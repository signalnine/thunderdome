@@ -0,0 +1,111 @@
+import * as fs from "node:fs";
+import * as path from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string;
+  stop: string | null;
+}
+
+interface TrackerData {
+  entries: TimeEntry[];
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(filePath: string) {
+    this.filePath = path.resolve(filePath);
+    this.entries = [];
+    this.load();
+  }
+
+  private load(): void {
+    try {
+      const data = fs.readFileSync(this.filePath, "utf-8");
+      const parsed: TrackerData = JSON.parse(data);
+      this.entries = parsed.entries;
+    } catch {
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    const data: TrackerData = { entries: this.entries };
+    fs.writeFileSync(this.filePath, JSON.stringify(data, null, 2), "utf-8");
+  }
+
+  start(task: string): void {
+    if (!task || task.trim() === "") {
+      throw new Error("Task name cannot be empty");
+    }
+
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    this.entries.push({
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    });
+
+    this.save();
+  }
+
+  stop(): void {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+  }
+
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    return this.entries.filter((entry) => {
+      const start = new Date(entry.start);
+      if (from && start < from) return false;
+      if (to && start > to) return false;
+      return true;
+    });
+  }
+
+  getSummary(from?: Date, to?: Date): Record<string, number> {
+    const entries = this.getEntries(from, to);
+    const summary: Record<string, number> = {};
+
+    for (const entry of entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  isRunning(): boolean {
+    return this.getRunningEntry() !== null;
+  }
+
+  private getRunningEntry(): TimeEntry | null {
+    for (let i = this.entries.length - 1; i >= 0; i--) {
+      if (this.entries[i].stop === null) {
+        return this.entries[i];
+      }
+    }
+    return null;
+  }
+}
