+
+  it('should reject non-objects', () => {
+    expect(validateOperation('string')).toBe(false);
+    expect(validateOperation(42)).toBe(false);
+  });
+
+  it('should reject insert with empty text', () => {
+    expect(validateOperation({ type: 'insert', position: 0, text: '' })).toBe(false);
