;\n  const server: Server = createServer(app);\n\n  // Middleware\n  app.use(express.json());\n\n  // REST routes\n  const router = createRouter(store);\n  app.use('/api', router);\n\n  // WebSocket server - handle upgrade manually to support path routing\n  const wss = new WebSocketServer({ noServer: true });\n  const collaboration = new CollaborationManager(store);\n  collaboration.setupWebSocket(wss);\n\n  server.on('upgrade', (request, socket, head) => {\n    const url = request.url ?? '';\n    // Accept WebSocket connections on paths like /documents/:id/ws or /ws/documents/:id\n    if (url.match(/\\/(?:ws\\/)?documents\\/[^/]+(?:\\/ws)?/)) {\n      wss.handleUpgrade(request, socket, head, (ws) => {\n        wss.emit('connection', ws, request);\n      });\n    } else {\n      socket.destroy();\n    }\n  });\n\n  let started = false;\n\n  return {\n    app,\n\n    async start(port?: number): Promise<number> {\n      if (started) {\n        const addr = server.address();\n        if (addr && typeof addr === 'object') {\n          return addr.port;\n        }\n        return port ?? 0;\n      }\n\n      return new Promise((resolve, reject) => {\n        server.listen(port ?? 0, () => {\n          started = true;\n          const addr = server.address();\n          if (addr && typeof addr === 'object') {\n            resolve(addr.port);\n          } else {\n            reject(new Error('Failed to get server address'));\n          }\n        });\n        server.on('error', reject);\n      });\n    },\n\n    async stop(): Promise<void> {\n      collaboration.shutdown();\n\n      return new Promise((resolve, reject) => {\n        server.close((err) => {\n          store.close();\n          if (err) {\n            reject(err);\n          } else {\n            started = false;\n            resolve();\n          }\n        });\n      });\n    },\n  };\n}\n","numLines":89,"startLine":1,"totalLines":89}}}
