+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_014XDTCGEUWftXwKzvBu5N1T","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013AstbE7iSN4LwVHgXXwJPK","name":"Write","input":{"file_path":"/workspace/tests/collaboration.test.ts","content":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport request from 'supertest';\nimport WebSocket from 'ws';\nimport { createApp, AppInstance } from '../src/server.js';\n\n/**\n * A WebSocket client wrapper that queues all incoming messages,\n * allowing them to be consumed asynchronously without race conditions.\n * Messages are buffered from the moment the socket opens.\n */\nclass TestClient {\n  ws: WebSocket;\n  private messageQueue: Record<string, unknown>[] = [];\n  private waiters: ((msg: Record<string, unknown>) => void)[] = [];\n  private openPromise: Promise<void>;\n\n  constructor(url: string) {\n    this.ws = new WebSocket(url);\n\n    // Set up message queueing BEFORE connection opens to avoid missing early messages\n    this.ws.on('message', (data) => {\n      const msg = JSON.parse(data.toString());\n      if (this.waiters.length > 0) {\n        const waiter = this.waiters.shift()!;\n        waiter(msg);\n      } else {\n        this.messageQueue.push(msg);\n      }\n    });\n\n    this.openPromise = new Promise((resolve, reject) => {\n      this.ws.on('open', () => resolve());\n      this.ws.on('error', reject);\n    });\n  }\n\n  async waitOpen(): Promise<void> {\n    await this.openPromise;\n  }\n\n  nextMessage(timeout = 5000): Promise<Record<string, unknown>> {\n    if (this.messageQueue.length > 0) {\n      return Promise.resolve(this.messageQueue.shift()!);\n    }\n\n    return new Promise((resolve, reject) => {\n      const timer = setTimeout(() => {\n        const idx = this.waiters.indexOf(waiter);\n        if (idx >= 0) this.waiters.splice(idx, 1);\n        reject(new Error('Timeout waiting for message'));\n      }, timeout);\n\n      const waiter = (msg: Record<string, unknown>) => {\n        clearTimeout(timer);\n        resolve(msg);\n      };\n      this.waiters.push(waiter);\n    });\n  }\n\n  async nextMessageOfType(type: string, timeout = 5000): Promise<Record<string, unknown>> {\n    const deadline = Date.now() + timeout;\n    while (true) {\n      const remaining = deadline - Date.now();\n      if (remaining <= 0) {\n        throw new Error(`Timeout waiting for message of type \"${type}\"`);\n      }\n      const msg = await this.nextMessage(remaining);\n      if (msg.type === type) return msg;\n    }\n  }\n\n  send(msg: Record<string, unknown>): void {\n    this.ws.send(JSON.stringify(msg));\n  }\n\n  close(): void {\n    if (this.ws.readyState === WebSocket.OPEN || this.ws.readyState === WebSocket.CONNECTING) {\n      this.ws.close();\n    }\n  }\n}\n\ndescribe('WebSocket Collaboration', () => {\n  let instance: AppInstance;\n  let port: number;\n  const clients: TestClient[] = [];\n\n  beforeEach(async () => {\n    instance = createApp(':memory:');\n    port = await instance.start(0);\n  });\n\n  afterEach(async () => {\n    for (const c of clients) {\n      c.close();\n    }\n    clients.length = 0;\n    await instance.stop();\n  });\n\n  async function createDoc(title: string, content: string = ''): Promise<string> {\n    const res = await request(instance.app)\n      .post('/api/documents')\n      .send({ title, content });\n    return res.body.id;\n  }\n\n  async function connect(docId: string): Promise<TestClient> {\n    const client = new TestClient(`ws://localhost:${port}/documents/${docId}/ws`);\n    clients.push(client);\n    await client.waitOpen();\n    return client;\n  }\n\n  it('should send sync message on connection', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const client = await connect(docId);\n    const msg = await client.nextMessage();\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe(0);\n    expect(msg.clientId).toBeDefined();\n  });\n\n  it('should send error for non-existent document', async () => {\n    const client = new TestClient(`ws://localhost:${port}/documents/nonexistent/ws`);\n    clients.push(client);\n\n    const msg = await client.nextMessage();\n    expect(msg.type).toBe('error');\n  });\n\n  it('should apply an insert operation and ack', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const client = await connect(docId);\n    const sync = await client.nextMessage();\n\n    client.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, text: ' world' },\n      version: sync.version,\n    });\n\n    const ack = await client.nextMessage();\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(1);\n\n    const res = await request(instance.app).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('hello world');\n  });\n\n  it('should apply a delete operation', async () => {\n    const docId = await createDoc('Test', 'hello world');\n    const client = await connect(docId);\n    await client.nextMessage(); // sync\n\n    client.send({\n      type: 'operation',\n      operation: { type: 'delete', position: 5, length: 6 },\n      version: 0,\n    });\n\n    const ack = await client.nextMessage();\n    expect(ack.type).toBe('ack');\n\n    const res = await request(instance.app).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('hello');\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const client1 = await connect(docId);\n    await client1.nextMessage(); // sync\n\n    const client2 = await connect(docId);\n    await client2.nextMessage(); // sync\n\n    client1.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, text: ' world' },\n      version: 0,\n    });\n\n    // Client 1 gets ack\n    const ack = await client1.nextMessage();\n    expect(ack.type).toBe('ack');\n\n    // Client 2 receives broadcast\n    const broadcast = await client2.nextMessage();\n    expect(broadcast.type).toBe('operation');\n    expect((broadcast.operation as { type: string }).type).toBe('insert');\n    expect(broadcast.version).toBe(1);\n  });\n\n  it('should handle concurrent edits from two clients with OT', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const client1 = await connect(docId);\n    const sync1 = await client1.nextMessage();\n\n    const client2 = await connect(docId);\n    await client2.nextMessage(); // sync\n\n    // Client 1 inserts \" world\" at position 5\n    client1.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, text: ' world' },\n      version: sync1.version,\n    });\n\n    const ack1 = await client1.nextMessageOfType('ack');\n    expect(ack1.version).toBe(1);\n\n    // Client 2 receives broadcast\n    await client2.nextMessageOfType('operation');\n\n    // Client 2 inserts \"Oh, \" at position 0, based on version 0\n    client2.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 0, text: 'Oh, ' },\n      version: 0,\n    });\n\n    const ack2 = await client2.nextMessageOfType('ack');\n    expect(ack2.version).toBe(2);\n\n    const res = await request(instance.app).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('Oh, hello world');\n  });\n\n  it('should reject invalid operations', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const client = await connect(docId);\n    await client.nextMessage(); // sync\n\n    client.send({\n      type: 'operation',\n      operation: { type: 'insert', position: -1, text: 'bad' },\n      version: 0,\n    });\n\n    const err = await client.nextMessage();\n    expect(err.type).toBe('error');\n  });\n\n  it('should reject operations with invalid version', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const client = await connect(docId);\n    await client.nextMessage(); // sync\n\n    client.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 0, text: 'hi' },\n      version: 99,\n    });\n\n    const err = await client.nextMessage();\n    expect(err.type).toBe('error');\n  });\n\n  it('should handle malformed JSON gracefully', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const client = await connect(docId);\n    await client.nextMessage(); // sync\n\n    client.ws.send('not json at all');\n\n    const err = await client.nextMessage();\n    expect(err.type).toBe('error');\n  });\n\n  it('should persist document across server restarts', async () => {\n    const tmpPath = `/tmp/test-collab-${Date.now()}.db`;\n\n    const inst1 = createApp(tmpPath);\n    const port1 = await inst1.start(0);\n\n    const res1 = await request(inst1.app)\n      .post('/api/documents')\n      .send({ title: 'Persistent', content: 'initial' });\n    const docId = res1.body.id;\n\n    // Connect and make an edit\n    const client = new TestClient(`ws://localhost:${port1}/documents/${docId}/ws`);\n    await client.waitOpen();\n    await client.nextMessage(); // sync\n\n    client.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 7, text: ' state' },\n      version: 0,\n    });\n    await client.nextMessageOfType('ack');\n\n    client.close();\n    // Wait for close to propagate\n    await new Promise((r) => setTimeout(r, 100));\n    await inst1.stop();\n\n    // Restart with same DB\n    const inst2 = createApp(tmpPath);\n    await inst2.start(0);\n\n    const res2 = await request(inst2.app).get(`/api/documents/${docId}`);\n    expect(res2.body.content).toBe('initial state');\n    expect(res2.body.title).toBe('Persistent');\n\n    await inst2.stop();\n  });\n\n  it('should store version history through WebSocket edits', async () => {\n    const docId = await createDoc('Test', 'abc');\n    const client = await connect(docId);\n    await client.nextMessage(); // sync\n\n    client.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 3, text: 'd' },\n      version: 0,\n    });\n    await client.nextMessageOfType('ack');\n\n    client.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 4, text: 'e' },\n      version: 1,\n    });\n    await client.nextMessageOfType('ack');\n\n    client.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, text: 'f' },\n      version: 2,\n    });\n    await client.nextMessageOfType('ack');\n\n    const res = await request(instance.app)\n      .get(`/api/documents/${docId}/versions`);\n    expect(res.body.length).toBe(4);\n    expect(res.body[0].version).toBe(0);\n    expect(res.body[0].content).toBe('abc');\n    expect(res.body[3].version).toBe(3);\n    expect(res.body[3].content).toBe('abcdef');\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const docId = await createDoc('Test', '');\n    const testClients: TestClient[] = [];\n\n    for (let i = 0; i < 10; i++) {\n      const client = await connect(docId);\n      await client.nextMessage(); // sync\n      testClients.push(client);\n    }\n\n    for (let i = 0; i < 10; i++) {\n      const client = testClients[i];\n\n      const versionsRes = await request(instance.app)\n        .get(`/api/documents/${docId}/versions`);\n      const currentVersion = versionsRes.body[versionsRes.body.length - 1].version;\n\n      client.send({\n        type: 'operation',\n        operation: { type: 'insert', position: 0, text: String(i) },\n        version: currentVersion,\n      });\n\n      await client.nextMessageOfType('ack');\n\n      // Drain broadcasts from other clients\n      for (let j = 0; j < 10; j++) {\n        if (j !== i) {\n          await testClients[j].nextMessageOfType('operation');\n        }\n      }\n    }\n\n    const res = await request(instance.app).get(`/api/documents/${docId}`);\n    expect(res.body.content.length).toBe(10);\n    for (let i = 0; i < 10; i++) {\n      expect(res.body.content).toContain(String(i));\n    }\n  });\n\n  it('should handle concurrent operations from multiple clients using OT', async () => {\n    const docId = await createDoc('Test', 'ABCDE');\n\n    const client1 = await connect(docId);\n    const sync1 = await client1.nextMessage();\n    expect(sync1.content).toBe('ABCDE');\n\n    const client2 = await connect(docId);\n    const sync2 = await client2.nextMessage();\n    expect(sync2.content).toBe('ABCDE');\n\n    // Client 1: insert 'X' at position 2\n    client1.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 2, text: 'X' },\n      version: 0,\n    });\n\n    const ack1 = await client1.nextMessageOfType('ack');\n    expect(ack1.version).toBe(1);\n\n    // Client 2: insert 'Y' at position 4, version 0\n    // After OT transform against insert at pos 2: position becomes 5\n    client2.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 4, text: 'Y' },\n      version: 0,\n    });\n\n    const ack2 = await client2.nextMessageOfType('ack');\n    expect(ack2.version).toBe(2);\n\n    const res = await request(instance.app).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('ABXCDYE');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5568,"cache_read_input_tokens":64824,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5568},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ba7df0fd-2045-4133-bb4c-31b7b7df73af","uuid":"a0c4be20-cbfe-4591-bf04-3a552cc7b8e5"}
