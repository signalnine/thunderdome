+import { describe, it, expect } from 'vitest';
+import {
+  applyOperation,
+  transformOperation,
+  transformOperationAgainstMany,
+  validateOperation,
+  Operation,
+} from '../src/ot.js';
+
+describe('applyOperation', () => {
+  it('should insert text at the beginning', () => {
+    expect(applyOperation('hello', { type: 'insert', position: 0, text: 'say ' })).toBe('say hello');
+  });
+
+  it('should insert text at the end', () => {
+    expect(applyOperation('hello', { type: 'insert', position: 5, text: ' world' })).toBe('hello world');
+  });
+
+  it('should insert text in the middle', () => {
+    expect(applyOperation('hllo', { type: 'insert', position: 1, text: 'e' })).toBe('hello');
+  });
+
+  it('should delete text from the beginning', () => {
+    expect(applyOperation('hello', { type: 'delete', position: 0, length: 2 })).toBe('llo');
+  });
+
+  it('should delete text from the end', () => {
+    expect(applyOperation('hello', { type: 'delete', position: 3, length: 2 })).toBe('hel');
+  });
+
+  it('should delete text from the middle', () => {
+    expect(applyOperation('hello', { type: 'delete', position: 1, length: 3 })).toBe('ho');
+  });
+
+  it('should throw for out-of-bounds insert', () => {
+    expect(() => applyOperation('hi', { type: 'insert', position: 5, text: 'x' })).toThrow();
+  });
+
+  it('should throw for out-of-bounds delete', () => {
+    expect(() => applyOperation('hi', { type: 'delete', position: 1, length: 5 })).toThrow();
+  });
+
+  it('should handle empty document insert', () => {
+    expect(applyOperation('', { type: 'insert', position: 0, text: 'a' })).toBe('a');
+  });
+});
+
+describe('transformOperation', () => {
+  describe('insert vs insert', () => {
+    it('should shift right when insert is after another insert', () => {
+      const op: Operation = { type: 'insert', position: 5, text: 'a' };
+      const against: Operation = { type: 'insert', position: 3, text: 'bb' };
+      const result = transformOperation(op, against);
+      expect(result).toEqual({ type: 'insert', position: 7, text: 'a' });
+    });
+
+    it('should not shift when insert is before another insert', () => {
+      const op: Operation = { type: 'insert', position: 2, text: 'a' };
+      const against: Operation = { type: 'insert', position: 5, text: 'bb' };
+      const result = transformOperation(op, against);
+      expect(result).toEqual({ type: 'insert', position: 2, text: 'a' });
+    });
+
+    it('should shift right at same position (server wins)', () => {
+      const op: Operation = { type: 'insert', position: 3, text: 'a' };
+      const against: Operation = { type: 'insert', position: 3, text: 'b' };
+      const result = transformOperation(op, against);
+      expect(result).toEqual({ type: 'insert', position: 4, text: 'a' });
+    });
+  });
+
+  describe('insert vs delete', () => {
+    it('should not shift when insert is before delete', () => {
+      const op: Operation = { type: 'insert', position: 2, text: 'a' };
+      const against: Operation = { type: 'delete', position: 5, length: 3 };
+      const result = transformOperation(op, against);
+      expect(result).toEqual({ type: 'insert', position: 2, text: 'a' });
+    });
+
+    it('should shift left when insert is after delete', () => {
+      const op: Operation = { type: 'insert', position: 8, text: 'a' };
+      const against: Operation = { type: 'delete', position: 3, length: 3 };
+      const result = transformOperation(op, against);
+      expect(result).toEqual({ type: 'insert', position: 5, text: 'a' });
+    });
+
+    it('should move to delete position when insert is inside deleted region', () => {
+      const op: Operation = { type: 'insert', position: 5, text: 'a' };
+      const against: Operation = { type: 'delete', position: 3, length: 5 };
+      const result = transformOperation(op, against);
+      // Insert is preserved at the delete boundary
+      expect(result).toEqual({ type: 'insert', position: 3, text: 'a' });
+    });
+  });
+
+  describe('delete vs insert', () => {
+    it('should shift right when delete is after insert', () => {
+      const op: Operation = { type: 'delete', position: 5, length: 3 };
+      const against: Operation = { type: 'insert', position: 3, text: 'ab' };
+      const result = transformOperation(op, against);
+      expect(result).toEqual({ type: 'delete', position: 7, length: 3 });
+    });
+
+    it('should not shift when delete is before insert', () => {
+      const op: Operation = { type: 'delete', position: 2, length: 2 };
+      const against: Operation = { type: 'insert', position: 8, text: 'ab' };
+      const result = transformOperation(op, against);
+      expect(result).toEqual({ type: 'delete', position: 2, length: 2 });
+    });
+  });
+
+  describe('delete vs delete', () => {
+    it('should shift left when delete is after another delete', () => {
+      const op: Operation = { type: 'delete', position: 8, length: 2 };
+      const against: Operation = { type: 'delete', position: 3, length: 3 };
+      const result = transformOperation(op, against);
+      expect(result).toEqual({ type: 'delete', position: 5, length: 2 });
+    });
+
+    it('should not shift when delete is before another delete', () => {
+      const op: Operation = { type: 'delete', position: 2, length: 2 };
+      const against: Operation = { type: 'delete', position: 8, length: 3 };
+      const result = transformOperation(op, against);
+      expect(result).toEqual({ type: 'delete', position: 2, length: 2 });
+    });
+
+    it('should become no-op when completely overlapping', () => {
+      const op: Operation = { type: 'delete', position: 3, length: 3 };
+      const against: Operation = { type: 'delete', position: 3, length: 3 };
+      const result = transformOperation(op, against);
+      expect(result.type).toBe('delete');
+      expect((result as { length: number }).length).toBe(0);
+    });
+  });
+
+  describe('convergence', () => {
+    it('two concurrent inserts at different positions should converge', () => {
+      const doc = 'hello world';
+      const op1: Operation = { type: 'insert', position: 5, text: ' beautiful' };
+      const op2: Operation = { type: 'insert', position: 0, text: 'Oh, ' };
+
+      // Apply op1 first, then transform and apply op2
+      const doc1 = applyOperation(doc, op1);
+      const op2Transformed = transformOperation(op2, op1);
+      const result1 = applyOperation(doc1, op2Transformed);
+
+      // Apply op2 first, then transform and apply op1
+      const doc2 = applyOperation(doc, op2);
+      const op1Transformed = transformOperation(op1, op2);
+      const result2 = applyOperation(doc2, op1Transformed);
+
+      expect(result1).toBe(result2);
+    });
+
+    it('concurrent insert and delete should produce correct server-side result', () => {
+      // In a centralized server architecture, ops are applied sequentially.
+      // The server applies op1, then transforms op2 against op1 before applying.
+      const doc = 'hello world';
+
+      // Scenario: op1 applied first (insert), op2 transformed against it (delete)
+      const op1: Operation = { type: 'insert', position: 5, text: ' dear' };
+      const op2: Operation = { type: 'delete', position: 0, length: 6 };
+
+      const afterOp1 = applyOperation(doc, op1);
+      expect(afterOp1).toBe('hello dear world');
+
+      const op2t = transformOperation(op2, op1);
+      // Delete expands to include inserted text since it spans the insert point
+      expect(op2t).toEqual({ type: 'delete', position: 0, length: 11 });
+
+      const result = applyOperation(afterOp1, op2t);
+      expect(result).toBe('world');
+    });
+
+    it('concurrent delete and insert should preserve insert when delete is applied first', () => {
+      const doc = 'hello world';
+
+      // Scenario: op1 applied first (delete), op2 transformed against it (insert)
+      const op1: Operation = { type: 'delete', position: 0, length: 6 };
+      const op2: Operation = { type: 'insert', position: 5, text: 'X' };
+
+      const afterOp1 = applyOperation(doc, op1);
+      expect(afterOp1).toBe('world');
+
+      const op2t = transformOperation(op2, op1);
+      // Insert inside deleted region: relocated to delete boundary
+      expect(op2t).toEqual({ type: 'insert', position: 0, text: 'X' });
+
+      const result = applyOperation(afterOp1, op2t);
+      expect(result).toBe('Xworld');
+    });
+  });
+});
