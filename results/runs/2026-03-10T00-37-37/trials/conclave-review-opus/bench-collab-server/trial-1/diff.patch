+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UjZYrt9ToaVd9uz4QsWTZq","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n     2→import request from 'supertest';\n     3→import WebSocket from 'ws';\n     4→import { createApp, AppInstance } from '../src/server.js';\n     5→\n     6→/**\n     7→ * A WebSocket client wrapper that queues all incoming messages,\n     8→ * allowing them to be consumed asynchronously without race conditions.\n     9→ * Messages are buffered from the moment the socket opens.\n    10→ */\n    11→class TestClient {\n    12→  ws: WebSocket;\n    13→  private messageQueue: Record<string, unknown>[] = [];\n    14→  private waiters: ((msg: Record<string, unknown>) => void)[] = [];\n    15→  private openPromise: Promise<void>;\n    16→\n    17→  constructor(url: string) {\n    18→    this.ws = new WebSocket(url);\n    19→\n    20→    // Set up message queueing BEFORE connection opens to avoid missing early messages\n    21→    this.ws.on('message', (data) => {\n    22→      const msg = JSON.parse(data.toString());\n    23→      if (this.waiters.length > 0) {\n    24→        const waiter = this.waiters.shift()!;\n    25→        waiter(msg);\n    26→      } else {\n    27→        this.messageQueue.push(msg);\n    28→      }\n    29→    });\n    30→\n    31→    this.openPromise = new Promise((resolve, reject) => {\n    32→      this.ws.on('open', () => resolve());\n    33→      this.ws.on('error', reject);\n    34→    });\n    35→  }\n    36→\n    37→  async waitOpen(): Promise<void> {\n    38→    await this.openPromise;\n    39→  }\n    40→\n    41→  nextMessage(timeout = 5000): Promise<Record<string, unknown>> {\n    42→    if (this.messageQueue.length > 0) {\n    43→      return Promise.resolve(this.messageQueue.shift()!);\n    44→    }\n    45→\n    46→    return new Promise((resolve, reject) => {\n    47→      const timer = setTimeout(() => {\n    48→        const idx = this.waiters.indexOf(waiter);\n    49→        if (idx >= 0) this.waiters.splice(idx, 1);\n    50→        reject(new Error('Timeout waiting for message'));\n    51→      }, timeout);\n    52→\n    53→      const waiter = (msg: Record<string, unknown>) => {\n    54→        clearTimeout(timer);\n    55→        resolve(msg);\n    56→      };\n    57→      this.waiters.push(waiter);\n    58→    });\n    59→  }\n    60→\n    61→  async nextMessageOfType(type: string, timeout = 5000): Promise<Record<string, unknown>> {\n    62→    const deadline = Date.now() + timeout;\n    63→    while (true) {\n    64→      const remaining = deadline - Date.now();\n    65→      if (remaining <= 0) {\n    66→        throw new Error(`Timeout waiting for message of type \"${type}\"`);\n    67→      }\n    68→      const msg = await this.nextMessage(remaining);\n    69→      if (msg.type === type) return msg;\n    70→    }\n    71→  }\n    72→\n    73→  send(msg: Record<string, unknown>): void {\n    74→    this.ws.send(JSON.stringify(msg));\n    75→  }\n    76→\n    77→  close(): void {\n    78→    if (this.ws.readyState === WebSocket.OPEN || this.ws.readyState === WebSocket.CONNECTING) {\n    79→      this.ws.close();\n    80→    }\n    81→  }\n    82→}\n    83→\n    84→describe('WebSocket Collaboration', () => {\n    85→  let instance: AppInstance;\n    86→  let port: number;\n    87→  const clients: TestClient[] = [];\n    88→\n    89→  beforeEach(async () => {\n    90→    instance = createApp(':memory:');\n    91→    port = await instance.start(0);\n    92→  });\n    93→\n    94→  afterEach(async () => {\n    95→    for (const c of clients) {\n    96→      c.close();\n    97→    }\n    98→    clients.length = 0;\n    99→    await instance.stop();\n   100→  });\n   101→\n   102→  async function createDoc(title: string, content: string = ''): Promise<string> {\n   103→    const res = await request(instance.app)\n   104→      .post('/api/documents')\n   105→      .send({ title, content });\n   106→    return res.body.id;\n   107→  }\n   108→\n   109→  async function connect(docId: string): Promise<TestClient> {\n   110→    const client = new TestClient(`ws://localhost:${port}/documents/${docId}/ws`);\n   111→    clients.push(client);\n   112→    await client.waitOpen();\n   113→    return client;\n   114→  }\n   115→\n   116→  it('should send sync message on connection', async () => {\n   117→    const docId = await createDoc('Test', 'hello');\n   118→    const client = await connect(docId);\n   119→    const msg = await client.nextMessage();\n   120→\n   121→    expect(msg.type).toBe('sync');\n   122→    expect(msg.content).toBe('hello');\n   123→    expect(msg.version).toBe(0);\n   124→    expect(msg.clientId).toBeDefined();\n   125→  });\n   126→\n   127→  it('should send error for non-existent document', async () => {\n   128→    const client = new TestClient(`ws://localhost:${port}/documents/nonexistent/ws`);\n   129→    clients.push(client);\n   130→\n   131→    const msg = await client.nextMessage();\n   132→    expect(msg.type).toBe('error');\n   133→  });\n   134→\n   135→  it('should apply an insert operation and ack', async () => {\n   136→    const docId = await createDoc('Test', 'hello');\n   137→    const client = await connect(docId);\n   138→    const sync = await client.nextMessage();\n   139→\n   140→    client.send({\n   141→      type: 'operation',\n   142→      operation: { type: 'insert', position: 5, text: ' world' },\n   143→      version: sync.version,\n   144→    });\n   145→\n   146→    const ack = await client.nextMessage();\n   147→    expect(ack.type).toBe('ack');\n   148→    expect(ack.version).toBe(1);\n   149→\n   150→    const res = await request(instance.app).get(`/api/documents/${docId}`);\n   151→    expect(res.body.content).toBe('hello world');\n   152→  });\n   153→\n   154→  it('should apply a delete operation', async () => {\n   155→    const docId = await createDoc('Test', 'hello world');\n   156→    const client = await connect(docId);\n   157→    await client.nextMessage(); // sync\n   158→\n   159→    client.send({\n   160→      type: 'operation',\n   161→      operation: { type: 'delete', position: 5, length: 6 },\n   162→      version: 0,\n   163→    });\n   164→\n   165→    const ack = await client.nextMessage();\n   166→    expect(ack.type).toBe('ack');\n   167→\n   168→    const res = await request(instance.app).get(`/api/documents/${docId}`);\n   169→    expect(res.body.content).toBe('hello');\n   170→  });\n   171→\n   172→  it('should broadcast operations to other clients', async () => {\n   173→    const docId = await createDoc('Test', 'hello');\n   174→    const client1 = await connect(docId);\n   175→    await client1.nextMessage(); // sync\n   176→\n   177→    const client2 = await connect(docId);\n   178→    await client2.nextMessage(); // sync\n   179→\n   180→    client1.send({\n   181→      type: 'operation',\n   182→      operation: { type: 'insert', position: 5, text: ' world' },\n   183→      version: 0,\n   184→    });\n   185→\n   186→    // Client 1 gets ack\n   187→    const ack = await client1.nextMessage();\n   188→    expect(ack.type).toBe('ack');\n   189→\n   190→    // Client 2 receives broadcast\n   191→    const broadcast = await client2.nextMessage();\n   192→    expect(broadcast.type).toBe('operation');\n   193→    expect((broadcast.operation as { type: string }).type).toBe('insert');\n   194→    expect(broadcast.version).toBe(1);\n   195→  });\n   196→\n   197→  it('should handle concurrent edits from two clients with OT', async () => {\n   198→    const docId = await createDoc('Test', 'hello');\n   199→    const client1 = await connect(docId);\n   200→    const sync1 = await client1.nextMessage();\n   201→\n   202→    const client2 = await connect(docId);\n   203→    await client2.nextMessage(); // sync\n   204→\n   205→    // Client 1 inserts \" world\" at position 5\n   206→    client1.send({\n   207→      type: 'operation',\n   208→      operation: { type: 'insert', position: 5, text: ' world' },\n   209→      version: sync1.version,\n   210→    });\n   211→\n   212→    const ack1 = await client1.nextMessageOfType('ack');\n   213→    expect(ack1.version).toBe(1);\n   214→\n   215→    // Client 2 receives broadcast\n   216→    await client2.nextMessageOfType('operation');\n   217→\n   218→    // Client 2 inserts \"Oh, \" at position 0, based on version 0\n   219→    client2.send({\n   220→      type: 'operation',\n   221→      operation: { type: 'insert', position: 0, text: 'Oh, ' },\n   222→      version: 0,\n   223→    });\n   224→\n   225→    const ack2 = await client2.nextMessageOfType('ack');\n   226→    expect(ack2.version).toBe(2);\n   227→\n   228→    const res = await request(instance.app).get(`/api/documents/${docId}`);\n   229→    expect(res.body.content).toBe('Oh, hello world');\n   230→  });\n   231→\n   232→  it('should reject invalid operations', async () => {\n   233→    const docId = await createDoc('Test', 'hello');\n   234→    const client = await connect(docId);\n   235→    await client.nextMessage(); // sync\n   236→\n   237→    client.send({\n   238→      type: 'operation',\n   239→      operation: { type: 'insert', position: -1, text: 'bad' },\n   240→      version: 0,\n   241→    });\n   242→\n   243→    const err = await client.nextMessage();\n   244→    expect(err.type).toBe('error');\n   245→  });\n   246→\n   247→  it('should reject operations with invalid version', async () => {\n   248→    const docId = await createDoc('Test', 'hello');\n   249→    const client = await connect(docId);\n   250→    await client.nextMessage(); // sync\n   251→\n   252→    client.send({\n   253→      type: 'operation',\n   254→      operation: { type: 'insert', position: 0, text: 'hi' },\n   255→      version: 99,\n   256→    });\n   257→\n   258→    const err = await client.nextMessage();\n   259→    expect(err.type).toBe('error');\n   260→  });\n   261→\n   262→  it('should handle malformed JSON gracefully', async () => {\n   263→    const docId = await createDoc('Test', 'hello');\n   264→    const client = await connect(docId);\n   265→    await client.nextMessage(); // sync\n   266→\n   267→    client.ws.send('not json at all');\n   268→\n   269→    const err = await client.nextMessage();\n   270→    expect(err.type).toBe('error');\n   271→  });\n   272→\n   273→  it('should persist document across server restarts', async () => {\n   274→    const tmpPath = `/tmp/test-collab-${Date.now()}.db`;\n   275→\n   276→    const inst1 = createApp(tmpPath);\n   277→    const port1 = await inst1.start(0);\n   278→\n   279→    const res1 = await request(inst1.app)\n   280→      .post('/api/documents')\n   281→      .send({ title: 'Persistent', content: 'initial' });\n   282→    const docId = res1.body.id;\n   283→\n   284→    // Connect and make an edit\n   285→    const client = new TestClient(`ws://localhost:${port1}/documents/${docId}/ws`);\n   286→    await client.waitOpen();\n   287→    await client.nextMessage(); // sync\n   288→\n   289→    client.send({\n   290→      type: 'operation',\n   291→      operation: { type: 'insert', position: 7, text: ' state' },\n   292→      version: 0,\n   293→    });\n   294→    await client.nextMessageOfType('ack');\n   295→\n   296→    client.close();\n   297→    // Wait for close to propagate\n   298→    await new Promise((r) => setTimeout(r, 100));\n   299→    await inst1.stop();\n   300→\n   301→    // Restart with same DB\n   302→    const inst2 = createApp(tmpPath);\n   303→    await inst2.start(0);\n   304→\n   305→    const res2 = await request(inst2.app).get(`/api/documents/${docId}`);\n   306→    expect(res2.body.content).toBe('initial state');\n   307→    expect(res2.body.title).toBe('Persistent');\n   308→\n   309→    await inst2.stop();\n   310→  });\n   311→\n   312→  it('should store version history through WebSocket edits', async () => {\n   313→    const docId = await createDoc('Test', 'abc');\n   314→    const client = await connect(docId);\n   315→    await client.nextMessage(); // sync\n   316→\n   317→    client.send({\n   318→      type: 'operation',\n   319→      operation: { type: 'insert', position: 3, text: 'd' },\n   320→      version: 0,\n   321→    });\n   322→    await client.nextMessageOfType('ack');\n   323→\n   324→    client.send({\n   325→      type: 'operation',\n   326→      operation: { type: 'insert', position: 4, text: 'e' },\n   327→      version: 1,\n   328→    });\n   329→    await client.nextMessageOfType('ack');\n   330→\n   331→    client.send({\n   332→      type: 'operation',\n   333→      operation: { type: 'insert', position: 5, text: 'f' },\n   334→      version: 2,\n   335→    });\n   336→    await client.nextMessageOfType('ack');\n   337→\n   338→    const res = await request(instance.app)\n   339→      .get(`/api/documents/${docId}/versions`);\n   340→    expect(res.body.length).toBe(4);\n   341→    expect(res.body[0].version).toBe(0);\n   342→    expect(res.body[0].content).toBe('abc');\n   343→    expect(res.body[3].version).toBe(3);\n   344→    expect(res.body[3].content).toBe('abcdef');\n   345→  });\n   346→\n   347→  it('should handle 10 concurrent clients', async () => {\n   348→    const docId = await createDoc('Test', '');\n   349→    const testClients: TestClient[] = [];\n   350→\n   351→    for (let i = 0; i < 10; i++) {\n   352→      const client = await connect(docId);\n   353→      await client.nextMessage(); // sync\n   354→      testClients.push(client);\n   355→    }\n   356→\n   357→    for (let i = 0; i < 10; i++) {\n   358→      const client = testClients[i];\n   359→\n   360→      const versionsRes = await request(instance.app)\n   361→        .get(`/api/documents/${docId}/versions`);\n   362→      const currentVersion = versionsRes.body[versionsRes.body.length - 1].version;\n   363→\n   364→      client.send({\n   365→        type: 'operation',\n   366→        operation: { type: 'insert', position: 0, text: String(i) },\n   367→        version: currentVersion,\n   368→      });\n   369→\n   370→      await client.nextMessageOfType('ack');\n   371→\n   372→      // Drain broadcasts from other clients\n   373→      for (let j = 0; j < 10; j++) {\n   374→        if (j !== i) {\n   375→          await testClients[j].nextMessageOfType('operation');\n   376→        }\n   377→      }\n   378→    }\n   379→\n   380→    const res = await request(instance.app).get(`/api/documents/${docId}`);\n   381→    expect(res.body.content.length).toBe(10);\n   382→    for (let i = 0; i < 10; i++) {\n   383→      expect(res.body.content).toContain(String(i));\n   384→    }\n   385→  });\n   386→\n   387→  it('should handle concurrent operations from multiple clients using OT', async () => {\n   388→    const docId = await createDoc('Test', 'ABCDE');\n   389→\n   390→    const client1 = await connect(docId);\n   391→    const sync1 = await client1.nextMessage();\n   392→    expect(sync1.content).toBe('ABCDE');\n   393→\n   394→    const client2 = await connect(docId);\n   395→    const sync2 = await client2.nextMessage();\n   396→    expect(sync2.content).toBe('ABCDE');\n   397→\n   398→    // Client 1: insert 'X' at position 2\n   399→    client1.send({\n   400→      type: 'operation',\n   401→      operation: { type: 'insert', position: 2, text: 'X' },\n   402→      version: 0,\n   403→    });\n   404→\n   405→    const ack1 = await client1.nextMessageOfType('ack');\n   406→    expect(ack1.version).toBe(1);\n   407→\n   408→    // Client 2: insert 'Y' at position 4, version 0\n   409→    // After OT transform against insert at pos 2: position becomes 5\n   410→    client2.send({\n   411→      type: 'operation',\n   412→      operation: { type: 'insert', position: 4, text: 'Y' },\n   413→      version: 0,\n   414→    });\n   415→\n   416→    const ack2 = await client2.nextMessageOfType('ack');\n   417→    expect(ack2.version).toBe(2);\n   418→\n   419→    const res = await request(instance.app).get(`/api/documents/${docId}`);\n   420→    expect(res.body.content).toBe('ABXCDYE');\n   421→  });\n   422→});\n   423→"}]},"parent_tool_use_id":"toolu_01UqorRftQ5nZ8pTNMnJXHRs","session_id":"ba7df0fd-2045-4133-bb4c-31b7b7df73af","uuid":"81da6e09-de0a-4d03-9f75-37d1bbdf2a84"}
