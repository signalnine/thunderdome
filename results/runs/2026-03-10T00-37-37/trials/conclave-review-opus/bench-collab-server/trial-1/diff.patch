+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013ep88gBTAE7icXWLrRyvku","type":"tool_result","content":"     1→import { WebSocket, WebSocketServer } from 'ws';\n     2→import { IncomingMessage } from 'http';\n     3→import { randomUUID } from 'crypto';\n     4→import { DocumentStore } from './db.js';\n     5→import {\n     6→  Operation,\n     7→  applyOperation,\n     8→  transformOperation,\n     9→  validateOperation,\n    10→} from './ot.js';\n    11→\n    12→interface ClientConnection {\n    13→  id: string;\n    14→  ws: WebSocket;\n    15→  documentId: string;\n    16→}\n    17→\n    18→interface DocumentSession {\n    19→  documentId: string;\n    20→  content: string;\n    21→  version: number;\n    22→  clients: Map<string, ClientConnection>;\n    23→  // History of operations applied since version 0, indexed by version\n    24→  operationLog: Operation[];\n    25→}\n    26→\n    27→// Incoming messages from clients\n    28→interface OperationMessage {\n    29→  type: 'operation';\n    30→  operation: Operation;\n    31→  version: number; // client's base version\n    32→}\n    33→\n    34→interface CursorMessage {\n    35→  type: 'cursor';\n    36→  position: number;\n    37→}\n    38→\n    39→type ClientMessage = OperationMessage | CursorMessage;\n    40→\n    41→// Outgoing messages to clients\n    42→interface SyncMessage {\n    43→  type: 'sync';\n    44→  content: string;\n    45→  version: number;\n    46→  clientId: string;\n    47→}\n    48→\n    49→interface OperationBroadcast {\n    50→  type: 'operation';\n    51→  operation: Operation;\n    52→  version: number;\n    53→  clientId: string;\n    54→}\n    55→\n    56→interface ErrorMessage {\n    57→  type: 'error';\n    58→  message: string;\n    59→}\n    60→\n    61→interface AckMessage {\n    62→  type: 'ack';\n    63→  version: number;\n    64→}\n    65→\n    66→type ServerMessage = SyncMessage | OperationBroadcast | ErrorMessage | AckMessage;\n    67→\n    68→export class CollaborationManager {\n    69→  private sessions: Map<string, DocumentSession> = new Map();\n    70→  private store: DocumentStore;\n    71→  private wss: WebSocketServer | null = null;\n    72→  private isShuttingDown = false;\n    73→\n    74→  constructor(store: DocumentStore) {\n    75→    this.store = store;\n    76→  }\n    77→\n    78→  setupWebSocket(wss: WebSocketServer): void {\n    79→    this.wss = wss;\n    80→    wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n    81→      this.handleConnection(ws, req);\n    82→    });\n    83→  }\n    84→\n    85→  private handleConnection(ws: WebSocket, req: IncomingMessage): void {\n    86→    // Extract document ID from URL path: /ws/documents/:id or /documents/:id/ws\n    87→    const url = req.url ?? '';\n    88→    const match = url.match(/\\/(?:ws\\/)?documents\\/([^/]+)(?:\\/ws)?/);\n    89→    if (!match) {\n    90→      this.sendMessage(ws, { type: 'error', message: 'Invalid WebSocket URL. Expected /documents/:id/ws' });\n    91→      ws.close(1008, 'Invalid URL');\n    92→      return;\n    93→    }\n    94→\n    95→    const documentId = match[1];\n    96→    const doc = this.store.getDocument(documentId);\n    97→    if (!doc) {\n    98→      this.sendMessage(ws, { type: 'error', message: 'Document not found' });\n    99→      ws.close(1008, 'Document not found');\n   100→      return;\n   101→    }\n   102→\n   103→    const clientId = randomUUID();\n   104→    const client: ClientConnection = { id: clientId, ws, documentId };\n   105→\n   106→    // Get or create session\n   107→    let session = this.sessions.get(documentId);\n   108→    if (!session) {\n   109→      session = {\n   110→        documentId,\n   111→        content: doc.content,\n   112→        version: this.getLatestVersion(documentId),\n   113→        clients: new Map(),\n   114→        operationLog: this.loadOperationLog(documentId),\n   115→      };\n   116→      this.sessions.set(documentId, session);\n   117→    }\n   118→\n   119→    session.clients.set(clientId, client);\n   120→\n   121→    // Send sync message with current document state\n   122→    const syncMsg: SyncMessage = {\n   123→      type: 'sync',\n   124→      content: session.content,\n   125→      version: session.version,\n   126→      clientId,\n   127→    };\n   128→    this.sendMessage(ws, syncMsg);\n   129→\n   130→    // Handle messages\n   131→    ws.on('message', (data) => {\n   132→      try {\n   133→        const msg = JSON.parse(data.toString()) as ClientMessage;\n   134→        this.handleMessage(client, session!, msg);\n   135→      } catch (err) {\n   136→        const errMsg = err instanceof Error ? err.message : 'Unknown error';\n   137→        this.sendMessage(ws, { type: 'error', message: `Invalid message: ${errMsg}` });\n   138→      }\n   139→    });\n   140→\n   141→    // Handle disconnect\n   142→    ws.on('close', () => {\n   143→      if (session && !this.isShuttingDown) {\n   144→        session.clients.delete(clientId);\n   145→        if (session.clients.size === 0) {\n   146→          // Persist final state and clean up session\n   147→          this.persistSession(session);\n   148→          this.sessions.delete(documentId);\n   149→        }\n   150→      }\n   151→    });\n   152→\n   153→    ws.on('error', () => {\n   154→      if (session) {\n   155→        session.clients.delete(clientId);\n   156→      }\n   157→    });\n   158→  }\n   159→\n   160→  private handleMessage(client: ClientConnection, session: DocumentSession, msg: ClientMessage): void {\n   161→    if (msg.type === 'operation') {\n   162→      this.handleOperation(client, session, msg);\n   163→    } else if (msg.type === 'cursor') {\n   164→      // Cursor updates: broadcast to other clients\n   165→      session.clients.forEach((c) => {\n   166→        if (c.id !== client.id && c.ws.readyState === WebSocket.OPEN) {\n   167→          this.sendMessage(c.ws, {\n   168→            type: 'cursor' as unknown as 'ack',\n   169→            position: msg.position,\n   170→            clientId: client.id,\n   171→          } as unknown as AckMessage);\n   172→        }\n   173→      });\n   174→    }\n   175→  }\n   176→\n   177→  private handleOperation(client: ClientConnection, session: DocumentSession, msg: OperationMessage): void {\n   178→    // Validate the operation\n   179→    if (!validateOperation(msg.operation)) {\n   180→      this.sendMessage(client.ws, {\n   181→        type: 'error',\n   182→        message: 'Invalid operation',\n   183→      });\n   184→      return;\n   185→    }\n   186→\n   187→    if (typeof msg.version !== 'number' || msg.version < 0) {\n   188→      this.sendMessage(client.ws, {\n   189→        type: 'error',\n   190→        message: 'Invalid version number',\n   191→      });\n   192→      return;\n   193→    }\n   194→\n   195→    if (msg.version > session.version) {\n   196→      this.sendMessage(client.ws, {\n   197→        type: 'error',\n   198→        message: `Version ${msg.version} is ahead of server version ${session.version}`,\n   199→      });\n   200→      return;\n   201→    }\n   202→\n   203→    // Transform the operation against all operations that happened since client's version\n   204→    let transformedOp = msg.operation;\n   205→    for (let i = msg.version; i < session.version; i++) {\n   206→      const concurrentOp = session.operationLog[i];\n   207→      if (concurrentOp) {\n   208→        transformedOp = transformOperation(transformedOp, concurrentOp);\n   209→      }\n   210→    }\n   211→\n   212→    // Skip no-op operations after transform\n   213→    const isNoop =\n   214→      (transformedOp.type === 'delete' && transformedOp.length <= 0) ||\n   215→      (transformedOp.type === 'insert' && transformedOp.text === '');\n   216→    if (isNoop) {\n   217→      this.sendMessage(client.ws, {\n   218→        type: 'ack',\n   219→        version: session.version,\n   220→      });\n   221→      return;\n   222→    }\n   223→\n   224→    // Apply the transformed operation to the document\n   225→    try {\n   226→      session.content = applyOperation(session.content, transformedOp);\n   227→    } catch (err) {\n   228→      const errMsg = err instanceof Error ? err.message : 'Failed to apply operation';\n   229→      this.sendMessage(client.ws, {\n   230→        type: 'error',\n   231→        message: errMsg,\n   232→      });\n   233→      return;\n   234→    }\n   235→\n   236→    // Update version\n   237→    session.version++;\n   238→    session.operationLog.push(transformedOp);\n   239→\n   240→    // Persist the version\n   241→    this.store.addVersion(\n   242→      session.documentId,\n   243→      session.version,\n   244→      session.content,\n   245→      JSON.stringify(transformedOp)\n   246→    );\n   247→    this.store.updateDocumentContent(session.documentId, session.content);\n   248→\n   249→    // Send ack to the originating client\n   250→    this.sendMessage(client.ws, {\n   251→      type: 'ack',\n   252→      version: session.version,\n   253→    });\n   254→\n   255→    // Broadcast the transformed operation to all other clients\n   256→    const broadcast: OperationBroadcast = {\n   257→      type: 'operation',\n   258→      operation: transformedOp,\n   259→      version: session.version,\n   260→      clientId: client.id,\n   261→    };\n   262→\n   263→    session.clients.forEach((c) => {\n   264→      if (c.id !== client.id && c.ws.readyState === WebSocket.OPEN) {\n   265→        this.sendMessage(c.ws, broadcast);\n   266→      }\n   267→    });\n   268→  }\n   269→\n   270→  private getLatestVersion(documentId: string): number {\n   271→    const latest = this.store.getLatestVersion(documentId);\n   272→    return latest ? latest.version : 0;\n   273→  }\n   274→\n   275→  private loadOperationLog(documentId: string): Operation[] {\n   276→    const versions = this.store.getVersions(documentId);\n   277→    const log: Operation[] = [];\n   278→    for (const v of versions) {\n   279→      if (v.operation) {\n   280→        log.push(JSON.parse(v.operation) as Operation);\n   281→      }\n   282→    }\n   283→    return log;\n   284→  }\n   285→\n   286→  private persistSession(session: DocumentSession): void {\n   287→    this.store.updateDocumentContent(session.documentId, session.content);\n   288→  }\n   289→\n   290→  private sendMessage(ws: WebSocket, msg: ServerMessage): void {\n   291→    if (ws.readyState === WebSocket.OPEN) {\n   292→      ws.send(JSON.stringify(msg));\n   293→    }\n   294→  }\n   295→\n   296→  shutdown(): void {\n   297→    this.isShuttingDown = true;\n   298→    // Persist all active sessions before closing connections\n   299→    for (const session of this.sessions.values()) {\n   300→      this.persistSession(session);\n   301→      for (const client of session.clients.values()) {\n   302→        client.ws.close(1001, 'Server shutting down');\n   303→      }\n   304→    }\n   305→    this.sessions.clear();\n   306→    if (this.wss) {\n   307→      this.wss.close();\n   308→    }\n   309→  }\n   310→\n   311→  getSessionInfo(documentId: string): { clientCount: number; version: number } | null {\n   312→    const session = this.sessions.get(documentId);\n   313→    if (!session) return null;\n   314→    return {\n   315→      clientCount: session.clients.size,\n   316→      version: session.version,\n   317→    };\n   318→  }\n   319→}\n   320→"}]},"parent_tool_use_id":"toolu_01UqorRftQ5nZ8pTNMnJXHRs","session_id":"ba7df0fd-2045-4133-bb4c-31b7b7df73af","uuid":"88c437c8-31ae-47ca-8a45-d5bcb9d0e217"}
