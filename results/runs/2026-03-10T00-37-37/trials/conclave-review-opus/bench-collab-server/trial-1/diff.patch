+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import { createApp, AppInstance } from '../src/server.js';
+
+describe('REST API', () => {
+  let instance: AppInstance;
+
+  beforeEach(async () => {
+    instance = createApp(':memory:');
+    await instance.start(0);
+  });
+
+  afterEach(async () => {
+    await instance.stop();
+  });
+
+  describe('POST /api/documents', () => {
+    it('should create a document', async () => {
+      const res = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Test Doc', content: 'Hello world' })
+        .expect(201);
+
+      expect(res.body.id).toBeDefined();
+      expect(res.body.title).toBe('Test Doc');
+      expect(res.body.content).toBe('Hello world');
+      expect(res.body.created_at).toBeDefined();
+      expect(res.body.updated_at).toBeDefined();
+    });
+
+    it('should create a document with empty content by default', async () => {
+      const res = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Empty Doc' })
+        .expect(201);
+
+      expect(res.body.content).toBe('');
+    });
+
+    it('should reject missing title', async () => {
+      await request(instance.app)
+        .post('/api/documents')
+        .send({ content: 'no title' })
+        .expect(400);
+    });
+  });
+
+  describe('GET /api/documents', () => {
+    it('should list all documents', async () => {
+      await request(instance.app).post('/api/documents').send({ title: 'Doc 1' });
+      await request(instance.app).post('/api/documents').send({ title: 'Doc 2' });
+
+      const res = await request(instance.app)
+        .get('/api/documents')
+        .expect(200);
+
+      expect(res.body).toHaveLength(2);
+    });
+
+    it('should return empty array when no documents exist', async () => {
+      const res = await request(instance.app)
+        .get('/api/documents')
+        .expect(200);
+
+      expect(res.body).toEqual([]);
+    });
+  });
+
+  describe('GET /api/documents/:id', () => {
+    it('should get a specific document', async () => {
+      const created = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'My Doc', content: 'content here' });
+
+      const res = await request(instance.app)
+        .get(`/api/documents/${created.body.id}`)
+        .expect(200);
+
+      expect(res.body.title).toBe('My Doc');
+      expect(res.body.content).toBe('content here');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(instance.app)
+        .get('/api/documents/nonexistent')
+        .expect(404);
+    });
+  });
+
+  describe('PUT /api/documents/:id', () => {
+    it('should update a document', async () => {
+      const created = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Original', content: 'old' });
+
+      const res = await request(instance.app)
+        .put(`/api/documents/${created.body.id}`)
+        .send({ title: 'Updated', content: 'new' })
+        .expect(200);
+
+      expect(res.body.title).toBe('Updated');
+      expect(res.body.content).toBe('new');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(instance.app)
+        .put('/api/documents/nonexistent')
+        .send({ title: 'Test' })
+        .expect(404);
+    });
+
+    it('should reject missing title', async () => {
+      const created = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Test' });
+
+      await request(instance.app)
+        .put(`/api/documents/${created.body.id}`)
+        .send({ content: 'no title' })
+        .expect(400);
+    });
+  });
+
+  describe('DELETE /api/documents/:id', () => {
+    it('should delete a document', async () => {
+      const created = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'To Delete' });
+
+      await request(instance.app)
+        .delete(`/api/documents/${created.body.id}`)
+        .expect(204);
+
+      await request(instance.app)
+        .get(`/api/documents/${created.body.id}`)
+        .expect(404);
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(instance.app)
+        .delete('/api/documents/nonexistent')
+        .expect(404);
+    });
+  });
+
+  describe('GET /api/documents/:id/versions', () => {
+    it('should return version history', async () => {
+      const created = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Versioned', content: 'initial' });
+
+      const res = await request(instance.app)
+        .get(`/api/documents/${created.body.id}/versions`)
+        .expect(200);
+
+      expect(res.body).toHaveLength(1);
+      expect(res.body[0].version).toBe(0);
+      expect(res.body[0].content).toBe('initial');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(instance.app)
+        .get('/api/documents/nonexistent/versions')
+        .expect(404);
+    });
+  });
+
+  describe('GET /api/documents/:id/versions/:version', () => {
+    it('should return a specific version', async () => {
+      const created = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Versioned', content: 'initial' });
+
+      const res = await request(instance.app)
+        .get(`/api/documents/${created.body.id}/versions/0`)
+        .expect(200);
+
+      expect(res.body.version).toBe(0);
+      expect(res.body.content).toBe('initial');
+    });
+
+    it('should return 404 for non-existent version', async () => {
+      const created = await request(instance.app)
+        .post('/api/documents')
+        .send({ title: 'Versioned', content: 'initial' });
+
+      await request(instance.app)
+        .get(`/api/documents/${created.body.id}/versions/99`)
+        .expect(404);
+    });
+  });
+});
+
+describe('Server lifecycle', () => {
+  it('should start on a random port and stop cleanly', async () => {
+    const instance = createApp(':memory:');
+    const port = await instance.start(0);
+    expect(port).toBeGreaterThan(0);
+    await instance.stop();
+  });
+
+  it('should handle start being called twice', async () => {
+    const instance = createApp(':memory:');
+    const port1 = await instance.start(0);
+    const port2 = await instance.start(0);
+    expect(port1).toBe(port2);
+    await instance.stop();
+  });
+});
