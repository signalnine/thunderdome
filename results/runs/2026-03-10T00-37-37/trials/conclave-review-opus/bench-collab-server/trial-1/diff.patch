@@ -0,0 +1,88 @@
+import express from 'express';
+import { createServer, Server } from 'http';
+import { WebSocketServer } from 'ws';
+import { createDatabase, DocumentStore } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationManager } from './collaboration.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath);
+  const store = new DocumentStore(db);
+  const app = express();
+  const server: Server = createServer(app);
+
+  // Middleware
+  app.use(express.json());
+
+  // REST routes
+  const router = createRouter(store);
+  app.use('/api', router);
+
+  // WebSocket server - handle upgrade manually to support path routing
+  const wss = new WebSocketServer({ noServer: true });
+  const collaboration = new CollaborationManager(store);
+  collaboration.setupWebSocket(wss);
+
+  server.on('upgrade', (request, socket, head) => {
+    const url = request.url ?? '';
+    // Accept WebSocket connections on paths like /documents/:id/ws or /ws/documents/:id
+    if (url.match(/\/(?:ws\/)?documents\/[^/]+(?:\/ws)?/)) {
+      wss.handleUpgrade(request, socket, head, (ws) => {
+        wss.emit('connection', ws, request);
+      });
+    } else {
+      socket.destroy();
+    }
+  });
+
+  let started = false;
+
+  return {
+    app,
+
+    async start(port?: number): Promise<number> {
+      if (started) {
+        const addr = server.address();
+        if (addr && typeof addr === 'object') {
+          return addr.port;
+        }
+        return port ?? 0;
+      }
+
+      return new Promise((resolve, reject) => {
+        server.listen(port ?? 0, () => {
+          started = true;
+          const addr = server.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            reject(new Error('Failed to get server address'));
+          }
+        });
+        server.on('error', reject);
+      });
+    },
+
+    async stop(): Promise<void> {
+      collaboration.shutdown();
+
+      return new Promise((resolve, reject) => {
+        server.close((err) => {
+          store.close();
+          if (err) {
+            reject(err);
+          } else {
+            started = false;
+            resolve();
+          }
+        });
+      });
+    },
+  };
+}
