+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DtWDJcdXaxurvffxPTePLJ","type":"tool_result","content":"     1→CREATE TABLE IF NOT EXISTS documents (\n     2→  id TEXT PRIMARY KEY,\n     3→  title TEXT NOT NULL,\n     4→  content TEXT NOT NULL DEFAULT '',\n     5→  created_at TEXT NOT NULL DEFAULT (datetime('now')),\n     6→  updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n     7→);\n     8→\n     9→CREATE TABLE IF NOT EXISTS versions (\n    10→  id INTEGER PRIMARY KEY AUTOINCREMENT,\n    11→  document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,\n    12→  version INTEGER NOT NULL,\n    13→  content TEXT NOT NULL,\n    14→  operation TEXT, -- JSON of the operation that produced this version\n    15→  created_at TEXT NOT NULL DEFAULT (datetime('now')),\n    16→  UNIQUE(document_id, version)\n    17→);\n    18→\n    19→CREATE TABLE IF NOT EXISTS active_connections (\n    20→  id TEXT PRIMARY KEY,\n    21→  document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,\n    22→  connected_at TEXT NOT NULL DEFAULT (datetime('now'))\n    23→);\n    24→"}]},"parent_tool_use_id":"toolu_01NXJnBQdTAsJmDV7W3wVUkM","session_id":"ba7df0fd-2045-4133-bb4c-31b7b7df73af","uuid":"98713b40-054e-43e6-a5e4-44a1ed737db6"}
