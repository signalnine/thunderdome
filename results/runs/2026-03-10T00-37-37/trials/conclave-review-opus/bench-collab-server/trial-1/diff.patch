+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WPPBpBhqXSuFX6zu1xvvxf","type":"tool_result","content":"     1→// Operational Transform implementation for collaborative text editing\n     2→\n     3→export interface InsertOp {\n     4→  type: 'insert';\n     5→  position: number;\n     6→  text: string;\n     7→}\n     8→\n     9→export interface DeleteOp {\n    10→  type: 'delete';\n    11→  position: number;\n    12→  length: number;\n    13→}\n    14→\n    15→export type Operation = InsertOp | DeleteOp;\n    16→\n    17→/**\n    18→ * Apply an operation to a document string, returning the new document.\n    19→ */\n    20→export function applyOperation(doc: string, op: Operation): string {\n    21→  if (op.type === 'insert') {\n    22→    if (op.text.length === 0) return doc; // no-op insert (from OT transform)\n    23→    if (op.position < 0 || op.position > doc.length) {\n    24→      throw new Error(`Insert position ${op.position} out of bounds [0, ${doc.length}]`);\n    25→    }\n    26→    return doc.slice(0, op.position) + op.text + doc.slice(op.position);\n    27→  } else {\n    28→    if (op.position < 0 || op.position + op.length > doc.length) {\n    29→      throw new Error(`Delete range [${op.position}, ${op.position + op.length}) out of bounds [0, ${doc.length}]`);\n    30→    }\n    31→    return doc.slice(0, op.position) + doc.slice(op.position + op.length);\n    32→  }\n    33→}\n    34→\n    35→/**\n    36→ * Transform operation `op` against a concurrent operation `against`.\n    37→ * Returns the transformed version of `op` that can be applied after `against`.\n    38→ *\n    39→ * This implements the standard OT inclusion transformation (IT) for insert/delete.\n    40→ */\n    41→export function transformOperation(op: Operation, against: Operation): Operation {\n    42→  if (op.type === 'insert' && against.type === 'insert') {\n    43→    // Both inserts: if op's position is after against's position, shift right\n    44→    if (op.position > against.position) {\n    45→      return { ...op, position: op.position + against.text.length };\n    46→    } else if (op.position < against.position) {\n    47→      return { ...op };\n    48→    } else {\n    49→      // Same position: break tie — we shift the incoming op right\n    50→      // (server-wins: the already-applied op takes priority at same position)\n    51→      return { ...op, position: op.position + against.text.length };\n    52→    }\n    53→  }\n    54→\n    55→  if (op.type === 'insert' && against.type === 'delete') {\n    56→    if (op.position <= against.position) {\n    57→      return { ...op };\n    58→    } else if (op.position >= against.position + against.length) {\n    59→      return { ...op, position: op.position - against.length };\n    60→    } else {\n    61→      // Insert inside deleted region: the insert is swallowed by the delete.\n    62→      // Return a zero-length insert (no-op) to maintain TP1 convergence\n    63→      // with the corresponding delete-spanning-insert transform.\n    64→      return { type: 'insert', position: against.position, text: '' };\n    65→    }\n    66→  }\n    67→\n    68→  if (op.type === 'delete' && against.type === 'insert') {\n    69→    if (op.position >= against.position) {\n    70→      // Delete is entirely after insert point: shift right\n    71→      return { ...op, position: op.position + against.text.length };\n    72→    } else if (op.position + op.length <= against.position) {\n    73→      // Delete is entirely before insert point: no change\n    74→      return { ...op };\n    75→    } else {\n    76→      // Delete spans across insert point. Split into two parts:\n    77→      // Part 1: delete from op.position to against.position (before the insert)\n    78→      // Part 2: delete from after the inserted text to the end of original delete\n    79→      // Combined: delete from op.position with total length = op.length + against.text.length\n    80→      // This includes the inserted text (insert is swallowed by delete).\n    81→      // This maintains TP1 convergence with the insert-inside-delete transform above.\n    82→      return { ...op, length: op.length + against.text.length };\n    83→    }\n    84→  }\n    85→\n    86→  // Both deletes\n    87→  if (op.type === 'delete' && against.type === 'delete') {\n    88→    if (op.position >= against.position + against.length) {\n    89→      // op is entirely after against\n    90→      return { ...op, position: op.position - against.length };\n    91→    } else if (op.position + op.length <= against.position) {\n    92→      // op is entirely before against\n    93→      return { ...op };\n    94→    } else {\n    95→      // Overlapping deletes\n    96→      const opEnd = op.position + op.length;\n    97→      const againstEnd = against.position + against.length;\n    98→\n    99→      const newPosition = Math.min(op.position, against.position);\n   100→      const overlapStart = Math.max(op.position, against.position);\n   101→      const overlapEnd = Math.min(opEnd, againstEnd);\n   102→      const overlapLength = Math.max(0, overlapEnd - overlapStart);\n   103→\n   104→      const newLength = op.length - overlapLength;\n   105→\n   106→      if (newLength <= 0) {\n   107→        // op's deletion was entirely covered by against\n   108→        return { type: 'delete', position: newPosition, length: 0 };\n   109→      }\n   110→\n   111→      // Adjust position: if op starts after against, shift left\n   112→      const adjustedPosition = op.position <= against.position\n   113→        ? op.position\n   114→        : op.position - Math.min(against.length, op.position - against.position);\n   115→\n   116→      return { type: 'delete', position: adjustedPosition, length: newLength };\n   117→    }\n   118→  }\n   119→\n   120→  // Fallback (should never reach here due to exhaustive checks)\n   121→  return { ...op } as Operation;\n   122→}\n   123→\n   124→/**\n   125→ * Transform an operation against a sequence of operations.\n   126→ */\n   127→export function transformOperationAgainstMany(op: Operation, ops: Operation[]): Operation {\n   128→  let result = op;\n   129→  for (const against of ops) {\n   130→    result = transformOperation(result, against);\n   131→  }\n   132→  return result;\n   133→}\n   134→\n   135→/**\n   136→ * Validate that an operation is well-formed.\n   137→ */\n   138→export function validateOperation(op: unknown): op is Operation {\n   139→  if (typeof op !== 'object' || op === null) return false;\n   140→  const obj = op as Record<string, unknown>;\n   141→\n   142→  if (obj.type === 'insert') {\n   143→    return (\n   144→      typeof obj.position === 'number' &&\n   145→      Number.isInteger(obj.position) &&\n   146→      obj.position >= 0 &&\n   147→      typeof obj.text === 'string' &&\n   148→      obj.text.length > 0\n   149→    );\n   150→  }\n   151→\n   152→  if (obj.type === 'delete') {\n   153→    return (\n   154→      typeof obj.position === 'number' &&\n   155→      Number.isInteger(obj.position) &&\n   156→      obj.position >= 0 &&\n   157→      typeof obj.length === 'number' &&\n   158→      Number.isInteger(obj.length) &&\n   159→      obj.length > 0\n   160→    );\n   161→  }\n   162→\n   163→  return false;\n   164→}\n   165→"}]},"parent_tool_use_id":"toolu_01UqorRftQ5nZ8pTNMnJXHRs","session_id":"ba7df0fd-2045-4133-bb4c-31b7b7df73af","uuid":"bd026b57-1676-4184-b0c7-c405294175fe"}
