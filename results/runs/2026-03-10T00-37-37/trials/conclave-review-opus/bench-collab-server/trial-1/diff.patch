index 0000000..564eaa0
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,162 @@
+// Operational Transform implementation for collaborative text editing
+
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  length: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+/**
+ * Apply an operation to a document string, returning the new document.
+ */
+export function applyOperation(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    if (op.text.length === 0) return doc; // no-op insert (from OT transform)
+    if (op.position < 0 || op.position > doc.length) {
+      throw new Error(`Insert position ${op.position} out of bounds [0, ${doc.length}]`);
+    }
+    return doc.slice(0, op.position) + op.text + doc.slice(op.position);
+  } else {
+    if (op.position < 0 || op.position + op.length > doc.length) {
+      throw new Error(`Delete range [${op.position}, ${op.position + op.length}) out of bounds [0, ${doc.length}]`);
+    }
+    return doc.slice(0, op.position) + doc.slice(op.position + op.length);
+  }
+}
+
+/**
+ * Transform operation `op` against a concurrent operation `against`.
+ * Returns the transformed version of `op` that can be applied after `against`.
+ *
+ * This implements the standard OT inclusion transformation (IT) for insert/delete.
+ */
+export function transformOperation(op: Operation, against: Operation): Operation {
+  if (op.type === 'insert' && against.type === 'insert') {
+    // Both inserts: if op's position is after against's position, shift right
+    if (op.position > against.position) {
+      return { ...op, position: op.position + against.text.length };
+    } else if (op.position < against.position) {
+      return { ...op };
+    } else {
+      // Same position: break tie — we shift the incoming op right
+      // (server-wins: the already-applied op takes priority at same position)
+      return { ...op, position: op.position + against.text.length };
+    }
+  }
+
+  if (op.type === 'insert' && against.type === 'delete') {
+    if (op.position <= against.position) {
+      return { ...op };
+    } else if (op.position >= against.position + against.length) {
+      return { ...op, position: op.position - against.length };
+    } else {
+      // Insert falls inside a concurrently deleted region.
+      // Relocate to the delete boundary to preserve the inserted text.
+      return { ...op, position: against.position };
+    }
+  }
+
+  if (op.type === 'delete' && against.type === 'insert') {
+    if (op.position >= against.position) {
+      // Delete is entirely after insert point: shift right
+      return { ...op, position: op.position + against.text.length };
+    } else if (op.position + op.length <= against.position) {
+      // Delete is entirely before insert point: no change
+      return { ...op };
+    } else {
+      // Delete spans across the insert point. The concurrent insert added text
+      // within our delete range. We expand the delete to cover the full range
+      // including the newly inserted text, so that after both operations are
+      // applied, the delete removes all originally-targeted characters plus the
+      // text that was inserted into the middle of the deleted region.
+      return { ...op, length: op.length + against.text.length };
+    }
+  }
+
+  // Both deletes
+  if (op.type === 'delete' && against.type === 'delete') {
+    if (op.position >= against.position + against.length) {
+      // op is entirely after against
+      return { ...op, position: op.position - against.length };
+    } else if (op.position + op.length <= against.position) {
+      // op is entirely before against
+      return { ...op };
+    } else {
+      // Overlapping deletes
+      const opEnd = op.position + op.length;
+      const againstEnd = against.position + against.length;
+
+      const newPosition = Math.min(op.position, against.position);
+      const overlapStart = Math.max(op.position, against.position);
+      const overlapEnd = Math.min(opEnd, againstEnd);
+      const overlapLength = Math.max(0, overlapEnd - overlapStart);
+
+      const newLength = op.length - overlapLength;
+
+      if (newLength <= 0) {
+        // op's deletion was entirely covered by against
+        return { type: 'delete', position: newPosition, length: 0 };
+      }
+
+      // Adjust position: if op starts after against, shift left
+      const adjustedPosition = op.position <= against.position
+        ? op.position
+        : op.position - Math.min(against.length, op.position - against.position);
+
+      return { type: 'delete', position: adjustedPosition, length: newLength };
+    }
+  }
+
+  // Fallback (should never reach here due to exhaustive checks)
+  return { ...op } as Operation;
+}
+
+/**
+ * Transform an operation against a sequence of operations.
+ */
+export function transformOperationAgainstMany(op: Operation, ops: Operation[]): Operation {
+  let result = op;
+  for (const against of ops) {
+    result = transformOperation(result, against);
+  }
+  return result;
+}
+
+/**
+ * Validate that an operation is well-formed.
+ */
+export function validateOperation(op: unknown): op is Operation {
+  if (typeof op !== 'object' || op === null) return false;
+  const obj = op as Record<string, unknown>;
+
+  if (obj.type === 'insert') {
+    return (
+      typeof obj.position === 'number' &&
+      Number.isInteger(obj.position) &&
+      obj.position >= 0 &&
+      typeof obj.text === 'string' &&
+      obj.text.length > 0
+    );
+  }
+
+  if (obj.type === 'delete') {
+    return (
+      typeof obj.position === 'number' &&
+      Number.isInteger(obj.position) &&
+      obj.position >= 0 &&
+      typeof obj.length === 'number' &&
+      Number.isInteger(obj.length) &&
+      obj.length > 0
+    );
+  }
+
+  return false;
+}
