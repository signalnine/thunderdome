+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PRfgRo9Linr43Jyo9nJyHS","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { readFileSync } from 'fs';\n     3→import { join, dirname } from 'path';\n     4→import { fileURLToPath } from 'url';\n     5→\n     6→const __dirname = dirname(fileURLToPath(import.meta.url));\n     7→\n     8→export interface DocumentRow {\n     9→  id: string;\n    10→  title: string;\n    11→  content: string;\n    12→  created_at: string;\n    13→  updated_at: string;\n    14→}\n    15→\n    16→export interface VersionRow {\n    17→  id: number;\n    18→  document_id: string;\n    19→  version: number;\n    20→  content: string;\n    21→  operation: string | null;\n    22→  created_at: string;\n    23→}\n    24→\n    25→export function createDatabase(dbPath?: string): Database.Database {\n    26→  const db = new Database(dbPath ?? ':memory:');\n    27→  db.pragma('journal_mode = WAL');\n    28→  db.pragma('foreign_keys = ON');\n    29→\n    30→  // Read and execute schema\n    31→  const schemaPath = join(__dirname, '..', 'schema.sql');\n    32→  const schema = readFileSync(schemaPath, 'utf-8');\n    33→  db.exec(schema);\n    34→\n    35→  return db;\n    36→}\n    37→\n    38→export class DocumentStore {\n    39→  private db: Database.Database;\n    40→\n    41→  // Prepared statements\n    42→  private stmtInsertDoc: Database.Statement;\n    43→  private stmtGetDoc: Database.Statement;\n    44→  private stmtListDocs: Database.Statement;\n    45→  private stmtUpdateDoc: Database.Statement;\n    46→  private stmtDeleteDoc: Database.Statement;\n    47→  private stmtInsertVersion: Database.Statement;\n    48→  private stmtGetVersions: Database.Statement;\n    49→  private stmtGetLatestVersion: Database.Statement;\n    50→  private stmtGetVersion: Database.Statement;\n    51→\n    52→  constructor(db: Database.Database) {\n    53→    this.db = db;\n    54→\n    55→    this.stmtInsertDoc = db.prepare(\n    56→      `INSERT INTO documents (id, title, content) VALUES (?, ?, ?)`\n    57→    );\n    58→    this.stmtGetDoc = db.prepare(\n    59→      `SELECT * FROM documents WHERE id = ?`\n    60→    );\n    61→    this.stmtListDocs = db.prepare(\n    62→      `SELECT * FROM documents ORDER BY updated_at DESC`\n    63→    );\n    64→    this.stmtUpdateDoc = db.prepare(\n    65→      `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`\n    66→    );\n    67→    this.stmtDeleteDoc = db.prepare(\n    68→      `DELETE FROM documents WHERE id = ?`\n    69→    );\n    70→    this.stmtInsertVersion = db.prepare(\n    71→      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`\n    72→    );\n    73→    this.stmtGetVersions = db.prepare(\n    74→      `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`\n    75→    );\n    76→    this.stmtGetLatestVersion = db.prepare(\n    77→      `SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1`\n    78→    );\n    79→    this.stmtGetVersion = db.prepare(\n    80→      `SELECT * FROM versions WHERE document_id = ? AND version = ?`\n    81→    );\n    82→  }\n    83→\n    84→  createDocument(id: string, title: string, content: string = ''): DocumentRow {\n    85→    this.stmtInsertDoc.run(id, title, content);\n    86→    // Create initial version (version 0)\n    87→    this.stmtInsertVersion.run(id, 0, content, null);\n    88→    return this.stmtGetDoc.get(id) as DocumentRow;\n    89→  }\n    90→\n    91→  getDocument(id: string): DocumentRow | undefined {\n    92→    return this.stmtGetDoc.get(id) as DocumentRow | undefined;\n    93→  }\n    94→\n    95→  listDocuments(): DocumentRow[] {\n    96→    return this.stmtListDocs.all() as DocumentRow[];\n    97→  }\n    98→\n    99→  updateDocument(id: string, title: string, content: string): DocumentRow | undefined {\n   100→    const result = this.stmtUpdateDoc.run(title, content, id);\n   101→    if (result.changes === 0) return undefined;\n   102→    return this.stmtGetDoc.get(id) as DocumentRow;\n   103→  }\n   104→\n   105→  updateDocumentContent(id: string, content: string): void {\n   106→    this.db.prepare(\n   107→      `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`\n   108→    ).run(content, id);\n   109→  }\n   110→\n   111→  deleteDocument(id: string): boolean {\n   112→    const result = this.stmtDeleteDoc.run(id);\n   113→    return result.changes > 0;\n   114→  }\n   115→\n   116→  addVersion(documentId: string, version: number, content: string, operation: string | null): void {\n   117→    this.stmtInsertVersion.run(documentId, version, content, operation);\n   118→  }\n   119→\n   120→  getVersions(documentId: string): VersionRow[] {\n   121→    return this.stmtGetVersions.all(documentId) as VersionRow[];\n   122→  }\n   123→\n   124→  getLatestVersion(documentId: string): VersionRow | undefined {\n   125→    return this.stmtGetLatestVersion.get(documentId) as VersionRow | undefined;\n   126→  }\n   127→\n   128→  getVersion(documentId: string, version: number): VersionRow | undefined {\n   129→    return this.stmtGetVersion.get(documentId, version) as VersionRow | undefined;\n   130→  }\n   131→\n   132→  close(): void {\n   133→    this.db.close();\n   134→  }\n   135→}\n   136→"}]},"parent_tool_use_id":"toolu_01UqorRftQ5nZ8pTNMnJXHRs","session_id":"ba7df0fd-2045-4133-bb4c-31b7b7df73af","uuid":"f02c437e-6555-4f91-90fe-b95ec28002e8"}
