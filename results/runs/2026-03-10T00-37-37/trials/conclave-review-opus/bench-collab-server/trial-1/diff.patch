 | CursorMessage;\n\n// Outgoing messages to clients\ninterface SyncMessage {\n  type: 'sync';\n  content: string;\n  version: number;\n  clientId: string;\n}\n\ninterface OperationBroadcast {\n  type: 'operation';\n  operation: Operation;\n  version: number;\n  clientId: string;\n}\n\ninterface ErrorMessage {\n  type: 'error';\n  message: string;\n}\n\ninterface AckMessage {\n  type: 'ack';\n  version: number;\n}\n\ntype ServerMessage = SyncMessage | OperationBroadcast | ErrorMessage | AckMessage;\n\nexport class CollaborationManager {\n  private sessions: Map<string, DocumentSession> = new Map();\n  private store: DocumentStore;\n  private wss: WebSocketServer | null = null;\n  private isShuttingDown = false;\n\n  constructor(store: DocumentStore) {\n    this.store = store;\n  }\n\n  setupWebSocket(wss: WebSocketServer): void {\n    this.wss = wss;\n    wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n      this.handleConnection(ws, req);\n    });\n  }\n\n  private handleConnection(ws: WebSocket, req: IncomingMessage): void {\n    // Extract document ID from URL path: /ws/documents/:id or /documents/:id/ws\n    const url = req.url ?? '';\n    const match = url.match(/\\/(?:ws\\/)?documents\\/([^/]+)(?:\\/ws)?/);\n    if (!match) {\n      this.sendMessage(ws, { type: 'error', message: 'Invalid WebSocket URL. Expected /documents/:id/ws' });\n      ws.close(1008, 'Invalid URL');\n      return;\n    }\n\n    const documentId = match[1];\n    const doc = this.store.getDocument(documentId);\n    if (!doc) {\n      this.sendMessage(ws, { type: 'error', message: 'Document not found' });\n      ws.close(1008, 'Document not found');\n      return;\n    }\n\n    const clientId = randomUUID();\n    const client: ClientConnection = { id: clientId, ws, documentId };\n\n    // Get or create session\n    let session = this.sessions.get(documentId);\n    if (!session) {\n      session = {\n        documentId,\n        content: doc.content,\n        version: this.getLatestVersion(documentId),\n        clients: new Map(),\n        operationLog: this.loadOperationLog(documentId),\n      };\n      this.sessions.set(documentId, session);\n    }\n\n    session.clients.set(clientId, client);\n\n    // Send sync message with current document state\n    const syncMsg: SyncMessage = {\n      type: 'sync',\n      content: session.content,\n      version: session.version,\n      clientId,\n    };\n    this.sendMessage(ws, syncMsg);\n\n    // Handle messages\n    ws.on('message', (data) => {\n      try {\n        const msg = JSON.parse(data.toString()) as ClientMessage;\n        this.handleMessage(client, session!, msg);\n      } catch (err) {\n        const errMsg = err instanceof Error ? err.message : 'Unknown error';\n        this.sendMessage(ws, { type: 'error', message: `Invalid message: ${errMsg}` });\n      }\n    });\n\n    // Handle disconnect\n    ws.on('close', () => {\n      if (session && !this.isShuttingDown) {\n        session.clients.delete(clientId);\n        if (session.clients.size === 0) {\n          // Persist final state and clean up session\n          this.persistSession(session);\n          this.sessions.delete(documentId);\n        }\n      }\n    });\n\n    ws.on('error', () => {\n      if (session) {\n        session.clients.delete(clientId);\n      }\n    });\n  }\n\n  private handleMessage(client: ClientConnection, session: DocumentSession, msg: ClientMessage): void {\n    if (msg.type === 'operation') {\n      this.handleOperation(client, session, msg);\n    } else if (msg.type === 'cursor') {\n      // Cursor updates: broadcast to other clients\n      session.clients.forEach((c) => {\n        if (c.id !== client.id && c.ws.readyState === WebSocket.OPEN) {\n          this.sendMessage(c.ws, {\n            type: 'cursor' as unknown as 'ack',\n            position: msg.position,\n            clientId: client.id,\n          } as unknown as AckMessage);\n        }\n      });\n    }\n  }\n\n  private handleOperation(client: ClientConnection, session: DocumentSession, msg: OperationMessage): void {\n    // Validate the operation\n    if (!validateOperation(msg.operation)) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: 'Invalid operation',\n      });\n      return;\n    }\n\n    if (typeof msg.version !== 'number' || msg.version < 0) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: 'Invalid version number',\n      });\n      return;\n    }\n\n    if (msg.version > session.version) {\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: `Version ${msg.version} is ahead of server version ${session.version}`,\n      });\n      return;\n    }\n\n    // Transform the operation against all operations that happened since client's version\n    let transformedOp = msg.operation;\n    for (let i = msg.version; i < session.version; i++) {\n      const concurrentOp = session.operationLog[i];\n      if (concurrentOp) {\n        transformedOp = transformOperation(transformedOp, concurrentOp);\n      }\n    }\n\n    // Skip no-op deletes (length 0 after transform)\n    if (transformedOp.type === 'delete' && transformedOp.length <= 0) {\n      // The operation was fully subsumed by concurrent operations\n      this.sendMessage(client.ws, {\n        type: 'ack',\n        version: session.version,\n      });\n      return;\n    }\n\n    // Apply the transformed operation to the document\n    try {\n      session.content = applyOperation(session.content, transformedOp);\n    } catch (err) {\n      const errMsg = err instanceof Error ? err.message : 'Failed to apply operation';\n      this.sendMessage(client.ws, {\n        type: 'error',\n        message: errMsg,\n      });\n      return;\n    }\n\n    // Update version\n    session.version++;\n    session.operationLog.push(transformedOp);\n\n    // Persist the version\n    this.store.addVersion(\n      session.documentId,\n      session.version,\n      session.content,\n      JSON.stringify(transformedOp)\n    );\n    this.store.updateDocumentContent(session.documentId, session.content);\n\n    // Send ack to the originating client\n    this.sendMessage(client.ws, {\n      type: 'ack',\n      version: session.version,\n    });\n\n    // Broadcast the transformed operation to all other clients\n    const broadcast: OperationBroadcast = {\n      type: 'operation',\n      operation: transformedOp,\n      version: session.version,\n      clientId: client.id,\n    };\n\n    session.clients.forEach((c) => {\n      if (c.id !== client.id && c.ws.readyState === WebSocket.OPEN) {\n        this.sendMessage(c.ws, broadcast);\n      }\n    });\n  }\n\n  private getLatestVersion(documentId: string): number {\n    const latest = this.store.getLatestVersion(documentId);\n    return latest ? latest.version : 0;\n  }\n\n  private loadOperationLog(documentId: string): Operation[] {\n    const versions = this.store.getVersions(documentId);\n    const log: Operation[] = [];\n    for (const v of versions) {\n      if (v.operation) {\n        log.push(JSON.parse(v.operation) as Operation);\n      }\n    }\n    return log;\n  }\n\n  private persistSession(session: DocumentSession): void {\n    this.store.updateDocumentContent(session.documentId, session.content);\n  }\n\n  private sendMessage(ws: WebSocket, msg: ServerMessage): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(msg));\n    }\n  }\n\n  shutdown(): void {\n    this.isShuttingDown = true;\n    // Persist all active sessions before closing connections\n    for (const session of this.sessions.values()) {\n      this.persistSession(session);\n      for (const client of session.clients.values()) {\n        client.ws.close(1001, 'Server shutting down');\n      }\n    }\n    this.sessions.clear();\n    if (this.wss) {\n      this.wss.close();\n    }\n  }\n\n  getSessionInfo(documentId: string): { clientCount: number; version: number } | null {\n    const session = this.sessions.get(documentId);\n    if (!session) return null;\n    return {\n      clientCount: session.clients.size,\n      version: session.version,\n    };\n  }\n}\n","structuredPatch":[{"oldStart":209,"oldLines":9,"newStart":209,"newLines":11,"lines":["       }","     }"," ","-    // Skip no-op deletes (length 0 after transform)","-    if (transformedOp.type === 'delete' && transformedOp.length <= 0) {","-      // The operation was fully subsumed by concurrent operations","+    // Skip no-op operations after transform","+    const isNoop =","+      (transformedOp.type === 'delete' && transformedOp.length <= 0) ||","+      (transformedOp.type === 'insert' && transformedOp.text === '');","+    if (isNoop) {","       this.sendMessage(client.ws, {","         type: 'ack',","         version: session.version,"]}],"userModified":false,"replaceAll":false}}
