oBe('Updated');\n   102→      expect(res.body.content).toBe('new');\n   103→    });\n   104→\n   105→    it('should return 404 for non-existent document', async () => {\n   106→      await request(instance.app)\n   107→        .put('/api/documents/nonexistent')\n   108→        .send({ title: 'Test' })\n   109→        .expect(404);\n   110→    });\n   111→\n   112→    it('should reject missing title', async () => {\n   113→      const created = await request(instance.app)\n   114→        .post('/api/documents')\n   115→        .send({ title: 'Test' });\n   116→\n   117→      await request(instance.app)\n   118→        .put(`/api/documents/${created.body.id}`)\n   119→        .send({ content: 'no title' })\n   120→        .expect(400);\n   121→    });\n   122→  });\n   123→\n   124→  describe('DELETE /api/documents/:id', () => {\n   125→    it('should delete a document', async () => {\n   126→      const created = await request(instance.app)\n   127→        .post('/api/documents')\n   128→        .send({ title: 'To Delete' });\n   129→\n   130→      await request(instance.app)\n   131→        .delete(`/api/documents/${created.body.id}`)\n   132→        .expect(204);\n   133→\n   134→      await request(instance.app)\n   135→        .get(`/api/documents/${created.body.id}`)\n   136→        .expect(404);\n   137→    });\n   138→\n   139→    it('should return 404 for non-existent document', async () => {\n   140→      await request(instance.app)\n   141→        .delete('/api/documents/nonexistent')\n   142→        .expect(404);\n   143→    });\n   144→  });\n   145→\n   146→  describe('GET /api/documents/:id/versions', () => {\n   147→    it('should return version history', async () => {\n   148→      const created = await request(instance.app)\n   149→        .post('/api/documents')\n   150→        .send({ title: 'Versioned', content: 'initial' });\n   151→\n   152→      const res = await request(instance.app)\n   153→        .get(`/api/documents/${created.body.id}/vers