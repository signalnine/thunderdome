+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01WbPhmbRKx7FkxneHsFBn9G","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015rpUNmu5H5zRUM7zcyzZZZ","name":"Write","input":{"file_path":"/workspace/tests/collaboration.test.ts","content":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport request from 'supertest';\nimport WebSocket from 'ws';\nimport { createApp, AppInstance } from '../src/server.js';\n\n/**\n * A WebSocket client wrapper that queues all incoming messages,\n * allowing them to be consumed asynchronously without race conditions.\n */\nclass TestClient {\n  ws: WebSocket;\n  private messageQueue: Record<string, unknown>[] = [];\n  private waiters: ((msg: Record<string, unknown>) => void)[] = [];\n  private openPromise: Promise<void>;\n\n  constructor(url: string) {\n    this.ws = new WebSocket(url);\n\n    // Set up message queueing BEFORE connection opens\n    this.ws.on('message', (data) => {\n      const msg = JSON.parse(data.toString());\n      if (this.waiters.length > 0) {\n        const waiter = this.waiters.shift()!;\n        waiter(msg);\n      } else {\n        this.messageQueue.push(msg);\n      }\n    });\n\n    this.openPromise = new Promise((resolve, reject) => {\n      this.ws.on('open', () => resolve());\n      this.ws.on('error', reject);\n    });\n  }\n\n  async waitOpen(): Promise<void> {\n    await this.openPromise;\n  }\n\n  nextMessage(timeout = 5000): Promise<Record<string, unknown>> {\n    // Check queue first\n    if (this.messageQueue.length > 0) {\n      return Promise.resolve(this.messageQueue.shift()!);\n    }\n\n    return new Promise((resolve, reject) => {\n      const timer = setTimeout(() => {\n        // Remove this waiter\n        const idx = this.waiters.indexOf(waiter);\n        if (idx >= 0) this.waiters.splice(idx, 1);\n        reject(new Error('Timeout waiting for message'));\n      }, timeout);\n\n      const waiter = (msg: Record<string, unknown>) => {\n        clearTimeout(timer);\n        resolve(msg);\n      };\n      this.waiters.push(waiter);\n    });\n  }\n\n  async nextMessageOfType(type: string, timeout = 5000): Promise<Record<string, unknown>> {\n    const deadline = Date.now() + timeout;\n    while (true) {\n      const remaining = deadline - Date.now();\n      if (remaining <= 0) {\n        throw new Error(`Timeout waiting for message of type \"${type}\"`);\n      }\n      const msg = await this.nextMessage(remaining);\n      if (msg.type === type) return msg;\n      // else discard and try again\n    }\n  }\n\n  send(msg: Record<string, unknown>): void {\n    this.ws.send(JSON.stringify(msg));\n  }\n\n  close(): void {\n    if (this.ws.readyState === WebSocket.OPEN || this.ws.readyState === WebSocket.CONNECTING) {\n      this.ws.close();\n    }\n  }\n}\n\ndescribe('WebSocket Collaboration', () => {\n  let instance: AppInstance;\n  let port: number;\n  const clients: TestClient[] = [];\n\n  beforeEach(async () => {\n    instance = createApp(':memory:');\n    port = await instance.start(0);\n  });\n\n  afterEach(async () => {\n    for (const c of clients) {\n      c.close();\n    }\n    clients.length = 0;\n    await instance.stop();\n  });\n\n  async function createDoc(title: string, content: string = ''): Promise<string> {\n    const res = await request(instance.app)\n      .post('/api/documents')\n      .send({ title, content });\n    return res.body.id;\n  }\n\n  async function connect(docId: string): Promise<TestClient> {\n    const client = new TestClient(`ws://localhost:${port}/documents/${docId}/ws`);\n    clients.push(client);\n    await client.waitOpen();\n    return client;\n  }\n\n  it('should send sync message on connection', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const client = await connect(docId);\n    const msg = await client.nextMessage();\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe(0);\n    expect(msg.clientId).toBeDefined();\n  });\n\n  it('should send error for non-existent document', async () => {\n    const client = new TestClient(`ws://localhost:${port}/documents/nonexistent/ws`);\n    clients.push(client);\n\n    const msg = await client.nextMessage();\n    expect(msg.type).toBe('error');\n  });\n\n  it('should apply an insert operation and ack', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const client = await connect(docId);\n    const sync = await client.nextMessage();\n\n    client.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, text: ' world' },\n      version: sync.version,\n    });\n\n    const ack = await client.nextMessage();\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(1);\n\n    // Verify via REST\n    const res = await request(instance.app).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('hello world');\n  });\n\n  it('should apply a delete operation', async () => {\n    const docId = await createDoc('Test', 'hello world');\n    const client = await connect(docId);\n    await client.nextMessage(); // sync\n\n    client.send({\n      type: 'operation',\n      operation: { type: 'delete', position: 5, length: 6 },\n      version: 0,\n    });\n\n    const ack = await client.nextMessage();\n    expect(ack.type).toBe('ack');\n\n    const res = await request(instance.app).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('hello');\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const client1 = await connect(docId);\n    await client1.nextMessage(); // sync\n\n    const client2 = await connect(docId);\n    await client2.nextMessage(); // sync\n\n    // Client 1 sends an operation\n    client1.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, text: ' world' },\n      version: 0,\n    });\n\n    // Client 1 gets ack\n    const ack = await client1.nextMessage();\n    expect(ack.type).toBe('ack');\n\n    // Client 2 should receive the broadcast\n    const broadcast = await client2.nextMessage();\n    expect(broadcast.type).toBe('operation');\n    expect((broadcast.operation as { type: string }).type).toBe('insert');\n    expect(broadcast.version).toBe(1);\n  });\n\n  it('should handle concurrent edits from two clients with OT', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const client1 = await connect(docId);\n    const sync1 = await client1.nextMessage();\n\n    const client2 = await connect(docId);\n    await client2.nextMessage(); // sync\n\n    // Client 1 inserts \" world\" at position 5\n    client1.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 5, text: ' world' },\n      version: sync1.version,\n    });\n\n    // Wait for ack\n    const ack1 = await client1.nextMessageOfType('ack');\n    expect(ack1.version).toBe(1);\n\n    // Client 2 receives broadcast\n    const broadcast = await client2.nextMessageOfType('operation');\n    expect(broadcast.version).toBe(1);\n\n    // Client 2 inserts \"Oh, \" at position 0, based on version 0\n    client2.send({\n      type: 'operation',\n      operation: { type: 'insert', position: 0, text: 'Oh, ' },\n      version: 0,\n    });\n\n    const ack2 = await client2.nextMessageOfType('ack');\n    expect(ack2.version).toBe(2);\n\n    // Verify final document state\n    const res = await request(instance.app).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('Oh, hello world');\n  });\n\n  it('should reject invalid operations', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const client = await connect(docId);\n    await client.nextMessage(); // sync\n\n    client.send({\n      type: 'operation',\n      operation: { type: 'insert', position: -1, text: 'bad' },\n      version: 0,\n    });\n\n    const err = await client.