nst op: Operation = { type: 'insert', position: 8, text: 'a' };\n    82→      const against: Operation = { type: 'delete', position: 3, length: 3 };\n    83→      const result = transformOperation(op, against);\n    84→      expect(result).toEqual({ type: 'insert', position: 5, text: 'a' });\n    85→    });\n    86→\n    87→    it('should produce no-op when insert is inside deleted region', () => {\n    88→      const op: Operation = { type: 'insert', position: 5, text: 'a' };\n    89→      const against: Operation = { type: 'delete', position: 3, length: 5 };\n    90→      const result = transformOperation(op, against);\n    91→      // Insert is swallowed by the delete for TP1 convergence\n    92→      expect(result).toEqual({ type: 'insert', position: 3, text: '' });\n    93→    });\n    94→  });\n    95→\n    96→  describe('delete vs insert', () => {\n    97→    it('should shift right when delete is after insert', () => {\n    98→      const op: Operation = { type: 'delete', position: 5, length: 3 };\n    99→      const against: Operation = { type: 'insert', position: 3, text: 'ab' };\n   100→      const result = transformOperation(op, against);\n   101→      expect(result).toEqual({ type: 'delete', position: 7, length: 3 });\n   102→    });\n   103→\n   104→    it('should not shift when delete is before insert', () => {\n   105→      const op: Operation = { type: 'delete', position: 2, length: 2 };\n   106→      const against: Operation = { type: 'insert', position: 8, text: 'ab' };\n   107→      const result = transformOperation(op, against);\n   108→      expect(result).toEqual({ type: 'delete', position: 2, length: 2 });\n   109→    });\n   110→  });\n   111→\n   112→  describe('delete vs delete', () => {\n   113→    it('should shift left when delete is after another delete', () => {\n   114→      const op: Operation = { type: 'delete', position: 8, length: 2 };\n   115→      const against: Operation = { type: 'delete', position: 3, length: 3 };\n   116→    