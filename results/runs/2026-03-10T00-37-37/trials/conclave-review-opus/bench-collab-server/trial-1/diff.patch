FROM documents ORDER BY updated_at DESC`\n    );\n    this.stmtUpdateDoc = db.prepare(\n      `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`\n    );\n    this.stmtDeleteDoc = db.prepare(\n      `DELETE FROM documents WHERE id = ?`\n    );\n    this.stmtInsertVersion = db.prepare(\n      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`\n    );\n    this.stmtGetVersions = db.prepare(\n      `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`\n    );\n    this.stmtGetLatestVersion = db.prepare(\n      `SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1`\n    );\n    this.stmtGetVersion = db.prepare(\n      `SELECT * FROM versions WHERE document_id = ? AND version = ?`\n    );\n  }\n\n  createDocument(id: string, title: string, content: string = ''): DocumentRow {\n    this.stmtInsertDoc.run(id, title, content);\n    // Create initial version (version 0)\n    this.stmtInsertVersion.run(id, 0, content, null);\n    return this.stmtGetDoc.get(id) as DocumentRow;\n  }\n\n  getDocument(id: string): DocumentRow | undefined {\n    return this.stmtGetDoc.get(id) as DocumentRow | undefined;\n  }\n\n  listDocuments(): DocumentRow[] {\n    return this.stmtListDocs.all() as DocumentRow[];\n  }\n\n  updateDocument(id: string, title: string, content: string): DocumentRow | undefined {\n    const result = this.stmtUpdateDoc.run(title, content, id);\n    if (result.changes === 0) return undefined;\n    return this.stmtGetDoc.get(id) as DocumentRow;\n  }\n\n  updateDocumentContent(id: string, content: string): void {\n    this.db.prepare(\n      `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`\n    ).run(content, id);\n  }\n\n  deleteDocument(id: string): boolean {\n    const result = this.stmtDeleteDoc.run(id);\n    return result.changes > 0;\n  }\n\n  addVersion(documentId: string, version: number, content: string, operation: string | null): void {\n    this.stmtInsertVersion.run(documentId, version, content, operation);\n  }\n\n  getVersions(documentId: string): VersionRow[] {\n    return this.stmtGetVersions.all(documentId) as VersionRow[];\n  }\n\n  getLatestVersion(documentId: string): VersionRow | undefined {\n    return this.stmtGetLatestVersion.get(documentId) as VersionRow | undefined;\n  }\n\n  getVersion(documentId: string, version: number): VersionRow | undefined {\n    return this.stmtGetVersion.get(documentId, version) as VersionRow | undefined;\n  }\n\n  close(): void {\n    this.db.close();\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":293,"cache_read_input_tokens":23025,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":293},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ba7df0fd-2045-4133-bb4c-31b7b7df73af","uuid":"31ca73e6-2962-47f6-b887-49497c07196a"}
