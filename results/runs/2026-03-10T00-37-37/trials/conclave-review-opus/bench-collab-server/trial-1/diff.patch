eturn undefined;\n    return this.stmtGetDoc.get(id) as DocumentRow;\n  }\n\n  updateDocumentContent(id: string, content: string): void {\n    this.db.prepare(\n      `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`\n    ).run(content, id);\n  }\n\n  deleteDocument(id: string): boolean {\n    const result = this.stmtDeleteDoc.run(id);\n    return result.changes > 0;\n  }\n\n  addVersion(documentId: string, version: number, content: string, operation: string | null): void {\n    this.stmtInsertVersion.run(documentId, version, content, operation);\n  }\n\n  getVersions(documentId: string): VersionRow[] {\n    return this.stmtGetVersions.all(documentId) as VersionRow[];\n  }\n\n  getLatestVersion(documentId: string): VersionRow | undefined {\n    return this.stmtGetLatestVersion.get(documentId) as VersionRow | undefined;\n  }\n\n  getVersion(documentId: string, version: number): VersionRow | undefined {\n    return this.stmtGetVersion.get(documentId, version) as VersionRow | undefined;\n  }\n\n  close(): void {\n    this.db.close();\n  }\n}\n","structuredPatch":[{"oldStart":48,"oldLines":6,"newStart":48,"newLines":7,"lines":["   private stmtGetVersions: Database.Statement;","   private stmtGetLatestVersion: Database.Statement;","   private stmtGetVersion: Database.Statement;","+  private stmtUpdateDocContent: Database.Statement;"," ","   constructor(db: Database.Database) {","     this.db = db;"]}],"userModified":false,"replaceAll":false}}
