id,\n      timestamp: v.timestamp,\n      content: clone(v.content),\n    })),\n    deleted: state.deleted,\n  };\n}\n\nfunction cloneDocs(docs: Map<string, DocState>): Map<string, DocState> {\n  const result = new Map<string, DocState>();\n  for (const [id, state] of docs) {\n    result.set(id, cloneDocState(state));\n  }\n  return result;\n}\n\n/**\n * Recursively collect all leaf paths where two objects differ.\n */\nfunction diffPaths(base: unknown, changed: unknown, prefix: string): string[] {\n  const paths: string[] = [];\n\n  if (base === changed) return paths;\n  if (base === null || base === undefined || changed === null || changed === undefined) {\n    return [prefix];\n  }\n  if (typeof base !== 'object' || typeof changed !== 'object') {\n    return [prefix];\n  }\n  if (Array.isArray(base) || Array.isArray(changed)) {\n    if (JSON.stringify(base) !== JSON.stringify(changed)) {\n      return [prefix];\n    }\n    return paths;\n  }\n\n  const baseObj = base as Record<string, unknown>;\n  const changedObj = changed as Record<string, unknown>;\n  const allKeys = new Set([...Object.keys(baseObj), ...Object.keys(changedObj)]);\n\n  for (const key of allKeys) {\n    const childPath = prefix ? `${prefix}.${key}` : key;\n    if (!(key in baseObj)) {\n      paths.push(childPath);\n    } else if (!(key in changedObj)) {\n      paths.push(childPath);\n    } else {\n      paths.push(...diffPaths(baseObj[key], changedObj[key], childPath));\n    }\n  }\n\n  return paths;\n}\n\nfunction getAtPath(obj: unknown, path: string): unknown {\n  const parts = path.split('.');\n  let current: unknown = obj;\n  for (const part of parts) {\n    if (current === null || current === undefined || typeof current !== 'object') {\n      return undefined;\n    }\n    current = (current as Record<string, unknown>)[part];\n  }\n  return current;\n}\n\nfunction setAtPath(obj: object, path: string, value: unknown): void {\n  const parts = path.split('.');\n  let current: Record<string, unk