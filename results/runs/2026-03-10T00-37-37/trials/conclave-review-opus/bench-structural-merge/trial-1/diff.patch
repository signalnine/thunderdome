baseDoc.content : null;\n      const ourContent = ourDoc && !ourDoc.deleted ? ourDoc.content : null;\n      const theirContent = theirDoc && !theirDoc.deleted ? theirDoc.content : null;\n\n      const baseJson = JSON.stringify(baseContent);\n      const ourJson = JSON.stringify(ourContent);\n      const theirJson = JSON.stringify(theirContent);\n\n      if (ourJson === theirJson) {\n        continue;\n      }\n\n      if (ourJson === baseJson && theirJson === baseJson) {\n        continue;\n      }\n\n      hasChanges = true;\n\n      if (ourJson === baseJson) {\n        // Only theirs changed — fast-forward\n        if (theirContent === null) {\n          merged[docId] = {};\n        } else {\n          merged[docId] = clone(theirContent);\n        }\n        continue;\n      }\n\n      if (theirJson === baseJson) {\n        // Only ours changed — keep ours\n        if (ourContent !== null) {\n          merged[docId] = clone(ourContent);\n        }\n        continue;\n      }\n\n      // Both sides changed\n      if (ourContent === null && theirContent === null) {\n        // Both deleted\n        continue;\n      }\n\n      if (ourContent === null || theirContent === null) {\n        if (ourContent === null) {\n          conflicts.push({\n            documentId: docId,\n            path: '',\n            base: clone(baseContent),\n            ours: null,\n            theirs: clone(theirContent),\n          });\n          merged[docId] = {};\n        } else {\n          conflicts.push({\n            documentId: docId,\n            path: '',\n            base: clone(baseContent),\n            ours: clone(ourContent),\n            theirs: null,\n          });\n          merged[docId] = clone(ourContent);\n        }\n        continue;\n      }\n\n      // Both have content — structural three-way merge\n      const result = threeWayMerge(baseContent, ourContent, theirContent, docId);\n      merged[docId] = result.merged;\n      conflicts.push(...result.conflicts);\n    }\n\n    if (!hasChanges) {\n      return { merged: {}, conflicts: [], applied: true };\n    }\n\n    const applied = conflicts.length === 0;\n\n    if (applied) {\n      // Apply the merge to the current branch\n      for (const docId of Object.keys(merged)) {\n        const mergedContent = merged[docId];\n        const ourDoc = targetData.docs.get(docId);\n        const theirDoc = sourceData.docs.get(docId);\n        const baseDoc = ancestor.get(docId);\n\n        const theirDeleted = theirDoc ? theirDoc.deleted : true;\n        const baseExists = baseDoc && !baseDoc.deleted;\n\n        // If theirs deleted and ours didn't change from base, delete\n        if (theirDeleted && baseExists) {\n          const bJson = JSON.stringify(baseDoc!.content);\n          const oJson = ourDoc ? JSON.stringify(ourDoc.content) : null;\n          const ourDeleted = ourDoc ? ourDoc.deleted : true;\n          if (oJson === bJson || ourDeleted) {\n            if (ourDoc) {\n              ourDoc.deleted = true;\n              ourDoc.content = {};\n            }\n            continue;\n          }\n        }\n\n        if (ourDoc) {\n          if (!deepEqual(ourDoc.content, mergedContent)) {\n            const version: Version = {\n              id: this.nextVersionId(),\n              timestamp: Date.now(),\n              content: clone(mergedContent),\n            };\n            ourDoc.content = clone(mergedContent);\n            ourDoc.versions.push(version);\n            ourDoc.deleted = false;\n          }\n        } else {\n          const version: Version = {\n            id: this.nextVersionId(),\n            timestamp: Date.now(),\n            content: clone(mergedContent),\n          };\n          targetData.docs.set(docId, {\n            content: clone(mergedContent),\n            versions: [version],\n            deleted: false,\n          });\n        }\n      }\n\n      // Update the fork point on the source branch so subsequent merges\n      // use the current state as