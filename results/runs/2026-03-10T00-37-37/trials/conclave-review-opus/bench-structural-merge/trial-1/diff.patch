+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Nci1iDaXEiVqDwzE9np1Bu","type":"tool_result","content":"     1→export interface Version {\n     2→  id: string;\n     3→  timestamp: number;\n     4→  content: object;\n     5→}\n     6→\n     7→export interface MergeResult {\n     8→  merged: Record<string, object>;\n     9→  conflicts: Conflict[];\n    10→  applied: boolean;\n    11→}\n    12→\n    13→export interface Conflict {\n    14→  documentId: string;\n    15→  path: string;\n    16→  base: unknown;\n    17→  ours: unknown;\n    18→  theirs: unknown;\n    19→}\n    20→\n    21→interface DocState {\n    22→  content: object;\n    23→  versions: Version[];\n    24→  deleted: boolean;\n    25→}\n    26→\n    27→interface BranchData {\n    28→  docs: Map<string, DocState>;\n    29→  /** Snapshot of docs at branch creation time (the common ancestor for merges). */\n    30→  forkPoint: Map<string, DocState> | null;\n    31→  /** Name of the branch this was forked from (used for ancestor lookup). */\n    32→  parentBranch: string | null;\n    33→}\n    34→\n    35→function clone<T>(value: T): T {\n    36→  return JSON.parse(JSON.stringify(value));\n    37→}\n    38→\n    39→let versionCounter = 0;\n    40→function nextVersionId(): string {\n    41→  return `v${++versionCounter}`;\n    42→}\n    43→\n    44→function cloneDocState(state: DocState): DocState {\n    45→  return {\n    46→    content: clone(state.content),\n    47→    versions: state.versions.map(v => ({\n    48→      id: v.id,\n    49→      timestamp: v.timestamp,\n    50→      content: clone(v.content),\n    51→    })),\n    52→    deleted: state.deleted,\n    53→  };\n    54→}\n    55→\n    56→function cloneDocs(docs: Map<string, DocState>): Map<string, DocState> {\n    57→  const result = new Map<string, DocState>();\n    58→  for (const [id, state] of docs) {\n    59→    result.set(id, cloneDocState(state));\n    60→  }\n    61→  return result;\n    62→}\n    63→\n    64→/**\n    65→ * Recursively collect all leaf paths where two objects differ.\n    66→ */\n    67→function diffPaths(base: unknown, changed: unknown, prefix: string): string[] {\n    68→  const paths: string[] = [];\n    69→\n    70→  if (base === changed) return paths;\n    71→  if (base === null || base === undefined || changed === null || changed === undefined) {\n    72→    return [prefix];\n    73→  }\n    74→  if (typeof base !== 'object' || typeof changed !== 'object') {\n    75→    return [prefix];\n    76→  }\n    77→  if (Array.isArray(base) || Array.isArray(changed)) {\n    78→    if (JSON.stringify(base) !== JSON.stringify(changed)) {\n    79→      return [prefix];\n    80→    }\n    81→    return paths;\n    82→  }\n    83→\n    84→  const baseObj = base as Record<string, unknown>;\n    85→  const changedObj = changed as Record<string, unknown>;\n    86→  const allKeys = new Set([...Object.keys(baseObj), ...Object.keys(changedObj)]);\n    87→\n    88→  for (const key of allKeys) {\n    89→    const childPath = prefix ? `${prefix}.${key}` : key;\n    90→    if (!(key in baseObj)) {\n    91→      paths.push(childPath);\n    92→    } else if (!(key in changedObj)) {\n    93→      paths.push(childPath);\n    94→    } else {\n    95→      paths.push(...diffPaths(baseObj[key], changedObj[key], childPath));\n    96→    }\n    97→  }\n    98→\n    99→  return paths;\n   100→}\n   101→\n   102→function getAtPath(obj: unknown, path: string): unknown {\n   103→  const parts = path.split('.');\n   104→  let current: unknown = obj;\n   105→  for (const part of parts) {\n   106→    if (current === null || current === undefined || typeof current !== 'object') {\n   107→      return undefined;\n   108→    }\n   109→    current = (current as Record<string, unknown>)[part];\n   110→  }\n   111→  return current;\n   112→}\n   113→\n   114→function setAtPath(obj: object, path: string, value: unknown): void {\n   115→  const parts = path.split('.');\n   116→  let current: Record<string, unknown> = obj as Record<string, unknown>;\n   117→  for (let i = 0; i < parts.length - 1; i++) {\n   118→    if (!(parts[i] in current) || current[parts[i]] === null || typeof current[parts[i]] !== 'object') {\n   119→      current[parts[i]] = {};\n   120→    }\n   121→    current = current[parts[i]] as Record<string, unknown>;\n   122→  }\n   123→  current[parts[parts.length - 1]] = value;\n   124→}\n   125→\n   126→function deleteAtPath(obj: object, path: string): void {\n   127→  const parts = path.split('.');\n   128→  let current: Record<string, unknown> = obj as Record<string, unknown>;\n   129→  for (let i = 0; i < parts.length - 1; i++) {\n   130→    if (!(parts[i] in current) || current[parts[i]] === null || typeof current[parts[i]] !== 'object') {\n   131→      return;\n   132→    }\n   133→    current = current[parts[i]] as Record<string, unknown>;\n   134→  }\n   135→  delete current[parts[parts.length - 1]];\n   136→}\n   137→\n   138→function deepEqual(a: unknown, b: unknown): boolean {\n   139→  return JSON.stringify(a) === JSON.stringify(b);\n   140→}\n   141→\n   142→/**\n   143→ * Three-way merge of a single document.\n   144→ * Returns the merged content and any conflicts.\n   145→ */\n   146→function threeWayMerge(\n   147→  base: object | null,\n   148→  ours: object | null,\n   149→  theirs: object | null,\n   150→  documentId: string,\n   151→): { merged: object; conflicts: Conflict[] } {\n   152→  const baseObj = base ?? {};\n   153→  const oursObj = ours ?? {};\n   154→  const theirsObj = theirs ?? {};\n   155→\n   156→  const ourChanges = diffPaths(baseObj, oursObj, '');\n   157→  const theirChanges = diffPaths(baseObj, theirsObj, '');\n   158→\n   159→  const conflicts: Conflict[] = [];\n   160→  const merged = clone(oursObj);\n   161→\n   162→  // Apply their changes that don't conflict\n   163→  const ourChangeSet = new Set(ourChanges);\n   164→\n   165→  for (const path of theirChanges) {\n   166→    const baseVal = getAtPath(baseObj, path);\n   167→    const ourVal = getAtPath(oursObj, path);\n   168→    const theirVal = getAtPath(theirsObj, path);\n   169→\n   170→    if (ourChangeSet.has(path)) {\n   171→      // Both sides changed this path\n   172→      if (deepEqual(ourVal, theirVal)) {\n   173→        // Same change — no conflict\n   174→        continue;\n   175→      }\n   176→      // Conflict: both changed to different values\n   177→      conflicts.push({\n   178→        documentId,\n   179→        path,\n   180→        base: clone(baseVal),\n   181→        ours: clone(ourVal),\n   182→        theirs: clone(theirVal),\n   183→      });\n   184→      // merged already has \"ours\" value\n   185→    } else {\n   186→      // Only theirs changed — apply their change\n   187→      const theirValInObj = getAtPath(theirsObj, path);\n   188→      // Check if the key was deleted in theirs\n   189→      if (theirValInObj === undefined && !(path in flatKeys(theirsObj, ''))) {\n   190→        deleteAtPath(merged, path);\n   191→      } else {\n   192→        setAtPath(merged, path, clone(theirValInObj));\n   193→      }\n   194→    }\n   195→  }\n   196→\n   197→  return { merged, conflicts };\n   198→}\n   199→\n   200→/**\n   201→ * Collect all dot-paths present in an object (leaf-level only if value is primitive,\n   202→ * but also intermediate paths for checking existence).\n   203→ */\n   204→function flatKeys(obj: unknown, prefix: string): Set<string> {\n   205→  const keys = new Set<string>();\n   206→  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {\n   207→    if (prefix) keys.add(prefix);\n   208→    return keys;\n   209→  }\n   210→  const record = obj as Record<string, unknown>;\n   211→  for (const key of Object.keys(record)) {\n   212→    const path = prefix ? `${prefix}.${key}` : key;\n   213→    keys.add(path);\n   214→    const sub = flatKeys(record[key], path);\n   215→    for (const s of sub) keys.add(s);\n   216→  }\n   217→  return keys;\n   218→}\n   219→\n   220→export class DocumentStore {\n   221→  private branches: Map<string, BranchData> = new Map();\n   222→  private currentBranch: string = 'main';\n   223→\n   224→  constructor() {\n   225→    this.branches.set('main', {\n   226→      docs: new Map(),\n   227→      forkPoint: null,\n   228→      parentBranch: null,\n   229→    });\n   230→  }\n   231→\n   232→  private getBranchData(name?: string): BranchData {\n   233→    const branchName = name ?? this.currentBranch;\n   234→    const branch = this.branches.get(branchName);\n   235→    if (!branch) {\n   236→      throw new Error(`Branch \"${branchName}\" does not exist`);\n   237→    }\n   238→    return branch;\n   239→  }\n   240→\n   241→  // ---- Document CRUD ----\n   242→\n   243→  create(id: string, content: object): void {\n   244→    const branch = this.getBranchData();\n   245→    const existing = branch.docs.get(id);\n   246→    if (existing && !existing.deleted) {\n   247→      throw new Error(`Document \"${id}\" already exists`);\n   248→    }\n   249→    const version: Version = {\n   250→      id: nextVersionId(),\n   251→      timestamp: Date.now(),\n   252→      content: clone(content),\n   253→    };\n   254→    branch.docs.set(id, {\n   255→      content: clone(content),\n   256→      versions: existing?.deleted ? [...existing.versions, version] : [version],\n   257→      deleted: false,\n   258→    });\n   259→  }\n   260→\n   261→  get(id: string): object {\n   262→    const branch = this.getBranchData();\n   263→    const doc = branch.docs.get(id);\n   264→    if (!doc || doc.deleted) {\n   265→      throw new Error(`Document \"${id}\" does not exist`);\n   266→    }\n   267→    return clone(doc.content);\n   268→  }\n   269→\n   270→  update(id: string, content: object): void {\n   271→    const branch = this.getBranchData();\n   272→    const doc = branch.docs.get(id);\n   273→    if (!doc || doc.deleted) {\n   274→      throw new Error(`Document \"${id}\" does not exist`);\n   275→    }\n   276→    const version: Version = {\n   277→      id: nextVersionId(),\n   278→      timestamp: Date.now(),\n   279→      content: clone(content),\n   280→    };\n   281→    doc.content = clone(content);\n   282→    doc.versions.push(version);\n   283→  }\n   284→\n   285→  delete(id: string): void {\n   286→    const branch = this.getBranchData();\n   287→    const doc = branch.docs.get(id);\n   288→    if (!doc || doc.deleted) {\n   289→      throw new Error(`Document \"${id}\" does not exist`);\n   290→    }\n   291→    doc.deleted = true;\n   292→    doc.content = {};\n   293→  }\n   294→\n   295→  // ---- Version History ----\n   296→\n   297→  getHistory(id: string): Version[] {\n   298→    const branch = this.getBranchData();\n   299→    const doc = branch.docs.get(id);\n   300→    if (!doc) {\n   301→      throw new Error(`Document \"${id}\" does not exist`);\n   302→    }\n   303→    return doc.versions.map(v => ({\n   304→      id: v.id,\n   305→      timestamp: v.timestamp,\n   306→      content: clone(v.content),\n   307→    }));\n   308→  }\n   309→\n   310→  getVersion(id: string, versionId: string): object {\n   311→    const branch = this.getBranchData();\n   312→    const doc = branch.docs.get(id);\n   313→    if (!doc) {\n   314→      throw new Error(`Document \"${id}\" does not exist`);\n   315→    }\n   316→    const version = doc.versions.find(v => v.id === versionId);\n   317→    if (!version) {\n   318→      throw new Error(`Version \"${versionId}\" does not exist for document \"${id}\"`);\n   319→    }\n   320→    return clone(version.content);\n   321→  }\n   322→\n   323→  // ---- Branching ----\n   324→\n   325→  createBranch(name: string, fromBranch?: string): void {\n   326→    if (this.branches.has(name)) {\n   327→      throw new Error(`Branch \"${name}\" already exists`);\n   328→    }\n   329→    const sourceName = fromBranch ?? this.currentBranch;\n   330→    const source = this.getBranchData(sourceName);\n   331→    this.branches.set(name, {\n   332→      docs: cloneDocs(source.docs),\n   333→      forkPoint: cloneDocs(source.docs),\n   334→      parentBranch: sourceName,\n   335→    });\n   336→    // Also record the fork point on the source branch if it doesn't have one yet\n   337→    // We need to store the fork point per-branch-pair, so we store it on the new branch\n   338→  }\n   339→\n   340→  switchBranch(name: string): void {\n   341→    if (!this.branches.has(name)) {\n   342→      throw new Error(`Branch \"${name}\" does not exist`);\n   343→    }\n   344→    this.currentBranch = name;\n   345→  }\n   346→\n   347→  getBranch(): string {\n   348→    return this.currentBranch;\n   349→  }\n   350→\n   351→  listBranches(): string[] {\n   352→    return Array.from(this.branches.keys());\n   353→  }\n   354→\n   355→  // ---- Merging ----\n   356→\n   357→  merge(sourceBranch: string): MergeResult {\n   358→    const targetData = this.getBranchData();\n   359→    const sourceData = this.getBranchData(sourceBranch);\n   360→\n   361→    // Find common ancestor: the fork point of the source branch\n   362→    // This is the state of the parent at the time the source branch was created\n   363→    const ancestor = this.findCommonAncestor(sourceBranch, this.currentBranch);\n   364→\n   365→    // Collect all document IDs across all three states\n   366→    const allDocIds = new Set<string>();\n   367→    for (const id of ancestor.keys()) allDocIds.add(id);\n   368→    for (const id of targetData.docs.keys()) allDocIds.add(id);\n   369→    for (const id of sourceData.docs.keys()) allDocIds.add(id);\n   370→\n   371→    const merged: Record<string, object> = {};\n   372→    const conflicts: Conflict[] = [];\n   373→    let hasChanges = false;\n   374→\n   375→    for (const docId of allDocIds) {\n   376→      const baseDoc = ancestor.get(docId);\n   377→      const ourDoc = targetData.docs.get(docId);\n   378→      const theirDoc = sourceData.docs.get(docId);\n   379→\n   380→      const baseContent = baseDoc && !baseDoc.deleted ? baseDoc.content : null;\n   381→      const ourContent = ourDoc && !ourDoc.deleted ? ourDoc.content : null;\n   382→      const theirContent = theirDoc && !theirDoc.deleted ? theirDoc.content : null;\n   383→\n   384→      // If nothing changed on either side for this doc, skip it\n   385→      const baseJson = JSON.stringify(baseContent);\n   386→      const ourJson = JSON.stringify(ourContent);\n   387→      const theirJson = JSON.stringify(theirContent);\n   388→\n   389→      if (ourJson === theirJson) {\n   390→        // Both sides are the same — no merge needed for this doc\n   391→        continue;\n   392→      }\n   393→\n   394→      if (ourJson === baseJson && theirJson === baseJson) {\n   395→        // No changes on either side\n   396→        continue;\n   397→      }\n   398→\n   399→      hasChanges = true;\n   400→\n   401→      if (ourJson === baseJson) {\n   402→        // Only theirs changed — fast-forward\n   403→        if (theirContent === null) {\n   404→          // They deleted the doc\n   405→          merged[docId] = {};\n   406→        } else {\n   407→          merged[docId] = clone(theirContent);\n   408→        }\n   409→        continue;\n   410→      }\n   411→\n   412→      if (theirJson === baseJson) {\n   413→        // Only ours changed — keep ours (already in target)\n   414→        if (ourContent !== null) {\n   415→          merged[docId] = clone(ourContent);\n   416→        }\n   417→        continue;\n   418→      }\n   419→\n   420→      // Both sides changed — need three-way merge\n   421→      if (ourContent === null && theirContent === null) {\n   422→        // Both deleted — no conflict\n   423→        continue;\n   424→      }\n   425→\n   426→      if (ourContent === null || theirContent === null) {\n   427→        // One side deleted, other modified — conflict on the whole document\n   428→        // Treat as conflict at root level\n   429→        if (ourContent === null) {\n   430→          // We deleted, they modified\n   431→          conflicts.push({\n   432→            documentId: docId,\n   433→            path: '',\n   434→            base: clone(baseContent),\n   435→            ours: null,\n   436→            theirs: clone(theirContent),\n   437→          });\n   438→          merged[docId] = {}; // \"ours\" is deletion\n   439→        } else {\n   440→          // They deleted, we modified\n   441→          conflicts.push({\n   442→            documentId: docId,\n   443→            path: '',\n   444→            base: clone(baseContent),\n   445→            ours: clone(ourContent),\n   446→            theirs: null,\n   447→          });\n   448→          merged[docId] = clone(ourContent); // favor ours\n   449→        }\n   450→        continue;\n   451→      }\n   452→\n   453→      // Both have content — structural three-way merge\n   454→      const result = threeWayMerge(baseContent, ourContent, theirContent, docId);\n   455→      merged[docId] = result.merged;\n   456→      conflicts.push(...result.conflicts);\n   457→    }\n   458→\n   459→    if (!hasChanges) {\n   460→      return { merged: {}, conflicts: [], applied: true };\n   461→    }\n   462→\n   463→    const applied = conflicts.length === 0;\n   464→\n   465→    if (applied) {\n   466→      // Apply the merge to the current branch\n   467→      for (const docId of Object.keys(merged)) {\n   468→        const mergedContent = merged[docId];\n   469→        const ourDoc = targetData.docs.get(docId);\n   470→        const theirDoc = sourceData.docs.get(docId);\n   471→        const baseDoc = ancestor.get(docId);\n   472→\n   473→        // Determine if the doc should be deleted\n   474→        const theirDeleted = theirDoc ? theirDoc.deleted : true;\n   475→        const ourDeleted = ourDoc ? ourDoc.deleted : true;\n   476→        const baseExists = baseDoc && !baseDoc.deleted;\n   477→\n   478→        // If theirs deleted and ours didn't change from base, delete\n   479→        if (theirDeleted && baseExists) {\n   480→          const baseJson = JSON.stringify(baseDoc!.content);\n   481→          const ourJson = ourDoc ? JSON.stringify(ourDoc.content) : null;\n   482→          if (ourJson === baseJson || ourDeleted) {\n   483→            if (ourDoc) {\n   484→              ourDoc.deleted = true;\n   485→              ourDoc.content = {};\n   486→            }\n   487→            continue;\n   488→          }\n   489→        }\n   490→\n   491→        if (ourDoc) {\n   492→          // Update existing doc\n   493→          if (!deepEqual(ourDoc.content, mergedContent)) {\n   494→            const version: Version = {\n   495→              id: nextVersionId(),\n   496→              timestamp: Date.now(),\n   497→              content: clone(mergedContent),\n   498→            };\n   499→            ourDoc.content = clone(mergedContent);\n   500→            ourDoc.versions.push(version);\n   501→            ourDoc.deleted = false;\n   502→          }\n   503→        } else {\n   504→          // New doc from source branch\n   505→          const version: Version = {\n   506→            id: nextVersionId(),\n   507→            timestamp: Date.now(),\n   508→            content: clone(mergedContent),\n   509→          };\n   510→          targetData.docs.set(docId, {\n   511→            content: clone(mergedContent),\n   512→            versions: [version],\n   513→            deleted: false,\n   514→          });\n   515→        }\n   516→      }\n   517→    }\n   518→\n   519→    return { merged, conflicts, applied };\n   520→  }\n   521→\n   522→  private findCommonAncestor(branchA: string, branchB: string): Map<string, DocState> {\n   523→    // The common ancestor is the fork point.\n   524→    // If branchA was forked from branchB (or vice versa), use the fork point.\n   525→    const dataA = this.getBranchData(branchA);\n   526→    const dataB = this.getBranchData(branchB);\n   527→\n   528→    if (dataA.parentBranch === branchB && dataA.forkPoint) {\n   529→      return dataA.forkPoint;\n   530→    }\n   531→    if (dataB.parentBranch === branchA && dataB.forkPoint) {\n   532→      return dataB.forkPoint;\n   533→    }\n   534→\n   535→    // If neither is a direct parent, find common ancestor through parent chain\n   536→    // For simplicity, walk up branch A's parent chain and find intersection with B's parent chain\n   537→    const aAncestors = this.getAncestorChain(branchA);\n   538→    const bAncestors = this.getAncestorChain(branchB);\n   539→\n   540→    for (const ancestor of aAncestors) {\n   541→      if (bAncestors.includes(ancestor)) {\n   542→        // Found common ancestor branch\n   543→        // The fork point would be the older fork point\n   544→        const aData = this.getBranchData(branchA);\n   545→        if (aData.forkPoint) return aData.forkPoint;\n   546→        break;\n   547→      }\n   548→    }\n   549→\n   550→    // Fallback: empty state (as if both diverged from nothing)\n   551→    return new Map();\n   552→  }\n   553→\n   554→  private getAncestorChain(branchName: string): string[] {\n   555→    const chain: string[] = [branchName];\n   556→    let current = branchName;\n   557→    let data = this.branches.get(current);\n   558→    while (data && data.parentBranch) {\n   559→      chain.push(data.parentBranch);\n   560→      current = data.parentBranch;\n   561→      data = this.branches.get(current);\n   562→    }\n   563→    return chain;\n   564→  }\n   565→}\n   566→"}]},"parent_tool_use_id":"toolu_011aSojzmzTdxCMohV4uasny","session_id":"0d5674de-076a-4f1f-812c-af9859c500ee","uuid":"83ddf86d-6bfc-47a8-8499-cb78f1740950"}
