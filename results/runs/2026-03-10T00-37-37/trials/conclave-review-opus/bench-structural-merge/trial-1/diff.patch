ter forward merge ===\");\nconst store2 = new DocumentStore();\nstore2.create('doc1', { a: 1 });\nstore2.createBranch('feature');\n\nstore2.switchBranch('feature');\nstore2.update('doc1', { a: 2 });\n\nstore2.switchBranch('main');\nstore2.merge('feature'); // main gets a=2\n\n// Now change main\nstore2.update('doc1', { a: 3 });\n\n// Try to merge main into feature\nstore2.switchBranch('feature');\ntry {\n  const r2 = store2.merge('main');\n  console.log(\"Reverse merge applied:\", r2.applied);\n  console.log(\"Reverse merge conflicts:\", r2.conflicts.length);\n  console.log(\"Reverse merge result:\", JSON.stringify(store2.get('doc1')));\n  // feature's forkPoint records main at {a:1}. main's forkPoint is null (it's the root).\n  // findCommonAncestor('main', 'feature'): \n  //   dataA (main).parentBranch is null, dataB (feature).parentBranch is 'main'\n  //   So dataB.parentBranch === 'main' (branchA), uses feature.forkPoint = {a:1}\n  //   base = {a: 1}, ours (feature) = {a: 2}, theirs (main) = {a: 3}\n  //   Both changed 'a' -> CONFLICT (but ours=2 came from the same source as main's merge)\n  // This is expected in a simple fork-point model, but it's a known limitation\n} catch (e: any) {\n  console.log(\"ERROR:\", e.message);\n}\n\n// Test: getHistory allows getting history of deleted doc\nconsole.log(\"\\n=== Test: getHistory on deleted doc ===\");\nconst store3 = new DocumentStore();\nstore3.create('doc1', { a: 1 });\nstore3.update('doc1', { a: 2 });\nstore3.delete('doc1');\ntry {\n  const h = store3.getHistory('doc1');\n  console.log(\"getHistory on deleted doc works:\", h.length, \"versions\");\n  // The spec says \"getHistory(id) returns versions\" - doesn't say it should throw on deleted\n  // But get() throws on deleted. This could be intentional.\n} catch (e: any) {\n  console.log(\"getHistory on deleted doc throws:\", e.message);\n}\n\n// Test: delete doesn't create a version\nconsole.log(\"\\n=== Test: delete doesn't create version ===\");\nconst store4 = new DocumentStore();\nstore4.create('doc1', { a: 1 });\nstore4.update('doc1', { a: 2 });\nconsole.log(\"Versions before delete:\", store4.getHistory('doc1').length); // 2\nstore4.delete('doc1');\n// Can't call getHistory on deleted doc... or can we?\n// Actually from above test it seems we can\nconst store5 = new DocumentStore();\nstore5.create('doc1', { a: 1 });\nconst preDeleteHistory = store5.getHistory('doc1');\nconsole.log(\"Versions before delete:\", preDeleteHistory.length);\n\nTESTEOF\nnpx tsx /tmp/edge_case_tests4.ts 2>&1","description":"Test fork point staleness and reverse merge scenarios","timeout":30000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1787,"cache_read_input_tokens":31207,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1787},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_011aSojzmzTdxCMohV4uasny","session_id":"0d5674de-076a-4f1f-812c-af9859c500ee","uuid":"ad97da24-a8f1-4a64-ba46-7bd4c1458743"}
