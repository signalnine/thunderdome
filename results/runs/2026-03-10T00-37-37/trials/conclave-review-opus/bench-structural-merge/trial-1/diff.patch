+        const theirDeleted = theirDoc ? theirDoc.deleted : true;
+        const baseExists = baseDoc && !baseDoc.deleted;
+
+        // If theirs deleted and ours didn't change from base, delete
+        if (theirDeleted && baseExists) {
+          const bJson = JSON.stringify(baseDoc!.content);
+          const oJson = ourDoc ? JSON.stringify(ourDoc.content) : null;
+          const ourDeleted = ourDoc ? ourDoc.deleted : true;
+          if (oJson === bJson || ourDeleted) {
+            if (ourDoc) {
+              ourDoc.deleted = true;
+              ourDoc.content = {};
+            }
+            continue;
+          }
+        }
+
+        if (ourDoc) {
+          if (!deepEqual(ourDoc.content, mergedContent)) {
+            const version: Version = {
+              id: this.nextVersionId(),
+              timestamp: Date.now(),
+              content: clone(mergedContent),
+            };
+            ourDoc.content = clone(mergedContent);
+            ourDoc.versions.push(version);
+            ourDoc.deleted = false;
+          }
+        } else {
+          const version: Version = {
+            id: this.nextVersionId(),
+            timestamp: Date.now(),
+            content: clone(mergedContent),
+          };
+          targetData.docs.set(docId, {
+            content: clone(mergedContent),
+            versions: [version],
+            deleted: false,
+          });
+        }
+      }
+
+      // Update the fork point on the source branch so subsequent merges
+      // use the current state as the new common ancestor
+      sourceData.forkPoint = cloneDocs(targetData.docs);
+      sourceData.parentBranch = this.currentBranch;
+    }
+
+    return { merged, conflicts, applied };
+  }
+
+  private findCommonAncestor(branchA: string, branchB: string): Map<string, DocState> {
+    const dataA = this.getBranchData(branchA);
+    const dataB = this.getBranchData(branchB);
+
+    if (dataA.parentBranch === branchB && dataA.forkPoint) {
+      return dataA.forkPoint;
+    }
+    if (dataB.parentBranch === branchA && dataB.forkPoint) {
+      return dataB.forkPoint;
+    }
+
+    // Walk up parent chains to find common ancestor
+    const aAncestors = this.getAncestorChain(branchA);
+    const bAncestors = this.getAncestorChain(branchB);
+
+    for (const anc of aAncestors) {
+      if (bAncestors.includes(anc)) {
+        const aData = this.getBranchData(branchA);
+        if (aData.forkPoint) return aData.forkPoint;
+        break;
+      }
+    }
+
+    return new Map();
+  }
+
+  private getAncestorChain(branchName: string): string[] {
+    const chain: string[] = [branchName];
+    let current = branchName;
+    let data = this.branches.get(current);
+    while (data && data.parentBranch) {
+      chain.push(data.parentBranch);
+      current = data.parentBranch;
+      data = this.branches.get(current);
+    }
+    return chain;
+  }
+}
