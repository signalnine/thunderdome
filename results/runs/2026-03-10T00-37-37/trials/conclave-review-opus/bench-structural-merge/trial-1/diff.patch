i < parts.length - 1; i++) {\n    if (!(parts[i] in current) || current[parts[i]] === null || typeof current[parts[i]] !== 'object') {\n      return;\n    }\n    current = current[parts[i]] as Record<string, unknown>;\n  }\n  delete current[parts[parts.length - 1]];\n}\n\nfunction deepEqual(a: unknown, b: unknown): boolean {\n  return JSON.stringify(a) === JSON.stringify(b);\n}\n\n/**\n * Three-way merge of a single document.\n * Returns the merged content and any conflicts.\n */\nfunction threeWayMerge(\n  base: object | null,\n  ours: object | null,\n  theirs: object | null,\n  documentId: string,\n): { merged: object; conflicts: Conflict[] } {\n  const baseObj = base ?? {};\n  const oursObj = ours ?? {};\n  const theirsObj = theirs ?? {};\n\n  const ourChanges = diffPaths(baseObj, oursObj, '');\n  const theirChanges = diffPaths(baseObj, theirsObj, '');\n\n  const conflicts: Conflict[] = [];\n  const merged = clone(oursObj);\n\n  // Apply their changes that don't conflict\n  const ourChangeSet = new Set(ourChanges);\n\n  for (const path of theirChanges) {\n    const baseVal = getAtPath(baseObj, path);\n    const ourVal = getAtPath(oursObj, path);\n    const theirVal = getAtPath(theirsObj, path);\n\n    if (ourChangeSet.has(path)) {\n      // Both sides changed this path\n      if (deepEqual(ourVal, theirVal)) {\n        // Same change — no conflict\n        continue;\n      }\n      // Conflict: both changed to different values\n      conflicts.push({\n        documentId,\n        path,\n        base: clone(baseVal),\n        ours: clone(ourVal),\n        theirs: clone(theirVal),\n      });\n      // merged already has \"ours\" value\n    } else {\n      // Only theirs changed — apply their change\n      const theirValInObj = getAtPath(theirsObj, path);\n      // Check if the key was deleted in theirs\n      if (theirValInObj === undefined && !(path in flatKeys(theirsObj, ''))) {\n        deleteAtPath(merged, path);\n      } else {\n        setAtPath(merged, path,