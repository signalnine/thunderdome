+  let current: unknown = obj;
+  for (let i = 0; i < parts.length; i++) {
+    if (current === null || current === undefined || typeof current !== 'object') {
+      return false;
+    }
+    const rec = current as Record<string, unknown>;
+    if (!(parts[i] in rec)) {
