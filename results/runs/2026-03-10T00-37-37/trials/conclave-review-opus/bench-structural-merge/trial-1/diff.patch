 id: v.id,\n      timestamp: v.timestamp,\n      content: clone(v.content),\n    })),\n    deleted: state.deleted,\n  };\n}\n\nfunction cloneDocs(docs: Map<string, DocState>): Map<string, DocState> {\n  const result = new Map<string, DocState>();\n  for (const [id, state] of docs) {\n    result.set(id, cloneDocState(state));\n  }\n  return result;\n}\n\nfunction diffPaths(base: unknown, changed: unknown, prefix: string): string[] {\n  const paths: string[] = [];\n\n  if (base === changed) return paths;\n  if (base === null || base === undefined || changed === null || changed === undefined) {\n    return [prefix];\n  }\n  if (typeof base !== 'object' || typeof changed !== 'object') {\n    return [prefix];\n  }\n  if (Array.isArray(base) || Array.isArray(changed)) {\n    if (JSON.stringify(base) !== JSON.stringify(changed)) {\n      return [prefix];\n    }\n    return paths;\n  }\n\n  const baseObj = base as Record<string, unknown>;\n  const changedObj = changed as Record<string, unknown>;\n  const allKeys = new Set([...Object.keys(baseObj), ...Object.keys(changedObj)]);\n\n  for (const key of allKeys) {\n    const childPath = prefix ? `${prefix}.${key}` : key;\n    if (!(key in baseObj)) {\n      paths.push(childPath);\n    } else if (!(key in changedObj)) {\n      paths.push(childPath);\n    } else {\n      paths.push(...diffPaths(baseObj[key], changedObj[key], childPath));\n    }\n  }\n\n  return paths;\n}\n\nfunction getAtPath(obj: unknown, path: string): unknown {\n  if (path === '') return obj;\n  const parts = path.split('.');\n  let current: unknown = obj;\n  for (const part of parts) {\n    if (current === null || current === undefined || typeof current !== 'object') {\n      return undefined;\n    }\n    current = (current as Record<string, unknown>)[part];\n  }\n  return current;\n}\n\nfunction setAtPath(obj: object, path: string, value: unknown): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj as Record<string, unknown>;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (!(parts[i] in current) || current[parts[i]] === null || typeof current[parts[i]] !== 'object') {\n      current[parts[i]] = {};\n    }\n    current = current[parts[i]] as Record<string, unknown>;\n  }\n  current[parts[parts.length - 1]] = value;\n}\n\nfunction deleteAtPath(obj: object, path: string): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj as Record<string, unknown>;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (!(parts[i] in current) || current[parts[i]] === null || typeof current[parts[i]] !== 'object') {\n      return;\n    }\n    current = current[parts[i]] as Record<string, unknown>;\n  }\n  delete current[parts[parts.length - 1]];\n}\n\nfunction deepEqual(a: unknown, b: unknown): boolean {\n  if (a === b) return true;\n  if (a === null || a === undefined || b === null || b === undefined) return a === b;\n  if (typeof a !== typeof b) return false;\n  if (typeof a !== 'object') return a === b;\n  if (Array.isArray(a) !== Array.isArray(b)) return false;\n  if (Array.isArray(a) && Array.isArray(b)) {\n    if (a.length !== b.length) return false;\n    return a.every((val, i) => deepEqual(val, b[i]));\n  }\n  const aObj = a as Record<string, unknown>;\n  const bObj = b as Record<string, unknown>;\n  const aKeys = Object.keys(aObj);\n  const bKeys = Object.keys(bObj);\n  if (aKeys.length !== bKeys.length) return false;\n  return aKeys.every(key => key in bObj && deepEqual(aObj[key], bObj[key]));\n}\n\nfunction hasKeyAtPath(obj: unknown, path: string): boolean {\n  if (path === '') return true;\n  const parts = path.split('.');\n  let current: unknown = obj;\n  for (let i = 0; i < parts.length; i++) {\n    if (current === null || current === undefined || typeof current !== 'object') {\n      return false;\n    }\n    const rec = current as Record<string, unknown>;\n    if (!(parts[i] in rec)) {\n      return false;\n    }\n    current = rec[parts[i]];\n  }\n  return true;\n}\n\n/**\n * Check if path `a` is a prefix of path `b` or vice versa.\n * \"config\" is a prefix of \"config.theme\", but not of \"config2\".\n */\nfunction pathsOverlap(a: string, b: string): boolean {\n  if (a === b) return true;\n  if (a === '' || b === '') return true;\n  return b.startsWith(a + '.') || a.startsWith(b + '.');\n}\n\n/**\n * Three-way merge of a single document.\n */\nfunction threeWayMerge(\n  base: object | null,\n  ours: object | null,\n  theirs: object | null,\n  documentId: string,\n): { merged: object; conflicts: Conflict[] } {\n  const baseObj = base ?? {};\n  const oursObj = ours ?? {};\n  const theirsObj = theirs ?? {};\n\n  const ourChanges = diffPaths(baseObj, oursObj, '');\n  const theirChanges = diffPaths(baseObj, theirsObj, '');\n\n  const conflicts: Conflict[] = [];\n  const merged = clone(oursObj);\n\n  // Track which their-changes have been handled as conflicts\n  const handledTheirPaths = new Set<string>();\n\n  // Check for overlapping paths between our changes and their changes\n  for (const theirPath of theirChanges) {\n    for (const ourPath of ourChanges) {\n      if (pathsOverlap(ourPath, theirPath)) {\n        // These paths overlap — check if it's a conflict\n        // Use the more specific (longer) path for the conflict if they differ\n        const conflictPath = ourPath === theirPath ? ourPath : (ourPath.length < theirPath.length ? ourPath : theirPath);\n        // Actually, if the paths differ, we should use the coarser (shorter) path\n        // because one side changed a subtree and the other changed the parent\n        const coarsePath = ourPath.length <= theirPath.length ? ourPath : theirPath;\n\n        const baseVal = getAtPath(baseObj, coarsePath);\n        const ourVal = getAtPath(oursObj, coarsePath);\n        const theirVal = getAtPath(theirsObj, coarsePath);\n\n        if (deepEqual(ourVal, theirVal)) {\n          // Same effective change — no conflict\n          handledTheirPaths.add(theirPath);\n          continue;\n        }\n\n        if (ourPath === theirPath) {\n          // Exact same path changed differently — conflict\n          conflicts.push({\n            documentId,\n            path: ourPath,\n            base: clone(baseVal),\n            ours: clone(ourVal),\n            theirs: clone(theirVal),\n          });\n          handledTheirPaths.add(theirPath);\n        } else {\n          // Overlapping but different paths — structural conflict at the coarser path\n          conflicts.push({\n            documentId,\n            path: coarsePath,\n            base: clone(getAtPath(baseObj, coarsePath)),\n            ours: clone(getAtPath(oursObj, coarsePath)),\n            theirs: clone(getAtPath(theirsObj, coarsePath)),\n          });\n          handledTheirPaths.add(theirPath);\n        }\n        break; // Only need to find one overlap per their-path\n      }\n    }\n  }\n\n  // Apply non-conflicting their-changes\n  for (const path of theirChanges) {\n    if (handledTheirPaths.has(path)) continue;\n\n    const theirVal = getAtPath(theirsObj, path);\n    if (theirVal === undefined && !hasKeyAtPath(theirsObj, path)) {\n      deleteAtPath(merged, path);\n    } else {\n      setAtPath(merged, path, clone(theirVal));\n    }\n  }\n\n  return { merged, conflicts };\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = 'main';\n  private versionCounter: number = 0;\n\n  constructor() {\n    this.branches.set('main', {\n      docs: new Map(),\n      forkPoint: null,\n      parentBranch: null,\n    });\n  }\n\n  private nextVersionId(): string {\n    return `v${++this.versionCounter}`;\n  }\n\n  private getBranchData(name?: string): BranchData {\n    const branchName = name ?? this.currentBranch;\n    const branch = this.branches.get(branchName);\n    if (!branch) {\n      throw new Error(`Branch \"${branchName}\" does not exist`);\n    }\n    return branch;\n  }\n\n  // ---- Document CRUD ----\n\n  create(id: string, content: object): void {\n    const branch = this.getBranchData();\n    const existing = branch.docs.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n    const version: Version = {\n      id: this.nextVersionId(),\n      timestamp: Date.now(),\n      content: clone(content),\n    };\n    branch.docs.set(id, {\n      content: clone(content),\n      versions: existing?.deleted ? [...existing.versions, version] : [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getBranchData();\n    const doc = branch.docs.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    return clone(doc.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getBranchData();\n    const doc = branch.docs.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    const version: Version = {\n      id: this.nextVersionId(),\n      timestamp: Date.now(),\n      content: clone(content),\n    };\n    doc.content = clone(content);\n    doc.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getBranchData();\n    const doc = branch.docs.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    doc.deleted = true;\n    doc.content = {};\n  }\n\n  // ---- Version History ----\n\n  getHistory(id: string): Version[] {\n    const branch = this.getBranchData();\n    const doc = branch.docs.get(id);\n    if (!doc) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    return doc.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: clone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.getBranch