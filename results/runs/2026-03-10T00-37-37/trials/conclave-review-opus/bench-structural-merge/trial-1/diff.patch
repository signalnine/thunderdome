\n  applied: boolean;\n}\n\nexport interface Conflict {\n  documentId: string;\n  path: string;\n  base: unknown;\n  ours: unknown;\n  theirs: unknown;\n}\n\ninterface DocState {\n  content: object;\n  versions: Version[];\n  deleted: boolean;\n}\n\ninterface BranchData {\n  docs: Map<string, DocState>;\n  /** Snapshot of docs at branch creation time (the common ancestor for merges). */\n  forkPoint: Map<string, DocState> | null;\n  /** Name of the branch this was forked from (used for ancestor lookup). */\n  parentBranch: string | null;\n}\n\nfunction clone<T>(value: T): T {\n  return JSON.parse(JSON.stringify(value));\n}\n\nlet versionCounter = 0;\nfunction nextVersionId(): string {\n  return `v${++versionCounter}`;\n}\n\nfunction cloneDocState(state: DocState): DocState {\n  return {\n    content: clone(state.content),\n    versions: state.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: clone(v.content),\n    })),\n    deleted: state.deleted,\n  };\n}\n\nfunction cloneDocs(docs: Map<string, DocState>): Map<string, DocState> {\n  const result = new Map<string, DocState>();\n  for (const [id, state] of docs) {\n    result.set(id, cloneDocState(state));\n  }\n  return result;\n}\n\n/**\n * Recursively collect all leaf paths where two objects differ.\n */\nfunction diffPaths(base: unknown, changed: unknown, prefix: string): string[] {\n  const paths: string[] = [];\n\n  if (base === changed) return paths;\n  if (base === null || base === undefined || changed === null || changed === undefined) {\n    return [prefix];\n  }\n  if (typeof base !== 'object' || typeof changed !== 'object') {\n    return [prefix];\n  }\n  if (Array.isArray(base) || Array.isArray(changed)) {\n    if (JSON.stringify(base) !== JSON.stringify(changed)) {\n      return [prefix];\n    }\n    return paths;\n  }\n\n  const baseObj = base as Record<string, unknown>;\n  const changedObj = changed as Record<string, unknown>;\n  const allKeys = new Set([...Object.keys(baseObj), ...Object.keys(changedObj)]);\n\n  for (const key of allKeys) {\n    const childPath = prefix ? `${prefix}.${key}` : key;\n    if (!(key in baseObj)) {\n      paths.push(childPath);\n    } else if (!(key in changedObj)) {\n      paths.push(childPath);\n    } else {\n      paths.push(...diffPaths(baseObj[key], changedObj[key], childPath));\n    }\n  }\n\n  return paths;\n}\n\nfunction getAtPath(obj: unknown, path: string): unknown {\n  const parts = path.split('.');\n  let current: unknown = obj;\n  for (const part of parts) {\n    if (current === null || current === undefined || typeof current !== 'object') {\n      return undefined;\n    }\n    current = (current as Record<string, unknown>)[part];\n  }\n  return current;\n}\n\nfunction setAtPath(obj: object, path: string, value: unknown): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj as Record<string, unknown>;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (!(parts[i] in current) || current[parts[i]] === null || typeof current[parts[i]] !== 'object') {\n      current[parts[i]] = {};\n    }\n    current = current[parts[i]] as Record<string, unknown>;\n  }\n  current[parts[parts.length - 1]] = value;\n}\n\nfunction deleteAtPath(obj: object, path: string): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj as Record<string, unknown>;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (!(parts[i] in current) || current[parts[i]] === null || typeof current[parts[i]] !== 'object') {\n      return;\n    }\n    current = current[parts[i]] as Record<string, unknown>;\n  }\n  delete current[parts[parts.length - 1]];\n}\n\nfunction deepEqual(a: unknown, b: unknown): boolean {\n  return JSON.stringify(a) === JSON.stringify(b);\n}\n\n/**\n * Three-way merge of a single document.\n * Returns the merged content and any conflicts.\n */\nfunction threeWayMerge(\n  base: object | null,\n  ours: object | null,\n  theirs: object | null,\n  documentId: string,\n): { merged: object; conflicts: Conflict[] } {\n  const baseObj = base ?? {};\n  const oursObj = ours ?? {};\n  const theirsObj = theirs ?? {};\n\n  const ourChanges = diffPaths(baseObj, oursObj, '');\n  const theirChanges = diffPaths(baseObj, theirsObj, '');\n\n  const conflicts: Conflict[] = [];\n  const merged = clone(oursObj);\n\n  // Apply their changes that don't conflict\n  const ourChangeSet = new Set(ourChanges);\n\n  for (const path of theirChanges) {\n    const baseVal = getAtPath(baseObj, path);\n    const ourVal = getAtPath(oursObj, path);\n    const theirVal = getAtPath(theirsObj, path);\n\n    if (ourChangeSet.has(path)) {\n      // Both sides changed this path\n      if (deepEqual(ourVal, theirVal)) {\n        // Same change — no conflict\n        continue;\n      }\n      // Conflict: both changed to different values\n      conflicts.push({\n        documentId,\n        path,\n        base: clone(baseVal),\n        ours: clone(ourVal),\n        theirs: clone(theirVal),\n      });\n      // merged already has \"ours\" value\n    } else {\n      // Only theirs changed — apply their change\n      const theirValInObj = getAtPath(theirsObj, path);\n      // Check if the key was deleted in theirs\n      if (theirValInObj === undefined && !(path in flatKeys(theirsObj, ''))) {\n        deleteAtPath(merged, path);\n      } else {\n        setAtPath(merged, path, clone(theirValInObj));\n      }\n    }\n  }\n\n  return { merged, conflicts };\n}\n\n/**\n * Collect all dot-paths present in an object (leaf-level only if value is primitive,\n * but also intermediate paths for checking existence).\n */\nfunction flatKeys(obj: unknown, prefix: string): Set<string> {\n  const keys = new Set<string>();\n  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {\n    if (prefix) keys.add(prefix);\n    return keys;\n  }\n  const record = obj as Record<string, unknown>;\n  for (const key of Object.keys(record)) {\n    const path = prefix ? `${prefix}.${key}` : key;\n    keys.add(path);\n    const sub = flatKeys(record[key], path);\n    for (const s of sub) keys.add(s);\n  }\n  return keys;\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      docs: new Map(),\n      forkPoint: null,\n      parentBranch: null,\n    });\n  }\n\n  private getBranchData(name?: string): BranchData {\n    const branchName = name ?? this.currentBranch;\n    const branch = this.branches.get(branchName);\n    if (!branch) {\n      throw new Error(`Branch \"${branchName}\" does not exist`);\n    }\n    return branch;\n  }\n\n  // ---- Document CRUD ----\n\n  create(id: string, content: object): void {\n    const branch = this.getBranchData();\n    const existing = branch.docs.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n    const version: Version = {\n      id: nextVersionId(),\n      timestamp: Date.now(),\n      content: clone(content),\n    };\n    branch.docs.set(id, {\n      content: clone(content),\n      versions: existing?.deleted ? [...existing.versions, version] : [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getBranchData();\n    const doc = branch.docs.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    return clone(doc.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getBranchData();\n    const doc = branch.docs.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    const version: Version = {\n      id: nextVersionId(),\n      timestamp: Date.now(),\n      content: clone(content),\n    };\n    doc.content = clone(content);\n    doc.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getBranchData();\n    const doc = branch.docs.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    doc.deleted = true;\n    doc.content = {};\n  }\n\n  // ---- Version History ----\n\n  getHistory(id: string): Version[] {\n    const branch = this.getBranchData();\n    const doc = branch.docs.get(id);\n    if (!doc) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    return doc.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: clone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.getBranchData();\n    const doc = branch.docs.get(id);\n    if (!doc) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    const version = doc.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" does not exist for document \"${id}\"`);\n    }\n    return clone(version.content);\n  }\n\n  // ---- Branching ----\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n    const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.getBranchData(sourceName);\n    this.branches.set(name, {\n      docs: cloneDocs(source.docs),\n      forkPoint: cloneDocs(source.docs),\n      parentBranch: sourceName,\n    });\n    // Also record the fork point on the source branch if it doesn't have one yet\n    // We need to store the fork point per-branch-pair, so we store it on the new branch\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" does not exist`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // ---- Merging ----\n\n  merge(sourceBranch: string): MergeResult {\n    const targetData = this.getBranchData();\n    const sourceData = this.getBranchData(sourceBranch);\n\n    // Find common ancestor: the fork point of the source branch\n    // This is the state of the parent at the time the source branch was created\n    const ancestor = this.findCommonAncestor(sourceBranch, this.currentBranch);\n\n    // Collect all document IDs across all three states\n    const allDocIds = new Set<string>();\n    for (const id of ancestor.keys()) allDocIds.add(id);\n    for (const id of targetData.docs.keys()) allDocIds.add(id);\n    for (const id of sourceData.docs.keys()) allDocIds.add(id);\n\n    const merged: Record<string, object> = {};\n    const conflicts: Conflict[] = [];\n    let hasChanges = false;\n\n    for (const docId of allDocIds) {\n      const baseDoc = ancestor.get(docId);\n      const ourDoc = targetData.docs.get(docId);\n      const theirDoc = sourceData.docs.get(docId);\n\n      const baseContent = baseDoc && !baseDoc.deleted ? baseDoc.content : null;\n      const ourContent = ourDoc && !ourDoc.deleted ? ourDoc.content : null;\n      const theirContent = theirDoc && !theirDoc.deleted ? theirDoc.content : null;\n\n      // If nothing changed on either side for this doc, skip it\n      const baseJson = JSON.stringify(baseContent);\n      const ourJson = JSON.stringify(ourContent);\n      const theirJson = JSON.stringify(theirContent);\n\n      if (ourJson === theirJson) {\n        // Both sides are the same — no merge needed for this doc\n        continue;\n      }\n\n      if (ourJson === baseJson && theirJson === baseJson) {\n        // No changes on either side\n        continue;\n      }\n\n      hasChanges = true;\n\n      if (ourJson === baseJson) {\n        // Only theirs changed — fast-forward\n        if (theirContent === null) {\n          // They deleted the doc\n          merged[docId] =