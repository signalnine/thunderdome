nch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 2 });\n\n      store.switchBranch('main');\n      const r1 = store.merge('feature');\n      expect(r1.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ a: 2 });\n\n      // Second round of changes on feature\n      store.switchBranch('feature');\n      store.update('doc1', { a: 3 });\n\n      store.switchBranch('main');\n      const r2 = store.merge('feature');\n      expect(r2.applied).toBe(true);\n      expect(r2.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ a: 3 });\n    });\n\n    it('should handle both branches adding different new fields', () => {\n      store.create('doc1', { base: 1 });\n      store.createBranch('feature');\n\n      store.update('doc1', { base: 1, mainField: 'hello' });\n\n      store.switchBranch('feature');\n      store.update('doc1', { base: 1, featureField: 'world' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ base: 1, mainField: 'hello', featureField: 'world' });\n    });\n\n    it('version IDs should be independent across store instances', () => {\n      const store2 = new DocumentStore();\n      store.create('doc1', { a: 1 });\n      store2.create('doc1', { a: 1 });\n      const h1 = store.getHistory('doc1');\n      const h2 = store2.getHistory('doc1');\n      // Both should start from v1 since counters are per-instance\n      expect(h1[0].id).toBe(h2[0].id);\n    });\n\n    it('should merge non-existent branch throws', () => {\n      expect(() => store.merge('nonexistent')).toThrow();\n    });\n  });\n});","originalFile":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { DocumentStore } from './index.js';\n\ndescribe('DocumentStore', () => {\n  let store: DocumentStore;\n\n  beforeEach(() => {\n    store = new DocumentStore();\n  });\n\n  describe('Document CRUD', () => {\n    it('should create and get a document', () => {\n      store.create('doc1', { name: 'test' });\n      expect(store.get('doc1')).toEqual({ name: 'test' });\n    });\n\n    it('should throw when creating a document with existing ID', () => {\n      store.create('doc1', { name: 'test' });\n      expect(() => store.create('doc1', { name: 'other' })).toThrow();\n    });\n\n    it('should throw when getting a non-existent document', () => {\n      expect(() => store.get('nonexistent')).toThrow();\n    });\n\n    it('should update a document', () => {\n      store.create('doc1', { name: 'test' });\n      store.update('doc1', { name: 'updated' });\n      expect(store.get('doc1')).toEqual({ name: 'updated' });\n    });\n\n    it('should throw when updating a non-existent document', () => {\n      expect(() => store.update('nonexistent', { name: 'test' })).toThrow();\n    });\n\n    it('should delete a document', () => {\n      store.create('doc1', { name: 'test' });\n      store.delete('doc1');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should throw when deleting a non-existent document', () => {\n      expect(() => store.delete('nonexistent')).toThrow();\n    });\n\n    it('should throw when deleting an already deleted document', () => {\n      store.create('doc1', { name: 'test' });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n\n    it('should deep clone on create', () => {\n      const obj = { a: { b: 1 } };\n      store.create('doc1', obj);\n      obj.a.b = 999;\n      expect(store.get('doc1')).toEqual({ a: { b: 1 } });\n    });\n\n    it('should deep clone on get', () => {\n      store.create('doc1', { a: { b: 1 } });\n      const retrieved = store.get('doc1') as { a: { b: number } };\n      retrieved.a.b = 999;\n      expect(store.get('doc1')).toEqual({ a: { b: 1 } });\n    });\n\n    it('should deep clone on update', () => {\n      store.create('doc1', { a: 1 });\n      const obj = { a: { b: 2 } };\n      store.update('doc1', obj);\n      obj.a.b = 999;\n      expect(store.get('doc1')).toEqual({ a: { b: 2 } });\n    });\n\n    it('should throw when updating a deleted document', () => {\n      store.create('doc1', { name: 'test' });\n      store.delete('doc1');\n      expect(() => store.update('doc1', { name: 'new' })).toThrow();\n    });\n  });\n\n  describe('Version History', () => {\n    it('should create a version on create', () => {\n      store.create('doc1', { name: 'v1' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(1);\n      expect(history[0].content).toEqual({ name: 'v1' });\n    });\n\n    it('should create a version on update', () => {\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(2);\n      expect(history[0].content).toEqual({ name: 'v1' });\n      expect(history[1].content).toEqual({ name: 'v2' });\n    });\n\n    it('should return versions in chronological order', () => {\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      store.update('doc1', { name: 'v3' });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);\n      expect(history[1].timestamp).toBeLessThanOrEqual(history[2].timestamp);\n    });\n\n    it('should get a specific version', () => {\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      const history = store.getHistory('doc1');\n      const v1Content = store.getVersion('doc1', history[0].id);\n      expect(v1Content).toEqual({ name: 'v1' });\n    });\n\n    it('should throw for non-existent version', () => {\n      store.create('doc1', { name: 'v1' });\n      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();\n    });\n\n    it('should throw getHistory for non-existent document', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    it('should throw getVersion for non-existent document', () => {\n      expect(() => store.getVersion('nonexistent', 'v1')).toThrow();\n    });\n\n    it('version content should be deep cloned', () => {\n      store.create('doc1', { a: { b: 1 } });\n      const history = store.getHistory('doc1');\n      (history[0].content as { a: { b: number } }).a.b = 999;\n      const history2 = store.getHistory('doc1');\n      expect(history2[0].content).toEqual({ a: { b: 1 } });\n    });\n\n    it('each version should have a unique id', () => {\n      store.create('doc1', { name: 'v1' });\n      store.update('doc1', { name: 'v2' });\n      const history = store.getHistory('doc1');\n      expect(history[0].id).not.toBe(history[1].id);\n    });\n  });\n\n  describe('Branching', () => {\n    it('should start on main branch', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should list branches', () => {\n      expect(store.listBranches()).toEqual(['main']);\n    });\n\n    it('should create a branch', () => {\n      store.createBranch('feature');\n      expect(store.listBranches()).toContain('feature');\n    });\n\n    it('should switch branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    it('should throw when creating a branch that already exists', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('should throw when switching to a non-existent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n\n    it('should isolate changes between branches', () => {\n      store.create('doc1', { name: 'original' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'modified' });\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'original' });\n\n      store.switchBranch('feature');\n      expect(store.get('doc1')).toEqual({ name: 'modified' });\n    });\n\n    it('should copy documents when creating a branch', () => {\n      store.create('doc1', { name: 'test' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.get('doc1')).toEqual({ name: 'test' });\n    });\n\n    it('should create a branch from a specific branch', () => {\n      store.create('doc1', { name: 'main-doc' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'feature-doc' });\n\n      store.switchBranch('main');\n      store.createBranch('from-feature', 'feature');\n      store.switchBranch('from-feature');\n      expect(store.get('doc1')).toEqual({ name: 'feature-doc' });\n    });\n\n    it('creating a doc on one branch should not affect another', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'feature-only' });\n\n      store.switchBranch('main');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('deleting a doc on one branch should not affect another', () => {\n      store.create('doc1', { name: 'test' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'test' });\n    });\n  });\n\n  describe('Merging', () => {\n    it('should merge a simple change from source to target', () => {\n      store.create('doc1', { name: 'original', value: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'modified', value: 1 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ name: 'modified', value: 1 });\n    });\n\n    it('should merge when only target changed (no-op for source)', () => {\n      store.create('doc1', { name: 'original' });\n      store.createBranch('feature');\n\n      // Change on main only\n      store.update('doc1', { name: 'main-change' });\n\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ name: 'main-change' });\n    });\n\n    it('should handle no changes on either side', () => {\n      store.create('doc1', { name: 'original' });\n      store.createBranch('feature');\n\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n    });\n\n    it('should merge non-conflicting changes on the same document', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      // Change field 'a' on main\n      store.update('doc1', { a: 10, b: 2 });\n\n      // Change field 'b' on feature\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 20 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ a: 10, b: 20 });\n    });\n\n    it('should detect conflicts when both sides change the same field differently', () => {\n      store.create('doc1', { name: 'original' });\n      store.createBranch('feature');\n\n      store.update('doc1', { name: 'main-change' });\n\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'feature-change' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'name',\n        base: 'original',\n        ours: 'main-change',\n        theirs: 'feature-change',\n      });\n      // Current branch should be unchanged\n      expect(store.get('doc1')).toEqual({ name: 'main-change' });\n    });\n\n    it('should not conflict when both sides make the same change', () => {\n      store.create('doc1', { name: 'original' });\n      store.createBranch('feature');\n\n      store.update('doc1', { name: 'same-change' });\n\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'same-change' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n    });\n\n    it('should merge new documents from source branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'new-doc' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({ name: 'new-doc' });\n    });\n\n    it('should handle merging with nested objects', () => {\n      store.create('doc1', { user: { name: 'John', age: 30 }, settings: { theme: 'light' } });\n      store.createBranch('feature');\n\n      store.update('doc1', { user: { name: 'John', age: 31 }, settings: { theme: 'light' } });\n\n      store.switchBranch('feature');\n      store.update('doc1', { user: { name: 'John', age: 30 }, settings: { theme: 'dark' } });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(store.get('doc1')).toEqual({\n        user: { name: 'John', age: 31 },\n        settings: { theme: 'dark' },\n      });\n    });\n\n    it('should handle conflicts in nested objects', () => {\n      store.create('doc1', 