@@ -0,0 +1,58 @@
+import { Plugin } from '../core/types.js';
+
+interface DevServerRoute {
+  path: string;
+  handler: string;
+}
+
+interface DevServerConfig {
+  port: number;
+  routes: DevServerRoute[];
+  assetPaths: string[];
+  searchIndexPath: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild(ctx) {
+        const routes: DevServerRoute[] = [];
+        const assetPaths: string[] = [];
+        let searchIndexPath = '';
+
+        // Get asset paths from asset-pipeline manifest
+        const assetManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (assetManifest) {
+          for (const asset of assetManifest.assets) {
+            assetPaths.push(asset);
+            routes.push({ path: `/assets/${asset}`, handler: 'asset' });
+          }
+        }
+
+        // Check for search index
+        if (ctx.output.has('search-index.json')) {
+          searchIndexPath = '/search-index.json';
+        }
+
+        // Add content routes for HTML files
+        for (const key of ctx.output.keys()) {
+          if (key.endsWith('.html')) {
+            routes.push({ path: `/${key}`, handler: 'static' });
+          }
+        }
+
+        const config: DevServerConfig = {
+          port: 3000,
+          routes,
+          assetPaths,
+          searchIndexPath,
+        };
+
+        ctx.data.set('dev-server-config', config);
+      },
+    },
+  };
+}
