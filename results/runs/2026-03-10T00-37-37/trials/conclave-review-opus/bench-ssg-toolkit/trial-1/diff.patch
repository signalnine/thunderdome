+import { Plugin } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file, _ctx) {
+        let content = file.content;
+
+        // Extract footnote definitions
+        const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+        const footnotes: { id: string; text: string }[] = [];
+        let match: RegExpExecArray | null;
+        while ((match = footnoteDefRegex.exec(content)) !== null) {
+          footnotes.push({ id: match[1], text: match[2] });
+        }
+        // Remove footnote definitions from content
+        content = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '');
+
+        // Replace footnote references [^1] with sup links
+        content = content.replace(/\[\^(\d+)\]/g, '<sup><a href="#fn-$1">$1</a></sup>');
+
+        // Process admonition containers :::type ... :::
+        content = content.replace(/^:::(\w+)\n([\s\S]*?)^:::/gm, (_match, type: string, body: string) => {
+          return `<div class="admonition admonition-${type}">\n<p>${body.trim()}</p>\n</div>`;
+        });
+
+        // Convert markdown to HTML using basic rules
+        // Process lines for block-level markdown
+        const lines = content.split('\n');
+        const htmlLines: string[] = [];
+        let inParagraph = false;
+
+        for (let i = 0; i < lines.length; i++) {
+          const line = lines[i];
+
+          // Skip empty lines
+          if (line.trim() === '') {
+            if (inParagraph) {
+              htmlLines.push('</p>');
+              inParagraph = false;
+            }
+            continue;
+          }
+
+          // Already HTML (starts with <)
+          if (line.trim().startsWith('<')) {
+            if (inParagraph) {
+              htmlLines.push('</p>');
+              inParagraph = false;
+            }
+            htmlLines.push(line);
+            continue;
+          }
+
+          // Headings
+          const headingMatch = line.match(/^(#{1,6})\s+(.+)$/);
+          if (headingMatch) {
+            if (inParagraph) {
+              htmlLines.push('</p>');
+              inParagraph = false;
+            }
+            const level = headingMatch[1].length;
+            const text = applyInline(headingMatch[2]);
+            htmlLines.push(`<h${level}>${text}</h${level}>`);
+            continue;
+          }
+
+          // Regular text - wrap in paragraph
+          const inlineText = applyInline(line);
+          if (!inParagraph) {
+            htmlLines.push(`<p>${inlineText}`);
+            inParagraph = true;
+          } else {
+            htmlLines.push(inlineText);
+          }
+        }
+
+        if (inParagraph) {
+          htmlLines.push('</p>');
+        }
+
+        content = htmlLines.join('\n');
+
+        // Append footnotes section
+        if (footnotes.length > 0) {
+          const items = footnotes.map(fn => `<li id="fn-${fn.id}">${fn.text}</li>`).join('\n');
+          content += `\n<section class="footnotes">\n<ol>\n${items}\n</ol>\n</section>`;
+        }
+
+        // Clean up extra blank lines
+        content = content.replace(/\n{3,}/g, '\n\n').trim();
+
+        return { ...file, content };
+      },
+    },
+  };
+}
+
+function applyInline(text: string): string {
+  // Bold **text**
+  text = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+  // Italic *text*
+  text = text.replace(/\*(.+?)\*/g, '<em>$1</em>');
+  // Inline code `text`
+  text = text.replace(/`(.+?)`/g, '<code>$1</code>');
+  // Links [text](url)
+  text = text.replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2">$1</a>');
+  return text;
+}
