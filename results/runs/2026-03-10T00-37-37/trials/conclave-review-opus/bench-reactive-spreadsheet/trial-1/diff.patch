   expect(cells.get('C1')).toBe(30);\n    });\n  });\n\n  describe('simple formulas', () => {\n    it('should evaluate addition', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('should evaluate subtraction', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 30);\n      sheet.set('A2', 10);\n      sheet.set('A3', '=A1-A2');\n      expect(sheet.get('A3')).toBe(20);\n    });\n\n    it('should evaluate multiplication', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('A2', 6);\n      sheet.set('A3', '=A1*A2');\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('should evaluate division', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 100);\n      sheet.set('A2', 4);\n      sheet.set('A3', '=A1/A2');\n      expect(sheet.get('A3')).toBe(25);\n    });\n\n    it('should respect operator precedence', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 2);\n      sheet.set('A2', 3);\n      sheet.set('A3', 4);\n      sheet.set('B1', '=A1+A2*A3');\n      expect(sheet.get('B1')).toBe(14);\n    });\n\n    it('should handle parentheses', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 2);\n      sheet.set('A2', 3);\n      sheet.set('B1', '=(A1+A2)*2');\n      expect(sheet.get('B1')).toBe(10);\n    });\n\n    it('should handle numeric literals in formulas', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=A1+10');\n      expect(sheet.get('B1')).toBe(15);\n    });\n\n    it('should handle unary minus', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=-A1');\n      expect(sheet.get('B1')).toBe(-5);\n    });\n  });\n\n  describe('cell references', () => {\n    it('should handle simple cell references', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 42);\n      sheet.set('B1', '=A1');\n      expect(sheet.get('B1')).toBe(42);\n    });\n\n    it('should handle multi-letter column references', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('AA1', 100);\n      sheet.set('AB1', '=AA1');\n      expect(sheet.get('AB1')).toBe(100);\n    });\n\n    it('should handle case-insensitive cell references', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('a1', 42);\n      expect(sheet.get('A1')).toBe(42);\n    });\n\n    it('should reference empty cells as null (treated as 0 in arithmetic)', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('B1', '=A1+5');\n      expect(sheet.get('B1')).toBe(5);\n    });\n  });\n\n  describe('comparison operators', () => {\n    it('should evaluate greater than', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 5);\n      sheet.set('B1', '=A1>A2');\n      expect(sheet.get('B1')).toBe(true);\n    });\n\n    it('should evaluate less than', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 3);\n      sheet.set('A2', 5);\n      sheet.set('B1', '=A1<A2');\n      expect(sheet.get('B1')).toBe(true);\n    });\n\n    it('should evaluate equal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('A2', 5);\n      sheet.set('B1', '=A1=A2');\n      expect(sheet.get('B1')).toBe(true);\n    });\n\n    it('should evaluate not equal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('A2', 3);\n      sheet.set('B1', '=A1<>A2');\n      expect(sheet.get('B1')).toBe(true);\n    });\n\n    it('should evaluate greater or equal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('A2', 5);\n      sheet.set('B1', '=A1>=A2');\n      expect(sheet.get('B1')).toBe(true);\n    });\n\n    it('should evaluate less or equal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('A2', 5);\n      sheet.set('B1', '=A1<=A2');\n      expect(sheet.get('B1')).toBe(true);\n    });\n  });\n\n  describe('SUM function', () => {\n    it('should sum a column range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('A4', 4);\n      sheet.set('A5', 5);\n      sheet.set('B1', '=SUM(A1:A5)');\n      expect(sheet.get('B1')).toBe(15);\n    });\n\n    it('should sum a row range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', 20);\n      sheet.set('C1', 30);\n      sheet.set('D1', '=SUM(A1:C1)');\n      expect(sheet.get('D1')).toBe(60);\n    });\n\n    it('should sum a block range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('B1', 3);\n      sheet.set('B2', 4);\n      sheet.set('C1', '=SUM(A1:B2)');\n      expect(sheet.get('C1')).toBe(10);\n    });\n\n    it('should ignore non-numeric values in SUM', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 'hello');\n      sheet.set('A3', 20);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(30);\n    });\n  });\n\n  describe('AVERAGE function', () => {\n    it('should compute average', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=AVERAGE(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n\n    it('should ignore non-numeric in average', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 'text');\n      sheet.set('A3', 30);\n      sheet.set('B1', '=AVERAGE(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n  });\n\n  describe('MIN function', () => {\n    it('should find minimum', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 30);\n      sheet.set('A2', 10);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MIN(A1:A3)');\n      expect(sheet.get('B1')).toBe(10);\n    });\n  });\n\n  describe('MAX function', () => {\n    it('should find maximum', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 30);\n      sheet.set('A2', 10);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MAX(A1:A3)');\n      expect(sheet.get('B1')).toBe(30);\n    });\n  });\n\n  describe('COUNT function', () => {\n    it('should count numeric values', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 'hello');\n      sheet.set('A3', 20);\n      sheet.set('A4', true);\n      sheet.set('B1', '=COUNT(A1:A4)');\n      expect(sheet.get('B1')).toBe(2);\n    });\n  });\n\n  describe('IF function', () => {\n    it('should return trueValue when condition is true', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 50);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('big');\n    });\n\n    it('should return falseValue when condition is false', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('small');\n    });\n\n    it('should work with numeric results', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=IF(A1>3, A1*2, A1)');\n      expect(sheet.get('B1')).toBe(10);\n    });\n  });\n\n  describe('reactive updates', () => {\n    it('should update dependent cells when source changes', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n    });\n\n    it('should update transitive dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=A1*2');\n      sheet.set('C1', '=B1+10');\n      expect(sheet.get('C1')).toBe(20);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe(20);\n      expect(sheet.get('C1')).toBe(30);\n    });\n\n    it('should update multiple dependents', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+1');\n      sheet.set('C1', '=A1+2');\n      sheet.set('D1', '=A1+3');\n\n      sheet.set('A1', 100);\n      expect(sheet.get('B1')).toBe(101);\n      expect(sheet.get('C1')).toBe(102);\n      expect(sheet.get('D1')).toBe(103);\n    });\n\n    it('should handle diamond dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=A1+1');\n      sheet.set('C1', '=A1+2');\n      sheet.set('D1', '=B1+C1');\n\n      expect(sheet.get('D1')).toBe(13);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe(11);\n      expect(sheet.get('C1')).toBe(12);\n      expect(sheet.get('D1')).toBe(23);\n    });\n\n    it('should update formulas referencing ranges', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(6);\n\n      sheet.set('A2', 10);\n      expect(sheet.get('B1')).toBe(14);\n    });\n\n    it('should handle overwriting a formula with a value', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+5');\n      expect(sheet.get('B1')).toBe(15);\n\n      sheet.set('B1', 99);\n      expect(sheet.get('B1')).toBe(99);\n\n      // Changing A1 should no longer affect B1\n      sheet.set('A1', 1000);\n      expect(sheet.get('B1')).toBe(99);\n    });\n\n    it('should handle replacing a formula with another formula', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('B1', '=A1+5');\n      expect(sheet.get('B1')).toBe(15);\n\n      sheet.set('B1', '=A2+5');\n      expect(sheet.get('B1')).toBe(25);\n\n      // A1 change should not affect B1 anymore\n      sheet.set('A1', 999);\n      expect(sheet.get('B1')).toBe(25);\n\n      // A2 change should affect B1\n      sheet.set('A2', 100);\n      expect(sheet.get('B1')).toBe(105);\n    });\n  });\n\n  describe('circular reference detection', () => {\n    it('should detect direct circular reference', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1');\n      expect(() => sheet.set('B1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should detect self-reference', () => {\n      const sheet = new Spreadsheet();\n      expect(() => sheet.set('A1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should detect indirect circular reference', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=C1');\n      sheet.set('B1', '=A1');\n      expect(() => sheet.set('C1', '=B1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should allow non-circular dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1');\n      sheet.set('C1', '=B1');\n      expect(sheet.get('C1')).toBe(10);\n    });\n  });\n\n  describe('example usage from spec', () => {\n    it('should handle the full example from the spec', () => {\n      const sheet = new Spreadsheet();\n\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n      expect(sheet.getDisplay('A3')).toBe('30');\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n\n      sheet.set('B1', '=SUM(A1:A2)');\n      expect(sheet.get('B1')).toBe(70);\n\n      sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('C1')).toBe('big');\n    });\n  });\n\n  describe('edge cases', () => {\n    it('should handle formula with only a number literal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=42');\n      expect(sheet.get('A1')).toBe(42);\n    });\n\n    it('should handle deeply chained dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', '=A1+1');\n      sheet.set('A3', '=A2+1');\n      sheet.set('A4', '=A3+1');\n      sheet.set('A5', '=A4+1');\n      expect(sheet.get('A5')).toBe(5);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('A5')).toBe(14);\n    });\n\n    it('should handle setting cells in any order', () => {\n      const sheet = new Spreadsheet();\n      // Set formula before its dependency\n      sheet.set('B1', '=A1+1');\n      expect(sheet.get('B1')).toBe(1); // A1 is null -> 0, 0+1=1\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe(11);\n    });\n\n    it('should handle Z and AA columns', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('Z1', 26);\n      sheet.set('AA1', 27);\n      sheet.set('AB1', '=Z1+AA1');\n      expect(sheet.get('AB1')).toBe(53);\n    });\n\n    it('should handle large row numbers', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A100', 42);\n      sheet.set('A101', '=A100+1');\n      expect(sheet.get('A101')).toBe(43);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":467,"oldLines":6,"newStart":467,"newLines":26,"lines":["       sheet.set('C1', '=B1');","       expect(sheet.get('C1')).toBe(10);","     });","+","+    it('should preserve state after circular reference error', () => {","+      const sheet = new Spreadsheet();","+      sheet.set('B1', 5);","+      sheet.set('A1', '=B1');","+      sheet.set('C1', '=A1');","+","+      expect(sheet.get('A1')).toBe(5);","+      expect(sheet.get('C1')).toBe(5);","+","+      // Try to create a cycle - should throw","+      expect(() => sheet