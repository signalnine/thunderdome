+// Helper to register and login a user, returning token and userId
+async function createUser(username: string, password = 'password123') {
+  const registerRes = await request(app)
+    .post('/auth/register')
+    .send({ username, password });
+  const loginRes = await request(app)
+    .post('/auth/login')
+    .send({ username, password });
+  return { token: loginRes.body.token, userId: loginRes.body.userId ?? registerRes.body.id };
+}
+
+// Helper to create a folder
+async function createFolder(token: string, name: string, parentId?: string) {
