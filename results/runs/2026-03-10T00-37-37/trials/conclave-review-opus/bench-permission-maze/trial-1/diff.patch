+describe('Edge Cases', () => {
+  beforeEach(() => {
+    app = createApp();
+  });
+
+  it('deeply nested folder permissions cascade', async () => {
+    const { token: aliceToken } = await createUser('alice');
+    const { token: bobToken, userId: bobId } = await createUser('bob');
+
+    const f1 = await createFolder(aliceToken, 'Level 1');
+    const f2 = await createFolder(aliceToken, 'Level 2', f1.body.id);
+    const f3 = await createFolder(aliceToken, 'Level 3', f2.body.id);
+
+    // Share top level with bob
+    await shareResource(aliceToken, 'folder', f1.body.id, bobId, 'viewer');
+
+    // Bob should access all levels
+    const res = await request(app)
+      .get(`/folders/${f3.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`);
+    expect(res.status).toBe(200);
+  });
+
+  it('document in deeply nested folder inherits permissions', async () => {
+    const { token: aliceToken } = await createUser('alice');
+    const { token: bobToken, userId: bobId } = await createUser('bob');
+
+    const f1 = await createFolder(aliceToken, 'Level 1');
+    const f2 = await createFolder(aliceToken, 'Level 2', f1.body.id);
+    const doc = await createDocument(aliceToken, 'Deep Doc', 'Content', f2.body.id);
+
+    // Share top level with bob as editor
+    await shareResource(aliceToken, 'folder', f1.body.id, bobId, 'editor');
+
+    // Bob should be able to edit the doc
+    const res = await request(app)
+      .put(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`)
+      .send({ content: 'Updated' });
+    expect(res.status).toBe(200);
+  });
+
+  it('owner created resource does not need explicit share', async () => {
+    const { token: aliceToken } = await createUser('alice');
+    const folder = await createFolder(aliceToken, 'My Folder');
+
+    // Alice can access her own folder without any shares
+    const res = await request(app)
+      .get(`/folders/${folder.body.id}`)
+      .set('Authorization', `Bearer ${aliceToken}`);
+    expect(res.status).toBe(200);
+  });
+
+  it('multiple shares - most permissive wins', async () => {
+    const { token: aliceToken } = await createUser('alice');
+    const { token: bobToken, userId: bobId } = await createUser('bob');
+
+    const parent = await createFolder(aliceToken, 'Parent');
+    const child = await createFolder(aliceToken, 'Child', parent.body.id);
+
+    // Share parent as editor, child as viewer
+    await shareResource(aliceToken, 'folder', parent.body.id, bobId, 'editor');
+    await shareResource(aliceToken, 'folder', child.body.id, bobId, 'viewer');
+
+    // Bob should have editor access on child (inherited > direct viewer)
+    const updateRes = await request(app)
+      .put(`/folders/${child.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`)
+      .send({ name: 'Renamed' });
+    expect(updateRes.status).toBe(200);
+  });
+
+  it('document content can be empty string', async () => {
+    const { token } = await createUser('alice');
+    const folder = await createFolder(token, 'Folder');
+    const res = await createDocument(token, 'Empty Doc', '', folder.body.id);
+    expect(res.status).toBe(201);
+    expect(res.body.content).toBe('');
+  });
+
+  it('different users can have different roles on the same resource', async () => {
+    const { token: aliceToken } = await createUser('alice');
+    const { token: bobToken, userId: bobId } = await createUser('bob');
+    const { token: charlieToken, userId: charlieId } = await createUser('charlie');
+
+    const folder = await createFolder(aliceToken, 'Folder');
+    const doc = await createDocument(aliceToken, 'Doc', 'Content', folder.body.id);
+
+    await shareResource(aliceToken, 'document', doc.body.id, bobId, 'viewer');
+    await shareResource(aliceToken, 'document', doc.body.id, charlieId, 'editor');
+
+    // Bob can read but not edit
+    const bobGet = await request(app)
+      .get(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`);
+    expect(bobGet.status).toBe(200);
+
+    const bobEdit = await request(app)
+      .put(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`)
+      .send({ content: 'by bob' });
+    expect(bobEdit.status).toBe(403);
+
+    // Charlie can edit
+    const charlieEdit = await request(app)
+      .put(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${charlieToken}`)
+      .send({ content: 'by charlie' });
+    expect(charlieEdit.status).toBe(200);
+  });
