@@ -0,0 +1,30 @@
+import { Router, Response } from 'express';
+import { Store } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+
+export function activityRoutes(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Get activity log
+  router.get('/', (req: AuthRequest, res: Response): void => {
+    const { resourceType, resourceId } = req.query;
+
+    let logs = [...store.activityLog];
+
+    if (resourceType && typeof resourceType === 'string') {
+      logs = logs.filter(l => l.resourceType === resourceType);
+    }
+
+    if (resourceId && typeof resourceId === 'string') {
+      logs = logs.filter(l => l.resourceId === resourceId);
+    }
+
+    // Sort by most recent first
+    logs.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());
+
+    res.status(200).json(logs);
+  });
+
+  return router;
+}
diff --git a/src/routes/auth.ts b/src/routes/auth.ts
new file mode 100644
