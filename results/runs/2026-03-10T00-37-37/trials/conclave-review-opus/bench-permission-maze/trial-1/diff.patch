d: bobId } = await createUser('bob');\n\n    const folder = await createFolder(aliceToken, 'Folder');\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n    const res = await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'editor');\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe('editor');\n  });\n\n  it('should not share with yourself', async () => {\n    const { token: aliceToken, userId: aliceId } = await createUser('alice');\n\n    const folder = await createFolder(aliceToken, 'Folder');\n    const res = await shareResource(aliceToken, 'folder', folder.body.id, aliceId, 'editor');\n    expect(res.status).toBe(400);\n  });\n\n  it('user without access cannot read folder', async () => {\n    const { token: aliceToken } = await createUser('alice');\n    const { token: bobToken } = await createUser('bob');\n\n    const folder = await createFolder(aliceToken, 'Private Folder');\n\n    const res = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('folder share gives access to documents inside it', async () => {\n    const { token: aliceToken } = await createUser('alice');\n    const { token: bobToken, userId: bobId } = await createUser('bob');\n\n    const folder = await createFolder(aliceToken, 'Folder');\n    const doc = await createDocument(aliceToken, 'Doc', 'Content', folder.body.id);\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n    // Bob can read the doc because they have viewer on the folder\n    const res = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(res.status).toBe(200);\n  });\n\n  it('effective permission is the most permissive role', async () => {\n    const { token: aliceToken } = await createUser('alice');\n    const { token: bobToken, userId: bobId } = await c