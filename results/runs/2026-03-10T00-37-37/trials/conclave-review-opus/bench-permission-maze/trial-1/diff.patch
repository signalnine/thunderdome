+++ b/src/routes/documents.ts
@@ -0,0 +1,174 @@
+import { Router, Response } from 'express';
+import crypto from 'node:crypto';
+import { Store } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+export function documentRoutes(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Create document
+  router.post('/', (req: AuthRequest, res: Response): void => {
+    const { title, content, folderId } = req.body;
+    const userId = req.userId!;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+
+    if (!folderId || typeof folderId !== 'string') {
+      res.status(400).json({ error: 'Folder ID is required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    // User needs editor+ access on the folder to create docs in it
+    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = crypto.randomUUID();
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content: String(content),
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    // Activity log
+    store.activityLog.push({
+      id: crypto.randomUUID(),
+      action: 'document_created',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+      details: { title, folderId },
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', (req: AuthRequest, res: Response): void => {
+    const { id } = req.params;
+    const userId = req.userId!;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.status(200).json(doc);
+  });
+
+  // Update document
+  router.put('/:id', (req: AuthRequest, res: Response): void => {
+    const { id } = req.params;
+    const userId = req.userId!;
+    const { title, content } = req.body;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    if (title !== undefined) {
+      if (typeof title !== 'string' || !title) {
+        res.status(400).json({ error: 'Title must be a non-empty string' });
+        return;
+      }
+      doc.title = title;
+    }
+
+    if (content !== undefined) {
+      doc.content = String(content);
+    }
+
+    doc.updatedAt = new Date().toISOString();
+
+    // Activity log
+    store.activityLog.push({
+      id: crypto.randomUUID(),
+      action: 'document_updated',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: doc.updatedAt,
+      details: { title: doc.title },
+    });
+
+    res.status(200).json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', (req: AuthRequest, res: Response): void => {
+    const { id } = req.params;
+    const userId = req.userId!;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const now = new Date().toISOString();
+
+    // Activity log
+    store.activityLog.push({
+      id: crypto.randomUUID(),
+      action: 'document_deleted',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+      details: { title: doc.title },
+    });
+
+    // Remove shares for this document
+    store.shares = store.shares.filter(
+      s => !(s.resourceType === 'document' && s.resourceId === id)
+    );
+
+    store.documents.delete(id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/routes/folders.ts b/src/routes/folders.ts
new file mode 100644
index 0000000..a356971
--- /dev/null
+++ b/src/routes/folders.ts
@@ -0,0 +1,187 @@
+import { Router, Response } from 'express';
+import crypto from 'node:crypto';
+import { Store } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+export function folderRoutes(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Create folder
+  router.post('/', (req: AuthRequest, res: Response): void => {
+    const { name, parentId } = req.body;
+    const userId = req.userId!;
+
+    if (!name || typeof name !== 'string') {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    // If parentId is specified, verify it exists and user has editor+ access
+    if (parentId !== undefined && parentId !== null) {
+      const parentFolder = store.folders.get(parentId);
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      if (!hasPermission(store, userId, 'folder', parentId, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = crypto.randomUUID();
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', (req: AuthRequest, res: Response): void => {
+    const { id } = req.params;
+    const userId = req.userId!;
+
+    const folder = store.folders.get(id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Get child folders
+    const children: { id: string; name: string }[] = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === id) {
+        children.push({ id: f.id, name: f.name });
+      }
+    }
+
+    // Get documents in folder
+    const documents: { id: string; title: string }[] = [];
+    for (const doc of store.documents.values()) {
+      if (doc.folderId === id) {
+        documents.push({ id: doc.id, title: doc.title });
+      }
+    }
+
+    res.status(200).json({ ...folder, children, documents });
+  });
+
+  // Update folder
+  router.put('/:id', (req: AuthRequest, res: Response): void => {
+    const { id } = req.params;
+    const userId = req.userId!;
+    const { name, parentId } = req.body;
+
+    const folder = store.folders.get(id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    if (name !== undefined) {
+      if (typeof name !== 'string' || !name) {
+        res.status(400).json({ error: 'Folder name must be a non-empty string' });
+        return;
+      }
+      folder.name = name;
+    }
+
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parentFolder = store.folders.get(parentId);
+        if (!parentFolder) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Prevent circular reference
+        if (parentId === id) {
+          res.status(400).json({ error: 'A folder cannot be its own parent' });
+          return;
+        }
+      }
+      folder.parentId = parentId;
+    }
+
+    res.status(200).json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', (req: AuthRequest, res: Response): void => {
+    const { id } = req.params;
+    const userId = req.userId!;
+
+    const folder = store.folders.get(id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Delete all documents in this folder
+    for (const [docId, doc] of store.documents) {
+      if (doc.folderId === id) {
+        store.documents.delete(docId);
+      }
+    }
+
+    // Delete all child folders recursively
+    deleteFolderRecursive(store, id);
+
+    // Remove shares for this folder
+    store.shares = store.shares.filter(
+      s => !(s.resourceType === 'folder' && s.resourceId === id)
+    );
+
+    store.folders.delete(id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
+
+function deleteFolderRecursive(store: Store, folderId: string): void {
+  const childFolderIds: string[] = [];
+  for (const f of store.folders.values()) {
+    if (f.parentId === folderId) {
+      childFolderIds.push(f.id);
+    }
+  }
+
+  for (const childId of childFolderIds) {
+    // Delete docs in child folder
+    for (const [docId, doc] of store.documents) {
+      if (doc.folderId === childId) {
+        store.documents.delete(docId);
+      }
+    }
+    // Remove shares for this child folder
+    store.shares = store.shares.filter(
+      s => !(s.resourceType === 'folder' && s.resourceId === childId)
+    );
+    deleteFolderRecursive(store, childId);
+    store.folders.delete(childId);
+  }
+}
diff --git a/src/routes/sharing.ts b/src/routes/sharing.ts
new file mode 100644
index 0000000..4f44591
--- /dev/null
+++ b/src/routes/sharing.ts
@@ -0,0 +1,184 @@
+import { Router, Response } from 'express';
+import crypto from 'node:crypto';
+import { Store } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+import { Role } from '../types.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function sharingRoutes(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Share a resource (folder or document)
+  router.post('/', (req: AuthRequest, res: Response): void => {
+    const { resourceType, resourceId, userId: targetUserId, role } = req.body;
+    const userId = req.userId!;
+
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, userId, and role are required' });
+      return;
+    }
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be "folder" or "document"' });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'role must be "viewer", "editor", or "owner"' });
+      return;
+    }
+
+    // Verify target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Can't share with yourself
+    if (targetUserId === userId) {
+      res.status(400).json({ error: 'Cannot share with yourself' });
+      return;
+    }
+
+    // Verify resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check permissions: editors can share, owners can share with any role
+    // Editors can share as viewer or editor, only owners can share as owner
+    if (role === 'owner') {
+      if (!hasPermission(store, userId, resourceType, resourceId, 'owner')) {
+        res.status(403).json({ error: 'Only owners can grant owner role' });
+        return;
+      }
+    } else {
+      if (!hasPermission(store, userId, resourceType, resourceId, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions to share' });
+        return;
+      }
+    }
+
+    // Check if share already exists and update it
+    const existingShare = store.shares.find(
+      s => s.resourceType === resourceType && s.resourceId === resourceId && s.userId === targetUserId
+    );
+
+    const now = new Date().toISOString();
+
+    if (existingShare) {
+      existingShare.role = role;
+      existingShare.grantedBy = userId;
+
+      // Activity log
+      store.activityLog.push({
+        id: crypto.randomUUID(),
+        action: 'share_updated',
+        userId,
+        resourceType,
+        resourceId,
+        timestamp: now,
+        details: { targetUserId, role },
+      });
+
+      res.status(200).json(existingShare);
+      return;
+    }
+
+    const share = {
+      id: crypto.randomUUID(),
+      resourceType,
+      resourceId,
+      userId: targetUserId,
+      role,
+      grantedBy: userId,
+      createdAt: now,
+    };
+    store.shares.push(share);
+
+    // Activity log
+    store.activityLog.push({
+      id: crypto.randomUUID(),
+      action: 'share_created',
+      userId,
+      resourceType,
+      resourceId,
+      timestamp: now,
+      details: { targetUserId, role },
+    });
+
+    res.status(201).json(share);
+  });
+
+  // Get shares for a resource
+  router.get('/:resourceType/:resourceId', (req: AuthRequest, res: Response): void => {
+    const { resourceType, resourceId } = req.params;
+    const userId = req.userId!;
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be "folder" or "document"' });
+      return;
+    }
+
+    // Verify resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    if (!hasPermission(store, userId, resourceType as 'folder' | 'document', resourceId, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const shares = store.shares.filter(
+      s => s.resourceType === resourceType && s.resourceId === resourceId
+    );
+
+    res.status(200).json(shares);
+  });
+
+  // Delete a share
+  router.delete('/:shareId', (req: AuthRequest, res: Response): void => {
+    const { shareId } = req.params;
+    const userId = req.userId!;
+
+    const shareIndex = store.shares.findIndex(s => s.id === shareId);
+    if (shareIndex === -1) {
+      res.status(404).json({ error: 'Share not found' });
+      return;
+    }
+
+    const share = store.shares[shareIndex];
+
+    // Only owners can remove shares
+    if (!hasPermission(store, userId, share.resourceType, share.resourceId, 'owner')) {
+      res.status(403).json({ error: 'Only owners can remove shares' });
+      return;
+    }
+
+    store.shares.splice(shareIndex, 1);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
