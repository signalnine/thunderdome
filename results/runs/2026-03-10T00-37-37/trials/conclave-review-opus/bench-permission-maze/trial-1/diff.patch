+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01RUefecxFYPNX7VmsUXXjy3","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015y5Y7Jq1AXZDcgJYfNr2QH","name":"Write","input":{"file_path":"/workspace/src/permissions.ts","content":"import { Store } from './store.js';\nimport { Role } from './types.js';\n\nconst ROLE_LEVEL: Record<Role, number> = {\n  viewer: 1,\n  editor: 2,\n  owner: 3,\n};\n\nexport function getEffectiveRole(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string\n): Role | null {\n  let bestRole: Role | null = null;\n\n  // Check if user is owner of the resource\n  if (resourceType === 'folder') {\n    const folder = store.folders.get(resourceId);\n    if (folder && folder.ownerId === userId) return 'owner';\n  } else {\n    const doc = store.documents.get(resourceId);\n    if (doc && doc.ownerId === userId) return 'owner';\n  }\n\n  // Check direct shares on the resource\n  for (const share of store.shares) {\n    if (share.resourceType === resourceType && share.resourceId === resourceId && share.userId === userId) {\n      if (!bestRole || ROLE_LEVEL[share.role] > ROLE_LEVEL[bestRole]) {\n        bestRole = share.role;\n      }\n    }\n  }\n\n  // If this is a document, also check folder shares (inherited permissions)\n  if (resourceType === 'document') {\n    const doc = store.documents.get(resourceId);\n    if (doc) {\n      const folderRole = getEffectiveFolderRole(store, userId, doc.folderId);\n      if (folderRole && (!bestRole || ROLE_LEVEL[folderRole] > ROLE_LEVEL[bestRole])) {\n        bestRole = folderRole;\n      }\n    }\n  }\n\n  // If this is a folder, check parent folder shares (inherited permissions)\n  if (resourceType === 'folder') {\n    const folder = store.folders.get(resourceId);\n    if (folder && folder.parentId) {\n      const parentRole = getEffectiveFolderRole(store, userId, folder.parentId);\n      if (parentRole && (!bestRole || ROLE_LEVEL[parentRole] > ROLE_LEVEL[bestRole])) {\n        bestRole = parentRole;\n      }\n    }\n  }\n\n  return bestRole;\n}\n\nfunction getEffectiveFolderRole(store: Store, userId: string, folderId: string): Role | null {\n  let bestRole: Role | null = null;\n\n  // Check if user is folder owner\n  const folder = store.folders.get(folderId);\n  if (folder && folder.ownerId === userId) return 'owner';\n\n  // Check direct shares on this folder\n  for (const share of store.shares) {\n    if (share.resourceType === 'folder' && share.resourceId === folderId && share.userId === userId) {\n      if (!bestRole || ROLE_LEVEL[share.role] > ROLE_LEVEL[bestRole]) {\n        bestRole = share.role;\n      }\n    }\n  }\n\n  // Check parent folder recursively\n  if (folder && folder.parentId) {\n    const parentRole = getEffectiveFolderRole(store, userId, folder.parentId);\n    if (parentRole && (!bestRole || ROLE_LEVEL[parentRole] > ROLE_LEVEL[bestRole])) {\n      bestRole = parentRole;\n    }\n  }\n\n  return bestRole;\n}\n\nexport function hasPermission(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string,\n  requiredRole: Role\n): boolean {\n  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);\n  if (!effectiveRole) return false;\n  return ROLE_LEVEL[effectiveRole] >= ROLE_LEVEL[requiredRole];\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":308,"cache_read_input_tokens":21540,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":308},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b7e39004-4e11-4fc8-b996-4f6368eab607","uuid":"cfc410e3-979d-45a6-bf5f-cdf6ec25c024"}
