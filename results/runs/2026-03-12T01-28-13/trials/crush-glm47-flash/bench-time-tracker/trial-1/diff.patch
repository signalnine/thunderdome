+import { describe, it, expect, beforeEach } from 'vitest';
+import { TimeTracker, TimeEntry, InvalidTimerNameError, NoTimerRunningError } from './index.js';
+const fs = await import('fs/promises');
+
+describe('TimeTracker', () => {
+  beforeEach(() => {
+    const tempFile = `/tmp/time-tracker-test-${Date.now()}.json`;
+    deleteTracker(tempFile);
+    return () => deleteTracker(tempFile);
+  });
+
+  async function deleteTracker(filePath: string) {
+    try {
+      const { existsSync } = await import('fs');
+      if (existsSync(filePath)) {
+        fs.unlink(filePath);
+      }
+    } catch {
+      // Ignore errors for cleanup
+    }
+  }
+
+  describe('startTimer', () => {
+    it('should start a timer with a valid name', () => {
+      const tracker = new TimeTracker('/tmp/test-1.json');
+      tracker.startTimer('Task 1');
+      expect(tracker.getRunningTimer()).toBe('Task 1');
+    });
+
+    it('should throw InvalidTimerNameError for empty name', () => {
+      const tracker = new TimeTracker('/tmp/test-2.json');
+      expect(() => tracker.startTimer('')).toThrow(InvalidTimerNameError);
+    });
+
+    it('should throw InvalidTimerNameError for whitespace-only name', () => {
+      const tracker = new TimeTracker('/tmp/test-3.json');
+      expect(() => tracker.startTimer('  ')).toThrow(InvalidTimerNameError);
+    });
+
+    it('should automatically stop previous timer when starting a new one', () => {
+      const tracker = new TimeTracker('/tmp/test-4.json');
+      tracker.startTimer('Task 1');
+      tracker.startTimer('Task 2');
+
+      expect(tracker.getRunningTimer()).toBe('Task 2');
+      const entries = tracker.getAllEntries();
+      expect(entries.length).toBe(1);
+    });
+
+    it('should support unicode characters', () => {
+      const tracker = new TimeTracker('/tmp/test-5.json');
+      tracker.startTimer('🎉 任务 1');
+      expect(tracker.getRunningTimer()).toBe('🎉 任务 1');
+    });
+  });
+
+  describe('stopTimer', () => {
+    it('should stop a timer and create an entry', () => {
+      const tracker = new TimeTracker('/tmp/test-6.json');
+      tracker.startTimer('Task 1');
+      tracker.stopTimer();
+
+      const entries = tracker.getAllEntries();
+      expect(entries.length).toBe(1);
+      expect(entries[0].taskName).toBe('Task 1');
+      expect(entries[0].endTime).toBeDefined();
+    });
+
+    it('should throw NoTimerRunningError when stopping with no timer running', () => {
+      const tracker = new TimeTracker('/tmp/test-7.json');
+      expect(() => tracker.stopTimer()).toThrow(NoTimerRunningError);
+    });
+
+    it('should use current time for stopped timer', () => {
+      const tracker = new TimeTracker('/tmp/test-8.json');
+      const startTime = Date.now();
+      tracker.startTimer('Task 1');
+      tracker.stopTimer();
+      const endTime = Date.now();
+
+      const entries = tracker.getAllEntries();
+      const endTimestamp = new Date(entries[0].endTime!).getTime();
+      expect(endTimestamp).toBeGreaterThanOrEqual(startTime);
+      expect(endTimestamp).toBeLessThanOrEqual(endTime);
+    });
+  });
+
+  describe('getAllEntries', () => {
+    it('should return all entries', () => {
+      const tracker = new TimeTracker('/tmp/test-9.json');
+      tracker.startTimer('Task 1');
+      tracker.stopTimer();
+
+      const entries = tracker.getAllEntries();
+      expect(entries.length).toBe(1);
+      expect(entries[0].taskName).toBe('Task 1');
+    });
+  });
+
+  describe('getEntriesByDateRange', () => {
+    it('should filter entries by date range inclusive', async () => {
+      const tracker = new TimeTracker('/tmp/test-10.json');
+      const yesterday = new Date();
+      yesterday.setDate(yesterday.getDate() - 1);
+
+      const entry1: TimeEntry = {
+        taskName: 'Task 1',
+        startTime: yesterday.toISOString(),
+        endTime: new Date(yesterday.getTime() + 1000).toISOString(),
+      };
+      await saveState(tracker, [entry1]);
+
+      const start = new Date('2026-03-10');
+      const end = new Date('2026-03-11');
+
+      const entries = tracker.getEntriesByDateRange(start, end);
+      expect(entries.length).toBe(1);
+    });
+
+    it('should return empty array for no matching entries', async () => {
+      const tracker = new TimeTracker('/tmp/test-11.json');
+      const entry1: TimeEntry = {
+        taskName: 'Task 1',
+        startTime: new Date().toISOString(),
+        endTime: new Date().toISOString(),
+      };
+      await saveState(tracker, [entry1]);
+
+      const start = new Date('2026-03-01');
+      const end = new Date('2026-03-02');
+
+      const entries = tracker.getEntriesByDateRange(start, end);
+      expect(entries.length).toBe(0);
+    });
+  });
+
+  describe('getSummary', () => {
+    it('should sum durations by task name', async () => {
+      const tracker = new TimeTracker('/tmp/test-12.json');
+      const now = new Date();
+      const entries: TimeEntry[] = [
+        {
+          taskName: 'Task 1',
+          startTime: new Date(now.getTime() - 1000).toISOString(),
+          endTime: new Date().toISOString(),
+        },
+        {
+          taskName: 'Task 2',
+          startTime: new Date(now.getTime() - 2000).toISOString(),
+          endTime: new Date(now.getTime() - 1000).toISOString(),
+        },
+      ];
+      await saveState(tracker, entries);
+
+      const summary = tracker.getSummary();
+      const durations = Array.from(summary.values());
+
+      expect(durations.length).toBe(2);
+      expect(durations[0]).toBeGreaterThan(0);
+      expect(durations[1]).toBeGreaterThan(0);
+    });
+  });
+
+  describe('getRunningTimer', () => {
+    it('should return the name of the running timer', () => {
+      const tracker = new TimeTracker('/tmp/test-13.json');
+      tracker.startTimer('Task 1');
+      expect(tracker.getRunningTimer()).toBe('Task 1');
+    });
+
+    it('should return undefined when no timer is running', () => {
+      const tracker = new TimeTracker('/tmp/test-14.json');
+      expect(tracker.getRunningTimer()).toBeUndefined();
+    });
+  });
+
+  describe('getFilePath', () => {
+    it('should return the configured file path', () => {
+      const tracker = new TimeTracker('/tmp/test-15.json');
+      const filePath = tracker.getFilePath();
+      expect(typeof filePath).toBe('string');
+    });
+  });
+
+  describe('persistence', () => {
+    it('should save and load state correctly', () => {
+      const tracker1 = new TimeTracker('/tmp/test-16.json');
+      tracker1.startTimer('Task 1');
+      tracker1.stopTimer();
+
+      const tracker2 = new TimeTracker('/tmp/test-16.json');
+      const entries = tracker2.getAllEntries();
+
+      expect(entries.length).toBe(1);
+    });
+
+    it('should auto-create parent directories', async () => {
+      const nestedPath = '/tmp/test-parent/test-sibling/test-nested.json';
+      const tracker = new TimeTracker(nestedPath);
+      const entry: TimeEntry = {
+        taskName: 'Task 1',
+        startTime: new Date(Date.now() - 1000).toISOString(),
+        endTime: new Date().toISOString(),
+      };
+      await saveState(tracker, [entry]);
+
+      const { existsSync } = await import('fs');
+      expect(existsSync('/tmp/test-parent')).toBe(true);
+      expect(existsSync('/tmp/test-parent/test-sibling')).toBe(true);
+    });
+  });
+});
+
+async function saveState(tracker: TimeTracker, entries: TimeEntry[]) {
+    (tracker as unknown as TrackerWithState).state = {
+      entries,
+      runningTimer: undefined,
+      filePath: tracker.getFilePath(),
+      save: () => Promise.resolve(),
+    };
+    await (tracker as unknown as TrackerWithState).save();
+  }
+
+  interface TrackerWithState {
+    state: TimerState;
+    save(): Promise<void>;
+  }
+
+  interface TimerState {
+    entries: TimeEntry[];
+    runningTimer?: {
+      taskName: string;
+      startTime: string;
+    };
+    filePath: string;
+    save?: () => Promise<void>;
+  }
