@@ -0,0 +1,162 @@
+import fs from 'fs/promises';
+import path from 'path';
+
+export interface TimeEntry {
+  taskName: string;
+  startTime: string;
+  endTime?: string;
+}
+
+export class InvalidTimerNameError extends Error {
+  constructor() {
+    super('Timer name cannot be empty');
+    this.name = 'InvalidTimerNameError';
+  }
+}
+
+export class NoTimerRunningError extends Error {
+  constructor() {
+    super('No timer is currently running');
+    this.name = 'NoTimerRunningError';
+  }
+}
+
+interface TimerState {
+  entries: TimeEntry[];
+  runningTimer?: {
+    taskName: string;
+    startTime: string;
+  };
+  filePath: string;
+}
+
+export class TimeTracker {
+  private state: TimerState;
+
+  constructor(filePath: string = './time-tracker-data.json') {
+    this.state = {
+      entries: [],
+      filePath,
+    };
+    this.load();
+  }
+
+  private async load() {
+    const { filePath } = this.state;
+    try {
+      const data = await fs.readFile(filePath, 'utf8');
+      const parsed = JSON.parse(data);
+      this.state = {
+        entries: parsed.entries || [],
+        runningTimer: parsed.runningTimer,
+        filePath,
+      };
+    } catch {
+      this.state.entries = [];
+      this.state.runningTimer = undefined;
+    }
+    await this.ensureDirectoryExists();
+  }
+
+  private async ensureDirectoryExists() {
+    const { filePath } = this.state;
+    const dir = path.dirname(filePath);
+    await fs.mkdir(dir, { recursive: true });
+  }
+
+  private async save() {
+    const { filePath } = this.state;
+    await this.ensureDirectoryExists();
+    await fs.writeFile(filePath, JSON.stringify(this.state, null, 2));
+  }
+
+  startTimer(name: string): void {
+    if (!name || name.trim() === '') {
+      throw new InvalidTimerNameError();
+    }
+
+    if (this.state.runningTimer) {
+      this.stopTimerInternal(this.state.runningTimer.taskName);
+    }
+
+    const now = new Date();
+    this.state.runningTimer = {
+      taskName: name,
+      startTime: now.toISOString(),
+    };
+    this.save();
+  }
+
+  stopTimer(): void {
+    if (!this.state.runningTimer) {
+      throw new NoTimerRunningError();
+    }
+    this.stopTimerInternal(this.state.runningTimer.taskName);
+  }
+
+  private stopTimerInternal(taskName: string): void {
+    const now = new Date();
+    this.state.entries.push({
+      taskName,
+      startTime: this.state.runningTimer!.startTime,
+      endTime: now.toISOString(),
+    });
+    this.state.runningTimer = undefined;
+    this.save();
+  }
+
+  getAllEntries(): TimeEntry[] {
+    return this.state.entries.map(entry => ({
+      ...entry,
+      startTime: new Date(entry.startTime).toISOString(),
+      endTime: entry.endTime ? new Date(entry.endTime).toISOString() : undefined,
+    }));
+  }
+
+  getEntriesByDateRange(start: Date, end: Date): TimeEntry[] {
+    const startDate = new Date(start);
+    const endDate = new Date(end);
+    startDate.setHours(0, 0, 0, 0);
+    endDate.setHours(23, 59, 59, 999);
+
+    return this.state.entries
+      .filter(entry => {
+        const startTime = new Date(entry.startTime);
+        return startTime >= startDate && startTime <= endDate;
+      })
+      .map(entry => ({
+        ...entry,
+        startTime: new Date(entry.startTime).toISOString(),
+        endTime: entry.endTime ? new Date(entry.endTime).toISOString() : undefined,
+      }));
+  }
+
+  getSummary(): Map<string, number> {
+    const summary = new Map<string, number>();
+
+    for (const entry of this.state.entries) {
+      const startTime = new Date(entry.startTime);
+      const endTime = entry.endTime ? new Date(entry.endTime) : new Date();
+      const duration = endTime.getTime() - startTime.getTime();
+      summary.set(entry.taskName, (summary.get(entry.taskName) || 0) + duration);
+    }
+
+    if (this.state.runningTimer) {
+      const startTime = new Date(this.state.runningTimer.startTime);
+      const duration = Date.now() - startTime.getTime();
+      summary.set(this.state.runningTimer.taskName, (summary.get(this.state.runningTimer.taskName) || 0) + duration);
+    }
+
+    return summary;
+  }
+
+  getFilePath(): string {
+    return this.state.filePath;
+  }
+
+  getRunningTimer(): string | undefined {
+    return this.state.runningTimer?.taskName;
+  }
+}
+
+export default TimeTracker;
