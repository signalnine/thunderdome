+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  throw new Error('No source found');
+}
+
+function nextPos(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  const visited = new Set<string>();
+  visited.add(`${sr},${sc}`);
+
+  const beams: Beam[] = [{ row: sr, col: sc, dir: 'down' }];
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const [nr, nc] = nextPos(beam.row, beam.col, beam.dir);
+
+    if (!inBounds(nr, nc, rows, cols)) continue;
+
+    visited.add(`${nr},${nc}`);
+
+    if (grid[nr][nc] === '^') {
+      beams.push({ row: nr, col: nc, dir: 'down-left' });
+      beams.push({ row: nr, col: nc, dir: 'down-right' });
+    } else {
+      beams.push({ row: nr, col: nc, dir: beam.dir });
+    }
+  }
+
+  return visited.size;
+}
+
+/**
+ * Trace a beam from a given position in a given direction until it either
+ * hits a splitter or exits the grid. Returns the cells visited along the way
+ * and the final outcome.
+ */
+function traceBeam(
+  startRow: number,
+  startCol: number,
+  dir: Direction,
+  grid: string[][],
+  rows: number,
+  cols: number
+): { visitedCells: [number, number][]; hitSplitter: [number, number] | null } {
+  const visitedCells: [number, number][] = [];
+  let row = startRow;
+  let col = startCol;
+
+  for (;;) {
+    const [nr, nc] = nextPos(row, col, dir);
+    if (!inBounds(nr, nc, rows, cols)) {
+      return { visitedCells, hitSplitter: null };
+    }
+    visitedCells.push([nr, nc]);
+    if (grid[nr][nc] === '^') {
+      return { visitedCells, hitSplitter: [nr, nc] };
+    }
+    row = nr;
+    col = nc;
+  }
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  // Use a DP approach: track how many paths reach each splitter,
+  // then propagate through the splitter graph.
+  // Process splitters by row order (beams only move downward).
+
+  // pathCount maps "row,col" of splitter -> number of paths arriving there
+  const pathCount = new Map<string, bigint>();
+
+  let totalExitPaths = 0n;
+
+  // Process the initial beam from source
+  const initialTrace = traceBeam(sr, sc, 'down', grid, rows, cols);
+  if (initialTrace.hitSplitter) {
+    const key = `${initialTrace.hitSplitter[0]},${initialTrace.hitSplitter[1]}`;
+    pathCount.set(key, (pathCount.get(key) ?? 0n) + 1n);
+  } else {
+    // Beam exits without hitting any splitter - 1 path
+    totalExitPaths += 1n;
+  }
