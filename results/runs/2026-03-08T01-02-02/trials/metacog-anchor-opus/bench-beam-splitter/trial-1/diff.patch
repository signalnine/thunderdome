+  // Collect all splitters and sort by row
+  const allSplitters: [number, number][] = [];
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      if (grid[r][c] === '^') {
+        allSplitters.push([r, c]);
+      }
+    }
+  }
+  // Already in row order from the loop above
+
+  // Process each splitter in row order
+  for (const [splR, splC] of allSplitters) {
+    const key = `${splR},${splC}`;
+    const arrivals = pathCount.get(key);
+    if (arrivals === undefined || arrivals === 0n) continue;
+
+    // This splitter splits into down-left and down-right
+    for (const dir of ['down-left', 'down-right'] as Direction[]) {
+      const trace = traceBeam(splR, splC, dir, grid, rows, cols);
+      if (trace.hitSplitter) {
+        const childKey = `${trace.hitSplitter[0]},${trace.hitSplitter[1]}`;
+        pathCount.set(childKey, (pathCount.get(childKey) ?? 0n) + arrivals);
+      } else {
+        // Beam exits the grid
+        totalExitPaths += arrivals;
+      }
+    }
+  }
+
+  return totalExitPaths;
+}
