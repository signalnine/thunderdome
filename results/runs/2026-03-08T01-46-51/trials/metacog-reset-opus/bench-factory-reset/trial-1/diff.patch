+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  it('returns empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('returns null for the example in TASK.md (no solution)', () => {
+    // target [T, T, F, T], buttons [0,1], [1,2,3], [0,3]
+    // The system is inconsistent
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('solves a simple single-button case', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('solves a two-button case', () => {
+    // Target: [true, true]
+    // Button 0: toggles [0], Button 1: toggles [1]
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0], [1]],
+    });
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('handles overlapping buttons', () => {
+    // Target: [true, false]
+    // Button 0: toggles [0, 1], Button 1: toggles [1]
+    // Press both: light 0 toggled once (on), light 1 toggled twice (off)
+    const result = solveToggle({
+      target: [true, false],
+      buttons: [[0, 1], [1]],
+    });
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('prefers fewer button presses', () => {
+    // Target: [true, false]
+    // Button 0: toggles [0], Button 1: toggles [0, 1], Button 2: toggles [1]
+    // Solution 1: press [0] (1 press)
+    // Solution 2: press [1, 2] (2 presses)
+    const result = solveToggle({
+      target: [true, false],
+      buttons: [[0], [0, 1], [1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('returns lex smallest when tied on count', () => {
+    // Target: [true]
+    // Button 0: toggles [0], Button 1: toggles [0]
+    // Both are 1-press solutions, [0] is lex smallest
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('handles no buttons needed', () => {
+    const result = solveToggle({
+      target: [false, false],
+      buttons: [[0], [1]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('handles larger systems', () => {
+    // 5 lights, 5 buttons (identity-like)
+    const result = solveToggle({
+      target: [true, false, true, false, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    });
+    expect(result).toEqual([0, 2, 4]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 3);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('solves a simple single-button case', () => {
+    // Counter 0 needs to be 2, button 0 affects counter 0, mod 3
+    const result = solveCounter([2], [[0]], 3);
+    expect(result).toEqual([2]);
+  });
+
+  it('solves a two-counter case', () => {
+    // Counters: target [1, 1], buttons: [0] and [1], mod 5
+    const result = solveCounter([1, 1], [[0], [1]], 5);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('handles overlapping buttons mod 3', () => {
+    // Target: [2, 1]
+    // Button 0 affects [0, 1] (+1 each), Button 1 affects [1] (+1)
+    // x0 = 2 (mod 3) for counter 0
+    // x0 + x1 = 1 (mod 3) for counter 1 => 2 + x1 = 1 => x1 = 2 (mod 3)
+    const result = solveCounter([2, 1], [[0, 1], [1]], 3);
+    expect(result).toEqual([2, 2]);
+  });
+
+  it('returns null for impossible systems', () => {
+    // Target: [1, 2], Button 0 affects [0, 1], mod 3
+    // x0 = 1 for counter 0, x0 = 2 for counter 1 — impossible
+    const result = solveCounter([1, 2], [[0, 1]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('prefers minimum total presses', () => {
+    // Target: [0], Buttons: [0] and [0], mod 5
+    // x0 + x1 = 0 (mod 5), so solutions: (0,0), (1,4), (2,3), (3,2), (4,1)
+    // Min total: (0,0) with total 0
+    const result = solveCounter([0], [[0], [0]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('returns lex smallest when tied on total', () => {
+    // Target: [3], Buttons: [0] and [0], mod 5
+    // x0 + x1 = 3 (mod 5), solutions: (0,3), (1,2), (2,1), (3,0), (4,4)
+    // totals: 3, 3, 3, 3, 8
+    // Min total = 3, lex smallest = (0,3)
+    const result = solveCounter([3], [[0], [0]], 5);
+    expect(result).toEqual([0, 3]);
+  });
+
+  it('handles mod 2 (same as toggle)', () => {
+    // Target: [1, 1], Buttons: [0] and [1], mod 2
+    const result = solveCounter([1, 1], [[0], [1]], 2);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('handles larger prime modulus', () => {
+    // Target: [50], Button: [0], mod 97
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+  });
+});
+
+describe('edge cases', () => {
+  it('solveToggle: empty target', () => {
+    const result = solveToggle({
+      target: [],
+      buttons: [],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('solveToggle: no buttons', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('solveToggle: more buttons than lights', () => {
+    // 2 lights, 4 buttons. Multiple solutions possible.
+    // Target: [true, true]
+    // Button 0: [0], Button 1: [1], Button 2: [0, 1], Button 3: [0]
+    // Solutions: [0, 1] (2 presses), [2] (1 press)
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0], [1], [0, 1], [0]],
+    });
+    expect(result).toEqual([2]);
+  });
+
+  it('solveCounter: no buttons', () => {
+    const result = solveCounter([1], [], 3);
+    expect(result).toBeNull();
+  });
+
+  it('solveCounter: zero target with buttons', () => {
+    const result = solveCounter([0, 0], [[0], [1]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+});
+
+describe('performance', () => {
+  it('solveToggle: handles 20 buttons x 20 lights', () => {
+    const n = 20;
+    const target = new Array(n).fill(true);
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+    }
+    const result = solveToggle({ target, buttons });
+    expect(result).not.toBeNull();
+    expect(result!.length).toBe(n);
+  });
+
+  it('solveToggle: handles 40 buttons x 40 lights (identity)', () => {
+    const n = 40;
+    const target = new Array(n).fill(true);
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+    }
+    const result = solveToggle({ target, buttons });
+    expect(result).not.toBeNull();
+    expect(result!.length).toBe(n);
+  });
+
+  it('solveCounter: handles 40 buttons x 40 lights mod 97 (identity)', () => {
+    const n = 40;
+    const target = new Array(n).fill(50);
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+    }
+    const result = solveCounter(target, buttons, 97);
+    expect(result).not.toBeNull();
+    expect(result!.every((v, i) => v === target[i])).toBe(true);
+  });
+
+  it('solveToggle: handles many free variables (40 buttons, 5 lights)', () => {
+    const nLights = 5;
+    const nButtons = 40;
+    const target = new Array(nLights).fill(true);
+    const buttons: number[][] = [];
+    for (let i = 0; i < nButtons; i++) {
+      buttons.push([i % nLights]);
+    }
+    const result = solveToggle({ target, buttons });
+    // Should find a solution (e.g., press button 0,1,2,3,4)
+    expect(result).not.toBeNull();
+    // Verify the solution is correct
+    const lights = new Array(nLights).fill(false);
+    for (const idx of result!) {
+      for (const l of buttons[idx]) {
+        lights[l] = !lights[l];
+      }
+    }
+    expect(lights).toEqual(target);
+  }, 5000);
+});
