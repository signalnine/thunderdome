n   106→    currentRow++;\n   107→  }\n   108→\n   109→  for (let row = 0; row < nLights; row++) {\n   110→    if (pivotCol[row] === -1) {\n   111→      let allZero = true;\n   112→      for (let col = 0; col < nButtons; col++) {\n   113→        if (matrix[row][col] !== 0) {\n   114→          allZero = false;\n   115→          break;\n   116→        }\n   117→      }\n   118→      if (allZero && matrix[row][nButtons] !== 0) {\n   119→        return null;\n   120→      }\n   121→    }\n   122→  }\n   123→\n   124→  const particular = new Array(nButtons).fill(0);\n   125→  for (let row = 0; row < nLights; row++) {\n   126→    if (pivotCol[row] !== -1) {\n   127→      particular[pivotCol[row]] = matrix[row][nButtons];\n   128→    }\n   129→  }\n   130→\n   131→  const freeVars: number[] = [];\n   132→  for (let col = 0; col < nButtons; col++) {\n   133→    if (pivotRow[col] === -1) {\n   134→      freeVars.push(col);\n   135→    }\n   136→  }\n   137→\n   138→  const nullVecs: number[][] = [];\n   139→  for (const freeCol of freeVars) {\n   140→    const vec = new Array(nButtons).fill(0);\n   141→    vec[freeCol] = 1;\n   142→    for (let row = 0; row < nLights; row++) {\n   143→      if (pivotCol[row] !== -1) {\n   144→        vec[pivotCol[row]] = mod(-matrix[row][freeCol], p);\n   145→      }\n   146→    }\n   147→    nullVecs.push(vec);\n   148→  }\n   149→\n   150→  return { particular, nullVecs, nButtons };\n   151→}\n   152→\n   153→// ─── Comparison helpers ──────────────────────────────────────────────\n   154→\n   155→function lexLess(a: number[], b: number[]): boolean {\n   156→  for (let i = 0; i < a.length; i++) {\n   157→    if (a[i] < b[i]) return true;\n   158→    if (a[i] > b[i]) return false;\n   159→  }\n   160→  return false;\n   161→}\n   162→\n   163→function toggleBetter(a: number[], b: number[]): boolean {\n   164→  const countA = a.reduce((s, v) => s + v, 0);\n   165→  const countB = b.reduce((s, v) => s + v, 0);\n   166→  if (countA !== countB) return countA < countB;\n   167→  for (let i = 0; i < a.length; i++) {\n   168→    if (a[i] === 1 && b[i] === 0) return true;\n   169→    if (a[i] === 0 && b[i] === 1) return false;\n   170→  }\n   171→  return false;\n   172→}\n   173→\n   174→function counterBetter(a: number[], b: number[]): boolean {\n   175→  const totalA = a.reduce((s, v) => s + v, 0);\n   176→  const totalB = b.reduce((s, v) => s + v, 0);\n   177→  if (totalA !== totalB) return totalA < totalB;\n   178→  return lexLess(a, b);\n   179→}\n   180→\n   181→// ─── Toggle solver (GF(2) specific with meet-in-the-middle) ─────────\n   182→\n   183→/**\n   184→ * For toggle (p=2), use bitmask-based meet-in-the-middle when the null space is large.\n   185→ * Each solution is a binary vector of length nButtons.\n   186→ * We use BigInt bitmasks for nButtons up to 40.\n   187→ */\n   188→function solveToggleOptimal(gauss: GaussResult): number[] {\n   189→  const { particular, nullVecs, nButtons } = gauss;\n   190→  const nFree = nullVecs.length;\n   191→\n   192→  if (nFree === 0) {\n   193→    return particular;\n   194→  }\n   195→\n   196→  // Convert to bitmasks for fast XOR operations\n   197→  const particularMask = vecToBigMask(particular);\n   198→  const nullMasks = nullVecs.map(v => vecToBigMask(v));\n   199→\n   200→  const totalCombinations = 1 << nFree; // 2^nFree\n   201→\n   202→  if (nFree <= 22) {\n   203→    // Direct enumeration with bitmask XOR\n   204→    let bestMask = particularMask;\n   205→    let bestCount = popcount(particularMask, nButtons);\n   206→    let bestToggleKey = toggleKey(particularMask, nButtons);\n   207→\n   208→    for (let mask = 1; mask < totalCombinations; mask++) {\n   209→      let solMask = particularMask;\n   210→      for (let k = 0; k < nFree; k++) {\n   211→        if (mask & (1 << k)) {\n   212→          solMask ^= nullMasks[k];\n   213→        }\n   214→      }\n   215→      const cnt = popcount(solMask, nButtons);\n   216→      if (cnt < bestCount) {\n   217→        bestCount = cnt;\n   218→        bestMask = solMask;\n   219→        bestToggleKey = toggleKey(solMask, nButtons);\n   220→      } else if (cnt === bestCount) {\n   221→        const key = toggleKey(solMask, nButtons);\n   222→        if (toggleKeyLess(key, bestToggleKey)) {\n   223→          bestMask = solMask;\n   224→          bestToggleKey = key;\n   225→        }\n   226→      }\n   227→    }\n   228→\n   229→    return bigMaskToVec(bestMask, nButtons);\n   230→  }\n   231→\n   232→  // Meet-in-the-middle for nFree > 22\n   233→  const halfA = Math.floor(nFree / 2);\n   234→  const halfB = nFree - halfA;\n   235→  const sizeA = 1 << halfA;\n   236→  const sizeB = 1 << halfB;\n   237→\n   238→  // Enumerate first half: compute XOR contribution to particular solution\n   239→  const halfAMasks: bigint[] = new Array(sizeA);\n   240→  for (let mask = 0; mask < sizeA; mask++) {\n   241→    let solMask = 0n;\n   242→    for (let k = 0; k < halfA; k++) {\n   243→      if (mask & (1 << k)) {\n   244→        solMask ^= nullMasks[k];\n   245→      }\n   246→    }\n   247→    halfAMasks[mask] = solMask;\n   248→  }\n   249→\n   250→  // Enumerate second half\n   251→  const halfBMasks: bigint[] = new Array(sizeB);\n   252→  for (let mask = 0; mask < sizeB; mask++) {\n   253→    let solMask = 0n;\n   254→    for (let k = 0; k < halfB; k++) {\n   255→      if (mask & (1 << k)) {\n   256→        solMask ^= nullMasks[halfA + k];\n   257→      }\n   258→    }\n   259→    halfBMasks[mask] = solMask;\n   260→  }\n   261→\n   262→  // For each combination of first and second half, find the best\n   263→  let bestMask = particularMask;\n   264→  let bestCount = popcount(particularMask, nButtons);\n   265→  let bestToggleKeyVal = toggleKey(particularMask, nButtons);\n   266→\n   267→  // If sizeA * sizeB is manageable (which it should be up to 2^40 / meet-in-middle approach)\n   268→  // But 2^20 * 2^20 = 2^40 iterations is still too many!\n   269→  // We need a smarter meet-in-the-middle.\n   270→\n   271→  // Actually, for the problem constraints: up to 40 buttons, 40 lights.\n   272→  // Worst case: 40 buttons, 0 lights → 40 free variables. But target is empty,\n   273→  // so particular is all zeros, and optimal is all zeros (0 presses).\n   274→  //\n   275→  // More realistically: 40 buttons, 10 lights → rank ≤ 10, up to 30 free variables.\n   276→  // 2^30 ≈ 1 billion, still too many for direct enumeration.\n   277→  //\n   278→  // For meet-in-the-middle on minimum weight binary vector:\n   279→  // We split into two halves and for each half, group by the XOR contribution.\n   280→  // But since solutions are 40-bit vectors, we can't use a simple hash map approach easily.\n   281→  //\n   282→  // Alternative approach: Since p=2, use the Lee/weight-minimization approach.\n   283→  // For minimum-weight codeword, we can sort null vectors to reduce the problem.\n   284→  //\n   285→  // Actually, a good approach for GF(2):\n   286→  // The null space has dimension nFree. We want the minimum weight vector in the coset\n   287→  // particular + span(nullVecs).\n   288→  //\n   289→  // We can try a different approach: systematically reduce the weight using the null vectors.\n   290→  // For each null vector, check if XORing it with the current solution reduces weight.\n   291→  // Repeat until no improvement. This is a greedy approach that finds a local minimum.\n   292→  // Then try all pairs, triples, etc. up to a certain depth.\n   293→\n   294→  // Greedy approach: try XORing each null vector and keep improvements\n   295→  let currentMask = particularMask;\n   296→  let currentCount = popcount(currentMask, nButtons);\n   297→  let improved = true;\n   298→  while (improved) {\n   299→    improved = false;\n   300→    for (let k = 0; k < nFree; k++) {\n   301→      const newMask = currentMask ^ nullMasks[k];\n   302→      const newCount = popcount(newMask, nButtons);\n   303→      if (newCount < currentCount) {\n   304→        currentMask = newMask;\n   305→        currentCount = newCount;\n   306→        improved = true;\n   307→      }\n   308→    }\n   309→  }\n   310→  bestMask = currentMask;\n   311→  bestCount = currentCount;\n   312→  bestToggleKeyVal = toggleKey(bestMask, nButtons);\n   313→\n   314→  // Try all pairs for further improvement\n   315→  for (let i = 0; i < nFree; i++) {\n   316→    for (let j = i + 1; j < nFree; j++) {\n   317→      const newMask = currentMask ^ nullMasks[i] ^ nullMasks[j];\n   318→      const newCount = popcount(newMask, nButtons);\n   319→      if (newCount < bestCount) {\n   320→        bestCount = newCount;\n   321→        bestMask = newMask;\n   322→        bestToggleKeyVal = toggleKey(bestMask, nButtons);\n   323→      } else if (newCount === bestCount) {\n   324→        const key = toggleKey(newMask, nButtons);\n   325→        if (toggleKeyLess(key, bestToggleKeyVal)) {\n   326→          bestMask = newMask;\n   327→          bestToggleKeyVal = key;\n   328→        }\n   329→      }\n   330→    }\n   331→  }\n   332→\n   333→  // For very large null spaces, do a proper meet-in-the-middle with bounded search\n   334→  if (nFree <= 40) {\n   335→    // Meet-in-the-middle: enumerate all first-half, store in a map keyed by XOR value\n   336→    // For each second-half, look up the best match\n   337→    // But we want to minimize popcount(particular XOR halfA XOR halfB)\n   338→    // = popcount((particular XOR halfA) XOR halfB)\n   339→    //\n   340→    // For each halfB value, we want to find the halfA value that when XORed gives\n   341→    // the lowest popcount with (particular XOR halfA XOR halfB).\n   342→    //\n   343→    // This is equivalent to: for each (pA = particular XOR halfA), find halfB\n   344→    // minimizing popcount(pA XOR halfB).\n   345→    //\n   346→    // If we store all halfB values, then for each pA, we need the nearest neighbor\n   347→    // in Hamming distance. This is hard in general.\n   348→    //\n   349→    // Alternative: just enumerate smaller halves and use partial matching.\n   350→    // With halfA = 20, halfB = 20: store all 2^20 halfB solutions, for each of 2^20 halfA\n   351→    // solutions, find the best halfB. If we sort halfB values, we can do binary search.\n   352→    //\n   353→    // Actually, the simplest approach that works: if nFree > 22, use a hybrid.\n   354→    // Split into groups, enumerate each group, and combine greedily.\n   355→\n   356→    // Group the null vectors into chunks of at most 20\n   357→    const chunkSize = Math.min(20, nFree);\n   358→    const nChunks = Math.ceil(nFree / chunkSize);\n   359→\n   360→    if (nChunks <= 2) {\n   361→      // Two chunks: proper meet-in-the-middle\n   362→      // Enumerate all combinations of the second half, store them sorted\n   363→      const sMasks: bigint[] = new Array(sizeB);\n   364→      for (let mask = 0; mask < sizeB; mask++) {\n   365→        sMasks[mask] = halfBMasks[mask];\n   366→      }\n   367→\n   368→      // For each first-half combination, find the best second-half\n   369→      for (let maskA = 0; maskA < sizeA; maskA++) {\n   370→        const pA = particularMask ^ halfAMasks[maskA];\n   371→        // Try all second-half combinations\n   372→        for (let maskB = 0; maskB < sizeB; maskB++) {\n   373→          const fullMask = pA ^ sMasks[maskB];\n   374→          const cnt = popcount(fullMask, nButtons);\n   375→          if (cnt < bestCount) {\n   376→            bestCount = cnt;\n   377→            bestMask = fullMask;\n   378→            bestToggleKeyVal = toggleKey(fullMask, nButtons);\n   379→          } else if (cnt === bestCount) {\n   380→            const key = toggleKey(fullMask, nButtons);\n   381→            if (toggleKeyLess(key, bestToggleKeyVal)) {\n   382→              bestMask = fullMask;\n   383→              bestToggleKeyVal = key;\n   384→            }\n   385→          }\n   386→        }\n   387→      }\n   388→    }\n   389→  }\n   390→\n   391→  return bigMaskToVec(bestMask, nButtons);\n   392→}\n   393→\n   394→function vecToBigMask(vec: number[]): bigint {\n   395→  let mask = 0n;\n   396→  for (let i = 0; i < vec.length; i++) {\n   397→    if (vec[i]) mask |= 1n << BigInt(i);\n   398→  }\n   399→  return mask;\n   400→}\n   401→\n   402→function bigMaskToVec(mask: bigint, n: number): number[] {\n   403→  const vec = new Array(n);\n   404→  for (let i = 0; i < n; i++) {\n   405→    vec[i] = Number((mask >> BigInt(i)) & 1n);\n   406→  }\n   407→  return vec;\n   408→}\n   409→\n   410→function popcount(mask: bigint, n: number): number {\n   411→  let count = 0;\n   412→  let m = mask;\n   413→  for (let i = 0; i < n; i++) {\n   414→    if (m & 1n) count++;\n   415→    m >>= 1n;\n   416→  }\n   417→  return count;\n   418→}\n   419→\n   420→/** Generate a key for toggle comparison: the list of pressed indices as a string */\n   421→function toggleKey(mask: bigint, n: number): string {\n   422→  const indices: number[] = [];\n   423→  for (let i = 0; i < n; i++) {\n   424→    if ((mask >> BigInt(i)) & 1n) indices.push(i);\n   425→  }\n   426→  return indices.join(',');\n   427→}\n   428→\n   429→function toggleKeyLess(a: string, b: string): boolean {\n   430→  const aa = a ? a.split(',').map(Number) : [];\n   431→  const bb = b ? b.split(',').map(Number) : [];\n   432→  // Same count (already ensured by caller checking count first)\n   433→  const len = Math.min(aa.length, bb.length);\n   434→  for (let i = 0; i < len; i++) {\n   435→    if (aa[i] < bb[i]) return true;\n   436→    if (aa[i] > bb[i]) return false;\n   437→  }\n   438→  return aa.length < bb.length;\n   439→}\n   440→\n   441→// ─── Counter solver (GF(p)) ─────────────────────────────────────────\n   442→\n   443→function solveCounterOptimal(gauss: GaussResult, p: number): number[] {\n   444→  const { particular, nullVecs, nButtons } = gauss;\n   445→  const nFree = nullVecs.length;\n   446→\n   447→  if (nFree === 0) {\n   448→    return particular.map(v => mod(v, p));\n   449→  }\n   450→\n   451→  const totalCombinations = Math.pow(p, nFree);\n   452→\n   453→  if (totalCombinations <= 5_000_000) {\n   454→    let bestSolution: number[] | null = null;\n   455→    let bestTotal = Infinity;\n   456→\n   457→    const freeValues = new Array(nFree).fill(0);\n   458→\n   459→    for (let iter = 0; iter < totalCombinations; iter++) {\n   460→      const solution = new Array(nButtons);\n   461→      let total = 0;\n   462→      for (let j = 0; j < nButtons; j++) {\n   463→        let val = particular[j];\n   464→        for (let k = 0; k < nFree; k++) {\n   465→          val += freeValues[k] * nullVecs[k][j];\n   466→        }\n   467→        solution[j] = mod(val, p);\n   468→        total += solution[j];\n   469→      }\n   470→\n   471→      if (total < bestTotal || (total === bestTotal && bestSolution !== null && lexLess(solution, bestSolution))) {\n   472→        bestTotal = total;\n   473→        bestSolution = solution.slice();\n   474→      }\n   475→\n   476→      // Increment mixed-radix counter\n   477→      let carry = 0;\n   478→      freeValues[nFree - 1]++;\n   479→      for (let k = nFree - 1; k >= 0; k--) {\n   480→        freeValues[k] += carry;\n   481→        carry = 0;\n   482→        if (freeValues[k] >= p) {\n   483→          freeValues[k] = 0;\n   484→          carry = 1;\n   485→        } else {\n   486→          break;\n   487→        }\n   488→      }\n   489→    }\n   490→\n   491→    return bestSolution!;\n   492→  }\n   493→\n   494→  // For large null spaces with p > 2, use greedy optimization\n   495→  // Try all single-variable settings for each free variable\n   496→  let bestSolution = particular.map(v => mod(v, p));\n   497→  let bestTotal = bestSolution.reduce((a, b) => a + b, 0);\n   498→\n   499→  // Greedy: for each free variable, try all p values and pick the best\n   500→  const currentCoeffs = new Array(nFree).fill(0);\n   501→  let improved = true;\n   502→  while (improved) {\n   503→    improved = false;\n   504→    for (let k = 0; k < nFree; k++) {\n   505→      let bestVal = currentCoeffs[k];\n   506→      let bestLocalTotal = bestTotal;\n   507→      let bestLocalSolution = bestSolution;\n   508→\n   509→      for (let v = 0; v < p; v++) {\n   510→        if (v === currentCoeffs[k]) continue;\n   511→        const diff = v - currentCoeffs[k];\n   512→        const solution = new Array(nButtons);\n   513→        let total = 0;\n   514→        for (let j = 0; j < nButtons; j++) {\n   515→          solution[j] = mod(bestSolution[j] + diff * nullVecs[k][j], p);\n   516→          total += solution[j];\n   517→        }\n   518→        if (total < bestLocalTotal || (total === bestLocalTotal && lexLess(solution, bestLocalSolution))) {\n   519→          bestLocalTotal = total;\n   520→          bestLocalSolution = solution;\n   521→          bestVal = v;\n   522→        }\n   523→      }\n   524→\n   525→      if (bestVal !== currentCoeffs[k]) {\n   526→        currentCoeffs[k] = bestVal;\n   527→        bestTotal = bestLocalTotal;\n   528→        bestSolution = bestLocalSolution;\n   529→        improved = true;\n   530→      }\n   531→    }\n   532→  }\n   533→\n   534→  return bestSolution;\n   535→}\n   536→\n   537→// ─── Public API ──────────────────────────────────────────────────────\n   538→\n   539→export function solveToggle(machine: Machine): number[] | null {\n   540→  const { target, buttons } = machine;\n   541→  const nLights = target.length;\n   542→  const nButtons = buttons.length;\n   543→\n   544→  const targetNums = target.map(t => t ? 1 : 0);\n   545→\n   546→  const gauss = gaussianElimination(nLights, nButtons, buttons, targetNums, 2);\n   547→  if (gauss === null) return null;\n   548→\n   549→  const solution = solveToggleOptimal(gauss);\n   550→\n   551→  const pressed: number[] = [];\n   552→  for (let i = 0; i < nButtons; i++) {\n   553→    if (solution[i] === 1) pressed.push(i);\n   554→  }\n   555→\n   556→  return pressed.sort((a, b) => a - b);\n   557→}\n   558→\n   559→export function solveCounter(\n   560→  lights: number[],\n   561→  buttons: number[][],\n   562→  modulus: number\n   563→): number[] | null {\n   564→  const nLights = lights.length;\n   565→  const nButtons = buttons.length;\n   566→\n   567→  const gauss = gaussianElimination(nLights, nButtons, buttons, lights, modulus);\n   568→  if (gauss === null) return null;\n   569→\n   570→  return solveCounterOptimal(gauss, modulus);\n   571→}\n   572→"}]},"parent_tool_use_id":null,"session_id":"b65653c6-ad8a-4278-b6fc-a3cf98c6da41","uuid":"9264a0c5-542e-41fa-9111-0701c123910f","tool_use_result":{"type":"update","filePath":"/workspace/src/index.ts","content":"/**\n * Factory Reset — Toggle and Counter puzzle solvers.\n *\n * Both problems reduce to solving a system of linear equations over a finite field:\n *   A * x = b  (mod p)\n * where A is the button-to-light incidence matrix, x is the vector of button presses,\n * and b is the target configuration.\n *\n * For toggle puzzles, p = 2 (GF(2), XOR).\n * For counter puzzles, p is a given prime.\n *\n * We use Gaussian elimination to find a particular solution and the null space,\n * then enumerate over null space combinations to find the optimal solution.\n */\n\n// ─── Types ───────────────────────────────────────────────────────────\n\ninterface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// ─── Modular arithmetic helpers ──────────────────────────────────────\n\nfunction mod(a: number, p: number): number {\n  return ((a % p) + p) % p;\n}\n\nfunction modInverse(a: number, p: number): number {\n  a = mod(a, p);\n  if (a === 0) throw new Error(\"No inverse for 0\");\n  let result = 1;\n  let base = a;\n  let exp = p - 2;\n  while (exp > 0) {\n    if (exp & 1) result = (result * base) % p;\n    base = (base * base) % p;\n    exp >>= 1;\n  }\n  return result;\n}\n\n// ─── Gaussian elimination core ───────────────────────────────────────\n\ninterface GaussResult {\n  particular: number[];\n  nullVecs: number[][];\n  nButtons: number;\n}\n\nfunction gaussianElimination(\n  nLights: number,\n  nButtons: number,\n  buttons: number[][],\n  target: number[],\n  p: number\n): GaussResult | null {\n  const matrix: number[][] = [];\n  for (let i = 0; i < nLights; i++) {\n    const row = new Array(nButtons + 1).fill(0);\n    row[nButtons] = mod(target[i], p);\n    matrix.push(row);\n  }\n  for (let j = 0; j < nButtons; j++) {\n    for (const lightIdx of buttons[j]) {\n      if (lightIdx < nLights) {\n        matrix[lightIdx][j] = mod(matrix[lightIdx][j] + 1, p);\n      }\n    }\n  }\n\n  const pivotCol: number[] = new Array(nLights).fill(-1);\n  const pivotRow: number[] = new Array(nButtons).fill(-1);\n\n  let currentRow = 0;\n  for (let col = 0; col < nButtons && currentRow < nLights; col++) {\n    let found = -1;\n    for (let row = currentRow; row < nLights; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    if (found !== currentRow) {\n      [matrix[currentRow], matrix[found]] = [matrix[found], matrix[currentRow]];\n    }\n\n    pivotCol[currentRow] = col;\n    pivotRow[col] = currentRow;\n\n    const inv = modInverse(matrix[currentRow][col], p);\n    for (let j = col; j <= nButtons; j++) {\n      matrix[currentRow][j] = mod(matrix[currentRow][j] * inv, p);\n    }\n\n    for (let row = 0; row < nLights; row++) {\n      if (row === currentRow || matrix[row][col] === 0) continue;\n      const factor = matrix[row][col];\n      for (let j = col; j <= nButtons; j++) {\n        matrix[row][j] = mod(matrix[row][j] - factor * matrix[currentRow][j], p);\n      }\n    }\n\n    currentRow++;\n  }\n\n  for (let row = 0; row < nLights; row++) {\n    if (pivotCol[row] === -1) {\n      let allZero = true;\n      for (let col = 0; col < nButtons; col++) {\n        if (matrix[row][col] !== 0) {\n          allZero = false;\n          break;\n        }\n      }\n      if (allZero && matrix[row][nButtons] !== 0) {\n        return null;\n      }\n    }\n  }\n\n  const particular = new Array(nButtons).fill(0);\n  for (let row = 0; row < nLights; row++) {\n    if (pivotCol[row] !== -1) {\n      particular[pivotCol[row]] = matrix[row][nButtons];\n    }\n  }\n\n  const freeVars: number[] = [];\n  for (let col = 0; col < nButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const nullVecs: number[][] = [];\n  for (const freeCol of freeVars) {\n    const vec = new Array(nButtons).fill(0);\n    vec[freeCol] = 1;\n    for (let row = 0; row < nLights; row++) {\n      if (pivotCol[row] !== -1) {\n        vec[pivotCol[row]] = mod(-matrix[row][freeCol], p);\n      }\n    }\n    nullVecs.push(vec);\n  }\n\n  return { particular, nullVecs, nButtons };\n}\n\n// ─── Comparison helpers ──────────────────────────────────────────────\n\nfunction lexLess(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\nfunction toggleBetter(a: number[], b: number[]): boolean {\n  const countA = a.reduce((s, v) => s + v, 0);\n  const countB = b.reduce((s, v) => s + v, 0);\n  if (countA !== countB) return countA < countB;\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] === 1 && b[i] === 0) return true;\n    if (a[i] === 0 && b[i] === 1) return false;\n  }\n  return false;\n}\n\nfunction counterBetter(a: number[], b: number[]): boolean {\n  const totalA = a.reduce((s, v) => s + v, 0);\n  const totalB = b.reduce((s, v) => s + v, 0);\n  if (totalA !== totalB) return totalA < totalB;\n  return lexLess(a, b);\n}\n\n// ─── Toggle solver (GF(2) specific with meet-in-the-middle) ─────────\n\n/**\n * For toggle (p=2), use bitmask-based meet-in-the-middle when the null space is large.\n * Each solution is a binary vector of length nButtons.\n * We use BigInt bitmasks for nButtons up to 40.\n */\nfunction solveToggleOptimal(gauss: GaussResult): number[] {\n  const { particular, nullVecs, nButtons } = gauss;\n  const nFree = nullVecs.length;\n\n  if (nFree === 0) {\n    return particular;\n  }\n\n  // Convert to bitmasks for fast XOR operations\n  const particularMask = vecToBigMask(particular);\n  const nullMasks = nullVecs.map(v => vecToBigMask(v));\n\n  const totalCombinations = 1 << nFree; // 2^nFree\n\n  if (nFree <= 22) {\n    // Direct enumeration with bitmask XOR\n    let bestMask = particularMask;\n    let bestCount = popcount(particularMask, nButtons);\n    let bestToggleKey = toggleKey(particularMask, nButtons);\n\n    for (let mask = 1; mask < totalCombinations; mask++) {\n      let solMask = particularMask;\n      for (let k = 0; k < nFree; k++) {\n        if (mask & (1 << k)) {\n          solMask ^= nullMasks[k];\n        }\n      }\n      const cnt = popcount(solMask, nButtons);\n      if (cnt < bestCount) {\n        bestCount = cnt;\n        bestMask = solMask;\n        bestToggleKey = toggleKey(solMask, nButtons);\n      } else if (cnt === bestCount) {\n        const key = toggleKey(solMask, nButtons);\n        if (toggleKeyLess(key, bestToggleKey)) {\n          bestMask = solMask;\n          bestToggleKey = key;\n        }\n      }\n    }\n\n    return bigMaskToVec(bestMask, nButtons);\n  }\n\n  // Meet-in-the-middle for nFree > 22\n  const halfA = Math.floor(nFree / 2);\n  const halfB = nFree - halfA;\n  const sizeA = 1 << halfA;\n  const sizeB = 1 << halfB;\n\n  // Enumerate first half: compute XOR contribution to particular solution\n  const halfAMasks: bigint[] = new Array(sizeA);\n  for (let mask = 0; mask < sizeA; mask++) {\n    let solMask = 0n;\n    for (let k = 0; k < halfA; k++) {\n      if (mask & (1 << k)) {\n        solMask ^= nullMasks[k];\n      }\n    }\n    halfAMasks[mask] = solMask;\n  }\n\n  // Enumerate second half\n  const halfBMasks: bigint[] = new Array(sizeB);\n  for (let mask = 0; mask < sizeB; mask++) {\n    let solMask = 0n;\n    for (let k = 0; k < halfB; k++) {\n      if (mask & (1 << k)) {\n        solMask ^= nullMasks[halfA + k];\n      }\n    }\n    halfBMasks[mask] = solMask;\n  }\n\n  // For each combination of first and second half, find the best\n  let bestMask = particularMask;\n  let bestCount = popcount(particularMask, nButtons);\n  let bestToggleKeyVal = toggleKey(particularMask, nButtons);\n\n  // If sizeA * sizeB is manageable (which it should be up to 2^40 / meet-in-middle approach)\n  // But 2^20 * 2^20 = 2^40 iterations is still too many!\n  // We need a smarter meet-in-the-middle.\n\n  // Actually, for the problem constraints: up to 40 buttons, 40 lights.\n  // Worst case: 40 buttons, 0 lights → 40 free variables. But target is empty,\n  // so particular is all zeros, and optimal is all zeros (0 presses).\n  //\n  // More realistically: 40 buttons, 10 lights → rank ≤ 10, up to 30 free variables.\n  // 2^30 ≈ 1 billion, still too many for direct enumeration.\n  //\n  // For meet-in-the-middle on minimum weight binary vector:\n  // We split into two halves and for each half, group by the XOR contribution.\n  // But since solutions are 40-bit vectors, we can't use a simple hash map approach easily.\n  //\n  // Alternative approach: Since p=2, use the Lee/weight-minimization approach.\n  // For minimum-weight codeword, we can sort null vectors to reduce the problem.\n  //\n  // Actually, a good approach for GF(2):\n  // The null space has dimension nFree. We want the minimum weight vector in the coset\n  // particular + span(nullVecs).\n  //\n  // We can try a different approach: systematically reduce the weight using the null vectors.\n  // For each null vector, check if XORing it with the current solution reduces weight.\n  // Repeat until no improvement. This is a greedy approach that finds a local minimum.\n  // Then try all pairs, triples, etc. up to a certain depth.\n\n  // Greedy approach: try XORing each null vector and keep improvements\n  let currentMask = particularMask;\n  let currentCount = popcount(currentMask, nButtons);\n  let improved = true;\n  while (improved) {\n    improved = false;\n    for (let k = 0; k < nFree; k++) {\n      const newMask = currentMask ^ nullMasks[k];\n      const newCount = popcount(newMask, nButtons);\n      if (newCount < currentCount) {\n        currentMask = newMask;\n        currentCount = newCount;\n        improved = true;\n      }\n    }\n  }\n  bestMask = currentMask;\n  bestCount = currentCount;\n  bestToggleKeyVal = toggleKey(bestMask, nButtons);\n\n  // Try all pairs for further improvement\n  for (let i = 0; i < nFree; i++) {\n    for (let j = i + 1; j < nFree; j++) {\n      const newMask = currentMask ^ nullMasks[i] ^ nullMasks[j];\n      const newCount = popcount(newMask, nButtons);\n      if (newCount < bestCount) {\n        bestCount = newCount;\n        bestMask = newMask;\n        bestToggleKeyVal = toggleKey(bestMask, nButtons);\n      } else if (newCount === bestCount) {\n        const key = toggleKey(newMask, nButtons);\n        if (toggleKeyLess(key, bestToggleKeyVal)) {\n          bestMask = newMask;\n          bestToggleKeyVal = key;\n        }\n      }\n    }\n  }\n\n  // For very large null spaces, do a proper meet-in-the-middle with bounded search\n  if (nFree <= 40) {\n    // Meet-in-the-middle: enumerate all first-half, store in a map keyed by XOR value\n    // For each second-half, look up the best match\n    // But we want to minimize popcount(particular XOR halfA XOR halfB)\n    // = popcount((particular XOR halfA) XOR halfB)\n    //\n    // For each halfB value, we want to find the halfA value that when XORed gives\n    // the lowest popcount with (particular XOR halfA XOR halfB).\n    //\n    // This is equivalent to: for each (pA = particular XOR halfA), find halfB\n    // minimizing popcount(pA XOR halfB).\n    //\n    // If we store all halfB values, then for each pA, we need the nearest neighbor\n    // in Hamming distance. This is hard in general.\n    //\n    // Alternative: just enumerate smaller halves and use partial matching.\n    // With halfA = 20, halfB = 20: store all 2^20 halfB solutions, for each of 2^20 halfA\n    // solutions, find the best halfB. If we sort halfB values, we can do binary search.\n    //\n    // Actually, the simplest approach that works: if nFree > 22, use a hybrid.\n    // Split into groups, enumerate each group, and combine greedily.\n\n    // Group the null vectors into chunks of at most 20\n    const chunkSize = Math.min(20, nFree);\n    const nChunks = Math.ceil(nFree / chunkSize);\n\n    if (nChunks <= 2) {\n      // Two chunks: proper meet-in-the-middle\n      // Enumerate all combinations of the second half, store them sorted\n      const sMasks: bigint[] = new Array(sizeB);\n      for (let mask = 0; mask < sizeB; mask++) {\n        sMasks[mask] = halfBMasks[mask];\n      }\n\n      // For each first-half combination, find the best second-half\n      for (let maskA = 0; maskA < sizeA; maskA++) {\n        const pA = particularMask ^ halfAMasks[maskA];\n        // Try all second-half combinations\n        for (let maskB = 0; maskB < sizeB; maskB++) {\n          const fullMask = pA ^ sMasks[maskB];\n          const cnt = popcount(fullMask, nButtons);\n          if (cnt < bestCount) {\n            bestCount = cnt;\n            bestMask = fullMask;\n            bestToggleKeyVal = toggleKey(fullMask, nButtons);\n          } else if (cnt === bestCount) {\n            const key = toggleKey(fullMask, nButtons);\n            if (toggleKeyLess(key, bestToggleKeyVal)) {\n              bestMask = fullMask;\n              bestToggleKeyVal = key;\n            }\n          }\n        }\n      }\n    }\n  }\n\n  return bigMaskToVec(bestMask, nButtons);\n}\n\nfunction vecToBigMask(vec: number[]): bigint {\n  let mask = 0n;\n  for (let i = 0; i < vec.length; i++) {\n    if (vec[i]) mask |= 1n << BigInt(i);\n  }\n  return mask;\n}\n\nfunction bigMaskToVec(mask: bigint, n: number): number[] {\n  const vec = new Array(n);\n  for (let i = 0; i < n; i++) {\n    vec[i] = Number((mask >> BigInt(i)) & 1n);\n  }\n  return vec;\n}\n\nfunction popcount(mask: bigint, n: number): number {\n  let count = 0;\n  let m = mask;\n  for (let i = 0; i < n; i++) {\n    if (m & 1n) count++;\n    m >>= 1n;\n  }\n  return count;\n}\n\n/** Generate a key for toggle comparison: the list of pressed indices as a string */\nfunction toggleKey(mask: bigint, n: number): string {\n  const indices: number[] = [];\n  for (let i = 0; i < n; i++) {\n    if ((mask >> BigInt(i)) & 1n) indices.push(i);\n  }\n  return indices.join(',');\n}\n\nfunction toggleKeyLess(a: string, b: string): boolean {\n  const aa = a ? a.split(',').map(Number) : [];\n  const bb = b ? b.split(',').map(Number) : [];\n  // Same count (already ensured by caller checking count first)\n  const len = Math.min(aa.length, bb.length);\n  for (let i = 0; i < len; i++) {\n    if (aa[i] < bb[i]) return true;\n    if (aa[i] > bb[i]) return false;\n  }\n  return aa.length < bb.length;\n}\n\n// ─── Counter solver (GF(p)) ─────────────────────────────────────────\n\nfunction solveCounterOptimal(gauss: GaussResult, p: number): number[] {\n  const { particular, nullVecs, nButtons } = gauss;\n  const nFree = nullVecs.length;\n\n  if (nFree === 0) {\n    return particular.map(v => mod(v, p));\n  }\n\n  const totalCombinations = Math.pow(p, nFree);\n\n  if (totalCombinations <= 5_000_000) {\n    let bestSolution: number[] | null = null;\n    let bestTotal = Infinity;\n\n    const freeValues = new Array(nFree).fill(0);\n\n    for (let iter = 0; iter < totalCombinations; iter++) {\n      const solution = new Array(nButtons);\n      let total = 0;\n      for (let j = 0; j < nButtons; j++) {\n        let val = particular[j];\n        for (let k = 0; k < nFree; k++) {\n          val += freeValues[k] * nullVecs[k][j];\n        }\n        solution[j] = mod(val, p);\n        total += solution[j];\n      }\n\n      if (total < bestTotal || (total === bestTotal && bestSolution !== null && lexLess(solution, bestSolution))) {\n        bestTotal = total;\n        bestSolution = solution.slice();\n      }\n\n      // Increment mixed-radix counter\n      let carry = 0;\n      freeValues[nFree - 1]++;\n      for (let k = nFree - 1; k >= 0; k--) {\n        freeValues[k] += carry;\n        carry = 0;\n        if (freeValues[k] >= p) {\n          freeValues[k] = 0;\n          carry = 1;\n        } else {\n          break;\n        }\n      }\n    }\n\n    return bestSolution!;\n  }\n\n  // For large null spaces with p > 2, use greedy optimization\n  // Try all single-variable settings for each free variable\n  let bestSolution = particular.map(v => mod(v, p));\n  let bestTotal = bestSolution.reduce((a, b) => a + b, 0);\n\n  // Greedy: for each free variable, try all p values and pick the best\n  const currentCoeffs = new Array(nFree).fill(0);\n  let improved = true;\n  while (improved) {\n    improved = false;\n    for (let k = 0; k < nFree; k++) {\n      let bestVal = currentCoeffs[k];\n      let bestLocalTotal = bestTotal;\n      let bestLocalSolution = bestSolution;\n\n      for (let v = 0; v < p; v++) {\n        if (v === currentCoeffs[k]) continue;\n        const diff = v - currentCoeffs[k];\n        const solution = new Array(nButtons);\n        let total = 0;\n        for (let j = 0; j < nButtons; j++) {\n          solution[j] = mod(bestSolution[j] + diff * nullVecs[k][j], p);\n          total += solution[j];\n        }\n        if (total < bestLocalTotal || (total === bestLocalTotal && lexLess(solution, bestLocalSolution))) {\n          bestLocalTotal = total;\n          bestLocalSolution = solution;\n          bestVal = v;\n        }\n      }\n\n      if (bestVal !== currentCoeffs[k]) {\n        currentCoeffs[k] = bestVal;\n        bestTotal = bestLocalTotal;\n        bestSolution = bestLocalSolution;\n        improved = true;\n      }\n    }\n  }\n\n  return bestSolution;\n}\n\n// ─── Public API ──────────────────────────────────────────────────────\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const nLights = target.length;\n  const nButtons = buttons.length;\n\n  const targetNums = target.map(t => t ? 1 : 0);\n\n  const gauss = gaussianElimination(nLights, nButtons, buttons, targetNums, 2);\n  if (gauss === null) return null;\n\n  const solution = solveToggleOptimal(gauss);\n\n  const pressed: number[] = [];\n  for (let i = 0; i < nButtons; i++) {\n    if (solution[i] === 1) pressed.push(i);\n  }\n\n  return pressed.sort((a, b) => a - b);\n}\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const nLights = lights.length;\n  const nButtons = buttons.length;\n\n  const gauss = gaussianElimination(nLights, nButtons, buttons, lights, modulus);\n  if (gauss === null) return null;\n\n  return solveCounterOptimal(gauss, modulus);\n}\n","structuredPatch":[{"oldStart":26,"oldLines":7,"newStart":26,"newLines":6,"lines":["   return ((a % p) + p) % p;"," }"," ","-/** Modular multiplicative inverse via Fermat's little theorem. p must be prime. */"," function modInverse(a: number, p: number): number {","   a = mod(a, p);","   if (a === 0) throw new Error(\"No inverse for 0\");"]},{"oldStart":44,"oldLines":15,"newStart":43,"newLines":11,"lines":[" // ─── Gaussian elimination core ───────────────────────────────────────"," "," interface GaussResult {","-  particular: number[] | null;","+  particular: number[];","   nullVecs: number[][];","   nButtons: number;"," }"," ","-/**","- * Perform Gaussian elimination on A*x = b (mod p).","- * Returns a particular solution and the null space basis, or null if inconsistent.","- */"," function gaussianElimination(","   nLights: number,","   nButtons: number,"]},{"oldStart":60,"oldLines":7,"newStart":55,"newLines":6,"lines":["   target: number[],","   p: 