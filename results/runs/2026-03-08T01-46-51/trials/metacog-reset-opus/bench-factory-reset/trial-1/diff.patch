tion and the null space,\n * then enumerate over null space combinations to find the optimal solution.\n */\n\n// ─── Types ───────────────────────────────────────────────────────────\n\ninterface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// ─── Modular arithmetic helpers ──────────────────────────────────────\n\nfunction mod(a: number, p: number): number {\n  return ((a % p) + p) % p;\n}\n\n/** Modular multiplicative inverse using extended Euclidean algorithm. p must be prime. */\nfunction modInverse(a: number, p: number): number {\n  a = mod(a, p);\n  if (a === 0) throw new Error(\"No inverse for 0\");\n  // Fermat's little theorem: a^(p-2) mod p\n  let result = 1;\n  let base = a;\n  let exp = p - 2;\n  while (exp > 0) {\n    if (exp & 1) result = (result * base) % p;\n    base = (base * base) % p;\n    exp >>= 1;\n  }\n  return result;\n}\n\n// ─── Core solver over GF(p) ─────────────────────────────────────────\n\n/**\n * Solve A * x = b (mod p) where:\n *   - A is an nLights x nButtons matrix\n *   - b is the target vector of length nLights\n *   - x[i] ∈ {0, ..., p-1}\n *\n * Returns the optimal x (min total presses, then lex smallest), or null if unsolvable.\n */\nfunction solveLinearSystem(\n  nLights: number,\n  nButtons: number,\n  buttons: number[][],\n  target: number[],\n  p: number\n): number[] | null {\n  // Build augmented matrix [A | b] with dimensions nLights x (nButtons + 1)\n  // A[row][col] = how many times button col affects light row\n  const matrix: number[][] = [];\n  for (let i = 0; i < nLights; i++) {\n    const row = new Array(nButtons + 1).fill(0);\n    row[nButtons] = mod(target[i], p);\n    matrix.push(row);\n  }\n  for (let j = 0; j < nButtons; j++) {\n    for (const lightIdx of buttons[j]) {\n      if (lightIdx < nLights) {\n        matrix[lightIdx][j] = mod(matrix[lightIdx][j] + 1, p);\n      }\n    }\n  }\n\n  // Gaussian elimination with partial pivoting\n  // pivotCol[row] = column index of the pivot in this row, or -1\n  const pivotCol: number[] = new Array(nLights).fill(-1);\n  // pivotRow[col] = row index where this column is a pivot, or -1\n  const pivotRow: number[] = new Array(nButtons).fill(-1);\n\n  let currentRow = 0;\n  for (let col = 0; col < nButtons && currentRow < nLights; col++) {\n    // Find a row with nonzero entry in this column\n    let found = -1;\n    for (let row = currentRow; row < nLights; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue; // Free variable\n\n    // Swap rows\n    if (found !== currentRow) {\n      [matrix[currentRow], matrix[found]] = [matrix[found], matrix[currentRow]];\n    }\n\n    pivotCol[currentRow] = col;\n    pivotRow[col] = currentRow;\n\n    // Scale pivot row so pivot element = 1\n    const inv = modInverse(matrix[currentRow][col], p);\n    for (let j = col; j <= nButtons; j++) {\n      matrix[currentRow][j] = mod(matrix[currentRow][j] * inv, p);\n    }\n\n    // Eliminate this column in all other rows\n    for (let row = 0; row < nLights; row++) {\n      if (row === currentRow || matrix[row][col] === 0) continue;\n      const factor = matrix[row][col];\n      for (let j = col; j <= nButtons; j++) {\n        matrix[row][j] = mod(matrix[row][j] - factor * matrix[currentRow][j], p);\n      }\n    }\n\n    currentRow++;\n  }\n\n  // Check for inconsistency: any row with all-zero coefficients but nonzero RHS\n  for (let row = 0; row < nLights; row++) {\n    if (pivotCol[row] === -1) {\n      // Check if this row has any nonzero coefficient\n      let allZero = true;\n      for (let col = 0; col < nButtons; col++) {\n        if (matrix[row][col] !== 0) {\n          allZero = false;\n          break;\n        }\n      }\n      if (allZero && matrix[row][nButtons] !== 0) {\n        return null; // Inconsistent system\n      }\n    }\n  }\n\n  // Identify free variables (columns that are not pivot columns)\n  const freeVars: number[] = [];\n  for (let col = 0; col < nButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  // If no free variables, there's a unique solution\n  if (freeVars.length === 0) {\n    const solution = new Array(nButtons).fill(0);\n    for (let row = 0; row < nLights; row++) {\n      if (pivotCol[row] !== -1) {\n        solution[pivotCol[row]] = matrix[row][nButtons];\n      }\n    }\n    return solution;\n  }\n\n  // With free variables, we need to find the optimal solution.\n  // The solution space is: x = particular + sum(freeVarValues[i] * nullVec[i])\n  // We need to enumerate over all p^(#freeVars) combinations.\n\n  // Build particular solution (free vars = 0)\n  const particular = new Array(nButtons).fill(0);\n  for (let row = 0; row < nLights; row++) {\n    if (pivotCol[row] !== -1) {\n      particular[pivotCol[row]] = matrix[row][nButtons];\n    }\n  }\n\n  // Build null space vectors: for each free variable, set it to 1 and others to 0\n  const nullVecs: number[][] = [];\n  for (const freeCol of freeVars) {\n    const vec = new Array(nButtons).fill(0);\n    vec[freeCol] = 1;\n    // For each pivot variable, compute its value\n    for (let row = 0; row < nLights; row++) {\n      if (pivotCol[row] !== -1) {\n        // The pivot variable's value is -matrix[row][freeCol] (the coefficient of freeCol in this row)\n        vec[pivotCol[row]] = mod(-matrix[row][freeCol], p);\n      }\n    }\n    nullVecs.push(vec);\n  }\n\n  const nFree = freeVars.length;\n\n  // For small null spaces, enumerate all combinations\n  // For p=2 and nFree <= 25, that's 2^25 ≈ 33M which is feasible\n  // For larger p, we might need smarter approaches, but given constraints (40 buttons, 40 lights),\n  // the null space dimension is typically small\n\n  const totalCombinations = Math.pow(p, nFree);\n\n  if (totalCombinations <= 5_000_000) {\n    // Direct enumeration\n    let bestSolution: number[] | null = null;\n    let bestTotal = Infinity;\n\n    // Enumerate