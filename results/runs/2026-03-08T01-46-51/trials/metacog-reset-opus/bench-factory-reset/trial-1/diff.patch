too large to enumerate.\n *\n * Actually, for this problem with the given constraints (up to 40 buttons/lights),\n * the null space can't be too large in practice. But let's handle it properly.\n *\n * For GF(p) with large null space, we can solve it as an integer linear program,\n * but a simpler approach: iterate through all combinations greedily.\n *\n * Given the 5-second constraint and max 40 variables, if p is small (2-7) and nFree is large,\n * we can try a branch-and-bound approach.\n */\nfunction optimizeLargeNullSpace(\n  particular: number[],\n  nullVecs: number[][],\n  nButtons: number,\n  nFree: number,\n  p: number\n): number[] {\n  // Branch and bound with pruning\n  const bestSolution: number[] = new Array(nButtons).fill(0);\n\n  // Start with particular solution (all free vars = 0)\n  for (let j = 0; j < nButtons; j++) {\n    bestSolution[j] = mod(particular[j], p);\n  }\n  let bestTotal = bestSolution.reduce((a, b) => a + b, 0);\n\n  const currentFree = new Array(nFree).fill(0);\n  const currentSolution = new Array(nButtons);\n\n  function dfs(depth: number): void {\n    if (depth === nFree) {\n      // Compute full solution\n      let total = 0;\n      for (let j = 0; j < nButtons; j++) {\n        let val = particular[j];\n        for (let k = 0; k < nFree; k++) {\n          val += currentFree[k] * nullVecs[k][j];\n        }\n        currentSolution[j] = mod(val, p);\n        total += currentSolution[j];\n      }\n      if (total < bestTotal || (total === bestTotal && lexLess(currentSolution, bestSolution))) {\n        bestTotal = total;\n        for (let j = 0; j < nButtons; j++) bestSolution[j] = currentSolution[j];\n      }\n      return;\n    }\n\n    for (let v = 0; v < p; v++) {\n      currentFree[depth] = v;\n      // Simple pruning: compute partial sum of determined buttons\n      // (This is a basic optimization; could be improved)\n      dfs(depth + 1);\n    }\n  }\n\n  // Only use DFS if total is manageable with timeout\n  const total = Math.pow(p, nFree);\n  if (total <= 50_000_000) {\n    dfs(0);\n  }\n\n  return bestSolution;\n}\n\n// ─── Public API ──────────────────────────────────────────────────────\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const nLights = target.length;\n  const nButtons = buttons.length;\n\n  // Convert boolean target to number array\n  const targetNums = target.map(t => t ? 1 : 0);\n\n  const solution = solveLinearSystem(nLights, nButtons, buttons, targetNums, 2);\n\n  if (solution === null) return null;\n\n  // Convert to list of button indices that are pressed (value = 1)\n  const pressed: number[] = [];\n  for (let i = 0; i < nButtons; i++) {\n    if (solution[i] === 1) pressed.push(i);\n  }\n\n  return pressed.sort((a, b) => a - b);\n}\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const nLights = lights.length;\n  const nButtons = buttons.length;\n\n  const solution = solveLinearSystem(nLights, nButtons, buttons, lights, modulus);\n\n  return solution;\n}\n"}}
