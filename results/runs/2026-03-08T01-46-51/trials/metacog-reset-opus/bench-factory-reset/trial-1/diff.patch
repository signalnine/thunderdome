  355→  const nLights = lights.length;\n   356→  const nButtons = buttons.length;\n   357→\n   358→  const solution = solveLinearSystem(nLights, nButtons, buttons, lights, modulus);\n   359→\n   360→  return solution;\n   361→}\n   362→"}]},"parent_tool_use_id":null,"session_id":"b65653c6-ad8a-4278-b6fc-a3cf98c6da41","uuid":"26c45531-11cd-4f90-81a5-7dd03e2551f4","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/index.ts","content":"/**\n * Factory Reset — Toggle and Counter puzzle solvers.\n *\n * Both problems reduce to solving a system of linear equations over a finite field:\n *   A * x = b  (mod p)\n * where A is the button-to-light incidence matrix, x is the vector of button presses,\n * and b is the target configuration.\n *\n * For toggle puzzles, p = 2 (GF(2), XOR).\n * For counter puzzles, p is a given prime.\n *\n * We use Gaussian elimination to find a particular solution and the null space,\n * then enumerate over null space combinations to find the optimal solution.\n */\n\n// ─── Types ───────────────────────────────────────────────────────────\n\ninterface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// ─── Modular arithmetic helpers ──────────────────────────────────────\n\nfunction mod(a: number, p: number): number {\n  return ((a % p) + p) % p;\n}\n\n/** Modular multiplicative inverse using extended Euclidean algorithm. p must be prime. */\nfunction modInverse(a: number, p: number): number {\n  a = mod(a, p);\n  if (a === 0) throw new Error(\"No inverse for 0\");\n  // Fermat's little theorem: a^(p-2) mod p\n  let result = 1;\n  let base = a;\n  let exp = p - 2;\n  while (exp > 0) {\n    if (exp & 1) result = (result * base) % p;\n    base = (base * base) % p;\n    exp >>= 1;\n  }\n  return result;\n}\n\n// ─── Core solver over GF(p) ─────────────────────────────────────────\n\n/**\n * Solve A * x = b (mod p) where:\n *   - A is an nLights x nButtons matrix\n *   - b is the target vector of length nLights\n *   - x[i] ∈ {0, ..., p-1}\n *\n * Returns the optimal x (min total presses, then lex smallest), or null if unsolvable.\n */\nfunction solveLinearSystem(\n  nLights: number,\n  nButtons: number,\n  buttons: number[][],\n  target: number[],\n  p: number\n): number[] | null {\n  // Build augmented matrix [A | b] with dimensions nLights x (nButtons + 1)\n  // A[row][col] = how many times button col affects light row\n  const matrix: number[][] = [];\n  for (let i = 0; i < nLights; i++) {\n    const row = new Array(nButtons + 1).fill(0);\n    row[nButtons] = mod(target[i], p);\n    matrix.push(row);\n  }\n  for (let j = 0; j < nButtons; j++) {\n    for (const lightIdx of buttons[j]) {\n      if (lightIdx < nLights) {\n        matrix[lightIdx][j] = mod(matrix[lightIdx][j] + 1, p);\n      }\n    }\n  }\n\n  // Gaussian elimination with partial pivoting\n  // pivotCol[row] = column index of the pivot in this row, or -1\n  const pivotCol: number[] = new Array(nLights).fill(-1);\n  // pivotRow[col] = row index where this column is a pivot, or -1\n  const pivotRow: number[] = new Array(nButtons).fill(-1);\n\n  let currentRow = 0;\n  for (let col = 0; col < nButtons && currentRow < nLights; col++) {\n    // Find a row with nonzero entry in this column\n    let found = -1;\n    for (let row = currentRow; row < nLights; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue; // Free variable\n\n    // Swap rows\n    if (found !== currentRow) {\n      [matrix[currentRow], matrix[found]] = [matrix[found], matrix[currentRow]];\n    }\n\n    pivotCol[currentRow] = col;\n    pivotRow[col] = currentRow;\n\n    // Scale pivot row so pivot element = 1\n    const inv = modInverse(matrix[currentRow][col], p);\n    for (let j = col; j <= nButtons; j++) {\n      matrix[currentRow][j] = mod(matrix[currentRow][j] * inv, p);\n    }\n\n    // Eliminate this column in all other rows\n    for (let row = 0; row < nLights; row++) {\n      if (row === currentRow || matrix[row][col] === 0) continue;\n      const factor = matrix[row][col];\n      for (let j = col; j <= nButtons; j++) {\n        matrix[row][j] = mod(matrix[row][j] - factor * matrix[currentRow][j], p);\n      }\n    }\n\n    currentRow++;\n  }\n\n  // Check for inconsistency: any row with all-zero coefficients but nonzero RHS\n  for (let row = 0; row < nLights; row++) {\n    if (pivotCol[row] === -1) {\n      // Check if this row has any nonzero coefficient\n      let allZero = true;\n      for (let col = 0; col < nButtons; col++) {\n        if (matrix[row][col] !== 0) {\n          allZero = false;\n          break;\n        }\n      }\n      if (allZero && matrix[row][nButtons] !== 0) {\n        return null; // Inconsistent system\n      }\n    }\n  }\n\n  // Identify free variables (columns that are not pivot columns)\n  const freeVars: number[] = [];\n  for (let col = 0; col < nButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  // If no free variables, there's a unique solution\n  if (freeVars.length === 0) {\n    const solution = new Array(nButtons).fill(0);\n    for (let row = 0; row < nLights; row++) {\n      if (pivotCol[row] !== -1) {\n        solution[pivotCol[row]] = matrix[row][nButtons];\n      }\n    }\n    return solution;\n  }\n\n  // With free variables, we need to find the optimal solution.\n  // The solution space is: x = particular + sum(freeVarValues[i] * nullVec[i])\n  // We need to enumerate over all p^(#freeVars) combinations.\n\n  // Build particular solution (free vars = 0)\n  const particular = new Array(nButtons).fill(0);\n  for (let row = 0; row < nLights; row++) {\n    if (pivotCol[row] !== -1) {\n      particular[pivotCol[row]] = matrix[row][nButtons];\n    }\n  }\n\n  // Build null space vectors: for each free variable, set it to 1 and others to 0\n  const nullVecs: number[][] = [];\n  for (const freeCol of freeVars) {\n    const vec = new Array(nButtons).fill(0);\n    vec[freeCol] = 1;\n    // For each pivot variable, compute its value\n    for (let row = 0; row < nLights; row++) {\n      if (pivotCol[row] !== -1) {\n        // The pivot variable's value is -matrix[row][freeCol] (the coefficient of freeCol in this row)\n        vec[pivotCol[row]] = mod(-matrix[row][freeCol], p);\n      }\n    }\n    nullVecs.push(vec);\n  }\n\n  const nFree = freeVars.length;\n\n  // For small null spaces, enumerate all combinations\n  // For p=2 and nFree <= 25, that's 2^25 ≈ 33M which is feasible\n  // For larger p, we might need smarter approaches, but given constraints (40 buttons, 40 lights),\n  // the null space dimension is typically small\n\n  const totalCombinations = Math.pow(p, nFree);\n\n  if (totalCombinations <= 5_000_000) {\n    // Direct enumeration\n    let bestSolution: number[] | null = null;\n    let bestTotal = Infinity;\n\n    // Enumerate using mixed-radix counter\n    const freeValues = new Array(nFree).fill(0);\n\n    for (let iter = 0; iter < totalCombinations; iter++) {\n      // Compute solution for current free variable assignment\n      const solution = new Array(nButtons);\n      for (let j = 0; j < nButtons; j++) {\n        let val = particular[j];\n        for (let k = 0; k < nFree; k++) {\n          val += freeValues[k] * nullVecs[k][j];\n        }\n        solution[j] = mod(val, p);\n      }\n\n      // Compute total presses\n      let total = 0;\n      for (let j = 0; j < nButtons; j++) {\n        total += solution[j];\n      }\n\n      if (total < bestTotal || (total === bestTotal && bestSolution !== null && lexLess(solution, bestSolution))) {\n        bestTotal = total;\n        bestSolution = solution.slice();\n      }\n\n      // Increment mixed-radix counter\n      let carry = 0;\n      freeValues[nFree - 1]++;\n      for (let k = nFree - 1; k >= 0; k--) {\n        freeValues[k] += carry;\n        carry = 0;\n        if (freeValues[k] >= p) {\n          freeValues[k] = 0;\n          carry = 1;\n        } else {\n          break;\n        }\n      }\n    }\n\n    return bestSolution;\n  }\n\n  // For very large null spaces, use a greedy/optimization approach\n  // This handles the edge case of many free variables with larger primes\n  return optimizeLargeNullSpace(particular, nullVecs, nButtons, nFree, p);\n}\n\n/** Lexicographic comparison: is a < b? */\nfunction lexLess(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\n/**\n * For large null spaces, optimize each button press count independently.\n * For each button j, we want to minimize solution[j] = particular[j] + sum(c[k] * nullVecs[k][j]) mod p.\n *\n * Since we want minimum total then lex smallest, we use a column-by-column optimization.\n * This is an approximation that works when the null space is too large to enumerate.\n *\n * Actually, for this problem with the given constraints (up to 40 buttons/lights),\n * the null space can't be too large in practice. But let's handle it properly.\n *\n * For GF(p) with large null space, we can solve it as an integer linear program,\n * but a simpler approach: iterate through all combinations greedily.\n *\n * Given the 5-second constraint and max 40 variables, if p is small (2-7) and nFree is large,\n * we can try a branch-and-bound approach.\n */\nfunction optimizeLargeNullSpace(\n  particular: number[],\n  nullVecs: number[][],\n  nButtons: number,\n  nFree: number,\n  p: number\n): number[] {\n  // Branch and bound with pruning\n  const bestSolution: number[] = new Array(nButtons).fill(0);\n\n  // Start with particular solution (all free vars = 0)\n  for (let j = 0; j < nButtons; j++) {\n    bestSolution[j] = mod(particular[j], p);\n  }\n  let bestTotal = bestSolution.reduce((a, b) => a + b, 0);\n\n  const currentFree = new Array(nFree).fill(0);\n  const currentSolution = new Array(nButtons);\n\n  function dfs(depth: number): void {\n    if (depth === nFree) {\n      // Compute full solution\n      let total = 0;\n      for (let j = 0; j < nButtons; j++) {\n        let val = particular[j];\n        for (let k = 0; k < nFree; k++) {\n          val += currentFree[k] * nullVecs[k][j];\n        }\n        currentSolution[j] = mod(val, p);\n        total += currentSolution[j];\n      }\n      if (total < bestTotal || (total === bestTotal && lexLess(currentSolution, bestSolution))) {\n        bestTotal = total;\n        for (let j = 0; j < nButtons; j++) bestSolution[j] = currentSolution[j];\n      }\n      return;\n    }\n\n    for (let v = 0; v < p; v++) {\n      currentFree[depth] = v;\n      // Simple pruning: compute partial sum of determined buttons\n      // (This is a basic optimization; could be improved)\n      dfs(depth + 1);\n    }\n  }\n\n  // Only use DFS if total is manageable with timeout\n  const total = Math.pow(p, nFree);\n  if (total <= 50_000_000) {\n    dfs(0);\n  }\n\n  return bestSolution;\n}\n\n// ─── Public API ──────────────────────────────────────────────────────\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const nLights = target.length;\n  const nButtons = buttons.length;\n\n  // Convert boolean target to number array\n  const targetNums = target.map(t => t ? 1 : 0);\n\n  const solution = solveLinearSystem(nLights, nButtons, buttons, targetNums, 2);\n\n  if (solution === null) return null;\n\n  // Convert to list of button indices that are pressed (value = 1)\n  const pressed: number[] = [];\n  for (let i = 0; i < nButtons; i++) {\n    if (solution[i] === 1) pressed.push(i);\n  }\n\n  return pressed.sort((a, b) => a - b);\n}\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const nLights = lights.length;\n  const nButtons = buttons.length;\n\n  const solution = solveLinearSystem(nLights, nButtons, buttons, lights, modulus);\n\n  return solution;\n}\n","numLines":362,"startLine":1,"totalLines":362}}}
