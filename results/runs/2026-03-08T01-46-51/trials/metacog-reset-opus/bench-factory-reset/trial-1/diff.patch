+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Us6KVeDzR29QhyWuSGyuv7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01A4ijM3XnUUdSpfMnMVkKEx","name":"Write","input":{"file_path":"/workspace/src/index.ts","content":"/**\n * Factory Reset — Toggle and Counter puzzle solvers.\n *\n * Both problems reduce to solving a system of linear equations over a finite field:\n *   A * x = b  (mod p)\n * where A is the button-to-light incidence matrix, x is the vector of button presses,\n * and b is the target configuration.\n *\n * For toggle puzzles, p = 2 (GF(2), XOR).\n * For counter puzzles, p is a given prime.\n *\n * We use Gaussian elimination to find a particular solution and the null space,\n * then enumerate over null space combinations to find the optimal solution.\n */\n\n// ─── Types ───────────────────────────────────────────────────────────\n\ninterface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// ─── Modular arithmetic helpers ──────────────────────────────────────\n\nfunction mod(a: number, p: number): number {\n  return ((a % p) + p) % p;\n}\n\n/** Modular multiplicative inverse via Fermat's little theorem. p must be prime. */\nfunction modInverse(a: number, p: number): number {\n  a = mod(a, p);\n  if (a === 0) throw new Error(\"No inverse for 0\");\n  let result = 1;\n  let base = a;\n  let exp = p - 2;\n  while (exp > 0) {\n    if (exp & 1) result = (result * base) % p;\n    base = (base * base) % p;\n    exp >>= 1;\n  }\n  return result;\n}\n\n// ─── Gaussian elimination core ───────────────────────────────────────\n\ninterface GaussResult {\n  particular: number[] | null;\n  nullVecs: number[][];\n  nButtons: number;\n}\n\n/**\n * Perform Gaussian elimination on A*x = b (mod p).\n * Returns a particular solution and the null space basis, or null if inconsistent.\n */\nfunction gaussianElimination(\n  nLights: number,\n  nButtons: number,\n  buttons: number[][],\n  target: number[],\n  p: number\n): GaussResult | null {\n  // Build augmented matrix [A | b]\n  const matrix: number[][] = [];\n  for (let i = 0; i < nLights; i++) {\n    const row = new Array(nButtons + 1).fill(0);\n    row[nButtons] = mod(target[i], p);\n    matrix.push(row);\n  }\n  for (let j = 0; j < nButtons; j++) {\n    for (const lightIdx of buttons[j]) {\n      if (lightIdx < nLights) {\n        matrix[lightIdx][j] = mod(matrix[lightIdx][j] + 1, p);\n      }\n    }\n  }\n\n  const pivotCol: number[] = new Array(nLights).fill(-1);\n  const pivotRow: number[] = new Array(nButtons).fill(-1);\n\n  let currentRow = 0;\n  for (let col = 0; col < nButtons && currentRow < nLights; col++) {\n    let found = -1;\n    for (let row = currentRow; row < nLights; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    if (found !== currentRow) {\n      [matrix[currentRow], matrix[found]] = [matrix[found], matrix[currentRow]];\n    }\n\n    pivotCol[currentRow] = col;\n    pivotRow[col] = currentRow;\n\n    const inv = modInverse(matrix[currentRow][col], p);\n    for (let j = col; j <= nButtons; j++) {\n      matrix[currentRow][j] = mod(matrix[currentRow][j] * inv, p);\n    }\n\n    for (let row = 0; row < nLights; row++) {\n      if (row === currentRow || matrix[row][col] === 0) continue;\n      const factor = matrix[row][col];\n      for (let j = col; j <= nButtons; j++) {\n        matrix[row][j] = mod(matrix[row][j] - factor * matrix[currentRow][j], p);\n      }\n    }\n\n    currentRow++;\n  }\n\n  // Check consistency\n  for (let row = 0; row < nLights; row++) {\n    if (pivotCol[row] === -1) {\n      let allZero = true;\n      for (let col = 0; col < nButtons; col++) {\n        if (matrix[row][col] !== 0) {\n          allZero = false;\n          break;\n        }\n      }\n      if (allZero && matrix[row][nButtons] !== 0) {\n        return null;\n      }\n    }\n  }\n\n  // Build particular solution (free vars = 0)\n  const particular = new Array(nButtons).fill(0);\n  for (let row = 0; row < nLights; row++) {\n    if (pivotCol[row] !== -1) {\n      particular[pivotCol[row]] = matrix[row][nButtons];\n    }\n  }\n\n  // Build null space vectors\n  const freeVars: number[] = [];\n  for (let col = 0; col < nButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const nullVecs: number[][] = [];\n  for (const freeCol of freeVars) {\n    const vec = new Array(nButtons).fill(0);\n    vec[freeCol] = 1;\n    for (let row = 0; row < nLights; row++) {\n      if (pivotCol[row] !== -1) {\n        vec[pivotCol[row]] = mod(-matrix[row][freeCol], p);\n      }\n    }\n    nullVecs.push(vec);\n  }\n\n  return { particular, nullVecs, nButtons };\n}\n\n// ─── Solution comparison helpers ─────────────────────────────────────\n\n/** Lexicographic comparison of arrays: is a < b? */\nfunction lexLess(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\n/**\n * Compare two toggle solutions (binary vectors) by their pressed-index lists.\n * Returns true if solution a is \"better\" (fewer presses, then lex smaller pressed indices).\n */\nfunction toggleBetter(a: number[], b: number[]): boolean {\n  const countA = a.reduce((s, v) => s + v, 0);\n  const countB = b.reduce((s, v) => s + v, 0);\n  if (countA !== countB) return countA < countB;\n\n  // Same count: compare pressed index lists lexicographically\n  // The first button index where they differ determines the order\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] === 1 && b[i] === 0) return true;   // a has this index, b doesn't → a's list has a smaller first differing element\n    if (a[i] === 0 && b[i] === 1) return false;\n  }\n  return false; // equal\n}\n\n/**\n * Compare two counter solutions by total presses, then lex on the result array.\n * Returns true if solution a is \"better\".\n */\nfunction counterBetter(a: number[], b: number[]): boolean {\n  const totalA = a.reduce((s, v) => s + v, 0);\n  const totalB = b.reduce((s, v) => s + v, 0);\n  if (totalA !== totalB) return totalA < totalB;\n  return lexLess(a, b);\n}\n\n// ─── Solution enumeration ────────────────────────────────────────────\n\nfunction findOptimalSolution(\n  gauss: GaussResult,\n  p: number,\n  isBetter: (a: number[], b: number[]) => boolean\n): number[] {\n  const { particular, nullVecs, nButtons } = gauss;\n  const nFree = nullVecs.length;\n\n  if (nFree === 0) {\n    return particular.map(v => mod(v, p));\n  }\n\n  let bestSolution: number[] | null = null;\n\n  const totalCombinations = Math.pow(p, nFree);\n\n  if (totalCombinations <= 5_000_000) {\n    // Direct enumeration with mixed-radix counter\n    const freeValues = new Array(nFree).fill(0);\n\n    for (let iter = 0; iter < totalCombinations; iter++) {\n      const solution = new Array(nButtons);\n      for (let j = 0; j < nButtons; j++) {\n        let val = particular[j];\n        for (let k = 0; k < nFree; k++) {\n          val += freeValues[k] * nullVecs[k][j];\n        }\n        solution[j] = mod(val, p);\n      }\n\n      if (bestSolution === null || isBetter(solution, bestSolution)) {\n        bestSolution = solution.slice();\n      }\n\n      // Increment mixed-radix counter\n      let carry = 0;\n      freeValues[nFree - 1]++;\n      for (let k = nFree - 1; k >= 0; k--) {\n        freeValues[k] += carry;\n        carry = 0;\n        if (freeValues[k] >= p) {\n          freeValues[k] = 0;\n          carry = 1;\n        } else {\n          break;\n        }\n      }\n    }\n\n    return bestSolution!;\n  }\n\n  // For very large null spaces, use branch-and-bound\n  return branchAndBound(particular, nullVecs, nButtons, nFree, p, isBetter);\n}\n\nfunction branchAndBound(\n  particular: number[],\n  nullVecs: number[][],\n  nButtons: number,\n  nFree: number,\n  p: number,\n  isBetter: (a: number[], b: number[]) => boolean\n): number[] {\n  // Start with particular solution\n  const bestSolution: number[] = particular.map(v => mod(v, p));\n  let bestTotal = bestSolution.reduce((a, b) => a + b, 0);\n\n  const currentFree = new Array(nFree).fill(0);\n\n  function dfs(depth: number, partialSum: number[]): void {\n    if (depth === nFree) {\n      const solution = partialSum.map(v => mod(v, p));\n      const total = solution.reduce((a, b) => a + b, 0);\n      if (total < bestTotal || (total === bestTotal && isBetter(solution, bestSolution))) {\n        bestTotal = total;\n        for (let j = 0; j < nButtons; j++) bestSolution[j] = solution[j];\n      }\n      return;\n    }\n\n    for (let v = 0; v < p; v++) {\n      currentFree[depth] = v;\n      const nextSum = partialSum.slice();\n      for (let j = 0; j < nButtons; j++) {\n        nextSum[j] += v * nullVecs[depth][j];\n      }\n      dfs(depth + 1, nextSum);\n    }\n  }\n\n  const total = Math.pow(p, nFree);\n  if (total <= 50_000_000) {\n    dfs(0, particular.slice());\n  }\n\n  return bestSolution;\n}\n\n// ─── Public API ──────────────────────────────────────────────────────\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const nLights = target.length;\n  const nButtons = buttons.length;\n\n  const targetNums = target.map(t => t ? 1 : 0);\n\n  const gauss = gaussianElimination(nLights, nButtons, buttons, targetNums, 2);\n  if (gauss === null) return null;\n\n  const solution = findOptimalSolution(gauss, 2, toggleBetter);\n\n  const pressed: number[] = [];\n  for (let i = 0; i < nButtons; i++) {\n    if (solution[i] === 1) pressed.push(i);\n  }\n\n  return pressed.sort((a, b) => a - b);\n}\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const nLights = lights.length;\n  const nButtons = buttons.length;\n\n  const gauss = gaussianElimination(nLights, nButtons, buttons, lights, modulus);\n  if (gauss === null) return null;\n\n  return findOptimalSolution(gauss, modulus, counterBetter);\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":6098,"cache_read_input_tokens":30400,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":6098},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b65653c6-ad8a-4278-b6fc-a3cf98c6da41","uuid":"c4f200d3-55b0-4206-b867-c293f664427e"}
