 0; row < nLights; row++) {\n   114→    if (pivotCol[row] !== -1) {\n   115→      particular[pivotCol[row]] = matrix[row][nButtons];\n   116→    }\n   117→  }\n   118→\n   119→  const freeVars: number[] = [];\n   120→  for (let col = 0; col < nButtons; col++) {\n   121→    if (pivotRow[col] === -1) {\n   122→      freeVars.push(col);\n   123→    }\n   124→  }\n   125→\n   126→  const nullVecs: number[][] = [];\n   127→  for (const freeCol of freeVars) {\n   128→    const vec = new Array(nButtons).fill(0);\n   129→    vec[freeCol] = 1;\n   130→    for (let row = 0; row < nLights; row++) {\n   131→      if (pivotCol[row] !== -1) {\n   132→        vec[pivotCol[row]] = mod(-matrix[row][freeCol], p);\n   133→      }\n   134→    }\n   135→    nullVecs.push(vec);\n   136→  }\n   137→\n   138→  return { particular, nullVecs, nButtons };\n   139→}\n   140→\n   141→// ─── Helpers ─────────────────────────────────────────────────────────\n   142→\n   143→function lexLess(a: number[], b: number[]): boolean {\n   144→  for (let i = 0; i < a.length; i++) {\n   145→    if (a[i] < b[i]) return true;\n   146→    if (a[i] > b[i]) return false;\n   147→  }\n   148→  return false;\n   149→}\n   150→\n   151→function popcountBig(mask: bigint): number {\n   152→  let count = 0;\n   153→  let m = mask;\n   154→  while (m > 0n) {\n   155→    m &= m - 1n;\n   156→    count++;\n   157→  }\n   158→  return count;\n   159→}\n   160→\n   161→function bigMaskToVec(mask: bigint, n: number): number[] {\n   162→  const vec = new Array(n);\n   163→  for (let i = 0; i < n; i++) {\n   164→    vec[i] = Number((mask >> BigInt(i)) & 1n);\n   165→  }\n   166→  return vec;\n   167→}\n   168→\n   169→function vecToBigMask(vec: number[]): bigint {\n   170→  let mask = 0n;\n   171→  for (let i = 0; i < vec.length; i++) {\n   172→    if (vec[i]) mask |= 1n << BigInt(i);\n   173→  }\n   174→  return mask;\n   175→}\n   176→\n   177→/**\n   178→ * For two masks with equal popcount, returns true if a produces a lex-smaller\n   179→ * pressed-index list. The first differing bit position determines order:\n   180→ * a is better if a has 1 there (meaning a includes a smaller index).\n   181→ */\n   182→function toggleMaskBetter(a: bigint, b: bigint): boolean {\n   183→  const diff = a ^ b;\n   184→  if (diff === 0n) return false;\n   185→  const lowestDiffBit = diff & (-diff);\n   186→  return (a & lowestDiffBit) !== 0n;\n   187→}\n   188→\n   189→// ─── Toggle solver (GF(2)) ──────────────────────────────────────────\n   190→\n   191→function solveToggleOptimal(gauss: GaussResult): number[] {\n   192→  const { particular, nullVecs, nButtons } = gauss;\n   193→  const nFree = nullVecs.length;\n   194→\n   195→  if (nFree === 0) {\n   196→    return particular;\n   197→  }\n   198→\n   199→  const particularMask = vecToBigMask(particular);\n   200→  const nullMasks = nullVecs.map(v => vecToBigMask(v));\n   201→\n   202→  // For small null spaces, enumerate directly\n   203→  if (nFree <= 22) {\n   204→    const totalCombinations = 1 << nFree;\n   205→    let bestMask = particularMask;\n   206→    let bestCount = popcountBig(particularMask);\n   207→\n   208→    for (let mask = 1; mask < totalCombinations; mask++) {\n   209→      let solMask = particularMask;\n   210→      for (let k = 0; k < nFree; k++) {\n   211→        if (mask & (1 << k)) {\n   212→          solMask ^= nullMasks[k];\n   213→        }\n   214→      }\n   215→      const cnt = popcountBig(solMask);\n   216→      if (cnt < bestCount || (cnt === bestCount && toggleMaskBetter(solMask, bestMask))) {\n   217→        bestCount = cnt;\n   218→        bestMask = solMask;\n   219→      }\n   220→    }\n   221→\n   222→    return bigMaskToVec(bestMask, nButtons);\n   223→  }\n   224→\n   225→  // For larger null spaces, use weight enumeration + null space membership check.\n   226→  // Build null space basis in RREF form using bigint masks for fast GF(2) operations.\n   227→  // The null vectors are already in a form where each has a unique free variable column.\n   228→  // To check if a vector v is in the null space span, we check if v can be zeroed out\n   229→  // by XORing with basis vectors.\n   230→\n   231→  // Build RREF null space basis indexed by their pivot (free variable) positions\n   232→  const basisByPivot = new Map<number, bigint>();\n   233→  for (let i = 0; i < nFree; i++) {\n   234→    // The free variable column for null vector i\n   235→    // Find the position where this null vector has its unique 1\n   236→    // That's the free variable position\n   237→    // Actually, in our construction, nullVecs[i] has a 1 at freeVars[i]\n   238→    // and the freeVars are the columns not used as pivots\n   239→    // We can extract the freeVar positions from the null vectors:\n   240→    // nullVecs[i][freeVars[i]] = 1 and for j != i, nullVecs[i][freeVars[j]] = 0\n   241→    // (because in GF(2), the null space basis is identity on free variables)\n   242→    // So the pivot of nullMasks[i] is the position of freeVars[i]\n   243→\n   244→    // Find the free variable position (the unique 1 among free variable columns)\n   245→    // Since we're in GF(2) and the basis is constructed to be identity on free vars,\n   246→    // the free variable for basis vector i is the i-th free variable\n   247→    // Let's just store by the lowest set bit that distinguishes them\n   248→    // Actually, let's just build an array for elimination\n   249→  }\n   250→\n   251→  // Build ordered null space basis for elimination\n   252→  // Re-construct with proper pivot positions\n   253→  const nullBasis: { pivot: number; mask: bigint }[] = [];\n   254→  for (let i = 0; i < nFree; i++) {\n   255→    // Find the unique column where this basis vector differs from others\n   256→    // In our construction, each basis vector has 1 in its own free variable column\n   257→    // and 0 in other free variable columns. So we just need to find which\n   258→    // free variable column has a 1.\n   259→    let pivot = -1;\n   260→    for (let j = 0; j < nButtons; j++) {\n   261→      if (nullVecs[i][j] === 1) {\n   262→        // Check if this is a free variable column (not a pivot column in the original system)\n   263→        let isFreeCol = true;\n   264→        for (let k = 0; k < nFree; k++) {\n   265→          if (k !== i && nullVecs[k][j] !== 0) {\n   266→            isFreeCol = false;\n   267→            break;\n   268→          }\n   269→        }\n   270→        if (isFreeCol) {\n   271→          pivot = j;\n   272→          break;\n   273→        }\n   274→      }\n   275→    }\n   276→    if (pivot === -1) {\n   277→      // Fallback: just use position of highest bit\n   278→      let m = nullMasks[i];\n   279→      pivot = 0;\n   280→      while (m > 1n) {\n   281→        m >>= 1n;\n   282→        pivot++;\n   283→      }\n   284→    }\n   285→    nullBasis.push({ pivot, mask: nullMasks[i] });\n   286→  }\n   287→  // Sort by pivot position for efficient elimination\n   288→  nullBasis.sort((a, b) => a.pivot - b.pivot);\n   289→\n   290→  /**\n   291→   * Check if vector v (as bigint) is in the null space span.\n   292→   * Uses Gaussian elimination against the null basis.\n   293→   */\n   294→  function inNullSpace(v: bigint): boolean {\n   295→    let current = v;\n   296→    for (const { pivot, mask } of nullBasis) {\n   297→      if ((current >> BigInt(pivot)) & 1n) {\n   298→        current ^= mask;\n   299→      }\n   300→    }\n   301→    return current === 0n;\n   302→  }\n   303→\n   304→  // Search for minimum weight solution by enumerating weights\n   305→  let bestMask = particularMask;\n   306→  let bestCount = popcountBig(particularMask);\n   307→\n   308→  // Check if particular is already weight 0 (all zeros pressed)\n   309→  // Weight w solution s means popcount(s) = w, and s XOR particular is in null space\n   310→\n   311→  for (let w = 0; w < bestCount; w++) {\n   312→    const found = findMinWeightSolution(nButtons, w, particularMask, inNullSpace);\n   313→    if (found !== null) {\n   314→      bestMask = found;\n   315→      bestCount = w;\n   316→      break;\n   317→    }\n   318→\n   319→    // Time check: if w >= 7 and we haven't found anything, the problem is hard.\n   320→    // Fall back to meet-in-the-middle or greedy.\n   321→    if (w >= 7) {\n   322→      // Use greedy approach as fallback\n   323→      const greedy = greedyToggle(particularMask, nullMasks, nFree, nButtons);\n   324→      if (popcountBig(greedy) < bestCount ||\n   325→          (popcountBig(greedy) === bestCount && toggleMaskBetter(greedy, bestMask))) {\n   326→        bestMask = greedy;\n   327→        bestCount = popcountBig(greedy);\n   328→      }\n   329→      break;\n   330→    }\n   331→  }\n   332→\n   333→  return bigMaskToVec(bestMask, nButtons);\n   334→}\n   335→\n   336→/**\n   337→ * Find a solution mask of exactly weight w, or null if none exists.\n   338→ * A mask s is valid if inNullSpace(s XOR particular) is true.\n   339→ * Returns the lex-smallest valid mask (by toggle comparison).\n   340→ */\n   341→function findMinWeightSolution(\n   342→  n: number,\n   343→  w: number,\n   344→  particular: bigint,\n   345→  inNullSpace: (v: bigint) => boolean\n   346→): bigint | null {\n   347→  let bestSol: bigint | null = null;\n   348→\n   349→  const positions = new Array(w);\n   350→\n   351→  function enumerate(depth: number, start: number): boolean {\n   352→    if (depth === w) {\n   353→      let mask = 0n;\n   354→      for (let i = 0; i < w; i++) {\n   355→        mask |= 1n << BigInt(positions[i]);\n   356→      }\n   357→      if (inNullSpace(mask ^ particular)) {\n   358→        if (bestSol === null || toggleMaskBetter(mask, bestSol)) {\n   359→          bestSol = mask;\n   360→        }\n   361→        // We want the lex-smallest, which means smallest pressed indices first.\n   362→        // Since we enumerate positions in ascending order, the first valid solution\n   363→        // with these particular positions IS the lex-smallest among solutions\n   364→        // with positions[0..depth-1] fixed. But we need to continue to check all\n   365→        // combinations at this weight level.\n   366→        // Actually, we enumerate in lex order of positions, so the first solution\n   367→        // found is the lex-smallest. But toggleMaskBetter uses a different ordering...\n   368→        // Let me just collect all solutions.\n   369→      }\n   370→      return false;\n   371→    }\n   372→\n   373→    const remaining = n - start;\n   374→    const needed = w - depth;\n   375→    if (remaining < needed) return false;\n   376→\n   377→    for (let i = start; i < n; i++) {\n   378→      positions[depth] = i;\n   379→      enumerate(depth + 1, i + 1);\n   380→    }\n   381→    return false;\n   382→  }\n   383→\n   384→  enumerate(0, 0);\n   385→  return bestSol;\n   386→}\n   387→\n   388→/**\n   389→ * Greedy approach: repeatedly XOR null vectors to reduce weight.\n   390→ */\n   391→function greedyToggle(\n   392→  particularMask: bigint,\n   393→  nullMasks: bigint[],\n   394→  nFree: number,\n   395→  _nButtons: number\n   396→): bigint {\n   397→  let current = particularMask;\n   398→  let currentCount = popcountBig(current);\n   399→\n   400→  let improved = true;\n   401→  while (improved) {\n   402→    improved = false;\n   403→    for (let k = 0; k < nFree; k++) {\n   404→      const next = current ^ nullMasks[k];\n   405→      const nextCount = popcountBig(next);\n   406→      if (nextCount < currentCount || (nextCount === currentCount && toggleMaskBetter(next, current))) {\n   407→        current = next;\n   408→        currentCount = nextCount;\n   409→        improved = true;\n   410→      }\n   411→    }\n   412→  }\n   413→\n   414→  // Also try pairs\n   415→  for (let i = 0; i < nFree; i++) {\n   416→    for (let j = i + 1; j < nFree; j++) {\n   417→      const next = current ^ nullMasks[i] ^ nullMasks[j];\n   418→      