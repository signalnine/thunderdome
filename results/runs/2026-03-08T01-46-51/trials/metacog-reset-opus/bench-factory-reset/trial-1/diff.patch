halfB = nFree - halfA;\n  const sizeA = 1 << halfA;\n  const sizeB = 1 << halfB;\n\n  // Enumerate second half, store in a Set for quick lookup\n  const halfBResults: bigint[] = new Array(sizeB);\n  for (let mask = 0; mask < sizeB; mask++) {\n    let solMask = 0n;\n    for (let k = 0; k < halfB; k++) {\n      if (mask & (1 << k)) {\n        solMask ^= nullMasks[halfA + k];\n      }\n    }\n    halfBResults[mask] = solMask;\n  }\n\n  // Build a Map from halfB XOR contribution -> list of mask indices\n  // Group by popcount of the full solution they'd produce (can't do this in advance\n  // since it depends on halfA).\n\n  // Instead, for each halfA combo, compute partialA = particular XOR halfA_contribution,\n  // then search all halfB combos for the best match.\n  // With sizeA * sizeB up to 2^20 * 2^20 = 2^40, this is still too much.\n  //\n  // Better approach: store halfB results in a map keyed by value.\n  // Then for each partialA, search for nearest neighbors by weight.\n  //\n  // Alternative: for each halfA combo, compute partialA.\n  // The best halfB is the one where partialA XOR halfB has minimum popcount.\n  // To find this efficiently, we want halfB ≈ partialA (bitwise).\n  //\n  // Store all halfB values in a Set. For each partialA, check if partialA itself\n  // is in the set (weight 0 match). If not, try flipping each bit of partialA\n  // (weight 1 matches), then pairs of bits (weight 2), etc.\n  //\n  // For weight w and n bits, there are C(n, w) combinations.\n  // C(40, 0) = 1, C(40, 1) = 40, C(40, 2) = 780, C(40, 3) = 9880, etc.\n  // We'd need to go up to weight ~20 in the worst case, but usually the minimum\n  // weight is small.\n\n  const halfBSet = new Set<bigint>();\n  for (let i = 0; i < sizeB; i++) {\n    halfBSet.add(halfBResults[i]);\n  }\n\n  let bestMask = particularMask;\n  let bestCount = popcountBig(particularMask);\n\n  // For each halfA combo\n  for (let maskA = 0; maskA < sizeA; maskA++) {\n    let halfAContrib = 0n;\n    for (let k = 0; k < halfA; k++) {\n      if (maskA & (1 << k)) {\n        halfAContrib ^= nullMasks[k];\n      }\n    }\n    const partialA = particularMask ^ halfAContrib;\n\n    // Search for the best halfB by trying weights from 0 upward\n    // Stop at bestCount (can't improve beyond current best)\n    for (let w = 0; w <= bestCount; w++) {\n      const found = findWeightMatch(partialA, halfBSet, nButtons, w);\n      if (found !== null) {\n        // found is the full solution mask with weight w\n        if (w < bestCount || (w === bestCount && toggleMaskBetter(found, bestMask, nButtons))) {\n          bestCount = w;\n          bestMask = found;\n        }\n        break; // Can't do better for this halfA\n      }\n    }\n  }\n\n  return bigMaskToVec(bestMask, nButtons);\n}\n\n/**\n * Find a halfB value in the set such that partialA XOR halfB has exactly weight w.\n * Returns the full solution (partialA XOR halfB) if found, null otherwise.\n *\n * Enumerate all n-bit masks of weight w and check if partialA XOR mask is in halfBSet.\n * Equivalently, check if partialA XOR (any halfB) has weight w.\n * We need: partialA XOR halfB has weight w, so halfB = partialA XOR (some weight-w mask).\n */\nfunction findWeightMatch(\n  partialA: bigint,\n  halfBSet: Set<bigint>,\n  n: number,\n  w: number\n): bigint | null {\n  // Enumerate all weight-w masks on n bits\n  // Return the lex-smallest solution (by toggle comparison) if multiple matches exist\n  let bestSol: bigint | null = null;\n\n  // Use recursive enumeration of w positions out of n\n  const positions = new Array(w);\n\n  function enumerate(depth: number, start: number): void {\n    if (depth === w) {\n      let mask = 0n;\n      for (let i = 0; i < w; i++) {\n        mask |= 1n << BigInt(positions[i]);\n      }\n      const needed = partialA ^ mask;\n      if (halfBSet.has(needed)) {\n        // Solution found: mask is the full solution\n        if (bestSol === null || toggleMaskBetter(mask, bestSol, n)) {\n       