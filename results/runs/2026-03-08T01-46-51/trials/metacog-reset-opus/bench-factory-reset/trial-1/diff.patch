m of linear equations over a finite field:\n *   A * x = b  (mod p)\n * where A is the button-to-light incidence matrix, x is the vector of button presses,\n * and b is the target configuration.\n *\n * For toggle puzzles, p = 2 (GF(2), XOR).\n * For counter puzzles, p is a given prime.\n *\n * We use Gaussian elimination to find a particular solution and the null space,\n * then enumerate over null space combinations to find the optimal solution.\n */\n\n// ─── Types ───────────────────────────────────────────────────────────\n\ninterface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// ─── Modular arithmetic helpers ──────────────────────────────────────\n\nfunction mod(a: number, p: number): number {\n  return ((a % p) + p) % p;\n}\n\nfunction modInverse(a: number, p: number): number {\n  a = mod(a, p);\n  if (a === 0) throw new Error(\"No inverse for 0\");\n  let result = 1;\n  let base = a;\n  let exp = p - 2;\n  while (exp > 0) {\n    if (exp & 1) result = (result * base) % p;\n    base = (base * base) % p;\n    exp >>= 1;\n  }\n  return result;\n}\n\n// ─── Gaussian elimination core ───────────────────────────────────────\n\ninterface GaussResult {\n  particular: number[];\n  nullVecs: number[][];\n  nButtons: number;\n}\n\nfunction gaussianElimination(\n  nLights: number,\n  nButtons: number,\n  buttons: number[][],\n  target: number[],\n  p: number\n): GaussResult | null {\n  const matrix: number[][] = [];\n  for (let i = 0; i < nLights; i++) {\n    const row = new Array(nButtons + 1).fill(0);\n    row[nButtons] = mod(target[i], p);\n    matrix.push(row);\n  }\n  for (let j = 0; j < nButtons; j++) {\n    for (const lightIdx of buttons[j]) {\n      if (lightIdx < nLights) {\n        matrix[lightIdx][j] = mod(matrix[lightIdx][j] + 1, p);\n      }\n    }\n  }\n\n  const pivotCol: number[] = new Array(nLights).fill(-1);\n  const pivotRow: number[] = new Array(nButtons).fill(-1);\n\n  let currentRow = 0;\n  for (let col = 0; col < nButtons && currentRow < nLights; col++) {\n    let found = -1;\n    for (let row = currentRow; row < nLights; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    if (found !== currentRow) {\n      [matrix[currentRow], matrix[found]] = [matrix[found], matrix[currentRow]];\n    }\n\n    pivotCol[currentRow] = col;\n    pivotRow[col] = currentRow;\n\n    const inv = modInverse(matrix[currentRow][col], p);\n    for (let j = col; j <= nButtons; j++) {\n      matrix[currentRow][j] = mod(matrix[currentRow][j] * inv, p);\n    }\n\n    for (let row = 0; row < nLights; row++) {\n      if (row === currentRow || matrix[row][col] === 0) continue;\n      const factor = matrix[row][col];\n      for (let j = col; j <= nButtons; j++) {\n        matrix[row][j] = mod(matrix[row][j] - factor * matrix[currentRow][j], p);\n      }\n    }\n\n    currentRow++;\n  }\n\n  for (let row = 0; row < nLights; row++) {\n    if (pivotCol[row] === -1) {\n      let allZero = true;\n      for (let col = 0; col < nButtons; col++) {\n        if (matrix[row][col] !== 0) {\n          allZero = false;\n          break;\n        }\n      }\n      if (allZero && matrix[row][nButtons] !== 0) {\n        return null;\n      }\n    }\n  }\n\n  const particular = new Array(nButtons).fill(0);\n  for (let row = 0; row < nLights; row++) {\n    if (pivotCol[row] !== -1) {\n      particular[pivotCol[row]] = matrix[row][nButtons];\n    }\n  }\n\n  const freeVars: number[] = [];\n  for (let col = 0; col < nButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const nullVecs: number[][] = [];\n  for (const freeCol of freeVars) {\n    const vec = new Array(nButtons).fill(0);\n    vec[freeCol] = 1;\n    for (let row = 0; row < nLights; row++) {\n      if (pivotCol[row] !== -1) {\n        vec[pivotCol[row]] = mod(-matrix[row][freeCol], p);\n      }\n    }\n    nullVecs.push(vec);\n  }\n\n  return { particular, nullVecs, nButtons };\n}\n\n// ─── Comparison helpers ──────────────────────────────────────────────\n\nfunction lexLess(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\nfunction toggleBetter(a: number[], b: number[]): boolean {\n  const countA = a.reduce((s, v) => s + v, 0);\n  const countB = b.reduce((s, v) => s + v, 0);\n  if (countA !== countB) return countA < countB;\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] === 1 && b[i] === 0) return true;\n    if (a[i] === 0 && b[i] === 1) return false;\n  }\n  return false;\n}\n\nfunction counterBetter(a: number[], b: number[]): boolean {\n  const totalA = a.reduce((s, v) => s + v, 0);\n  const totalB = b.reduce((s, v) => s + v, 0);\n  if (totalA !== totalB) return totalA < totalB;\n  return lexLess(a, b);\n}\n\n// ─── Toggle solver (GF(2) specific with meet-in-the-middle) ─────────\n\n/**\n * For toggle (p=2), use bitmask-based meet-in-the-middle when the null space is large.\n * Each solution is a binary vector of length nButtons.\n * We use BigInt bitmasks for nButtons up to 40.\n */\nfunction solveToggleOptimal(gauss: GaussResult): number[] {\n  const { particular, nullVecs, nButtons } = gauss;\n  const nFree = nullVecs.length;\n\n  if (nFree === 0) {\n    return particular;\n  }\n\n  // Convert to bitmasks for fast XOR operations\n  const particularMask = vecToBigMask(particular);\n  const nullMasks = nullVecs.map(v => vecToBigMask(v));\n\n  const totalCombinations = 1 << nFree; // 2^nFree\n\n  if (nFree <= 22) {\n    // Direct enumeration with bitmask XOR\n    let bestMask = particularMask;\n    let bestCount = popcount(particularMask, nButtons);\n    let bestToggleKey = toggleKey(particularMask, nButtons);\n\n    for (let mask = 1; mask < totalCombinations; mask++) {\n      let solMask = particularMask;\n      for (let k = 0; k < nFree; k++) {\n        if (mask & (1 << k)) {\n          solMask ^= nullMasks[k];\n        }\n      }\n      const cnt = popcount(solMask, nButtons);\n      if (cnt < bestCount) {\n        bestCount = cnt;\n        bestMask = solMask;\n        bestToggleKey = toggleKey(solMask, nButtons);\n      } else if (cnt === bestCount) {\n        const key = toggleKey(solMask, nButtons);\n        if (toggleKeyLess(key, bestToggleKey)) {\n          bestMask = solMask;\n          bestToggleKey = key;\n        }\n      }\n    }\n\n    return bigMaskToVec(bestMask, nButtons);\n  }\n\n  // Meet-in-the-middle for nFree > 22\n  const halfA = Math.floor(nFree / 2);\n  const halfB = nFree - halfA;\n  const sizeA = 1 << halfA;\n  const sizeB = 1 << halfB;\n\n  // Enumerate first half: compute XOR contribution to particular solution\n  const halfAMasks: bigint[] = new Array(sizeA);\n  for (let mask = 0; mask < sizeA; mask++) {\n    let solMask = 0n;\n    for (let k = 0; k < halfA; k++) {\n      if (mask & (1 << k)) {\n        solMask ^= nullMasks[k];\n      }\n    }\n    halfAMasks[mask] = solMask;\n  }\n\n  // Enumerate second half\n  const halfBMasks: bigint[] = new Array(sizeB);\n  for (let mask = 0; mask < sizeB; mask++) {\n    let solMask = 0n;\n    for (let k = 0; k < halfB; k++) {\n      if (mask & (1 << k)) {\n        solMask ^= nullMasks[halfA + k];\n      }\n    }\n    halfBMasks[mask] = solMask;\n  }\n\n  // For each combination of first and second half, find the best\n  let bestMask = particularMask;\n  let bestCount = popcount(particularMask, nButtons);\n  let bestToggleKeyVal = toggleKey(particularMask, nButtons);\n\n  // If sizeA * sizeB is manageable (which it should be up to 2^40 / meet-in-middle approach)\n  // But 2^20 * 2^20 = 2^40 iterations is still too many!\n  // We need a smarter meet-in-the-middle.\n\n  // Actually, for the problem constraints: up to 40 buttons, 40 lights.\n  // Worst case: 40 buttons, 0 lights → 40 free variables. But target is empty,\n  // so particular is all zeros, and optimal is all zeros (0 presses).\n  //\n  // More realistically: 40 buttons, 10 lights → rank ≤ 10, up to 30 free variables.\n  // 2^30 ≈ 1 billion, still too many for direct enumeration.\n  //\n  // For meet-in-the-middle on minimum weight binary vector:\n  // We split into two halves and for each half, group by the XOR contribution.\n  // But since solutions are 40-bit vectors, we can't use a simple hash map approach easily.\n  //\n  // Alternative approach: Since p=2, use the Lee/weight-minimization approach.\n  // For minimum-weight codeword, we can sort null vectors to reduce the problem.\n  //\n  // Actually, a good approach for GF(2):\n  // The null space has dimension nFree. We want the minimum weight vector in the coset\n  // particular + span(nullVecs).\n  //\n  // We can try a different approach: systematically reduce the weight using the null vectors.\n  // For each null vector, check if XORing it with the current solution reduces weight.\n  // Repeat until no improvement. This is a greedy approach that finds a local minimum.\n  // Then try all pairs, triples, etc. up to a certain depth.\n\n  // Greedy approach: try XORing each null vector and keep improvements\n  let currentMask = particularMask;\n  let currentCount = popcount(currentMask, nButtons);\n  let improved = true;\n  while (improved) {\n    improved = false;\n    for (let k = 0; k < nFree; k++) {\n      const newMask = currentMask ^ nullMasks[k];\n      const newCount = popcount(newMask, nButtons);\n      if (newCount < currentCount) {\n        currentMask = newMask;\n        currentCount = newCount;\n        improved = true;\n      }\n    }\n  }\n  bestMask = currentMask;\n  bestCount = currentCount;\n  bestToggleKeyVal = toggleKey(bestMask, nButtons);\n\n  // Try all pairs for further improvement\n  for (let i = 0; i < nFree; i++) {\n    for (let j = i + 1; j < nFree; j++) {\n      const newMask = currentMask ^ nullMasks[i] ^ nullMasks[j];\n      const newCount = popcount(newMask, nButtons);\n      if (newCount < bestCount) {\n        bestCount = newCount;\n        bestMask = newMask;\n        bestToggleKeyVal = toggleKey(bestMask, nButtons);\n      } else if (newCount === bestCount) {\n        const key = toggleKey(newMask, nButtons);\n        if (toggleKeyLess(key, bestToggleKeyVal)) {\n          bestMask = newMask;\n          bestToggleKeyVal = key;\n        }\n      }\n    }\n  }\n\n  // For very large null spaces, do a proper meet-in-the-middle with bounded search\n  if (nFree <= 40) {\n    // Meet-in-the-middle: enumerate all first-half, store in a map keyed by XOR value\n    // For each second-half, look up the best match\n    // But we want to minimize popcount(particular XOR halfA XOR halfB)\n    // = popcount((particular XOR halfA) XOR halfB)\n    //\n    // For each halfB value, we want to find the halfA value that when XORed gives\n    // the lowest popcount with (particular XOR halfA XOR halfB).\n    //\n    // This is equivalent to: for each (pA = particular XOR halfA), find halfB\n    // minimizing popcount(pA XOR halfB).\n    //\n    // If we store all halfB values, then for each pA, we need the nearest neighbor\n    // in Hamming distance. This is hard in general.\n    //\n    // Alternative: just enumerate smaller halves and use partial matching.\n    // With halfA = 20, halfB = 20: store all 2^20 halfB solutions, for each of 2^20 halfA\n    // solutions, find the best halfB. If we sort halfB values, we can do binary search.\n    //\n    // Actually, the simplest approach that works: if nFree > 22, use a hybrid.\n    // Split into groups, enumerate each group, and combine greedily.\n\n    // Group the null vectors into chunks of at most 20\n    const chunkSize = Math.min(20, nFree);\n    const nChunks = Math.ceil(nFree / chunkSize);\n\n    if (nChunks <= 2) {\n      // Two chunks: proper meet-in-the-middle\n      // Enumerate all combinations of the second half, store them sorted\n      const sMasks: bigint[] = new Array(sizeB);\n      for (let mask = 0; mask < sizeB; mask++) {\n        sMasks[mask] = halfBMasks[mask];\n      }\n\n      // For each first-half combination, find the best second-half\n      for (let maskA = 0; maskA < sizeA; maskA++) {\n        const pA = particularMask ^ halfAMasks[maskA];\n        // Try all second-half combinations\n        for (let maskB = 0; maskB < sizeB; maskB++) {\n          const fullMask = pA ^ sMasks[maskB];\n          const cnt = popcount(fullMask, nButtons);\n          if (cnt < bestCount) {\n            bestCount = cnt;\n            bestMask = fullMask;\n            bestToggleKeyVal = toggleKey(fullMask, nButtons);\n          } else if (cnt === bestCount) {\n            const key = toggleKey(fullMask, nButtons);\n            if (toggleKeyLess(key, bestToggleKeyVal)) {\n              bestMask = fullMask;\n              bestToggleKeyVal = key;\n            }\n          }\n        }\n      }\n    }\n  }\n\n  return bigMaskToVec(bestMask, nButtons);\n}\n\nfunction vecToBigMask(vec: number[]): bigint {\n  let mask = 0n;\n  for (let i = 0; i < vec.length; i++) {\n    if (vec[i]) mask |= 1n << BigInt(i);\n  }\n  return mask;\n}\n\nfunction bigMaskToVec(mask: bigint, n: number): number[] {\n  const vec = new Array(n);\n  for (let i = 0; i < n; i++) {\n    vec[i] = Number((mask >> BigInt(i)) & 1n);\n  }\n  return vec;\n}\n\nfunction popcount(mask: bigint, n: number): number {\n  let count = 0;\n  let m = mask;\n  for (let i = 0; i < n; i++) {\n    if (m & 1n) count++;\n    m >>= 1n;\n  }\n  return count;\n}\n\n/** Generate a key for toggle comparison: the list of pressed indices as a string */\nfunction toggleKey(mask: bigint, n: number): string {\n  const indices: number[] = [];\n  for (let i = 0; i < n; i++) {\n    if ((mask >> BigInt(i)) & 1n) indices.push(i);\n  }\n  return indices.join(',');\n}\n\nfunction toggleKeyLess(a: string, b: string): boolean {\n  const aa = a ? a.split(',').map(Number) : [];\n  const bb = b ? b.split(',').map(Number) : [];\n  // Same count (already ensured by caller checking count first)\n  const len = Math.min(aa.length, bb.length);\n  for (let i = 0; i < len; i++) {\n    if (aa[i] < bb[i]) return true;\n    if (aa[i] > bb[i]) return false;\n  }\n  return aa.length < bb.length;\n}\n\n// ─── Counter solver (GF(p)) ─────────────────────────────────────────\n\nfunction solveCounterOptimal(gauss: GaussResult, p: number): number[] {\n  const { particular, nullVecs, nButtons } = gauss;\n  const nFree = nullVecs.length;\n\n  if (nFree === 0) {\n    return particular.map(v => mod(v, p));\n  }\n\n  const totalCombinations = Math.pow(p, nFree);\n\n  if (totalCombinations <= 5_000_000) {\n    let bestSolution: number[] | null = null;\n    let bestTotal = Infinity;\n\n    const freeValues = new Array(nFree).fill(0);\n\n    for (let iter = 0; iter < totalCombinations; iter++) {\n      const solution = new Array(nButtons);\n      let total = 0;\n      for (let j = 0; j < nButtons; j++) {\n        let val = particular[j];\n        for (let k = 0; k < nFree; k++) {\n          val += freeValues[k] * nullVecs[k][j];\n        }\n        solution[j] = mod(val, p);\n        total += solution[j];\n      }\n\n      if (total < bestTotal || (total === bestTotal && bestSolution !== null && lexLess(solution, bestSolution))) {\n        bestTotal = total;\n        bestSolution = solution.slice();\n      }\n\n      // Increment mixed-radix counter\n      let carry = 0;\n      freeValues[nFree - 1]++;\n      for (let k = nFree - 1; k >= 0; k--) {\n        freeValues[k] += carry;\n        carry = 0;\n        if (freeValues[k] >= p) {\n          freeValues[k] = 0;\n          carry = 1;\n        } else {\n          break;\n        }\n      }\n    }\n\n    return bestSolution!;\n  }\n\n  // For large null spaces with p > 2, use greedy optimization\n  // Try all single-variable settings for each free variable\n  let bestSolution = particular.map(v => mod(v, p));\n  let bestTotal = bestSolution.reduce((a, b) => a + b, 0);\n\n  // Greedy: for each free variable, try all p values and pick the best\n  const currentCoeffs = new Array(nFree).fill(0);\n  let improved = true;\n  while (improved) {\n    improved = false;\n    for (let k = 0; k < nFree; k++) {\n      let bestVal = currentCoeffs[k];\n      let bestLocalTotal = bestTotal;\n      let bestLocalSolution = bestSolution;\n\n      for (let v = 0; v < p; v++) {\n        if (v === currentCoeffs[k]) continue;\n        const diff = v - currentCoeffs[k];\n        const solution = new Array(nButtons);\n        let total = 0;\n        for (let j = 0; j < nButtons; j++) {\n          solution[j] = mod(bestSolution[j] + diff * nullVecs[k][j], p);\n          total += solution[j];\n        }\n        if (total < bestLocalTotal || (total === bestLocalTotal && lexLess(solution, bestLocalSolution))) {\n          bestLocalTotal = total;\n          bestLocalSolution = solution;\n          bestVal = v;\n        }\n      }\n\n      if (bestVal !== currentCoeffs[k]) {\n        currentCoeffs[k] = bestVal;\n        bestTotal = bestLocalTotal;\n        bestSolution = bestLocalSolution;\n        improved = true;\n      }\n    }\n  }\n\n  return bestSolution;\n}\n\n// ─── Public API ──────────────────────────────────────────────────────\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const nLights = target.length;\n  const nButtons = buttons.length;\n\n  const targetNums = target.map(t => t ? 1 : 0);\n\n  const gauss = gaussianElimination(nLights, nButtons, buttons, targetNums, 2);\n  if (gauss === null) return null;\n\n  const solution = solveToggleOptimal(gauss);\n\n  const pressed: number[] = [];\n  for (let i = 0; i < nButtons; i++) {\n    if (solution[i] === 1) pressed.push(i);\n  }\n\n  return pressed.sort((a, b) => a - b);\n}\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const nLights = lights.length;\n  const nButtons = buttons.length;\