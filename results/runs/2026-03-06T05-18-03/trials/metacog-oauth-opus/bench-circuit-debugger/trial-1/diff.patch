result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a02', 'a05', 'b04', 'c01', 'c04', 't03', 'z03', 'z05'].sort()\n    );\n  });\n});\n","structuredPatch":[{"oldStart":206,"oldLines":4,"newStart":206,"newLines":34,"lines":["       ['a02', 'a05', 'b04', 'c01', 'c04', 't03', 'z03', 'z05'].sort()","     );","   });","+","+  it('should handle swapped z output with non-adjacent wire', () => {","+    const gates = buildAdder(10);","+","+    // Swap wires at different bit positions","+    swapOutputs(gates, 'z01', 'c03');","+    swapOutputs(gates, 'z05', 't05');","+    swapOutputs(gates, 'a07', 'c07');","+    swapOutputs(gates, 'z09', 'b09');","+","+    const result = findSwappedWires(gates);","+    expect(result).toEqual(","+      ['a07', 'b09', 'c03', 'c07', 't05', 'z01', 'z05', 'z09'].sort()","+    );","+  });","+","+  it('should handle swaps at consecutive bit positions', () => {","+    const gates = buildAdder(8);","+","+    // Swap wires at consecutive positions","+    swapOutputs(gates, 'z01', 't01');","+    swapOutputs(gates, 'z02', 't02');","+    swapOutputs(gates, 'z03', 't03');","+    swapOutputs(gates, 'z04', 't04');","+","+    const result = findSwappedWires(gates);","+    expect(result).toEqual(","+      ['t01', 't02', 't03', 't04', 'z01', 'z02', 'z03', 'z04'].sort()","+    );","+  });"," });"]}],"userModified":false,"replaceAll":false}}
