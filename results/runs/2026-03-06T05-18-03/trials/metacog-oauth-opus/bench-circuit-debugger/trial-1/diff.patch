+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit of logic gates given initial wire values.
+ * Returns the final value of every wire (inputs + computed).
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find 8 wires involved in 4 output-wire swaps in a ripple-carry adder circuit.
+ *
+ * Approach: Walk the expected ripple-carry adder structure bit by bit.
+ * For each bit position, find gates by their operation and inputs (which are
+ * structural invariants — inputs don't change in a swap, only outputs do).
+ * When we find a gate with the right inputs but wrong output, we've found a swap.
+ * We use the actual (possibly swapped) output to continue tracing, which lets
+ * us handle cascading effects.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Index: (op, in1, in2) -> gate (order-independent on inputs)
+  const byInputs = new Map<string, Gate>();
+  for (const g of gates) {
+    const [a, b] = [g.in1, g.in2].sort();
+    byInputs.set(`${g.op}:${a}:${b}`, g);
+  }
+
+  // Index: output wire -> gate
+  const byOutput = new Map<string, Gate>();
+  for (const g of gates) {
+    byOutput.set(g.out, g);
+  }
+
+  // Index: (op, oneInput) -> list of gates
+  const byOpAndInput = new Map<string, Gate[]>();
+  for (const g of gates) {
+    for (const inp of [g.in1, g.in2]) {
+      const key = `${g.op}:${inp}`;
+      if (!byOpAndInput.has(key)) byOpAndInput.set(key, []);
+      byOpAndInput.get(key)!.push(g);
+    }
+  }
+
+  function findGate(op: string, a: string, b: string): Gate | undefined {
+    const [sa, sb] = [a, b].sort();
+    return byInputs.get(`${op}:${sa}:${sb}`);
+  }
+
+  function findGateByOpAndOneInput(op: string, input: string, exclude?: Gate): Gate | undefined {
+    const list = byOpAndInput.get(`${op}:${input}`) || [];
+    for (const g of list) {
+      if (g !== exclude) return g;
+    }
+    return undefined;
+  }
+
+  // Determine number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const mx = w.match(/^x(\d+)$/);
+      if (mx) maxBit = Math.max(maxBit, parseInt(mx[1]));
+    }
+  }
+  const numBits = maxBit + 1;
+
+  const swapped = new Set<string>();
+
+  function markSwap(a: string, b: string): void {
+    swapped.add(a);
+    swapped.add(b);
+  }
+
+  // Trace the adder structure, using actual wire names (which may be swapped).
+  // We track the "carry" wire through each stage.
+  let carry = '';
+
+  // Bit 0: half adder
+  // x00 XOR y00 -> z00
+  // x00 AND y00 -> carry
+  {
+    const xorGate = findGate('XOR', 'x00', 'y00');
+    if (xorGate && xorGate.out !== 'z00') {
+      markSwap(xorGate.out, 'z00');
+    }
+
+    const andGate = findGate('AND', 'x00', 'y00');
+    carry = andGate ? andGate.out : '';
+  }
+
+  // Bits 1..N-1: full adders
+  for (let i = 1; i < numBits; i++) {
+    const xi = `x${i.toString().padStart(2, '0')}`;
+    const yi = `y${i.toString().padStart(2, '0')}`;
+    const zi = `z${i.toString().padStart(2, '0')}`;
+
+    // Step 1: xi XOR yi -> partialSum
+    const xorGate = findGate('XOR', xi, yi);
+    if (!xorGate) continue;
+    let partialSum = xorGate.out;
+
+    // Step 2: partialSum XOR carry -> zi
+    let sumGate = findGate('XOR', partialSum, carry);
+
+    if (!sumGate) {
+      // Either partialSum or carry (or both) are swapped outputs.
+      //
+      // Case A: partialSum is swapped. The real partial sum wire is something else.
+      //   We can find it by looking for an XOR gate that uses carry as one input.
+      // Case B: carry is swapped. The real carry wire is something else.
+      //   We can find it by looking for an XOR gate that uses partialSum as one input.
+      //
+      // Try case A first: find an XOR gate with carry as input (excluding the xi XOR yi gate)
+      const candidateA = findGateByOpAndOneInput('XOR', carry, xorGate);
+      // Try case B: find an XOR gate with partialSum as input (excluding the xi XOR yi gate)
+      const candidateB = findGateByOpAndOneInput('XOR', partialSum, xorGate);
+
+      if (candidateA) {
+        // Found XOR gate using carry. Its other input is the real partial sum.
+        const realPartialSum = candidateA.in1 === carry ? candidateA.in2 : candidateA.in1;
+        markSwap(partialSum, realPartialSum);
+        partialSum = realPartialSum;
+        sumGate = candidateA;
+        // Check if sumGate's output is zi
+        if (sumGate.out !== zi) {
+          markSwap(sumGate.out, zi);
+        }
+      } else if (candidateB) {
+        // Found XOR gate using partialSum. Its other input is the real carry.
+        const realCarry = candidateB.in1 === partialSum ? candidateB.in2 : candidateB.in1;
+        markSwap(carry, realCarry);
+        carry = realCarry;
+        sumGate = candidateB;
+        if (sumGate.out !== zi) {
+          markSwap(sumGate.out, zi);
+        }
+      }
+    } else {
+      // sumGate found, verify its output is zi
+      if (sumGate.out !== zi) {
+        markSwap(sumGate.out, zi);
+      }
+    }
+
+    // Step 3: xi AND yi -> generate
+    const genGate = findGate('AND', xi, yi);
+    const generate = genGate ? genGate.out : '';
+
+    // Step 4: partialSum AND carry -> propagate
+    const propGate = findGate('AND', partialSum, carry);
+    const propagate = propGate ? propGate.out : '';
+
+    // Step 5: generate OR propagate -> carry_out
+    const carryGate = findGate('OR', generate, propagate);
+    if (carryGate) {
+      carry = carryGate.out;
+    } else if (generate && propagate) {
+      // One of generate or propagate might be swapped
+      const candidateG = findGateByOpAndOneInput('OR', generate);
+      const candidateP = findGateByOpAndOneInput('OR', propagate);
+
+      if (candidateG) {
+        const realProp = candidateG.in1 === generate ? candidateG.in2 : candidateG.in1;
+        if (realProp !== propagate) {
+          markSwap(propagate, realProp);
+        }
+        carry = candidateG.out;
+      } else if (candidateP) {
+        const realGen = candidateP.in1 === propagate ? candidateP.in2 : candidateP.in1;
+        if (realGen !== generate) {
+          markSwap(generate, realGen);
+        }
+        carry = candidateP.out;
+      }
+    }
+  }
+
+  // Final carry should be the last z bit
+  const finalZ = `z${numBits.toString().padStart(2, '0')}`;
+  if (carry !== finalZ) {
+    if (!swapped.has(carry) && !swapped.has(finalZ)) {
+      markSwap(carry, finalZ);
+    }
+  }
+
+  return [...swapped].sort();
+}
