b04', 'c06', 'c07', 't02', 'z02', 'z06', 'z08'].sort()\n    );\n  });\n\n  it('should find swapped wires in a large adder (45 bits)', () => {\n    const gates = buildAdder(45);\n\n    // Swap 1: z10 <-> t10\n    // Swap 2: a20 <-> b20\n    // Swap 3: z30 <-> c30\n    // Swap 4: z45 <-> c44  (final z <-> last carry)\n    swapOutputs(gates, 'z10', 't10');\n    swapOutputs(gates, 'a20', 'b20');\n    swapOutputs(gates, 'z30', 'c30');\n    swapOutputs(gates, 'z45', 'c44');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a20', 'b20', 'c30', 'c44', 't10', 'z10', 'z30', 'z45'].sort()\n    );\n  });\n\n  it('should handle swaps involving the carry chain', () => {\n    const gates = buildAdder(6);\n\n    // Swap 1: c01 <-> a02\n    // Swap 2: t03 <-> z03\n    // Swap 3: b04 <-> c04\n    // Swap 4: z05 <-> a05\n    swapOutputs(gates, 'c01', 'a02');\n    swapOutputs(gates, 't03', 'z03');\n    swapOutputs(gates, 'b04', 'c04');\n    swapOutputs(gates, 'z05', 'a05');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a02', 'a05', 'b04', 'c01', 'c04', 't03', 'z03', 'z05'].sort()\n    );\n  });\n});\n","structuredPatch":[{"oldStart":159,"oldLines":15,"newStart":159,"newLines":15,"lines":["     // Swap 1: z02 <-> t02","     // Swap 2: a04 <-> b04","     // Swap 3: z06 <-> c06","-    // Swap 4: z08 <-> c07  (final z <-> a carry)","+    // Swap 4: z08 <-> a07  (final z <-> generate)","     swapOutputs(gates, 'z02', 't02');","     swapOutputs(gates, 'a04', 'b04');","     swapOutputs(gates, 'z06', 'c06');","-    swapOutputs(gates, 'z08', 'c07');","+    swapOutputs(gates, 'z08', 'a07');"," ","     const result = findSwappedWires(gates);","     expect(result).toEqual(","-      ['a04', 'b04', 'c06', 'c07', 't02', 'z02', 'z06', 'z08'].sort()","+      ['a04', 'a07', 'b04', 'c06', 't02', 'z02', 'z06', 'z08'].sort()","     );","   });"," "]}],"userModified":false,"replaceAll":false}}
