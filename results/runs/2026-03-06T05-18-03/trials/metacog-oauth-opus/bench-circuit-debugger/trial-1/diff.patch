+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from '../src/index.js';
+
+describe('simulate', () => {
+  it('should evaluate AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should evaluate OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should evaluate XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should handle chained gates in dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, d: 0, c: 1, e: 1,
+    });
+    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({
+      a: 0, b: 1, d: 0, c: 0, e: 0,
+    });
+  });
+
+  it('should handle gates given in reverse dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, d: 0, c: 1, e: 1,
+    });
+  });
+
+  it('should simulate a correct 4-bit adder', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },
+    ];
+
+    // X = 10 (0b1010), Y = 6 (0b0110), Z = 16 (0b10000)
+    const inputs: Record<string, number> = {
+      x00: 0, x01: 1, x02: 0, x03: 1,
+      y00: 0, y01: 1, y02: 1, y03: 0,
+    };
+
+    const result = simulate(gates, inputs);
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(0);
+    expect(result.z02).toBe(0);
+    expect(result.z03).toBe(0);
+    expect(result.z04).toBe(1);
+  });
+});
+
+/**
+ * Build a correct N-bit ripple-carry adder circuit.
+ * All intermediate wires have unique names.
+ */
+function buildAdder(numBits: number): Gate[] {
+  const gates: Gate[] = [];
+
+  // Bit 0: half adder
+  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+  for (let i = 1; i < numBits; i++) {
+    const pad = i.toString().padStart(2, '0');
+    const prevPad = (i - 1).toString().padStart(2, '0');
+    const xi = `x${pad}`;
+    const yi = `y${pad}`;
+    const zi = `z${pad}`;
+    const ti = `t${pad}`;
+    const ai = `a${pad}`;
+    const bi = `b${pad}`;
+    const ci = `c${pad}`;
+    const cPrev = `c${prevPad}`;
+
+    gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });
+    gates.push({ op: 'XOR', in1: ti, in2: cPrev, out: zi });
+    gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });
+    gates.push({ op: 'AND', in1: ti, in2: cPrev, out: bi });
+    gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });
+  }
+
+  // The final carry c(N-1) becomes z(N)
+  // We do this by renaming the last carry gate's output
+  const lastCarryName = `c${(numBits - 1).toString().padStart(2, '0')}`;
+  const finalZName = `z${numBits.toString().padStart(2, '0')}`;
+  const lastGate = gates.find(g => g.out === lastCarryName)!;
+  lastGate.out = finalZName;
+
+  return gates;
+}
+
+function swapOutputs(gates: Gate[], w1: string, w2: string): void {
+  const g1 = gates.find(g => g.out === w1)!;
+  const g2 = gates.find(g => g.out === w2)!;
+  if (!g1) throw new Error(`Wire ${w1} not found`);
+  if (!g2) throw new Error(`Wire ${w2} not found`);
+  g1.out = w2;
+  g2.out = w1;
+}
+
+describe('findSwappedWires', () => {
+  it('should find swapped wires in a small adder (4 bits)', () => {
+    const gates = buildAdder(4);
+
+    // Swap 1: z00 <-> c00  (half adder outputs swapped)
+    // Swap 2: z01 <-> a01
+    // Swap 3: t02 <-> b02
+    // Swap 4: z03 <-> z04
+    swapOutputs(gates, 'z00', 'c00');
+    swapOutputs(gates, 'z01', 'a01');
+    swapOutputs(gates, 't02', 'b02');
+    swapOutputs(gates, 'z03', 'z04');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a01', 'b02', 'c00', 't02', 'z00', 'z01', 'z03', 'z04'].sort()
+    );
+  });
+
+  it('should find swapped wires in a medium adder (8 bits)', () => {
+    const gates = buildAdder(8);
+
+    // Swap 1: z02 <-> t02
+    // Swap 2: a04 <-> c04 (generate swapped with carry out)
+    // Swap 3: z06 <-> c06
+    // Swap 4: z08 <-> a07  (final z <-> generate)
+    swapOutputs(gates, 'z02', 't02');
+    swapOutputs(gates, 'a04', 'c04');
+    swapOutputs(gates, 'z06', 'c06');
+    swapOutputs(gates, 'z08', 'a07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a04', 'a07', 'c04', 'c06', 't02', 'z02', 'z06', 'z08'].sort()
+    );
+  });
+
+  it('should find swapped wires in a large adder (45 bits)', () => {
+    const gates = buildAdder(45);
+
+    // Swap 1: z10 <-> t10
+    // Swap 2: a20 <-> c20 (generate swapped with carry out)
+    // Swap 3: z30 <-> c30
+    // Swap 4: z45 <-> b44  (final z <-> propagate at last bit)
+    swapOutputs(gates, 'z10', 't10');
+    swapOutputs(gates, 'a20', 'c20');
+    swapOutputs(gates, 'z30', 'c30');
+    swapOutputs(gates, 'z45', 'b44');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a20', 'b44', 'c20', 'c30', 't10', 'z10', 'z30', 'z45'].sort()
+    );
+  });
+
+  it('should handle swaps involving the carry chain', () => {
+    const gates = buildAdder(6);
+
+    // Swap 1: c01 <-> a02
+    // Swap 2: t03 <-> z03
+    // Swap 3: b04 <-> c04
+    // Swap 4: z05 <-> a05
+    swapOutputs(gates, 'c01', 'a02');
+    swapOutputs(gates, 't03', 'z03');
+    swapOutputs(gates, 'b04', 'c04');
+    swapOutputs(gates, 'z05', 'a05');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a02', 'a05', 'b04', 'c01', 'c04', 't03', 'z03', 'z05'].sort()
+    );
+  });
+
+  it('should handle swapped z output with non-adjacent wire', () => {
+    const gates = buildAdder(10);
+
+    // Swap wires at different bit positions
+    swapOutputs(gates, 'z01', 'c03');
+    swapOutputs(gates, 'z05', 't05');
+    swapOutputs(gates, 'a07', 'c07');
+    swapOutputs(gates, 'z09', 'b09');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a07', 'b09', 'c03', 'c07', 't05', 'z01', 'z05', 'z09'].sort()
+    );
+  });
+
+  it('should handle carry swapped with distant z wire', () => {
+    const gates = buildAdder(8);
+
+    // c02 <-> z05: carry at bit 2 swapped with z output at bit 5
+    swapOutputs(gates, 'c02', 'z05');
+    swapOutputs(gates, 'z01', 't01');
+    swapOutputs(gates, 'a06', 'c06');
+    swapOutputs(gates, 'z08', 'b07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a06', 'b07', 'c02', 'c06', 't01', 'z01', 'z05', 'z08'].sort()
+    );
+  });
+
+  it('should handle swaps at consecutive bit positions', () => {
+    const gates = buildAdder(8);
+
+    // Swap wires at consecutive positions
+    swapOutputs(gates, 'z01', 't01');
+    swapOutputs(gates, 'z02', 't02');
+    swapOutputs(gates, 'z03', 't03');
+    swapOutputs(gates, 'z04', 't04');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['t01', 't02', 't03', 't04', 'z01', 'z02', 'z03', 'z04'].sort()
+    );
+  });
+});
