+  afterAll(() => {
+    try {
+      if (existsSync(dbPath)) unlinkSync(dbPath);
+    } catch {
+      // ignore cleanup errors
+    }
+  });
+
+  it('should persist documents across server restarts', async () => {
+    // Start server, create document
+    const app1 = createApp(dbPath);
+    const port1 = await app1.start(0);
+
+    const res1 = await request(app1.app)
+      .post('/documents')
+      .send({ title: 'Persistent Doc', content: 'I survive restarts' })
+      .expect(201);
+
+    const docId = res1.body.id;
