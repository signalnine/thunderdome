@@ -0,0 +1,179 @@
+/**
+ * Operational Transformation (OT) engine for collaborative editing.
+ *
+ * Supports two operation types:
+ * - insert: Insert text at a given position
+ * - delete: Delete a number of characters at a given position
+ */
+
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+export interface VersionedOperation {
+  operation: Operation;
+  version: number;  // The document version this operation was based on
+  clientId?: string;
+}
+
+/**
+ * Apply an operation to a document string.
+ */
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    return content.slice(0, pos) + op.text + content.slice(pos);
+  } else if (op.type === 'delete') {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    const count = Math.min(op.count, content.length - pos);
+    if (count <= 0) return content;
+    return content.slice(0, pos) + content.slice(pos + count);
+  }
+  return content;
+}
+
+/**
+ * Transform operation `op1` against `op2`.
+ * Returns the transformed version of `op1` that should be applied after `op2`.
+ *
+ * This implements the standard OT transformation functions for insert and delete.
+ */
+export function transformOperation(op1: Operation, op2: Operation): Operation {
+  if (op1.type === 'insert' && op2.type === 'insert') {
+    return transformInsertInsert(op1, op2);
+  } else if (op1.type === 'insert' && op2.type === 'delete') {
+    return transformInsertDelete(op1, op2);
+  } else if (op1.type === 'delete' && op2.type === 'insert') {
+    return transformDeleteInsert(op1, op2);
+  } else if (op1.type === 'delete' && op2.type === 'delete') {
+    return transformDeleteDelete(op1 as DeleteOp, op2 as DeleteOp);
+  }
+  return op1;
+}
+
+function transformInsertInsert(op1: InsertOp, op2: InsertOp): InsertOp {
+  if (op1.position < op2.position || (op1.position === op2.position && (op1.text <= op2.text))) {
+    // op1 is before or at same position (with tie-breaking by text)
+    return { ...op1 };
+  } else {
+    return { ...op1, position: op1.position + op2.text.length };
+  }
+}
+
+function transformInsertDelete(op1: InsertOp, op2: DeleteOp): InsertOp {
+  if (op1.position <= op2.position) {
+    return { ...op1 };
+  } else if (op1.position >= op2.position + op2.count) {
+    return { ...op1, position: op1.position - op2.count };
+  } else {
+    // Insert position is within deleted range - move to delete position
+    return { ...op1, position: op2.position };
+  }
+}
+
+function transformDeleteInsert(op1: DeleteOp, op2: InsertOp): DeleteOp {
+  if (op2.position >= op1.position + op1.count) {
+    // Insert is after the delete range
+    return { ...op1 };
+  } else if (op2.position <= op1.position) {
+    // Insert is before the delete range
+    return { ...op1, position: op1.position + op2.text.length };
+  } else {
+    // Insert is within the delete range - split the delete around the insert
+    // The delete still needs to delete the same characters, but the insert
+    // has been placed in the middle, so we expand the count
+    return { ...op1, count: op1.count + op2.text.length };
+  }
+}
+
+function transformDeleteDelete(op1: DeleteOp, op2: DeleteOp): DeleteOp {
+  if (op1.position >= op2.position + op2.count) {
+    // op1 is entirely after op2
+    return { ...op1, position: op1.position - op2.count };
+  } else if (op1.position + op1.count <= op2.position) {
+    // op1 is entirely before op2
+    return { ...op1 };
+  } else {
+    // Overlapping deletes
+    const overlapStart = Math.max(op1.position, op2.position);
+    const overlapEnd = Math.min(op1.position + op1.count, op2.position + op2.count);
+    const overlap = Math.max(0, overlapEnd - overlapStart);
+
+    const newPosition = Math.min(op1.position, op2.position);
+    const newCount = op1.count - overlap;
+
+    if (newCount <= 0) {
+      return { type: 'delete', position: newPosition, count: 0 };
+    }
+
+    // Adjust position based on where op2 was
+    const adjustedPosition = op1.position <= op2.position
+      ? op1.position
+      : op1.position - (op2.count - overlap);
+
+    return { type: 'delete', position: Math.max(0, adjustedPosition), count: newCount };
+  }
+}
+
+/**
+ * Transform an operation against a series of operations that have already been applied.
+ */
+export function transformAgainstHistory(op: Operation, history: Operation[]): Operation {
+  let transformed = op;
+  for (const histOp of history) {
+    transformed = transformOperation(transformed, histOp);
+  }
+  return transformed;
+}
+
+/**
+ * Validate that an operation is well-formed.
+ */
+export function validateOperation(op: unknown): op is Operation {
+  if (!op || typeof op !== 'object') return false;
+  const o = op as Record<string, unknown>;
+
+  if (o.type === 'insert') {
+    return (
+      typeof o.position === 'number' &&
+      o.position >= 0 &&
+      Number.isInteger(o.position) &&
+      typeof o.text === 'string' &&
+      o.text.length > 0
+    );
+  } else if (o.type === 'delete') {
+    return (
+      typeof o.position === 'number' &&
+      o.position >= 0 &&
+      Number.isInteger(o.position) &&
+      typeof o.count === 'number' &&
+      o.count > 0 &&
+      Number.isInteger(o.count)
+    );
+  }
+  return false;
+}
+
+/**
+ * Validate a versioned operation message from a client.
+ */
+export function validateVersionedOperation(msg: unknown): msg is VersionedOperation {
+  if (!msg || typeof msg !== 'object') return false;
+  const m = msg as Record<string, unknown>;
+
+  if (typeof m.version !== 'number' || !Number.isInteger(m.version) || m.version < 0) {
+    return false;
+  }
+
+  return validateOperation(m.operation);
+}
