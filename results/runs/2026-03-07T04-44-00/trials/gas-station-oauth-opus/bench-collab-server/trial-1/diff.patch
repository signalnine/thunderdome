+// Helper to create a WebSocket connection to a document
+function connectWs(port: number, docId: string): Promise<{ ws: WebSocket; syncMsg: Record<string, unknown> }> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://127.0.0.1:${port}/ws/documents/${docId}`);
+    const timer = setTimeout(() => reject(new Error('WebSocket connection timeout')), 5000);
+    ws.on('message', (data) => {
+      clearTimeout(timer);
+      const msg = JSON.parse(data.toString());
+      if (msg.type === 'sync') {
+        resolve({ ws, syncMsg: msg });
+      }
+    });
+    ws.on('error', (err) => {
+      clearTimeout(timer);
+      reject(err);
+    });
+  });
+}
+
+// Helper to wait for a specific message type from a WebSocket
+function waitForMessage(ws: WebSocket, type: string, timeout = 5000): Promise<Record<string, unknown>> {
+  return new Promise((resolve, reject) => {
+    const timer = setTimeout(() => reject(new Error(`Timeout waiting for ${type}`)), timeout);
+    const handler = (data: Buffer | string) => {
+      const msg = JSON.parse(typeof data === 'string' ? data : data.toString());
+      if (msg.type === type) {
+        clearTimeout(timer);
+        ws.off('message', handler);
+        resolve(msg);
+      }
+    };
+    ws.on('message', handler);
+  });
+}
+
+// Helper to send an operation and wait for ack
+function sendOp(
+  ws: WebSocket,
+  operation: Record<string, unknown>,
+  version: number
+): Promise<Record<string, unknown>> {
+  const ackPromise = waitForMessage(ws, 'ack');
+  ws.send(JSON.stringify({ type: 'operation', operation, version }));
+  return ackPromise;
+}
+
+// Helper to close WebSocket cleanly
+function closeWs(ws: WebSocket): Promise<void> {
+  return new Promise((resolve) => {
+    if (ws.readyState === WebSocket.CLOSED || ws.readyState === WebSocket.CLOSING) {
+      resolve();
+      return;
+    }
+    ws.on('close', () => resolve());
+    ws.close();
+  });
+}
+
+// Helper to create a document via REST
+async function createDoc(app: AppInstance, title = 'Test Doc', content = ''): Promise<Record<string, unknown>> {
+  const res = await request(app.app)
+    .post('/documents')
+    .send({ title, content })
+    .expect(201);
+  return res.body;
+}
