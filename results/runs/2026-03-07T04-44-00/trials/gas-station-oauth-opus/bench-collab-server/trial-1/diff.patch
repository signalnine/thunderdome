+  afterAll(async () => {
+    await app.stop();
+  });
+
+  it('should create a document', async () => {
+    const res = await request(app.app)
+      .post('/documents')
+      .send({ title: 'My Document', content: 'Hello world' })
+      .expect(201);
+
+    expect(res.body).toHaveProperty('id');
+    expect(res.body.title).toBe('My Document');
+    expect(res.body.content).toBe('Hello world');
+    expect(res.body).toHaveProperty('created_at');
+    expect(res.body).toHaveProperty('updated_at');
+  });
+
+  it('should create a document with empty content', async () => {
+    const res = await request(app.app)
+      .post('/documents')
+      .send({ title: 'Empty Doc' })
+      .expect(201);
+
+    expect(res.body.content).toBe('');
+  });
+
+  it('should reject document creation without title', async () => {
+    await request(app.app)
+      .post('/documents')
+      .send({ content: 'No title' })
+      .expect(400);
+  });
+
+  it('should get a document by id', async () => {
+    const created = await createDoc(app, 'Get Test', 'content here');
+    const res = await request(app.app)
+      .get(`/documents/${created.id}`)
