@@ -0,0 +1,280 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage } from 'http';
+import { Server } from 'http';
+import { randomUUID } from 'crypto';
+import { DocumentStore } from './database.js';
+import {
+  Operation,
+  applyOperation,
+  transformOperation,
+  validateOperation,
+} from './ot.js';
+
+interface ClientConnection {
+  ws: WebSocket;
+  clientId: string;
+  documentId: string;
+}
+
+interface DocumentState {
+  version: number;
+  // Operations applied since version 0, indexed by version number
+  operations: Operation[];
+}
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  private store: DocumentStore;
+  private clients: Map<string, ClientConnection> = new Map();
+  private documentStates: Map<string, DocumentState> = new Map();
+
+  constructor(server: Server, store: DocumentStore) {
+    this.store = store;
+    this.wss = new WebSocketServer({ server });
+
+    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {
+      this.handleConnection(ws, req);
+    });
+  }
+
+  private getDocumentState(documentId: string): DocumentState {
+    let state = this.documentStates.get(documentId);
+    if (!state) {
+      const latestVersion = this.store.getLatestVersion(documentId);
+      // Load operation history from DB
+      const versions = this.store.getVersions(documentId);
+      const operations: Operation[] = [];
+      for (const v of versions) {
+        if (v.operation) {
+          try {
+            operations[v.version] = JSON.parse(v.operation);
+          } catch {
+            // skip malformed
+          }
+        }
+      }
+      state = { version: latestVersion, operations };
+      this.documentStates.set(documentId, state);
+    }
+    return state;
+  }
+
+  private handleConnection(ws: WebSocket, req: IncomingMessage): void {
+    // Extract document ID from URL path: /ws/documents/:id or /documents/:id/ws
+    const url = req.url || '';
+    const documentId = this.extractDocumentId(url);
+
+    if (!documentId) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid WebSocket URL. Expected /ws/documents/:id or /documents/:id/ws' }));
+      ws.close(1008, 'Invalid URL');
+      return;
+    }
+
+    // Check if document exists
+    const doc = this.store.getDocument(documentId);
+    if (!doc) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close(1008, 'Document not found');
+      return;
+    }
+
+    const clientId = randomUUID();
+    const connection: ClientConnection = { ws, clientId, documentId };
+    this.clients.set(clientId, connection);
+    this.store.addConnection(clientId, documentId);
+
+    const state = this.getDocumentState(documentId);
+
+    // Send sync message with current state
+    ws.send(JSON.stringify({
+      type: 'sync',
+      document: doc,
+      version: state.version,
+      clientId,
+    }));
+
+    ws.on('message', (data: Buffer | string) => {
+      this.handleMessage(clientId, data);
+    });
+
+    ws.on('close', () => {
+      this.handleDisconnect(clientId);
+    });
+
+    ws.on('error', () => {
+      this.handleDisconnect(clientId);
+    });
+  }
+
+  private extractDocumentId(url: string): string | null {
+    // Support both: /ws/documents/:id and /documents/:id/ws
+    // Also strip query strings
+    const pathOnly = url.split('?')[0];
+
+    const match1 = pathOnly.match(/^\/ws\/documents\/([^/]+)$/);
+    if (match1) return match1[1];
+
+    const match2 = pathOnly.match(/^\/documents\/([^/]+)\/ws$/);
+    if (match2) return match2[1];
+
+    // Also support just /ws/:id for simplicity
+    const match3 = pathOnly.match(/^\/ws\/([^/]+)$/);
+    if (match3) return match3[1];
+
+    return null;
+  }
+
+  private handleMessage(clientId: string, data: Buffer | string): void {
+    const connection = this.clients.get(clientId);
+    if (!connection) return;
+
+    let message: Record<string, unknown>;
+    try {
+      message = JSON.parse(typeof data === 'string' ? data : data.toString());
+    } catch {
+      connection.ws.send(JSON.stringify({
+        type: 'error',
+        message: 'Invalid JSON',
+      }));
+      return;
+    }
+
+    const { type } = message;
+
+    if (type === 'operation') {
+      this.handleOperation(clientId, message);
+    } else {
+      connection.ws.send(JSON.stringify({
+        type: 'error',
+        message: `Unknown message type: ${type}`,
+      }));
+    }
+  }
+
+  private handleOperation(clientId: string, message: Record<string, unknown>): void {
+    const connection = this.clients.get(clientId);
+    if (!connection) return;
+
+    const { documentId } = connection;
+    const doc = this.store.getDocument(documentId);
+    if (!doc) {
+      connection.ws.send(JSON.stringify({
+        type: 'error',
+        message: 'Document no longer exists',
+      }));
+      return;
+    }
+
+    // Validate the operation
+    const rawOp = message.operation;
+    if (!validateOperation(rawOp)) {
+      connection.ws.send(JSON.stringify({
+        type: 'error',
+        message: 'Invalid operation',
+      }));
+      return;
+    }
+
+    const clientVersion = typeof message.version === 'number' ? message.version : undefined;
+    const state = this.getDocumentState(documentId);
+
+    let op: Operation = rawOp as Operation;
+
+    // Transform against concurrent operations if needed
+    if (clientVersion !== undefined && clientVersion < state.version) {
+      // Transform against all operations that happened between clientVersion and current version
+      for (let i = clientVersion + 1; i <= state.version; i++) {
+        const concurrentOp = state.operations[i];
+        if (concurrentOp) {
+          op = transformOperation(op, concurrentOp);
+        }
+      }
+    }
+
+    // Validate operation against current content
+    const currentContent = doc.content;
+    if (op.type === 'insert') {
+      if (op.position > currentContent.length) {
+        op = { ...op, position: currentContent.length };
+      }
+    } else if (op.type === 'delete') {
+      if (op.position >= currentContent.length) {
+        connection.ws.send(JSON.stringify({
+          type: 'ack',
+          version: state.version,
+        }));
+        return;
+      }
+      if (op.position + op.count > currentContent.length) {
+        op = { ...op, count: currentContent.length - op.position };
+      }
+      if (op.count <= 0) {
+        connection.ws.send(JSON.stringify({
+          type: 'ack',
+          version: state.version,
+        }));
+        return;
+      }
+    }
+
+    // Apply the operation
+    const newContent = applyOperation(currentContent, op);
+    state.version++;
+    state.operations[state.version] = op;
+
+    // Persist
+    this.store.updateContent(documentId, newContent);
+    this.store.createVersion(documentId, state.version, newContent, JSON.stringify(op));
+
+    // Acknowledge the sender
+    connection.ws.send(JSON.stringify({
+      type: 'ack',
+      version: state.version,
+    }));
+
+    // Broadcast to other clients on the same document
+    this.broadcastToDocument(documentId, clientId, {
+      type: 'operation',
+      operation: op,
+      version: state.version,
+      clientId,
+    });
+  }
+
+  private broadcastToDocument(documentId: string, excludeClientId: string, message: object): void {
+    const messageStr = JSON.stringify(message);
+    for (const [id, conn] of this.clients) {
+      if (id !== excludeClientId && conn.documentId === documentId && conn.ws.readyState === WebSocket.OPEN) {
+        conn.ws.send(messageStr);
+      }
+    }
+  }
+
+  private handleDisconnect(clientId: string): void {
+    const connection = this.clients.get(clientId);
+    if (connection) {
+      this.store.removeConnection(clientId);
+      this.clients.delete(clientId);
+    }
+  }
+
+  getConnectedClients(documentId: string): number {
+    let count = 0;
+    for (const conn of this.clients.values()) {
+      if (conn.documentId === documentId && conn.ws.readyState === WebSocket.OPEN) {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  closeAll(): void {
+    for (const [id, conn] of this.clients) {
+      conn.ws.close(1001, 'Server shutting down');
+      this.store.removeConnection(id);
+    }
+    this.clients.clear();
+    this.documentStates.clear();
+    this.wss.close();
+  }
+}
