@@ -0,0 +1,269 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      const v1 = wires[gate.in1];
+      const v2 = wires[gate.in2];
+      if (v1 !== undefined && v2 !== undefined) {
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = v1 & v2;
+            break;
+          case 'OR':
+            result = v1 | v2;
+            break;
+          case 'XOR':
+            result = v1 ^ v2;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Find the number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^x(\d+)$/);
+      if (m) {
+        maxBit = Math.max(maxBit, parseInt(m[1], 10));
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+  const lastZ = `z${String(numBits).padStart(2, '0')}`;
+
+  // Build lookup by output
+  const gateByOutput = new Map<string, Gate>();
+  for (const g of gates) {
+    gateByOutput.set(g.out, g);
+  }
+
+  // Build lookup by (op, sorted inputs)
+  function findGate(
+    op: Gate['op'],
+    a: string,
+    b: string,
+  ): Gate | undefined {
+    for (const g of gates) {
+      if (g.op !== op) continue;
+      if (
+        (g.in1 === a && g.in2 === b) ||
+        (g.in1 === b && g.in2 === a)
+      ) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  function findGatesWithInput(
+    op: Gate['op'],
+    input: string,
+  ): Gate[] {
+    return gates.filter(
+      (g) => g.op === op && (g.in1 === input || g.in2 === input),
+    );
+  }
+
+  const swapped = new Set<string>();
+
+  // ---- Structural Rules for Ripple-Carry Adder ----
+  //
+  // In a correct adder:
+  // 1. Every z-output (except the last) comes from an XOR gate
+  // 2. XOR gates either have x/y inputs (partial sum) or output z## (final sum)
+  // 3. AND gates (except bit-0 half-adder) must feed into OR gates
+  // 4. OR gate outputs never go to z-wires (except possibly the final carry)
+
+  for (const gate of gates) {
+    const { op, in1, in2, out } = gate;
+
+    // Rule 1: z-outputs must be XOR (except last z = carry)
+    if (out.startsWith('z') && out !== lastZ && op !== 'XOR') {
+      swapped.add(out);
+    }
+
+    // Rule 2: Non-input XOR gates must output to z
+    if (op === 'XOR') {
+      const hasXY =
+        (in1.startsWith('x') || in1.startsWith('y')) &&
+        (in2.startsWith('x') || in2.startsWith('y'));
+      if (!hasXY && !out.startsWith('z')) {
+        swapped.add(out);
+      }
+    }
+
+    // Rule 3: AND gate outputs (except bit-0) must feed into OR gates
+    if (op === 'AND') {
+      const isBit0 =
+        (in1 === 'x00' && in2 === 'y00') ||
+        (in1 === 'y00' && in2 === 'x00');
+      if (!isBit0) {
+        const orConsumers = findGatesWithInput('OR', out);
+        if (orConsumers.length === 0) {
+          swapped.add(out);
+        }
+      }
+    }
+
+    // Rule 4: OR gate outputs must not be z-wires (except final carry)
+    if (op === 'OR' && out.startsWith('z') && out !== lastZ) {
+      swapped.add(out);
+    }
+  }
+
+  if (swapped.size === 8) {
+    return [...swapped].sort();
+  }
+
+  // ---- Carry Chain Tracing ----
+  // Walk the adder bit by bit. At each bit, verify expected structure
+  // and detect anomalies. This catches swaps that the structural rules miss,
+  // such as when a partial sum XOR output is swapped with a carry wire.
+
+  // We need to track expected wire names through the carry chain.
+  // The approach: at each bit, find the expected gates and verify connections.
+
+  let carryWire = '';
+
+  for (let i = 0; i < numBits; i++) {
+    const xi = `x${String(i).padStart(2, '0')}`;
+    const yi = `y${String(i).padStart(2, '0')}`;
+    const zi = `z${String(i).padStart(2, '0')}`;
+
+    if (i === 0) {
+      // Half adder
+      const xorGate = findGate('XOR', xi, yi);
+      const andGate = findGate('AND', xi, yi);
+
+      if (xorGate) {
+        if (xorGate.out !== zi) {
+          swapped.add(xorGate.out);
+          swapped.add(zi);
+        }
+      }
+      if (andGate) {
+        carryWire = andGate.out;
+      }
+    } else {
+      // Full adder for bit i
+      const partialXor = findGate('XOR', xi, yi);
+      if (!partialXor) continue;
+
+      let partialWire = partialXor.out;
+
+      // Look for the final sum XOR: partialWire XOR carryWire -> zi
+      let finalXor = findGate('XOR', partialWire, carryWire);
+
+      if (!finalXor) {
+        // The XOR gate for final sum can't be found with expected inputs.
+        // Either partialWire or carryWire (or both) is wrong due to a swap.
+
+        // Strategy: look for what XOR gate uses carryWire
+        const xorsWithCarry = findGatesWithInput('XOR', carryWire);
+        const candidateFromCarry = xorsWithCarry.find(
+          (g) => g !== partialXor,
+        );
+
+        if (candidateFromCarry) {
+          // Found a XOR using carry. Its other input should be partialWire but isn't.
+          const otherInput =
+            candidateFromCarry.in1 === carryWire
+              ? candidateFromCarry.in2
+              : candidateFromCarry.in1;
+          // partialWire was swapped with otherInput
+          swapped.add(partialWire);
+          swapped.add(otherInput);
+          partialWire = otherInput;
+          finalXor = candidateFromCarry;
+        } else {
+          // No XOR uses carryWire (other than partialXor).
+          // Try: look for XOR using partialWire
+          const xorsWithPartial = findGatesWithInput('XOR', partialWire);
+          const candidateFromPartial = xorsWithPartial.find(
+            (g) => g !== partialXor,
+          );
+
+          if (candidateFromPartial) {
+            const otherInput =
+              candidateFromPartial.in1 === partialWire
+                ? candidateFromPartial.in2
+                : candidateFromPartial.in1;
+            // carryWire was swapped with otherInput
+            swapped.add(carryWire);
+            swapped.add(otherInput);
+            carryWire = otherInput;
+            finalXor = candidateFromPartial;
+          }
+        }
+      }
+
+      if (finalXor) {
+        if (finalXor.out !== zi) {
+          swapped.add(finalXor.out);
+          swapped.add(zi);
+        }
+      }
+
+      // Compute carry for next bit
+      const genGate = findGate('AND', xi, yi);
+      const propGate = findGate('AND', partialWire, carryWire);
+
+      if (genGate && propGate) {
+        const orGate = findGate('OR', genGate.out, propGate.out);
+        if (orGate) {
+          carryWire = orGate.out;
+        } else {
+          // One of genGate.out or propGate.out might be swapped.
+          // Find the OR gate that has at least one of these as input.
+          const orWithGen = findGatesWithInput('OR', genGate.out);
+          const orWithProp = findGatesWithInput('OR', propGate.out);
+          if (orWithGen.length > 0) {
+            carryWire = orWithGen[0].out;
+          } else if (orWithProp.length > 0) {
+            carryWire = orWithProp[0].out;
+          }
+        }
+      } else if (genGate && !propGate) {
+        // propGate not found - try to find carry via OR with gen
+        const orWithGen = findGatesWithInput('OR', genGate.out);
+        if (orWithGen.length > 0) {
+          carryWire = orWithGen[0].out;
+        }
+      } else if (!genGate && propGate) {
+        const orWithProp = findGatesWithInput('OR', propGate.out);
+        if (orWithProp.length > 0) {
+          carryWire = orWithProp[0].out;
+        }
+      }
+    }
+
+    if (swapped.size >= 8) break;
+  }
+
+  return [...swapped].sort();
+}
