@@ -0,0 +1,765 @@
+import { randomUUID } from 'crypto';
+
+// ============================================================
+// Types and Interfaces
+// ============================================================
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  createdAt: Date;
+  queue: string;
+  priority: number;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  failureCount: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+}
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  runAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface ProgressInfo {
+  progress: number;
+  message?: string;
+}
+
+export type ProgressCallback = (info: ProgressInfo) => void;
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  lastRun?: Date;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFn = (task: Task) => Promise<void>;
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+// ============================================================
+// TaskQueue Implementation
+// ============================================================
+
+export class TaskQueue {
+  private tasks: Map<string, Task> = new Map();
+  private queues: Map<string, string[]> = new Map(); // queueName -> task IDs in insertion order
+  private deadLetterQueues: Map<string, string[]> = new Map();
+  private concurrencyLimits: Map<string, number> = new Map();
+  private progressSubscribers: Map<string, Set<ProgressCallback>> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private middlewareStacks: Map<string, MiddlewareFn[]> = new Map();
+  private handlers: Map<string, HandlerFn> = new Map();
+  private isShutdown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+  private insertionCounter = 0;
+  private insertionOrder: Map<string, number> = new Map();
+
+  // Phase 1: Add a task
+  addTask<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {
+    if (this.isShutdown) {
+      throw new Error('Queue is shutting down, cannot add new tasks');
+    }
+
+    const queueName = options.queue ?? 'default';
+    const priority = options.priority ?? 5;
+
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Calculate availability time
+    let availableAt = new Date();
+    if (options.runAt) {
+      availableAt = options.runAt;
+    } else if (options.delay !== undefined && options.delay > 0) {
+      availableAt = new Date(Date.now() + options.delay);
+    }
+
+    // Validate dependencies
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      const depTask = this.tasks.get(depId);
+      if (!depTask) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+
+    // Check for circular dependencies
+    if (dependencies.length > 0) {
+      const taskId = randomUUID(); // pre-generate ID
+      this.detectCircularDeps(taskId, dependencies);
+
+      const task: Task<T> = {
+        id: taskId,
+        payload,
+        status: 'pending',
+        createdAt: new Date(),
+        queue: queueName,
+        priority,
+        availableAt,
+        attempt: 0,
+        maxRetries: options.maxRetries ?? 3,
+        backoffDelay: options.backoffDelay ?? 1000,
+        failureCount: 0,
+        dependencies,
+        progress: 0,
+      };
+
+      this.tasks.set(task.id, task as Task);
+      this.insertionOrder.set(task.id, this.insertionCounter++);
+      this.ensureQueue(queueName);
+      this.queues.get(queueName)!.push(task.id);
+
+      return task;
+    }
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      payload,
+      status: 'pending',
+      createdAt: new Date(),
+      queue: queueName,
+      priority,
+      availableAt,
+      attempt: 0,
+      maxRetries: options.maxRetries ?? 3,
+      backoffDelay: options.backoffDelay ?? 1000,
+      failureCount: 0,
+      dependencies,
+      progress: 0,
+    };
+
+    this.tasks.set(task.id, task as Task);
+    this.insertionOrder.set(task.id, this.insertionCounter++);
+    this.ensureQueue(queueName);
+    this.queues.get(queueName)!.push(task.id);
+
+    return task;
+  }
+
+  // Phase 1: Get next task
+  getNextTask(queueName: string = 'default'): Task | null {
+    const taskIds = this.queues.get(queueName);
+    if (!taskIds) return null;
+
+    // Phase 8: Check concurrency limit
+    const limit = this.concurrencyLimits.get(queueName);
+    if (limit !== undefined) {
+      const activeCount = this.getActiveCount(queueName);
+      if (activeCount >= limit) return null;
+    }
+
+    const now = Date.now();
+
+    // Collect all available candidates
+    const candidates: Array<{ id: string; task: Task; isDelayed: boolean; insertion: number }> = [];
+
+    for (const taskId of taskIds) {
+      const task = this.tasks.get(taskId);
+      if (!task || task.status !== 'pending') continue;
+
+      // Check if available (Phase 4: delayed tasks)
+      if (task.availableAt.getTime() > now) continue;
+
+      // Check dependencies (Phase 7)
+      if (!this.areDependenciesMet(task)) continue;
+
+      const isDelayed = task.availableAt.getTime() > task.createdAt.getTime();
+      candidates.push({
+        id: taskId,
+        task,
+        isDelayed,
+        insertion: this.insertionOrder.get(taskId) ?? 0,
+      });
+    }
+
+    if (candidates.length === 0) return null;
+
+    // Sort candidates:
+    // 1. Non-delayed tasks before delayed tasks
+    // 2. Among non-delayed: priority, then FIFO (insertion order)
+    // 3. Among delayed: availability time, then priority, then FIFO
+    candidates.sort((a, b) => {
+      // Non-delayed preferred over delayed
+      if (!a.isDelayed && b.isDelayed) return -1;
+      if (a.isDelayed && !b.isDelayed) return 1;
+
+      if (!a.isDelayed && !b.isDelayed) {
+        // Both non-delayed: priority then FIFO
+        if (a.task.priority !== b.task.priority) return a.task.priority - b.task.priority;
+        return a.insertion - b.insertion;
+      }
+
+      // Both delayed: availability time, then priority, then FIFO
+      const aTime = a.task.availableAt.getTime();
+      const bTime = b.task.availableAt.getTime();
+      if (aTime !== bTime) return aTime - bTime;
+      if (a.task.priority !== b.task.priority) return a.task.priority - b.task.priority;
+      return a.insertion - b.insertion;
+    });
+
+    const best = candidates[0];
+    best.task.status = 'processing';
+    best.task.attempt += 1;
+    return best.task;
+  }
+
+  // Phase 1: Count pending tasks
+  pendingCount(queueName: string = 'default'): number {
+    const taskIds = this.queues.get(queueName);
+    if (!taskIds) return 0;
+    return taskIds.filter(id => {
+      const task = this.tasks.get(id);
+      return task && task.status === 'pending';
+    }).length;
+  }
+
+  // Phase 2: List queue names
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // Phase 5: Complete a task
+  completeTask(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') throw new Error(`Cannot complete task in status: ${task.status}`);
+
+    task.status = 'completed';
+
+    // Remove from queue list
+    this.removeFromQueue(task.queue, taskId);
+  }
+
+  // Phase 5: Fail a task
+  failTask(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') throw new Error(`Cannot fail task in status: ${task.status}`);
+
+    task.error = error;
+    task.failureCount += 1;
+
+    if (task.attempt < task.maxRetries) {
+      // Re-add with backoff delay
+      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      // Task stays in queue list
+    } else {
+      // All retries exhausted
+      task.status = 'failed';
+      // Move to DLQ (Phase 6)
+      this.removeFromQueue(task.queue, taskId);
+      this.ensureDLQ(task.queue);
+      this.deadLetterQueues.get(task.queue)!.push(taskId);
+    }
+  }
+
+  // Phase 6: Get DLQ tasks
+  getDeadLetterTasks(queueName: string = 'default'): Task[] {
+    const dlqIds = this.deadLetterQueues.get(queueName);
+    if (!dlqIds) return [];
+    return dlqIds.map(id => this.tasks.get(id)!).filter(Boolean);
+  }
+
+  // Phase 6: Retry a DLQ task
+  retryDeadLetterTask(taskId: string): Task {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    // Remove from DLQ
+    const dlq = this.deadLetterQueues.get(task.queue);
+    if (!dlq || !dlq.includes(taskId)) {
+      throw new Error(`Task ${taskId} is not in the dead letter queue`);
+    }
+
+    const idx = dlq.indexOf(taskId);
+    dlq.splice(idx, 1);
+
+    // Reset task for fresh retries
+    task.status = 'pending';
+    task.attempt = 0;
+    task.failureCount = 0;
+    task.error = undefined;
+    task.availableAt = new Date();
+    task.progress = 0;
+    task.progressMessage = undefined;
+
+    // Re-add to queue
+    this.ensureQueue(task.queue);
+    this.queues.get(task.queue)!.push(taskId);
+    this.insertionOrder.set(taskId, this.insertionCounter++);
+
+    return task;
+  }
+
+  // Phase 6: Clear DLQ
+  clearDeadLetterQueue(queueName: string = 'default'): void {
+    const dlq = this.deadLetterQueues.get(queueName);
+    if (dlq) {
+      for (const taskId of dlq) {
+        this.tasks.delete(taskId);
+      }
+      dlq.length = 0;
+    }
+  }
+
+  // Phase 7: Get task by ID
+  getTask(taskId: string): Task | undefined {
+    return this.tasks.get(taskId);
+  }
+
+  // Phase 7: Check dependency status
+  getDependencyStatus(taskId: string): { resolved: string[]; unresolved: string[] } {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    const resolved: string[] = [];
+    const unresolved: string[] = [];
+
+    for (const depId of task.dependencies) {
+      const dep = this.tasks.get(depId);
+      if (dep && dep.status === 'completed') {
+        resolved.push(depId);
+      } else {
+        unresolved.push(depId);
+      }
+    }
+
+    return { resolved, unresolved };
+  }
+
+  // Phase 8: Set concurrency limit
+  setConcurrency(queueName: string, limit: number): void {
+    if (limit <= 0) {
+      this.concurrencyLimits.delete(queueName);
+    } else {
+      this.concurrencyLimits.set(queueName, limit);
+    }
+  }
+
+  // Phase 8: Get concurrency limit
+  getConcurrency(queueName: string): number | undefined {
+    return this.concurrencyLimits.get(queueName);
+  }
+
+  // Phase 8: Get active (processing) count
+  getActiveCount(queueName: string = 'default'): number {
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.queue === queueName && task.status === 'processing') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  // Phase 9: Report progress
+  reportProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') throw new Error(`Cannot report progress for task in status: ${task.status}`);
+
+    task.progress = Math.max(0, Math.min(100, progress));
+    task.progressMessage = message;
+
+    // Notify subscribers
+    const subs = this.progressSubscribers.get(taskId);
+    if (subs) {
+      for (const cb of subs) {
+        cb({ progress: task.progress, message: task.progressMessage });
+      }
+    }
+  }
+
+  // Phase 9: Get progress
+  getProgress(taskId: string): ProgressInfo | null {
+    const task = this.tasks.get(taskId);
+    if (!task) return null;
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  // Phase 9: Subscribe to progress
+  onProgress(taskId: string, callback: ProgressCallback): () => void {
+    if (!this.progressSubscribers.has(taskId)) {
+      this.progressSubscribers.set(taskId, new Set());
+    }
+    this.progressSubscribers.get(taskId)!.add(callback);
+
+    // Return unsubscribe function
+    return () => {
+      const subs = this.progressSubscribers.get(taskId);
+      if (subs) {
+        subs.delete(callback);
+        if (subs.size === 0) {
+          this.progressSubscribers.delete(taskId);
+        }
+      }
+    };
+  }
+
+  // Phase 9: Cancel task
+  cancelTask(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Cannot cancel task in status: ${task.status}`);
+    }
+
+    task.status = 'cancelled';
+
+    // Remove from queue
+    this.removeFromQueue(task.queue, taskId);
+  }
+
+  // Phase 10: Add schedule
+  addSchedule(cron: string, queueName: string, payload: unknown): Schedule {
+    this.validateCron(cron);
+
+    const schedule: Schedule = {
+      id: randomUUID(),
+      cron,
+      queue: queueName,
+      payload,
+    };
+
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  // Phase 10: Remove schedule
+  removeSchedule(scheduleId: string): void {
+    this.schedules.delete(scheduleId);
+  }
+
+  // Phase 10: List schedules
+  getSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  // Phase 10: Tick - check and enqueue due tasks
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (this.shouldRunSchedule(schedule, currentTime)) {
+        const task = this.addTask(schedule.payload, { queue: schedule.queue });
+        created.push(task);
+        schedule.lastRun = currentTime;
+      }
+    }
+
+    return created;
+  }
+
+  // Phase 11: Add middleware
+  addMiddleware(queueName: string, middleware: MiddlewareFn): void {
+    if (!this.middlewareStacks.has(queueName)) {
+      this.middlewareStacks.set(queueName, []);
+    }
+    this.middlewareStacks.get(queueName)!.push(middleware);
+  }
+
+  // Phase 11: Set handler
+  setHandler(queueName: string, handler: HandlerFn): void {
+    this.handlers.set(queueName, handler);
+  }
+
+  // Phase 11: Process task through middleware + handler
+  async processTask(taskId: string): Promise<void> {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') throw new Error(`Task is not in processing state: ${task.status}`);
+
+    const middlewares = this.middlewareStacks.get(task.queue) ?? [];
+    const handler = this.handlers.get(task.queue);
+
+    let index = 0;
+    let nextCalled = false;
+
+    const executeNext = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const mw = middlewares[index++];
+        nextCalled = false;
+        await mw(task, async () => {
+          nextCalled = true;
+          await executeNext();
+        });
+        // If middleware didn't call next, skip rest
+        if (!nextCalled && index <= middlewares.length) {
+          return;
+        }
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await executeNext();
+    } catch (err) {
+      const errMsg = err instanceof Error ? err.message : String(err);
+      this.failTask(taskId, errMsg);
+      throw err;
+    }
+  }
+
+  // Phase 12: Graceful shutdown
+  async shutdown(options: ShutdownOptions = {}): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShutdown = true;
+    this.shutdownPromise = this.performShutdown(options);
+    return this.shutdownPromise;
+  }
+
+  // Phase 12: Register shutdown callback
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  // ============================================================
+  // Private helpers
+  // ============================================================
+
+  private ensureQueue(name: string): void {
+    if (!this.queues.has(name)) {
+      this.queues.set(name, []);
+    }
+  }
+
+  private ensureDLQ(name: string): void {
+    if (!this.deadLetterQueues.has(name)) {
+      this.deadLetterQueues.set(name, []);
+    }
+  }
+
+  private removeFromQueue(queueName: string, taskId: string): void {
+    const taskIds = this.queues.get(queueName);
+    if (taskIds) {
+      const idx = taskIds.indexOf(taskId);
+      if (idx !== -1) {
+        taskIds.splice(idx, 1);
+      }
+    }
+  }
+
+  private areDependenciesMet(task: Task): boolean {
+    if (task.dependencies.length === 0) return true;
+    return task.dependencies.every(depId => {
+      const dep = this.tasks.get(depId);
+      return dep && dep.status === 'completed';
+    });
+  }
+
+  private detectCircularDeps(newTaskId: string, dependencies: string[]): void {
+    // BFS to detect if any dependency chain leads back to newTaskId
+    // Also check if any dependency transitively depends on another dependency being added
+    const visited = new Set<string>();
+    const queue = [...dependencies];
+
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      if (current === newTaskId) {
+        throw new Error('Circular dependency detected');
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      const task = this.tasks.get(current);
+      if (task) {
+        // Check tasks that depend on this task (reverse deps)
+        // Actually we need to check forward: what does `current` depend on
+        // We want to ensure no cycle: newTask depends on A, A depends on B, B depends on newTask (impossible since newTask doesn't exist yet)
+        // But we also need to check: if A depends on something that will depend on newTask
+        // Since newTask doesn't exist yet, the only cycle would be if one of the deps depends on another dep
+        // Actually, since we haven't added the task yet, we just need to check existing dependency chains
+        for (const depId of task.dependencies) {
+          if (!visited.has(depId)) {
+            queue.push(depId);
+          }
+        }
+      }
+    }
+
+    // Also check for cycles among existing tasks that may form when adding this new dependency link
+    // The new task depends on `dependencies`. If any of those tasks are blocked by something
+    // that would need this new task to complete, we have a cycle. But since the new task doesn't
+    // exist yet, no existing task can reference it. So cycles are only possible if
+    // dependencies form cycles among themselves (which would have been caught when they were added).
+  }
+
+  private validateCron(cron: string): void {
+    const parts = cron.trim().split(/\s+/);
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${cron}`);
+    }
+
+    // Validate basic patterns
+    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;
+
+    // Check minute field
+    if (!/^(\*|0|[1-9]\d?|\*\/\d+)$/.test(minute)) {
+      throw new Error(`Invalid cron expression: ${cron}`);
+    }
+
+    // Check hour field
+    if (!/^(\*|0|[1-9]\d?|\*\/\d+)$/.test(hour)) {
+      throw new Error(`Invalid cron expression: ${cron}`);
+    }
+
+    // Check remaining fields (just validate they're * for our simple subset)
+    if (dayOfMonth !== '*' && !/^\d+$/.test(dayOfMonth)) {
+      throw new Error(`Invalid cron expression: ${cron}`);
+    }
+    if (month !== '*' && !/^\d+$/.test(month)) {
+      throw new Error(`Invalid cron expression: ${cron}`);
+    }
+    if (dayOfWeek !== '*' && !/^\d+$/.test(dayOfWeek)) {
+      throw new Error(`Invalid cron expression: ${cron}`);
+    }
+  }
+
+  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {
+    const parts = schedule.cron.trim().split(/\s+/);
+    const [minuteField, hourField] = parts;
+
+    const currentMinute = now.getMinutes();
+    const currentHour = now.getHours();
+
+    // Check minute field
+    if (!this.matchesCronField(minuteField, currentMinute)) return false;
+
+    // Check hour field
+    if (!this.matchesCronField(hourField, currentHour)) return false;
+
+    // Check if we already ran for this matching time
+    if (schedule.lastRun) {
+      const lastMinute = schedule.lastRun.getMinutes();
+      const lastHour = schedule.lastRun.getHours();
+      const lastDate = schedule.lastRun.toDateString();
+      const nowDate = now.toDateString();
+
+      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {
+        return false;
+      }
+    }
+
+    return true;
+  }
+
+  private matchesCronField(field: string, value: number): boolean {
+    if (field === '*') return true;
+
+    if (field.startsWith('*/')) {
+      const interval = parseInt(field.slice(2), 10);
+      return value % interval === 0;
+    }
+
+    const num = parseInt(field, 10);
+    return value === num;
+  }
+
+  private async performShutdown(options: ShutdownOptions): Promise<ShutdownResult> {
+    const startTime = Date.now();
+    const timeout = options.timeout ?? 30000;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Get all processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        duration: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete or timeout
+    let completed = 0;
+    let forceCancelled = 0;
+
+    const waitForCompletion = new Promise<void>((resolve) => {
+      const checkInterval = setInterval(() => {
+        let allDone = true;
+        for (const task of processingTasks) {
+          if (task.status === 'processing') {
+            allDone = false;
+            break;
+          }
+        }
+        if (allDone) {
+          clearInterval(checkInterval);
+          resolve();
+        }
+      }, 10);
+
+      setTimeout(() => {
+        clearInterval(checkInterval);
+        resolve();
+      }, timeout);
+    });
+
+    await waitForCompletion;
+
+    // Count results and force-cancel remaining
+    for (const task of processingTasks) {
+      if (task.status === 'processing') {
+        task.status = 'cancelled';
+        this.removeFromQueue(task.queue, task.id);
+        forceCancelled++;
+      } else if (task.status === 'completed') {
+        completed++;
+      } else if (task.status === 'failed') {
+        completed++;
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+}
