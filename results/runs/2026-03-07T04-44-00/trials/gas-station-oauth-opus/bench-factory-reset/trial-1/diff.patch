+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  it('returns empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('returns null when no solution exists (example from spec)', () => {
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('solves a simple case with one button', () => {
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('finds minimum presses', () => {
+    // 3 lights, target [true, true, true]
+    // Button 0: toggles [0,1,2] (all three)
+    // Button 1: toggles [0]
+    // Button 2: toggles [1]
+    // Button 3: toggles [2]
+    // Solution: just button 0 (1 press) beats buttons 1+2+3 (3 presses)
+    const result = solveToggle({
+      target: [true, true, true],
+      buttons: [[0, 1, 2], [0], [1], [2]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('returns lex smallest when tied on count', () => {
+    // 2 lights, target [true, true]
+    // Button 0: toggles [0, 1]
+    // Button 1: toggles [0, 1]
+    // Both are 1-press solutions; button 0 is lex smaller.
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1], [0, 1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('handles case with no buttons', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('handles case with no buttons and target all off', () => {
+    const result = solveToggle({
+      target: [false, false],
+      buttons: [],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('solves a 2-button case', () => {
+    // 3 lights: target [true, false, true]
+    // Button 0: [0, 2]
+    // Button 1: [1]
+    // Press button 0 only: [on, off, on] = target.
+    const result = solveToggle({
+      target: [true, false, true],
+      buttons: [[0, 2], [1]],
+    });
+    expect(result).toEqual([0]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns all zeros when target is all zero', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('solves a simple mod-5 case', () => {
+    // 1 light, target [3], 1 button toggles light 0
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('returns null for impossible case', () => {
+    // 2 lights, 1 button toggles both. Target [1, 2] mod 3.
+    // Pressing x times: both counters = x. Can't get [1, 2].
+    const result = solveCounter([1, 2], [[0, 1]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('finds minimum total presses', () => {
+    // 1 light, target [1], mod 5
+    // Button 0: [0], Button 1: [0]
+    // Both single-press: result [1,0] or [0,1]. Min sum=1 for either.
+    // Lex smallest: [0,1] vs [1,0] → [0,1] is smaller.
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('handles modular arithmetic correctly', () => {
+    // 1 light, target [0], mod 3
+    // Button 0: [0]. Press 0 times → 0. That's the target.
+    const result = solveCounter([0], [[0]], 3);
+    expect(result).toEqual([0]);
+  });
+
+  it('handles mod 2 (binary) case', () => {
+    // Equivalent to a toggle puzzle in mod 2.
+    // 2 lights, target [1, 1], mod 2
+    // Button 0: [0, 1]
+    const result = solveCounter([1, 1], [[0, 1]], 2);
+    expect(result).toEqual([1]);
+  });
+
+  it('returns lex smallest on tie', () => {
+    // 1 light, target [4], mod 5
+    // Button 0: [0], Button 1: [0]
+    // Press 4 of button 0 = sum 4. Press 4 of button 1 = sum 4.
+    // Press 2+2 = sum 4. Press 1+3 = sum 4. Press 3+1 = sum 4. Press 0+4 = sum 4.
+    // Min sum is 4. Lex smallest with sum=4: [0, 4].
+    const result = solveCounter([4], [[0], [0]], 5);
+    expect(result).toEqual([0, 4]);
+  });
+
+  it('handles no buttons with nonzero target', () => {
+    const result = solveCounter([1], [], 3);
+    expect(result).toBeNull();
+  });
+
+  it('handles no buttons with zero target', () => {
+    const result = solveCounter([0, 0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  it('solves multi-button multi-light case', () => {
+    // 2 lights, 2 buttons, mod 3
+    // Button 0: [0], Button 1: [1]
+    // Target: [2, 1]
+    // Solution: press button 0 twice, button 1 once → [2, 1]
+    const result = solveCounter([2, 1], [[0], [1]], 3);
+    expect(result).toEqual([2, 1]);
+  });
+
+  it('handles overlapping buttons in counter mode', () => {
+    // 2 lights, 2 buttons, mod 5
+    // Button 0: [0, 1], Button 1: [1]
+    // Target: [2, 3]
+    // b0 affects light 0: b0 = 2
+    // b0 + b1 affects light 1: 2 + b1 = 3 mod 5 → b1 = 1
+    const result = solveCounter([2, 3], [[0, 1], [1]], 5);
+    expect(result).toEqual([2, 1]);
+  });
+});
