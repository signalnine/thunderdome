@@ -0,0 +1,142 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+import { EventRow, DashboardRow } from "../db.js";
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ["id", "tenant_id", "name", "properties", "timestamp", "user_id", "session_id"];
+  const lines = [headers.join(",")];
+  for (const event of events) {
+    const row = headers.map((h) => {
+      const val = event[h as keyof EventRow];
+      if (val === null || val === undefined) return "";
+      const str = String(val);
+      if (str.includes(",") || str.includes('"') || str.includes("\n")) {
+        return `"${str.replace(/"/g, '""')}"`;
+      }
+      return str;
+    });
+    lines.push(row.join(","));
+  }
+  return lines.join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const headers = ["id", "tenant_id", "name", "owner_id", "config", "created_at", "updated_at"];
+  const lines = [headers.join(",")];
+  for (const dashboard of dashboards) {
+    const row = headers.map((h) => {
+      const val = dashboard[h as keyof DashboardRow];
+      if (val === null || val === undefined) return "";
+      const str = String(val);
+      if (str.includes(",") || str.includes('"') || str.includes("\n")) {
+        return `"${str.replace(/"/g, '""')}"`;
+      }
+      return str;
+    });
+    lines.push(row.join(","));
+  }
+  return lines.join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get("/events/json", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const tenantId = req.user!.tid;
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    const parsed = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=events.json");
+    res.json({ events: parsed });
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const tenantId = req.user!.tid;
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (event_name) {
+      sql += " AND name = ?";
+      params.push(event_name);
+    }
+    if (start_date) {
+      sql += " AND timestamp >= ?";
+      params.push(start_date);
+    }
+    if (end_date) {
+      sql += " AND timestamp <= ?";
+      params.push(end_date);
+    }
+
+    sql += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCsv(events));
+  });
+
+  // Export dashboards as JSON
+  router.get("/dashboards/json", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const tenantId = req.user!.tid;
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenantId) as DashboardRow[];
+
+    const parsed = dashboards.map((d) => ({
+      ...d,
+      config: JSON.parse(d.config),
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.json");
+    res.json({ dashboards: parsed });
+  });
+
+  // Export dashboards as CSV
+  router.get("/dashboards/csv", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const tenantId = req.user!.tid;
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenantId) as DashboardRow[];
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+    res.send(dashboardsToCsv(dashboards));
+  });
+
+  return router;
+}
