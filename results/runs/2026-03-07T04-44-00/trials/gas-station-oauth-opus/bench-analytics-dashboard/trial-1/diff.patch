new file mode 100644
index 0000000..f8b2b01
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,111 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+interface QueryFilter {
+  event_name?: string;
+  start_date?: string;
+  end_date?: string;
+  properties?: Record<string, string>;
+}
+
+function buildWhereClause(
+  tenantId: string,
+  filter?: QueryFilter
+): { sql: string; params: unknown[] } {
+  const conditions: string[] = ["tenant_id = ?"];
+  const params: unknown[] = [tenantId];
+
+  if (filter?.event_name) {
+    conditions.push("name = ?");
+    params.push(filter.event_name);
+  }
+
+  if (filter?.start_date) {
+    conditions.push("timestamp >= ?");
+    params.push(filter.start_date);
+  }
+
+  if (filter?.end_date) {
+    conditions.push("timestamp <= ?");
+    params.push(filter.end_date);
+  }
+
+  if (filter?.properties) {
+    for (const [key, value] of Object.entries(filter.properties)) {
+      conditions.push("json_extract(properties, ?) = ?");
+      params.push(`$.${key}`, value);
+    }
+  }
+
+  return { sql: conditions.join(" AND "), params };
+}
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post("/count", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const filter = req.body as QueryFilter;
+    const tenantId = req.user!.tid;
+    const { sql, params } = buildWhereClause(tenantId, filter);
+
+    const result = db
+      .prepare(`SELECT COUNT(*) as count FROM events WHERE ${sql}`)
+      .get(...params) as { count: number };
+
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const { interval, ...filter } = req.body as QueryFilter & { interval?: string };
+    const tenantId = req.user!.tid;
+    const { sql, params } = buildWhereClause(tenantId, filter);
+
+    let dateFormat: string;
+    switch (interval) {
+      case "hour":
+        dateFormat = "%Y-%m-%dT%H:00:00";
+        break;
+      case "month":
+        dateFormat = "%Y-%m-01";
+        break;
+      case "day":
+      default:
+        dateFormat = "%Y-%m-%d";
+        break;
+    }
+
+    const rows = db
+      .prepare(
+        `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE ${sql} GROUP BY bucket ORDER BY bucket`
+      )
+      .all(...params) as Array<{ bucket: string; count: number }>;
+
+    res.json({ timeseries: rows });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const { property, ...filter } = req.body as QueryFilter & { property: string };
+    const tenantId = req.user!.tid;
+
+    if (!property) {
+      res.status(400).json({ error: "property field is required for breakdown queries", code: "BAD_REQUEST" });
+      return;
+    }
+
+    const { sql, params } = buildWhereClause(tenantId, filter);
+
+    const rows = db
+      .prepare(
+        `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE ${sql} GROUP BY value ORDER BY count DESC`
+      )
+      .all(`$.${property}`, ...params) as Array<{ value: string | null; count: number }>;
+
+    res.json({ breakdown: rows });
+  });
+
+  return router;
+}
