@@ -0,0 +1,84 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Ingest single event
+  router.post("/", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const { name, properties, timestamp, session_id } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required", code: "BAD_REQUEST" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tid;
+    const userId = req.user!.sub;
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = properties ? JSON.stringify(properties) : "{}";
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, userId, session_id || null);
+
+    res.status(201).json({
+      id,
+      tenant_id: tenantId,
+      name,
+      properties: properties || {},
+      timestamp: eventTimestamp,
+      user_id: userId,
+      session_id: session_id || null,
+    });
+  });
+
+  // Batch ingest events
+  router.post("/batch", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty", code: "BAD_REQUEST" });
+      return;
+    }
+
+    const tenantId = req.user!.tid;
+    const userId = req.user!.sub;
+
+    const insert = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const results: Array<{ id: string; name: string }> = [];
+
+    const insertAll = db.transaction(() => {
+      for (const event of events) {
+        if (!event.name) continue;
+        const id = uuidv4();
+        const eventTimestamp = event.timestamp || new Date().toISOString();
+        const eventProperties = event.properties
+          ? JSON.stringify(event.properties)
+          : "{}";
+        insert.run(
+          id,
+          tenantId,
+          event.name,
+          eventProperties,
+          eventTimestamp,
+          userId,
+          event.session_id || null
+        );
+        results.push({ id, name: event.name });
+      }
+    });
+
+    insertAll();
+
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  return router;
+}
