+++ b/src/routes/dashboards.ts
@@ -0,0 +1,138 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+import { DashboardRow } from "../db.js";
+
+export function createDashboardRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Create dashboard
+  router.post("/", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required", code: "BAD_REQUEST" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tid;
+    const ownerId = req.user!.sub;
+    const dashConfig = config ? JSON.stringify(config) : "{}";
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, ownerId, dashConfig, now, now);
+
+    res.status(201).json({
+      id,
+      tenant_id: tenantId,
+      name,
+      owner_id: ownerId,
+      config: config || {},
+      created_at: now,
+      updated_at: now,
+    });
+  });
+
+  // List dashboards for tenant
+  router.get("/", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const tenantId = req.user!.tid;
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenantId) as DashboardRow[];
+
+    res.json({
+      dashboards: dashboards.map((d) => ({
+        ...d,
+        config: JSON.parse(d.config),
+      })),
+    });
+  });
+
+  // Get single dashboard
+  router.get("/:id", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const tenantId = req.user!.tid;
+    const { id } = req.params;
+
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found", code: "NOT_FOUND" });
+      return;
+    }
+
+    const widgets = db
+      .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+      .all(id);
+
+    res.json({
+      ...dashboard,
+      config: JSON.parse(dashboard.config),
+      widgets: (widgets as Array<{ config: string; [key: string]: unknown }>).map((w) => ({
+        ...w,
+        config: JSON.parse(w.config),
+      })),
+    });
+  });
+
+  // Update dashboard
+  router.put("/:id", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const tenantId = req.user!.tid;
+    const { id } = req.params;
+    const { name, config } = req.body;
+
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(id, tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found", code: "NOT_FOUND" });
+      return;
+    }
+
+    const updatedName = name || existing.name;
+    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?"
+    ).run(updatedName, updatedConfig, now, id);
+
+    res.json({
+      id,
+      tenant_id: tenantId,
+      name: updatedName,
+      owner_id: existing.owner_id,
+      config: config !== undefined ? config : JSON.parse(existing.config),
+      created_at: existing.created_at,
+      updated_at: now,
+    });
+  });
+
+  // Delete dashboard
+  router.delete("/:id", authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+    const tenantId = req.user!.tid;
+    const { id } = req.params;
+
+    const existing = db
+      .prepare("SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(id, tenantId);
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found", code: "NOT_FOUND" });
+      return;
+    }
+
+    db.prepare("DELETE FROM dashboards WHERE id = ?").run(id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
