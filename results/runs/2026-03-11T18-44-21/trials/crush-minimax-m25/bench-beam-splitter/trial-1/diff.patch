+export type Direction = 'down' | 'down-left' | 'down-right';
+
+export interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  const visited = new Set<string>();
+
+  const beams: Beam[] = [];
+
+  for (let col = 0; col < cols; col++) {
+    if (grid[0][col] === 'S') {
+      beams.push({ row: 0, col, dir: 'down' });
+    }
+  }
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const key = `${beam.row},${beam.col}`;
+
+    if (
+      beam.row < 0 ||
+      beam.row >= rows ||
+      beam.col < 0 ||
+      beam.col >= cols
+    ) {
+      continue;
+    }
+
+    if (visited.has(key)) {
+      continue;
+    }
+    visited.add(key);
+
+    const cell = grid[beam.row][beam.col];
+
+    if (cell === '^') {
+      beams.push({ row: beam.row + 1, col: beam.col - 1, dir: 'down-left' });
+      beams.push({ row: beam.row + 1, col: beam.col + 1, dir: 'down-right' });
+    } else if (beam.dir === 'down') {
+      beams.push({ row: beam.row + 1, col: beam.col, dir: 'down' });
+    } else if (beam.dir === 'down-left') {
+      beams.push({ row: beam.row + 1, col: beam.col - 1, dir: 'down-left' });
+    } else if (beam.dir === 'down-right') {
+      beams.push({ row: beam.row + 1, col: beam.col + 1, dir: 'down-right' });
+    }
+  }
+
+  return visited.size;
+}
+
+function computePathsFromCell(
+  grid: string[][],
+  row: number,
+  col: number,
+  dir: Direction,
+  memo: Map<string, bigint>
+): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  if (row < 0 || row >= rows || col < 0 || col >= cols) {
+    return 1n;
+  }
+
+  const cell = grid[row][col];
+  const key = `${row},${col},${dir}`;
+
+  if (memo.has(key)) {
+    return memo.get(key)!;
+  }
+
+  let result: bigint;
+
+  if (cell === '^') {
+    result =
+      computePathsFromCell(grid, row + 1, col - 1, 'down-left', memo) +
+      computePathsFromCell(grid, row + 1, col + 1, 'down-right', memo);
+  } else if (dir === 'down') {
+    result = computePathsFromCell(grid, row + 1, col, 'down', memo);
+  } else if (dir === 'down-left') {
+    result = computePathsFromCell(grid, row + 1, col - 1, 'down-left', memo);
+  } else {
+    result = computePathsFromCell(grid, row + 1, col + 1, 'down-right', memo);
+  }
+
+  memo.set(key, result);
+  return result;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const cols = grid[0].length;
+  const memo = new Map<string, bigint>();
+
+  let totalPaths = 0n;
+
+  for (let col = 0; col < cols; col++) {
+    if (grid[0][col] === 'S') {
+      totalPaths += computePathsFromCell(grid, 0, col, 'down', memo);
+    }
+  }
+
+  return totalPaths;
+}
