+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+/**
+ * Detect cycles in the prerequisite graph using DFS.
+ * Throws if a cycle (including self-reference) is found.
+ */
+function detectCycles(events: Event[]): void {
+  const eventMap = new Map(events.map(e => [e.id, e]));
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const e of events) color.set(e.id, WHITE);
+
+  function dfs(id: string): void {
+    color.set(id, GRAY);
+    const event = eventMap.get(id);
+    for (const prereq of event?.prerequisites ?? []) {
+      if (!color.has(prereq)) continue; // unknown prereq — ignore for cycle check
+      if (color.get(prereq) === GRAY) {
+        throw new Error(`Prerequisite cycle detected involving event "${id}" and "${prereq}"`);
+      }
+      if (color.get(prereq) === WHITE) {
+        dfs(prereq);
+      }
+    }
+    color.set(id, BLACK);
+  }
+
+  for (const e of events) {
+    if (color.get(e.id) === WHITE) dfs(e.id);
+  }
+}
+
+/**
+ * Topological sort of events by prerequisites (Kahn's algorithm).
+ * Returns events in an order where prerequisites come before dependents.
+ */
+function topologicalSort(events: Event[]): Event[] {
+  const eventMap = new Map(events.map(e => [e.id, e]));
+  const inDegree = new Map<string, number>();
+  const dependents = new Map<string, string[]>(); // prereq -> list of events that need it
+
+  for (const e of events) {
+    if (!inDegree.has(e.id)) inDegree.set(e.id, 0);
+    for (const prereq of e.prerequisites ?? []) {
+      if (!eventMap.has(prereq)) continue; // skip unknown prerequisites
+      inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);
+      if (!dependents.has(prereq)) dependents.set(prereq, []);
+      dependents.get(prereq)!.push(e.id);
+    }
+  }
+
+  const queue: string[] = [];
+  for (const e of events) {
+    if ((inDegree.get(e.id) ?? 0) === 0) queue.push(e.id);
+  }
+
+  const result: Event[] = [];
+  while (queue.length > 0) {
+    const id = queue.shift()!;
+    result.push(eventMap.get(id)!);
+    for (const dep of dependents.get(id) ?? []) {
+      const newDegree = (inDegree.get(dep) ?? 0) - 1;
+      inDegree.set(dep, newDegree);
+      if (newDegree === 0) queue.push(dep);
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Find the earliest start time for an event in a given room,
+ * given the room's existing schedule and a minimum gap.
+ * Returns null if no slot is available within the window.
+ */
+function findEarliestSlot(
+  roomSchedule: { startTime: number; endTime: number }[],
+  duration: number,
+  windowStart: number,
+  windowEnd: number,
+  gap: number,
+  earliestStart: number,
+): number | null {
+  const start = Math.max(windowStart, earliestStart);
+  if (start + duration > windowEnd) return null;
+
+  // Sort room events by start time
+  const sorted = [...roomSchedule].sort((a, b) => a.startTime - b.startTime);
+
+  if (sorted.length === 0) {
+    return start + duration <= windowEnd ? start : null;
+  }
+
+  // Try fitting before the first event
+  const firstGapEnd = sorted[0].startTime;
+  if (start + duration <= firstGapEnd) {
+    return start;
+  }
+
+  // Try fitting in gaps between existing events
+  for (let i = 0; i < sorted.length; i++) {
+    const slotStart = Math.max(start, sorted[i].endTime + gap);
+    const nextStart = i + 1 < sorted.length ? sorted[i + 1].startTime : windowEnd;
+    if (slotStart + duration <= nextStart && slotStart + duration <= windowEnd) {
+      return slotStart;
+    }
+  }
+
+  return null;
+}
+
+/**
+ * Schedule events into rooms respecting all constraints.
+ * Maximizes the number of events scheduled.
+ */
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  if (events.length === 0) return { assignments: [], unscheduled: [] };
+
+  detectCycles(events);
+
+  const gap = options.gap ?? 15;
+  const { startTime, endTime } = options;
+
+  // Sort events topologically so prerequisites come first
+  const sortedEvents = topologicalSort(events);
+
+  // Track scheduled assignments
+  const assignments: Assignment[] = [];
+  const scheduledIds = new Set<string>();
+  const unscheduledIds = new Set<string>();
+
+  // Map from roomId to its scheduled intervals
+  const roomSchedules = new Map<string, { startTime: number; endTime: number }[]>();
+  for (const room of rooms) roomSchedules.set(room.id, []);
+
+  // Map from eventId to its assignment (for prerequisite lookup)
+  const assignmentMap = new Map<string, Assignment>();
+
+  // We'll use a greedy approach with preference-first placement.
+  // For optimization, we try to schedule all events and track which ones can't fit.
+  // The topological order ensures prerequisites are placed before dependents.
+
+  for (const event of sortedEvents) {
+    const attendees = event.attendees ?? 1;
+
+    // Determine earliest start based on prerequisites
+    let earliestStart = startTime;
+    let prereqFailed = false;
+
+    for (const prereqId of event.prerequisites ?? []) {
+      if (unscheduledIds.has(prereqId)) {
+        // Prerequisite couldn't be scheduled — this event can't be either
+        prereqFailed = true;
+        break;
+      }
+      const prereqAssignment = assignmentMap.get(prereqId);
+      if (!prereqAssignment) {
+        // Prerequisite not yet scheduled (shouldn't happen with topo sort, but handle it)
+        prereqFailed = true;
+        break;
+      }
+      earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);
+    }
+
+    if (prereqFailed) {
+      unscheduledIds.add(event.id);
+      continue;
+    }
+
+    // Filter rooms by capacity
+    const eligibleRooms = rooms.filter(r => r.capacity >= attendees);
+    if (eligibleRooms.length === 0) {
+      unscheduledIds.add(event.id);
+      continue;
+    }
+
+    // Sort eligible rooms: preferred room first, then by capacity (smallest sufficient)
+    const orderedRooms = [...eligibleRooms].sort((a, b) => {
+      if (event.preferredRoom) {
+        if (a.id === event.preferredRoom) return -1;
+        if (b.id === event.preferredRoom) return 1;
+      }
+      return a.capacity - b.capacity;
+    });
+
+    let placed = false;
+    for (const room of orderedRooms) {
+      const roomSchedule = roomSchedules.get(room.id)!;
+      const slot = findEarliestSlot(
+        roomSchedule,
+        event.duration,
+        startTime,
+        endTime,
+        gap,
+        earliestStart,
+      );
+
+      if (slot !== null) {
+        const assignment: Assignment = {
+          eventId: event.id,
+          roomId: room.id,
+          startTime: slot,
+          endTime: slot + event.duration,
+        };
+        assignments.push(assignment);
+        assignmentMap.set(event.id, assignment);
+        scheduledIds.add(event.id);
+        roomSchedule.push({ startTime: slot, endTime: slot + event.duration });
+        placed = true;
+        break;
+      }
+    }
+
+    if (!placed) {
+      unscheduledIds.add(event.id);
+    }
+  }
+
+  // Check if we can improve by trying to reschedule — run a second pass with optimization.
+  // If some events are unscheduled, try a different ordering to maximize scheduled count.
+  if (unscheduledIds.size > 0) {
+    const betterResult = tryOptimize(events, rooms, options, gap);
+    if (betterResult.assignments.length > assignments.length) {
+      return betterResult;
+    }
+  }
+
+  return {
+    assignments,
+    unscheduled: [...unscheduledIds],
+  };
+}
+
+/**
+ * Optimization pass: try alternative orderings to maximize scheduled events.
+ * Uses a backtracking/greedy approach considering event sizes.
+ */
+function tryOptimize(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number,
+): ScheduleResult {
+  const { startTime, endTime } = options;
+
+  // Try scheduling shorter events first (greedy optimization)
+  const sortedEvents = topologicalSort(events);
+
+  // Group events by topological level to allow reordering within levels
+  // We'll try: shorter-first within topological constraints
+  const assignments: Assignment[] = [];
+  const scheduledIds = new Set<string>();
+  const unscheduledIds = new Set<string>();
+  const roomSchedules = new Map<string, { startTime: number; endTime: number }[]>();
+  const assignmentMap = new Map<string, Assignment>();
+
+  for (const room of rooms) roomSchedules.set(room.id, []);
+
+  // Sort by duration (shorter first) while respecting topological order
+  // Build dependency levels
+  const eventMap = new Map(events.map(e => [e.id, e]));
+  const levels = computeLevels(events, eventMap);
+  const levelSorted = [...sortedEvents].sort((a, b) => {
+    const la = levels.get(a.id) ?? 0;
+    const lb = levels.get(b.id) ?? 0;
+    if (la !== lb) return la - lb;
+    return a.duration - b.duration; // shorter first within same level
+  });
+
+  for (const event of levelSorted) {
+    const attendees = event.attendees ?? 1;
+
+    let earliestStart = startTime;
+    let prereqFailed = false;
+
+    for (const prereqId of event.prerequisites ?? []) {
+      if (unscheduledIds.has(prereqId)) {
+        prereqFailed = true;
+        break;
+      }
+      const prereqAssignment = assignmentMap.get(prereqId);
+      if (!prereqAssignment) {
+        prereqFailed = true;
+        break;
+      }
+      earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);
+    }
+
+    if (prereqFailed) {
+      unscheduledIds.add(event.id);
+      continue;
+    }
+
+    const eligibleRooms = rooms.filter(r => r.capacity >= attendees);
+    if (eligibleRooms.length === 0) {
+      unscheduledIds.add(event.id);
+      continue;
+    }
+
+    const orderedRooms = [...eligibleRooms].sort((a, b) => {
+      if (event.preferredRoom) {
+        if (a.id === event.preferredRoom) return -1;
+        if (b.id === event.preferredRoom) return 1;
+      }
+      return a.capacity - b.capacity;
+    });
+
+    let placed = false;
+    for (const room of orderedRooms) {
+      const roomSchedule = roomSchedules.get(room.id)!;
+      const slot = findEarliestSlot(
+        roomSchedule,
+        event.duration,
+        startTime,
+        endTime,
+        gap,
+        earliestStart,
+      );
+
+      if (slot !== null) {
+        const assignment: Assignment = {
+          eventId: event.id,
+          roomId: room.id,
+          startTime: slot,
+          endTime: slot + event.duration,
+        };
+        assignments.push(assignment);
+        assignmentMap.set(event.id, assignment);
+        scheduledIds.add(event.id);
+        roomSchedule.push({ startTime: slot, endTime: slot + event.duration });
+        placed = true;
+        break;
+      }
+    }
+
+    if (!placed) {
+      unscheduledIds.add(event.id);
+    }
+  }
+
+  return {
+    assignments,
+    unscheduled: [...unscheduledIds],
+  };
+}
+
+/**
+ * Compute topological levels for events (depth from roots).
+ */
+function computeLevels(events: Event[], eventMap: Map<string, Event>): Map<string, number> {
+  const levels = new Map<string, number>();
+
+  function getLevel(id: string, visited: Set<string>): number {
+    if (levels.has(id)) return levels.get(id)!;
+    if (visited.has(id)) return 0; // cycle guard (already detected earlier)
+    visited.add(id);
+    const event = eventMap.get(id);
+    if (!event || !event.prerequisites?.length) {
+      levels.set(id, 0);
+      return 0;
+    }
+    const maxPrereqLevel = Math.max(
+      ...event.prerequisites
+        .filter(p => eventMap.has(p))
+        .map(p => getLevel(p, new Set(visited)))
+    );
+    const level = maxPrereqLevel + 1;
+    levels.set(id, level);
+    return level;
+  }
+
+  for (const e of events) getLevel(e.id, new Set());
+  return levels;
+}
