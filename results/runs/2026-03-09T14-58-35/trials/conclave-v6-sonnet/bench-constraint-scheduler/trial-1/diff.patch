s: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60 },\n      { id: 'e2', name: 'Event 2', duration: 60 },\n    ];\n    const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n\n    const result = schedule(events, rooms, DEFAULT_OPTIONS);\n\n    expect(result.assignments).toHaveLength(2);\n    expect(result.unscheduled).toHaveLength(0);\n\n    const assignments = result.assignments.sort((a, b) => a.startTime - b.startTime);\n    const [first, second] = assignments;\n    // Gap must be at least 15 minutes between end of first and start of second\n    expect(second.startTime - first.endTime).toBeGreaterThanOrEqual(15);\n  });\n\n  it('schedules multiple events across multiple rooms', () => {\n    const events: Event[] = [\n      { id: 'e1', name: 'Event 1', duration: 60 },\n      { id: 'e2', name: 'Event 2', duration: 60 },\n    ];\n    const rooms: Room[] = [\n      { id: 'r1', name: 'Room 1', capacity: 10 },\n      { id: 'r2', name: 'Room 2', capacity: 10 },\n    ];\n\n    const result = schedule(events, rooms, DEFAULT_OPTIONS);\n\n    expect(result.assignments).toHaveLength(2);\n    expect(result.unscheduled).toHaveLength(0);\n  });\n});\n\ndescribe('schedule - room capacity', () => {\n  it('does not assign event when attendees exceed room capacity', () => {\n    const events: Event[] = [{ id: 'e1', name: 'Event 1', duration: 60, attendees: 20 }];\n    const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n\n    const result = schedule(events, rooms, DEFAULT_OPTIONS);\n\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toEqual(['e1']);\n  });\n\n  it('assigns event when attendees equal room capacity', () => {\n    const events: Event[] = [{ id: 'e1', name: 'Event 1', duration: 60, attendees: 10 }];\n    const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n\n    const result = schedule(events, rooms, DEFAULT_OPTIONS);\n\n    expect(result.assignments).toHaveLength(1);\n    expect(r