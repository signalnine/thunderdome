  expect(() => tracker.start('')).toThrow();\n  });\n\n  test('start with whitespace-only name throws an error', () => {\n    expect(() => tracker.start('   ')).toThrow();\n  });\n\n  test('starting a new timer auto-stops the running one', () => {\n    tracker.start('task-a');\n    tracker.start('task-b');\n    const entries = tracker.getEntries();\n    expect(entries).toHaveLength(2);\n    expect(entries[0].stoppedAt).toBeDefined();\n    expect(entries[1].stoppedAt).toBeUndefined();\n  });\n\n  // --- stop ---\n\n  test('stop sets stoppedAt on the running entry', () => {\n    tracker.start('coding');\n    const before = Date.now();\n    tracker.stop();\n    const after = Date.now();\n    const entry = tracker.getEntries()[0];\n    expect(entry.stoppedAt).toBeGreaterThanOrEqual(before);\n    expect(entry.stoppedAt).toBeLessThanOrEqual(after);\n  });\n\n  test('stop when nothing is running throws an error', () => {\n    expect(() => tracker.stop()).toThrow();\n  });\n\n  test('stop after already stopped throws an error', () => {\n    tracker.start('task');\n    tracker.stop();\n    expect(() => tracker.stop()).toThrow();\n  });\n\n  // --- persistence ---\n\n  test('data is saved to file after start', () => {\n    tracker.start('coding');\n    expect(existsSync(dataFile)).toBe(true);\n  });\n\n  test('data is saved to file after stop', () => {\n    tracker.start('coding');\n    tracker.stop();\n    expect(existsSync(dataFile)).toBe(true);\n  });\n\n  test('a new tracker instance loads existing data from file', () => {\n    tracker.start('coding');\n    tracker.stop();\n    const tracker2 = new TimeTracker(dataFile);\n    expect(tracker2.getEntries()).toHaveLength(1);\n    expect(tracker2.getEntries()[0].name).toBe('coding');\n  });\n\n  test('creates parent directories automatically if they do not exist', () => {\n    const nestedFile = join(tmpDir, 'a', 'b', 'c', 'data.json');\n    const nestedTracker = new TimeTracker(nestedFile);\n    nestedTracker.start('task');\