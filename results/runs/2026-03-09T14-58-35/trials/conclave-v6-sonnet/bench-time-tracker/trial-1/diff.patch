index 0000000..4c41f93
--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,84 @@
+import { readFileSync, writeFileSync, mkdirSync, existsSync } from 'node:fs';
+import { dirname } from 'node:path';
+
+export interface TimeEntry {
+  name: string;
+  startedAt: number;
+  stoppedAt?: number;
+}
+
+export interface GetEntriesOptions {
+  from?: number;
+  to?: number;
+}
+
+interface PersistedData {
+  entries: TimeEntry[];
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[];
+
+  constructor(private readonly filePath: string) {
+    this.entries = this.load();
+  }
+
+  start(name: string): void {
+    if (!name || !name.trim()) {
+      throw new Error('Task name must not be empty');
+    }
+    const running = this.entries.find((e) => e.stoppedAt === undefined);
+    if (running) {
+      running.stoppedAt = Date.now();
+    }
+    this.entries.push({ name, startedAt: Date.now() });
+    this.save();
+  }
+
+  stop(): void {
+    const running = this.entries.find((e) => e.stoppedAt === undefined);
+    if (!running) {
+      throw new Error('No timer is currently running');
+    }
+    running.stoppedAt = Date.now();
+    this.save();
+  }
+
+  getEntries(options?: GetEntriesOptions): TimeEntry[] {
+    let result = this.entries;
+    if (options?.from !== undefined) {
+      result = result.filter((e) => e.startedAt >= (options.from as number));
+    }
+    if (options?.to !== undefined) {
+      result = result.filter((e) => e.startedAt <= (options.to as number));
+    }
+    return result;
+  }
+
+  summarize(): Record<string, number> {
+    const now = Date.now();
+    const totals: Record<string, number> = {};
+    for (const entry of this.entries) {
+      const end = entry.stoppedAt ?? now;
+      const duration = end - entry.startedAt;
+      totals[entry.name] = (totals[entry.name] ?? 0) + duration;
+    }
+    return totals;
+  }
+
+  private load(): TimeEntry[] {
+    if (!existsSync(this.filePath)) {
+      return [];
+    }
+    const raw = readFileSync(this.filePath, 'utf-8');
+    const data: PersistedData = JSON.parse(raw) as PersistedData;
+    return data.entries ?? [];
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    const data: PersistedData = { entries: this.entries };
+    writeFileSync(this.filePath, JSON.stringify(data, null, 2), 'utf-8');
+  }
+}
