son({ error: 'email and password required' });\n      return;\n    }\n    const user = db.prepare('SELECT * FROM users WHERE email = ?').get(email) as\n      | { id: string; tenant_id: string; role: string; password_hash: string }\n      | undefined;\n    if (!user || user.password_hash !== hashPassword(password)) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n    const token = signToken({ userId: user.id, tenantId: user.tenant_id, role: user.role });\n    res.json({ token, userId: user.id, tenantId: user.tenant_id, role: user.role });\n  });\n\n  // GET /me\n  router.get('/me', authMiddleware, (req: Request, res: Response): void => {\n    const auth = req.auth as JwtPayload;\n    const user = db\n      .prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?')\n      .get(auth.userId);\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    res.json(user);\n  });\n\n  // PATCH /users/:id/role  (admin only, same tenant)\n  router.patch('/users/:id/role', authMiddleware, (req: Request, res: Response): void => {\n    const auth = req.auth as JwtPayload;\n    if (auth.role !== 'admin') {\n      res.status(403).json({ error: 'Admin only' });\n      return;\n    }\n    const { role } = req.body as { role?: string };\n    const validRoles = ['admin', 'editor', 'viewer'];\n    if (!role || !validRoles.includes(role)) {\n      res.status(400).json({ error: 'role must be admin, editor, or viewer' });\n      return;\n    }\n    const result = db\n      .prepare('UPDATE users SET role = ? WHERE id = ? AND tenant_id = ?')\n      .run(role, req.params.id, auth.tenantId);\n    if (result.changes === 0) {\n      res.status(404).json({ error: 'User not found in your tenant' });\n      return;\n    }\n    res.json({ updated: true });\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
