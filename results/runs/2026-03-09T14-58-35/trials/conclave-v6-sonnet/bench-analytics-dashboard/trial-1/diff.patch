          let sql = `\n            SELECT strftime('${intervalFormat}', timestamp) as bucket, COUNT(*) as count\n            FROM events\n            WHERE tenant_id = ?\n          `;\n          const params: unknown[] = [auth.tenantId];\n          if (body.eventName) {\n            sql += ' AND name = ?';\n            params.push(body.eventName);\n          }\n          if (body.startDate) {\n            sql += ' AND timestamp >= ?';\n            params.push(body.startDate);\n          }\n          if (body.endDate) {\n            sql += ' AND timestamp <= ?';\n            params.push(body.endDate);\n          }\n          sql += ' GROUP BY bucket ORDER BY bucket';\n          const rows = db.prepare(sql).all(...(params as [unknown, ...unknown[]]));\n          res.json({ series: rows });\n          break;\n        }\n\n        case 'breakdown': {\n          if (!body.breakdownProperty) {\n            res.status(400).json({ error: 'breakdownProperty required for breakdown query' });\n            return;\n          }\n          const prop = body.breakdownProperty;\n          let sql = `\n            SELECT json_extract(properties, '$.\"${prop}\"') as value, COUNT(*) as count\n            FROM events\n            WHERE tenant_id = ?\n          `;\n          const params: unknown[] = [auth.tenantId];\n          if (body.eventName) {\n            sql += ' AND name = ?';\n            params.push(body.eventName);\n          }\n          sql += ' GROUP BY value ORDER BY count DESC';\n          const rows = db.prepare(sql).all(...(params as [unknown, ...unknown[]]));\n          res.json({ breakdown: rows });\n          break;\n        }\n\n        default:\n          res.status(400).json({ error: 'Unknown query type' });\n      }\n    } catch (err) {\n      res.status(500).json({ error: String(err) });\n    }\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
