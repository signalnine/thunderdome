+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { authMiddleware, JwtPayload } from '../auth.js';
+
+function rowsToCsv(rows: Record<string, unknown>[]): string {
+  if (rows.length === 0) return '';
+  const headers = Object.keys(rows[0]);
+  const lines = [
+    headers.join(','),
+    ...rows.map((r) =>
+      headers
+        .map((h) => {
+          const val = r[h];
+          const str = val === null || val === undefined ? '' : String(val);
+          // Escape quotes and wrap in quotes if contains comma, quote, or newline
+          if (str.includes(',') || str.includes('"') || str.includes('\n')) {
+            return `"${str.replace(/"/g, '""')}"`;
+          }
+          return str;
+        })
+        .join(',')
+    ),
+  ];
+  return lines.join('\n');
+}
+
+export function createExportRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  // GET /export/events?format=json|csv&eventName=...
+  router.get('/events', (req: Request, res: Response): void => {
+    const auth = req.auth as JwtPayload;
+    const format = (req.query.format as string) ?? 'json';
+    const eventName = req.query.eventName as string | undefined;
+
+    let sql = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [auth.tenantId];
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+    sql += ' ORDER BY timestamp DESC';
+
+    const rows = db.prepare(sql).all(...(params as [unknown, ...unknown[]])) as Record<
+      string,
+      unknown
+    >[];
+
+    if (format === 'csv') {
+      res.setHeader('Content-Type', 'text/csv');
+      res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+      res.send(rowsToCsv(rows));
+    } else {
+      res.json(rows);
+    }
+  });
+
+  // GET /export/dashboards/:id?format=json|csv
+  router.get('/dashboards/:id', (req: Request, res: Response): void => {
+    const auth = req.auth as JwtPayload;
+    const format = (req.query.format as string) ?? 'json';
+    const dashboard = db
+      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(req.params.id, auth.tenantId) as Record<string, unknown> | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    if (format === 'csv') {
+      res.setHeader('Content-Type', 'text/csv');
+      res.setHeader(
+        'Content-Disposition',
+        `attachment; filename="dashboard-${req.params.id}.csv"`
+      );
+      res.send(rowsToCsv([dashboard]));
+    } else {
+      res.json({ ...dashboard, config: JSON.parse(dashboard.config as string) });
+    }
+  });
+
+  return router;
+}
diff --git a/src/routes/query.ts b/src/routes/query.ts
new file mode 100644
index 0000000..152a7ae
--- /dev/null
+++ b/src/routes/query.ts
@@ -0,0 +1,108 @@
+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { authMiddleware, JwtPayload } from '../auth.js';
+
+interface QueryBody {
+  type: 'count' | 'timeseries' | 'breakdown';
+  eventName?: string;
+  // timeseries options
+  startDate?: string;
+  endDate?: string;
+  interval?: 'day' | 'hour' | 'week';
+  // breakdown options
+  breakdownProperty?: string;
+}
+
+export function createQueryRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  router.post('/', (req: Request, res: Response): void => {
+    const auth = req.auth as JwtPayload;
+    const body = req.body as QueryBody;
+
+    if (!body.type) {
+      res.status(400).json({ error: 'type is required (count|timeseries|breakdown)' });
+      return;
+    }
+
+    try {
+      switch (body.type) {
+        case 'count': {
+          let sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+          const params: unknown[] = [auth.tenantId];
+          if (body.eventName) {
+            sql += ' AND name = ?';
+            params.push(body.eventName);
+          }
+          const row = db.prepare(sql).get(...(params as [unknown, ...unknown[]])) as {
+            count: number;
+          };
+          res.json({ count: row.count });
+          break;
+        }
+
+        case 'timeseries': {
+          const intervalFormat =
+            body.interval === 'hour'
+              ? '%Y-%m-%dT%H:00'
+              : body.interval === 'week'
+              ? '%Y-W%W'
+              : '%Y-%m-%d';
+          let sql = `
+            SELECT strftime('${intervalFormat}', timestamp) as bucket, COUNT(*) as count
+            FROM events
+            WHERE tenant_id = ?
+          `;
+          const params: unknown[] = [auth.tenantId];
+          if (body.eventName) {
+            sql += ' AND name = ?';
+            params.push(body.eventName);
+          }
+          if (body.startDate) {
+            sql += ' AND timestamp >= ?';
+            params.push(body.startDate);
+          }
+          if (body.endDate) {
+            sql += ' AND timestamp <= ?';
+            params.push(body.endDate);
+          }
+          sql += ' GROUP BY bucket ORDER BY bucket';
+          const rows = db.prepare(sql).all(...(params as [unknown, ...unknown[]]));
+          res.json({ series: rows });
+          break;
+        }
+
+        case 'breakdown': {
+          if (!body.breakdownProperty) {
+            res.status(400).json({ error: 'breakdownProperty required for breakdown query' });
+            return;
+          }
+          const prop = body.breakdownProperty;
+          let sql = `
+            SELECT json_extract(properties, '$."${prop}"') as value, COUNT(*) as count
+            FROM events
+            WHERE tenant_id = ?
+          `;
+          const params: unknown[] = [auth.tenantId];
+          if (body.eventName) {
+            sql += ' AND name = ?';
+            params.push(body.eventName);
+          }
+          sql += ' GROUP BY value ORDER BY count DESC';
+          const rows = db.prepare(sql).all(...(params as [unknown, ...unknown[]]));
+          res.json({ breakdown: rows });
+          break;
+        }
+
+        default:
+          res.status(400).json({ error: 'Unknown query type' });
+      }
+    } catch (err) {
+      res.status(500).json({ error: String(err) });
+    }
+  });
+
+  return router;
+}
