 '2024-01-01T10:00:00Z' },\n          { name: 'page_view', properties: { url: '/about' }, timestamp: '2024-01-01T11:00:00Z' },\n          { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-02T10:00:00Z' },\n          { name: 'click', properties: { button: 'cta' }, timestamp: '2024-01-02T12:00:00Z' },\n        ],\n      });\n    return { app, token };\n  }\n\n  it('counts all events', async () => {\n    const { app, token } = await setupWithEvents();\n    const res = await request(app)\n      .post('/query')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ type: 'count' });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(4);\n  });\n\n  it('counts events by name', async () => {\n    const { app, token } = await setupWithEvents();\n    const res = await request(app)\n      .post('/query')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ type: 'count', eventName: 'page_view' });\n    expect(res.body.count).toBe(3);\n  });\n\n  it('returns timeseries bucketed by day', async () => {\n    const { app, token } = await setupWithEvents();\n    const res = await request(app)\n      .post('/query')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ type: 'timeseries', eventName: 'page_view', interval: 'day' });\n    expect(res.status).toBe(200);\n    expect(res.body.series.length).toBe(2);\n  });\n\n  it('returns breakdown by property', async () => {\n    const { app, token } = await setupWithEvents();\n    const res = await request(app)\n      .post('/query')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ type: 'breakdown', eventName: 'page_view', breakdownProperty: 'url' });\n    expect(res.status).toBe(200);\n    expect(res.body.breakdown[0].value).toBe('/home');\n    expect(res.body.breakdown[0].count).toBe(2);\n  });\n\n  it('enforces tenant isolation in queries', async () => {\n    const app = makeApp();\n    const { body: t1 } = await request(app)\n      .post('/auth/register')\n      .send({ email: 'ta@a.com', password: 'pw', tenantId: 'tenantA' });\n    const { body: t2 } = await request(app)\n      .post('/auth/register')\n      .send({ email: 'tb@b.com', password: 'pw', tenantId: 'tenantB' });\n    await request(app)\n      .post('/events')\n      .set('Authorization', `Bearer ${t1.token}`)\n      .send({ name: 'secret_event' });\n    const res = await request(app)\n      .post('/query')\n      .set('Authorization', `Bearer ${t2.token}`)\n      .send({ type: 'count' });\n    expect(res.body.count).toBe(0);\n  });\n\n  it('returns 401 for unauthenticated query', async () => {\n    const app = makeApp();\n    const res = await request(app).post('/query').send({ type: 'count' });\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe('Dashboard CRUD', () => {\n  async function setup() {\n    const app = makeApp();\n    const { body: { token } } = await request(app)\n      .post('/auth/register')\n      .send({ email: 'dash@test.com', password: 'pw', tenantId: 'dashTenant' });\n    return { app, token };\n  }\n\n  it('creates and retrieves a dashboard', async () => {\n    const { app, token } = await setup();\n    const create = await request(app)\n      .post('/dashboards')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'My Dashboard', config: { widgets: [] } });\n    expect(create.status).toBe(201);\n    const id = create.body.id;\n    const get = await request(app)\n      .get(`/dashboards/${id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(get.status).toBe(200);\n    expect(get.body.name).toBe('My Dashboard');\n  });\n\n  it('lists dashboards for tenant', async () => {\n    const { app, token } = await setup();\n    await request(app)\n      .post('/dashboards')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Dashboard 1' });\n    await request(app)\n      .post('/dashboards')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Dashboard 2' });\n    c