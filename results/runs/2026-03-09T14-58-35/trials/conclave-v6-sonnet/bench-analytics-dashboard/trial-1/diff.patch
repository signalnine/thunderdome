@@ -0,0 +1,95 @@
+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import { authMiddleware, JwtPayload } from '../auth.js';
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export function createDashboardsRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  // GET /dashboards
+  router.get('/', (req: Request, res: Response): void => {
+    const auth = req.auth as JwtPayload;
+    const rows = db
+      .prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC')
+      .all(auth.tenantId) as DashboardRow[];
+    res.json(
+      rows.map((r) => ({ ...r, config: JSON.parse(r.config) }))
+    );
+  });
+
+  // POST /dashboards
+  router.post('/', (req: Request, res: Response): void => {
+    const auth = req.auth as JwtPayload;
+    const { name, config = {} } = req.body as { name?: string; config?: object };
+    if (!name) {
+      res.status(400).json({ error: 'name is required' });
+      return;
+    }
+    const id = uuidv4();
+    const now = new Date().toISOString();
+    db.prepare(
+      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, auth.tenantId, name, auth.userId, JSON.stringify(config), now, now);
+    res.status(201).json({ id, name, tenantId: auth.tenantId });
+  });
+
+  // GET /dashboards/:id
+  router.get('/:id', (req: Request, res: Response): void => {
+    const auth = req.auth as JwtPayload;
+    const row = db
+      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(req.params.id, auth.tenantId) as DashboardRow | undefined;
+    if (!row) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+    res.json({ ...row, config: JSON.parse(row.config) });
+  });
+
+  // PATCH /dashboards/:id
+  router.patch('/:id', (req: Request, res: Response): void => {
+    const auth = req.auth as JwtPayload;
+    const { name, config } = req.body as { name?: string; config?: object };
+    const existing = db
+      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(req.params.id, auth.tenantId) as DashboardRow | undefined;
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+    const now = new Date().toISOString();
+    const newName = name ?? existing.name;
+    const newConfig = config !== undefined ? JSON.stringify(config) : existing.config;
+    db.prepare(
+      'UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ? AND tenant_id = ?'
+    ).run(newName, newConfig, now, req.params.id, auth.tenantId);
+    res.json({ updated: true });
+  });
+
+  // DELETE /dashboards/:id
+  router.delete('/:id', (req: Request, res: Response): void => {
+    const auth = req.auth as JwtPayload;
+    const result = db
+      .prepare('DELETE FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .run(req.params.id, auth.tenantId);
+    if (result.changes === 0) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+    res.json({ deleted: true });
+  });
+
+  return router;
+}
