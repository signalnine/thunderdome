+import { describe, test, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  test('returns empty array when target is all off', () => {
+    const machine = {
+      target: [false, false, false],
+      buttons: [[0], [1], [2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  test('single button that matches target', () => {
+    const machine = {
+      target: [true, true, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  test('requires two buttons', () => {
+    const machine = {
+      target: [true, false, true],
+      buttons: [[0, 1], [1, 2]],
+    };
+    // button 0 toggles [0,1], button 1 toggles [1,2]
+    // press both: 0=on, 1=off, 2=on => [T,F,T]
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  test('returns null when no solution exists', () => {
+    // target is [T,T,F,T] from the task description example
+    const machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  test('prefers fewer button presses when multiple solutions exist', () => {
+    // 3 lights, buttons: 0->[0,1,2], 1->[0], 2->[1,2]
+    // Pressing button 0 gives [T,T,T]
+    // Pressing buttons 1+2 also gives [T,T,T]
+    const machine = {
+      target: [true, true, true],
+      buttons: [[0, 1, 2], [0], [1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  test('prefers lexicographically smaller when tied on count', () => {
+    // Two 1-button solutions: [0] or [1]
+    const machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0, 1]],
+    };
+    // Both buttons toggle same lights, both are valid 1-button solutions
+    // [0] < [1] lexicographically
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  test('returns empty array solution over null when all-off is target', () => {
+    const machine = {
+      target: [false, false],
+      buttons: [[0, 1], [0, 1]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  test('handles single button single light', () => {
+    const machine = {
+      target: [true],
+      buttons: [[0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  test('handles no buttons with all-off target', () => {
+    const machine = {
+      target: [false, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  test('handles no buttons with non-trivial target', () => {
+    const machine = {
+      target: [true, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  test('handles multiple valid 2-button solutions, picks lex smallest', () => {
+    // 4 buttons, each toggling a different pair, target needs exactly 2 toggles
+    // buttons: 0->[0,1], 1->[0,1], 2->[2,3], 3->[2,3]
+    // target: [T,T,T,T]
+    // Press 0+2 or 0+3 or 1+2 or 1+3
+    // Lex smallest: [0,2]
+    const machine = {
+      target: [true, true, true, true],
+      buttons: [[0, 1], [0, 1], [2, 3], [2, 3]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 2]);
+  });
+});
+
+describe('solveCounter', () => {
+  test('returns all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0], [1], [2]], 5);
+    expect(result).toEqual([0, 0, 0]);
+  });
+
+  test('single button pressed once', () => {
+    const result = solveCounter([1, 1, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([1, 0]);
+  });
+
+  test('counter wraps around with modulus', () => {
+    // target counter 0 = 2, button 0 adds 1 to counter 0
+    // need to press button 0 twice
+    const result = solveCounter([2], [[0]], 5);
+    expect(result).toEqual([2]);
+  });
+
+  test('modular arithmetic: 4+3=2 mod 5', () => {
+    // target = [2], button 0 affects counter 0
+    // can press 2 times for value 2
+    const result = solveCounter([2], [[0]], 5);
+    expect(result).toEqual([2]);
+  });
+
+  test('returns null when no solution exists', () => {
+    // counter with modulus 5, button only affects counter 0
+    // target counter 1 = 1, but no button touches counter 1
+    const result = solveCounter([0, 1], [[0]], 5);
+    expect(result).toBeNull();
+  });
+
+  test('minimizes total presses', () => {
+    // target [1,1], mod 3
+    // button 0: affects [0,1], button 1: affects [0], button 2: affects [1]
+    // Solution A: press button 0 once => [1,1]. Total = 1
+    // Solution B: press button 1 and 2 once each => [1,1]. Total = 2
+    const result = solveCounter([1, 1], [[0, 1], [0], [1]], 3);
+    expect(result).toEqual([1, 0, 0]);
+  });
+
+  test('prefers lexicographically smaller when tied on total presses', () => {
+    // Two solutions with same total: [1,0] vs [0,1]
+    // button 0: affects [0,1], button 1: affects [0,1]  (same effect)
+    // target [1,1] mod 3: press button 0 once or button 1 once
+    // [1,0] < [0,1] lexicographically... wait, compare element by element
+    // [1,0] vs [0,1]: first element 1 > 0, so [0,1] < [1,0]
+    const result = solveCounter([1, 1], [[0, 1], [0, 1]], 3);
+    expect(result).toEqual([0, 1]);
+  });
+
+  test('handles prime modulus 7', () => {
+    // target [3, 5], buttons: 0->[0], 1->[1], mod 7
+    const result = solveCounter([3, 5], [[0], [1]], 7);
+    expect(result).toEqual([3, 5]);
+  });
+
+  test('returns all zeros with all-zero target and no buttons needed', () => {
+    const result = solveCounter([0, 0], [[0], [1]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  test('handles system requiring modular inverse', () => {
+    // target [1], button 0 affects [0] with effect of pressing 3 times for mod 5
+    // Actually button increments by 1 each press. Need 1 press for target 1.
+    // Let's test: target [3], button 0 affects [0], mod 5
+    // press 3 times
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  test('handles no buttons with all-zero target', () => {
+    const result = solveCounter([0, 0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  test('handles no buttons with non-zero target', () => {
+    const result = solveCounter([1, 0], [], 5);
+    expect(result).toBeNull();
+  });
+});
