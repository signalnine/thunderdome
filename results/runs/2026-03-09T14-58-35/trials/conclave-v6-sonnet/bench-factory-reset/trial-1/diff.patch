+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function enumerateToggleSolutions(
+  particular: number[],
+  nullBasis: number[][],
+  nullDim: number,
+  numButtons: number
+): number[] {
+  // Enumerate all 2^nullDim null-space combinations using Gray code order
+  // (each step flips exactly one basis vector) for incremental weight tracking.
+  const sol = [...particular];
+  let count = 0;
+  for (let i = 0; i < numButtons; i++) if (sol[i]) count++;
+
+  let bestCount = count;
+  let bestSol = [...sol];
+
+  const numCombinations = 1 << nullDim;
+
+  for (let mask = 1; mask < numCombinations; mask++) {
+    // Lowest set bit tells us which basis vector to toggle
+    const k = Math.clz32(mask & (-mask)) ^ 31; // fast log2 for powers of 2
+    const basis = nullBasis[k];
+    for (let i = 0; i < numButtons; i++) {
+      if (basis[i]) {
+        if (sol[i]) { count--; sol[i] = 0; }
+        else { count++; sol[i] = 1; }
+      }
+    }
+
+    if (count < bestCount) {
+      bestCount = count;
+      bestSol = [...sol];
+    } else if (count === bestCount && isToggleLexSmaller(sol, bestSol, numButtons)) {
+      bestSol = [...sol];
+    }
+  }
+
+  return solutionToIndices(bestSol);
+}
+
+// Compare two binary solution vectors by their index sets, lexicographically
+function isToggleLexSmaller(a: number[], b: number[], n: number): boolean {
+  let ai = 0;
+  let bi = 0;
+  while (ai < n && bi < n) {
+    while (ai < n && !a[ai]) ai++;
+    while (bi < n && !b[bi]) bi++;
+    if (ai >= n && bi >= n) return false;
+    if (ai >= n) return true; // a exhausted first (impossible if counts equal, but safe)
+    if (bi >= n) return false;
+    if (ai < bi) return true;
+    if (ai > bi) return false;
+    ai++; bi++;
+  }
+  return false;
+}
+
+function greedyToggleSolution(
+  particular: number[],
+  nullBasis: number[][],
+  nullDim: number,
+  numButtons: number
+): number[] {
+  // Greedy improvement: repeatedly find a null-space vector subset to XOR
+  // that reduces the solution weight, until no improvement possible.
+  // Try all single basis vectors and pairs for local improvement.
+  let sol = [...particular];
+  let improved = true;
+
+  while (improved) {
+    improved = false;
+    const currentIndices = solutionToIndices(sol);
+
+    // Try toggling each single basis vector
+    for (let k = 0; k < nullDim; k++) {
+      const candidate = sol.map((v, i) => v ^ nullBasis[k][i]);
+      const candidateIndices = solutionToIndices(candidate);
+      if (compareButtonSets(candidateIndices, currentIndices) < 0) {
+        sol = candidate;
+        improved = true;
+      }
+    }
+  }
+
+  void numButtons;
+  return solutionToIndices(sol);
+}
+
+// Compare two button-index sets: by count first, then lexicographic on the index arrays
+function compareButtonSets(a: number[], b: number[]): number {
+  if (a.length !== b.length) return a.length - b.length;
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return 0;
+}
+
+function solutionToIndices(sol: number[]): number[] {
+  const result: number[] = [];
+  for (let i = 0; i < sol.length; i++) {
+    if (sol[i]) result.push(i);
+  }
+  return result;
+}
+
+/**
+ * Solve a toggle puzzle using Gaussian elimination over GF(2).
+ *
+ * Each button press is a binary variable. The system is:
+ *   For each light j: XOR of x_i for all buttons i affecting light j = target[j]
+ *
+ * After finding the solution space, enumerate null-space combinations to find
+ * minimum-weight (fewest presses), then lexicographically smallest index set.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return target.every(t => !t) ? [] : null;
+  }
+
+  // Build augmented matrix [A | b] over GF(2)
+  // Row = light j, col = button i, augmented = target[j]
+  // Use bigint bitmask: bit i = button i, bit numButtons = target
+  const mat: bigint[] = new Array(numLights);
+  for (let j = 0; j < numLights; j++) {
+    let row = 0n;
+    for (let i = 0; i < numButtons; i++) {
+      if (buttons[i].includes(j)) {
+        row |= 1n << BigInt(i);
+      }
+    }
+    if (target[j]) {
+      row |= 1n << BigInt(numButtons);
+    }
+    mat[j] = row;
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotColForRow: number[] = new Array(numLights).fill(-1);
+  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);
+  let curRow = 0;
+
+  for (let col = 0; col < numButtons && curRow < numLights; col++) {
+    let found = -1;
+    for (let r = curRow; r < numLights; r++) {
+      if ((mat[r] >> BigInt(col)) & 1n) {
+        found = r;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [mat[curRow], mat[found]] = [mat[found], mat[curRow]];
+    pivotColForRow[curRow] = col;
+    pivotRowForCol[col] = curRow;
+
+    for (let r = 0; r < numLights; r++) {
+      if (r !== curRow && (mat[r] >> BigInt(col)) & 1n) {
+        mat[r] ^= mat[curRow];
+      }
+    }
+    curRow++;
+  }
+
+  const rank = curRow;
+
+  // Check consistency
+  for (let r = rank; r < numLights; r++) {
+    if ((mat[r] >> BigInt(numButtons)) & 1n) {
+      return null;
+    }
+  }
+
+  // Build particular solution (free vars = 0)
+  const particular = new Array(numButtons).fill(0);
+  for (let r = 0; r < rank; r++) {
+    const col = pivotColForRow[r];
+    if ((mat[r] >> BigInt(numButtons)) & 1n) {
+      particular[col] = 1;
+    }
+  }
+
+  // Find free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRowForCol[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  const nullDim = freeVars.length;
+
+  if (nullDim === 0) {
+    return solutionToIndices(particular);
+  }
+
+  // Compute null space basis vectors
+  const nullBasis: number[][] = [];
+  for (let k = 0; k < nullDim; k++) {
+    const freeCol = freeVars[k];
+    const basisVec = new Array(numButtons).fill(0);
+    basisVec[freeCol] = 1;
+    for (let r = 0; r < rank; r++) {
+      if ((mat[r] >> BigInt(freeCol)) & 1n) {
+        basisVec[pivotColForRow[r]] ^= 1;
+      }
+    }
+    nullBasis.push(basisVec);
+  }
+
+  if (nullDim <= 20) {
+    // Enumerate all 2^nullDim combinations directly
+    return enumerateToggleSolutions(particular, nullBasis, nullDim, numButtons);
+  }
+
+  // For large null spaces: greedy local search
+  // Start with particular solution, repeatedly apply null-space vectors that reduce weight
+  return greedyToggleSolution(particular, nullBasis, nullDim, numButtons);
+}
+
+/**
+ * Solve a counter puzzle using Gaussian elimination over GF(p) where p is prime.
+ *
+ * Each counter j: sum of x_i for all buttons i affecting j ≡ target[j] (mod p)
+ *
+ * Among all solutions, return minimum total presses, then lexicographically smallest.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+  const p = modulus;
+
+  if (numButtons === 0) {
+    return lights.every(t => t === 0) ? [] : null;
+  }
+
+  // Build augmented matrix [A | b] over GF(p)
+  const mat: number[][] = [];
+  for (let j = 0; j < numCounters; j++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let i = 0; i < numButtons; i++) {
+      if (buttons[i].includes(j)) {
+        row[i] = 1;
+      }
+    }
+    row[numButtons] = lights[j];
+    mat.push(row);
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotColForRow: number[] = new Array(numCounters).fill(-1);
+  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);
+  let curRow = 0;
+
+  for (let col = 0; col < numButtons && curRow < numCounters; col++) {
+    let found = -1;
+    for (let r = curRow; r < numCounters; r++) {
+      if (mat[r][col] !== 0) {
+        found = r;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [mat[curRow], mat[found]] = [mat[found], mat[curRow]];
+    pivotColForRow[curRow] = col;
+    pivotRowForCol[col] = curRow;
+
+    // Normalize pivot row
+    const pivotVal = mat[curRow][col];
+    const inv = modInverse(pivotVal, p);
+    for (let c = 0; c <= numButtons; c++) {
+      mat[curRow][c] = (mat[curRow][c] * inv) % p;
+    }
+
+    // Eliminate all other rows
+    for (let r = 0; r < numCounters; r++) {
+      if (r !== curRow && mat[r][col] !== 0) {
+        const factor = mat[r][col];
+        for (let c = 0; c <= numButtons; c++) {
+          mat[r][c] = ((mat[r][c] - factor * mat[curRow][c]) % p + p) % p;
+        }
+      }
+    }
+    curRow++;
+  }
+
+  const rank = curRow;
+
+  // Check consistency
+  for (let r = rank; r < numCounters; r++) {
+    if (mat[r][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Build particular solution (free vars = 0)
+  const particular = new Array(numButtons).fill(0);
+  for (let r = 0; r < rank; r++) {
+    const col = pivotColForRow[r];
+    particular[col] = mat[r][numButtons];
+  }
+
+  // Find free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRowForCol[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  const nullDim = freeVars.length;
+
+  if (nullDim === 0) {
+    return particular;
+  }
+
+  // Compute null space basis vectors over GF(p)
+  const nullBasis: number[][] = [];
+  for (let k = 0; k < nullDim; k++) {
+    const freeCol = freeVars[k];
+    const basisVec = new Array(numButtons).fill(0);
+    basisVec[freeCol] = 1;
+    for (let r = 0; r < rank; r++) {
+      const pivCol = pivotColForRow[r];
+      // pivot_var = rhs - sum(non_pivot_coeffs * non_pivot_vars)
+      // with all other free vars = 0 and freeCol = 1:
+      // pivot_var = -mat[r][freeCol] mod p
+      basisVec[pivCol] = ((-mat[r][freeCol]) % p + p) % p;
+    }
+    nullBasis.push(basisVec);
+  }
+
+  // General solution: x = particular + sum_k(c_k * nullBasis[k]) mod p
+  // Minimize sum(x_i), then lex smallest x array
+  // For small null dimensions, brute force; for larger, coordinate descent
+
+  if (nullDim <= 5) {
+    return bruteForceCounter(particular, nullBasis, nullDim, p, numButtons);
+  }
+
+  return coordinateDescentCounter(particular, nullBasis, nullDim, p, numButtons);
+}
+
+function compareCounterSolutions(a: number[], b: number[]): number {
+  const sumA = a.reduce((s, v) => s + v, 0);
+  const sumB = b.reduce((s, v) => s + v, 0);
+  if (sumA !== sumB) return sumA - sumB;
+  // Lex comparison
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return 0;
+}
+
+function bruteForceCounter(
+  particular: number[],
+  nullBasis: number[][],
+  nullDim: number,
+  p: number,
+  _numButtons: number
+): number[] {
+  let bestSol = [...particular];
+
+  function enumerateClean(k: number, sol: number[]): void {
+    if (k === nullDim) {
+      if (compareCounterSolutions(sol, bestSol) < 0) {
+        bestSol = [...sol];
+      }
+      return;
+    }
+    let cur = [...sol];
+    for (let c = 0; c < p; c++) {
+      enumerateClean(k + 1, cur);
+      // Advance to next c: add nullBasis[k]
+      cur = cur.map((v, i) => (v + nullBasis[k][i]) % p);
+    }
+  }
+
+  enumerateClean(0, [...particular]);
+  return bestSol;
+}
+
+function coordinateDescentCounter(
+  particular: number[],
+  nullBasis: number[][],
+  nullDim: number,
+  p: number,
+  _numButtons: number
+): number[] {
+  const coeffs = new Array(nullDim).fill(0);
+  let sol = [...particular];
+  let changed = true;
+
+  while (changed) {
+    changed = false;
+    for (let k = 0; k < nullDim; k++) {
+      let bestC = coeffs[k];
+      let bestSolForK = [...sol];
+
+      // Try all p values for coefficient k
+      // Start from c=0 by resetting to base (subtract current contribution)
+      const baseSol = sol.map((v, i) => ((v - coeffs[k] * nullBasis[k][i]) % p + p) % p);
+
+      let cur = [...baseSol];
+      for (let c = 0; c < p; c++) {
+        if (compareCounterSolutions(cur, bestSolForK) < 0) {
+          bestC = c;
+          bestSolForK = [...cur];
+        }
+        // Advance cur by adding nullBasis[k]
+        cur = cur.map((v, i) => (v + nullBasis[k][i]) % p);
+      }
+
+      if (bestC !== coeffs[k]) {
+        coeffs[k] = bestC;
+        sol = [...bestSolForK];
+        changed = true;
+      }
+    }
+  }
+
+  return sol;
+}
+
+function modInverse(a: number, p: number): number {
+  let [old_r, r] = [a, p];
+  let [old_s, s] = [1, 0];
+
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+
+  return ((old_s % p) + p) % p;
+}
