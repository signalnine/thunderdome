index 0000000..205bc89
--- /dev/null
+++ b/src/plugins/rss-feed.ts
@@ -0,0 +1,64 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function escapeXml(str: string): string {
+  return str
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;');
+}
+
+function getFileTags(file: ContentFile, _tagMap: Map<string, ContentFile[]> | undefined): string[] {
+  if (!file.tags) return [];
+  return file.tags;
+}
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild(ctx: BuildContext): void {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+
+        // Sort files by date, newest first; files without dates go last
+        const sorted = [...ctx.files].sort((a, b) => {
+          if (!a.date && !b.date) return 0;
+          if (!a.date) return 1;
+          if (!b.date) return -1;
+          return b.date.localeCompare(a.date);
+        });
+
+        const items = sorted.map(file => {
+          const title = escapeXml(file.title);
+          const link = `${ctx.config.baseUrl}/${file.slug}.html`;
+          const content = `<![CDATA[${file.content}]]>`;
+          const pubDate = file.date ? `<pubDate>${file.date}</pubDate>` : '';
+          const tags = getFileTags(file, tagMap);
+          const categories = tags.map(t => `<category>${escapeXml(t)}</category>`).join('\n    ');
+
+          return `  <item>
+    <title>${title}</title>
+    <link>${link}</link>
+    <description>${content}</description>
+    ${pubDate}
+    ${categories}
+  </item>`;
+        });
+
+        const feed = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${escapeXml(ctx.config.title)}</title>
+    <link>${ctx.config.baseUrl}</link>
+    <description>${escapeXml(ctx.config.title)}</description>
+${items.join('\n')}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', feed);
+      },
+    },
+  };
+}
