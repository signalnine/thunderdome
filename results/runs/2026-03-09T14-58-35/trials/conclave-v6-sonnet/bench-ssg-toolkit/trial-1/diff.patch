+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processFootnotes(content: string): { content: string; footnotes: Map<string, string> } {
+  const footnotes = new Map<string, string>();
+  // Extract footnote definitions
+  const cleaned = content.replace(/^\[\^(\w+)\]:\s*(.+)$/gm, (_, id, text) => {
+    footnotes.set(id, text.trim());
+    return '';
+  });
+  return { content: cleaned.trim(), footnotes };
+}
+
+function addFootnoteRefs(html: string, _footnotes: Map<string, string>): { html: string; order: string[] } {
+  // Replace [^id] references with superscript links
+  // We need to track order for numbered refs
+  const order: string[] = [];
+  const result = html.replace(/\[\^(\w+)\]/g, (_, id) => {
+    if (!order.includes(id)) order.push(id);
+    const num = order.indexOf(id) + 1;
+    return `<sup><a href="#fn-${num}">${num}</a></sup>`;
+  });
+  return { html: result, order };
+}
+
+function buildFootnotesSection(footnotes: Map<string, string>, order: string[]): string {
+  if (footnotes.size === 0) return '';
+  const items = order.map((id, idx) => {
+    const num = idx + 1;
+    const text = footnotes.get(id) || '';
+    return `<li id="fn-${num}">${text}</li>`;
+  }).join('\n');
+  return `\n<section class="footnotes"><ol>\n${items}\n</ol></section>`;
+}
+
+async function transformContent(file: ContentFile, _ctx: BuildContext): Promise<ContentFile> {
+  let content = file.content;
+
+  // Process admonition containers before markdown parsing
+  const admonitionPattern = /^(:::(\w+)\n[\s\S]*?\n:::)/gm;
+  const admonitionBlocks: string[] = [];
+  const placeholders: string[] = [];
+
+  let idx = 0;
+  content = content.replace(admonitionPattern, (match) => {
+    const placeholder = `ADMONITION_PLACEHOLDER_${idx}`;
+    admonitionBlocks.push(match);
+    placeholders.push(placeholder);
+    idx++;
+    return placeholder;
+  });
+
+  // Extract footnote definitions
+  const { content: withoutDefs, footnotes } = processFootnotes(content);
+
+  // Parse markdown to HTML
+  let html = await marked.parse(withoutDefs);
+
+  // Restore admonition blocks
+  for (let i = 0; i < placeholders.length; i++) {
+    const block = admonitionBlocks[i];
+    const match = block.match(/^:::(\w+)\n([\s\S]*)\n:::$/m);
+    if (match) {
+      const type = match[1];
+      const body = match[2].trim();
+      const admonitionHtml = `<div class="admonition admonition-${type}">${body}</div>`;
+      html = html.replace(new RegExp(`<p>${placeholders[i]}</p>`, 'g'), admonitionHtml);
+      html = html.replace(new RegExp(placeholders[i], 'g'), admonitionHtml);
+    }
+  }
+
+  // Process footnote references
+  const fnResult = addFootnoteRefs(html, footnotes);
+  html = fnResult.html;
+  const order = fnResult.order;
+
+  // Append footnotes section
+  if (footnotes.size > 0) {
+    html += buildFootnotesSection(footnotes, order);
+  }
+
+  return { ...file, content: html };
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent,
+    },
+  };
+}
