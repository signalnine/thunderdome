@@ -0,0 +1,24 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function highlightCodeBlocks(content: string): string {
+  // Match <pre><code class="language-X">...</code></pre>
+  return content.replace(
+    /<pre><code class="(language-([^"]+))">([\s\S]*?)<\/code><\/pre>/g,
+    (_, existingClass, lang, code) => {
+      return `<pre data-language="${lang}"><code class="${existingClass} highlighted">${code}</code></pre>`;
+    }
+  );
+}
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        return { ...file, content: highlightCodeBlocks(file.content) };
+      },
+    },
+  };
+}
