\n          const pubDate = file.date ? `<pubDate>${file.date}</pubDate>` : '';\n          const tags = getFileTags(file, tagMap);\n          const categories = tags.map(t => `<category>${escapeXml(t)}</category>`).join('\\n    ');\n\n          return `  <item>\n    <title>${title}</title>\n    <link>${link}</link>\n    <description>${content}</description>\n    ${pubDate}\n    ${categories}\n  </item>`;\n        });\n\n        const feed = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<rss version=\"2.0\">\n  <channel>\n    <title>${escapeXml(ctx.config.title)}</title>\n    <link>${ctx.config.baseUrl}</link>\n    <description>${escapeXml(ctx.config.title)}</description>\n${items.join('\\n')}\n  </channel>\n</rss>`;\n\n        ctx.output.set('feed.xml', feed);\n      },\n    },\n  };\n}\n","structuredPatch":[{"oldStart":8,"oldLines":7,"newStart":8,"newLines":7,"lines":["     .replace(/\"/g, '&quot;');"," }"," ","-function getFileTags(file: ContentFile, tagMap: Map<string, ContentFile[]> | undefined): string[] {","+function getFileTags(file: ContentFile, _tagMap: Map<string, ContentFile[]> | undefined): string[] {","   if (!file.tags) return [];","   return file.tags;"," }"]}],"userModified":false,"replaceAll":false}}
