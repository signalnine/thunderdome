+++ b/src/plugins/asset-pipeline.ts
@@ -0,0 +1,44 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function extractAndRewriteAssets(content: string, ctx: BuildContext): string {
+  const manifest = (ctx.data.get('asset-manifest') as { assets: string[] }) || { assets: [] };
+
+  // Rewrite relative src attributes (images, etc.) - not already /assets/
+  content = content.replace(
+    /\bsrc="\.\/([^"]+)"/g,
+    (_, filename) => {
+      if (!manifest.assets.includes(filename)) {
+        manifest.assets.push(filename);
+      }
+      return `src="/assets/${filename}"`;
+    }
+  );
+
+  // Rewrite relative href attributes (links to non-html files)
+  content = content.replace(
+    /\bhref="\.\/([^"]+)"/g,
+    (_, filename) => {
+      if (!manifest.assets.includes(filename)) {
+        manifest.assets.push(filename);
+      }
+      return `href="/assets/${filename}"`;
+    }
+  );
+
+  ctx.data.set('asset-manifest', manifest);
+  return content;
+}
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, ctx: BuildContext): ContentFile {
+        const content = extractAndRewriteAssets(file.content, ctx);
+        return { ...file, content };
+      },
+    },
+  };
+}
