 1 = 1', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 0, b: 1 });\n    expect(result['c']).toBe(1);\n  });\n\n  test('OR gate: 0 OR 0 = 0', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 0, b: 0 });\n    expect(result['c']).toBe(0);\n  });\n\n  test('XOR gate: 1 XOR 1 = 0', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 1 });\n    expect(result['c']).toBe(0);\n  });\n\n  test('XOR gate: 1 XOR 0 = 1', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result['c']).toBe(1);\n  });\n\n  test('returns all wire values including inputs', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result['a']).toBe(1);\n    expect(result['b']).toBe(0);\n    expect(result['c']).toBe(0);\n  });\n\n  test('handles chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },  // depends on c\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },  // comes second in array\n    ];\n    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    expect(result['c']).toBe(1);\n    expect(result['e']).toBe(1);\n  });\n\n  test('4-bit adder: 1 + 1 = 2 (binary 0010)', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR',  in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR',  in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR',  in1: 'a03', in2: 'b03', out: 'c03' },\n      { op: 'AND', in1: 'c03', in2: 'c03', out: 'z04' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 0, x02: 0, x03: 0,\n      y00: 1, y01: 0, y02: 0, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    expect(result['z00']).toBe(0);\n    expect(result['z01']).toBe(1);\n    expect(result['z02']).toBe(0);\n    expect(result['z03']).toBe(0);\n    expect(result['z04']).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function make4BitAdder(): Gate[] {\n    return [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR',  in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR',  in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR',  in1: 'a03', in2: 'b03', out: 'c03' },\n      { op: 'AND', in1: 'c03', in2: 'c03', out: 'z04' },\n    ];\n  }\n\n  function swapWires(gates: Gate[], w1: string, w2: string): Gate[] {\n    return gates.map(g => {\n      let out = g.out;\n      if (out === w1) out = w2;\n      else if (out === w2) out = w1;\n      return { ...g, out };\n    });\n  }\n\n  test('adder simulation is correct: 3+1=4', () => {\n    const adder = make4BitAdder();\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 0, x03: 0,\n      y00: 1, y01: 0, y02: 0, y03: 0,\n    };\n    const result = simulate(adder, inputs);\n    expect(result['z00']).toBe(0);\n    expect(result['z01']).toBe(0);\n    expect(result['z02']).toBe(1);\n    expect(result['z03']).toBe(0);\n  });\n\n  test('finds swap: z00 output is from AND gate (carry/sum swapped at bit 0)', () => {\n    // Swap z00 and c00: now AND(x00,y00)->z00 and XOR(x00,y00)->c00\n    let gates = make4BitAdder();\n    gates = swapWires(gates, 'z00', 'c00');\n    // Need 3 more swaps to make it 4-pair total — add 3 independent non-interchangeable swaps\n    gates = swapWires(gates, 'z01', 't01');  // swap final sum with partial sum (bit 1)\n    gates = swapWires(gates, 'z02', 'c02');  // swap sum with carry-out (bit 2)\n    gates = swapWires(gates, 'z03', 't03');  // swap final sum with partial sum (bit 3)\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    const expected = ['c00', 'c02', 't01', 't03', 'z00', 'z01', 'z02', 'z03'].sort();\n    expect(result).toEqual(expected);\n  });\n\n  test('returns sorted array of 8 wire names for 4 swaps', () => {\n    let gates = make4BitAdder();\n    gates = swapWires(gates, 'z00', 'c00');\n    gates = swapWires(gates, 'z01', 't01');\n    gates = swapWires(gates, 'z02', 'c02');\n    gates = swapWires(gates, 'z03', 't03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual([...result].sort());\n  });\n\n  test('detects z-wire swapped with partial sum wire (bit 1)', () => {\n    let gates = make4BitAdder();\n    // Swap t01 <-> z01, and 3 others far from each other\n    gates = swapWires(gates, 't01', 'z01');\n    gates = swapWires(gates, 'z00', 'c00');\n    gates = swapWires(gates, 'c02', 'b02');  // carry swapped with propagate\n    gates = swapWires(gates, 'z03', 'a03');  // sum swapped with generate\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toContain('t01');\n    expect(result).toContain('z01');\n    expect(result).toContain('z00');\n    expect(result).toContain('c00');\n  });\n});\n","structuredPatch":[{"oldStart":75,"oldLines":8,"newStart":75,"newLines":7,"lines":["       { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },","       { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },","       { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },","-      { op: 'OR',  in1: 'a03', in2: 'b03', out: 'c03' },","-      { op: 'AND', in1: 'c03', in2: 'c03', out: 'z04' },","+      { op: 'OR',  in1: 'a03', in2: 'b03', out: 'z04' },","     ];","     const inputs: Record<string, number> = {","       x00: 1, x01: 0, x02: 0, x03: 0,"]}],"userModified":false,"replaceAll":false}}
