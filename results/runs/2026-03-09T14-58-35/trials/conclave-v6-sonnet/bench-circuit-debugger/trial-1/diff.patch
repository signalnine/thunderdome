+    gates = swapWires(gates, 'z01', 't01');  // swap final sum with partial sum (bit 1)
+    gates = swapWires(gates, 'z02', 'c02');  // swap sum with carry-out (bit 2)
+    gates = swapWires(gates, 'z03', 't03');  // swap final sum with partial sum (bit 3)
+
