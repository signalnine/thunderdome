);\n    expect(result['c']).toBe(0);\n  });\n\n  test('OR gate: 0 OR 1 = 1', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 0, b: 1 });\n    expect(result['c']).toBe(1);\n  });\n\n  test('OR gate: 0 OR 0 = 0', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 0, b: 0 });\n    expect(result['c']).toBe(0);\n  });\n\n  test('XOR gate: 1 XOR 1 = 0', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 1 });\n    expect(result['c']).toBe(0);\n  });\n\n  test('XOR gate: 1 XOR 0 = 1', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result['c']).toBe(1);\n  });\n\n  test('returns all wire values including inputs', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result['a']).toBe(1);\n    expect(result['b']).toBe(0);\n    expect(result['c']).toBe(0);\n  });\n\n  test('handles chained gates in dependency order', () => {\n    // a AND b -> c, c OR d -> e\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },  // depends on c\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },  // comes second in array\n    ];\n    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    expect(result['c']).toBe(1);\n    expect(result['e']).toBe(1);\n  });\n\n  test('4-bit adder: 1 + 1 = 2 (binary 0010)', () => {\n    // Correct 4-bit adder circuit\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a