E carry signal path.\n\n  function findGate(op: Gate['op'], w1: string, w2: string): Gate | undefined {\n    return gates.find(g =>\n      g.op === op &&\n      ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))\n    );\n  }\n\n  let numBits = 0;\n  for (const gate of gates) {\n    for (const w of [gate.in1, gate.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);\n    }\n  }\n\n  function pad(n: number) { return String(n).padStart(2, '0'); }\n\n  const swapped = new Set<string>();\n  let carryWire: string;\n\n  // --- Bit 0: half adder ---\n  {\n    const xorG = findGate('XOR', 'x00', 'y00');\n    const andG = findGate('AND', 'x00', 'y00');\n    if (!xorG || !andG) throw new Error('Missing bit-0 gates');\n\n    // XOR -> z00, AND -> carry\n    if (xorG.out !== 'z00') {\n      swapped.add(xorG.out);\n      swapped.add('z00');\n    }\n    // carry = AND output, but if AND outputs z00, carry is actually xorG output\n    carryWire = andG.out === 'z00' ? xorG.out : andG.out;\n  }\n\n  // --- Bits 1..N-1: full adders ---\n  for (let bit = 1; bit < numBits; bit++) {\n    const xN = `x${pad(bit)}`;\n    const yN = `y${pad(bit)}`;\n    const zN = `z${pad(bit)}`;\n\n    // [A] Partial sum: XOR(xN, yN) -> partialWire\n    const gateA = findGate('XOR', xN, yN);\n    if (!gateA) continue;\n    let partialWire = gateA.out;\n\n    // [B] Final sum: XOR(partial, carry) -> zN\n    let gateB = findGate('XOR', partialWire, carryWire);\n    if (!gateB) {\n      // partialWire or carryWire might be swapped.\n      // carryWire is tracked, so look for any XOR using carryWire.\n      for (const g of gates) {\n        if (g.op === 'XOR' && (g.in1 === carryWire || g.in2 === carryWire)) {\n          const truePartial = g.in1 === carryWire ? g.in2 : g.in1;\n          if (truePartial !== partialWire) {\n            swapped.add(partialWire);\n            swapped.add(truePartial);\n            partialWire = truePartial;\n            gateB = g;\n            break;\n          }\n        }\n      }\n    }\n    if (!gateB) continue;\n\n    if (gateB.out !== zN) {\n      swapped.add(gateB.out);\n      swapped.add(zN);\n    }\n\n    // [C] Generate: AND(xN, yN) -> generateWire\n    const gateC = findGate('AND', xN, yN);\n    if (!gateC) continue;\n    const generateWire = gateC.out;\n\n    // [D] Propagate: AND(partial, carry) -> propagateWire\n    const gateD = findGate('AND', partialWire, carryWire);\n    if (!gateD) continue;\n    const propagateWire = gateD.out;\n\n    // [E] Carry: OR(generate, propagate) -> nextCarryWire\n    let gateE = findGate('OR', generateWire, propagateWire);\n    if (!gateE) {\n      // One of generate/propagate wires is misnamed (swapped).\n      // Find OR gate by one known input.\n      for (const g of gates) {\n        if (g.op === 'OR') {\n          if (g.in1 === generateWire || g.in2 === generateWire) {\n            const actual = g.in1 === generateWire ? g.in2 : g.in1;\n            if (actual !== propagateWire) {\n              swapped.add(propagateWire);\n              swapped.add(actual);\n            }\n            gateE = g;\n            break;\n          } else if (g.in1 === propagateWire || g.in2 === propagateWire) {\n            const actual = g.in1 === propagateWire ? g.in2 : g.in1;\n            if (actual !== generateWire) {\n              swapped.add(generateWire);\n              swapped.add(actual);\n            }\n            gateE = g;\n            break;\n          }\n        }\n      }\n    }\n    if (!gateE) continue;\n\n    // The OR gate output IS the next carry.\n    // If it has a z-wire name, that name is wrong (swapped with actual carry).\n    // But the SIGNAL is still the carry — use gateE.out as carryWire.\n    const isLastBit = bit === numBits - 1;\n    if (!isLastBit && /^z\\d+$/.test(gateE.out)) {\n      // OR output is named like zNN — it's swapped with actual carry wire.\n      // The actual carry wire (that should have been OR output) must be somewhere.\n      // It's the wire that got swapped in: since the OR output got renamed to zNN,\n      // the wire that was supposed to be zNN (final XOR output) got the carry name.\n      // We already recorded gateB.out != zN (or not), but this is about a different issue:\n      // the OR output itself has a wrong name.\n      //\n      // We need to find the wire that \"should have been\" the carry output.\n      // Since the circuit has exactly paired swaps, gateE.out (e.g. z02) was swapped\n      // with another wire. That other wire is now the carry name feeding bit+1.\n      // We find it by looking at what name bit+1's XOR(partial, carry) uses.\n      const nextPartialGate = findGate('XOR', `x${pad(bit + 1)}`, `y${pad(bit + 1)}`);\n      if (nextPartialGate) {\n        for (const g of gates) {\n          if (g.op === 'XOR' &&\n              (g.in1 === nextPartialGate.out || g.in2 === nextPartialGate.out)) {\n            const usedCarry = g.in1 === nextPartialGate.out ? g.in2 : g.in1;\n            if (usedCarry !== gateE.out) {\n              // The wire bit+1 uses as carry (usedCarry) was swapped with gateE.out\n              swapped.add(gateE.out);\n              swapped.add(usedCarry);\n              carryWire = gateE.out; // The true carry signal is still in gateE\n              break;\n            }\n          }\n        }\n        // If we didn't find the swap partner via XOR, just record gateE.out is wrong\n        if (!swapped.has(gateE.out)) {\n          swapped.add(gateE.out);\n        }\n      }\n      carryWire = gateE.out;\n    } else {\n      carryWire = gateE.out;\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":32,"oldLines":7,"newStart":32,"newLines":12,"lines":[" }"," "," export function findSwappedWires(gates: Gate[]): string[] {","-  // Find gate by op and two inputs (order-independent)","+  // Structural analysis of a ripple-carry adder.","+  // We walk bit-by-bit, tracking the actual