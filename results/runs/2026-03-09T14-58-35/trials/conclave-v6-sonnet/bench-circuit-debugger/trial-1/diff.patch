      const in1Gate = byOut.get(zNGate.in1);\n      const in2Gate = byOut.get(zNGate.in2);\n\n      let partialInput: string | undefined;\n      // Partial comes from XOR gate whose inputs are xN, yN... but it might be swapped\n      // Actually: identify which input is NOT from an OR gate (OR = carry)\n      if (in1Gate?.op === 'OR') {\n        partialInput = zNGate.in2;\n      } else if (in2Gate?.op === 'OR') {\n        partialInput = zNGate.in1;\n      } else if (in1Gate?.op === 'AND' && isXYWire(in1Gate.in1) && isXYWire(in1Gate.in2)) {\n        // bit-0 carry comes from AND(x00,y00)\n        partialInput = zNGate.in2;\n      } else if (in2Gate?.op === 'AND' && isXYWire(in2Gate.in1) && isXYWire(in2Gate.in2)) {\n        partialInput = zNGate.in1;\n      }\n\n      if (partialInput) {\n        // gateA.out and partialInput are swapped\n        addSwapPair(gateA.out, partialInput);\n      }\n    }\n  }\n\n  // Check per-gate rules: AND outputs z-wire, OR outputs z-wire (except final carry)\n  const finalCarryWire = `z${pad(numBits)}`;\n  for (const gate of gates) {\n    const out = gate.out;\n\n    // AND must not output z-wire\n    if (gate.op === 'AND' && isZWire(out)) {\n      // Find the correct gate for this z-wire\n      // The z-wire's correct producer is XOR; find XOR that should produce it\n      const zBit = parseInt(out.slice(1));\n      if (zBit === 0) {\n        // z00 from AND: correct gate is XOR(x00,y00)\n        const xorBit0 = findGate('XOR', 'x00', 'y00');\n        if (xorBit0 && !swapped.has(out)) {\n          addSwapPair(out, xorBit0.out);\n        }\n      } else if (zBit < numBits) {\n        // z-bit from AND: find the XOR for this bit that uses XOR(xN,yN).out\n        const xN = `x${pad(zBit)}`;\n        const yN = `y${pad(zBit)}`;\n        const gateA = findGate('XOR', xN, yN);\n        if (gateA && !swapped.has(out)) {\n          for (const g of gates) {\n            if (g.op === 'XOR' && (g.in1 === gateA.out || g.in2 === gateA.out)) {\n              addSwapPair(out, g.out);\n              break;\n            }\n          }\n        }\n      }\n    }\n\n    // OR must not output z-wire (except final carry)\n    if (gate.op === 'OR' && isZWire(out) && out !== finalCarryWire) {\n      // OR outputs wrong z-wire; the correct output for this OR should be a carry\n      // The correct carry for this bit: it's used by the next bit's XOR and AND.\n      // Find the next bit's XOR(xN+1,yN+1) and its partner XOR that reads carry.\n      // The carry = the input to that XOR that isn't the partial sum.\n      //\n      // How to find \"which bit\" this OR belongs to?\n      // OR(gen, prop) where gen = AND(xN,yN).out and prop = AND(partial,carry).out\n      // We can find which bit by looking at what feeds into the OR.\n      // OR.in1 or OR.in2 should come from AND(xN,yN) for some bit N.\n      let orBit = -1;\n      const orIn1Gate = byOut.get(gate.in1);\n      const orIn2Gate = byOut.get(gate.in2);\n      const andFromXY = orIn1Gate?.op === 'AND' && isXYWire(orIn1Gate.in1) && isXYWire(orIn1Gate.in2)\n        ? orIn1Gate\n        : orIn2Gate?.op === 'AND' && isXYWire(orIn2Gate.in1) && isXYWire(orIn2Gate.in2)\n          ? orIn2Gate\n          : undefined;\n\n      if (andFromXY) {\n        const xMatch = andFromXY.in1.match(/^x(\\d+)$/) ?? andFromXY.in2.match(/^x(\\d+)$/);\n        if (xMatch) orBit = parseInt(xMatch[1]);\n      }\n\n      if (orBit >= 0 && !swapped.has(out)) {\n        // Find the z-wire this OR should produce: it's the carry into bit orBit+1\n        // The carry into bit orBit+1 is the wire that bit orBit+1's final sum XOR reads.\n        // bit orBit+1 final sum XOR: XOR(partial(orBit+1), carry)\n        // partial(orBit+1) = XOR(x(orBit+1), y(orBit+1)).out\n        const nextBit = orBit + 1;\n        if (nextBit < numBits) {\n          const nextGateA = findGate('XOR', `x${pad(nextBit)}`, `y${pad(nextBit)}`);\n          if (nextGateA) {\n            // Find XOR that uses nextGateA.out as one input\n            for (const g of gates) {\n              if (g.op === 'XOR' && (g.in1 === nextGateA.out || g.in2 === nextGateA.out)) {\n                const carryExpected = g.in1 === nextGateA.out ? g.in2 : g.in1;\n                if (carryExpected !== out && !swapped.has(carryExpected)) {\n                  addSwapPair(out, carryExpected);\n                }\n                break;\n              }\n            }\n          }\n        }\n      }\n    }\n\n    // XOR(xN,yN) for N>0 must not output z-wire\n    if (gate.op === 'XOR' && isXYWire(gate.in1) && isXYWire(gate.in2)) {\n      const xMatch = gate.in1.match(/^x(\\d+)$/) ?? gate.in2.match(/^x(\\d+)$/);\n      if (xMatch) {\n        const bit = parseInt(xMatch[1]);\n        if (bit > 0 && isZWire(out)) {\n          // XOR(xN,yN) outputs z-wire incorrectly.\n          // The correct output for XOR(xN,yN) is the partial sum (non-z).\n          // The z-wire (out) should be produced by the final sum XOR.\n          // Find the final sum XOR at bit N: XOR(partial, carry).\n          // In the circuit, the final sum XOR still reads the ORIGINAL partial name.\n          // Since XOR(xN,yN) now outputs Z instead of P, the final sum XOR reads P.\n          // We need to find Z's swap partner: the gate that should produce Z.\n          // Z = `out`. It's produced by XOR(xN,yN). Z should be produced by final sum XOR.\n          // Find final sum XOR: it produces zN = `z(bit)`.\n          const zN = `z${pad(bit)}`;\n          const zNGate = byOut.get(zN);\n          if (zNGate && zNGate.op === 'XOR' && !swapped.has(out) && !swapped.has(zN)) {\n            // zN is produced by a XOR gate. That XOR gate's inputs include\n            // the original partial name (= what XOR(xN,yN) used to produce).\n            // The original partial name is one of zNGate's inputs.\n            // BUT: since XOR(xN,yN) now outputs out (= z-wire), the final sum XOR\n            // reads the ORIGINAL partial wire name. That name is swap