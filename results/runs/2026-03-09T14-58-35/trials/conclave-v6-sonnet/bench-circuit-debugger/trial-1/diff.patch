1 (the original A.out), then\n  //   B now outputs t01, and B reads t01 as one of its inputs.\n  //   This means B.in1 = B.out OR B.in2 = B.out.\n\n  const byOut = new Map<string, Gate>();\n  for (const g of gates) byOut.set(g.out, g);\n\n  function findGate(op: Gate['op'], w1: string, w2: string): Gate | undefined {\n    return gates.find(g =>\n      g.op === op &&\n      ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))\n    );\n  }\n\n  let numBits = 0;\n  for (const gate of gates) {\n    for (const w of [gate.in1, gate.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);\n    }\n  }\n\n  function pad(n: number) { return String(n).padStart(2, '0'); }\n  function isZWire(w: string) { return /^z\\d+$/.test(w); }\n  function isXYWire(w: string) { return /^[xy]\\d+$/.test(w); }\n\n  const swapped = new Set<string>();\n\n  // First pass: detect self-referential gates (a gate reads its own output as input).\n  // This happens when B's output was swapped with A.out (the original partial name).\n  // After the swap: B.out = original_A.out, and B still reads original_A.out.\n  for (const gate of gates) {\n    if (gate.in1 === gate.out || gate.in2 === gate.out) {\n      // This gate's output was swapped with one of its own inputs.\n      // Identify the swap pair:\n      // gate.out should be the output of a DIFFERENT gate (the \"in\" role).\n      // gate.out (current = original_partial_name) should be the partial sum wire.\n      // The z-wire that was swapped with gate.out: find the XOR(xN,yN) that should\n      // output this partial, and check what z-wire it outputs.\n      const selfInput = gate.in1 === gate.out ? gate.in1 : gate.in2;\n      // selfInput = gate.out. Find what z-wire XOR(xN,yN) is outputting that\n      // should have been this wire.\n      // For each bit, check if XOR(xN,yN).out is a z-wire AND the corresponding\n      // final sum XOR outputs the gate.out wire via self-refere