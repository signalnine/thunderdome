t as input\n  for (let bit = 1; bit < numBits; bit++) {\n    const xN = `x${pad(bit)}`;\n    const yN = `y${pad(bit)}`;\n    const zN = `z${pad(bit)}`;\n\n    const gateA = findGate('XOR', xN, yN);\n    if (!gateA) continue;\n    if (isZWire(gateA.out)) continue; // handled in self-reference pass or already flagged\n\n    // Find XOR using gateA.out as one input\n    for (const g of gates) {\n      if (g.op === 'XOR' && (g.in1 === gateA.out || g.in2 === gateA.out)) {\n        if (g.out !== zN) {\n          swapped.add(g.out);\n          swapped.add(zN);\n        }\n        break;\n      }\n    }\n\n    // Find OR using AND(xN,yN).out as one input\n    const gateC = findGate('AND', xN, yN);\n    if (!gateC) continue;\n    if (isZWire(gateC.out)) {\n      // AND outputs z-wire: find correct gate for that z-bit\n      const zBit = parseInt(gateC.out.slice(1));\n      if (zBit > 0 && zBit < numBits) {\n        const gateAZ = findGate('XOR', `x${pad(zBit)}`, `y${pad(zBit)}`);\n        if (gateAZ) {\n          for (const g of gates) {\n            if (g.op === 'XOR' && (g.in1 === gateAZ.out || g.in2 === gateAZ.out)) {\n              swapped.add(gateC.out);\n              swapped.add(g.out);\n              break;\n            }\n          }\n        }\n      }\n      continue;\n    }\n\n    for (const g of gates) {\n      if (g.op === 'OR' && (g.in1 === gateC.out || g.in2 === gateC.out)) {\n        const isLastBit = bit === numBits - 1;\n        const finalCarry = `z${pad(numBits)}`;\n        if (isZWire(g.out) && !(isLastBit && g.out === finalCarry)) {\n          // OR outputs wrong z-wire: find correct carry\n          const nextBit = bit + 1;\n          if (nextBit < numBits) {\n            const nextGateA = findGate('XOR', `x${pad(nextBit)}`, `y${pad(nextBit)}`);\n            if (nextGateA) {\n              for (const xorG of gates) {\n                if (xorG.op === 'XOR' && (xorG.in1 === nextGateA.out || xorG.in2 === nextGateA.out)) {\n                  const carryName = xorG.in1 === nextGateA.out ? xorG.in2 : xorG.in1;\n                  swapped.add(g.out);\n                  swapped.add(carryName);\n                  break;\n                }\n              }\n            }\n          }\n        }\n        break;\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":130,"oldLines":7,"newStart":130,"newLines":6,"lines":["       // Self-ref OR: carry output C was swapped with propagate P.","       // OR(gen, P) now outputs P (self-ref) instead of C.","       // Find the correct carry name C by looking at what the next bit's final-sum XOR reads.","-      const genInput = gate.in1 === gate.out ? gate.in1 : gate.in2; // this is gate.out = propagate","       const otherInput = gate.in1 === gate.out ? gate.in2 : gate.in1; // this is the generate input","       const genGate = byOut.get(otherInput);","       // genGate = AND(xM,yM)"]}],"userModified":false,"replaceAll":false}}
