 gateC.out)) {","+        gateE = g;","+        break;","+      }","+    }"," ","     if (!gateE) {","-      // One of generate/propagate is swapped","-      const altE1 = findGateByOneInput('OR', generateName);","-      if (altE1) {","-        const actual = altE1.in1 === generateName ? altE1.in2 : altE1.in1;","-        if (actual !== propagateName) {","-          swapped.add(propagateName);","-          swapped.add(actual);","+      // gateC.out is swapped — find OR by gateD.out","+      for (const g of gates) {","+        if (g.op === 'OR' && (g.in1 === gateD.out || g.in2 === gateD.out)) {","+          const actualGenerate = g.in1 === gateD.out ? g.in2 : g.in1;","+          swapped.add(gateC.out);","+          swapped.add(actualGenerate);","+          gateE = g;","+          break;","         }","-        gateE = altE1;","-      } else {","-        const altE2 = findGateByOneInput('OR', propagateName);","-        if (altE2) {","-          const actual = altE2.in1 === propagateName ? altE2.in2 : altE2.in1;","-          if (actual !== generateName) {","-            swapped.add(generateName);","-            swapped.add(actual);","-          }","-          gateE = altE2;","-        }","       }","+    } else {","+      // Check that gateD.out is the other input to OR","+      const orOtherInput = gateE.in1 === gateC.out ? gateE.in2 : gateE.in1;","+      if (orOtherInput !== gateD.out) {","+        swapped.add(gateD.out);","+        swapped.add(orOtherInput);","+      }","     }"," ","     if (!gateE) continue;"]},{"oldStart":249,"oldLines":8,"newStart":301,"newLines":5,"lines":["     prevCarryGate = gateE;","   }"," ","-  // Ensure carryActualBit0 is used (suppress unused warning)","-  void carryActualBit0;","-","   return [...swapped].sort();"," }"]}],"originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number>