th > 0) {\n    changed = false;\n    for (let i = pending.length - 1; i >= 0; i--) {\n      const gate = pending[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        let out: number;\n        if (gate.op === 'AND') out = a & b;\n        else if (gate.op === 'OR') out = a | b;\n        else out = a ^ b;\n        wires[gate.out] = out;\n        pending.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Strategy: validate adder structure bit-by-bit using rule-based checks.\n  //\n  // For each bit N, the circuit must satisfy:\n  //   1. XOR(xN,yN).out must NOT be zN (for N>0), and must BE z0 (for N=0)\n  //   2. There exists a XOR gate taking XOR(xN,yN).out as input → this is the final sum XOR\n  //   3. That final sum XOR must output zN\n  //   4. AND(xN,yN).out must not be a z-wire\n  //   5. There exists an OR gate taking AND(xN,yN).out as input → this is the carry OR\n  //   6. That carry OR must NOT output a z-wire (except z(numBits) at the last bit)\n  //\n  // When a rule fails, we find and record the swap pair.\n\n  const byOut = new Map<string, Gate>();\n  for (const g of gates) byOut.set(g.out, g);\n\n  function findGate(op: Gate['op'], w1: string, w2: string): Gate | undefined {\n    return gates.find(g =>\n      g.op === op &&\n      ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))\n    );\n  }\n\n  let numBits = 0;\n  for (const gate of gates) {\n    for (const w of [gate.in1, gate.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);\n    }\n  }\n\n  function pad(n: number) { return String(n).padStart(2, '0'); }\n  function isZWire(w: string) { return /^z\\d+$/.test(w); }\n  function isXYWire(w: string) { return /^[xy]\\d+$/.test(w); }\n\n  const swapped = new Set<string>();\n\n  // Bit 0: half adder\n  {\n    const xorG = findGate('XOR', 'x00', 'y00');\n    if (xorG && xorG.out !== 'z00') {\n      swapped.add(xorG.out);\n      swapped.add('z00');\n    }\n  }\n\n  // Bits 1..N-1 and also check final carry\n  for (let bit = 1; bit <= numBits; bit++) {\n    const xN = bit < numBits ? `x${pad(bit)}` : null;\n    const yN = bit < numBits ? `y${pad(bit)}` : null;\n    const zN = `z${pad(bit)}`;\n\n    if (bit < numBits) {\n      // Check each full-adder bit\n      const gateA = findGate('XOR', xN!, yN!); // partial sum gate\n      if (!gateA) continue;\n\n      // Rule: gateA.out must not be zN\n      if (isZWire(gateA.out)) {\n        // gateA outputs a z-wire — wrong.\n        // Find final sum XOR: XOR gate with gateA.out as one input\n        // Wait: if gateA.out = z-wire, then gateA IS XOR(xN,yN) producing z-wire.\n        // This means z-wire is swapped with the original partial sum wire.\n        // The partial sum wire is what gateA SHOULD output.\n        // The final sum XOR reads the original partial (gateA's correct output).\n        // To find the final sum XOR, look for the gate that produces zN:\n        const zNGate = byOut.get(zN);\n        if (zNGate && zNGate.op === 'XOR') {\n          // zN is correctly a XOR — find which input is gateA.out\n          // zNGate reads (partialOriginal, carry). partialOriginal is NOT gateA.out.\n          // gateA.out (z-wire) and partialOriginal are swapped.\n          // partialOriginal = whichever of zNGate.in1/in2 is NOT carry\n          const in1G = byOut.get(zNGate.in1);\n          const in2G = byOut.get(zNGate.in2);\n          let partnerWire: string | undefined;\n          // The carry input comes from OR or AND(x00,y00) (only for bit 1 with bit-0 carry)\n          if (in1G?.op === 'OR') partnerWire = zNGate.in2;\n          else if (in2G?.op === 'OR') partnerWire = zNGate.in1;\n          else if (in1G?.op === 'AND' && isXYWire(in1G.in1) && isXYWire(in1G.in2)) {\n            partnerWi