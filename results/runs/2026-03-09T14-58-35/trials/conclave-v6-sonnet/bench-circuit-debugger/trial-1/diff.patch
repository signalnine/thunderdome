n      const gate = pending[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        let out: number;\n        if (gate.op === 'AND') out = a & b;\n        else if (gate.op === 'OR') out = a | b;\n        else out = a ^ b;\n        wires[gate.out] = out;\n        pending.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Strategy: check each gate output for correctness using adder structural rules.\n  //\n  // Rules a correct ripple-carry adder output wire must satisfy:\n  //\n  // 1. zN must be produced by a XOR gate (for 0 <= N <= numBits-1)\n  // 2. z0 must be XOR(x00, y00)\n  // 3. zN (N>0) must be XOR where one input is output of XOR(xN, yN)\n  //    and the other input is a carry wire (from OR or AND-carry-bit0)\n  // 4. No intermediate non-z wire should be the output of a XOR(xN, yN) gate\n  //    that also feeds directly into a z-output XOR... wait, that's circular.\n  //\n  // Simpler structural checks we can apply to each individual wire:\n  //   - A z-wire must come from XOR gate\n  //   - XOR(xN, yN) must not output a z-wire (except z0 from XOR(x0,y0))\n  //   - OR gate must not output a z-wire (except the final carry z(N+1))\n  //   - etc.\n  //\n  // These per-wire checks identify WRONG outputs. We then pair them up as swaps.\n  //\n  // Specifically, the rules for a correct adder:\n  //   For bit 0:\n  //     - z00 is produced by XOR(x00, y00)\n  //   For bit N > 0:\n  //     - zN is produced by XOR gate\n  //     - That XOR's inputs are: XOR(xN,yN).out and some carry wire\n  //     - The carry wire is: output of OR gate (which combines generate and propagate)\n  //     - The OR gate's inputs are: AND(xN,yN).out and AND(XOR(xN,yN).out, carry).out\n  //\n  // Violations: any wire that fails these checks is wrong.\n  //\n  // Per-gate structural rules 