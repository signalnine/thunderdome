tructural constraint is violated, we identify the swapped wires\n  // and try to repair the carry chain.\n\n  // Build index: (op, set{in1,in2}) -> gate\n  function findGate(op: Gate['op'], w1: string, w2: string): Gate | undefined {\n    return gates.find(g =>\n      g.op === op &&\n      ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))\n    );\n  }\n\n  // Build index: output wire -> gate\n  const byOut = new Map<string, Gate>();\n  for (const gate of gates) {\n    byOut.set(gate.out, gate);\n  }\n\n  // Find number of input bits\n  let numBits = 0;\n  for (const gate of gates) {\n    for (const w of [gate.in1, gate.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);\n    }\n  }\n\n  const swapped = new Set<string>();\n\n  function pad(n: number) { return String(n).padStart(2, '0'); }\n\n  // Process bit 0 (half adder)\n  const xorBit0 = findGate('XOR', 'x00', 'y00');\n  const andBit0 = findGate('AND', 'x00', 'y00');\n\n  if (!xorBit0 || !andBit0) {\n    throw new Error('Invalid circuit: missing bit-0 gates');\n  }\n\n  // z00 should come from XOR(x00,y00). If not, mark swap.\n  if (xorBit0.out !== 'z00') {\n    swapped.add(xorBit0.out);\n    swapped.add('z00');\n  }\n\n  let carryWire = andBit0.out;\n\n  // If andBit0 outputs z00, the wires are swapped between XOR and AND\n  if (andBit0.out === 'z00') {\n    carryWire = xorBit0.out;\n  }\n\n  // Process bits 1..N-1 (full adders)\n  for (let bit = 1; bit < numBits; bit++) {\n    const xN = `x${pad(bit)}`;\n    const yN = `y${pad(bit)}`;\n    const zN = `z${pad(bit)}`;\n\n    // Step 1: Find XOR(xN, yN) -> partialSum\n    const xorPartial = findGate('XOR', xN, yN);\n    if (!xorPartial) continue;\n    let partialSum = xorPartial.out;\n\n    // Step 2: Find XOR(partialSum, carry) -> zN\n    // If can't find it, partialSum may be swapped\n    let xorFinal = findGate('XOR', partialSum, carryWire);\n    if (!xorFinal) {\n      // Try treating z