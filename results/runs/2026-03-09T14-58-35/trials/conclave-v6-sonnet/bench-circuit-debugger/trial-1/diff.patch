riginalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const pending = [...gates];\n\n  let changed = true;\n  while (changed && pending.length > 0) {\n    changed = false;\n    for (let i = pending.length - 1; i >= 0; i--) {\n      const gate = pending[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        let out: number;\n        if (gate.op === 'AND') out = a & b;\n        else if (gate.op === 'OR') out = a | b;\n        else out = a ^ b;\n        wires[gate.out] = out;\n        pending.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Find violations of adder structural rules to identify swapped wire pairs.\n  //\n  // Adder structural rules:\n  //   z00 must come from XOR(x00, y00)          [half adder sum]\n  //   zN (0 < N < numBits) must come from XOR   [full adder sum]\n  //   zN (N > 0): XOR's inputs must include XOR(xN,yN).out [partial sum]\n  //   z(numBits) must come from OR               [final carry]\n  //   AND gate output must NOT be a z-wire       [AND never produces z]\n  //   OR gate output must NOT be a z-wire except z(numBits) [OR is carry, not sum]\n  //   XOR(xN,yN) output must NOT be a z-wire (N>0) [partial sum is not final sum]\n  //\n  // For each violation, we find the swap partner:\n  //   If zN is produced by wrong gate G (AND/OR/wrong-XOR):\n  //     The CORRECT gate for zN (call it G') is producing some wire W\n  //     G should produce W (not zN), so W and zN are swapped\n  //\n  //   If XOR(xN,yN) outputs z-wire Z:\n  //     The CORRECT gate for zN is a XOR that uses XOR(xN,yN).out as one input\n  //     But XOR(xN,yN).out = Z, so the correct gate uses Z as input\n  //     Actually: in the original circuit, XOR(xN,yN) outputs some wire P (not Z)\n  //     and the final sum XOR reads P. After swap, XOR(xN,yN) outputs Z, but\n  //     the final sum XOR still reads P (the old name). Since Z is now\n  //     what XOR(xN,yN) outputs, Z was swapped with P.\n  //     Find P: look at zN = XOR(?, carry). One of its inputs is P.\n  //     P is the non-carry input of the gate producing zN.\n\n  const byOut = new Map<string, Gate>();\n  for (const g of gates) byOut.set(g.out, g);\n\n  function findGate(op: Gate['op'], w1: string, w2: string): Gate | undefined {\n    return gates.find(g =>\n      g.op === op &&\n      ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))\n    );\n  }\n\n  let numBits = 0;\n  for (const gate of gates) {\n    for (const w of [gate.in1, gate.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);\n    }\n  }\n\n  function pad(n: number) { return String(n).padStart(2, '0'); }\n  function isZWire(w: string) { return /^z\\d+$/.test(w); }\n  function isXYWire(w: string) { return /^[xy]\\d+$/.test(w); }\n\n  const swapped = new Set<string>();\n\n  function addSwapPair(w1: string, w2: string) {\n    swapped.add(w1);\n    swapped.add(w2);\n  }\n\n  // Check z00\n  {\n    const z00Gate = byOut.get('z00');\n    const correctGate = findGate('XOR', 'x00', 'y00');\n    if (z00Gate && correctGate && z00Gate !== correctGate) {\n      // z00 is produced by wrong gate; correct gate produces something else\n      addSwapPair('z00', correctGate.out);\n    }\n  }\n\n  // Check z(numBits) — final carry must come from OR\n  {\n    const zFinal = `z${pad(numBits)}`;\n    const zFinalGate = byOut.get(zFinal);\n    if (zFinalGate && zFinalGate.op !== 'OR') {\n      // z(numBits) must come from OR; find the OR gate that should produce it\n      // The final carry OR is the OR gate whose output doesn't feed any other gate\n      // (or we can identify it by its position in the adder)\n      // For now just flag it\n      swapped.add(zFinal);\n    }\n  }\n\n  // Check z1..z(numBits-1)\n  for (let bit = 1; bit < numBits; bit++) {\n    const zN = `z${pad(bit)}`;\n    const zNGate = byOut.get(zN);\n    if (!zNGate) continue;\n\n    const xN = `x${pad(bit)}`;\n    const yN = `y${pad(bit)}`;\n    const gateA = findGate('XOR', xN, yN); // partial sum gate\n\n    if (!gateA) continue;\n\n    // zN must come from XOR\n    if (zNGate.op !== 'XOR') {\n      // Find the correct XOR for zN: it should take gateA.out as one input\n      // In the original circuit, gateA.out = some partial wire P\n      // The final sum XOR is: XOR(P, carry) → zN\n      // After swap, gateA.out = maybe wrong name\n      // We look for XOR that uses gateA.out as one input\n      for (const g of gates) {\n        if (g.op === 'XOR' && (g.in1 === gateA.out || g.in2 === gateA.out)) {\n          // This XOR is the correct gate for zN, it's producing some wire W\n          addSwapPair(zN, g.out);\n          break;\n        }\n      }\n      continue; // skip the input-check since zN gate is wrong type\n    }\n\n    // zN comes from XOR — check its inputs\n    // One input should be gateA.out (partial sum)\n    if (zNGate.in1 !== gateA.out && zNGate.in2 !== gateA.out) {\n      // The XOR producing zN doesn't use gateA.out as input.\n      // This means gateA.out was swapped with the actual partial wire name.\n      // The actual partial wire is zNGate.in1 or zNGate.in2 (whichever is partial).\n      // We need to find which of the two inputs is the partial (vs carry).\n      // Partial comes from XOR(xN,yN); carry comes from OR/AND.\n      const in1Gate = byOut.get(zNGate.in1);\n      const in2Gate = byOut.get(zNGate.in2);\n\n      let partialInput: string | undefined;\n      // Partial comes from XOR gate whose inputs are xN, yN... but it might be swapped\n      // Actually: identify which input is NOT from an OR gate (OR = carry)\n      if (in1Gate?.op === 'OR') {\n        partialInput = zNGate.in2;\n      } else if (in2Gate?.op === 'OR') {\n        partialInput = zNGate.in1;\n      } else if (in1Gate?.op === 'AND' && isXYWire(in1Gate.in1) && isXYWire(in1Gate.in2)) {\n        // bit-0 carry comes from AND(x00,y00)\n        partialInput = zNGate.in2;\n      } else if (in2Gate?.op === 'AND' && isXYWire(in2Gate.in1) && isXYWire(in2Gate.in2)) {\n        partialInput = zNGate.in1;\n      }\n\n      if (partialInput) {\n        // gateA.out and partialInput are swapped\n        addSwapPair(gateA.out, partialInput);\n      }\n    }\n  }\n\n  // Check per-gate rules: AND outputs z-wire, OR outputs z-wire (except final carry)\n  const finalCarryWire = `z${pad(numBits)}`;\n  for (const gate of gates) {\n    const out = gate.out;\n\n    // AND must not output z-wire\n    if (gate.op === 'AND' && isZWire(out)) {\n      // Find the correct gate for this z-wire\n      // The z-wire's correct producer is XOR; find XOR that should produce it\n      const zBit = parseInt(out.slice(1));\n      if (zBit === 0) {\n        // z00 from AND: correct gate is XOR(x00,y00)\n        const xorBit0 = findGate('XOR', 'x00', 'y00');\n        if (xorBit0 && !swapped.has(out)) {\n          addSwapPair(out, xorBit0.out);\n        }\n      } else if (zBit < numBits) {\n        // z-bit from AND: find the XOR for this bit that uses XOR(xN,yN).out\n        const xN = `x${pad(zBit)}`;\n        const yN = `y${pad(zBit)}`;\n        const gateA = findGate('XOR', xN, yN);\n        if (gateA && !swapped.has(out)) {\n          for (const g of gates) {\n            if (g.op === 'XOR' && (g.in1 === gateA.out || g.in2 === gateA.out)) {\n              addSwapPair(out, g.out);\n              break;\n            }\n          }\n        }\n      }\n    }\n\n    // OR must not output z-wire (except final carry)\n    if (gate.op === 'OR' && isZWire(out) && out !== finalCarryWire) {\n      // OR outputs wrong z-wire; the co