 name of the OR (or AND for bit 0).\n  // This might be a \"wrong\" name (if swapped), but it's the name downstream gates need.\n  // When we find a swap (e.g., OR output is named like a z-wire), we record the swap\n  // and also identify the true carry name by looking at what next bit uses.\n\n  function findGate(op: Gate['op'], w1: string, w2: string): Gate | undefined {\n    return gates.find(g =>\n      g.op === op &&\n      ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))\n    );\n  }\n\n  // Find a gate by op and ONE input (returns first match)\n  function findGateByOneInput(op: Gate['op'], w: string): Gate | undefined {\n    return gates.find(g =>\n      g.op === op && (g.in1 === w || g.in2 === w)\n    );\n  }\n\n  let numBits = 0;\n  for (const gate of gates) {\n    for (const w of [gate.in1, gate.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);\n    }\n  }\n\n  function pad(n: number) { return String(n).padStart(2, '0'); }\n\n  const swapped = new Set<string>();\n\n  // carryName: the wire name carrying the carry signal\n  // This is the actual output wire name of the AND (bit 0) or OR (bits 1+) gate.\n  // It may have a \"wrong\" human-readable name if swapped, but it's what downstream\n  // gates reference.\n  let carryName: string;\n\n  // Bit 0: half adder\n  {\n    const xorG = findGate('XOR', 'x00', 'y00'); // finds XOR by inputs\n    const andG = findGate('AND', 'x00', 'y00');\n    if (!xorG || !andG) throw new Error('Missing bit-0 gates');\n\n    // XOR output should be z00\n    if (xorG.out !== 'z00') {\n      swapped.add(xorG.out);\n      swapped.add('z00');\n    }\n    // AND output is the carry (regardless of its name)\n    carryName = andG.out;\n  }\n\n  // Bits 1..N-1: full adders\n  for (let bit = 1; bit < numBits; bit++) {\n    const xN = `x${pad(bit)}`;\n    const yN = `y${pad(bit)}`;\n    const zN = `z${pad(bit)}`;\n\n    // Gate A: XOR(xN, yN) → partialN\n    c