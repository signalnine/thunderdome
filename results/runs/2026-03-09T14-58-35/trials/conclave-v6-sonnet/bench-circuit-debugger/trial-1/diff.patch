— add 3 independent non-interchangeable swaps\n    gates = swapWires(gates, 'z01', 't01');  // swap final sum with partial sum (bit 1)\n    gates = swapWires(gates, 'z02', 'c02');  // swap sum with carry-out (bit 2)\n    gates = swapWires(gates, 'z03', 't03');  // swap final sum with partial sum (bit 3)\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    const expected = ['c00', 'c02', 't01', 't03', 'z00', 'z01', 'z02', 'z03'].sort();\n    expect(result).toEqual(expected);\n  });\n\n  test('returns sorted array of 8 wire names for 4 swaps', () => {\n    let gates = make4BitAdder();\n    gates = swapWires(gates, 'z00', 'c00');\n    gates = swapWires(gates, 'z01', 't01');\n    gates = swapWires(gates, 'z02', 'c02');\n    gates = swapWires(gates, 'z03', 't03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual([...result].sort());\n  });\n\n  test('detects z-wire swapped with partial sum wire (bit 1)', () => {\n    let gates = make4BitAdder();\n    // Swap t01 <-> z01, and 3 others far from each other\n    gates = swapWires(gates, 't01', 'z01');\n    gates = swapWires(gates, 'z00', 'c00');\n    gates = swapWires(gates, 'c02', 'b02');  // carry swapped with propagate\n    gates = swapWires(gates, 'z03', 'a03');  // sum swapped with generate\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toContain('t01');\n    expect(result).toContain('z01');\n    expect(result).toContain('z00');\n    expect(result).toContain('c00');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":643,"cache_read_input_tokens":47665,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":643},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"350d141e-1ad6-4c7b-94f6-5ea915684ec7","uuid