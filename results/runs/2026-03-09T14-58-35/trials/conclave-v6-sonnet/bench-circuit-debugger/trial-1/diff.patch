and must NOT be a z-wire for N>0\n    48→  //   R2: B.out must equal zN\n    49→  //   R3: C.out must NOT be a z-wire\n    50→  //   R4: E.out must NOT be a z-wire except z(numBits) for N=numBits-1\n    51→  //\n    52→  // Critical insight: after output swaps, a gate may have its own output as one\n    53→  // of its inputs (creating a detectable \"self-referential\" anomaly).\n    54→  // Example: if B's output z01 is swapped with t01 (the original A.out), then\n    55→  //   B now outputs t01, and B reads t01 as one of its inputs.\n    56→  //   This means B.in1 = B.out OR B.in2 = B.out.\n    57→\n    58→  const byOut = new Map<string, Gate>();\n    59→  for (const g of gates) byOut.set(g.out, g);\n    60→\n    61→  function findGate(op: Gate['op'], w1: string, w2: string): Gate | undefined {\n    62→    return gates.find(g =>\n    63→      g.op === op &&\n    64→      ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))\n    65→    );\n    66→  }\n    67→\n    68→  let numBits = 0;\n    69→  for (const gate of gates) {\n    70→    for (const w of [gate.in1, gate.in2]) {\n    71→      const m = w.match(/^x(\\d+)$/);\n    72→      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);\n    73→    }\n    74→  }\n    75→\n    76→  function pad(n: number) { return String(n).padStart(2, '0'); }\n    77→  function isZWire(w: string) { return /^z\\d+$/.test(w); }\n    78→  function isXYWire(w: string) { return /^[xy]\\d+$/.test(w); }\n    79→\n    80→  const swapped = new Set<string>();\n    81→\n    82→  // First pass: detect self-referential gates (a gate reads its own output as input).\n    83→  // This happens when B's output was swapped with A.out (the original partial name).\n    84→  // After the swap: B.out = original_A.out, and B still reads original_A.out.\n    85→  for (const gate of gates) {\n    86→    if (gate.in1 === gate.out || gate.in2 === gate.out) {\n    87→      // This gate's output was swapped with one of its own inputs.\n    88→    