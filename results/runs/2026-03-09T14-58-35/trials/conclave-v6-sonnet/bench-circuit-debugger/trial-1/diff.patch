 Rules we can check:\n  //   R1: A.out must be z00 for N=0, and must NOT be a z-wire for N>0\n  //   R2: B.out must equal zN\n  //   R3: C.out must NOT be a z-wire\n  //   R4: E.out must NOT be a z-wire except z(numBits) for N=numBits-1\n  //\n  // Critical insight: after output swaps, a gate may have its own output as one\n  // of its inputs (creating a detectable \"self-referential\" anomaly).\n  // Example: if B's output z01 is swapped with t01 (the original A.out), then\n  //   B now outputs t01, and B reads t01 as one of its inputs.\n  //   This means B.in1 = B.out OR B.in2 = B.out.\n\n  const byOut = new Map<string, Gate>();\n  for (const g of gates) byOut.set(g.out, g);\n\n  function findGate(op: Gate['op'], w1: string, w2: string): Gate | undefined {\n    return gates.find(g =>\n      g.op === op &&\n      ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))\n    );\n  }\n\n  let numBits = 0;\n  for (const gate of gates) {\n    for (const w of [gate.in1, gate.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);\n    }\n  }\n\n  function pad(n: number) { return String(n).padStart(2, '0'); }\n  function isZWire(w: string) { return /^z\\d+$/.test(w); }\n  function isXYWire(w: string) { return /^[xy]\\d+$/.test(w); }\n\n  const swapped = new Set<string>();\n\n  // First pass: detect self-referential gates (a gate reads its own output as input).\n  // This happens when B's output was swapped with A.out (the original partial name).\n  // After the swap: B.out = original_A.out, and B still reads original_A.out.\n  for (const gate of gates) {\n    if (gate.in1 === gate.out || gate.in2 === gate.out) {\n      // This gate's output was swapped with one of its own inputs.\n      // Identify the swap pair:\n      // gate.out should be the output of a DIFFERENT gate (the \"in\" role).\n      // gate.out (current = original_partial_name) should be the partial sum wire.\n      // The z-wire that was swapped with gate.out: find the XOR(xN,yN) that should\n      // output this partial, and check what z-wire it outputs.\n      const selfInput = gate.in1 === gate.out ? gate.in1 : gate.in2;\n      // selfInput = gate.out. Find what z-wire XOR(xN,yN) is outputting that\n      // should have been this wire.\n      // For each bit, check if XOR(xN,yN).out is a z-wire AND the corresponding\n      // final sum XOR outputs the gate.out wire via self-reference.\n      //\n      // Actually simpler: gate.out is a partial wire that was swapped with some z-wire.\n      // The z-wire is what XOR(xN,yN) currently outputs.\n      // To find which XOR(xN,yN): iterate bits and see which gateA.out leads to this gate.\n      // But that's expensive. Instead: gate.out is the partner, and we need the z-wire.\n      //\n      // The z-wire that was swapped with gate.out: look for XOR(xN,yN) where\n      // the gate that reads XOR(xN,yN).out AS INPUT would be... our gate.\n      // Our gate reads gate.out (= some partial wire name) as one input.\n      // In the ORIGINAL circuit, the gate that read this wire was gate itself,\n      // and the XOR(xN,yN) output this partial wire.\n      // Now XOR(xN,yN) outputs a z-wire instead.\n      //\n      // Find which XOR(xN,yN) gate was \"supposed to\" produce gate.out:\n      // That gate A must satisfy: in the swapped circuit, A.out is a z-wire,\n      // AND there exists a gate B that reads A.out... but A.out changed.\n      //\n      // Let's approach from the other side: find a XOR(xN,yN) gate A such that\n      // A.out is a z-wire, and our current gate reads A.out... nope, our gate\n      // reads gate.out (an intermediate), not A.out (z-wire).\n      //\n      // The key link: gate.out = original A.out. A.out was swapped with z-wire Z.\n      // Now A.out = Z. AND gate reads gate.out = original A.out.\n      // So: gate.in1 or gate.in2 = gate.out = original A.out.\n      // We need to find A (which now outputs Z instead of gate.out).\n      // A is the XOR(xN,yN) gate for some bit N.\n      // A.out = Z (z-wire).\n      // The correct z-wire for that bit is zN. If A.out = zN, then z-wire is\n      // its own bit's z — special case. If A.out = different z-wire, it's a general case.\n      //\n      // For simplicity: iterate all XOR(xN,yN) gates for N>0, find any with a z-wire output.\n      // For each such gate A with A.out = Z (z-wire):\n      //   Check if there's a gate B reading A.out (= Z) as input... no, because A.out changed.\n      //   Actually: does gate B read the original A.out (= gate.out)?\n      //   gate.out = original A.out. So our gate B reads gate.out = original A.out.\n      //   B and A: A.out should be gate.out but is Z. B reads gate.out but gate.out ≠ A.out.\n      //\n      // This means Z and gate.out are swapped: Z → gate.out, gate.out → Z.\n      //\n      // So for our gate, we look for a XOR(xN,yN) gate whose output is a z-wire.\n      // That z-wire and gate.out are the swap pair.\n      //\n      // But there might be multiple XOR(xN,yN) gates with z-wire outputs.\n      // We need to find the specific one that corresponds to THIS gate.\n      // Hint: both gates belong to the SAME bit N.\n      // Bit N: gateA = XOR(xN,yN) → Z (wrong). gateB = our gate → gate.out (wrong).\n      // gateB reads gate.out (= original gateA.out) and carry as inputs.\n      // To verify: gateB should take gateA.out as one input (but gateA.out changed to Z).\n      // In the correct circuit, gateB.in1 or gateB.in2 = original gateA.out = gate.out.\n      // And that's exactly what we see: gate.in1 = gate.out (self-referential).\n      //\n      // So: gate belongs to bit N. gateA = XOR(xN,yN) where A's output is Z (z-wire).\n      // But we don't know N directly from gate.\n      //\n      // Approach: find all XOR(xN,yN) gates that output z-wires, and for each,\n      // check if there's a gate that reads that z-wire as input AND that gate's\n      // output has a self-referential property.\n      //\n      // Actually: gate.out = original A.out. And A now outputs Z.\n      // So: we look for Z such that byOut.get(Z).in1 or in2 = Z.\n      // Z = gateA.out. The gate that reads Z as its own output is gate B.\n      // In other words: gate B where B.in1 = Z or B.in2 = Z AND B.out = Z.\n      // But Z = gateA.out ≠ gate.out. So we can't directly link.\n      //\n      // SIMPLEST APPROACH: for each self-referential gate (B where B.out = one of its inputs),\n      // find any XOR(xN,yN) gate with a z-wire output. Pair them if they're at the same bit.\n      //\n      // Actually, let's just directly:\n      // gate.out and Z are swapped, where Z = gateA.out for some gateA.\n      // Z is the z-wire that took gate.out's place.\n      // gate.out = selfInput = gate.in1 or gate.in2.\n      //\n      // We need: for each self-referential gate B, find the corresponding gateA\n      // whose output Z = the z-wire that was swapped with gate.out.\n      //\n      // How? gate B is the final sum XOR for bit N. gateA is XOR(xN,yN).\n      // Both belong to bit N. gateA.out = Z (z-wire). B.out = gate.out (original partial for bit N).\n      //\n      // To find which bit: gateA has inputs xN, yN. Find gateA such that gateA.out is a z-wire\n      // AND gateA feeds into gate B (via the swap relationship).\n      //\n      // Actually: the original relationship is gateA → gateB. In the original circuit,\n      // gateA.out = gate.out (the partial), and gateB reads gateA.out = gate.out.\n      // After the swap: gateA.out = Z, gateB.out = gate.out.\n      // The original gateA.out (gate.out) is now gateB's output.\n      // gate.out feeds into gate: gate.in1 = gate.out (self-reference).\n      //\n      // The swap pair: gate.out ↔ Z.\n      // We need to find Z. Z = gateA.out where gateA = XOR(xN,yN) for some bit N.\n      // gateA and gateB are at the same bit N.\n      //\n      // One approach: Z should be used as an input by some gate in the circuit\n      // as gateA's \"output wire\" after swapping... but no gate reads Z except maybe\n      // the gate that should read the carry OR something.\n      //\n      // Let me just iterate: for each XOR gate with a z-wire output that reads (xN,yN),\n      // and look for a gate that reads gate.out (our self-referential output) and also\n      // reads the carry (= output of OR or AND gate at bit N-1).\n      // That matching pair is {gate.out, gateA.out}.\n      //\n      // Actually: I realize I'm overcomplicating this. Let me just check:\n      // our gate is B (final sum XOR). It reads gate.out (= original partial).\n      // The corresponding gateA = XOR(xN,yN) for the same bit N.\n      // gateA.out = Z (z-wire).\n      //\n      // To find N: gate B reads the carry from bit N-1 as its other input.\n      // Carry from bit N-1 comes from OR gate (or AND for N=1).\n      // So gate B.in2 (or in1, whichever is NOT gate.out) comes from OR or AND(x00,y00).\n      // From that, we can find N.\n      //\n      // Once we have the carry wire name, we find bit N by the carry's source OR gate's bit.\n      // That OR gate belongs to bit N-1. From the OR's inputs (AND(xN-1,yN-1).out and AND(partial,carry).out),\n      // we find N-1, then N.\n      //\n      // This is getting very complex. Let me just search directly:\n      // for our self-referential gate, find any XOR(xN,yN) gate (N>0) that outputs a z-wire.\n      // Pair self-referential.out with that z-wire.\n      // (In the 4-pair scenario, there's exactly one such pairing per self-referential gate.)\n      //\n      // BUT: what if there are multiple XOR(xN,yN) gates with z-wire outputs?\n      // In test 1, swaps are z01<->t01 and z03<->t03.\n      // Both XOR(x01,y01) and XOR(x03,y03) output z-wires.\n      // And gates XOR(t01,c00) and XOR(z03,c02) are self-referential.\n      //\n      // For XOR(t01,c00): out='t01', in1='t01' → self-referential. Partner = z01 (XOR(x01,y01).out).\n      // For XOR(z03,c02): out='t03', in2 is... let me check.\n      //   After z03<->t03 swap: XOR(x03,y03).out='z03', XOR(z03,c02).out='t03'.\n      //   So XOR(z03,c02) has in1='z03' and out='t03'. NOT self-referential since z03≠t03.\n      //\n      // Hmm, XOR(z03,c02) is NOT self-referential! It reads z03 (which is x03 XOR y03 output) and c02 as inputs. Its output is t03.\n      //\n      // Wait, let me re-examine swap 4 (z03 <-> t03):\n      // Original: XOR(x03,y03) → t03, XOR(t03,c02) → z03\n      // After swap z03<->t03: XOR(x03,y03) → z03, XOR(t03,c02) → t03\n      // XOR(t03,c02) reads t03 as input. t03 = this gate's OWN output. SELF-REFERENTIAL! ✓\n      //\n      // OK so XOR(t03,c02) IS self-referential: in1='t03', out='t03'.\n      // Great, so both XOR gates (for bits 1 and 3) that have swapped partials ARE self-referential.\n      //\n      // The challenge: with multiple self-referential gates and multiple XOR(xN,yN) z-wire outputs,\n      // which pairs up with which?\n      //\n      // The constraint: self-referential gate B reads [self.out, carry] as inputs.\n      // XOR(xN,yN) gate A outputs a z-wire Z.\n      // B and A are at the same bit N.\n      // The self-referential input of B (= B.out) is the original partial of bit N.\n      // Z should be AT bit N's z-wire (= zN = z01 or z03 etc).\n      //\n      // So the pairing: if B is self-referential with B.out = P, and A = XOR(xN,yN) with A.out = Z (z-wire),\n      // then {P, Z} are swapped IF A.out = zN where bit N corresponds to B's bit.\n      //\n      // But how do we know B's bit? B's carry input comes from OR/AND at bit N-1.\n      // We could trace back. But let me try a simpler heuristic:\n      // Since P ≠ Z, and the z-wires are z00..zN, if A.out = zN for bit N,\n      // then B reads the original P (= B.out) and the carry from bit N-1.\n      // B's carry input = B's non-self-referential input.\n      // That carry came from OR(generate_N-1, propagate_N-1) or AND(x00,y00) for N=1.\n      //\n      // The simplest pairing for our tests: for each self-referential XOR gate B,\n      // check each XOR(xN,yN) gate A with z-wire output, and pair the one where\n      // A's corresponding zN (= A.out = Z, which should be zN) matches the bit.\n      // Actually, in test 1: A.out = z01 (from XOR(x01,y01)), and B is XOR(t01,c00) → t01.\n      // The pairing is {t01, z01} because A.out = z01 and B.out = t01.\n      // AND: we know B is at bit 1 because B reads t01 (original partial from bit 1) and c00 (carry from bit 0).\n      // AND: A is XOR(x01,y01) which is also at bit 1.\n      // The z-wire that SHOULD be from B is z01 (= bit 1's z-wire).\n      // A.out = z01 = the z-wire for bit 1.\n      // So the pairing is: A.out = z01, B.out = t01, swap pair = {z01, t01}. ✓\n\n      // Implementation: for each XOR gate A = XOR(xN,yN) with A.out = z-wire Z,\n      // if Z = zN (the z-wire for bit N), pair with self-referential B.\n      // But how do we find B from A?\n      //\n      // Try: pair self-referential B's output (P) with the z-wire that was swapped with P.\n      // P is the original partial sum for bit N. The z-wire is A.out = Z.\n      //\n      // Simplest pairing: for each self-referential gate B,\n      // look for a XOR(xN,yN) gate A whose bit N z-wire = A.out.\n      // That is: A = XOR(xN,yN), A.out = zN, and B is the gate at bit N.\n      //\n      // To verify B is at bit N: B's carry input should come from carry-of-bit-(N-1).\n      // The carry of bit N-1 is the output of OR(gateC_(N-1), gateD_(N-1)) or AND(x00,y00) for N=1.\n      //\n      // This is getting complex. Let me just try the simplest approach and see if it works:\n      // For each self-referential gate B (B.out = B.in1 or B.in2),\n      // the partner z-wire Z is the z-wire from the corresponding XOR(xN,yN) gate.\n      // We find it by: B reads [B.out, carry]. carry = B's other input (not self-ref).\n      // carry comes from some OR gate (or AND for bit 1).\n      // That carry's source OR gate belongs to bit N-1.\n      // From bit N-1, we get N. Then Z = zN.\n      //\n      // Pair: {B.out, zN}.\n\n      const otherInput = gate.in1 === gate.out ? gate.in2 : gate.in1;\n      // otherInput is the carry coming from bit N-1\n      const carrySourceGate = byOut.get(otherInput);\n      let bitN = -1;\n\n      if (carrySourceGate) {\n        if (isXYWire(carrySourceGate.in1) && isXYWire(carrySourceGate.in2) &&\n            (carrySourceGate.op === 'AND' || carrySourceGate.op === 'XOR')) {\n          // carry from AND(x00,y00) or (swapped) XOR(x00,y00) → bit N = 1\n          bitN = 1;\n        } else if (carrySourceGate.op === 'OR') {\n          // carry from OR(gen, prop) → find which bit's OR this is\n          // OR.in1 or OR.in2 comes from AND(xM,yM) for some M\n          const orIn1G = byOut.get(carrySourceGate.in1);\n          const orIn2G = byOut.get(carrySourceGate.in2);\n          const andFromXY = (orIn1G?.op === 'AND' && isXYWire(orIn1G.in1) && isXYWire(orIn1G.in2)) ? orIn1G\n            : (orIn2G?.op === 'AND' && isXYWire(orIn2G.in1) && isXYWire(orIn2G.in2)) ? orIn2G\n            : undefined;\n          if (andFromXY) {\n            const xMatch = andFromXY.in1.match(/^x(\\d+)$/) ?? andFromXY.in2.match(/^x(\\d+)$/);\n            if (xMatch) bitN = parseInt(xMatch[1]) + 1;\n          }\n        } else if (carrySourceGate.op === 'XOR' && !isXYWire(carrySourceGate.in1) && !isXYWire(carrySourceGate.in2)) {\n          // carry source is a final-sum XOR at some bit M (its output was swapped with a z-wire).\n          // Find M by checking which input came from XOR(xM,yM).\n          const csIn1G = byOut.get(carrySourceGate.in1);\n          const csIn2G = byOut.get(carrySourceGate.in2);\n          const partialSrcG = (csIn1G?.op === 'XOR' && isXYWire(csIn1G.in1) && isXYWire(csIn1G.in2)) ? csIn1G\n            : (csIn2G?.op === 'XOR' && isXYWire(csIn2G.in1) && isXYWire(csIn2G.in2)) ? csIn2G\n            : undefined;\n          if (partialSrcG) {\n            const xM