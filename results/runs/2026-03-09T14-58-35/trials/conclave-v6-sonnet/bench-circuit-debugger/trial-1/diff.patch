1', out: 'b02' },\n      { op: 'OR',  in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR',  in1: 'a03', in2: 'b03', out: 'c03' },\n      { op: 'AND', in1: 'c03', in2: 'c03', out: 'z04' },\n    ];\n  }\n\n  function swapWires(gates: Gate[], w1: string, w2: string): Gate[] {\n    return gates.map(g => {\n      let out = g.out;\n      if (out === w1) out = w2;\n      else if (out === w2) out = w1;\n      return { ...g, out };\n    });\n  }\n\n  test('returns empty array for a correct adder (no swaps)', () => {\n    // This is not a 4-swap circuit so we don't call findSwappedWires here -\n    // the spec says exactly 4 pairs are swapped. Instead verify simulate works.\n    const adder = make4BitAdder();\n    // We'll test the real behavior with exactly 4 swaps\n    // For now verify the adder itself is correct by simulating\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 0, x03: 0,\n      y00: 1, y01: 0, y02: 0, y03: 0,\n    };\n    const result = simulate(adder, inputs);\n    // 3 + 1 = 4 (binary 0100), z02=1\n    expect(result['z00']).toBe(0);\n    expect(result['z01']).toBe(0);\n    expect(result['z02']).toBe(1);\n    expect(result['z03']).toBe(0);\n  });\n\n  test('finds 4 pairs of swapped wires in a 4-bit adder', () => {\n    // Swap 4 pairs: (z00,c00), (t01,z01), (a02,b02), (z03,t03)\n    let gates = make4BitAdder();\n    gates = swapWires(gates, 'z00', 'c00');\n    gates = swapWires(gates, 't01', 'z01');\n    gates = swapWires(gates, 'a02', 'b02');\n    gates = swapWires(gates, 'z03', 't03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toHaveLength(8);\n    expect(result).toEqual([...['z00', 'c00', 't01', 'z01', 'a02', 'b02', 'z03', 't03']].sort());\n  });\n\n  test('returns sorted array of swapped wire names', () => {\n    let gates = make4BitAdder();\n    gates = swapWires(gates, 'z00', 'c00');\n    gates = swapWires(gates, 't01', 'z01');\n    gates = swapWires(gates, 'a02', 'b02');\n    gates = swapWires(gates, 'z03', 't03');\n\n    const result = findSwappedWires(gates);\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n});\n"}}
