+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const pending = [...gates];
+
+  let changed = true;
+  while (changed && pending.length > 0) {
+    changed = false;
+    for (let i = pending.length - 1; i >= 0; i--) {
+      const gate = pending[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let out: number;
+        if (gate.op === 'AND') out = a & b;
+        else if (gate.op === 'OR') out = a | b;
+        else out = a ^ b;
+        wires[gate.out] = out;
+        pending.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Identify swapped wire pairs using structural validation of adder rules.
+  //
+  // Key structural rules for a correct ripple-carry adder:
+  //
+  // For each bit N:
+  //   A = XOR(xN, yN)  — partial sum
+  //   B = XOR(A.out, carry)  — final sum, outputs zN
+  //   C = AND(xN, yN)  — generate
+  //   D = AND(A.out, carry)  — propagate
+  //   E = OR(C.out, D.out)  — carry out
+  //
+  // Rules we can check:
+  //   R1: A.out must be z00 for N=0, and must NOT be a z-wire for N>0
+  //   R2: B.out must equal zN
+  //   R3: C.out must NOT be a z-wire
+  //   R4: E.out must NOT be a z-wire except z(numBits) for N=numBits-1
+  //
+  // Critical insight: after output swaps, a gate may have its own output as one
+  // of its inputs (creating a detectable "self-referential" anomaly).
+  // Example: if B's output z01 is swapped with t01 (the original A.out), then
+  //   B now outputs t01, and B reads t01 as one of its inputs.
+  //   This means B.in1 = B.out OR B.in2 = B.out.
+
+  const byOut = new Map<string, Gate>();
+  for (const g of gates) byOut.set(g.out, g);
+
+  function findGate(op: Gate['op'], w1: string, w2: string): Gate | undefined {
+    return gates.find(g =>
+      g.op === op &&
+      ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))
+    );
+  }
+
+  let numBits = 0;
+  for (const gate of gates) {
+    for (const w of [gate.in1, gate.in2]) {
+      const m = w.match(/^x(\d+)$/);
+      if (m) numBits = Math.max(numBits, parseInt(m[1]) + 1);
+    }
+  }
+
+  function pad(n: number) { return String(n).padStart(2, '0'); }
+  function isZWire(w: string) { return /^z\d+$/.test(w); }
+  function isXYWire(w: string) { return /^[xy]\d+$/.test(w); }
+
+  const swapped = new Set<string>();
+
+  // First pass: detect self-referential gates (a gate reads its own output as input).
+  for (const gate of gates) {
+    if (gate.in1 !== gate.out && gate.in2 !== gate.out) continue;
+
+    if (gate.op === 'XOR') {
+      // Self-ref XOR: partial sum P was swapped with z-wire Z.
+      // XOR(xN,yN) now outputs Z, and XOR(P, carry) now outputs P (self-ref).
+      // Find N from the carry source, then pair gate.out with zN.
+      const otherInput = gate.in1 === gate.out ? gate.in2 : gate.in1;
+      const carrySourceGate = byOut.get(otherInput);
+      let bitN = -1;
+
+      if (carrySourceGate) {
+        if (isXYWire(carrySourceGate.in1) && isXYWire(carrySourceGate.in2)) {
+          // carry = AND(xM,yM) or XOR(xM,yM) [if XOR(x00,y00) was swapped with AND(x00,y00)]
+          const xMatch = carrySourceGate.in1.match(/^x(\d+)$/) ?? carrySourceGate.in2.match(/^x(\d+)$/);
+          if (xMatch) bitN = parseInt(xMatch[1]) + 1;
+        } else if (carrySourceGate.op === 'OR') {
+          // carry = OR(gen, prop) for bit M-1 → our bit N = M
+          const orIn1G = byOut.get(carrySourceGate.in1);
+          const orIn2G = byOut.get(carrySourceGate.in2);
+          const andFromXY = (orIn1G?.op === 'AND' && isXYWire(orIn1G.in1) && isXYWire(orIn1G.in2)) ? orIn1G
+            : (orIn2G?.op === 'AND' && isXYWire(orIn2G.in1) && isXYWire(orIn2G.in2)) ? orIn2G
+            : undefined;
+          if (andFromXY) {
+            const xMatch = andFromXY.in1.match(/^x(\d+)$/) ?? andFromXY.in2.match(/^x(\d+)$/);
+            if (xMatch) bitN = parseInt(xMatch[1]) + 1;
+          }
+        } else if (carrySourceGate.op === 'XOR' && !isXYWire(carrySourceGate.in1) && !isXYWire(carrySourceGate.in2)) {
+          // carry source = final-sum XOR at bit M (its carry output was swapped with a z-wire).
+          // Find M from that XOR's partial sum input (XOR(xM,yM)).
+          const csIn1G = byOut.get(carrySourceGate.in1);
+          const csIn2G = byOut.get(carrySourceGate.in2);
+          const partialSrcG = (csIn1G?.op === 'XOR' && isXYWire(csIn1G.in1) && isXYWire(csIn1G.in2)) ? csIn1G
+            : (csIn2G?.op === 'XOR' && isXYWire(csIn2G.in1) && isXYWire(csIn2G.in2)) ? csIn2G
+            : undefined;
+          if (partialSrcG) {
+            const xMatch = partialSrcG.in1.match(/^x(\d+)$/) ?? partialSrcG.in2.match(/^x(\d+)$/);
+            if (xMatch) bitN = parseInt(xMatch[1]) + 1;
+          }
+        }
+      }
+
+      if (bitN > 0 && bitN < numBits) {
+        swapped.add(gate.out);
+        swapped.add(`z${pad(bitN)}`);
+      }
+    } else if (gate.op === 'OR') {
+      // Self-ref OR: carry output C was swapped with propagate P.
+      // OR(gen, P) now outputs P (self-ref) instead of C.
+      // Find the correct carry name C by looking at what the next bit's final-sum XOR reads.
+      const otherInput = gate.in1 === gate.out ? gate.in2 : gate.in1; // this is the generate input
+      const genGate = byOut.get(otherInput);
+      // genGate = AND(xM,yM)
+      if (genGate?.op === 'AND' && isXYWire(genGate.in1) && isXYWire(genGate.in2)) {
+        const xMatch = genGate.in1.match(/^x(\d+)$/) ?? genGate.in2.match(/^x(\d+)$/);
+        if (xMatch) {
+          const M = parseInt(xMatch[1]); // bit of the OR gate
+          const nextBit = M + 1;
+          if (nextBit < numBits) {
+            const nextPartialGate = findGate('XOR', `x${pad(nextBit)}`, `y${pad(nextBit)}`);
+            if (nextPartialGate) {
+              // Find the final sum XOR at bit nextBit that reads nextPartialGate.out
+              for (const g of gates) {
+                if (g.op === 'XOR' && (g.in1 === nextPartialGate.out || g.in2 === nextPartialGate.out)) {
+                  // g is final sum XOR at bit nextBit
+                  const carryName = g.in1 === nextPartialGate.out ? g.in2 : g.in1;
+                  swapped.add(gate.out); // propagate wire (wrong carry output)
+                  swapped.add(carryName); // actual carry name (should be OR's output)
+                  break;
+                }
+              }
+            }
+          }
+        }
+      }
+    }
+  }
+
+  // Second pass: standard checks (no self-reference needed)
+
+  // Bit 0: z00 from XOR(x00,y00)
+  {
+    const xorG = findGate('XOR', 'x00', 'y00');
+    if (xorG && xorG.out !== 'z00') {
+      swapped.add(xorG.out);
+      swapped.add('z00');
+    }
+  }
+
+  // Bits 1..N-1: find final sum XOR via gateA.out as input
+  for (let bit = 1; bit < numBits; bit++) {
+    const xN = `x${pad(bit)}`;
+    const yN = `y${pad(bit)}`;
+    const zN = `z${pad(bit)}`;
+
+    const gateA = findGate('XOR', xN, yN);
+    if (!gateA) continue;
+    if (isZWire(gateA.out)) continue; // handled in self-reference pass or already flagged
+
+    // Find XOR using gateA.out as one input
+    for (const g of gates) {
+      if (g.op === 'XOR' && (g.in1 === gateA.out || g.in2 === gateA.out)) {
+        if (g.out !== zN) {
+          swapped.add(g.out);
+          swapped.add(zN);
+        }
+        break;
+      }
+    }
+
+    // Find OR using AND(xN,yN).out as one input
+    const gateC = findGate('AND', xN, yN);
+    if (!gateC) continue;
+    if (isZWire(gateC.out)) {
+      // AND outputs z-wire: find correct gate for that z-bit
+      const zBit = parseInt(gateC.out.slice(1));
+      if (zBit > 0 && zBit < numBits) {
+        const gateAZ = findGate('XOR', `x${pad(zBit)}`, `y${pad(zBit)}`);
+        if (gateAZ) {
+          for (const g of gates) {
+            if (g.op === 'XOR' && (g.in1 === gateAZ.out || g.in2 === gateAZ.out)) {
+              swapped.add(gateC.out);
+              swapped.add(g.out);
+              break;
+            }
+          }
+        }
+      }
+      continue;
+    }
+
+    for (const g of gates) {
+      if (g.op === 'OR' && (g.in1 === gateC.out || g.in2 === gateC.out)) {
+        const isLastBit = bit === numBits - 1;
+        const finalCarry = `z${pad(numBits)}`;
+        if (isZWire(g.out) && !(isLastBit && g.out === finalCarry)) {
+          // OR outputs wrong z-wire: find correct carry
+          const nextBit = bit + 1;
+          if (nextBit < numBits) {
+            const nextGateA = findGate('XOR', `x${pad(nextBit)}`, `y${pad(nextBit)}`);
+            if (nextGateA) {
+              for (const xorG of gates) {
+                if (xorG.op === 'XOR' && (xorG.in1 === nextGateA.out || xorG.in2 === nextGateA.out)) {
+                  const carryName = xorG.in1 === nextGateA.out ? xorG.in2 : xorG.in1;
+                  swapped.add(g.out);
+                  swapped.add(carryName);
+                  break;
+                }
+              }
+            }
+          }
+        }
+        break;
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
