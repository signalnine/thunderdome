n\n  it('returns 401 without auth token', async () => {\n    const res = await request(app).post('/folders').send({ name: 'X' });\n    expect(res.status).toBe(401);\n  });\n\n  it('returns 404 if parent folder does not exist', async () => {\n    const { token } = await registerAndLogin('fuser4');\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: '9999' });\n\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('Folder read', () => {\n  it('owner can read their folder', async () => {\n    const { token } = await registerAndLogin('fuser5');\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Readable' });\n\n    const res = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Readable');\n  });\n\n  it('returns 403 for a folder the user has no access to', async () => {\n    const { token: t1 } = await registerAndLogin('fuser6');\n    const { token: t2 } = await registerAndLogin('fuser7');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${t1}`)\n      .send({ name: 'Private' });\n\n    const res = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${t2}`);\n\n    expect(res.status).toBe(403);\n  });\n\n  it('returns 404 for nonexistent folder', async () => {\n    const { token } = await registerAndLogin('fuser8');\n    const res = await request(app)\n      .get('/folders/9999')\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('Folder update', () => {\n  it('owner can update folder name', async () => {\n    const { token } = await registerAndLogin('fuser9');\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Old Name' });\n\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'New Name' });\n\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('New Name');\n  });\n\n  it('viewer cannot update folder', async () => {\n    const { token: t1, userId: u1 } = await registerAndLogin('fuser10');\n    const { token: t2, userId: u2 } = await registerAndLogin('fuser11');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${t1}`)\n      .send({ name: 'Restricted' });\n\n    // share as viewer\n    await request(app)\n      .post(`/folders/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${t1}`)\n      .send({ userId: u2, role: 'viewer' });\n\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${t2}`)\n      .send({ name: 'Hacked' });\n\n    expect(res.status).toBe(403);\n  });\n});\n\ndescribe('Folder delete', () => {\n  it('owner can delete folder', async () => {\n    const { token } = await registerAndLogin('fuser12');\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Deletable' });\n\n    const del = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(del.status).toBe(204);\n\n    const get = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(get.status).toBe(404);\n  });\n\n  it('editor cannot delete folder', async () => {\n    const { token: t1, userId: u1 } = await registerAndLogin('fuser13');\n    const { token: t2, userId: u2 } = await registerAndLogin('fuser14');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${t1}`)\n      .send({ name: 'Safe' });\n\n    await request(app)\n      .post(`/folders/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${t1}`)\n      .send({ userId: u2, role: 'editor' });\n\n    const res = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${t2}`);\n\n    expect(res.status).toBe(403);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":343,"cache_read_input_tokens":34060,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":343},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ef98f216-232d-49cf-b6f6-65820a924748","uuid":"3c1f65f4-17aa-40b9-b116-2dc1c7c2fdab"}
