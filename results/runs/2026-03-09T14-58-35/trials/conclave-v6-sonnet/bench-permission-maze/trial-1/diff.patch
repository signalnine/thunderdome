@@ -0,0 +1,39 @@
+export type Role = 'viewer' | 'editor' | 'owner';
+
+export interface User {
+  id: string;
+  username: string;
+  passwordHash: string;
+}
+
+export interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+  createdAt: Date;
+}
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+  createdAt: Date;
+  updatedAt: Date;
+}
+
+export interface Permission {
+  userId: string;
+  role: Role;
+}
+
+export interface ActivityEntry {
+  id: string;
+  action: string;
+  userId: string;
+  resourceType: 'document' | 'folder';
+  resourceId: string;
+  timestamp: Date;
+}
