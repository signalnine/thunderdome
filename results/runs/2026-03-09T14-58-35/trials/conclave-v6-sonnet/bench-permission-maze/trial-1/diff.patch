+++ b/src/store.ts
@@ -0,0 +1,54 @@
+import type { User, Folder, Document, Permission, ActivityEntry, Role } from './types.js';
+
+export class Store {
+  users = new Map<string, User>();
+  usersByName = new Map<string, User>();
+  tokens = new Map<string, string>(); // token -> userId
+  folders = new Map<string, Folder>();
+  documents = new Map<string, Document>();
+  folderPermissions = new Map<string, Permission[]>(); // folderId -> permissions
+  documentPermissions = new Map<string, Permission[]>(); // documentId -> permissions
+  activityLog: ActivityEntry[] = [];
+
+  private counter = 0;
+
+  newId(): string {
+    return String(++this.counter);
+  }
+
+  addActivity(action: string, userId: string, resourceType: 'document' | 'folder', resourceId: string) {
+    this.activityLog.push({
+      id: this.newId(),
+      action,
+      userId,
+      resourceType,
+      resourceId,
+      timestamp: new Date(),
+    });
+  }
+
+  getEffectiveRole(userId: string, resourceType: 'folder' | 'document', resourceId: string): Role | null {
+    // Check direct permissions on resource
+    const permMap = resourceType === 'folder' ? this.folderPermissions : this.documentPermissions;
+    const perms = permMap.get(resourceId) ?? [];
+    const direct = perms.find(p => p.userId === userId);
+
+    // If document, also check folder permissions (inherited)
+    let inherited: Role | null = null;
+    if (resourceType === 'document') {
+      const doc = this.documents.get(resourceId);
+      if (doc) {
+        inherited = this.getEffectiveRole(userId, 'folder', doc.folderId);
+      }
+    }
+
+    // Merge roles: pick most permissive
+    const roles: Role[] = [];
+    if (direct) roles.push(direct.role);
+    if (inherited) roles.push(inherited);
+    if (roles.length === 0) return null;
+    if (roles.includes('owner')) return 'owner';
+    if (roles.includes('editor')) return 'editor';
+    return 'viewer';
+  }
+}
