+export function foldersRouter(store: Store): Router {
+  const router = Router();
+  const auth = requireAuth(store);
+
+  router.post('/', auth, (req: AuthRequest, res) => {
+    const { name, parentId } = req.body ?? {};
+    if (!name) return res.status(400).json({ error: 'name required' });
+
+    if (parentId) {
+      const parent = store.folders.get(parentId);
+      if (!parent) return res.status(404).json({ error: 'parent folder not found' });
+      const role = store.getEffectiveRole(req.userId!, 'folder', parentId);
+      if (!role || role === 'viewer') {
+        return res.status(403).json({ error: 'insufficient permissions' });
+      }
+    }
+
+    const id = store.newId();
+    const folder = {
+      id,
+      name,
+      parentId: parentId ?? null,
+      ownerId: req.userId!,
+      createdAt: new Date(),
+    };
+    store.folders.set(id, folder);
+    store.folderPermissions.set(id, [{ userId: req.userId!, role: 'owner' }]);
+
+    return res.status(201).json(folder);
+  });
+
+  router.get('/:id', auth, (req: AuthRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) return res.status(404).json({ error: 'folder not found' });
+
+    const role = store.getEffectiveRole(req.userId!, 'folder', req.params.id);
+    if (!role) return res.status(403).json({ error: 'insufficient permissions' });
+
+    return res.json(folder);
+  });
+
+  router.put('/:id', auth, (req: AuthRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) return res.status(404).json({ error: 'folder not found' });
+
+    const role = store.getEffectiveRole(req.userId!, 'folder', req.params.id);
+    if (!role || role === 'viewer') {
+      return res.status(403).json({ error: 'insufficient permissions' });
+    }
+
+    const { name } = req.body ?? {};
+    if (name) folder.name = name;
+    return res.json(folder);
+  });
+
+  router.delete('/:id', auth, (req: AuthRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) return res.status(404).json({ error: 'folder not found' });
+
+    const role = store.getEffectiveRole(req.userId!, 'folder', req.params.id);
+    if (role !== 'owner') {
+      return res.status(403).json({ error: 'only owner can delete' });
+    }
+
+    store.folders.delete(req.params.id);
+    store.folderPermissions.delete(req.params.id);
+    return res.status(204).send();
+  });
+
+  router.post('/:id/share', auth, (req: AuthRequest, res) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) return res.status(404).json({ error: 'folder not found' });
+
+    const role = store.getEffectiveRole(req.userId!, 'folder', req.params.id);
+    if (!role || role === 'viewer') {
+      return res.status(403).json({ error: 'insufficient permissions' });
+    }
+
+    const { userId: targetUserId, role: targetRole } = req.body ?? {};
+    if (!targetUserId || !targetRole) {
+      return res.status(400).json({ error: 'userId and role required' });
+    }
+    if (!store.users.has(targetUserId)) {
+      return res.status(404).json({ error: 'user not found' });
+    }
+    if (!['viewer', 'editor', 'owner'].includes(targetRole)) {
+      return res.status(400).json({ error: 'invalid role' });
+    }
+
+    const perms = store.folderPermissions.get(req.params.id)!;
+    const existing = perms.find(p => p.userId === targetUserId);
+    if (existing) {
+      existing.role = targetRole;
+    } else {
+      perms.push({ userId: targetUserId, role: targetRole });
+    }
+
+    store.addActivity('share', req.userId!, 'folder', req.params.id);
+    return res.status(200).json({ message: 'shared' });
+  });
+
+  return router;
+}
diff --git a/src/middleware.ts b/src/middleware.ts
new file mode 100644
