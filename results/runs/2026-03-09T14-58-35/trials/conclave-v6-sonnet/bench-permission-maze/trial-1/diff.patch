er3 as viewer\n    const res = await request(app)\n      .post(`/folders/${folder.id}/share`)\n      .set('Authorization', `Bearer ${editorToken}`)\n      .send({ userId: viewerId, role: 'viewer' });\n\n    expect(res.status).toBe(200);\n\n    // puser3 can now read\n    const readRes = await request(app)\n      .get(`/folders/${folder.id}`)\n      .set('Authorization', `Bearer ${viewerToken}`);\n    expect(readRes.status).toBe(200);\n  });\n\n  it('viewer cannot share folder', async () => {\n    const { token: ownerToken } = await registerAndLogin('puser4');\n    const { token: viewerToken, userId: viewerId } = await registerAndLogin('puser5');\n    const { userId: otherId } = await registerAndLogin('puser6');\n\n    const folder = await createFolder(ownerToken);\n\n    await request(app)\n      .post(`/folders/${folder.id}/share`)\n      .set('Authorization', `Bearer ${ownerToken}`)\n      .send({ userId: viewerId, role: 'viewer' });\n\n    const res = await request(app)\n      .post(`/folders/${folder.id}/share`)\n      .set('Authorization', `Bearer ${viewerToken}`)\n      .send({ userId: otherId, role: 'viewer' });\n\n    expect(res.status).toBe(403);\n  });\n});\n\ndescribe('Document sharing', () => {\n  it('owner can share document with viewer', async () => {\n    const { token: t1 } = await registerAndLogin('puser7');\n    const { token: t2, userId: u2 } = await registerAndLogin('puser8');\n\n    const folder = await createFolder(t1);\n    const doc = await createDoc(t1, folder.id);\n\n    const share = await request(app)\n      .post(`/documents/${doc.id}/share`)\n      .set('Authorization', `Bearer ${t1}`)\n      .send({ userId: u2, role: 'viewer' });\n\n    expect(share.status).toBe(200);\n\n    const read = await request(app)\n      .get(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${t2}`);\n\n    expect(read.status).toBe(200);\n  });\n\n  it('viewer cannot share document', async () => {\n    const { token: t1 } = await registerAndLogin('puser9');\n    const { token: t2, userId: u2 } = await registerAndLogin('puser10');\n    const { userId: u3 } = await registerAndLogin('puser11');\n\n    const folder = await createFolder(t1);\n    const doc = await createDoc(t1, folder.id);\n\n    await request(app)\n      .post(`/documents/${doc.id}/share`)\n      .set('Authorization', `Bearer ${t1}`)\n      .send({ userId: u2, role: 'viewer' });\n\n    const res = await request(app)\n      .post(`/documents/${doc.id}/share`)\n      .set('Authorization', `Bearer ${t2}`)\n      .send({ userId: u3, role: 'viewer' });\n\n    expect(res.status).toBe(403);\n  });\n});\n\ndescribe('Permission inheritance from folder', () => {\n  it('viewer of folder can read documents inside it', async () => {\n    const { token: t1 } = await registerAndLogin('puser12');\n    const { token: t2, userId: u2 } = await registerAndLogin('puser13');\n\n    const folder = await createFolder(t1);\n    const doc = await createDoc(t1, folder.id, 'Inherited Doc');\n\n    // Share folder as viewer\n    await request(app)\n      .post(`/folders/${folder.id}/share`)\n      .set('Authorization', `Bearer ${t1}`)\n      .send({ userId: u2, role: 'viewer' });\n\n    // t2 can read doc via folder access\n    const res = await request(app)\n      .get(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${t2}`);\n\n    expect(res.status).toBe(200);\n  });\n\n  it('editor of folder can edit documents inside it', async () => {\n    const { token: t1 } = await registerAndLogin('puser14');\n    const { token: t2, userId: u2 } = await registerAndLogin('puser15');\n\n    const folder = await createFolder(t1);\n    const doc = await createDoc(t1, folder.id, 'Editable Doc');\n\n    await request(app)\n      .post(`/folders/${folder.id}/share`)\n      .set('Authorization', `Bearer ${t1}`)\n      .send({ userId: u2, role: 'editor' });\n\n    const res = await request(app)\n      .put(`/documents/${doc.id}`)\n      .set('Authorization', `Bearer ${t2}`)\n      