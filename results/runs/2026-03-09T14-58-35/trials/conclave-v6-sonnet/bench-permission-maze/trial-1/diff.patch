ers')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Folder' });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Original', folderId: folder.body.id });\n\n    await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Updated' });\n\n    const log = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n\n    const updateEntry = log.body.find(\n      (e: { action: string; resourceId: string }) =>\n        e.action === 'update' && e.resourceId === doc.body.id\n    );\n    expect(updateEntry).toBeDefined();\n  });\n\n  it('records document deletion', async () => {\n    const { token, userId } = await registerAndLogin('auser3');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Folder' });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Doomed', folderId: folder.body.id });\n\n    await request(app)\n      .delete(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    const log = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n\n    const deleteEntry = log.body.find(\n      (e: { action: string; resourceId: string }) =>\n        e.action === 'delete' && e.resourceId === doc.body.id\n    );\n    expect(deleteEntry).toBeDefined();\n  });\n\n  it('records sharing events', async () => {\n    const { token: t1, userId: u1 } = await registerAndLogin('auser4');\n    const { userId: u2 } = await registerAndLogin('auser5');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${t1}`)\n      .send({ name: 'Shared' });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${t1}`)\n      .send({ title: 'Shared Doc', folderId: folder.body.id });\n\n    await request(app)\n      .post(`/documents/${doc.body.id}/share`)\n      .set('Authorization', `Bearer ${t1}`)\n      .send({ userId: u2, role: 'viewer' });\n\n    const log = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${t1}`);\n\n    const shareEntry = log.body.find(\n      (e: { action: string; resourceId: string }) =>\n        e.action === 'share' && e.resourceId === doc.body.id\n    );\n    expect(shareEntry).toBeDefined();\n    expect(shareEntry.userId).toBe(u1);\n  });\n\n  it('requires authentication to access activity log', async () => {\n    const res = await request(app).get('/activity');\n    expect(res.status).toBe(401);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
