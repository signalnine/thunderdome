new file mode 100644
index 0000000..dfaefd2
--- /dev/null
+++ b/src/app.ts
@@ -0,0 +1,26 @@
+import express from 'express';
+import { Store } from './store.js';
+import { authRouter } from './auth.js';
+import { foldersRouter } from './folders.js';
+import { documentsRouter } from './documents.js';
+import { requireAuth } from './middleware.js';
+import type { AuthRequest } from './middleware.js';
+
+export function createApp(): express.Application {
+  const app = express();
+  const store = new Store();
+
+  app.use(express.json());
+
+  app.use('/auth', authRouter(store));
+  app.use('/folders', foldersRouter(store));
+  app.use('/documents', documentsRouter(store));
+
+  const auth = requireAuth(store);
+
+  app.get('/activity', auth, (req: AuthRequest, res) => {
+    return res.json(store.activityLog);
+  });
+
+  return app;
+}
diff --git a/src/auth.ts b/src/auth.ts
new file mode 100644
index 0000000..4816a14
--- /dev/null
+++ b/src/auth.ts
@@ -0,0 +1,43 @@
+import { Router } from 'express';
+import type { Store } from './store.js';
+import crypto from 'crypto';
+
+function hashPassword(password: string): string {
+  return crypto.createHash('sha256').update(password).digest('hex');
+}
+
+function generateToken(): string {
+  return crypto.randomBytes(32).toString('hex');
+}
+
+export function authRouter(store: Store): Router {
+  const router = Router();
+
+  router.post('/register', (req, res) => {
+    const { username, password } = req.body ?? {};
+    if (!username || !password) {
+      return res.status(400).json({ error: 'username and password required' });
+    }
+    if (store.usersByName.has(username)) {
+      return res.status(409).json({ error: 'username already taken' });
+    }
+    const id = store.newId();
+    const user = { id, username, passwordHash: hashPassword(password) };
+    store.users.set(id, user);
+    store.usersByName.set(username, user);
+    return res.status(201).json({ userId: id, username });
+  });
+
+  router.post('/login', (req, res) => {
+    const { username, password } = req.body ?? {};
+    const user = store.usersByName.get(username);
+    if (!user || user.passwordHash !== hashPassword(password)) {
+      return res.status(401).json({ error: 'invalid credentials' });
+    }
+    const token = generateToken();
+    store.tokens.set(token, user.id);
+    return res.status(200).json({ token, userId: user.id });
+  });
+
+  return router;
+}
diff --git a/src/documents.ts b/src/documents.ts
new file mode 100644
index 0000000..9aee278
--- /dev/null
+++ b/src/documents.ts
@@ -0,0 +1,119 @@
+import { Router } from 'express';
+import type { Store } from './store.js';
+import { requireAuth } from './middleware.js';
+import type { AuthRequest } from './middleware.js';
+
+export function documentsRouter(store: Store): Router {
+  const router = Router();
+  const auth = requireAuth(store);
+
+  router.post('/', auth, (req: AuthRequest, res) => {
+    const { title, content, folderId } = req.body ?? {};
+    if (!title || !folderId) {
+      return res.status(400).json({ error: 'title and folderId required' });
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) return res.status(404).json({ error: 'folder not found' });
+
+    const folderRole = store.getEffectiveRole(req.userId!, 'folder', folderId);
+    if (!folderRole || folderRole === 'viewer') {
+      return res.status(403).json({ error: 'insufficient permissions' });
+    }
+
+    const id = store.newId();
+    const now = new Date();
+    const doc = {
+      id,
+      title,
+      content: content ?? '',
+      folderId,
+      ownerId: req.userId!,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+    store.documentPermissions.set(id, [{ userId: req.userId!, role: 'owner' }]);
+    store.addActivity('create', req.userId!, 'document', id);
+
+    return res.status(201).json(doc);
+  });
+
+  router.get('/:id', auth, (req: AuthRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) return res.status(404).json({ error: 'document not found' });
+
+    const role = store.getEffectiveRole(req.userId!, 'document', req.params.id);
+    if (!role) return res.status(403).json({ error: 'insufficient permissions' });
+
+    return res.json(doc);
+  });
+
+  router.put('/:id', auth, (req: AuthRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) return res.status(404).json({ error: 'document not found' });
+
+    const role = store.getEffectiveRole(req.userId!, 'document', req.params.id);
+    if (!role || role === 'viewer') {
+      return res.status(403).json({ error: 'insufficient permissions' });
+    }
+
+    const { title, content } = req.body ?? {};
+    if (title) doc.title = title;
+    if (content !== undefined) doc.content = content;
+    doc.updatedAt = new Date();
+    store.addActivity('update', req.userId!, 'document', req.params.id);
+
+    return res.json(doc);
+  });
+
+  router.delete('/:id', auth, (req: AuthRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) return res.status(404).json({ error: 'document not found' });
+
+    const role = store.getEffectiveRole(req.userId!, 'document', req.params.id);
+    if (role !== 'owner') {
+      return res.status(403).json({ error: 'only owner can delete' });
+    }
+
+    store.addActivity('delete', req.userId!, 'document', req.params.id);
+    store.documents.delete(req.params.id);
+    store.documentPermissions.delete(req.params.id);
+
+    return res.status(204).send();
+  });
+
+  router.post('/:id/share', auth, (req: AuthRequest, res) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) return res.status(404).json({ error: 'document not found' });
+
+    const role = store.getEffectiveRole(req.userId!, 'document', req.params.id);
+    if (!role || role === 'viewer') {
+      return res.status(403).json({ error: 'insufficient permissions' });
+    }
+
+    const { userId: targetUserId, role: targetRole } = req.body ?? {};
+    if (!targetUserId || !targetRole) {
+      return res.status(400).json({ error: 'userId and role required' });
+    }
+    if (!store.users.has(targetUserId)) {
+      return res.status(404).json({ error: 'user not found' });
+    }
+    if (!['viewer', 'editor', 'owner'].includes(targetRole)) {
+      return res.status(400).json({ error: 'invalid role' });
+    }
+
+    const perms = store.documentPermissions.get(req.params.id)!;
+    const existing = perms.find(p => p.userId === targetUserId);
+    if (existing) {
+      existing.role = targetRole;
+    } else {
+      perms.push({ userId: targetUserId, role: targetRole });
+    }
+
+    store.addActivity('share', req.userId!, 'document', req.params.id);
+    return res.status(200).json({ message: 'shared' });
+  });
+
+  return router;
+}
