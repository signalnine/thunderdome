   // ^ . ^ . .\n+    // . . . . .\n+    const g = grid(['.S...', '.^...', '^.^..', '.....']);\n+    // Beam: (0,1) -> (1,1) splitter\n+    //   Left: (2,0) splitter -> (3,-1) absorbed + (3,1)\n+    //   Right: (2,2) splitter -> (3,1) + (3,3)\n+    // Visited: (0,1),(1,1),(2,0),(2,2),(3,1),(3,3) = 6\n+    expect(countBeamCells(g)).toBe(6);\n+  });\n+\n+  test('beam exits immediately if source is at last row', () => {\n+    // . S .\n+    const g = grid(['.S.']);\n+    // source at (0,1), next step would be row 1 which is out of bounds\n+    expect(countBeamCells(g)).toBe(1);\n+  });\n+\n+  test('diagonal beam going out of left boundary is absorbed', () => {\n+    // S .\n+    // ^ .\n+    const g = grid(['S.', '^.']);\n+    // Beam: (0,0) -> (1,0) splitter -> (2,-1) absorbed + (2,1) exits\n+    // Visited: (0,0), (1,0) = 2\n+    expect(countBeamCells(g)).toBe(2);\n+  });\n+\n+  test('diagonal beam going out of right boundary is absorbed', () => {\n+    // . S\n+    // . ^\n+    const g = grid(['.S', '.^']);\n+    // Beam: (0,1) -> (1,1) splitter -> (2,0) + (2,2) absorbed\n+    // Visited: (0,1), (1,1) = 2\n+    expect(countBeamCells(g)).toBe(2);\n+  });\n+\n+  test('two beams visiting the same cell counts it only once', () => {\n+    // . S . . .\n+    // . ^ . . .\n+    // ^ . ^ . .\n+    // . . . . .\n+    // Both left and right branches from row 2 splitters go to (3,1)\n+    // but (3,1) is counted only once\n+    const g = grid(['.S...', '.^...', '^.^..', '.....']);\n+    expect(countBeamCells(g)).toBe(6);\n+  });\n+\n+  test('splitter not hit by any beam does not count as visited', () => {\n+    // S . .\n+    // . . ^\n+    // . . .\n+    const g = grid(['S..', '..^', '...']);\n+    // Beam: (0,0) -> (1,0) -> (2,0) -> exits\n+    // The ^ at (1,2) is never hit\n+    expect(countBeamCells(g)).toBe(3);\n+  });\n+\n+  test('multiple splitters in sequence double path each time', () => {\n+    // S\n+    // ^\n+    // . (exits at left and right, but both out of 1-wide grid)\n+    // Actually test with wider grid\n+    // . S .\n+    // . ^ .\n+    // ^ . ^\n+    // . . .\n+    const g = grid(['.S.', '.^.', '^.^', '...']);\n+    // (0,1) -> (1,1) splitter -> left (2,0) splitter, right (2,2) splitter\n+    // (2,0): left -> (3,-1) absorbed, right -> (3,1)\n+    // (2,2): left -> (3,1), right -> (3,3) absorbed\n+    // Visited: (0,1),(1,1),(2,0),(2,2),(3,1) = 5\n+    expect(countBeamCells(g)).toBe(5);\n+  });\n+});\n+\n+describe('countBeamPaths', () => {\n+  test('single path with no splitters', () => {\n+    // S\n+    // .\n+    // .\n+    const g = grid(['S', '.', '.']);\n+    expect(countBeamPaths(g)).toBe(1n);\n+  });\n+\n+  test('spec example 1: one splitter yields 2 paths', () => {\n+    const g = grid(['.S...', '.....', '.^...', '.....']);\n+    expect(countBeamPaths(g)).toBe(2n);\n+  });\n+\n+  test('spec example 2: two splitters yields 4 paths', () => {\n+    // . S . . .\n+    // . ^ . . .\n+    // ^ . ^ . .\n+    // . . . . .\n+    // All 4 paths exit (including the absorbed one at col -1)\n+    const g = grid(['.S...', '.^...', '^.^..', '.....']);\n+    expect(countBeamPaths(g)).toBe(4n);\n+  });\n+\n+  test('source at last row: 1 path exits immediately', () => {\n+    const g = grid(['.S.']);\n+    expect(countBeamPaths(g)).toBe(1n);\n+  });\n+\n+  test('no splitters: always 1 path', () => {\n+    const g = grid(['S....', '.....', '.....', '.....']);\n+    expect(countBeamPaths(g)).toBe(1n);\n+  });\n+\n+  test('K splitters all in line yield 2^K paths', () => {\n+    // . . S . .   row 0\n+    // . . ^ . .   row 1 - splitter at (1,2)\n+    // . ^ . ^ .   row 2 - splitters at (2,1) and (2,3)\n+    // ^ . . . ^   row 3 - splitters at (3,0) and (3,4)\n+    // . . . . .   row 4\n+    const g = grid([\n+      '..S..',\n+      '..^..',\n+      '.^.^.',\n+      '^...^',\n+      '.....',\n+    ]);\n+    // (0,2) -> (1,2) splitter\n+    //   Left: (2,1) splitter\n+    //     -> down-left (3,0) splitter -> (4,-1) absorbed, (4,1) exits  [2 paths]\n+    //     -> down-right (3,2) empty -> (4,2) exits                      [1 path]\n+    //   Right: (2,3) splitter\n+    //     -> down-left (3,2) empty -> (4,2) exits                       [1 path]\n+    //     -> down-right (3,4) splitter -> (4,3) exits, (4,5) absorbed   [2 paths]\n+    // Total: 6 paths (absorbed beams still count as exiting the grid)\n+    expect(countBeamPaths(g)).toBe(6n);\n+  });\n+\n+  test('returns bigint type', () => {\n+    const g = grid(['S']);\n+    const result = countBeamPaths(g);\n+    expect(typeof result).toBe('bigint');\n+  });\n+\n+  test('large grid performance: 200x200 with 50 splitters completes in time', () => {\n+    // Build a 200x200 grid with S at top center and 50 splitters in chain\n+    const rows = 200;\n+    const cols = 200;\n+    const g: string[][] = Array.from({ length: rows }, () =>\n+      Array(cols).fill('.')\n+    );\n+    g[0][100] = 'S';\n+    // Place splitters so each one is hit - put them in a column cascade\n+    // Beam goes down from col 100, hits splitter at each even row\n+    // After each split, we'd need to track many beams - but we want path count not cell count\n+    // Place 50 splitters all in column 100, rows 1-50\n+    for (let r = 1; r <= 50; r++) {\n+      g[r][100] = '^';\n+    }\n+    const start = Date.now();\n+    const result = countBeamPaths(g);\n+    const elapsed = Date.now() - start;\n+    expect(elapsed).toBeLessThan(5000);\n+    // 50 splitters but only the first one at (1,100) is hit by initial beam\n+    // After that splits go diagonal and never hit another splitter\n+    expect(result).toBe(2n); // only first splitter hit\n+  });\n+});\ndiff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..9a5c106\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,136 @@\n+/**\n+ * Beam propagation simulator for a 2D grid laboratory.\n+ *\n+ * Grid cells:\n+ *   'S' - beam source (top row), emits beam straight down\n+ *   '^' - splitter, beam splits into down-left and down-right\n+ *   '.' - empty cell, beam passes through\n+ */\n+\n+type Direction = 'down' | 'down-left' | 'down-right';\n+\n+interface BeamState {\n+  row: number;\n+  col: number;\n+  dir: Direction;\n+}\n+\n+function nextPosition(row: number, col: number, dir: Direction): [number, number] {\n+  switch (dir) {\n+    case 'down':       return [row + 1, col];\n+    case 'down-left':  return [row + 1, col - 1];\n+    case 'down-right': return [row + 1, col + 1];\n+  }\n+}\n+\n+function inBounds(row: number, col: number, rows: number, cols: number): boolean {\n+  return row >= 0 && row < rows && col >= 0 && col < cols;\n+}\n+\n+function findSource(grid: string[][]): [number, number] {\n+  const cols = grid[0]?.length ?? 0;\n+  for (let c = 0; c < cols; c++) {\n+    if (grid[0][c] === 'S') return [0, c];\n+  }\n+  throw new Error('No source found in grid');\n+}\n+\n+/**\n+ * Count the number of distinct cells visited by any beam.\n+ * The source cell counts as visited.\n+ * Splitter cells hit by beams count as visited.\n+ */\n+export function countBeamCells(grid: string[][]): number {\n+  const rows = grid.length;\n+  const cols = grid[0]?.length ?? 0;\n+  const [srcRow, srcCol] = findSource(grid);\n+\n+  const visited = new Set<string>();\n+  const queue: BeamState[] = [{ row: srcRow, col: srcCol, dir: 'down' }];\n+  const seen = new Set<string>();\n+\n+  while (queue.length > 0) {\n+    const { row, col, dir } = queue.pop()!;\n+\n+    if (!inBounds(row, col, rows, cols)) continue;\n+\n+    const stateKey = `${row},${col},${dir}`;\n+    if (seen.has(stateKey)) continue;\n+    seen.add(stateKey);\n+\n+    visited.add(`${row},${col}`);\n+\n+    const cell = grid[row][col];\n+\n+    if (cell === '^') {\n+      const [lr, lc] = nextPosition(row, col, 'down-left');\n+      const [rr, rc] = nextPosition(row, col, 'down-right');\n+      queue.push({ row: lr, col: lc, dir: 'down-left' });\n+      queue.push({ row: rr, col: rc, dir: 'down-right' });\n+    } else {\n+      const [nr, nc] = nextPosition(row, col, dir);\n+      queue.push({ row: nr, col: nc, dir });\n+    }\n+  }\n+\n+  return visited.size;\n+}\n+\n+/**\n+ * Count the total number of distinct source-to-exit paths.\n+ *\n+ * Uses weighted BFS: each beam carries a path count. When a beam hits a\n+ * splitter both child beams inherit the count. Beams at the same (row, col,\n+ * dir) are merged so the frontier stays O(rows * cols * 3) regardless of the\n+ * number of paths.\n+ */\n+export function countBeamPaths(grid: string[][]): bigint {\n+  const rows = grid.length;\n+  const cols = grid[0]?.length ?? 0;\n+  const [srcRow, srcCol] = findSource(grid);\n+\n+  function stateKey(r: number, c: number, d: Direction): string {\n+    return `${r},${c},${d}`;\n+  }\n+\n+  let totalExited = 0n;\n+  let frontier = new Map<string, bigint>();\n+  frontier.set(stateKey(srcRow, srcCol, 'down'), 1n);\n+\n+  while (frontier.size > 0) {\n+    const nextFrontier = new Map<string, bigint>();\n+\n+    for (const [key, pathCount] of frontier) {\n+      const parts = key.split(',');\n+      const row = parseInt(parts[0]);\n+      const col = parseInt(parts[1]);\n+      const dir = parts[2] as Direction;\n+\n+      const cell = grid[row][col];\n+\n+      if (cell === '^') {\n+        for (const splitDir of ['down-left', 'down-right'] as Direction[]) {\n+          const [nr, nc] = nextPosition(row, col, splitDir);\n+          if (inBounds(nr, nc, rows, cols)) {\n+            const nk = stateKey(nr, nc, splitDir);\n+            nextFrontier.set(nk, (nextFrontier.get(nk) ?? 0n) + pathCount);\n+          } else {\n+            totalExited += pathCount;\n+          }\n+        }\n+      } else {\n+        const [nr, nc] = nextPosition(row, col, dir);\n+        if (inBounds(nr, nc, rows, cols)) {\n+          const nk = stateKey(nr, nc, dir);\n+          nextFrontier.set(nk, (nextFrontier.get(nk) ?? 0n) + pathCount);\n+        } else {\n+          totalExited += pathCount;\n+     