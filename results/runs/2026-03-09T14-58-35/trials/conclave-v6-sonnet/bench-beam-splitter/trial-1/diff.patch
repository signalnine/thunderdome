e loops\n  const seen = new Set<string>();\n\n  while (queue.length > 0) {\n    const { row, col, dir } = queue.pop()!;\n\n    if (!inBounds(row, col, rows, cols)) continue;\n\n    const stateKey = `${row},${col},${dir}`;\n    if (seen.has(stateKey)) continue;\n    seen.add(stateKey);\n\n    visited.add(`${row},${col}`);\n\n    const cell = grid[row][col];\n\n    if (cell === '^') {\n      // Split into down-left and down-right\n      const [lr, lc] = nextPosition(row, col, 'down-left');\n      const [rr, rc] = nextPosition(row, col, 'down-right');\n      queue.push({ row: lr, col: lc, dir: 'down-left' });\n      queue.push({ row: rr, col: rc, dir: 'down-right' });\n    } else {\n      // Empty or source: continue in same direction\n      const [nr, nc] = nextPosition(row, col, dir);\n      queue.push({ row: nr, col: nc, dir });\n    }\n  }\n\n  return visited.size;\n}\n\n/**\n * Count the total number of distinct source-to-exit paths.\n * Each splitter doubles the number of paths.\n *\n * Instead of enumerating paths (infeasible for large inputs), we propagate\n * a path-count multiplier through the beam simulation. Each cell carries\n * the number of paths that flow through it. When a beam hits a splitter,\n * both child beams inherit the count. The total path count is the sum of\n * counts for all beams that exit the grid.\n */\nexport function countBeamPaths(grid: string[][]): bigint {\n  const rows = grid.length;\n  const cols = grid[0]?.length ?? 0;\n  const [srcRow, srcCol] = findSource(grid);\n\n  // Each entry: beam position + direction + accumulated path count\n  interface WeightedBeam {\n    row: number;\n    col: number;\n    dir: Direction;\n    paths: bigint;\n  }\n\n  let totalExited = 0n;\n\n  // Use a map to accumulate path counts per (row, col, dir) to avoid\n  // re-processing the same state multiple times (handles diamond merges)\n  const pending = new Map<string, bigint>();\n  const initialKey = `${srcRow},${srcCol},down`;\n  pending.set(initialKey, 1n);\n\n  // Process in topological order (beams always move down, so row increases)\n  // We process row by row.\n  // Since all movement increases row by 1, we can process level by level.\n  // Collect all pending beams for the current row, process them, emit children.\n\n  // Simple BFS-like approach with deduplication:\n  // Process states level by level (by row), accumulating counts.\n  const processed = new Map<string, bigint>();\n\n  // Use a queue that processes in order\n  const queue: WeightedBeam[] = [{ row: srcRow, col: srcCol, dir: 'down', paths: 1n }];\n\n  // Accumulator: aggregate incoming path counts before processing a state\n  // to handle multiple beams arriving at the same (row, col, dir)\n  const incoming = new Map<string, bigint>();\n  incoming.set(`${srcRow},${srcCol},down`, 1n);\n\n  // We'll process row by row\n  // Group states by row\n  function stateKey(r: number, c: number, d: Direction): string {\n    return `${r},${c},${d}`;\n  }\n\n  // Use a level-by-level BFS\n  // Current frontier: map of stateKey -> path count\n  let frontier = new Map<string, bigint>();\n  frontier.set(stateKey(srcRow, srcCol, 'down'), 1n);\n\n  while (frontier.size > 0) {\n    const nextFrontier = new Map<string, bigint>();\n\n    for (const [key, pathCount] of frontier) {\n      const [rowStr, colStr, dir] = key.split(',');\n      const row = parseInt(rowStr);\n      const col = parseInt(colStr);\n      const d = dir as Direction;\n\n      if (!inBounds(row, col, rows, cols)) {\n        // Beam exited — count these paths\n        totalExited += pathCount;\n        continue;\n      }\n\n      const cell = grid[row][col];\n\n      if (cell === '^') {\n        // Split\n        for (const splitDir of ['down-left', 'down-right'] as Direction[]) {\n          const [nr, nc] = nextPosition(row, col, splitDir);\n          const nk = stateKey(nr, nc, splitDir);\n          nextFrontier.set(nk, (nextFrontier.get(nk) ?? 0n) + pathCount);\n        }\n      } else {\n 