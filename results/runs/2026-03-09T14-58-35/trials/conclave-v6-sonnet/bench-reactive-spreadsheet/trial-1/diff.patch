+// ─── Types ────────────────────────────────────────────────────────────────────
+
+type CellValue = string | number | boolean | null;
+
+interface CellData {
+  raw: string | number | boolean;   // what was set (formula string or literal)
+  computed: CellValue;              // evaluated result
+  deps: Set<string>;                // cells this cell depends on
+}
+
+// ─── Cell Reference Parsing ───────────────────────────────────────────────────
+
+function normalizeRef(ref: string): string {
+  return ref.toUpperCase();
+}
+
+const CELL_REF_RE = /^([A-Za-z]+)([1-9][0-9]*)$/;
+
+function isValidRef(ref: string): boolean {
+  return CELL_REF_RE.test(ref);
+}
+
+/** Parse a cell ref like "A1" or "AA10" into { col, row } indices (0-based col). */
+function parseRef(ref: string): { col: number; row: number } {
+  const m = CELL_REF_RE.exec(ref);
+  if (!m) throw new Error(`Invalid cell reference: ${ref}`);
+  const colStr = m[1].toUpperCase();
+  const row = parseInt(m[2], 10);
+  let col = 0;
+  for (let i = 0; i < colStr.length; i++) {
+    col = col * 26 + (colStr.charCodeAt(i) - 64);
+  }
+  return { col, row };
+}
+
+/** Encode a { col, row } (1-based col) back to "A1" style. */
+function encodeRef(col: number, row: number): string {
+  let colStr = '';
+  let c = col;
+  while (c > 0) {
+    const rem = (c - 1) % 26;
+    colStr = String.fromCharCode(65 + rem) + colStr;
+    c = Math.floor((c - 1) / 26);
+  }
+  return `${colStr}${row}`;
+}
+
+/** Expand a range string like "A1:C3" to a list of normalized cell refs. */
+function expandRange(range: string): string[] {
+  const parts = range.split(':');
+  if (parts.length !== 2) throw new Error(`Invalid range: ${range}`);
+  const start = parseRef(parts[0].toUpperCase());
+  const end = parseRef(parts[1].toUpperCase());
+
+  const minCol = Math.min(start.col, end.col);
+  const maxCol = Math.max(start.col, end.col);
+  const minRow = Math.min(start.row, end.row);
+  const maxRow = Math.max(start.row, end.row);
+
+  const refs: string[] = [];
+  for (let row = minRow; row <= maxRow; row++) {
+    for (let col = minCol; col <= maxCol; col++) {
+      refs.push(encodeRef(col, row));
+    }
+  }
+  return refs;
+}
+
+// ─── Formula Tokenizer ────────────────────────────────────────────────────────
+
+type TokenType =
+  | 'NUMBER' | 'STRING' | 'BOOLEAN'
+  | 'CELL_REF' | 'RANGE'
+  | 'IDENT'
+  | 'OP' | 'LPAREN' | 'RPAREN' | 'COMMA'
+  | 'EOF';
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+function tokenize(expr: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < expr.length) {
+    // skip whitespace
+    if (/\s/.test(expr[i])) { i++; continue; }
+
+    // string literal "..."
+    if (expr[i] === '"') {
+      let j = i + 1;
+      while (j < expr.length && expr[j] !== '"') j++;
+      tokens.push({ type: 'STRING', value: expr.slice(i + 1, j) });
+      i = j + 1;
+      continue;
+    }
+
+    // number
+    if (/[0-9]/.test(expr[i]) || (expr[i] === '.' && /[0-9]/.test(expr[i + 1] ?? ''))) {
+      let j = i;
+      while (j < expr.length && /[0-9.]/.test(expr[j])) j++;
+      tokens.push({ type: 'NUMBER', value: expr.slice(i, j) });
+      i = j;
+      continue;
+    }
+
+    // identifier, cell ref, range, boolean
+    if (/[A-Za-z]/.test(expr[i])) {
+      let j = i;
+      while (j < expr.length && /[A-Za-z0-9]/.test(expr[j])) j++;
+      const word = expr.slice(i, j);
+
+      // Check for range: WORD:WORD
+      if (expr[j] === ':') {
+        let k = j + 1;
+        while (k < expr.length && /[A-Za-z0-9]/.test(expr[k])) k++;
+        const rangeStr = expr.slice(i, k);
+        tokens.push({ type: 'RANGE', value: rangeStr });
+        i = k;
+        continue;
+      }
+
+      const upper = word.toUpperCase();
+      if (upper === 'TRUE') {
+        tokens.push({ type: 'BOOLEAN', value: 'true' });
+      } else if (upper === 'FALSE') {
+        tokens.push({ type: 'BOOLEAN', value: 'false' });
+      } else if (isValidRef(word) && /[0-9]/.test(word[word.length - 1])) {
+        tokens.push({ type: 'CELL_REF', value: upper });
+      } else {
+        tokens.push({ type: 'IDENT', value: upper });
+      }
+      i = j;
+      continue;
+    }
+
+    // two-char operators
+    const two = expr.slice(i, i + 2);
+    if (two === '>=' || two === '<=' || two === '<>') {
+      tokens.push({ type: 'OP', value: two });
+      i += 2;
+      continue;
+    }
+
+    // single-char operators and punctuation
+    const ch = expr[i];
+    if ('+-*/'.includes(ch)) {
+      tokens.push({ type: 'OP', value: ch });
+    } else if (ch === '>') {
+      tokens.push({ type: 'OP', value: '>' });
+    } else if (ch === '<') {
+      tokens.push({ type: 'OP', value: '<' });
+    } else if (ch === '=') {
+      tokens.push({ type: 'OP', value: '=' });
+    } else if (ch === '(') {
+      tokens.push({ type: 'LPAREN', value: '(' });
+    } else if (ch === ')') {
+      tokens.push({ type: 'RPAREN', value: ')' });
+    } else if (ch === ',') {
+      tokens.push({ type: 'COMMA', value: ',' });
+    } else {
+      throw new Error(`Unexpected character: ${ch}`);
+    }
+    i++;
+  }
+
+  tokens.push({ type: 'EOF', value: '' });
+  return tokens;
+}
+
+// ─── Formula Parser / Evaluator ───────────────────────────────────────────────
+// Recursive descent: handles comparison, addition, multiplication, unary, primary
+
+class FormulaEvaluator {
+  private tokens: Token[];
+  private pos: number;
+  private deps: Set<string>;
+  private getCellValue: (ref: string) => CellValue;
+  private getCellRange: (range: string) => CellValue[];
+
+  constructor(
+    tokens: Token[],
+    getCellValue: (ref: string) => CellValue,
+    getCellRange: (range: string) => CellValue[],
+  ) {
+    this.tokens = tokens;
+    this.pos = 0;
+    this.deps = new Set();
+    this.getCellValue = getCellValue;
+    this.getCellRange = getCellRange;
+  }
+
+  getDeps(): Set<string> { return this.deps; }
+
+  private peek(): Token { return this.tokens[this.pos]; }
+  private consume(): Token { return this.tokens[this.pos++]; }
+
+  private expect(type: TokenType): Token {
+    const t = this.consume();
+    if (t.type !== type) throw new Error(`Expected ${type}, got ${t.type}`);
+    return t;
+  }
+
+  evaluate(): CellValue {
+    const val = this.parseComparison();
+    if (this.peek().type !== 'EOF') {
+      throw new Error(`Unexpected token: ${this.peek().value}`);
+    }
+    return val;
+  }
+
+  private parseComparison(): CellValue {
+    let left = this.parseAddSub();
+    while (this.peek().type === 'OP' && ['>', '<', '>=', '<=', '=', '<>'].includes(this.peek().value)) {
+      const op = this.consume().value;
+      const right = this.parseAddSub();
+      left = this.applyComparison(op, left, right);
+    }
+    return left;
+  }
+
+  private applyComparison(op: string, left: CellValue, right: CellValue): boolean {
+    const l = left as number;
+    const r = right as number;
+    switch (op) {
+      case '>': return l > r;
+      case '<': return l < r;
+      case '>=': return l >= r;
+      case '<=': return l <= r;
+      case '=': return left === right;
+      case '<>': return left !== right;
+      default: throw new Error(`Unknown operator: ${op}`);
+    }
+  }
+
+  private parseAddSub(): CellValue {
+    let left = this.parseMulDiv();
+    while (this.peek().type === 'OP' && (this.peek().value === '+' || this.peek().value === '-')) {
+      const op = this.consume().value;
+      const right = this.parseMulDiv();
+      left = op === '+' ? (left as number) + (right as number) : (left as number) - (right as number);
+    }
+    return left;
+  }
+
+  private parseMulDiv(): CellValue {
+    let left = this.parseUnary();
+    while (this.peek().type === 'OP' && (this.peek().value === '*' || this.peek().value === '/')) {
+      const op = this.consume().value;
+      const right = this.parseUnary();
+      left = op === '*' ? (left as number) * (right as number) : (left as number) / (right as number);
+    }
+    return left;
+  }
+
+  private parseUnary(): CellValue {
+    if (this.peek().type === 'OP' && this.peek().value === '-') {
+      this.consume();
+      return -(this.parsePrimary() as number);
+    }
+    if (this.peek().type === 'OP' && this.peek().value === '+') {
+      this.consume();
+      return this.parsePrimary();
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): CellValue {
+    const t = this.peek();
+
+    if (t.type === 'NUMBER') {
+      this.consume();
+      return parseFloat(t.value);
+    }
+
+    if (t.type === 'STRING') {
+      this.consume();
+      return t.value;
+    }
+
+    if (t.type === 'BOOLEAN') {
+      this.consume();
+      return t.value === 'true';
+    }
+
+    if (t.type === 'CELL_REF') {
+      this.consume();
+      this.deps.add(t.value);
+      return this.getCellValue(t.value) ?? 0;
+    }
+
+    if (t.type === 'LPAREN') {
+      this.consume();
+      const val = this.parseComparison();
+      this.expect('RPAREN');
+      return val;
+    }
+
+    if (t.type === 'IDENT') {
+      return this.parseFunction();
+    }
+
+    throw new Error(`Unexpected token: ${t.type} '${t.value}'`);
+  }
+
+  private parseFunction(): CellValue {
+    const name = this.consume().value; // function name
+    this.expect('LPAREN');
+
+    const args: CellValue[] = [];
+    let rangeRefs: string[] | null = null;
+
+    // special handling: first arg may be a RANGE token for aggregate functions
+    if (['SUM', 'AVERAGE', 'MIN', 'MAX', 'COUNT'].includes(name)) {
+      if (this.peek().type === 'RANGE') {
+        const rangeToken = this.consume();
+        rangeRefs = expandRange(rangeToken.value);
+        rangeRefs.forEach(ref => this.deps.add(ref));
+      }
+      this.expect('RPAREN');
+
+      const nums = rangeRefs
+        ? rangeRefs.map(r => this.getCellValue(r)).filter((v): v is number => typeof v === 'number')
+        : [];
+
+      switch (name) {
+        case 'SUM': return nums.reduce((a, b) => a + b, 0);
+        case 'AVERAGE': return nums.length > 0 ? nums.reduce((a, b) => a + b, 0) / nums.length : 0;
+        case 'MIN': return nums.length > 0 ? Math.min(...nums) : 0;
+        case 'MAX': return nums.length > 0 ? Math.max(...nums) : 0;
+        case 'COUNT': return nums.length;
+      }
+    }
+
+    if (name === 'IF') {
+      // IF(condition, trueVal, falseVal)
+      const condition = this.parseComparison();
+      this.expect('COMMA');
+      const trueVal = this.parseComparison();
+      this.expect('COMMA');
+      const falseVal = this.parseComparison();
+      this.expect('RPAREN');
+      return condition ? trueVal : falseVal;
+    }
+
+    // generic: collect comma-separated args
+    while (this.peek().type !== 'RPAREN' && this.peek().type !== 'EOF') {
+      args.push(this.parseComparison());
+      if (this.peek().type === 'COMMA') this.consume();
+    }
+    this.expect('RPAREN');
+
+    throw new Error(`Unknown function: ${name}`);
+  }
+}
+
+// ─── Spreadsheet ──────────────────────────────────────────────────────────────
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // reverse dep map: for each cell, which cells depend on it
+  private reverseDeps: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = normalizeRef(cell);
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      this.setFormula(ref, value);
+    } else {
+      this.setLiteral(ref, value);
+    }
+  }
+
+  get(cell: string): CellValue {
+    const ref = normalizeRef(cell);
+    return this.cells.get(ref)?.computed ?? null;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computed);
+    }
+    return result;
+  }
+
+  // ── Private ──────────────────────────────────────────────────────────────────
+
+  private setLiteral(ref: string, value: string | number | boolean): void {
+    // Remove old reverse-dep entries
+    this.removeReverseDeps(ref);
+
+    this.cells.set(ref, {
+      raw: value,
+      computed: value,
+      deps: new Set(),
+    });
+
+    this.propagate(ref);
+  }
+
+  private setFormula(ref: string, formula: string): void {
+    // Evaluate to discover deps
+    const { computed, deps } = this.evalFormula(formula.slice(1), ref);
+
+    // Circular reference check: ref must not appear in deps (transitively)
+    this.checkCircular(ref, deps);
+
+    // Remove old reverse-dep entries
+    this.removeReverseDeps(ref);
+
+    this.cells.set(ref, { raw: formula, computed, deps });
+
+    // Register new reverse deps
+    for (const dep of deps) {
+      if (!this.reverseDeps.has(dep)) this.reverseDeps.set(dep, new Set());
+      this.reverseDeps.get(dep)!.add(ref);
+    }
+
+    this.propagate(ref);
+  }
+
+  private evalFormula(expr: string, _selfRef?: string): { computed: CellValue; deps: Set<string> } {
+    const tokens = tokenize(expr);
+    const evaluator = new FormulaEvaluator(
+      tokens,
+      (r) => this.cells.get(r)?.computed ?? null,
+      (range) => expandRange(range).map(r => this.cells.get(r)?.computed ?? null),
+    );
+    const computed = evaluator.evaluate();
+    return { computed, deps: evaluator.getDeps() };
+  }
+
+  private checkCircular(ref: string, newDeps: Set<string>): void {
+    // DFS: if ref is reachable from any of its new deps, it's circular
+    const visited = new Set<string>();
+    const stack = [...newDeps];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === ref) {
+        throw new Error(`Circular reference detected involving ${ref}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      const data = this.cells.get(current);
+      if (data) {
+        for (const dep of data.deps) {
+          stack.push(dep);
+        }
+      }
+    }
+  }
+
+  private removeReverseDeps(ref: string): void {
+    const old = this.cells.get(ref);
+    if (!old) return;
+    for (const dep of old.deps) {
+      this.reverseDeps.get(dep)?.delete(ref);
+    }
+  }
+
+  /** Propagate value changes to all transitive dependents using topological order. */
+  private propagate(changedRef: string): void {
+    // BFS/topological through reverse deps
+    const visited = new Set<string>();
+    const queue: string[] = [];
+
+    // Find all cells that depend on changedRef
+    const enqueue = (r: string) => {
+      const rdeps = this.reverseDeps.get(r);
+      if (!rdeps) return;
+      for (const dep of rdeps) {
+        if (!visited.has(dep)) {
+          visited.add(dep);
+          queue.push(dep);
+        }
+      }
+    };
+
+    enqueue(changedRef);
+
+    for (let i = 0; i < queue.length; i++) {
+      const r = queue[i];
+      const data = this.cells.get(r);
+      if (!data) continue;
+
+      if (typeof data.raw === 'string' && data.raw.startsWith('=')) {
+        const { computed, deps } = this.evalFormula(data.raw.slice(1));
+        // Update reverse deps if deps changed
+        this.removeReverseDeps(r);
+        for (const dep of deps) {
+          if (!this.reverseDeps.has(dep)) this.reverseDeps.set(dep, new Set());
+          this.reverseDeps.get(dep)!.add(r);
+        }
+        data.computed = computed;
+        data.deps = deps;
+      }
+
+      // Propagate further
+      enqueue(r);
+    }
+  }
+}
