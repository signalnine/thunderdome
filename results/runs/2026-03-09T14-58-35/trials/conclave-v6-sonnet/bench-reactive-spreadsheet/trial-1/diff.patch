eet.get('B1')).toBe(0);\n  });\n});\n\ndescribe('IF function', () => {\n  it('returns trueValue when condition is true', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 50);\n    sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n    expect(sheet.get('B1')).toBe('big');\n  });\n\n  it('returns falseValue when condition is false', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n    expect(sheet.get('B1')).toBe('small');\n  });\n\n  it('handles equality comparison in IF', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('B1', '=IF(A1=5, \"yes\", \"no\")');\n    expect(sheet.get('B1')).toBe('yes');\n  });\n\n  it('handles not-equal comparison in IF', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('B1', '=IF(A1<>5, \"yes\", \"no\")');\n    expect(sheet.get('B1')).toBe('no');\n  });\n\n  it('handles >= comparison in IF', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('B1', '=IF(A1>=5, \"yes\", \"no\")');\n    expect(sheet.get('B1')).toBe('yes');\n  });\n\n  it('handles <= comparison in IF', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 4);\n    sheet.set('B1', '=IF(A1<=5, \"yes\", \"no\")');\n    expect(sheet.get('B1')).toBe('yes');\n  });\n\n  it('handles numeric trueValue and falseValue', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('B1', '=IF(A1>5, 100, 0)');\n    expect(sheet.get('B1')).toBe(100);\n  });\n});\n\n// ─── Reactive Updates ─────────────────────────────────────────────────────────\n\ndescribe('reactive updates', () => {\n  it('updates dependent cell when dependency changes', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('B1', '=A1+1');\n    expect(sheet.get('B1')).toBe(6);\n\n    sheet.set('A1', 10);\n    expect(sheet.get('B1')).toBe(11);\n  