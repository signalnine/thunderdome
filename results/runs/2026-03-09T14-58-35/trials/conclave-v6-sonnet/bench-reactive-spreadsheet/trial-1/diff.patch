CellRange: (range: string) => CellValue[],\n  ) {\n    this.tokens = tokens;\n    this.pos = 0;\n    this.deps = new Set();\n    this.getCellValue = getCellValue;\n    this.getCellRange = getCellRange;\n  }\n\n  getDeps(): Set<string> { return this.deps; }\n\n  private peek(): Token { return this.tokens[this.pos]; }\n  private consume(): Token { return this.tokens[this.pos++]; }\n\n  private expect(type: TokenType): Token {\n    const t = this.consume();\n    if (t.type !== type) throw new Error(`Expected ${type}, got ${t.type}`);\n    return t;\n  }\n\n  evaluate(): CellValue {\n    const val = this.parseComparison();\n    if (this.peek().type !== 'EOF') {\n      throw new Error(`Unexpected token: ${this.peek().value}`);\n    }\n    return val;\n  }\n\n  private parseComparison(): CellValue {\n    let left = this.parseAddSub();\n    while (this.peek().type === 'OP' && ['>', '<', '>=', '<=', '=', '<>'].includes(this.peek().value)) {\n      const op = this.consume().value;\n      const right = this.parseAddSub();\n      left = this.applyComparison(op, left, right);\n    }\n    return left;\n  }\n\n  private applyComparison(op: string, left: CellValue, right: CellValue): boolean {\n    const l = left as number;\n    const r = right as number;\n    switch (op) {\n      case '>': return l > r;\n      case '<': return l < r;\n      case '>=': return l >= r;\n      case '<=': return l <= r;\n      case '=': return left === right;\n      case '<>': return left !== right;\n      default: throw new Error(`Unknown operator: ${op}`);\n    }\n  }\n\n  private parseAddSub(): CellValue {\n    let left = this.parseMulDiv();\n    while (this.peek().type === 'OP' && (this.peek().value === '+' || this.peek().value === '-')) {\n      const op = this.consume().value;\n      const right = this.parseMulDiv();\n      left = op === '+' ? (left as number) + (right as number) : (left as number) - (right as number);\n    }\n    return left;\n  }\n\n  private parseMulDiv(): CellValue {\n    let left = this.parseUnary();\n    while (this.peek().type === 'OP' && (this.peek().value === '*' || this.peek().value === '/')) {\n      const op = this.consume().value;\n      const right = this.parseUnary();\n      left = op === '*' ? (left as number) * (right as number) : (left as number) / (right as number);\n    }\n    return left;\n  }\n\n  private parseUnary(): CellValue {\n    if (this.peek().type === 'OP' && this.peek().value === '-') {\n      this.consume();\n      return -(this.parsePrimary() as number);\n    }\n    if (this.peek().type === 'OP' && this.peek().value === '+') {\n      this.consume();\n      return this.parsePrimary();\n    }\n    return this.parsePrimary();\n  }\n\n  private parsePrimary(): CellValue {\n    const t = this.peek();\n\n    if (t.type === 'NUMBER') {\n      this.consume();\n      return parseFloat(t.value);\n    }\n\n    if (t.type === 'STRING') {\n      this.consume();\n      return t.value;\n    }\n\n    if (t.type === 'BOOLEAN') {\n      this.consume();\n      return t.value === 'true';\n    }\n\n    if (t.type === 'CELL_REF') {\n      this.consume();\n      this.deps.add(t.value);\n      return this.getCellValue(t.value) ?? 0;\n    }\n\n    if (t.type === 'LPAREN') {\n      this.consume();\n      const val = this.parseComparison();\n      this.expect('RPAREN');\n      return val;\n    }\n\n    if (t.type === 'IDENT') {\n      return this.parseFunction();\n    }\n\n    throw new Error(`Unexpected token: ${t.type} '${t.value}'`);\n  }\n\n  private parseFunction(): CellValue {\n    const name = this.consume().value; // function name\n    this.expect('LPAREN');\n\n    const args: CellValue[] = [];\n    let rangeRefs: string[] | null = null;\n\n    // special handling: first arg may be a RANGE token for aggregate functions\n    if (['SUM', 'AVERAGE', 'MIN', 'MAX', 'COUNT'].includes(name)) {\n      if (this.peek().type === 'RANGE') {\n        const rangeToken = this.consume();\n        rangeRefs = expandRange(rangeToken.value);\n