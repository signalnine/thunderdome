'A5', 5);\n    sheet.set('B1', '=SUM(A1:A5)');\n    expect(sheet.get('B1')).toBe(15);\n  });\n\n  it('ignores non-numeric values in range', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 1);\n    sheet.set('A2', 'hello');\n    sheet.set('A3', 3);\n    sheet.set('B1', '=SUM(A1:A3)');\n    expect(sheet.get('B1')).toBe(4);\n  });\n\n  it('returns 0 for an empty range', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('B1', '=SUM(A1:A3)');\n    expect(sheet.get('B1')).toBe(0);\n  });\n});\n\ndescribe('AVERAGE function', () => {\n  it('computes average of numeric values in range', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 20);\n    sheet.set('A3', 30);\n    sheet.set('B1', '=AVERAGE(A1:A3)');\n    expect(sheet.get('B1')).toBe(20);\n  });\n\n  it('ignores non-numeric values when averaging', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 'text');\n    sheet.set('A3', 30);\n    sheet.set('B1', '=AVERAGE(A1:A3)');\n    expect(sheet.get('B1')).toBe(20);\n  });\n});\n\ndescribe('MIN function', () => {\n  it('returns minimum numeric value in range', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('A2', 2);\n    sheet.set('A3', 8);\n    sheet.set('B1', '=MIN(A1:A3)');\n    expect(sheet.get('B1')).toBe(2);\n  });\n});\n\ndescribe('MAX function', () => {\n  it('returns maximum numeric value in range', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('A2', 2);\n    sheet.set('A3', 8);\n    sheet.set('B1', '=MAX(A1:A3)');\n    expect(sheet.get('B1')).toBe(8);\n  });\n});\n\ndescribe('COUNT function', () => {\n  it('counts numeric values in range', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 1);\n    sheet.set('A2', 'text');\n    sheet.set('A3', 3);\n    sheet.set('A4', true);\n    sheet.set('B1', '=COUNT(A1:A4)');\n    expect(sheet.get('B1')).toBe(2);\n  });\n\n  it('returns 0 for empty range', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('B1', '=COUNT(A1:A3)');\n    expect(sheet.get('B1')).toBe(0);\n  });\n});\n\ndescribe('IF function', () => {\n  it('returns trueValue when condition is true', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 50);\n    sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n    expect(sheet.get('B1')).toBe('big');\n  });\n\n  it('returns falseValue when condition is false', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n    expect(sheet.get('B1')).toBe('small');\n  });\n\n  it('handles equality comparison in IF', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('B1', '=IF(A1=5, \"yes\", \"no\")');\n    expect(sheet.get('B1')).toBe('yes');\n  });\n\n  it('handles not-equal comparison in IF', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('B1', '=IF(A1<>5, \"yes\", \"no\")');\n    expect(sheet.get('B1')).toBe('no');\n  });\n\n  it('handles >= comparison in IF', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('B1', '=IF(A1>=5, \"yes\", \"no\")');\n    expect(sheet.get('B1')).toBe('yes');\n  });\n\n  it('handles <= comparison in IF', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 4);\n    sheet.set('B1', '=IF(A1<=5, \"yes\", \"no\")');\n    expect(sheet.get('B1')).toBe('yes');\n  });\n\n  it('handles numeric trueValue and falseValue', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('B1', '=IF(A1>5, 100, 0)');\n    expect(sheet.get('B1')).toBe(100);\n  });\n});\n\n// ─── Reactive Updates ─────────────────────────────────────────────────────────\n\ndescribe('reactive updates', () => {\n  it('updates dependent cell when dependency changes', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('B1', '=A1+1');\n    expect(sheet.get('B1')).toBe(6);\n\n    sheet.set('A1', 10);\n    expect(sheet.get('B1')).toBe(11);\n  });\n\n  it('updates transitively dependent cells', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 1);\n    sheet.set('B1', '=A1+1');\n    sheet.set('C1', '=B1+1');\n    expect(sheet.get('C1')).toBe(3);\n\n    sheet.set('A1', 10);\n    expect(sheet.get('B1')).toBe(11);\n    expect(sheet.get('C1')).toBe(12);\n  });\n\n  it('updates SUM formula when a range cell changes', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 20);\n    sheet.set('B1', '=SUM(A1:A2)');\n    expect(sheet.get('B1')).toBe(30);\n\n    sheet.set('A1', 50);\n    expect(sheet.get('B1')).toBe(70);\n  });\n\n  it('updates multiple dependents when one cell changes', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('B1', '=A1*2');\n    sheet.set('C1', '=A1*3');\n    expect(sheet.get('B1')).toBe(10);\n    expect(sheet.get('C1')).toBe(15);\n\n    sheet.set('A1', 10);\n    expect(sheet.get('B1')).toBe(20);\n    expect(sheet.get('C1')).toBe(30);\n  });\n\n  it('recomputes IF result when referenced cell changes', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 50);\n    sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n    expect(sheet.get('B1')).toBe('big');\n\n    sheet.set('A1', 10);\n    expect(sheet.get('B1')).toBe('small');\n  });\n});\n\n// ─── Circular Reference Detection ────────────────────────────────────────────\n\ndescribe('circular reference detection', () => {\n  it('throws when setting a direct self-reference', () => {\n    const sheet = new Spreadsheet();\n    expect(() => sheet.set('A1', '=A1')).toThrow();\n  });\n\n  it('throws when setting a direct circular reference A1->B1->A1', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=B1+1');\n    expect(() => sheet.set('B1', '=A1+1')).toThrow();\n  });\n\n  it('throws when setting an indirect circular reference', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=B1+1');\n    sheet.set('B1', '=C1+1');\n    expect(() => sheet.set('C1', '=A1+1')).toThrow();\n  });\n\n  it('does not modify cell state when circular reference is detected', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=B1+1');\n    sheet.set('B1', 5);\n    expect(() => sheet.set('B1', '=A1+1')).toThrow();\n    // B1 should retain its previous value\n    expect(sheet.get('B1')).toBe(5);\n  });\n});\n\n// ─── getDisplay ───────────────────────────────────────────────────────────────\n\ndescribe('getDisplay', () => {\n  it('displays number as string', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 42);\n    expect(sheet.getDisplay('A1')).toBe('42');\n  });\n\n  it('displays float as string', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 3.14);\n    expect(sheet.getDisplay('A1')).toBe('3.14');\n  });\n\n  it('displays string value', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 'hello');\n    expect(sheet.getDisplay('A1')).toBe('hello');\n  });\n\n  it('displays boolean true', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', true);\n    expect(sheet.getDisplay('A1')).toBe('true');\n  });\n\n  it('displays boolean false', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', false);\n    expect(sheet.getDisplay('A1')).toBe('false');\n  });\n\n  it('displays empty cell as empty string', () => {\n    const sheet = new Spreadsheet();\n    expect(sheet.getDisplay('A1')).toBe('');\n  });\n\n  it('displays computed formula result', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 20);\n    sheet.set('A3', '=A1+A2');\n    expect(sheet.getDisplay('A3')).toBe('30');\n  });\n});\n\n// ─── getCells ─────────────────────────────────────────────────────────────────\n\ndescribe('getCells', () => {\n  it('returns empty map when no cells set', () => {\n    const sheet = new Spreadsheet();\n    expect(sheet.getCells().size).toBe(0);\n  });\n\n  it('returns all set cells', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('B2', 'hello');\n    const cells = sheet.getCells();\n    expect(cells.size).toBe(2);\n    expect(cells.get('A1')).toBe(10);\n    expect(cells.get('B2')).toBe('hello');\n  });\n\n  it('returns computed values for formula cells', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 20);\n    sheet.set('A3', '=A1+A2');\n    const cells = sheet.getCells();\n    expect(cells.get('A3')).toBe(30);\n  });\n\n  it('keys are normalized to uppercase', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('a1', 42);\n    const cells = sheet.getCells();\n    expect(cells.has('A1')).toBe(true);\n  });\n});\n\n// ─── End-to-end example from spec ─────────────────────────────────────────────\n\ndescribe('end-to-end spec example', () => {\n  it('matches the spec example behavior', () => {\n    const sheet = new Spreadsheet();\n\n    sheet.set('A1', 10);\n    sheet.set('A2', 20);\n    sheet.set('A3', '=A1+A2');\n    expect(sheet.get('A3')).toBe(30);\n    expect(sheet.getDisplay('A3')).toBe('30');\n\n    sheet.set('A1', 50);\n    expect(sheet.get('A3')).toBe(70);\n\n    sheet.set('B1', '=SUM(A1:A2)');\n    expect(sheet.get('B1')).toBe(70);\n\n    sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n    expect(sheet.get('C1')).toBe('big');\n  });\n});\n","structuredPatch":[],"originalFile":null}}
