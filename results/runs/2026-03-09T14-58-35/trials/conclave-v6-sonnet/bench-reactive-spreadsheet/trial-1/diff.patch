'hello');\n  });\n\n  it('stores and retrieves boolean true', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', true);\n    expect(sheet.get('A1')).toBe(true);\n  });\n\n  it('stores and retrieves boolean false', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', false);\n    expect(sheet.get('A1')).toBe(false);\n  });\n\n  it('returns null for empty cells', () => {\n    const sheet = new Spreadsheet();\n    expect(sheet.get('A1')).toBeNull();\n  });\n\n  it('can update a cell value', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A1', 20);\n    expect(sheet.get('A1')).toBe(20);\n  });\n});\n\n// ─── Formula Arithmetic ───────────────────────────────────────────────────────\n\ndescribe('formula arithmetic', () => {\n  it('evaluates a literal number formula', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=5');\n    expect(sheet.get('A1')).toBe(5);\n  });\n\n  it('evaluates addition of two literals', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=2+3');\n    expect(sheet.get('A1')).toBe(5);\n  });\n\n  it('evaluates subtraction', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=10-3');\n    expect(sheet.get('A1')).toBe(7);\n  });\n\n  it('evaluates multiplication', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=4*5');\n    expect(sheet.get('A1')).toBe(20);\n  });\n\n  it('evaluates division', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=10/4');\n    expect(sheet.get('A1')).toBe(2.5);\n  });\n\n  it('evaluates expression with parentheses', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=(2+3)*4');\n    expect(sheet.get('A1')).toBe(20);\n  });\n\n  it('evaluates a formula referencing a cell', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('B1', '=A1');\n    expect(sheet.get('B1')).toBe(10);\n  });\n\n  it('evaluates a formula ref