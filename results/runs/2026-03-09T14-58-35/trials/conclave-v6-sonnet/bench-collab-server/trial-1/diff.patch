index 0000000..afc3ae7
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,87 @@
+export type InsertOp = { type: 'insert'; pos: number; text: string };
+export type DeleteOp = { type: 'delete'; pos: number; length: number };
+export type Operation = InsertOp | DeleteOp;
+
+export function applyOp(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const pos = Math.min(op.pos, doc.length);
+    return doc.slice(0, pos) + op.text + doc.slice(pos);
+  } else {
+    const pos = Math.min(op.pos, doc.length);
+    const end = Math.min(pos + op.length, doc.length);
+    return doc.slice(0, pos) + doc.slice(end);
+  }
+}
+
+/**
+ * transform(clientOp, serverOp) → [clientOp', serverOp']
+ * Returns the transformed client op to apply after serverOp has already been applied.
+ * Uses server-wins tiebreaking for concurrent inserts at same position.
+ */
+export function transform(clientOp: Operation, serverOp: Operation): [Operation, Operation] {
+  if (clientOp.type === 'insert' && serverOp.type === 'insert') {
+    // server insert is already applied; shift client insert if needed
+    // server wins tiebreak: if same pos, server goes first → client shifts right
+    if (serverOp.pos <= clientOp.pos) {
+      return [
+        { ...clientOp, pos: clientOp.pos + serverOp.text.length },
+        serverOp,
+      ];
+    }
+    return [clientOp, serverOp];
+  }
+
+  if (clientOp.type === 'insert' && serverOp.type === 'delete') {
+    if (serverOp.pos + serverOp.length <= clientOp.pos) {
+      // server delete entirely before client insert
+      return [{ ...clientOp, pos: clientOp.pos - serverOp.length }, serverOp];
+    } else if (serverOp.pos >= clientOp.pos) {
+      // server delete entirely after (or at) client insert position
+      return [clientOp, serverOp];
+    } else {
+      // client insert is within deleted range → move to start of deleted region
+      return [{ ...clientOp, pos: serverOp.pos }, serverOp];
+    }
+  }
+
+  if (clientOp.type === 'delete' && serverOp.type === 'insert') {
+    if (serverOp.pos <= clientOp.pos) {
+      // server insert before or at client delete start → shift client delete right
+      return [{ ...clientOp, pos: clientOp.pos + serverOp.text.length }, serverOp];
+    } else if (serverOp.pos >= clientOp.pos + clientOp.length) {
+      // server insert after client delete → no change
+      return [clientOp, serverOp];
+    } else {
+      // server insert inside client delete range → extend client delete
+      return [{ ...clientOp, length: clientOp.length + serverOp.text.length }, serverOp];
+    }
+  }
+
+  // Both deletes
+  if (clientOp.type === 'delete' && serverOp.type === 'delete') {
+    const cStart = clientOp.pos;
+    const cEnd = clientOp.pos + clientOp.length;
+    const sStart = serverOp.pos;
+    const sEnd = serverOp.pos + serverOp.length;
+
+    if (sEnd <= cStart) {
+      // server delete entirely before client delete
+      return [{ ...clientOp, pos: clientOp.pos - serverOp.length }, serverOp];
+    } else if (sStart >= cEnd) {
+      // server delete entirely after client delete
+      return [clientOp, serverOp];
+    } else {
+      // overlapping deletes
+      // chars deleted by server that fall before client range
+      const deletedBeforeClient = Math.max(0, Math.min(sEnd, cStart) - sStart);
+      // overlap between client and server delete ranges
+      const overlapStart = Math.max(cStart, sStart);
+      const overlapEnd = Math.min(cEnd, sEnd);
+      const overlap = Math.max(0, overlapEnd - overlapStart);
+      const newLength = Math.max(0, clientOp.length - overlap);
+      return [{ ...clientOp, pos: cStart - deletedBeforeClient, length: newLength }, serverOp];
+    }
+  }
+
+  return [clientOp, serverOp];
+}
