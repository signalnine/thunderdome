beforeEach, afterEach } from 'vitest';\nimport { WebSocket } from 'ws';\nimport { createApp } from '../src/server.js';\n\ntype AppInstance = ReturnType<typeof createApp>;\n\nlet appInstance: AppInstance;\nlet port: number;\nlet baseUrl: string;\n\nasync function createDoc(title: string, content: string): Promise<{ id: string; version: number }> {\n  const res = await fetch(`${baseUrl}/documents`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ title, content }),\n  });\n  return res.json() as Promise<{ id: string; version: number }>;\n}\n\nasync function getDoc(id: string): Promise<{ content: string; version: number }> {\n  const res = await fetch(`${baseUrl}/documents/${id}`);\n  return res.json() as Promise<{ content: string; version: number }>;\n}\n\nasync function getHistory(id: string): Promise<Array<{ version: number }>> {\n  const res = await fetch(`${baseUrl}/documents/${id}/history`);\n  return res.json() as Promise<Array<{ version: number }>>;\n}\n\nfunction wsConnect(docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}`);\n    ws.once('open', () => resolve(ws));\n    ws.once('error', reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    ws.once('message', (data) => {\n      try {\n        resolve(JSON.parse(data.toString()) as Record<string, unknown>);\n      } catch (e) {\n        reject(e);\n      }\n    });\n    ws.once('error', reject);\n  });\n}\n\nbeforeEach(async () => {\n  appInstance = createApp(':memory:');\n  port = await appInstance.start(0);\n  baseUrl = `http://localhost:${port}`;\n});\n\nafterEach(async () => {\n  await appInstance.stop();\n});\n\ndescribe('WebSocket sync', () => {\n  it('sends sync message on connect', async () => {\n    const doc = await createDoc('Test', 'hello');\n    const ws = await wsConnect(doc.id);\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    ws.close();\n  });\n\n  it('rejects connection for nonexistent document', async () => {\n    await new Promise<void>((resolve) => {\n      const ws = new WebSocket(`ws://localhost:${port}/ws/nonexistent`);\n      ws.once('close', () => resolve());\n      ws.once('error', () => resolve());\n    });\n  });\n});\n\ndescribe('WebSocket operations', () => {\n  it('applies insert and sends ack', async () => {\n    const doc = await createDoc('T', 'hello');\n    const ws = await wsConnect(doc.id);\n    await waitForMessage(ws); // sync\n\n    const ackPromise = waitForMessage(ws);\n    ws.send(JSON.stringify({\n      type: 'op',\n      version: 1,\n      op: { type: 'insert', pos: 5, text: ' world' },\n    }));\n    const ack = await ackPromise;\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(2);\n\n    const updated = await getDoc(doc.id);\n    expect(updated.content).toBe('hello world');\n    ws.close();\n  });\n\n  it('applies delete and sends ack', async () => {\n    const doc = await createDoc('T', 'hello world');\n    const ws = await wsConnect(doc.id);\n    await waitForMessage(ws); // sync\n\n    const ackPromise = waitForMessage(ws);\n    ws.send(JSON.stringify({\n      type: 'op',\n      version: 1,\n      op: { type: 'delete', pos: 5, length: 6 },\n    }));\n    const ack = await ackPromise;\n    expect(ack.type).toBe('ack');\n\n    const updated = await getDoc(doc.id);\n    expect(updated.content).toBe('hello');\n    ws.close();\n  });\n\n  it('broadcasts op to other clients', async () => {\n    const doc = await createDoc('T', 'hello');\n    const ws1 = await wsConnect(doc.id);\n    const ws2 = await wsConnect(doc.id);\n\n    await waitForMessage(ws1); // sync\n    await waitForMessage(ws2); // sync\n\n    const broadcastPromise = waitForMessage(ws2);\n    ws1.send(JSON.stringify({\n      type: 'op',\n      version: 1,\n      op: { type: 'insert', pos: 5, text: '!' },\n    }));\n\n    const broadcast = await broadcastPromise;\n    expect(broadcast.type).toBe('op');\n    expect((broadcast.op as { text: string }).text).toBe('!');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('does not broadcast to sender', async () => {\n    const doc = await createDoc('T', 'hello');\n    const ws = await wsConnect(doc.id);\n    await waitForMessage(ws); // sync\n\n    const ackPromise = waitForMessage(ws);\n    ws.send(JSON.stringify({\n      type: 'op',\n      version: 1,\n      op: { type: 'insert', pos: 0, text: 'X' },\n    }));\n    const ack = await ackPromise;\n    // Should receive ack, not a broadcast of own op\n    expect(ack.type).toBe('ack');\n    ws.close();\n  });\n\n  it('rejects invalid op type', async () => {\n    const doc = await createDoc('T', 'hi');\n    const ws = await wsConnect(doc.id);\n    await waitForMessage(ws); // sync\n\n    const errPromise = waitForMessage(ws);\n    ws.send(JSON.stringify({ type: 'op', version: 1, op: { type: 'bad_op' } }));\n    const err = await errPromise;\n    expect(err.type).toBe('error');\n    ws.close();\n  });\n\n  it('rejects malformed JSON', async () => {\n    const doc = await createDoc('T', 'hi');\n    const ws = await wsConnect(doc.id);\n    await waitForMessage(ws); // sync\n\n    const errPromise = waitForMessage(ws);\n    ws.send('not json');\n    const err = await errPromise;\n    expect(err.type).toBe('error');\n    ws.close();\n  });\n\n  it('rejects op message without version field', async () => {\n    const doc = await createDoc('T', 'hi');\n    const ws = await wsConnect(doc.id);\n    await waitForMessage(ws); // sync\n\n    const errPromise = waitForMessage(ws);\n    ws.send(JSON.stringify({ type: 'op', op: { type: 'insert', pos: 0, text: 'X' } }));\n    const err = await errPromise;\n    expect(err.type).toBe('error');\n    ws.close();\n  });\n});\n\ndescribe('Concurrent edits convergence', () => {\n  it('two simultaneous inserts both preserved', async () => {\n    const doc = await createDoc('T', 'hello');\n    const docId = doc.id;\n\n    const ws1 = await wsConnect(docId);\n    const ws2 = await wsConnect(docId);\n    await waitForMessage(ws1); // sync v1\n    await waitForMessage(ws2); // sync v1\n\n    // ws1 inserts 'A' at pos 0 → 'Ahello'\n    // ws2 inserts 'B' at pos 5 → 'helloB' (concurrent, also at version 1)\n    // After OT: both preserved\n\n    const ack1Promise = waitForMessage(ws1);\n    ws1.send(JSON.stringify({ type: 'op', version: 1, op: { type: 'insert', pos: 0, text: 'A' } }));\n    const ack1 = await ack1Promise;\n    expect(ack1.type).toBe('ack');\n\n    // ws2 sends its op (concurrent with ws1's at version 1)\n    // ws2 may first receive broadcast of ws1's op, ignore it and wait for own ack\n    const ws2Messages: Record<string, unknown>[] = [];\n    const ws2DonePromise = new Promise<void>((resolve) => {\n      const handler = (data: Buffer) => {\n        const msg = JSON.parse(data.toString()) as Record<string, unknown>;\n        ws2Messages.push(msg);\n        if (msg.type === 'ack' || ws2Messages.length >= 2) {\n          ws2.off('message', handler);\n          resolve();\n        }\n      };\n      ws2.on('message', handler);\n      ws2.send(JSON.stringify({ type: 'op', version: 1, op: { type: 'insert', pos: 5, text: 'B' } }));\n    });\n    await ws2DonePromise;\n\n    await new Promise(r => setTimeout(r, 100));\n\n    const final = await getDoc(docId);\n    const content = final.content;\n    expect(content).toContain('A');\n    expect(content).toContain('B');\n    expect(content).toContain('hello');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('handles 10 concurrent clients without corruption', async () => {\n    const doc = await createDoc('Stress', '');\n    const docId = doc.id;\n\n    const clients = await Promise.all(\n      Array.from({ length: 10 }, () => wsConnect(docId))\n    );\n\n    // Wait for all sync messages\n    await Promise.all(clients.map(ws => waitForMessage(ws)));\n\n    // Each client inserts a unique character at pos 0 based on version 1\n    const chars = 'ABCDEFGHIJ';\n    await Promise.all(\n      clients.map((ws, i) => {\n        ws.send(JSON.stringify({\n          type: 'op',\n          version: 1,\n          op: { type: 'insert', pos: 0, text: chars[i] },\n        }));\n        return Promise.resolve();\n      })\n    );\n\n    // Wait for all ops to settle\n    await new Promise(r => setTimeout(r, 1000));\n\n    const final = await getDoc(docId);\n    const content = final.content;\n\n    // All 10 characters must appear in the document\n    for (const ch of chars) {\n      expect(content).toContain(ch);\n    }\n    // Document should have exactly 10 characters\n    expect(content.length).toBe(10);\n\n    clients.forEach(ws => ws.close());\n  });\n\n  it('version history tracks all operations', async () => {\n    const doc = await createDoc('T', 'hello');\n    const docId = doc.id;\n\n    const ws = await wsConnect(docId);\n    await waitForMessage(ws); // sync\n\n    const ack1Promise = waitForMessage(ws);\n    ws.send(JSON.stringify({ type: 'op', version: 1, op: { type: 'insert', pos: 5, text: ' world' } }));\n    await ack1Promise;\n\n    const ack2Promise = waitForMessage(ws);\n    ws.send(JSON.stringify({ type: 'op', version: 2, op: { type: 'insert', pos: 11, text: '!' } }));\n    await ack2Promise;\n\n    const history = await getHistory(docId);\n    expect(history).toHaveLength(3);\n    expect(history[0].version).toBe(1);\n    expect(history[1].version).toBe(2);\n    expect(history[2].version).toBe(3);\n\n    ws.close();\n  });\n});\n"}}
