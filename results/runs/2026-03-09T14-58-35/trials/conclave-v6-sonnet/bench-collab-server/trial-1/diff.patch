ffer) => {\n        msgs.push(JSON.parse(data.toString()) as Record<string, unknown>);\n        count++;\n        if (count >= 1) {\n          ws2.off('message', handler);\n          resolve();\n        }\n      };\n      ws2.on('message', handler);\n      ws2.send(JSON.stringify({ type: 'op', version: 1, op: { type: 'insert', pos: 5, text: 'B' } }));\n    });\n\n    // Wait a bit for all ops to settle\n    await new Promise(r => setTimeout(r, 100));\n\n    const final = await request(appInstance.app).get(`/documents/${docId}`);\n    const content = final.body.content as string;\n    // Both 'A' and 'B' must appear, 'hello' must appear\n    expect(content).toContain('A');\n    expect(content).toContain('B');\n    expect(content).toContain('hello');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('handles 10 concurrent clients without corruption', async () => {\n    const doc = await request(appInstance.app)\n      .post('/documents')\n      .send({ title: 'Stress', content: '' });\n    const docId = doc.body.id as string;\n\n    const clients = await Promise.all(\n      Array.from({ length: 10 }, () => wsConnect(docId))\n    );\n\n    // Wait for all sync messages\n    await Promise.all(clients.map(ws => waitForMessage(ws)));\n\n    // Each client inserts a unique character at pos 0 based on version 1\n    const chars = 'ABCDEFGHIJ';\n    await Promise.all(\n      clients.map((ws, i) => {\n        ws.send(JSON.stringify({\n          type: 'op',\n          version: 1,\n          op: { type: 'insert', pos: 0, text: chars[i] },\n        }));\n        return Promise.resolve();\n      })\n    );\n\n    // Wait for all ops to be processed\n    await new Promise(r => setTimeout(r, 1000));\n\n    const final = await request(appInstance.app).get(`/documents/${docId}`);\n    const content = final.body.content as string;\n\n    // All 10 characters should be in the final document\n    for (const ch of chars) {\n      expect(content).toContain(ch);\n    }\n    // Document should have exactly 10 characters\n    expect(content.length).toBe(10);\n\n    clients.forEach(ws => ws.close());\n  });\n\n  it('version history tracks all operations', async () => {\n    const doc = await request(appInstance.app)\n      .post('/documents')\n      .send({ title: 'T', content: 'hello' });\n    const docId = doc.body.id as string;\n\n    const ws = await wsConnect(docId);\n    await waitForMessage(ws); // sync\n\n    const ack1Promise = waitForMessage(ws);\n    ws.send(JSON.stringify({ type: 'op', version: 1, op: { type: 'insert', pos: 5, text: ' world' } }));\n    await ack1Promise;\n\n    const ack2Promise = waitForMessage(ws);\n    ws.send(JSON.stringify({ type: 'op', version: 2, op: { type: 'insert', pos: 11, text: '!' } }));\n    await ack2Promise;\n\n    const history = await request(appInstance.app).get(`/documents/${docId}/history`);\n    expect(history.body).toHaveLength(3);\n    expect(history.body[0].version).toBe(1);\n    expect(history.body[1].version).toBe(2);\n    expect(history.body[2].version).toBe(3);\n\n    ws.close();\n  });\n});\n"}}
