@@ -0,0 +1,78 @@
+import { describe, it, expect } from 'vitest';
+import { transform, applyOp, type Operation } from '../src/ot.js';
+
+describe('applyOp', () => {
+  it('applies insert at position 0', () => {
+    expect(applyOp('hello', { type: 'insert', pos: 0, text: 'say ' })).toBe('say hello');
+  });
+
+  it('applies insert at end', () => {
+    expect(applyOp('hello', { type: 'insert', pos: 5, text: '!' })).toBe('hello!');
+  });
+
+  it('applies delete', () => {
+    expect(applyOp('hello world', { type: 'delete', pos: 5, length: 6 })).toBe('hello');
+  });
+
+  it('applies delete at position 0', () => {
+    expect(applyOp('hello', { type: 'delete', pos: 0, length: 2 })).toBe('llo');
+  });
+});
+
+describe('transform', () => {
+  it('transforms concurrent inserts at same position (server wins tiebreak)', () => {
+    const opA: Operation = { type: 'insert', pos: 3, text: 'X' };
+    const opB: Operation = { type: 'insert', pos: 3, text: 'Y' };
+    // A is server-applied; transform B against A
+    const [bPrime] = transform(opB, opA);
+    // After A inserts 'X' at 3, B should insert at 4
+    expect(bPrime).toEqual({ type: 'insert', pos: 4, text: 'Y' });
+  });
+
+  it('transforms insert against prior insert before it', () => {
+    const opA: Operation = { type: 'insert', pos: 1, text: 'XY' };
+    const opB: Operation = { type: 'insert', pos: 5, text: 'Z' };
+    const [bPrime] = transform(opB, opA);
+    expect(bPrime).toEqual({ type: 'insert', pos: 7, text: 'Z' });
+  });
+
+  it('transforms insert against prior insert after it (no shift)', () => {
+    const opA: Operation = { type: 'insert', pos: 5, text: 'XY' };
+    const opB: Operation = { type: 'insert', pos: 2, text: 'Z' };
+    const [bPrime] = transform(opB, opA);
+    expect(bPrime).toEqual({ type: 'insert', pos: 2, text: 'Z' });
+  });
+
+  it('transforms insert against delete before it', () => {
+    const opA: Operation = { type: 'delete', pos: 0, length: 3 };
+    const opB: Operation = { type: 'insert', pos: 5, text: 'X' };
+    const [bPrime] = transform(opB, opA);
+    expect(bPrime).toEqual({ type: 'insert', pos: 2, text: 'X' });
+  });
+
+  it('transforms delete against insert before it', () => {
+    const opA: Operation = { type: 'insert', pos: 0, text: 'XY' };
+    const opB: Operation = { type: 'delete', pos: 3, length: 2 };
+    const [bPrime] = transform(opB, opA);
+    expect(bPrime).toEqual({ type: 'delete', pos: 5, length: 2 });
+  });
+
+  it('transforms concurrent deletes at same range (idempotent)', () => {
+    const opA: Operation = { type: 'delete', pos: 2, length: 3 };
+    const opB: Operation = { type: 'delete', pos: 2, length: 3 };
+    const [bPrime] = transform(opB, opA);
+    // After A deletes chars 2-4, B's delete covers same range → noop (length 0)
+    expect(bPrime).toEqual({ type: 'delete', pos: 2, length: 0 });
+  });
+
+  it('handles delete overlapping with prior delete', () => {
+    // opA deletes chars 2-4 (length 3), opB deletes chars 0-3 (length 4)
+    const opA: Operation = { type: 'delete', pos: 2, length: 3 };
+    const opB: Operation = { type: 'delete', pos: 0, length: 4 };
+    const [bPrime] = transform(opB, opA);
+    // opB originally covers 0-3; opA removed 2-4
+    // The overlap is 2-3 (2 chars removed by A from B's range)
+    // B's remaining range: 0-1 (length 2)
+    expect(bPrime).toEqual({ type: 'delete', pos: 0, length: 2 });
+  });
+});
