m({ length: 10 }, () => wsConnect(port, docId))\n      );\n\n      // Wait for all sync messages\n      await Promise.all(clients.map(ws => waitForMessage(ws)));\n\n      // Each client inserts a unique character at pos 0 based on version 1\n      const chars = 'ABCDEFGHIJ';\n      await Promise.all(\n        clients.map((ws, i) => {\n          ws.send(JSON.stringify({\n            type: 'op',\n            version: 1,\n            op: { type: 'insert', pos: 0, text: chars[i] },\n          }));\n          return Promise.resolve();\n        })\n      );\n\n      // Wait for all ops to settle\n      await new Promise(r => setTimeout(r, 1000));\n\n      const final = await getDoc(baseUrl, docId);\n      const content = final.content;\n\n      // All 10 characters must appear in the document\n      for (const ch of chars) {\n        expect(content).toContain(ch);\n      }\n      // Document should have exactly 10 characters\n      expect(content.length).toBe(10);\n\n      clients.forEach(ws => ws.close());\n    } finally {\n      await app.stop();\n    }\n  });\n\n  it('version history tracks all operations', async () => {\n    const { app, port, baseUrl } = await setup();\n    try {\n      const doc = await createDoc(baseUrl, 'T', 'hello');\n      const docId = doc.id;\n\n      const ws = await wsConnect(port, docId);\n      await waitForMessage(ws); // sync\n\n      const ack1Promise = waitForMessage(ws);\n      ws.send(JSON.stringify({ type: 'op', version: 1, op: { type: 'insert', pos: 5, text: ' world' } }));\n      await ack1Promise;\n\n      const ack2Promise = waitForMessage(ws);\n      ws.send(JSON.stringify({ type: 'op', version: 2, op: { type: 'insert', pos: 11, text: '!' } }));\n      await ack2Promise;\n\n      const history = await getHistory(baseUrl, docId);\n      expect(history).toHaveLength(3);\n      expect(history[0].version).toBe(1);\n      expect(history[1].version).toBe(2);\n      expect(history[2].version).toBe(3);\n\n      ws.close();\n    } finally {\n      await app.stop();\n    }\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":14,"newStart":1,"newLines":20,"lines":["-import { describe, it, expect, beforeEach, afterEach } from 'vitest';","+import { describe, it, expect } from 'vitest';"," import { WebSocket } from 'ws';"," import { createApp } from '../src/server.js';"," "," type AppInstance = ReturnType<typeof createApp>;"," ","-let appInstance: AppInstance;","-let port: number;","-let baseUrl: string;","+async function setup(): Promise<{ app: AppInstance; port: number; baseUrl: string }> {","+  const app = createApp(':memory:');","+  const port = await app.start(0);","+  return { app, port, baseUrl: `http://localhost:${port}` };","+}"," ","-async function createDoc(title: string, content: string): Promise<{ id: string; version: number }> {","+async function createDoc(","+  baseUrl: string,","+  title: string,","+  content: string","+): Promise<{ id: string; version: number }> {","   const res = await fetch(`${baseUrl}/documents`, {","     method: 'POST',","     headers: { 'Content-Type': 'application/json' },"]},{"oldStart":17,"oldLines":17,"newStart":23,"newLines":23,"lines":["   return res.json() as Promise<{ id: string; version: number }>;"," }"," ","-async function getDoc(id: string): Promise<{ content: string; version: number }> {","+async function getDoc(","+  baseUrl: string,","+  id: string","+): Promise<{ content: string; version: number }> {","   const res = await fetch(`${baseUrl}/documents/${id}`);","   return res.json() as Promise<{ content: string; version: number }>;"," }"," ","-async function getHistory(id: string): Promise<Array<{ version: number }>> {","+async function getHistory(","+  baseUrl: string,","+  id: string","+): Promise<Array<{ version: number }>> {","   const res = await fetch(`${baseUrl}/documents/${id}/history`);","   return res.json() as Promise<Array<{ version: number }>>;"," }"," ","-function wsConnect(docId: string): Promise<WebSocket> {","+function wsConne