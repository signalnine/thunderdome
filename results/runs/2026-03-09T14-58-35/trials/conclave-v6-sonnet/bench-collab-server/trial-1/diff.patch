+{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_018o3J91W9rpdy3wMC187BnT","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01SxiJLBmmLk8LpU7toScnCq","name":"Write","input":{"file_path":"/workspace/tests/documents.test.ts","content":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport { initDb } from '../src/db.js';\nimport {\n  createDocument,\n  getDocument,\n  listDocuments,\n  updateDocument,\n  deleteDocument,\n  getVersionHistory,\n} from '../src/documents.js';\nimport type Database from 'better-sqlite3';\n\nlet db: Database.Database;\n\nbeforeEach(() => {\n  db = initDb(':memory:');\n});\n\nafterEach(() => {\n  db.close();\n});\n\ndescribe('createDocument', () => {\n  it('creates a document and returns it', () => {\n    const doc = createDocument(db, 'My Doc', 'Hello world');\n    expect(doc.id).toBeTruthy();\n    expect(doc.title).toBe('My Doc');\n    expect(doc.content).toBe('Hello world');\n    expect(doc.version).toBe(1);\n  });\n\n  it('creates a document with empty content by default', () => {\n    const doc = createDocument(db, 'Empty', '');\n    expect(doc.content).toBe('');\n  });\n});\n\ndescribe('getDocument', () => {\n  it('returns null for nonexistent document', () => {\n    expect(getDocument(db, 'nonexistent')).toBeNull();\n  });\n\n  it('returns the document', () => {\n    const created = createDocument(db, 'Test', 'content');\n    const fetched = getDocument(db, created.id);\n    expect(fetched?.id).toBe(created.id);\n    expect(fetched?.title).toBe('Test');\n  });\n});\n\ndescribe('listDocuments', () => {\n  it('returns empty array when no documents', () => {\n    expect(listDocuments(db)).toEqual([]);\n  });\n\n  it('lists all documents', () => {\n    createDocument(db, 'A', '');\n    createDocument(db, 'B', '');\n    const docs = listDocuments(db);\n    expect(docs).toHaveLength(2);\n  });\n});\n\ndescribe('updateDocument', () => {\n  it('updates content and increments version', () => {\n    const doc = createDocument(db, 'Doc', 'hello');\n    const updated = updateDocument(db, doc.id, 'hello world', { type: 'insert', pos: 5, text: ' world' });\n    expect(updated?.content).toBe('hello world');\n    expect(updated?.version).toBe(2);\n  });\n\n  it('returns null for nonexistent document', () => {\n    const result = updateDocument(db, 'missing', 'x', { type: 'insert', pos: 0, text: 'x' });\n    expect(result).toBeNull();\n  });\n});\n\ndescribe('deleteDocument', () => {\n  it('deletes a document', () => {\n    const doc = createDocument(db, 'Doc', 'hello');\n    deleteDocument(db, doc.id);\n    expect(getDocument(db, doc.id)).toBeNull();\n  });\n\n  it('returns false for nonexistent document', () => {\n    expect(deleteDocument(db, 'missing')).toBe(false);\n  });\n});\n\ndescribe('getVersionHistory', () => {\n  it('returns version history', () => {\n    const doc = createDocument(db, 'Doc', 'hello');\n    updateDocument(db, doc.id, 'hello world', { type: 'insert', pos: 5, text: ' world' });\n    const history = getVersionHistory(db, doc.id);\n    expect(history).toHaveLength(2);\n    expect(history[0].version).toBe(1);\n    expect(history[1].version).toBe(2);\n    expect(history[1].content).toBe('hello world');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1034,"cache_read_input_tokens":47467,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1034},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9afc7e8f-bb6c-44d5-b274-f24facf40226","uuid":"0ff5df66-15d3-4d11-9c2e-2f3db4c4079d"}
