+import { EventBus } from '../bus.js';
+import { Events, NotificationService, OrderCreatedEvent, OrderStatusChangedEvent, PaymentProcessedEvent } from '../types.js';
+
+type Notification = { type: string; message: string; timestamp: number };
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  const notifications = new Map<string, Notification[]>();
+  const orderToUser = new Map<string, string>(); // orderId -> userId
+
+  bus.on(Events.ORDER_CREATED, (payload) => {
+    const event = payload as OrderCreatedEvent;
+    orderToUser.set(event.orderId, event.userId);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, (payload) => {
+    const event = payload as OrderStatusChangedEvent;
+    const userId = orderToUser.get(event.orderId);
+    if (!userId) return;
+    const userNotifs = notifications.get(userId);
+    if (!userNotifs) return;
+    userNotifs.push({
+      type: 'order_status_changed',
+      message: `Order ${event.orderId} status changed to ${event.status}`,
+      timestamp: Date.now(),
+    });
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload) => {
+    const event = payload as PaymentProcessedEvent;
+    const userId = orderToUser.get(event.orderId);
+    if (!userId) return;
+    const userNotifs = notifications.get(userId);
+    if (!userNotifs) return;
+    userNotifs.push({
+      type: 'payment_processed',
+      message: `Payment for order ${event.orderId}: ${event.status}`,
+      timestamp: Date.now(),
+    });
+  });
+
+  return {
+    subscribe(userId: string): void {
+      if (!notifications.has(userId)) {
+        notifications.set(userId, []);
+      }
+    },
+
+    getNotifications(userId: string): Array<{ type: string; message: string; timestamp: number }> {
+      return notifications.get(userId) ?? [];
+    },
+  };
+}
