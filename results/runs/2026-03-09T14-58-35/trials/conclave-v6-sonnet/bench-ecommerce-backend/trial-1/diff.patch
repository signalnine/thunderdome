+import { v4 as uuidv4 } from 'uuid';
+import { EventBus } from '../bus.js';
+import { Events, PaymentProcessedEvent, PaymentService, PaymentStatus } from '../types.js';
+
+type PaymentOptions = {
+  outcome?: 'success' | 'failure' | 'timeout';
+};
+
+export function createPaymentService(bus: EventBus, options: PaymentOptions = {}): PaymentService {
+  const successfulTransactions = new Map<string, { orderId: string; amount: number }>();
+
+  async function simulateOutcome(orderId: string): Promise<{ status: PaymentStatus; transactionId?: string; error?: string }> {
+    const outcome = options.outcome ?? 'success';
+
+    if (outcome === 'timeout') {
+      const payload: PaymentProcessedEvent = { orderId, status: PaymentStatus.TIMEOUT };
+      await bus.emit(Events.PAYMENT_PROCESSED, payload);
+      return { status: PaymentStatus.TIMEOUT };
+    }
+
+    if (outcome === 'failure') {
+      const payload: PaymentProcessedEvent = { orderId, status: PaymentStatus.FAILED, error: 'Payment declined' };
+      await bus.emit(Events.PAYMENT_PROCESSED, payload);
+      return { status: PaymentStatus.FAILED, error: 'Payment declined' };
+    }
+
+    // success
+    const transactionId = uuidv4();
+    return { status: PaymentStatus.SUCCESS, transactionId };
+  }
+
+  return {
+    async processPayment(orderId: string, amount: number): Promise<{ status: PaymentStatus; transactionId?: string; error?: string }> {
+      const result = await simulateOutcome(orderId);
+
+      if (result.status === PaymentStatus.SUCCESS && result.transactionId) {
+        successfulTransactions.set(result.transactionId, { orderId, amount });
+        const payload: PaymentProcessedEvent = { orderId, status: PaymentStatus.SUCCESS, transactionId: result.transactionId };
+        await bus.emit(Events.PAYMENT_PROCESSED, payload);
+      }
+
+      return result;
+    },
+
+    async refund(transactionId: string): Promise<boolean> {
+      if (!successfulTransactions.has(transactionId)) return false;
+      successfulTransactions.delete(transactionId);
+      return true;
+    },
+  };
+}
