@@ -0,0 +1,48 @@
+import { v4 as uuidv4 } from 'uuid';
+import { EventBus } from '../bus.js';
+import { CartService } from '../types.js';
+
+type Cart = { id: string; userId: string; items: Map<string, number> };
+
+export function createCartService(_bus: EventBus): CartService {
+  const carts = new Map<string, Cart>();
+
+  function toItems(itemsMap: Map<string, number>) {
+    return Array.from(itemsMap.entries()).map(([productId, quantity]) => ({ productId, quantity }));
+  }
+
+  return {
+    createCart(userId: string): string {
+      const id = uuidv4();
+      carts.set(id, { id, userId, items: new Map() });
+      return id;
+    },
+
+    addItem(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      const existing = cart.items.get(productId) ?? 0;
+      cart.items.set(productId, existing + quantity);
+    },
+
+    removeItem(cartId: string, productId: string): void {
+      carts.get(cartId)?.items.delete(productId);
+    },
+
+    getCart(cartId: string) {
+      const cart = carts.get(cartId);
+      if (!cart) return null;
+      return { id: cart.id, userId: cart.userId, items: toItems(cart.items) };
+    },
+
+    clearCart(cartId: string): void {
+      carts.get(cartId)?.items.clear();
+    },
+
+    updateQuantity(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.set(productId, quantity);
+    },
+  };
+}
