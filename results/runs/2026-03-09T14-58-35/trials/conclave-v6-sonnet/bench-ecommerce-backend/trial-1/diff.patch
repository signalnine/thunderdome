@@ -0,0 +1,47 @@
+import { EventBus } from '../bus.js';
+import { Events, InventoryService, LowStockAlertEvent } from '../types.js';
+
+export function createInventoryService(bus: EventBus): InventoryService {
+  const stock = new Map<string, number>();
+  const thresholds = new Map<string, number>();
+
+  function currentStock(productId: string): number {
+    return stock.get(productId) ?? 0;
+  }
+
+  async function checkLowStock(productId: string): Promise<void> {
+    const threshold = thresholds.get(productId);
+    if (threshold === undefined) return;
+    const qty = currentStock(productId);
+    if (qty < threshold) {
+      const payload: LowStockAlertEvent = { productId, currentQuantity: qty, threshold };
+      await bus.emit(Events.LOW_STOCK_ALERT, payload);
+    }
+  }
+
+  return {
+    setStock(productId: string, quantity: number): void {
+      stock.set(productId, quantity);
+    },
+
+    getStock(productId: string): number {
+      return currentStock(productId);
+    },
+
+    reserve(productId: string, quantity: number): boolean {
+      const available = currentStock(productId);
+      if (available < quantity) return false;
+      stock.set(productId, available - quantity);
+      checkLowStock(productId);
+      return true;
+    },
+
+    release(productId: string, quantity: number): void {
+      stock.set(productId, currentStock(productId) + quantity);
+    },
+
+    setLowStockThreshold(productId: string, threshold: number): void {
+      thresholds.set(productId, threshold);
+    },
+  };
+}
