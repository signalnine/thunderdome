s[0]).toMatchObject({ productId: 'p1', currentQuantity: 4, threshold: 5 });\n  });\n\n  it('does not emit low stock alert when stock stays above threshold', async () => {\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, (p) => alerts.push(p));\n\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 3);\n    await inventory.reserve('p1', 5);\n    await new Promise((r) => setTimeout(r, 0));\n\n    expect(alerts).toHaveLength(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":627,"cache_read_input_tokens":32881,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":627},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c29c5eb4-6e68-4dbc-8163-444da618dcde","uuid":"dc199cf2-18ed-4ee2-a543-e75bc2b27aa7"}
