+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { createCatalogService } from './index.js';
+import { Events } from '../types.js';
+
+describe('CatalogService', () => {
+  let bus: EventBus;
+  let catalog: ReturnType<typeof createCatalogService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    catalog = createCatalogService(bus);
+  });
+
+  it('creates a product and returns a unique id', () => {
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    expect(typeof id).toBe('string');
+    expect(id.length).toBeGreaterThan(0);
+  });
+
+  it('creates products with unique ids', () => {
+    const id1 = catalog.createProduct('A', 1, 'cat');
+    const id2 = catalog.createProduct('B', 2, 'cat');
+    expect(id1).not.toBe(id2);
+  });
+
+  it('emits product:created event when product is created', async () => {
+    const events: unknown[] = [];
+    bus.on(Events.PRODUCT_CREATED, (payload) => { events.push(payload); });
+
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    await new Promise<void>((r) => { setTimeout(r, 0); });
+
+    expect(events).toHaveLength(1);
+    expect(events[0]).toMatchObject({ productId: id, name: 'Widget', price: 9.99, category: 'tools' });
+  });
+
+  it('retrieves a product by id', () => {
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    const product = catalog.getProduct(id);
+    expect(product).toMatchObject({ id, name: 'Widget', price: 9.99, category: 'tools' });
+  });
+
+  it('returns null for unknown product id', () => {
+    expect(catalog.getProduct('nonexistent')).toBeNull();
+  });
+
+  it('lists all products', () => {
+    catalog.createProduct('A', 1, 'cat1');
+    catalog.createProduct('B', 2, 'cat2');
+    const all = catalog.listProducts();
+    expect(all).toHaveLength(2);
+  });
+
+  it('lists products filtered by category', () => {
+    catalog.createProduct('A', 1, 'tools');
+    catalog.createProduct('B', 2, 'books');
+    catalog.createProduct('C', 3, 'tools');
+    const tools = catalog.listProducts('tools');
+    expect(tools).toHaveLength(2);
+    expect(tools.every((p) => p.category === 'tools')).toBe(true);
+  });
+
+  it('searches products by name substring (case insensitive)', () => {
+    catalog.createProduct('Blue Widget', 5, 'tools');
+    catalog.createProduct('Red Gadget', 10, 'tools');
+    const results = catalog.searchProducts('widget');
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('Blue Widget');
+  });
+
+  it('updates product fields', () => {
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    catalog.updateProduct(id, { price: 19.99, name: 'Super Widget' });
+    const product = catalog.getProduct(id);
+    expect(product?.price).toBe(19.99);
+    expect(product?.name).toBe('Super Widget');
+    expect(product?.category).toBe('tools');
+  });
+
+  it('removes a product and returns true', () => {
+    const id = catalog.createProduct('Widget', 9.99, 'tools');
+    const removed = catalog.removeProduct(id);
+    expect(removed).toBe(true);
+    expect(catalog.getProduct(id)).toBeNull();
+  });
+
+  it('returns false when removing nonexistent product', () => {
+    expect(catalog.removeProduct('nonexistent')).toBe(false);
+  });
+});
