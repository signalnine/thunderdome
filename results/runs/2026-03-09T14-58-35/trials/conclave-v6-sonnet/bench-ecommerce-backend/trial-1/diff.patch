+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { createCartService } from './index.js';
+
+describe('CartService', () => {
+  let bus: EventBus;
+  let cart: ReturnType<typeof createCartService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    cart = createCartService(bus);
+  });
+
+  it('creates a cart and returns a unique id', () => {
+    const id = cart.createCart('user1');
+    expect(typeof id).toBe('string');
+    expect(id.length).toBeGreaterThan(0);
+  });
+
+  it('creates carts with unique ids', () => {
+    const id1 = cart.createCart('user1');
+    const id2 = cart.createCart('user2');
+    expect(id1).not.toBe(id2);
+  });
+
+  it('retrieves a cart by id', () => {
+    const id = cart.createCart('user1');
+    const c = cart.getCart(id);
+    expect(c).toMatchObject({ id, userId: 'user1', items: [] });
+  });
+
+  it('returns null for unknown cart', () => {
+    expect(cart.getCart('nonexistent')).toBeNull();
+  });
+
+  it('adds an item to a cart', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    const c = cart.getCart(id);
+    expect(c?.items).toHaveLength(1);
+    expect(c?.items[0]).toMatchObject({ productId: 'p1', quantity: 2 });
+  });
+
+  it('consolidates same product when added multiple times', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.addItem(id, 'p1', 3);
+    const c = cart.getCart(id);
+    expect(c?.items).toHaveLength(1);
+    expect(c?.items[0]).toMatchObject({ productId: 'p1', quantity: 5 });
+  });
+
+  it('removes an item from a cart', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.removeItem(id, 'p1');
+    const c = cart.getCart(id);
+    expect(c?.items).toHaveLength(0);
+  });
+
+  it('updates quantity of an item', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.updateQuantity(id, 'p1', 10);
+    const c = cart.getCart(id);
+    expect(c?.items[0].quantity).toBe(10);
+  });
+
+  it('clears all items from a cart', () => {
+    const id = cart.createCart('user1');
+    cart.addItem(id, 'p1', 2);
+    cart.addItem(id, 'p2', 1);
+    cart.clearCart(id);
+    const c = cart.getCart(id);
+    expect(c?.items).toHaveLength(0);
+  });
+});
