+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../bus.js';
+import { createAnalyticsService } from './index.js';
+import { Events, PaymentStatus } from '../types.js';
+
+describe('AnalyticsService', () => {
+  let bus: EventBus;
+  let analytics: ReturnType<typeof createAnalyticsService>;
+
+  beforeEach(() => {
+    bus = new EventBus();
+    analytics = createAnalyticsService(bus);
+  });
+
+  it('returns 0 count for untracked event', () => {
+    expect(analytics.getEventCount('nonexistent')).toBe(0);
+  });
+
+  it('counts events by type', async () => {
+    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'A', price: 10, category: 'cat' });
+    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'B', price: 20, category: 'cat' });
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 10 });
+
+    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);
+    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);
+  });
+
+  it('tracks revenue from successful payments', async () => {
+    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'tx1' });
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 99.99 });
+    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'err' });
+
+    expect(analytics.getRevenue()).toBeCloseTo(99.99);
+  });
+
+  it('returns 0 revenue when no successful payments', () => {
+    expect(analytics.getRevenue()).toBe(0);
+  });
+
+  it('calculates conversion rate as orders / unique carts', async () => {
+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });
+    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 50 });
+
+    expect(analytics.getConversionRate()).toBeCloseTo(0.5);
+  });
+
+  it('returns 0 conversion rate when no carts', () => {
+    expect(analytics.getConversionRate()).toBe(0);
+  });
+
+  it('returns top products by order quantity', async () => {
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 10 });
+    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [{ productId: 'p1', quantity: 3 }, { productId: 'p2', quantity: 1 }] });
+
+    await bus.emit(Events.ORDER_CREATED, { orderId: 'o2', userId: 'u1', cartId: 'c2', total: 20 });
+    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u1', items: [{ productId: 'p1', quantity: 2 }] });
+
+    const top = analytics.getTopProducts(2);
+    expect(top[0].productId).toBe('p1');
+    expect(top[0].count).toBe(5);
+    expect(top[1].productId).toBe('p2');
+    expect(top[1].count).toBe(1);
+  });
+});
diff --git a/src/analytics/index.ts b/src/analytics/index.ts
new file mode 100644
index 0000000..23dd4fc
--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,110 @@
+import { EventBus } from '../bus.js';
+import {
+  AnalyticsService,
+  CartUpdatedEvent,
+  Events,
+  OrderCreatedEvent,
+  PaymentProcessedEvent,
+  PaymentStatus,
+} from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let revenue = 0;
+  const uniqueCartIds = new Set<string>();
+  let orderCount = 0;
+  const productCounts = new Map<string, number>(); // productId -> total quantity ordered
+
+  // Track data needed for deferred attribution
+  const orderTotals = new Map<string, number>(); // orderId -> total
+  const orderCartIds = new Map<string, string>(); // orderId -> cartId
+  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>(); // cartId -> items
+  const pendingPayments = new Set<string>(); // orderId for successful payments waiting for order data
+  const processedOrders = new Set<string>(); // orderId where product attribution is done
+
+  function trackEvent(eventType: string): void {
+    eventCounts.set(eventType, (eventCounts.get(eventType) ?? 0) + 1);
+  }
+
+  // Listen to all known events for counting
+  const allEvents = Object.values(Events);
+  for (const eventName of allEvents) {
+    bus.on(eventName, () => trackEvent(eventName));
+  }
+
+  function tryAttributeProducts(orderId: string): void {
+    if (processedOrders.has(orderId)) return;
+    const cartId = orderCartIds.get(orderId);
+    if (cartId === undefined) return;
+    const items = cartItems.get(cartId);
+    if (items === undefined) return;
+    processedOrders.add(orderId);
+    for (const item of items) {
+      productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);
+    }
+  }
+
+  function tryAttributeRevenue(orderId: string): void {
+    if (!pendingPayments.has(orderId)) return;
+    const total = orderTotals.get(orderId);
+    if (total === undefined) return;
+    pendingPayments.delete(orderId);
+    revenue += total;
+  }
+
+  bus.on(Events.CART_UPDATED, (payload) => {
+    const event = payload as CartUpdatedEvent;
+    uniqueCartIds.add(event.cartId);
+    cartItems.set(event.cartId, event.items);
+    // Try to attribute products for any orders referencing this cart
+    for (const [orderId, cartId] of orderCartIds.entries()) {
+      if (cartId === event.cartId) {
+        tryAttributeProducts(orderId);
+      }
+    }
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload) => {
+    const event = payload as OrderCreatedEvent;
+    orderCount++;
+    orderTotals.set(event.orderId, event.total);
+    orderCartIds.set(event.orderId, event.cartId);
+    tryAttributeProducts(event.orderId);
+    tryAttributeRevenue(event.orderId);
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload) => {
+    const event = payload as PaymentProcessedEvent;
+    if (event.status === PaymentStatus.SUCCESS) {
+      const total = orderTotals.get(event.orderId);
+      if (total !== undefined) {
+        revenue += total;
+      } else {
+        // Payment came before order - defer revenue attribution
+        pendingPayments.add(event.orderId);
+      }
+    }
+  });
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) ?? 0;
+    },
+
+    getRevenue(): number {
+      return revenue;
+    },
+
+    getConversionRate(): number {
+      if (uniqueCartIds.size === 0) return 0;
+      return orderCount / uniqueCartIds.size;
+    },
+
+    getTopProducts(limit: number): Array<{ productId: string; count: number }> {
+      return Array.from(productCounts.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
