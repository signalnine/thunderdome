CHANGED, (p) => events.push(p));\n\n    const id = orders.createOrder('user1', 'cart1', 50);\n    await new Promise((r) => setTimeout(r, 0));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise((r) => setTimeout(r, 0));\n\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CONFIRMED);\n    expect(events).toHaveLength(1);\n    expect(events[0]).toMatchObject({\n      orderId: id,\n      status: OrderStatus.CONFIRMED,\n      previousStatus: OrderStatus.PENDING,\n    });\n  });\n\n  it('lists orders for a user', () => {\n    orders.createOrder('user1', 'cart1', 10);\n    orders.createOrder('user1', 'cart2', 20);\n    orders.createOrder('user2', 'cart3', 30);\n    const user1Orders = orders.listOrders('user1');\n    expect(user1Orders).toHaveLength(2);\n  });\n\n  it('can cancel an order', async () => {\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    await new Promise((r) => setTimeout(r, 0));\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CANCELLED);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":844,"cache_read_input_tokens":35300,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":844},"output_tokens":22,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c29c5eb4-6e68-4dbc-8163-444da618dcde","uuid":"0b01a06b-d07c-425c-b95b-ce8c5ad6a38f"}
