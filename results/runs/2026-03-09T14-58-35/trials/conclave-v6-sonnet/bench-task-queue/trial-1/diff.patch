+describe('Phase 5: Retry with Backoff', () => {
+  let system: TaskQueueSystem;
+
+  beforeEach(() => {
+    system = new TaskQueueSystem();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('completeTask marks task completed', () => {
+    const t = system.addTask('job');
+    system.getNextTask();
+    system.completeTask(t.id);
+    expect(system.getTask(t.id)!.status).toBe('completed');
+  });
+
+  it('failTask re-queues with backoff when retries remain', () => {
+    const t = system.addTask('job', { maxRetries: 3, baseDelay: 1000 });
+    system.getNextTask(); // attempt 1
+    system.failTask(t.id);
+    // Should be back to pending with backoff
+    expect(system.getTask(t.id)!.status).toBe('pending');
+    // backoff = 1000 * 2^0 = 1000ms
+    expect(system.getNextTask()).toBeNull(); // not yet available
+    vi.advanceTimersByTime(1001);
+    expect(system.getNextTask()).not.toBeNull();
+  });
+
+  it('exponential backoff doubles each attempt', () => {
+    const t = system.addTask('job', { maxRetries: 3, baseDelay: 1000 });
+    // attempt 1
+    system.getNextTask();
+    system.failTask(t.id);
+    // backoff = 1000ms; advance past it
+    vi.advanceTimersByTime(1001);
+    // attempt 2
+    system.getNextTask();
+    system.failTask(t.id);
+    // backoff = 2000ms
+    expect(system.getNextTask()).toBeNull();
+    vi.advanceTimersByTime(2001);
+    expect(system.getNextTask()).not.toBeNull();
