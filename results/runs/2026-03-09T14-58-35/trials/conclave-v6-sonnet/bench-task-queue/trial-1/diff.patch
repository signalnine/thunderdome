@@ -0,0 +1,81 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../index.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let system: TaskQueueSystem;
+
+  beforeEach(() => {
+    system = new TaskQueueSystem();
+  });
+
+  it('shutdown completes immediately when no tasks are processing', async () => {
+    const summary = await system.shutdown();
+    expect(summary.completed).toBe(0);
+    expect(summary.forceCancelled).toBe(0);
+    expect(typeof summary.durationMs).toBe('number');
+    expect(summary.durationMs).toBeGreaterThanOrEqual(0);
+  });
+
+  it('after shutdown, adding tasks throws', async () => {
+    await system.shutdown();
+    expect(() => system.addTask('x')).toThrow();
+  });
+
+  it('calling shutdown multiple times returns the same promise result', async () => {
+    const r1 = system.shutdown();
+    const r2 = system.shutdown();
+    const [s1, s2] = await Promise.all([r1, r2]);
+    expect(s1).toBe(s2);
+  });
+
+  it('onShutdown callbacks are called during shutdown', async () => {
+    const called: boolean[] = [];
+    system.onShutdown(() => {
+      called.push(true);
+    });
+    await system.shutdown();
+    expect(called).toHaveLength(1);
+  });
+
+  it('async onShutdown callbacks are awaited', async () => {
+    const called: boolean[] = [];
+    system.onShutdown(async () => {
+      await new Promise(r => setTimeout(r, 10));
+      called.push(true);
+    });
+    await system.shutdown();
+    expect(called).toHaveLength(1);
+  });
+
+  it('processing tasks that complete within timeout are counted as completed', async () => {
+    const t = system.addTask('job');
+    system.getNextTask();
+    // Complete the task shortly after shutdown starts
+    const completeTimer = setTimeout(() => system.completeTask(t.id), 10);
+    const summary = await system.shutdown(5000);
+    clearTimeout(completeTimer);
+    expect(summary.completed).toBe(1);
+    expect(summary.forceCancelled).toBe(0);
+  });
+
+  it('processing tasks force-cancelled after timeout expires', async () => {
+    system.addTask('job');
+    system.getNextTask(); // starts processing, never completes
+    const summary = await system.shutdown(100); // short timeout
+    expect(summary.forceCancelled).toBe(1);
+  });
+
+  it('shutdown summary has a durationMs field', async () => {
+    const summary = await system.shutdown();
+    expect(typeof summary.durationMs).toBe('number');
+  });
+
+  it('multiple callbacks all run', async () => {
+    const log: number[] = [];
+    system.onShutdown(() => { log.push(1); });
+    system.onShutdown(() => { log.push(2); });
+    system.onShutdown(() => { log.push(3); });
+    await system.shutdown();
+    expect(log).toEqual([1, 2, 3]);
+  });
+});
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..e426506
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,72 @@
+export type TaskStatus =
+  | 'pending'
+  | 'processing'
+  | 'completed'
+  | 'failed'
+  | 'cancelled'
+  | 'dead-lettered';
+
+export interface TaskOptions {
+  priority?: number;
+  delayMs?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  baseDelay?: number;
+  dependsOn?: string[];
+  queue?: string;
+}
+
+export interface ProgressInfo {
+  percent: number;
+  message?: string;
+}
+
+export interface TaskData<T = unknown> {
+  id: string;
+  queueName: string;
+  payload: T;
+  status: TaskStatus;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  baseDelay: number;
+  dependsOn: string[];
+  delayed: boolean;
+  error?: Error;
+  progress?: ProgressInfo;
+  completedAt?: Date;
+  failedAt?: Date;
+  cancelledAt?: Date;
+}
+
+export type MiddlewareFn<T = unknown> = (
+  task: TaskData<T>,
+  next: () => Promise<void>
+) => Promise<void>;
+
+export type HandlerFn<T = unknown> = (task: TaskData<T>) => Promise<void>;
+
+export type ProgressListener = (info: ProgressInfo) => void;
+
+export interface ShutdownSummary {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
+
+export interface ScheduleOptions {
+  id?: string;
+  cron: string;
+  queueName: string;
+  payload: unknown;
+}
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queueName: string;
+  payload: unknown;
+  lastRunAt?: Date;
+}
