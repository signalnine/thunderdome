+// src/tests/phase-11.test.ts
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../index.js';
+
+describe('Phase 11: Middleware', () => {
+  let system: TaskQueueSystem;
+
+  beforeEach(() => { system = new TaskQueueSystem(); });
+
+  it('middleware runs before handler', async () => {
+    const order: string[] = [];
+    system.use('default', async (task, next) => {
+      order.push('middleware');
+      await next();
+    });
+    system.setHandler('default', async () => {
+      order.push('handler');
+    });
+    const t = system.addTask('job');
+    system.getNextTask();
+    await system.processTask(t.id);
+    expect(order).toEqual(['middleware', 'handler']);
+  });
+
+  it('middleware can skip handler by not calling next', async () => {
+    const handlerCalled: boolean[] = [];
+    system.use('default', async (_task, _next) => {
+      // don't call next
+    });
+    system.setHandler('default', async () => {
+      handlerCalled.push(true);
+    });
+    const t = system.addTask('job');
+    system.getNextTask();
+    await system.processTask(t.id);
+    expect(handlerCalled).toHaveLength(0);
+  });
+
+  it('multiple middlewares run in registration order', async () => {
+    const order: number[] = [];
+    for (let i = 1; i <= 3; i++) {
+      const n = i;
+      system.use('default', async (_task, next) => {
+        order.push(n);
+        await next();
+      });
+    }
+    system.setHandler('default', async () => {});
+    const t = system.addTask('job');
+    system.getNextTask();
+    await system.processTask(t.id);
+    expect(order).toEqual([1, 2, 3]);
+  });
+
+  it('middleware can modify the task', async () => {
+    system.use('default', async (task, next) => {
+      (task.payload as any).modified = true;
+      await next();
+    });
+    let receivedPayload: unknown;
+    system.setHandler('default', async task => {
+      receivedPayload = task.payload;
+    });
+    const t = system.addTask({ original: true });
+    system.getNextTask();
+    await system.processTask(t.id);
+    expect((receivedPayload as any).modified).toBe(true);
+  });
+
+  it('middleware error marks task as failed', async () => {
+    system.use('default', async (_task, _next) => {
+      throw new Error('middleware boom');
+    });
+    const t = system.addTask('job', { maxRetries: 0 });
+    system.getNextTask();
+    await system.processTask(t.id);
+    expect(system.getDeadLetterTasks()).toHaveLength(1);
+  });
