+import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
+import { TaskQueueSystem } from '../index.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let system: TaskQueueSystem;
+
+  beforeEach(() => {
+    system = new TaskQueueSystem();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('failed task with maxRetries=0 moves to DLQ immediately', () => {
+    const t = system.addTask('job', { maxRetries: 0 });
+    system.getNextTask();
+    system.failTask(t.id);
+    expect(system.getDeadLetterTasks()).toHaveLength(1);
+    expect(system.getDeadLetterTasks()[0].id).toBe(t.id);
+  });
+
+  it('DLQ tasks retain error information', () => {
+    const t = system.addTask('job', { maxRetries: 0 });
+    system.getNextTask();
+    system.failTask(t.id, new Error('oops'));
+    const dlq = system.getDeadLetterTasks();
+    expect(dlq[0].error?.message).toBe('oops');
+  });
+
+  it('DLQ tasks retain attempt count', () => {
+    const t = system.addTask('job', { maxRetries: 1, baseDelay: 100 });
+    // attempt 1
+    system.getNextTask();
+    system.failTask(t.id);
+    vi.advanceTimersByTime(200);
+    // attempt 2 (final)
+    system.getNextTask();
+    system.failTask(t.id);
+    expect(system.getDeadLetterTasks()[0].attempts).toBe(2);
+  });
+
+  it('requeueFromDLQ moves task back to queue for fresh retries', () => {
+    const t = system.addTask('job', { maxRetries: 0 });
+    system.getNextTask();
+    system.failTask(t.id);
+    system.requeueFromDLQ(t.id);
+    expect(system.getDeadLetterTasks()).toHaveLength(0);
+    expect(system.getPendingCount()).toBe(1);
+    // attempts reset
+    expect(system.getTask(t.id)!.attempts).toBe(0);
+  });
+
+  it('clearDeadLetterQueue removes all DLQ tasks', () => {
+    const t1 = system.addTask('a', { maxRetries: 0 });
+    const t2 = system.addTask('b', { maxRetries: 0 });
+    system.getNextTask();
+    system.failTask(t1.id);
+    system.getNextTask();
+    system.failTask(t2.id);
+    system.clearDeadLetterQueue();
+    expect(system.getDeadLetterTasks()).toHaveLength(0);
+  });
+
+  it('each named queue has its own DLQ', () => {
+    const t1 = system.addTask('a', { queue: 'q1', maxRetries: 0 });
+    const t2 = system.addTask('b', { queue: 'q2', maxRetries: 0 });
+    system.getNextTask('q1');
+    system.failTask(t1.id);
+    system.getNextTask('q2');
+    system.failTask(t2.id);
+    expect(system.getDeadLetterTasks('q1')).toHaveLength(1);
+    expect(system.getDeadLetterTasks('q2')).toHaveLength(1);
+    expect(system.getDeadLetterTasks('q1')[0].id).toBe(t1.id);
+    expect(system.getDeadLetterTasks('q2')[0].id).toBe(t2.id);
+  });
+
+  it('DLQ tasks have dead-lettered status', () => {
+    const t = system.addTask('job', { maxRetries: 0 });
+    system.getNextTask();
+    system.failTask(t.id);
+    expect(system.getDeadLetterTasks()[0].status).toBe('dead-lettered');
+  });
+});
