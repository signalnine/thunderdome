+import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
+import { TaskQueueSystem } from '../index.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  let system: TaskQueueSystem;
+
+  beforeEach(() => {
+    system = new TaskQueueSystem();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('completeTask marks task completed', () => {
+    const t = system.addTask('job');
+    system.getNextTask();
+    system.completeTask(t.id);
+    expect(system.getTask(t.id)!.status).toBe('completed');
+  });
+
+  it('failTask re-queues with backoff when retries remain', () => {
+    const t = system.addTask('job', { maxRetries: 3, baseDelay: 1000 });
+    system.getNextTask(); // attempt 1
+    system.failTask(t.id);
+    expect(system.getTask(t.id)!.status).toBe('pending');
+    expect(system.getNextTask()).toBeNull(); // not yet available
+    vi.advanceTimersByTime(1001);
+    expect(system.getNextTask()).not.toBeNull();
+  });
+
+  it('exponential backoff doubles each attempt', () => {
+    const t = system.addTask('job', { maxRetries: 3, baseDelay: 1000 });
+    // attempt 1 - backoff = 1000ms
+    system.getNextTask();
+    system.failTask(t.id);
+    vi.advanceTimersByTime(1001);
+    // attempt 2 - backoff = 2000ms
+    system.getNextTask();
+    system.failTask(t.id);
+    expect(system.getNextTask()).toBeNull();
+    vi.advanceTimersByTime(2001);
+    expect(system.getNextTask()).not.toBeNull();
+  });
+
+  it('task goes to dead-lettered state after max retries exhausted', () => {
+    const t = system.addTask('job', { maxRetries: 1, baseDelay: 100 });
+    // attempt 1
+    system.getNextTask();
+    system.failTask(t.id);
+    vi.advanceTimersByTime(200);
+    // attempt 2 (final)
+    system.getNextTask();
+    system.failTask(t.id);
+    expect(system.getTask(t.id)!.status).toBe('dead-lettered');
+  });
+
+  it('retried tasks keep original queue', () => {
+    system.addTask('job', { queue: 'special', maxRetries: 1, baseDelay: 100 });
+    system.getNextTask('special');
+    const tasks = system.getPendingCount('special');
+    expect(tasks).toBe(0);
+    // fail it - should requeue in 'special'
+    const allTasks = system.listQueues();
+    expect(allTasks).toContain('special');
+  });
+
+  it('tracks attempt count', () => {
+    const t = system.addTask('job', { maxRetries: 3, baseDelay: 100 });
+    system.getNextTask();
+    expect(system.getTask(t.id)!.attempts).toBe(1);
+    system.failTask(t.id);
+    vi.advanceTimersByTime(200);
+    system.getNextTask();
+    expect(system.getTask(t.id)!.attempts).toBe(2);
+  });
+
+  it('stores error on failed task', () => {
+    const t = system.addTask('job', { maxRetries: 0 });
+    system.getNextTask();
+    system.failTask(t.id, new Error('boom'));
+    expect(system.getTask(t.id)!.error?.message).toBe('boom');
+  });
+});
