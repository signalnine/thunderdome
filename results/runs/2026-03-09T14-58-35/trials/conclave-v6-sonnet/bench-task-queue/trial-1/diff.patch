+```typescript
+// src/TaskQueueSystem.ts
+import type {
+  TaskData,
+  TaskOptions,
+  MiddlewareFn,
+  HandlerFn,
+  ProgressListener,
+  ShutdownSummary,
+  Schedule,
+  ScheduleOptions,
+} from './types.js';
+import { Queue } from './Queue.js';
+import { Scheduler } from './Scheduler.js';
+
+const DEFAULT_QUEUE = 'default';
+
+export class TaskQueueSystem {
+  private queues: Map<string, Queue> = new Map();
+  private scheduler: Scheduler;
+  private isShuttingDown = false;
+  private shutdownPromise?: Promise<ShutdownSummary>;
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+
+  constructor() {
+    this.scheduler = new Scheduler(this);
+  }
+
+  // ─── Queue management ────────────────────────────────────────────────────
+
+  private getOrCreateQueue(name: string): Queue {
+    if (!this.queues.has(name)) {
+      this.queues.set(name, new Queue(name));
+    }
+    return this.queues.get(name)!;
+  }
+
+  listQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // ─── Task addition ───────────────────────────────────────────────────────
+
+  addTask<T>(
+    payload: T,
+    options: TaskOptions & { queue?: string } = {}
+  ): TaskData<T> {
+    if (this.isShuttingDown) {
+      throw new Error('System is shutting down; cannot add new tasks');
+    }
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+
+    // Validate dependencies
+    if (options.dependsOn && options.dependsOn.length > 0) {
+      for (const depId of options.dependsOn) {
+        const dep = this.findTaskById(depId);
+        if (!dep) throw new Error(`Dependency task ${depId} does not exist`);
+      }
+      this.detectCircularDependency(options.dependsOn, new Set());
+    }
+
+    const q = this.getOrCreateQueue(queueName) as Queue<T>;
+    return q.addTask(payload, options);
+  }
+
+  private findTaskById(id: string): TaskData | null {
+    for (const q of this.queues.values()) {
+      try {
+        return q.findTask(id);
+      } catch {
+        // not in this queue
+      }
+    }
+    return null;
+  }
+
+  private detectCircularDependency(
+    depIds: string[],
+    visited: Set<string>
+  ): void {
+    for (const id of depIds) {
+      if (visited.has(id)) {
+        throw new Error(`Circular dependency detected involving task ${id}`);
+      }
+      const dep = this.findTaskById(id);
+      if (dep && dep.dependsOn.length > 0) {
+        const next = new Set(visited);
+        next.add(id);
+        this.detectCircularDependency(dep.dependsOn, next);
+      }
+    }
+  }
+
+  // ─── Task retrieval ──────────────────────────────────────────────────────
+
+  private getResolvedTaskIds(): Set<string> {
+    const resolved = new Set<string>();
+    for (const q of this.queues.values()) {
+      for (const t of q.getAllTasks()) {
+        if (t.status === 'completed') resolved.add(t.id);
+      }
+    }
+    return resolved;
+  }
+
+  getNextTask(queueName: string = DEFAULT_QUEUE): TaskData | null {
+    const q = this.queues.get(queueName);
+    if (!q) return null;
+    return q.getNextTask(this.getResolvedTaskIds());
+  }
+
+  // ─── Task lifecycle ──────────────────────────────────────────────────────
+
+  completeTask(taskId: string): TaskData {
+    const { queue, task } = this.locateTask(taskId);
+    queue.completeTask(taskId);
+    return task;
+  }
+
+  failTask(taskId: string, error?: Error): TaskData {
+    const { queue } = this.locateTask(taskId);
+    return queue.failTask(taskId, error);
+  }
+
+  cancelTask(taskId: string): TaskData {
+    const { queue } = this.locateTask(taskId);
+    return queue.cancelTask(taskId);
+  }
+
+  reportProgress(
+    taskId: string,
+    percent: number,
+    message?: string
+  ): void {
+    const { queue } = this.locateTask(taskId);
+    queue.reportProgress(taskId, percent, message);
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    const { queue } = this.locateTask(taskId);
+    return queue.onProgress(taskId, listener);
+  }
+
+  getTask(taskId: string): TaskData | null {
+    return this.findTaskById(taskId);
+  }
+
+  private locateTask(id: string): { queue: Queue; task: TaskData } {
+    for (const q of this.queues.values()) {
+      try {
+        const task = q.findTask(id);
+        return { queue: q, task };
+      } catch {
+        // not in this queue
+      }
+    }
+    throw new Error(`Task ${id} not found in any queue`);
+  }
+
+  // ─── Queue stats ─────────────────────────────────────────────────────────
+
+  getPendingCount(queueName: string = DEFAULT_QUEUE): number {
+    return this.queues.get(queueName)?.getPendingCount() ?? 0;
+  }
+
+  setConcurrencyLimit(
+    queueName: string,
+    limit: number | null
+  ): void {
+    this.getOrCreateQueue(queueName).setConcurrencyLimit(limit);
+  }
+
+  getConcurrencyLimit(queueName: string): number | null {
+    return this.queues.get(queueName)?.getConcurrencyLimit() ?? null;
+  }
+
+  getActiveCount(queueName: string = DEFAULT_QUEUE): number {
+    return this.queues.get(queueName)?.getActiveCount() ?? 0;
+  }
+
+  // ─── Dead letter queue ───────────────────────────────────────────────────
+
+  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): TaskData[] {
+    return this.queues.get(queueName)?.getDeadLetterTasks() ?? [];
+  }
+
+  requeueFromDLQ(taskId: string): TaskData {
+    const { queue } = this.locateDLQTask(taskId);
+    return queue.requeueFromDLQ(taskId);
+  }
+
+  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {
+    this.queues.get(queueName)?.clearDeadLetterQueue();
+  }
+
+  private locateDLQTask(id: string): { queue: Queue; task: TaskData } {
+    for (const q of this.queues.values()) {
+      const dlq = q.getDeadLetterTasks();
+      const task = dlq.find(t => t.id === id);
+      if (task) return { queue: q, task };
+    }
+    throw new Error(`Task ${id} not found in any dead letter queue`);
+  }
+
+  // ─── Middleware & handler ────────────────────────────────────────────────
+
+  use<T>(queueName: string, middleware: MiddlewareFn<T>): void {
+    (this.getOrCreateQueue(queueName) as Queue<T>).useMiddleware(middleware);
+  }
+
+  setHandler<T>(queueName: string, handler: HandlerFn<T>): void {
+    (this.getOrCreateQueue(queueName) as Queue<T>).setHandler(handler);
+  }
+
+  async processTask(taskId: string): Promise<void> {
+    const { queue, task } = this.locateTask(taskId);
+    const middlewares = queue.getMiddlewares() as MiddlewareFn[];
+    const handler = queue.getHandler() as HandlerFn | undefined;
+
+    const run = async (index: number): Promise<void> => {
+      if (index < middlewares.length) {
+        await middlewares[index](task, () => run(index + 1));
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await run(0);
+    } catch (err) {
+      queue.failTask(taskId, err instanceof Error ? err : new Error(String(err)));
+      return;
+    }
+    // Only auto-complete if still processing (middleware might have called fail/cancel)
+    if (task.status === 'processing') {
+      queue.completeTask(taskId);
+    }
+  }
+
+  // ─── Scheduler ──────────────────────────────────────────────────────────
+
+  addSchedule(options: ScheduleOptions): Schedule {
+    return this.scheduler.addSchedule(options);
+  }
+
+  removeSchedule(id: string): void {
+    this.scheduler.removeSchedule(id);
+  }
+
+  listSchedules(): Schedule[] {
+    return this.scheduler.listSchedules();
+  }
+
+  tick(now?: Date): void {
+    this.scheduler.tick(now);
+  }
+
+  // ─── Graceful shutdown ───────────────────────────────────────────────────
+
+  onShutdown(cb: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(cb);
+  }
+
+  async shutdown(timeoutMs = 30000): Promise<ShutdownSummary> {
+    if (this.shutdownPromise) return this.shutdownPromise;
+
+    this.isShuttingDown = true;
+    const startTime = Date.now();
+
+    this.shutdownPromise = (async (): Promise<ShutdownSummary> => {
+      // Run registered callbacks
+      for (const cb of this.shutdownCallbacks) {
+        await cb();
+      }
+
+      // Collect all processing tasks
+      const processingTasks: TaskData[] = [];
+      for (const q of this.queues.values()) {
+        processingTasks.push(...q.getProcessingTasks());
+      }
+
+      if (processingTasks.length === 0) {
+        return { completed: 0, forceCancelled: 0, durationMs: Date.now() - startTime };
+      }
+
+      // Wait for them to finish, up to timeout
+      const deadline = Date.now() + timeoutMs;
+      let completed = 0;
+      let forceCancelled = 0;
+
+      const pollInterval = 50;
+      while (Date.now() < deadline) {
+        const stillProcessing: TaskData[] = [];
+        for (const q of this.queues.values()) {
+          stillProcessing.push(...q.getProcessingTasks());
+        }
+        if (stillProcessing.length === 0) break;
+        await new Promise(r => setTimeout(r, pollInterval));
+      }
+
+      // Force-cancel anything still processing
+      for (const q of this.queues.values()) {
+        for (const t of q.getProcessingTasks()) {
+          try {
+            q.cancelTask(t.id);
+            forceCancelled += 1;
+          } catch {
+            // already done
+          }
+        }
+      }
+
+      // Count completed
+      for (const q of this.queues.values()) {
+        for (const t of q.getAllTasks()) {
+          if (processingTasks.some(p => p.id === t.id) && t.status === 'completed') {
+            completed += 1;
+          }
+        }
+      }
+
+      return {
+        completed,
+        forceCancelled,
+        durationMs: Date.now() - startTime,
+      };
+    })();
+
+    return this.shutdownPromise;
+  }
+}
