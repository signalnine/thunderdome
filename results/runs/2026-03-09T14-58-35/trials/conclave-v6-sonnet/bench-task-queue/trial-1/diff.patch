ask.availableAt > now) return false;\n    if (task.dependsOn.length > 0) {\n      if (!task.dependsOn.every(id => resolvedIds.has(id))) return false;\n    }\n    return true;\n  }\n\n  getNextTask(resolvedIds: Set<string>): TaskData<T> | null {\n    if (\n      this.concurrencyLimit !== null &&\n      this.activeCount >= this.concurrencyLimit\n    ) {\n      return null;\n    }\n\n    const available = this.tasks.filter(t => this.isAvailable(t, resolvedIds));\n    if (available.length === 0) return null;\n\n    available.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      if (a.availableAt.getTime() !== b.availableAt.getTime())\n        return a.availableAt.getTime() - b.availableAt.getTime();\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = available[0];\n    task.status = 'processing';\n    task.attempts += 1;\n    this.activeCount += 1;\n    return task;\n  }\n\n  completeTask(id: string): TaskData<T> {\n    const task = this.findTaskInActive(id);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${id} is not in processing state`);\n    }\n    task.status = 'completed';\n    task.completedAt = new Date();\n    this.activeCount -= 1;\n    return task;\n  }\n\n  failTask(id: string, error?: Error): TaskData<T> {\n    const task = this.findTaskInActive(id);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${id} is not in processing state`);\n    }\n    task.error = error;\n    this.activeCount -= 1;\n\n    if (task.attempts <= task.maxRetries) {\n      const backoffMs = task.baseDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + backoffMs);\n    } else {\n      task.status = 'dead-lettered';\n      task.failedAt = new Date();\n      this.tasks.splice(this.tasks.indexOf(task), 1);\n      this.deadLetterTasks.push(task);\n    }\n    return task;\n  }\n\n  cancelTask(id: string): TaskData<T> {\n    // Check in tasks array\n    let task = this.tasks.find(t => t.id === id);\n    if (!task) throw new Error(`Task ${id} not found`);\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Task ${id} cannot be cancelled in state ${task.status}`);\n    }\n    if (task.status === 'processing') {\n      this.activeCount -= 1;\n    }\n    task.status = 'cancelled';\n    task.cancelledAt = new Date();\n    return task;\n  }\n\n  reportProgress(id: string, percent: number, message?: string): void {\n    if (percent < 0 || percent > 100) {\n      throw new RangeError('Progress percent must be 0-100');\n    }\n    const task = this.findTaskInActive(id);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${id} is not processing`);\n    }\n    task.progress = { percent, message };\n    const listeners = this.progressListeners.get(id);\n    if (listeners) {\n      for (const fn of listeners) {\n        fn(task.progress);\n      }\n    }\n  }\n\n  onProgress(id: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(id)) {\n      this.progressListeners.set(id, new Set());\n    }\n    this.progressListeners.get(id)!.add(listener);\n    return () => {\n      this.progressListeners.get(id)?.delete(listener);\n    };\n  }\n\n  getDeadLetterTasks(): TaskData<T>[] {\n    return [...this.deadLetterTasks];\n  }\n\n  requeueFromDLQ(id: string): TaskData<T> {\n    const idx = this.deadLetterTasks.findIndex(t => t.id === id);\n    if (idx === -1) throw new Error(`Task ${id} not found in dead letter queue`);\n    const task = this.deadLetterTasks[idx];\n    this.deadLetterTasks.splice(idx, 1);\n    task.status = 'pending';\n    task.attempts = 0;\n    task.availableAt = new Date();\n    task.error = undefined;\n    this.tasks.push(task);\n    return task;\n  }\n\n  clearDeadLetterQueue(): void {\n    this.deadLetterTasks = [];\n  }\n\n  setConcurrencyLimit(limit: number | null): void {\n    this.concurrencyLimit = limit;\n  }\n\n  getConcurrencyLimit(): number | null {\n    return this.concurrencyLimit;\n  }\n\n  getActiveCount(): number {\n    return this.activeCount;\n  }\n\n  getPendingCount(): number {\n    return this.tasks.filter(t => t.status === 'pending').length;\n  }\n\n  getProcessingTasks(): TaskData<T>[] {\n    return this.tasks.filter(t => t.status === 'processing');\n  }\n\n  getAllTasks(): TaskData<T>[] {\n    return [...this.tasks];\n  }\n\n  findTask(id: string): TaskData<T> {\n    const t =\n      this.tasks.find(t => t.id === id) ??\n      this.deadLetterTasks.find(t => t.id === id);\n    if (!t) throw new Error(`Task ${id} not found`);\n    return t;\n  }\n\n  private findTaskInActive(id: string): TaskData<T> {\n    const t = this.tasks.find(t => t.id === id);\n    if (!t) throw new Error(`Task ${id} not found`);\n    return t;\n  }\n\n  useMiddleware(fn: MiddlewareFn<T>): void {\n    this.middlewares.push(fn);\n  }\n\n  setHandler(fn: HandlerFn<T>): void {\n    this.handler = fn;\n  }\n\n  getMiddlewares(): MiddlewareFn<T>[] {\n    return this.middlewares;\n  }\n\n  getHandler(): HandlerFn<T> | undefined {\n    return this.handler;\n  }\n}\n","structuredPatch":[{"oldStart":50,"oldLines":9,"newStart":50,"newLines":9,"lines":["     if (available.length === 0) return null;"," ","     available.sort((a, b) => {","-      if (a.priority !== b.priority) return a.priority - b.priority;","       if (a.availableAt.getTime() !== b.availableAt.getTime())","         return a.availableAt.getTime() - b.availableAt.getTime();","+      if (a.priority !== b.priority) return a.priority - b.priority;","       return a.createdAt.getTime() - b.createdAt.getTime();","     });"," "]}],"userModified":false,"replaceAll":false}}
