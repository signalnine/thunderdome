+    const r2 = system.shutdown();
+    expect(await r1).toBe(await r2);
+  });
+
+  it('onShutdown callbacks are called', async () => {
+    const called: boolean[] = [];
+    system.onShutdown(() => { called.push(true); });
+    await system.shutdown();
+    expect(called).toHaveLength(1);
+  });
+
+  it('processing tasks that complete within timeout are counted', async () => {
+    const t = system.addTask('job');
+    system.getNextTask();
+    // Complete the task shortly after shutdown starts
+    setTimeout(() => system.completeTask(t.id), 10);
+    const summary = await system.shutdown(5000);
+    expect(summary.completed).toBe(1);
+    expect(summary.forceCancelled).toBe(0);
+  });
+
+  it('processing tasks force-cancelled after timeout', async () => {
+    const t = system.addTask('job');
+    system.getNextTask();
+    // Never complete it
