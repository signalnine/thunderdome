+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueueSystem } from '../index.js';
+
+describe('Phase 9: Progress and Cancellation', () => {
+  let system: TaskQueueSystem;
+
+  beforeEach(() => {
+    system = new TaskQueueSystem();
+  });
+
+  it('reportProgress updates task progress', () => {
+    const t = system.addTask('job');
+    system.getNextTask();
+    system.reportProgress(t.id, 50, 'halfway');
+    expect(system.getTask(t.id)!.progress).toEqual({ percent: 50, message: 'halfway' });
+  });
+
+  it('throws on progress percent below 0', () => {
+    const t = system.addTask('job');
+    system.getNextTask();
+    expect(() => system.reportProgress(t.id, -1)).toThrow();
+  });
+
+  it('throws on progress percent above 100', () => {
+    const t = system.addTask('job');
+    system.getNextTask();
+    expect(() => system.reportProgress(t.id, 101)).toThrow();
+  });
+
+  it('progress listeners are notified', () => {
+    const t = system.addTask('job');
+    system.getNextTask();
+    const received: number[] = [];
+    system.onProgress(t.id, info => received.push(info.percent));
+    system.reportProgress(t.id, 25);
+    system.reportProgress(t.id, 75);
+    expect(received).toEqual([25, 75]);
+  });
+
+  it('unsubscribe stops notifications', () => {
+    const t = system.addTask('job');
+    system.getNextTask();
+    const received: number[] = [];
+    const unsub = system.onProgress(t.id, info => received.push(info.percent));
+    system.reportProgress(t.id, 25);
+    unsub();
+    system.reportProgress(t.id, 75);
+    expect(received).toEqual([25]);
+  });
+
+  it('cancel pending task removes it from queue', () => {
+    const t = system.addTask('job');
+    system.cancelTask(t.id);
+    expect(system.getTask(t.id)!.status).toBe('cancelled');
+    expect(system.getNextTask()).toBeNull();
+  });
+
+  it('cancel processing task updates status', () => {
+    const t = system.addTask('job');
+    system.getNextTask();
+    system.cancelTask(t.id);
+    expect(system.getTask(t.id)!.status).toBe('cancelled');
+  });
+
+  it('cancelling processing task frees concurrency slot', () => {
+    system.setConcurrencyLimit('default', 1);
+    const t = system.addTask('a');
+    system.addTask('b');
+    system.getNextTask();
+    system.cancelTask(t.id);
+    expect(system.getNextTask()).not.toBeNull();
+  });
+
+  it('cancelled tasks are not retried', () => {
+    const t = system.addTask('job', { maxRetries: 3 });
+    system.getNextTask();
+    system.cancelTask(t.id);
+    expect(system.getTask(t.id)!.status).toBe('cancelled');
+    expect(system.getPendingCount()).toBe(0);
+  });
+});
