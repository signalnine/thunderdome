+import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
+import { TaskQueueSystem } from '../index.js';
+
+describe('Phase 4: Delayed Tasks', () => {
+  let system: TaskQueueSystem;
+
+  beforeEach(() => {
+    system = new TaskQueueSystem();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('delayed task not returned before delay expires', () => {
+    system.addTask('delayed', { delayMs: 5000 });
+    expect(system.getNextTask()).toBeNull();
+  });
+
+  it('delayed task returned after delay expires', () => {
+    system.addTask('delayed', { delayMs: 5000 });
+    vi.advanceTimersByTime(5001);
+    const t = system.getNextTask();
+    expect(t).not.toBeNull();
+    expect(t!.payload).toBe('delayed');
+  });
+
+  it('non-delayed tasks preferred over not-yet-available delayed tasks', () => {
+    system.addTask('delayed', { delayMs: 5000 });
+    system.addTask('immediate');
+    expect(system.getNextTask()!.payload).toBe('immediate');
+  });
+
+  it('task has availableAt set correctly', () => {
+    const before = Date.now();
+    const t = system.addTask('x', { delayMs: 1000 });
+    expect(t.availableAt.getTime()).toBeGreaterThanOrEqual(before + 1000);
+  });
+
+  it('availableAt option works', () => {
+    const future = new Date(Date.now() + 10000);
+    const t = system.addTask('x', { availableAt: future });
+    expect(t.availableAt).toEqual(future);
+    expect(system.getNextTask()).toBeNull();
+  });
+
+  it('multiple delayed tasks ordered by availableAt then priority', () => {
+    system.addTask('later-high', { delayMs: 1000, priority: 1 });
+    system.addTask('sooner-low', { delayMs: 500, priority: 9 });
+    vi.advanceTimersByTime(2000);
+    // sooner availableAt wins over priority
+    expect(system.getNextTask()!.payload).toBe('sooner-low');
+  });
+});
