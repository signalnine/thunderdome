+
+  it('task goes to failed state after max retries exhausted', () => {
+    const t = system.addTask('job', { maxRetries: 1, baseDelay: 100 });
+    // attempt 1
+    system.getNextTask();
+    system.failTask(t.id);
+    // retry
+    vi.advanceTimersByTime(200);
+    system.getNextTask();
+    system.failTask(t.id);
+    // exhausted
+    expect(system.getTask(t.id)!.status).toBe('dead-lettered');
+  });
+
+  it('retried tasks keep original queue and priority', () => {
