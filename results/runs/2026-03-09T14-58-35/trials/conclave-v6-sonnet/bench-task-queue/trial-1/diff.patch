@@ -0,0 +1,99 @@
+import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
+import { TaskQueueSystem } from '../index.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  let system: TaskQueueSystem;
+
+  beforeEach(() => {
+    system = new TaskQueueSystem();
+    vi.useFakeTimers();
+    vi.setSystemTime(new Date('2026-01-01T00:00:00Z'));
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('creates a schedule and returns schedule object with id and cron', () => {
+    const s = system.addSchedule({
+      cron: '*/5 * * * *',
+      queueName: 'default',
+      payload: { job: 'report' },
+    });
+    expect(s.id).toBeTruthy();
+    expect(s.cron).toBe('*/5 * * * *');
+    expect(s.queueName).toBe('default');
+  });
+
+  it('tick enqueues task when every-N-minutes cron is due', () => {
+    system.addSchedule({ cron: '*/5 * * * *', queueName: 'default', payload: 'recurring' });
+    // advance 5 minutes + 1ms
+    vi.advanceTimersByTime(5 * 60 * 1000 + 1);
+    system.tick();
+    expect(system.getPendingCount()).toBe(1);
+  });
+
+  it('tick does not enqueue if not enough time has passed', () => {
+    system.addSchedule({ cron: '*/5 * * * *', queueName: 'default', payload: 'recurring' });
+    // advance only 4 minutes
+    vi.advanceTimersByTime(4 * 60 * 1000);
+    system.tick();
+    expect(system.getPendingCount()).toBe(0);
+  });
+
+  it('removeSchedule stops future enqueuing', () => {
+    const s = system.addSchedule({
+      cron: '*/5 * * * *',
+      queueName: 'default',
+      payload: 'recurring',
+    });
+    system.removeSchedule(s.id);
+    vi.advanceTimersByTime(10 * 60 * 1000);
+    system.tick();
+    expect(system.getPendingCount()).toBe(0);
+  });
+
+  it('listSchedules returns active schedules', () => {
+    system.addSchedule({ cron: '0 * * * *', queueName: 'default', payload: {} });
+    system.addSchedule({ cron: '0 0 * * *', queueName: 'q2', payload: {} });
+    expect(system.listSchedules()).toHaveLength(2);
+  });
+
+  it('enqueued recurring tasks are normal tasks subject to queue rules', () => {
+    system.addSchedule({
+      cron: '*/1 * * * *',
+      queueName: 'default',
+      payload: { type: 'cron' },
+    });
+    vi.advanceTimersByTime(60 * 1000 + 100);
+    system.tick();
+    const t = system.getNextTask();
+    expect(t).not.toBeNull();
+    expect((t!.payload as { type: string }).type).toBe('cron');
+    expect(t!.status).toBe('processing');
+  });
+
+  it('tick creates multiple tasks if multiple schedules are due', () => {
+    system.addSchedule({ cron: '*/5 * * * *', queueName: 'default', payload: 'a' });
+    system.addSchedule({ cron: '*/5 * * * *', queueName: 'default', payload: 'b' });
+    vi.advanceTimersByTime(6 * 60 * 1000);
+    system.tick();
+    expect(system.getPendingCount()).toBe(2);
+  });
+
+  it('tick advances interval after firing — fires again after another interval', () => {
+    system.addSchedule({ cron: '*/5 * * * *', queueName: 'default', payload: 'x' });
+    // Fire once
+    vi.advanceTimersByTime(5 * 60 * 1000 + 1);
+    system.tick();
+    expect(system.getPendingCount()).toBe(1);
+    // Tick again too soon (only 1 minute later) — no new task
+    vi.advanceTimersByTime(1 * 60 * 1000);
+    system.tick();
+    expect(system.getPendingCount()).toBe(1);
+    // Another 5 full minutes pass — fires again
+    vi.advanceTimersByTime(5 * 60 * 1000);
+    system.tick();
+    expect(system.getPendingCount()).toBe(2);
+  });
+});
