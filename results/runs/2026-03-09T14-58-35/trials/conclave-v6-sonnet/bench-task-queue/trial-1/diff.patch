+
+  it('getConcurrencyLimit returns null for unlimited', () => {
+    expect(system.getConcurrencyLimit('default')).toBeNull();
+  });
+
+  it('getActiveCount reflects processing tasks', () => {
+    system.addTask('x');
+    system.getNextTask();
+    expect(system.getActiveCount()).toBe(1);
