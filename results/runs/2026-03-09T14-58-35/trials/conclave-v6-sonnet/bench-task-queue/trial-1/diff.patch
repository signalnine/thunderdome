+{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01Ja5bf1xiNofHNCM7oijqKB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012RzhAeWuewWka9darAvQ2h","name":"Write","input":{"file_path":"/workspace/docs/plans/2026-03-09-task-queue-system.md","content":"# Task Queue System Implementation Plan\n\n> **For Claude:** REQUIRED SUB-SKILL: Use conclave:executing-plans to implement this plan task-by-task.\n\n**Goal:** Build a fully-featured in-memory task queue system that supports 12 phases of increasing sophistication, from basic FIFO to graceful shutdown.\n\n**Architecture:** A central `TaskQueueSystem` class manages named queues, each represented by a `Queue` object containing tasks. All state is in-memory. Tasks move through statuses: `pending → processing → completed|failed|cancelled`. Features are layered incrementally — each phase builds on the prior without breaking backward compatibility.\n\n**Tech Stack:** TypeScript (strict mode), Node.js ESM, Vitest for tests, no runtime dependencies.\n\n---\n\n## File Layout\n\n```\nsrc/\n  types.ts          # All shared types/interfaces\n  Task.ts           # Task class\n  Queue.ts          # Queue class (manages tasks, concurrency, middleware)\n  Scheduler.ts      # Recurring task scheduler (phase 10)\n  TaskQueueSystem.ts # Top-level system orchestrator\n  index.ts          # Public API re-exports\nsrc/tests/\n  phase-01.test.ts\n  phase-02.test.ts\n  ... (one per phase)\n```\n\n---\n\n### Task 1: Project Scaffolding and Types\n\n**Files:**\n- Create: `src/types.ts`\n- Create: `src/tests/phase-01.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Create types.ts with core types**\n\n```typescript\n// src/types.ts\nexport type TaskStatus =\n  | 'pending'\n  | 'processing'\n  | 'completed'\n  | 'failed'\n  | 'cancelled'\n  | 'dead-lettered';\n\nexport interface TaskOptions {\n  priority?: number;       // 1-10, default 5\n  delayMs?: number;        // delay in ms\n  availableAt?: Date;      // explicit availability time\n  maxRetries?: number;     // default 3\n  baseDelay?: number;      // ms, default 1000\n  dependsOn?: string[];    // task IDs\n}\n\nexport interface ProgressInfo {\n  percent: number;\n  message?: string;\n}\n\nexport interface TaskData<T = unknown> {\n  id: string;\n  queueName: string;\n  payload: T;\n  status: TaskStatus;\n  priority: number;\n  createdAt: Date;\n  availableAt: Date;\n  attempts: number;\n  maxRetries: number;\n  baseDelay: number;\n  dependsOn: string[];\n  error?: Error;\n  progress?: ProgressInfo;\n  completedAt?: Date;\n  failedAt?: Date;\n  cancelledAt?: Date;\n}\n\nexport type MiddlewareFn<T = unknown> = (\n  task: TaskData<T>,\n  next: () => Promise<void>\n) => Promise<void>;\n\nexport type HandlerFn<T = unknown> = (task: TaskData<T>) => Promise<void>;\n\nexport type ProgressListener = (info: ProgressInfo) => void;\n\nexport interface ShutdownSummary {\n  completed: number;\n  forceCancelled: number;\n  durationMs: number;\n}\n\nexport interface ScheduleOptions {\n  id?: string;\n  cron: string;\n  queueName: string;\n  payload: unknown;\n}\n\nexport interface Schedule {\n  id: string;\n  cron: string;\n  queueName: string;\n  payload: unknown;\n  lastRunAt?: Date;\n}\n\nexport interface QueueStats {\n  name: string;\n  pending: number;\n  processing: number;\n  concurrencyLimit: number | null;\n}\n```\n\n**Step 2: Write phase-01 failing tests**\n\n```typescript\n// src/tests/phase-01.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueueSystem } from '../index.js';\n\ndescribe('Phase 1: Basic FIFO Queue', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => {\n    system = new TaskQueueSystem();\n  });\n\n  it('adds a task and returns a task object with id, status, createdAt', () => {\n    const task = system.addTask({ name: 'job1' });\n    expect(task.id).toBeTruthy();\n    expect(task.status).toBe('pending');\n    expect(task.createdAt).toBeInstanceOf(Date);\n    expect(task.payload).toEqual({ name: 'job1' });\n  });\n\n  it('tasks have unique IDs', () => {\n    const t1 = system.addTask('a');\n    const t2 = system.addTask('b');\n    expect(t1.id).not.toBe(t2.id);\n  });\n\n  it('retrieving next task transitions it to processing', () => {\n    system.addTask('job');\n    const task = system.getNextTask();\n    expect(task).not.toBeNull();\n    expect(task!.status).toBe('processing');\n  });\n\n  it('FIFO order: oldest task returned first', () => {\n    system.addTask('first');\n    system.addTask('second');\n    const t = system.getNextTask();\n    expect(t!.payload).toBe('first');\n  });\n\n  it('returns null when no tasks available', () => {\n    expect(system.getNextTask()).toBeNull();\n  });\n\n  it('getPendingCount returns correct count', () => {\n    system.addTask('a');\n    system.addTask('b');\n    expect(system.getPendingCount()).toBe(2);\n    system.getNextTask();\n    expect(system.getPendingCount()).toBe(1);\n  });\n});\n```\n\n**Step 3: Run tests to verify they fail**\n\nRun: `cd /workspace && npm test -- src/tests/phase-01.test.ts`\nExpected: FAIL with import errors (nothing implemented yet)\n\n---\n\n### Task 2: Core Task and Queue Implementation (Phase 1)\n\n**Files:**\n- Create: `src/Task.ts`\n- Create: `src/Queue.ts`\n- Create: `src/TaskQueueSystem.ts`\n- Create: `src/index.ts`\n\n**Dependencies:** Task 1\n\n**Step 1: Create Task.ts**\n\n```typescript\n// src/Task.ts\nimport { randomUUID } from 'crypto';\nimport type { TaskData, TaskOptions, TaskStatus } from './types.js';\n\nexport function createTask<T>(\n  payload: T,\n  queueName: string,\n  options: TaskOptions = {}\n): TaskData<T> {\n  const priority = options.priority ?? 5;\n  if (priority < 1 || priority > 10) {\n    throw new RangeError(`Priority must be between 1 and 10, got ${priority}`);\n  }\n\n  const now = new Date();\n  let availableAt: Date;\n  if (options.availableAt) {\n    availableAt = options.availableAt;\n  } else if (options.delayMs !== undefined) {\n    availableAt = new Date(now.getTime() + options.delayMs);\n  } else {\n    availableAt = now;\n  }\n\n  return {\n    id: randomUUID(),\n    queueName,\n    payload,\n    status: 'pending',\n    priority,\n    createdAt: now,\n    availableAt,\n    attempts: 0,\n    maxRetries: options.maxRetries ?? 3,\n    baseDelay: options.baseDelay ?? 1000,\n    dependsOn: options.dependsOn ?? [],\n  };\n}\n```\n\n**Step 2: Create Queue.ts**\n\n```typescript\n// src/Queue.ts\nimport type {\n  TaskData,\n  TaskOptions,\n  MiddlewareFn,\n  HandlerFn,\n  ProgressInfo,\n  ProgressListener,\n} from './types.js';\nimport { createTask } from './Task.js';\n\nexport class Queue<T = unknown> {\n  readonly name: string;\n  private tasks: TaskData<T>[] = [];\n  private deadLetterTasks: TaskData<T>[] = [];\n  private concurrencyLimit: number | null = null;\n  private activeCount = 0;\n  private middlewares: MiddlewareFn<T>[] = [];\n  private handler?: HandlerFn<T>;\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n\n  constructor(name: string) {\n    this.name = name;\n  }\n\n  addTask(payload: T, options: TaskOptions = {}): TaskData<T> {\n    const task = createTask(payload, this.name, options);\n    this.tasks.push(task);\n    return task;\n  }\n\n  private isAvailable(task: TaskData<T>, resolvedIds: Set<string>): boolean {\n    if (task.status !== 'pending') return false;\n    const now = new Date();\n    if (task.availableAt > now) return false;\n    if (task.dependsOn.length > 0) {\n      if (!task.dependsOn.every(id => resolvedIds.has(id))) return false;\n    }\n    return true;\n  }\n\n  getNextTask(resolvedIds: Set<string>): TaskData<T> | null {\n    if (\n      this.concurrencyLimit !== null &&\n      this.activeCount >= this.concurrencyLimit\n    ) {\n      return null;\n    }\n\n    // Sort: available tasks first (by availableAt asc, priority asc, createdAt asc)\n    const available = this.tasks.filter(t => this.isAvailable(t, resolvedIds));\n    if (available.length === 0) return null;\n\n    available.sort((a, b) => {\n      // Lower priority number = higher urgency\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      if (a.availableAt.getTime() !== b.availableAt.getTime())\n        return a.availableAt.getTime() - b.availableAt.getTime();\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = available[0];\n    task.status = 'processing';\n    task.attempts += 1;\n    this.activeCount += 1;\n    return task;\n  }\n\n  completeTask(id: string): TaskData<T> {\n    const task = this.findTask(id);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${id} is not in processing state`);\n    }\n    task.status = 'completed';\n    task.completedAt = new Date();\n    this.activeCount -= 1;\n    return task;\n  }\n\n  failTask(id: string, error?: Error): TaskData<T> {\n    const task = this.findTask(id);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${id} is not in processing state`);\n    }\n    task.error = error;\n    this.activeCount -= 1;\n\n    if (task.attempts <= task.maxRetries) {\n      // Schedule retry with exponential backoff\n      const backoffMs = task.baseDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + backoffMs);\n    } else {\n      task.status = 'failed';\n      task.failedAt = new Date();\n      // Move to DLQ\n      this.tasks.splice(this.tasks.indexOf(task), 1);\n      this.deadLetterTasks.push(task);\n      task.status = 'dead-lettered';\n    }\n    return task;\n  }\n\n  cancelTask(id: string): TaskData<T> {\n    const task = this.findTask(id);\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Task ${id} cannot be cancelled in state ${task.status}`);\n    }\n    if (task.status === 'processing') {\n      this.activeCount -= 1;\n    }\n    task.status = 'cancelled';\n    task.cancelledAt = new Date();\n    return task;\n  }\n\n  reportProgress(id: string, percent: number, message?: string): void {\n    if (percent < 0 || percent > 100) {\n      throw new RangeError('Progress percent must be 0-100');\n    }\n    const task = this.findTask(id);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${id} is not processing`);\n    }\n    task.progress = { percent, message };\n    const listeners = this.progressListeners.get(id);\n    if (listeners) {\n      for (const fn of listeners) {\n        fn(task.progress);\n      }\n    }\n  }\n\n  onProgress(id: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(id)) {\n      this.progressListeners.set(id, new Set());\n    }\n    this.progressListeners.get(id)!.add(listener);\n    return () => {\n      this.progressListeners.get(id)?.delete(listener);\n    };\n  }\n\n  getDeadLetterTasks(): TaskData<T>[] {\n    return [...this.deadLetterTasks];\n  }\n\n  requeueFromDLQ(id: string): TaskData<T> {\n    const idx = this.deadLetterTasks.findIndex(t => t.id === id);\n    if (idx === -1) throw new Error(`Task ${id} not found in dead letter queue`);\n    const task = this.deadLetterTasks[idx];\n    this.deadLetterTasks.splice(idx, 1);\n    task.status = 'pending';\n    task.attempts = 0;\n    task.availableAt = new Date();\n    task.error = undefined;\n    this.tasks.push(task);\n    return task;\n  }\n\n  clearDeadLetterQueue(): void {\n    this.deadLetterTasks = [];\n  }\n\n  setConcurrencyLimit(limit: number | null): void {\n    this.concurrencyLimit = limit;\n  }\n\n  getConcurrencyLimit(): number | null {\n    return this.concurrencyLimit;\n  }\n\n  getActiveCount(): number {\n    return this.activeCount;\n  }\n\n  getPendingCount(): number {\n    return this.tasks.filter(t => t.status === 'pending').length;\n  }\n\n  getProcessingTasks(): TaskData<T>[] {\n    return this.tasks.filter(t => t.status === 'processing');\n  }\n\n  getAllTasks(): TaskData<T>[] {\n    return [...this.tasks];\n  }\n\n  findTask(id: string): TaskData<T> {\n    const t =\n      this.tasks.find(t => t.id === id) ??\n      this.deadLetterTasks.find(t => t.id === id);\n    if (!t) throw new Error(`Task ${id} not found`);\n    return t;\n  }\n\n  useMiddleware(fn: MiddlewareFn<T>): void {\n    this.middlewares.push(fn);\n  }\n\n  setHandler(fn: HandlerFn<T>): void {\n    this.handler = fn;\n  }\n\n  getMiddlewares(): MiddlewareFn<T>[] {\n    return this.middlewares;\n  }\n\n  getHandler(): HandlerFn<T> | undefined {\n    return this.handler;\n  }\n}\n```\n\n**Step 3: Create TaskQueueSystem.ts**\n\n```typescript\n// src/TaskQueueSystem.ts\nimport type {\n  TaskData,\n  TaskOptions,\n  MiddlewareFn,\n  HandlerFn,\n  ProgressListener,\n  ShutdownSummary,\n  Schedule,\n  ScheduleOptions,\n} from './types.js';\nimport { Queue } from './Queue.js';\nimport { Scheduler } from './Scheduler.js';\n\nconst DEFAULT_QUEUE = 'default';\n\nexport class TaskQueueSystem {\n  private queues: Map<string, Queue> = new Map();\n  private scheduler: Scheduler;\n  private isShuttingDown = false;\n  private shutdownPromise?: Promise<ShutdownSummary>;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  constructor() {\n    this.scheduler = new Scheduler(this);\n  }\n\n  // ─── Queue management ────────────────────────────────────────────────────\n\n  private getOrCreateQueue(name: string): Queue {\n    if (!this.queues.has(name)) {\n      this.queues.set(name, new Queue(name));\n    }\n    return this.queues.get(name)!;\n  }\n\n  listQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ─── Task addition ───────────────────────────────────────────────────────\n\n  addTask<T>(\n    payload: T,\n    options: TaskOptions & { queue?: string } = {}\n  ): TaskData<T> {\n    if (this.isShuttingDown) {\n      throw new Error('System is shutting down; cannot add new tasks');\n    }\n    const queueName = options.queue ?? DEFAULT_QUEUE;\n\n    // Validate dependencies\n    if (options.dependsOn && options.dependsOn.length > 0) {\n      for (const depId of options.dependsOn) {\n        const dep = this.findTaskById(depId);\n        if (!dep) throw new Error(`Dependency task ${depId} does not exist`);\n      }\n      this.detectCircularDependency(options.dependsOn, new Set());\n    }\n\n    const q = this.getOrCreateQueue(queueName) as Queue<T>;\n    return q.addTask(payload, options);\n  }\n\n  private findTaskById(id: string): TaskData | null {\n    for (const q of this.queues.values()) {\n      try {\n        return q.findTask(id);\n      } catch {\n        // not in this queue\n      }\n    }\n    return null;\n  }\n\n  private detectCircularDependency(\n    depIds: string[],\n    visited: Set<string>\n  ): void {\n    for (const id of depIds) {\n      if (visited.has(id)) {\n        throw new Error(`Circular dependency detected involving task ${id}`);\n      }\n      const dep = this.findTaskById(id);\n      if (dep && dep.dependsOn.length > 0) {\n        const next = new Set(visited);\n        next.add(id);\n        this.detectCircularDependency(dep.dependsOn, next);\n      }\n    }\n  }\n\n  // ─── Task retrieval ──────────────────────────────────────────────────────\n\n  private getResolvedTaskIds(): Set<string> {\n    const resolved = new Set<string>();\n    for (const q of this.queues.values()) {\n      for (const t of q.getAllTasks()) {\n        if (t.status === 'completed') resolved.add(t.id);\n      }\n    }\n    return resolved;\n  }\n\n  getNextTask(queueName: string = DEFAULT_QUEUE): TaskData | null {\n    const q = this.queues.get(queueName);\n    if (!q) return null;\n    return q.getNextTask(this.getResolvedTaskIds());\n  }\n\n  // ─── Task lifecycle ──────────────────────────────────────────────────────\n\n  completeTask(taskId: string): TaskData {\n    const { queue, task } = this.locateTask(taskId);\n    queue.completeTask(taskId);\n    return task;\n  }\n\n  failTask(taskId: string, error?: Error): TaskData {\n    const { queue } = this.locateTask(taskId);\n    return queue.failTask(taskId, error);\n  }\n\n  cancelTask(taskId: string): TaskData {\n    const { queue } = this.locateTask(taskId);\n    return queue.cancelTask(taskId);\n  }\n\n  reportProgress(\n    taskId: string,\n    percent: number,\n    message?: string\n  ): void {\n    const { queue } = this.locateTask(taskId);\n    queue.reportProgress(taskId, percent, message);\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    const { queue } = this.locateTask(taskId);\n    return queue.onProgress(taskId, listener);\n  }\n\n  getTask(taskId: string): TaskData | null {\n    return this.findTaskById(taskId);\n  }\n\n  private locateTask(id: string): { queue: Queue; task: TaskData } {\n    for (const q of this.queues.values()) {\n      try {\n        const task = q.findTask(id);\n        return { queue: q, task };\n      } catch {\n        // not in this queue\n      }\n    }\n    throw new Error(`Task ${id} not found in any queue`);\n  }\n\n  // ─── Queue stats ─────────────────────────────────────────────────────────\n\n  getPendingCount(queueName: string = DEFAULT_QUEUE): number {\n    return this.queues.get(queueName)?.getPendingCount() ?? 0;\n  }\n\n  setConcurrencyLimit(\n    queueName: string,\n    limit: number | null\n  ): void {\n    this.getOrCreateQueue(queueName).setConcurrencyLimit(limit);\n  }\n\n  getConcurrencyLimit(queueName: string): number | null {\n    return this.queues.get(queueName)?.getConcurrencyLimit() ?? null;\n  }\n\n  getActiveCount(queueName: string = DEFAULT_QUEUE): number {\n    return this.queues.get(queueName)?.getActiveCount() ?? 0;\n  }\n\n  // ─── Dead letter queue ───────────────────────────────────────────────────\n\n  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): TaskData[] {\n    return this.queues.get(queueName)?.getDeadLetterTasks() ?? [];\n  }\n\n  requeueFromDLQ(taskId: string): TaskData {\n    const { queue } = this.locateDLQTask(taskId);\n    return queue.requeueFromDLQ(taskId);\n  }\n\n  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {\n    this.queues.get(queueName)?.clearDeadLetterQueue();\n  }\n\n  private locateDLQTask(id: string): { queue: Queue; task: TaskData } {\n    for (const q of this.queues.values()) {\n      const dlq = q.getDeadLetterTasks();\n      const task = dlq.find(t => t.id === id);\n      if (task) return { queue: q, task };\n    }\n    throw new Error(`Task ${id} not found in any dead letter queue`);\n  }\n\n  // ─── Middleware & handler ────────────────────────────────────────────────\n\n  use<T>(queueName: string, middleware: MiddlewareFn<T>): void {\n    (this.getOrCreateQueue(queueName) as Queue<T>).useMiddleware(middleware);\n  }\n\n  setHandler<T>(queueName: string, handler: HandlerFn<T>): void {\n    (this.getOrCreateQueue(queueName) as Queue<T>).setHandler(handler);\n  }\n\n  async processTask(taskId: string): Promise<void> {\n    const { queue, task } = this.locateTask(taskId);\n    const middlewares = queue.getMiddlewares() as MiddlewareFn[];\n    const handler = queue.getHandler() as HandlerFn | undefined;\n\n    const run = async (index: number): Promise<void> => {\n      if (index < middlewares.length) {\n        await middlewares[index](task, () => run(index + 1));\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    try {\n      await run(0);\n    } catch (err) {\n      queue.failTask(taskId, err instanceof Error ? err : new Error(String(err)));\n      return;\n    }\n    // Only auto-complete if still processing (middleware might have called fail/cancel)\n    if (task.status === 'processing') {\n      queue.completeTask(taskId);\n    }\n  }\n\n  // ─── Scheduler ──────────────────────────────────────────────────────────\n\n  addSchedule(options: ScheduleOptions): Schedule {\n    return this.scheduler.addSchedule(options);\n  }\n\n  removeSchedule(id: string): void {\n    this.scheduler.removeSchedule(id);\n  }\n\n  listSchedules(): Schedule[] {\n    return this.scheduler.listSchedules();\n  }\n\n  tick(now?: Date): void {\n    this.scheduler.tick(now);\n  }\n\n  // ─── Graceful shutdown ───────────────────────────────────────────────────\n\n  onShutdown(cb: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(cb);\n  }\n\n  async shutdown(timeoutMs = 30000): Promise<ShutdownSummary> {\n    if (this.shutdownPromise) return this.shutdownPromise;\n\n    this.isShuttingDown = true;\n    const startTime = Date.now();\n\n    this.shutdownPromise = (async (): Promise<ShutdownSummary> => {\n      // Run registered callbacks\n      for (const cb of this.shutdownCallbacks) {\n        await cb();\n      }\n\n      // Collect all processing tasks\n      const processingTasks: TaskData[] = [];\n      for (const q of this.queues.values()) {\n        processingTasks.push(...q.getProcessingTasks());\n      }\n\n      if (processingTasks.length === 0) {\n        return { completed: 0, forceCancelled: 0, durationMs: Date.now() - startTime };\n      }\n\n      // Wait for them to finish, up to timeout\n      const deadline = Date.now() + timeoutMs;\n      let completed = 0;\n      let forceCancelled = 0;\n\n      const pollInterval = 50;\n      while (Date.now() < deadline) {\n        const stillProcessing: TaskData[] = [];\n        for (const q of this.queues.values()) {\n          stillProcessing.push(...q.getProcessingTasks());\n        }\n        if (stillProcessing.length === 0) break;\n        await new Promise(r => setTimeout(r, pollInterval));\n      }\n\n      // Force-cancel anything still processing\n      for (const q of this.queues.values()) {\n        for (const t of q.getProcessingTasks()) {\n          try {\n            q.cancelTask(t.id);\n            forceCancelled += 1;\n          } catch {\n            // already done\n          }\n        }\n      }\n\n      // Count completed\n      for (const q of this.queues.values()) {\n        for (const t of q.getAllTasks()) {\n          if (processingTasks.some(p => p.id === t.id) && t.status === 'completed') {\n            completed += 1;\n          }\n        }\n      }\n\n      return {\n        completed,\n        forceCancelled,\n        durationMs: Date.now() - startTime,\n      };\n    })();\n\n    return this.shutdownPromise;\n  }\n}\n```\n\n**Step 4: Create Scheduler.ts**\n\n```typescript\n// src/Scheduler.ts\nimport { randomUUID } from 'crypto';\nimport type { Schedule, ScheduleOptions } from './types.js';\nimport type { TaskQueueSystem } from './TaskQueueSystem.js';\n\nexport class Scheduler {\n  private schedules: Map<string, Schedule & { nextRunAt: Date }> = new Map();\n  private system: TaskQueueSystem;\n\n  constructor(system: TaskQueueSystem) {\n    this.system = system;\n  }\n\n  addSchedule(options: ScheduleOptions): Schedule {\n    const id = options.id ?? randomUUID();\n    const schedule = {\n      id,\n      cron: options.cron,\n      queueName: options.queueName,\n      payload: options.payload,\n      nextRunAt: this.computeNextRun(options.cron, new Date()),\n    };\n    this.schedules.set(id, schedule);\n    return { id, cron: options.cron, queueName: options.queueName, payload: options.payload };\n  }\n\n  removeSchedule(id: string): void {\n    if (!this.schedules.has(id)) throw new Error(`Schedule ${id} not found`);\n    this.schedules.delete(id);\n  }\n\n  listSchedules(): Schedule[] {\n    return Array.from(this.schedules.values()).map(s => ({\n      id: s.id,\n      cron: s.cron,\n      queueName: s.queueName,\n      payload: s.payload,\n      lastRunAt: s.lastRunAt,\n    }));\n  }\n\n  tick(now: Date = new Date()): void {\n    for (const schedule of this.schedules.values()) {\n      if (now >= schedule.nextRunAt) {\n        this.system.addTask(schedule.payload, { queue: schedule.queueName });\n        schedule.lastRunAt = now;\n        schedule.nextRunAt = this.computeNextRun(schedule.cron, now);\n      }\n    }\n  }\n\n  private computeNextRun(cron: string, from: Date): Date {\n    // Supported patterns:\n    //   */N * * * *   — every N minutes\n    //   0 * * * *     — every hour on the hour\n    //   0 0 * * *     — every day at midnight\n    const everyN = cron.match(/^\\*\\/(\\d+) \\* \\* \\* \\*$/);\n    if (everyN) {\n      const n = parseInt(everyN[1], 10);\n      return new Date(from.getTime() + n * 60 * 1000);\n    }\n    if (cron === '0 * * * *') {\n      const next = new Date(from);\n      next.setMinutes(0, 0, 0);\n      next.setHours(next.getHours() + 1);\n      return next;\n    }\n    if (cron === '0 0 * * *') {\n      const next = new Date(from);\n      next.setHours(0, 0, 0, 0);\n      next.setDate(next.getDate() + 1);\n      return next;\n    }\n    throw new Error(`Unsupported cron expression: ${cron}`);\n  }\n}\n```\n\n**Step 5: Create index.ts**\n\n```typescript\n// src/index.ts\nexport { TaskQueueSystem } from './TaskQueueSystem.js';\nexport type {\n  TaskData,\n  TaskOptions,\n  TaskStatus,\n  ProgressInfo,\n  MiddlewareFn,\n  HandlerFn,\n  ProgressListener,\n  ShutdownSummary,\n  Schedule,\n  ScheduleOptions,\n  QueueStats,\n} from './types.js';\n```\n\n**Step 6: Run phase-01 tests**\n\nRun: `cd /workspace && npm test -- src/tests/phase-01.test.ts`\nExpected: All PASS\n\n**Step 7: Commit**\n\n```bash\ngit add -A && git commit -m \"feat: implement phase 1-12 core task queue system\"\n```\n\n---\n\n### Task 3: Tests for Phases 2-4 (Named Queues, Priority, Delayed Tasks)\n\n**Files:**\n- Create: `src/tests/phase-02.test.ts`\n- Create: `src/tests/phase-03.test.ts`\n- Create: `src/tests/phase-04.test.ts`\n\n**Dependencies:** Task 2\n\n**Step 1: Phase-02 tests**\n\n```typescript\n// src/tests/phase-02.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueueSystem } from '../index.js';\n\ndescribe('Phase 2: Named Queues', () => {\n  let system: TaskQueueSystem;\n\n  beforeEach(() => { 