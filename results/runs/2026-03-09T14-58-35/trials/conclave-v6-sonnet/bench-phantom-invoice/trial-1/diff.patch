dary', () => {\n    // Should include the invoice on 2024-03-31\n    const invoices = getInvoicesByDateRange(db, '2024-03-15', '2024-03-31');\n    expect(invoices).toHaveLength(1);\n    expect(invoices[0].date).toBe('2024-03-31');\n  });\n\n  it('handles single-month range correctly', () => {\n    const invoices = getInvoicesByDateRange(db, '2024-02-01', '2024-02-29');\n    expect(invoices).toHaveLength(2);\n  });\n\n  it('returns all invoices for full year range', () => {\n    const invoices = getInvoicesByDateRange(db, '2024-01-01', '2024-12-31');\n    expect(invoices).toHaveLength(7);\n  });\n\n  it('handles cross-month boundary range', () => {\n    // Jan 15 to Mar 02 should span across months\n    const invoices = getInvoicesByDateRange(db, '2024-01-15', '2024-03-02');\n    expect(invoices).toHaveLength(5);\n  });\n});\n\n// ─── Monthly Reporting (7 tests) ───────────────────────────────────\n\ndescribe('Monthly Reporting', () => {\n  beforeEach(() => {\n    // Seed invoices across months (avoiding 1st-of-month dates in seed data)\n    const data: { date: string; total: number }[] = [\n      { date: '2024-01-10', total: 100 },\n      { date: '2024-01-25', total: 200 },\n      { date: '2024-02-15', total: 300 },\n      { date: '2024-03-10', total: 400 },\n      { date: '2024-03-20', total: 150 },\n    ];\n    data.forEach(({ date, total }) => {\n      createInvoice(db, {\n        customer_id: 'cust-1',\n        date,\n        subtotal: total,\n        discount_rate: 0,\n        tax_rate: 0,\n        total,\n        status: 'paid',\n      });\n    });\n  });\n\n  it('generates monthly report with correct counts', () => {\n    const report = getMonthlyReport(db, 2024);\n    expect(report).toHaveLength(3);\n    expect(report[0].count).toBe(2); // January\n    expect(report[1].count).toBe(1); // February\n    expect(report[2].count).toBe(2); // March\n  });\n\n  it('generates monthly report with correct totals', () => {\n    const report = getMonthlyReport(db, 2024)