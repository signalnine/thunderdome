 }));\n    const cycles = deps.detectCycles('a', registry);\n    expect(cycles).not.toBeNull();\n    expect(cycles!.length).toBeGreaterThan(0);\n  });\n\n  it('hasCircularDependency returns false for acyclic graph', () => {\n    expect(deps.hasCircularDependency('root', registry)).toBe(false);\n  });\n\n  it('hasCircularDependency returns true for cyclic graph', () => {\n    registry.register(makeManifest('x', '1.0.0', { y: '1.0.0' }));\n    registry.register(makeManifest('y', '1.0.0', { x: '1.0.0' }));\n    expect(deps.hasCircularDependency('x', registry)).toBe(true);\n  });\n\n  it('topologicalSort returns dependencies before dependents', () => {\n    const order = deps.topologicalSort('root', registry);\n    const rootIdx = order.indexOf('root');\n    const c1Idx = order.indexOf('child1');\n    const gcIdx = order.indexOf('grandchild');\n    // grandchild before child1 before root\n    expect(gcIdx).toBeLessThan(c1Idx);\n    expect(c1Idx).toBeLessThan(rootIdx);\n  });\n\n  it('flattenDependencies returns all transitive deps (no root)', () => {\n    const flat = deps.flattenDependencies('root', registry);\n    expect(flat).toContain('child1');\n    expect(flat).toContain('child2');\n    expect(flat).toContain('grandchild');\n    expect(flat).not.toContain('root');\n  });\n\n  it('flattenDependencies deduplicates', () => {\n    // diamond dependency: root -> a, root -> b, both -> shared\n    registry.register(makeManifest('r2', '1.0.0', { a: '1.0.0', b: '1.0.0' }));\n    registry.register(makeManifest('a', '1.0.0', { shared: '1.0.0' }));\n    registry.register(makeManifest('b', '1.0.0', { shared: '1.0.0' }));\n    registry.register(makeManifest('shared', '1.0.0', {}));\n    const flat = deps.flattenDependencies('r2', registry);\n    const sharedCount = flat.filter(n => n === 'shared').length;\n    expect(sharedCount).toBe(1);\n  });\n});\nEOF","description":"Write /workspace/src/deps/deps.test.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":nul