(visited.has(name)) return;\n    visited.add(name);\n    const manifest = registry.get(name);\n    if (manifest) {\n      for (const dep of Object.keys(manifest.dependencies)) {\n        topoSortInternal(dep, registry, visited, result);\n      }\n    }\n    result.push(name);\n  }\n\n  return {\n    buildTree(name, registry) { return buildTreeInternal(name, registry, new Set()); },\n    detectCycles(name, registry) { const c = detectCyclesInternal(name, registry, [], new Set()); return c.length > 0 ? c : null; },\n    topologicalSort(name, registry) { const r: string[] = []; topoSortInternal(name, registry, new Set(), r); return r; },\n    flattenDependencies(name, registry) {\n      const result: string[] = [];\n      const visited = new Set<string>();\n      const queue = [name];\n      visited.add(name);\n      while (queue.length > 0) {\n        const current = queue.shift()!;\n        const manifest = registry.get(current);\n        if (!manifest) continue;\n        for (const dep of Object.keys(manifest.dependencies)) {\n          if (!visited.has(dep)) { visited.add(dep); result.push(dep); queue.push(dep); }\n        }\n      }\n      return result;\n    },\n    hasCircularDependency(name, registry) { return detectCyclesInternal(name, registry, [], new Set()).length > 0; },\n  };\n}\n```\n\nReturn the final test output showing all tests passing.","agentId":"a24bc20","content":[{"type":"text","text":"All 8 tests pass. Here is a summary of what was created:\n\n**Files created:**\n\n1. `/workspace/src/index.ts` - The integration layer that:\n   - Instantiates all five services (`createRegistry`, `createResolver`, `createRunner`, `createReviewService`, `createDepsService`) via a single `createMarketplace(dbPath)` factory\n   - Exposes the `Marketplace` interface with direct access to all five services plus `installPlugin`\n   - `installPlugin` validates required manifest fields (`name`, `version`, `entryPoint`), registers the plugin, resolves dependencies against