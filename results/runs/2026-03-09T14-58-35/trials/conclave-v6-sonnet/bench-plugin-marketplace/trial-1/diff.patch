uginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: 'Good' });\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u2', rating: 2, comment: 'Meh' });\n    reviews.addReview({ pluginName: 'bar', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'Best' });\n    expect(reviews.getReviews('foo')).toHaveLength(2);\n    expect(reviews.getReviews('bar')).toHaveLength(1);\n  });\n\n  it('getAverageRating computes correct average', () => {\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: '' });\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u2', rating: 2, comment: '' });\n    expect(reviews.getAverageRating('foo')).toBe(3);\n  });\n\n  it('getAverageRating returns 0 when no reviews', () => {\n    expect(reviews.getAverageRating('none')).toBe(0);\n  });\n\n  it('flagReview marks a review as flagged', () => {\n    const r = reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'spam' });\n    reviews.flagReview(r.id);\n    const flagged = reviews.getFlaggedReviews();\n    expect(flagged.some(f => f.id === r.id)).toBe(true);\n  });\n\n  it('flagged reviews excluded from average rating', () => {\n    const r1 = reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u2', rating: 1, comment: '' });\n    reviews.flagReview(r1.id);\n    // only r2 (rating 1) is unflagged\n    expect(reviews.getAverageRating('foo')).toBe(1);\n  });\n\n  it('removeReview deletes a review', () => {\n    const r = reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: '' });\n    expect(reviews.removeReview(r.id)).toBe(true);\n    expect(reviews.getReviews('foo')).toHaveLength(0);\n  });\n\n  it('removeReview returns false for nonexistent id', () => {\n    ex