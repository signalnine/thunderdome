+{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_011PzH2y8XpSugwPyev1BjYU","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01PMzMimJY5V3A7eKogVKshn","name":"Write","input":{"file_path":"/workspace/docs/plans/2026-03-09-plugin-marketplace.md","content":"# Plugin Marketplace Implementation Plan\n\n> **For Claude:** REQUIRED SUB-SKILL: Use conclave:executing-plans to implement this plan task-by-task.\n\n**Goal:** Build a 5-module plugin marketplace system with registry, version resolution, sandboxed execution, reviews, and dependency graph analysis, composed into a single `createMarketplace()` API.\n\n**Architecture:** Each module lives in its own directory (`src/registry/`, `src/resolver/`, etc.) and exports a factory function returning the typed service interface. Modules share only types from `src/types.ts`. SQLite (better-sqlite3) is used for persistence in registry and reviews; all other modules are stateless. The integration layer in `src/index.ts` composes all five services.\n\n**Tech Stack:** TypeScript (ES2022, Node16 modules), better-sqlite3, semver, Node.js `vm` module for sandboxing, vitest for testing.\n\n---\n\n### Task 1: Plugin Registry (`src/registry/index.ts`)\n\n**Files:**\n- Create: `src/registry/index.ts`\n- Create: `src/registry/registry.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write failing tests**\n\n```typescript\n// src/registry/registry.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { createRegistry } from './index.js';\nimport type { PluginManifest } from '../types.js';\n\nconst makeManifest = (name: string, version: string): PluginManifest => ({\n  name,\n  version,\n  description: 'test plugin',\n  author: 'tester',\n  dependencies: {},\n  entryPoint: 'index.js',\n  permissions: [],\n});\n\ndescribe('PluginRegistry', () => {\n  let registry: ReturnType<typeof createRegistry>;\n\n  beforeEach(() => {\n    registry = createRegistry(':memory:');\n  });\n\n  it('registers and retrieves a plugin', () => {\n    const m = makeManifest('foo', '1.0.0');\n    registry.register(m);\n    expect(registry.get('foo')).toEqual(m);\n  });\n\n  it('get returns null for unknown plugin', () => {\n    expect(registry.get('unknown')).toBeNull();\n  });\n\n  it('registers multiple versions', () => {\n    registry.register(makeManifest('foo', '1.0.0'));\n    registry.register(makeManifest('foo', '2.0.0'));\n    const versions = registry.listVersions('foo');\n    expect(versions).toContain('1.0.0');\n    expect(versions).toContain('2.0.0');\n  });\n\n  it('getVersion returns specific version', () => {\n    registry.register(makeManifest('foo', '1.0.0'));\n    registry.register(makeManifest('foo', '2.0.0'));\n    const m = registry.getVersion('foo', '1.0.0');\n    expect(m?.version).toBe('1.0.0');\n  });\n\n  it('get returns latest version (highest semver)', () => {\n    registry.register(makeManifest('foo', '1.0.0'));\n    registry.register(makeManifest('foo', '2.0.0'));\n    expect(registry.get('foo')?.version).toBe('2.0.0');\n  });\n\n  it('list returns all plugins (deduplicated by name/version)', () => {\n    registry.register(makeManifest('foo', '1.0.0'));\n    registry.register(makeManifest('bar', '1.0.0'));\n    const all = registry.list();\n    expect(all.length).toBe(2);\n  });\n\n  it('search filters by name and description', () => {\n    registry.register(makeManifest('awesome-plugin', '1.0.0'));\n    registry.register(makeManifest('other', '1.0.0'));\n    const results = registry.search('awesome');\n    expect(results.length).toBe(1);\n    expect(results[0].name).toBe('awesome-plugin');\n  });\n\n  it('remove deletes a specific version', () => {\n    registry.register(makeManifest('foo', '1.0.0'));\n    registry.register(makeManifest('foo', '2.0.0'));\n    const removed = registry.remove('foo', '1.0.0');\n    expect(removed).toBe(true);\n    expect(registry.getVersion('foo', '1.0.0')).toBeNull();\n    expect(registry.getVersion('foo', '2.0.0')).not.toBeNull();\n  });\n\n  it('remove returns false for nonexistent plugin', () => {\n    expect(registry.remove('none', '1.0.0')).toBe(false);\n  });\n\n  it('update modifies fields', () => {\n    registry.register(makeManifest('foo', '1.0.0'));\n    registry.update('foo', '1.0.0', { description: 'updated' });\n    expect(registry.getVersion('foo', '1.0.0')?.description).toBe('updated');\n  });\n\n  it('listVersions returns empty array for unknown plugin', () => {\n    expect(registry.listVersions('none')).toEqual([]);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npx vitest run src/registry/registry.test.ts 2>&1 | tail -20\n```\n\nExpected: FAIL - module not found\n\n**Step 3: Implement the registry**\n\n```typescript\n// src/registry/index.ts\nimport Database from 'better-sqlite3';\nimport type { PluginManifest, RegistryService } from '../types.js';\nimport semver from 'semver';\n\nexport function createRegistry(dbPath = ':memory:'): RegistryService {\n  const db = new Database(dbPath);\n\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS plugins (\n      name TEXT NOT NULL,\n      version TEXT NOT NULL,\n      data TEXT NOT NULL,\n      PRIMARY KEY (name, version)\n    )\n  `);\n\n  return {\n    register(manifest: PluginManifest): void {\n      const stmt = db.prepare(\n        'INSERT OR REPLACE INTO plugins (name, version, data) VALUES (?, ?, ?)'\n      );\n      stmt.run(manifest.name, manifest.version, JSON.stringify(manifest));\n    },\n\n    get(name: string): PluginManifest | null {\n      const versions = this.listVersions(name);\n      if (versions.length === 0) return null;\n      const latest = semver.maxSatisfying(versions, '*') ?? versions[versions.length - 1];\n      return this.getVersion(name, latest);\n    },\n\n    getVersion(name: string, version: string): PluginManifest | null {\n      const row = db.prepare('SELECT data FROM plugins WHERE name = ? AND version = ?')\n        .get(name, version) as { data: string } | undefined;\n      return row ? JSON.parse(row.data) as PluginManifest : null;\n    },\n\n    list(): PluginManifest[] {\n      const rows = db.prepare('SELECT data FROM plugins').all() as { data: string }[];\n      return rows.map(r => JSON.parse(r.data) as PluginManifest);\n    },\n\n    search(query: string): PluginManifest[] {\n      const q = query.toLowerCase();\n      return this.list().filter(m =>\n        m.name.toLowerCase().includes(q) ||\n        m.description.toLowerCase().includes(q)\n      );\n    },\n\n    remove(name: string, version: string): boolean {\n      const result = db.prepare('DELETE FROM plugins WHERE name = ? AND version = ?')\n        .run(name, version);\n      return result.changes > 0;\n    },\n\n    listVersions(name: string): string[] {\n      const rows = db.prepare('SELECT version FROM plugins WHERE name = ?')\n        .all(name) as { version: string }[];\n      return rows.map(r => r.version);\n    },\n\n    update(name: string, version: string, updates: Partial<PluginManifest>): void {\n      const existing = this.getVersion(name, version);\n      if (!existing) throw new Error(`Plugin ${name}@${version} not found`);\n      const updated = { ...existing, ...updates };\n      db.prepare('UPDATE plugins SET data = ? WHERE name = ? AND version = ?')\n        .run(JSON.stringify(updated), name, version);\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npx vitest run src/registry/registry.test.ts 2>&1 | tail -20\n```\n\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/registry/ && git commit -m \"feat: implement plugin registry with SQLite persistence\"\n```\n\n---\n\n### Task 2: Version Resolver (`src/resolver/index.ts`)\n\n**Files:**\n- Create: `src/resolver/index.ts`\n- Create: `src/resolver/resolver.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write failing tests**\n\n```typescript\n// src/resolver/resolver.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { createResolver } from './index.js';\n\ndescribe('VersionResolver', () => {\n  const resolver = createResolver();\n\n  it('satisfies a matching version against a range', () => {\n    expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);\n    expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n  });\n\n  it('maxSatisfying returns highest matching version', () => {\n    const versions = ['1.0.0', '1.2.0', '1.5.0', '2.0.0'];\n    expect(resolver.maxSatisfying(versions, '^1.0.0')).toBe('1.5.0');\n  });\n\n  it('maxSatisfying returns null when no match', () => {\n    expect(resolver.maxSatisfying(['1.0.0'], '^2.0.0')).toBeNull();\n  });\n\n  it('validRange returns true for valid ranges', () => {\n    expect(resolver.validRange('^1.0.0')).toBe(true);\n    expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);\n    expect(resolver.validRange('not-a-range')).toBe(false);\n  });\n\n  it('resolve returns concrete versions for constraints', () => {\n    const available = { foo: ['1.0.0', '1.5.0', '2.0.0'], bar: ['3.0.0', '4.0.0'] };\n    const constraints = [\n      { name: 'foo', range: '^1.0.0' },\n      { name: 'bar', range: '^3.0.0' },\n    ];\n    const resolved = resolver.resolve(constraints, available);\n    expect(resolved).toHaveLength(2);\n    const foo = resolved.find(r => r.name === 'foo');\n    expect(foo?.version).toBe('1.5.0');\n    expect(foo?.satisfies).toBe('^1.0.0');\n  });\n\n  it('resolve throws when constraint cannot be satisfied', () => {\n    const available = { foo: ['1.0.0'] };\n    const constraints = [{ name: 'foo', range: '^2.0.0' }];\n    expect(() => resolver.resolve(constraints, available)).toThrow();\n  });\n\n  it('resolve throws when plugin not in available', () => {\n    const available = {};\n    const constraints = [{ name: 'foo', range: '^1.0.0' }];\n    expect(() => resolver.resolve(constraints, available)).toThrow();\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npx vitest run src/resolver/resolver.test.ts 2>&1 | tail -20\n```\n\n**Step 3: Implement the resolver**\n\n```typescript\n// src/resolver/index.ts\nimport semver from 'semver';\nimport type { ResolverService, VersionConstraint, ResolvedVersion } from '../types.js';\n\nexport function createResolver(): ResolverService {\n  return {\n    resolve(constraints: VersionConstraint[], available: Record<string, string[]>): ResolvedVersion[] {\n      return constraints.map(({ name, range }) => {\n        const versions = available[name];\n        if (!versions || versions.length === 0) {\n          throw new Error(`No versions available for plugin: ${name}`);\n        }\n        const version = semver.maxSatisfying(versions, range);\n        if (!version) {\n          throw new Error(`No version of ${name} satisfies range ${range}. Available: ${versions.join(', ')}`);\n        }\n        return { name, version, satisfies: range };\n      });\n    },\n\n    satisfies(version: string, range: string): boolean {\n      return semver.satisfies(version, range);\n    },\n\n    maxSatisfying(versions: string[], range: string): string | null {\n      return semver.maxSatisfying(versions, range);\n    },\n\n    validRange(range: string): boolean {\n      return semver.validRange(range) !== null;\n    },\n  };\n}\n```\n\n**Step 4: Run tests**\n\n```bash\ncd /workspace && npx vitest run src/resolver/resolver.test.ts 2>&1 | tail -20\n```\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/resolver/ && git commit -m \"feat: implement semver version resolver\"\n```\n\n---\n\n### Task 3: Sandboxed Runner (`src/runner/index.ts`)\n\n**Files:**\n- Create: `src/runner/index.ts`\n- Create: `src/runner/runner.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write failing tests**\n\n```typescript\n// src/runner/runner.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { createRunner } from './index.js';\n\ndescribe('SandboxedRunner', () => {\n  const runner = createRunner();\n\n  it('executes simple code and returns output', async () => {\n    const result = await runner.execute('1 + 1');\n    expect(result.success).toBe(true);\n    expect(result.output).toBe(2);\n    expect(result.duration).toBeGreaterThanOrEqual(0);\n  });\n\n  it('passes context into the sandbox', async () => {\n    const result = await runner.execute('x + y', { x: 3, y: 4 });\n    expect(result.success).toBe(true);\n    expect(result.output).toBe(7);\n  });\n\n  it('captures errors without throwing', async () => {\n    const result = await runner.execute('throw new Error(\"boom\")');\n    expect(result.success).toBe(false);\n    expect(result.error).toContain('boom');\n  });\n\n  it('returns memoryUsed as a number', async () => {\n    const result = await runner.execute('\"hello\"');\n    expect(typeof result.memoryUsed).toBe('number');\n    expect(result.memoryUsed).toBeGreaterThanOrEqual(0);\n  });\n\n  it('enforces timeout for runaway code', async () => {\n    const result = await runner.executeWithTimeout('while(true){}', 100);\n    expect(result.success).toBe(false);\n    expect(result.error).toMatch(/timeout|timed out/i);\n  }, 5000);\n\n  it('executeWithTimeout runs normal code fine', async () => {\n    const result = await runner.executeWithTimeout('\"ok\"', 2000);\n    expect(result.success).toBe(true);\n    expect(result.output).toBe('ok');\n  });\n\n  it('sandbox is isolated - no access to process', async () => {\n    const result = await runner.execute('typeof process');\n    // process should be undefined or inaccessible in sandbox\n    expect(result.output).toBe('undefined');\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npx vitest run src/runner/runner.test.ts 2>&1 | tail -20\n```\n\n**Step 3: Implement the runner**\n\n```typescript\n// src/runner/index.ts\nimport vm from 'vm';\nimport type { RunnerService, SandboxResult } from '../types.js';\n\nexport function createRunner(): RunnerService {\n  async function runCode(\n    code: string,\n    timeoutMs: number,\n    context: Record<string, unknown> = {}\n  ): Promise<SandboxResult> {\n    const start = Date.now();\n    const memBefore = process.memoryUsage().heapUsed;\n\n    try {\n      const sandbox = vm.createContext({ ...context });\n      const script = new vm.Script(code);\n      const output = script.runInContext(sandbox, { timeout: timeoutMs });\n      const duration = Date.now() - start;\n      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - memBefore);\n      return { success: true, output, duration, memoryUsed };\n    } catch (err: unknown) {\n      const duration = Date.now() - start;\n      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - memBefore);\n      const error = err instanceof Error ? err.message : String(err);\n      const isTimeout = error.includes('timed out') || error.includes('Script execution timed out');\n      return {\n        success: false,\n        output: null,\n        duration,\n        memoryUsed,\n        error: isTimeout ? `Execution timed out after ${timeoutMs}ms` : error,\n      };\n    }\n  }\n\n  return {\n    execute(code: string, context?: Record<string, unknown>): Promise<SandboxResult> {\n      return runCode(code, 5000, context);\n    },\n\n    executeWithTimeout(\n      code: string,\n      timeoutMs: number,\n      context?: Record<string, unknown>\n    ): Promise<SandboxResult> {\n      return runCode(code, timeoutMs, context);\n    },\n  };\n}\n```\n\n**Step 4: Run tests**\n\n```bash\ncd /workspace && npx vitest run src/runner/runner.test.ts 2>&1 | tail -20\n```\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/runner/ && git commit -m \"feat: implement sandboxed runner using Node.js vm module\"\n```\n\n---\n\n### Task 4: Review System (`src/reviews/index.ts`)\n\n**Files:**\n- Create: `src/reviews/index.ts`\n- Create: `src/reviews/reviews.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write failing tests**\n\n```typescript\n// src/reviews/reviews.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { createReviewService } from './index.js';\n\ndescribe('ReviewService', () => {\n  let reviews: ReturnType<typeof createReviewService>;\n\n  beforeEach(() => {\n    reviews = createReviewService(':memory:');\n  });\n\n  it('adds a review and returns it with id and createdAt', () => {\n    const r = reviews.addReview({\n      pluginName: 'foo',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'Great!',\n    });\n    expect(r.id).toBeGreaterThan(0);\n    expect(r.flagged).toBe(false);\n    expect(r.createdAt).toBeTruthy();\n    expect(r.rating).toBe(5);\n  });\n\n  it('getReviews returns all reviews for a plugin', () => {\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: 'Good' });\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u2', rating: 2, comment: 'Meh' });\n    reviews.addReview({ pluginName: 'bar', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'Best' });\n    expect(reviews.getReviews('foo')).toHaveLength(2);\n    expect(reviews.getReviews('bar')).toHaveLength(1);\n  });\n\n  it('getAverageRating computes correct average', () => {\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: '' });\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u2', rating: 2, comment: '' });\n    expect(reviews.getAverageRating('foo')).toBe(3);\n  });\n\n  it('getAverageRating returns 0 when no reviews', () => {\n    expect(reviews.getAverageRating('none')).toBe(0);\n  });\n\n  it('flagReview marks a review as flagged', () => {\n    const r = reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'spam' });\n    reviews.flagReview(r.id);\n    const flagged = reviews.getFlaggedReviews();\n    expect(flagged.some(f => f.id === r.id)).toBe(true);\n  });\n\n  it('flagged reviews excluded from average rating', () => {\n    const r1 = reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u2', rating: 1, comment: '' });\n    reviews.flagReview(r1.id);\n    // only r2 (rating 1) is unflagged\n    expect(reviews.getAverageRating('foo')).toBe(1);\n  });\n\n  it('removeReview deletes a review', () => {\n    const r = reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: '' });\n    expect(reviews.removeReview(r.id)).toBe(true);\n    expect(reviews.getReviews('foo')).toHaveLength(0);\n  });\n\n  it('removeReview returns false for nonexistent id', () => {\n    expect(reviews.removeReview(9999)).toBe(false);\n  });\n\n  it('getReviewsByUser returns all reviews by a user', () => {\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    reviews.addReview({ pluginName: 'bar', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: '' });\n    reviews.addReview({ pluginName: 'baz', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: '' });\n    expect(reviews.getReviewsByUser('u1')).toHaveLength(2);\n  });\n\n  it('getReviewCount returns correct count', () => {\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n    expect(reviews.getReviewCount('foo')).toBe(2);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npx vitest run src/reviews/reviews.test.ts 2>&1 | tail -20\n```\n\n**Step 3: Implement the review service**\n\n```typescript\n// src/reviews/index.ts\nimport Database from 'better-sqlite3';\nimport type { Review, ReviewService } from '../types.js';\n\nexport function createReviewService(dbPath = ':memory:'): ReviewService {\n  const db = new Database(dbPath);\n\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS reviews (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      pluginName TEXT NOT NULL,\n      pluginVersion TEXT NOT NULL,\n      userId TEXT NOT NULL,\n      rating INTEGER NOT NULL,\n      comment TEXT NOT NULL,\n      flagged INTEGER NOT NULL DEFAULT 0,\n      createdAt TEXT NOT NULL\n    )\n  `);\n\n  function rowToReview(row: Record<string, unknown>): Review {\n    return {\n      id: row.id as number,\n      pluginName: row.pluginName as string,\n      pluginVersion: row.pluginVersion as string,\n      userId: row.userId as string,\n      rating: row.rating as number,\n      comment: row.comment as string,\n      flagged: Boolean(row.flagged),\n      createdAt: row.createdAt as string,\n    };\n  }\n\n  return {\n    addReview(review: Omit<Review, 'id' | 'createdAt' | 'flagged'>): Review {\n      const createdAt = new Date().toISOString();\n      const result = db.prepare(\n        'INSERT INTO reviews (pluginName, pluginVersion, userId, rating, comment, flagged, createdAt) VALUES (?, ?, ?, ?, ?, 0, ?)'\n      ).run(review.pluginName, review.pluginVersion, review.userId, review.rating, review.comment, createdAt);\n      return { ...review, id: result.lastInsertRowid as number, flagged: false, createdAt };\n    },\n\n    getReviews(pluginName: string): Review[] {\n      const rows = db.prepare('SELECT * FROM reviews WHERE pluginName = ?').all(pluginName) as Record<string, unknown>[];\n      return rows.map(rowToReview);\n    },\n\n    getAverageRating(pluginName: string): number {\n      const row = db.prepare(\n        'SELECT AVG(rating) as avg FROM reviews WHERE pluginName = ? AND flagged = 0'\n      ).get(pluginName) as { avg: number | null };\n      return row.avg ?? 0;\n    },\n\n    flagReview(reviewId: number): void {\n      db.prepare('UPDATE reviews SET flagged = 1 WHERE id = ?').run(reviewId);\n    },\n\n    getFlaggedReviews(): Review[] {\n      const rows = db.prepare('SELECT * FROM reviews WHERE flagged = 1').all() as Record<string, unknown>[];\n      return rows.map(rowToReview);\n    },\n\n    removeReview(reviewId: number): boolean {\n      const result = db.prepare('DELETE FROM reviews WHERE id = ?').run(reviewId);\n      return result.changes > 0;\n    },\n\n    getReviewsByUser(userId: string): Review[] {\n      const rows = db.prepare('SELECT * FROM reviews WHERE userId = ?').all(userId) as Record<string, unknown>[];\n      return rows.map(rowToReview);\n    },\n\n    getReviewCount(pluginName: string): number {\n      const row = db.prepare('SELECT COUNT(*) as count FROM reviews WHERE pluginName = ?').get(pluginName) as { count: number };\n      return row.count;\n    },\n  };\n}\n```\n\n**Step 4: Run tests**\n\n```bash\ncd /workspace && npx vitest run src/reviews/reviews.test.ts 2>&1 | tail -20\n```\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/reviews/ && git commit -m \"feat: implement review service with SQLite persistence\"\n```\n\n---\n\n### Task 5: Dependency Graph (`src/deps/index.ts`)\n\n**Files:**\n- Create: `src/deps/index.ts`\n- Create: `src/deps/deps.test.ts`\n\n**Dependencies:** Task 1 (registry needed for tests)\n\n**Step 1: Write failing tests**\n\n```typescript\n// src/deps/deps.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { createDepsService } from './index.js';\nimport { createRegistry } from '../registry/index.js';\nimport type { PluginManifest, RegistryService } from '../types.js';\n\nfunction makeManifest(name: string, version: string, deps: Record<string, string> = {}): PluginManifest {\n  return { name, version, description: '', author: '', dependencies: deps, entryPoint: '', permissions: [] };\n}\n\ndescribe('DepsService', () => {\n  let registry: RegistryService;\n  let deps: ReturnType<typeof createDepsService>;\n\n  beforeEach(() => {\n    registry = createRegistry(':memory:');\n    deps = createDepsService();\n\n    registry.register(makeManifest('root', '1.0.0', { child1: '1.0.0', child2: '1.0.0' }));\n    registry.register(makeManifest('child1', '1.0.0', { grandchild: '1.0.0' }));\n    registry.register(makeManifest('child2', '1.0.0', {}));\n    registry.register(makeManifest('grandchild', '1.0.0', {}));\n  });\n\n  it('buildTree returns a tree with correct structure', () => {\n    const tree = deps.buildTree('root', registry);\n    expect(tree.name).toBe('root');\n    expect(tree.dependencies.length).toBe(2);\n    const c1 = tree.dependencies.find(d => d.name === 'child1');\n    expect(c1?.dependencies.length).toBe(1);\n    expect(c1?.dependencies[0].name).toBe('grandchild');\n  });\n\n  it('detectCycles returns null when no cycles', () => {\n    expect(deps.detectCycles('root', registry)).toBeNull();\n  });\n\n  it('detectCycles returns cycle paths when cycles present', () => {\n    // a -> b -> a\n    registry.register(makeManifest('a', '1.0.0', { b: '1.0.0' }));\n    registry.register(makeManifest('b', '1.0.0', { a: '1.0.0' }));\n    const cycles = deps.detectCycles('a', registry);\n    expect(cycles).not.toBeNull();\n    expect(cycles!.length).toBeGreaterThan(0);\n  });\n\n  it('hasCircularDependency returns false for acyclic graph', () => {\n    expect(deps.hasCircularDependency('root', registry)).toBe(false);\n  });\n\n  it('hasCircularDependency returns true for cyclic graph', () => {\n    registry.register(makeManifest('x', '1.0.0', { y: '1.0.0' }));\n    registry.register(makeManifest('y', '1.0.0', { x: '1.0.0' }));\n    expect(deps.hasCircularDependency('x', registry)).toBe(true);\n  });\n\n  it('topologicalSort returns dependencies before dependents', () => {\n    const order = deps.topologicalSort('root', registry);\n    const rootIdx = order.indexOf('root');\n    const c1Idx = order.indexOf('child1');\n    const gcIdx = order.indexOf('grandchild');\n    // grandchild before child1 before root\n    expect(gcIdx).toBeLessThan(c1Idx);\n    expect(c1Idx).toBeLessThan(rootIdx);\n  });\n\n  it('flattenDependencies returns all transitive deps (no root)', () => {\n    const flat = deps.flattenDependencies('root', registry);\n    expect(flat).toContain('child1');\n    expect(flat).toContain('child2');\n    expect(flat).toContain('grandchild');\n    expect(flat).not.toContain('root');\n  });\n\n  it('flattenDependencies deduplicates', () => {\n    // diamond dependency: root -> a, root -> b, both -> shared\n    registry.register(makeManifest('r2', '1.0.0', { a: '1.0.0', b: '1.0.0' }));\n    registry.register(makeManifest('a', '1.0.0', { shared: '1.0.0' }));\n    registry.register(makeManifest('b', '1.0.0', { shared: '1.0.0' }));\n    registry.register(makeManifest('shared', '1.0.0', {}));\n    const flat = deps.flattenDependencies('r2', registry);\n    const sharedCount = flat.filter(n => n === 'shared').length;\n    expect(sharedCount).toBe(1);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npx vitest run src/deps/deps.test.ts 2>&1 | tail -20\n```\n\n**Step 3: Implement the deps service**\n\n```typescript\n// src/deps/index.ts\nimport type { DependencyNode, DepsService, RegistryService } from '../types.js';\n\nexport function createDepsService(): DepsService {\n  function buildTreeInternal(\n    name: string,\n    registry: RegistryService,\n    visited: Set<string>\n  ): DependencyNode {\n    const manifest = registry.get(name);\n    if (!manifest) return { name, version: 'unknown', dependencies: [] };\n    if (visited.has(name)) return { name, version: manifest.version, dependencies: [] };\n\n    visited.add(name);\n    const children = Object.keys(manifest.dependencies).map(dep =>\n      buildTreeInternal(dep, registry, new Set(visited))\n    );\n    return { name, version: manifest.version, dependencies: children };\n  }\n\n  function detectCyclesInternal(\n    name: string,\n    registry: RegistryService,\n    path: string[],\n    visiting: Set<string>\n  ): string[][] {\n    if (visiting.has(name)) {\n      const cycleStart = path.indexOf(name);\n      return [path.slice(cycleStart).concat(name)];\n    }\n\n    const manifest = registry.get(name);\n    if (!manifest) return [];\n\n    visiting.add(name);\n    path.push(name);\n    const cycles: string[][] = [];\n\n    for (const dep of Object.keys(manifest.dependencies)) {\n      cycles.push(...detectCyclesInternal(dep, registry, [...path], new Set(visiting)));\n    }\n\n    return cycles;\n  }\n\n  function topoSortInternal(\n    name: string,\n    registry: RegistryService,\n    visited: Set<string>,\n    result: string[]\n  ): void {\n    if (visited.has(name)) return;\n    visited.add(name);\n\n    const manifest = registry.get(name);\n    if (manifest) {\n      for (const dep of Object.keys(manifest.dependencies)) {\n        topoSortInternal(dep, registry, visited, result);\n      }\n    }\n    result.push(name);\n  }\n\n  return {\n    buildTree(name: string, registry: RegistryService): DependencyNode {\n      return buildTreeInternal(name, registry, new Set());\n    },\n\n    detectCycles(name: string, registry: RegistryService): string[][] | null {\n      const cycles = detectCyclesInternal(name, registry, [], new Set());\n      return cycles.length > 0 ? cycles : null;\n    },\n\n    topologicalSort(name: string, registry: RegistryService): string[] {\n      const result: string[] = [];\n      topoSortInternal(name, registry, new Set(), result);\n      return result;\n    },\n\n    flattenDependencies(name: string, registry: RegistryService): string[] {\n      const result: string[] = [];\n      const visited = new Set<string>();\n      const queue = [name];\n      visited.add(name);\n\n      while (queue.length > 0) {\n        const current = queue.shift()!;\n        const manifest = registry.get(current);\n        if (!manifest) continue;\n        for (const dep of Object.keys(manifest.dependencies)) {\n          if (!visited.has(dep)) {\n            visited.add(dep);\n            result.push(dep);\n            queue.push(dep);\n          }\n        }\n      }\n      return result;\n    },\n\n    hasCircularDependency(name: string, registry: RegistryService): boolean {\n      const cycles = detectCyclesInternal(name, registry, [], new Set());\n      return cycles.length > 0;\n    },\n  };\n}\n```\n\n**Step 4: Run tests**\n\n```bash\ncd /workspace && npx vitest run src/deps/deps.test.ts 2>&1 | tail -20\n```\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/deps/ && git commit -m \"feat: implement dependency graph analysis service\"\n```\n\n---\n\n### Task 6: Integration Layer (`src/index.ts`)\n\n**Files:**\n- Create: `src/index.ts`\n- Create: `src/index.test.ts`\n\n**Dependencies:** Tasks 1-5\n\n**Step 1: Write failing tests**\n\n```typescript\n// src/index.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { createMarketplace } from './index.js';\nimport type { PluginManifest } from './types.js';\n\nconst makeManifest = (overrides: Partial<PluginManifest> = {}): PluginManifest => ({\n  name: 'my-plugin',\n  version: '1.0.0',\n  description: 'test',\n  author: 'me',\n  dependencies: {},\n  entryPoint: '\"loaded\"',\n  permissions: [],\n  ...overrides,\n});\n\ndescribe('createMarketplace', () => {\n  it('exposes all five services', () => {\n    const mp = createMarketplace();\n    expect(mp.registry).toBeDefined();\n    expect(mp.resolver).toBeDefined();\n    expect(mp.runner).toBeDefined();\n    expect(mp.reviews).toBeDefined();\n    expect(mp.deps).toBeDefined();\n  });\n\n  it('installPlugin validates required fields - missing name throws', async () => {\n    const mp = createMarketplace();\n    await expect(mp.installPlugin({ ...makeManifest(), name: '' })).rejects.toThrow();\n  });\n\n  it('installPlugin validates required fields - missing version throws', async () => {\n    const mp = createMarketplace();\n    await expect(mp.installPlugin({ ...make