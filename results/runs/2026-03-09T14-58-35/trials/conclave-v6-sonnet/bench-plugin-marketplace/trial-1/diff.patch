me: 'main-plugin',\n      dependencies: { 'dep-a': '^1.0.0' },\n    }));\n    expect(result.resolvedDeps).toHaveLength(1);\n    expect(result.resolvedDeps[0].name).toBe('dep-a');\n    expect(result.resolvedDeps[0].version).toBe('1.5.0');\n  });\n\n  it('installPlugin rejects circular dependencies', async () => {\n    const mp = createMarketplace();\n    // Register a->b->a cycle\n    mp.registry.register(makeManifest({ name: 'a', version: '1.0.0', dependencies: { b: '1.0.0' } }));\n    mp.registry.register(makeManifest({ name: 'b', version: '1.0.0', dependencies: { a: '1.0.0' } }));\n    await expect(mp.installPlugin(makeManifest({\n      name: 'a',\n      version: '2.0.0',\n      dependencies: { b: '1.0.0' },\n    }))).rejects.toThrow(/circular/i);\n  });\n});\n```\n\nThen run: `cd /workspace && npx vitest run src/index.test.ts 2>&1`\n\nIf tests fail, fix the implementation. The deps module (src/deps/index.ts) may or may not exist yet - if it doesn't exist, create it too with this content:\n\n```typescript\nimport type { DependencyNode, DepsService, RegistryService } from '../types.js';\n\nexport function createDepsService(): DepsService {\n  function buildTreeInternal(name: string, registry: RegistryService, visited: Set<string>): DependencyNode {\n    const manifest = registry.get(name);\n    if (!manifest) return { name, version: 'unknown', dependencies: [] };\n    if (visited.has(name)) return { name, version: manifest.version, dependencies: [] };\n    visited.add(name);\n    const children = Object.keys(manifest.dependencies).map(dep => buildTreeInternal(dep, registry, new Set(visited)));\n    return { name, version: manifest.version, dependencies: children };\n  }\n\n  function detectCyclesInternal(name: string, registry: RegistryService, path: string[], visiting: Set<string>): string[][] {\n    if (visiting.has(name)) {\n      const cycleStart = path.indexOf(name);\n      return [path.slice(cycleStart).concat(name)];\n    }\n    const manifest = registry.get