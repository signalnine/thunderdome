luginRegistry', () => {\n  let registry: ReturnType<typeof createRegistry>;\n\n  beforeEach(() => {\n    registry = createRegistry(':memory:');\n  });\n\n  it('registers and retrieves a plugin', () => {\n    const m = makeManifest('foo', '1.0.0');\n    registry.register(m);\n    expect(registry.get('foo')).toEqual(m);\n  });\n\n  it('get returns null for unknown plugin', () => {\n    expect(registry.get('unknown')).toBeNull();\n  });\n\n  it('registers multiple versions', () => {\n    registry.register(makeManifest('foo', '1.0.0'));\n    registry.register(makeManifest('foo', '2.0.0'));\n    const versions = registry.listVersions('foo');\n    expect(versions).toContain('1.0.0');\n    expect(versions).toContain('2.0.0');\n  });\n\n  it('getVersion returns specific version', () => {\n    registry.register(makeManifest('foo', '1.0.0'));\n    registry.register(makeManifest('foo', '2.0.0'));\n    const m = registry.getVersion('foo', '1.0.0');\n    expect(m?.version).toBe('1.0.0');\n  });\n\n  it('get returns latest version (highest semver)', () => {\n    registry.register(makeManifest('foo', '1.0.0'));\n    registry.register(makeManifest('foo', '2.0.0'));\n    expect(registry.get('foo')?.version).toBe('2.0.0');\n  });\n\n  it('list returns all plugins (deduplicated by name/version)', () => {\n    registry.register(makeManifest('foo', '1.0.0'));\n    registry.register(makeManifest('bar', '1.0.0'));\n    const all = registry.list();\n    expect(all.length).toBe(2);\n  });\n\n  it('search filters by name and description', () => {\n    registry.register(makeManifest('awesome-plugin', '1.0.0'));\n    registry.register(makeManifest('other', '1.0.0'));\n    const results = registry.search('awesome');\n    expect(results.length).toBe(1);\n    expect(results[0].name).toBe('awesome-plugin');\n  });\n\n  it('remove deletes a specific version', () => {\n    registry.register(makeManifest('foo', '1.0.0'));\n    registry.register(makeManifest('foo', '2.0.0'));\n    const removed = registry.remove('foo', '1.0.0');\n    expect(removed).toBe(true);\n    expect(registry.getVersion('foo', '1.0.0')).toBeNull();\n    expect(registry.getVersion('foo', '2.0.0')).not.toBeNull();\n  });\n\n  it('remove returns false for nonexistent plugin', () => {\n    expect(registry.remove('none', '1.0.0')).toBe(false);\n  });\n\n  it('update modifies fields', () => {\n    registry.register(makeManifest('foo', '1.0.0'));\n    registry.update('foo', '1.0.0', { description: 'updated' });\n    expect(registry.getVersion('foo', '1.0.0')?.description).toBe('updated');\n  });\n\n  it('listVersions returns empty array for unknown plugin', () => {\n    expect(registry.listVersions('none')).toEqual([]);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npx vitest run src/registry/registry.test.ts 2>&1 | tail -20\n```\n\nExpected: FAIL - module not found\n\n**Step 3: Implement the registry**\n\n```typescript\n// src/registry/index.ts\nimport Database from 'better-sqlite3';\nimport type { PluginManifest, RegistryService } from '../types.js';\nimport semver from 'semver';\n\nexport function createRegistry(dbPath = ':memory:'): RegistryService {\n  const db = new Database(dbPath);\n\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS plugins (\n      name TEXT NOT NULL,\n      version TEXT NOT NULL,\n      data TEXT NOT NULL,\n      PRIMARY KEY (name, version)\n    )\n  `);\n\n  return {\n    register(manifest: PluginManifest): void {\n      const stmt = db.prepare(\n        'INSERT OR REPLACE INTO plugins (name, version, data) VALUES (?, ?, ?)'\n      );\n      stmt.run(manifest.name, manifest.version, JSON.stringify(manifest));\n    },\n\n    get(name: string): PluginManifest | null {\n      const versions = this.listVersions(name);\n      if (versions.length === 0) return null;\n      const latest = semver.maxSatisfying(versions, '*') ?? versions[versions.length - 1];\n      return this.getVersion(name, latest);\n    },\n\n    getVersion(name: string, version: string): PluginManifest | null {\n      const row = db.prepare('SELECT data FROM plugins WHERE name = ? AND version = ?')\n        .get(name, version) as { data: string } | undefined;\n      return row ? JSON.parse(row.data) as PluginManifest : null;\n    },\n\n    list(): PluginManifest[] {\n      const rows = db.prepare('SELECT data FROM plugins').all() as { data: string }[];\n      return rows.map(r => JSON.parse(r.data) as PluginManifest);\n    },\n\n    search(query: string): PluginManifest[] {\n      const q = query.toLowerCase();\n      return this.list().filter(m =>\n        m.name.toLowerCase().includes(q) ||\n        m.description.toLowerCase().includes(q)\n      );\n    },\n\n    remove(name: string, version: string): boolean {\n      const result = db.prepare('DELETE FROM plugins WHERE name = ? AND version = ?')\n        .run(name, version);\n      return result.changes > 0;\n    },\n\n    listVersions(name: string): string[] {\n      const rows = db.prepare('SELECT version FROM plugins WHERE name = ?')\n        .all(name) as { version: string }[];\n      return rows.map(r => r.version);\n    },\n\n    update(name: string, version: string, updates: Partial<PluginManifest>): void {\n      const existing = this.getVersion(name, version);\n      if (!existing) throw new Error(`Plugin ${name}@${version} not found`);\n      const updated = { ...existing, ...updates };\n      db.prepare('UPDATE plugins SET data = ? WHERE name = ? AND version = ?')\n        .run(JSON.stringify(updated), name, version);\n    },\n  };\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\n```bash\ncd /workspace && npx vitest run src/registry/registry.test.ts 2>&1 | tail -20\n```\n\nExpected: all tests PASS\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/registry/ && git commit -m \"feat: implement plugin registry with SQLite persistence\"\n```\n\n---\n\n### Task 2: Version Resolver (`src/resolver/index.ts`)\n\n**Files:**\n- Create: `src/resolver/index.ts`\n- Create: `src/resolver/resolver.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write failing tests**\n\n```typescript\n// src/resolver/resolver.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { createResolver } from './index.js';\n\ndescribe('VersionResolver', () => {\n  const resolver = createResolver();\n\n  it('satisfies a matching version against a range', () => {\n    expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);\n    expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n  });\n\n  it('maxSatisfying returns highest matching version', () => {\n    const versions = ['1.0.0', '1.2.0', '1.5.0', '2.0.0'];\n    expect(resolver.maxSatisfying(versions, '^1.0.0')).toBe('1.5.0');\n  });\n\n  it('maxSatisfying returns null when no match', () => {\n    expect(resolver.maxSatisfying(['1.0.0'], '^2.0.0')).toBeNull();\n  });\n\n  it('validRange returns true for valid ranges', () => {\n    expect(resolver.validRange('^1.0.0')).toBe(true);\n    expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);\n    expect(resolver.validRange('not-a-range')).toBe(false);\n  });\n\n  it('resolve returns concrete versions for constraints', () => {\n    const available = { foo: ['1.0.0', '1.5.0', '2.0.0'], bar: ['3.0.0', '4.0.0'] };\n    const constraints = [\n      { name: 'foo', range: '^1.0.0' },\n      { name: 'bar', range: '^3.0.0' },\n    ];\n    const resolved = resolver.resolve(constraints, available);\n    expect(resolved).toHaveLength(2);\n    const foo = resolved.find(r => r.name === 'foo');\n    expect(foo?.version).toBe('1.5.0');\n    expect(foo?.satisfies).toBe('^1.0.0');\n  });\n\n  it('resolve throws when constraint cannot be satisfied', () => {\n    const available = { foo: ['1.0.0'] };\n    const constraints = [{ name: 'foo', range: '^2.0.0' }];\n    expect(() => resolver.resolve(constraints, available)).toThrow();\n  });\n\n  it('resolve throws when plugin not in available', () => {\n    const available = {};\n    const constraints = [{ name: 'foo', range: '^1.0.0' }];\n    expect(() => resolver.resolve(constraints, available)).toThrow();\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npx vitest run src/resolver/resolver.test.ts 2>&1 | tail -20\n```\n\n**Step 3: Implement the resolver**\n\n```typescript\n// src/resolver/index.ts\nimport semver from 'semver';\nimport type { ResolverService, VersionConstraint, ResolvedVersion } from '../types.js';\n\nexport function createResolver(): ResolverService {\n  return {\n    resolve(constraints: VersionConstraint[], available: Record<string, string[]>): ResolvedVersion[] {\n      return constraints.map(({ name, range }) => {\n        const versions = available[name];\n        if (!versions || versions.length === 0) {\n          throw new Error(`No versions available for plugin: ${name}`);\n        }\n        const version = semver.maxSatisfying(versions, range);\n        if (!version) {\n          throw new Error(`No version of ${name} satisfies range ${range}. Available: ${versions.join(', ')}`);\n        }\n        return { name, version, satisfies: range };\n      });\n    },\n\n    satisfies(version: string, range: string): boolean {\n      return semver.satisfies(version, range);\n    },\n\n    maxSatisfying(versions: string[], range: string): string | null {\n      return semver.maxSatisfying(versions, range);\n    },\n\n    validRange(range: string): boolean {\n      return semver.validRange(range) !== null;\n    },\n  };\n}\n```\n\n**Step 4: Run tests**\n\n```bash\ncd /workspace && npx vitest run src/resolver/resolver.test.ts 2>&1 | tail -20\n```\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/resolver/ && git commit -m \"feat: implement semver version resolver\"\n```\n\n---\n\n### Task 3: Sandboxed Runner (`src/runner/index.ts`)\n\n**Files:**\n- Create: `src/runner/index.ts`\n- Create: `src/runner/runner.test.ts`\n\n**Dependencies:** none\n\n**Step 1: Write failing tests**\n\n```typescript\n// src/runner/runner.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { createRunner } from './index.js';\n\ndescribe('SandboxedRunner', () => {\n  const runner = createRunner();\n\n  it('executes simple code and returns output', async () => {\n    const result = await runner.execute('1 + 1');\n    expect(result.success).toBe(true);\n    expect(result.output).toBe(2);\n    expect(result.duration).toBeGreaterThanOrEqual(0);\n  });\n\n  it('passes context into the sandbox', async () => {\n    const result = await runner.execute('x + y', { x: 3, y: 4 });\n    expect(result.success).toBe(true);\n    expect(result.output).toBe(7);\n  });\n\n  it('captures errors without throwing', async () => {\n    const result = await runner.execute('throw new Error(\"boom\")');\n    expect(result.success).toBe(false);\n    expect(result.error).toContain('boom');\n  });\n\n  it('returns memoryUsed as a number', async () => {\n    const result = await runner.execute('\"hello\"');\n    expect(typeof result.memoryUsed).toBe('number');\n    expect(result.memoryUsed).toBeGreaterThanOrEqual(0);\n  });\n\n  it('enforces timeout for runaway code', async () => {\n    const result = await runner.executeWithTimeout('while(true){}', 100);\n    expect(result.success).toBe(false);\n    expect(result.error).toMatch(/timeout|timed out/i);\n  }, 5000);\n\n  it('executeWithTimeout runs normal code fine', async () => {\n    const result = await runner.executeWithTimeout('\"ok\"', 2000);\n    expect(result.success).toBe(true);\n    expect(result.output).toBe('ok');\n  });\n\n  it('sandbox is isolated - no access to process', async () => {\n    const result = await runner.execute('typeof process');\n    // process should be undefined or inaccessible in sandbox\n    expect(result.output).toBe('undefined');\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npx vitest run src/runner/runner.test.ts 2>&1 | tail -20\n```\n\n**Step 3: Implement the runner**\n\n```typescript\n// src/runner/index.ts\nimport vm from 'vm';\nimport type { RunnerService, SandboxResult } from '../types.js';\n\nexport function createRunner(): RunnerService {\n  async function runCode(\n    code: string,\n    timeoutMs: number,\n    context: Record<string, unknown> = {}\n  ): Promise<SandboxResult> {\n    const start = Date.now();\n    const memBefore = process.memoryUsage().heapUsed;\n\n    try {\n      const sandbox = vm.createContext({ ...context });\n      const script = new vm.Script(code);\n      const output = script.runInContext(sandbox, { timeout: timeoutMs });\n      const duration = Date.now() - start;\n      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - memBefore);\n      return { success: true, output, duration, memoryUsed };\n    } catch (err: unknown) {\n      const duration = Date.now() - start;\n      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - memBefore);\n      const error = err instanceof Error ? err.message : String(err);\n      const isTimeout = error.includes('timed out') || error.includes('Script execution timed out');\n      return {\n        success: false,\n        output: null,\n        duration,\n        memoryUsed,\n        error: isTimeout ? `Execution timed out after ${timeoutMs}ms` : error,\n      };\n    }\n  }\n\n  return {\n    execute(code: string, context?: Record<string, unknown>): Promise<SandboxResult> {\n      return runCode(code, 5000, context);\n    },\n\n    executeWithTimeout(\n      code: string,\n      timeoutMs: number,\n      context?: Record<string, unknown>\n    ): Promise<SandboxResult> {\n      return runCode(code, timeoutMs, context);\n    },\n  };\n}\n```\n\n**Step 4: Run tests**\n\n```bash\ncd /workspace && npx vitest run src/runner/runner.test.ts 2>&1 | tail -20\n```\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/runner/ && git commit -m \"feat: implement sandboxed runner using Node.js vm module\"\n```\n\n---\n\n### Task 4: Review 