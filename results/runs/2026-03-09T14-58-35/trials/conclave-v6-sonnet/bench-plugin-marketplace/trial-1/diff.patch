dy exist and are implemented:\n- /workspace/src/registry/index.ts - exports createRegistry()\n- /workspace/src/resolver/index.ts - exports createResolver()\n- /workspace/src/runner/index.ts - exports createRunner()\n- /workspace/src/reviews/index.ts - exports createReviewService()\n- /workspace/src/deps/index.ts - exports createDepsService()\n\nCreate these two files:\n\n**File 1: /workspace/src/index.ts**\n```typescript\nimport { createRegistry } from './registry/index.js';\nimport { createResolver } from './resolver/index.js';\nimport { createRunner } from './runner/index.js';\nimport { createReviewService } from './reviews/index.js';\nimport { createDepsService } from './deps/index.js';\nimport type {\n  PluginManifest,\n  RegistryService,\n  ResolverService,\n  RunnerService,\n  ReviewService,\n  DepsService,\n  ResolvedVersion,\n  SandboxResult,\n} from './types.js';\n\nexport interface Marketplace {\n  registry: RegistryService;\n  resolver: ResolverService;\n  runner: RunnerService;\n  reviews: ReviewService;\n  deps: DepsService;\n  installPlugin(manifest: PluginManifest): Promise<{\n    resolvedDeps: ResolvedVersion[];\n    sandboxResult: SandboxResult;\n  }>;\n}\n\nexport function createMarketplace(dbPath = ':memory:'): Marketplace {\n  const registry = createRegistry(dbPath);\n  const resolver = createResolver();\n  const runner = createRunner();\n  const reviews = createReviewService(dbPath);\n  const deps = createDepsService();\n\n  return {\n    registry,\n    resolver,\n    runner,\n    reviews,\n    deps,\n\n    async installPlugin(manifest: PluginManifest) {\n      // Validate required fields\n      if (!manifest.name) throw new Error('Plugin manifest must have a name');\n      if (!manifest.version) throw new Error('Plugin manifest must have a version');\n      if (!manifest.entryPoint) throw new Error('Plugin manifest must have an entryPoint');\n\n      // Register the plugin\n      registry.register(manifest);\n\n      // Resolve dependencies\n      const depNames = Object.keys(manifest.dependencies);\n      let resolvedDeps: ResolvedVersion[] = [];\n      if (depNames.length > 0) {\n        const constraints = depNames.map(name => ({\n          name,\n          range: manifest.dependencies[name],\n        }));\n        const available: Record<string, string[]> = {};\n        for (const name of depNames) {\n          available[name] = registry.listVersions(name);\n        }\n        resolvedDeps = resolver.resolve(constraints, available);\n      }\n\n      // Check for circular dependencies\n      if (deps.hasCircularDependency(manifest.name, registry)) {\n        throw new Error(`Circular dependency detected for plugin: ${manifest.name}`);\n      }\n\n      // Execute entry point in sandbox\n      const sandboxResult = await runner.execute(manifest.entryPoint);\n\n      return { resolvedDeps, sandboxResult };\n    },\n  };\n}\n\n// Re-export types and factories for consumers\nexport { createRegistry } from './registry/index.js';\nexport { createResolver } from './resolver/index.js';\nexport { createRunner } from './runner/index.js';\nexport { createReviewService } from './reviews/index.js';\nexport { createDepsService } from './deps/index.js';\nexport type * from './types.js';\n```\n\n**File 2: /workspace/src/index.test.ts**\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createMarketplace } from './index.js';\nimport type { PluginManifest } from './types.js';\n\nconst makeManifest = (overrides: Partial<PluginManifest> = {}): PluginManifest => ({\n  name: 'my-plugin',\n  version: '1.0.0',\n  description: 'test',\n  author: 'me',\n  dependencies: {},\n  entryPoint: '\"loaded\"',\n  permissions: [],\n  ...overrides,\n});\n\ndescribe('createMarketplace', () => {\n  it('exposes all five services', () => {\n    const mp = createMarketplace();\n    expect(mp.registry).toBeDefined();\n    expect(mp.resolver).toBeDefined();\n    expect(mp.runner).toBeDefined();\n    expect(mp.reviews).toBe