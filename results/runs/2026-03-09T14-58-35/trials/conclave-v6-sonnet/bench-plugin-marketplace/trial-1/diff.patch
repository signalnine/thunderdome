+import { describe, it, expect } from 'vitest';
+import { createResolver } from './index.js';
+
+describe('VersionResolver', () => {
+  const resolver = createResolver();
+
+  it('satisfies a matching version against a range', () => {
+    expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);
+    expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+  });
+
+  it('maxSatisfying returns highest matching version', () => {
+    const versions = ['1.0.0', '1.2.0', '1.5.0', '2.0.0'];
+    expect(resolver.maxSatisfying(versions, '^1.0.0')).toBe('1.5.0');
+  });
+
+  it('maxSatisfying returns null when no match', () => {
+    expect(resolver.maxSatisfying(['1.0.0'], '^2.0.0')).toBeNull();
+  });
+
+  it('validRange returns true for valid ranges', () => {
+    expect(resolver.validRange('^1.0.0')).toBe(true);
+    expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);
+    expect(resolver.validRange('not-a-range')).toBe(false);
+  });
+
+  it('resolve returns concrete versions for constraints', () => {
+    const available = { foo: ['1.0.0', '1.5.0', '2.0.0'], bar: ['3.0.0', '4.0.0'] };
+    const constraints = [
+      { name: 'foo', range: '^1.0.0' },
+      { name: 'bar', range: '^3.0.0' },
+    ];
+    const resolved = resolver.resolve(constraints, available);
+    expect(resolved).toHaveLength(2);
+    const foo = resolved.find(r => r.name === 'foo');
+    expect(foo?.version).toBe('1.5.0');
+    expect(foo?.satisfies).toBe('^1.0.0');
+  });
+
+  it('resolve throws when constraint cannot be satisfied', () => {
+    const available = { foo: ['1.0.0'] };
+    const constraints = [{ name: 'foo', range: '^2.0.0' }];
+    expect(() => resolver.resolve(constraints, available)).toThrow();
+  });
+
+  it('resolve throws when plugin not in available', () => {
+    const available = {};
+    const constraints = [{ name: 'foo', range: '^1.0.0' }];
+    expect(() => resolver.resolve(constraints, available)).toThrow();
+  });
+});
