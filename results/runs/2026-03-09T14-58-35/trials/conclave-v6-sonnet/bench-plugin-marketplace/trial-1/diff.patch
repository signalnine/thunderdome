Implement the review service**\n\n```typescript\n// src/reviews/index.ts\nimport Database from 'better-sqlite3';\nimport type { Review, ReviewService } from '../types.js';\n\nexport function createReviewService(dbPath = ':memory:'): ReviewService {\n  const db = new Database(dbPath);\n\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS reviews (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      pluginName TEXT NOT NULL,\n      pluginVersion TEXT NOT NULL,\n      userId TEXT NOT NULL,\n      rating INTEGER NOT NULL,\n      comment TEXT NOT NULL,\n      flagged INTEGER NOT NULL DEFAULT 0,\n      createdAt TEXT NOT NULL\n    )\n  `);\n\n  function rowToReview(row: Record<string, unknown>): Review {\n    return {\n      id: row.id as number,\n      pluginName: row.pluginName as string,\n      pluginVersion: row.pluginVersion as string,\n      userId: row.userId as string,\n      rating: row.rating as number,\n      comment: row.comment as string,\n      flagged: Boolean(row.flagged),\n      createdAt: row.createdAt as string,\n    };\n  }\n\n  return {\n    addReview(review: Omit<Review, 'id' | 'createdAt' | 'flagged'>): Review {\n      const createdAt = new Date().toISOString();\n      const result = db.prepare(\n        'INSERT INTO reviews (pluginName, pluginVersion, userId, rating, comment, flagged, createdAt) VALUES (?, ?, ?, ?, ?, 0, ?)'\n      ).run(review.pluginName, review.pluginVersion, review.userId, review.rating, review.comment, createdAt);\n      return { ...review, id: result.lastInsertRowid as number, flagged: false, createdAt };\n    },\n\n    getReviews(pluginName: string): Review[] {\n      const rows = db.prepare('SELECT * FROM reviews WHERE pluginName = ?').all(pluginName) as Record<string, unknown>[];\n      return rows.map(rowToReview);\n    },\n\n    getAverageRating(pluginName: string): number {\n      const row = db.prepare(\n        'SELECT AVG(rating) as avg FROM reviews WHERE pluginName = ? AND flagged = 0'\n      ).get(pluginName) as { avg: number | null };\n      return row.avg ?? 0;\n    },\n\n    flagReview(reviewId: number): void {\n      db.prepare('UPDATE reviews SET flagged = 1 WHERE id = ?').run(reviewId);\n    },\n\n    getFlaggedReviews(): Review[] {\n      const rows = db.prepare('SELECT * FROM reviews WHERE flagged = 1').all() as Record<string, unknown>[];\n      return rows.map(rowToReview);\n    },\n\n    removeReview(reviewId: number): boolean {\n      const result = db.prepare('DELETE FROM reviews WHERE id = ?').run(reviewId);\n      return result.changes > 0;\n    },\n\n    getReviewsByUser(userId: string): Review[] {\n      const rows = db.prepare('SELECT * FROM reviews WHERE userId = ?').all(userId) as Record<string, unknown>[];\n      return rows.map(rowToReview);\n    },\n\n    getReviewCount(pluginName: string): number {\n      const row = db.prepare('SELECT COUNT(*) as count FROM reviews WHERE pluginName = ?').get(pluginName) as { count: number };\n      return row.count;\n    },\n  };\n}\n```\n\n**Step 4: Run tests**\n\n```bash\ncd /workspace && npx vitest run src/reviews/reviews.test.ts 2>&1 | tail -20\n```\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/reviews/ && git commit -m \"feat: implement review service with SQLite persistence\"\n```\n\n---\n\n### Task 5: Dependency Graph (`src/deps/index.ts`)\n\n**Files:**\n- Create: `src/deps/index.ts`\n- Create: `src/deps/deps.test.ts`\n\n**Dependencies:** Task 1 (registry needed for tests)\n\n**Step 1: Write failing tests**\n\n```typescript\n// src/deps/deps.test.ts\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { createDepsService } from './index.js';\nimport { createRegistry } from '../registry/index.js';\nimport type { PluginManifest, RegistryService } from '../types.js';\n\nfunction makeManifest(name: string, version: string, deps: Record<string, string> = {}): PluginManifest {\n  return { name, version, description: '', author: '', dependencies: deps, entryPoint: '', permissions: [] };\n}\n\ndescribe('DepsService', () => {\n  let registry: RegistryService;\n  let deps: ReturnType<typeof createDepsService>;\n\n  beforeEach(() => {\n    registry = createRegistry(':memory:');\n    deps = createDepsService();\n\n    registry.register(makeManifest('root', '1.0.0', { child1: '1.0.0', child2: '1.0.0' }));\n    registry.register(makeManifest('child1', '1.0.0', { grandchild: '1.0.0' }));\n    registry.register(makeManifest('child2', '1.0.0', {}));\n    registry.register(makeManifest('grandchild', '1.0.0', {}));\n  });\n\n  it('buildTree returns a tree with correct structure', () => {\n    const tree = deps.buildTree('root', registry);\n    expect(tree.name).toBe('root');\n    expect(tree.dependencies.length).toBe(2);\n    const c1 = tree.dependencies.find(d => d.name === 'child1');\n    expect(c1?.dependencies.length).toBe(1);\n    expect(c1?.dependencies[0].name).toBe('grandchild');\n  });\n\n  it('detectCycles returns null when no cycles', () => {\n    expect(deps.detectCycles('root', registry)).toBeNull();\n  });\n\n  it('detectCycles returns cycle paths when cycles present', () => {\n    // a -> b -> a\n    registry.register(makeManifest('a', '1.0.0', { b: '1.0.0' }));\n    registry.register(makeManifest('b', '1.0.0', { a: '1.0.0' }));\n    const cycles = deps.detectCycles('a', registry);\n    expect(cycles).not.toBeNull();\n    expect(cycles!.length).toBeGreaterThan(0);\n  });\n\n  it('hasCircularDependency returns false for acyclic graph', () => {\n    expect(deps.hasCircularDependency('root', registry)).toBe(false);\n  });\n\n  it('hasCircularDependency returns true for cyclic graph', () => {\n    registry.register(makeManifest('x', '1.0.0', { y: '1.0.0' }));\n    registry.register(makeManifest('y', '1.0.0', { x: '1.0.0' }));\n    expect(deps.hasCircularDependency('x', registry)).toBe(true);\n  });\n\n  it('topologicalSort returns dependencies before dependents', () => {\n    const order = deps.topologicalSort('root', registry);\n    const rootIdx = order.indexOf('root');\n    const c1Idx = order.indexOf('child1');\n    const gcIdx = order.indexOf('grandchild');\n    // grandchild before child1 before root\n    expect(gcIdx).toBeLessThan(c1Idx);\n    expect(c1Idx).toBeLessThan(rootIdx);\n  });\n\n  it('flattenDependencies returns all transitive deps (no root)', () => {\n    const flat = deps.flattenDependencies('root', registry);\n    expect(flat).toContain('child1');\n    expect(flat).toContain('child2');\n    expect(flat).toContain('grandchild');\n    expect(flat).not.toContain('root');\n  });\n\n  it('flattenDependencies deduplicates', () => {\n    // diamond dependency: root -> a, root -> b, both -> shared\n    registry.register(makeManifest('r2', '1.0.0', { a: '1.0.0', b: '1.0.0' }));\n    registry.register(makeManifest('a', '1.0.0', { shared: '1.0.0' }));\n    registry.register(makeManifest('b', '1.0.0', { shared: '1.0.0' }));\n    registry.register(makeManifest('shared', '1.0.0', {}));\n    const flat = deps.flattenDependencies('r2', registry);\n    const sharedCount = flat.filter(n => n === 'shared').length;\n    expect(sharedCount).toBe(1);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npx vitest run src/deps/deps.test.ts 2>&1 | tail -20\n```\n\n**Step 3: Implement the deps service**\n\n```typescript\n// src/deps/index.ts\nimport type { DependencyNode, DepsService, RegistryService } from '../types.js';\n\nexport function createDepsService(): DepsService {\n  function buildTreeInternal(\n    name: string,\n    registry: RegistryService,\n    visited: Set<string>\n  ): DependencyNode {\n    const manifest = registry.get(name);\n    if (!manifest) return { name, version: 'unknown', dependencies: [] };\n    if (visited.has(name)) return { name, version: manifest.version, dependencies: [] };\n\n    visited.add(name);\n    const children = Object.keys(manifest.dependencies).map(dep =>\n      buildTreeInternal(dep, registry, new Set(visited))\n    );\n    return { name, version: manifest.version, dependencies: children };\n  }\n\n  function detectCyclesInternal(\n    name: string,\n    registry: RegistryService,\n    path: string[],\n    visiting: Set<string>\n  ): string[][] {\n    if (visiting.has(name)) {\n      const cycleStart = path.indexOf(name);\n      return [path.slice(cycleStart).concat(name)];\n    }\n\n    const manifest = registry.get(name);\n    if (!manifest) return [];\n\n    visiting.add(name);\n    path.push(name);\n    const cycles: string[][] = [];\n\n    for (const dep of Object.keys(manifest.dependencies)) {\n      cycles.push(...detectCyclesInternal(dep, registry, [...path], new Set(visiting)));\n    }\n\n    return cycles;\n  }\n\n  function topoSortInternal(\n    name: string,\n    registry: RegistryService,\n    visited: Set<string>,\n    result: string[]\n  ): void {\n    if (visited.has(name)) return;\n    visited.add(name);\n\n    const manifest = registry.get(name);\n    if (manifest) {\n      for (const dep of Object.keys(manifest.dependencies)) {\n        topoSortInternal(dep, registry, visited, result);\n      }\n    }\n    result.push(name);\n  }\n\n  return {\n    buildTree(name: string, registry: RegistryService): DependencyNode {\n      return buildTreeInternal(name, registry, new Set());\n    },\n\n    detectCycles(name: string, registry: RegistryService): string[][] | null {\n      const cycles = detectCyclesInternal(name, registry, [], new Set());\n      return cycles.length > 0 ? cycles : null;\n    },\n\n    topologicalSort(name: string, registry: RegistryService): string[] {\n      const result: string[] = [];\n      topoSortInternal(name, registry, new Set(), result);\n      return result;\n    },\n\n    flattenDependencies(name: string, registry: RegistryService): string[] {\n      const result: string[] = [];\n      const visited = new Set<string>();\n      const queue = [name];\n      visited.add(name);\n\n      while (queue.length > 0) {\n        const current = queue.shift()!;\n        const manifest = registry.get(current);\n        if (!manifest) continue;\n        for (const dep of Object.keys(manifest.dependencies)) {\n          if (!visited.has(dep)) {\n            visited.add(dep);\n            result.push(dep);\n            queue.push(dep);\n          }\n        }\n      }\n      return result;\n    },\n\n    hasCircularDependency(name: string, registry: RegistryService): boolean {\n      const cycles = detectCyclesInternal(name, registry, [], new Set());\n      return cycles.length > 0;\n    },\n  };\n}\n```\n\n**Step 4: Run tests**\n\n```bash\ncd /workspace && npx vitest run src/deps/deps.test.ts 2>&1 | tail -20\n```\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/deps/ && git commit -m \"feat: implement dependency graph analysis service\"\n```\n\n---\n\n### Task 6: Integration Layer (`src/index.ts`)\n\n**Files:**\n- Create: `src/index.ts`\n- Create: `src/index.test.ts`\n\n**Dependencies:** Tasks 1-5\n\n**Step 1: Write failing tests**\n\n```typescript\n// src/index.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { createMarketplace } from './index.js';\nimport type { PluginManifest } from './types.js';\n\nconst makeManifest = (overrides: Partial<PluginManifest> = {}): PluginManifest => ({\n  name: 'my-plugin',\n  version: '1.0.0',\n  description: 'test',\n  author: 'me',\n  dependencies: {},\n  entryPoint: '\"loaded\"',\n  permissions: [],\n  ...overrides,\n});\n\ndescribe('createMarketplace', () => {\n  it('exposes all five services', () => {\n    const mp = createMarketplace();\n    expect(mp.registry).toBeDefined();\n    expect(mp.resolver).toBeDefined();\n    expect(mp.runner).toBeDefined();\n    expect(mp.reviews).toBeDefined();\n    expect(mp.deps).toBeDefined();\n  });\n\n  it('installPlugin validates required fields - missing name throws', async () => {\n    const mp = createMarketplace();\n    await expect(mp.installPlugin({ ...makeManifest(), name: '' })).rejects.toThrow();\n  });\n\n  it('installPlugin validates required fields - missing version throws', async () => {\n    const mp = createMarketplace();\n    await expect(mp.installPlugin({ ...makeManifest(), version: '' })).rejects.toThrow();\n  });\n\n  it('installPlugin validates required fields - missing entryPoint throws', async () => {\n    const mp = createMarketplace();\n    await expect(mp.installPlugin({ ...makeManifest(), entryPoint: '' })).rejects.toThrow();\n  });\n\n  it('installPlugin registers the plugin', async () => {\n    const mp = createMarketplace();\n    await mp.installPlugin(makeManifest());\n    expect(mp.registry.get('my-plugin')).toBeDefined();\n  });\n\n  it('installPlugin returns sandbox result and resolved deps', async () => {\n    const mp = createMarketplace();\n    const result = await mp.installPlugin(makeManifest());\n    expect(result.sandboxResult.success).toBe(true);\n    expect(result.sandboxResult.output).toBe('loaded');\n    expect(result.resolvedDeps).toEqual([]);\n  });\n\n  it('installPlugin resolves dependencies from registry', async () => {\n    const mp = createMarketplace();\n    // Pre-register a dependency\n    mp.registry.register(makeManifest({ name: 'dep-a', version: '1.5.0' }));\n    const result = await mp.installPlugin(makeManifest({\n      name: 'main-plugin',\n      dependencies: { 'dep-a': '^1.0.0' },\n    }));\n    expect(result.resolvedDeps).toHaveLength(1);\n    expect(result.resolvedDeps[0].name).toBe('dep-a');\n    expect(result.resolvedDeps[0].version).toBe('1.5.0');\n  });\n\n  it('installPlugin rejects circular dependencies', async () => {\n    const mp = createMarketplace();\n    // Register a->b->a cycle\n    mp.registry.register(makeManifest({ name: 'a', version: '1.0.0', dependencies: { b: '1.0.0' } }));\n    mp.registry.register(makeManifest({ name: 'b', version: '1.0.0', dependencies: { a: '1.0.0' } }));\n    await expect(mp.installPlugin(makeManifest({\n      name: 'a',\n      version: '2.0.0',\n      dependencies: { b: '1.0.0' },\n    }))).rejects.toThrow(/circular/i);\n  });\n});\n```\n\n**Step 2: Run test to verify it fails**\n\n```bash\ncd /workspace && npx vitest run src/index.test.ts 2>&1 | tail -20\n```\n\n**Step 3: Implement the integration layer**\n\n```typescript\n// src/index.ts\nimport { createRegistry } from './registry/index.js';\nimport { createResolver } from './resolver/index.js';\nimport { createRunner } from './runner/index.js';\nimport { createReviewService } from './reviews/index.js';\nimport { createDepsService } from './deps/index.js';\nimport type {\n  PluginManifest,\n  RegistryService,\n  ResolverService,\n  RunnerService,\n  ReviewService,\n  DepsService,\n  ResolvedVersion,\n  SandboxResult,\n} from './types.js';\n\nexport interface Marketplace {\n  registry: RegistryService;\n  resolver: ResolverService;\n  runner: RunnerService;\n  reviews: ReviewService;\n  deps: DepsService;\n  installPlugin(manifest: PluginManifest): Promise<{\n    resolvedDeps: ResolvedVersion[];\n    sandboxResult: SandboxResult;\n  }>;\n}\n\nexport function createMarketplace(dbPath = ':memory:'): Marketplace {\n  const registry = createRegistry(dbPath);\n  const resolver = createResolver();\n  const runner = createRunner();\n  const reviews = createReviewService(dbPath);\n  const deps = createDepsService();\n\n  return {\n    registry,\n    resolver,\n    runner,\n    reviews,\n    deps,\n\n    async installPlugin(manifest: PluginManifest) {\n      // Validate required fields\n      if (!manifest.name) throw new Error('Plugin manifest must have a name');\n      if (!manifest.version) throw new Error('Plugin manifest must have a version');\n      if (!manifest.entryPoint) throw new Error('Plugin manifest must have an entryPoint');\n\n      // Register the plugin\n      registry.register(manifest);\n\n      // Resolve dependencies\n      const depNames = Object.keys(manifest.dependencies);\n      let resolvedDeps: ResolvedVersion[] = [];\n      if (depNames.length > 0) {\n        const constraints = depNames.map(name => ({\n          name,\n          range: manifest.dependencies[name],\n        }));\n        const available: Record<string, string[]> = {};\n        for (const name of depNames) {\n          available[name] = registry.listVersions(name);\n        }\n        resolvedDeps = resolver.resolve(constraints, available);\n      }\n\n      // Check for circular dependencies\n      if (deps.hasCircularDependency(manifest.name, registry)) {\n        throw new Error(`Circular dependency detected for plugin: ${manifest.name}`);\n      }\n\n      // Execute entry point in sandbox\n      const sandboxResult = await runner.execute(manifest.entryPoint);\n\n      return { resolvedDeps, sandboxResult };\n    },\n  };\n}\n\n// Re-export types and factories for consumers\nexport { createRegistry } from './registry/index.js';\nexport { createResolver } from './resolver/index.js';\nexport { createRunner } from './runner/index.js';\nexport { createReviewService } from './reviews/index.js';\nexport { createDepsService } from './deps/index.js';\nexport type * from './types.js';\n```\n\n**Step 4: Run tests**\n\n```bash\ncd /workspace && npx vitest run src/index.test.ts 2>&1 | tail -20\n```\n\n**Step 5: Commit**\n\n```bash\ncd /workspace && git add src/index.ts src/index.test.ts && git commit -m \"feat: implement createMarketplace integration layer\"\n```\n\n---\n\n### Task 7: Full Verification\n\n**Files:** all\n\n**Dependencies:** Tasks 1-6\n\n**Step 1: Run all tests**\n\n```bash\ncd /workspace && npm test 2>&1\n```\n\nExpected: all tests pass\n\n**Step 2: TypeScript build**\n\n```bash\ncd /workspace && npm run build 2>&1\n```\n\nExpected: no errors\n\n**Step 3: Lint**\n\n```bash\ncd /workspace && npm run lint 2>&1\n```\n\nExpected: no errors\n\n**Step 4: Fix any issues found, then final commit**\n\n```bash\ncd /workspace && git add -A && git commit -m \"chore: fix any build/lint/test issues\"\n```\n","structuredPatch":[],"originalFile":null}}
