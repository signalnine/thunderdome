+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+  // find source
+  let sr = -1, sc = -1;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      sr = 0;
+      sc = c;
+      break;
+    }
+  }
+  if (sr === -1) return 0; // no source, though problem says always present
+
+  const visited: boolean[][] = Array.from({ length: rows }, () => Array(cols).fill(false));
+  // dp[row][col][dirIndex] where dirIndex: -1->0, 0->1, 1->2
+  const dp: bigint[][][] = Array.from({ length: rows }, () =>
+    Array.from({ length: cols }, () => [0n, 0n, 0n])
+  );
+  const dirToIndex = (d: number): number => d + 1; // -1 =>0, 0=>1, 1=>2
+  // initial direction down (0)
+  dp[sr][sc][dirToIndex(0)] = 1n;
+
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      const ch = grid[r][c];
+      for (let d = -1; d <= 1; d++) {
+        const idx = dirToIndex(d);
+        const count = dp[r][c][idx];
+        if (count === 0n) continue;
+        // mark visited
+        visited[r][c] = true;
+        if (ch === '^') {
+          // splitter: split into down-left and down-right
+          for (const nd of [-1, 1]) {
+            const nr = r + 1;
+            const nc = c + nd;
+            if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+              // exited
+              // do nothing for cell count, already marked
+            } else {
+              const nidx = dirToIndex(nd);
+              dp[nr][nc][nidx] += count;
+            }
+          }
+        } else {
+          // '.' or 'S': continue same direction
+          const nr = r + 1;
+          const nc = c + d;
+          if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+            // exited
+          } else {
+            const nidx = dirToIndex(d);
+            dp[nr][nc][nidx] += count;
+          }
+        }
+      }
+    }
+  }
+
+  // count visited cells
+  let cellCount = 0;
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      if (visited[r][c]) cellCount++;
+    }
+  }
+  return cellCount;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+  // find source
+  let sr = -1, sc = -1;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      sr = 0;
+      sc = c;
+      break;
+    }
+  }
+  if (sr === -1) return 0n;
+
+  // dp[row][col][dirIndex]
+  const dp: bigint[][][] = Array.from({ length: rows }, () =>
+    Array.from({ length: cols }, () => [0n, 0n, 0n])
+  );
+  const dirToIndex = (d: number): number => d + 1;
+  dp[sr][sc][dirToIndex(0)] = 1n;
+
+  let totalPaths = 0n;
+
+  for (let r = 0; r < rows; r++) {
+    for (let c = 0; c < cols; c++) {
+      const ch = grid[r][c];
+      for (let d = -1; d <= 1; d++) {
+        const idx = dirToIndex(d);
+        const count = dp[r][c][idx];
+        if (count === 0n) continue;
+        if (ch === '^') {
+          // splitter: split into down-left and down-right
+          for (const nd of [-1, 1]) {
+            const nr = r + 1;
+            const nc = c + nd;
+            if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+              totalPaths += count;
+            } else {
+              const nidx = dirToIndex(nd);
+              dp[nr][nc][nidx] += count;
+            }
+          }
+        } else {
+          // '.' or 'S': continue same direction
+          const nr = r + 1;
+          const nc = c + d;
+          if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+            totalPaths += count;
+          } else {
+            const nidx = dirToIndex(d);
+            dp[nr][nc][nidx] += count;
+          }
+        }
+      }
+    }
+  }
+
+  return totalPaths;
+}
