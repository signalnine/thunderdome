+/// <reference types="vitest" />
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  test('example 1', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  test('example 2', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  test('empty grid', () => {
+    expect(countBeamCells([])).toBe(0);
+  });
+
+  test('no splitter', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // beam goes down from (0,1) to (1,1) to (2,1) then exits at row 3 (beyond)
+    // visited: (0,1), (1,1), (2,1) -> 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('splitter at bottom row', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '^', '.'],
+    ];
+    // beam: (0,1) -> (1,1) -> (2,1) hits splitter
+    // splits to (3,0) and (3,2) -> both exit (row 3 is beyond)
+    // visited: (0,1), (1,1), (2,1) -> 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('splitter causing beam to go out of bounds sideways', () => {
+    const grid: string[][] = [
+      ['S', '.'],
+      ['^', '.'],
+    ];
+    // beam: (0,0) -> (1,0) hits splitter
+    // splits to (2,-1) [absorbed] and (2,1) [absorbed because row 2 is beyond? Wait grid has 2 rows: row0 and row1.
+    // Actually, row index: 0 and 1. So when at (1,0) and split, next row is 2 which is >= rows (2) -> absorbed.
+    // So visited: (0,0), (1,0) -> 2
+    expect(countBeamCells(grid)).toBe(2);
+  });
+});
+
+describe('countBeamPaths', () => {
+  test('example 1', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  test('example 2', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // According to the example, all 4 paths exit (absorbed = exits grid): paths to (3,-1), (3,1), (3,1), (3,3) -> 4
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  test('empty grid', () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  test('no splitter', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // one path that exits at bottom
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  test('splitter at bottom row', () => {
+    const grid: string[][] = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '^', '.'],
+    ];
+    // beam hits splitter at (2,1) and splits into two beams that exit (row 3 is beyond)
+    // so 2 paths
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  test('splitter causing beam to go out of bounds sideways', () => {
+    const grid: string[][] = [
+      ['S', '.'],
+      ['^', '.'],
+    ];
+    // beam hits splitter at (1,0) and splits into two beams that exit (row 2 is beyond)
+    // so 2 paths
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+});
