+        case 'AVERAGE': return nums.length ? nums.reduce((a, b) => a + b, 0) / nums.length : 0;
+        case 'MIN': return Math.min(...nums);
+        case 'MAX': return Math.max(...nums);
+        case 'COUNT': return nums.length;
+        default: throw new Error(`Unknown function: ${name}`);
+      }
+    }
+    case 'range':
+      throw new Error('Range can only be used as function argument');
+  }
+}
+
+function collectValues(expr: Expr, getCell: (ref: string) => CellValue): CellValue[] {
+  if (expr.type === 'range') {
+    return expandRange(expr.start, expr.end).map(ref => getCell(ref));
+  }
+  return [evaluate(expr, getCell)];
