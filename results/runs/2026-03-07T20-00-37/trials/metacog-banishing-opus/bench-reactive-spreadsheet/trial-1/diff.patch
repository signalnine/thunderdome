+interface Parser {
+  src: string;
+  pos: number;
+}
+
+function peek(p: Parser): string {
+  skipWhitespace(p);
+  return p.src[p.pos] || '';
+}
+
+function skipWhitespace(p: Parser): void {
+  while (p.pos < p.src.length && p.src[p.pos] === ' ') p.pos++;
+}
+
+function parseExpr(p: Parser): Expr {
+  return parseComparison(p);
+}
+
+function matchComparisonOp(p: Parser): string | null {
+  skipWhitespace(p);
+  if (p.src[p.pos] === '<' && p.src[p.pos + 1] === '>') {
+    p.pos += 2; return '<>';
+  } else if (p.src[p.pos] === '>' && p.src[p.pos + 1] === '=') {
+    p.pos += 2; return '>=';
+  } else if (p.src[p.pos] === '<' && p.src[p.pos + 1] === '=') {
+    p.pos += 2; return '<=';
+  } else if (p.src[p.pos] === '>') {
+    p.pos++; return '>';
+  } else if (p.src[p.pos] === '<') {
+    p.pos++; return '<';
+  } else if (p.src[p.pos] === '=' && p.pos > 0) {
+    p.pos++; return '=';
+  }
+  return null;
+}
+
+function parseComparison(p: Parser): Expr {
+  let left = parseAddSub(p);
+  let op = matchComparisonOp(p);
+  while (op !== null) {
+    const right = parseAddSub(p);
+    left = { type: 'binop', op, left, right };
+    op = matchComparisonOp(p);
+  }
+  return left;
+}
+
+function parseAddSub(p: Parser): Expr {
+  let left = parseMulDiv(p);
+  let ch = peek(p);
+  while (ch === '+' || ch === '-') {
+    p.pos++;
+    const right = parseMulDiv(p);
+    left = { type: 'binop', op: ch, left, right };
+    ch = peek(p);
+  }
+  return left;
+}
+
+function parseMulDiv(p: Parser): Expr {
+  let left = parseUnary(p);
+  let ch = peek(p);
+  while (ch === '*' || ch === '/') {
+    p.pos++;
