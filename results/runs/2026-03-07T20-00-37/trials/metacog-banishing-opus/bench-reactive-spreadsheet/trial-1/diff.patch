+        case '-': return (l as number) - (r as number);
+        case '*': return (l as number) * (r as number);
+        case '/': return (l as number) / (r as number);
+        case '>': return (l as number) > (r as number);
+        case '<': return (l as number) < (r as number);
+        case '>=': return (l as number) >= (r as number);
+        case '<=': return (l as number) <= (r as number);
+        case '=': return l === r;
+        case '<>': return l !== r;
+        default: throw new Error(`Unknown operator: ${expr.op}`);
+      }
+    }
+    case 'call': {
