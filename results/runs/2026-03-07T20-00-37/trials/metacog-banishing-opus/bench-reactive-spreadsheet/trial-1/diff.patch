+
+    // Compute value
+    const computed = expr ? evaluate(expr, (r) => this.get(r)) : (typeof value === 'string' && !value.startsWith('=') ? value : value);
+    const cellData: CellData = { raw, computed, deps };
+    this.cells.set(ref, cellData);
+
+    // Propagate to dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = normRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computed;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computed);
+    }
+    return result;
+  }
+
+  private checkCircular(ref: string, deps: Set<string>): void {
+    // BFS/DFS from each dependency to see if we can reach `ref`
+    const visited = new Set<string>();
+    const stack = [...deps];
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === ref) {
+        throw new Error(`Circular reference detected involving ${ref}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+      const currentData = this.cells.get(current);
+      if (currentData) {
+        for (const d of currentData.deps) {
+          stack.push(d);
+        }
+      }
+    }
+  }
+
+  private propagate(changed: string): void {
+    // Topological order of dependents to recompute
+    const order = this.topoOrder(changed);
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (!data) continue;
+      const expr = this.parsed.get(ref);
+      if (expr) {
+        data.computed = evaluate(expr, (r) => this.get(r));
+      }
+    }
+  }
+
+  private topoOrder(changed: string): string[] {
+    // BFS from changed cell's dependents
+    const order: string[] = [];
+    const visited = new Set<string>();
+    const queue = [changed];
+    visited.add(changed);
+
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const deps = this.dependents.get(current);
+      if (deps) {
+        for (const dep of deps) {
+          if (!visited.has(dep)) {
+            visited.add(dep);
+            order.push(dep);
+            queue.push(dep);
+          }
+        }
+      }
+    }
+    return order;
+  }
+}
