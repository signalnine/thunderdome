+
+// --- Cell reference parsing ---
+
+function parseColRow(ref: string): [number, number] {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  const col = colToIndex(match[1]);
+  const row = parseInt(match[2], 10);
+  return [col, row];
+}
+
+function colToIndex(col: string): number {
+  let idx = 0;
+  for (let i = 0; i < col.length; i++) {
+    idx = idx * 26 + (col.charCodeAt(i) - 64);
+  }
+  return idx;
+}
+
+function indexToCol(idx: number): string {
+  let s = '';
+  while (idx > 0) {
+    const rem = (idx - 1) % 26;
+    s = String.fromCharCode(65 + rem) + s;
+    idx = Math.floor((idx - 1) / 26);
+  }
+  return s;
+}
+
+function normRef(ref: string): string {
+  return ref.toUpperCase();
+}
+
+function expandRange(start: string, end: string): string[] {
+  const [c1, r1] = parseColRow(start);
+  const [c2, r2] = parseColRow(end);
+  const minC = Math.min(c1, c2), maxC = Math.max(c1, c2);
+  const minR = Math.min(r1, r2), maxR = Math.max(r1, r2);
+  const cells: string[] = [];
+  for (let c = minC; c <= maxC; c++) {
+    for (let r = minR; r <= maxR; r++) {
+      cells.push(indexToCol(c) + r);
+    }
+  }
+  return cells;
+}
+
+// --- Formula parser (recursive descent) ---
+
+type Expr =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'ref'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'binop'; op: string; left: Expr; right: Expr }
+  | { type: 'unary'; op: string; operand: Expr }
+  | { type: 'call'; name: string; args: Expr[] };
