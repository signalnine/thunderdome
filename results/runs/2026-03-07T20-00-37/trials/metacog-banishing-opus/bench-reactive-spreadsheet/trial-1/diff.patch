+function extractDeps(expr: Expr): Set<string> {
+  const deps = new Set<string>();
+  function walk(e: Expr): void {
+    switch (e.type) {
+      case 'ref':
+        deps.add(e.ref);
+        break;
+      case 'range':
+        for (const ref of expandRange(e.start, e.end)) {
+          deps.add(ref);
+        }
+        break;
+      case 'binop':
+        walk(e.left);
+        walk(e.right);
+        break;
+      case 'unary':
+        walk(e.operand);
+        break;
+      case 'call':
+        for (const arg of e.args) walk(arg);
+        break;
+    }
+  }
+  walk(expr);
+  return deps;
+}
