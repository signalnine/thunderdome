+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function nextPos(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+
+  const src = findSource(grid);
+  if (!src) return 0;
+
+  const visited = new Set<string>();
+  const beams: Beam[] = [{ row: src[0], col: src[1], dir: 'down' }];
+  visited.add(`${src[0]},${src[1]}`);
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const { row, col, dir } = beam;
+
+    if (grid[row][col] === '^') {
+      // Splitter: produce two beams going down-left and down-right
+      const [lr, lc] = nextPos(row, col, 'down-left');
+      if (inBounds(lr, lc, rows, cols)) {
+        visited.add(`${lr},${lc}`);
+        beams.push({ row: lr, col: lc, dir: 'down-left' });
+      }
+      const [rr, rc] = nextPos(row, col, 'down-right');
+      if (inBounds(rr, rc, rows, cols)) {
+        visited.add(`${rr},${rc}`);
+        beams.push({ row: rr, col: rc, dir: 'down-right' });
+      }
+    } else {
+      // Continue in current direction
+      const [nr, nc] = nextPos(row, col, dir);
+      if (inBounds(nr, nc, rows, cols)) {
+        visited.add(`${nr},${nc}`);
+        beams.push({ row: nr, col: nc, dir: dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+/**
+ * Trace a beam from a starting position+direction until it hits a splitter or exits.
+ * Returns the splitter position [row, col] if hit, or null if exits grid.
+ * Also collects visited cells along the way.
+ */
+function traceBeam(
+  startRow: number,
+  startCol: number,
+  dir: Direction,
+  grid: string[][],
+  rows: number,
+  cols: number,
+  visited?: Set<string>
+): [number, number] | null {
+  let r = startRow;
+  let c = startCol;
+
+  // Move step by step in the given direction
+  for (;;) {
+    const [nr, nc] = nextPos(r, c, dir);
+    if (!inBounds(nr, nc, rows, cols)) {
+      return null; // beam exits
+    }
+    r = nr;
+    c = nc;
+    if (visited) visited.add(`${r},${c}`);
+    if (grid[r][c] === '^') {
+      return [r, c]; // hit a splitter
+    }
+  }
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+
+  const src = findSource(grid);
+  if (!src) return 0n;
+
+  // Memoize path counts for each splitter position
+  const memo = new Map<string, bigint>();
+
+  function pathsFromSplitter(splitterRow: number, splitterCol: number, dir: Direction): bigint {
+    const [nr, nc] = nextPos(splitterRow, splitterCol, dir);
+    if (!inBounds(nr, nc, rows, cols)) {
+      return 1n; // beam immediately exits = 1 path
+    }
+    // Check if this cell is itself a splitter
+    if (grid[nr][nc] === '^') {
+      const key = `${nr},${nc}`;
+      if (memo.has(key)) return memo.get(key)!;
+      const leftPaths = pathsFromSplitter(nr, nc, 'down-left');
+      const rightPaths = pathsFromSplitter(nr, nc, 'down-right');
+      const total = leftPaths + rightPaths;
+      memo.set(key, total);
+      return total;
+    }
+    // Trace from (nr, nc) in direction dir
+    return pathsFromCell(nr, nc, dir);
+  }
+
+  function pathsFromCell(row: number, col: number, dir: Direction): bigint {
+    const target = traceBeam(row, col, dir, grid, rows, cols);
+    if (target === null) {
+      return 1n;
+    }
+    const key = `${target[0]},${target[1]}`;
+    if (memo.has(key)) return memo.get(key)!;
+    const leftPaths = pathsFromSplitter(target[0], target[1], 'down-left');
+    const rightPaths = pathsFromSplitter(target[0], target[1], 'down-right');
+    const total = leftPaths + rightPaths;
+    memo.set(key, total);
+    return total;
+  }
+
+  // Start: beam from source going down
+  // The source itself is the starting point
+  // Trace from source downward
+  const [sr, sc] = src;
+
+  // Check if source cell itself... source is always on top row, emits beam down.
+  // First move is to (sr+1, sc) going down.
+  if (sr + 1 >= rows) {
+    // Grid is only 1 row, beam exits immediately
+    return 1n;
+  }
+
+  const firstRow = sr + 1;
+  const firstCol = sc;
+
+  if (grid[firstRow][firstCol] === '^') {
+    // Immediately hits a splitter
+    const key = `${firstRow},${firstCol}`;
+    const leftPaths = pathsFromSplitter(firstRow, firstCol, 'down-left');
+    const rightPaths = pathsFromSplitter(firstRow, firstCol, 'down-right');
+    const total = leftPaths + rightPaths;
+    memo.set(key, total);
+    return total;
+  }
+
+  return pathsFromCell(firstRow, firstCol, 'down');
+}
