--- /dev/null
+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,137 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processFootnotes(content: string): string {
+  // Extract footnote definitions [^N]: text
+  const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  const footnotes: Map<string, string> = new Map();
+  let match: RegExpExecArray | null;
+  while ((match = footnoteDefRegex.exec(content)) !== null) {
+    footnotes.set(match[1], match[2]);
+  }
+
+  if (footnotes.size === 0) return content;
+
+  // Remove footnote definitions from content
+  let result = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '');
+
+  // Replace inline footnote references [^N] with superscript links
+  result = result.replace(/\[\^(\d+)\]/g, (_match, id: string) => {
+    return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+  });
+
+  // Build footnotes section
+  const footnotesHtml = Array.from(footnotes.entries())
+    .map(([id, text]) => `<li id="fn-${id}">${text}</li>`)
+    .join('\n');
+
+  result = result.trimEnd() + `\n<section class="footnotes">\n<ol>\n${footnotesHtml}\n</ol>\n</section>`;
+
+  return result;
+}
+
+function processAdmonitions(content: string): string {
+  return content.replace(
+    /^:::(note|warning|tip)\n([\s\S]*?)^:::/gm,
+    (_match, type: string, body: string) => {
+      return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+    }
+  );
+}
+
+function markdownToHtml(content: string): string {
+  let html = content;
+
+  // Process headings (must be done before paragraph processing)
+  html = html.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
+  html = html.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
+  html = html.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
+  html = html.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
+  html = html.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
+  html = html.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');
+
+  // Process code blocks (fenced)
+  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_match, lang: string, code: string) => {
+    if (lang) {
+      return `<pre><code class="language-${lang}">${code.trimEnd()}</code></pre>`;
+    }
+    return `<pre><code>${code.trimEnd()}</code></pre>`;
+  });
+
+  // Process inline styles
+  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
+  html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
+
+  // Process links
+  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
+
+  // Process unordered lists
+  html = html.replace(/^[-*]\s+(.+)$/gm, '<li>$1</li>');
+
+  // Wrap consecutive li elements in ul
+  html = html.replace(/((?:<li>.*<\/li>\n?)+)/g, '<ul>\n$1</ul>');
+
+  // Process paragraphs - wrap standalone text lines
+  const lines = html.split('\n');
+  const result: string[] = [];
+  for (const line of lines) {
+    const trimmed = line.trim();
+    if (
+      trimmed === '' ||
+      trimmed.startsWith('<h') ||
+      trimmed.startsWith('<pre') ||
+      trimmed.startsWith('<ul') ||
+      trimmed.startsWith('<li') ||
+      trimmed.startsWith('</ul') ||
+      trimmed.startsWith('<div') ||
+      trimmed.startsWith('</div') ||
+      trimmed.startsWith('<section') ||
+      trimmed.startsWith('</section') ||
+      trimmed.startsWith('<ol') ||
+      trimmed.startsWith('</ol') ||
+      trimmed.startsWith('<sup') ||
+      trimmed.startsWith('<blockquote')
+    ) {
+      result.push(line);
+    } else if (trimmed.length > 0 && !trimmed.startsWith('<')) {
+      result.push(`<p>${trimmed}</p>`);
+    } else {
+      result.push(line);
+    }
+  }
+
+  return result.filter(line => line.trim() !== '').join('\n');
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // If content looks like it's already HTML (starts with <), preserve it
+        if (content.trim().startsWith('<')) {
+          return { ...file, content };
+        }
+
+        if (content === '') {
+          return { ...file, content: '' };
+        }
+
+        // Process admonitions before markdown conversion
+        content = processAdmonitions(content);
+
+        // Process footnotes
+        content = processFootnotes(content);
+
+        // Convert markdown to HTML
+        content = markdownToHtml(content);
+
+        return { ...file, content };
+      },
+    },
+  };
+}
