server-config') as DevServerConfig;\n    93→    expect(config.assetPaths).toEqual([]);\n    94→  });\n    95→});\n    96→"}]},"parent_tool_use_id":"toolu_017Uqu5sf5nPzFsA1J5hc8Po","session_id":"3e21e73b-f718-4343-a647-fa1a63219f0d","uuid":"64da5003-fd79-4901-b5bb-5611cd2cbfce"}
