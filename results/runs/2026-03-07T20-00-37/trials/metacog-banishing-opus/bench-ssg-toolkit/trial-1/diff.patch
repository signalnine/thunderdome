+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V79jgoYUHVabF8N496mA4M","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { createRssFeedPlugin } from '../../src/plugins/rss-feed.js';\n     3→import { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n     4→\n     5→const testConfig: SiteConfig = {\n     6→  title: 'Test Site',\n     7→  baseUrl: 'https://example.com',\n     8→  outputDir: './dist',\n     9→  contentDir: './content',\n    10→  templateDir: './templates',\n    11→};\n    12→\n    13→function makeCtx(files: ContentFile[] = [], data?: Map<string, unknown>): BuildContext {\n    14→  return {\n    15→    config: testConfig,\n    16→    files,\n    17→    output: new Map(),\n    18→    assets: new Map(),\n    19→    data: data || new Map(),\n    20→  };\n    21→}\n    22→\n    23→function makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n    24→  return {\n    25→    slug: 'test',\n    26→    title: 'Test',\n    27→    content: '<p>HTML content</p>',\n    28→    metadata: {},\n    29→    ...overrides,\n    30→  };\n    31→}\n    32→\n    33→describe('rss-feed plugin', () => {\n    34→  const plugin = createRssFeedPlugin();\n    35→\n    36→  it('generates valid RSS 2.0 XML', async () => {\n    37→    const files = [makeFile({ slug: 'post-1', title: 'Post 1', date: '2024-01-01' })];\n    38→    const ctx = makeCtx(files);\n    39→    await plugin.hooks.afterBuild!(ctx);\n    40→    const feed = ctx.output.get('feed.xml')!;\n    41→    expect(feed).toContain('<?xml version=\"1.0\"');\n    42→    expect(feed).toContain('<rss version=\"2.0\">');\n    43→    expect(feed).toContain('<channel>');\n    44→    expect(feed).toContain('<item>');\n    45→    expect(feed).toContain('</rss>');\n    46→  });\n    47→\n    48→  it('feed items contain HTML content not raw markdown', async () => {\n    49→    const files = [\n    50→      makeFile({\n    51→        slug: 'post-1',\n    52→        title: 'Post 1',\n    53→        content: '<p>This is <strong>HTML</strong> content</p>',\n    54→        date: '2024-01-01',\n    55→      }),\n    56→    ];\n    57→    const ctx = makeCtx(files);\n    58→    await plugin.hooks.afterBuild!(ctx);\n    59→    const feed = ctx.output.get('feed.xml')!;\n    60→    expect(feed).toContain('<![CDATA[<p>This is <strong>HTML</strong> content</p>]]>');\n    61→  });\n    62→\n    63→  it('feed items include category tags from taxonomy', async () => {\n    64→    const files = [\n    65→      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['javascript'], date: '2024-01-01' }),\n    66→    ];\n    67→    const tagMap = new Map<string, ContentFile[]>();\n    68→    tagMap.set('javascript', [files[0]]);\n    69→    const data = new Map<string, unknown>();\n    70→    data.set('taxonomy-tags', tagMap);\n    71→    const ctx = makeCtx(files, data);\n    72→    await plugin.hooks.afterBuild!(ctx);\n    73→    const feed = ctx.output.get('feed.xml')!;\n    74→    expect(feed).toContain('<category>javascript</category>');\n    75→  });\n    76→\n    77→  it('feed includes channel title from config', async () => {\n    78→    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n    79→    const ctx = makeCtx(files);\n    80→    await plugin.hooks.afterBuild!(ctx);\n    81→    const feed = ctx.output.get('feed.xml')!;\n    82→    expect(feed).toContain('<title>Test Site</title>');\n    83→  });\n    84→\n    85→  it('feed items sorted by date newest first', async () => {\n    86→    const files = [\n    87→      makeFile({ slug: 'old', title: 'Old Post', date: '2023-01-01' }),\n    88→      makeFile({ slug: 'new', title: 'New Post', date: '2024-06-15' }),\n    89→      makeFile({ slug: 'mid', title: 'Mid Post', date: '2024-01-01' }),\n    90→    ];\n    91→    const ctx = makeCtx(files);\n    92→    await plugin.hooks.afterBuild!(ctx);\n    93→    const feed = ctx.output.get('feed.xml')!;\n    94→    const newIdx = feed.indexOf('New Post');\n    95→    const midIdx = feed.indexOf('Mid Post');\n    96→    const oldIdx = feed.indexOf('Old Post');\n    97→    expect(newIdx).toBeLessThan(midIdx);\n    98→    expect(midIdx).toBeLessThan(oldIdx);\n    99→  });\n   100→\n   101→  it('handles files without dates', async () => {\n   102→    const files = [\n   103→      makeFile({ slug: 'no-date', title: 'No Date Post', content: '<p>No date</p>' }),\n   104→    ];\n   105→    const ctx = makeCtx(files);\n   106→    await plugin.hooks.afterBuild!(ctx);\n   107→    const feed = ctx.output.get('feed.xml')!;\n   108→    expect(feed).toContain('No Date Post');\n   109→    expect(feed).not.toContain('<pubDate>undefined</pubDate>');\n   110→  });\n   111→\n   112→  it('feed link uses baseUrl from config', async () => {\n   113→    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n   114→    const ctx = makeCtx(files);\n   115→    await plugin.hooks.afterBuild!(ctx);\n   116→    const feed = ctx.output.get('feed.xml')!;\n   117→    expect(feed).toContain('<link>https://example.com</link>');\n   118→    expect(feed).toContain('<link>https://example.com/post-1.html</link>');\n   119→  });\n   120→});\n   121→"}]},"parent_tool_use_id":"toolu_017Uqu5sf5nPzFsA1J5hc8Po","session_id":"3e21e73b-f718-4343-a647-fa1a63219f0d","uuid":"e6c38870-0a20-432e-9db2-e086f33011ad"}
