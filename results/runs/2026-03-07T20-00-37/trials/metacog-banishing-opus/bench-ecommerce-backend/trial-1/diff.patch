uct', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('A', 10, 'cat1');\n    catalog.updateProduct(id, { price: 20, name: 'B' });\n    expect(catalog.getProduct(id)).toEqual({ id, name: 'B', price: 20, category: 'cat1' });\n  });\n\n  it('should remove a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('A', 10, 'cat1');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct('nonexistent')).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.PRODUCT_CREATED, (p) => { events.push(p); });\n    catalog.createProduct('Test', 5, 'cat');\n    // bus.emit is async but called synchronously within createProduct - wait a tick\n    await new Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n  });\n});\n\ndescribe('InventoryService', () => {\n  it('should set and get stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should reserve stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve insufficient stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(3);\n  });\n\n  it('should release reserved stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert', async () => {\n    const inventory = createInventoryService(bus);\n    const alerts: unknown[] = [];\n    bus.on(Events.LOW_STOCK_ALERT, (p) => { alerts.push(p); });\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    // Stock is 10, threshold 5, no alert yet\n    await new Promise(r => setTimeout(r, 10));\n    expect(alerts).toHaveLength(0);\n\n    inventory.setStock('p1', 3);\n    await new Promise(r => setTimeout(r, 10));\n    expect(alerts).toHaveLength(1);\n  });\n});\n\ndescribe('CartService', () => {\n  it('should create cart and add items', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c).toBeTruthy();\n    expect(c!.items).toEqual([{ productId: 'p1', quantity: 2 }]);\n  });\n\n  it('should consolidate same product additions', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    expect(cart.getCart(id)!.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n  });\n\n  it('should remove item', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    expect(cart.getCart(id)!.items).toEqual([{ productId: 'p2', quantity: 1 }]);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    expect(cart.getCart(id)!.items).toEqual([{ productId: 'p1', quantity: 10 }]);\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    expect(cart.getCart(id)!.items).toEqual([]);\n  });\n\n  it('should return null for nonexistent cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('PricingService', () => {\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10',\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // (100 - 10) * 0.1\n    expect(result.total).toBe(99); // 90 + 9\n  });\n\n  it('should track product prices from events', async () => {\n    const pricing = createPricingService(bus);\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 25, 'gadgets');\n    await new Promise(r => setTimeout(r, 10));\n    // The productId is generated by catalog, but pricing should have stored the price\n    // We need to know the id, which is prod_1 since it's the first product\n    expect(pricing.getPrice('prod_1')).toBe(25);\n  });\n\n  it('should ignore unknown discount code', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 50 }],\n      'INVALID',\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(55); // 50 + 5 tax\n  });\n});\n\ndescribe('OrderService', () => {\n  it('should create and retrieve orders', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    const order = orders.getOrder(id);\n    expect(order).toBeTruthy();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(100);\n  });\n\n  it('should update order status', async () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n\n    const statusChanges: unknown[] = [];\n    bus.on(Events.ORDER_STATUS_CHANGED, (p) => { statusChanges.push(p); });\n\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n    expect(statusChanges).toHaveLength(1);\n    expect((statusChanges[0] as { previousStatus: string }).previousStatus).toBe(OrderStatus.PENDING);\n  });\n\n  it('should list orders by user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'c1', 10);\n    orders.createOrder('user2', 'c2', 20);\n    orders.createOrder('user1', 'c3', 30);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for nonexistent order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('PaymentService', () => {\n  it('should process payment successfully', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeTruthy();\n  });\n\n  it('should simulate failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should simulate timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(await payment.refund(result.transactionId!)).toBe(true);\n  });\n\n  it('should not refund nonexistent transaction', async () => {\n    const payment = createPaymentService(bus);\n    expect(await payment.refund('nonexistent')).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const events: unknown[] = [];\n    bus.on(Events.PAYMENT_PROCESSED, (p) => { events.push(p); });\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 50);\n    expect(events).toHaveLength(1);\n  });\n});\n\ndescribe('NotificationService', () => {\n  it('should send notifications to subscribed users on order events', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(1);\n    expect(notifs[0].type).toBe('order_created');\n  });\n\n  it('should not send notifications to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    orders.createOrder('user2', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(notifications.getNotifications('user2')).toHaveLength(0);\n  });\n\n  it('should track order status changes', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(2);\n    expect(notifs.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should send payment notifications', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    await payment.processPayment(orderId, 50);\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  it('should count events', async () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n\n    catalog.createProduct('A', 10, 'cat');\n    catalog.createProduct('B', 20, 'cat');\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cartService = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const c1 = cartService.createCart('user1');\n    cartService.addItem(c1, 'p1', 1);\n    await new Promise(r => setTimeout(r, 10));\n\n    const c2 = cartService.createCart('user2');\n    cartService.addItem(c2, 'p2', 1);\n    await new Promise(r => setTimeout(r, 10));\n\n    orders.createOrder('user1', c1, 50);\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should track top products', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cartService = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const c1 = cartService.createCart('user1');\n    cartService.addItem(c1, 'p1', 5);\n    cartService.addItem(c1, 'p2', 2);\n    await new Promise(r => setTimeout(r, 10));\n\n    orders.createOrder('user1', c1, 100);\n    await new Promise(r => setTimeout(r, 10));\n\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(2);\n  });\n\n  it('should not count revenue for failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n\n    expect(analytics.getRevenue()).toBe(0);\n  });\n});\n\ndescribe('Integration: Full flow', () => {\n  it('should handle a complete purchase flow', async () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29, 'electronics');\n    await new Promise(r => setTimeout(r, 10));\n\n    // Set inventory\n    inventory.setStock(p1, 10);\n    inventory.setStock(p2, 50);\n\n    // Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, p1, 1);\n    cartService.addItem(cartId, p2, 2);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Calculate price\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(item => ({\n      productId: item.productId,\n      quantity: item.quantity,\n      price: pricing.getPrice(item.productId),\n    }));\n    const totals = pricing.calculateTotal(items);\n    expect(totals.subtotal).toBe(1057);\n    expect(totals.tax).toBeCloseTo(105.7, 2);\n\n    // Reserve inventory\n    expect(inventory.reserve(p1, 1)).toBe(true);\n    expect(inventory.reserve(p2, 2)).toBe(true);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, totals.total);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Process payment\n    const payResult = await payment.processPayment(orderId, totals.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Verify final state\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.DELIVERED);\n    expect(inventory.getStock(p1)).toBe(9);\n\n    // Verify notifications were sent\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(4); // order created + 3 status changes + payment\n\n    // Verify analytics\n    expect(analytics.getRevenue()).toBe(totals.total);\n    expect(analytics.getConversionRate()).toBe(1);\n    expect(analytics.getTopProducts(1)[0].productId).toBe(p2); // mouse qty 2 > laptop qty 1... wait, let me check\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":239,"cache_read_input_tokens":36143,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":239},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4be15ed7-9c8a-4a81-9fc5-e8c1c2bbcfaf","uuid":"2a920a3c-0567-4b29-a66e-6f81fe8e207b"}
