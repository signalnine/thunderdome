new file mode 100644
index 0000000..dd4e898
--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,104 @@
+import { EventBus } from '../bus.js';
+import {
+  AnalyticsService,
+  Events,
+  OrderCreatedEvent,
+  PaymentProcessedEvent,
+  PaymentStatus,
+} from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let revenue = 0;
+  const cartIds = new Set<string>();
+  let orderCount = 0;
+  const productCounts = new Map<string, number>();
+  const orderAmounts = new Map<string, number>();
+  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();
+
+  function increment(eventType: string) {
+    eventCounts.set(eventType, (eventCounts.get(eventType) ?? 0) + 1);
+  }
+
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    const event = payload as { cartId: string; items: Array<{ productId: string; quantity: number }> };
+    cartIds.add(event.cartId);
+    cartItems.set(event.cartId, event.items);
+    increment(Events.CART_UPDATED);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    orderCount++;
+    orderAmounts.set(event.orderId, event.total);
+    increment(Events.ORDER_CREATED);
+
+    const items = cartItems.get(event.cartId);
+    if (items) {
+      for (const item of items) {
+        productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);
+      }
+    }
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as PaymentProcessedEvent;
+    increment(Events.PAYMENT_PROCESSED);
+    if (event.status === PaymentStatus.SUCCESS) {
+      const amount = orderAmounts.get(event.orderId);
+      if (amount !== undefined) {
+        revenue += amount;
+      }
+    }
+  });
+
+  bus.on(Events.PRODUCT_CREATED, (_payload: unknown) => {
+    increment(Events.PRODUCT_CREATED);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, (_payload: unknown) => {
+    increment(Events.ORDER_STATUS_CHANGED);
+  });
+
+  bus.on(Events.INVENTORY_UPDATED, (_payload: unknown) => {
+    increment(Events.INVENTORY_UPDATED);
+  });
+
+  bus.on(Events.LOW_STOCK_ALERT, (_payload: unknown) => {
+    increment(Events.LOW_STOCK_ALERT);
+  });
+
+  bus.on(Events.NOTIFICATION_SENT, (_payload: unknown) => {
+    increment(Events.NOTIFICATION_SENT);
+  });
+
+  bus.on(Events.PRICE_CALCULATED, (_payload: unknown) => {
+    increment(Events.PRICE_CALCULATED);
+  });
+
+  bus.on(Events.ANALYTICS_EVENT, (_payload: unknown) => {
+    increment(Events.ANALYTICS_EVENT);
+  });
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) ?? 0;
+    },
+
+    getRevenue(): number {
+      return revenue;
+    },
+
+    getConversionRate(): number {
+      if (cartIds.size === 0) return 0;
+      return orderCount / cartIds.size;
+    },
+
+    getTopProducts(limit: number) {
+      return Array.from(productCounts.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
