+import express from 'express';
+import type Database from 'better-sqlite3';
+import { createDatabase } from './database.js';
+import { usersRouter } from './routes/users.js';
+import { eventsRouter } from './routes/events.js';
+import { queriesRouter } from './routes/queries.js';
+import { dashboardsRouter } from './routes/dashboards.js';
+import { exportRouter } from './routes/export.js';
+
+export function createApp(db?: Database.Database): express.Application {
+  const database = db || createDatabase();
+  const app = express();
+
+  app.use(express.json());
+
+  app.get('/health', (_req, res) => {
+    res.json({ status: 'ok' });
+  });
+
+  app.use('/api/users', usersRouter(database));
+  app.use('/api/events', eventsRouter(database));
+  app.use('/api/queries', queriesRouter(database));
+  app.use('/api/dashboards', dashboardsRouter(database));
+  app.use('/api/export', exportRouter(database));
+
+  return app;
+}
