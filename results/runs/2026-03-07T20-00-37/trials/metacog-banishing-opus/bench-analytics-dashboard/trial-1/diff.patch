rst user is admin\n    });\n\n    it('should login a user', async () => {\n      await request(app)\n        .post('/api/users/register')\n        .send({ email: 'test@example.com', password: 'password123', tenantId: 'tenant1' });\n\n      const res = await request(app)\n        .post('/api/users/login')\n        .send({ email: 'test@example.com', password: 'password123' });\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n    });\n\n    it('should reject invalid login', async () => {\n      const res = await request(app)\n        .post('/api/users/login')\n        .send({ email: 'nonexistent@example.com', password: 'password123' });\n      expect(res.status).toBe(401);\n    });\n\n    it('should get user profile', async () => {\n      const reg = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'test@example.com', password: 'password123', tenantId: 'tenant1' });\n\n      const res = await request(app)\n        .get('/api/users/me')\n        .set('Authorization', `Bearer ${reg.body.token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe('test@example.com');\n    });\n\n    it('should reject unauthenticated profile request', async () => {\n      const res = await request(app).get('/api/users/me');\n      expect(res.status).toBe(401);\n    });\n\n    it('should change user role as admin', async () => {\n      const admin = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'admin@example.com', password: 'password123', tenantId: 'tenant1' });\n\n      const viewer = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'viewer@example.com', password: 'password123', tenantId: 'tenant1' });\n\n      const res = await request(app)\n        .put(`/api/users/${viewer.body.id}/role`)\n        .set('Authorization', `Bearer ${admin.body.token}`)\n        .send({ role: 'editor' });\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe('editor');\n    });\n\n    it('should prevent non-admin from changing roles', async () => {\n      const admin = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'admin@example.com', password: 'password123', tenantId: 'tenant1' });\n\n      const viewer = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'viewer@example.com', password: 'password123', tenantId: 'tenant1' });\n\n      const viewerLogin = await request(app)\n        .post('/api/users/login')\n        .send({ email: 'viewer@example.com', password: 'password123' });\n\n      const res = await request(app)\n        .put(`/api/users/${admin.body.id}/role`)\n        .set('Authorization', `Bearer ${viewerLogin.body.token}`)\n        .send({ role: 'admin' });\n      expect(res.status).toBe(403);\n    });\n  });\n\n  describe('Event Ingestion', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'test@example.com', password: 'password123', tenantId: 'tenant1' });\n      token = reg.body.token;\n    });\n\n    it('should ingest a single event', async () => {\n      const res = await request(app)\n        .post('/api/events')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'page_view', properties: { url: '/home' } });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe('page_view');\n    });\n\n    it('should ingest batch events', async () => {\n      const res = await request(app)\n        .post('/api/events/batch')\n        .set('Authorization', `Bearer ${token}`)\n        .send({\n          events: [\n            { name: 'page_view', properties: { url: '/home' } },\n            { name: 'click', properties: { button: 'signup' } },\n            { name: 'page_view', properties: { url: '/about' } },\n          ],\n        });\n      expect(res.status).toBe(201);\n      expect(res.body.inserted).toBe(3);\n    });\n\n    it('should reject unauthenticated event', async () => {\n      const res = await request(app)\n        .post('/api/events')\n        .send({ name: 'page_view' });\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe('Query Engine', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'test@example.com', password: 'password123', tenantId: 'tenant1' });\n      token = reg.body.token;\n\n      await request(app)\n        .post('/api/events/batch')\n        .set('Authorization', `Bearer ${token}`)\n        .send({\n          events: [\n            { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-01T10:00:00Z' },\n            { name: 'page_view', properties: { url: '/about' }, timestamp: '2024-01-01T14:00:00Z' },\n            { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-02T10:00:00Z' },\n            { name: 'click', properties: { button: 'signup' }, timestamp: '2024-01-02T12:00:00Z' },\n          ],\n        });\n    });\n\n    it('should count events', async () => {\n      const res = await request(app)\n        .post('/api/queries/count')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ eventName: 'page_view' });\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(3);\n    });\n\n    it('should count all events', async () => {\n      const res = await request(app)\n        .post('/api/queries/count')\n        .set('Authorization', `Bearer ${token}`)\n        .send({});\n      expect(res.status).toBe(200);\n      expect(res.body.count).toBe(4);\n    });\n\n    it('should return timeseries data', async () => {\n      const res = await request(app)\n        .post('/api/queries/timeseries')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ eventName: 'page_view', interval: 'day' });\n      expect(res.status).toBe(200);\n      expect(res.body.data.length).toBe(2);\n    });\n\n    it('should return breakdown data', async () => {\n      const res = await request(app)\n        .post('/api/queries/breakdown')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ eventName: 'page_view', property: 'url' });\n      expect(res.status).toBe(200);\n      expect(res.body.data.length).toBe(2);\n    });\n  });\n\n  describe('Tenant Isolation', () => {\n    let token1: string;\n    let token2: string;\n\n    beforeEach(async () => {\n      const reg1 = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'user1@example.com', password: 'password123', tenantId: 'tenant1' });\n      token1 = reg1.body.token;\n\n      const reg2 = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'user2@example.com', password: 'password123', tenantId: 'tenant2' });\n      token2 = reg2.body.token;\n\n      await request(app)\n        .post('/api/events')\n        .set('Authorization', `Bearer ${token1}`)\n        .send({ name: 'page_view', properties: { url: '/home' } });\n\n      await request(app)\n        .post('/api/events')\n        .set('Authorization', `Bearer ${token2}`)\n        .send({ name: 'click', properties: { button: 'login' } });\n    });\n\n    it('should isolate event counts by tenant', async () => {\n      const res1 = await request(app)\n        .post('/api/queries/count')\n        .set('Authorization', `Bearer ${token1}`)\n        .send({});\n      expect(res1.body.count).toBe(1);\n\n      const res2 = await request(app)\n        .post('/api/queries/count')\n        .set('Authorization', `Bearer ${token2}`)\n        .send({});\n      expect(res2.body.count).toBe(1);\n    });\n  });\n\n  describe('Dashboard CRUD', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'test@example.com', password: 'password123', tenantId: 'tenant1' });\n      token = reg.body.token;\n    });\n\n    it('should create a dashboard', async () => {\n      const res = await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'My Dashboard', config: { theme: 'dark' } });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe('My Dashboard');\n    });\n\n    it('should list dashboards', async () => {\n      await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Dashboard 1' });\n      await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Dashboard 2' });\n\n      const res = await request(app)\n        .get('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.length).toBe(2);\n    });\n\n    it('should get a single dashboard', async () => {\n      const created = await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'My Dashboard' });\n\n      const res = await request(app)\n        .get(`/api/dashboards/${created.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('My Dashboard');\n    });\n\n    it('should update a dashboard', async () => {\n      const created = await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Old Name' });\n\n      const res = await request(app)\n        .put(`/api/dashboards/${created.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'New Name' });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('New Name');\n    });\n\n    it('should delete a dashboard', async () => {\n      const created = await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'To Delete' });\n\n      const res = await request(app)\n        .delete(`/api/dashboards/${created.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(204);\n\n      const get = await request(app)\n        .get(`/api/dashboards/${created.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(get.status).toBe(404);\n    });\n  });\n\n  describe('Data Export', () => {\n    let token: string;\n\n    beforeEach(async () => {\n      const reg = await request(app)\n        .post('/api/users/register')\n        .send({ email: 'test@example.com', password: 'password123', tenantId: 'tenant1' });\n      token = reg.body.token;\n\n      await request(app)\n        .post('/api/events/batch')\n        .set('Authorization', `Bearer ${token}`)\n        .send({\n          events: [\n            { name: 'page_view', properties: { url: '/home' } },\n            { name: 'click', properties: { button: 'signup' } },\n          ],\n        });\n    });\n\n    it('should export events as JSON', async () => {\n      const res = await request(app)\n        .get('/api/export/events/json')\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(2);\n      expect(res.body.count).toBe(2);\n    });\n\n    it('should export events as CSV', async () => {\n      const res = await request(app)\n        .get('/api/export/events/csv')\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers['content-type']).toContain('text/csv');\n      const lines = res.text.split('\\n');\n      expect(lines.length).toBe(3); // header + 2 events\n    });\n\n    it('should export dashboards as JSON', async () => {\n      await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Test Dashboard' });\n\n      const res = await request(app)\n        .get('/api/export/dashboards/json')\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards.length).toBe(1);\n    });\n\n    it('should export dashboards as CSV', async () => {\n      await request(app)\n        .post('/api/dashboards')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Test Dashboard' });\n\n      const res = await request(app)\n        .get('/api/export/dashboards/csv')\n        .set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.headers['content-type']).toContain('text/csv');\n    });\n  });\n});\n","structuredPatch":[{"oldStart":91,"oldLines":7,"newStart":91,"newLines":7,"lines":["         .post('/api/users/register')","         .send({ email: 'admin@example.com', password: 'password123', tenantId: 'tenant1' });"," ","-      const viewer = await request(app)","+      await request(app)","         .post('/api/users/register')","         .send({ email: 'viewer@example.com', password: 'password123', tenantId: 'tenant1' });"," "]}],"userModified":false,"replaceAll":false}}
