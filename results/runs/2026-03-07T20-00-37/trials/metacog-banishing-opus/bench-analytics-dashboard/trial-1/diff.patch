@@ -0,0 +1,163 @@
+import { Router, Response } from 'express';
+import type Database from 'better-sqlite3';
+import { authMiddleware, AuthRequest } from '../auth.js';
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export function exportRouter(db: Database.Database): Router {
+  const router = Router();
+  const auth = authMiddleware(db);
+
+  router.use(auth);
+
+  router.get('/events/json', (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+
+    const { eventName, startDate, endDate } = req.query;
+
+    let sql = 'SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [req.user.tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    sql += ' ORDER BY timestamp DESC';
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    const formatted = events.map(e => ({
+      id: e.id,
+      name: e.name,
+      properties: JSON.parse(e.properties),
+      timestamp: e.timestamp,
+      userId: e.user_id,
+      sessionId: e.session_id,
+    }));
+
+    res.json({ events: formatted, count: formatted.length });
+  });
+
+  router.get('/events/csv', (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+
+    const { eventName, startDate, endDate } = req.query;
+
+    let sql = 'SELECT id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [req.user.tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    sql += ' ORDER BY timestamp DESC';
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    const header = 'id,name,properties,timestamp,user_id,session_id';
+    const rows = events.map(e => {
+      const props = e.properties.replace(/"/g, '""');
+      return `${e.id},${e.name},"${props}",${e.timestamp},${e.user_id || ''},${e.session_id || ''}`;
+    });
+
+    const csv = [header, ...rows].join('\n');
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+    res.send(csv);
+  });
+
+  router.get('/dashboards/json', (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+
+    const dashboards = db.prepare(
+      'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ?'
+    ).all(req.user.tenantId) as DashboardRow[];
+
+    const formatted = dashboards.map(d => ({
+      id: d.id,
+      name: d.name,
+      tenantId: d.tenant_id,
+      ownerId: d.owner_id,
+      config: JSON.parse(d.config),
+      createdAt: d.created_at,
+      updatedAt: d.updated_at,
+    }));
+
+    res.json({ dashboards: formatted, count: formatted.length });
+  });
+
+  router.get('/dashboards/csv', (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+
+    const dashboards = db.prepare(
+      'SELECT id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ?'
+    ).all(req.user.tenantId) as DashboardRow[];
+
+    const header = 'id,name,owner_id,config,created_at,updated_at';
+    const rows = dashboards.map(d => {
+      const config = d.config.replace(/"/g, '""');
+      return `${d.id},${d.name},${d.owner_id},"${config}",${d.created_at},${d.updated_at}`;
+    });
+
+    const csv = [header, ...rows].join('\n');
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="dashboards.csv"');
+    res.send(csv);
+  });
+
+  return router;
+}
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..a0e9b0e
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,149 @@
+import { Router, Response } from 'express';
+import type Database from 'better-sqlite3';
+import { authMiddleware, AuthRequest } from '../auth.js';
+
+export function queriesRouter(db: Database.Database): Router {
+  const router = Router();
+  const auth = authMiddleware(db);
+
+  router.use(auth);
+
+  router.post('/count', (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+
+    const { eventName, startDate, endDate, filters } = req.body;
+
+    let sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [req.user.tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ' AND json_extract(properties, ?) = ?';
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  router.post('/timeseries', (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+
+    const bucketExpr = getBucketExpression(interval || 'day');
+
+    let sql = `SELECT ${bucketExpr} as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [req.user.tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ' AND json_extract(properties, ?) = ?';
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += ' GROUP BY bucket ORDER BY bucket ASC';
+
+    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+    res.json({ data: results, interval: interval || 'day' });
+  });
+
+  router.post('/breakdown', (req: AuthRequest, res: Response): void => {
+    if (!req.user) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+
+    const { eventName, property, startDate, endDate, filters } = req.body;
+
+    if (!property) {
+      res.status(400).json({ error: 'property is required for breakdown queries' });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [`$.${property}`, req.user.tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ' AND json_extract(properties, ?) = ?';
+        params.push(`$.${key}`, value);
+      }
+    }
+
+    sql += ' GROUP BY value ORDER BY count DESC';
+
+    const results = db.prepare(sql).all(...params) as Array<{ value: string; count: number }>;
+    res.json({ data: results, property });
+  });
+
+  return router;
+}
+
+function getBucketExpression(interval: string): string {
+  switch (interval) {
+    case 'hour':
+      return "strftime('%Y-%m-%d %H:00:00', timestamp)";
+    case 'day':
+      return "strftime('%Y-%m-%d', timestamp)";
+    case 'week':
+      return "strftime('%Y-%W', timestamp)";
+    case 'month':
+      return "strftime('%Y-%m', timestamp)";
+    default:
+      return "strftime('%Y-%m-%d', timestamp)";
+  }
+}
