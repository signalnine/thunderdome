+import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string;
+  stop: string | null;
+}
+
+interface StorageData {
+  entries: TimeEntry[];
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.load();
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    this.entries.push({
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    });
+
+    this.save();
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return { ...running };
+  }
+
+  getEntries(options?: { from?: Date; to?: Date }): TimeEntry[] {
+    if (!options) {
+      return this.entries.map((e) => ({ ...e }));
+    }
+
+    return this.entries
+      .filter((entry) => {
+        const entryStart = new Date(entry.start);
+        if (options.from && entryStart < options.from) return false;
+        if (options.to && entryStart > options.to) return false;
+        return true;
+      })
+      .map((e) => ({ ...e }));
+  }
+
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+    const now = Date.now();
+
+    for (const entry of this.entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop ? new Date(entry.stop).getTime() : now;
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  isRunning(): boolean {
+    return this.getRunningEntry() !== null;
+  }
+
+  getRunningTask(): string | null {
+    const running = this.getRunningEntry();
+    return running ? running.task : null;
+  }
+
+  private getRunningEntry(): TimeEntry | null {
+    for (let i = this.entries.length - 1; i >= 0; i--) {
+      if (this.entries[i].stop === null) {
+        return this.entries[i];
+      }
+    }
+    return null;
+  }
+
+  private load(): void {
+    try {
+      const data = readFileSync(this.filePath, "utf-8");
+      const parsed: StorageData = JSON.parse(data);
+      this.entries = parsed.entries ?? [];
+    } catch {
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+
+    const data: StorageData = { entries: this.entries };
+    writeFileSync(this.filePath, JSON.stringify(data, null, 2), "utf-8");
+  }
+}
