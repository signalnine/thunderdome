);\n      expect(entries[1].stop).toBeNull();\n    });\n\n    it(\"should throw when starting with empty name\", () => {\n      const tracker = new TimeTracker(filePath);\n      expect(() => tracker.start(\"\")).toThrow(\"Task name cannot be empty\");\n      expect(() => tracker.start(\"   \")).toThrow(\"Task name cannot be empty\");\n    });\n\n    it(\"should throw when stopping with no running timer\", () => {\n      const tracker = new TimeTracker(filePath);\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n  });\n\n  describe(\"persistence\", () => {\n    it(\"should persist entries to file\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      tracker.stop();\n\n      expect(existsSync(filePath)).toBe(true);\n\n      const data = JSON.parse(readFileSync(filePath, \"utf-8\"));\n      expect(data.entries).toHaveLength(1);\n      expect(data.entries[0].task).toBe(\"coding\");\n    });\n\n    it(\"should load entries from existing file\", () => {\n      const tracker1 = new TimeTracker(filePath);\n      tracker1.start(\"coding\");\n      tracker1.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe(\"coding\");\n    });\n\n    it(\"should create parent directories automatically\", () => {\n      const nestedPath = join(\n        tmpdir(),\n        `time-tracker-test-${Date.now()}`,\n        \"nested\",\n        \"deep\",\n        \"data.json\"\n      );\n      const tracker = new TimeTracker(nestedPath);\n      tracker.start(\"test\");\n      tracker.stop();\n\n      expect(existsSync(nestedPath)).toBe(true);\n      rmSync(join(tmpdir(), `time-tracker-test-${Date.now().toString().slice(0, -3)}`), {\n        recursive: true,\n        force: true,\n      });\n    });\n\n    it(\"should handle non-existent file gracefully\", () => {\n      const tracker = new TimeTracker(filePath);\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(0);\n    });\n  });\n\n  describe(\"getEntries with date filtering\", () => {\n    it(\"should return all entries without filter\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"task1\");\n      tracker.stop();\n      tracker.start(\"task2\");\n      tracker.stop();\n\n      expect(tracker.getEntries()).toHaveLength(2);\n    });\n\n    it(\"should filter by date range\", async () => {\n      const tracker = new TimeTracker(filePath);\n\n      tracker.start(\"old-task\");\n      tracker.stop();\n      await sleep(20);\n\n      const from = new Date();\n      await sleep(20);\n\n      tracker.start(\"new-task\");\n      tracker.stop();\n\n      const filtered = tracker.getEntries({ from });\n      expect(filtered).toHaveLength(1);\n      expect(filtered[0].task).toBe(\"new-task\");\n    });\n\n    it(\"should filter with 'to' date\", async () => {\n      const tracker = new TimeTracker(filePath);\n\n      tracker.start(\"early-task\");\n      tracker.stop();\n\n      await sleep(20);\n      const to = new Date();\n      await sleep(20);\n\n      tracker.start(\"late-task\");\n      tracker.stop();\n\n      const filtered = tracker.getEntries({ to });\n      expect(filtered).toHaveLength(1);\n      expect(filtered[0].task).toBe(\"early-task\");\n    });\n  });\n\n  describe(\"getSummary\", () => {\n    it(\"should sum durations by task name\", async () => {\n      const tracker = new TimeTracker(filePath);\n\n      tracker.start(\"coding\");\n      await sleep(20);\n      tracker.stop();\n\n      tracker.start(\"coding\");\n      await sleep(20);\n      tracker.stop();\n\n      tracker.start(\"review\");\n      await sleep(20);\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThan(30);\n      expect(summary[\"review\"]).toBeGreaterThan(10);\n    });\n\n    it(\