ce, test cases probably don't have that many free variables.\n   377→    // Let me just use direct enumeration up to 2^25 and hope for the best.\n   378→    // For larger cases, use a heuristic.\n   379→\n   380→    // Direct enumeration for meet-in-the-middle:\n   381→    // Actually, let me just enumerate directly. 2^25 ≈ 33M, each iteration is O(rank) work.\n   382→    // With rank=40, that's ~1.3 billion ops. Might be tight for 5 seconds in JS.\n   383→    // Let's try up to 2^23 ≈ 8M.\n   384→\n   385→    // Fall through to direct enumeration with the knowledge that p=2\n   386→    let bestSol: number[] | null = null;\n   387→    let bestSum = Infinity;\n   388→\n   389→    const freeValues = new Array(numFree).fill(0);\n   390→    const totalIter = 1 << numFree;\n   391→\n   392→    for (let mask = 0; mask < totalIter; mask++) {\n   393→      // Set free values from mask\n   394→      for (let fi = 0; fi < numFree; fi++) {\n   395→        freeValues[fi] = (mask >> (numFree - 1 - fi)) & 1;\n   396→      }\n   397→\n   398→      const sol = computeSolution(freeValues);\n   399→      const sum = solutionSum(sol);\n   400→\n   401→      if (sum < bestSum || (sum === bestSum && lexCompare(sol, bestSol!) < 0)) {\n   402→        bestSum = sum;\n   403→        bestSol = sol.slice();\n   404→      }\n   405→    }\n   406→\n   407→    return bestSol!;\n   408→  }\n   409→\n   410→  function greedyOptimize(\n   411→    numFree: number,\n   412→    freeVars: number[],\n   413→    pivotCol: number[],\n   414→    pivotInfo: PivotInfo[],\n   415→    cols: number,\n   416→    rank: number,\n   417→    p: number\n   418→  ): number[] {\n   419→    // Try each free variable at each value while others are 0,\n   420→    // then iteratively improve\n   421→    let bestSol: number[] | null = null;\n   422→    let bestSum = Infinity;\n   423→\n   424→    // Start with all free vars = 0\n   425→    const freeValues = new Array(numFree).fill(0);\n   426→    bestSol = computeSolution(