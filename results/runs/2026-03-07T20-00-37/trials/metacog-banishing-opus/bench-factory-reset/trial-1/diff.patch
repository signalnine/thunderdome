+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function modInverse(a: number, p: number): number {
+  a = ((a % p) + p) % p;
+  let result = 1;
+  let base = a;
+  let exp = p - 2;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % p;
+    base = (base * base) % p;
+    exp >>= 1;
+  }
+  return result;
+}
+
+function modPos(val: number, p: number): number {
+  return ((val % p) + p) % p;
+}
+
+interface PivotInfo {
+  constant: number;
+  coeffs: number[];
+}
+
+type SolutionCompare = (a: number[], b: number[]) => number;
+
+function lexCmpVec(a: number[], b: number[]): number {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return 0;
+}
+
+function lexCmpSets(a: number[], b: number[]): number {
+  // Compare by extracting sorted indices where value > 0
+  // For p=2, this compares the pressed button sets lexicographically
+  const setA: number[] = [];
+  const setB: number[] = [];
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] > 0) setA.push(i);
+    if (b[i] > 0) setB.push(i);
+  }
+  const len = Math.min(setA.length, setB.length);
+  for (let i = 0; i < len; i++) {
+    if (setA[i] !== setB[i]) return setA[i] - setB[i];
+  }
+  return setA.length - setB.length;
+}
+
+function solveLinearSystem(
+  numLights: number,
+  numButtons: number,
+  buttonEffects: number[][],
+  target: number[],
+  p: number,
+  cmp: SolutionCompare
+): number[] | null {
+  const rows = numLights;
+  const cols = numButtons;
+
+  const matrix: number[][] = [];
+  for (let i = 0; i < rows; i++) {
+    const row = new Array<number>(cols + 1);
+    for (let j = 0; j < cols; j++) {
+      row[j] = buttonEffects[j][i] % p;
+    }
+    row[cols] = target[i] % p;
+    matrix.push(row);
+  }
+
+  const pivotCol: number[] = [];
+  let curRow = 0;
+
+  for (let col = 0; col < cols && curRow < rows; col++) {
+    let pivotRow = -1;
+    for (let r = curRow; r < rows; r++) {
+      if (matrix[r][col] !== 0) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    if (pivotRow !== curRow) {
+      [matrix[curRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[curRow]];
+    }
+
+    const inv = modInverse(matrix[curRow][col], p);
+    for (let k = col; k <= cols; k++) {
+      matrix[curRow][k] = (matrix[curRow][k] * inv) % p;
+    }
+
+    for (let r = 0; r < rows; r++) {
+      if (r === curRow || matrix[r][col] === 0) continue;
+      const factor = matrix[r][col];
+      for (let k = col; k <= cols; k++) {
+        matrix[r][k] = modPos(matrix[r][k] - factor * matrix[curRow][k], p);
+      }
+    }
+
+    pivotCol.push(col);
+    curRow++;
+  }
+
+  const rank = curRow;
+
+  for (let r = rank; r < rows; r++) {
+    if (matrix[r][cols] !== 0) return null;
+  }
+
+  const pivotColSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < cols; j++) {
+    if (!pivotColSet.has(j)) freeVars.push(j);
+  }
+
+  if (freeVars.length === 0) {
+    const solution = new Array(cols).fill(0);
+    for (let i = 0; i < rank; i++) {
+      solution[pivotCol[i]] = matrix[i][cols];
+    }
+    return solution;
+  }
+
+  const pivotInfoArr: PivotInfo[] = [];
+  for (let i = 0; i < rank; i++) {
+    const coeffs = new Array<number>(freeVars.length);
+    for (let fi = 0; fi < freeVars.length; fi++) {
+      coeffs[fi] = matrix[i][freeVars[fi]];
+    }
+    pivotInfoArr.push({ constant: matrix[i][cols], coeffs });
+  }
+
+  const numFree = freeVars.length;
+
+  function computeSolution(freeValues: number[]): number[] {
+    const sol = new Array(cols).fill(0);
+    for (let fi = 0; fi < numFree; fi++) {
+      sol[freeVars[fi]] = freeValues[fi];
+    }
+    for (let i = 0; i < rank; i++) {
+      let val = pivotInfoArr[i].constant;
+      for (let fi = 0; fi < numFree; fi++) {
+        val -= pivotInfoArr[i].coeffs[fi] * freeValues[fi];
+      }
+      sol[pivotCol[i]] = modPos(val, p);
+    }
+    return sol;
+  }
+
+  function solSum(sol: number[]): number {
+    let s = 0;
+    for (let i = 0; i < sol.length; i++) s += sol[i];
+    return s;
+  }
+
+  function isBetter(sol: number[], solSum: number, bestSol: number[], bestSum: number): boolean {
+    if (solSum < bestSum) return true;
+    if (solSum === bestSum && cmp(sol, bestSol) < 0) return true;
+    return false;
+  }
+
+  let totalCombinations = 1;
+  let feasible = true;
+  for (let i = 0; i < numFree; i++) {
+    totalCombinations *= p;
+    if (totalCombinations > 10_000_000) {
+      feasible = false;
+      break;
+    }
+  }
+
+  if (feasible) {
+    return enumerateAll(totalCombinations);
+  }
+
+  return coordinateDescent();
+
+  function enumerateAll(total: number): number[] | null {
+    let bestSol: number[] | null = null;
+    let bestSum = Infinity;
+    const fv = new Array(numFree).fill(0);
+
+    for (let iter = 0; iter < total; iter++) {
+      const sol = computeSolution(fv);
+      const sum = solSum(sol);
+      if (bestSol === null || isBetter(sol, sum, bestSol, bestSum)) {
+        bestSum = sum;
+        bestSol = sol.slice();
+      }
+
+      let carry = 1;
+      for (let fi = numFree - 1; fi >= 0 && carry; fi--) {
+        fv[fi] += carry;
+        if (fv[fi] >= p) {
+          fv[fi] = 0;
+        } else {
+          carry = 0;
+        }
+      }
+    }
+
+    return bestSol;
+  }
+
+  function coordinateDescent(): number[] {
+    const fv = new Array(numFree).fill(0);
+    let bestSol = computeSolution(fv);
+    let bestSum = solSum(bestSol);
+
+    for (let fi = 0; fi < numFree; fi++) {
+      let bestVal = 0;
+      for (let v = 1; v < p; v++) {
+        fv[fi] = v;
+        const sol = computeSolution(fv);
+        const sum = solSum(sol);
+        if (isBetter(sol, sum, bestSol, bestSum)) {
+          bestSum = sum;
+          bestSol = sol.slice();
+          bestVal = v;
+        }
+      }
+      fv[fi] = bestVal;
+    }
+
+    let improved = true;
+    while (improved) {
+      improved = false;
+      for (let fi = 0; fi < numFree; fi++) {
+        const origVal = fv[fi];
+        let bestVal = origVal;
+
+        for (let v = 0; v < p; v++) {
+          if (v === origVal) continue;
+          fv[fi] = v;
+          const sol = computeSolution(fv);
+          const sum = solSum(sol);
+          if (isBetter(sol, sum, bestSol, bestSum)) {
+            bestSum = sum;
+            bestSol = sol.slice();
+            bestVal = v;
+          }
+        }
+
+        fv[fi] = bestVal;
+        if (bestVal !== origVal) improved = true;
+      }
+    }
+
+    return bestSol;
+  }
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  const targetNum = target.map(t => t ? 1 : 0);
+
+  const buttonEffects: number[][] = [];
+  for (let b = 0; b < numButtons; b++) {
+    const effect = new Array(numLights).fill(0);
+    for (const lightIdx of buttons[b]) {
+      effect[lightIdx] = 1;
+    }
+    buttonEffects.push(effect);
+  }
+
+  const solution = solveLinearSystem(numLights, numButtons, buttonEffects, targetNum, 2, lexCmpSets);
+  if (solution === null) return null;
+
+  const result: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (solution[i] === 1) result.push(i);
+  }
+  return result;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+
+  const buttonEffects: number[][] = [];
+  for (let b = 0; b < numButtons; b++) {
+    const effect = new Array(numLights).fill(0);
+    for (const lightIdx of buttons[b]) {
+      effect[lightIdx] = 1;
+    }
+    buttonEffects.push(effect);
+  }
+
+  return solveLinearSystem(numLights, numButtons, buttonEffects, lights, modulus, lexCmpVec);
+}
