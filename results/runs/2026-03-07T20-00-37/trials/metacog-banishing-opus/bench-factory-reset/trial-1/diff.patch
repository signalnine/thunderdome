 Machine = {\n      target: [true, false],\n      buttons: [[0]]\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]);\n  });\n\n  it('should return empty array when target is all off', () => {\n    const machine: Machine = {\n      target: [false, false, false],\n      buttons: [[0, 1], [1, 2]]\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([]);\n  });\n\n  it('should find minimum set of buttons', () => {\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0], [1], [0, 1]]\n    };\n    const result = solveToggle(machine);\n    expect(result).not.toBeNull();\n    expect(result!.length).toBe(1);\n    expect(result).toEqual([2]);\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should handle overlapping buttons', () => {\n    const machine: Machine = {\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2]]\n    };\n    const result = solveToggle(machine);\n    expect(result).not.toBeNull();\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should return lex smallest for tied solutions', () => {\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0], [0]]\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle larger case', () => {\n    const machine: Machine = {\n      target: [true, true, true, true, true],\n      buttons: [[0, 1], [2, 3], [4], [0, 2, 4], [1, 3]]\n    };\n    const result = solveToggle(machine);\n    expect(result).not.toBeNull();\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should handle identity-like buttons (each toggles one light)', () => {\n    const machine: Machine = {\n      target: [true, false, true, false, true],\n      buttons: [[0], [1], [2], [3], [4]]\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0, 2, 4]);\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should handle no buttons', () => {\n    const machine: Machine = {\n      target: [true],\n      buttons: []\n    };\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('should handle no buttons with all-false target', () => {\n    const machine: Machine = {\n      target: [false, false],\n      buttons: []\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([]);\n  });\n\n  it('should handle button that toggles no lights', () => {\n    const machine: Machine = {\n      target: [true],\n      buttons: [[], [0]]\n    };\n    const result = solveToggle(machine);\n    expect(result).not.toBeNull();\n    expect(verifyToggle(machine, result!)).toBe(true);\n    expect(result).toEqual([1]);\n  });\n\n  it('should handle multiple free variables and pick minimum then lex smallest', () => {\n    // 3 identical buttons, target 1 light on\n    // Any one button solves it. Should pick button 0.\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0], [0], [0]]\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]);\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should handle 10 lights and 10 buttons', () => {\n    const n = 10;\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i]);\n    }\n    const target = new Array(n).fill(true);\n    const machine: Machine = { target, buttons };\n    const result = solveToggle(machine);\n    expect(result).not.toBeNull();\n    expect(result!.length).toBe(n);\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('should solve simple counter case', () => {\n    const result = solveCounter([1, 0], [[0]], 2);\n    expect(result).not.toBeNull();\n    expect(result).toEqual([1]);\n    expect(verifyCounter([1, 0], [[0]], 2, result!)).toBe(true);\n  });\n\n  it('should solve with modulus 3', () => {\n    const result = solveCounter([2], [[0]], 3);\n    expect(result).not.toBeNull();\n    expect(result).toEqual([2]);\n    expect(verifyCounter([2], [[0]], 3, result!)).toBe(true);\n  });\n\n  it('should return null for impossible counter case', () => {\n    const result = solveCounter([1], [], 2);\n    expect(result).toBeNull();\n  });\n\n  it('should minimize total presses', () => {\n    // Two buttons both affect light 0, mod 5\n    // (b0 + b1) mod 5 = 3. Solutions: (0,3),(1,2),(2,1),(3,0),(4,4)\n    // Min sum=3, lex smallest: (0,3)\n    const result = solveCounter([3], [[0], [0]], 5);\n    expect(result).not.toBeNull();\n    expect(verifyCounter([3], [[0], [0]], 5, result!)).toBe(true);\n    const sum = result!.reduce((a, b) => a + b, 0);\n    expect(sum).toBe(3);\n    expect(result).toEqual([0, 3]);\n  });\n\n  it('should handle multiple counters', () => {\n    const result = solveCounter([1, 1], [[0], [1]], 2);\n    expect(result).not.toBeNull();\n    expect(result).toEqual([1, 1]);\n    expect(verifyCounter([1, 1], [[0], [1]], 2, result!)).toBe(true);\n  });\n\n  it('should handle prime modulus', () => {\n    const result = solveCounter([3, 4], [[0, 1], [0]], 7);\n    expect(result).not.toBeNull();\n    expect(verifyCounter([3, 4], [[0, 1], [0]], 7, result!)).toBe(true);\n  });\n\n  it('should handle all-zero target', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);\n    expect(result).not.toBeNull();\n    expect(result).toEqual([0, 0]);\n    expect(verifyCounter([0, 0, 0], [[0, 1], [1, 2]], 5, result!)).toBe(true);\n  });\n\n  it('should handle modulus 97', () => {\n    const result = solveCounter([50], [[0]], 97);\n    expect(result).not.toBeNull();\n    expect(result).toEqual([50]);\n    expect(verifyCounter([50], [[0]], 97, result!)).toBe(true);\n  });\n\n  it('should handle impossible counter case with conflicting constraints', () => {\n    // Button 0 affects both light 0 and light 1.\n    // Want light 0 = 1, light 1 = 0 mod 2\n    // b0 = 1 (for light 0), b0 = 0 (for light 1) - impossible\n    const result = solveCounter([1, 0], [[0, 1]], 2);\n    expect(result).toBeNull();\n  });\n\n  it('should handle larger system with modulus 7', () => {\n    // 3 counters, 3 buttons, mod 7\n    // Button 0: affects counter 0\n    // Button 1: affects counter 1\n    // Button 2: affects counter 2\n    // Target: [3, 5, 6]\n    const result = solveCounter([3, 5, 6], [[0], [1], [2]], 7);\n    expect(result).toEqual([3, 5, 6]);\n    expect(verifyCounter([3, 5, 6], [[0], [1], [2]], 7, result!)).toBe(true);\n  });\n\n  it('should handle overlapping buttons with modular arithmetic', () => {\n    // 2 counters, 2 buttons, mod 3\n    // Button 0: affects counter 0, 1\n    // Button 1: affects counter 1\n    // Target: [1, 2]\n    // System: b0 = 1 mod 3, (b0 + b1) = 2 mod 3\n    // b0 = 1, b1 = 1\n    const result = solveCounter([1, 2], [[0, 1], [1]], 3);\n    expect(result).toEqual([1, 1]);\n    expect(verifyCounter([1, 2], [[0, 1], [1]], 3, result!)).toBe(true);\n  });\n});\n\ndescribe('performance', () => {\n  it('should handle 20x20 toggle in reasonable time', () => {\n    const n = 20;\n    const buttons: number[][] = [];\n    // Each button toggles itself and the next light (circular)\n    for (let i = 0; i < n; i++) {\n      buttons.push([i, (i + 1) % n]);\n    }\n    const target = new Array(n).fill(true);\n    const machine: Machine = { target, buttons };\n    const start = Date.now();\n    const result = solveToggle(machine);\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    if (result !== null) {\n      expect(verifyToggle(machine, result)).toBe(true);\n    }\n  });\n\n  it('should handle 40x40 unique toggle in reasonable time', () => {\n    const n = 40;\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i]);\n    }\n    const target = new Array(n).fill(true);\n    const machine: Machine = { target, buttons };\n    const start = Date.now();\n    const result = solveToggle(machine);\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).not.toBeNull();\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should handle 40x40 counter with mod 97 in reasonable time', () => {\n    const n = 40;\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i]);\n    }\n    const target = new Array(n).fill(0).map((_, i) => i % 97);\n    const start = Date.now();\n    const result = solveCounter(target, buttons, 97);\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).not.toBeNull();\n    expect(verifyCounter(target, buttons, 97, result!)).toBe(true);\n  });\n});\n","structuredPatch":[{"oldStart":17,"oldLines":10,"newStart":17,"newLines":8,"lines":[" function verifyCounter(target: number[], buttons: number[][], modulus: number, presses: number[]): boolean {","   const state = new Array(target.length).fill(0);","   for (let b = 0; b < buttons.length; b++) {","-    for (let press = 0; press < presses[b]; press++) {","-      for (const idx of buttons[b]) {","-        state[idx] = (state[idx] + 1) % modulus;","-      }","+    for (const idx of buttons[b]) {","+      state[idx] = (state[idx] + presses[b]) % modulus;","     }","   }","   for (let i = 0; i < target.length; i++) {"]},{"oldStart":79,"oldLines":8,"newStart":77,"newLines":6,"lines":["   });"," ","   it('should return lex smallest for tied solutions', () => {","-    // Two identical buttons - both achieve the same thing","-    // Should pick the lower-indexed one","     const machine: Machine = {","       target: [true],","       buttons: [[0], [0]]"]},{"oldStart":98,"oldLines":13,"newStart":94,"newLines":74,"lines":["     expect(result).not.toBeNull();","     expect(verifyToggle(machine, result!)).toBe(true);","   });","+","+  it('should handle identity-like buttons (each toggles one light)', () => {","+    