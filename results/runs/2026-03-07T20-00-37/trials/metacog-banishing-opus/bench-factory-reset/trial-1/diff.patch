ngth; i++) {\n    if (state[i] !== machine.target[i]) return false;\n  }\n  return true;\n}\n\nfunction verifyCounter(target: number[], buttons: number[][], modulus: number, presses: number[]): boolean {\n  const state = new Array(target.length).fill(0);\n  for (let b = 0; b < buttons.length; b++) {\n    for (let press = 0; press < presses[b]; press++) {\n      for (const idx of buttons[b]) {\n        state[idx] = (state[idx] + 1) % modulus;\n      }\n    }\n  }\n  for (let i = 0; i < target.length; i++) {\n    if (state[i] !== target[i]) return false;\n  }\n  return true;\n}\n\ndescribe('solveToggle', () => {\n  it('should return null for impossible case from task description', () => {\n    const machine: Machine = {\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]]\n    };\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('should solve simple case with one button', () => {\n    const machine: Machine = {\n      target: [true, false],\n      buttons: [[0]]\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]);\n  });\n\n  it('should return empty array when target is all off', () => {\n    const machine: Machine = {\n      target: [false, false, false],\n      buttons: [[0, 1], [1, 2]]\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([]);\n  });\n\n  it('should find minimum set of buttons', () => {\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0], [1], [0, 1]]\n    };\n    const result = solveToggle(machine);\n    expect(result).not.toBeNull();\n    expect(result!.length).toBe(1);\n    expect(result).toEqual([2]);\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should handle overlapping buttons', () => {\n    const machine: Machine = {\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2]]\n    };\n    const result = solveToggle(machine);\n    expect(result).not.toBeNull();\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should return lex smallest for tied solutions', () => {\n    // Two identical buttons - both achieve the same thing\n    // Should pick the lower-indexed one\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0], [0]]\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle larger case', () => {\n    const machine: Machine = {\n      target: [true, true, true, true, true],\n      buttons: [[0, 1], [2, 3], [4], [0, 2, 4], [1, 3]]\n    };\n    const result = solveToggle(machine);\n    expect(result).not.toBeNull();\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('should solve simple counter case', () => {\n    // One button that affects light 0. Target: light 0 = 1, light 1 = 0\n    // result[i] = number of times button i is pressed\n    // Only 1 button, so result has length 1\n    const result = solveCounter([1, 0], [[0]], 2);\n    expect(result).not.toBeNull();\n    expect(result).toEqual([1]);\n    expect(verifyCounter([1, 0], [[0]], 2, result!)).toBe(true);\n  });\n\n  it('should solve with modulus 3', () => {\n    const result = solveCounter([2], [[0]], 3);\n    expect(result).not.toBeNull();\n    expect(result).toEqual([2]);\n    expect(verifyCounter([2], [[0]], 3, result!)).toBe(true);\n  });\n\n  it('should return null for impossible counter case', () => {\n    // Two buttons both affect light 0. Target is 1 mod 2.\n    // Both buttons together: (b0 + b1) mod 2 = 1\n    // This is solvable: b0=1, b1=0 or b0=0, b1=1\n    // So let's create a truly impossible case:\n    // 1 light, 0 buttons, target is 1\n    const result = solveCounter([1], [], 2);\n    expect(result).toBeNull();\n  });\n\n  it('should minimize total presses', () => {\n    // Two buttons both toggle light 0, mod 5\n    // Target: light 0 = 3\n    // Solutions: (0,3), (1,2), (2,1), (3,0), (4,4)\n    // Min total: (2,1) and (1,2) and (3,0) all have sum 3\n    // (3,0) also has sum 3\n    // Wait: (b0+b1) mod 5 = 3\n    // (0,3)=3, (1,2)=3, (2,1)=3, (3,0)=3, (4,4)=8\n    // All of 0+3, 1+2, 2+1, 3+0 = 3. Lex smallest: (0,3)\n    const result = solveCounter([3], [[0], [0]], 5);\n    expect(result).not.toBeNull();\n    expect(verifyCounter([3], [[0], [0]], 5, result!)).toBe(true);\n    const sum = result!.reduce((a, b) => a + b, 0);\n    expect(sum).toBe(3);\n    expect(result).toEqual([0, 3]);\n  });\n\n  it('should handle multiple counters', () => {\n    const result = solveCounter([1, 1], [[0], [1]], 2);\n    expect(result).not.toBeNull();\n    expect(result).toEqual([1, 1]);\n    expect(verifyCounter([1, 1], [[0], [1]], 2, result!)).toBe(true);\n  });\n\n  it('should handle prime modulus', () => {\n    const result = solveCounter([3, 4], [[0, 1], [0]], 7);\n    expect(result).not.toBeNull();\n    expect(verifyCounter([3, 4], [[0, 1], [0]], 7, result!)).toBe(true);\n  });\n});\n"}}
