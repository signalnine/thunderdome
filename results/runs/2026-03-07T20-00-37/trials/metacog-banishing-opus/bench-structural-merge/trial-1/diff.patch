  return val !== null && typeof val === 'object' && !Array.isArray(val);\n}\n\nfunction deepEqual(a: unknown, b: unknown): boolean {\n  if (a === b) return true;\n  if (a === null || b === null) return a === b;\n  if (typeof a !== typeof b) return false;\n  if (Array.isArray(a) && Array.isArray(b)) {\n    if (a.length !== b.length) return false;\n    return a.every((v, i) => deepEqual(v, b[i]));\n  }\n  if (isObject(a) && isObject(b)) {\n    const keysA = Object.keys(a);\n    const keysB = Object.keys(b);\n    if (keysA.length !== keysB.length) return false;\n    return keysA.every(k => k in b && deepEqual(a[k], b[k]));\n  }\n  return false;\n}\n\n/**\n * Three-way merge of objects. Returns the merged result and any conflicts.\n * `base` is the common ancestor, `ours` is the current branch, `theirs` is the source branch.\n */\nfunction threeWayMerge(\n  base: Record<string, unknown>,\n  ours: Record<string, unknown>,\n  theirs: Record<string, unknown>,\n  docId: string,\n  pathPrefix: string,\n): { result: Record<string, unknown>; conflicts: Conflict[] } {\n  const conflicts: Conflict[] = [];\n  const result: Record<string, unknown> = deepClone(ours) as Record<string, unknown>;\n\n  const allKeys = new Set([\n    ...Object.keys(base),\n    ...Object.keys(ours),\n    ...Object.keys(theirs),\n  ]);\n\n  for (const key of allKeys) {\n    const baseVal = base[key];\n    const ourVal = ours[key];\n    const theirVal = theirs[key];\n    const currentPath = pathPrefix ? `${pathPrefix}.${key}` : key;\n\n    const oursChanged = !deepEqual(baseVal, ourVal);\n    const theirsChanged = !deepEqual(baseVal, theirVal);\n\n    if (!oursChanged && !theirsChanged) {\n      // No changes\n      continue;\n    }\n\n    if (oursChanged && !theirsChanged) {\n      // Only ours changed — keep ours (already in result)\n      continue;\n    }\n\n    if (!oursChanged && theirsChanged) {\n      // Only theirs changed — take theirs\n      if (theirVal === undefined) {\n        delete result[key];\n      } else {\n        result[key] = deepClone(theirVal);\n      }\n      continue;\n    }\n\n    // Both changed\n    if (deepEqual(ourVal, theirVal)) {\n      // Both changed to the same value — no conflict\n      continue;\n    }\n\n    // Both changed to different values — check if we can recurse into sub-objects\n    if (isObject(baseVal) && isObject(ourVal) && isObject(theirVal)) {\n      const sub = threeWayMerge(\n        baseVal as Record<string, unknown>,\n        ourVal as Record<string, unknown>,\n        theirVal as Record<string, unknown>,\n        docId,\n        currentPath,\n      );\n      result[key] = sub.result;\n      conflicts.push(...sub.conflicts);\n    } else {\n      // Leaf conflict — keep ours in result, record conflict\n      conflicts.push({\n        documentId: docId,\n        path: currentPath,\n        base: baseVal === undefined ? undefined : deepClone(baseVal),\n        ours: ourVal === undefined ? undefined : deepClone(ourVal),\n        theirs: theirVal === undefined ? undefined : deepClone(theirVal),\n      });\n      // result already has ours\n    }\n  }\n\n  return { result, conflicts };\n}\n\n// ---- DocumentStore ----\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      docs: new Map(),\n      ancestor: null,\n      parentBranch: null,\n    });\n  }\n\n  // ---- helpers ----\n\n  private getBranchData(name?: string): BranchData {\n    const branch = this.branches.get(name ?? this.currentBranch);\n    if (!branch) {\n      throw new Error(`Branch \"${name ?? this.currentBranch}\" does not exist`);\n    }\n    return branch;\n  }\n\n  // ---- Document CRUD ----\n\n  create(id: string, content: object): void {\n    const branch = this.getBranchData();\n    const existing = branch.docs.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" alrea