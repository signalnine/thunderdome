+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  // ---- CRUD ----
+
+  describe('CRUD operations', () => {
+    it('creates and gets a document', () => {
+      store.create('doc1', { name: 'Alice' });
+      expect(store.get('doc1')).toEqual({ name: 'Alice' });
+    });
+
+    it('throws when creating a duplicate document', () => {
+      store.create('doc1', { name: 'Alice' });
+      expect(() => store.create('doc1', { name: 'Bob' })).toThrow();
+    });
+
+    it('throws when getting a non-existent document', () => {
+      expect(() => store.get('missing')).toThrow();
+    });
+
+    it('updates a document', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.update('doc1', { name: 'Bob' });
+      expect(store.get('doc1')).toEqual({ name: 'Bob' });
+    });
+
+    it('throws when updating a non-existent document', () => {
+      expect(() => store.update('missing', { name: 'x' })).toThrow();
+    });
+
+    it('deletes a document', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('throws when deleting a non-existent document', () => {
+      expect(() => store.delete('missing')).toThrow();
+    });
+
+    it('throws when deleting an already deleted document', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.delete('doc1');
+      expect(() => store.delete('doc1')).toThrow();
+    });
+
+    it('deep clones on create and get', () => {
+      const content = { nested: { value: 1 } };
+      store.create('doc1', content);
+      content.nested.value = 999;
+      const retrieved = store.get('doc1') as { nested: { value: number } };
+      expect(retrieved.nested.value).toBe(1);
+      retrieved.nested.value = 999;
+      expect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);
+    });
+  });
+
+  // ---- Version history ----
+
+  describe('Version history', () => {
+    it('tracks versions on create and update', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      store.update('doc1', { v: 3 });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ v: 1 });
+      expect(history[1].content).toEqual({ v: 2 });
+      expect(history[2].content).toEqual({ v: 3 });
+    });
+
+    it('versions are in chronological order', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      const history = store.getHistory('doc1');
+      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);
+    });
+
+    it('each version has a unique id', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      const history = store.getHistory('doc1');
+      expect(history[0].id).not.toBe(history[1].id);
+    });
+
+    it('getVersion returns content at a specific version', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      const history = store.getHistory('doc1');
+      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });
+      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });
+    });
+
+    it('throws for non-existent version id', () => {
+      store.create('doc1', { v: 1 });
+      expect(() => store.getVersion('doc1', 'bogus')).toThrow();
+    });
+
+    it('throws for non-existent document', () => {
+      expect(() => store.getHistory('missing')).toThrow();
+    });
+  });
+
+  // ---- Branching ----
+
+  describe('Branching', () => {
+    it('default branch is main', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('creates and switches branches', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    it('lists branches', () => {
+      store.createBranch('feature');
+      expect(store.listBranches()).toContain('main');
+      expect(store.listBranches()).toContain('feature');
+    });
+
+    it('throws on duplicate branch name', () => {
+      store.createBranch('feature');
+      expect(() => store.createBranch('feature')).toThrow();
+    });
+
+    it('throws when switching to non-existent branch', () => {
+      expect(() => store.switchBranch('nope')).toThrow();
+    });
+
+    it('branches are isolated', () => {
+      store.create('doc1', { v: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { v: 2 });
+      expect(store.get('doc1')).toEqual({ v: 2 });
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ v: 1 });
+    });
+
+    it('branch from a specific branch', () => {
+      store.create('doc1', { v: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { v: 2 });
+      store.createBranch('feature2', 'feature');
+      store.switchBranch('feature2');
+      expect(store.get('doc1')).toEqual({ v: 2 });
+    });
+
+    it('new branch inherits existing documents', () => {
+      store.create('doc1', { v: 1 });
+      store.create('doc2', { v: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.get('doc1')).toEqual({ v: 1 });
+      expect(store.get('doc2')).toEqual({ v: 2 });
+    });
+  });
+
+  // ---- Merging ----
+
+  describe('Merging', () => {
+    it('merges non-conflicting changes from source into target', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, b: 3 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 1, b: 3 });
+      expect(store.get('doc1')).toEqual({ a: 1, b: 3 });
+    });
+
+    it('merges changes to different fields without conflict', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, b: 3 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 10, b: 2 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 3 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 3 });
+    });
+
+    it('detects conflicts when both branches change the same field differently', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 2 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 3 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0]).toEqual({
+        documentId: 'doc1',
+        path: 'a',
+        base: 1,
+        ours: 3,
+        theirs: 2,
+      });
+      // Current branch should be unchanged
+      expect(store.get('doc1')).toEqual({ a: 3 });
+    });
+
+    it('no conflict when both branches change same field to same value', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 42 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 42 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it('handles new documents on source branch', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { a: 1 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 1 });
+      expect(store.get('doc1')).toEqual({ a: 1 });
+    });
+
+    it('handles documents deleted on source branch', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.delete('doc1');
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged).not.toHaveProperty('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('multiple documents merge independently', () => {
+      store.create('doc1', { a: 1 });
+      store.create('doc2', { x: 10 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 2 });
+      store.update('doc2', { x: 20 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 2 });
+      expect(result.merged['doc2']).toEqual({ x: 20 });
+    });
+
+    it('deep nested merge without conflict', () => {
+      store.create('doc1', { a: { b: { c: 1, d: 2 } } });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: { b: { c: 99, d: 2 } } });
+      store.switchBranch('main');
+      store.update('doc1', { a: { b: { c: 1, d: 99 } } });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: { b: { c: 99, d: 99 } } });
+    });
+
+    it('deep nested conflict', () => {
+      store.create('doc1', { a: { b: { c: 1 } } });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: { b: { c: 2 } } });
+      store.switchBranch('main');
+      store.update('doc1', { a: { b: { c: 3 } } });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].path).toBe('a.b.c');
+    });
+
+    it('no-op merge when nothing changed', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it('merged field shows ours for conflicting fields', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 20 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 100, b: 200 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      // merged should show "ours" for conflicts
+      expect(result.merged['doc1']).toEqual({ a: 100, b: 200 });
+    });
+
+    it('merge does not apply when there are conflicts', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 2 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 3 });
+      store.merge('feature');
+      // main should still have a: 3
+      expect(store.get('doc1')).toEqual({ a: 3 });
+    });
+
+    it('handles new fields added on one side', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, b: 2 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 1, b: 2 });
+    });
+
+    it('handles fields removed on one side', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: 1 });
+    });
+  });
+});
diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..a39ef92
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,461 @@
+// ---- Interfaces ----
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+// ---- Internal types ----
+
+interface DocState {
+  content: object;
+  deleted: boolean;
+  versions: Version[];
+}
+
+interface BranchData {
+  docs: Map<string, DocState>;
+  /** Snapshot of all docs at the moment this branch was created (the merge base). */
+  ancestor: Map<string, DocState> | null;
+  /** Name of the branch this was forked from. */
+  parentBranch: string | null;
+}
+
+// ---- Helpers ----
+
+function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+let versionCounter = 0;
+function nextVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+function cloneDocState(state: DocState): DocState {
+  return {
+    content: deepClone(state.content),
+    deleted: state.deleted,
+    versions: state.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+  };
+}
+
+function cloneDocs(docs: Map<string, DocState>): Map<string, DocState> {
+  const result = new Map<string, DocState>();
+  for (const [id, state] of docs) {
+    result.set(id, cloneDocState(state));
+  }
+  return result;
+}
+
+// ---- Three-way merge logic ----
+
+function isObject(val: unknown): val is Record<string, unknown> {
+  return val !== null && typeof val === 'object' && !Array.isArray(val);
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return a === b;
+  if (typeof a !== typeof b) return false;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    return a.every((v, i) => deepEqual(v, b[i]));
+  }
+  if (isObject(a) && isObject(b)) {
+    const keysA = Object.keys(a);
+    const keysB = Object.keys(b);
+    if (keysA.length !== keysB.length) return false;
+    return keysA.every(k => k in b && deepEqual(a[k], b[k]));
+  }
+  return false;
+}
+
+/**
+ * Three-way merge of objects. Returns the merged result and any conflicts.
+ * `base` is the common ancestor, `ours` is the current branch, `theirs` is the source branch.
+ */
+function threeWayMerge(
+  base: Record<string, unknown>,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+  docId: string,
+  pathPrefix: string,
+): { result: Record<string, unknown>; conflicts: Conflict[] } {
+  const conflicts: Conflict[] = [];
+  const result: Record<string, unknown> = deepClone(ours) as Record<string, unknown>;
+
+  const allKeys = new Set([
+    ...Object.keys(base),
+    ...Object.keys(ours),
+    ...Object.keys(theirs),
+  ]);
+
+  for (const key of allKeys) {
+    const baseVal = base[key];
+    const ourVal = ours[key];
+    const theirVal = theirs[key];
+    const currentPath = pathPrefix ? `${pathPrefix}.${key}` : key;
+
+    const oursChanged = !deepEqual(baseVal, ourVal);
+    const theirsChanged = !deepEqual(baseVal, theirVal);
+
+    if (!oursChanged && !theirsChanged) {
+      // No changes
+      continue;
+    }
+
+    if (oursChanged && !theirsChanged) {
+      // Only ours changed — keep ours (already in result)
+      continue;
+    }
+
+    if (!oursChanged && theirsChanged) {
+      // Only theirs changed — take theirs
+      if (theirVal === undefined) {
+        delete result[key];
+      } else {
+        result[key] = deepClone(theirVal);
+      }
+      continue;
+    }
+
+    // Both changed
+    if (deepEqual(ourVal, theirVal)) {
+      // Both changed to the same value — no conflict
+      continue;
+    }
+
+    // Both changed to different values — check if we can recurse into sub-objects
+    if (isObject(baseVal) && isObject(ourVal) && isObject(theirVal)) {
+      const sub = threeWayMerge(
+        baseVal as Record<string, unknown>,
+        ourVal as Record<string, unknown>,
+        theirVal as Record<string, unknown>,
+        docId,
+        currentPath,
+      );
+      result[key] = sub.result;
+      conflicts.push(...sub.conflicts);
+    } else {
+      // Leaf conflict — keep ours in result, record conflict
+      conflicts.push({
+        documentId: docId,
+        path: currentPath,
+        base: baseVal === undefined ? undefined : deepClone(baseVal),
+        ours: ourVal === undefined ? undefined : deepClone(ourVal),
+        theirs: theirVal === undefined ? undefined : deepClone(theirVal),
+      });
+      // result already has ours
+    }
+  }
+
+  return { result, conflicts };
+}
+
+// ---- DocumentStore ----
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      docs: new Map(),
+      ancestor: null,
+      parentBranch: null,
+    });
+  }
+
+  // ---- helpers ----
+
+  private getBranchData(name?: string): BranchData {
+    const branch = this.branches.get(name ?? this.currentBranch);
+    if (!branch) {
+      throw new Error(`Branch "${name ?? this.currentBranch}" does not exist`);
+    }
+    return branch;
+  }
+
+  // ---- Document CRUD ----
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const existing = branch.docs.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const version: Version = {
+      id: nextVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    branch.docs.set(id, {
+      content: deepClone(content),
+      deleted: false,
+      versions: existing ? [...existing.versions, version] : [version],
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const doc = branch.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version: Version = {
+      id: nextVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    doc.content = deepClone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getBranchData();
+    const doc = branch.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    doc.deleted = true;
+  }
+
+  // ---- Version history ----
+
+  getHistory(id: string): Version[] {
+    const branch = this.getBranchData();
+    const doc = branch.docs.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.docs.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // ---- Branching ----
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.getBranchData(sourceName);
+    this.branches.set(name, {
+      docs: cloneDocs(source.docs),
+      ancestor: cloneDocs(source.docs),
+      parentBranch: sourceName,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // ---- Merging ----
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceBranchData = this.getBranchData(sourceBranch);
+    const targetBranchData = this.getBranchData();
+
+    // The ancestor is the snapshot from when the source branch was created.
+    // If the source branch has no ancestor (e.g. merging main into a feature),
+    // we need to find the common ancestor.
+    const ancestor = sourceBranchData.ancestor;
+    if (!ancestor) {
+      throw new Error(`Cannot determine merge base for branch "${sourceBranch}"`);
+    }
+
+    const allDocIds = new Set<string>();
+    for (const id of ancestor.keys()) allDocIds.add(id);
+    for (const id of sourceBranchData.docs.keys()) allDocIds.add(id);
+    for (const id of targetBranchData.docs.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+    let hasChanges = false;
+
+    for (const docId of allDocIds) {
+      const baseDoc = ancestor.get(docId);
+      const ourDoc = targetBranchData.docs.get(docId);
+      const theirDoc = sourceBranchData.docs.get(docId);
+
+      const baseContent = baseDoc && !baseDoc.deleted ? baseDoc.content : undefined;
+      const ourContent = ourDoc && !ourDoc.deleted ? ourDoc.content : undefined;
+      const theirContent = theirDoc && !theirDoc.deleted ? theirDoc.content : undefined;
+
+      const oursChanged = !deepEqual(baseContent, ourContent);
+      const theirsChanged = !deepEqual(baseContent, theirContent);
+
+      if (!oursChanged && !theirsChanged) {
+        // No changes to this doc — keep as-is on our branch
+        if (ourContent !== undefined) {
+          merged[docId] = deepClone(ourContent);
+        }
+        continue;
+      }
+
+      hasChanges = true;
+
+      if (oursChanged && !theirsChanged) {
+        // Only our side changed
+        if (ourContent !== undefined) {
+          merged[docId] = deepClone(ourContent);
+        }
+        // If we deleted it, just don't include in merged
+        continue;
+      }
+
+      if (!oursChanged && theirsChanged) {
+        // Only their side changed — take theirs
+        if (theirContent !== undefined) {
+          merged[docId] = deepClone(theirContent);
+        }
+        // If they deleted it, don't include in merged
+        continue;
+      }
+
+      // Both sides changed this document
+      if (deepEqual(ourContent, theirContent)) {
+        // Same change — no conflict
+        if (ourContent !== undefined) {
+          merged[docId] = deepClone(ourContent);
+        }
+        continue;
+      }
+
+      // Handle document-level create/delete conflicts
+      if (ourContent === undefined || theirContent === undefined) {
+        // One side deleted, the other modified — conflict at document level
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: baseContent === undefined ? undefined : deepClone(baseContent),
+          ours: ourContent === undefined ? undefined : deepClone(ourContent),
+          theirs: theirContent === undefined ? undefined : deepClone(theirContent),
+        });
+        // In "ours wins" resolution, keep ours
+        if (ourContent !== undefined) {
+          merged[docId] = deepClone(ourContent);
+        }
+        continue;
+      }
+
+      // Both sides have content — do field-level three-way merge
+      const base = (baseContent ?? {}) as Record<string, unknown>;
+      const ours = ourContent as Record<string, unknown>;
+      const theirs = theirContent as Record<string, unknown>;
+
+      const { result, conflicts } = threeWayMerge(base, ours, theirs, docId, '');
+      merged[docId] = result;
+      allConflicts.push(...conflicts);
+    }
+
+    if (!hasChanges) {
+      // Fast-forward / no-op
+      return { merged, conflicts: [], applied: true };
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge to the current branch
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const existingDoc = targetBranchData.docs.get(docId);
+          const mergedContent = merged[docId];
+          if (existingDoc && !existingDoc.deleted) {
+            // Update existing doc if content changed
+            if (!deepEqual(existingDoc.content, mergedContent)) {
+              const version: Version = {
+                id: nextVersionId(),
+                timestamp: Date.now(),
+                content: deepClone(mergedContent),
+              };
+              existingDoc.content = deepClone(mergedContent);
+              existingDoc.versions.push(version);
+            }
+          } else {
+            // Document was created on source branch or was deleted on target
+            const version: Version = {
+              id: nextVersionId(),
+              timestamp: Date.now(),
+              content: deepClone(mergedContent),
+            };
+            targetBranchData.docs.set(docId, {
+              content: deepClone(mergedContent),
+              deleted: false,
+              versions: existingDoc ? [...existingDoc.versions, version] : [version],
+            });
+          }
+        } else {
+          // Document was deleted (not in merged but existed)
+          const existingDoc = targetBranchData.docs.get(docId);
+          if (existingDoc && !existingDoc.deleted) {
+            existingDoc.deleted = true;
+          }
+        }
+      }
+
+      // Update the ancestor snapshot for future merges from the same branch
+      sourceBranchData.ancestor = cloneDocs(targetBranchData.docs);
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+}
