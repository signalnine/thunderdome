ted: { value: 1 } };\n      store.create('doc1', content);\n      content.nested.value = 999;\n      const retrieved = store.get('doc1') as { nested: { value: number } };\n      expect(retrieved.nested.value).toBe(1);\n      retrieved.nested.value = 999;\n      expect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);\n    });\n  });\n\n  // ---- Version history ----\n\n  describe('Version history', () => {\n    it('tracks versions on create and update', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ v: 1 });\n      expect(history[1].content).toEqual({ v: 2 });\n      expect(history[2].content).toEqual({ v: 3 });\n    });\n\n    it('versions are in chronological order', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);\n    });\n\n    it('each version has a unique id', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(history[0].id).not.toBe(history[1].id);\n    });\n\n    it('getVersion returns content at a specific version', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      const history = store.getHistory('doc1');\n      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });\n      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });\n    });\n\n    it('throws for non-existent version id', () => {\n      store.create('doc1', { v: 1 });\n      expect(() => store.getVersion('doc1', 'bogus')).toThrow();\n    });\n\n    it('throws for non-existent document', () => {\n      expect(() => store.getHistory('missing')).toThrow();\n    });\n  });\n\n  // ---- Branching ----\n\n  describe('Branching', () => {\n    it('default branch is main', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('creates and switches branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    it('lists branches', () => {\n      store.createBranch('feature');\n      expect(store.listBranches()).toContain('main');\n      expect(store.listBranches()).toContain('feature');\n    });\n\n    it('throws on duplicate branch name', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('throws when switching to non-existent branch', () => {\n      expect(() => store.switchBranch('nope')).toThrow();\n    });\n\n    it('branches are isolated', () => {\n      store.create('doc1', { v: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { v: 2 });\n      expect(store.get('doc1')).toEqual({ v: 2 });\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ v: 1 });\n    });\n\n    it('branch from a specific branch', () => {\n      store.create('doc1', { v: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { v: 2 });\n      store.createBranch('feature2', 'feature');\n      store.switchBranch('feature2');\n      expect(store.get('doc1')).toEqual({ v: 2 });\n    });\n\n    it('new branch inherits existing documents', () => {\n      store.create('doc1', { v: 1 });\n      store.create('doc2', { v: 2 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.get('doc1')).toEqual({ v: 1 });\n      expect(store.get('doc2')).toEqual({ v: 2 });\n    });\n  });\n\n  // ---- Merging ----\n\n  describe('Merging', () => {\n    it('merges non-conflicting changes from source into target', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 3 });\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 1, b: 3 });\n      expect(store.get('doc1')).toEqual({ a: 1, b: 3 });\n    });\n\n    it('merges changes to different fields without conflict', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 3 });\n      store.switchBranch('main');\n      store.update('doc1', { a: 10, b: 2 });\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 3 });\n      expect(store.get('doc1')).toEqual({ a: 10, b: 3 });\n    });\n\n    it('detects conflicts when both branches change the same field differently', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: 2 });\n      store.switchBranch('main');\n      store.update('doc1', { a: 3 });\n      const result = store.merge('feature');\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'a',\n        base: 1,\n        ours: 3,\n        theirs: 2,\n      });\n      // Current branch should be unchanged\n      expect(store.get('doc1')).toEqual({ a: 3 });\n    });\n\n    it('no conflict when both branches change same field to same value', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: 42 });\n      store.switchBranch('main');\n      store.update('doc1', { a: 42 });\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n    });\n\n    it('handles new documents on source branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { a: 1 });\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: 1 });\n      expect(store.get('doc1')).toEqual({ a: 1 });\n    });\n\n    it('handles documents deleted on source branch', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.delete('doc1');\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.merged).not.toHaveProperty('doc1');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('multiple documents merge independently', () => {\n      store.create('doc1', { a: 1 });\n      store.create('doc2', { x: 10 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: 2 });\n      store.update('doc2', { x: 20 });\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: 2 });\n      expect(result.merged['doc2']).toEqual({ x: 20 });\n    });\n\n    it('deep nested merge without conflict', () => {\n      store.create('doc1', { a: { b: { c: 1, d: 2 } } });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: { b: { c: 99, d: 2 } } });\n      store.switchBranch('main');\n      store.update('doc1', { a: { b: { c: 1, d: 99 } } });\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: { b: { c: 99, d: 99 } } });\n    });\n\n    it('deep nested conflict', () => {\n      store.create('doc1', { a: { b: { c: 1 } } });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: { b: { c: 2 } } });\n      store.switchBranch('main');\n      store.update('doc1', { a: { b: { c: 3 } } });\n      const result = store.merge('feature');\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('a.b.c');\n    });\n\n    it('no-op merge when nothing changed', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n    });\n\n    it('merged field shows ours for conflicting fields', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: 10, b: 20 });\n      store.switchBranch('main');\n      store.update('doc1', { a: 100, b: 200 });\n      const result = store.merge('feature');\n      expect(result.applied).toBe(false);\n      // merged should show \"ours\" for conflicts\n      expect(result.merged['doc1']).toEqual({ a: 100, b: 200 });\n    });\n\n    it('merge does not apply when there are conflicts', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: 2 });\n      store.switchBranch('main');\n      store.update('doc1', { a: 3 });\n      store.merge('feature');\n      // main should still have a: 3\n      expect(store.get('doc1')).toEqual({ a: 3 });\n    });\n\n    it('handles new fields added on one side', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 2 });\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: 1, b: 2 });\n    });\n\n    it('handles fields removed on one side', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1 });\n      store.switchBranch('main');\n      const result = store.merge('feature');\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: 1 });\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":257,"cache_read_input_tokens":28553,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":257},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3025fff2-fa2e-42bd-9523-9f76bce741f8","uuid":"b63481a8-47bf-4fcb-bb60-0092281e5315"}
