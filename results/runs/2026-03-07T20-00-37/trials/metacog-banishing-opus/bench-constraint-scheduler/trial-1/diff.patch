ult.assignments[0].eventId).toBe('e1');\n    expect(result.assignments[0].startTime).toBe(540);\n    expect(result.assignments[0].endTime).toBe(600);\n  });\n\n  it('returns empty for no events', () => {\n    const result = schedule([], rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toHaveLength(0);\n  });\n\n  it('puts all events in unscheduled when no rooms', () => {\n    const events = [{ id: 'e1', name: 'Event 1', duration: 60 }];\n    const result = schedule(events, [], defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toEqual(['e1']);\n  });\n\n  it('respects room capacity', () => {\n    const events = [{ id: 'e1', name: 'Big Event', duration: 60, attendees: 15 }];\n    const smallRooms = [{ id: 'r1', name: 'Small', capacity: 10 }];\n    const result = schedule(events, smallRooms, defaultOptions);\n    expect(result.unscheduled).toEqual(['e1']);\n  });\n\n  it('respects capacity - places in room with enough capacity', () => {\n    const events = [{ id: 'e1', name: 'Big Event', duration: 60, attendees: 15 }];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n    expect(result.assignments[0].roomId).toBe('r2'); // only r2 has capacity 20\n  });\n\n  it('respects prerequisite ordering', () => {\n    const events = [\n      { id: 'e1', name: 'First', duration: 60 },\n      { id: 'e2', name: 'Second', duration: 60, prerequisites: ['e1'] },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(2);\n    const a1 = result.assignments.find((a) => a.eventId === 'e1')!;\n    const a2 = result.assignments.find((a) => a.eventId === 'e2')!;\n    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15); // default gap\n  });\n\n  it('respects room gaps', () => {\n    const events = [\n      { id: 'e1', name: 'First', duration: 60 },\n      { id: 'e