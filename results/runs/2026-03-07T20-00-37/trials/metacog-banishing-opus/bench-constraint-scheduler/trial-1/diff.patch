    ];\n    expect(() => schedule(events, rooms, defaultOptions)).toThrow(/cycle/i);\n  });\n\n  it('respects preferred room when possible', () => {\n    const events = [\n      { id: 'e1', name: 'Preferred', duration: 60, preferredRoom: 'r2' },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments[0].roomId).toBe('r2');\n  });\n\n  it('uses custom gap', () => {\n    const events = [\n      { id: 'e1', name: 'First', duration: 60 },\n      { id: 'e2', name: 'Second', duration: 60 },\n    ];\n    const oneRoom = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    const result = schedule(events, oneRoom, { ...defaultOptions, gap: 30 });\n    expect(result.assignments).toHaveLength(2);\n    const a1 = result.assignments.find((a) => a.eventId === 'e1')!;\n    const a2 = result.assignments.find((a) => a.eventId === 'e2')!;\n    const [first, second] =\n      a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n    expect(second.startTime).toBeGreaterThanOrEqual(first.endTime + 30);\n  });\n\n  it('handles events that do not fit in time window', () => {\n    const events = [{ id: 'e1', name: 'Too Long', duration: 600 }];\n    // Window is 540-1020 = 480 min, event is 600 min\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.unscheduled).toEqual(['e1']);\n  });\n\n  it('marks events unscheduled when prerequisites are unschedulable', () => {\n    const smallRoom = [{ id: 'r1', name: 'Small', capacity: 5 }];\n    const events = [\n      { id: 'e1', name: 'Too Big', duration: 60, attendees: 10 },\n      { id: 'e2', name: 'Depends', duration: 30, prerequisites: ['e1'] },\n    ];\n    const result = schedule(events, smallRoom, defaultOptions);\n    expect(result.unscheduled).toContain('e1');\n    expect(result.unscheduled).toContain('e2');\n  });\n\n  it('schedules multiple events across multiple rooms', () => {\n    const events = [\n      { id: 'e1', name: 'A', duration: 60 },\n      { id: 'e2', name: 'B', duration: 60 },\n      { id: 'e3', name: 'C', duration: 60 },\n      { id: 'e4', name: 'D', duration: 60 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(4);\n    expect(result.unscheduled).toHaveLength(0);\n  });\n\n  it('handles gap of 0', () => {\n    const events = [\n      { id: 'e1', name: 'First', duration: 60 },\n      { id: 'e2', name: 'Second', duration: 60 },\n    ];\n    const oneRoom = [{ id: 'r1', name: 'Room 1', capacity: 10 }];\n    const result = schedule(events, oneRoom, { ...defaultOptions, gap: 0 });\n    expect(result.assignments).toHaveLength(2);\n    const a1 = result.assignments.find((a) => a.eventId === 'e1')!;\n    const a2 = result.assignments.find((a) => a.eventId === 'e2')!;\n    const [first, second] =\n      a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n    expect(second.startTime).toBeGreaterThanOrEqual(first.endTime);\n  });\n\n  it('prerequisite gap applies even across rooms', () => {\n    const events = [\n      { id: 'e1', name: 'First', duration: 60, preferredRoom: 'r1' },\n      { id: 'e2', name: 'Second', duration: 60, prerequisites: ['e1'], preferredRoom: 'r2' },\n    ];\n    const result = schedule(events, rooms, { ...defaultOptions, gap: 30 });\n    expect(result.assignments).toHaveLength(2);\n    const a1 = result.assignments.find((a) => a.eventId === 'e1')!;\n    const a2 = result.assignments.find((a) => a.eventId === 'e2')!;\n    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 30);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
