diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..427933d
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,508 @@
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+/**
+ * Detect cycles in the prerequisite graph via DFS.
+ * Throws an error if a cycle is found.
+ * Returns a topological ordering of event IDs.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // States: 0 = unvisited, 1 = in-progress, 2 = done
+  const state = new Map<string, number>();
+  for (const e of events) {
+    state.set(e.id, 0);
+  }
+
+  const order: string[] = [];
+
+  function dfs(id: string, path: string[]): void {
+    const s = state.get(id);
+    if (s === 2) return;
+    if (s === 1) {
+      throw new Error(
+        `Prerequisite cycle detected: ${[...path, id].join(' -> ')}`
+      );
+    }
+
+    state.set(id, 1);
+    const ev = eventMap.get(id);
+    if (ev?.prerequisites) {
+      for (const prereqId of ev.prerequisites) {
+        // Self-reference is a cycle
+        if (prereqId === id) {
+          throw new Error(
+            `Prerequisite cycle detected: ${id} -> ${id}`
+          );
+        }
+        // Prereq referencing unknown event: skip (it won't be scheduled anyway)
+        if (!eventMap.has(prereqId)) {
+          continue;
+        }
+        dfs(prereqId, [...path, id]);
+      }
+    }
+
+    state.set(id, 2);
+    order.push(id);
+  }
+
+  for (const e of events) {
+    if (state.get(e.id) === 0) {
+      dfs(e.id, []);
+    }
+  }
+
+  return order;
+}
+
+/**
+ * Get the earliest possible start time for an event given prerequisite constraints.
+ */
+function getEarliestStartAfterPrereqs(
+  event: Event,
+  assignments: Map<string, Assignment>,
+  gap: number
+): number {
+  let earliest = 0;
+  if (event.prerequisites) {
+    for (const prereqId of event.prerequisites) {
+      const prereqAssignment = assignments.get(prereqId);
+      if (prereqAssignment) {
+        earliest = Math.max(earliest, prereqAssignment.endTime + gap);
+      }
+    }
+  }
+  return earliest;
+}
+
+/**
+ * Get the list of rooms that can fit this event's attendees, with preferred room first.
+ */
+function getEligibleRooms(event: Event, rooms: Room[]): Room[] {
+  const attendees = event.attendees ?? 1;
+  const eligible = rooms.filter((r) => r.capacity >= attendees);
+
+  if (event.preferredRoom) {
+    const prefIdx = eligible.findIndex((r) => r.id === event.preferredRoom);
+    if (prefIdx > 0) {
+      const [preferred] = eligible.splice(prefIdx, 1);
+      eligible.unshift(preferred);
+    }
+  }
+
+  return eligible;
+}
+
+/**
+ * Find the earliest available slot in a room that starts at or after `earliestStart`
+ * and fits the event duration, respecting the gap and end time constraints.
+ */
+function findEarliestSlot(
+  roomId: string,
+  duration: number,
+  earliestStart: number,
+  endTime: number,
+  gap: number,
+  roomAssignments: Assignment[]
+): number | null {
+  // Sort room assignments by start time
+  const sorted = [...roomAssignments].sort((a, b) => a.startTime - b.startTime);
+
+  // Try to fit before the first assignment or in gaps between assignments
+  let candidateStart = earliestStart;
+
+  for (const existing of sorted) {
+    // If we can fit before this existing assignment
+    if (candidateStart + duration <= existing.startTime - gap) {
+      // But we also need candidateStart + duration <= endTime
+      if (candidateStart + duration <= endTime) {
+        return candidateStart;
+      }
+    }
+    // Move candidate past this existing assignment (with gap)
+    if (candidateStart < existing.endTime + gap) {
+      candidateStart = existing.endTime + gap;
+    }
+  }
+
+  // Try after all existing assignments
+  if (candidateStart + duration <= endTime) {
+    return candidateStart;
+  }
+
+  return null;
+}
+
+/**
+ * Try to place an event, returning the best assignment or null.
+ */
+function tryPlace(
+  event: Event,
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number,
+  currentAssignments: Map<string, Assignment>,
+  roomSchedules: Map<string, Assignment[]>
+): Assignment | null {
+  const earliestPrereq = getEarliestStartAfterPrereqs(event, currentAssignments, gap);
+  const earliestStart = Math.max(options.startTime, earliestPrereq);
+
+  // Check if all prerequisites have been scheduled
+  if (event.prerequisites) {
+    for (const prereqId of event.prerequisites) {
+      // If a prerequisite exists in the event list but wasn't scheduled, we can't schedule this either
+      if (!currentAssignments.has(prereqId)) {
+        // But only if the prereq is a real event in our set
+        // (unknown prereqs we just ignore at the topo-sort level, but here we need to be careful)
+        return null;
+      }
+    }
+  }
+
+  const eligibleRooms = getEligibleRooms(event, rooms);
+  if (eligibleRooms.length === 0) return null;
+
+  let bestAssignment: Assignment | null = null;
+
+  for (const room of eligibleRooms) {
+    const roomAssigns = roomSchedules.get(room.id) ?? [];
+    const slotStart = findEarliestSlot(
+      room.id,
+      event.duration,
+      earliestStart,
+      options.endTime,
+      gap,
+      roomAssigns
+    );
+
+    if (slotStart !== null) {
+      const assignment: Assignment = {
+        eventId: event.id,
+        roomId: room.id,
+        startTime: slotStart,
+        endTime: slotStart + event.duration,
+      };
+
+      // Prefer the earliest start time, and prefer the preferred room on ties
+      if (
+        !bestAssignment ||
+        slotStart < bestAssignment.startTime ||
+        (slotStart === bestAssignment.startTime &&
+          room.id === event.preferredRoom)
+      ) {
+        bestAssignment = assignment;
+      }
+    }
+  }
+
+  return bestAssignment;
+}
+
+/**
+ * Place an assignment into the tracking structures.
+ */
+function placeAssignment(
+  assignment: Assignment,
+  currentAssignments: Map<string, Assignment>,
+  roomSchedules: Map<string, Assignment[]>
+): void {
+  currentAssignments.set(assignment.eventId, assignment);
+  const ra = roomSchedules.get(assignment.roomId) ?? [];
+  ra.push(assignment);
+  roomSchedules.set(assignment.roomId, ra);
+}
+
+/**
+ * Remove an assignment from the tracking structures.
+ */
+function removeAssignment(
+  eventId: string,
+  currentAssignments: Map<string, Assignment>,
+  roomSchedules: Map<string, Assignment[]>
+): void {
+  const assignment = currentAssignments.get(eventId);
+  if (!assignment) return;
+  currentAssignments.delete(eventId);
+  const ra = roomSchedules.get(assignment.roomId);
+  if (ra) {
+    const idx = ra.findIndex((a) => a.eventId === eventId);
+    if (idx >= 0) ra.splice(idx, 1);
+  }
+}
+
+/**
+ * Compute how constrained an event is (fewer eligible rooms = more constrained).
+ * More constrained events should be scheduled first.
+ */
+function computeConstraintScore(event: Event, rooms: Room[]): number {
+  const attendees = event.attendees ?? 1;
+  const eligibleCount = rooms.filter((r) => r.capacity >= attendees).length;
+  const prereqCount = event.prerequisites?.length ?? 0;
+  // Lower score = more constrained = should be scheduled earlier
+  return eligibleCount * 1000 - prereqCount * 100 - event.duration;
+}
+
+/**
+ * Schedule events using backtracking to maximize the number of placed events.
+ */
+function scheduleWithBacktracking(
+  events: Event[],
+  topoOrder: string[],
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number,
+  knownEventIds: Set<string>
+): { assignments: Map<string, Assignment>; roomSchedules: Map<string, Assignment[]> } {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Build dependency graph: for each event, which events depend on it
+  const dependents = new Map<string, Set<string>>();
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const prereqId of e.prerequisites) {
+        if (!dependents.has(prereqId)) {
+          dependents.set(prereqId, new Set());
+        }
+        dependents.get(prereqId)!.add(e.id);
+      }
+    }
+  }
+
+  // Sort events within topo order levels by constraint score
+  // First, compute topo-level for each event
+  const topoIndex = new Map<string, number>();
+  for (let i = 0; i < topoOrder.length; i++) {
+    topoIndex.set(topoOrder[i], i);
+  }
+
+  // Sort by: topo order first, then most constrained
+  const sortedEvents = [...topoOrder].sort((a, b) => {
+    const idxA = topoIndex.get(a)!;
+    const idxB = topoIndex.get(b)!;
+    if (idxA !== idxB) return idxA - idxB;
+    const evA = eventMap.get(a)!;
+    const evB = eventMap.get(b)!;
+    return computeConstraintScore(evA, rooms) - computeConstraintScore(evB, rooms);
+  });
+
+  // Filter to only events whose prerequisites are all known events
+  const schedulableEvents = sortedEvents.filter((id) => {
+    const ev = eventMap.get(id)!;
+    if (!ev.prerequisites) return true;
+    return ev.prerequisites.every((prereqId) => knownEventIds.has(prereqId));
+  });
+
+  const currentAssignments = new Map<string, Assignment>();
+  const roomSchedules = new Map<string, Assignment[]>();
+  for (const room of rooms) {
+    roomSchedules.set(room.id, []);
+  }
+
+  // Greedy pass: try to schedule each event
+  const failed: string[] = [];
+  for (const eventId of schedulableEvents) {
+    const event = eventMap.get(eventId)!;
+    const assignment = tryPlace(event, rooms, options, gap, currentAssignments, roomSchedules);
+    if (assignment) {
+      placeAssignment(assignment, currentAssignments, roomSchedules);
+    } else {
+      failed.push(eventId);
+    }
+  }
+
+  // Improvement phase: try removing placed events to fit more failed events (net gain).
+  // This handles cases where one long event blocks multiple shorter events.
+  if (failed.length > 0) {
+    let improved = true;
+    const maxIterations = events.length * events.length; // prevent infinite loops
+    let iteration = 0;
+
+    while (improved && iteration < maxIterations) {
+      improved = false;
+      iteration++;
+
+      // First pass: try to directly place any failed events (maybe prior changes opened slots)
+      for (let i = failed.length - 1; i >= 0; i--) {
+        const failedId = failed[i];
+        const failedEvent = eventMap.get(failedId)!;
+
+        // Check prerequisites
+        if (failedEvent.prerequisites) {
+          const prereqsMet = failedEvent.prerequisites.every(
+            (pid) => currentAssignments.has(pid)
+          );
+          if (!prereqsMet) continue;
+        }
+
+        const directPlace = tryPlace(
+          failedEvent, rooms, options, gap, currentAssignments, roomSchedules
+        );
+        if (directPlace) {
+          placeAssignment(directPlace, currentAssignments, roomSchedules);
+          failed.splice(i, 1);
+          improved = true;
+        }
+      }
+
+      if (improved) continue;
+
+      // Second pass: try removing one placed event and see if we get a net gain
+      // by placing multiple failed events in the freed space
+      const placedIds = [...currentAssignments.keys()];
+
+      for (const candidateId of placedIds) {
+        // Don't remove if candidateId has dependents that are currently scheduled
+        const deps = dependents.get(candidateId);
+        if (deps) {
+          const hasScheduledDependent = [...deps].some(
+            (d) => currentAssignments.has(d)
+          );
+          if (hasScheduledDependent) continue;
+        }
+
+        const savedAssignment = currentAssignments.get(candidateId)!;
+        removeAssignment(candidateId, currentAssignments, roomSchedules);
+
+        // Try to place as many failed events as possible
+        const newlyPlaced: Array<{ id: string; assignment: Assignment; idx: number }> = [];
+
+        for (let i = 0; i < failed.length; i++) {
+          const fid = failed[i];
+          const fev = eventMap.get(fid)!;
+
+          if (fev.prerequisites) {
+            const prereqsMet = fev.prerequisites.every(
+              (pid) => currentAssignments.has(pid)
+            );
+            if (!prereqsMet) continue;
+          }
+
+          const attempt = tryPlace(fev, rooms, options, gap, currentAssignments, roomSchedules);
+          if (attempt) {
+            placeAssignment(attempt, currentAssignments, roomSchedules);
+            newlyPlaced.push({ id: fid, assignment: attempt, idx: i });
+          }
+        }
+
+        // Also try to re-place the removed event
+        const candidateEvent = eventMap.get(candidateId)!;
+        const rePlace = tryPlace(
+          candidateEvent, rooms, options, gap, currentAssignments, roomSchedules
+        );
+
+        const netGain = newlyPlaced.length + (rePlace ? 1 : 0) - 1; // -1 for the removed event
+
+        if (netGain > 0) {
+          // Keep the new placements, they result in more total events
+          if (rePlace) {
+            placeAssignment(rePlace, currentAssignments, roomSchedules);
+          }
+          // Remove the newly placed events from the failed list (in reverse order to preserve indices)
+          const indicesToRemove = newlyPlaced.map((p) => p.idx).sort((a, b) => b - a);
+          for (const idx of indicesToRemove) {
+            failed.splice(idx, 1);
+          }
+          // If the original candidate wasn't re-placed, add it to failed
+          if (!rePlace) {
+            failed.push(candidateId);
+          }
+          improved = true;
+          break; // restart the outer loop
+        } else {
+          // Undo: remove newly placed events and restore the original
+          for (const p of newlyPlaced) {
+            removeAssignment(p.id, currentAssignments, roomSchedules);
+          }
+          placeAssignment(savedAssignment, currentAssignments, roomSchedules);
+        }
+      }
+    }
+  }
+
+  return { assignments: currentAssignments, roomSchedules };
+}
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+
+  // Handle empty inputs
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  if (rooms.length === 0) {
+    return { assignments: [], unscheduled: events.map((e) => e.id) };
+  }
+
+  // Step 1: Detect cycles and get topological order (throws on cycle)
+  const topoOrder = topologicalSort(events);
+
+  const knownEventIds = new Set(events.map((e) => e.id));
+
+  // Step 2: Schedule with backtracking
+  const { assignments } = scheduleWithBacktracking(
+    events,
+    topoOrder,
+    rooms,
+    options,
+    gap,
+    knownEventIds
+  );
+
+  // Step 3: Build result
+  const assignmentList: Assignment[] = [];
+  const unscheduled: string[] = [];
+
+  for (const event of events) {
+    const assignment = assignments.get(event.id);
+    if (assignment) {
+      assignmentList.push(assignment);
+    } else {
+      unscheduled.push(event.id);
+    }
+  }
+
+  return { assignments: assignmentList, unscheduled };
+}
