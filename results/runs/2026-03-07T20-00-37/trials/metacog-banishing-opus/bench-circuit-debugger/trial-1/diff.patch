+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+function isXYInput(wire: string): boolean {
+  return /^[xy]\d+$/.test(wire);
+}
+
+function isZOutput(wire: string): boolean {
+  return /^z\d+$/.test(wire);
+}
+
+function hasXYInputs(gate: Gate): boolean {
+  return isXYInput(gate.in1) && isXYInput(gate.in2);
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Find the highest z-bit number
+  const zBits = gates
+    .map((g) => g.out)
+    .filter(isZOutput)
+    .map((w) => parseInt(w.slice(1)));
+  const maxZ = Math.max(...zBits);
+  const lastZ = `z${String(maxZ).padStart(2, '0')}`;
+
+  // Build lookup: which gates does a wire feed into?
+  const wireToConsumers = new Map<string, Gate[]>();
+  for (const gate of gates) {
+    if (!wireToConsumers.has(gate.in1)) wireToConsumers.set(gate.in1, []);
+    wireToConsumers.get(gate.in1)!.push(gate);
+    if (!wireToConsumers.has(gate.in2)) wireToConsumers.set(gate.in2, []);
+    wireToConsumers.get(gate.in2)!.push(gate);
+  }
+
+  const swapped = new Set<string>();
+
+  for (const gate of gates) {
+    const { op, out } = gate;
+    const xyInputs = hasXYInputs(gate);
+
+    // Rule 1: XOR gates with x/y inputs should NOT output to z (except z00)
+    // In the adder, xNN XOR yNN produces a partial sum (intermediate wire),
+    // not a z-output. The only exception is bit 0: x00 XOR y00 -> z00.
+    if (op === 'XOR' && xyInputs && isZOutput(out) && out !== 'z00') {
+      swapped.add(out);
+    }
+
+    // Rule 2: XOR gates that do NOT have x/y inputs must output to z.
+    // These are the "partial_sum XOR carry_in -> zNN" gates.
+    if (op === 'XOR' && !xyInputs && !isZOutput(out)) {
+      swapped.add(out);
+    }
+
+    // Rule 3: z-outputs (except the last one) must come from XOR gates.
+    // The last z-bit is the final carry, which comes from an OR gate.
+    if (isZOutput(out) && out !== lastZ && op !== 'XOR') {
+      swapped.add(out);
+    }
+
+    // Rule 4: AND gates (except x00 AND y00) must feed into OR gates.
+    // AND outputs are either generate-carry or propagate-carry, both feed OR.
+    const isBit0AND =
+      xyInputs &&
+      ((gate.in1 === 'x00' && gate.in2 === 'y00') ||
+        (gate.in1 === 'y00' && gate.in2 === 'x00'));
+    if (op === 'AND' && !isBit0AND) {
+      const consumers = wireToConsumers.get(out) || [];
+      if (consumers.length > 0 && consumers.every((c) => c.op !== 'OR')) {
+        swapped.add(out);
+      }
+    }
+
+    // Rule 5: XOR gates with x/y inputs (partial sums) must feed into
+    // XOR and AND gates (not OR gates). If they feed into OR, something is wrong.
+    if (op === 'XOR' && xyInputs) {
+      const consumers = wireToConsumers.get(out) || [];
+      if (consumers.length > 0 && consumers.some((c) => c.op === 'OR')) {
+        swapped.add(out);
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
