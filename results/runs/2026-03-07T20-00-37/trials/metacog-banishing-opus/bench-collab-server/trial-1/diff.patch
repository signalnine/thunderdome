@@ -0,0 +1,54 @@
+import express from 'express';
+import { createServer, Server } from 'http';
+import { createDatabase, DocumentStore } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationManager } from './collaboration.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath);
+  const store = new DocumentStore(db);
+
+  const app = express();
+  app.use(express.json());
+
+  const router = createRouter(store);
+  app.use('/api', router);
+
+  const httpServer: Server = createServer(app);
+  const collaboration = new CollaborationManager(httpServer, store);
+
+  let isRunning = false;
+
+  return {
+    app,
+    async start(port: number = 0): Promise<number> {
+      return new Promise((resolve) => {
+        httpServer.listen(port, () => {
+          isRunning = true;
+          const addr = httpServer.address();
+          const actualPort =
+            typeof addr === 'object' && addr ? addr.port : port;
+          resolve(actualPort);
+        });
+      });
+    },
+    async stop(): Promise<void> {
+      if (!isRunning) return;
+      collaboration.closeAll();
+      return new Promise((resolve, reject) => {
+        httpServer.close((err) => {
+          isRunning = false;
+          store.close();
+          if (err) reject(err);
+          else resolve();
+        });
+      });
+    },
+  };
+}
