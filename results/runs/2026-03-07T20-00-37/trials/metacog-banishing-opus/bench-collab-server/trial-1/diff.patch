+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage } from 'http';
+import { Server } from 'http';
+import { DocumentStore } from './db.js';
+import {
+  Operation,
+  applyOperation,
+  transformAgainstAll,
+  validateOperation,
+} from './ot.js';
+
+interface ClientConnection {
+  ws: WebSocket;
+  clientId: string;
+  documentId: string;
+}
+
+interface IncomingMessage_WS {
+  type: string;
+  clientId?: string;
+  version?: number;
+  operation?: Operation;
+}
+
+interface DocumentSession {
+  documentId: string;
+  clients: Map<string, ClientConnection>;
+  // Operations applied since version 0 (index i = operation that produced version i+1)
+  operationLog: Operation[];
+}
+
+export class CollaborationManager {
+  private wss: WebSocketServer;
+  private store: DocumentStore;
+  private sessions: Map<string, DocumentSession> = new Map();
+
+  constructor(server: Server, store: DocumentStore) {
+    this.store = store;
+    this.wss = new WebSocketServer({ server, path: undefined });
+
+    // We handle upgrade manually to extract document ID from the URL path
+    server.on('upgrade', (request: IncomingMessage, socket, head) => {
+      const url = new URL(request.url || '/', `http://${request.headers.host || 'localhost'}`);
+      const match = url.pathname.match(/^\/ws\/documents\/([^/]+)$/);
+
+      if (!match) {
+        socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+        socket.destroy();
+        return;
+      }
+
+      const documentId = match[1];
+      const doc = this.store.getDocument(documentId);
+      if (!doc) {
+        socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+        socket.destroy();
+        return;
+      }
+
+      this.wss.handleUpgrade(request, socket, head, (ws) => {
+        this.wss.emit('connection', ws, request, documentId);
+      });
+    });
+
+    this.wss.on(
+      'connection',
+      (ws: WebSocket, _request: IncomingMessage, documentId: string) => {
+        this.handleConnection(ws, documentId);
+      }
+    );
+  }
+
+  private getOrCreateSession(documentId: string): DocumentSession {
+    let session = this.sessions.get(documentId);
+    if (!session) {
+      // Load operation log from version history
+      const versions = this.store.getVersions(documentId);
+      const operationLog: Operation[] = [];
+      for (const v of versions) {
+        if (v.operation) {
+          try {
+            operationLog.push(JSON.parse(v.operation) as Operation);
+          } catch {
+            // Skip malformed operations in history
+          }
+        }
+      }
+
+      session = {
+        documentId,
+        clients: new Map(),
+        operationLog,
+      };
+      this.sessions.set(documentId, session);
+    }
+    return session;
+  }
+
+  private handleConnection(ws: WebSocket, documentId: string): void {
+    const clientId = crypto.randomUUID();
+    const session = this.getOrCreateSession(documentId);
+
+    const client: ClientConnection = { ws, clientId, documentId };
+    session.clients.set(clientId, client);
+
+    // Send sync message with current document state
+    const doc = this.store.getDocument(documentId);
+    if (!doc) {
+      ws.close(1008, 'Document not found');
+      return;
+    }
+
+    const currentVersion = this.store.getCurrentVersion(documentId);
+
+    ws.send(
+      JSON.stringify({
+        type: 'sync',
+        documentId,
+        clientId,
+        content: doc.content,
+        version: currentVersion,
+      })
+    );
+
+    // Broadcast user joined
+    this.broadcastToOthers(session, clientId, {
+      type: 'user_joined',
+      clientId,
+      activeUsers: session.clients.size,
+    });
+
+    ws.on('message', (data) => {
+      try {
+        const message = JSON.parse(data.toString()) as IncomingMessage_WS;
+        this.handleMessage(session, client, message);
+      } catch (err) {
+        ws.send(
+          JSON.stringify({
+            type: 'error',
+            message: 'Invalid message format',
+          })
+        );
+      }
+    });
+
+    ws.on('close', () => {
+      session.clients.delete(clientId);
+      this.broadcastToOthers(session, clientId, {
+        type: 'user_left',
+        clientId,
+        activeUsers: session.clients.size,
+      });
+
+      if (session.clients.size === 0) {
+        this.sessions.delete(documentId);
+      }
+    });
+  }
+
+  private handleMessage(
+    session: DocumentSession,
+    client: ClientConnection,
+    message: IncomingMessage_WS
+  ): void {
+    if (message.type !== 'operation') {
+      client.ws.send(
+        JSON.stringify({
+          type: 'error',
+          message: `Unknown message type: ${message.type}`,
+        })
+      );
+      return;
+    }
+
+    if (!message.operation) {
+      client.ws.send(
+        JSON.stringify({
+          type: 'error',
+          message: 'Missing operation field',
+        })
+      );
+      return;
+    }
+
+    const validationError = validateOperation(message.operation);
+    if (validationError) {
+      client.ws.send(
+        JSON.stringify({
+          type: 'error',
+          message: validationError,
+        })
+      );
+      return;
+    }
+
+    if (typeof message.version !== 'number') {
+      client.ws.send(
+        JSON.stringify({
+          type: 'error',
+          message: 'Missing or invalid version field',
+        })
+      );
+      return;
+    }
+
+    const currentVersion = this.store.getCurrentVersion(session.documentId);
+
+    // The client's operation was based on `message.version`.
+    // We need to transform it against all operations that have been applied
+    // since that version.
+    let op = message.operation;
+    if (message.version < currentVersion) {
+      // Get all operations from message.version to currentVersion
+      const missedOps: Operation[] = [];
+      for (let v = message.version + 1; v <= currentVersion; v++) {
+        const versionRecord = this.store.getVersion(session.documentId, v);
+        if (versionRecord && versionRecord.operation) {
+          try {
+            missedOps.push(JSON.parse(versionRecord.operation) as Operation);
+          } catch {
+            // Skip malformed
+          }
+        }
+      }
+      if (missedOps.length > 0) {
+        op = transformAgainstAll(op, missedOps);
+      }
+    } else if (message.version > currentVersion) {
+      client.ws.send(
+        JSON.stringify({
+          type: 'error',
+          message: `Version ${message.version} is ahead of server version ${currentVersion}`,
+        })
+      );
+      return;
+    }
+
+    // Apply the (possibly transformed) operation to the document
+    const doc = this.store.getDocument(session.documentId);
+    if (!doc) {
+      client.ws.send(
+        JSON.stringify({ type: 'error', message: 'Document not found' })
+      );
+      return;
+    }
+
+    let newContent: string;
+    try {
+      newContent = applyOperation(doc.content, op);
+    } catch (err) {
+      client.ws.send(
+        JSON.stringify({
+          type: 'error',
+          message: `Failed to apply operation: ${(err as Error).message}`,
+        })
+      );
+      return;
+    }
+
+    // Persist
+    const newVersion = this.store.updateContent(
+      session.documentId,
+      newContent,
+      JSON.stringify(op)
+    );
+    session.operationLog.push(op);
+
+    // Acknowledge to the sender
+    client.ws.send(
+      JSON.stringify({
+        type: 'ack',
+        version: newVersion,
+        operation: op,
+      })
+    );
+
+    // Broadcast to other clients
+    this.broadcastToOthers(session, client.clientId, {
+      type: 'operation',
+      clientId: client.clientId,
+      version: newVersion,
+      operation: op,
+    });
+  }
+
+  private broadcastToOthers(
+    session: DocumentSession,
+    excludeClientId: string,
+    message: Record<string, unknown>
+  ): void {
+    const payload = JSON.stringify(message);
+    for (const [id, client] of session.clients) {
+      if (id !== excludeClientId && client.ws.readyState === WebSocket.OPEN) {
+        client.ws.send(payload);
+      }
+    }
+  }
+
+  closeAll(): void {
+    for (const session of this.sessions.values()) {
+      for (const client of session.clients.values()) {
+        client.ws.close(1001, 'Server shutting down');
+      }
+    }
+    this.sessions.clear();
+    this.wss.close();
+  }
+}
