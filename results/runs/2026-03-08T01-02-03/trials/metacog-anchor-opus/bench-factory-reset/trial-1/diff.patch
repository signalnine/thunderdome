   334→    let carry = 1;\n   335→    for (let i = 0; i < numFree && carry; i++) {\n   336→      freeValues[i]++;\n   337→      if (freeValues[i] >= modulus) {\n   338→        freeValues[i] = 0;\n   339→      } else {\n   340→        carry = 0;\n   341→      }\n   342→    }\n   343→  }\n   344→\n   345→  return bestResult;\n   346→}\n   347→\n   348→function isLexSmallerArr(a: number[], b: number[]): boolean {\n   349→  for (let i = 0; i < a.length; i++) {\n   350→    if (a[i] < b[i]) return true;\n   351→    if (a[i] > b[i]) return false;\n   352→  }\n   353→  return false;\n   354→}\n   355→\n   356→function solveCounterMITM(\n   357→  numButtons: number,\n   358→  numFree: number,\n   359→  freeVars: number[],\n   360→  pivotCol: number[],\n   361→  coeffs: number[][],\n   362→  rhs: number[],\n   363→  rank: number,\n   364→  modulus: number\n   365→): number[] | null {\n   366→  // Split free variables into two halves\n   367→  const halfA = Math.floor(numFree / 2);\n   368→  const halfB = numFree - halfA;\n   369→\n   370→  // For each first-half assignment, compute the contribution to each pivot variable\n   371→  // and total sum of presses (free vars + resulting pivot adjustments).\n   372→  //\n   373→  // Key insight: in RREF, pivot[r] = rhs[r] - sum(coeffs[r][fi] * freeVal[fi])\n   374→  // So the contribution from first half to pivot[r] is: -sum(coeffs[r][fi] * valsA[fi]) for fi in first half\n   375→  // And from second half: -sum(coeffs[r][fi] * valsB[fi]) for fi in second half\n   376→  //\n   377→  // For MITM, we want to find pairs (A, B) that minimize:\n   378→  //   sum(valsA) + sum(valsB) + sum(mod(rhs[r] - contribA[r] - contribB[r], p) for r)\n   379→  //\n   380→  // Since the pivot values depend on both halves, we can't fully decouple.\n   381→  // Instead, we key on contribA and for each contribB, look up matching contribA.\n   382→  // But we need to evaluate the full objective for each pair.\n   383→  //\n   384→  // Better approach: key on contribA (the effect vector), and for each contribB,\n   385→  // iterate over all possible matching contribA entries and compute the full cost.\n   386→  // But this defeats the purpose of MITM.\n   387→  //\n   388→  // Alternative: enumerate all contribA, store by effect vector.\n   389→  // For each contribB, compute the needed pivot values and the resulting total cost.\n   390→  // The issue is: for a given (contribA, contribB), the total cost is:\n   391→  //   sumA + sumB + sum(mod(rhs[r] - contribA[r] - contribB[r], p))\n   392→  //\n   393→  // For fixed contribB, as contribA varies, the cost changes in a complex way.\n   394→  // We can't simply look up the \"best\" contribA because the pivot contributions change.\n   395→  //\n   396→  // Practical approach: group first-half entries by their effect vector.\n   397→  // For each contribB, compute effectB, then for each possible effectA in the map,\n   398→  // compute cost and track the best.\n   399→  //\n   400→  // This is O(|firstHalf-groups| * |secondHalf|) which may still be large.\n   401→  // But it reduces the problem significantly if many first-half assignments map to the same effect.\n   402→\n   403→  // Actually, let me reconsider. The number of distinct effect vectors is at most p^rank.\n   404→  // Since rank <= 40 and p <= 97, this can be very large.\n   405→  // But the number of first-half assignments is p^halfA which is also large.\n   406→  //\n   407→  // A better strategy: since we store the BEST first-half assignment for each effect vector,\n   408→  // we iterate over all second-half assignments and for EACH one, we iterate over\n   409→  // all stored first-half effect vectors. But this is expensive.\n   410→  //\n   411→  // Let me use a different strategy: just enumerate all first-half entries,\n   412→  // and for each second-half entry, look up by a specific key.\n   413→  //\n   414→  // The trick: fix the target pivot values. For each possible set of pivot values,\n   415→ 