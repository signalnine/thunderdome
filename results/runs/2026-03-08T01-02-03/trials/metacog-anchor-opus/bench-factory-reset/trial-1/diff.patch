olveGF2(matrix, numLights, numButtons);\n}\n\nfunction solveGF2(matrix: number[][], numRows: number, numCols: number): number[] | null {\n  // Gaussian elimination over GF(2) with full pivoting\n  const pivotCol: number[] = []; // pivotCol[rank_index] = column of that pivot\n  const pivotRowForCol: number[] = new Array(numCols).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numCols; col++) {\n    // Find pivot row\n    let found = -1;\n    for (let row = rank; row < numRows; row++) {\n      if (matrix[row][col] === 1) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n    pivotCol.push(col);\n    pivotRowForCol[col] = rank;\n\n    // Eliminate all other rows (reduced row echelon)\n    for (let row = 0; row < numRows; row++) {\n      if (row !== rank && matrix[row][col] === 1) {\n        for (let k = col; k <= numCols; k++) {\n          matrix[row][k] ^= matrix[rank][k];\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency\n  for (let row = rank; row < numRows; row++) {\n    if (matrix[row][numCols] === 1) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numCols; col++) {\n    if (pivotRowForCol[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // If no free variables, unique solution\n  if (numFree === 0) {\n    const result: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if (matrix[r][numCols] === 1) {\n        result.push(pivotCol[r]);\n      }\n    }\n    result.sort((a, b) => a - b);\n    return result;\n  }\n\n  // Enumerate 2^numFree assignments to find minimum Hamming weight solution\n  // For numFree <= 25, this is at most ~33M which is feasible\n  let bestResult: number[] | null = null;\n  let bestCount = numCols + 1;\n\n  const limit = 1 << numFree;\n  for (let mask = 0