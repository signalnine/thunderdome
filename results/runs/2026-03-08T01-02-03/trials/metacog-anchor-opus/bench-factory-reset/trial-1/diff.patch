 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n\n  return solveGF2(matrix, numLights, numButtons);\n}\n\nfunction solveGF2(matrix: number[][], numRows: number, numCols: number): number[] | null {\n  // Gaussian elimination over GF(2) with full pivoting\n  const pivotCol: number[] = []; // pivotCol[rank_index] = column of that pivot\n  const pivotRowForCol: number[] = new Array(numCols).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numCols; col++) {\n    // Find pivot row\n    let found = -1;\n    for (let row = rank; row < numRows; row++) {\n      if (matrix[row][col] === 1) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n    pivotCol.push(col);\n    pivotRowForCol[col] = rank;\n\n    // Eliminate all other rows (reduced row echelon)\n    for (let row = 0; row < numRows; row++) {\n      if (row !== rank && matrix[row][col] === 1) {\n        for (let k = col; k <= numCols; k++) {\n          matrix[row][k] ^= matrix[rank][k];\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency\n  for (let row = rank; row < numRows; row++) {\n    if (matrix[row][numCols] === 1) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numCols; col++) {\n    if (pivotRowForCol[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // If no free variables, unique solution\n  if (numFree === 0) {\n    const result: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if (matrix[r][numCols] === 1) {\n        result.push(pivotCol[r]);\n      }\n    }\n    result.sort((a, b) => a - b);\n    return result;\n  }\n\n  // Enumerate 2^numFree assignments to find minimum Hamming weight solution\n  // For numFree <= 25, this is at most ~33M which is feasible\n  let bestResult: number[] | null = null;\n  let bestCount = numCols + 1;\n\n  const limit = 1 << numFree;\n  for (let mask = 0; mask < limit; mask++) {\n    // Compute full solution from free variable assignment\n    const pressed: number[] = [];\n\n    // Free variables that are set\n    let freeCount = 0;\n    for (let i = 0; i < numFree; i++) {\n      if ((mask >> i) & 1) {\n        pressed.push(freeVars[i]);\n        freeCount++;\n      }\n    }\n\n    // Pivot variables: for row r with pivot in column pivotCol[r],\n    // x[pivotCol[r]] = RHS[r] XOR sum(matrix[r][freeVars[i]] * freeVal[i])\n    // Since we're in RREF, matrix[r][otherPivotCol] = 0 for other pivots\n    for (let r = 0; r < rank; r++) {\n      let val = matrix[r][numCols];\n      for (let i = 0; i < numFree; i++) {\n        if ((mask >> i) & 1) {\n          val ^= matrix[r][freeVars[i]];\n        }\n      }\n      if (val === 1) {\n        pressed.push(pivotCol[r]);\n      }\n    }\n\n    if (pressed.length < bestCount) {\n      pressed.sort((a, b) => a - b);\n      bestCount = pressed.length;\n      bestResult = pressed;\n    } else if (pressed.length === bestCount) {\n      pressed.sort((a, b) => a - b);\n      if (isLexSmaller(pressed, bestResult!)) {\n        bestResult = pressed;\n      }\n    }\n  }\n\n  return bestResult;\n}\n\nfunction isLexSmaller(a: number[], b: number[]): boolean {\n  const len = Math.min(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return a.length < b.length;\n}\n\nfunction modInverse(a: number, p: number): number {\n  let [old_r, r] = [a, p];\n  let [old_s, s] = [1, 0];\n  while (r !== 0) {\n    const q = Math.floor(old_r / r);\n    [old_r, r] = [r, old_r - q * r];\n    [old_s, s] = [s, old_s - q * s];\n  }\n  return ((old_s % p) + p) % p;\n}\n\nfunction mod(a: number, p: number): number {\n  return ((a % p) + p) % p;\n}\n\n/**\n * Solve a counter puzzle over GF(p).\n * Find number of times to press each button so counters match target.\n * Returns array of press counts, or null if no solution exists.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numLights = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | b] over GF(modulus)\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = lights[i] % modulus;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(modulus) → RREF\n  const pivotCol: number[] = [];\n  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    let found = -1;\n    for (let row = rank; row < numLights; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n    pivotCol.push(col);\n    pivotRowForCol[col] = rank;\n\n    // Scale pivot row\n    const inv = modInverse(matrix[rank][col], modulus);\n    for (let k = col; k <= numButtons; k++) {\n      matrix[rank][k] = (matrix[rank][k] * inv) % modulus;\n    }\n\n    // Eliminate all other rows\n    for (let row = 0; row < numLights; row++) {\n      if (row !== rank && matrix[row][col] !== 0) {\n        const factor = matrix[row][col];\n        for (let k = col; k <= numButtons; k++) {\n          matrix[row][k] = mod(matrix[row][k] - factor * matrix[rank][k], modulus);\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency\n  for (let row = rank; row < numLights; row++) {\n    if (matrix[row][numButtons] !== 0) {\n      return null;\n    }