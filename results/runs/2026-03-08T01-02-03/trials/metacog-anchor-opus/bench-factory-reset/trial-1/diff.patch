+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix [A | b] over GF(2)
+  // Rows = lights, Columns = buttons, augmented column = target
+  // A[i][j] = 1 if button j toggles light i
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(2) → Reduced Row Echelon Form
+  const pivotCol: number[] = [];
+  const isPivotCol = new Array(numButtons).fill(false);
+  let rank = 0;
+
+  for (let col = 0; col < numButtons; col++) {
+    let pivotRow = -1;
+    for (let row = rank; row < numLights; row++) {
+      if (matrix[row][col] === 1) {
+        pivotRow = row;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    [matrix[rank], matrix[pivotRow]] = [matrix[pivotRow], matrix[rank]];
+    pivotCol.push(col);
+    isPivotCol[col] = true;
+
+    for (let row = 0; row < numLights; row++) {
+      if (row !== rank && matrix[row][col] === 1) {
+        for (let k = col; k <= numButtons; k++) {
+          matrix[row][k] ^= matrix[rank][k];
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Consistency check
+  for (let row = rank; row < numLights; row++) {
+    if (matrix[row][numButtons] === 1) return null;
+  }
+
+  // Collect free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!isPivotCol[col]) freeVars.push(col);
+  }
+
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const result: number[] = [];
+    for (let r = 0; r < rank; r++) {
+      if (matrix[r][numButtons] === 1) result.push(pivotCol[r]);
+    }
+    return result.sort((a, b) => a - b);
+  }
+
+  // Precompute free variable coefficients in each pivot row
+  const freeCoeffs: number[][] = [];
+  for (let r = 0; r < rank; r++) {
+    const c: number[] = new Array(numFree);
+    for (let fi = 0; fi < numFree; fi++) {
+      c[fi] = matrix[r][freeVars[fi]];
+    }
+    freeCoeffs.push(c);
+  }
+  const rhsVals: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    rhsVals.push(matrix[r][numButtons]);
+  }
+
+  let bestResult: number[] | null = null;
+  let bestCount = numButtons + 1;
+
+  const limit = 1 << numFree;
+  for (let mask = 0; mask < limit; mask++) {
+    const pressed: number[] = [];
+
+    for (let i = 0; i < numFree; i++) {
+      if ((mask >> i) & 1) pressed.push(freeVars[i]);
+    }
+
+    for (let r = 0; r < rank; r++) {
+      let val = rhsVals[r];
+      for (let i = 0; i < numFree; i++) {
+        if ((mask >> i) & 1) val ^= freeCoeffs[r][i];
+      }
+      if (val === 1) pressed.push(pivotCol[r]);
+    }
+
+    if (pressed.length < bestCount) {
+      pressed.sort((a, b) => a - b);
+      bestCount = pressed.length;
+      bestResult = pressed;
+    } else if (pressed.length === bestCount) {
+      pressed.sort((a, b) => a - b);
+      if (lexSmaller(pressed, bestResult!)) {
+        bestResult = pressed;
+      }
+    }
+  }
+
+  return bestResult;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (i >= b.length) return false;
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+function modInverse(a: number, p: number): number {
+  let [old_r, r] = [a, p];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % p) + p) % p;
+}
+
+function posmod(a: number, p: number): number {
+  return ((a % p) + p) % p;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix [A | b] over GF(modulus)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = posmod(lights[i], modulus);
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(modulus) → RREF
+  const pivotCol: number[] = [];
+  const isPivotCol = new Array(numButtons).fill(false);
+  let rank = 0;
+
+  for (let col = 0; col < numButtons; col++) {
+    let pivotRow = -1;
+    for (let row = rank; row < numLights; row++) {
+      if (matrix[row][col] !== 0) {
+        pivotRow = row;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    [matrix[rank], matrix[pivotRow]] = [matrix[pivotRow], matrix[rank]];
+    pivotCol.push(col);
+    isPivotCol[col] = true;
+
+    const inv = modInverse(matrix[rank][col], modulus);
+    for (let k = col; k <= numButtons; k++) {
+      matrix[rank][k] = (matrix[rank][k] * inv) % modulus;
+    }
+
+    for (let row = 0; row < numLights; row++) {
+      if (row !== rank && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let k = col; k <= numButtons; k++) {
+          matrix[row][k] = posmod(matrix[row][k] - factor * matrix[rank][k], modulus);
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Consistency check
+  for (let row = rank; row < numLights; row++) {
+    if (matrix[row][numButtons] !== 0) return null;
+  }
+
+  // Collect free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!isPivotCol[col]) freeVars.push(col);
+  }
+
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const result = new Array(numButtons).fill(0);
+    for (let r = 0; r < rank; r++) {
+      result[pivotCol[r]] = matrix[r][numButtons];
+    }
+    return result;
+  }
+
+  // Precompute coefficients
+  const freeCoeffs: number[][] = [];
+  const rhsVals: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    const c: number[] = new Array(numFree);
+    for (let fi = 0; fi < numFree; fi++) {
+      c[fi] = matrix[r][freeVars[fi]];
+    }
+    freeCoeffs.push(c);
+    rhsVals.push(matrix[r][numButtons]);
+  }
+
+  // Determine enumeration strategy
+  const totalCombinations = numFree <= 15 ? Math.pow(modulus, numFree) : Infinity;
+
+  if (totalCombinations <= 20_000_000) {
+    return enumerateCounter(numButtons, numFree, freeVars, pivotCol, freeCoeffs, rhsVals, rank, modulus, totalCombinations);
+  }
+
+  // For large search spaces, use MITM
+  return counterMITM(numButtons, numFree, freeVars, pivotCol, freeCoeffs, rhsVals, rank, modulus);
+}
+
+function enumerateCounter(
+  numButtons: number,
+  numFree: number,
+  freeVars: number[],
+  pivotCol: number[],
+  freeCoeffs: number[][],
+  rhsVals: number[],
+  rank: number,
+  modulus: number,
+  total: number
+): number[] | null {
+  let bestResult: number[] | null = null;
+  let bestSum = Infinity;
+
+  const fv = new Array(numFree).fill(0);
+
+  for (let c = 0; c < total; c++) {
+    let sum = 0;
+    for (let i = 0; i < numFree; i++) sum += fv[i];
+
+    if (sum <= bestSum) {
+      const solution = new Array(numButtons).fill(0);
+      for (let i = 0; i < numFree; i++) {
+        solution[freeVars[i]] = fv[i];
+      }
+
+      for (let r = 0; r < rank; r++) {
+        let val = rhsVals[r];
+        for (let fi = 0; fi < numFree; fi++) {
+          val -= freeCoeffs[r][fi] * fv[fi];
+        }
+        const pv = posmod(val, modulus);
+        solution[pivotCol[r]] = pv;
+        sum += pv;
+      }
+
+      if (sum < bestSum || (sum === bestSum && lexSmallerArr(solution, bestResult!))) {
+        bestSum = sum;
+        bestResult = [...solution];
+      }
+    }
+
+    // Increment mixed-radix
+    for (let i = 0; i < numFree; i++) {
+      fv[i]++;
+      if (fv[i] < modulus) break;
+      fv[i] = 0;
+    }
+  }
+
+  return bestResult;
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function counterMITM(
+  numButtons: number,
+  numFree: number,
+  freeVars: number[],
+  pivotCol: number[],
+  freeCoeffs: number[][],
+  rhsVals: number[],
+  rank: number,
+  modulus: number
+): number[] | null {
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+
+  // Build map: effectA vector → best {freeVals, sumA}
+  // effectA[r] = sum(freeCoeffs[r][fi] * valsA[fi]) mod p for fi in [0, halfA)
+  type Entry = { vals: number[]; sumA: number };
+  const bestHalf = new Map<string, Entry>();
+
+  const totalA = Math.pow(modulus, halfA);
+  const va = new Array(halfA).fill(0);
+
+  for (let i = 0; i < totalA; i++) {
+    const effects: number[] = new Array(rank);
+    let sumA = 0;
+
+    for (let fi = 0; fi < halfA; fi++) sumA += va[fi];
+
+    for (let r = 0; r < rank; r++) {
+      let val = 0;
+      for (let fi = 0; fi < halfA; fi++) {
+        val += freeCoeffs[r][fi] * va[fi];
+      }
+      effects[r] = val % modulus;
+    }
+
+    const key = effects.join(',');
+    const existing = bestHalf.get(key);
+    if (!existing || sumA < existing.sumA) {
+      bestHalf.set(key, { vals: [...va], sumA });
+    }
+
+    for (let fi = 0; fi < halfA; fi++) {
+      va[fi]++;
+      if (va[fi] < modulus) break;
+      va[fi] = 0;
+    }
+  }
+
+  let bestResult: number[] | null = null;
+  let bestSum = Infinity;
+
+  const totalB = Math.pow(modulus, halfB);
+  const vb = new Array(halfB).fill(0);
+
+  for (let i = 0; i < totalB; i++) {
+    let sumB = 0;
+    const effectB: number[] = new Array(rank);
+
+    for (let fi = 0; fi < halfB; fi++) sumB += vb[fi];
+
+    for (let r = 0; r < rank; r++) {
+      let val = 0;
+      for (let fi = 0; fi < halfB; fi++) {
+        val += freeCoeffs[r][halfA + fi] * vb[fi];
+      }
+      effectB[r] = val % modulus;
+    }
+
+    // Try all effectA entries from the map
+    for (const [key, entryA] of bestHalf) {
+      if (entryA.sumA + sumB >= bestSum) continue;
+
+      // Parse effectA from key
+      const effectA = key.split(',').map(Number);
+
+      // Compute pivot values
+      let sum = entryA.sumA + sumB;
+      let tooLarge = false;
+      const pivotVals: number[] = new Array(rank);
+      for (let r = 0; r < rank; r++) {
+        const pv = posmod(rhsVals[r] - effectA[r] - effectB[r], modulus);
+        pivotVals[r] = pv;
+        sum += pv;
+        if (sum >= bestSum) { tooLarge = true; break; }
+      }
+      if (tooLarge) continue;
+
+      if (sum < bestSum) {
+        const solution = new Array(numButtons).fill(0);
+        for (let fi = 0; fi < halfA; fi++) solution[freeVars[fi]] = entryA.vals[fi];
+        for (let fi = 0; fi < halfB; fi++) solution[freeVars[halfA + fi]] = vb[fi];
+        for (let r = 0; r < rank; r++) solution[pivotCol[r]] = pivotVals[r];
+
+        bestSum = sum;
+        bestResult = solution;
+      } else if (sum === bestSum) {
+        const solution = new Array(numButtons).fill(0);
+        for (let fi = 0; fi < halfA; fi++) solution[freeVars[fi]] = entryA.vals[fi];
+        for (let fi = 0; fi < halfB; fi++) solution[freeVars[halfA + fi]] = vb[fi];
+        for (let r = 0; r < rank; r++) solution[pivotCol[r]] = pivotVals[r];
+
+        if (lexSmallerArr(solution, bestResult!)) {
+          bestResult = solution;
+        }
+      }
+    }
+
+    for (let fi = 0; fi < halfB; fi++) {
+      vb[fi]++;
+      if (vb[fi] < modulus) break;
+      vb[fi] = 0;
+    }
+  }
+
+  return bestResult;
+}
