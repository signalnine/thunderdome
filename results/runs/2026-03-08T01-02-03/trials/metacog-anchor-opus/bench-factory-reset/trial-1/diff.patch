+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+// Helper to verify toggle solution
+function verifyToggle(machine: Machine, solution: number[] | null): boolean {
+  if (solution === null) return false;
+  const state = new Array(machine.target.length).fill(false);
+  for (const btn of solution) {
+    for (const light of machine.buttons[btn]) {
+      state[light] = !state[light];
+    }
+  }
+  return state.every((v, i) => v === machine.target[i]);
+}
+
+// Helper to verify counter solution
+function verifyCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+  solution: number[] | null
+): boolean {
+  if (solution === null) return false;
+  const state = new Array(lights.length).fill(0);
+  for (let b = 0; b < buttons.length; b++) {
+    for (const counter of buttons[b]) {
+      state[counter] = (state[counter] + solution[b]) % modulus;
+    }
+  }
+  return state.every((v, i) => v === lights[i]);
+}
+
+describe('solveToggle', () => {
+  it('should return empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should solve a simple single-button case', () => {
+    const machine: Machine = {
+      target: [true, true, false],
+      buttons: [[0, 1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+
+  it('should return null for the example in TASK.md', () => {
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should find minimum button presses', () => {
+    // Buttons 0 and 1 together toggle all 4 lights
+    // Button 2 toggles all 4 lights alone
+    // Target: all on
+    // Solution: button 2 (1 press) instead of buttons 0+1 (2 presses)
+    const machine: Machine = {
+      target: [true, true, true, true],
+      buttons: [[0, 1], [2, 3], [0, 1, 2, 3]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([2]);
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+
+  it('should return lexicographically smallest when tied on count', () => {
+    // Two buttons that do the same thing
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    const result = solveToggle(machine);
+    // Both button 0 and button 1 toggle light 0
+    // Both are 1-press solutions, lex smallest is [0]
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle no buttons', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should handle no lights with no buttons', () => {
+    const machine: Machine = {
+      target: [],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should handle multiple buttons needed', () => {
+    const machine: Machine = {
+      target: [true, false, true],
+      buttons: [[0], [1], [2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 2]);
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+
+  it('should solve with overlapping buttons', () => {
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    };
+    // Need all three toggled.
+    // b0 XOR b2 = 1 (light 0)
+    // b0 XOR b1 = 1 (light 1)
+    // b1 XOR b2 = 1 (light 2)
+    // Adding all three: 0 = 1 mod 2 -> no solution? Let me check.
+    // Actually: sum of all three equations: (b0+b2) + (b0+b1) + (b1+b2) = 3 mod 2 = 1
+    // LHS = 2b0 + 2b1 + 2b2 = 0 mod 2. So 0 = 1, contradiction.
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should handle large unique solution', () => {
+    // Identity-like: each button toggles exactly one light
+    const n = 10;
+    const target = new Array(n).fill(true);
+    const buttons = Array.from({ length: n }, (_, i) => [i]);
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine);
+    expect(result).toEqual(Array.from({ length: n }, (_, i) => i));
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+
+  it('should handle free variables and find minimum', () => {
+    // 2 lights, 3 buttons
+    // Button 0: toggles light 0
+    // Button 1: toggles light 1
+    // Button 2: toggles lights 0 and 1
+    // Target: [true, true]
+    // Solutions: {0,1}, {2} -> minimum is {2}
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0, 1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([2]);
+    expect(verifyToggle(machine, result)).toBe(true);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should solve a simple single-button case', () => {
+    // Button 0 increments counter 0
+    // Target: counter 0 = 3 (mod 5)
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+    expect(verifyCounter([3], [[0]], 5, result)).toBe(true);
+  });
+
+  it('should return null when no solution exists', () => {
+    // Button 0 increments both counters
+    // Target: counter 0 = 1, counter 1 = 2 (mod 5)
+    // Both counters get same increments, so can't differ
+    const result = solveCounter([1, 2], [[0, 1]], 5);
+    expect(result).toBeNull();
+  });
+
+  it('should find minimum total presses', () => {
+    // Button 0 increments counter 0
+    // Button 1 increments counter 0
+    // Target: counter 0 = 1 (mod 5)
+    // Solutions: [1,0] sum=1, [0,1] sum=1
+    // Lex smallest with min sum: [0,1]? No, [1,0] is lex smaller. Wait...
+    // [0,1] vs [1,0]: first element 0 < 1, so [0,1] is lex smaller
+    const result = solveCounter([1], [[0], [0]], 5);
+    // Both have sum 1. [0,1] is lex smaller than [1,0].
+    // Wait: the result array is [presses for button 0, presses for button 1]
+    // [1, 0] means press button 0 once
+    // [0, 1] means press button 1 once
+    // Lex comparison: [0,1] < [1,0] since first element 0 < 1
+    expect(result).toEqual([0, 1]);
+    expect(verifyCounter([1], [[0], [0]], 5, result)).toBe(true);
+  });
+
+  it('should handle modular arithmetic', () => {
+    // Button 0 increments counter 0
+    // Target: counter 0 = 0 (mod 3)
+    // Press 0 times (sum 0) or 3 times (but max is modulus-1=2, so wrap)
+    // Minimum is 0 presses
+    const result = solveCounter([0], [[0]], 3);
+    expect(result).toEqual([0]);
+  });
+
+  it('should solve a multi-button multi-counter case', () => {
+    // 2 counters, 2 buttons, mod 5
+    // Button 0: increments counter 0
+    // Button 1: increments counter 1
+    // Target: [3, 4]
+    const result = solveCounter([3, 4], [[0], [1]], 5);
+    expect(result).toEqual([3, 4]);
+    expect(verifyCounter([3, 4], [[0], [1]], 5, result)).toBe(true);
+  });
+
+  it('should handle overlapping buttons', () => {
+    // 2 counters, 2 buttons, mod 5
+    // Button 0: increments counters 0, 1
+    // Button 1: increments counter 1
+    // Target: [2, 3]
+    // b0 = 2 (from counter 0), b0 + b1 = 3 mod 5 -> b1 = 1
+    const result = solveCounter([2, 3], [[0, 1], [1]], 5);
+    expect(result).toEqual([2, 1]);
+    expect(verifyCounter([2, 3], [[0, 1], [1]], 5, result)).toBe(true);
+  });
+
+  it('should handle prime modulus correctly', () => {
+    // mod 7
+    // Button 0: counter 0
+    // Target: counter 0 = 6
+    const result = solveCounter([6], [[0]], 7);
+    expect(result).toEqual([6]);
+    expect(verifyCounter([6], [[0]], 7, result)).toBe(true);
+  });
+
+  it('should find solution with free variables', () => {
+    // 1 counter, 2 buttons, mod 5
+    // Both buttons increment counter 0
+    // Target: counter 0 = 1
+    // b0 + b1 = 1 mod 5
+    // Possible: (0,1),(1,0),(2,4),(3,3),(4,2)
+    // Min sum: (0,1) sum=1, (1,0) sum=1
+    // Lex smallest: (0,1)
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+    expect(verifyCounter([1], [[0], [0]], 5, result)).toBe(true);
+  });
+
+  it('should handle no buttons with non-zero target', () => {
+    const result = solveCounter([1], [], 5);
+    expect(result).toBeNull();
+  });
+
+  it('should handle no buttons with zero target', () => {
+    const result = solveCounter([0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  it('should handle empty counters and buttons', () => {
+    const result = solveCounter([], [], 5);
+    expect(result).toEqual([]);
+  });
+});
