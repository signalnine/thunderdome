716f55d0","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/index.ts","content":"export interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve a toggle puzzle over GF(2).\n * Find minimum set of buttons to press so lights match the target.\n * Returns sorted button indices, or null if no solution exists.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | b] over GF(2)\n  // Rows = lights, Columns = buttons + 1 (augmented)\n  // A[i][j] = 1 if button j toggles light i\n  // b[i] = target[i] ? 1 : 0\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(2)\n  // Track which column is the pivot for each row\n  const pivotCol: number[] = new Array(numLights).fill(-1);\n  const pivotRow: number[] = new Array(numButtons).fill(-1); // pivotRow[col] = row that has pivot in this col\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    // Find pivot row\n    let found = -1;\n    for (let row = rank; row < numLights; row++) {\n      if (matrix[row][col] === 1) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n    pivotCol[rank] = col;\n    pivotRow[col] = rank;\n\n    // Eliminate other rows\n    for (let row = 0; row < numLights; row++) {\n      if (row !== rank && matrix[row][col] === 1) {\n        for (let k = 0; k < numButtons + 1; k++) {\n          matrix[row][k] ^= matrix[rank][k];\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency: if any row has all-zero coefficients but non-zero RHS\n  for (let row = rank; row < numLights; row++) {\n    if (matrix[row][numButtons] === 1) {\n      return null;\n    }\n  }\n\n  // Identify free variables (columns without pivots)\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  // If no free variables, unique solution\n  if (freeVars.length === 0) {\n    const result: number[] = [];\n    for (let row = 0; row < rank; row++) {\n      if (matrix[row][numButtons] === 1) {\n        result.push(pivotCol[row]);\n      }\n    }\n    result.sort((a, b) => a - b);\n    return result;\n  }\n\n  // Enumerate free variable assignments to find minimum weight solution\n  // For GF(2), each free var is 0 or 1, so 2^k combinations\n  const numFree = freeVars.length;\n\n  if (numFree > 25) {\n    // For very large free variable spaces, use meet-in-the-middle\n    return solveToggleMITM(matrix, pivotCol, pivotRow, freeVars, rank, numButtons);\n  }\n\n  let bestResult: number[] | null = null;\n  let bestCount = numButtons + 1;\n\n  for (let mask = 0; mask < (1 << numFree); mask++) {\n    const solution = new Array(numButtons).fill(0);\n\n    // Set free variables\n    for (let i = 0; i < numFree; i++) {\n      solution[freeVars[i]] = (mask >> i) & 1;\n    }\n\n    // Compute pivot variables by back-substitution\n    for (let row = rank - 1; row >= 0; row--) {\n      const col = pivotCol[row];\n      let val = matrix[row][numButtons];\n      for (let k = 0; k < numButtons; k++) {\n        if (k !== col && matrix[row][k] === 1) {\n          val ^= solution[k];\n        }\n      }\n      solution[col] = val;\n    }\n\n    // Count pressed buttons\n    const pressed: number[] = [];\n    for (let i = 0; i < numButtons; i++) {\n      if (solution[i] === 1) pressed.push(i);\n    }\n\n    if (pressed.length < bestCount ||\n        (pressed.length 