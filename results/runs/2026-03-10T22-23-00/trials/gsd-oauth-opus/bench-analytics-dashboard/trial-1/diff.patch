@@ -0,0 +1,29 @@
+import express from "express";
+import type Database from "better-sqlite3";
+import { createDatabase } from "./db.js";
+import { createUserRoutes } from "./routes/users.js";
+import { createEventRoutes } from "./routes/events.js";
+import { createQueryRoutes } from "./routes/queries.js";
+import { createDashboardRoutes } from "./routes/dashboards.js";
+import { createExportRoutes } from "./routes/export.js";
+
+export function createApp(db?: Database.Database): express.Express {
+  const database = db || createDatabase();
+  const app = express();
+
+  app.use(express.json());
+
+  // Health check
+  app.get("/health", (_req, res) => {
+    res.json({ status: "ok" });
+  });
+
+  // Routes
+  app.use("/api/users", createUserRoutes(database));
+  app.use("/api/events", createEventRoutes(database));
+  app.use("/api/queries", createQueryRoutes(database));
+  app.use("/api/dashboards", createDashboardRoutes(database));
+  app.use("/api/export", createExportRoutes(database));
+
+  return app;
+}
