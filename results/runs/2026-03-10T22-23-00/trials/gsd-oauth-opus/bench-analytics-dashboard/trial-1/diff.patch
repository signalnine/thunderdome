quest(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" } },\n          { name: \"click\", properties: { button: \"signup\" } },\n        ],\n      });\n  });\n\n  it(\"should export events as JSON\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(2);\n  });\n\n  it(\"should export events as CSV\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events/csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"id,tenant_id,name\");\n  });\n\n  it(\"should export dashboards as JSON\", async () => {\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Test Dashboard\" });\n\n    const res = await request(app)\n      .get(\"/api/export/dashboards/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.dashboards.length).toBe(1);\n  });\n\n  it(\"should export dashboards as CSV\", async () => {\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Test Dashboard\" });\n\n    const res = await request(app)\n      .get(\"/api/export/dashboards/csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"id,tenant_id,name\");\n  });\n\n  it(\"should respect tenant isolation in exports\", async () => {\n    const otherRes = await request(app)\n      .post(\"/api/users/register\")\n      .send({ email: \"other@example.com\", password: \"pass\", tenantId: \"tenant2\" });\n\n    const res = await request(app)\n      .get(\"/api/export/events/json\")\n      .set(\"Authorization\", `Bearer ${otherRes.body.token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(0);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
