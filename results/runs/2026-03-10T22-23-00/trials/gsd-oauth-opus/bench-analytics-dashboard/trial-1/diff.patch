+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01UQhkNXyzuCxmBuSbA5Cjk2","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BLTrmf1giuQhRag8uJWymo","name":"Write","input":{"file_path":"/workspace/src/routes/dashboards.ts","content":"import { Router, Response } from \"express\";\nimport { v4 as uuidv4 } from \"uuid\";\nimport type Database from \"better-sqlite3\";\nimport { AuthenticatedRequest, authMiddleware } from \"../auth.js\";\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\ninterface WidgetRow {\n  id: string;\n  dashboard_id: string;\n  type: string;\n  config: string;\n  position_x: number;\n  position_y: number;\n  width: number;\n  height: number;\n}\n\nfunction formatDashboard(row: DashboardRow, widgets?: WidgetRow[]) {\n  return {\n    id: row.id,\n    tenantId: row.tenant_id,\n    name: row.name,\n    ownerId: row.owner_id,\n    config: JSON.parse(row.config),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n    widgets: widgets\n      ? widgets.map((w) => ({\n          id: w.id,\n          dashboardId: w.dashboard_id,\n          type: w.type,\n          config: JSON.parse(w.config),\n          positionX: w.position_x,\n          positionY: w.position_y,\n          width: w.width,\n          height: w.height,\n        }))\n      : undefined,\n  };\n}\n\nexport function createDashboardRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // Create dashboard\n  router.post(\n    \"/\",\n    authMiddleware,\n    (req: AuthenticatedRequest, res: Response): void => {\n      const { name, config, widgets } = req.body;\n\n      if (!name) {\n        res.status(400).json({ error: \"Dashboard name is required\" });\n        return;\n      }\n\n      const id = uuidv4();\n      const now = new Date().toISOString();\n      const dashConfig = config ? JSON.stringify(config) : \"{}\";\n\n      db.prepare(\n        \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n      ).run(id, req.user!.tenantId, name, req.user!.userId, dashConfig, now, now);\n\n      // Insert widgets if provided\n      if (Array.isArray(widgets)) {\n        const insertWidget = db.prepare(\n          \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n        );\n        for (const w of widgets) {\n          insertWidget.run(\n            uuidv4(),\n            id,\n            w.type || \"counter\",\n            w.config ? JSON.stringify(w.config) : \"{}\",\n            w.positionX ?? 0,\n            w.positionY ?? 0,\n            w.width ?? 1,\n            w.height ?? 1\n          );\n        }\n      }\n\n      const row = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ?\")\n        .get(id) as DashboardRow;\n      const widgetRows = db\n        .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n        .all(id) as WidgetRow[];\n\n      res.status(201).json(formatDashboard(row, widgetRows));\n    }\n  );\n\n  // List dashboards for tenant\n  router.get(\n    \"/\",\n    authMiddleware,\n    (req: AuthenticatedRequest, res: Response): void => {\n      const rows = db\n        .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n        .all(req.user!.tenantId) as DashboardRow[];\n\n      res.json(rows.map((r) => formatDashboard(r)));\n    }\n  );\n\n  // Get single dashboard\n  router.get(\n    \"/:id\",\n    authMiddleware,\n    (req: AuthenticatedRequest, res: Response): void => {\n      const row = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n        .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n\n      if (!row) {\n        res.status(404).json({ error: \"Dashboard not found\" });\n        return;\n      }\n\n      const widgetRows = db\n        .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n        .all(row.id) as WidgetRow[];\n\n      res.json(formatDashboard(row, widgetRows));\n    }\n  );\n\n  // Update dashboard\n  router.put(\n    \"/:id\",\n    authMiddleware,\n    (req: AuthenticatedRequest, res: Response): void => {\n      const existing = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n        .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n\n      if (!existing) {\n        res.status(404).json({ error: \"Dashboard not found\" });\n        return;\n      }\n\n      const { name, config, widgets } = req.body;\n      const now = new Date().toISOString();\n\n      db.prepare(\n        \"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\"\n      ).run(\n        name || existing.name,\n        config ? JSON.stringify(config) : existing.config,\n        now,\n        req.params.id\n      );\n\n      // Replace widgets if provided\n      if (Array.isArray(widgets)) {\n        db.prepare(\"DELETE FROM widgets WHERE dashboard_id = ?\").run(req.params.id);\n        const insertWidget = db.prepare(\n          \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n        );\n        for (const w of widgets) {\n          insertWidget.run(\n            uuidv4(),\n            req.params.id,\n            w.type || \"counter\",\n            w.config ? JSON.stringify(w.config) : \"{}\",\n            w.positionX ?? 0,\n            w.positionY ?? 0,\n            w.width ?? 1,\n            w.height ?? 1\n          );\n        }\n      }\n\n      const updated = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ?\")\n        .get(req.params.id) as DashboardRow;\n      const widgetRows = db\n        .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n        .all(req.params.id) as WidgetRow[];\n\n      res.json(formatDashboard(updated, widgetRows));\n    }\n  );\n\n  // Delete dashboard\n  router.delete(\n    \"/:id\",\n    authMiddleware,\n    (req: AuthenticatedRequest, res: Response): void => {\n      const existing = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n        .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n\n      if (!existing) {\n        res.status(404).json({ error: \"Dashboard not found\" });\n        return;\n      }\n\n      db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(req.params.id);\n\n      res.status(204).send();\n    }\n  );\n\n  // Add widget to dashboard\n  router.post(\n    \"/:id/widgets\",\n    authMiddleware,\n    (req: AuthenticatedRequest, res: Response): void => {\n      const dashboard = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n        .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n\n      if (!dashboard) {\n        res.status(404).json({ error: \"Dashboard not found\" });\n        return;\n      }\n\n      const { type, config, positionX, positionY, width, height } = req.body;\n\n      if (!type || ![\"counter\", \"timeseries\", \"breakdown\", \"funnel\"].includes(type)) {\n        res.status(400).json({\n          error: \"Valid widget type is required (counter, timeseries, breakdown, funnel)\",\n        });\n        return;\n      }\n\n      const id = uuidv4();\n      db.prepare(\n        \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n      ).run(\n        id,\n        req.params.id,\n        type,\n        config ? JSON.stringify(config) : \"{}\",\n        positionX ?? 0,\n        positionY ?? 0,\n        width ?? 1,\n        height ?? 1\n      );\n\n      res.status(201).json({\n        id,\n        dashboardId: req.params.id,\n        type,\n        config: config || {},\n        positionX: positionX ?? 0,\n        positionY: positionY ?? 0,\n        width: width ?? 1,\n        height: height ?? 1,\n      });\n    }\n  );\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":364,"cache_read_input_tokens":27840,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":364},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a598cb02-66c9-4d65-b30a-e93d928ec327","uuid":"2daf6ef0-5751-4d16-bd65-d92d3fbe888f"}
