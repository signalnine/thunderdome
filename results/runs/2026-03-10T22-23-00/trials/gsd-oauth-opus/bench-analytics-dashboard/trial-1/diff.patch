epare(sql).all(...params) as BreakdownRow[];\n      res.json({\n        eventName,\n        property,\n        data: rows.map((r) => ({\n          value: r.value,\n          count: r.count,\n        })),\n      });\n    }\n  );\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
