d.name),\n        escapeCsvValue(d.owner_id),\n        escapeCsvValue(d.config),\n        escapeCsvValue(d.created_at),\n        escapeCsvValue(d.updated_at),\n      ].join(\",\")\n  );\n  return [header, ...rows].join(\"\\n\");\n}\n\nexport function createExportRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // Export events as JSON\n  router.get(\n    \"/events/json\",\n    authMiddleware,\n    (req: AuthenticatedRequest, res: Response): void => {\n      const { eventName, startDate, endDate } = req.query;\n\n      let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n      const params: string[] = [req.user!.tenantId];\n\n      if (eventName) {\n        sql += \" AND name = ?\";\n        params.push(eventName as string);\n      }\n\n      if (startDate) {\n        sql += \" AND timestamp >= ?\";\n        params.push(startDate as string);\n      }\n\n      if (endDate) {\n        sql += \" AND timestamp <= ?\";\n        params.push(endDate as string);\n      }\n\n      sql += \" ORDER BY timestamp DESC\";\n\n      const rows = db.prepare(sql).all(...params) as EventRow[];\n\n      const events = rows.map((r) => ({\n        id: r.id,\n        tenantId: r.tenant_id,\n        name: r.name,\n        properties: JSON.parse(r.properties),\n        timestamp: r.timestamp,\n        userId: r.user_id,\n        sessionId: r.session_id,\n      }));\n\n      res.setHeader(\"Content-Type\", \"application/json\");\n      res.setHeader(\n        \"Content-Disposition\",\n        'attachment; filename=\"events.json\"'\n      );\n      res.json({ events });\n    }\n  );\n\n  // Export events as CSV\n  router.get(\n    \"/events/csv\",\n    authMiddleware,\n    (req: AuthenticatedRequest, res: Response): void => {\n      const { eventName, startDate, endDate } = req.query;\n\n      let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n      const params: string[] = [req.user!.tenantId];\n\n      if (eventName) {\n        sql += \" AND name = ?\";\n        params.push(eventName as string);\n      }\n\n      if (startDate) {\n        sql += \" AND timestamp >= ?\";\n        params.push(startDate as string);\n      }\n\n      if (endDate) {\n        sql += \" AND timestamp <= ?\";\n        params.push(endDate as string);\n      }\n\n      sql += \" ORDER BY timestamp DESC\";\n\n      const rows = db.prepare(sql).all(...params) as EventRow[];\n\n      res.setHeader(\"Content-Type\", \"text/csv\");\n      res.setHeader(\n        \"Content-Disposition\",\n        'attachment; filename=\"events.csv\"'\n      );\n      res.send(eventsToCsv(rows));\n    }\n  );\n\n  // Export dashboards as JSON\n  router.get(\n    \"/dashboards/json\",\n    authMiddleware,\n    (req: AuthenticatedRequest, res: Response): void => {\n      const dashboards = db\n        .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ?\")\n        .all(req.user!.tenantId) as DashboardRow[];\n\n      const result = dashboards.map((d) => {\n        const widgets = db\n          .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n          .all(d.id) as WidgetRow[];\n\n        return {\n          id: d.id,\n          tenantId: d.tenant_id,\n          name: d.name,\n          ownerId: d.owner_id,\n          config: JSON.parse(d.config),\n          createdAt: d.created_at,\n          updatedAt: d.updated_at,\n          widgets: widgets.map((w) => ({\n            id: w.id,\n            type: w.type,\n            config: JSON.parse(w.config),\n            positionX: w.position_x,\n            positionY: w.position_y,\n            width: w.width,\n            height: w.height,\n          })),\n        };\n      });\n\n      res.setHeader(\"Content-Type\", \"application/json\");\n      res.setHeader(\n        \"Content-Disposition\",\n        'attachment; filename=\"dashboards.json\"'\n      );\n      res.json({ dashboards: result });\n    }\n  );\n\n  // Export dashboards as CSV\n  router.get(\n    \"/dashboards/csv\",\n    authMiddleware,\n    (req: