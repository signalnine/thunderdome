@@ -0,0 +1,228 @@
+import { Router, Response } from "express";
+import type Database from "better-sqlite3";
+import { AuthenticatedRequest, authMiddleware } from "../auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function escapeCsvValue(val: string): string {
+  if (val.includes(",") || val.includes('"') || val.includes("\n")) {
+    return `"${val.replace(/"/g, '""')}"`;
+  }
+  return val;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = "id,tenant_id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map(
+    (e) =>
+      [
+        escapeCsvValue(e.id),
+        escapeCsvValue(e.tenant_id),
+        escapeCsvValue(e.name),
+        escapeCsvValue(e.properties),
+        escapeCsvValue(e.timestamp),
+        escapeCsvValue(e.user_id || ""),
+        escapeCsvValue(e.session_id || ""),
+      ].join(",")
+  );
+  return [header, ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const header = "id,tenant_id,name,owner_id,config,created_at,updated_at";
+  const rows = dashboards.map(
+    (d) =>
+      [
+        escapeCsvValue(d.id),
+        escapeCsvValue(d.tenant_id),
+        escapeCsvValue(d.name),
+        escapeCsvValue(d.owner_id),
+        escapeCsvValue(d.config),
+        escapeCsvValue(d.created_at),
+        escapeCsvValue(d.updated_at),
+      ].join(",")
+  );
+  return [header, ...rows].join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get(
+    "/events/json",
+    authMiddleware,
+    (req: AuthenticatedRequest, res: Response): void => {
+      const { eventName, startDate, endDate } = req.query;
+
+      let sql = "SELECT * FROM events WHERE tenant_id = ?";
+      const params: string[] = [req.user!.tenantId];
+
+      if (eventName) {
+        sql += " AND name = ?";
+        params.push(eventName as string);
+      }
+
+      if (startDate) {
+        sql += " AND timestamp >= ?";
+        params.push(startDate as string);
+      }
+
+      if (endDate) {
+        sql += " AND timestamp <= ?";
+        params.push(endDate as string);
+      }
+
+      sql += " ORDER BY timestamp DESC";
+
+      const rows = db.prepare(sql).all(...params) as EventRow[];
+
+      const events = rows.map((r) => ({
+        id: r.id,
+        tenantId: r.tenant_id,
+        name: r.name,
+        properties: JSON.parse(r.properties),
+        timestamp: r.timestamp,
+        userId: r.user_id,
+        sessionId: r.session_id,
+      }));
+
+      res.setHeader("Content-Type", "application/json");
+      res.setHeader(
+        "Content-Disposition",
+        'attachment; filename="events.json"'
+      );
+      res.json({ events });
+    }
+  );
+
+  // Export events as CSV
+  router.get(
+    "/events/csv",
+    authMiddleware,
+    (req: AuthenticatedRequest, res: Response): void => {
+      const { eventName, startDate, endDate } = req.query;
+
+      let sql = "SELECT * FROM events WHERE tenant_id = ?";
+      const params: string[] = [req.user!.tenantId];
+
+      if (eventName) {
+        sql += " AND name = ?";
+        params.push(eventName as string);
+      }
+
+      if (startDate) {
+        sql += " AND timestamp >= ?";
+        params.push(startDate as string);
+      }
+
+      if (endDate) {
+        sql += " AND timestamp <= ?";
+        params.push(endDate as string);
+      }
+
+      sql += " ORDER BY timestamp DESC";
+
+      const rows = db.prepare(sql).all(...params) as EventRow[];
+
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader(
+        "Content-Disposition",
+        'attachment; filename="events.csv"'
+      );
+      res.send(eventsToCsv(rows));
+    }
+  );
+
+  // Export dashboards as JSON
+  router.get(
+    "/dashboards/json",
+    authMiddleware,
+    (req: AuthenticatedRequest, res: Response): void => {
+      const dashboards = db
+        .prepare("SELECT * FROM dashboards WHERE tenant_id = ?")
+        .all(req.user!.tenantId) as DashboardRow[];
+
+      const result = dashboards.map((d) => {
+        const widgets = db
+          .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+          .all(d.id) as WidgetRow[];
+
+        return {
+          id: d.id,
+          tenantId: d.tenant_id,
+          name: d.name,
+          ownerId: d.owner_id,
+          config: JSON.parse(d.config),
+          createdAt: d.created_at,
+          updatedAt: d.updated_at,
+          widgets: widgets.map((w) => ({
+            id: w.id,
+            type: w.type,
+            config: JSON.parse(w.config),
+            positionX: w.position_x,
+            positionY: w.position_y,
+            width: w.width,
+            height: w.height,
+          })),
+        };
+      });
+
+      res.setHeader("Content-Type", "application/json");
+      res.setHeader(
+        "Content-Disposition",
+        'attachment; filename="dashboards.json"'
+      );
+      res.json({ dashboards: result });
+    }
+  );
+
+  // Export dashboards as CSV
+  router.get(
+    "/dashboards/csv",
+    authMiddleware,
+    (req: AuthenticatedRequest, res: Response): void => {
+      const dashboards = db
+        .prepare("SELECT * FROM dashboards WHERE tenant_id = ?")
+        .all(req.user!.tenantId) as DashboardRow[];
+
+      res.setHeader("Content-Type", "text/csv");
+      res.setHeader(
+        "Content-Disposition",
+        'attachment; filename="dashboards.csv"'
+      );
+      res.send(dashboardsToCsv(dashboards));
+    }
+  );
+
+  return router;
+}
