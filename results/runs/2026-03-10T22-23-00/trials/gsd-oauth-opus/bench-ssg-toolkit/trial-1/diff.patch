 {\n    49→    const output = new Map<string, string>();\n    50→    output.set('tags/javascript.html', '<html>js tag page</html>');\n    51→    const tagMap = new Map<string, ContentFile[]>();\n    52→    tagMap.set('javascript', []);\n    53→    const data = new Map<string, unknown>();\n    54→    data.set('taxonomy-tags', tagMap);\n    55→    const ctx = makeCtx(output, data);\n    56→    await plugin.hooks.afterBuild!(ctx);\n    57→    const sitemap = ctx.output.get('sitemap.xml')!;\n    58→    expect(sitemap).toContain('https://example.com/tags/javascript.html');\n    59→  });\n    60→\n    61→  it('includes feed.xml URL', async () => {\n    62→    const output = new Map<string, string>();\n    63→    output.set('feed.xml', '<rss></rss>');\n    64→    const ctx = makeCtx(output);\n    65→    await plugin.hooks.afterBuild!(ctx);\n    66→    const sitemap = ctx.output.get('sitemap.xml')!;\n    67→    expect(sitemap).toContain('https://example.com/feed.xml');\n    68→  });\n    69→\n    70→  it('URLs use baseUrl from config', async () => {\n    71→    const output = new Map<string, string>();\n    72→    output.set('about.html', '<html></html>');\n    73→    const ctx = makeCtx(output);\n    74→    await plugin.hooks.afterBuild!(ctx);\n    75→    const sitemap = ctx.output.get('sitemap.xml')!;\n    76→    expect(sitemap).toContain('https://example.com/about.html');\n    77→  });\n    78→\n    79→  it('sitemap is valid XML structure', async () => {\n    80→    const output = new Map<string, string>();\n    81→    output.set('post.html', '<html></html>');\n    82→    const ctx = makeCtx(output);\n    83→    await plugin.hooks.afterBuild!(ctx);\n    84→    const sitemap = ctx.output.get('sitemap.xml')!;\n    85→    expect(sitemap).toContain('<?xml version=\"1.0\"');\n    86→    expect(sitemap).toContain('<urlset');\n    87→    expect(sitemap).toContain('</urlset>');\n    88→    expect(sitemap).toContain('<url>');\n    89→    expect(sitemap).toContain('<loc>');\n    90→  });\n    91→\n    92→  it('handles site with no tag pages', async () => {\n    93→    const output = new Map<string, string>();\n    94→    output.set('post.html', '<html></html>');\n    95→    const ctx = makeCtx(output);\n    96→    await plugin.hooks.afterBuild!(ctx);\n    97→    const sitemap = ctx.output.get('sitemap.xml')!;\n    98→    expect(sitemap).toContain('https://example.com/post.html');\n    99→    expect(sitemap).not.toContain('/tags/');\n   100→  });\n   101→});\n   102→"}]},"parent_tool_use_id":"toolu_011wYXYRqTApbJCzRKNRALob","session_id":"be3c0c0c-a2b9-4162-9663-02371e52e19a","uuid":"a5923bff-a4e4-470b-abd9-4219bbccd9ae"}
