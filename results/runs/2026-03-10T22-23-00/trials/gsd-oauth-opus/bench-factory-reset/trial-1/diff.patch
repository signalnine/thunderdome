+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  it('returns empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0], [1], [2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('returns null when no solution exists (example from spec)', () => {
+    // From the TASK.md example: target [T, T, F, T] with given buttons has no solution
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('solves a simple single-button case', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('solves with minimum presses', () => {
+    // Light 0 needs to be on.
+    // Button 0 toggles [0], Button 1 toggles [0]
+    // Either button alone works (1 press), pressing both cancels out.
+    // Should return [0] (lex smallest single press)
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('solves a 2-light 2-button case', () => {
+    // Lights: 2, Target: [true, true]
+    // Button 0: toggles [0, 1] -> pressing just button 0 gives [T, T]
+    // Button 1: toggles [0]
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('needs two buttons', () => {
+    // Target: [true, false, true]
+    // Button 0: toggles [0]
+    // Button 1: toggles [1]
+    // Button 2: toggles [2]
+    // Need buttons 0 and 2
+    const result = solveToggle({
+      target: [true, false, true],
+      buttons: [[0], [1], [2]],
+    });
+    expect(result).toEqual([0, 2]);
+  });
+
+  it('returns lexicographically smallest among tied solutions', () => {
+    // Target: [true]
+    // Button 0: toggles [0]
+    // Button 1: toggles [0]
+    // Both are single-press solutions. Lex smallest is [0].
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('handles overlapping buttons', () => {
+    // Target: [true, true, true]
+    // Button 0: toggles [0, 1]
+    // Button 1: toggles [1, 2]
+    // Button 2: toggles [0, 2]
+    // Press all three: light 0 toggled by 0,2 = on+on = off. Nope.
+    // Press 0 and 1: [T, T^T=F, T] = [T, F, T]. Nope.
+    // Press 0,1,2: light 0: b0^b2 = 1, light 1: b0^b1 = 1, light 2: b1^b2 = 1
+    // b0=1,b1=1,b2=1: l0=0, l1=0, l2=0. Nope.
+    // Let me work out the system:
+    // l0: b0 ^ b2 = 1
+    // l1: b0 ^ b1 = 1
+    // l2: b1 ^ b2 = 1
+    // From l0: b2 = 1^b0. From l1: b1 = 1^b0. From l2: (1^b0) ^ (1^b0) = 0 ≠ 1.
+    // No solution!
+    const result = solveToggle({
+      target: [true, true, true],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('handles the case where no buttons are needed', () => {
+    const result = solveToggle({
+      target: [false, false],
+      buttons: [[0], [1]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('handles empty buttons array', () => {
+    const result = solveToggle({
+      target: [false],
+      buttons: [],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('returns null with empty buttons but non-zero target', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('handles larger example', () => {
+    // 5 lights, 5 buttons (identity-like)
+    const result = solveToggle({
+      target: [true, false, true, false, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    });
+    expect(result).toEqual([0, 2, 4]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0], [1], [2]], 5);
+    expect(result).toEqual([0, 0, 0]);
+  });
+
+  it('solves a simple single-button case', () => {
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('returns null when no solution exists', () => {
+    // Target: counter 0 = 1, counter 1 = 0
+    // Button 0 affects both [0, 1]
+    // Can't set counter 0 to 1 without also setting counter 1 to 1
+    const result = solveCounter([1, 0], [[0, 1]], 5);
+    expect(result).toBeNull();
+  });
+
+  it('solves with minimum total presses', () => {
+    // Target: [1], modulus 5
+    // Button 0 affects [0], Button 1 affects [0]
+    // Solutions: b0+b1 ≡ 1 (mod 5)
+    // (1,0) sum=1, (0,1) sum=1, (2,4) sum=6, (3,3) sum=6, (4,2) sum=6
+    // Minimum sum = 1, lex smallest = [0, 1]
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('handles modular arithmetic', () => {
+    // Target: [0], modulus 3
+    // Button 0 affects [0]
+    // 0 presses gives 0. Minimum is 0.
+    const result = solveCounter([0], [[0]], 3);
+    expect(result).toEqual([0]);
+  });
+
+  it('handles two buttons two counters', () => {
+    // Target: [2, 3], modulus 5
+    // Button 0 affects [0], Button 1 affects [1]
+    // Solution: [2, 3]
+    const result = solveCounter([2, 3], [[0], [1]], 5);
+    expect(result).toEqual([2, 3]);
+  });
+
+  it('handles overlapping buttons', () => {
+    // Target: [1, 1], modulus 3
+    // Button 0 affects [0, 1] -> both counters +1
+    // Just press button 0 once: [1, 1]. Done.
+    const result = solveCounter([1, 1], [[0, 1]], 3);
+    expect(result).toEqual([1]);
+  });
+
+  it('solves with modulus 2 (binary case)', () => {
+    // Similar to toggle but with counter semantics
+    const result = solveCounter([1, 0, 1], [[0], [1], [2]], 2);
+    expect(result).toEqual([1, 0, 1]);
+  });
+
+  it('returns null with no buttons and non-zero target', () => {
+    const result = solveCounter([1], [], 5);
+    expect(result).toBeNull();
+  });
+
+  it('returns empty array when no buttons and target is zeros', () => {
+    const result = solveCounter([0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  it('handles larger modulus', () => {
+    // Target: [50], modulus 97
+    // Button 0 affects [0]
+    // Press 50 times
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+  });
+
+  it('prefers lexicographically smallest when tied on sum', () => {
+    // Target: [2], modulus 5
+    // Button 0 affects [0], Button 1 affects [0]
+    // b0 + b1 ≡ 2 (mod 5)
+    // Solutions with min sum: (0,2) sum=2, (1,1) sum=2, (2,0) sum=2
+    // Lex smallest: [0, 2]
+    const result = solveCounter([2], [[0], [0]], 5);
+    expect(result).toEqual([0, 2]);
+  });
