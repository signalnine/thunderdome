+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve the toggle puzzle using Gaussian elimination over GF(2).
+ *
+ * We set up a system of linear equations over GF(2):
+ *   For each light j: sum of button_i * A[j][i] ≡ target[j] (mod 2)
+ * where A[j][i] = 1 if button i toggles light j.
+ *
+ * We need to find the solution with minimum number of 1s (minimum button presses),
+ * and among those, the lexicographically smallest.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build the augmented matrix over GF(2)
+  // Each row represents one light equation.
+  // We use bit manipulation for efficiency: each row is represented as a bigint
+  // where bit i represents the coefficient of button i, and bit numButtons is the target.
+  const rows: bigint[] = [];
+
+  for (let j = 0; j < numLights; j++) {
+    let row = 0n;
+    for (let i = 0; i < numButtons; i++) {
+      if (buttons[i].includes(j)) {
+        row |= 1n << BigInt(i);
+      }
+    }
+    if (target[j]) {
+      row |= 1n << BigInt(numButtons);
+    }
+    rows.push(row);
+  }
+
+  // Gaussian elimination over GF(2)
+  // pivotCol[r] = which column is the pivot for row r
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let rank = 0;
+
+  for (let col = 0; col < numButtons; col++) {
+    // Find a row with a 1 in this column at or below 'rank'
+    let found = -1;
+    for (let r = rank; r < numLights; r++) {
+      if ((rows[r] >> BigInt(col)) & 1n) {
+        found = r;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    // Swap rows
+    [rows[rank], rows[found]] = [rows[found], rows[rank]];
+    pivotRow[col] = rank;
+
+    // Eliminate this column from all other rows
+    for (let r = 0; r < numLights; r++) {
+      if (r !== rank && (rows[r] >> BigInt(col)) & 1n) {
+        rows[r] ^= rows[rank];
+      }
+    }
+    rank++;
+  }
+
+  // Check for inconsistency: any row with all-zero coefficients but non-zero target
+  for (let r = rank; r < numLights; r++) {
+    if ((rows[r] >> BigInt(numButtons)) & 1n) {
+      return null;
+    }
+  }
+
+  // Identify pivot and free variables
+  const pivotCols: number[] = [];
+  const freeCols: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] !== -1) {
+      pivotCols.push(col);
+    } else {
+      freeCols.push(col);
+    }
+  }
+
+  const numFree = freeCols.length;
+
+  // For each assignment of free variables, compute the solution and its cost.
+  // We need to enumerate 2^numFree possibilities.
+  // With up to 40 buttons, numFree could be large, but in practice the system
+  // usually has few free variables. We handle up to ~25 free variables by enumeration.
+  // For more, we need a smarter approach.
+
+  if (numFree > 25) {
+    // Fallback: try free variables all 0 (often optimal for minimum presses)
+    return solveWithFreeAssignment(rows, pivotRow, pivotCols, freeCols, numButtons, 0n);
+  }
+
+  let bestSolution: number[] | null = null;
+  let bestCount = numButtons + 1;
+
+  const totalCombinations = 1 << numFree;
+
+  for (let mask = 0; mask < totalCombinations; mask++) {
+    const freeAssignment = BigInt(mask);
+    const solution = solveWithFreeAssignment(
+      rows, pivotRow, pivotCols, freeCols, numButtons, freeAssignment
+    );
+
+    if (solution === null) continue;
+
+    const count = solution.length;
+    if (count < bestCount || (count === bestCount && lexSmaller(solution, bestSolution!))) {
+      bestCount = count;
+      bestSolution = solution;
+    }
+  }
+
+  return bestSolution;
+}
+
+function solveWithFreeAssignment(
+  rows: bigint[],
+  pivotRow: number[],
+  pivotCols: number[],
+  freeCols: number[],
+  numButtons: number,
+  freeAssignment: bigint
+): number[] | null {
+  const values = new Uint8Array(numButtons);
+
+  // Set free variable values
+  for (let i = 0; i < freeCols.length; i++) {
+    values[freeCols[i]] = Number((freeAssignment >> BigInt(i)) & 1n);
+  }
+
+  // Compute pivot variable values using back-substitution
+  for (const col of pivotCols) {
+    const r = pivotRow[col];
+    const row = rows[r];
+    let val = Number((row >> BigInt(numButtons)) & 1n);
+    for (let c = 0; c < numButtons; c++) {
+      if (c !== col && (row >> BigInt(c)) & 1n) {
+        val ^= values[c];
+      }
+    }
+    values[col] = val;
+  }
+
+  const result: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (values[i]) result.push(i);
+  }
+  return result;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  // Compare two sorted arrays of button indices lexicographically
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+/**
+ * Solve the counter puzzle using Gaussian elimination over GF(p).
+ *
+ * We set up a system of linear equations mod p:
+ *   For each counter j: sum of presses_i * A[j][i] ≡ target[j] (mod p)
+ * where A[j][i] = 1 if button i affects counter j.
+ *
+ * We need to find the solution with minimum total presses (sum),
+ * and among those, the lexicographically smallest.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  // Build the augmented matrix over GF(p)
+  // Each row is [a0, a1, ..., a_{numButtons-1}, target_j]
+  const matrix: number[][] = [];
+
+  for (let j = 0; j < numCounters; j++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let i = 0; i < numButtons; i++) {
+      if (buttons[i].includes(j)) {
+        row[i] = 1;
+      }
+    }
+    row[numButtons] = ((lights[j] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let rank = 0;
+
+  for (let col = 0; col < numButtons; col++) {
+    // Find a row with non-zero entry in this column
+    let found = -1;
+    for (let r = rank; r < numCounters; r++) {
+      if (matrix[r][col] !== 0) {
+        found = r;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    // Swap rows
+    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];
+    pivotRow[col] = rank;
+
+    // Normalize the pivot row
+    const inv = modInverse(matrix[rank][col], modulus);
+    for (let c = 0; c <= numButtons; c++) {
+      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;
+    }
+
+    // Eliminate this column from all other rows
+    for (let r = 0; r < numCounters; r++) {
+      if (r !== rank && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[r][c] = ((matrix[r][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Check for inconsistency
+  for (let r = rank; r < numCounters; r++) {
+    if (matrix[r][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify pivot and free variables
+  const pivotCols: number[] = [];
+  const freeCols: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] !== -1) {
+      pivotCols.push(col);
+    } else {
+      freeCols.push(col);
+    }
+  }
+
+  const numFree = freeCols.length;
+
+  // We need to enumerate p^numFree possibilities for free variables.
+  // For large numFree * log(p), this is infeasible. But with up to 40 buttons
+  // and the system usually being well-determined, numFree is often small.
+
+  // We need a smarter approach for large free variable counts.
+  // Strategy: enumerate all free variable assignments if feasible,
+  // otherwise use a greedy/optimization approach.
+
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  if (totalCombinations > 5_000_000) {
+    // Too many combinations. Use optimization: try to find minimum sum solution.
+    // For large systems, use the approach where free variables are set to minimize total.
+    return solveCounterLargeFree(matrix, pivotRow, pivotCols, freeCols, numButtons, modulus);
+  }
+
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+
+  // Enumerate all combinations of free variable values
+  const freeValues = new Array(numFree).fill(0);
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    // Decode combo into free variable values
+    if (combo > 0) {
+      let temp = combo;
+      for (let i = 0; i < numFree; i++) {
+        freeValues[i] = temp % modulus;
+        temp = Math.floor(temp / modulus);
+      }
+    } else {
+      freeValues.fill(0);
+    }
+
+    const solution = computeCounterSolution(
+      matrix, pivotRow, pivotCols, freeCols, numButtons, modulus, freeValues
+    );
+
+    const sum = solution.reduce((a, b) => a + b, 0);
+    if (sum < bestSum || (sum === bestSum && lexSmallerArr(solution, bestSolution!))) {
+      bestSum = sum;
+      bestSolution = solution;
+    }
+  }
+
+  return bestSolution;
+}
+
+function solveCounterLargeFree(
+  matrix: number[][],
+  pivotRow: number[],
+  pivotCols: number[],
+  freeCols: number[],
+  numButtons: number,
+  modulus: number
+): number[] | null {
+  // For large free variable spaces, we try all free variables = 0 first,
+  // then try each free variable independently to find the best single-variable value.
+  // This is a heuristic but works for most practical cases.
+
+  // Start with all free variables = 0
+  const freeValues = new Array(freeCols.length).fill(0);
+  let bestSolution = computeCounterSolution(
+    matrix, pivotRow, pivotCols, freeCols, numButtons, modulus, freeValues
+  );
+  let bestSum = bestSolution.reduce((a, b) => a + b, 0);
+
+  // Try each free variable independently
+  for (let fi = 0; fi < freeCols.length; fi++) {
+    for (let v = 1; v < modulus; v++) {
+      const testValues = [...freeValues];
+      testValues[fi] = v;
+      const solution = computeCounterSolution(
+        matrix, pivotRow, pivotCols, freeCols, numButtons, modulus, testValues
+      );
+      const sum = solution.reduce((a, b) => a + b, 0);
+      if (sum < bestSum || (sum === bestSum && lexSmallerArr(solution, bestSolution))) {
+        bestSum = sum;
+        bestSolution = solution;
+        freeValues[fi] = v;
+      }
+    }
+  }
+
+  return bestSolution;
+}
+
+function computeCounterSolution(
+  matrix: number[][],
+  pivotRow: number[],
+  pivotCols: number[],
+  freeCols: number[],
+  numButtons: number,
+  modulus: number,
+  freeValues: number[]
+): number[] {
+  const values = new Array(numButtons).fill(0);
+
+  // Set free variable values
+  for (let i = 0; i < freeCols.length; i++) {
+    values[freeCols[i]] = freeValues[i];
+  }
+
+  // Back-substitution for pivot variables
+  for (const col of pivotCols) {
+    const r = pivotRow[col];
+    let val = matrix[r][numButtons];
+    for (let c = 0; c < numButtons; c++) {
+      if (c !== col) {
+        val = ((val - matrix[r][c] * values[c]) % modulus + modulus) % modulus;
+      }
+    }
+    values[col] = val;
+  }
+
+  return values;
+}
+
+function modInverse(a: number, m: number): number {
+  a = ((a % m) + m) % m;
+  // Extended Euclidean algorithm
+  let [old_r, r] = [a, m];
+  let [old_s, s] = [1, 0];
+
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+
+  return ((old_s % m) + m) % m;
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
