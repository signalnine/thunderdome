te) {","+              const realCarry = otherInput(nextSumGate, nextPS);","               swapOutputs(carry, realCarry);","-              rebuildLookups();","               carry = realCarry;","             }","           }"]}],"originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  let changed = true;\n  while (changed && remaining.length > 0) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        let result: number;\n        switch (gate.op) {\n          case 'AND':\n            result = a & b;\n            break;\n          case 'OR':\n            result = a | b;\n            break;\n          case 'XOR':\n            result = a ^ b;\n            break;\n        }\n        wires[gate.out] = result;\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Determine how many input bits we have\n  const inputBits = new Set<number>();\n  for (const gate of gates) {\n    for (const wire of [gate.in1, gate.in2]) {\n      const xMatch = wire.match(/^x(\\d+)$/);\n      if (xMatch) inputBits.add(parseInt(xMatch[1], 10));\n    }\n  }\n  const N = Math.max(...inputBits) + 1;\n\n  // Build lookup structures\n  // Map from output wire to gate\n  const outToGate = new Map<string, Gate>();\n  for (const gate of gates) {\n    outToGate.set(gate.out, gate);\n  }\n\n  // Find gate by inputs and op\n  function findGate(op: string, in1: string, in2: string): Gate | undefined {\n    return gates.find(g =>\n      g.op === op &&\n      ((g.in1 === in1 && g.in2 === in2) || (g.in1 === in2 && g.in2 === in1))\n    );\n  }\n\n  // For a ripple-carry adder, the structure for each bit i is:\n  // Bit 0 (half adder):\n  //   x00 XOR y00 -> z00\n  //   x00 AND y00 -> c00\n  //\n  // Bit i > 0 (full adder):\n  //   x_i XOR y_i -> t_i       (partial sum)\n  //   t_i XOR c_{i-1} -> z_i   (final sum)\n  //   x_i AND y_i -> a_i       (generate)\n  //   t_i AND c_{i-1} -> b_i   (propagate carry)\n  //   a_i OR b_i -> c_i        (carry out)\n  //\n  // Final: c_{N-1} -> z_N (the last carry becomes the MSB output)\n\n  // Strategy: Walk the adder structure bit by bit. At each bit, identify what\n  // wire *should* be there and check if it matches. When there's a mismatch,\n  // we've found a swap.\n\n  const swapped = new Set<string>();\n\n  // Helper: swap two gate outputs\n  function swapOutputs(w1: string, w2: string): void {\n    const g1 = gates.find(g => g.out === w1)!;\n    const g2 = gates.find(g => g.out === w2)!;\n    g1.out = w2;\n    g2.out = w1;\n    swapped.add(w1);\n    swapped.add(w2);\n  }\n\n  // We'll work with a mutable copy approach - actually mutate gates to fix swaps\n  // as we find them, which lets us trace the rest of the circuit correctly.\n\n  // Rebuild lookup after each swap\n  function rebuildLookups(): void {\n    outToGate.clear();\n    for (const gate of gates) {\n      outToGate.set(gate.out, gate);\n    }\n  }\n\n  function pad(n: number): string {\n    return n.toString().padStart(2, '0');\n  }\n\n  // Find a gate that uses given inputs (in any order) with given op\n  function findGateByInputsAndOp(op: string, a: string, b: string): Gate | undefined {\n    return gates.find(g =>\n      g.op === op &&\n      ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a))\n    );\n  }\n\n  // Find a gate that uses a particular wire as input with a given op\n  function findGateUsingInputWithOp(wire: string, op: string): Gate | undefined {\n    return gates.find(g => g.op === op && (g.in1 === wire || g.in2 === wire));\n  }\n\n  // Get the other input of a gate\n  function otherInput(gate: Gate, wire: string): string {\n    return gate.in1 === wire ? gate.in2 : gate.in1;\n  }\n\n  let carry: string | undefined;\n\n  // Process bit 0: half adder\n  {\n    const x = `x${pad(0)}`;\n    const y = `y${pad(0)}`;\n    const z = `z${pad(0)}`;\n\n    // x XOR y -> z00\n    const xorGate = findGateByInputsAndOp('XOR', x, y);\n    if (xorGate) {\n      if (xorGate.out !== z) {\n        // xorGate.out and z are swapped\n        swapOutputs(xorGate.out, z);\n        rebuildLookups();\n      }\n    }\n\n    // x AND y -> carry\n    const andGate = findGateByInputsAndOp('AND', x, y);\n    if (andGate) {\n      carry = andGate.out;\n    }\n  }\n\n  // Process bits 1..N-1: full adders\n  for (let i = 1; i < N; i++) {\n    const x = `x${pad(i)}`;\n    const y = `y${pad(i)}`;\n    const z = `z${pad(i)}`;\n\n    // Step 1: Find x_i XOR y_i -> t_i (partial sum)\n    let xorXY = findGateByInputsAndOp('XOR', x, y);\n    if (!xorXY) {\n      // This shouldn't happen in a valid adder with swaps, but handle gracefully\n      continue;\n    }\n    let partialSum = xorXY.out;\n\n    // Step 2: Find t_i XOR carry -> z_i (final sum)\n    // The XOR gate that uses partialSum should produce z_i\n    let xorCarry = findGateByInputsAndOp('XOR', partialSum, carry!);\n\n    if (!xorCarry) {\n      // If we can't find XOR(partialSum, carry), then either partialSum or carry\n      // might be swapped. Let's check:\n      // Find any XOR gate that uses carry - if it exists, its other input should be partialSum\n      const xorWithCarry = findGateUsingInputWithOp(carry!, 'XOR');\n      if (xorWithCarry) {\n        // The other input of this gate should have been partialSum but isn't\n        // So partialSum wire is swapped with something\n        const correctPartialSum = otherInput(xorWithCarry, carry!);\n        // partialSum and correctPartialSum are 