out: 'c' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1 });\n    expect(result.c).toBe(1);\n    expect(result.a).toBe(1);\n    expect(result.b).toBe(1);\n  });\n\n  it('should evaluate AND gate with 0 input', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(0);\n    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n  });\n\n  it('should evaluate a simple OR gate', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);\n    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n  });\n\n  it('should evaluate a simple XOR gate', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);\n    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    expect(result.c).toBe(1);\n    expect(result.e).toBe(1);\n  });\n\n  it('should simulate a 4-bit adder (0+0)', () => {\n    const gates = make4BitAdder();\n    const inputs: Record<string, number> = {};\n    for (let i = 0; i < 4; i++) {\n      inputs[`x${i.toString().padStart(2, '0')}`] = 0;\n      inputs[`y${i.toString().padStart(2, '0')}`] = 0;\n    }\n    const result = simulate(gates, inputs);\n    for (let i = 0; i <= 4; i++) {\n      expect(result[`z${i.toString().padStart(2, '0')}`]).toBe(0);\n    }\n  });\n\n  it('should simulate a 4-bit adder (5+3=8)', () => {\n    const gates = make4BitAdder();\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 0, x02: 1, x03: 0,\n      y00: 1, y01: 1, y02: 0, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    // 8 = 01000\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(0);\n  });\n\n  it('should simulate a 4-bit adder (15+15=30)', () => {\n    const gates = make4BitAdder();\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 1, x03: 1,\n      y00: 1, y01: 1, y02: 1, y03: 1,\n    };\n    const result = simulate(gates, inputs);\n    // 30 = 11110\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(1);\n  });\n\n  it('should simulate the example from AoC 2024 Day 24', () => {\n    // Smaller example from AoC\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'z01' },\n      { op: 'OR', in1: 'x02', in2: 'y02', out: 'z02' },\n    ];\n    const inputs = {\n      x00: 1, x01: 1, x02: 1,\n      y00: 0, y01: 0, y02: 1,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0); // 1 AND 0\n    expect(result.z01).toBe(1); // 1 XOR 0\n    expect(result.z02).toBe(1); // 1 OR 1\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  it('should find swapped wires when z outputs are swapped with internal wires', () => {\n    // Make a bigger adder (8-bit) so we have room for 4 swaps\n    const gates = makeNBitAdder(8);\n\n    // Verify the adder works before swapping\n    verifyAdder(gates, 8);\n\n    // Swap 1: z01 <-> a01 (z output swapped with generate)\n    swapGateOutputs(gates, 'z01', 'a01');\n    // Swap 2: z03 <-> c02 (z output swapped with carry)\n    swapGateOutputs(gates, 'z03', 'c02');\n    // Swap 3: z05 <-> a05 (z output swapped with generate)\n    swapGateOutputs(gates, 'z05', 'a05');\n    // Swap 4: z07 <-> b07 (z output swapped with propagate)\n    swapGateOutputs(gates, 'z07', 'b07');\n\n    const