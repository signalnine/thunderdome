+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (changed && remaining.length > 0) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Work on a mutable copy of gates
+  const gatesCopy: Gate[] = gates.map(g => ({ ...g }));
+
+  // Determine how many input bits we have
+  const inputBits = new Set<number>();
+  for (const gate of gatesCopy) {
+    for (const wire of [gate.in1, gate.in2]) {
+      const xMatch = wire.match(/^x(\d+)$/);
+      if (xMatch) inputBits.add(parseInt(xMatch[1], 10));
+    }
+  }
+  const N = Math.max(...inputBits) + 1;
+
+  const swapped = new Set<string>();
+
+  function pad(n: number): string {
+    return n.toString().padStart(2, '0');
+  }
+
+  // Helper: swap two gate outputs in gatesCopy and record them
+  function swapOutputs(w1: string, w2: string): void {
+    const g1 = gatesCopy.find(g => g.out === w1)!;
+    const g2 = gatesCopy.find(g => g.out === w2)!;
+    g1.out = w2;
+    g2.out = w1;
+    swapped.add(w1);
+    swapped.add(w2);
+  }
+
+  // Find gate by op and exactly these two inputs (order-independent)
+  function findGate(op: string, a: string, b: string): Gate | undefined {
+    return gatesCopy.find(g =>
+      g.op === op &&
+      ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a))
+    );
+  }
+
+  // Find gate that uses wire as one of its inputs with given op
+  function findGateWithInput(wire: string, op: string, exclude?: Gate): Gate | undefined {
+    return gatesCopy.find(g =>
+      g.op === op && g !== exclude &&
+      (g.in1 === wire || g.in2 === wire)
+    );
+  }
+
+  // Get the other input of a gate given one input
+  function otherInput(gate: Gate, wire: string): string {
+    return gate.in1 === wire ? gate.in2 : gate.in1;
+  }
+
+  // Trace the adder structure bit by bit
+  let carry: string | undefined;
+
+  // === Bit 0: Half adder ===
+  // XOR(x00, y00) -> z00
+  // AND(x00, y00) -> carry
+  {
+    const xorGate = findGate('XOR', 'x00', 'y00');
+    if (xorGate && xorGate.out !== 'z00') {
+      swapOutputs(xorGate.out, 'z00');
+    }
+
+    const andGate = findGate('AND', 'x00', 'y00');
+    carry = andGate?.out;
+  }
+
+  // === Bits 1..N-1: Full adders ===
+  for (let i = 1; i < N && carry; i++) {
+    const xi = `x${pad(i)}`;
+    const yi = `y${pad(i)}`;
+    const zi = `z${pad(i)}`;
+
+    // 1) Find XOR(xi, yi) -> partialSum
+    const xorXY = findGate('XOR', xi, yi);
+    if (!xorXY) continue;
+    let partialSum = xorXY.out;
+
+    // 2) Find XOR(partialSum, carry) -> zi
+    let sumGate = findGate('XOR', partialSum, carry);
+
+    if (!sumGate) {
+      // Either partialSum or carry is wrong (swapped with something else).
+      // Try finding XOR that uses partialSum (other than xorXY) first, since
+      // partialSum is more reliably identified (direct output of XOR(xi, yi)):
+      const xorUsingPS = findGateWithInput(partialSum, 'XOR', xorXY);
+      if (xorUsingPS) {
+        // partialSum is correct. The other input should be carry but isn't.
+        const expectedCarry = otherInput(xorUsingPS, partialSum);
+        swapOutputs(carry, expectedCarry);
+        carry = expectedCarry;
+        sumGate = xorUsingPS;
+      } else {
+        // partialSum is not used by any other XOR gate - it must be swapped.
+        // Find the XOR gate that uses carry (this should be the sum gate for this bit):
+        const xorUsingCarry = findGateWithInput(carry, 'XOR');
+        if (xorUsingCarry) {
+          const expectedPartialSum = otherInput(xorUsingCarry, carry);
+          swapOutputs(partialSum, expectedPartialSum);
+          partialSum = expectedPartialSum;
+          sumGate = xorUsingCarry;
+        }
+      }
+    }
+
+    // 3) Check that sumGate outputs zi
+    if (sumGate && sumGate.out !== zi) {
+      swapOutputs(sumGate.out, zi);
+    }
+
+    // 4) Find AND(xi, yi) -> generate
+    const andXY = findGate('AND', xi, yi);
+    const generate = andXY?.out;
+
+    // 5) Find AND(partialSum, carry) -> propagate
+    const andCarry = findGate('AND', partialSum, carry);
+    const propagate = andCarry?.out;
+
+    // 6) Find OR(generate, propagate) -> newCarry
+    if (generate && propagate) {
+      let orGate = findGate('OR', generate, propagate);
+      if (!orGate) {
+        // One of generate/propagate is swapped
+        const orUsingGen = findGateWithInput(generate, 'OR');
+        if (orUsingGen) {
+          const expectedProp = otherInput(orUsingGen, generate);
+          swapOutputs(propagate, expectedProp);
+          orGate = orUsingGen;
+        } else {
+          const orUsingProp = findGateWithInput(propagate, 'OR');
+          if (orUsingProp) {
+            const expectedGen = otherInput(orUsingProp, propagate);
+            swapOutputs(generate, expectedGen);
+            orGate = orUsingProp;
+          }
+        }
+      }
+
+      if (orGate) {
+        carry = orGate.out;
+
+        // The carry output should NOT be a z-wire (unless it's the final carry z_N)
+        const zFinal = `z${pad(N)}`;
+        if (carry.startsWith('z') && carry !== zFinal) {
+          // This carry is incorrectly a z-wire. Need to find what it was swapped with.
+          // The real z-wire for carry's z-number should come from an XOR gate.
+          // Find the gate currently outputting the wire that should be our carry.
+          // Strategy: look at the next bit's XOR to find the real carry name.
+          const nextXi = `x${pad(i + 1)}`;
+          const nextYi = `y${pad(i + 1)}`;
+          const nextXorXY = findGate('XOR', nextXi, nextYi);
+          if (nextXorXY) {
+            const nextPS = nextXorXY.out;
+            // Find XOR using nextPS (other than nextXorXY) - its other input is the real carry
+            const nextSumGate = findGateWithInput(nextPS, 'XOR', nextXorXY);
+            if (nextSumGate) {
+              const realCarry = otherInput(nextSumGate, nextPS);
+              swapOutputs(carry, realCarry);
+              carry = realCarry;
+            }
+          }
+        }
+      }
+    }
+  }
+
+  // Check the final carry: it should be z_N
+  const zFinal = `z${pad(N)}`;
+  if (carry && carry !== zFinal) {
+    // The final carry wire should be z_N but it's something else
+    // This means carry and z_N are swapped
+    swapOutputs(carry, zFinal);
+  }
+
+  return [...swapped].sort();
+}
