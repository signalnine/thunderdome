e that uses a particular wire as input with a given op\n  function findGateUsingInputWithOp(wire: string, op: string): Gate | undefined {\n    return gates.find(g => g.op === op && (g.in1 === wire || g.in2 === wire));\n  }\n\n  // Get the other input of a gate\n  function otherInput(gate: Gate, wire: string): string {\n    return gate.in1 === wire ? gate.in2 : gate.in1;\n  }\n\n  let carry: string | undefined;\n\n  // Process bit 0: half adder\n  {\n    const x = `x${pad(0)}`;\n    const y = `y${pad(0)}`;\n    const z = `z${pad(0)}`;\n\n    // x XOR y -> z00\n    const xorGate = findGateByInputsAndOp('XOR', x, y);\n    if (xorGate) {\n      if (xorGate.out !== z) {\n        // xorGate.out and z are swapped\n        swapOutputs(xorGate.out, z);\n        rebuildLookups();\n      }\n    }\n\n    // x AND y -> carry\n    const andGate = findGateByInputsAndOp('AND', x, y);\n    if (andGate) {\n      carry = andGate.out;\n    }\n  }\n\n  // Process bits 1..N-1: full adders\n  for (let i = 1; i < N; i++) {\n    const x = `x${pad(i)}`;\n    const y = `y${pad(i)}`;\n    const z = `z${pad(i)}`;\n\n    // Step 1: Find x_i XOR y_i -> t_i (partial sum)\n    let xorXY = findGateByInputsAndOp('XOR', x, y);\n    if (!xorXY) {\n      // This shouldn't happen in a valid adder with swaps, but handle gracefully\n      continue;\n    }\n    let partialSum = xorXY.out;\n\n    // Step 2: Find t_i XOR carry -> z_i (final sum)\n    // The XOR gate that uses partialSum should produce z_i\n    let xorCarry = findGateByInputsAndOp('XOR', partialSum, carry!);\n\n    if (!xorCarry) {\n      // If we can't find XOR(partialSum, carry), then either partialSum or carry\n      // might be swapped. Let's check:\n      // Find any XOR gate that uses carry - if it exists, its other input should be partialSum\n      const xorWithCarry = findGateUsingInputWithOp(carry!, 'XOR');\n      if (xorWithCarry) {\n        // The other input of this gate should have been partialSum but isn't\n        // So partialSum wire is swapped with something\n        const correctPartialSum = otherInput(xorWithCarry, carry!);\n        // partialSum and correctPartialSum are swapped\n        swapOutputs(partialSum, correctPartialSum);\n        rebuildLookups();\n        partialSum = correctPartialSum;\n        xorCarry = xorWithCarry;\n      } else {\n        // No XOR gate uses carry - carry might be swapped\n        // Find XOR gate that uses partialSum (other than xorXY)\n        const xorWithPartial = gates.find(g =>\n          g.op === 'XOR' && g !== xorXY &&\n          (g.in1 === partialSum || g.in2 === partialSum)\n        );\n        if (xorWithPartial) {\n          const correctCarry = otherInput(xorWithPartial, partialSum);\n          swapOutputs(carry!, correctCarry);\n          rebuildLookups();\n          carry = correctCarry;\n          xorCarry = xorWithPartial;\n        }\n      }\n    }\n\n    if (xorCarry) {\n      if (xorCarry.out !== z) {\n        // The output should be z_i but it's something else - swap needed\n        swapOutputs(xorCarry.out, z);\n        rebuildLookups();\n      }\n    }\n\n    // Step 3: Find x_i AND y_i -> a_i (generate carry)\n    let andXY = findGateByInputsAndOp('AND', x, y);\n    let generate = andXY ? andXY.out : undefined;\n\n    // Step 4: Find t_i AND carry -> b_i (propagate carry)\n    let andCarry = findGateByInputsAndOp('AND', partialSum, carry!);\n    let propagate = andCarry ? andCarry.out : undefined;\n\n    // Step 5: Find a_i OR b_i -> c_i (carry out)\n    if (generate && propagate) {\n      let orGate = findGateByInputsAndOp('OR', generate, propagate);\n      if (!orGate) {\n        // One of generate or propagate might be swapped\n        // Find OR gate that uses generate\n        const orWithGen = findGateUsingInputWithOp(generate, 'OR');\n        if (orWithGen) {\n          const correctPropagate = otherInput(orWithGen, generate);\n          swapOutputs(propagate, correctPropagate);\n          rebuildLookups();\n          propagate = correctPropagate;\n          orGate = orWithGen;\n        } else {\n          // Find OR gate that uses propagate\n          const orWithProp = findGateUsingInputWithOp(propagate, 'OR');\n          if (orWithProp) {\n            const correctGenerate = otherInput(orWithProp, propagate);\n            swapOutputs(generate, correctGenerate);\n            rebuildLookups();\n            generate = correctGenerate;\n            orGate = orWithProp;\n          }\n        }\n      }\n      if (orGate) {\n        carry = orGate.out;\n        // Check if carry is z_something when it shouldn't be (except for the final bit)\n        if (i < N - 1 && carry.startsWith('z')) {\n          // carry shouldn't be a z wire (except the last one z_N)\n          // Find what z wire this is and what should be there\n          // The gate that should output this z wire must be swapped with this carry\n          // Actually, this carry = z?? is wrong. We need to find what wire the OR gate\n          // should output to. Look for the next bit's usage or just find the gate\n          // that currently outputs what should be the carry.\n          // Simpler: find the XOR gate for the next bit that should use this carry.\n          // Actually, the issue is that the OR gate outputs zXX when it should output\n          // something else. We need to find the gate that currently outputs the wire\n          // that the OR gate *should* output. That wire would be the one used by the\n          // next stage.\n          // For now: find the gate whose output should be this z wire. The z wire\n          // should come from an XOR gate. If the carry and the z wire are swapped,\n          // we need to find which wire was supposed to be the carry.\n          // Let's find the XOR gate in this bit that produces z_i... that was already handled.\n          // The issue is carry = z_something for a future bit.\n          // Let's just find the correct swap partner.\n          const zNum = parseInt(carry.slice(1), 10);\n          // Find the XOR gate that should output this z wire\n          // That XOR gate currently has a non-z output (which is our real carry)\n          // Actually, we already fixed z_i above. So this z must be for a different bit.\n          // The swap must be between carry wire and some other wire.\n          // Since OR gate shouldn't output z, find what it should be:\n          // The correct approach: the z wire (for bit zNum) should come from an XOR.\n          // The XOR for bit zNum would have been processed or will be processed.\n          // But we can identify the swap now: the OR gate outputs a z wire,\n          // which means this z wire is swapped with the actual carry name.\n          // Find the XOR gate for this z bit - it should exist and its output is\n          // the real carry name.\n\n          // Hmm, let's think simpler. If an OR gate (carry) outputs z_something,\n          // then there must be another gate that outputs the real carry wire name.\n          // Those two are swapped.\n          // But we don't know the real carry wire name...\n          // Let's find the gate that should output z_{zNum} - it should be an XOR.\n          // If zNum == i+1, the next bit's XOR(partialSum, carry) should output it.\n          // But that hasn't been processed yet.\n\n          // Alternative approach: just look at what gate takes this carry as input\n          // for XOR in the next bit.\n          const nextX = `x${pad(i + 1)}`;\n          const nextY = `y${pad(i + 1)}`;\n          const nextXorXY = findGateByInputsAndOp('XOR', nextX, nextY);\n          if (nextXorXY) {\n            const nextPartialSum = nextXorXY.out;\n            // Find XOR gate using nextPartialSum - its other input should be our carry\n            const nextXorCarry = gates.find(g =>\n              g.op === 'XOR' && g !== nextXorXY &&\n              (g.in1 === nextPartialSum || g.in2 === nextPartialSum)\n            );\n            if (nextXorCa