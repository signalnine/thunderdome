const inputs: Record<string, number> = {};\n    for (let i = 0; i < bits; i++) {\n      const pad = i.toString().padStart(2, '0');\n      inputs[`x${pad}`] = (a >> i) & 1;\n      inputs[`y${pad}`] = (b >> i) & 1;\n    }\n\n    const result = simulate(gates, inputs);\n    let actual = 0;\n    for (let i = 0; i <= bits; i++) {\n      const pad = i.toString().padStart(2, '0');\n      actual |= (result[`z${pad}`] ?? 0) << i;\n    }\n\n    if (actual !== expected) {\n      throw new Error(`Adder failed: ${a} + ${b} = ${actual}, expected ${expected}`);\n    }\n  }\n}\n\nfunction make4BitAdder(): Gate[] {\n  return makeNBitAdder(4);\n}\n\nfunction makeNBitAdder(n: number): Gate[] {\n  const gates: Gate[] = [];\n  const pad = (i: number) => i.toString().padStart(2, '0');\n\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: `x00`, in2: `y00`, out: `z00` });\n  gates.push({ op: 'AND', in1: `x00`, in2: `y00`, out: `c00` });\n\n  // Bits 1..n-1: full adders\n  for (let i = 1; i < n; i++) {\n    const prevCarry = i === 1 ? 'c00' : `c${pad(i - 1)}`;\n    const isLast = i === n - 1;\n\n    gates.push({ op: 'XOR', in1: `x${pad(i)}`, in2: `y${pad(i)}`, out: `t${pad(i)}` });\n    gates.push({ op: 'XOR', in1: `t${pad(i)}`, in2: prevCarry, out: `z${pad(i)}` });\n    gates.push({ op: 'AND', in1: `x${pad(i)}`, in2: `y${pad(i)}`, out: `a${pad(i)}` });\n    gates.push({ op: 'AND', in1: `t${pad(i)}`, in2: prevCarry, out: `b${pad(i)}` });\n    gates.push({\n      op: 'OR',\n      in1: `a${pad(i)}`,\n      in2: `b${pad(i)}`,\n      out: isLast ? `z${pad(n)}` : `c${pad(i)}`\n    });\n  }\n\n  return gates;\n}\n","structuredPatch":[{"oldStart":132,"oldLines":18,"newStart":132,"newLines":18,"lines":["   it('should handle swaps between internal wires of different bits', () => {","     const gates = makeNBitAdder(10);"," ","-    // Swap a01 (generate for bit 1) with t03 (partial sum for bit 3)","-    swapGateOutputs(gates, 'a01', 't03');","-    // Swap b02 with c04","-    swapGateOutputs(gate