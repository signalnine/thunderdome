@@ -0,0 +1,119 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':       return [row + 1, col];
+    case 'down-left':  return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<string>();
+  // Track (row, col, dir) to avoid reprocessing the same beam state
+  const seen = new Set<string>();
+
+  const beams: Beam[] = [{ row: source[0], col: source[1], dir: 'down' }];
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const { row, col, dir } = beam;
+
+    if (!inBounds(row, col, rows, cols)) continue;
+
+    const stateKey = `${row},${col},${dir}`;
+    if (seen.has(stateKey)) continue;
+    seen.add(stateKey);
+
+    visited.add(`${row},${col}`);
+
+    const cell = grid[row][col];
+
+    if (cell === '^') {
+      // Splitter: split into down-left and down-right
+      const [nlr, nlc] = advance(row, col, 'down-left');
+      const [nrr, nrc] = advance(row, col, 'down-right');
+      beams.push({ row: nlr, col: nlc, dir: 'down-left' });
+      beams.push({ row: nrr, col: nrc, dir: 'down-right' });
+    } else {
+      // Continue in current direction
+      const [nr, nc] = advance(row, col, dir);
+      beams.push({ row: nr, col: nc, dir });
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // We need to count distinct source-to-exit paths.
+  // A path ends when the beam exits the grid.
+  // At each splitter, the beam splits into 2 paths.
+  //
+  // Key insight: we can use memoization on (row, col, dir) to count
+  // how many exit paths a beam at that state produces.
+  // If a beam exits the grid, that's 1 path.
+  // If a beam hits a splitter, the total paths = paths(down-left) + paths(down-right).
+  // If a beam continues, paths = paths(next state).
+
+  const memo = new Map<string, bigint>();
+
+  function countPaths(row: number, col: number, dir: Direction): bigint {
+    if (!inBounds(row, col, rows, cols)) {
+      // Beam exited the grid — this is one complete path
+      return 1n;
+    }
+
+    const key = `${row},${col},${dir}`;
+    const cached = memo.get(key);
+    if (cached !== undefined) return cached;
+
+    const cell = grid[row][col];
+    let result: bigint;
+
+    if (cell === '^') {
+      const [nlr, nlc] = advance(row, col, 'down-left');
+      const [nrr, nrc] = advance(row, col, 'down-right');
+      result = countPaths(nlr, nlc, 'down-left') + countPaths(nrr, nrc, 'down-right');
+    } else {
+      const [nr, nc] = advance(row, col, dir);
+      result = countPaths(nr, nc, dir);
+    }
+
+    memo.set(key, result);
+    return result;
+  }
+
+  return countPaths(source[0], source[1], 'down');
+}
