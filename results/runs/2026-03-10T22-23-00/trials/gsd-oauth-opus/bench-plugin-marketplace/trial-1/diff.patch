(makeManifest({ name: 'plugin-b', version: '1.0.0' }));\n    const list = registry.list();\n    expect(list).toHaveLength(2);\n  });\n\n  it('should search plugins by name', () => {\n    registry.register(makeManifest({ name: 'auth-plugin' }));\n    registry.register(makeManifest({ name: 'logger-plugin' }));\n    const results = registry.search('auth');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('auth-plugin');\n  });\n\n  it('should search plugins by description', () => {\n    registry.register(makeManifest({ name: 'plugin-x', description: 'Handles authentication' }));\n    registry.register(makeManifest({ name: 'plugin-y', description: 'Logging utility' }));\n    const results = registry.search('authentication');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should remove a plugin version', () => {\n    registry.register(makeManifest());\n    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);\n    expect(registry.get('test-plugin')).toBeNull();\n  });\n\n  it('should return false when removing non-existent', () => {\n    expect(registry.remove('nonexistent', '1.0.0')).toBe(false);\n  });\n\n  it('should list versions for a plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    registry.register(makeManifest({ version: '1.5.0' }));\n    const versions = registry.listVersions('test-plugin');\n    expect(versions).toHaveLength(3);\n    expect(versions).toContain('1.0.0');\n    expect(versions).toContain('1.5.0');\n    expect(versions).toContain('2.0.0');\n  });\n\n  it('should update a plugin', () => {\n    registry.register(makeManifest());\n    registry.update('test-plugin', '1.0.0', { description: 'Updated description' });\n    const result = registry.get('test-plugin');\n    expect(result!.description).toBe('Updated description');\n  });\n\n  it('should throw when updating non-existent plugin', () => {\n    expect(() => registry.update('nonexistent', '1.0.0', { description: 'x' })).toThrow();\n  });\n\n  it('should handle multiple versions of same plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    expect(registry.listVersions('test-plugin')).toHaveLength(2);\n    // Remove one version\n    registry.remove('test-plugin', '1.0.0');\n    expect(registry.listVersions('test-plugin')).toHaveLength(1);\n    expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();\n  });\n\n  it('should store and retrieve dependencies', () => {\n    registry.register(makeManifest({ dependencies: { 'dep-a': '^1.0.0' } }));\n    const result = registry.get('test-plugin');\n    expect(result!.dependencies).toEqual({ 'dep-a': '^1.0.0' });\n  });\n\n  it('should store and retrieve permissions', () => {\n    registry.register(makeManifest({ permissions: ['fs:read', 'net:connect'] }));\n    const result = registry.get('test-plugin');\n    expect(result!.permissions).toEqual(['fs:read', 'net:connect']);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":394,"cache_read_input_tokens":29588,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":394},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b0e9bd61-e3b7-4397-83b6-ed61e28920de","uuid":"4293aaa1-6501-4c95-9d42-4ae7f1529355"}
