Path);\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n\n    it(\"should auto-stop previous timer when starting a new one\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"task1\");\n      tracker.start(\"task2\");\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(2);\n      expect(entries[0].stop).not.toBeNull();\n      expect(entries[1].stop).toBeNull();\n    });\n  });\n\n  describe(\"persistence\", () => {\n    it(\"should persist data to file\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      tracker.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe(\"coding\");\n    });\n\n    it(\"should create parent directories if they don't exist\", () => {\n      const nested = join(\n        tmpdir(),\n        `tt-test-${Date.now()}`,\n        \"sub\",\n        \"data.json\"\n      );\n      const tracker = new TimeTracker(nested);\n      tracker.start(\"test\");\n      tracker.stop();\n      expect(existsSync(nested)).toBe(true);\n      // cleanup\n      const { rmSync } = require(\"node:fs\");\n      rmSync(join(tmpdir(), `tt-test-${Date.now().toString().slice(0, -1)}`), {\n        recursive: true,\n        force: true,\n      });\n    });\n\n    it(\"should handle non-existent file gracefully\", () => {\n      const tracker = new TimeTracker(\"/tmp/does-not-exist-\" + Date.now() + \".json\");\n      expect(tracker.getEntries()).toEqual([]);\n    });\n  });\n\n  describe(\"getEntries\", () => {\n    it(\"should return all entries\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"task1\");\n      tracker.stop();\n      tracker.start(\"task2\");\n      tracker.stop();\n      expect(tracker.getEntries()).toHaveLength(2);\n    });\n\n    it(\"should filter by date range\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"task1\");\n      tracker.stop();\n\n      const now = new Date();\n      const past = new Date(now.getTime() - 100000);\n      const future = new Date(now.getTime() + 100000);\n\n      const entries = tracker.getEntries(past, future);\n      expect(entries).toHaveLength(1);\n\n      const noEntries = tracker.getEntries(future);\n      expect(noEntries).toHaveLength(0);\n    });\n  });\n\n  describe(\"getSummary\", () => {\n    it(\"should sum durations per task name\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"meeting\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(Object.keys(summary)).toHaveLength(2);\n      expect(summary[\"coding\"]).toBeGreaterThanOrEqual(0);\n      expect(summary[\"meeting\"]).toBeGreaterThanOrEqual(0);\n    });\n\n    it(\"should use current time for running tasks\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThanOrEqual(0);\n    });\n  });\n\n  describe(\"unicode support\", () => {\n    it(\"should handle unicode task names\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"编程\");\n      tracker.stop();\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe(\"编程\");\n    });\n\n    it(\"should handle emoji task names\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"🚀 Launch prep\");\n      tracker.stop();\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe(\"🚀 Launch prep\");\n\n      // Verify persistence\n      const tracker2 = new TimeTracker(filePath);\n      const entries2 = tracker2.getEnt