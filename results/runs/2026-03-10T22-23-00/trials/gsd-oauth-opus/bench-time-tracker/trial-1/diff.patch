.stop = new Date().toISOString();\n    this.save();\n    return running;\n  }\n\n  getRunning(): TimeEntry | undefined {\n    return this.entries.find((e) => e.stop === null);\n  }\n\n  getEntries(from?: Date, to?: Date): TimeEntry[] {\n    if (!from && !to) {\n      return [...this.entries];\n    }\n    return this.entries.filter((entry) => {\n      const start = new Date(entry.start);\n      if (from && start < from) return false;\n      if (to && start > to) return false;\n      return true;\n    });\n  }\n\n  getSummary(from?: Date, to?: Date): TimeSummary {\n    const entries = this.getEntries(from, to);\n    const summary: TimeSummary = {};\n    const now = Date.now();\n\n    for (const entry of entries) {\n      const startMs = new Date(entry.start).getTime();\n      const stopMs = entry.stop ? new Date(entry.stop).getTime() : now;\n      const duration = stopMs - startMs;\n      summary[entry.task] = (summary[entry.task] ?? 0) + duration;\n    }\n\n    return summary;\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":240,"cache_read_input_tokens":20412,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":240},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"53c1c425-c08e-42dc-860f-aa1929262f40","uuid":"d341d9a7-524f-46be-a5c1-8d85a2de63cd"}
