+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { TimeTracker } from "../src/tracker.js";
+import { unlinkSync, mkdirSync, existsSync, readFileSync } from "node:fs";
+import { join } from "node:path";
+import { tmpdir } from "node:os";
+
+function tmpFile(): string {
+  return join(
+    tmpdir(),
+    `time-tracker-test-${Date.now()}-${Math.random().toString(36).slice(2)}.json`
+  );
+}
+
+function cleanup(path: string) {
+  try {
+    unlinkSync(path);
+  } catch {
+    // ignore
+  }
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    cleanup(filePath);
+  });
+
+  describe("start/stop", () => {
+    it("should start a timer and return the entry", () => {
+      const tracker = new TimeTracker(filePath);
+      const entry = tracker.start("coding");
+      expect(entry.task).toBe("coding");
+      expect(entry.start).toBeTruthy();
+      expect(entry.stop).toBeNull();
+    });
+
+    it("should stop a running timer", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      const stopped = tracker.stop();
+      expect(stopped.task).toBe("coding");
+      expect(stopped.stop).toBeTruthy();
+    });
+
+    it("should throw when starting with empty name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("")).toThrow("Task name must not be empty");
+      expect(() => tracker.start("   ")).toThrow("Task name must not be empty");
+    });
+
+    it("should throw when stopping with no running timer", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+
+    it("should auto-stop previous timer when starting a new one", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.start("task2");
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].stop).not.toBeNull();
+      expect(entries[1].stop).toBeNull();
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist data to file", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+    });
+
+    it("should create parent directories if they don't exist", () => {
+      const nested = join(
+        tmpdir(),
+        `tt-test-${Date.now()}`,
+        "sub",
+        "data.json"
+      );
+      const tracker = new TimeTracker(nested);
+      tracker.start("test");
+      tracker.stop();
+      expect(existsSync(nested)).toBe(true);
+      // cleanup
+      const { rmSync } = require("node:fs");
+      rmSync(join(tmpdir(), `tt-test-${Date.now().toString().slice(0, -1)}`), {
+        recursive: true,
+        force: true,
+      });
+    });
+
+    it("should handle non-existent file gracefully", () => {
+      const tracker = new TimeTracker("/tmp/does-not-exist-" + Date.now() + ".json");
+      expect(tracker.getEntries()).toEqual([]);
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.stop();
+      tracker.start("task2");
+      tracker.stop();
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter by date range", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.stop();
+
+      const now = new Date();
+      const past = new Date(now.getTime() - 100000);
+      const future = new Date(now.getTime() + 100000);
+
+      const entries = tracker.getEntries(past, future);
+      expect(entries).toHaveLength(1);
+
+      const noEntries = tracker.getEntries(future);
+      expect(noEntries).toHaveLength(0);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations per task name", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("meeting");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(Object.keys(summary)).toHaveLength(2);
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(summary["meeting"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should use current time for running tasks", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("编程");
+      tracker.stop();
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("编程");
+    });
+
+    it("should handle emoji task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("🚀 Launch prep");
+      tracker.stop();
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("🚀 Launch prep");
+
+      // Verify persistence
+      const tracker2 = new TimeTracker(filePath);
+      const entries2 = tracker2.getEntries();
+      expect(entries2[0].task).toBe("🚀 Launch prep");
+    });
+
+    it("should handle combined unicode and emoji", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("café ☕ タスク");
+      tracker.stop();
+      const summary = tracker.getSummary();
+      expect(summary["café ☕ タスク"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("getRunning", () => {
+    it("should return undefined when nothing is running", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(tracker.getRunning()).toBeUndefined();
+    });
+
+    it("should return the running entry", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      const running = tracker.getRunning();
+      expect(running?.task).toBe("task1");
+    });
   });
