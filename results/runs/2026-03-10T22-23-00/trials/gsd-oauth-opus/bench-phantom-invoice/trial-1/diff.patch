+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01REg3cMPaY3v8gKM7Z79JCG","type":"tool_result","content":"     1→// Force a non-UTC timezone so timezone-sensitive bugs are exposed\n     2→process.env.TZ = 'America/New_York';\n     3→\n     4→import { describe, it, expect, beforeEach } from 'vitest';\n     5→import type Database from 'better-sqlite3';\n     6→import { createDatabase } from '../src/db/connection.js';\n     7→import {\n     8→  getInvoicesByDateRange,\n     9→  getInvoiceById,\n    10→  createInvoice,\n    11→  getInvoicesByCustomer,\n    12→} from '../src/db/queries.js';\n    13→import {\n    14→  calculateInvoiceTotal,\n    15→  applyDiscount,\n    16→  calculateSubtotal,\n    17→  generateInvoice,\n    18→} from '../src/services/billing.js';\n    19→import { getMonthlyReport, getCustomerReport, getRevenueByPeriod } from '../src/services/reporting.js';\n    20→\n    21→let db: Database.Database;\n    22→\n    23→beforeEach(() => {\n    24→  db = createDatabase(':memory:');\n    25→});\n    26→\n    27→// ─── Invoice CRUD (8 tests) ────────────────────────────────────────\n    28→\n    29→describe('Invoice CRUD', () => {\n    30→  it('creates an invoice and returns its ID', () => {\n    31→    const id = createInvoice(db, {\n    32→      customer_id: 'cust-1',\n    33→      date: '2024-03-15',\n    34→      subtotal: 100,\n    35→      discount_rate: 0,\n    36→      tax_rate: 0.1,\n    37→      total: 110,\n    38→      status: 'draft',\n    39→    });\n    40→    expect(id).toBe(1);\n    41→  });\n    42→\n    43→  it('retrieves an invoice by ID', () => {\n    44→    const id = createInvoice(db, {\n    45→      customer_id: 'cust-1',\n    46→      date: '2024-03-15',\n    47→      subtotal: 200,\n    48→      discount_rate: 0.1,\n    49→      tax_rate: 0.08,\n    50→      total: 194.40,\n    51→      status: 'sent',\n    52→    });\n    53→    const invoice = getInvoiceById(db, id);\n    54→    expect(invoice).toBeDefined();\n    55→    expect(invoice!.customer_id).toBe('cust-1');\n    56→    expect(invoice!.subtotal).toBe(200);\n    57→  });\n    58→\n    59→  it('returns undefined for non-existent invoice', () => {\n    60→    const invoice = getInvoiceById(db, 999);\n    61→    expect(invoice).toBeUndefined();\n    62→  });\n    63→\n    64→  it('creates an invoice with line items', () => {\n    65→    const id = createInvoice(db, {\n    66→      customer_id: 'cust-2',\n    67→      date: '2024-04-01',\n    68→      subtotal: 250,\n    69→      discount_rate: 0,\n    70→      tax_rate: 0.05,\n    71→      total: 262.50,\n    72→      status: 'draft',\n    73→      line_items: [\n    74→        { description: 'Widget A', quantity: 5, unit_price: 30 },\n    75→        { description: 'Widget B', quantity: 2, unit_price: 50 },\n    76→      ],\n    77→    });\n    78→    const invoice = getInvoiceById(db, id);\n    79→    expect(invoice!.line_items).toHaveLength(2);\n    80→    expect(invoice!.line_items[0].description).toBe('Widget A');\n    81→  });\n    82→\n    83→  it('lists invoices by customer', () => {\n    84→    createInvoice(db, {\n    85→      customer_id: 'cust-A',\n    86→      date: '2024-01-10',\n    87→      subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'paid',\n    88→    });\n    89→    createInvoice(db, {\n    90→      customer_id: 'cust-B',\n    91→      date: '2024-01-12',\n    92→      subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'paid',\n    93→    });\n    94→    createInvoice(db, {\n    95→      customer_id: 'cust-A',\n    96→      date: '2024-02-05',\n    97→      subtotal: 150, discount_rate: 0, tax_rate: 0, total: 150, status: 'draft',\n    98→    });\n    99→\n   100→    const invoices = getInvoicesByCustomer(db, 'cust-A');\n   101→    expect(invoices).toHaveLength(2);\n   102→    expect(invoices.every(inv => inv.customer_id === 'cust-A')).toBe(true);\n   103→  });\n   104→\n   105→  it('returns invoices sorted by date', () => {\n   106→    createInvoice(db, {\n   107→      customer_id: 'cust-1',\n   108→      date: '2024-03-15',\n   109→      subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'draft',\n   110→    });\n   111→    createInvoice(db, {\n   112→      customer_id: 'cust-1',\n   113→      date: '2024-01-10',\n   114→      subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'draft',\n   115→    });\n   116→    createInvoice(db, {\n   117→      customer_id: 'cust-1',\n   118→      date: '2024-02-20',\n   119→      subtotal: 150, discount_rate: 0, tax_rate: 0, total: 150, status: 'draft',\n   120→    });\n   121→\n   122→    const invoices = getInvoicesByDateRange(db, '2024-01-01', '2024-12-31');\n   123→    expect(invoices[0].date).toBe('2024-01-10');\n   124→    expect(invoices[1].date).toBe('2024-02-20');\n   125→    expect(invoices[2].date).toBe('2024-03-15');\n   126→  });\n   127→\n   128→  it('stores invoice status correctly', () => {\n   129→    const id = createInvoice(db, {\n   130→      customer_id: 'cust-1',\n   131→      date: '2024-06-01',\n   132→      subtotal: 500, discount_rate: 0.05, tax_rate: 0.1, total: 522.50,\n   133→      status: 'paid',\n   134→    });\n   135→    const invoice = getInvoiceById(db, id);\n   136→    expect(invoice!.status).toBe('paid');\n   137→  });\n   138→\n   139→  it('calculates subtotal from line items', () => {\n   140→    const items = [\n   141→      { description: 'Item A', quantity: 3, unit_price: 10 },\n   142→      { description: 'Item B', quantity: 1, unit_price: 25.50 },\n   143→      { description: 'Item C', quantity: 2, unit_price: 7.25 },\n   144→    ];\n   145→    expect(calculateSubtotal(items)).toBe(70);\n   146→  });\n   147→});\n   148→\n   149→// ─── Billing Calculations (8 tests) ────────────────────────────────\n   150→\n   151→describe('Billing Calculations', () => {\n   152→  it('calculates total without discount', () => {\n   153→    // subtotal=100, no discount, 10% tax => 110\n   154→    const total = calculateInvoiceTotal(100, 0, 0.1);\n   155→    expect(total).toBe(110);\n   156→  });\n   157→\n   158→  it('calculates total with 10% discount', () => {\n   159→    // subtotal=200, 10% discount => 180, then 8% tax => 194.40\n   160→    const total = calculateInvoiceTotal(200, 0.1, 0.08);\n   161→    expect(total).toBe(194.40);\n   162→  });\n   163→\n   164→  it('calculates total with 25% discount and 8% tax', () => {\n   165→    // subtotal=400, 25% discount => 300, 8% tax => 324\n   166→    const total = calculateInvoiceTotal(400, 0.25, 0.08);\n   167→    expect(total).toBe(324);\n   168→  });\n   169→\n   170→  it('applies discount correctly', () => {\n   171→    expect(applyDiscount(200, 0.15)).toBe(170);\n   172→  });\n   173→\n   174→  it('handles zero tax rate', () => {\n   175→    const total = calculateInvoiceTotal(500, 0.2, 0);\n   176→    expect(total).toBe(400);\n   177→  });\n   178→\n   179→  it('handles zero subtotal', () => {\n   180→    const total = calculateInvoiceTotal(0, 0.1, 0.08);\n   181→    expect(total).toBe(0);\n   182→  });\n   183→\n   184→  it('generates invoice with correct total', () => {\n   185→    const id = generateInvoice(db, {\n   186→      customer_id: 'cust-1',\n   187→      date: '2024-05-10',\n   188→      discount_rate: 0,\n   189→      tax_rate: 0.08,\n   190→      line_items: [\n   191→        { description: 'Service', quantity: 1, unit_price: 1000 },\n   192→      ],\n   193→    });\n   194→    const invoice = getInvoiceById(db, id);\n   195→    // 1000 * 1.0 * 1.08 = 1080\n   196→    expect(invoice!.total).toBe(1080);\n   197→  });\n   198→\n   199→  it('generates invoice with multiple line items and discount', () => {\n   200→    const id = generateInvoice(db, {\n   201→      customer_id: 'cust-2',\n   202→      date: '2024-07-20',\n   203→      discount_rate: 0.15,\n   204→      tax_rate: 0,\n   205→      line_items: [\n   206→        { description: 'Product A', quantity: 10, unit_price: 50 },\n   207→        { description: 'Product B', quantity: 5, unit_price: 100 },\n   208→      ],\n   209→    });\n   210→    const invoice = getInvoiceById(db, id);\n   211→    // subtotal = 500 + 500 = 1000\n   212→    // discounted = 1000 * 0.85 = 850\n   213→    // total = 850 * 1.0 = 850\n   214→    expect(invoice!.total).toBe(850);\n   215→  });\n   216→});\n   217→\n   218→// ─── Date Range Queries (7 tests) ──────────────────────────────────\n   219→\n   220→describe('Date Range Queries', () => {\n   221→  beforeEach(() => {\n   222→    // Seed some invoices across different dates\n   223→    const dates = [\n   224→      '2024-01-15', '2024-01-31', '2024-02-01',\n   225→      '2024-02-28', '2024-03-01', '2024-03-31',\n   226→      '2024-06-30',\n   227→    ];\n   228→    dates.forEach((date, i) => {\n   229→      createInvoice(db, {\n   230→        customer_id: `cust-${i}`,\n   231→        date,\n   232→        subtotal: (i + 1) * 100,\n   233→        discount_rate: 0,\n   234→        tax_rate: 0,\n   235→        total: (i + 1) * 100,\n   236→        status: 'paid',\n   237→      });\n   238→    });\n   239→  });\n   240→\n   241→  it('returns invoices within a date range', () => {\n   242→    const invoices = getInvoicesByDateRange(db, '2024-02-01', '2024-03-15');\n   243→    expect(invoices).toHaveLength(3);\n   244→  });\n   245→\n   246→  it('returns empty array when no invoices match', () => {\n   247→    const invoices = getInvoicesByDateRange(db, '2025-01-01', '2025-12-31');\n   248→    expect(invoices).toHaveLength(0);\n   249→  });\n   250→\n   251→  it('includes invoices on start date boundary', () => {\n   252→    const invoices = getInvoicesByDateRange(db, '2024-01-15', '2024-01-20');\n   253→    expect(invoices).toHaveLength(1);\n   254→    expect(invoices[0].date).toBe('2024-01-15');\n   255→  });\n   256→\n   257→  it('includes invoices on end date boundary', () => {\n   258→    // Should include the invoice on 2024-03-31\n   259→    const invoices = getInvoicesByDateRange(db, '2024-03-15', '2024-03-31');\n   260→    expect(invoices).toHaveLength(1);\n   261→    expect(invoices[0].date).toBe('2024-03-31');\n   262→  });\n   263→\n   264→  it('handles single-month range correctly', () => {\n   265→    const invoices = getInvoicesByDateRange(db, '2024-02-01', '2024-02-29');\n   266→    expect(invoices).toHaveLength(2);\n   267→  });\n   268→\n   269→  it('returns all invoices for full year range', () => {\n   270→    const invoices = getInvoicesByDateRange(db, '2024-01-01', '2024-12-31');\n   271→    expect(invoices).toHaveLength(7);\n   272→  });\n   273→\n   274→  it('handles cross-month boundary range', () => {\n   275→    // Jan 15 to Mar 02 should span across months\n   276→    const invoices = getInvoicesByDateRange(db, '2024-01-15', '2024-03-02');\n   277→    expect(invoices).toHaveLength(5);\n   278→  });\n   279→});\n   280→\n   281→// ─── Monthly Reporting (7 tests) ───────────────────────────────────\n   282→\n   283→describe('Monthly Reporting', () => {\n   284→  beforeEach(() => {\n   285→    // Seed invoices across months (avoiding 1st-of-month dates in seed data)\n   286→    const data: { date: string; total: number }[] = [\n   287→      { date: '2024-01-10', total: 100 },\n   288→      { date: '2024-01-25', total: 200 },\n   289→      { date: '2024-02-15', total: 300 },\n   290→      { date: '2024-03-10', total: 400 },\n   291→      { date: '2024-03-20', total: 150 },\n   292→    ];\n   293→    data.forEach(({ date, total }) => {\n   294→      createInvoice(db, {\n   295→        customer_id: 'cust-1',\n   296→        date,\n   297→        subtotal: total,\n   298→        discount_rate: 0,\n   299→        tax_rate: 0,\n   300→        total,\n   301→        status: 'paid',\n   302→      });\n   303→    });\n   304→  });\n   305→\n   306→  it('generates monthly report with correct counts', () => {\n   307→    const report = getMonthlyReport(db, 2024);\n   308→    expect(report).toHaveL