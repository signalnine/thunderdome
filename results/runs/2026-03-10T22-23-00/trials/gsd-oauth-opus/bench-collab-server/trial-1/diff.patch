e p are at the same positions, and characters after p\n      // are shifted right by b.text.length.\n      // So we expand the delete to cover both parts.\n      return { ...a, length: a.length + b.text.length };\n    }\n  }\n\n  // a.type === 'delete' && b.type === 'delete'\n  const delA = a as DeleteOp;\n  const delB = b as DeleteOp;\n  const aEnd = delA.position + delA.length;\n  const bEnd = delB.position + delB.length;\n\n  if (aEnd <= delB.position) {\n    // a is entirely before b: no change\n    return { ...delA };\n  }\n\n  if (delA.position >= bEnd) {\n    // a is entirely after b: shift left\n    return { type: 'delete', position: delA.position - delB.length, length: delA.length };\n  }\n\n  // Overlapping deletes\n  if (delA.position >= delB.position && aEnd <= bEnd) {\n    // a is entirely within b: nothing left to delete\n    return { type: 'delete', position: delB.position, length: 0 };\n  }\n\n  if (delA.position < delB.position && aEnd > bEnd) {\n    // a contains b entirely: reduce a's length by b's length\n    return { type: 'delete', position: delA.position, length: delA.length - delB.length };\n  }\n\n  if (delA.position < delB.position) {\n    // a starts before b, but overlaps\n    return { type: 'delete', position: delA.position, length: delB.position - delA.position };\n  }\n\n  // a starts within b's range but extends beyond\n  return { type: 'delete', position: delB.position, length: aEnd - bEnd };\n}\n\n/**\n * Transform an operation against a sequence of operations that have\n * been applied since the operation's base version.\n */\nexport function transformAgainstHistory(\n  op: Operation,\n  history: Operation[]\n): Operation {\n  let transformed = op;\n  for (const histOp of history) {\n    transformed = transformOp(transformed, histOp);\n    // If a delete was reduced to 0 length, it's a no-op\n    if (transformed.type === 'delete' && transformed.length === 0) {\n      return transformed;\n    }\n  }\n  return transformed;\n}\n\n/**\