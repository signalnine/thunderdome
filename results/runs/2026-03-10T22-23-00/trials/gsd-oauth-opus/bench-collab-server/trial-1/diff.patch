"-    await new Promise(resolve => setTimeout(resolve, 100));","-","-    // Drain all pending messages from all sockets","-    for (const ws of sockets) {","-      // eslint-disable-next-line @typescript-eslint/no-explicit-any","-      (ws as any)._events?.message && ws.removeAllListeners('message');","-    }","-","-    // Each client inserts their number at the end","-    // We do them sequentially so each knows the current version","-    let currentVersion = syncs[0].version as number;","-","+    // Each client inserts their digit at position 0, sequentially","+    let currentVersion = 1; // All started at version 1","     for (let i = 0; i < NUM_CLIENTS; i++) {","-      const ws = sockets[i];","-      const ackPromise = waitForMessage(ws);","-","-      ws.send(JSON.stringify({","+      const c = wsClients[i];","+      c.ws.send(JSON.stringify({","         type: 'operation',","         op: { type: 'insert', position: 0, text: String(i) },","         version: currentVersion,","       }));"," ","-      const ack = await ackPromise;","+      const ack = await c.waitForMessage();","       expect(ack.type).toBe('ack');","       currentVersion = ack.version as number;"," ","-      // Wait a bit to let broadcasts settle","-      await new Promise(resolve => setTimeout(resolve, 20));","+      // Drain broadcast messages from other clients","+      for (let j = 0; j < NUM_CLIENTS; j++) {","+        if (j !== i) {","+          await wsClients[j].waitForMessage(); // operation broadcast","+        }","+      }","     }"," ","-    // Wait for everything to settle","-    await new Promise(resolve => setTimeout(resolve, 200));","-","     // Verify document content","     const res = await request(baseUrl).get(`/api/documents/${docId}`);","     const content = res.body.content;"]},{"oldStart":325,"oldLines":17,"newStart":316,"newLines":17,"lines":["   it('handles delete operations', async () => {","     const docId = await createDoc('Test', 'hello world');"," ","-    const ws = await connect(docId);","-    const sync = await waitForMessage(ws);","+    const c = await connect(docId);","+    const sync = await c.waitForMessage();"," ","     // Delete \" world\"","-    ws.send(JSON.stringify({","+    c.ws.send(JSON.stringify({","       type: 'operation',","       op: { type: 'delete', position: 5, length: 6 },","       version: sync.version,","     }));"," ","-    const ack = await waitForMessage(ws);","+    const ack = await c.waitForMessage();","     expect(ack.type).toBe('ack');"," ","     const res = await request(baseUrl).get(`/api/documents/${docId}`);"]},{"oldStart":348,"oldLines":13,"newStart":339,"newLines":15,"lines":["     const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);","     clients.push(ws);"," ","-    const openPromise = new Promise<void>((resolve, reject) => {","-      ws.on('open', () => resolve());","-      ws.on('error', reject);","+    const msg = await new Promise<Record<string, unknown>>((resolve, reject) => {","+      const timer = setTimeout(() => reject(new Error('timeout')), 5000);","+      ws.on('message', (data: Buffer) => {","+        clearTimeout(timer);","+        resolve(JSON.parse(data.toString()));","+      });","+      ws.on('error', (e) => { clearTimeout(timer); reject(e); });","     });","-    await openPromise;"," ","-    const msg = await waitForMessage(ws);","     expect(msg.type).toBe('sync');","     expect(msg.content).toBe('content');","   });"]},{"oldStart":362,"oldLines":43,"newStart":355,"newLines":42,"lines":["   it('notifies when clients join and leave', async () => {","     const docId = await createDoc('Test', 'hello');"," ","-    const ws1 = await connect(docId);","-    await waitForMessage(ws1); // sync","+    const c1 = await connect(docId);","+    await c1.waitForMessage(); // sync"," ","-    const ws2 = await connect(docId);","-    await waitForMessage(ws2); // sync","+    const c2 = await connect(docId);","+    await c2.waitForMessage(); // sync"," ","-    // ws1 should get client_joined","-    const joined = await waitForMessage(ws1);","+    // c1 should get client_joined","+    const joined = await c1.waitForMessage();","     expect(joined.type).toBe('client_joined');"," ","-    // ws2 closes","-    const leftPromise = waitForMessage(ws1);","-    ws2.close();","+    // c2 closes","+    c2.ws.close();"," ","-    const left = await leftPromise;","+    const left = await c1.waitForMessage();","     expect(left.type).toBe('client_left');","   });"," ","   it('version history grows with WebSocket operations', async () => {","     const docId = await createDoc('Test', 'hello');"," ","-    const ws = await connect(docId);","-    const sync = await waitForMessage(ws);","+    const c = await connect(docId);","+    const sync = await c.waitForMessage();"," ","-    ws.send(JSON.stringify({","+    c.ws.send(JSON.stringify({","       type: 'operation',","       op: { type: 'insert', position: 5, text: ' world' },","       version: sync.version,","     }));","-    await waitForMessage(ws); // ack","+    await c.waitForMessage(); // ack"," ","-    ws.send(JSON.stringify({","+    c.ws.send(JSON.stringify({","       type: 'operation',","       op: { type: 'insert', position: 11, text: '!' },","       version: (sync.version as number) + 1,","     }));","-    await waitForMessage(ws); // ack","+    await c.waitForMessage(); // ack"," ","     const versionsRes = await request(baseUrl).get(`/api/documents/${docId}/versions`);","     expect(versionsRes.body.length).toBeGreaterThanOrEqual(3); // initial + 2 ops"]}],"originalFile":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport request from 'supertest';\nimport WebSocket from 'ws';\nimport { createApp, AppInstance } from '../src/server.js';\n\nfunction connectWs(port: number, docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}`);\n    ws.on('open', () => resolve(ws));\n    ws.on('error', reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket, timeout = 5000): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(() => reject(new Error('Timeout waiting for message')), timeout);\n    ws.once('message', (data: Buffer) => {\n      clearTimeout(timer);\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\nfunction collectMessages(ws: WebSocket, count: number, timeout = 5000): Promise<Record<string, unknown>[]> {\n  return new Promise((resolve, reject) => {\n    const messages: Record<string, unknown>[] = [];\n    const timer = setTimeout(() => reject(new Error(`Timeout: got ${messages.length}/${count} messages`)), timeout);\n    const handler = (data: Buffer) => {\n      messages.push(JSON.parse(data.toString()));\n      if (messages.length >= count) {\n        clearTimeout(timer);\n        ws.removeListener('message', handler);\n        resolve(messages);\n      }\n    };\n    ws.on('message', handler);\n  });\n}\n\ndescribe('WebSocket Collaboration', () => {\n  let appInstance: AppInstance;\n  let port: number;\n  let baseUrl: string;\n  const clients: WebSocket[] = [];\n\n  beforeEach(async () => {\n    appInstance = createApp(':memory:');\n    port = await appInstance.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    for (const ws of clients) {\n      if (ws.readyState === WebSocket.OPEN) {\n        ws.close();\n      }\n    }\n    clients.length = 0;\n    await appInstance.stop();\n  });\n\n  async function createDoc(title: string, content: string = ''): Promise<string> {\n    const res = await request(baseUrl)\n      .post('/api/documents')\n      .send({ title, content });\n    return res.body.id;\n  }\n\n  async function connect(docId: string): Promise<WebSocket> {\n    const ws = await connectWs(port, docId);\n    clients.push(ws);\n    return ws;\n  }\n\n  it('sends sync message on connection', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const ws = await connect(docId);\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe(1);\n    expect(msg.clientId).toBeDefined();\n  });\n\n  it('rejects connection for non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/nonexistent`);\n    clients.push(ws);\n\n    const closePromise = new Promise<number>((resolve) => {\n      ws.on('close', (code: number) => resolve(code));\n    });\n\n    const code = await closePromise;\n    expect(code).toBe(1008);\n  });\n\n  it('broadcasts operations to other clients', async () => {\n    const docId = await createDoc('Test', 'hello');\n\n    const ws1 = await connect(docId);\n    const sync1 = await waitForMessage(ws1);\n\n    const ws2 = await connect(docId);\n    const sync2 = await waitForMessage(ws2);\n    // ws1 gets client_joined notification\n    await waitForMessage(ws1);\n\n    // ws1 sends an operation\n    const receivePromise = waitForMessage(ws2);\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 5, text: ' world' },\n      version: sync1.version,\n    }));\n\n    // ws1 gets ack\n    const ack = await waitForMessage(ws1);\n    expect(ack.type).toBe('ack');\n\n    // ws2 gets the operation\n    const broadcast = await receivePromise;\n    expect(broadcast.type).toBe('operation');\n    expect((broadcast.op as Record<string, unknown>).type).toBe('insert');\n    expect((broadcast.op as Record<string, unknown>).text).toBe(' world');\n  });\n\n  it('persists operations via REST', async () => {\n    const docId = await createDoc('Test', 'hello');\n\n    const ws = await connect(docId);\n    const sync = await waitForMessage(ws);\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 5, text: ' world' },\n      version: sync.version,\n    }));\n\n    await waitForMessage(ws); // ack\n\n    // Check via REST\n    const res = await request(baseUrl).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('hello world');\n  });\n\n  it('handles sequential operations from same client', async () => {\n    const docId = await createDoc('Test', '');\n\n    const ws = await connect(docId);\n    const sync = await waitForMessage(ws);\n\n    // First op: insert \"hello\"\n    ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 0, text: 'hello' },\n      version: sync.version,\n    }));\n    const ack1 = await waitForMessage(ws);\n    expect(ack1.type).toBe('ack');\n\n    // Second op: insert \" world\" after \"hello\"\n    ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 5, text: ' world' },\n      version: ack1.version,\n    }));\n    const ack2 = await waitForMessage(ws);\n    expect(ack2.type).toBe('ack');\n\n    const res = await request(baseUrl).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('hello world');\n  });\n\n  it('rejects malformed operations', async () => {\n    const docId = await createDoc('Test', 'hello');\n\n    const ws = await connect(docId);\n    await waitForMessage(ws);\n\n    // Send invalid operation\n    ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'invalid' },\n      version: 1,\n    }));\n\n    const error = await waitForMessage(ws);\n    expect(error.type).toBe('error');\n  });\n\n  it('rejects invalid JSON', async () => {\n    const docId = await createDoc('Test', 'hello');\n\n    const ws = await connect(docId);\n    await waitForMessage(ws);\n\n    ws.send('not json{{{');\n\n    const error = await waitForMessage(ws);\n    expect(error.type).toBe('error');\n  });\n\n  it('handles concurrent edits from two clients using OT', async () => {\n    const docId = await createDoc('Test', 'abcd');\n\n    const ws1 = await connect(docId);\n    const sync1 = await waitForMessage(ws1);\n\n    const ws2 = await connect(docId);\n    const sync2 = await waitForMessage(ws2);\n    // ws1 gets client_joined\n    await waitForMessage(ws1);\n\n    // Both clients are at version 1 with content \"abcd\"\n    // ws1 inserts \"X\" at position 2 (between b and c): \"abXcd\"\n    // ws2 inserts \"Y\" at position 4 (at the end): \"abcdY\"\n    // Both based on version 1\n\n    const receiveOnWs2 = waitForMessage(ws2);\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 2, text: 'X' },\n      version: sync1.version,\n    }));\n\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe('ack');\n\n    // ws2 receives ws1's op\n    const ws1OpOnWs2 = await receiveOnWs2;\n    expect(ws1OpOnWs2.type).toBe('operation');\n\n    // Now ws2 sends its op, still based on version 1\n    // The server should transform it against ws1's insert\n    const receiveOnWs1 = waitForMessage(ws1);\n\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'insert', position: 4, text: 'Y' },\n      version: sync2.version,\n    }));\n\n    const ack2 = await waitForMessage(ws2);\n    expect(ack2.type).toBe('ack');\n\n    // ws1 receives the transformed op\n    const ws2OpOnWs1 = await receiveOnWs1;\n    expect(ws2OpOnWs1.type).toBe('operation');\n\n    // Verify final document content\n    const res = await request(baseUrl).get(`/api/documents/${docId}`);\n    // \"abcd\" -> insert X at 2 -> \"abXcd\" -> insert Y at 5 (transformed from 4+1) -> \"abXcdY\"\n    expect(res.body.content).toBe('abXcdY');\n  });\n\n  it('handles 10 concurrent clients without corruption', async () => {\n    const docId = await createDoc('Test', 'start');\n    const NUM_CLIENTS = 10;\n\n    const sockets: WebSocket[] = [];\n    const syncs: Record<string, unknown>[] = [];\n\n    // Connect all clients\n    for (let i = 0; i < NUM_CLIENTS; i++) {\n      const ws = await connect(docId);\n      const sync = 