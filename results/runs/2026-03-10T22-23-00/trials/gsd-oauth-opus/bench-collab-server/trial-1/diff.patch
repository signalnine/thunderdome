nalFile":"import { describe, it, expect } from 'vitest';\nimport {\n  applyOperation,\n  transformOp,\n  transformAgainstHistory,\n  validateOperation,\n  validateClientOperation,\n  Operation,\n} from '../src/ot.js';\n\ndescribe('applyOperation', () => {\n  it('inserts text at the beginning', () => {\n    expect(applyOperation('hello', { type: 'insert', position: 0, text: 'say ' })).toBe(\n      'say hello'\n    );\n  });\n\n  it('inserts text at the end', () => {\n    expect(applyOperation('hello', { type: 'insert', position: 5, text: ' world' })).toBe(\n      'hello world'\n    );\n  });\n\n  it('inserts text in the middle', () => {\n    expect(applyOperation('hllo', { type: 'insert', position: 1, text: 'e' })).toBe('hello');\n  });\n\n  it('deletes text from the beginning', () => {\n    expect(applyOperation('hello', { type: 'delete', position: 0, length: 2 })).toBe('llo');\n  });\n\n  it('deletes text from the end', () => {\n    expect(applyOperation('hello', { type: 'delete', position: 3, length: 2 })).toBe('hel');\n  });\n\n  it('deletes text from the middle', () => {\n    expect(applyOperation('hello', { type: 'delete', position: 1, length: 3 })).toBe('ho');\n  });\n\n  it('inserts into empty document', () => {\n    expect(applyOperation('', { type: 'insert', position: 0, text: 'hello' })).toBe('hello');\n  });\n\n  it('throws on out-of-bounds insert', () => {\n    expect(() => applyOperation('hello', { type: 'insert', position: 10, text: 'x' })).toThrow();\n  });\n\n  it('throws on out-of-bounds delete', () => {\n    expect(() => applyOperation('hello', { type: 'delete', position: 3, length: 5 })).toThrow();\n  });\n\n  it('throws on negative position insert', () => {\n    expect(() => applyOperation('hello', { type: 'insert', position: -1, text: 'x' })).toThrow();\n  });\n});\n\ndescribe('transformOp', () => {\n  describe('insert vs insert', () => {\n    it('transforms insert before another insert (no shift needed)', () => {\n      const a: Operation = { type: 'insert', position: 1, text: 'a' };\n      const b: Operation = { type: 'insert', position: 3, text: 'b' };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'insert', position: 1, text: 'a' });\n    });\n\n    it('transforms insert after another insert (shifts right)', () => {\n      const a: Operation = { type: 'insert', position: 5, text: 'a' };\n      const b: Operation = { type: 'insert', position: 2, text: 'bbb' };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'insert', position: 8, text: 'a' });\n    });\n\n    it('handles same position inserts (tie-breaking)', () => {\n      const a: Operation = { type: 'insert', position: 3, text: 'a' };\n      const b: Operation = { type: 'insert', position: 3, text: 'b' };\n      const result = transformOp(a, b);\n      // a yields to b, shifts right\n      expect(result).toEqual({ type: 'insert', position: 4, text: 'a' });\n    });\n  });\n\n  describe('insert vs delete', () => {\n    it('insert before delete: no change', () => {\n      const a: Operation = { type: 'insert', position: 1, text: 'x' };\n      const b: Operation = { type: 'delete', position: 3, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'insert', position: 1, text: 'x' });\n    });\n\n    it('insert after delete: shifts left', () => {\n      const a: Operation = { type: 'insert', position: 5, text: 'x' };\n      const b: Operation = { type: 'delete', position: 1, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'insert', position: 3, text: 'x' });\n    });\n\n    it('insert within deleted range: moves to delete position', () => {\n      const a: Operation = { type: 'insert', position: 3, text: 'x' };\n      const b: Operation = { type: 'delete', position: 2, length: 4 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'insert', position: 2, text: 'x' });\n    });\n  });\n\n  describe('delete vs insert', () => {\n    it('delete before insert: no change', () => {\n      const a: Operation = { type: 'delete', position: 0, length: 2 };\n      const b: Operation = { type: 'insert', position: 5, text: 'x' };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 0, length: 2 });\n    });\n\n    it('delete after insert: shifts right', () => {\n      const a: Operation = { type: 'delete', position: 5, length: 2 };\n      const b: Operation = { type: 'insert', position: 2, text: 'xxx' };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 8, length: 2 });\n    });\n\n    it('delete spanning insert: expands to include inserted text', () => {\n      const a: Operation = { type: 'delete', position: 2, length: 4 };\n      const b: Operation = { type: 'insert', position: 3, text: 'xx' };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 2, length: 6 });\n    });\n  });\n\n  describe('delete vs delete', () => {\n    it('non-overlapping, a before b', () => {\n      const a: Operation = { type: 'delete', position: 0, length: 2 };\n      const b: Operation = { type: 'delete', position: 5, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 0, length: 2 });\n    });\n\n    it('non-overlapping, a after b', () => {\n      const a: Operation = { type: 'delete', position: 5, length: 2 };\n      const b: Operation = { type: 'delete', position: 0, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 3, length: 2 });\n    });\n\n    it('a contained within b: becomes no-op', () => {\n      const a: Operation = { type: 'delete', position: 2, length: 2 };\n      const b: Operation = { type: 'delete', position: 1, length: 5 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 1, length: 0 });\n    });\n\n    it('b contained within a: reduces a length', () => {\n      const a: Operation = { type: 'delete', position: 1, length: 5 };\n      const b: Operation = { type: 'delete', position: 2, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 1, length: 3 });\n    });\n\n    it('identical deletes: becomes no-op', () => {\n      const a: Operation = { type: 'delete', position: 2, length: 3 };\n      const b: Operation = { type: 'delete', position: 2, length: 3 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 2, length: 0 });\n    });\n  });\n});\n\ndescribe('transformAgainstHistory', () => {\n  it('transforms through multiple operations', () => {\n    const op: Operation = { type: 'insert', position: 5, text: 'X' };\n    const history: Operation[] = [\n      { type: 'insert', position: 2, text: 'ab' }, // shifts +2\n      { type: 'insert', position: 0, text: 'c' }, // shifts +1\n    ];\n    const result = transformAgainstHistory(op, history);\n    expect(result).toEqual({ type: 'insert', position: 8, text: 'X' });\n  });\n\n  it('returns no-op delete when fully consumed', () => {\n    const op: Operation = { type: 'delete', position: 2, length: 3 };\n    const history: Operation[] = [{ type: 'delete', position: 1, length: 5 }];\n    const result = transformAgainstHistory(op, history);\n    expect(result.type).toBe('delete');\n    if (result.type === 'delete') {\n      expect(result.length).toBe(0);\n    }\n  });\n});\n\ndescribe('convergence', () => {\n  it('two concurrent inserts at different positions converge', () => {\n    const doc = 'hello world';\n    const opA: Operation = { type: 'insert', position: 5, text: ' beautiful' };\n    const opB: Operation = { type: 'insert', position: 11, text: '!' };\n\n    // Server applies A first, then transforms B against A\n    const transformedB = transformOp(opB, opA);\n\n    const resultAB = applyOperation(applyOperation(doc, opA), transformedB);\n\n    // Client B applies B first, then transforms A against B\n    const transformedA = transformOp(opA, opB);\n    const resultBA = applyOperation(applyOperation(doc, opB), transformedA);\n\n    expect(resultAB).toBe(resultBA);\n    expect(resultAB).toContain('beautiful');\n    expect(resultAB).toContain('!');\n  });\n\n  it('two concurrent inserts at the same position converge', () => {\n    const doc = 'hello';\n    const opA: Operation = { type: 'insert', position: 5, text: ' world' };\n    const opB: Operation = { type: 'insert', position: 5, text: '!' };\n\n    const transformedB = transformOp(opB, opA);\n    const resultAB = applyOperation(applyOperation(doc, opA), transformedB);\n\n    const transformedA = transformOp(opA, opB);\n    const resultBA = applyOperation(applyOperation(doc, opB), transformedA);\n\n    expect(resultAB).toBe(resultBA);\n    // Both texts should be present\n    expect(resultAB).toContain(' world');\n    expect(resultAB).toContain('!');\n  });\n\n  it('concurrent insert and delete converge', () => {\n    const doc = 'hello world';\n    const opA: Operation = { type: 'insert', position: 5, text: ' beautiful' };\n    const opB: Operation = { type: 'delete', position: 5, length: 6 };\n\n    const transformedB = transformOp(opB, opA);\n    const resultAB = applyOperation(applyOperation(doc, opA), transformedB);\n\n    const transformedA = transformOp(opA, opB);\n    const resultBA = applyOperation(applyOperation(doc, opB), transformedA);\n\n    expect(resultAB).toBe(resultBA);\n  });\n});\n\ndescribe('validateOperation', () => {\n  it('accepts valid insert', () => {\n    expect(validateOperation({ type: 'insert', position: 0, text: 'hello' })).toBe(true);\n  });\n\n  it('accepts valid delete', () => {\n    expect(validateOperation({ type: 'delete', position: 0, length: 5 })).toBe(true);\n  });\n\n  it('rejects missing type', () => {\n    expect(validateOperation({ position: 0, text: 'hello' })).toBe(false);\n  });\n\n  it('rejects negative position', () => {\n    expect(validateOperation({ type: 'insert', position: -1, text: 'hello' })).toBe(false);\n  });\n\n  it('rejects empty text in insert', () => {\n    expect(validateOperation({ type: 'insert', position: 0, text: '' })).toBe(false);\n  });\n\n  it('rejects zero length delete', () => {\n    expect(validateOperation({ type: 'delete', position: 0, length: 0 })).toBe(false);\n  });\n\n  it('rejects non-integer position', () => {\n    expect(validateOperation({ type: 'insert', position: 1.5, text: 'x' })).toBe(false);\n  });\n\n  it('rejects null', () => {\n    expect(validateOperation(null)).toBe(false);\n  });\n\n  it('rejects string', () => {\n    expect(validateOperation('insert')).toBe(false);\n  });\n});\n\ndescribe('validateClientOperation', () => {\n  it('accepts valid client operation', () => {\n    expect(\n      validateClientOperation({\n        op: { type: 'insert', position: 0, text: 'hello' },\n        version: 1,\n        clientId: 'abc',\n      })\n    ).toBe(true);\n  });\n\n  it('rejects missing version', () => {\n    expect(\n      validateClientOperation({\n        op: { type: 'insert', position: 0, text: 'hello' },\n        clientId: 'abc',\n      })\n    ).toBe(false);\n  });\n\n  it('rejects missing clientId', () => {\n    expect(\n      validateClientOperation({\n        op: { type: 'insert', position: 0, text: 'hello' },\n        version: 1,\n      })\n    ).toBe(false);\n  });\n\n  it('rejects invalid op', () => {\n    expect(\n      validateClientOperation({\n        op: { type: 'invalid' },\n        version: 1,\n        clientId: 'abc',\n      })\n    ).toBe(false);\n  });\n});\n","structuredPatch":[{"oldStart":210,"oldLines":10,"newStart":210,"newLines":13,"lines":["     const opA: Operation = { type: 'insert', position: 5, text: ' world' };","     const opB: Operation = { type: 'insert', position: 5, text: '!' };"," ","+    // Server ap