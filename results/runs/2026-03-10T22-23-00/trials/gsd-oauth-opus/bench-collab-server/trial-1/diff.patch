ion('hello', { type: 'insert', position: -1, text: 'x' })).toThrow();\n  });\n});\n\ndescribe('transformOp', () => {\n  describe('insert vs insert', () => {\n    it('transforms insert before another insert (no shift needed)', () => {\n      const a: Operation = { type: 'insert', position: 1, text: 'a' };\n      const b: Operation = { type: 'insert', position: 3, text: 'b' };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'insert', position: 1, text: 'a' });\n    });\n\n    it('transforms insert after another insert (shifts right)', () => {\n      const a: Operation = { type: 'insert', position: 5, text: 'a' };\n      const b: Operation = { type: 'insert', position: 2, text: 'bbb' };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'insert', position: 8, text: 'a' });\n    });\n\n    it('handles same position inserts (tie-breaking)', () => {\n      const a: Operation = { type: 'insert', position: 3, text: 'a' };\n      const b: Operation = { type: 'insert', position: 3, text: 'b' };\n      const result = transformOp(a, b);\n      // a yields to b, shifts right\n      expect(result).toEqual({ type: 'insert', position: 4, text: 'a' });\n    });\n  });\n\n  describe('insert vs delete', () => {\n    it('insert before delete: no change', () => {\n      const a: Operation = { type: 'insert', position: 1, text: 'x' };\n      const b: Operation = { type: 'delete', position: 3, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'insert', position: 1, text: 'x' });\n    });\n\n    it('insert after delete: shifts left', () => {\n      const a: Operation = { type: 'insert', position: 5, text: 'x' };\n      const b: Operation = { type: 'delete', position: 1, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'insert', position: 3, text: 'x' });\n    });\n\n    it('insert within deleted range: moves to delete position', () => {\n      const a: Operation = { type: 'insert', position: 3, text: 'x' };\n      const b: Operation = { type: 'delete', position: 2, length: 4 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'insert', position: 2, text: 'x' });\n    });\n  });\n\n  describe('delete vs insert', () => {\n    it('delete before insert: no change', () => {\n      const a: Operation = { type: 'delete', position: 0, length: 2 };\n      const b: Operation = { type: 'insert', position: 5, text: 'x' };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 0, length: 2 });\n    });\n\n    it('delete after insert: shifts right', () => {\n      const a: Operation = { type: 'delete', position: 5, length: 2 };\n      const b: Operation = { type: 'insert', position: 2, text: 'xxx' };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 8, length: 2 });\n    });\n\n    it('delete spanning insert: expands to include inserted text', () => {\n      const a: Operation = { type: 'delete', position: 2, length: 4 };\n      const b: Operation = { type: 'insert', position: 3, text: 'xx' };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 2, length: 6 });\n    });\n  });\n\n  describe('delete vs delete', () => {\n    it('non-overlapping, a before b', () => {\n      const a: Operation = { type: 'delete', position: 0, length: 2 };\n      const b: Operation = { type: 'delete', position: 5, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 0, length: 2 });\n    });\n\n    it('non-overlapping, a after b', () => {\n      const a: Operation = { type: 'delete', position: 5, length: 2 };\n      const b: Operation = { type: 'delete', position: 0, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 3, length: 2 });\n    });\n\n    it('a contained within b: becomes no-op', () => {\n      const a: Operation = { type: 'delete', position: 2, length: 2 };\n      const b: Operation = { type: 'delete', position: 1, length: 5 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 1, length: 0 });\n    });\n\n    it('b contained within a: reduces a length', () => {\n      const a: Operation = { type: 'delete', position: 1, length: 5 };\n      const b: Operation = { type: 'delete', position: 2, length: 2 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 1, length: 3 });\n    });\n\n    it('identical deletes: becomes no-op', () => {\n      const a: Operation = { type: 'delete', position: 2, length: 3 };\n      const b: Operation = { type: 'delete', position: 2, length: 3 };\n      const result = transformOp(a, b);\n      expect(result).toEqual({ type: 'delete', position: 2, length: 0 });\n    });\n  });\n});\n\ndescribe('transformAgainstHistory', () => {\n  it('transforms through multiple operations', () => {\n    const op: Operation = { type: 'insert', position: 5, text: 'X' };\n    const history: Operation[] = [\n      { type: 'insert', position: 2, text: 'ab' }, // shifts +2\n      { type: 'insert', position: 0, text: 'c' }, // shifts +1\n    ];\n    const result = transformAgainstHistory(op, history);\n    expect(result).toEqual({ type: 'insert', position: 8, text: 'X' });\n  });\n\n  it('returns no-op delete when fully consumed', () => {\n    const op: Operation = { type: 'delete', position: 2, length: 3 };\n    const history: Operation[] = [{ type: 'delete', position: 1, length: 5 }];\n    const result = transformAgainstHistory(op, history);\n    expect(result.type).toBe('delete');\n    if (result.type === 'delete') {\n      expect(result.length).toBe(0);\n    }\n  });\n});\n\ndescribe('convergence', () => {\n  it('two concurrent inserts at different positions converge', () => {\n    const doc = 'hello world';