@@ -0,0 +1,215 @@
+/**
+ * Operational Transformation engine for collaborative text editing.
+ *
+ * Supports two operation types:
+ * - insert: Insert text at a position
+ * - delete: Delete a range of text at a position
+ *
+ * Operations reference a base version (the version of the document
+ * the client had when it generated the operation). The server transforms
+ * incoming operations against any operations that have been applied since
+ * that base version.
+ */
+
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  length: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+export interface ClientOperation {
+  op: Operation;
+  version: number; // base version the client had when generating this op
+  clientId: string;
+}
+
+/**
+ * Apply an operation to a document string. Returns the new document content.
+ * Throws if the operation is invalid for the given document.
+ */
+export function applyOperation(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    if (op.position < 0 || op.position > doc.length) {
+      throw new Error(
+        `Insert position ${op.position} out of bounds for document of length ${doc.length}`
+      );
+    }
+    return doc.slice(0, op.position) + op.text + doc.slice(op.position);
+  } else {
+    if (op.position < 0 || op.position + op.length > doc.length) {
+      throw new Error(
+        `Delete range [${op.position}, ${op.position + op.length}) out of bounds for document of length ${doc.length}`
+      );
+    }
+    return doc.slice(0, op.position) + doc.slice(op.position + op.length);
+  }
+}
+
+/**
+ * Transform operation `a` against operation `b`.
+ * Returns the transformed version of `a` that can be applied after `b`
+ * has already been applied.
+ *
+ * This implements the standard OT inclusion transformation (IT) function.
+ */
+export function transformOp(a: Operation, b: Operation, aPriority = false): Operation {
+  if (a.type === 'insert' && b.type === 'insert') {
+    if (a.position < b.position) {
+      return { ...a };
+    } else if (a.position > b.position) {
+      return { ...a, position: a.position + b.text.length };
+    } else {
+      // Same position: use priority flag for tie-breaking
+      // When aPriority is true, a goes first (no shift)
+      // When aPriority is false (default), a yields to b (shifts right)
+      if (aPriority) {
+        return { ...a };
+      }
+      return { ...a, position: a.position + b.text.length };
+    }
+  }
+
+  if (a.type === 'insert' && b.type === 'delete') {
+    if (a.position <= b.position) {
+      return { ...a };
+    } else if (a.position >= b.position + b.length) {
+      return { ...a, position: a.position - b.length };
+    } else {
+      // a's insertion point is within b's deleted range
+      // Move insertion to the start of the deleted range
+      return { ...a, position: b.position };
+    }
+  }
+
+  if (a.type === 'delete' && b.type === 'insert') {
+    if (b.position <= a.position) {
+      return { ...a, position: a.position + b.text.length };
+    } else if (b.position >= a.position + a.length) {
+      return { ...a };
+    } else {
+      // b inserts within a's delete range: split the delete around the insertion
+      // After b's insert, a's range is shifted. We expand the delete to cover
+      // the original range plus the new text would be wrong. Instead, we keep
+      // deleting the same characters, which are now split.
+      // The simplest correct approach: delete becomes longer to account for inserted text.
+      // Actually, the correct OT approach is to keep deleting the same characters.
+      // After b inserts at position p within [a.position, a.position+a.length),
+      // the characters before p are at the same positions, and characters after p
+      // are shifted right by b.text.length.
+      // So we expand the delete to cover both parts.
+      return { ...a, length: a.length + b.text.length };
+    }
+  }
+
+  // a.type === 'delete' && b.type === 'delete'
+  const delA = a as DeleteOp;
+  const delB = b as DeleteOp;
+  const aEnd = delA.position + delA.length;
+  const bEnd = delB.position + delB.length;
+
+  if (aEnd <= delB.position) {
+    // a is entirely before b: no change
+    return { ...delA };
+  }
+
+  if (delA.position >= bEnd) {
+    // a is entirely after b: shift left
+    return { type: 'delete', position: delA.position - delB.length, length: delA.length };
+  }
+
+  // Overlapping deletes
+  if (delA.position >= delB.position && aEnd <= bEnd) {
+    // a is entirely within b: nothing left to delete
+    return { type: 'delete', position: delB.position, length: 0 };
+  }
+
+  if (delA.position < delB.position && aEnd > bEnd) {
+    // a contains b entirely: reduce a's length by b's length
+    return { type: 'delete', position: delA.position, length: delA.length - delB.length };
+  }
+
+  if (delA.position < delB.position) {
+    // a starts before b, but overlaps
+    return { type: 'delete', position: delA.position, length: delB.position - delA.position };
+  }
+
+  // a starts within b's range but extends beyond
+  return { type: 'delete', position: delB.position, length: aEnd - bEnd };
+}
+
+/**
+ * Transform an operation against a sequence of operations that have
+ * been applied since the operation's base version.
+ */
+export function transformAgainstHistory(
+  op: Operation,
+  history: Operation[]
+): Operation {
+  let transformed = op;
+  for (const histOp of history) {
+    transformed = transformOp(transformed, histOp);
+    // If a delete was reduced to 0 length, it's a no-op
+    if (transformed.type === 'delete' && transformed.length === 0) {
+      return transformed;
+    }
+  }
+  return transformed;
+}
+
+/**
+ * Validate that an operation is well-formed.
+ */
+export function validateOperation(op: unknown): op is Operation {
+  if (typeof op !== 'object' || op === null) return false;
+
+  const obj = op as Record<string, unknown>;
+
+  if (obj.type === 'insert') {
+    return (
+      typeof obj.position === 'number' &&
+      Number.isInteger(obj.position) &&
+      obj.position >= 0 &&
+      typeof obj.text === 'string' &&
+      obj.text.length > 0
+    );
+  }
+
+  if (obj.type === 'delete') {
+    return (
+      typeof obj.position === 'number' &&
+      Number.isInteger(obj.position) &&
+      obj.position >= 0 &&
+      typeof obj.length === 'number' &&
+      Number.isInteger(obj.length) &&
+      obj.length > 0
+    );
+  }
+
+  return false;
+}
+
+/**
+ * Validate a full client operation message.
+ */
+export function validateClientOperation(msg: unknown): msg is ClientOperation {
+  if (typeof msg !== 'object' || msg === null) return false;
+
+  const obj = msg as Record<string, unknown>;
+
+  return (
+    typeof obj.version === 'number' &&
+    Number.isInteger(obj.version) &&
+    obj.version >= 0 &&
+    typeof obj.clientId === 'string' &&
+    obj.clientId.length > 0 &&
+    validateOperation(obj.op)
+  );
+}
