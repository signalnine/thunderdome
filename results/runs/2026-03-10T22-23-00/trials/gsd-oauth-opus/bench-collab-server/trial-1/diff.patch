@@ -0,0 +1,222 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import { createApp, AppInstance } from '../src/server.js';
+
+describe('REST API', () => {
+  let appInstance: AppInstance;
+  let port: number;
+  let baseUrl: string;
+
+  beforeEach(async () => {
+    appInstance = createApp(':memory:');
+    port = await appInstance.start(0);
+    baseUrl = `http://localhost:${port}`;
+  });
+
+  afterEach(async () => {
+    await appInstance.stop();
+  });
+
+  describe('POST /api/documents', () => {
+    it('creates a document with title and content', async () => {
+      const res = await request(baseUrl)
+        .post('/api/documents')
+        .send({ title: 'Test Doc', content: 'Hello world' });
+
+      expect(res.status).toBe(201);
+      expect(res.body.title).toBe('Test Doc');
+      expect(res.body.content).toBe('Hello world');
+      expect(res.body.id).toBeDefined();
+      expect(res.body.created_at).toBeDefined();
+      expect(res.body.updated_at).toBeDefined();
+    });
+
+    it('creates a document with empty content by default', async () => {
+      const res = await request(baseUrl)
+        .post('/api/documents')
+        .send({ title: 'Empty Doc' });
+
+      expect(res.status).toBe(201);
+      expect(res.body.content).toBe('');
+    });
+
+    it('rejects missing title', async () => {
+      const res = await request(baseUrl)
+        .post('/api/documents')
+        .send({ content: 'No title' });
+
+      expect(res.status).toBe(400);
+      expect(res.body.error).toBeDefined();
+    });
+  });
+
+  describe('GET /api/documents', () => {
+    it('lists all documents', async () => {
+      await request(baseUrl).post('/api/documents').send({ title: 'Doc 1' });
+      await request(baseUrl).post('/api/documents').send({ title: 'Doc 2' });
+
+      const res = await request(baseUrl).get('/api/documents');
+      expect(res.status).toBe(200);
+      expect(res.body).toHaveLength(2);
+    });
+
+    it('returns empty array when no documents exist', async () => {
+      const res = await request(baseUrl).get('/api/documents');
+      expect(res.status).toBe(200);
+      expect(res.body).toEqual([]);
+    });
+  });
+
+  describe('GET /api/documents/:id', () => {
+    it('gets a document by id', async () => {
+      const created = await request(baseUrl)
+        .post('/api/documents')
+        .send({ title: 'My Doc', content: 'Content' });
+
+      const res = await request(baseUrl).get(`/api/documents/${created.body.id}`);
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('My Doc');
+      expect(res.body.content).toBe('Content');
+    });
+
+    it('returns 404 for non-existent document', async () => {
+      const res = await request(baseUrl).get('/api/documents/nonexistent');
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('PUT /api/documents/:id', () => {
+    it('updates document title and content', async () => {
+      const created = await request(baseUrl)
+        .post('/api/documents')
+        .send({ title: 'Old Title', content: 'Old Content' });
+
+      const res = await request(baseUrl)
+        .put(`/api/documents/${created.body.id}`)
+        .send({ title: 'New Title', content: 'New Content' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('New Title');
+      expect(res.body.content).toBe('New Content');
+    });
+
+    it('updates only title', async () => {
+      const created = await request(baseUrl)
+        .post('/api/documents')
+        .send({ title: 'Old Title', content: 'Keep This' });
+
+      const res = await request(baseUrl)
+        .put(`/api/documents/${created.body.id}`)
+        .send({ title: 'New Title' });
+
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('New Title');
+      expect(res.body.content).toBe('Keep This');
+    });
+
+    it('returns 404 for non-existent document', async () => {
+      const res = await request(baseUrl)
+        .put('/api/documents/nonexistent')
+        .send({ title: 'New Title' });
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('DELETE /api/documents/:id', () => {
+    it('deletes a document', async () => {
+      const created = await request(baseUrl)
+        .post('/api/documents')
+        .send({ title: 'To Delete' });
+
+      const res = await request(baseUrl).delete(`/api/documents/${created.body.id}`);
+      expect(res.status).toBe(204);
+
+      const getRes = await request(baseUrl).get(`/api/documents/${created.body.id}`);
+      expect(getRes.status).toBe(404);
+    });
+
+    it('returns 404 for non-existent document', async () => {
+      const res = await request(baseUrl).delete('/api/documents/nonexistent');
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('GET /api/documents/:id/versions', () => {
+    it('returns version history', async () => {
+      const created = await request(baseUrl)
+        .post('/api/documents')
+        .send({ title: 'Versioned', content: 'v1' });
+
+      await request(baseUrl)
+        .put(`/api/documents/${created.body.id}`)
+        .send({ content: 'v2' });
+
+      const res = await request(baseUrl).get(`/api/documents/${created.body.id}/versions`);
+      expect(res.status).toBe(200);
+      expect(res.body.length).toBeGreaterThanOrEqual(2);
+      expect(res.body[0].version).toBe(1);
+      expect(res.body[0].content).toBe('v1');
+    });
+
+    it('returns 404 for non-existent document', async () => {
+      const res = await request(baseUrl).get('/api/documents/nonexistent/versions');
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('GET /api/documents/:id/versions/:version', () => {
+    it('returns a specific version', async () => {
+      const created = await request(baseUrl)
+        .post('/api/documents')
+        .send({ title: 'Versioned', content: 'v1' });
+
+      const res = await request(baseUrl).get(
+        `/api/documents/${created.body.id}/versions/1`
+      );
+      expect(res.status).toBe(200);
+      expect(res.body.content).toBe('v1');
+      expect(res.body.version).toBe(1);
+    });
+
+    it('returns 404 for non-existent version', async () => {
+      const created = await request(baseUrl)
+        .post('/api/documents')
+        .send({ title: 'Versioned', content: 'v1' });
+
+      const res = await request(baseUrl).get(
+        `/api/documents/${created.body.id}/versions/999`
+      );
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('Persistence', () => {
+    it('data survives across server instances with same db path', async () => {
+      const tmpDbPath = `/tmp/test-collab-${Date.now()}.db`;
+
+      // Create first instance
+      const app1 = createApp(tmpDbPath);
+      const port1 = await app1.start(0);
+      const url1 = `http://localhost:${port1}`;
+
+      const created = await request(url1)
+        .post('/api/documents')
+        .send({ title: 'Persistent', content: 'survives restart' });
+
+      const docId = created.body.id;
+      await app1.stop();
+
+      // Create second instance with same db
+      const app2 = createApp(tmpDbPath);
+      const port2 = await app2.start(0);
+      const url2 = `http://localhost:${port2}`;
+
+      const res = await request(url2).get(`/api/documents/${docId}`);
+      expect(res.status).toBe(200);
+      expect(res.body.title).toBe('Persistent');
+      expect(res.body.content).toBe('survives restart');
+
+      await app2.stop();
+    });
+  });
+});
