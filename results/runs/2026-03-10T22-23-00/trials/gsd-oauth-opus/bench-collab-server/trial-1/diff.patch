ns', async () => {\n    const docId = await createDoc('Test', 'hello world');\n\n    const c = await connect(docId);\n    const sync = await c.waitForMessage();\n\n    // Delete \" world\"\n    c.ws.send(JSON.stringify({\n      type: 'operation',\n      op: { type: 'delete', position: 5, length: 6 },\n      version: sync.version,\n    }));\n\n    const ack = await c.waitForMessage();\n    expect(ack.type).toBe('ack');\n\n    const res = await request(baseUrl).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('hello');\n  });\n\n  it('supports /documents/:id/ws path', async () => {\n    const docId = await createDoc('Test', 'content');\n\n    const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}/ws`);\n    clients.push(ws);\n\n    const msg = await new Promise<Record<string, unknown>>((resolve, reject) => {\n      const timer = setTimeout(() => reject(new Error('timeout')), 5000);\n      ws.on('message', (data: Buffer) => {\n        clearTimeout(timer);\n        resolve(JSON.parse(data.toString()));\n      });\n      ws.on('error', (e) => { clearTimeout(timer); reject(e); });\n    });\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('content');\n  });\n\n  it('notifies when clients join and leave', async () => {\n    const docId = await createDoc('Test', 'hello');\n\n    const c1 = await connect(docId);\n    await c1.waitForMessage(); // sync\n\n    const c2 = await connect(docId);\n    await c2.waitForMessage(); // sync\n\n    // c1 should get client_joined\n    const joined = await c1.waitForMessage();\n    expect(joined.type).toBe('client_joined');\n\n    // c2 closes\n    c2.ws.close();\n\n    const left = await c1.waitForMessage();\n    expect(left.type).toBe('client_left');\n  });\n\n  it('version history grows with WebSocket operations', async () => {\n    const docId = await createDoc('Test', 'hello');\n\n    const c = await connect(docId);\n    const sync = await c.waitForMessage();\n\n    c.ws.send(JSON.stri