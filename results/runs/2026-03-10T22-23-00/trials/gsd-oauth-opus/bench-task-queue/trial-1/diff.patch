+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  function exhaustRetries(taskId: string, queueName: string = 'default') {
+    const task = tq.getTask(taskId)!;
+    for (let i = 0; i < task.maxRetries; i++) {
+      // Make task available
+      task.availableAt = new Date(Date.now() - 1);
+      tq.getNextTask(queueName);
+      tq.failTask(taskId, new Error(`fail-${i + 1}`));
+    }
+    // One more to exhaust
+    if (task.status === 'pending') {
+      task.availableAt = new Date(Date.now() - 1);
+      tq.getNextTask(queueName);
+      tq.failTask(taskId, new Error('final-fail'));
+    }
+  }
+
+  it('should move task to DLQ after retries exhausted', () => {
+    const task = tq.addTask('work', { maxRetries: 1, backoffDelay: 0 });
+    exhaustRetries(task.id);
+
+    const dlqTasks = tq.getDeadLetterTasks();
+    expect(dlqTasks.length).toBe(1);
+    expect(dlqTasks[0].id).toBe(task.id);
+  });
+
+  it('should retain error information', () => {
+    const task = tq.addTask('work', { maxRetries: 0 });
+    tq.getNextTask();
+    tq.failTask(task.id, new Error('fatal error'));
+
+    const dlqTasks = tq.getDeadLetterTasks();
+    expect(dlqTasks[0].error?.message).toBe('fatal error');
+  });
+
+  it('should retain failure count', () => {
+    const task = tq.addTask('work', { maxRetries: 1, backoffDelay: 0 });
+    exhaustRetries(task.id);
+
+    const dlqTasks = tq.getDeadLetterTasks();
+    expect(dlqTasks[0].failCount).toBeGreaterThan(0);
+  });
+
+  it('should view dead-lettered tasks per queue', () => {
+    const t1 = tq.addTask('work1', { queue: 'q1', maxRetries: 0 });
+    const t2 = tq.addTask('work2', { queue: 'q2', maxRetries: 0 });
+
+    tq.getNextTask('q1');
+    tq.failTask(t1.id, new Error('fail'));
+    tq.getNextTask('q2');
+    tq.failTask(t2.id, new Error('fail'));
+
+    expect(tq.getDeadLetterTasks('q1').length).toBe(1);
+    expect(tq.getDeadLetterTasks('q2').length).toBe(1);
+  });
+
+  it('should redrive a task back to its original queue', () => {
+    const task = tq.addTask('work', { maxRetries: 0 });
+    tq.getNextTask();
+    tq.failTask(task.id, new Error('fail'));
+
+    expect(tq.getDeadLetterTasks().length).toBe(1);
+
+    const redriven = tq.redriveTask(task.id);
+    expect(redriven.status).toBe('pending');
+    expect(redriven.attempt).toBe(0);
+
+    expect(tq.getDeadLetterTasks().length).toBe(0);
+    expect(tq.pendingCount()).toBe(1);
+
+    // Should be processable again
+    const next = tq.getNextTask();
+    expect(next?.id).toBe(task.id);
+  });
+
+  it('should throw when redriving a non-failed task', () => {
+    const task = tq.addTask('work');
+    expect(() => tq.redriveTask(task.id)).toThrow();
+  });
+
+  it('should clear all dead-lettered tasks for a queue', () => {
+    const t1 = tq.addTask('work1', { maxRetries: 0 });
+    const t2 = tq.addTask('work2', { maxRetries: 0 });
+
+    tq.getNextTask();
+    tq.failTask(t1.id, new Error('fail'));
+    tq.getNextTask();
+    tq.failTask(t2.id, new Error('fail'));
+
+    expect(tq.getDeadLetterTasks().length).toBe(2);
+
+    const cleared = tq.clearDeadLetterQueue();
+    expect(cleared).toBe(2);
+    expect(tq.getDeadLetterTasks().length).toBe(0);
+  });
+
+  it('should return empty array for non-existent queue DLQ', () => {
+    expect(tq.getDeadLetterTasks('nonexistent')).toEqual([]);
+  });
+
+  it('should return 0 when clearing empty DLQ', () => {
+    expect(tq.clearDeadLetterQueue()).toBe(0);
+  });
+});
