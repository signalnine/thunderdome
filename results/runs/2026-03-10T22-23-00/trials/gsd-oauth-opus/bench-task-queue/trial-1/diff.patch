+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should stop accepting new tasks after shutdown', async () => {
+    await tq.shutdown();
+    expect(() => tq.addTask('work')).toThrow(/shutting down/);
+  });
+
+  it('should complete immediately with no processing tasks', async () => {
+    const result = await tq.shutdown();
+
+    expect(result.completed).toBe(0);
+    expect(result.forceCancelled).toBe(0);
+    expect(result.durationMs).toBeDefined();
+  });
+
+  it('should wait for processing tasks to complete', async () => {
+    const task = tq.addTask('work');
+    tq.getNextTask();
+
+    // Complete the task after a short delay
+    setTimeout(() => {
+      tq.completeTask(task.id);
+    }, 50);
+
+    const result = await tq.shutdown(5000);
+    expect(result.completed).toBe(1);
+    expect(result.forceCancelled).toBe(0);
+  });
+
+  it('should force-cancel tasks exceeding timeout', async () => {
+    const task = tq.addTask('slow-work');
+    tq.getNextTask();
+
+    // Don't complete the task - let it timeout
