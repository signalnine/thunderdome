+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_0198YQmUeCUUtrThHShumivU","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AsdQPLAmDsZYC6VccDtzA2","name":"Write","input":{"file_path":"/workspace/tests/phase05.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\ndescribe('Phase 5: Retry with Backoff', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  it('should mark a processing task as completed', () => {\n    const task = tq.addTask('work');\n    tq.getNextTask();\n    const completed = tq.completeTask(task.id);\n    expect(completed.status).toBe('completed');\n  });\n\n  it('should throw when completing a non-processing task', () => {\n    const task = tq.addTask('work');\n    expect(() => tq.completeTask(task.id)).toThrow();\n  });\n\n  it('should mark a processing task as failed', () => {\n    const task = tq.addTask('work', { maxRetries: 0 });\n    tq.getNextTask();\n    const failed = tq.failTask(task.id, new Error('oops'));\n    expect(failed.status).toBe('failed');\n    expect(failed.error?.message).toBe('oops');\n  });\n\n  it('should retry failed task with remaining retries', () => {\n    const task = tq.addTask('work', { maxRetries: 3 });\n    tq.getNextTask();\n    const result = tq.failTask(task.id, new Error('fail'));\n\n    // Task should be re-queued as pending\n    expect(result.status).toBe('pending');\n    expect(result.failCount).toBe(1);\n  });\n\n  it('should use exponential backoff for retries', () => {\n    const task = tq.addTask('work', { maxRetries: 3, backoffDelay: 1000 });\n\n    // Attempt 1\n    tq.getNextTask();\n    const before1 = Date.now();\n    tq.failTask(task.id, new Error('fail'));\n    // backoff = 1000 * 2^0 = 1000ms\n    expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(before1 + 900);\n\n    // Attempt 2 (we need to advance time or use processAt trick)\n    // For now just verify the delay is applied\n    expect(task.attempt).toBe(1);\n  });\n\n  it('should track attempt count', () => {\n    const task = tq.addTask('work', { maxRetries: 3 });\n    expect(task.attempt).toBe(0);\n\n    tq.getNextTask();\n    expect(task.attempt).toBe(1);\n  });\n\n  it('should default maxRetries to 3', () => {\n    const task = tq.addTask('work');\n    expect(task.maxRetries).toBe(3);\n  });\n\n  it('should default backoffDelay to 1000ms', () => {\n    const task = tq.addTask('work');\n    expect(task.backoffDelay).toBe(1000);\n  });\n\n  it('should allow configurable maxRetries', () => {\n    const task = tq.addTask('work', { maxRetries: 5 });\n    expect(task.maxRetries).toBe(5);\n  });\n\n  it('should allow configurable backoffDelay', () => {\n    const task = tq.addTask('work', { backoffDelay: 500 });\n    expect(task.backoffDelay).toBe(500);\n  });\n\n  it('should keep original queue and priority on retry', () => {\n    const task = tq.addTask('work', {\n      queue: 'myqueue',\n      priority: 2,\n      maxRetries: 3,\n    });\n    tq.getNextTask('myqueue');\n    tq.failTask(task.id, new Error('fail'));\n\n    expect(task.queue).toBe('myqueue');\n    expect(task.priority).toBe(2);\n  });\n\n  it('should remain failed when retries exhausted', () => {\n    const task = tq.addTask('work', { maxRetries: 1, backoffDelay: 0 });\n\n    // First attempt\n    tq.getNextTask();\n    tq.failTask(task.id, new Error('fail1'));\n    expect(task.status).toBe('pending'); // still has retries\n\n    // Make available immediately for testing\n    task.availableAt = new Date(Date.now() - 1);\n\n    // Second attempt\n    tq.getNextTask();\n    tq.failTask(task.id, new Error('fail2'));\n    expect(task.status).toBe('failed'); // no more retries\n  });\n\n  it('should throw when failing a non-processing task', () => {\n    const task = tq.addTask('work');\n    expect(() => tq.failTask(task.id)).toThrow();\n  });\n\n  it('should throw for non-existent task', () => {\n    expect(() => tq.completeTask('nonexistent')).toThrow();\n    expect(() => tq.failTask('nonexistent')).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1087,"cache_read_input_tokens":47149,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1087},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8bdd05c5-3a95-4f32-b942-b13e7309e3c4","uuid":"4f6df04e-5a55-475b-b2dc-6a94e09c6ef9"}
