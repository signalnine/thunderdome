ve dependents\n   156→    this.resolveDependents(taskId);\n   157→\n   158→    return task;\n   159→  }\n   160→\n   161→  failTask(taskId: string, error?: Error): Task {\n   162→    const task = this.allTasks.get(taskId);\n   163→    if (!task) throw new Error(`Task ${taskId} not found`);\n   164→    if (task.status !== 'processing') {\n   165→      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n   166→    }\n   167→\n   168→    task.failCount += 1;\n   169→    task.error = error;\n   170→\n   171→    // Check if retries remain\n   172→    if (task.attempt < task.maxRetries) {\n   173→      // Re-add with exponential backoff delay\n   174→      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n   175→      task.status = 'pending';\n   176→      task.availableAt = new Date(Date.now() + delay);\n   177→      task.progress = 0;\n   178→      task.progressMessage = undefined;\n   179→      // Task remains in queue\n   180→      return task;\n   181→    }\n   182→\n   183→    // No retries left\n   184→    task.status = 'failed';\n   185→    this.removeFromQueue(task);\n   186→\n   187→    // Phase 6: Move to dead letter queue\n   188→    const queue = this.getOrCreateQueue(task.queue);\n   189→    queue.deadLetterQueue.push(task);\n   190→\n   191→    return task;\n   192→  }\n   193→\n   194→  // ─── Phase 6: Dead Letter Queue ───────────────────────────────────\n   195→\n   196→  getDeadLetterTasks(queueName: string = 'default'): Task[] {\n   197→    const queue = this.queues.get(queueName);\n   198→    if (!queue) return [];\n   199→    return [...queue.deadLetterQueue];\n   200→  }\n   201→\n   202→  redriveTask(taskId: string): Task {\n   203→    const task = this.allTasks.get(taskId);\n   204→    if (!task) throw new Error(`Task ${taskId} not found`);\n   205→    if (task.status !== 'failed') {\n   206→      throw new Error(`Task ${taskId} is not in failed state`);\n   207→    }\n   208→\n   209→    // Remove from DLQ\n   210→    const queue = this.getOrCreateQueue(task.queue);\n   211→    const dlqIndex = queue.deadLetterQueue.indexOf(task);\n   212→    if (dlqIndex === -1) {\n   213→      throw new Error(`Task ${taskId} is not in the dead letter queue`);\n   214→    }\n   215→    queue.deadLetterQueue.splice(dlqIndex, 1);\n   216→\n   217→    // Reset for fresh retry\n   218→    task.status = 'pending';\n   219→    task.attempt = 0;\n   220→    task.progress = 0;\n   221→    task.progressMessage = undefined;\n   222→    task.error = undefined;\n   223→    task.availableAt = new Date();\n   224→\n   225→    queue.tasks.push(task);\n   226→\n   227→    return task;\n   228→  }\n   229→\n   230→  clearDeadLetterQueue(queueName: string = 'default'): number {\n   231→    const queue = this.queues.get(queueName);\n   232→    if (!queue) return 0;\n   233→    const count = queue.deadLetterQueue.length;\n   234→    // Remove from allTasks as well\n   235→    for (const task of queue.deadLetterQueue) {\n   236→      this.allTasks.delete(task.id);\n   237→    }\n   238→    queue.deadLetterQueue = [];\n   239→    return count;\n   240→  }\n   241→\n   242→  // ─── Phase 7: Task Dependencies ───────────────────────────────────\n   243→\n   244→  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } {\n   245→    const task = this.allTasks.get(taskId);\n   246→    if (!task) throw new Error(`Task ${taskId} not found`);\n   247→\n   248→    const resolved = Array.from(task.resolvedDependencies);\n   249→    const pending = task.dependencies.filter(dep => !task.resolvedDependencies.has(dep));\n   250→\n   251→    return {\n   252→      dependencies: [...task.dependencies],\n   253→      resolved,\n   254→      pending,\n   255→    };\n   256→  }\n   257→\n   258→  private detectCircularDependencies(newTask: Task): void {\n   259→    // BFS to check if any dependency chain leads back to newTask\n   260→    const visited = new Set<string>();\n   261→    const toVisit = [...newTask.dependencies];\n   262→\n   263→    while (toVisit.length > 0) {\n   264→      const currentId = toVisit.pop()!;\n   265→      if (visited.has(currentId)) continue;\n   266→      visited.add(currentId);\n   267→\n   268→      // Check all tasks that this task depends on\n   269→      const currentTask = this.allTasks.get(currentId);\n   270→      if (currentTask) {\n   271→        for (const depId of currentTask.dependencies) {\n   272→          if (depId === newTask.id) {\n   273→            throw new Error('Circular dependency detected');\n   274→          }\n   275→          toVisit.push(depId);\n   276→        }\n   277→      }\n   278→    }\n   279→  }\n   280→\n   281→  private resolveDependents(completedTaskId: string): void {\n   282→    for (const task of this.allTasks.values()) {\n   283→      if (task.dependencies.includes(completedTaskId) && !task.resolvedDependencies.has(completedTaskId)) {\n   284→        task.resolvedDependencies.add(completedTaskId);\n   285→      }\n   286→    }\n   287→  }\n   288→\n   289→  // ─── Phase 8: Concurrency Control ─────────────────────────────────\n   290→\n   291→  setConcurrency(queueName: string, limit: number | null): void {\n   292→    const queue = this.getOrCreateQueue(queueName);\n   293→    queue.concurrencyLimit = limit;\n   294→  }\n   295→\n   296→  getConcurrency(queueName: string = 'default'): number | null {\n   297→    const queue = this.queues.get(queueName);\n   298→    if (!queue) return null;\n   299→    return queue.concurrencyLimit;\n   300→  }\n   301→\n   302→  getActiveCount(queueName: string = 'default'): number {\n   303→    const queue = this.queues.get(queueName);\n   304→    if (!queue) return 0;\n   305→    return queue.tasks.filter(t => t.status === 'processing').length;\n   306→  }\n   307→\n   308→  // ─── Phase 9: Progress Tracking and Cancellation ──────────────────\n   309→\n   310→  updateProgress(taskId: string, progress: number, message?: string): void {\n   311→    const task = this.allTasks.get(taskId);\n   312→    if (!task) throw new Error(`Task ${taskId} not found`);\n   313→    if (task.status !== 'processing') {\n   314→      throw new Error(`Task ${taskId} is not in processing state`);\n   315→    }\n   316→\n   317→    if (progress < 0 || progress > 100) {\n   318→      throw new Error('Progress must be between 0 and 100');\n   319→    }\n   320→\n   321→    task.progress = progress;\n   322→    task.progressMessage = message;\n   323→\n   324→    // Notify listeners\n   325→    const listeners = this.progressListeners.get(taskId);\n   326→    if (listeners) {\n   327→      for (const listener of listeners) {\n   328→        listener(progress, message);\n   329→      }\n   330→    }\n   331→  }\n   332→\n   333→  getProgress(taskId: string): { progress: number; message?: string } {\n   334→    const task = this.allTasks.get(taskId);\n   335→    if (!task) throw new Error(`Task ${taskId} not found`);\n   336→    return { progress: task.progress, message: task.progressMessage };\n   337→  }\n   338→\n   339→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   340→    if (!this.progressListeners.has(taskId)) {\n   341→      this.progressListeners.set(taskId, new Set());\n   342→    }\n   343→    this.progressListeners.get(taskId)!.add(listener);\n   344→\n   345→    // Return unsubscribe function\n   346→    return () => {\n   347→      const listeners = this.progressListeners.get(taskId);\n   348→      if (listeners) {\n   349→        listeners.delete(listener);\n   350→        if (listeners.size === 0) {\n   351→          this.progressListeners.delete(taskId);\n   352→        }\n   353→      }\n   354→    };\n   355→  }\n   356→\n   357→  cancelTask(taskId: string): Task {\n   358→    const task = this.allTasks.get(taskId);\n   359→    if (!task) throw new Error(`Task ${taskId} not found`);\n   360→    if (task.status !== 'pending' && task.status !== 'processing') {\n   361→      throw new Error(`Task ${taskId} cannot be cancelled (current: ${task.status})`);\n   362→    }\n   363→\n   364→    task.status = 'cancelled';\n   365→    this.removeFromQueue(task);\n   366→\n   367→    return task;\n   368→  }\n   369→\n   370→  // ─── Phase 10: Recurring Tasks ────────────────────────────────────\n   371→\n   372→  addSchedule(\n   373→    cronExpression: string,\n   374→    queueName: string,\n   375→    payload: unknown,\n   376→    taskOptions?: Omit<TaskOptions, 'queue'>,\n   377→  ): Schedule {\n   378→    this.validateCron(cronExpression);\n   379→\n   380→    const schedule: Schedule = {\n   381→      id: randomUUID(),\n   382→      cronExpression,\n   383→      queue: queueName,\n   384→      payload,\n   385→      taskOptions,\n   386→      active: true,\n   387→    };\n   388→\n   389→    this.schedules.set(schedule.id, schedule);\n   390→    return schedule;\n   391→  }\n   392→\n   393→  removeSchedule(scheduleId: string): boolean {\n   394→    const schedule = this.schedules.get(scheduleId);\n   395→    if (!schedule) return false;\n   396→    schedule.active = false;\n   397→    this.schedules.delete(scheduleId);\n   398→    return true;\n   399→  }\n   400→\n   401→  getSchedules(): Schedule[] {\n   402→    return Array.from(this.schedules.values()).filter(s => s.active);\n   403→  }\n   404→\n   405→  tick(now: Date = new Date()): Task[] {\n   406→    const created: Task[] = [];\n   407→\n   408→    for (const schedule of this.schedules.values()) {\n   409→      if (!schedule.active) continue;\n   410→\n   411→      if (this.shouldRunSchedule(schedule, now)) {\n   412→        const task = this.addTask(schedule.payload, {\n   413→          ...schedule.taskOptions,\n   414→          queue: schedule.queue,\n   415→        });\n   416→        created.push(task);\n   417→        schedule.lastRun = now;\n   418→      }\n   419→    }\n   420→\n   421→    return created;\n   422→  }\n   423→\n   424→  private validateCron(expr: string): void {\n   425→    const parts = expr.trim().split(/\\s+/);\n   426→    if (parts.length !== 5) {\n   427→      throw new Error(`Invalid cron expression: ${expr}`);\n   428→    }\n   429→\n   430→    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n   431→\n   432→    // Validate supported patterns\n   433→    const isValid =\n   434→      (this.isValidCronField(minute) && this.isValidCronField(hour) &&\n   435→       dayOfMonth === '*' && month === '*' && dayOfWeek === '*');\n   436→\n   437→    if (!isValid) {\n   438→      throw new Error(`Unsupported cron expression: ${expr}`);\n   439→    }\n   440→  }\n   441→\n   442→  private isValidCronField(field: string): boolean {\n   443→    if (field === '*') return true;\n   444→    if (/^\\d+$/.test(field)) return true;\n   445→    if (/^\\*\\/\\d+$/.test(field)) return true;\n   446→    return false;\n   447→  }\n   448→\n   449→  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n   450→    const parts = schedule.cronExpression.trim().split(/\\s+/);\n   451→    const [minuteExpr, hourExpr] = parts;\n   452→\n   453→    const currentMinute = now.getMinutes();\n   454→    const currentHour = now.getHours();\n   455→\n   456→    // Check if current time matches the cron expression\n   457→    if (!this.matchesCronField(minuteExpr, currentMinute)) return false;\n   458→    if (!this.matchesCronField(hourExpr, currentHour)) return false;\n   459→\n   460→    // Prevent running more than once per matching minute\n   461→    if (schedule.lastRun) {\n   462→      const lastMinute = schedule.lastRun.getMinutes();\n   463→      const lastHour = schedule.lastRun.getHours();\n   464→      const lastDate = schedule.lastRun.toDateString();\n   465→      const nowDate = now.toDateString();\n   466→\n   467→      if (lastDate === nowDate && lastHour === currentHour && lastMinute === currentMinute) {\n   468→        return false;\n   469→      }\n   470→    }\n   471→\n   472→    return true;\n   473→  }\n   474→\n   475→  private matchesCronField(expr: string, value: number): boolean {\n   476→    if (expr === '*') return true;\n   477→\n   478→    // */N pattern\n   479→    const stepMatch = expr.match(/^\\*\\/(\\d+)$/);\n   480→    if (stepMatch) {\n   481→      const step = parseInt(stepMatch[1], 10);\n   482→      return value % step === 0;\n   483→    }\n   484→\n   485→    // Exact number\n   486→    const num = parseInt(expr, 10);\n   487→    if (!isNaN(num)) {\n   488→      return value === num;\n   489→    }\n   490→\n   491→    return false;\n   492→  }\n   493→\n   494→  // ─── Phase 11: Middleware Pipeline ─────────────────────────────────\n   495→\n   496→  use(queueName: string, middleware: MiddlewareFn): void {\n   497→    const queue = this.getOrCreateQueue(queueName);\n   498→    queue.middlewares.push(middleware);\n   499→  }\n   500→\n   501→  setProcessor(queueName: string, processor: ProcessorFn): void {\n   502→    const queue = this.getOrCreateQueue(queueName);\n   503→    queue.processor = processor;\n   504→  }\n   505→\n   506→  async processTask(queueName: string = 'default'): Promise<Task | null> {\n   507→    const task = this.getNextTask(queueName);\n   508→    if (!task) return null;\n   509→\n   510→    const queue = this.getOrCreateQueue(queueName);\n   511→    const middlewares = [...queue.middlewares];\n   512→    const processor = queue.processor;\n   513→\n   514→    try {\n   515→      let index = 0;\n   516→      let aborted = false;\n   517→\n   518→      const runNext = async (): Promise<void> => {\n   519→        if (aborted) return;\n   520→        if (index < middlewares.length) {\n   521→          const mw = middlewares[index++];\n   522→          await mw(task, runNext);\n   523→        } else if (processor) {\n   524→          await processor(task);\n   525→        }\n   526→      };\n   527→\n   528→      await runNext();\n   529→\n   530→      // If task is still processing (middleware/processor didn't change it), mark complete\n   531→      if (task.status === 'processing') {\n   532→        this.completeTask(task.id);\n   533→      }\n   534→    } catch (err) {\n   535→      if (task.status === 'processing') {\n   536→        this.failTask(task.id, err instanceof Error ? err : new Error(String(err)));\n   537→      }\n   538→    }\n   539→\n   540→    return task;\n   541→  }\n   542→\n   543→  // ─── Phase 12: Graceful Shutdown ──────────────────────────────────\n   544→\n   545→  onShutdown(callback: ShutdownCallback): void {\n   546→    this.shutdownCallbacks.push(callback);\n   547→  }\n   548→\n   549→  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {\n   550→    if (this.shutdownPromise) {\n   551→      return this.shutdownPromise;\n   552→    }\n   553→\n   554→    this.isShuttingDown = true;\n   555→    this.shutdownPromise = this.performShutdown(timeoutMs);\n   556→    return this.shutdownPromise;\n   557→  }\n   558→\n   559→  get shuttingDown(): boolean {\n   560→    return this.isShuttingDown;\n   561→  }\n   562→\n   563→  private async performShutdown(timeoutMs: number): Promise<ShutdownResult> {\n   564→    const startTime = Date.now();\n   565→    let completed = 0;\n   566→    let forceCancelled = 0;\n   567→\n   568→    // Run shutdown callbacks\n   569→    for (const cb of this.shutdownCallbacks) {\n   570→      try {\n   571→        await cb();\n   572→      } catch (_e) {\n   573→        // Ignore callback errors during shutdown\n   574→      }\n   575→    }\n   576→\n   577→    // Collect all processing tasks\n   578→    const processingTasks = this.getProcessingTasks();\n   579→\n   580→    if (processingTasks.length === 0) {\n   581→      return {\n   582→        completed: 0,\n   583→        forceCancelled: 0,\n   584→        durationMs: Date.now() - startTime,\n   585→      };\n   586→    }\n   587→\n   588→    // Wait for processing tasks with timeout\n   589→    const waitResult = await Promise.race([\n   590→      this.waitForProcessing(processingTasks),\n   591→      this.timeoutPromise(timeoutMs),\n   592→    ]);\n   593→\n   594→    if (waitResult === 'timeout') {\n   595→      // Force cancel remaining processing tasks\n   596→      for (const task of processingTasks) {\n   597→        if (task.status === 'processing') {\n   598→          task.status = 'cancelled';\n   599→          this.removeFromQueue(task);\n   600→          forceCancelled++;\n   601→        } else if (task.status === 'completed' || task.status === 'failed') {\n   602→          completed++;\n   603→        }\n   604→      }\n   605→    } else {\n   606→      completed = processingTasks.length;\n   607→    }\n   608→\n   609→    return {\n   610→      completed,\n   611→      forceCancelled,\n   612→      durationMs: Date.now() - startTime,\n   613→    };\n   614→  }\n   615→\n   616→  private getProcessingTasks(): Task[] {\n   617→    const tasks: Task[] = [];\n   618→    for (const task of this.allTasks.values()) {\n   619→      if (task.status === 'processing') {\n   620→        tasks.push(task);\n   621→      }\n   622→    }\n   623→    return tasks;\n   624→  }\n   625→\n   626→  private waitForProcessing(tasks: Task[]): Promise<'done'> {\n   627→    return new Promise((resolve) => {\n   628→      const check = () => {\n   629→        if (tasks.every(t => t.status !== 'processing')) {\n   630→          resolve('done');\n   631→        } else {\n   632→          setTimeout(check, 10);\n   633→        }\n   634→      };\n   635→      check();\n   636→    });\n   637→  }\n   638→\n   639→  private timeoutPromise(ms: number): Promise<'timeout'> {\n   640→    return new Promise(resolve => setTimeout(() => resolve('timeout'), ms));\n   641→  }\n   642→\n   643→  // ─── Helpers ───────────────────────────────────────────────────────\n   644→\n   645→  private getOrCreateQueue(name: string): QueueState {\n   646→    if (!this.queues.has(name)) {\n   647→      this.queues.set(name, {\n   648→        tasks: [],\n   649→        deadLetterQueue: [],\n   650→        concurrencyLimit: null,\n   651→        middlewares: [],\n   652→        processor: null,\n   653→      });\n   654→    }\n   655→    return this.queues.get(name)!;\n   656→  }\n   657→\n   658→  private removeFromQueue(task: Task): void {\n   659→    const queue = this.queues.get(task.queue);\n   660→    if (!queue) return;\n   661→    const index = queue.tasks.indexOf(task);\n   662→    if (index !== -1) {\n   663→      queue.tasks.splice(index, 1);\n   664→    }\n   665→  }\n   666→\n   667→  private compareTasks(a: Task, b: Task): number {\n   668→    // Lower priority number = higher priority\n   669→    if (a.priority !== b.priority) return a.priority - b.priority;\n   670→    // Then by availability time\n   671→    if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n   672→      return a.availableAt.getTime() - b.availableAt.getTime();\n   673→    }\n   674→    // Then FIFO (creation time)\n   675→    return a.createdAt.getTime() - b.createdAt.getTime();\n   676→  }\n   677→}\n   678→"}]},"parent_tool_use_id":null,"session_id":"8bdd05c5-3a95-4f32-b942-b13e7309e3c4","uuid":"99247efa-9fa6-4cf3-aef7-464830016934","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/TaskQueue.ts","content":"import { randomUUID } from 'node:crypto';\nimport {\n  Task,\n  TaskOptions,\n  TaskStatus,\n  createTask,\n  Schedule,\n  MiddlewareFn,\n  ProcessorFn,\n  ProgressListener,\n  ShutdownResult,\n  ShutdownCallback,\n} from './types.js';\n\ninterface QueueState {\n  tasks: Task[];\n  deadLetterQueue: Task[];\n  concurrencyLimit: number | null;\n  middlewares: MiddlewareFn[];\n  processor: ProcessorFn | null;\n}\n\nexport class TaskQueue {\n  private queues: Map<string, QueueState> = new Map();\n  private allTasks: Map<string, Task> = new Map();\n  private schedules: Map<string, Schedule> = new Map();\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n  private shutdownCallbacks: ShutdownCallback[] = [];\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n\n  // ─── Phase 1: Basic FIFO Queue ────────────────────────────────────\n\n  addTask<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: queue system is shutting down');\n    }\n\n    const queueName = options.queue ?? 'default';\n\n    // Phase 3: Validate priority\n    if (options.priority !== undefined) {\n      if (!Number.isInteger(options.priority) || options.priority < 1 || options.priority > 10) {\n        throw new Error(`Invalid priority ${options.priority}: must be an integer between 1 and 10`);\n      }\n    }\n\n    // Phase 7: Validate dependencies\n    if (options.dependencies && options.dependencies.length > 0) {\n      for (const depId of options.dependencies) {\n        const depTask = this.allTasks.get(depId);\n        if (!depTask) {\n          throw new Error(`Dependency task ${depId} does not exist`);\n        }\n      }\n    }\n\n    const task = createTask(payload, { ...options, queue: queueName });\n\n    // Phase 7: Check circular dependencies\n    if (task.dependencies.length > 0) {\n      this.detectCircularDependencies(task);\n      // Mark already-completed dependencies as resolved\n      for (const depId of task.dependencies) {\n        const depTask = this.allTasks.get(depId);\n        if (depTask && depTask.status === 'completed') {\n          task.resolvedDependencies.add(depId);\n        }\n      }\n    }\n\n    this.allTasks.set(task.id, task);\n    const queue = this.getOrCreateQueue(queueName);\n    queue.tasks.push(task);\n\n    return task as Task<T>;\n  }\n\n  getNextTask(queueName: string = 'default'): Task | null {\n    const queue = this.queues.get(queueName);\n    if (!queue) return null;\n\n    // Phase 8: Check concurrency\n    if (queue.concurrencyLimit !== null) {\n      const activeCount = this.getActiveCount(queueName);\n      if (activeCount >= queue.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n\n    // Find the best candidate: consider priority, availability, FIFO, and dependencies\n    let bestIndex = -1;\n    let bestTask: Task | null = null;\n\n    for (let i = 0; i < queue.tasks.length; i++) {\n      const task = queue.tasks[i];\n      if (task.status !== 'pending') continue;\n\n      // Phase 4: Skip delayed tasks that aren't available yet\n      if (task.availableAt > now) continue;\n\n      // Phase 7: Skip tasks with unresolved dependencies\n      if (task.dependencies.length > 0) {\n        const allResolved = task.dependencies.every(depId => task.resolvedDependencies.has(depId));\n        if (!allResolved) continue;\n      }\n\n      if (bestTask === null || this.compareTasks(task, bestTask) < 0) {\n        bestTask = task;\n        bestIndex = i;\n      }\n    }\n\n    if (bestIndex === -1) return null;\n\n    const task = queue.tasks[bestIndex];\n    task.status = 'processing';\n    task.attempt += 1;\n\n    return task;\n  }\n\n  pendingCount(queueName: string = 'default'): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n    return queue.tasks.filter(t => t.status === 'pending').length;\n  }\n\n  getTask(taskId: string): Task | null {\n    return this.allTasks.get(taskId) ?? null;\n  }\n\n  // ─── Phase 2: Named Queues ────────────────────────────────────────\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ─── Phase 5: Retry with Backoff ──────────────────────────────────\n\n  completeTask(taskId: string): Task {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task ${taskId} not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.status = 'completed';\n    this.removeFromQueue(task);\n\n    // Phase 8: Free concurrency slot (implicit)\n\n    // Phase 7: Resolve dependents\n    this.resolveDependents(taskId);\n\n    return task;\n  }\n\n  failTask(taskId: string, error?: Error): Task {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task ${taskId} not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.failCount += 1;\n    task.error = error;\n\n    // Check if retries remain\n    if (task.attempt < task.maxRetries) {\n      // Re-add with exponential backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n      task.progressMessage = undefined;\n      // Task remains in queue\n      return task;\n    }\n\n    // No retries left\n    task.status = 'failed';\n    this.removeFromQueue(task);\n\n    // Phase 6: Move to dead letter queue\n    const queue = this.getOrCreateQueue(task.queue);\n    queue.deadLetterQueue.push(task);\n\n    return task;\n  }\n\n  // ─── Phase 6: Dead Letter Queue ───────────────────────────────────\n\n  getDeadLetterTasks(queueName: string = 'default'): Task[] {\n    const queue = this.queues.get(queueName);\n    if (!queue) return [];\n    return [...queue.deadLetterQueue];\n  }\n\n  redriveTask(taskId: string): Task {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task ${taskId} not found`);\n    if (task.status !== 'failed') {\n      throw new Error(`Task ${taskId} is not in failed state`);\n    }\n\n    // Remove from DLQ\n    const queue = this.getOrCreateQueue(task.queue);\n    const dlqIndex = queue.deadLetterQueue.indexOf(task);\n    if (dlqIndex === -1) {\n      throw new Error(`Task ${taskId} is not in the dead letter queue`);\n    }\n    queue.deadLetterQueue.splice(dlqIndex, 1);\n\n    // Reset for fresh retry\n    task.status = 'pending';\n    task.attempt = 0;\n    task.progress = 0;\n    task.progressMessage = undefined;\n    task.error = undefined;\n    task.availableAt = new Date();\n\n    queue.tasks.push(task);\n\n    return task;\n  }\n\n  clearDeadLetterQueue(queueName: string = 'default'): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n    const count = queue.deadLetterQueue.length;\n    // Remove from allTasks as well\n    for (const task of queue.deadLetterQueue) {\n      this.allTasks.delete(task.id);\n    }\n    queue.deadLetterQueue = [];\n    return count;\n  }\n\n  // ─── Phase 7: Task Dependencies ───────────────────────────────────\n\n  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task ${taskId} not found`);\n\n    const resolved = Array.from(task.resolvedDependencies);\n    const pending = task.dependencies.filter(dep => !task.resolvedDependencies.has(dep));\n\n    return {\n      dependencies: [...task.dependencies],\n      resolved,\n      pending,\n    };\n  }\n\n  private detectCircularDependencies(newTask: Task): void {\n    // BFS to check if any dependency chain leads back to newTask\n    const visited = new Set<string>();\n    const toVisit = [...newTask.dependencies];\n\n    while (toVisit.length > 0) {\n      const currentId = toVisit.pop()!;\n      if (visited.has(currentId)) continue;\n      visited.add(currentId);\n\n      // Check all tasks that this task depends on\n      const currentTask = this.allTasks.get(currentId);\n      if (currentTask) {\n        for (const depId of currentTask.dependencies) {\n          if (depId === newTask.id) {\n            throw new Error('Circular dependency detected');\n          }\n          toVisit.push(depId);\n        }\n      }\n    }\n  }\n\n  private resolveDependents(completedTaskId: string): void {\n    for (const task of this.allTasks.values()) {\n      if (task.dependencies.includes(completedTaskId) && !task.resolvedDependencies.has(completedTaskId)) {\n        task.resolvedDependencies.add(completedTaskId);\n      }\n    }\n  }\n\n  // ─── Phase 8: Concurrency Control ─────────────────────────────────\n\n  setConcurrency(queueName: string, limit: number | null): void {\n    const queue = this.getOrCreateQueue(queueName);\n    queue.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName: string = 'default'): number | null {\n    const queue = this.queues.get(queueName);\n    if (!queue) return null;\n    return queue.concurrencyLimit;\n  }\n\n  getActiveCount(queueName: string = 'default'): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n    return queue.tasks.filter(t => t.status === 'processing').length;\n  }\n\n  // ─── Phase 9: Progress Tracking and Cancellation ──────────────────\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task ${taskId} not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state`);\n    }\n\n    if (progress < 0 || progress > 100) {\n      throw new Error('Progress must be between 0 and 100');\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task ${taskId} not found`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  cancelTask(taskId: string): Task {\n    const task = this.allTasks.get(taskId);\n    if (!task) throw new Error(`Task ${taskId} not found`);\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Task ${taskId} cannot be cancelled (current: ${task.status})`);\n    }\n\n    task.status = 'cancelled';\n    this.removeFromQueue(task);\n\n    return task;\n  }\n\n  // ─── Phase 10: Recurring Tasks ────────────────────────────────────\n\n  addSchedule(\n    cronExpression: string,\n    queueName: string,\n    payload: unknown,\n    taskOptions?: Omit<TaskOptions, 'queue'>,\n  ): Schedule {\n    this.validateCron(cronExpression);\n\n    const schedule: Schedule = {\n      id: randomUUID(),\n      cronExpression,\n      queue: queueName,\n      payload,\n      taskOptions,\n      active: true,\n    };\n\n    this.schedules.set(schedule.id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): boolean {\n    const schedule = this.schedules.get(scheduleId);\n    if (!schedule) return false;\n    schedule.active = false;\n    this.schedules.delete(scheduleId);\n    return true;\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values()).filter(s => s.active);\n  }\n\n  tick(now: Date = new Date()): Task[] {\n    const created: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (!schedule.active) continue;\n\n      if (this.shouldRunSchedule(schedule, now)) {\n        const task = this.addTask(schedule.payload, {\n          ...schedule.taskOptions,\n          queue: schedule.queue,\n        });\n        created.push(task);\n        schedule.lastRun = now;\n      }\n    }\n\n    return created;\n  }\n\n  private validateCron(expr: string): void {\n    const parts = expr.trim().split(/\\s+/);\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${expr}`);\n    }\n\n    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n\n    // Validate supported patterns\n    const isValid =\n      (this.isValidCronField(minute) && this.isValidCronField(hour) &&\n       dayOfMonth === '*' && month === '*' && dayOfWeek === '*');\n\n    if (!isValid) {\n      throw new Error(`Unsupported cron expression: ${expr}`);\n    }\n  }\n\n  private isValidCronField(field: string): boolean {\n    if (field === '*') return true;\n    if (/^\\d+$/.test(field)) return true;\n    if (/^\\*\\/\\d+$/.test(field)) return true;\n    return false;\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const parts = schedule.cronExpression.trim().split(/\\s+/);\n    const [minuteExpr, hourExpr] = parts;\n\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n\n    // Check if current time matches the cron expression\n    if (!this.matchesCronField(minuteExpr, currentMinute)) return false;\n    if (!this.matchesCronField(hourExpr, currentHour)) return false;\n\n    // Prevent running more than once per matching minute\n    if (schedule.lastRun) {\n      const lastMinute = schedule.lastRun.getMinutes();\n      const lastHour = schedule.lastRun.getHours();\n      const lastDate = schedule.lastRun.toDateString();\n      const nowDate = now.toDateString();\n\n      if (lastDate === nowDate && lastHour === currentHour && lastMinute === currentMinute) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  private matchesCronField(expr: string, value: number): boolean {\n    if (expr === '*') return true;\n\n    // */N pattern\n    const stepMatch = expr.match(/^\\*\\/(\\d+)$/);\n    if (stepMatch) {\n      const step = parseInt(stepMatch[1], 10);\n      return value % step === 0;\n    }\n\n    // Exact number\n    const num = parseInt(expr, 10);\n    if (!isNaN(num)) {\n      return value === num;\n    }\n\n    return false;\n  }\n\n  // ─── Phase 11: Middleware Pipeline ─────────────────────────────────\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    const queue = this.getOrCreateQueue(queueName);\n    queue.middlewares.push(middleware);\n  }\n\n  setProcessor(queueName: string, processor: ProcessorFn): void {\n    const queue = this.getOrCreateQueue(queueName);\n    queue.processor = processor;\n  }\n\n  async processTask(queueName: string = 'default'): Promise<Task | null> {\n    const task = this.getNextTask(queueName);\n    if (!task) return null;\n\n    const queue = this.getOrCreateQueue(queueName);\n    const middlewares = [...queue.middlewares];\n    const processor = queue.processor;\n\n    try {\n      let index = 0;\n      let aborted = false;\n\n      const runNext = async (): Promise<void> => {\n        if (aborted) return;\n        if (index < middlewares.length) {\n          const mw = middlewares[index++];\n          await mw(task, runNext);\n        } else if (processor) {\n          await processor(task);\n        }\n      };\n\n      await runNext();\n\n      // If task is still processing (middleware/processor didn't change it), mark complete\n      if (task.status === 'processing') {\n        this.completeTask(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.failTask(task.id, err instanceof Error ? err : new Error(String(err)));\n      }\n    }\n\n    return task;\n  }\n\n  // ─── Phase 12: Graceful Shutdown ──────────────────────────────────\n\n  onShutdown(callback: ShutdownCallback): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.performShutdown(timeoutMs);\n    return this.shutdownPromise;\n  }\n\n  get shuttingDown(): boolean {\n    return this.isShuttingDown;\n  }\n\n  private async performShutdown(timeoutMs: number): Promise<ShutdownResult> {\n    const startTime = Date.now();\n    let completed = 0;\n    let forceCancelled = 0;\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      try {\n        await cb();\n      } catch (_e) {\n        // Ignore callback errors during shutdown\n      }\n    }\n\n    // Collect all processing tasks\n    const processingTasks = this.getProcessingTasks();\n\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        forceCancelled: 0,\n        durationMs: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks with timeout\n    const waitResult = await Promise.race([\n      this.waitForProcessing(processingTasks),\n      this.timeoutPromise(timeoutMs),\n    ]);\n\n    if (waitResult === 'timeout') {\n      // Force cancel remaining processing tasks\n      for (const task of processingTasks) {\n        if (task.status === 'processing') {\n          task.status = 'cancelled';\n          this.removeFromQueue(task);\n          forceCancelled++;\n        } else if (task.status === 'completed' || task.status === 'failed') {\n          completed++;\n        }\n      }\n    } else {\n      completed = processingTasks.length;\n    }\n\n    return {\n      completed,\n      forceCancelled,\n      durationMs: Date.now() - startTime,\n    };\n  }\n\n  private getProcessingTasks(): Task[] {\n    const tasks: Task[] = [];\n    for (const task of this.allTasks.values()) {\n      if (task.status === 'processing') {\n        tasks.push(task);\n      }\n    }\n    return tasks;\n  }\n\n  private waitForProcessing(tasks: Task[])