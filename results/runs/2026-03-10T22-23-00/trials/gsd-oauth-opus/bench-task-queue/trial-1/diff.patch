+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 4: Delayed and Scheduled Tasks', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should accept a delay in milliseconds', () => {
+    const task = tq.addTask('delayed', { delay: 5000 });
+    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());
+  });
+
+  it('should accept a specific future time', () => {
+    const future = new Date(Date.now() + 60000);
+    const task = tq.addTask('scheduled', { processAt: future });
+    expect(task.availableAt.getTime()).toBe(future.getTime());
+  });
+
+  it('should not return delayed tasks before availability', () => {
+    tq.addTask('delayed', { delay: 60000 });
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should return non-delayed tasks even when delayed tasks exist', () => {
+    tq.addTask('delayed', { delay: 60000 });
+    tq.addTask('immediate');
+
+    const task = tq.getNextTask();
+    expect(task?.payload).toBe('immediate');
+  });
+
+  it('should return delayed task when time has passed', () => {
+    const past = new Date(Date.now() - 1000);
+    tq.addTask('was-delayed', { processAt: past });
+
+    const task = tq.getNextTask();
+    expect(task?.payload).toBe('was-delayed');
+  });
+
+  it('should order available delayed tasks by availability, then priority, then FIFO', () => {
+    const t1 = new Date(Date.now() - 2000);
+    const t2 = new Date(Date.now() - 1000);
+
+    tq.addTask('earlier', { processAt: t1, priority: 5 });
+    tq.addTask('later', { processAt: t2, priority: 5 });
+
+    expect(tq.getNextTask()?.payload).toBe('earlier');
+    expect(tq.getNextTask()?.payload).toBe('later');
+  });
+
+  it('should prefer higher priority among available delayed tasks', () => {
+    const past = new Date(Date.now() - 1000);
+
+    tq.addTask('low', { processAt: past, priority: 10 });
+    tq.addTask('high', { processAt: past, priority: 1 });
+
+    expect(tq.getNextTask()?.payload).toBe('high');
+    expect(tq.getNextTask()?.payload).toBe('low');
+  });
+
+  it('should expose availability time on task', () => {
+    const task = tq.addTask('data', { delay: 5000 });
+    expect(task.availableAt).toBeInstanceOf(Date);
+    expect(task.availableAt.getTime()).toBeGreaterThan(task.createdAt.getTime());
+  });
+
+  it('should work with named queues', () => {
+    tq.addTask('delayed-email', { queue: 'emails', delay: 60000 });
+    tq.addTask('immediate-email', { queue: 'emails' });
+
+    expect(tq.getNextTask('emails')?.payload).toBe('immediate-email');
+    expect(tq.getNextTask('emails')).toBeNull();
+  });
+
+  it('should set availableAt to now for non-delayed tasks', () => {
+    const before = Date.now();
+    const task = tq.addTask('immediate');
+    const after = Date.now();
+
+    expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(before);
+    expect(task.availableAt.getTime()).toBeLessThanOrEqual(after);
+  });
+});
