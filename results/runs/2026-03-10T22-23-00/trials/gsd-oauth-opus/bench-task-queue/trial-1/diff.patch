+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should create a schedule', () => {
+    const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });
+
+    expect(schedule.id).toBeDefined();
+    expect(schedule.cronExpression).toBe('*/5 * * * *');
+    expect(schedule.queue).toBe('default');
+    expect(schedule.payload).toEqual({ type: 'cleanup' });
+    expect(schedule.active).toBe(true);
+  });
+
+  it('should list active schedules', () => {
+    tq.addSchedule('*/5 * * * *', 'default', 'payload1');
+    tq.addSchedule('0 * * * *', 'emails', 'payload2');
+
+    const schedules = tq.getSchedules();
+    expect(schedules).toHaveLength(2);
+  });
+
+  it('should remove a schedule', () => {
+    const schedule = tq.addSchedule('*/5 * * * *', 'default', 'data');
+    expect(tq.getSchedules()).toHaveLength(1);
+
+    const removed = tq.removeSchedule(schedule.id);
+    expect(removed).toBe(true);
+    expect(tq.getSchedules()).toHaveLength(0);
+  });
+
+  it('should return false when removing non-existent schedule', () => {
+    expect(tq.removeSchedule('nonexistent')).toBe(false);
+  });
+
+  it('should enqueue tasks on tick for */N pattern', () => {
+    tq.addSchedule('*/5 * * * *', 'default', { type: 'recurring' });
+
+    // Tick at a time divisible by 5
+    const time = new Date(2024, 0, 1, 12, 0, 0); // 12:00
+    const tasks = tq.tick(time);
+
+    expect(tasks).toHaveLength(1);
+    expect(tasks[0].payload).toEqual({ type: 'recurring' });
+    expect(tq.pendingCount()).toBe(1);
+  });
+
+  it('should not enqueue tasks when cron does not match', () => {
+    tq.addSchedule('*/5 * * * *', 'default', 'data');
+
+    const time = new Date(2024, 0, 1, 12, 3, 0); // 12:03 (not divisible by 5)
+    const tasks = tq.tick(time);
+
+    expect(tasks).toHaveLength(0);
+  });
+
+  it('should support hourly cron (0 * * * *)', () => {
+    tq.addSchedule('0 * * * *', 'default', 'hourly');
+
+    const onHour = new Date(2024, 0, 1, 14, 0, 0);
+    expect(tq.tick(onHour)).toHaveLength(1);
+
+    const offHour = new Date(2024, 0, 1, 14, 30, 0);
+    expect(tq.tick(offHour)).toHaveLength(0);
+  });
+
+  it('should support daily cron (0 0 * * *)', () => {
+    tq.addSchedule('0 0 * * *', 'default', 'daily');
+
+    const midnight = new Date(2024, 0, 1, 0, 0, 0);
+    expect(tq.tick(midnight)).toHaveLength(1);
+
+    const noon = new Date(2024, 0, 1, 12, 0, 0);
+    expect(tq.tick(noon)).toHaveLength(0);
+  });
+
+  it('should not run same schedule twice in same minute', () => {
+    tq.addSchedule('*/5 * * * *', 'default', 'data');
+
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    tq.tick(time);
+    const secondTick = tq.tick(time);
+
+    expect(secondTick).toHaveLength(0);
+    expect(tq.pendingCount()).toBe(1);
+  });
+
+  it('should stop creating tasks after schedule removal', () => {
+    const schedule = tq.addSchedule('*/5 * * * *', 'default', 'data');
+    tq.removeSchedule(schedule.id);
+
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    const tasks = tq.tick(time);
+
+    expect(tasks).toHaveLength(0);
+  });
+
+  it('should create regular tasks subject to queue rules', () => {
+    tq.addSchedule('*/5 * * * *', 'myqueue', 'data', { priority: 2 });
+
+    const time = new Date(2024, 0, 1, 12, 0, 0);
+    const tasks = tq.tick(time);
+
+    expect(tasks[0].queue).toBe('myqueue');
+    expect(tasks[0].priority).toBe(2);
+    expect(tasks[0].status).toBe('pending');
+  });
+
+  it('should throw for invalid cron expression', () => {
+    expect(() => tq.addSchedule('bad', 'default', 'data')).toThrow();
+    expect(() => tq.addSchedule('* * *', 'default', 'data')).toThrow();
+  });
+});
