q.updateProgress(task.id, 50);\n      tq.updateProgress(task.id, 100, 'done');\n\n      expect(updates).toHaveLength(3);\n      expect(updates[0]).toEqual({ progress: 25, message: 'started' });\n      expect(updates[1]).toEqual({ progress: 50, message: undefined });\n      expect(updates[2]).toEqual({ progress: 100, message: 'done' });\n    });\n\n    it('should support unsubscribing from progress', () => {\n      const task = tq.addTask('work');\n      tq.getNextTask();\n\n      const updates: number[] = [];\n      const unsubscribe = tq.onProgress(task.id, (progress) => {\n        updates.push(progress);\n      });\n\n      tq.updateProgress(task.id, 25);\n      unsubscribe();\n      tq.updateProgress(task.id, 50);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should start with 0 progress', () => {\n      const task = tq.addTask('work');\n      expect(task.progress).toBe(0);\n\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(0);\n    });\n  });\n\n  describe('Cancellation', () => {\n    it('should cancel a pending task', () => {\n      const task = tq.addTask('work');\n      const cancelled = tq.cancelTask(task.id);\n\n      expect(cancelled.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n      expect(tq.pendingCount()).toBe(0);\n    });\n\n    it('should cancel a processing task', () => {\n      const task = tq.addTask('work');\n      tq.getNextTask();\n      const cancelled = tq.cancelTask(task.id);\n\n      expect(cancelled.status).toBe('cancelled');\n    });\n\n    it('should throw when cancelling a completed task', () => {\n      const task = tq.addTask('work');\n      tq.getNextTask();\n      tq.completeTask(task.id);\n\n      expect(() => tq.cancelTask(task.id)).toThrow();\n    });\n\n    it('should throw when cancelling a failed task', () => {\n      const task = tq.addTask('work', { maxRetries: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id, new Error('fail'));\n\n      expect(() => tq.cancelTask(task.id)).toThrow();\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.addTask('work', { maxRetries: 3 });\n      tq.getNextTask();\n      tq.cancelTask(task.id);\n\n      expect(task.status).toBe('cancelled');\n      // Task should not be in queue at all\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should throw for non-existent task', () => {\n      expect(() => tq.cancelTask('nonexistent')).toThrow();\n    });\n\n    it('should remove cancelled pending task from queue', () => {\n      tq.addTask('keep');\n      const toCancel = tq.addTask('cancel');\n      tq.addTask('keep2');\n\n      tq.cancelTask(toCancel.id);\n\n      expect(tq.pendingCount()).toBe(2);\n      expect(tq.getNextTask()?.payload).toBe('keep');\n      expect(tq.getNextTask()?.payload).toBe('keep2');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1219,"cache_read_input_tokens":52490,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1219},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8bdd05c5-3a95-4f32-b942-b13e7309e3c4","uuid":"29347cec-be49-4893-8cfd-290de1c20d79"}
