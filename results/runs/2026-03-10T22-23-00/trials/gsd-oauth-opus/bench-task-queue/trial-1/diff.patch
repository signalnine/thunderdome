+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NSrA4M1SM7xWCPLtFSpvhH","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→import {\n     3→  Task,\n     4→  TaskOptions,\n     5→  TaskStatus,\n     6→  createTask,\n     7→  Schedule,\n     8→  MiddlewareFn,\n     9→  ProcessorFn,\n    10→  ProgressListener,\n    11→  ShutdownResult,\n    12→  ShutdownCallback,\n    13→} from './types.js';\n    14→\n    15→interface QueueState {\n    16→  tasks: Task[];\n    17→  deadLetterQueue: Task[];\n    18→  concurrencyLimit: number | null;\n    19→  middlewares: MiddlewareFn[];\n    20→  processor: ProcessorFn | null;\n    21→}\n    22→\n    23→export class TaskQueue {\n    24→  private queues: Map<string, QueueState> = new Map();\n    25→  private allTasks: Map<string, Task> = new Map();\n    26→  private schedules: Map<string, Schedule> = new Map();\n    27→  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n    28→  private shutdownCallbacks: ShutdownCallback[] = [];\n    29→  private isShuttingDown = false;\n    30→  private shutdownPromise: Promise<ShutdownResult> | null = null;\n    31→\n    32→  // ─── Phase 1: Basic FIFO Queue ────────────────────────────────────\n    33→\n    34→  addTask<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {\n    35→    if (this.isShuttingDown) {\n    36→      throw new Error('Cannot add tasks: queue system is shutting down');\n    37→    }\n    38→\n    39→    const queueName = options.queue ?? 'default';\n    40→\n    41→    // Phase 3: Validate priority\n    42→    if (options.priority !== undefined) {\n    43→      if (!Number.isInteger(options.priority) || options.priority < 1 || options.priority > 10) {\n    44→        throw new Error(`Invalid priority ${options.priority}: must be an integer between 1 and 10`);\n    45→      }\n    46→    }\n    47→\n    48→    // Phase 7: Validate dependencies\n    49→    if (options.dependencies && options.dependencies.length > 0) {\n    50→      for (const depId of options.dependencies) {\n    51→        const depTask = this.allTasks.get(depId);\n    52→        if (!depTask) {\n    53→          throw new Error(`Dependency task ${depId} does not exist`);\n    54→        }\n    55→      }\n    56→    }\n    57→\n    58→    const task = createTask(payload, { ...options, queue: queueName });\n    59→\n    60→    // Phase 7: Check circular dependencies\n    61→    if (task.dependencies.length > 0) {\n    62→      this.detectCircularDependencies(task);\n    63→      // Mark already-completed dependencies as resolved\n    64→      for (const depId of task.dependencies) {\n    65→        const depTask = this.allTasks.get(depId);\n    66→        if (depTask && depTask.status === 'completed') {\n    67→          task.resolvedDependencies.add(depId);\n    68→        }\n    69→      }\n    70→    }\n    71→\n    72→    this.allTasks.set(task.id, task);\n    73→    const queue = this.getOrCreateQueue(queueName);\n    74→    queue.tasks.push(task);\n    75→\n    76→    return task as Task<T>;\n    77→  }\n    78→\n    79→  getNextTask(queueName: string = 'default'): Task | null {\n    80→    const queue = this.queues.get(queueName);\n    81→    if (!queue) return null;\n    82→\n    83→    // Phase 8: Check concurrency\n    84→    if (queue.concurrencyLimit !== null) {\n    85→      const activeCount = this.getActiveCount(queueName);\n    86→      if (activeCount >= queue.concurrencyLimit) {\n    87→        return null;\n    88→      }\n    89→    }\n    90→\n    91→    const now = new Date();\n    92→\n    93→    // Find the best candidate: consider priority, availability, FIFO, and dependencies\n    94→    let bestIndex = -1;\n    95→    let bestTask: Task | null = null;\n    96→\n    97→    for (let i = 0; i < queue.tasks.length; i++) {\n    98→      const task = queue.tasks[i];\n    99→      if (task.status !== 'pending') continue;\n   100→\n   101→      // Phase