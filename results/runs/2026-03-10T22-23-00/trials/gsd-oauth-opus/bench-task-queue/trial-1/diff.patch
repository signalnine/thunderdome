+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should default to unlimited concurrency', () => {
+    expect(tq.getConcurrency()).toBeNull();
+  });
+
+  it('should set concurrency limit', () => {
+    tq.setConcurrency('default', 2);
+    expect(tq.getConcurrency()).toBe(2);
+  });
+
+  it('should respect concurrency limit', () => {
+    tq.setConcurrency('default', 2);
+
+    tq.addTask('a');
+    tq.addTask('b');
+    tq.addTask('c');
+
+    const t1 = tq.getNextTask();
+    expect(t1).not.toBeNull();
+
+    const t2 = tq.getNextTask();
+    expect(t2).not.toBeNull();
+
+    // Should return null because limit is reached
+    const t3 = tq.getNextTask();
+    expect(t3).toBeNull();
+  });
+
+  it('should free slot when task completes', () => {
+    tq.setConcurrency('default', 1);
+
+    tq.addTask('a');
+    tq.addTask('b');
+
+    const t1 = tq.getNextTask();
+    expect(t1).not.toBeNull();
+    expect(tq.getNextTask()).toBeNull();
+
+    tq.completeTask(t1!.id);
+
+    const t2 = tq.getNextTask();
+    expect(t2).not.toBeNull();
+    expect(t2?.payload).toBe('b');
+  });
+
+  it('should free slot when task fails', () => {
+    tq.setConcurrency('default', 1);
+
+    tq.addTask('a', { maxRetries: 0 });
+    tq.addTask('b');
+
+    const t1 = tq.getNextTask();
+    tq.failTask(t1!.id, new Error('fail'));
+
+    const t2 = tq.getNextTask();
+    expect(t2).not.toBeNull();
+    expect(t2?.payload).toBe('b');
+  });
+
+  it('should track active count', () => {
+    tq.addTask('a');
+    tq.addTask('b');
+
+    expect(tq.getActiveCount()).toBe(0);
+
+    tq.getNextTask();
+    expect(tq.getActiveCount()).toBe(1);
+
+    tq.getNextTask();
+    expect(tq.getActiveCount()).toBe(2);
+  });
+
+  it('should still respect priority ordering with concurrency limits', () => {
+    tq.setConcurrency('default', 1);
+
+    tq.addTask('low', { priority: 10 });
+    tq.addTask('high', { priority: 1 });
+
+    const task = tq.getNextTask();
+    expect(task?.payload).toBe('high');
+  });
+
+  it('should remove concurrency limit with null', () => {
+    tq.setConcurrency('default', 1);
+    expect(tq.getConcurrency()).toBe(1);
+
+    tq.setConcurrency('default', null);
+    expect(tq.getConcurrency()).toBeNull();
+  });
+
+  it('should handle per-queue concurrency independently', () => {
+    tq.setConcurrency('q1', 1);
+    tq.setConcurrency('q2', 1);
+
+    tq.addTask('q1-a', { queue: 'q1' });
+    tq.addTask('q1-b', { queue: 'q1' });
+    tq.addTask('q2-a', { queue: 'q2' });
+
+    const t1 = tq.getNextTask('q1');
+    expect(t1).not.toBeNull();
+    expect(tq.getNextTask('q1')).toBeNull(); // q1 at limit
+
+    const t2 = tq.getNextTask('q2');
+    expect(t2).not.toBeNull(); // q2 still has room
+  });
+
+  it('should return 0 active count for non-existent queue', () => {
+    expect(tq.getActiveCount('nonexistent')).toBe(0);
+  });
+});
