+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should register and execute middleware', async () => {
+    const order: string[] = [];
+
+    tq.use('default', (_task, next) => {
+      order.push('middleware1');
+      next();
+    });
+
+    tq.setProcessor('default', () => {
+      order.push('processor');
+    });
+
+    tq.addTask('work');
+    await tq.processTask();
+
+    expect(order).toEqual(['middleware1', 'processor']);
+  });
+
+  it('should execute middleware in registration order', async () => {
+    const order: string[] = [];
+
+    tq.use('default', (_task, next) => {
+      order.push('first');
+      next();
+    });
+
+    tq.use('default', (_task, next) => {
+      order.push('second');
+      next();
+    });
+
+    tq.use('default', (_task, next) => {
+      order.push('third');
+      next();
+    });
+
+    tq.setProcessor('default', () => {
+      order.push('handler');
+    });
+
+    tq.addTask('work');
+    await tq.processTask();
+
+    expect(order).toEqual(['first', 'second', 'third', 'handler']);
+  });
+
+  it('should skip processing when middleware does not call next', async () => {
+    const order: string[] = [];
+
+    tq.use('default', (_task, _next) => {
+      order.push('blocker');
+      // Not calling next!
+    });
+
+    tq.use('default', (_task, next) => {
+      order.push('never-reached');
+      next();
+    });
+
+    tq.setProcessor('default', () => {
+      order.push('handler');
+    });
+
+    tq.addTask('work');
+    await tq.processTask();
+
+    expect(order).toEqual(['blocker']);
+  });
+
+  it('should allow middleware to modify task', async () => {
+    tq.use('default', (task, next) => {
+      (task.payload as Record<string, unknown>).modified = true;
+      next();
+    });
+
+    let receivedPayload: unknown;
+    tq.setProcessor('default', (task) => {
+      receivedPayload = task.payload;
+    });
+
+    tq.addTask({ original: true });
+    await tq.processTask();
+
+    expect(receivedPayload).toEqual({ original: true, modified: true });
+  });
+
+  it('should mark task as failed when middleware throws', async () => {
+    tq.use('default', () => {
+      throw new Error('middleware error');
+    });
+
+    const task = tq.addTask('work', { maxRetries: 0 });
+    await tq.processTask();
+
+    const result = tq.getTask(task.id);
+    expect(result?.status).toBe('failed');
+    expect(result?.error?.message).toBe('middleware error');
+  });
+
+  it('should complete task after successful processing', async () => {
+    tq.setProcessor('default', () => {
+      // Success
+    });
+
+    const task = tq.addTask('work');
+    await tq.processTask();
+
+    const result = tq.getTask(task.id);
+    expect(result?.status).toBe('completed');
+  });
+
+  it('should return null when no tasks available', async () => {
+    const result = await tq.processTask();
+    expect(result).toBeNull();
+  });
+
+  it('should handle per-queue middleware independently', async () => {
+    const q1Log: string[] = [];
+    const q2Log: string[] = [];
+
+    tq.use('q1', (_task, next) => {
+      q1Log.push('q1-mw');
+      next();
+    });
+
+    tq.use('q2', (_task, next) => {
+      q2Log.push('q2-mw');
+      next();
+    });
+
+    tq.addTask('work1', { queue: 'q1' });
+    tq.addTask('work2', { queue: 'q2' });
+
+    await tq.processTask('q1');
+    await tq.processTask('q2');
+
+    expect(q1Log).toEqual(['q1-mw']);
+    expect(q2Log).toEqual(['q2-mw']);
+  });
+
+  it('should handle async middleware', async () => {
+    const order: string[] = [];
+
+    tq.use('default', async (_task, next) => {
+      order.push('async-start');
+      await new Promise(resolve => setTimeout(resolve, 10));
+      order.push('async-end');
+      await next();
+    });
+
+    tq.setProcessor('default', () => {
+      order.push('handler');
+    });
+
+    tq.addTask('work');
+    await tq.processTask();
+
+    expect(order).toEqual(['async-start', 'async-end', 'handler']);
+  });
+
+  it('should mark task failed when processor throws', async () => {
+    tq.setProcessor('default', () => {
+      throw new Error('processor error');
+    });
+
+    const task = tq.addTask('work', { maxRetries: 0 });
+    await tq.processTask();
+
+    const result = tq.getTask(task.id);
+    expect(result?.status).toBe('failed');
+    expect(result?.error?.message).toBe('processor error');
+  });
+
+  it('should auto-complete task when no processor is registered', async () => {
+    tq.addTask('work');
+    const task = await tq.processTask();
+
+    expect(task?.status).toBe('completed');
+  });
+});
