+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should add a task and return a task object', () => {
+    const task = tq.addTask({ message: 'hello' });
+    expect(task).toBeDefined();
+    expect(task.id).toBeDefined();
+    expect(typeof task.id).toBe('string');
+    expect(task.payload).toEqual({ message: 'hello' });
+    expect(task.status).toBe('pending');
+    expect(task.createdAt).toBeInstanceOf(Date);
+  });
+
+  it('should generate unique IDs for each task', () => {
+    const t1 = tq.addTask('a');
+    const t2 = tq.addTask('b');
+    expect(t1.id).not.toBe(t2.id);
+  });
+
+  it('should retrieve tasks in FIFO order', () => {
+    tq.addTask('first');
+    tq.addTask('second');
+    tq.addTask('third');
+
+    const r1 = tq.getNextTask();
+    expect(r1?.payload).toBe('first');
+
+    const r2 = tq.getNextTask();
+    expect(r2?.payload).toBe('second');
+
+    const r3 = tq.getNextTask();
+    expect(r3?.payload).toBe('third');
+  });
+
+  it('should transition retrieved task to processing state', () => {
+    tq.addTask('work');
+    const task = tq.getNextTask();
+    expect(task?.status).toBe('processing');
+  });
+
+  it('should return null when queue is empty', () => {
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should return null when all tasks are processing', () => {
+    tq.addTask('work');
+    tq.getNextTask();
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should track pending count', () => {
+    expect(tq.pendingCount()).toBe(0);
+    tq.addTask('a');
+    tq.addTask('b');
+    expect(tq.pendingCount()).toBe(2);
+    tq.getNextTask();
+    expect(tq.pendingCount()).toBe(1);
+  });
+
+  it('should retrieve a task by ID', () => {
+    const added = tq.addTask({ data: 42 });
+    const found = tq.getTask(added.id);
+    expect(found).toBe(added);
+    expect(found?.payload).toEqual({ data: 42 });
+  });
+
+  it('should return null for non-existent task ID', () => {
+    expect(tq.getTask('nonexistent')).toBeNull();
+  });
+
+  it('should handle various payload types', () => {
+    const t1 = tq.addTask(42);
+    const t2 = tq.addTask('string');
+    const t3 = tq.addTask([1, 2, 3]);
+    const t4 = tq.addTask(null);
+
+    expect(t1.payload).toBe(42);
+    expect(t2.payload).toBe('string');
+    expect(t3.payload).toEqual([1, 2, 3]);
+    expect(t4.payload).toBeNull();
+  });
+});
