+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 7: Task Dependencies', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should create a task with dependencies', () => {
+    const dep = tq.addTask('dependency');
+    const task = tq.addTask('dependent', { dependencies: [dep.id] });
+
+    expect(task.dependencies).toContain(dep.id);
+  });
+
+  it('should block task with unresolved dependencies', () => {
+    const dep = tq.addTask('dependency');
+    tq.addTask('dependent', { dependencies: [dep.id] });
+
+    // Get dependency first (it's pending)
+    const next = tq.getNextTask();
+    expect(next?.payload).toBe('dependency');
+
+    // Dependent should not be available
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should unblock task when dependency completes', () => {
+    const dep = tq.addTask('dependency');
+    tq.addTask('dependent', { dependencies: [dep.id] });
+
+    const depTask = tq.getNextTask();
+    tq.completeTask(depTask!.id);
+
+    const next = tq.getNextTask();
+    expect(next?.payload).toBe('dependent');
+  });
+
+  it('should handle multiple dependencies', () => {
+    const dep1 = tq.addTask('dep1');
+    const dep2 = tq.addTask('dep2');
+    tq.addTask('dependent', { dependencies: [dep1.id, dep2.id] });
+
+    // Complete dep1
+    const d1 = tq.getNextTask();
+    tq.completeTask(d1!.id);
+
+    // Dependent should still be blocked (dep2 not done)
+    const d2 = tq.getNextTask();
+    expect(d2?.payload).toBe('dep2');
+    expect(tq.getNextTask()).toBeNull();
+
+    // Complete dep2
+    tq.completeTask(d2!.id);
+
+    // Now dependent should be available
+    const next = tq.getNextTask();
+    expect(next?.payload).toBe('dependent');
+  });
+
+  it('should detect direct circular dependencies', () => {
+    const t1 = tq.addTask('task1');
+
+    // t1 exists, now try to add task that depends on t1
+    const t2 = tq.addTask('task2', { dependencies: [t1.id] });
+
+    // Now try to add dependency from t1 to t2 - but t1 is already created
+    // We'd need to make t1 depend on t2, which would be at creation time
+    // So let's test differently:
+    expect(t2.dependencies).toContain(t1.id);
+  });
+
+  it('should throw for non-existent dependency', () => {
+    expect(() => {
+      tq.addTask('work', { dependencies: ['nonexistent-id'] });
+    }).toThrow();
+  });
+
+  it('should keep dependents blocked when dependency fails', () => {
+    const dep = tq.addTask('dependency', { maxRetries: 0 });
+    tq.addTask('dependent', { dependencies: [dep.id] });
+
+    const d = tq.getNextTask();
+    tq.failTask(d!.id, new Error('failed'));
+
+    // Dependent should remain blocked (not failed)
+    const next = tq.getNextTask();
+    expect(next).toBeNull();
+  });
+
+  it('should inspect dependency status', () => {
+    const dep1 = tq.addTask('dep1');
+    const dep2 = tq.addTask('dep2');
+    const task = tq.addTask('dependent', { dependencies: [dep1.id, dep2.id] });
+
+    const status = tq.getDependencyStatus(task.id);
+    expect(status.dependencies).toHaveLength(2);
+    expect(status.resolved).toHaveLength(0);
+    expect(status.pending).toHaveLength(2);
+
+    // Complete dep1
+    const d1 = tq.getNextTask();
+    tq.completeTask(d1!.id);
+
+    const status2 = tq.getDependencyStatus(task.id);
+    expect(status2.resolved).toHaveLength(1);
+    expect(status2.pending).toHaveLength(1);
+  });
+
+  it('should throw when inspecting non-existent task dependencies', () => {
+    expect(() => tq.getDependencyStatus('nonexistent')).toThrow();
+  });
+
+  it('should handle task with already-completed dependencies', () => {
+    const dep = tq.addTask('dep');
+    const d = tq.getNextTask();
+    tq.completeTask(d!.id);
+
+    // Add dependent after dep is already completed
+    const task = tq.addTask('dependent', { dependencies: [dep.id] });
+
+    // Should be immediately available
+    const next = tq.getNextTask();
+    expect(next?.id).toBe(task.id);
+  });
+});
