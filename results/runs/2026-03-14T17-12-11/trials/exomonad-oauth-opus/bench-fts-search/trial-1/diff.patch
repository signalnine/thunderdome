+function sanitizeFtsQuery(query: string): string {
+  // Preserve quoted phrases, remove FTS5 special characters from unquoted parts
+  const parts: string[] = [];
+  const phraseRegex = /"([^"]*)"/g;
+  let lastIndex = 0;
+  let match;
+
+  while ((match = phraseRegex.exec(query)) !== null) {
+    // Sanitize text before the quote
+    const before = query.slice(lastIndex, match.index);
+    parts.push(before.replace(/[^\w\s]/g, ' '));
+    // Keep the quoted phrase (sanitize inside quotes too, but keep quotes)
+    const inner = match[1].replace(/[^\w\s]/g, ' ').trim();
+    if (inner) parts.push(`"${inner}"`);
+    lastIndex = phraseRegex.lastIndex;
+  }
+  // Sanitize remaining text after last quote
+  const remaining = query.slice(lastIndex);
+  parts.push(remaining.replace(/[^\w\s]/g, ' '));
+
+  return parts.join(' ').replace(/\s+/g, ' ').trim();
+}
