+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index';
+
+describe('solveToggle', () => {
+  it('should return empty array for empty target', () => {
+    const machine: Machine = {
+      target: [],
+      buttons: []
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should solve a simple toggle puzzle', () => {
+    // Light 0 needs to be ON, button 0 toggles light 0
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0]]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should return null for unsolvable puzzle', () => {
+    // Light 0 needs to be ON, but button toggles light 1
+    const machine: Machine = {
+      target: [true],
+      buttons: [[1]]
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should find minimum button presses', () => {
+    // Two lights, need both ON
+    // Button 0: toggle light 0
+    // Button 1: toggle light 1
+    // Button 2: toggle both
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0, 1]]
+    };
+    // Best solution: press button 2 only (1 press)
+    const result = solveToggle(machine);
+    expect(result).toEqual([2]);
+  });
+
+  it('should prefer lexicographically smallest on tie', () => {
+    // Both buttons achieve the same result
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]]
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]); // Lex smallest is [0]
+  });
+
+  it('should handle the example from the task', () => {
+    // Target: [true, true, false, true]
+    // Buttons:
+    //   0: toggles lights [0, 1]
+    //   1: toggles lights [1, 2, 3]
+    //   2: toggles lights [0, 3]
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]]
+    };
+    // This should be unsolvable based on the example
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should handle multiple lights and buttons', () => {
+    const machine: Machine = {
+      target: [true, false, true],
+      buttons: [[0], [1], [2], [0, 1], [1, 2], [0, 2]]
+    };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    if (result) {
+      // Verify solution
+      const state = [false, false, false];
+      for (const btn of result) {
+        for (const light of machine.buttons[btn]) {
+          state[light] = !state[light];
+        }
+      }
+      expect(state).toEqual([true, false, true]);
+    }
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return zeros for empty target', () => {
+    expect(solveCounter([], [], 5)).toEqual([]);
+  });
+
+  it('should solve a simple counter puzzle', () => {
+    // One counter needs to be 2, one button increments it
+    const result = solveCounter([2], [[0]], 5);
+    expect(result).toEqual([2]);
+  });
+
+  it('should handle modulus wraparound', () => {
+    // mod 3, target is 2, but need to press button 5 times (5 % 3 = 2)
+    // Actually the solution should be 2, not 5
+    const result = solveCounter([2], [[0]], 3);
+    expect(result).toEqual([2]);
+  });
+
+  it('should find minimum total presses', () => {
+    // Two counters, need [1, 1]
+    // Button 0: increments counter 0
+    // Button 1: increments counter 1
+    // Button 2: increments both
+    // Best: press button 2 once (total = 1)
+    const result = solveCounter([1, 1], [[0], [1], [0, 1]], 5);
+    expect(result).toEqual([0, 0, 1]);
+  });
+
+  it('should prefer lexicographically smallest on tie', () => {
+    // mod 5, need counter 0 = 2
+    // Button 0: increments counter 0
+    // Button 1: increments counter 0 (same effect)
+    // Solution could be [2, 0] or [0, 2] or [1, 1]
+    // Minimum total is 2, lex smallest is [2, 0]
+    const result = solveCounter([2], [[0], [0]], 5);
+    expect(result).toEqual([2, 0]);
+  });
+
+  it('should return null for unsolvable puzzle', () => {
+    // mod 2, need counter 0 = 1
+    // But button only affects counter 1
+    const result = solveCounter([1, 0], [[1]], 2);
+    expect(result).toBeNull();
+  });
+
+  it('should handle multiple counters with shared buttons', () => {
+    const result = solveCounter([2, 3, 1], [[0, 1], [1, 2], [0, 2]], 5);
+    expect(result).not.toBeNull();
+    if (result) {
+      // Verify solution
+      const state = [0, 0, 0];
+      for (let i = 0; i < result.length; i++) {
+        for (const idx of [[0, 1], [1, 2], [0, 2]][i]) {
+          state[idx] = (state[idx] + result[i]) % 5;
+        }
+      }
+      expect(state).toEqual([2, 3, 1]);
+    }
+  });
+});
