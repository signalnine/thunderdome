+{"type":"tool_use","timestamp":1772760170146,"sessionID":"ses_33f429f36ffexnomPtY6GOCoqX","part":{"id":"prt_cc0bd7a99001oZNUUffDRVuC1c","sessionID":"ses_33f429f36ffexnomPtY6GOCoqX","messageID":"msg_cc0bd77d60027bZDl4RZziWiRt","type":"tool","callID":"b35897472","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/TaskQueue.ts","content":"// src/TaskQueue.ts\n// In-memory task queue implementation supporting multiple phases.\n\nimport { randomUUID } from \"crypto\";\n\nexport type TaskStatus =\n  | \"pending\"\n  | \"processing\"\n  | \"completed\"\n  | \"failed\"\n  | \"cancelled\";\n\nexport interface Task<T = any> {\n  id: string;\n  payload: T;\n  status: TaskStatus;\n  createdAt: number; // epoch ms\n  // execution metadata\n  attempts: number;\n  maxAttempts: number;\n  backoffMs: number; // base backoff\n  availableAt: number; // when it may be taken\n  // priority (higher number = higher priority)\n  priority: number;\n  // dependencies\n  dependencies: Set<string>;\n  dependents: Set<string>;\n  // progress (0-100)\n  progress?: number;\n  // error info if failed\n  error?: any;\n}\n\nexport interface Middleware<T = any> {\n  (task: Task<T>): void | Promise<void>;\n}\n\n/**\n * Options for adding a task.\n */\nexport interface AddTaskOptions<T = any> {\n  payload: T;\n  queue?: string; // default queue name\n  priority?: number; // default 0\n  delayMs?: number; // delay before task becomes available\n  maxAttempts?: number; // default 1\n  backoffMs?: number; // base backoff for retries, default 0\n  dependencies?: string[]; // ids of tasks that must complete first\n}\n\n/**\n * Core Queue Manager handling multiple named queues.\n */\nexport class QueueManager {\n  private queues: Map<string, Queue> = new Map();\n  private middleware: Middleware[] = [];\n  private shuttingDown: boolean = false;\n\n  constructor() {\n    // ensure default queue exists\n    this.getOrCreateQueue(\"default\");\n  }\n\n  /** Register a middleware that runs before a task is returned for processing */\n  use(mw: Middleware) {\n    this.middleware.push(mw);\n  }\n\n  /** Add a task to a queue */\n  addTask<T>(options: AddTaskOptions<T>): Task<T> {\n    const {\n      payload,\n      queue = \"default\",\n      priority = 0,\n      delayMs = 0,\n      maxAttempts = 1,\n      backoffMs = 0,\n      dependencies = [],\n    } = options;\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: \"pending\",\n      createdAt: Date.now(),\n      attempts: 0,\n      maxAttempts,\n      backoffMs,\n      availableAt: Date.now() + delayMs,\n      priority,\n      dependencies: new Set(dependencies),\n      dependents: new Set(),\n    };\n\n    const q = this.getOrCreateQueue(queue);\n\n    // Validate dependencies exist\n    for (const depId of dependencies) {\n      const depTask = q.getTask(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task ${depId} does not exist`);\n      }\n    }\n\n    // Detect circular dependencies via DFS\n    const visited = new Set<string>();\n    const stack = new Set<string>();\n    const hasCycle = (tid: string): boolean => {\n      if (stack.has(tid)) return true;\n      if (visited.has(tid)) return false;\n      visited.add(tid);\n      stack.add(tid);\n      const t = q.getTask(tid);\n      if (t) {\n        for (const dep of t.dependencies) {\n          if (hasCycle(dep)) return true;\n        }\n      }\n      stack.delete(tid);\n      return false;\n    };\n    q.addTask(task);\n    if (hasCycle(task.id)) {\n      // rollback\n      q.removeTask(task.id);\n      throw new Error(`Circular dependency detected for task ${task.id}`);\n    }\n\n    // Register this task as dependent of its dependencies\n    for (const depId of dependencies) {\n      const depTask = q.getTask(depId)!;\n      depTask.dependents.add(task.id);\n    }\n\n    return task;\n  }\n\n  /** Retrieve next available task from a queue */\n  async getNextTask(queueName = \"default\"): Promise<Task<any> | null> {\n    if (this.shuttingDown) return null;\n    const q = this.queues.get(queueName);\n    if (!q) return null;\n    const task = q.peekNext();\n    if (!task) return null;\n    // run middleware (allow async)\n    for (const mw of this.middleware) {\n      await mw(task);\n    }\n    return task;\n  }\n\n  /** Mark a task as completed or failed */\n  finishTask(taskId: string, success: boolean, error?: any): void {\n    // Find which queue holds the task\n    for (const q of this.queues.values()) {\n      const task = q.getTask(taskId);\n      if (task) {\n        q.finishTask(task, success, error);\n        return;\n      }\n    }\n    throw new Error(`Task ${taskId} not found`);\n  }\n\n  /** Cancel a pending task */\n  cancelTask(taskId: string): void {\n    for (const q of this.queues.values()) {\n      const task = q.getTask(taskId);\n      if (task) {\n        q.cancelTask(task);\n        return;\n      }\n    }\n    throw new Error(`Task ${taskId} not found`);\n  }\n\n  /** Retrieve dead-letter tasks from a queue */\n  getDeadLetterTasks(queueName = \"default\"): Task<any>[] {\n    const q = this.queues.get(queueName);\n    if (!q) return [];\n    return q.deadLetter;\n  }\n\n  /** Graceful shutdown – stop providing new tasks */\n  async shutdown(): Promise<void> {\n    this.shuttingDown = true;\n    // wait for all processing tasks to complete (simple poll)\n    const poll = async () => {\n      const stillRunning = Array.from(this.queues.values()).some(\n        (q) => q.processingCount > 0\n      );\n      if (stillRunning) {\n        await new Promise((res) => setTimeout(res, 50));\n        return poll();\n      }\n    };\n    await poll();\n  }\n\n  // internal helper\n  private getOrCreateQueue(name: string): Queue {\n    let q = this.queues.get(name);\n    if (!q) {\n      q = new Queue(name);\n      this.queues.set(name, q);\n    }\n    return q;\n  }\n}\n\n/**\n * Simple FIFO/priority queue for a single named queue.\n */\nclass Queue {\n  readonly name: string;\n  private tasks: Map<string, Task> = new Map();\n  // list of task ids in insertion order for FIFO; we will sort when retrieving\n  private pendingIds: Set<string> = new Set();\n  deadLetter: Task[] = [];\n  processingCount: number = 0;\n  // optional concurrency limit (default unlimited)\n  maxConcurrency: number = Infinity;\n\n  constructor(name: string) {\n    this.name = name;\n  }\n\n  addTask(task: Task): void {\n    this.tasks.set(task.id, task);\n    this.pendingIds.add(task.id);\n  }\n\n  removeTask(taskId: string): void {\n    this.tasks.delete(taskId);\n    this.pendingIds.delete(taskId);\n  }\n\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  /** Return the next eligible pending task respecting priority, delay, dependencies, and concurrency */\n  peekNext(): Task | null {\n    if (this.processingCount >= this.maxConcurrency) return null;\n    const now = Date.now();\n    // gather eligible tasks\n    const eligible: Task[] = [];\n    for (const id of this.pendingIds) {\n      const t = this.tasks.get(id)!;\n      if (t.status !== \"pending\") continue;\n      if (t.availableAt > now) continue;\n      // dependencies must be completed\n      let depsMet = true;\n      for (const depId of t.dependencies) {\n        const dep = this.tasks.get(depId);\n        if (!dep || dep.status !== \"completed\") {\n          depsMet = false;\n          break;\n        }\n      }\n      if (!depsMet) continue;\n      eligible.push(t);\n    }\n    if (eligible.length === 0) return null;\n    // sort by priority desc, then createdAt asc\n    eligible.sort((a, b) => {\n      if (b.priority !== a.priority) return b.priority - a.priority;\n      return a.createdAt - b.createdAt;\n    });\n    const next = eligible[0];\n    next.status = \"processing\";\n    this.processingCount++;\n    this.pendingIds.delete(next.id);\n    return next;\n  }\n\n  /** Called when a task finishes processing */\n  finishTask(task: Task, success: boolean, error?: any): void {\n    this.processingCount = Math.max(this.processingCount - 1, 0);\n    if (success) {\n      task.status = \"completed\";\n    } else {\n      task.attempts++;\n      task.error = error;\n      if (task.attempts < task.maxAttempts) {\n        // schedule retry with backoff (exponential)\n        const delay = task.backoffMs * Math.pow(2, task.attempts - 1);\n        task.availableAt = Date.now() + delay;\n        task.status = \"pending\";\n        this.pendingIds.add(task.id);\n      } else {\n        task.status = \"failed\";\n        this.deadLetter.push(task);\n      }\n    }\n    // unblock dependents if completed\n    if (task.status === \"completed\") {\n      for (const depId of task.dependents) {\n        const depTask = this.tasks.get(depId);\n        if (depTask) {\n          // nothing specific needed; next peek will see deps met\n        }\n      }\n    }\n  }\n\n  cancelTask(task: Task): void {\n    if (task.status === \"pending\") {\n      task.status = \"cancelled\";\n      this.pendingIds.delete(task.id);\n    }\n  }\n}\n\nexport default QueueManager;\n"},"output":"Wrote file successfully.","title":"src/TaskQueue.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/TaskQueue.ts","exists":false,"truncated":false},"time":{"start":1772760170133,"end":1772760170145}}}}
