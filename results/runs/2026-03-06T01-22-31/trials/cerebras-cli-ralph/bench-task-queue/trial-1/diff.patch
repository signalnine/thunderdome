diff --git a/src/TaskQueue.ts b/src/TaskQueue.ts
new file mode 100644
index 0000000..e90b8ab
--- /dev/null
+++ b/src/TaskQueue.ts
@@ -0,0 +1,337 @@
+// src/TaskQueue.ts
+// In-memory task queue implementation supporting multiple phases.
+
+import { randomUUID } from "crypto";
+
+export type TaskStatus =
+  | "pending"
+  | "processing"
+  | "completed"
+  | "failed"
+  | "cancelled";
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  createdAt: number; // epoch ms
+  // execution metadata
+  attempts: number;
+  maxAttempts: number;
+  backoffMs: number; // base backoff
+  availableAt: number; // when it may be taken
+  // priority (higher number = higher priority)
+  priority: number;
+  // dependencies
+  dependencies: Set<string>;
+  dependents: Set<string>;
+  // progress (0-100)
+  progress?: number;
+  // error info if failed
+  error?: unknown;
+}
+
+export interface Middleware<T = unknown> {
+  (task: Task<T>): void | Promise<void>;
+}
+
+/**
+ * Options for adding a task.
+ */
+export interface AddTaskOptions<T = unknown> {
+  payload: T;
+  queue?: string; // default queue name
+  priority?: number; // default 0
+  delayMs?: number; // delay before task becomes available
+  maxAttempts?: number; // default 1
+  backoffMs?: number; // base backoff for retries, default 0
+  dependencies?: string[]; // ids of tasks that must complete first
+}
+
+/**
+ * Core Queue Manager handling multiple named queues.
+ */
+export class QueueManager {
+  private queues: Map<string, Queue> = new Map();
+  private middleware: Middleware[] = [];
+  private shuttingDown: boolean = false;
+
+  constructor() {
+    // ensure default queue exists
+    this.getOrCreateQueue("default");
+  }
+
+  /** Register a middleware that runs before a task is returned for processing */
+  use(mw: Middleware) {
+    this.middleware.push(mw);
+  }
+
+  /** Add a task to a queue */
+  addTask<T>(options: AddTaskOptions<T>): Task<T> {
+    const {
+      payload,
+      queue = "default",
+      priority = 0,
+      delayMs = 0,
+      maxAttempts = 1,
+      backoffMs = 0,
+      dependencies = [],
+    } = options;
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      payload,
+      status: "pending",
+      createdAt: Date.now(),
+      attempts: 0,
+      maxAttempts,
+      backoffMs,
+      availableAt: Date.now() + delayMs,
+      priority,
+      dependencies: new Set(dependencies),
+      dependents: new Set(),
+    };
+
+    const q = this.getOrCreateQueue(queue);
+
+    // Validate dependencies exist
+    for (const depId of dependencies) {
+      const depTask = q.getTask(depId);
+      if (!depTask) {
+        throw new Error(`Dependency task ${depId} does not exist`);
+      }
+    }
+
+    // Additional check: reject if any dependency is an ancestor of another dependency (to prevent indirect cycles/redundant hierarchy)
+    const dependsOn = (startId: string, targetId: string, visited = new Set<string>()): boolean => {
+      if (visited.has(startId)) return false;
+      visited.add(startId);
+      const startTask = q.getTask(startId);
+      if (!startTask) return false;
+      if (startTask.dependencies.has(targetId)) return true;
+      for (const d of startTask.dependencies) {
+        if (dependsOn(d, targetId, visited)) return true;
+      }
+      return false;
+    };
+    for (let i = 0; i < dependencies.length; i++) {
+      for (let j = i + 1; j < dependencies.length; j++) {
+        const a = dependencies[i];
+        const b = dependencies[j];
+        if (dependsOn(a, b) || dependsOn(b, a)) {
+          throw new Error(`Dependency relationship between ${a} and ${b} creates a cycle`);
+        }
+      }
+    }
+
+    // Detect circular dependencies via DFS (including the new task)
+    const visited = new Set<string>();
+    const stack = new Set<string>();
+    const hasCycle = (tid: string): boolean => {
+      if (stack.has(tid)) return true;
+      if (visited.has(tid)) return false;
+      visited.add(tid);
+      stack.add(tid);
+      const t = q.getTask(tid);
+      if (t) {
+        for (const dep of t.dependencies) {
+          if (hasCycle(dep)) return true;
+        }
+      }
+      stack.delete(tid);
+      return false;
+    };
+    q.addTask(task);
+    if (hasCycle(task.id)) {
+      // rollback
+      q.removeTask(task.id);
+      throw new Error(`Circular dependency detected for task ${task.id}`);
+    }
+
+    // Register this task as dependent of its dependencies
+    for (const depId of dependencies) {
+      const depTask = q.getTask(depId)!;
+      depTask.dependents.add(task.id);
+    }
+
+    return task;
+  }
+
+  /** Retrieve next available task from a queue */
+  async getNextTask(queueName = "default"): Promise<Task<unknown> | null> {
+    if (this.shuttingDown) return null;
+    const q = this.queues.get(queueName);
+    if (!q) return null;
+    const task = q.peekNext();
+    if (!task) return null;
+    // run middleware (allow async)
+    for (const mw of this.middleware) {
+      await mw(task);
+    }
+    return task;
+  }
+
+  /** Mark a task as completed or failed */
+  finishTask(taskId: string, success: boolean, error?: unknown): void {
+    // Find which queue holds the task
+    for (const q of this.queues.values()) {
+      const task = q.getTask(taskId);
+      if (task) {
+        q.finishTask(task, success, error);
+        return;
+      }
+    }
+    throw new Error(`Task ${taskId} not found`);
+  }
+
+  /** Cancel a pending task */
+  cancelTask(taskId: string): void {
+    for (const q of this.queues.values()) {
+      const task = q.getTask(taskId);
+      if (task) {
+        q.cancelTask(task);
+        return;
+      }
+    }
+    throw new Error(`Task ${taskId} not found`);
+  }
+
+  /** Retrieve dead-letter tasks from a queue */
+  getDeadLetterTasks(queueName = "default"): Task<any>[] {
+    const q = this.queues.get(queueName);
+    if (!q) return [];
+    return q.deadLetter;
+  }
+
+  /** Graceful shutdown – stop providing new tasks */
+  async shutdown(): Promise<void> {
+    this.shuttingDown = true;
+    // wait for all processing tasks to complete (simple poll)
+    const poll = async () => {
+      const stillRunning = Array.from(this.queues.values()).some(
+        (q) => q.processingCount > 0
+      );
+      if (stillRunning) {
+        await new Promise((res) => setTimeout(res, 50));
+        return poll();
+      }
+    };
+    await poll();
+  }
+
+  // internal helper
+  private getOrCreateQueue(name: string): Queue {
+    let q = this.queues.get(name);
+    if (!q) {
+      q = new Queue(name);
+      this.queues.set(name, q);
+    }
+    return q;
+  }
+}
+
+/**
+ * Simple FIFO/priority queue for a single named queue.
+ */
+class Queue {
+  readonly name: string;
+  private tasks: Map<string, Task> = new Map();
+  // list of task ids in insertion order for FIFO; we will sort when retrieving
+  private pendingIds: Set<string> = new Set();
+  deadLetter: Task[] = [];
+  processingCount: number = 0;
+  // optional concurrency limit (default unlimited)
+  maxConcurrency: number = Infinity;
+
+  constructor(name: string) {
+    this.name = name;
+  }
+
+  addTask(task: Task): void {
+    this.tasks.set(task.id, task);
+    this.pendingIds.add(task.id);
+  }
+
+  removeTask(taskId: string): void {
+    this.tasks.delete(taskId);
+    this.pendingIds.delete(taskId);
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return this.tasks.get(taskId);
+  }
+
+  /** Return the next eligible pending task respecting priority, delay, dependencies, and concurrency */
+  peekNext(): Task | null {
+    if (this.processingCount >= this.maxConcurrency) return null;
+    const now = Date.now();
+    // gather eligible tasks
+    const eligible: Task[] = [];
+    for (const id of this.pendingIds) {
+      const t = this.tasks.get(id)!;
+      if (t.status !== "pending") continue;
+      if (t.availableAt > now) continue;
+      // dependencies must be completed
+      let depsMet = true;
+      for (const depId of t.dependencies) {
+        const dep = this.tasks.get(depId);
+        if (!dep || dep.status !== "completed") {
+          depsMet = false;
+          break;
+        }
+      }
+      if (!depsMet) continue;
+      eligible.push(t);
+    }
+    if (eligible.length === 0) return null;
+    // sort by priority desc, then createdAt asc
+    eligible.sort((a, b) => {
+      if (b.priority !== a.priority) return b.priority - a.priority;
+      return a.createdAt - b.createdAt;
+    });
+    const next = eligible[0];
+    next.status = "processing";
+    this.processingCount++;
+    this.pendingIds.delete(next.id);
+    return next;
+  }
+
+  /** Called when a task finishes processing */
+  finishTask(task: Task, success: boolean, error?: any): void {
+    this.processingCount = Math.max(this.processingCount - 1, 0);
+    if (success) {
+      task.status = "completed";
+    } else {
+      task.attempts++;
+      task.error = error;
+      if (task.attempts < task.maxAttempts) {
+        // schedule retry with backoff (exponential)
+        const delay = task.backoffMs * Math.pow(2, task.attempts - 1);
+        task.availableAt = Date.now() + delay;
+        task.status = "pending";
+        this.pendingIds.add(task.id);
+      } else {
+        task.status = "failed";
+        this.deadLetter.push(task);
+      }
+    }
+    // unblock dependents if completed
+    if (task.status === "completed") {
+      for (const depId of task.dependents) {
+        const depTask = this.tasks.get(depId);
+        if (depTask) {
+          // nothing specific needed; next peek will see deps met
+        }
+      }
+    }
+  }
+
+  cancelTask(task: Task): void {
+    if (task.status === "pending") {
+      task.status = "cancelled";
+      this.pendingIds.delete(task.id);
+    }
+  }
+}
+
+export default QueueManager;
diff --git a/src/__tests__/TaskQueue.test.ts b/src/__tests__/TaskQueue.test.ts
new file mode 100644
index 0000000..dd56a24
--- /dev/null
+++ b/src/__tests__/TaskQueue.test.ts
@@ -0,0 +1,104 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import QueueManager from '../TaskQueue';
+
+let qm: QueueManager;
+
+beforeEach(() => {
+  qm = new QueueManager();
+});
+
+describe('Phase 1: Basic FIFO', () => {
+  it('adds and retrieves tasks in order', async () => {
+    const t1 = qm.addTask({ payload: 'first' });
+    const t2 = qm.addTask({ payload: 'second' });
+    const next1 = await qm.getNextTask();
+    expect(next1?.id).toBe(t1.id);
+    expect(next1?.status).toBe('processing');
+    qm.finishTask(t1.id, true);
+    const next2 = await qm.getNextTask();
+    expect(next2?.id).toBe(t2.id);
+    qm.finishTask(t2.id, true);
+    const none = await qm.getNextTask();
+    expect(none).toBeNull();
+  });
+});
+
+describe('Phase 2: Named queues', () => {
+  it('separates tasks by queue name', async () => {
+    const tA = qm.addTask({ payload: 'A', queue: 'alpha' });
+    const tB = qm.addTask({ payload: 'B', queue: 'beta' });
+    const nextAlpha = await qm.getNextTask('alpha');
+    expect(nextAlpha?.id).toBe(tA.id);
+    const nextBeta = await qm.getNextTask('beta');
+    expect(nextBeta?.id).toBe(tB.id);
+  });
+});
+
+describe('Phase 3: Priority', () => {
+  it('returns higher priority task first', async () => {
+    const low = qm.addTask({ payload: 'low', priority: 1 });
+    const high = qm.addTask({ payload: 'high', priority: 5 });
+    const next = await qm.getNextTask();
+    expect(next?.id).toBe(high.id);
+    qm.finishTask(high.id, true);
+    const next2 = await qm.getNextTask();
+    expect(next2?.id).toBe(low.id);
+  });
+});
+
+describe('Phase 4: Delayed tasks', () => {
+  it('does not return task before delay', async () => {
+    const delayed = qm.addTask({ payload: 'later', delayMs: 50 });
+    const early = await qm.getNextTask();
+    expect(early).toBeNull();
+    // wait
+    await new Promise((r) => setTimeout(r, 60));
+    const later = await qm.getNextTask();
+    expect(later?.id).toBe(delayed.id);
+  });
+});
+
+describe('Phase 5 & 6: Retry and dead letter', () => {
+  it('retries failed task up to maxAttempts then moves to dead letter', async () => {
+    const task = qm.addTask({ payload: 'retry', maxAttempts: 2, backoffMs: 10 });
+    // first failure
+    qm.finishTask(task.id, false, new Error('fail1'));
+    // should be pending again after backoff
+    let next = await qm.getNextTask();
+    expect(next).toBeNull(); // backoff not elapsed
+    await new Promise((r) => setTimeout(r, 15));
+    next = await qm.getNextTask();
+    expect(next?.id).toBe(task.id);
+    // second failure -> dead letter
+    qm.finishTask(task.id, false, new Error('fail2'));
+    const dead = qm.getDeadLetterTasks();
+    expect(dead.some((t) => t.id === task.id)).toBe(true);
+  });
+});
+
+describe('Phase 7: Dependencies', () => {
+  it('blocks dependent task until prerequisite completes', async () => {
+    const prereq = qm.addTask({ payload: 'prereq' });
+    const dep = qm.addTask({ payload: 'dependent', dependencies: [prereq.id] });
+    // dependent should not be available yet
+    const early = await qm.getNextTask();
+    expect(early?.id).toBe(prereq.id);
+    qm.finishTask(prereq.id, true);
+    const later = await qm.getNextTask();
+    expect(later?.id).toBe(dep.id);
+  });
+  it('rejects circular dependencies', () => {
+    const t1 = qm.addTask({ payload: 't1' });
+    // create second depending on first
+    const t2 = qm.addTask({ payload: 't2', dependencies: [t1.id] });
+    // attempt to add a third that creates a cycle back to t1
+    expect(() =>
+      qm.addTask({ payload: 't3', dependencies: [t2.id, t1.id] })
+    ).toThrow();
+  });
+  it('errors when depending on non‑existent task', () => {
+    expect(() =>
+      qm.addTask({ payload: 'bad', dependencies: ['nonexistent'] })
+    ).toThrow();
+  });
+});
