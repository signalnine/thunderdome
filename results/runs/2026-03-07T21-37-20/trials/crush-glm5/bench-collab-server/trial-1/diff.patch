+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export interface InsertOperation {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOperation {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOperation | DeleteOperation;
+
+export interface WsMessage {
+  type: 'operation' | 'ack' | 'sync' | 'error';
+  [key: string]: unknown;
+}
+
+export interface SyncMessage extends WsMessage {
+  type: 'sync';
+  content: string;
+  version: number;
+}
+
+export interface AckMessage extends WsMessage {
+  type: 'ack';
+  version: number;
+}
+
+export interface OperationMessage extends WsMessage {
+  type: 'operation';
+  operation: Operation;
+  version?: number;
+}
+
+export interface ErrorMessage extends WsMessage {
+  type: 'error';
+  message: string;
+}
