@@ -0,0 +1,184 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import type { IncomingMessage } from 'http';
+import type Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+import type { Document, Operation } from './models.js';
+import { applyOperation, validateOperation, transformOperation } from './ot.js';
+
+interface DocumentRoom {
+  docId: string;
+  clients: Map<WebSocket, string>;
+  pendingOperations: Array<{ op: Operation; baseVersion: number }>;
+  currentVersion: number;
+  content: string;
+}
+
+export function createWebSocketServer(db: Database.Database): WebSocketServer {
+  const wss = new WebSocketServer({ noServer: true });
+  const rooms = new Map<string, DocumentRoom>();
+  
+  function getRoom(docId: string): DocumentRoom | undefined {
+    return rooms.get(docId);
+  }
+  
+  function createRoom(docId: string): DocumentRoom | undefined {
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(docId) as Document | undefined;
+    if (!doc) return undefined;
+    
+    const versionRow = db.prepare('SELECT MAX(version) as maxVersion FROM versions WHERE document_id = ?').get(docId) as { maxVersion: number | null };
+    const currentVersion = versionRow.maxVersion ?? 0;
+    
+    const room: DocumentRoom = {
+      docId,
+      clients: new Map(),
+      pendingOperations: [],
+      currentVersion,
+      content: doc.content,
+    };
+    
+    rooms.set(docId, room);
+    return room;
+  }
+  
+  function syncDocumentFromDb(docId: string): { content: string; version: number } | null {
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(docId) as Document | undefined;
+    if (!doc) return null;
+    
+    const versionRow = db.prepare('SELECT MAX(version) as maxVersion FROM versions WHERE document_id = ?').get(docId) as { maxVersion: number | null };
+    const currentVersion = versionRow.maxVersion ?? 0;
+    
+    return { content: doc.content, version: currentVersion };
+  }
+  
+  function broadcastToRoom(room: DocumentRoom, message: object, excludeClient?: WebSocket) {
+    const data = JSON.stringify(message);
+    for (const [client] of room.clients) {
+      if (client !== excludeClient && client.readyState === WebSocket.OPEN) {
+        client.send(data);
+      }
+    }
+  }
+  
+  wss.on('connection', (ws: WebSocket, req: IncomingMessage, docId: string) => {
+    let room = getRoom(docId);
+    
+    if (!room) {
+      room = createRoom(docId);
+      if (!room) {
+        ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+        ws.close();
+        return;
+      }
+    }
+    
+    const syncState = syncDocumentFromDb(docId);
+    if (!syncState) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close();
+      return;
+    }
+    
+    room.content = syncState.content;
+    room.currentVersion = syncState.version;
+    
+    const clientId = randomUUID();
+    room.clients.set(ws, clientId);
+    
+    db.prepare('INSERT INTO active_connections (id, document_id, connected_at) VALUES (?, ?, ?)').run(clientId, docId, new Date().toISOString());
+    
+    ws.send(JSON.stringify({
+      type: 'sync',
+      content: room.content,
+      version: room.currentVersion,
+    }));
+    
+    ws.on('message', (data: Buffer) => {
+      try {
+        const msg = JSON.parse(data.toString());
+        
+        if (msg.type !== 'operation') {
+          ws.send(JSON.stringify({ type: 'error', message: 'Unknown message type' }));
+          return;
+        }
+        
+        const operation = msg.operation as Operation;
+        
+        if (operation.type !== 'insert' && operation.type !== 'delete') {
+          ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation type' }));
+          return;
+        }
+        
+        if (!validateOperation(operation, room.content.length)) {
+          ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation: out of bounds' }));
+          return;
+        }
+        
+        const clientVersion = typeof msg.version === 'number' ? msg.version : room.currentVersion;
+        
+        let transformedOp = operation;
+        for (const pending of room.pendingOperations) {
+          if (pending.baseVersion >= clientVersion) {
+            transformedOp = transformOperation(transformedOp, pending.op);
+          }
+        }
+        
+        if (transformedOp.type === 'delete' && transformedOp.count === 0) {
+          ws.send(JSON.stringify({ type: 'ack', version: room.currentVersion }));
+          return;
+        }
+        
+        if (!validateOperation(transformedOp, room.content.length)) {
+          ws.send(JSON.stringify({ type: 'error', message: 'Transformed operation invalid' }));
+          return;
+        }
+        
+        room.content = applyOperation(room.content, transformedOp);
+        room.currentVersion += 1;
+        
+        room.pendingOperations.push({ op: transformedOp, baseVersion: clientVersion });
+        if (room.pendingOperations.length > 100) {
+          room.pendingOperations.shift();
+        }
+        
+        const now = new Date().toISOString();
+        db.prepare('UPDATE documents SET content = ?, updated_at = ? WHERE id = ?').run(room.content, now, docId);
+        db.prepare('INSERT INTO versions (document_id, version, content, operation, created_at) VALUES (?, ?, ?, ?, ?)').run(docId, room.currentVersion, room.content, JSON.stringify(transformedOp), now);
+        
+        ws.send(JSON.stringify({ type: 'ack', version: room.currentVersion }));
+        
+        broadcastToRoom(room, { type: 'operation', operation: transformedOp, version: room.currentVersion }, ws);
+        
+      } catch (e) {
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid message format' }));
+      }
+    });
+    
+    ws.on('close', () => {
+      const clientId = room?.clients.get(ws);
+      if (clientId) {
+        db.prepare('DELETE FROM active_connections WHERE id = ?').run(clientId);
+      }
+      room?.clients.delete(ws);
+      
+      if (room && room.clients.size === 0) {
+        rooms.delete(docId);
+      }
+    });
+  });
+  
+  return wss;
+}
+
+export function handleUpgrade(
+  wss: WebSocketServer,
+  req: IncomingMessage,
+  socket: import('stream').Duplex,
+  head: Buffer
+): void {
+  const pathname = req.url ?? '/';
+  const docId = pathname.slice(1);
+  
+  wss.handleUpgrade(req, socket, head, (ws) => {
+    wss.emit('connection', ws, req, docId);
+  });
+}
