+import express from 'express';
+import { createServer } from 'http';
+import type { Server as HttpServer } from 'http';
+import type { WebSocketServer } from 'ws';
+import type Database from 'better-sqlite3';
+import { createDatabase, clearConnections } from './db.js';
+import { createRoutes } from './routes.js';
+import { createWebSocketServer, handleUpgrade } from './ws.js';
+
+export interface AppInstance {
+  app: express.Application;
+  server: HttpServer;
+  wss: WebSocketServer;
+  db: Database.Database;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath);
+  
+  clearConnections(db);
+  
+  const app = express();
+  app.use(express.json());
+  
+  const routes = createRoutes(db);
+  app.use('/', routes);
+  
+  const server = createServer(app);
+  const wss = createWebSocketServer(db);
+  
+  server.on('upgrade', (req, socket, head) => {
+    handleUpgrade(wss, req, socket, head);
+  });
+  
+  const start = (port = 0): Promise<number> => {
+    return new Promise((resolve, reject) => {
+      server.listen(port, () => {
+        const address = server.address();
+        if (address && typeof address === 'object') {
+          resolve(address.port);
+        } else {
+          reject(new Error('Failed to get server port'));
+        }
+      });
+    });
+  };
+  
+  const stop = (): Promise<void> => {
+    return new Promise((resolve, reject) => {
+      wss.clients.forEach((client) => {
+        client.close();
+      });
+      
+      server.close((err) => {
+        if (err) {
+          reject(err);
+        } else {
+          db.close();
+          resolve();
+        }
+      });
+    });
+  };
+  
+  return {
+    app,
+    server,
+    wss,
+    db,
+    start,
+    stop,
+  };
+}
