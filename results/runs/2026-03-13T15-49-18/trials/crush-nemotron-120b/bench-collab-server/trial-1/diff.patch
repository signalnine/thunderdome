+import express, { Request, Response } from 'express';
+import { WebSocketServer, WebSocket } from 'ws';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+
+interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface InsertOperation {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+interface DeleteOperation {
+  type: 'delete';
+  position: number;
+  length: number;
+}
+
+type Operation = InsertOperation | DeleteOperation;
+
+interface WSMessage {
+  type: 'operation' | 'sync';
+  operation?: Operation;
+  clientVersion?: number;
+  version?: number;
+  content?: string;
+}
+
+/**
+ * Transform operation2 against operation1 (assuming operation1 happened first)
+ * Returns operation2' that can be applied after operation1
+ */
+export function transformOperation(operation1: Operation, operation2: Operation): Operation | null {
+  if (operation1.type === 'insert' && operation2.type === 'insert') {
+    if (operation2.position < operation1.position) {
+      return operation2;
+    } else {
+      return {
+        ...operation2,
+        position: operation2.position + operation1.text.length
+      };
+    }
+  }
+
+  if (operation1.type === 'insert' && operation2.type === 'delete') {
+    if (operation2.position < operation1.position) {
+      return operation2;
+    } else if (operation2.position >= operation1.position && operation2.position < operation1.position + operation1.text.length) {
+      // Delete is within the inserted text - adjust to delete after the inserted text
+      return {
+        ...operation2,
+        position: operation2.position + operation1.text.length
+      };
+    } else {
+      // Delete is after the inserted text
+      return {
+        ...operation2,
+        position: operation2.position + operation1.text.length
+      };
+    }
+  }
+
+  if (operation1.type === 'delete' && operation2.type === 'insert') {
+    if (operation2.position <= operation1.position) {
+      return operation2;
+    } else {
+      return {
+        ...operation2,
+        position: operation2.position - operation1.length
+      };
+    }
+  }
+
+  if (operation1.type === 'delete' && operation2.type === 'delete') {
+    if (operation2.position < operation1.position) {
+      return operation2;
+    } else if (operation2.position >= operation1.position && operation2.position < operation1.position + operation1.length) {
+      // Delete is within the deleted range - becomes a no-op
+      return null;
+    } else {
+      // Delete is after the deleted range
+      return {
+        ...operation2,
+        position: operation2.position - operation1.length
+      };
+    }
+  }
+
+  return operation2; // fallback
+}
+
+class CollaborativeServer {
+  private app: express.Application;
+  private wss: WebSocketServer | null;
+  private db: Database.Database;
+  private connections: Map<string, Set<WebSocket>>; // documentId => set of connections
+  private server: import('http').Server | undefined; // HTTP server
+
+  constructor(dbFile: string = ':memory:') {
+    this.app = express();
+    this.app.use(express.json());
+
+    // Initialize database
+    this.db = new Database(dbFile);
+    this.db.pragma('journal_mode = WAL');
+    this.initializeDatabase();
+
+    this.connections = new Map();
+
+    // REST API
+    this.app.post('/documents', this.createDocument.bind(this));
+    this.app.get('/documents', this.listDocuments.bind(this));
+    this.app.get('/documents/:id', this.getDocument.bind(this));
+    this.app.get('/documents/:id/versions', this.getDocumentVersions.bind(this));
+    this.app.put('/documents/:id', this.updateDocument.bind(this));
+    this.app.delete('/documents/:id', this.deleteDocument.bind(this));
+
+    // WebSocket server will be attached to HTTP server later
+    this.wss = null;
+  }
+
+  private initializeDatabase(): void {
+    // Execute schema.sql
+    const schema = `
+      CREATE TABLE IF NOT EXISTS documents (
+        id TEXT PRIMARY KEY,
+        title TEXT NOT NULL,
+        content TEXT NOT NULL DEFAULT '',
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+
+      CREATE TABLE IF NOT EXISTS versions (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+        version INTEGER NOT NULL,
+        content TEXT NOT NULL,
+        operation TEXT, -- JSON of the operation that produced this version
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        UNIQUE(document_id, version)
+      );
+
+      CREATE TABLE IF NOT EXISTS active_connections (
+        id TEXT PRIMARY KEY,
+        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+        connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+    `;
+    this.db.exec(schema);
+  }
+
+  private createDocument(req: Request, res: Response): void {
+    const { title = '', content = '' } = req.body;
+    const id = uuidv4();
+    const now = new Date().toISOString();
+
+    const stmt = this.db.prepare(`
+      INSERT INTO documents (id, title, content, created_at, updated_at)
+      VALUES (@id, @title, @content, @created_at, @updated_at)
+    `);
+    stmt.run({ id, title, content, created_at: now, updated_at: now });
+
+    // Create initial version (version 0)
+    const versionStmt = this.db.prepare(`
+      INSERT INTO versions (document_id, version, content, operation, created_at)
+      VALUES (@document_id, @version, @content, @operation, @created_at)
+    `);
+    versionStmt.run({
+      document_id: id,
+      version: 0,
+      content,
+      operation: null,
+      created_at: now
+    });
+
+    res.status(201).json({ id, title, content, created_at: now, updated_at: now });
+  }
+
+  private listDocuments(req: Request, res: Response): void {
+    const stmt = this.db.prepare('SELECT id, title, content, created_at, updated_at FROM documents ORDER BY updated_at DESC');
+    const documents = stmt.all() as Document[];
+    res.json(documents);
+  }
+
+  private getDocument(req: Request, res: Response): void {
+    const { id } = req.params;
+    const stmt = this.db.prepare('SELECT * FROM documents WHERE id = ?');
+    const doc = stmt.get(id) as Document | undefined;
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  }
+
+  private updateDocument(req: Request, res: Response): void {
+    const { id } = req.params;
+    const { title, content } = req.body;
+    const now = new Date().toISOString();
+
+    const stmt = this.db.prepare(`
+      UPDATE documents 
+      SET title = COALESCE(@title, title),
+          content = COALESCE(@content, content),
+          updated_at = @updated_at
+      WHERE id = @id
+    `);
+    const result = stmt.run({ title, content, updated_at: now, id });
+    if (result.changes === 0) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    // Create a new version for this update
+    const versionStmt = this.db.prepare('SELECT MAX(version) as maxVersion FROM versions WHERE document_id = ?');
+    const versionRow = versionStmt.get(id) as { maxVersion: number } | undefined;
+    const newVersion = (versionRow?.maxVersion ?? -1) + 1;
+
+    const insertVersionStmt = this.db.prepare(`
+      INSERT INTO versions (document_id, version, content, operation, created_at)
+      VALUES (@document_id, @version, @content, @operation, @created_at)
+    `);
+    // We don't have the operation from REST update, so we store null
+    insertVersionStmt.run({
+      document_id: id,
+      version: newVersion,
+      content: content ?? '',
+      operation: null,
+      created_at: now
+    });
+
+    res.json({ id, title: title ?? '', content: content ?? '', updated_at: now });
+  }
+
+  private getDocumentVersions(req: Request, res: Response): void {
+    const { id } = req.params;
+    const stmt = this.db.prepare(`
+      SELECT version, content, operation, created_at FROM versions 
+      WHERE document_id = ? 
+      ORDER BY version ASC
+    `);
+    const versions = stmt.all(id) as Array<{
+      version: number;
+      content: string;
+      operation: string | null;
+      created_at: string;
+    }>;
+    res.json(versions);
+  }
+
+  private deleteDocument(req: Request, res: Response): void {
+    const { id } = req.params;
+    const stmt = this.db.prepare('DELETE FROM documents WHERE id = ?');
+    const result = stmt.run(id);
+    if (result.changes === 0) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.status(204).end();
+  }
+
+  private getDocumentVersion(documentId: string): { version: number; content: string } | null {
+    const stmt = this.db.prepare(`
+      SELECT version, content FROM versions 
+      WHERE document_id = ? 
+      ORDER BY version DESC 
+      LIMIT 1
+    `);
+    const row = stmt.get(documentId) as { version: number; content: string } | undefined;
+    if (!row) return null;
+    return { version: row.version, content: row.content };
+  }
+
+  private getVersionsSince(documentId: string, startVersion: number): Array<{ version: number; operation: Operation | null }> {
+    const stmt = this.db.prepare(`
+      SELECT version, operation FROM versions 
+      WHERE document_id = ? AND version > ? 
+      ORDER BY version ASC
+    `);
+    const rows = stmt.all(documentId, startVersion) as Array<{ version: number; operation: string | null }>;
+    return rows.map(row => ({
+      version: row.version,
+      operation: row.operation ? JSON.parse(row.operation) : null
+    }));
+  }
+
+  private saveVersion(documentId: string, version: number, content: string, operation: Operation | null): void {
+    const now = new Date().toISOString();
+    const stmt = this.db.prepare(`
+      INSERT INTO versions (document_id, version, content, operation, created_at)
+      VALUES (@document_id, @version, @content, @operation, @created_at)
+    `);
+    stmt.run({
+      document_id: documentId,
+      version,
+      content,
+      operation: operation ? JSON.stringify(operation) : null,
+      created_at: now
+    });
+  }
+
+  private handleWebSocketConnection(ws: WebSocket, req: Request): void {
+    console.log(`WebSocket connection attempt. URL: ${req.url}`);
+    const pathParts = req.url?.split('/') ?? [];
+    console.log(`Path parts: ${JSON.stringify(pathParts)}`);
+    const documentId = pathParts[2];
+    if (!documentId) {
+      console.log('No document ID in URL');
+      ws.close(1008, 'Document ID required');
+      return;
+    }
+
+    console.log(`Document ID: ${documentId}`);
+    // Check if document exists
+    const docStmt = this.db.prepare('SELECT id FROM documents WHERE id = ?');
+    const doc = docStmt.get(documentId);
+    if (!doc) {
+      console.log(`Document not found: ${documentId}`);
+      ws.close(1008, 'Document not found');
+      return;
+    }
+
+    // Add to connections map
+    if (!this.connections.has(documentId)) {
+      this.connections.set(documentId, new Set());
+    }
+    this.connections.get(documentId)!.add(ws);
+
+    // Send current state to client
+    const state = this.getDocumentVersion(documentId);
+    if (state) {
+      const syncMsg: WSMessage = {
+        type: 'sync',
+        version: state.version,
+        content: state.content
+      };
+      ws.send(JSON.stringify(syncMsg));
+    }
+
+    ws.on('message', (data: Buffer) => {
+      console.log(`Received WebSocket message: ${data.toString()}`);
+      try {
+        const msg: WSMessage = JSON.parse(data.toString());
+        console.log(`Parsed message: ${JSON.stringify(msg)}`);
+        if (msg.type === 'operation' && msg.operation && msg.clientVersion !== undefined) {
+          console.log(`Calling handleOperation with operation: ${JSON.stringify(msg.operation)}, clientVersion: ${msg.clientVersion}`);
+          this.handleOperation(documentId, ws, msg.operation, msg.clientVersion);
+        } else {
+          console.log(`Message is not a valid operation: type=${msg.type}, hasOperation=${!!msg.operation}, clientVersionDefined=${msg.clientVersion !== undefined}`);
+        }
+      } catch (e) {
+        console.error('Invalid WebSocket message:', e);
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid message format' }));
+      }
+    });
+
+    ws.on('close', () => {
+      console.log(`WebSocket connection closed for document ${documentId}`);
+      if (this.connections.has(documentId)) {
+        this.connections.get(documentId)!.delete(ws);
+        if (this.connections.get(documentId)!.size === 0) {
+          this.connections.delete(documentId);
+        }
+      }
+    });
+
+    ws.on('error', (error) => {
+      console.error('WebSocket error:', error);
+    });
+  }
+
+  private handleOperation(documentId: string, sender: WebSocket, operation: Operation, clientVersion: number): void {
+    console.log(`handleOperation called: doc=${documentId}, op=${JSON.stringify(operation)}, clientVersion=${clientVersion}`);
+    // Get current server version and content
+    const currentState = this.getDocumentVersion(documentId);
+    if (!currentState) {
+      console.log(`Document not found: ${documentId}`);
+      sender.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      return;
+    }
+
+    const serverVersion = currentState.version;
+    console.log(`Current server version: ${serverVersion}, client version: ${clientVersion}`);
+    if (clientVersion > serverVersion) {
+      console.log(`Client version ahead of server`);
+      sender.send(JSON.stringify({ type: 'error', message: 'Client version ahead of server' }));
+      return;
+    }
+
+    // Validate operation
+    if (!this.isValidOperation(operation, currentState.content.length)) {
+      console.log(`Invalid operation: ${JSON.stringify(operation)} for content length ${currentState.content.length}`);
+      sender.send(JSON.stringify({ type: 'error', message: 'Invalid operation' }));
+      return;
+    }
+
+    // Get operations that have been applied since clientVersion
+    const operationsSince = this.getVersionsSince(documentId, clientVersion);
+    console.log(`Operations since clientVersion ${clientVersion}: ${JSON.stringify(operationsSince)}`);
+
+    // Transform the operation against each intervening operation
+    let transformedOp = operation;
+    for (const { operation: prevOp } of operationsSince) {
+      if (prevOp) {
+        const oldTransformedOp = transformedOp;
+        transformedOp = transformOperation(prevOp, transformedOp)!;
+        console.log(`Transforming ${JSON.stringify(oldTransformedOp)} against ${JSON.stringify(prevOp)} => ${JSON.stringify(transformedOp)}`);
+        if (transformedOp === null) {
+          // Operation became a no-op
+          console.log(`Operation became no-op after transformation`);
+          break;
+        }
+      }
+    }
+
+    if (transformedOp === null) {
+      // No-op, just send current state again
+      console.log(`Operation is no-op, sending current state to sender`);
+      const syncMsg: WSMessage = {
+        type: 'sync',
+        version: serverVersion,
+        content: currentState.content
+      };
+      sender.send(JSON.stringify(syncMsg));
+      return;
+    }
+
+    // Apply transformed operation to current content
+    let newContent = currentState.content;
+    if (transformedOp.type === 'insert') {
+      newContent = 
+        newContent.slice(0, transformedOp.position) + 
+        transformedOp.text + 
+        newContent.slice(transformedOp.position);
+    } else if (transformedOp.type === 'delete') {
+      const { position, length } = transformedOp;
+      newContent = 
+        newContent.slice(0, position) + 
+        newContent.slice(position + length);
+    }
+    console.log(`Applying operation: ${JSON.stringify(operation)} transformed to ${JSON.stringify(transformedOp)} result: "${newContent}"`);
+
+    // Save new version
+    const newVersion = serverVersion + 1;
+    console.log(`Saving version ${newVersion} with content: "${newContent}"`);
+    this.saveVersion(documentId, newVersion, newContent, transformedOp);
+
+    // Broadcast sync to all clients (including sender) with the new state
+    const syncMsg: WSMessage = {
+      type: 'sync',
+      version: newVersion,
+      content: newContent
+    };
+    const message = JSON.stringify(syncMsg);
+    console.log(`Broadcasting to ${this.connections.has(documentId) ? this.connections.get(documentId)!.size : 0} connections: ${message}`);
+    if (this.connections.has(documentId)) {
+      for (const conn of this.connections.get(documentId)!) {
+        if (conn.readyState === WebSocket.OPEN) {
+          console.log(`Sending to connection`);
+          conn.send(message);
+        } else {
+          console.log(`Not sending to connection - readyState: ${conn.readyState}`);
+        }
+      }
+    }
+    console.log(`handleOperation finished`);
+  }
+
+  private isValidOperation(operation: Operation, contentLength: number): boolean {
+    if (operation.type === 'insert') {
+      return operation.position >= 0 && operation.position <= contentLength;
+    } else if (operation.type === 'delete') {
+      return operation.position >= 0 && 
+             operation.position <= contentLength && 
+             operation.length >= 0 && 
+             operation.position + operation.length <= contentLength;
+    }
+    return false;
+  }
+
+  async start(port: number = 0): Promise<number> {
+    return new Promise((resolve) => {
+      this.server = this.app.listen(port, () => {
+        const address = this.server.address();
+        const portNumber = typeof address === 'string' ? address : address?.port;
+        if (typeof portNumber === 'number') {
+          console.log(`HTTP server listening on port ${portNumber}`);
+          // Attach WebSocket server to HTTP server
+          this.wss = new WebSocketServer({ server: this.server });
+          console.log('WebSocket server attached to HTTP server');
+          this.wss.on('connection', (ws, req) => {
+            console.log(`WebSocket connection received`);
+            this.handleWebSocketConnection(ws, req);
+          });
+          resolve(portNumber);
+        } else {
+          resolve(0);
+        }
+      });
+    });
+  }
+
+  stop(): void {
+    if (this.wss) {
+      this.wss.close();
+    }
+    if (this.server) {
+      this.server.close();
+    }
+    this.db.close();
+  }
+
+  getApp(): express.Application {
+    return this.app;
+  }
+}
+
+/**
+ * Factory function to create the collaborative server
+ * @param dbFile Optional path to SQLite database file (defaults to memory)
+ * @returns Object with app, start, and stop methods
+ */
+export function createApp(dbFile?: string) {
+  const server = new CollaborativeServer(dbFile);
+  return {
+    app: server.getApp(),
+    start: server.start.bind(server),
+    stop: server.stop.bind(server)
+  };
+}
