+
+describe('Simple Concurrent Editing Test', () => {
+  test('should handle two clients sending operations sequentially', async () => {
+    // Create server
+    const serverObject = createApp(':memory:');
+    const app = serverObject.app;
+    const port = await serverObject.start();
+    const request = supertest(app);
+    
+    try {
+      // Create a document
+      const createRes = await request
+        .post('/documents')
+        .send({ title: 'Test Doc', content: 'Hello' })
+        .expect(201);
+      
+      const docId = createRes.body.id;
+      
+      // Connect first WebSocket client
+      const ws1 = new WebSocket(`ws://localhost:${port}/ws/${docId}`);
+      
+      // Wait for connection and initial sync
+      await new Promise<void>((resolve, reject) => {
+        ws1.on('open', () => {
+          ws1.once('message', (data) => {
+            const msg = JSON.parse(data.toString());
+            expect(msg.type).toBe('sync');
+            expect(msg.content).toBe('Hello');
+            resolve();
+          });
+        });
+        
+        ws1.on('error', reject);
+      });
+      
+      // Client 1 sends an operation
+      const op1 = { type: 'insert', position: 5, text: ' Beautiful' };
+      ws1.send(JSON.stringify({ type: 'operation', operation: op1, clientVersion: 0 }));
+      
+      // Wait for the operation to be processed
+      await new Promise<void>((resolve, reject) => {
+        ws1.once('message', (data) => {
+          const msg = JSON.parse(data.toString());
+          if (msg.type === 'sync' && msg.version === 1) {
+            expect(msg.content).toBe('Hello Beautiful');
+            resolve();
+          } else {
+            reject(new Error('Expected sync acknowledgment'));
+          }
+        });
+        
+        ws1.on('error', reject);
+      });
+      
+      // Close first client
+      ws1.close();
+      
+      // Connect second WebSocket client
+      const ws2 = new WebSocket(`ws://localhost:${port}/ws/${docId}`);
+      
+      // Wait for connection and get current state
+      await new Promise<void>((resolve, reject) => {
+        ws2.on('open', () => {
+          ws2.once('message', (data) => {
+            const msg = JSON.parse(data.toString());
+            expect(msg.type).toBe('sync');
+            expect(msg.content).toBe('Hello Beautiful'); // Should see the updated content
+            resolve();
+          });
+        });
+        
+        ws2.on('error', reject);
+      });
+      
+      // Client 2 sends an operation
+      const op2 = { type: 'insert', position: 0, text: 'Awesome ' };
+      ws2.send(JSON.stringify({ type: 'operation', operation: op2, clientVersion: 1 }));
+      
+      // Wait for the operation to be processed
+      await new Promise<void>((resolve, reject) => {
+        ws2.once('message', (data) => {
+          const msg = JSON.parse(data.toString());
+          if (msg.type === 'sync' && msg.version === 2) {
+            expect(msg.content).toBe('Awesome Hello Beautiful');
+            resolve();
+          } else {
+            reject(new Error('Expected sync acknowledgment'));
+          }
+        });
+        
+        ws2.on('error', reject);
+      });
+    } finally {
+      serverObject.stop();
+    }
+  });
+  
+  test('should handle concurrent operations with operational transformation', async () => {
+    // Create server
+    const serverObject = createApp(':memory:');
+    const app = serverObject.app;
+    const port = await serverObject.start();
+    const request = supertest(app);
+    
+    try {
+      // Create a document with content "ab"
+      const createRes = await request
+        .post('/documents')
+        .send({ title: 'Test Doc', content: 'ab' })
+        .expect(201);
