+import { createApp } from './server';
+import { WebSocket } from 'ws';
+import supertest from 'supertest';
+import { expect, test, describe } from 'vitest';
+
+describe('Two Client Debug Test', () => {
+  test('should handle two clients inserting at different positions', async () => {
+    // Create server
+    const serverObject = createApp(':memory:');
+    const app = serverObject.app;
+    const port = await serverObject.start();
+    const request = supertest(app);
+    
+    try {
+      // Create a document with initial content "ab"
+      const createRes = await request
+        .post('/documents')
+        .send({ title: 'Test Doc', content: 'ab' })
+        .expect(201);
+      
+      const docId = createRes.body.id;
+      
+      // Connect first WebSocket client
+      const ws1 = new WebSocket(`ws://localhost:${port}/ws/${docId}`);
+      
+      // Connect second WebSocket client
+      const ws2 = new WebSocket(`ws://localhost:${port}/ws/${docId}`);
+      
+      // Arrays to store messages
+      const ws1Messages: any[] = [];
+      const ws2Messages: any[] = [];
+      
+      ws1.on('message', (data) => {
+        ws1Messages.push(JSON.parse(data.toString()));
+      });
+      
+      ws2.on('message', (data) => {
+        ws2Messages.push(JSON.parse(data.toString()));
+      });
+      
+      // Wait for both connections and initial sync
+      await new Promise<void>((resolve, reject) => {
+        let readyCount = 0;
+        const checkReady = () => {
+          if (readyCount >= 2) {
+            // Both clients have received initial sync
+            const ws1Sync = ws1Messages.find(m => m.type === 'sync');
+            const ws2Sync = ws2Messages.find(m => m.type === 'sync');
+            if (ws1Sync && ws2Sync) {
+              resolve();
+            }
+          }
+        };
+        
+        ws1.on('open', () => {
+          readyCount++;
+          checkReady();
+        });
+        
+        ws2.on('open', () => {
+          readyCount++;
+          checkReady();
+        });
+        
+        ws1.on('error', reject);
+        ws2.on('error', reject);
+      });
+      
+      // Both clients should have received the initial sync
+      expect(ws1Messages[0]).toEqual({
+        type: 'sync',
+        version: 0,
+        content: 'ab'
+      });
+      
+      expect(ws2Messages[0]).toEqual({
+        type: 'sync',
+        version: 0,
+        content: 'ab'
+      });
+      
+      // Clear messages for next phase
+      ws1Messages.splice(0);
+      ws2Messages.splice(0);
+      
+      console.log('Sending operation from ws1: insert "X" at position 0');
+      // Client 1 inserts 'X' at position 0 (beginning)
+      const op1 = { type: 'insert', position: 0, text: 'X' };
+      ws1.send(JSON.stringify({ type: 'operation', operation: op1, clientVersion: 0 }));
+      
+      console.log('Sending operation from ws2: insert "Y" at position 2');
+      // Client 2 inserts 'Y' at position 2 (end)
+      const op2 = { type: 'insert', position: 2, text: 'Y' };
+      ws2.send(JSON.stringify({ type: 'operation', operation: op2, clientVersion: 0 }));
+      
+      // Wait for both operations to be processed and acknowledged
+      // Each client should receive messages until they get a sync with version 2
+      await new Promise<void>((resolve, reject) => {
+        const checkMessages = () => {
+          const ws1HasVersion2Sync = ws1Messages.some(m => m.type === 'sync' && m.version === 2);
+          const ws2HasVersion2Sync = ws2Messages.some(m => m.type === 'sync' && m.version === 2);
+          
+          if (ws1HasVersion2Sync && ws2HasVersion2Sync) {
+            resolve();
+          }
+        };
+        
+        ws1.on('message', checkMessages);
+        ws2.on('message', checkMessages);
+        setTimeout(checkMessages, 50); // Initial check
+        
+        // Set a timeout to avoid hanging
+        setTimeout(() => {
+          reject(new Error('Timeout waiting for operation processing'));
+        }, 5000);
+      });
+      
+      console.log('ws1Messages:', ws1Messages);
+      console.log('ws2Messages:', ws2Messages);
+      
+      // Check that both clients converged to the same content
+      // Client 1's operation: insert 'X' at 0 -> "Xab"
+      // Client 2's operation: insert 'Y' at 2 -> "abY"
+      // Depending on order:
+      // If op1 first: "Xab" then op2 at position 2 (in "Xab") -> "XaYb"
+      // If op2 first: "abY" then op1 at position 0 (in "abY") -> "XabY"
+      
+      // Find the final sync messages (version 2)
+      const ws1FinalSync = ws1Messages.find(m => m.type === 'sync' && m.version === 2);
+      const ws2FinalSync = ws2Messages.find(m => m.type === 'sync' && m.version === 2);
+      
+      expect(ws1FinalSync).toBeDefined();
+      expect(ws2FinalSync).toBeDefined();
+      
+      if (ws1FinalSync && ws2FinalSync) {
+        // Both clients should converge to the same content
+        expect(ws1FinalSync.content).toBe(ws2FinalSync.content);
+        // Content should be one of the two expected outcomes
+        const content = ws1FinalSync.content;
+        expect([
+          'XaYb',    // op1 then op2
+          'XabY'     // op2 then op1
+        ]).toContain(content);
+      }
+    } finally {
+      serverObject.stop();
+    }
+  });
+});
