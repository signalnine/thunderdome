+// Import the transformOperation function from server.ts
+// Since it's not exported, we'll need to access it differently for testing
+// Let's copy the function here for testing purposes
+function transformOperation(operation1: any, operation2: any): any | null {
+  if (operation1.type === 'insert' && operation2.type === 'insert') {
+    if (operation2.position < operation1.position) {
+      return operation2;
+    } else {
+      return {
+        ...operation2,
+        position: operation2.position + operation1.text.length
+      };
+    }
+  }
+
+  if (operation1.type === 'insert' && operation2.type === 'delete') {
+    if (operation2.position < operation1.position) {
+      return operation2;
+    } else if (operation2.position >= operation1.position && operation2.position < operation1.position + operation1.text.length) {
+      // Delete is within the inserted text - adjust to delete after the inserted text
+      return {
+        ...operation2,
+        position: operation2.position + operation1.text.length
+      };
+    } else {
+      // Delete is after the inserted text
+      return {
+        ...operation2,
+        position: operation2.position + operation1.text.length
+      };
+    }
+  }
+
+  if (operation1.type === 'delete' && operation2.type === 'insert') {
+    if (operation2.position <= operation1.position) {
+      return operation2;
+    } else {
+      return {
+        ...operation2,
+        position: operation2.position - operation1.length
+      };
+    }
+  }
+
+  if (operation1.type === 'delete' && operation2.type === 'delete') {
+    if (operation2.position < operation1.position) {
+      return operation2;
+    } else if (operation2.position >= operation1.position && operation2.position < operation1.position + operation1.length) {
+      // Delete is within the deleted range - becomes a no-op
+      return null;
+    } else {
+      // Delete is after the deleted range
+      return {
+        ...operation2,
+        position: operation2.position - operation1.length
+      };
+    }
+  }
+
+  return operation2; // fallback
+}
+
+// Test case from our concurrent test
+console.log('Testing insert-insert transformation:');
+
+// op1: insert 'X' at 0
+// op2: insert 'Y' at 2
+const op1 = { type: 'insert', position: 0, text: 'X' };
+const op2 = { type: 'insert', position: 2, text: 'Y' };
+
+console.log('op1:', op1);
+console.log('op2:', op2);
+
+const result1 = transformOperation(op1, op2);
+console.log('transformOperation(op1, op2):', result1);
+
+const result2 = transformOperation(op2, op1);
+console.log('transformOperation(op2, op1):', result2);
+
+// Let's manually verify what these should be
+console.log('\nManual verification:');
+
+// For transformOperation(op1, op2):
+// We want B' such that: apply(B', apply(op1, S)) = apply(op1, apply(op2, S))
+// S = "ab"
+// apply(op2, S) = insert 'Y' at 2 in "ab" = "abY"
+// apply(op1, "abY") = insert 'X' at 0 in "abY" = "XabY"
+// apply(op1, S) = insert 'X' at 0 in "ab" = "Xab"
+// So we want B' such that: apply(B', "Xab") = "XabY"
+// This means insert 'Y' at position 3 in "Xab"
+// So B' should be { type: 'insert', position: 3, text: 'Y' }
+console.log('Expected transformOperation(op1, op2):', { type: 'insert', position: 3, text: 'Y' });
+
+// For transformOperation(op2, op1):
+// We want A' such that: apply(A', apply(op2, S)) = apply(op2, apply(op1, S))
+// S = "ab"
+// apply(op1, S) = insert 'X' at 0 in "ab" = "Xab"
+// apply(op2, "Xab") = insert 'Y' at 2 in "Xab" = "XaYb"
+// apply(op2, S) = insert 'Y' at 2 in "ab" = "abY"
+// So we want A' such that: apply(A', "abY") = "XaYb"
+// This means insert 'X' at position 0 in "abY"
+// So A' should be { type: 'insert', position: 0, text: 'X' }
+console.log('Expected transformOperation(op2, op1):', { type: 'insert', position: 0, text: 'X' });
