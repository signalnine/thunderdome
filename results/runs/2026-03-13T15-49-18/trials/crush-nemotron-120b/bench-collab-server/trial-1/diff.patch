+import { createApp } from './server';
+import { WebSocket } from 'ws';
+import supertest from 'supertest';
+import { expect, test, describe } from 'vitest';
+
+describe('Simple Concurrent Editing Test', () => {
+  test('should handle basic WebSocket operation flow', async () => {
+    // Create server
+    const serverObject = createApp(':memory:');
+    const app = serverObject.app;
+    const port = await serverObject.start();
+    const request = supertest(app);
+    
+    try {
+      // Create a document
+      const createRes = await request
+        .post('/documents')
+        .send({ title: 'Test Doc', content: 'Hello' })
+        .expect(201);
+      
+      const docId = createRes.body.id;
+      
+      // Connect a WebSocket client
+      const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}`);
+      
+      // Wait for connection and initial sync
+      await new Promise<void>((resolve, reject) => {
+        ws.on('open', () => {
+          // Wait for sync message
+          ws.once('message', (data) => {
+            const msg = JSON.parse(data.toString());
+            expect(msg.type).toBe('sync');
+            expect(msg.content).toBe('Hello');
+            resolve();
+          });
+        });
+        
+        ws.on('error', reject);
+      });
+      
+      // Send an insert operation
+      const operation = { type: 'insert', position: 5, text: ' World' };
+      ws.send(JSON.stringify({ type: 'operation', operation, clientVersion: 0 }));
+      
+      // Wait for the operation to be processed and echoed back
+      await new Promise<void>((resolve, reject) => {
+        ws.once('message', (data) => {
+          const msg = JSON.parse(data.toString());
+          if (msg.type === 'sync' && msg.version === 1) {
+            // Operation was applied, we got the updated content back
+            expect(msg.content).toBe('Hello World');
+            resolve();
+          } else if (msg.type === 'operation') {
+            // Echo of our operation (also acceptable)
+            expect(msg.operation).toEqual(operation);
+            // Wait for the sync acknowledgment
+            ws.once('message', (data2) => {
+              const msg2 = JSON.parse(data2.toString());
+              if (msg2.type === 'sync' && msg2.version === 1) {
+                expect(msg2.content).toBe('Hello World');
+                resolve();
+              } else {
+                reject(new Error('Unexpected message after operation echo'));
+              }
+            });
+          } else {
+            reject(new Error('Unexpected message type'));
+          }
+        });
+        
+        ws.on('error', reject);
+      });
+    } finally {
+      serverObject.stop();
+    }
+  });
+});
