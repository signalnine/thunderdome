@@ -0,0 +1,121 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+function findSource(grid: string[][]): [number, number] | null {
+  if (grid.length === 0 || grid[0].length === 0) return null;
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const source = findSource(grid);
+  if (!source) return 0;
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  const visited = new Set<number>();
+  const cellKey = (r: number, c: number) => r * cols + c;
+
+  // Track unique (col, direction) states per row - deduplicates beams
+  // that would visit the same cells going forward
+  let current: Map<number, Set<Direction>> = new Map();
+
+  // Source cell
+  visited.add(cellKey(source[0], source[1]));
+  const addState = (map: Map<number, Set<Direction>>, col: number, dir: Direction) => {
+    let dirs = map.get(col);
+    if (!dirs) {
+      dirs = new Set();
+      map.set(col, dirs);
+    }
+    dirs.add(dir);
+  };
+  addState(current, source[1], 'down');
+
+  for (let r = 0; r < rows; r++) {
+    const next: Map<number, Set<Direction>> = new Map();
+
+    for (const [col, dirs] of current) {
+      for (const dir of dirs) {
+        const [nr, nc] = advance(r, col, dir);
+        if (!inBounds(nr, nc, rows, cols)) continue;
+
+        visited.add(cellKey(nr, nc));
+
+        if (grid[nr][nc] === '^') {
+          addState(next, nc, 'down-left');
+          addState(next, nc, 'down-right');
+        } else {
+          addState(next, nc, dir);
+        }
+      }
+    }
+
+    current = next;
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const source = findSource(grid);
+  if (!source) return 0n;
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  // DP: process row by row. Track (col, direction) -> path count.
+  let totalPaths = 0n;
+
+  type DirMap = Map<Direction, bigint>;
+  let current = new Map<number, DirMap>();
+
+  const addToMap = (map: Map<number, DirMap>, col: number, dir: Direction, count: bigint) => {
+    let dirMap = map.get(col);
+    if (!dirMap) {
+      dirMap = new Map();
+      map.set(col, dirMap);
+    }
+    dirMap.set(dir, (dirMap.get(dir) ?? 0n) + count);
+  };
+
+  addToMap(current, source[1], 'down', 1n);
+
+  for (let r = 0; r < rows; r++) {
+    const next = new Map<number, DirMap>();
+
+    for (const [col, dirMap] of current) {
+      for (const [dir, pathCount] of dirMap) {
+        const [nr, nc] = advance(r, col, dir);
+
+        if (!inBounds(nr, nc, rows, cols)) {
+          totalPaths += pathCount;
+          continue;
+        }
+
+        if (grid[nr][nc] === '^') {
+          addToMap(next, nc, 'down-left', pathCount);
+          addToMap(next, nc, 'down-right', pathCount);
+        } else {
+          addToMap(next, nc, dir, pathCount);
+        }
+      }
+    }
+
+    current = next;
+  }
+
+  return totalPaths;
+}
