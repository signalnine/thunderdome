+import { describe, it, expect, beforeEach } from 'vitest';
+import { createResolver } from './index.js';
+import type { ResolverService } from '../types.js';
+
+describe('VersionResolver', () => {
+  let resolver: ResolverService;
+
+  beforeEach(() => {
+    resolver = createResolver();
+  });
+
+  it('should resolve a matching version', () => {
+    const result = resolver.resolve(
+      [{ name: 'foo', range: '^1.0.0' }],
+      { foo: ['1.0.0', '1.1.0', '1.2.0', '2.0.0'] }
+    );
+    expect(result).toHaveLength(1);
+    expect(result[0].name).toBe('foo');
+    expect(result[0].version).toBe('1.2.0');
+    expect(result[0].satisfies).toBe('^1.0.0');
+  });
+
+  it('should throw when no versions available', () => {
+    expect(() =>
+      resolver.resolve([{ name: 'bar', range: '^1.0.0' }], {})
+    ).toThrow('No versions available');
+  });
+
+  it('should throw when no version satisfies range', () => {
+    expect(() =>
+      resolver.resolve(
+        [{ name: 'baz', range: '^3.0.0' }],
+        { baz: ['1.0.0', '2.0.0'] }
+      )
+    ).toThrow('No version of baz satisfies');
+  });
+
+  it('should resolve multiple constraints', () => {
+    const result = resolver.resolve(
+      [
+        { name: 'a', range: '~1.0.0' },
+        { name: 'b', range: '^2.0.0' },
+      ],
+      {
+        a: ['1.0.0', '1.0.5', '1.1.0'],
+        b: ['2.0.0', '2.1.0', '3.0.0'],
+      }
+    );
+    expect(result).toHaveLength(2);
+    expect(result[0].version).toBe('1.0.5');
+    expect(result[1].version).toBe('2.1.0');
+  });
+
+  it('satisfies should check version against range', () => {
+    expect(resolver.satisfies('1.5.0', '^1.0.0')).toBe(true);
+    expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+  });
+
+  it('maxSatisfying should find highest matching version', () => {
+    expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0')).toBe('1.5.0');
+  });
+
+  it('maxSatisfying should return null when nothing matches', () => {
+    expect(resolver.maxSatisfying(['1.0.0'], '^2.0.0')).toBeNull();
+  });
+
+  it('validRange should validate semver ranges', () => {
+    expect(resolver.validRange('^1.0.0')).toBe(true);
+    expect(resolver.validRange('~2.0.0')).toBe(true);
+    expect(resolver.validRange('not-a-range')).toBe(false);
+  });
+});
