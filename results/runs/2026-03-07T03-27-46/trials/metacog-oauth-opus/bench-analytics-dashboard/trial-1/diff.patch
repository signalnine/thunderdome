+import { Router, Response } from "express";
+import { getDb } from "../db.js";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+const router = Router();
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function escapeCsvField(value: string): string {
+  if (value.includes(",") || value.includes('"') || value.includes("\n")) {
+    return `"${value.replace(/"/g, '""')}"`;
+  }
+  return value;
+}
+
+// Export events as JSON
+router.get("/events/json", authMiddleware, (req: AuthRequest, res: Response) => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+  const eventName = req.query.eventName as string | undefined;
+  const startDate = req.query.startDate as string | undefined;
+  const endDate = req.query.endDate as string | undefined;
+
+  let query = "SELECT * FROM events WHERE tenant_id = ?";
+  const params: string[] = [tenantId];
+
+  if (eventName) {
+    query += " AND name = ?";
+    params.push(eventName);
+  }
+  if (startDate) {
+    query += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+  if (endDate) {
+    query += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  query += " ORDER BY timestamp DESC";
+
+  const rows = db.prepare(query).all(...params) as EventRow[];
+
+  const events = rows.map((row) => ({
+    id: row.id,
+    tenantId: row.tenant_id,
+    name: row.name,
+    properties: JSON.parse(row.properties),
+    timestamp: row.timestamp,
+    userId: row.user_id,
+    sessionId: row.session_id,
+  }));
+
+  res.setHeader("Content-Type", "application/json");
+  res.setHeader("Content-Disposition", "attachment; filename=events.json");
+  res.json({ events });
+});
+
+// Export events as CSV
+router.get("/events/csv", authMiddleware, (req: AuthRequest, res: Response) => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+  const eventName = req.query.eventName as string | undefined;
+  const startDate = req.query.startDate as string | undefined;
+  const endDate = req.query.endDate as string | undefined;
+
+  let query = "SELECT * FROM events WHERE tenant_id = ?";
+  const params: string[] = [tenantId];
+
+  if (eventName) {
+    query += " AND name = ?";
+    params.push(eventName);
+  }
+  if (startDate) {
+    query += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+  if (endDate) {
+    query += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  query += " ORDER BY timestamp DESC";
+
+  const rows = db.prepare(query).all(...params) as EventRow[];
+
+  const header = "id,tenant_id,name,properties,timestamp,user_id,session_id";
+  const csvRows = rows.map((row) =>
+    [
+      escapeCsvField(row.id),
+      escapeCsvField(row.tenant_id),
+      escapeCsvField(row.name),
+      escapeCsvField(row.properties),
+      escapeCsvField(row.timestamp),
+      escapeCsvField(row.user_id || ""),
+      escapeCsvField(row.session_id || ""),
+    ].join(",")
+  );
+
+  const csv = [header, ...csvRows].join("\n");
+
+  res.setHeader("Content-Type", "text/csv");
+  res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+  res.send(csv);
+});
+
+// Export dashboard as JSON
+router.get("/dashboards/:id/json", authMiddleware, (req: AuthRequest, res: Response) => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  const dashboard = db
+    .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+    .get(req.params.id, tenantId) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: "Dashboard not found" });
+    return;
+  }
+
+  const widgets = db
+    .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+    .all(dashboard.id) as WidgetRow[];
+
+  const result = {
+    id: dashboard.id,
+    tenantId: dashboard.tenant_id,
+    name: dashboard.name,
+    ownerId: dashboard.owner_id,
+    config: JSON.parse(dashboard.config),
+    createdAt: dashboard.created_at,
+    updatedAt: dashboard.updated_at,
+    widgets: widgets.map((w) => ({
+      id: w.id,
+      dashboardId: w.dashboard_id,
+      type: w.type,
+      config: JSON.parse(w.config),
+      positionX: w.position_x,
+      positionY: w.position_y,
+      width: w.width,
+      height: w.height,
+    })),
+  };
+
+  res.setHeader("Content-Type", "application/json");
+  res.setHeader("Content-Disposition", `attachment; filename=dashboard-${dashboard.id}.json`);
+  res.json(result);
+});
+
+// Export dashboard as CSV
+router.get("/dashboards/:id/csv", authMiddleware, (req: AuthRequest, res: Response) => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  const dashboard = db
+    .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+    .get(req.params.id, tenantId) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: "Dashboard not found" });
+    return;
+  }
+
+  const widgets = db
+    .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+    .all(dashboard.id) as WidgetRow[];
+
+  const header = "widget_id,type,config,position_x,position_y,width,height";
+  const csvRows = widgets.map((w) =>
+    [
+      escapeCsvField(w.id),
+      escapeCsvField(w.type),
+      escapeCsvField(w.config),
+      String(w.position_x),
+      String(w.position_y),
+      String(w.width),
+      String(w.height),
+    ].join(",")
+  );
+
+  const dashboardInfo = `# Dashboard: ${dashboard.name}\n# ID: ${dashboard.id}\n# Tenant: ${dashboard.tenant_id}\n`;
+  const csv = dashboardInfo + [header, ...csvRows].join("\n");
+
+  res.setHeader("Content-Type", "text/csv");
+  res.setHeader("Content-Disposition", `attachment; filename=dashboard-${dashboard.id}.csv`);
+  res.send(csv);
+});
+
+export default router;
