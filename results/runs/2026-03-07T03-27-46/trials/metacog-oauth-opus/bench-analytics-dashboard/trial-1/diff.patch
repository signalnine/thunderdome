+import { Router, Response } from "express";
+import { v4 as uuidv4 } from "uuid";
+import { getDb } from "../db.js";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+const router = Router();
+
+// Ingest a single event
+router.post("/", authMiddleware, (req: AuthRequest, res: Response) => {
+  const { name, properties, timestamp, sessionId } = req.body;
+
+  if (!name) {
+    res.status(400).json({ error: "Event name is required" });
+    return;
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const tenantId = req.user!.tenantId;
+  const userId = req.user!.userId;
+  const props = properties ? JSON.stringify(properties) : "{}";
+  const ts = timestamp || new Date().toISOString();
+
+  db.prepare(
+    "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+  ).run(id, tenantId, name, props, ts, userId, sessionId || null);
+
+  res.status(201).json({ id, name, tenantId, timestamp: ts });
+});
+
+// Ingest a batch of events
+router.post("/batch", authMiddleware, (req: AuthRequest, res: Response) => {
+  const { events } = req.body;
+
+  if (!Array.isArray(events) || events.length === 0) {
+    res.status(400).json({ error: "events array is required and must not be empty" });
+    return;
+  }
+
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+  const userId = req.user!.userId;
+
+  const insert = db.prepare(
+    "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+  );
+
+  const results: Array<{ id: string; name: string }> = [];
+
+  const insertMany = db.transaction(() => {
+    for (const event of events) {
+      if (!event.name) continue;
+      const id = uuidv4();
+      const props = event.properties ? JSON.stringify(event.properties) : "{}";
+      const ts = event.timestamp || new Date().toISOString();
+      insert.run(id, tenantId, event.name, props, ts, userId, event.sessionId || null);
+      results.push({ id, name: event.name });
+    }
+  });
+
+  insertMany();
+
+  res.status(201).json({ inserted: results.length, events: results });
+});
+
+// List events for the tenant
+router.get("/", authMiddleware, (req: AuthRequest, res: Response) => {
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+  const limit = Math.min(parseInt(req.query.limit as string) || 100, 1000);
+  const offset = parseInt(req.query.offset as string) || 0;
+  const name = req.query.name as string | undefined;
+
+  let query = "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?";
+  const params: (string | number)[] = [tenantId];
+
+  if (name) {
+    query += " AND name = ?";
+    params.push(name);
+  }
+
+  query += " ORDER BY timestamp DESC LIMIT ? OFFSET ?";
+  params.push(limit, offset);
+
+  const rows = db.prepare(query).all(...params) as Array<{
+    id: string;
+    tenant_id: string;
+    name: string;
+    properties: string;
+    timestamp: string;
+    user_id: string | null;
+    session_id: string | null;
+  }>;
+
+  const events = rows.map((row) => ({
+    id: row.id,
+    tenantId: row.tenant_id,
+    name: row.name,
+    properties: JSON.parse(row.properties),
+    timestamp: row.timestamp,
+    userId: row.user_id,
+    sessionId: row.session_id,
+  }));
+
+  res.json({ events, limit, offset });
+});
+
+export default router;
