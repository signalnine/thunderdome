+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_011ygeXTg7F4zLD3rc1PkNNM","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KyqoyRJMNgMVYUE9eNqMgc","name":"Write","input":{"file_path":"/workspace/src/routes/dashboards.ts","content":"import { Router, Response } from \"express\";\nimport { v4 as uuidv4 } from \"uuid\";\nimport { getDb } from \"../db.js\";\nimport { AuthRequest, authMiddleware } from \"../auth.js\";\n\nconst router = Router();\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\ninterface WidgetRow {\n  id: string;\n  dashboard_id: string;\n  type: string;\n  config: string;\n  position_x: number;\n  position_y: number;\n  width: number;\n  height: number;\n}\n\nfunction formatDashboard(row: DashboardRow) {\n  return {\n    id: row.id,\n    tenantId: row.tenant_id,\n    name: row.name,\n    ownerId: row.owner_id,\n    config: JSON.parse(row.config),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nfunction formatWidget(row: WidgetRow) {\n  return {\n    id: row.id,\n    dashboardId: row.dashboard_id,\n    type: row.type,\n    config: JSON.parse(row.config),\n    positionX: row.position_x,\n    positionY: row.position_y,\n    width: row.width,\n    height: row.height,\n  };\n}\n\n// List dashboards for tenant\nrouter.get(\"/\", authMiddleware, (req: AuthRequest, res: Response) => {\n  const db = getDb();\n  const tenantId = req.user!.tenantId;\n\n  const rows = db\n    .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n    .all(tenantId) as DashboardRow[];\n\n  res.json({ dashboards: rows.map(formatDashboard) });\n});\n\n// Create a dashboard\nrouter.post(\"/\", authMiddleware, (req: AuthRequest, res: Response) => {\n  const { name, config } = req.body;\n\n  if (!name) {\n    res.status(400).json({ error: \"Dashboard name is required\" });\n    return;\n  }\n\n  const db = getDb();\n  const id = uuidv4();\n  const tenantId = req.user!.tenantId;\n  const ownerId = req.user!.userId;\n  const configStr = config ? JSON.stringify(config) : \"{}\";\n\n  db.prepare(\n    \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)\"\n  ).run(id, tenantId, name, ownerId, configStr);\n\n  const row = db.prepare(\"SELECT * FROM dashboards WHERE id = ?\").get(id) as DashboardRow;\n  res.status(201).json(formatDashboard(row));\n});\n\n// Get a single dashboard with widgets\nrouter.get(\"/:id\", authMiddleware, (req: AuthRequest, res: Response) => {\n  const db = getDb();\n  const tenantId = req.user!.tenantId;\n\n  const row = db\n    .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n  if (!row) {\n    res.status(404).json({ error: \"Dashboard not found\" });\n    return;\n  }\n\n  const widgets = db\n    .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n    .all(row.id) as WidgetRow[];\n\n  res.json({\n    ...formatDashboard(row),\n    widgets: widgets.map(formatWidget),\n  });\n});\n\n// Update a dashboard\nrouter.put(\"/:id\", authMiddleware, (req: AuthRequest, res: Response) => {\n  const { name, config } = req.body;\n  const db = getDb();\n  const tenantId = req.user!.tenantId;\n\n  const existing = db\n    .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n  if (!existing) {\n    res.status(404).json({ error: \"Dashboard not found\" });\n    return;\n  }\n\n  const newName = name || existing.name;\n  const newConfig = config ? JSON.stringify(config) : existing.config;\n\n  db.prepare(\n    \"UPDATE dashboards SET name = ?, config = ?, updated_at = datetime('now') WHERE id = ?\"\n  ).run(newName, newConfig, existing.id);\n\n  const updated = db.prepare(\"SELECT * FROM dashboards WHERE id = ?\").get(existing.id) as DashboardRow;\n  res.json(formatDashboard(updated));\n});\n\n// Delete a dashboard\nrouter.delete(\"/:id\", authMiddleware, (req: AuthRequest, res: Response) => {\n  const db = getDb();\n  const tenantId = req.user!.tenantId;\n\n  const existing = db\n    .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n  if (!existing) {\n    res.status(404).json({ error: \"Dashboard not found\" });\n    return;\n  }\n\n  db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(existing.id);\n  res.status(204).send();\n});\n\n// Add a widget to a dashboard\nrouter.post(\"/:id/widgets\", authMiddleware, (req: AuthRequest, res: Response) => {\n  const { type, config, positionX, positionY, width, height } = req.body;\n  const db = getDb();\n  const tenantId = req.user!.tenantId;\n\n  const dashboard = db\n    .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n  if (!dashboard) {\n    res.status(404).json({ error: \"Dashboard not found\" });\n    return;\n  }\n\n  if (!type || ![\"counter\", \"timeseries\", \"breakdown\", \"funnel\"].includes(type)) {\n    res.status(400).json({ error: \"Valid widget type required (counter, timeseries, breakdown, funnel)\" });\n    return;\n  }\n\n  const id = uuidv4();\n  const configStr = config ? JSON.stringify(config) : \"{}\";\n\n  db.prepare(\n    \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n  ).run(id, req.params.id, type, configStr, positionX || 0, positionY || 0, width || 1, height || 1);\n\n  const widget = db.prepare(\"SELECT * FROM widgets WHERE id = ?\").get(id) as WidgetRow;\n  res.status(201).json(formatWidget(widget));\n});\n\n// Delete a widget\nrouter.delete(\"/:dashboardId/widgets/:widgetId\", authMiddleware, (req: AuthRequest, res: Response) => {\n  con