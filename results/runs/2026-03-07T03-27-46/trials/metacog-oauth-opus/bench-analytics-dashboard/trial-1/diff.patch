+import { Router, Response } from "express";
+import { getDb } from "../db.js";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+const router = Router();
+
+// Count events matching filters
+router.post("/count", authMiddleware, (req: AuthRequest, res: Response) => {
+  const { eventName, filters, startDate, endDate } = req.body;
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  let query = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+  const params: string[] = [tenantId];
+
+  if (eventName) {
+    query += " AND name = ?";
+    params.push(eventName);
+  }
+
+  if (startDate) {
+    query += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+
+  if (endDate) {
+    query += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  if (filters && typeof filters === "object") {
+    for (const [key, value] of Object.entries(filters)) {
+      query += " AND json_extract(properties, ?) = ?";
+      params.push(`$.${key}`, String(value));
+    }
+  }
+
+  const result = db.prepare(query).get(...params) as { count: number };
+  res.json({ count: result.count });
+});
+
+// Timeseries query - bucket event counts over time
+router.post("/timeseries", authMiddleware, (req: AuthRequest, res: Response) => {
+  const { eventName, startDate, endDate, interval, filters } = req.body;
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  // Default interval is 'day'
+  const bucketInterval = interval || "day";
+
+  let dateFormat: string;
+  switch (bucketInterval) {
+    case "hour":
+      dateFormat = "%Y-%m-%dT%H:00:00";
+      break;
+    case "month":
+      dateFormat = "%Y-%m-01";
+      break;
+    case "week":
+      // SQLite doesn't have native week start, use day of year math
+      dateFormat = "%Y-%W";
+      break;
+    case "day":
+    default:
+      dateFormat = "%Y-%m-%d";
+      break;
+  }
+
+  let query = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+  const params: string[] = [tenantId];
+
+  if (eventName) {
+    query += " AND name = ?";
+    params.push(eventName);
+  }
+
+  if (startDate) {
+    query += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+
+  if (endDate) {
+    query += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  if (filters && typeof filters === "object") {
+    for (const [key, value] of Object.entries(filters)) {
+      query += " AND json_extract(properties, ?) = ?";
+      params.push(`$.${key}`, String(value));
+    }
+  }
+
+  query += " GROUP BY bucket ORDER BY bucket ASC";
+
+  const rows = db.prepare(query).all(...params) as Array<{ bucket: string; count: number }>;
+
+  res.json({
+    interval: bucketInterval,
+    data: rows.map((row) => ({
+      period: row.bucket,
+      count: row.count,
+    })),
+  });
+});
+
+// Breakdown query - group by property value
+router.post("/breakdown", authMiddleware, (req: AuthRequest, res: Response) => {
+  const { eventName, property, startDate, endDate, filters, limit: queryLimit } = req.body;
+
+  if (!property) {
+    res.status(400).json({ error: "property is required for breakdown queries" });
+    return;
+  }
+
+  const db = getDb();
+  const tenantId = req.user!.tenantId;
+
+  let query = `SELECT json_extract(properties, ?) as prop_value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+  const params: string[] = [`$.${property}`, tenantId];
+
+  if (eventName) {
+    query += " AND name = ?";
+    params.push(eventName);
+  }
+
+  if (startDate) {
+    query += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+
+  if (endDate) {
+    query += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  if (filters && typeof filters === "object") {
+    for (const [key, value] of Object.entries(filters)) {
+      query += " AND json_extract(properties, ?) = ?";
+      params.push(`$.${key}`, String(value));
+    }
+  }
+
+  query += " AND json_extract(properties, ?) IS NOT NULL";
+  params.push(`$.${property}`);
+
+  query += " GROUP BY prop_value ORDER BY count DESC";
+
+  if (queryLimit) {
+    query += ` LIMIT ${parseInt(String(queryLimit), 10)}`;
+  }
+
+  const rows = db.prepare(query).all(...params) as Array<{ prop_value: string; count: number }>;
+
+  res.json({
+    property,
+    data: rows.map((row) => ({
+      value: row.prop_value,
+      count: row.count,
+    })),
+  });
+});
+
+export default router;
