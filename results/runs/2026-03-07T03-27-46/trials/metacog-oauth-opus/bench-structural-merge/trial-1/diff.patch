+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocumentRecord {
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchData {
+  documents: Map<string, DocumentRecord>;
+}
+
+function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+function getAllPaths(
+  obj: Record<string, unknown>,
+  prefix: string = ""
+): string[] {
+  const paths: string[] = [];
+  for (const key of Object.keys(obj)) {
+    const fullPath = prefix ? `${prefix}.${key}` : key;
+    const val = obj[key];
+    if (val !== null && typeof val === "object" && !Array.isArray(val)) {
+      paths.push(...getAllPaths(val as Record<string, unknown>, fullPath));
+    } else {
+      paths.push(fullPath);
+    }
+  }
+  return paths;
+}
+
+function getAtPath(obj: Record<string, unknown>, path: string): unknown {
+  const parts = path.split(".");
+  let current: unknown = obj;
+  for (const part of parts) {
+    if (current === null || typeof current !== "object") return undefined;
+    current = (current as Record<string, unknown>)[part];
+  }
+  return current;
+}
+
+function setAtPath(
+  obj: Record<string, unknown>,
+  path: string,
+  value: unknown
+): void {
+  const parts = path.split(".");
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (
+      !(part in current) ||
+      current[part] === null ||
+      typeof current[part] !== "object" ||
+      Array.isArray(current[part])
+    ) {
+      current[part] = {};
+    }
+    current = current[part] as Record<string, unknown>;
+  }
+  current[parts[parts.length - 1]] = value;
+}
+
+function deleteAtPath(obj: Record<string, unknown>, path: string): void {
+  const parts = path.split(".");
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (current[part] === null || typeof current[part] !== "object")
+      return;
+    current = current[part] as Record<string, unknown>;
+  }
+  delete current[parts[parts.length - 1]];
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  return JSON.stringify(a) === JSON.stringify(b);
+}
+
+// Collect all leaf paths from multiple objects combined
+function collectAllPaths(
+  ...objects: (Record<string, unknown> | null | undefined)[]
+): Set<string> {
+  const paths = new Set<string>();
+  for (const obj of objects) {
+    if (obj != null) {
+      for (const p of getAllPaths(obj)) {
+        paths.add(p);
+      }
+    }
+  }
+  return paths;
+}
+
+// Clean up empty intermediate objects left after deletions
+function cleanEmptyObjects(obj: Record<string, unknown>): void {
+  for (const key of Object.keys(obj)) {
+    const val = obj[key];
+    if (val !== null && typeof val === "object" && !Array.isArray(val)) {
+      cleanEmptyObjects(val as Record<string, unknown>);
+      if (Object.keys(val as Record<string, unknown>).length === 0) {
+        delete obj[key];
+      }
+    }
+  }
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = "main";
+  // Track the snapshot of each branch at the time it was created
+  // Maps branchName -> { parentBranch, snapshot of documents at fork time }
+  private branchOrigins: Map<
+    string,
+    { parent: string; snapshot: Map<string, object | null> }
+  > = new Map();
+
+  constructor() {
+    this.branches.set("main", { documents: new Map() });
+  }
+
+  private getBranchData(name?: string): BranchData {
+    const branchName = name ?? this.currentBranch;
+    const branch = this.branches.get(branchName);
+    if (!branch) throw new Error(`Branch "${branchName}" does not exist`);
+    return branch;
+  }
+
+  // --- CRUD ---
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const version: Version = {
+      id: randomUUID(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    branch.documents.set(id, {
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(doc.versions[doc.versions.length - 1].content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version: Version = {
+      id: randomUUID(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    doc.deleted = true;
+  }
+
+  // --- Version History ---
+
+  getHistory(id: string): Version[] {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc.versions.map((v) => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = doc.versions.find((v) => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist`);
+    }
+    return deepClone(version.content);
+  }
+
+  // --- Branching ---
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.getBranchData(sourceName);
+
+    // Deep clone all documents for the new branch
+    const newDocs = new Map<string, DocumentRecord>();
+    const snapshot = new Map<string, object | null>();
+
+    for (const [docId, record] of source.documents) {
+      newDocs.set(docId, {
+        versions: record.versions.map((v) => ({
+          id: v.id,
+          timestamp: v.timestamp,
+          content: deepClone(v.content),
+        })),
+        deleted: record.deleted,
+      });
+      // Record current state at fork time
+      if (record.deleted) {
+        snapshot.set(docId, null);
+      } else {
+        snapshot.set(
+          docId,
+          deepClone(record.versions[record.versions.length - 1].content)
+        );
+      }
+    }
+
+    this.branches.set(name, { documents: newDocs });
+    this.branchOrigins.set(name, { parent: sourceName, snapshot });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // --- Merging ---
+
+  private getDocumentContent(
+    branch: BranchData,
+    docId: string
+  ): object | null {
+    const doc = branch.documents.get(docId);
+    if (!doc || doc.deleted) return null;
+    return deepClone(doc.versions[doc.versions.length - 1].content);
+  }
+
+  private findCommonAncestor(
+    sourceBranch: string
+  ): Map<string, object | null> {
+    // The common ancestor is the snapshot taken when the branch was created
+    // We need to find the relationship between source and current branch
+    const origin = this.branchOrigins.get(sourceBranch);
+    if (origin && origin.parent === this.currentBranch) {
+      // Source was branched from current - use the snapshot
+      return origin.snapshot;
+    }
+
+    const currentOrigin = this.branchOrigins.get(this.currentBranch);
+    if (currentOrigin && currentOrigin.parent === sourceBranch) {
+      // Current was branched from source - use the snapshot
+      return currentOrigin.snapshot;
+    }
+
+    // Both branched from a common parent - find it
+    // For simplicity, check if they share a common parent
+    if (
+      origin &&
+      currentOrigin &&
+      origin.parent === currentOrigin.parent
+    ) {
+      // Both branched from the same parent - we need the earlier snapshot
+      // Since they diverged from the same parent, the common ancestor is
+      // the state at the time the first branch was created
+      // Use the snapshot from whichever was created (they should be similar)
+      return origin.snapshot;
+    }
+
+    // Fallback: empty state as common ancestor
+    return new Map();
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    if (!this.branches.has(sourceBranch)) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+
+    const currentBranchData = this.getBranchData();
+    const sourceBranchData = this.getBranchData(sourceBranch);
+    const baseSnapshot = this.findCommonAncestor(sourceBranch);
+
+    // Collect all document IDs across base, ours, and theirs
+    const allDocIds = new Set<string>();
+    for (const id of baseSnapshot.keys()) allDocIds.add(id);
+    for (const id of currentBranchData.documents.keys()) allDocIds.add(id);
+    for (const id of sourceBranchData.documents.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const base = baseSnapshot.get(docId) ?? null;
+      const ours = this.getDocumentContent(currentBranchData, docId);
+      const theirs = this.getDocumentContent(sourceBranchData, docId);
+
+      // If nothing changed on either side, skip
+      if (deepEqual(base, ours) && deepEqual(base, theirs)) {
+        if (ours !== null) {
+          merged[docId] = ours;
+        }
+        continue;
+      }
+
+      // If only one side changed
+      if (deepEqual(base, ours) && !deepEqual(base, theirs)) {
+        // Only source changed - take theirs
+        if (theirs !== null) {
+          merged[docId] = theirs;
+        }
+        // If theirs is null (deleted), don't include in merged
+        continue;
+      }
+
+      if (!deepEqual(base, ours) && deepEqual(base, theirs)) {
+        // Only current changed - keep ours
+        if (ours !== null) {
+          merged[docId] = ours;
+        }
+        continue;
+      }
+
+      // Both sides changed
+      // Handle deletion cases
+      if (ours === null && theirs === null) {
+        // Both deleted - no conflict
+        continue;
+      }
+
+      if (ours === null || theirs === null) {
+        // One deleted, one modified - this is a conflict at the document level
+        // For the merged output, favor ours
+        if (ours !== null) {
+          merged[docId] = ours;
+        }
+        conflicts.push({
+          documentId: docId,
+          path: "",
+          base,
+          ours,
+          theirs,
+        });
+        continue;
+      }
+
+      // Both sides modified - do field-level three-way merge
+      const baseObj = (base ?? {}) as Record<string, unknown>;
+      const oursObj = ours as Record<string, unknown>;
+      const theirsObj = theirs as Record<string, unknown>;
+
+      const allPaths = collectAllPaths(baseObj, oursObj, theirsObj);
+      const mergedDoc = deepClone(oursObj) as Record<string, unknown>;
+
+      for (const path of allPaths) {
+        const baseVal = getAtPath(baseObj, path);
+        const oursVal = getAtPath(oursObj, path);
+        const theirsVal = getAtPath(theirsObj, path);
+
+        const baseChanged = !deepEqual(baseVal, oursVal);
+        const theirsChanged = !deepEqual(baseVal, theirsVal);
+
+        if (!baseChanged && theirsChanged) {
+          // Only source changed this path - take theirs
+          if (theirsVal === undefined) {
+            deleteAtPath(mergedDoc, path);
+          } else {
+            setAtPath(mergedDoc, path, deepClone(theirsVal));
+          }
+        } else if (baseChanged && theirsChanged) {
+          // Both changed
+          if (!deepEqual(oursVal, theirsVal)) {
+            // Different values - conflict
+            conflicts.push({
+              documentId: docId,
+              path,
+              base: baseVal,
+              ours: oursVal,
+              theirs: theirsVal,
+            });
+            // merged keeps ours (already there)
+          }
+          // Same value = no conflict, ours is already correct
+        }
+        // If only ours changed, mergedDoc already has our value
+      }
+
+      cleanEmptyObjects(mergedDoc);
+      merged[docId] = mergedDoc as object;
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge to the current branch
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const doc = currentBranchData.documents.get(docId);
+          const mergedContent = merged[docId];
+          if (doc && !doc.deleted) {
+            // Check if content actually changed
+            const currentContent =
+              doc.versions[doc.versions.length - 1].content;
+            if (!deepEqual(currentContent, mergedContent)) {
+              doc.versions.push({
+                id: randomUUID(),
+                timestamp: Date.now(),
+                content: deepClone(mergedContent),
+              });
+            }
+          } else if (!doc) {
+            // Document is new from source branch
+            currentBranchData.documents.set(docId, {
+              versions: [
+                {
+                  id: randomUUID(),
+                  timestamp: Date.now(),
+                  content: deepClone(mergedContent),
+                },
+              ],
+              deleted: false,
+            });
+          } else if (doc.deleted) {
+            // Was deleted on our side but exists in merge result
+            doc.deleted = false;
+            doc.versions.push({
+              id: randomUUID(),
+              timestamp: Date.now(),
+              content: deepClone(mergedContent),
+            });
+          }
+        } else {
+          // Document not in merged means it was deleted
+          const doc = currentBranchData.documents.get(docId);
+          if (doc && !doc.deleted) {
+            doc.deleted = true;
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts, applied };
+  }
+}
