+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WtBpZvxPxvatV8cZa6Uv5x","type":"tool_result","content":"File created successfully at: /workspace/tests/app.test.ts"}]},"parent_tool_use_id":null,"session_id":"226423f2-5908-4b13-9732-b00df4252652","uuid":"0ee2af63-932a-491b-a5c1-94bfd5e804ab","tool_use_result":{"type":"create","filePath":"/workspace/tests/app.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport request from 'supertest';\nimport { createApp } from '../src/app.js';\nimport type { Express } from 'express';\n\nlet app: Express;\n\nbeforeEach(() => {\n  app = createApp();\n});\n\n// Helper to register and login a user, returning { token, userId }\nasync function createUser(username: string, password: string) {\n  const regRes = await request(app)\n    .post('/auth/register')\n    .send({ username, password });\n  const loginRes = await request(app)\n    .post('/auth/login')\n    .send({ username, password });\n  return { token: loginRes.body.token as string, userId: regRes.body.id as string };\n}\n\n// Helper to create a folder\nasync function createFolder(token: string, name: string, parentId?: string) {\n  const res = await request(app)\n    .post('/folders')\n    .set('Authorization', `Bearer ${token}`)\n    .send({ name, parentId: parentId || null });\n  return res;\n}\n\n// Helper to create a document\nasync function createDocument(token: string, title: string, content: string, folderId: string) {\n  const res = await request(app)\n    .post('/documents')\n    .set('Authorization', `Bearer ${token}`)\n    .send({ title, content, folderId });\n  return res;\n}\n\n// Helper to share a resource\nasync function shareResource(token: string, resourceType: string, resourceId: string, userId: string, role: string) {\n  const res = await request(app)\n    .post('/share')\n    .set('Authorization', `Bearer ${token}`)\n    .send({ resourceType, resourceId, userId, role });\n  return res;\n}\n\ndescribe('Auth', () => {\n  it('should register a new user', async () => {\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'pass123' });\n    expect(res.status).toBe(201);\n    expect(res.body).toHaveProperty('id');\n    expect(res.body.username).toBe('alice');\n  });\n\n  it('should reject duplicate username', async () => {\n    await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'pass123' });\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'otherpass' });\n    expect(res.status).toBe(409);\n  });\n\n  it('should reject registration with missing fields', async () => {\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should login and return a token', async () => {\n    await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'pass123' });\n    const res = await request(app)\n      .post('/auth/login')\n      .send({ username: 'alice', password: 'pass123' });\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveProperty('token');\n    expect(res.body).toHaveProperty('userId');\n  });\n\n  it('should reject login with wrong password', async () => {\n    await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'pass123' });\n    const res = await request(app)\n      .post('/auth/login')\n      .send({ username: 'alice', password: 'wrong' });\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject login for non-existent user', async () => {\n    const res = await request(app)\n      .post('/auth/login')\n      .send({ username: 'nobody', password: 'pass' });\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject requests without auth token', async () => {\n    const res = await request(app).get('/folders/some-id');\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject requests with invalid token', async () => {\n    const res = await request(app)\n      .get('/folders/some-id')\n      .set('Authorization', 'Bearer invalid-token');\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe('Folders', () => {\n  it('should create a folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await createFolder(token, 'My Folder');\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe('My Folder');\n    expect(res.body).toHaveProperty('id');\n    expect(res.body.parentId).toBeNull();\n  });\n\n  it('should get a folder with children and documents', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folderRes = await createFolder(token, 'Parent');\n    const folderId = folderRes.body.id;\n\n    await createFolder(token, 'Child', folderId);\n    await createDocument(token, 'Doc1', 'Content1', folderId);\n\n    const res = await request(app)\n      .get(`/folders/${folderId}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Parent');\n    expect(res.body.children).toHaveLength(1);\n    expect(res.body.documents).toHaveLength(1);\n  });\n\n  it('should create nested folders', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const parent = await createFolder(token, 'Parent');\n    const child = await createFolder(token, 'Child', parent.body.id);\n    expect(child.status).toBe(201);\n    expect(child.body.parentId).toBe(parent.body.id);\n  });\n\n  it('should update a folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Old Name');\n\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'New Name' });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('New Name');\n  });\n\n  it('should delete a folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'To Delete');\n\n    const res = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should return 404 for non-existent folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .get('/folders/nonexistent')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should reject folder creation with missing name', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({});\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject creation with non-existent parent', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await createFolder(token, 'Orphan', 'no-such-parent');\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('Documents', () => {\n  it('should create a document in a folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Docs');\n    const res = await createDocument(token, 'My Doc', 'Hello world', folder.body.id);\n    expect(res.status).toBe(201);\n    expect(res.body.title).toBe('My Doc');\n    expect(res.body.content).toBe('Hello world');\n    expect(res.body.folderId).toBe(folder.body.id);\n  });\n\n  it('should get a document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Docs');\n    const doc = await createDocument(token, 'My Doc', 'Content', folder.body.id);\n\n    const res = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('My Doc');\n  });\n\n  it('should update a document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Docs');\n    const doc = await createDocument(token, 'My Doc', 'Original', folder.body.id);\n\n    const res = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Updated Doc', content: 'Updated content' });\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Updated Doc');\n    expect(res.body.content).toBe('Updated content');\n  });\n\n  it('should delete a document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Docs');\n    const doc = await createDocument(token, 'My Doc', 'Content', folder.body.id);\n\n    const res = await request(app)\n      .delete(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .get('/documents/nonexistent')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should reject document creation with missing fields', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'No folder' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject document creation in non-existent folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await createDocument(token, 'Doc', 'Content', 'no-folder');\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('Sharing & Permissions', () => {\n  it('should share a folder with another user', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Shared Folder');\n    const res = await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n    expect(res.status).toBe(201);\n    expect(res.body.role).toBe('viewer');\n  });\n\n  it('should allow viewer to read a shared folder', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Shared Folder');\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n    const res = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(res.status).toBe(200);\n  });\n\n  it('should deny viewer from updating a folder', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Shared');\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ name: 'Renamed' });\n    expect(res.status).toBe(403);\n  });\n\n  it('should allow editor to update a folder', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Shared');\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'editor');\n\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ name: 'Renamed' });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Renamed');\n  });\n\n  it('should deny non-owner from deleting a folder', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Shared');\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'editor');\n\n    const res = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('should share a document with another user', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Docs');\n    const doc = await createDocument(aliceToken, 'Shared Doc', 'Content', folder.body.id);\n    const res = await shareResource(aliceToken, 'document', doc.body.id, bobId, 'editor');\n    expect(res.status).toBe(201);\n  });\n\n  it('should inherit folder permissions for documents', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Shared Folder');\n    const doc = await createDocument(aliceToken, 'Doc', 'Content', folder.body.id);\n\n    // Share folder with bob as viewer\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n    // Bob should be able to read the document through folder access\n    const res = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(res.status).toBe(200);\n  });\n\n  it('should deny access when user has no permissions', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Private');\n    const res = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('should use most permissive role from multiple paths', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Shared Folder');\n    const doc = await createDocument(aliceToken, 'Doc', 'Content', folder.body.id);\n\n    // Share folder as viewer\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n    // Share document directly as editor\n    await shareResource(aliceToken, 'document', doc.body.id, bobId, 'editor');\n\n    // Bob should be able to edit (most permissive)\n    const res = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ content: 'Updated by Bob' });\n    expect(res.status).toBe(200);\n    expect(res.body.content).toBe('Updated by Bob');\n  });\n\n  it('should deny viewer from sharing', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n    const { userId: charlieId } = await createUser('charlie', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Shared');\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n    const res = await shareResource(bobToken, 'folder', folder.body.id, charlieId, 'viewer');\n    expect(res.status).toBe(403);\n  });\n\n  it('should allow editor to share with others', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n    const { userId: charlieId } = await createUser('charlie', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Shared');\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'editor');\n\n    const res = await shareResource(bobToken, 'folder', folder.body.id, charlieId, 'viewer');\n    expect(res.status).toBe(201);\n  });\n\n  it('should deny editor from assigning owner role', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n    const { userId: charlieId } = await createUser('charlie', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Shared');\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'editor');\n\n    const res = await shareResource(bobToken, 'folder', folder.body.id, charlieId, 'owner');\n    expect(res.status).toBe(403);\n  });\n\n  it('should return 404 for sharing with non-existent user', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const folder = await createFolder(aliceToken, 'Folder');\n    const res = await shareResource(aliceToken, 'folder', folder.body.id, 'no-such-user', 'viewer');\n    expect(res.status).toBe(404);\n  });\n\n  it('should return 404 for sharing non-existent resource', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { userId: bobId } = await createUser('bob', 'pass');\n    const res = await shareResource(aliceToken, 'folder', 'no-such-folder', bobId, 'viewer');\n    expect(res.status).toBe(404);\n  });\n\n  it('should get shares for a resource', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Folder');\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n    const res = await request(app)\n      .get(`/share/folder/${folder.body.id}`)\n      .set('Authorization', `Bearer ${aliceToken}`);\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveLength(1);\n    expect(res.body[0].userId).toBe(bobId);\n  });\n\n  it('should inherit permissions through nested folders', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n\n    const parent = await createFolder(aliceToken, 'Parent');\n    const child = await createFolder(aliceToken, 'Child', parent.body.id);\n\n    // Share parent folder with bob\n    await shareResource(aliceToken, 'folder', parent.body.id, bobId, 'viewer');\n\n    // Bob should be able to read child folder\n    const res = await request(app)\n      .get(`/folders/${child.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`);\n    expect(res.status).toBe(200);\n  });\n\n  it('should update existing share role', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Folder');\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n    // Upgrade to editor\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'editor');\n\n    // Bob should now be able to update\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ name: 'Updated by Bob' });\n    expect(res.status).toBe(200);\n  });\n});\n\ndescribe('Activity Log', () => {\n  it('should log document creation', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Docs');\n    await createDocument(token, 'Doc', 'Content', folder.body.id);\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    const createEntries = res.body.filter((e: { action: string }) => e.action === 'document_created');\n    expect(createEntries.length).toBeGreaterThanOrEqual(1);\n  });\n\n  it('should log document updates', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Docs');\n    const doc = await createDocument(token, 'Doc', 'Content', folder.body.id);\n\n    await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ content: 'Updated' });\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    const updateEntries = res.body.filter((e: { action: string }) => e.action === 'document_updated');\n    expect(updateEntries.length).toBeGreaterThanOrEqual(1);\n  });\n\n  it('should log document deletion', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Docs');\n    const doc = await createDocument(token, 'Doc', 'Content', folder.body.id);\n\n    await request(app)\n      .delete(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    const deleteEntries = res.body.filter((e: { action: string }) => e.action === 'document_deleted');\n    expect(deleteEntries.length).toBeGreaterThanOrEqual(1);\n  });\n\n  it('should log sharing events', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Folder');\n    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'viewer');\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${aliceToken}`);\n    const shareEntries = res.body.filter((e: { action: string }) => e.action === 'shared');\n    expect(shareEntries.length).toBeGreaterThanOrEqual(1);\n  });\n\n  it('should include timestamp in activity entries', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Docs');\n    await createDocument(token, 'Doc', 'Content', folder.body.id);\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.body[0]).toHaveProperty('timestamp');\n    expect(res.body[0]).toHaveProperty('action');\n    expect(res.body[0]).toHaveProperty('userId');\n    expect(res.body[0]).toHaveProperty('resourceType');\n    expect(res.body[0]).toHaveProperty('resourceId');\n  });\n\n  it('should require auth for activity log', async () => {\n    const res = await request(app).get('/activity');\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe('Edge Cases', () => {\n  it('should reject sharing with invalid role', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { userId: bobId } = await createUser('bob', 'pass');\n    const folder = await createFolder(aliceToken, 'Folder');\n\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'folder', resourceId: folder.body.id, userId: bobId, role: 'admin' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject sharing with invalid resource type', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { userId: bobId } = await createUser('bob', 'pass');\n\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'invalid', resourceId: 'some-id', userId: bobId, role: 'viewer' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should allow owner to share with owner role', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Folder');\n    const res = await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'owner');\n    expect(res.status).toBe(201);\n  });\n\n  it('should handle document in nested folder with folder-level permissions', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n\n    const parent = await createFolder(aliceToken, 'Parent');\n    const child = await createFolder(aliceToken, 'Child', parent.body.id);\n    const doc = await createDocument(aliceToken, 'Nested Doc', 'Content', child.body.id);\n\n    // Share parent folder with bob as editor\n    await shareResource(aliceToken, 'folder', parent.body.id, bobId, 'editor');\n\n    // Bob should be able to edit the nested doc (inherits from parent -> child -> doc)\n    const res = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ content: 'Updated by Bob' });\n    expect(res.status).toBe(200);\n    expect(res.body.content).toBe('Updated by Bob');\n  });\n});\n","structuredPatch":[],"originalFile":null}}
