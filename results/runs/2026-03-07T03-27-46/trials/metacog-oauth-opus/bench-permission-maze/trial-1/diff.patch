@@ -0,0 +1,101 @@
+import { Router, Request, Response } from 'express';
+import { Store } from '../store.js';
+import { authMiddleware } from '../middleware.js';
+
+export function foldersRouter(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Create folder
+  router.post('/', (req: Request, res: Response): void => {
+    const user = req.user!;
+    const { name, parentId } = req.body;
+
+    if (!name || typeof name !== 'string') {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    // If parentId is specified, verify it exists and user has access
+    if (parentId) {
+      const parent = store.getFolder(parentId);
+      if (!parent) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      const role = store.getEffectiveRole(user.id, 'folder', parentId);
+      if (!role || (role !== 'editor' && role !== 'owner')) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const folder = store.createFolder(name, parentId || null, user.id);
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', (req: Request, res: Response): void => {
+    const user = req.user!;
+    const folder = store.getFolder(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = store.getEffectiveRole(user.id, 'folder', folder.id);
+    if (!role) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const children = store.getFolderChildren(folder.id);
+    const documents = store.getDocumentsInFolder(folder.id);
+
+    res.json({ ...folder, children, documents });
+  });
+
+  // Update folder
+  router.put('/:id', (req: Request, res: Response): void => {
+    const user = req.user!;
+    const folder = store.getFolder(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = store.getEffectiveRole(user.id, 'folder', folder.id);
+    if (!role || role === 'viewer') {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const updates: Partial<{ name: string; parentId: string | null }> = {};
+    if (req.body.name !== undefined) updates.name = req.body.name;
+    if (req.body.parentId !== undefined) updates.parentId = req.body.parentId;
+
+    const updated = store.updateFolder(folder.id, updates);
+    res.json(updated);
+  });
+
+  // Delete folder
+  router.delete('/:id', (req: Request, res: Response): void => {
+    const user = req.user!;
+    const folder = store.getFolder(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = store.getEffectiveRole(user.id, 'folder', folder.id);
+    if (role !== 'owner') {
+      res.status(403).json({ error: 'Only owners can delete folders' });
+      return;
+    }
+
+    store.deleteFolder(folder.id);
+    res.status(204).send();
+  });
+
+  return router;
+}
