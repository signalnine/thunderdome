const folder = store.getFolder(resourceId);\n    45→      if (!folder) {\n    46→        res.status(404).json({ error: 'Folder not found' });\n    47→        return;\n    48→      }\n    49→    } else {\n    50→      const doc = store.getDocument(resourceId);\n    51→      if (!doc) {\n    52→        res.status(404).json({ error: 'Document not found' });\n    53→        return;\n    54→      }\n    55→    }\n    56→\n    57→    // Check sharer's permissions\n    58→    const sharerRole = store.getEffectiveRole(user.id, resourceType, resourceId);\n    59→    if (!sharerRole) {\n    60→      res.status(403).json({ error: 'Access denied' });\n    61→      return;\n    62→    }\n    63→\n    64→    // Viewers cannot share\n    65→    if (sharerRole === 'viewer') {\n    66→      res.status(403).json({ error: 'Viewers cannot share resources' });\n    67→      return;\n    68→    }\n    69→\n    70→    // Editors can share but cannot assign owner role\n    71→    if (sharerRole === 'editor' && role === 'owner') {\n    72→      res.status(403).json({ error: 'Editors cannot assign owner role' });\n    73→      return;\n    74→    }\n    75→\n    76→    const share = store.addShare(resourceType, resourceId, userId, role);\n    77→    store.addActivity('shared', user.id, resourceType, resourceId, `Shared with user ${userId} as ${role}`);\n    78→    res.status(201).json(share);\n    79→  });\n    80→\n    81→  // Get shares for a resource\n    82→  router.get('/:resourceType/:resourceId', (req: Request, res: Response): void => {\n    83→    const user = req.user!;\n    84→    const { resourceType, resourceId } = req.params;\n    85→\n    86→    if (!VALID_RESOURCE_TYPES.includes(resourceType as ResourceType)) {\n    87→      res.status(400).json({ error: 'Invalid resource type' });\n    88→      return;\n    89→    }\n    90→\n    91→    const role = store.getEffectiveRole(user.id, resourceType as ResourceType, resourceId);\n    92→    if (!role) {\n    93→      res.status(403