@@ -0,0 +1,102 @@
+import { Router, Request, Response } from 'express';
+import { Store } from '../store.js';
+import { authMiddleware } from '../middleware.js';
+import { Role, ResourceType } from '../types.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+const VALID_RESOURCE_TYPES: ResourceType[] = ['folder', 'document'];
+
+export function sharingRouter(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Share a resource
+  router.post('/', (req: Request, res: Response): void => {
+    const user = req.user!;
+    const { resourceType, resourceId, userId, role } = req.body;
+
+    if (!resourceType || !VALID_RESOURCE_TYPES.includes(resourceType)) {
+      res.status(400).json({ error: 'Valid resourceType is required (folder or document)' });
+      return;
+    }
+    if (!resourceId || typeof resourceId !== 'string') {
+      res.status(400).json({ error: 'resourceId is required' });
+      return;
+    }
+    if (!userId || typeof userId !== 'string') {
+      res.status(400).json({ error: 'userId is required' });
+      return;
+    }
+    if (!role || !VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Valid role is required (viewer, editor, or owner)' });
+      return;
+    }
+
+    // Check that the target user exists
+    const targetUser = store.findUserById(userId);
+    if (!targetUser) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Check that the resource exists
+    if (resourceType === 'folder') {
+      const folder = store.getFolder(resourceId);
+      if (!folder) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      const doc = store.getDocument(resourceId);
+      if (!doc) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check sharer's permissions
+    const sharerRole = store.getEffectiveRole(user.id, resourceType, resourceId);
+    if (!sharerRole) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    // Viewers cannot share
+    if (sharerRole === 'viewer') {
+      res.status(403).json({ error: 'Viewers cannot share resources' });
+      return;
+    }
+
+    // Editors can share but cannot assign owner role
+    if (sharerRole === 'editor' && role === 'owner') {
+      res.status(403).json({ error: 'Editors cannot assign owner role' });
+      return;
+    }
+
+    const share = store.addShare(resourceType, resourceId, userId, role);
+    store.addActivity('shared', user.id, resourceType, resourceId, `Shared with user ${userId} as ${role}`);
+    res.status(201).json(share);
+  });
+
+  // Get shares for a resource
+  router.get('/:resourceType/:resourceId', (req: Request, res: Response): void => {
+    const user = req.user!;
+    const { resourceType, resourceId } = req.params;
+
+    if (!VALID_RESOURCE_TYPES.includes(resourceType as ResourceType)) {
+      res.status(400).json({ error: 'Invalid resource type' });
+      return;
+    }
+
+    const role = store.getEffectiveRole(user.id, resourceType as ResourceType, resourceId);
+    if (!role) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const shares = store.getSharesForResource(resourceType as ResourceType, resourceId);
+    res.json(shares);
+  });
+
+  return router;
+}
diff --git a/src/store.ts b/src/store.ts
new file mode 100644
index 0000000..afc9e3a
--- /dev/null
+++ b/src/store.ts
@@ -0,0 +1,258 @@
+import { User, Folder, Document, Share, ActivityLogEntry, Role, ResourceType } from './types.js';
+import crypto from 'node:crypto';
+
+function genId(): string {
+  return crypto.randomUUID();
+}
+
+const ROLE_WEIGHT: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function createStore() {
+  const users = new Map<string, User>();
+  const folders = new Map<string, Folder>();
+  const documents = new Map<string, Document>();
+  const shares: Share[] = [];
+  const activityLog: ActivityLogEntry[] = [];
+
+  // ---- Users ----
+  function createUser(username: string, password: string): User {
+    const id = genId();
+    const user: User = { id, username, password, token: null };
+    users.set(id, user);
+    return user;
+  }
+
+  function findUserByUsername(username: string): User | undefined {
+    for (const u of users.values()) {
+      if (u.username === username) return u;
+    }
+    return undefined;
+  }
+
+  function findUserByToken(token: string): User | undefined {
+    for (const u of users.values()) {
+      if (u.token === token) return u;
+    }
+    return undefined;
+  }
+
+  function findUserById(id: string): User | undefined {
+    return users.get(id);
+  }
+
+  function generateToken(userId: string): string {
+    const user = users.get(userId);
+    if (!user) throw new Error('User not found');
+    user.token = genId();
+    return user.token;
+  }
+
+  // ---- Folders ----
+  function createFolder(name: string, parentId: string | null, ownerId: string): Folder {
+    const id = genId();
+    const folder: Folder = { id, name, parentId, ownerId, createdAt: new Date().toISOString() };
+    folders.set(id, folder);
+    return folder;
+  }
+
+  function getFolder(id: string): Folder | undefined {
+    return folders.get(id);
+  }
+
+  function updateFolder(id: string, updates: Partial<Pick<Folder, 'name' | 'parentId'>>): Folder | undefined {
+    const folder = folders.get(id);
+    if (!folder) return undefined;
+    if (updates.name !== undefined) folder.name = updates.name;
+    if (updates.parentId !== undefined) folder.parentId = updates.parentId;
+    return folder;
+  }
+
+  function deleteFolder(id: string): boolean {
+    return folders.delete(id);
+  }
+
+  function getFolderChildren(parentId: string): Folder[] {
+    const result: Folder[] = [];
+    for (const f of folders.values()) {
+      if (f.parentId === parentId) result.push(f);
+    }
+    return result;
+  }
+
+  function getDocumentsInFolder(folderId: string): Document[] {
+    const result: Document[] = [];
+    for (const d of documents.values()) {
+      if (d.folderId === folderId) result.push(d);
+    }
+    return result;
+  }
+
+  // ---- Documents ----
+  function createDocument(title: string, content: string, folderId: string, ownerId: string): Document {
+    const id = genId();
+    const now = new Date().toISOString();
+    const doc: Document = { id, title, content, folderId, ownerId, createdAt: now, updatedAt: now };
+    documents.set(id, doc);
+    return doc;
+  }
+
+  function getDocument(id: string): Document | undefined {
+    return documents.get(id);
+  }
+
+  function updateDocument(id: string, updates: Partial<Pick<Document, 'title' | 'content'>>): Document | undefined {
+    const doc = documents.get(id);
+    if (!doc) return undefined;
+    if (updates.title !== undefined) doc.title = updates.title;
+    if (updates.content !== undefined) doc.content = updates.content;
+    doc.updatedAt = new Date().toISOString();
+    return doc;
+  }
+
+  function deleteDocument(id: string): boolean {
+    return documents.delete(id);
+  }
+
+  // ---- Sharing ----
+  function addShare(resourceType: ResourceType, resourceId: string, userId: string, role: Role): Share {
+    // Check if share already exists, update if so
+    const existing = shares.find(
+      s => s.resourceType === resourceType && s.resourceId === resourceId && s.userId === userId
+    );
+    if (existing) {
+      existing.role = role;
+      return existing;
+    }
+    const share: Share = { id: genId(), resourceType, resourceId, userId, role };
+    shares.push(share);
+    return share;
+  }
+
+  function getSharesForResource(resourceType: ResourceType, resourceId: string): Share[] {
+    return shares.filter(s => s.resourceType === resourceType && s.resourceId === resourceId);
+  }
+
+  function getSharesForUser(userId: string): Share[] {
+    return shares.filter(s => s.userId === userId);
+  }
+
+  // Get ancestor folder chain for a folder
+  function getFolderAncestors(folderId: string): Folder[] {
+    const ancestors: Folder[] = [];
+    let current = folders.get(folderId);
+    while (current && current.parentId) {
+      const parent = folders.get(current.parentId);
+      if (!parent) break;
+      ancestors.push(parent);
+      current = parent;
+    }
+    return ancestors;
+  }
+
+  // Get effective role for a user on a resource.
+  // Checks direct shares + inherited folder shares.
+  function getEffectiveRole(userId: string, resourceType: ResourceType, resourceId: string): Role | null {
+    let bestRole: Role | null = null;
+
+    // Check if user is the owner of the resource
+    if (resourceType === 'folder') {
+      const folder = folders.get(resourceId);
+      if (folder && folder.ownerId === userId) return 'owner';
+    } else {
+      const doc = documents.get(resourceId);
+      if (doc && doc.ownerId === userId) return 'owner';
+    }
+
+    // Direct share on this resource
+    const directShares = shares.filter(
+      s => s.resourceType === resourceType && s.resourceId === resourceId && s.userId === userId
+    );
+    for (const s of directShares) {
+      if (!bestRole || ROLE_WEIGHT[s.role] > ROLE_WEIGHT[bestRole]) {
+        bestRole = s.role;
+      }
+    }
+
+    // If it's a document, check shares on the folder and folder ancestors
+    if (resourceType === 'document') {
+      const doc = documents.get(resourceId);
+      if (doc) {
+        // Check folder shares
+        const folderRole = getEffectiveRole(userId, 'folder', doc.folderId);
+        if (folderRole && (!bestRole || ROLE_WEIGHT[folderRole] > ROLE_WEIGHT[bestRole])) {
+          bestRole = folderRole;
+        }
+      }
+    }
+
+    // If it's a folder, check ancestor folders
+    if (resourceType === 'folder') {
+      const ancestors = getFolderAncestors(resourceId);
+      for (const ancestor of ancestors) {
+        const ancestorShares = shares.filter(
+          s => s.resourceType === 'folder' && s.resourceId === ancestor.id && s.userId === userId
+        );
+        for (const s of ancestorShares) {
+          if (!bestRole || ROLE_WEIGHT[s.role] > ROLE_WEIGHT[bestRole]) {
+            bestRole = s.role;
+          }
+        }
+        // Check if user is the owner of ancestor folder
+        if (ancestor.ownerId === userId) {
+          bestRole = 'owner';
+        }
+      }
+    }
+
+    return bestRole;
+  }
+
+  // ---- Activity Log ----
+  function addActivity(action: string, userId: string, resourceType: ResourceType, resourceId: string, details?: string): ActivityLogEntry {
+    const entry: ActivityLogEntry = {
+      id: genId(),
+      action,
+      userId,
+      resourceType,
+      resourceId,
+      timestamp: new Date().toISOString(),
+      details,
+    };
+    activityLog.push(entry);
+    return entry;
+  }
+
+  function getActivityLog(): ActivityLogEntry[] {
+    return [...activityLog];
+  }
+
+  return {
+    createUser,
+    findUserByUsername,
+    findUserByToken,
+    findUserById,
+    generateToken,
+    createFolder,
+    getFolder,
+    updateFolder,
+    deleteFolder,
+    getFolderChildren,
+    getDocumentsInFolder,
+    createDocument,
+    getDocument,
+    updateDocument,
+    deleteDocument,
+    addShare,
+    getSharesForResource,
+    getSharesForUser,
+    getEffectiveRole,
+    addActivity,
+    getActivityLog,
+  };
+}
+
+export type Store = ReturnType<typeof createStore>;
