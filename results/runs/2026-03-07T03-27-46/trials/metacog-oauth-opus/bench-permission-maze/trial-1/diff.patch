hould reject sharing with invalid resource type', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { userId: bobId } = await createUser('bob', 'pass');\n\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${aliceToken}`)\n      .send({ resourceType: 'invalid', resourceId: 'some-id', userId: bobId, role: 'viewer' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should allow owner to share with owner role', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { userId: bobId } = await createUser('bob', 'pass');\n\n    const folder = await createFolder(aliceToken, 'Folder');\n    const res = await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'owner');\n    expect(res.status).toBe(201);\n  });\n\n  it('should handle document in nested folder with folder-level permissions', async () => {\n    const { token: aliceToken } = await createUser('alice', 'pass');\n    const { token: bobToken, userId: bobId } = await createUser('bob', 'pass');\n\n    const parent = await createFolder(aliceToken, 'Parent');\n    const child = await createFolder(aliceToken, 'Child', parent.body.id);\n    const doc = await createDocument(aliceToken, 'Nested Doc', 'Content', child.body.id);\n\n    // Share parent folder with bob as editor\n    await shareResource(aliceToken, 'folder', parent.body.id, bobId, 'editor');\n\n    // Bob should be able to edit the nested doc (inherits from parent -> child -> doc)\n    const res = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bobToken}`)\n      .send({ content: 'Updated by Bob' });\n    expect(res.status).toBe(200);\n    expect(res.body.content).toBe('Updated by Bob');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":105,"cache_read_input_tokens":29646,"cache_crea