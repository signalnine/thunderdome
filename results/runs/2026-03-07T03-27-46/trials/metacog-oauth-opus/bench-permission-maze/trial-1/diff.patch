+import { Router, Request, Response } from 'express';
+import { Store } from '../store.js';
+import { authMiddleware } from '../middleware.js';
+
+export function activityRouter(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  router.get('/', (_req: Request, res: Response): void => {
+    const log = store.getActivityLog();
+    res.json(log);
+  });
+
+  return router;
+}
diff --git a/src/routes/auth.ts b/src/routes/auth.ts
new file mode 100644
index 0000000..227da51
--- /dev/null
+++ b/src/routes/auth.ts
@@ -0,0 +1,43 @@
+import { Router, Request, Response } from 'express';
+import { Store } from '../store.js';
+
+export function authRouter(store: Store): Router {
+  const router = Router();
+
+  // Register
+  router.post('/register', (req: Request, res: Response): void => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+    if (typeof username !== 'string' || typeof password !== 'string') {
+      res.status(400).json({ error: 'Username and password must be strings' });
+      return;
+    }
+    if (store.findUserByUsername(username)) {
+      res.status(409).json({ error: 'Username already taken' });
+      return;
+    }
+    const user = store.createUser(username, password);
+    res.status(201).json({ id: user.id, username: user.username });
+  });
+
+  // Login
+  router.post('/login', (req: Request, res: Response): void => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+    const user = store.findUserByUsername(username);
+    if (!user || user.password !== password) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+    const token = store.generateToken(user.id);
+    res.json({ token, userId: user.id });
+  });
+
+  return router;
+}
diff --git a/src/routes/documents.ts b/src/routes/documents.ts
new file mode 100644
index 0000000..71562f1
--- /dev/null
+++ b/src/routes/documents.ts
@@ -0,0 +1,107 @@
+import { Router, Request, Response } from 'express';
+import { Store } from '../store.js';
+import { authMiddleware } from '../middleware.js';
+
+export function documentsRouter(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Create document
+  router.post('/', (req: Request, res: Response): void => {
+    const user = req.user!;
+    const { title, content, folderId } = req.body;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+    if (!folderId || typeof folderId !== 'string') {
+      res.status(400).json({ error: 'Folder ID is required' });
+      return;
+    }
+
+    const folder = store.getFolder(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = store.getEffectiveRole(user.id, 'folder', folderId);
+    if (!role || role === 'viewer') {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const doc = store.createDocument(title, content, folderId, user.id);
+    store.addActivity('document_created', user.id, 'document', doc.id);
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', (req: Request, res: Response): void => {
+    const user = req.user!;
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = store.getEffectiveRole(user.id, 'document', doc.id);
+    if (!role) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/:id', (req: Request, res: Response): void => {
+    const user = req.user!;
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = store.getEffectiveRole(user.id, 'document', doc.id);
+    if (!role || role === 'viewer') {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const updates: Partial<{ title: string; content: string }> = {};
+    if (req.body.title !== undefined) updates.title = req.body.title;
+    if (req.body.content !== undefined) updates.content = req.body.content;
+
+    const updated = store.updateDocument(doc.id, updates);
+    store.addActivity('document_updated', user.id, 'document', doc.id);
+    res.json(updated);
+  });
+
+  // Delete document
+  router.delete('/:id', (req: Request, res: Response): void => {
+    const user = req.user!;
+    const doc = store.getDocument(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = store.getEffectiveRole(user.id, 'document', doc.id);
+    if (role !== 'owner') {
+      res.status(403).json({ error: 'Only owners can delete documents' });
+      return;
+    }
+
+    store.deleteDocument(doc.id);
+    store.addActivity('document_deleted', user.id, 'document', doc.id);
+    res.status(204).send();
+  });
+
+  return router;
+}
