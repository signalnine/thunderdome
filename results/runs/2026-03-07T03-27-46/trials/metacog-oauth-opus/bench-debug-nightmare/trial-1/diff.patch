 o.status === status)\n      .map((o) => ({ ...o }));\n  }\n\n  clear(): void {\n    this.store.clear();\n  }\n}\n","structuredPatch":[{"oldStart":35,"oldLines":7,"newStart":35,"newLines":7,"lines":["   update(id: string, updates: Partial<Order>): Order | undefined {","     const existing = this.store.get(id);","     if (!existing) return undefined;","-    const updated = { ...updates, id, updatedAt: Date.now() } as Order;","+    const updated = { ...existing, ...updates, id, updatedAt: Date.now() };","     this.store.set(id, updated);","     return { ...updated };","   }"]}],"userModified":false,"replaceAll":false}}
