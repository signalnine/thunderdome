+import { describe, it, expect } from 'vitest';
+import { apply, transform, compose, validate, baseLength, targetLength, Operation } from '../src/ot.js';
+
+describe('OT Engine', () => {
+  describe('apply', () => {
+    it('should apply retain operation (identity)', () => {
+      expect(apply('hello', [5])).toBe('hello');
+    });
+
+    it('should apply insert at beginning', () => {
+      expect(apply('world', ['hello ', 5])).toBe('hello world');
+    });
+
+    it('should apply insert at end', () => {
+      expect(apply('hello', [5, ' world'])).toBe('hello world');
+    });
+
+    it('should apply insert in middle', () => {
+      expect(apply('hllo', [1, 'e', 3])).toBe('hello');
+    });
+
+    it('should apply delete', () => {
+      expect(apply('hello world', [5, -6])).toBe('hello');
+    });
+
+    it('should apply delete at beginning', () => {
+      expect(apply('hello world', [-6, 5])).toBe('world');
+    });
+
+    it('should apply combined operations', () => {
+      // retain 5 ("hello"), delete 1 (" "), insert " beautiful", retain 5 ("world")
+      expect(apply('hello world', [5, -1, ' beautiful', 5])).toBe('hello beautifulworld');
+    });
+
+    it('should apply insert in middle of text', () => {
+      expect(apply('hello world', [6, 'beautiful ', 5])).toBe('hello beautiful world');
+    });
+
+    it('should apply to empty document', () => {
+      expect(apply('', ['hello'])).toBe('hello');
+    });
+
+    it('should throw on mismatched length', () => {
+      expect(() => apply('hello', [10])).toThrow();
+    });
+  });
+
+  describe('transform', () => {
+    it('should transform two inserts at different positions', () => {
+      // Doc: "hello"
+      // A inserts " world" at end: [5, " world"]
+      // B inserts "say " at beginning: ["say ", 5]
+      const a: Operation = [5, ' world'];
+      const b: Operation = ['say ', 5];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const docA = apply('hello', a);       // "hello world"
+      const docB = apply('hello', b);       // "say hello"
+      const resultAB = apply(docA, bPrime); // apply B' to "hello world"
+      const resultBA = apply(docB, aPrime); // apply A' to "say hello"
+      expect(resultAB).toBe(resultBA);
+    });
+
+    it('should transform two inserts at same position', () => {
+      // Doc: "hello"
+      // Both insert at position 5
+      const a: Operation = [5, ' world'];
+      const b: Operation = [5, '!'];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const docA = apply('hello', a);
+      const docB = apply('hello', b);
+      const resultAB = apply(docA, bPrime);
+      const resultBA = apply(docB, aPrime);
+      expect(resultAB).toBe(resultBA);
+    });
+
+    it('should transform insert and delete', () => {
+      // Doc: "hello world"
+      // A inserts "beautiful " at position 6: [6, "beautiful ", 5]
+      // B deletes "world": [6, -5]
+      const a: Operation = [6, 'beautiful ', 5];
+      const b: Operation = [6, -5];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const docA = apply('hello world', a);
+      const docB = apply('hello world', b);
+      const resultAB = apply(docA, bPrime);
+      const resultBA = apply(docB, aPrime);
+      expect(resultAB).toBe(resultBA);
+    });
+
+    it('should transform two deletes at same position', () => {
+      // Doc: "hello world"
+      // Both delete "world"
+      const a: Operation = [6, -5];
+      const b: Operation = [6, -5];
+      const [aPrime, bPrime] = transform(a, b);
+
+      const docA = apply('hello world', a); // "hello "
+      const docB = apply('hello world', b); // "hello "
+      const resultAB = apply(docA, bPrime);
+      const resultBA = apply(docB, aPrime);
+      expect(resultAB).toBe(resultBA);
+      expect(resultAB).toBe('hello ');
+    });
+
+    it('should preserve both insertions', () => {
+      const a: Operation = [3, 'X', 2];     // Insert X at pos 3 in "hello"
+      const b: Operation = [1, 'Y', 4];     // Insert Y at pos 1 in "hello"
+      const [aPrime, bPrime] = transform(a, b);
+      const resultAB = apply(apply('hello', a), bPrime);
+      const resultBA = apply(apply('hello', b), aPrime);
+      expect(resultAB).toBe(resultBA);
+      // Both X and Y should be present
+      expect(resultAB).toContain('X');
+      expect(resultAB).toContain('Y');
+    });
+
+    it('should throw on mismatched base lengths', () => {
+      expect(() => transform([5], [3])).toThrow();
+    });
+  });
+
+  describe('compose', () => {
+    it('should compose two sequential operations', () => {
+      const a: Operation = [5, ' world'];       // "hello" -> "hello world"
+      const b: Operation = [11, '!'];           // "hello world" -> "hello world!"
+      const composed = compose(a, b);
+      expect(apply('hello', composed)).toBe('hello world!');
+    });
+
+    it('should compose insert then delete', () => {
+      const a: Operation = ['X', 5];           // "hello" -> "Xhello"
+      const b: Operation = [-1, 5];            // "Xhello" -> "hello"
+      const composed = compose(a, b);
+      expect(apply('hello', composed)).toBe('hello');
+    });
+  });
+
+  describe('validate', () => {
+    it('should return null for valid operation', () => {
+      expect(validate([5, ' world'], 5)).toBeNull();
+    });
+
+    it('should reject non-array', () => {
+      expect(validate('not an array' as unknown as Operation, 5)).toBeTruthy();
+    });
+
+    it('should reject zero numeric component', () => {
+      expect(validate([0, 5], 5)).toBeTruthy();
+    });
+
+    it('should reject empty string component', () => {
+      expect(validate(['', 5], 5)).toBeTruthy();
+    });
+
+    it('should reject mismatched base length', () => {
+      expect(validate([10], 5)).toBeTruthy();
+    });
+  });
+
+  describe('baseLength and targetLength', () => {
+    it('should compute correct base and target lengths', () => {
+      const op: Operation = [3, 'abc', -2, 5]; // retain 3, insert "abc", delete 2, retain 5
+      expect(baseLength(op)).toBe(10); // 3 + 2 + 5
+      expect(targetLength(op)).toBe(11); // 3 + 3 + 5
+    });
+  });
+});
