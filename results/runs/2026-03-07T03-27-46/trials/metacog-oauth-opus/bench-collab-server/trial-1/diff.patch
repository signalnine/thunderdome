@@ -0,0 +1,411 @@
+/**
+ * Operational Transformation engine for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert the string
+ * - number < 0: delete |N| characters
+ *
+ * The "base length" of an operation is the length of the document it applies to.
+ * The "target length" is the length of the document after applying it.
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface OperationMessage {
+  type: 'operation';
+  docId: string;
+  clientId: string;
+  revision: number; // the version the client had when it generated this op
+  operation: Operation;
+}
+
+export interface SyncMessage {
+  type: 'sync';
+  docId: string;
+  content: string;
+  revision: number;
+}
+
+export interface AckMessage {
+  type: 'ack';
+  revision: number;
+}
+
+export interface ErrorMessage {
+  type: 'error';
+  message: string;
+}
+
+export interface BroadcastMessage {
+  type: 'operation';
+  clientId: string;
+  revision: number;
+  operation: Operation;
+}
+
+export type ServerMessage = SyncMessage | AckMessage | ErrorMessage | BroadcastMessage;
+export type ClientMessage = OperationMessage;
+
+/** Compute the base length (input document length) of an operation */
+export function baseLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;
+      else len += Math.abs(c);
+    }
+    // inserts don't consume input characters
+  }
+  return len;
+}
+
+/** Compute the target length (output document length) of an operation */
+export function targetLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;
+      // deletes don't produce output characters
+    } else {
+      len += c.length;
+    }
+  }
+  return len;
+}
+
+/** Apply an operation to a document string */
+export function apply(doc: string, op: Operation): string {
+  const bl = baseLength(op);
+  if (bl !== doc.length) {
+    throw new Error(
+      `Operation base length (${bl}) does not match document length (${doc.length})`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) {
+        // retain
+        result += doc.slice(pos, pos + c);
+        pos += c;
+      } else {
+        // delete
+        pos += Math.abs(c);
+      }
+    } else {
+      // insert
+      result += c;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Transform two concurrent operations so they can be applied in sequence.
+ * Given operations A and B that both apply to the same document state,
+ * returns [A', B'] such that apply(apply(doc, A), B') === apply(apply(doc, B), A')
+ */
+export function transform(
+  op1: Operation,
+  op2: Operation
+): [Operation, Operation] {
+  if (baseLength(op1) !== baseLength(op2)) {
+    throw new Error(
+      `Operations have different base lengths: ${baseLength(op1)} vs ${baseLength(op2)}`
+    );
+  }
+
+  const op1Prime: Operation = [];
+  const op2Prime: Operation = [];
+
+  let i = 0;
+  let j = 0;
+  // Remaining portion of current component being processed
+  let c1: OpComponent | null = op1[i] ?? null;
+  let c2: OpComponent | null = op2[j] ?? null;
+
+  while (c1 !== null || c2 !== null) {
+    // If op1 has an insert, it goes first in both primes
+    if (typeof c1 === 'string') {
+      op1Prime.push(c1);
+      op2Prime.push(c1.length); // op2' must retain over op1's insert
+      i++;
+      c1 = op1[i] ?? null;
+      continue;
+    }
+
+    // If op2 has an insert, it goes first in both primes
+    if (typeof c2 === 'string') {
+      op2Prime.push(c2);
+      op1Prime.push(c2.length); // op1' must retain over op2's insert
+      j++;
+      c2 = op2[j] ?? null;
+      continue;
+    }
+
+    // Both are numbers (retain or delete) or we're done
+    if (c1 === null || c2 === null) {
+      throw new Error('Operation length mismatch during transform');
+    }
+
+    const n1 = c1 as number;
+    const n2 = c2 as number;
+    const abs1 = Math.abs(n1);
+    const abs2 = Math.abs(n2);
+
+    if (n1 > 0 && n2 > 0) {
+      // Both retain
+      const min = Math.min(abs1, abs2);
+      op1Prime.push(min);
+      op2Prime.push(min);
+      if (abs1 === abs2) {
+        i++; j++;
+        c1 = op1[i] ?? null;
+        c2 = op2[j] ?? null;
+      } else if (abs1 < abs2) {
+        i++;
+        c1 = op1[i] ?? null;
+        c2 = n2 - abs1;
+      } else {
+        j++;
+        c1 = n1 - abs2;
+        c2 = op2[j] ?? null;
+      }
+    } else if (n1 < 0 && n2 < 0) {
+      // Both delete the same region
+      const min = Math.min(abs1, abs2);
+      // Neither prime needs anything - both deleted the same characters
+      if (abs1 === abs2) {
+        i++; j++;
+        c1 = op1[i] ?? null;
+        c2 = op2[j] ?? null;
+      } else if (abs1 < abs2) {
+        i++;
+        c1 = op1[i] ?? null;
+        c2 = -(abs2 - min);
+      } else {
+        j++;
+        c1 = -(abs1 - min);
+        c2 = op2[j] ?? null;
+      }
+    } else if (n1 < 0 && n2 > 0) {
+      // op1 deletes, op2 retains
+      const min = Math.min(abs1, abs2);
+      op1Prime.push(-min); // op1' still deletes
+      // op2' doesn't retain (those chars are deleted by op1)
+      if (abs1 === abs2) {
+        i++; j++;
+        c1 = op1[i] ?? null;
+        c2 = op2[j] ?? null;
+      } else if (abs1 < abs2) {
+        i++;
+        c1 = op1[i] ?? null;
+        c2 = n2 - abs1;
+      } else {
+        j++;
+        c1 = -(abs1 - abs2);
+        c2 = op2[j] ?? null;
+      }
+    } else if (n1 > 0 && n2 < 0) {
+      // op1 retains, op2 deletes
+      const min = Math.min(abs1, abs2);
+      op2Prime.push(-min); // op2' still deletes
+      // op1' doesn't retain (those chars are deleted by op2)
+      if (abs1 === abs2) {
+        i++; j++;
+        c1 = op1[i] ?? null;
+        c2 = op2[j] ?? null;
+      } else if (abs1 < abs2) {
+        i++;
+        c1 = op1[i] ?? null;
+        c2 = -(abs2 - abs1);
+      } else {
+        j++;
+        c1 = n1 - abs2;
+        c2 = op2[j] ?? null;
+      }
+    }
+  }
+
+  return [compact(op1Prime), compact(op2Prime)];
+}
+
+/** Remove no-ops and merge adjacent components of the same type */
+function compact(op: Operation): Operation {
+  const result: Operation = [];
+
+  for (const c of op) {
+    if (typeof c === 'number' && c === 0) continue;
+    if (typeof c === 'string' && c === '') continue;
+
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+
+    const last = result[result.length - 1];
+
+    if (typeof c === 'string' && typeof last === 'string') {
+      result[result.length - 1] = last + c;
+    } else if (typeof c === 'number' && typeof last === 'number') {
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = last + c;
+      } else {
+        result.push(c);
+      }
+    } else {
+      result.push(c);
+    }
+  }
+
+  return result;
+}
+
+/** Compose two sequential operations into one */
+export function compose(op1: Operation, op2: Operation): Operation {
+  if (targetLength(op1) !== baseLength(op2)) {
+    throw new Error('Operations are not composable');
+  }
+
+  const result: Operation = [];
+  let i = 0;
+  let j = 0;
+  let c1: OpComponent | null = op1[i] ?? null;
+  let c2: OpComponent | null = op2[j] ?? null;
+
+  while (c1 !== null || c2 !== null) {
+    // Delete from op1 goes straight through
+    if (typeof c1 === 'number' && c1 < 0) {
+      result.push(c1);
+      i++;
+      c1 = op1[i] ?? null;
+      continue;
+    }
+
+    // Insert from op2 goes straight through
+    if (typeof c2 === 'string') {
+      result.push(c2);
+      j++;
+      c2 = op2[j] ?? null;
+      continue;
+    }
+
+    if (c1 === null || c2 === null) {
+      throw new Error('Compose length mismatch');
+    }
+
+    if (typeof c1 === 'number' && c1 > 0 && typeof c2 === 'number' && c2 > 0) {
+      // Both retain
+      const r1: number = c1;
+      const r2: number = c2;
+      const min = Math.min(r1, r2);
+      result.push(min);
+      if (r1 === r2) {
+        i++; j++;
+        c1 = op1[i] ?? null;
+        c2 = op2[j] ?? null;
+      } else if (r1 < r2) {
+        i++;
+        c1 = op1[i] ?? null;
+        c2 = r2 - r1;
+      } else {
+        j++;
+        c1 = r1 - r2;
+        c2 = op2[j] ?? null;
+      }
+    } else if (typeof c1 === 'string' && typeof c2 === 'number' && c2 > 0) {
+      // op1 inserts, op2 retains
+      const s1: string = c1;
+      const r2: number = c2;
+      const sLen = s1.length;
+      const min = Math.min(sLen, r2);
+      result.push(s1.slice(0, min));
+      if (sLen === r2) {
+        i++; j++;
+        c1 = op1[i] ?? null;
+        c2 = op2[j] ?? null;
+      } else if (sLen < r2) {
+        i++;
+        c1 = op1[i] ?? null;
+        c2 = r2 - sLen;
+      } else {
+        j++;
+        c1 = s1.slice(r2);
+        c2 = op2[j] ?? null;
+      }
+    } else if (typeof c1 === 'number' && c1 > 0 && typeof c2 === 'number' && c2 < 0) {
+      // op1 retains, op2 deletes
+      const r1: number = c1;
+      const d2: number = c2;
+      const abs2 = Math.abs(d2);
+      const min = Math.min(r1, abs2);
+      result.push(-min);
+      if (r1 === abs2) {
+        i++; j++;
+        c1 = op1[i] ?? null;
+        c2 = op2[j] ?? null;
+      } else if (r1 < abs2) {
+        i++;
+        c1 = op1[i] ?? null;
+        c2 = d2 + r1; // d2 is negative, adding positive makes it less negative
+      } else {
+        j++;
+        c1 = r1 - abs2;
+        c2 = op2[j] ?? null;
+      }
+    } else if (typeof c1 === 'string' && typeof c2 === 'number' && c2 < 0) {
+      // op1 inserts, op2 deletes what was inserted
+      const s1: string = c1;
+      const d2: number = c2;
+      const sLen = s1.length;
+      const abs2 = Math.abs(d2);
+      if (sLen === abs2) {
+        i++; j++;
+        c1 = op1[i] ?? null;
+        c2 = op2[j] ?? null;
+      } else if (sLen < abs2) {
+        i++;
+        c1 = op1[i] ?? null;
+        c2 = d2 + sLen;
+      } else {
+        j++;
+        c1 = s1.slice(abs2);
+        c2 = op2[j] ?? null;
+      }
+    }
+  }
+
+  return compact(result);
+}
+
+/** Validate that an operation is well-formed and applicable to a document of given length */
+export function validate(op: Operation, docLength: number): string | null {
+  if (!Array.isArray(op)) {
+    return 'Operation must be an array';
+  }
+
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (!Number.isInteger(c) || c === 0) {
+        return 'Numeric components must be non-zero integers';
+      }
+    } else if (typeof c !== 'string') {
+      return 'Components must be numbers or strings';
+    } else if (c === '') {
+      return 'String components must be non-empty';
+    }
+  }
+
+  const bl = baseLength(op);
+  if (bl !== docLength) {
+    return `Operation base length (${bl}) does not match document length (${docLength})`;
+  }
+
+  return null;
+}
