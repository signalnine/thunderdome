+describe('Concurrent Clients', () => {
+  it('should handle 10 concurrent clients without corruption', async () => {
+    server = createApp();
+    port = await server.start(0);
+
+    try {
+      const createRes = await request(server.app)
+        .post('/api/documents')
+        .send({ title: 'Stress Test', content: '' });
+
+      const docId = createRes.body.id;
+      const numClients = 10;
+      const clients: { ws: WebSocket; messages: unknown[] }[] = [];
+
+      // Connect all clients
+      for (let i = 0; i < numClients; i++) {
+        const client = await createWsClient(docId);
+        clients.push(client);
+      }
+
+      // Each client sends an insert operation sequentially
+      // (since they need to track revisions correctly)
+      let currentRevision = 1;
+      let expectedContent = '';
+
+      for (let i = 0; i < numClients; i++) {
+        const text = `c${i}`;
+        const contentLen = expectedContent.length;
+        const op: Operation = contentLen > 0 ? [contentLen, text] : [text];
+
+        clients[i].ws.send(JSON.stringify({
+          type: 'operation',
+          docId,
+          revision: currentRevision,
+          operation: op,
+        }));
+
+        // Wait for ack
+        const ackIdx = clients[i].messages.length;
+        await waitForMessage(clients[i].messages, ackIdx + 1, 3000);
+
+        const ack = clients[i].messages[ackIdx] as { type: string; revision: number };
+        expect(ack.type).toBe('ack');
+        currentRevision = ack.revision;
+        expectedContent += text;
+      }
+
+      // Verify final state
+      const docRes = await request(server.app)
+        .get(`/api/documents/${docId}`)
+        .expect(200);
+
+      expect(docRes.body.content).toBe(expectedContent);
+
+      // All clients should have received all the data
+      for (const client of clients) {
+        client.ws.close();
+      }
+    } finally {
+      await server.stop();
+    }
+  });
