+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01L8Jf8cVeWzrpbKXmYw8xrR","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Kjab8H6HFUK5Y5bPKjWNwa","name":"Write","input":{"file_path":"/workspace/src/websocket.ts","content":"import { WebSocketServer, WebSocket } from 'ws';\nimport { IncomingMessage } from 'http';\nimport { Server } from 'http';\nimport { randomUUID } from 'crypto';\nimport { DocumentDatabase } from './database.js';\nimport {\n  Operation,\n  ServerMessage,\n  apply,\n  transform,\n  validate,\n} from './ot.js';\n\ninterface ClientConnection {\n  ws: WebSocket;\n  clientId: string;\n  docId: string;\n}\n\ninterface DocumentState {\n  clients: Map<string, ClientConnection>;\n  /** Server-side operation log: operations applied since version 1 */\n  history: Operation[];\n}\n\nexport class CollaborationServer {\n  private wss: WebSocketServer;\n  private documents: Map<string, DocumentState> = new Map();\n  private db: DocumentDatabase;\n\n  constructor(server: Server, db: DocumentDatabase) {\n    this.db = db;\n    this.wss = new WebSocketServer({ server });\n    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n      this.handleConnection(ws, req);\n    });\n  }\n\n  private getDocIdFromUrl(url: string | undefined): string | null {\n    if (!url) return null;\n    // Expected format: /documents/:id or /ws/documents/:id\n    const match = url.match(/\\/documents\\/([^/?]+)/);\n    return match ? match[1] : null;\n  }\n\n  private getOrCreateDocState(docId: string): DocumentState {\n    let state = this.documents.get(docId);\n    if (!state) {\n      // Load history from database\n      const versions = this.db.getVersions(docId);\n      const history: Operation[] = [];\n      for (const v of versions) {\n        if (v.operation) {\n          try {\n            history.push(JSON.parse(v.operation));\n          } catch {\n            // skip invalid operations\n          }\n        }\n      }\n      state = { clients: new Map(), history };\n      this.documents.set(docId, state);\n    }\n    return state;\n  }\n\n  private handleConnection(ws: WebSocket, req: IncomingMessage): void {\n    const docId = this.getDocIdFromUrl(req.url);\n    if (!docId) {\n      this.sendMessage(ws, { type: 'error', message: 'No document ID in URL' });\n      ws.close();\n      return;\n    }\n\n    const doc = this.db.getDocument(docId);\n    if (!doc) {\n      this.sendMessage(ws, { type: 'error', message: 'Document not found' });\n      ws.close();\n      return;\n    }\n\n    const clientId = randomUUID();\n    const state = this.getOrCreateDocState(docId);\n    const conn: ClientConnection = { ws, clientId, docId };\n    state.clients.set(clientId, conn);\n\n    // Track connection in DB\n    this.db.addConnection(clientId, docId);\n\n    const revision = this.db.getLatestVersion(docId);\n\n    // Send sync message with current document state\n    this.sendMessage(ws, {\n      type: 'sync',\n      docId,\n      content: doc.content,\n      revision,\n    });\n\n    ws.on('message', (data: Buffer | string) => {\n      this.handleMessage(conn, data);\n    });\n\n    ws.on('close', () => {\n      state.clients.delete(clientId);\n      this.db.removeConnection(clientId);\n      if (state.clients.size === 0) {\n        this.documents.delete(docId);\n      }\n    });\n\n    ws.on('error', () => {\n      state.clients.delete(clientId);\n      this.db.removeConnection(clientId);\n    });\n  }\n\n  private handleMessage(conn: ClientConnection, raw: Buffer | string): void {\n    let msg;\n    try {\n      msg = JSON.parse(typeof raw === 'string' ? raw : raw.toString());\n    } catch {\n      this.sendMessage(conn.ws, { type: 'error', message: 'Invalid JSON' });\n      return;\n    }\n\n    if (msg.type !== 'operation') {\n      this.sendMessage(conn.ws, { type: 'error', message: `Unknown message type: ${msg.type}` });\n      return;\n    }\n\n    const { operation, revision } = msg;\n\n    if (!Array.isArray(operation)) {\n      this.sendMessage(conn.ws, { type: 'error', message: 'Operation must be an array' });\n      return;\n    }\n\n    if (typeof revision !== 'number' || revision < 0) {\n      this.sendMessage(conn.ws, { type: 'error', message: 'Invalid revision number' });\n      return;\n    }\n\n    this.applyOperation(conn, operation, revision);\n  }\n\n  private applyOperation(\n    conn: ClientConnection,\n    operation: Operation,\n    clientRevision: number\n  ): void {\n    const doc = this.db.getDocument(conn.docId);\n    if (!doc) {\n      this.sendMessage(conn.ws, { type: 'error', message: 'Document not found' });\n      return;\n    }\n\n    const state = this.getOrCreateDocState(conn.docId);\n    const serverRevision = this.db.getLatestVersion(conn.docId);\n\n    // The client's revision tells us which version they started from.\n    // We need to transform the operation against all operations that\n    // happened between clientRevision and serverRevision.\n    if (clientRevision < 0 || clientRevision > serverRevision) {\n      this.sendMessage(conn.ws, {\n        type: 'error',\n        message: `Invalid revision: client=${clientRevision}, server=${serverRevision}`,\n      });\n      return;\n    }\n\n    let transformedOp = operation;\n\n    // Transform against operations that happened since the client's revision\n    if (clientRevision < serverRevision) {\n      // Get versions from clientRevision+1 to serverRevision\n      const versions = this.db.getVersions(conn.docId);\n      const concurrentVersions = versions.filter(\n        (v) => v.version > clientRevision && v.version <= serverRevision\n      );\n\n      for (const v of concurrentVersions) {\n        if (!v.operation) continue;\n        let serverOp: Operation;\n        try {\n          serverOp = JSON.parse(v.operation);\n        } catch {\n          continue;\n        }\n\n        // Validate before transforming\n        const validationError = va