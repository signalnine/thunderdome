+// ============================================================================
+// Cell Reference Utilities
+// ============================================================================
+
+function columnToNumber(col: string): number {
+  let result = 0;
+  for (let i = 0; i < col.length; i++) {
+    result = result * 26 + (col.charCodeAt(i) - 64); // A=1, B=2, ...
+  }
+  return result;
+}
+
+function numberToColumn(num: number): string {
+  let result = '';
+  while (num > 0) {
+    num--;
+    result = String.fromCharCode(65 + (num % 26)) + result;
+    num = Math.floor(num / 26);
+  }
+  return result;
+}
+
+function parseRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: columnToNumber(match[1]), row: parseInt(match[2], 10) };
+}
+
+function refToString(col: number, row: number): string {
+  return numberToColumn(col) + row;
+}
+
+function expandRange(startRef: string, endRef: string): string[] {
+  const start = parseRef(startRef);
+  const end = parseRef(endRef);
+  const minCol = Math.min(start.col, end.col);
+  const maxCol = Math.max(start.col, end.col);
+  const minRow = Math.min(start.row, end.row);
+  const maxRow = Math.max(start.row, end.row);
+  const cells: string[] = [];
+  for (let c = minCol; c <= maxCol; c++) {
+    for (let r = minRow; r <= maxRow; r++) {
+      cells.push(refToString(c, r));
+    }
+  }
+  return cells;
+}
+
+// ============================================================================
+// Tokenizer
+// ============================================================================
+
+enum TokenType {
+  Number = 'Number',
+  String = 'String',
+  Boolean = 'Boolean',
+  CellRef = 'CellRef',
+  Function = 'Function',
+  Operator = 'Operator',
+  LParen = 'LParen',
+  RParen = 'RParen',
+  Comma = 'Comma',
+  Colon = 'Colon',
+  EOF = 'EOF',
+}
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+function tokenize(formula: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < formula.length) {
+    const ch = formula[i];
+
+    // Whitespace
+    if (ch === ' ' || ch === '\t') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (ch === '"') {
+      let str = '';
+      i++; // skip opening quote
+      while (i < formula.length && formula[i] !== '"') {
+        str += formula[i];
+        i++;
+      }
+      if (i < formula.length) i++; // skip closing quote
+      tokens.push({ type: TokenType.String, value: str });
+      continue;
+    }
+
+    // Number
+    if ((ch >= '0' && ch <= '9') || (ch === '.' && i + 1 < formula.length && formula[i + 1] >= '0' && formula[i + 1] <= '9')) {
+      let num = '';
+      while (i < formula.length && ((formula[i] >= '0' && formula[i] <= '9') || formula[i] === '.')) {
+        num += formula[i];
+        i++;
+      }
+      tokens.push({ type: TokenType.Number, value: num });
+      continue;
+    }
+
+    // Identifiers: cell refs, function names, booleans
+    if (ch >= 'A' && ch <= 'Z' || ch >= 'a' && ch <= 'z') {
+      let ident = '';
+      while (i < formula.length && ((formula[i] >= 'A' && formula[i] <= 'Z') || (formula[i] >= 'a' && formula[i] <= 'z') || (formula[i] >= '0' && formula[i] <= '9'))) {
+        ident += formula[i];
+        i++;
+      }
+
+      const upper = ident.toUpperCase();
+
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: TokenType.Boolean, value: upper === 'TRUE' ? 'true' : 'false' });
+      } else if (i < formula.length && formula[i] === '(') {
+        // Check if it's a function name vs cell ref followed by '('
+        // Known functions
+        const funcs = ['SUM', 'AVERAGE', 'MIN', 'MAX', 'COUNT', 'IF'];
+        if (funcs.includes(upper)) {
+          tokens.push({ type: TokenType.Function, value: upper });
+        } else {
+          // Treat as cell ref
+          tokens.push({ type: TokenType.CellRef, value: upper });
+        }
+      } else {
+        // Check if it looks like a cell ref (letters followed by digits)
+        const cellMatch = upper.match(/^([A-Z]+)(\d+)$/);
+        if (cellMatch) {
+          tokens.push({ type: TokenType.CellRef, value: upper });
+        } else {
+          // Unknown identifier, treat as cell ref anyway
+          tokens.push({ type: TokenType.CellRef, value: upper });
+        }
+      }
+      continue;
+    }
+
+    // Multi-char operators
+    if (ch === '<') {
+      if (i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push({ type: TokenType.Operator, value: '<=' });
+        i += 2;
+        continue;
+      }
+      if (i + 1 < formula.length && formula[i + 1] === '>') {
+        tokens.push({ type: TokenType.Operator, value: '<>' });
+        i += 2;
+        continue;
+      }
+      tokens.push({ type: TokenType.Operator, value: '<' });
+      i++;
+      continue;
+    }
+
+    if (ch === '>') {
+      if (i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push({ type: TokenType.Operator, value: '>=' });
+        i += 2;
+        continue;
+      }
+      tokens.push({ type: TokenType.Operator, value: '>' });
+      i++;
+      continue;
+    }
+
+    if (ch === '=') {
+      tokens.push({ type: TokenType.Operator, value: '=' });
+      i++;
+      continue;
+    }
+
+    if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {
+      tokens.push({ type: TokenType.Operator, value: ch });
+      i++;
+      continue;
+    }
+
+    if (ch === '(') {
+      tokens.push({ type: TokenType.LParen, value: '(' });
+      i++;
+      continue;
+    }
+
+    if (ch === ')') {
+      tokens.push({ type: TokenType.RParen, value: ')' });
+      i++;
+      continue;
+    }
+
+    if (ch === ',') {
+      tokens.push({ type: TokenType.Comma, value: ',' });
+      i++;
+      continue;
+    }
+
+    if (ch === ':') {
+      tokens.push({ type: TokenType.Colon, value: ':' });
+      i++;
+      continue;
+    }
+
+    throw new Error(`Unexpected character: ${ch}`);
+  }
+
+  tokens.push({ type: TokenType.EOF, value: '' });
+  return tokens;
+}
+
+// ============================================================================
+// AST
+// ============================================================================
+
+type ASTNode =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'cellref'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'binop'; op: string; left: ASTNode; right: ASTNode }
+  | { type: 'unary'; op: string; operand: ASTNode }
+  | { type: 'function'; name: string; args: ASTNode[] };
+
+// ============================================================================
+// Parser (recursive descent)
+// ============================================================================
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token {
+    return this.tokens[this.pos];
+  }
+
+  private consume(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  private expect(type: TokenType): Token {
+    const tok = this.consume();
+    if (tok.type !== type) {
+      throw new Error(`Expected ${type} but got ${tok.type} (${tok.value})`);
+    }
+    return tok;
+  }
+
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    if (this.peek().type !== TokenType.EOF) {
+      throw new Error(`Unexpected token: ${this.peek().value}`);
+    }
+    return node;
+  }
+
+  private parseComparison(): ASTNode {
+    let left = this.parseAddSub();
+    const compOps = ['>', '<', '>=', '<=', '=', '<>'];
+    while (this.peek().type === TokenType.Operator && compOps.includes(this.peek().value)) {
+      const op = this.consume().value;
+      const right = this.parseAddSub();
+      left = { type: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  private parseAddSub(): ASTNode {
+    let left = this.parseMulDiv();
+    while (this.peek().type === TokenType.Operator && (this.peek().value === '+' || this.peek().value === '-')) {
+      const op = this.consume().value;
+      const right = this.parseMulDiv();
+      left = { type: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  private parseMulDiv(): ASTNode {
+    let left = this.parseUnary();
+    while (this.peek().type === TokenType.Operator && (this.peek().value === '*' || this.peek().value === '/')) {
+      const op = this.consume().value;
+      const right = this.parseUnary();
+      left = { type: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    if (this.peek().type === TokenType.Operator && this.peek().value === '-') {
+      this.consume();
+      const operand = this.parseUnary();
+      return { type: 'unary', op: '-', operand };
+    }
+    if (this.peek().type === TokenType.Operator && this.peek().value === '+') {
+      this.consume();
+      return this.parseUnary();
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const tok = this.peek();
+
+    if (tok.type === TokenType.Number) {
+      this.consume();
+      return { type: 'number', value: parseFloat(tok.value) };
+    }
+
+    if (tok.type === TokenType.String) {
+      this.consume();
+      return { type: 'string', value: tok.value };
+    }
+
+    if (tok.type === TokenType.Boolean) {
+      this.consume();
+      return { type: 'boolean', value: tok.value === 'true' };
+    }
+
+    if (tok.type === TokenType.Function) {
+      const name = this.consume().value;
+      this.expect(TokenType.LParen);
+      const args: ASTNode[] = [];
+      if (this.peek().type !== TokenType.RParen) {
+        args.push(this.parseArg());
+        while (this.peek().type === TokenType.Comma) {
+          this.consume();
+          args.push(this.parseArg());
+        }
+      }
+      this.expect(TokenType.RParen);
+      return { type: 'function', name, args };
+    }
+
+    if (tok.type === TokenType.CellRef) {
+      const ref = this.consume().value;
+      // Check for range
+      if (this.peek().type === TokenType.Colon) {
+        this.consume();
+        const endRef = this.expect(TokenType.CellRef).value;
+        return { type: 'range', start: ref, end: endRef };
+      }
+      return { type: 'cellref', ref };
+    }
+
+    if (tok.type === TokenType.LParen) {
+      this.consume();
+      const node = this.parseComparison();
+      this.expect(TokenType.RParen);
+      return node;
+    }
+
+    throw new Error(`Unexpected token: ${tok.type} (${tok.value})`);
+  }
+
+  private parseArg(): ASTNode {
+    // An argument can be a range or an expression
+    return this.parseComparison();
+  }
+}
+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+// ============================================================================
+// Dependency extraction
+// ============================================================================
+
+function extractDependencies(node: ASTNode): Set<string> {
+  const deps = new Set<string>();
+
+  function walk(n: ASTNode): void {
+    switch (n.type) {
+      case 'cellref':
+        deps.add(n.ref);
+        break;
+      case 'range': {
+        const cells = expandRange(n.start, n.end);
+        for (const c of cells) deps.add(c);
+        break;
+      }
+      case 'binop':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'unary':
+        walk(n.operand);
+        break;
+      case 'function':
+        for (const arg of n.args) walk(arg);
+        break;
+      // number, string, boolean: no deps
+    }
+  }
+
+  walk(node);
+  return deps;
+}
+
+// ============================================================================
+// Cell types
+// ============================================================================
+
+type CellValue = string | number | boolean | null;
+
+interface CellData {
+  rawValue: string | number | boolean;
+  formula: ASTNode | null;
+  computed: CellValue;
+  dependencies: Set<string>; // cells this cell depends on
+}
+
+// ============================================================================
+// Spreadsheet
+// ============================================================================
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  private dependents: Map<string, Set<string>> = new Map(); // reverse graph: cell -> cells that depend on it
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+    const oldData = this.cells.get(ref);
+
+    // Remove old reverse dependencies
+    if (oldData) {
+      for (const dep of oldData.dependencies) {
+        const depSet = this.dependents.get(dep);
+        if (depSet) {
+          depSet.delete(ref);
+        }
+      }
+    }
+
+    let formula: ASTNode | null = null;
+    let dependencies = new Set<string>();
+    let computed: CellValue;
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaStr = value.substring(1);
+      formula = parseFormula(formulaStr);
+      dependencies = extractDependencies(formula);
+
+      // Check for circular reference before committing
+      this.checkCircular(ref, dependencies);
+
+      // Register reverse dependencies
+      for (const dep of dependencies) {
+        if (!this.dependents.has(dep)) {
+          this.dependents.set(dep, new Set());
+        }
+        this.dependents.get(dep)!.add(ref);
+      }
+
+      computed = this.evaluate(formula);
+    } else {
+      computed = value;
+    }
+
+    this.cells.set(ref, {
+      rawValue: value,
+      formula,
+      computed,
+      dependencies,
+    });
+
+    // Reactively update all downstream dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = cell.toUpperCase();
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computed;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computed);
+    }
+    return result;
+  }
+
+  // --------------------------------------------------------------------------
+  // Circular reference detection
+  // --------------------------------------------------------------------------
+
+  private checkCircular(cell: string, newDeps: Set<string>): void {
+    // DFS from each dependency to see if we can reach `cell`
+    const visited = new Set<string>();
+
+    const dfs = (current: string): boolean => {
+      if (current === cell) return true;
+      if (visited.has(current)) return false;
+      visited.add(current);
+
+      // Follow the dependencies of `current`
+      const data = this.cells.get(current);
+      if (data) {
+        for (const dep of data.dependencies) {
+          if (dfs(dep)) return true;
+        }
+      }
+      return false;
+    };
+
+    for (const dep of newDeps) {
+      if (dep === cell || dfs(dep)) {
+        throw new Error(`Circular reference detected: ${cell}`);
+      }
+    }
+  }
+
+  // --------------------------------------------------------------------------
+  // Propagation
+  // --------------------------------------------------------------------------
+
+  private propagate(changedCell: string): void {
+    // Topological sort of all transitive dependents, then recompute in order
+    const order = this.topologicalSort(changedCell);
+
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data && data.formula) {
+        data.computed = this.evaluate(data.formula);
+      }
+    }
+  }
+
+  private topologicalSort(startCell: string): string[] {
+    // BFS to find all reachable dependents, then topo-sort them
+    const visited = new Set<string>();
+    const queue: string[] = [startCell];
+    const reachable: string[] = [];
+
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const deps = this.dependents.get(current);
+      if (deps) {
+        for (const dep of deps) {
+          if (!visited.has(dep)) {
+            visited.add(dep);
+            reachable.push(dep);
+            queue.push(dep);
+          }
+        }
+      }
+    }
+
+    // Topo-sort using Kahn's algorithm within the reachable subgraph.
+    // Only count edges between nodes in the reachable set (not from startCell,
+    // which is already updated).
+    if (reachable.length === 0) return [];
+
+    const reachableSet = new Set(reachable);
+
+    const inDegree = new Map<string, number>();
+    for (const r of reachable) inDegree.set(r, 0);
+
+    for (const r of reachable) {
+      const data = this.cells.get(r);
+      if (data) {
+        for (const dep of data.dependencies) {
+          if (reachableSet.has(dep)) {
+            inDegree.set(r, (inDegree.get(r) || 0) + 1);
+          }
+        }
+      }
+    }
+
+    const sorted: string[] = [];
+    const zeroQueue: string[] = [];
+    for (const r of reachable) {
+      if (inDegree.get(r) === 0) zeroQueue.push(r);
+    }
+
+    while (zeroQueue.length > 0) {
+      const current = zeroQueue.shift()!;
+      sorted.push(current);
+      const deps = this.dependents.get(current);
+      if (deps) {
+        for (const dep of deps) {
+          if (reachableSet.has(dep)) {
+            const newDeg = (inDegree.get(dep) || 0) - 1;
+            inDegree.set(dep, newDeg);
+            if (newDeg === 0) zeroQueue.push(dep);
+          }
+        }
+      }
+    }
+
+    return sorted;
+  }
+
+  // --------------------------------------------------------------------------
+  // Evaluation
+  // --------------------------------------------------------------------------
+
+  private evaluate(node: ASTNode): CellValue {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'cellref': {
+        const val = this.get(node.ref);
+        return val === null ? 0 : val;
+      }
+      case 'range':
+        throw new Error('Range can only be used inside functions');
+      case 'unary': {
+        const operand = this.evaluate(node.operand);
+        if (node.op === '-') {
+          return -(operand as number);
+        }
+        return operand;
+      }
+      case 'binop':
+        return this.evalBinop(node.op, node.left, node.right);
+      case 'function':
+        return this.evalFunction(node.name, node.args);
+    }
+  }
+
+  private evalBinop(op: string, leftNode: ASTNode, rightNode: ASTNode): CellValue {
+    const left = this.evaluate(leftNode);
+    const right = this.evaluate(rightNode);
+
+    const l = left as number;
+    const r = right as number;
+
+    switch (op) {
+      case '+': return l + r;
+      case '-': return l - r;
+      case '*': return l * r;
+      case '/': return l / r;
+      case '>': return l > r;
+      case '<': return l < r;
+      case '>=': return l >= r;
+      case '<=': return l <= r;
+      case '=': return left === right;
+      case '<>': return left !== right;
+      default:
+        throw new Error(`Unknown operator: ${op}`);
+    }
+  }
+
+  private resolveRange(node: ASTNode): CellValue[] {
+    if (node.type === 'range') {
+      const cells = expandRange(node.start, node.end);
+      return cells.map(c => this.get(c));
+    }
+    // Single value
+    return [this.evaluate(node)];
+  }
+
+  private evalFunction(name: string, args: ASTNode[]): CellValue {
+    switch (name) {
+      case 'SUM': {
+        const values = this.collectNumericValues(args);
+        return values.reduce((sum, v) => sum + v, 0);
+      }
+      case 'AVERAGE': {
+        const values = this.collectNumericValues(args);
+        if (values.length === 0) return 0;
+        return values.reduce((sum, v) => sum + v, 0) / values.length;
+      }
+      case 'MIN': {
+        const values = this.collectNumericValues(args);
+        if (values.length === 0) return 0;
+        return Math.min(...values);
+      }
+      case 'MAX': {
+        const values = this.collectNumericValues(args);
+        if (values.length === 0) return 0;
+        return Math.max(...values);
+      }
+      case 'COUNT': {
+        const values = this.collectAllValues(args);
+        return values.filter(v => typeof v === 'number').length;
+      }
+      case 'IF': {
+        if (args.length < 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evaluate(args[0]);
+        if (condition) {
+          return this.evaluate(args[1]);
+        } else {
+          return this.evaluate(args[2]);
+        }
+      }
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+
+  private collectNumericValues(args: ASTNode[]): number[] {
+    const result: number[] = [];
+    for (const arg of args) {
+      const values = this.resolveRange(arg);
+      for (const v of values) {
+        if (typeof v === 'number') {
+          result.push(v);
+        }
+      }
+    }
+    return result;
+  }
+
+  private collectAllValues(args: ASTNode[]): CellValue[] {
+    const result: CellValue[] = [];
+    for (const arg of args) {
+      const values = this.resolveRange(arg);
+      for (const v of values) {
+        result.push(v);
+      }
+    }
+    return result;
+  }
+}
