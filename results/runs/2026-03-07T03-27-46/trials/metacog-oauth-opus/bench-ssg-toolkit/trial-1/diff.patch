+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processFootnotes(content: string): string {
+  const footnoteDefinitions = new Map<string, string>();
+
+  // Extract footnote definitions: [^N]: text
+  const withoutDefs = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, (_match, id: string, text: string) => {
+    footnoteDefinitions.set(id, text);
+    return '';
+  });
+
+  // Replace inline footnote references: [^N]
+  let processed = withoutDefs.replace(/\[\^(\d+)\]/g, (_match, id: string) => {
+    return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+  });
+
+  // Append footnote section if any definitions exist
+  if (footnoteDefinitions.size > 0) {
+    const items = Array.from(footnoteDefinitions.entries())
+      .map(([id, text]) => `<li id="fn-${id}">${text}</li>`)
+      .join('');
+    processed += `<section class="footnotes"><ol>${items}</ol></section>`;
+  }
+
+  return processed;
+}
+
+function processAdmonitions(content: string): string {
+  return content.replace(/:::(note|warning|tip)\n([\s\S]*?):::/g, (_match, type: string, body: string) => {
+    return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+  });
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Process admonitions before markdown conversion
+        content = processAdmonitions(content);
+
+        // Process footnotes before markdown conversion
+        content = processFootnotes(content);
+
+        // Convert markdown to HTML
+        content = marked.parse(content, { async: false }) as string;
+
+        return { ...file, content };
+      },
+    },
+  };
+}
