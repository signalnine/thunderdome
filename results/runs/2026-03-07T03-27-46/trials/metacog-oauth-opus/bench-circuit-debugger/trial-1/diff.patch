sum).\n    54→ */\n    55→export function findSwappedWires(gates: Gate[]): string[] {\n    56→  const gateByOutput = new Map<string, Gate>();\n    57→  for (const g of gates) {\n    58→    gateByOutput.set(g.out, g);\n    59→  }\n    60→\n    61→  // Build consumer index\n    62→  const consumersByWire = new Map<string, Gate[]>();\n    63→  for (const g of gates) {\n    64→    for (const w of [g.in1, g.in2]) {\n    65→      let list = consumersByWire.get(w);\n    66→      if (!list) {\n    67→        list = [];\n    68→        consumersByWire.set(w, list);\n    69→      }\n    70→      list.push(g);\n    71→    }\n    72→  }\n    73→\n    74→  // Index gates by (op, inputs) for fast lookup\n    75→  const gatesByOpAndInputs = new Map<string, Gate>();\n    76→  for (const g of gates) {\n    77→    const key1 = `${g.op}:${g.in1}:${g.in2}`;\n    78→    const key2 = `${g.op}:${g.in2}:${g.in1}`;\n    79→    gatesByOpAndInputs.set(key1, g);\n    80→    gatesByOpAndInputs.set(key2, g);\n    81→  }\n    82→\n    83→  function findGateByOpInputs(op: Gate['op'], in1: string, in2: string): Gate | undefined {\n    84→    return gatesByOpAndInputs.get(`${op}:${in1}:${in2}`);\n    85→  }\n    86→\n    87→  function getConsumers(wire: string): Gate[] {\n    88→    return consumersByWire.get(wire) || [];\n    89→  }\n    90→\n    91→  function getConsumerOps(wire: string): Set<Gate['op']> {\n    92→    return new Set(getConsumers(wire).map((g) => g.op));\n    93→  }\n    94→\n    95→  // Determine the number of input bits\n    96→  let maxBit = 0;\n    97→  for (const g of gates) {\n    98→    for (const w of [g.in1, g.in2]) {\n    99→      const mx = w.match(/^x(\\d+)$/);\n   100→      if (mx) {\n   101→        maxBit = Math.max(maxBit, parseInt(mx[1], 10));\n   102→      }\n   103→    }\n   104→  }\n   105→  const numBits = maxBit + 1;\n   106→  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n   107→\n   108→  const swapped = new Set<string>();\n   109→\n   110→  // =========================================================\n   111→  // Phase 1: Rule-based structural checks\n   112→  // =========================================================\n   113→  // These rules identify swapped wires based on local properties\n   114→  // (producer gate type + consumer gate types).\n   115→\n   116→  for (const g of gates) {\n   117→    const wire = g.out;\n   118→    const consumers = getConsumerOps(wire);\n   119→\n   120→    // z-outputs (except last) must come from XOR\n   121→    if (wire.startsWith('z') && wire !== lastZ && g.op !== 'XOR') {\n   122→      swapped.add(wire);\n   123→    }\n   124→\n   125→    if (g.op === 'XOR') {\n   126→      const isXY = isXYInputs(g);\n   127→      if (isXY) {\n   128→        const bitNum = getBitNum(g);\n   129→        if (bitNum === 0) {\n   130→          if (wire !== 'z00') {\n   131→            swapped.add(wire);\n   132→          }\n   133→        } else {\n   134→          // Partial sum should not output to z directly\n   135→          if (wire.startsWith('z')) {\n   136→            swapped.add(wire);\n   137→          }\n   138→          // Partial sum should be consumed by XOR and AND, not OR\n   139→          if (consumers.has('OR')) {\n   140→            swapped.add(wire);\n   141→          }\n   142→        }\n   143→      } else {\n   144→        // Non-x/y XOR = sum gate, should output to z\n   145→        if (!wire.startsWith('z')) {\n   146→          swapped.add(wire);\n   147→        }\n   148→      }\n   149→    }\n   150→\n   151→    if (g.op === 'AND') {\n   152→      if (isXYInputs(g) && getBitNum(g) === 0) {\n   153→        // Bit 0 carry: consumed by XOR and AND, not OR\n   154→        if (consumers.has('OR')) {\n   155→          swapped.add(wire);\n   156→        }\n   157→      } else {\n   158→        // Generate/propagate carry: consumed by OR, not XOR\n   159→        if (consumers.has('XOR')) {\n   160→          swapped.add(wire);\n   161→        }\n   162→      }\n   163→    }\n   164→\n   165→    if (g.op === 'OR') {\n   166→      if (consumers.has('OR')) {\n   167→        swapped.add(wire);\n   168→      }\n   169→      if (wire.startsWith('z') && wire !== lastZ) {\n   170→        swapped.add(wire);\n   171→      }\n   172→    }\n   173→  }\n   174→\n   175→  // =========================================================\n   176→  // Phase 2: Trace-based structural checks\n   177→  // =========================================================\n   178→  // Trace the adder bit by bit. When we can't find expected connections,\n   179→  // we identify swaps by examining what the z-producing gate uses.\n   180→  // This catches swaps invisible to type-only rules.\n   181→\n   182→  if (swapped.size < 8) {\n   183→    let carry: string | undefined;\n   184→\n   185→    for (let bit = 0; bit < numBits; bit++) {\n   186→      const xWire = `x${String(bit).padStart(2, '0')}`;\n   187→      const yWire = `y${String(bit).padStart(2, '0')}`;\n   188→      const zWire = `z${String(bit).padStart(2, '0')}`;\n   189→\n   190→      if (bit === 0) {\n   191→        const andGate = findGateByOpInputs('AND', xWire, yWire);\n   192→        if (andGate) {\n   193→          carry = andGate.out;\n   194→        }\n   195→      } else {\n   196→        if (!carry) break;\n   197→\n   198→        const partialGate = findGateByOpInputs('XOR', xWire, yWire);\n   199→        if (!partialGate) continue;\n   200→\n   201→        let partial = partialGate.out;\n   202→\n   203→        // Try to find the sum gate: XOR(partial, carry) -> zNN\n   204→        let sumGate = findGateByOpInputs('XOR', partial, carry);\n   205→\n   206→        if (!sumGate) {\n   207→          // Either partial or carry is swapped to a different wire name.\n   208→          // Look at the z-producing gate (if it's XOR) to figure out the mapping.\n   209→          const zProducer = gateByOutput.get(zWire);\n   210→\n   211→          if (zProducer && zProducer.op === 'XOR' && !swapped.has(zWire)) {\n   212→            // z is correctly XOR. Check its inputs against expected.\n   213→            const zIn1 = zProducer.in1;\n   214→            const zIn2 = zProducer.in2;\n   215→\n   216→            if (zIn1 === carry || zIn2 === carry) {\n   217→              const actualPartial = zIn1 === carry ? zIn2 : zIn1;\n   218→              if (actualPartial !== partial) {\n   219→                swapped.add(partial);\n   220→                swapped.add(actualPartial);\n   221→                partial = actualPartial;\n   222→                sumGate = zProducer;\n   223→              }\n   224→            } else if (zIn1 === partial || zIn2 === partial) {\n   225→              const actualCarry = zIn1 === partial ? zIn2 : zIn1;\n   226→              if (actualCarry !== carry) {\n   227→                swapped.add(carry);\n   228→                swapped.add(actualCarry);\n   229→                carry = actualCarry;\n   230→                sumGate = zProducer;\n   231→              }\n   232→            }\n   233→          } else if (swapped.has(zWire)) {\n   234→            // z is already known to be swapped. Find the XOR(partial, carry) wherever it outputs.\n   235→            sumGate = findGateByOpInputs('XOR', partial, carry);\n   236→            // sumGate might not exist if partial or carry is also swapped\n   237→          }\n   238→        }\n   239→\n   240→        // Compute carry for this bit\n   241→        const genGate = findGateByOpInputs('AND', xWire, yWire);\n   242→        const propGate = findGateByOpInputs('AND', partial, carry);\n   243→\n   244→        if (genGate && propGate) {\n   245→          const carryGate = findGateByOpInputs('OR', genGate.out, propGate.out);\n   246→          if (carryGate) {\n   247→            carry = carryGate.out;\n   248→          } else {\n   249→            // One of gen/prop outputs might be swapped. The gen or prop output\n   250→            // has been flagged by phase 1 rules. We need to find the actual\n   251→            // carry OR gate. Look for an OR gate that uses one of them.\n   252→            const genConsumers = getConsumers(genGate.out);\n   253→            const propConsumers = getConsumers(propGate.out);\n   254→\n   255→            // Find the OR consumer of whichever is correct\n   256→            let orGate: Gate | undefined;\n   257→            for (const c of genConsumers) {\n   258→              if (c.op === 'OR') { orGate = c; break; }\n   259→            }\n   260→            if (!orGate) {\n   261→              for (const c of propConsumers) {\n   262→                if (c.op === 'OR') { orGate = c; break; }\n   263→              }\n   264→            }\n   265→            if (orGate) {\n   266→              carry = orGate.out;\n   267→            } else {\n   268→              break;\n   269→            }\n   270→          }\n   271→        } else if (!propGate && genGate) {\n   272→          // propGate = AND(partial, carry) not found. This might happen if\n   273→          // partial or carry wire name was updated. Try to find the OR gate\n   274→          // that uses genGate.out to find the carry.\n   275→          const genConsumers = getConsumers(genGate.out);\n   276→          let orGate: Gate | undefined;\n   277→          for (const c of genConsumers) {\n   278→            if (c.op === 'OR') { orGate = c; break; }\n   279→          }\n   280→          if (orGate) {\n   281→            carry = orGate.out;\n   282→          } else {\n   283→            break;\n   284→          }\n   285→        } else {\n   286→          break;\n   287→        }\n   288→      }\n   289→    }\n   290→  }\n   291→\n   292→  return [...swapped].sort();\n   293→\n   294→  function isXYInputs(g: Gate): boolean {\n   295→    return (\n   296→      (g.in1.startsWith('x') && g.in2.startsWith('y')) ||\n   297→      (g.in1.startsWith('y') && g.in2.startsWith('x'))\n   298→    );\n   299→  }\n   300→\n   301→  function getBitNum(g: Gate): number {\n   302→    const w