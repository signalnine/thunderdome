+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit: given gates and initial wire values, compute all wire values.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+  let progress = true;
+
+  while (remaining.length > 0 && progress) {
+    progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 swapped output wires in a broken ripple-carry adder circuit.
+ *
+ * Two-phase approach:
+ * Phase 1: Rule-based - check producer type vs expected role, and consumer types.
+ * Phase 2: Trace-based - follow the adder structure bit by bit to catch swaps
+ *          that are invisible to type-only rules (e.g., carry swapped with
+ *          adjacent partial sum).
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  const gateByOutput = new Map<string, Gate>();
+  for (const g of gates) {
+    gateByOutput.set(g.out, g);
+  }
+
+  // Build consumer index
+  const consumersByWire = new Map<string, Gate[]>();
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      let list = consumersByWire.get(w);
+      if (!list) {
+        list = [];
+        consumersByWire.set(w, list);
+      }
+      list.push(g);
+    }
+  }
+
+  // Index gates by (op, inputs) for fast lookup
+  const gatesByOpAndInputs = new Map<string, Gate>();
+  for (const g of gates) {
+    const key1 = `${g.op}:${g.in1}:${g.in2}`;
+    const key2 = `${g.op}:${g.in2}:${g.in1}`;
+    gatesByOpAndInputs.set(key1, g);
+    gatesByOpAndInputs.set(key2, g);
+  }
+
+  function findGateByOpInputs(op: Gate['op'], in1: string, in2: string): Gate | undefined {
+    return gatesByOpAndInputs.get(`${op}:${in1}:${in2}`);
+  }
+
+  function getConsumers(wire: string): Gate[] {
+    return consumersByWire.get(wire) || [];
+  }
+
+  function getConsumerOps(wire: string): Set<Gate['op']> {
+    return new Set(getConsumers(wire).map((g) => g.op));
+  }
+
+  // Determine the number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const mx = w.match(/^x(\d+)$/);
+      if (mx) {
+        maxBit = Math.max(maxBit, parseInt(mx[1], 10));
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+  const lastZ = `z${String(numBits).padStart(2, '0')}`;
+
+  const swapped = new Set<string>();
+
+  // =========================================================
+  // Phase 1: Rule-based structural checks
+  // =========================================================
+  // These rules identify swapped wires based on local properties
+  // (producer gate type + consumer gate types).
+
+  for (const g of gates) {
+    const wire = g.out;
+    const consumers = getConsumerOps(wire);
+
+    // z-outputs (except last) must come from XOR
+    if (wire.startsWith('z') && wire !== lastZ && g.op !== 'XOR') {
+      swapped.add(wire);
+    }
+
+    if (g.op === 'XOR') {
+      const isXY = isXYInputs(g);
+      if (isXY) {
+        const bitNum = getBitNum(g);
+        if (bitNum === 0) {
+          if (wire !== 'z00') {
+            swapped.add(wire);
+          }
+        } else {
+          // Partial sum should not output to z directly
+          if (wire.startsWith('z')) {
+            swapped.add(wire);
+          }
+          // Partial sum should be consumed by XOR and AND, not OR
+          if (consumers.has('OR')) {
+            swapped.add(wire);
+          }
+        }
+      } else {
+        // Non-x/y XOR = sum gate, should output to z
+        if (!wire.startsWith('z')) {
+          swapped.add(wire);
+        }
+      }
+    }
+
+    if (g.op === 'AND') {
+      if (isXYInputs(g) && getBitNum(g) === 0) {
+        // Bit 0 carry: consumed by XOR and AND, not OR
+        if (consumers.has('OR')) {
+          swapped.add(wire);
+        }
+      } else {
+        // Generate/propagate carry: consumed by OR, not XOR
+        if (consumers.has('XOR')) {
+          swapped.add(wire);
+        }
+      }
+    }
+
+    if (g.op === 'OR') {
+      if (consumers.has('OR')) {
+        swapped.add(wire);
+      }
+      if (wire.startsWith('z') && wire !== lastZ) {
+        swapped.add(wire);
+      }
+    }
+  }
+
+  // =========================================================
+  // Phase 2: Trace-based structural checks
+  // =========================================================
+  // Trace the adder bit by bit. When we can't find expected connections,
+  // we identify swaps by examining what the z-producing gate uses.
+  // This catches swaps invisible to type-only rules.
+
+  if (swapped.size < 8) {
+    let carry: string | undefined;
+
+    for (let bit = 0; bit < numBits; bit++) {
+      const xWire = `x${String(bit).padStart(2, '0')}`;
+      const yWire = `y${String(bit).padStart(2, '0')}`;
+      const zWire = `z${String(bit).padStart(2, '0')}`;
+
+      if (bit === 0) {
+        const andGate = findGateByOpInputs('AND', xWire, yWire);
+        if (andGate) {
+          carry = andGate.out;
+        }
+      } else {
+        if (!carry) break;
+
+        const partialGate = findGateByOpInputs('XOR', xWire, yWire);
+        if (!partialGate) continue;
+
+        let partial = partialGate.out;
+
+        // Try to find the sum gate: XOR(partial, carry) -> zNN
+        let sumGate = findGateByOpInputs('XOR', partial, carry);
+
+        if (!sumGate) {
+          // Either partial or carry is swapped to a different wire name.
+          // Look at the z-producing gate (if it's XOR) to figure out the mapping.
+          const zProducer = gateByOutput.get(zWire);
+
+          if (zProducer && zProducer.op === 'XOR' && !swapped.has(zWire)) {
+            // z is correctly XOR. Check its inputs against expected.
+            const zIn1 = zProducer.in1;
+            const zIn2 = zProducer.in2;
+
+            if (zIn1 === carry || zIn2 === carry) {
+              const actualPartial = zIn1 === carry ? zIn2 : zIn1;
+              if (actualPartial !== partial) {
+                swapped.add(partial);
+                swapped.add(actualPartial);
+                partial = actualPartial;
+                sumGate = zProducer;
+              }
+            } else if (zIn1 === partial || zIn2 === partial) {
+              const actualCarry = zIn1 === partial ? zIn2 : zIn1;
+              if (actualCarry !== carry) {
+                swapped.add(carry);
+                swapped.add(actualCarry);
+                carry = actualCarry;
+                sumGate = zProducer;
+              }
+            }
+          } else if (swapped.has(zWire)) {
+            // z is already known to be swapped. Find the XOR(partial, carry) wherever it outputs.
+            sumGate = findGateByOpInputs('XOR', partial, carry);
+            // sumGate might not exist if partial or carry is also swapped
+          }
+        }
+
+        // Compute carry for this bit
+        const genGate = findGateByOpInputs('AND', xWire, yWire);
+        const propGate = findGateByOpInputs('AND', partial, carry);
+
+        if (genGate && propGate) {
+          const carryGate = findGateByOpInputs('OR', genGate.out, propGate.out);
+          if (carryGate) {
+            carry = carryGate.out;
+          } else {
+            // One of gen/prop outputs might be swapped. The gen or prop output
+            // has been flagged by phase 1 rules. We need to find the actual
+            // carry OR gate. Look for an OR gate that uses one of them.
+            const genConsumers = getConsumers(genGate.out);
+            const propConsumers = getConsumers(propGate.out);
+
+            // Find the OR consumer of whichever is correct
+            let orGate: Gate | undefined;
+            for (const c of genConsumers) {
+              if (c.op === 'OR') { orGate = c; break; }
+            }
+            if (!orGate) {
+              for (const c of propConsumers) {
+                if (c.op === 'OR') { orGate = c; break; }
+              }
+            }
+            if (orGate) {
+              carry = orGate.out;
+            } else {
+              break;
+            }
+          }
+        } else if (!propGate && genGate) {
+          // propGate = AND(partial, carry) not found. This might happen if
+          // partial or carry wire name was updated. Try to find the OR gate
+          // that uses genGate.out to find the carry.
+          const genConsumers = getConsumers(genGate.out);
+          let orGate: Gate | undefined;
+          for (const c of genConsumers) {
+            if (c.op === 'OR') { orGate = c; break; }
+          }
+          if (orGate) {
+            carry = orGate.out;
+          } else {
+            break;
+          }
+        } else {
+          break;
+        }
+      }
+    }
+  }
+
+  return [...swapped].sort();
+
+  function isXYInputs(g: Gate): boolean {
+    return (
+      (g.in1.startsWith('x') && g.in2.startsWith('y')) ||
+      (g.in1.startsWith('y') && g.in2.startsWith('x'))
+    );
+  }
+
+  function getBitNum(g: Gate): number {
+    const w = g.in1.startsWith('x') || g.in1.startsWith('y') ? g.in1 : g.in2;
+    return parseInt(w.slice(1), 10);
+  }
+}
