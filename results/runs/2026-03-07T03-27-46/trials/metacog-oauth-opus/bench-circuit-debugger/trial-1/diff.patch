nst bitNum = getBitNum(g);\n        if (bitNum === 0) {\n          if (wire !== 'z00') {\n            swapped.add(wire);\n          }\n        } else {\n          // Partial sum should not be z\n          if (wire.startsWith('z')) {\n            swapped.add(wire);\n          }\n          // Partial sum should be consumed by XOR and AND, not OR\n          if (consumers.has('OR')) {\n            swapped.add(wire);\n          }\n        }\n      } else {\n        // Non-x/y XOR = sum gate, should output to z\n        if (!wire.startsWith('z')) {\n          swapped.add(wire);\n        }\n      }\n    }\n\n    if (g.op === 'AND') {\n      if (isXYInputs(g) && getBitNum(g) === 0) {\n        // Bit 0 carry: consumed by XOR and AND, not OR\n        if (consumers.has('OR')) {\n          swapped.add(wire);\n        }\n      } else {\n        // Generate/propagate carry: consumed by OR, not XOR\n        if (consumers.has('XOR')) {\n          swapped.add(wire);\n        }\n      }\n    }\n\n    if (g.op === 'OR') {\n      // Carry: consumed by XOR and AND, not OR (unless it's lastZ with no consumers)\n      if (consumers.has('OR')) {\n        swapped.add(wire);\n      }\n      if (wire.startsWith('z') && wire !== lastZ) {\n        swapped.add(wire);\n      }\n    }\n  }\n\n  // =========================================================\n  // Phase 2: Trace-based structural checks\n  // =========================================================\n  // Trace the adder bit by bit. When we can't find a gate that should\n  // exist (e.g., XOR(partial, carry)), we identify swapped wires by\n  // looking at what the z-producing gate actually uses.\n\n  if (swapped.size < 8) {\n    let carry: string | undefined;\n\n    for (let bit = 0; bit < numBits; bit++) {\n      const xWire = `x${String(bit).padStart(2, '0')}`;\n      const yWire = `y${String(bit).padStart(2, '0')}`;\n      const zWire = `z${String(bit).padStart(2, '0')}`;\n\n      if (bit === 0) {\n        const xorGate = findGate('