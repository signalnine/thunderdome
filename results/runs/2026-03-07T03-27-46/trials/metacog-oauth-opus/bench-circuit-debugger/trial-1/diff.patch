n findSwappedWires(gates: Gate[]): string[] {\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Build consumer index\n  const consumersByWire = new Map<string, Gate[]>();\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      let list = consumersByWire.get(w);\n      if (!list) {\n        list = [];\n        consumersByWire.set(w, list);\n      }\n      list.push(g);\n    }\n  }\n\n  // Index gates by (op, inputs) for fast lookup\n  const gatesByOpAndInputs = new Map<string, Gate>();\n  for (const g of gates) {\n    const key1 = `${g.op}:${g.in1}:${g.in2}`;\n    const key2 = `${g.op}:${g.in2}:${g.in1}`;\n    gatesByOpAndInputs.set(key1, g);\n    gatesByOpAndInputs.set(key2, g);\n  }\n\n  function findGateByOpInputs(op: Gate['op'], in1: string, in2: string): Gate | undefined {\n    return gatesByOpAndInputs.get(`${op}:${in1}:${in2}`);\n  }\n\n  function getConsumers(wire: string): Gate[] {\n    return consumersByWire.get(wire) || [];\n  }\n\n  function getConsumerOps(wire: string): Set<Gate['op']> {\n    return new Set(getConsumers(wire).map((g) => g.op));\n  }\n\n  // Determine the number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const mx = w.match(/^x(\\d+)$/);\n      if (mx) {\n        maxBit = Math.max(maxBit, parseInt(mx[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  const swapped = new Set<string>();\n\n  // =========================================================\n  // Phase 1: Rule-based structural checks\n  // =========================================================\n  // These rules identify swapped wires based on local properties\n  // (producer gate type + consumer gate types).\n\n  for (const g of gates) {\n    const wire = g.out;\n    const consumers = getConsumerOps(wire);\n\n    // z-outputs (except last) must come from