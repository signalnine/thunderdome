  }","-    }","-  }","-}"]}],"originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\n/**\n * Simulate a circuit: given gates and initial wire values, compute all wire values.\n */\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n  let progress = true;\n\n  while (remaining.length > 0 && progress) {\n    progress = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 swapped output wires in a broken ripple-carry adder circuit.\n *\n * Uses structural analysis: traces the expected ripple-carry adder pattern\n * bit by bit, checking that each gate's role matches its operation type.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Index gates by (op, inputs) for fast lookup\n  const gatesByOpAndInputs = new Map<string, Gate>();\n  for (const g of gates) {\n    const key1 = `${g.op}:${g.in1}:${g.in2}`;\n    const key2 = `${g.op}:${g.in2}:${g.in1}`;\n    gatesByOpAndInputs.set(key1, g);\n    gatesByOpAndInputs.set(key2, g);\n  }\n\n  function findGate(op: Gate['op'], in1: string, in2: string): Gate | undefined {\n    return gatesByOpAndInputs.get(`${op}:${in1}:${in2}`);\n  }\n\n  // Determine the number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const mx = w.match(/^x(\\d+)$/);\n      if (mx) {\n        maxBit = Math.max(maxBit, parseInt(mx[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  const swapped = new Set<string>();\n\n  // Apply local structural rules that identify swap candidates\n  // without cascading effects.\n  //\n  // Rule 1: z-outputs (except lastZ) must come from XOR gates\n  for (let i = 0; i <= numBits; i++) {\n    const zWire = `z${String(i).padStart(2, '0')}`;\n    const producer = gateByOutput.get(zWire);\n    if (producer && zWire !== lastZ && producer.op !== 'XOR') {\n      swapped.add(zWire);\n    }\n  }\n\n  // Rule 2: XOR(xNN, yNN) for N>0 should not output to z\n  // (it should produce a partial sum, not a final sum)\n  for (const g of gates) {\n    if (g.op === 'XOR' && isXYGate(g)) {\n      const bitNum = getBitNum(g);\n      if (bitNum > 0 && g.out.startsWith('z')) {\n        swapped.add(g.out);\n      }\n    }\n  }\n\n  // Rule 3: AND gate outputs (except x00 AND y00) should feed into OR gates only.\n  // If an AND output feeds into XOR, the AND's output is swapped.\n  for (const g of gates) {\n    if (g.op === 'AND' && !(isXYGate(g) && getBitNum(g) === 0)) {\n      for (const consumer of getConsumers(g.out)) {\n        if (consumer.op === 'XOR') {\n          swapped.add(g.out);\n        }\n      }\n    }\n  }\n\n  // Rule 4: XOR(xNN, yNN) outputs for N>0 should feed into XOR and AND, not OR.\n  for (const g of gates) {\n    if (g.op === 'XOR' && isXYGate(g) && getBitNum(g) > 0) {\n      for (const consumer of getConsumers(g.out)) {\n        if (consumer.op === 'OR') {\n          swapped.add(g.out);\n        }\n      }\n    }\n  }\n\n  // Rule 5: OR gate outputs should feed into XOR and AND (as carry to next bit),\n  // not into a