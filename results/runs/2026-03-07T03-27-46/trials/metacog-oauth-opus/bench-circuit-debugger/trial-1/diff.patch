st consumers = getConsumerOps(wire);\n\n    if (wire.startsWith('z') && wire !== lastZ) {\n      // z-outputs (except last) must come from XOR\n      if (g.op !== 'XOR') {\n        swapped.add(wire);\n      }\n    }\n\n    if (g.op === 'XOR') {\n      const isXY = isXYInputs(g);\n      if (isXY) {\n        const bitNum = getBitNum(g);\n        if (bitNum === 0) {\n          // x00 XOR y00 should produce z00\n          if (wire !== 'z00') {\n            swapped.add(wire);\n          }\n        } else {\n          // xNN XOR yNN for N>0 produces a partial sum\n          // It should NOT output to z directly\n          if (wire.startsWith('z')) {\n            swapped.add(wire);\n          }\n          // Partial sums should be consumed by XOR and AND, not OR\n          if (consumers.has('OR')) {\n            swapped.add(wire);\n          }\n        }\n      } else {\n        // Non-x/y XOR gates produce final sums (z outputs)\n        // They should output to z (not an intermediate wire)\n        if (!wire.startsWith('z')) {\n          swapped.add(wire);\n        }\n      }\n    }\n\n    if (g.op === 'AND') {\n      const isXY = isXYInputs(g);\n      if (isXY && getBitNum(g) === 0) {\n        // x00 AND y00 produces carry for bit 0\n        // Should be consumed by XOR and AND (bit 1's sum and propagate)\n        // Should NOT be consumed by OR\n        if (consumers.has('OR')) {\n          swapped.add(wire);\n        }\n      } else {\n        // All other AND gates produce either generate or propagate carries\n        // They should be consumed by OR (carry combination)\n        // They should NOT be consumed by XOR\n        if (consumers.has('XOR')) {\n          swapped.add(wire);\n        }\n      }\n    }\n\n    if (g.op === 'OR') {\n      // OR gates produce carries\n      // They should be consumed by XOR and AND (next bit) or be lastZ\n      // They should NOT be consumed by OR\n      if (consumers.has('OR')) {\n        swapped.add(wire);\n      }\n      // OR 