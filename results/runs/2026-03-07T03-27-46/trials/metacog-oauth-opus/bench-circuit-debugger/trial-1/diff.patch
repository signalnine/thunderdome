 swapped output wires in a broken ripple-carry adder circuit.\n *\n * Strategy: A ripple-carry adder has a rigid structure. For each bit position,\n * we know what type of gate should produce each wire. We check structural\n * invariants and collect violations.\n *\n * Ripple-carry adder structure for N-bit addition:\n *\n * Bit 0 (half adder):\n *   x00 XOR y00 -> z00          (sum bit)\n *   x00 AND y00 -> c00          (carry out)\n *\n * Bit i (full adder, i = 1..N-1):\n *   xII XOR yII -> tII          (partial sum)\n *   tII XOR c(i-1) -> zII       (final sum)\n *   xII AND yII -> aII          (generate carry)\n *   tII AND c(i-1) -> bII       (propagate carry)\n *   aII OR bII -> cII           (carry out)\n *\n * Bit N (final):\n *   c(N-1) -> zNN               (MSB output = last carry)\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Helper: check if a gate has specific inputs (order-independent)\n  function hasInputs(g: Gate, a: string, b: string): boolean {\n    return (\n      (g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a)\n    );\n  }\n\n  // Helper: find a gate by op and inputs\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string\n  ): Gate | undefined {\n    return gates.find(\n      (g) => g.op === op && hasInputs(g, in1, in2)\n    );\n  }\n\n  // Determine the number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      const mx = w.match(/^x(\\d+)$/);\n      if (mx) {\n        maxBit = Math.max(maxBit, parseInt(mx[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n\n  const swapped = new Set<string>();\n\n  // Structural rules for a ripple-carry adder:\n  //\n  // 1. Every XOR gate that takes x and y inputs should NOT output to z\n  //    (except bit 0 where x00 XOR y00 -> z00).\n  //    If it does output to z (for bit > 0), that z wire is swapped.\n  //\n  // 2. Every z output (except the last one zNN which is a carry) must be\n  //    produced by an XOR gate.\n  //\n  // 3. An AND gate should never output to z (except possibly the last bit).\n  //\n  // 4. An OR gate should never output to z (except possibly the last bit).\n  //\n  // 5. A XOR gate's output (if not z) should be consumed by exactly one\n  //    XOR and one AND (the two gates in the full adder that use the\n  //    partial sum). If a non-z XOR output is consumed by an OR, it's wrong.\n  //\n  // More precisely, let's validate structurally:\n\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  for (const g of gates) {\n    // Rule: OR gates should never output to z (except the final carry bit)\n    if (g.op === 'OR' && g.out.startsWith('z') && g.out !== lastZ) {\n      swapped.add(g.out);\n    }\n\n    // Rule: AND gates should never output to z (except for z-last in degenerate case)\n    if (g.op === 'AND' && g.out.startsWith('z') && g.out !== lastZ) {\n      swapped.add(g.out);\n    }\n\n    // Rule: For XOR gates with x/y inputs (partial sum generators) for bit > 0,\n    // they should NOT output directly to z.\n    if (g.op === 'XOR') {\n      const isXY =\n        (g.in1.startsWith('x') && g.in2.startsWith('y')) ||\n        (g.in1.startsWith('y') && g.in2.startsWith('x'));\n      if (isXY) {\n        const bitStr = g.in1.slice(1);\n        const bitNum = parseInt(bitStr, 10);\n        if (bitNum > 0 && g.out.startsWith('z')) {\n          // This XOR(x,y) should produce a partial sum, not a z output\n          swapped.add(g.out);\n        }\n      }\n    }\n\n    // Rule: XOR gates that produce z outputs should have their inputs be\n    // the partial-sum XOR and the carry. If a z-producing XOR has x/y\n    // inputs, that's only valid for bit 0 (already handled above).\n\n    // Rule: For non-z XOR outputs (partial sums), they should be used\n    // by both a XOR and an AND gate. If used by an OR, something is wrong.\n    if (g.op === 'XOR' && !g.out.startsWith('z')) {\n      const isXY =\n        (g.in1.startsWith('x') && g.in2.startsWith('y')) ||\n        (g.in1.startsWith('y') && g.in2.startsWith('x'));\n      if (isXY) {\n        // This is a partial sum for some bit. Check what consumes it.\n        const consumers = gates.filter(\n          (c) => c.in1 === g.out || c.in2 === g.out\n        );\n        for (const c of consumers) {\n          if (c.op === 'OR') {\n            // A partial sum should never feed directly into an OR gate.\n            // The partial sum feeds into XOR(partial, carry) and AND(partial, carry).\n            // OR is only for combining generate and propagate carries.\n            swapped.add(g.out);\n          }\n        }\n      }\n    }\n\n    // Rule: AND gates (except for bit 0's carry generator x00 AND y00)\n    // should have their outputs consumed by an OR gate (carry combination).\n    // If an AND output feeds into a XOR, it's likely swapped.\n    if (g.op === 'AND') {\n      const isBit0 =\n        hasInputs(g, 'x00', 'y00');\n      if (!isBit0) {\n        const consumers = gates.filter(\n          (c) => c.in1 === g.out || c.in2 === g.out\n        );\n        for (const c of consumers) {\n          if (c.op === 'XOR') {\n            // An AND output should feed into OR, not XOR\n            swapped.add(g.out);\n          }\n        }\n      }\n    }\n\n    // Rule: OR gates produce carries. A carry should be consumed by\n    // XOR and AND in the next bit (or be the final z output).\n    // If an OR output feeds into another OR, it's wrong.\n    if (g.op === 'OR') {\n      const consumers = gates.filter(\n        (c) => c.in1 === g.out || c.in2 === g.out\n      );\n      for (const c of consumers) {\n        if (c.op === 'OR') {\n          // Carry should not feed into OR\n          swapped.add(g.out);\n        }\n      }\n    }\n  }\n\n  // If we've found exactly 8, we're done. But if the rules above found\n  // fewer, we need additional analysis. Let's also try to trace the\n  // adder structure bit by bit and find mismatches.\n\n  if (swapped.size !== 8) {\n    // Fallback: trace the adder structure more carefully\n    // This handles edge cases the simple rules might miss\n    traceAdderStructure(gates, numBits, swapped, gateByOutput, findGate);\n  }\n\n  return [...swapped].sort();\n}\n\nfunction traceAdderStructure(\n  gates: Gate[],\n  numBits: number,\n  swapped: Set<string>,\n  gateByOutput: Map<string, Gate>,\n  findGate: (op: Gate['op'], in1: string, in2: string) => Gate | undefined\n): void {\n  let carry: string | undefined;\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const xWire = `x${String(bit).padStart(2, '0')}`;\n    const yWire = `y${String(bit).padStart(2, '0')}`;\n    const zWire = `z${String(bit).padStart(2, '0')}`;\n\n    if (bit === 0) {\n      // Half adder: XOR -> z00, AND -> carry\n      const xorGate = findGate('XOR', xWire, yWire);\n      const andGate = findGate('AND', xWire, yWire);\n      if (xorGate) {\n        if (xorGate.out !== zWire) {\n          swapped.add(xorGate.out);\n          swapped.add(zWire);\n        }\n        carry = andGate?.out;\n      }\n    } else {\n      if (!carry) break;\n\n      // Full adder:\n      // XOR(x, y) -> partial\n      const partialGate = findGate('XOR', xWire, yWire);\n      if (!partialGate) continue;\n\n      const partial = partialGate.out;\n\n      // XOR(partial, carry) -> z\n      let sumGate = findGate('XOR', partial, carry);\n      if (!sumGate) {\n        // The partial or carry wire might be swapped; try to find what\n        // produces this z and trace backwards\n        const zGate = gateByOutput.get(zWire);\n        if (zGate && zGate.op === 'XOR') {\n          // One of zGate's inputs should be carry; the other should be partial\n          // but isn't because of a swap\n          if (zGate.in1 === carry || zGate.in2 === carry) {\n           