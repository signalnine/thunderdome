2, '0')}`;\n      const zWire = `z${String(bit).padStart(2, '0')}`;\n\n      if (bit === 0) {\n        const andGate = findGateByOpInputs('AND', xWire, yWire);\n        if (andGate) {\n          carry = andGate.out;\n        }\n      } else {\n        if (!carry) break;\n\n        const partialGate = findGateByOpInputs('XOR', xWire, yWire);\n        if (!partialGate) continue;\n\n        let partial = partialGate.out;\n\n        // Try to find the sum gate: XOR(partial, carry) -> zNN\n        let sumGate = findGateByOpInputs('XOR', partial, carry);\n\n        if (!sumGate) {\n          // Either partial or carry is swapped to a different wire name.\n          // Look at the z-producing gate (if it's XOR) to figure out the mapping.\n          const zProducer = gateByOutput.get(zWire);\n\n          if (zProducer && zProducer.op === 'XOR' && !swapped.has(zWire)) {\n            // z is correctly XOR. Check its inputs against expected.\n            const zIn1 = zProducer.in1;\n            const zIn2 = zProducer.in2;\n\n            if (zIn1 === carry || zIn2 === carry) {\n              const actualPartial = zIn1 === carry ? zIn2 : zIn1;\n              if (actualPartial !== partial) {\n                swapped.add(partial);\n                swapped.add(actualPartial);\n                partial = actualPartial;\n                sumGate = zProducer;\n              }\n            } else if (zIn1 === partial || zIn2 === partial) {\n              const actualCarry = zIn1 === partial ? zIn2 : zIn1;\n              if (actualCarry !== carry) {\n                swapped.add(carry);\n                swapped.add(actualCarry);\n                carry = actualCarry;\n                sumGate = zProducer;\n              }\n            }\n          } else if (swapped.has(zWire)) {\n            // z is already known to be swapped. Find the XOR(partial, carry) wherever it outputs.\n            sumGate = findGateByOpInputs('XOR', partial, carry);\n            // sumGate might not exist if partial or carry is also swapped\n          }\n        }\n\n        // Compute carry for this bit\n        const genGate = findGateByOpInputs('AND', xWire, yWire);\n        const propGate = findGateByOpInputs('AND', partial, carry);\n\n        if (genGate && propGate) {\n          const carryGate = findGateByOpInputs('OR', genGate.out, propGate.out);\n          if (carryGate) {\n            carry = carryGate.out;\n          } else {\n            // One of gen/prop outputs might be swapped. The gen or prop output\n            // has been flagged by phase 1 rules. We need to find the actual\n            // carry OR gate. Look for an OR gate that uses one of them.\n            const genConsumers = getConsumers(genGate.out);\n            const propConsumers = getConsumers(propGate.out);\n\n            // Find the OR consumer of whichever is correct\n            let orGate: Gate | undefined;\n            for (const c of genConsumers) {\n              if (c.op === 'OR') { orGate = c; break; }\n            }\n            if (!orGate) {\n              for (const c of propConsumers) {\n                if (c.op === 'OR') { orGate = c; break; }\n              }\n            }\n            if (orGate) {\n              carry = orGate.out;\n            } else {\n              break;\n            }\n          }\n        } else if (!propGate && genGate) {\n          // propGate = AND(partial, carry) not found. This might happen if\n          // partial or carry wire name was updated. Try to find the OR gate\n          // that uses genGate.out to find the carry.\n          const genConsumers = getConsumers(genGate.out);\n          let orGate: Gate | undefined;\n          for (const c of genConsumers) {\n            if (c.op === 'OR') { orGate = c; break; }\n          }\n          if (orGate) {\n            carry = orGate.out;\n          } else {\n            break;\n          }\n        } else {\n          break;\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n\n  function isXYInputs(g: Gate): boolean {\n    return (\n      (g.in1.startsWith('x') && g.in2.startsWith('y')) ||\n      (g.in1.startsWith('y') && g.in2.startsWith('x'))\n    );\n  }\n\n  function getBitNum(g: Gate): number {\n    const w = g.in1.startsWith('x') || g.in1.startsWith('y') ? g.in1 : g.in2;\n    return parseInt(w.slice(1), 10);\n  }\n}\n","structuredPatch":[{"oldStart":80,"oldLines":13,"newStart":80,"newLines":16,"lines":["     gatesByOpAndInputs.set(key2, g);","   }"," ","-  function findGate(op: Gate['op'], in1: string, in2: string): Gate | undefined {","+  function findGateByOpInputs(op: Gate['op'], in1: string, in2: string): Gate | undefined {","     return gatesByOpAndInputs.get(`${op}:${in1}:${in2}`);","   }"," ","+  function getConsumers(wire: string): Gate[] {","+    return consumersByWire.get(wire) || [];","+  }","+","   function getConsumerOps(wire: string): Set<Gate['op']> {","-    const consumers = consumersByWire.get(wire) || [];","-    return new Set(consumers.map((g) => g.op));","+    return new Set(getConsumers(wire).map((g) => g.op));","   }"," ","   // Determine the number of input bits"]},{"oldStart":107,"oldLines":6,"newStart":110,"newLines":8,"lines":["   // =========================================================","   // Phase 1: Rule-based structural checks","   // =========================================================","+  // These rules identify swapped wires based on local properties","+  // (producer gate type + consumer gate types)."," ","   for (const g of gates) {","     const wire = g.out;"]},{"oldStart":126,"oldLines":7,"newStart":131,"newLines":7,"lines":["             swapped.add(wire);","           }","         } else {","-          // Partial sum should not be z","+          // Partial sum should not output to z directly","           if (wire.startsWith('z')) {","             swapped.add(wire);","           }"]},{"oldStart":158,"oldLines":7,"newStart":163,"newLines":6,"lines":["     }"," ","     if (g.op === 'OR') {","- 