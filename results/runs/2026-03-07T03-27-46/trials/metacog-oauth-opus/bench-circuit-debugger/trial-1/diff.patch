ires', () => {\n  /**\n   * Build a correct N-bit ripple-carry adder circuit.\n   */\n  function buildCorrectAdder(numBits: number): Gate[] {\n    const gates: Gate[] = [];\n    // Bit 0: half adder\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n    for (let i = 1; i < numBits; i++) {\n      const pad = String(i).padStart(2, '0');\n      const prevPad = String(i - 1).padStart(2, '0');\n      gates.push({ op: 'XOR', in1: `x${pad}`, in2: `y${pad}`, out: `t${pad}` });\n      gates.push({ op: 'XOR', in1: `t${pad}`, in2: `c${prevPad}`, out: `z${pad}` });\n      gates.push({ op: 'AND', in1: `x${pad}`, in2: `y${pad}`, out: `a${pad}` });\n      gates.push({ op: 'AND', in1: `t${pad}`, in2: `c${prevPad}`, out: `b${pad}` });\n      gates.push({ op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: `c${pad}` });\n    }\n\n    // Last carry -> final z bit\n    const lastPad = String(numBits - 1).padStart(2, '0');\n    const finalZ = `z${String(numBits).padStart(2, '0')}`;\n    // We need to \"pass through\" the carry. Since we can only have gates,\n    // use an OR with itself (c OR c = c) or we can use the c directly as the\n    // z output. Actually the task says c03 -> z04 which is a direct wire.\n    // But our gate model requires a gate. Let's use a workaround:\n    // The last carry gate already produces the final carry. Let's just\n    // rename its output to the final z.\n    // Actually, looking at the example more carefully, the last carry IS z04.\n    // So the OR gate for the last bit should output directly to z(N).\n    // Let's fix: change the last carry gate's output to finalZ.\n    const lastCarryGate = gates[gates.length - 1]; // OR gate for last bit\n    lastCarryGate.out = finalZ;\n\n    return gates;\n  }\n\n  /**\n   * Swap outputs of two gates.\n   */\n  function swapOutputs(gates: Gate[], out1: string, out2: string): void {\n    const g1 = gates.find((g) => g.out === out1)