ule: For non-z XOR outputs (partial sums), they should be used\n    // by both a XOR and an AND gate. If used by an OR, something is wrong.\n    if (g.op === 'XOR' && !g.out.startsWith('z')) {\n      const isXY =\n        (g.in1.startsWith('x') && g.in2.startsWith('y')) ||\n        (g.in1.startsWith('y') && g.in2.startsWith('x'));\n      if (isXY) {\n        // This is a partial sum for some bit. Check what consumes it.\n        const consumers = gates.filter(\n          (c) => c.in1 === g.out || c.in2 === g.out\n        );\n        for (const c of consumers) {\n          if (c.op === 'OR') {\n            // A partial sum should never feed directly into an OR gate.\n            // The partial sum feeds into XOR(partial, carry) and AND(partial, carry).\n            // OR is only for combining generate and propagate carries.\n            swapped.add(g.out);\n          }\n        }\n      }\n    }\n\n    // Rule: AND gates (except for bit 0's carry generator x00 AND y00)\n    // should have their outputs consumed by an OR gate (carry combination).\n    // If an AND output feeds into a XOR, it's likely swapped.\n    if (g.op === 'AND') {\n      const isBit0 =\n        hasInputs(g, 'x00', 'y00');\n      if (!isBit0) {\n        const consumers = gates.filter(\n          (c) => c.in1 === g.out || c.in2 === g.out\n        );\n        for (const c of consumers) {\n          if (c.op === 'XOR') {\n            // An AND output should feed into OR, not XOR\n            swapped.add(g.out);\n          }\n        }\n      }\n    }\n\n    // Rule: OR gates produce carries. A carry should be consumed by\n    // XOR and AND in the next bit (or be the final z output).\n    // If an OR output feeds into another OR, it's wrong.\n    if (g.op === 'OR') {\n      const consumers = gates.filter(\n        (c) => c.in1 === g.out || c.in2 === g.out\n      );\n      for (const c of consumers) {\n        if (c.op === 'OR') {\n          // Carry should not feed into OR\n          swapped.add(g.out);\n        }\n      }\n    }\n  }\n\n  // If we've found exactly 8, we're done. But if the rules above found\n  // fewer, we need additional analysis. Let's also try to trace the\n  // adder structure bit by bit and find mismatches.\n\n  if (swapped.size !== 8) {\n    // Fallback: trace the adder structure more carefully\n    // This handles edge cases the simple rules might miss\n    traceAdderStructure(gates, numBits, swapped, gateByOutput, findGate);\n  }\n\n  return [...swapped].sort();\n}\n\nfunction traceAdderStructure(\n  gates: Gate[],\n  numBits: number,\n  swapped: Set<string>,\n  gateByOutput: Map<string, Gate>,\n  findGate: (op: Gate['op'], in1: string, in2: string) => Gate | undefined\n): void {\n  let carry: string | undefined;\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const xWire = `x${String(bit).padStart(2, '0')}`;\n    const yWire = `y${String(bit).padStart(2, '0')}`;\n    const zWire = `z${String(bit).padStart(2, '0')}`;\n\n    if (bit === 0) {\n      // Half adder: XOR -> z00, AND -> carry\n      const xorGate = findGate('XOR', xWire, yWire);\n      const andGate = findGate('AND', xWire, yWire);\n      if (xorGate) {\n        if (xorGate.out !== zWire) {\n          swapped.add(xorGate.out);\n          swapped.add(zWire);\n        }\n        carry = andGate?.out;\n      }\n    } else {\n      if (!carry) break;\n\n      // Full adder:\n      // XOR(x, y) -> partial\n      const partialGate = findGate('XOR', xWire, yWire);\n      if (!partialGate) continue;\n\n      const partial = partialGate.out;\n\n      // XOR(partial, carry) -> z\n      let sumGate = findGate('XOR', partial, carry);\n      if (!sumGate) {\n        // The partial or carry wire might be swapped; try to find what\n        // produces this z and trace backwards\n        const zGate = gateByOutput.get(zWire);\n        if (zGate && zGate.op === 'XOR') {\n          // One of zGate's inputs should be carry; the other should be partial\n          // but isn't because of a s