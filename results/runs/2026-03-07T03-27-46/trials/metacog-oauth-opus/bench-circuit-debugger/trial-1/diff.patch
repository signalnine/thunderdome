 in1: 'x01', in2: 'y01', out: 'a01' },\n    81→      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n    82→      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    83→    ];\n    84→    const inputs = { x00: 1, x01: 1, y00: 1, y01: 1 };\n    85→    const result = simulate(gates, inputs);\n    86→    expect(result.z00).toBe(0);\n    87→    expect(result.z01).toBe(1);\n    88→    expect(result.z02).toBe(1);\n    89→  });\n    90→});\n    91→\n    92→describe('findSwappedWires', () => {\n    93→  /**\n    94→   * Build a correct N-bit ripple-carry adder circuit.\n    95→   * The final carry (from the highest bit) outputs to z(N).\n    96→   */\n    97→  function buildCorrectAdder(numBits: number): Gate[] {\n    98→    const gates: Gate[] = [];\n    99→    // Bit 0: half adder\n   100→    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n   101→    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n   102→\n   103→    for (let i = 1; i < numBits; i++) {\n   104→      const pad = String(i).padStart(2, '0');\n   105→      const prevPad = String(i - 1).padStart(2, '0');\n   106→      gates.push({ op: 'XOR', in1: `x${pad}`, in2: `y${pad}`, out: `t${pad}` });\n   107→      gates.push({ op: 'XOR', in1: `t${pad}`, in2: `c${prevPad}`, out: `z${pad}` });\n   108→      gates.push({ op: 'AND', in1: `x${pad}`, in2: `y${pad}`, out: `a${pad}` });\n   109→      gates.push({ op: 'AND', in1: `t${pad}`, in2: `c${prevPad}`, out: `b${pad}` });\n   110→      if (i === numBits - 1) {\n   111→        // Last bit: carry out becomes the final z output\n   112→        const finalZ = `z${String(numBits).padStart(2, '0')}`;\n   113→        gates.push({ op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: finalZ });\n   114→      } else {\n   115→        gates.push({ op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: `c${pad}` });\n   116→      }\n   117→    }\n   118→\n   119→    return gates;\n   120→  }\n   121→\n   122→  /**\n   123→   * Swap outputs of two gates.\n   124→   */\n   125→  function swapOutputs(gates: Gate[], out1: string, out2: string): void {\n   126→    const g1 = gates.find((g) => g.out === out1)!;\n   127→    const g2 = gates.find((g) => g.out === out2)!;\n   128→    g1.out = out2;\n   129→    g2.out = out1;\n   130→  }\n   131→\n   132→  /**\n   133→   * Verify a correct adder works before swapping.\n   134→   */\n   135→  function verifyAdder(numBits: number) {\n   136→    const gates = buildCorrectAdder(numBits);\n   137→    const maxVal = (1 << numBits) - 1;\n   138→    // Test a few values\n   139→    for (const [x, y] of [[0, 0], [1, 1], [maxVal, 1], [maxVal, maxVal]]) {\n   140→      const inputs: Record<string, number> = {};\n   141→      for (let i = 0; i < numBits; i++) {\n   142→        const pad = String(i).padStart(2, '0');\n   143→        inputs[`x${pad}`] = (x >> i) & 1;\n   144→        inputs[`y${pad}`] = (y >> i) & 1;\n   145→      }\n   146→      const result = simulate(gates, inputs);\n   147→      let z = 0;\n   148→      for (let i = 0; i <= numBits; i++) {\n   149→        const pad = String(i).padStart(2, '0');\n   150→        z += (result[`z${pad}`] || 0) << i;\n   151→      }\n   152→      expect(z).toBe(x + y);\n   153→    }\n   154→  }\n   155→\n   156→  it('should verify correct 4-bit adder', () => {\n   157→    verifyAdder(4);\n   158→  });\n   159→\n   160→  it('should verify correct 8-bit adder', () => {\n   161→    verifyAdder(8);\n   162→  });\n   163→\n   164→  it('should find swapped z and intermediate wires', () => {\n   165→    // Swaps where z outputs are swapped with intermediate wires.\n   166→    // These are always detectable because z wires have no consumers\n   167→    // while intermediate wires have consumers.\n   168→    const gates = buildCorrectAdder(10);\n   169→    swapOutputs(gates, 'z01', 'a01'); // z swapped with generate carry\n   170→    swapOutputs(gates, 'z03', 'b03'); // z swapped with propagate carry\n   171→    swapOutputs(gates, 'z05', 'c05'); // z swapped with carry out\n   172→    swapOutputs(gates, 'z07', 'a07'); // z swapped with generate carry\n   173→\n   174→    const result = findSwappedWires(gates);\n   175→    expect(result).toEqual(\n   176→      ['a01', 'a07', 'b03', 'c05', 'z01', 'z03', 'z05', 'z07'].sort()\n   177→    );\n   178→  });\n   179→\n   180→  it('should find swapped z and partial sum wires', () => {\n   181→    const gates = buildCorrectAdder(10);\n   182→    swapOutputs(gates, 'z02', 't02'); // z swapped with partial sum\n   183→    swapOutputs(gates, 'z04', 't04');\n   184→    swapOutputs(gates, 'z06', 'a06');\n   185→    swapOutputs(gates, 'z08', 'b08');\n   186→\n   187→    const result = findSwappedWires(gates);\n   188→    expect(result).toEqual(\n   189→      ['a06', 'b08', 't02', 't04', 'z02', 'z04', 'z06', 'z08'].sort()\n   190→    );\n   191→  });\n   192→\n   193→  it('should find swapped carry chain wires', () => {\n   194→    // Swaps between carry outputs and non-carry wires\n   195→    const gates = buildCorrectAdder(12);\n   196→    swapOutputs(gates, 'c01', 'a02'); // carry swapped with next bit's generate\n   197→    swapOutputs(gates, 'c05', 'b06'); // carry swapped with next bit's propagate\n   198→    swapOutputs(gates, 'z03', 't03'); // z swapped with partial\n   199→    swapOutputs(gates, 'z09', 'a09'); // z swapped with generate\n   200→\n   201→    const result = findSwappedWires(gates);\n   202→    expect(result).toEqual(\n   203→      ['a02', 'a09', 'b06', 'c01', 'c05', 't03', 'z03', 'z09'].sort()\n   204→    );\n   205→  });\n   206→\n   207→  it('should handle 45-bit adder within time limit', () => {\n   208→    const gates = buildCorrectAdder(45);\n   209→    swapOutputs(gates, 'z05', 'a05');\n   210→    swapOutputs(gates, 'z20', 't20');\n   211→    swapOutputs(gates, 'z35', 'b35');\n   212→    swapOutputs(gates, 'z44', 'a44');\n   213→\n   214→    const start = Date.now();\n   215→    const result = findSwappedWires(gates);\n   216→    const elapsed = Date.