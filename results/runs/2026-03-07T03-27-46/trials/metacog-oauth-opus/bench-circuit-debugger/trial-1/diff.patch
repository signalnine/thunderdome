 Rule 2: XOR(xNN, yNN) for N>0 should not output to z\n  // (it should produce a partial sum, not a final sum)\n  for (const g of gates) {\n    if (g.op === 'XOR' && isXYGate(g)) {\n      const bitNum = getBitNum(g);\n      if (bitNum > 0 && g.out.startsWith('z')) {\n        swapped.add(g.out);\n      }\n    }\n  }\n\n  // Rule 3: AND gate outputs (except x00 AND y00) should feed into OR gates only.\n  // If an AND output feeds into XOR, the AND's output is swapped.\n  for (const g of gates) {\n    if (g.op === 'AND' && !(isXYGate(g) && getBitNum(g) === 0)) {\n      for (const consumer of getConsumers(g.out)) {\n        if (consumer.op === 'XOR') {\n          swapped.add(g.out);\n        }\n      }\n    }\n  }\n\n  // Rule 4: XOR(xNN, yNN) outputs for N>0 should feed into XOR and AND, not OR.\n  for (const g of gates) {\n    if (g.op === 'XOR' && isXYGate(g) && getBitNum(g) > 0) {\n      for (const consumer of getConsumers(g.out)) {\n        if (consumer.op === 'OR') {\n          swapped.add(g.out);\n        }\n      }\n    }\n  }\n\n  // Rule 5: OR gate outputs should feed into XOR and AND (as carry to next bit),\n  // not into another OR.\n  for (const g of gates) {\n    if (g.op === 'OR') {\n      for (const consumer of getConsumers(g.out)) {\n        if (consumer.op === 'OR') {\n          swapped.add(g.out);\n        }\n      }\n    }\n  }\n\n  // If we haven't found 8 yet, use trace-based detection\n  if (swapped.size < 8) {\n    traceAdder(numBits, swapped, gateByOutput, findGate);\n  }\n\n  return [...swapped].sort();\n\n  function isXYGate(g: Gate): boolean {\n    return (\n      (g.in1.startsWith('x') && g.in2.startsWith('y')) ||\n      (g.in1.startsWith('y') && g.in2.startsWith('x'))\n    );\n  }\n\n  function getBitNum(g: Gate): number {\n    const w = g.in1.startsWith('x') || g.in1.startsWith('y') ? g.in1 : g.in2;\n    return parseInt(w.slice(1), 10);\n  }\n\n  function getConsumers(wire: string): Gate[] {\n    return gates.filter((g) => g.in1 === wire || g.in2 === wire);\n  }\n}\n\nfunction traceAdder(\n  numBits: number,\n  swapped: Set<string>,\n  gateByOutput: Map<string, Gate>,\n  findGate: (op: Gate['op'], in1: string, in2: string) => Gate | undefined\n): void {\n  let carry: string | undefined;\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const xWire = `x${String(bit).padStart(2, '0')}`;\n    const yWire = `y${String(bit).padStart(2, '0')}`;\n    const zWire = `z${String(bit).padStart(2, '0')}`;\n\n    if (bit === 0) {\n      // Half adder\n      const xorGate = findGate('XOR', xWire, yWire);\n      const andGate = findGate('AND', xWire, yWire);\n\n      if (xorGate && xorGate.out !== zWire) {\n        swapped.add(xorGate.out);\n        swapped.add(zWire);\n      }\n\n      if (andGate) {\n        carry = andGate.out;\n        // Carry from bit 0 should come from AND - check if it was swapped\n        // If it was swapped, it would already be detected by rule 3 above\n        // but we might need to adjust our carry tracking\n        if (swapped.has(carry)) {\n          // Find what it was swapped with by looking at what's wrong\n          const zGateProducer = gateByOutput.get(zWire);\n          if (zGateProducer && zGateProducer.op === 'XOR') {\n            // Check if one of the z01 gate's inputs is our carry\n            // If not, find the actual carry\n          }\n        }\n      }\n    } else {\n      if (!carry) break;\n\n      // Full adder: XOR(x, y) -> partial\n      const partialGate = findGate('XOR', xWire, yWire);\n      if (!partialGate) continue;\n\n      let partial = partialGate.out;\n\n      // If partial is already known to be swapped, we need to figure out\n      // what it was swapped WITH to use the correct wire name\n      if (swapped.has(partial)) {\n        // The partial was swapped. Find what the z-producing XOR gate\n        // actually uses as its non-carry input\n        const zProducer = gateByOutput.get(zWire);\n        if (zProducer && zProducer.op === 'XOR') {\n          const otherInput = zProducer.in1 === carry ? zProducer.in2 :\n                             zProducer.in2 === carry ? zProducer.in1 : undefined;\n          if (otherInput && otherInput !== partial) {\n            // The z-producer expects a wire that was swapped with our partial\n            swapped.add(otherInput);\n          }\n        }\n      }\n\n      // XOR(partial, carry) -> z\n      let sumGate = findGate('XOR', partial, carry);\n\n      if (!sumGate) {\n        // Can't find the expected sum gate. Either partial or carry is wrong.\n        // Check the z-producing gate\n        const zProducer = gateByOutput.get(zWire);\n        if (zProducer && zProducer.op === 'XOR') {\n          if (zProducer.in1 === carry || zProducer.in2 === carry) {\n            const otherInput = zProducer.in1 === carry ? zProducer.in2 : zProducer.in1;\n            if (otherInput !== partial) {\n              swapped.add(partial);\n              swapped.add(otherInput);\n              partial = otherInput;\n              sumGate = zProducer;\n            }\n          } else if (zProducer.in1 === partial || zProducer.in2 === partial) {\n            const otherInput = zProducer.in1 === partial ? zProducer.in2 : zProducer.in1;\n            if (otherInput !== carry) {\n              swapped.add(carry);\n              swapped.add(otherInput);\n              carry = otherInput;\n              sumGate = zProducer;\n            }\n          }\n        }\n      }\n\n      if (sumGate && sumGate.out !== zWire) {\n        swapped.add(sumGate.out);\n        swapped.add(zWire);\n      }\n\n      // AND(x, y) -> generate\n      const genGate = findGate('AND', xWire, yWire);\n      // AND(partial, carry) -> propagate\n      const propGate = findGate('AND', partial, carry);\n\n      if (genGate && propGate) {\n        const carryGate = findGate('OR', genGate.out, propGate.out);\n        if (carryGate) {\n          carry = carryGate.out;\n        }\n      }\n    }\n  }\n}\n","structuredPatch":