+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    const result = simulate(gates, { a: 1, b: 1, d: 0 });
+    expect(result.c).toBe(1);
+    expect(result.e).toBe(1);
+  });
+
+  it('should simulate a correct 2-bit adder: 1+1=2', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },
+    ];
+    const inputs = { x00: 1, x01: 0, y00: 1, y01: 0 };
+    const result = simulate(gates, inputs);
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(0);
+  });
+
+  it('should simulate a correct 2-bit adder: 3+3=6', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },
+    ];
+    const inputs = { x00: 1, x01: 1, y00: 1, y01: 1 };
+    const result = simulate(gates, inputs);
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(1);
+  });
+});
+
+describe('findSwappedWires', () => {
+  /**
+   * Build a correct N-bit ripple-carry adder circuit.
+   * The final carry (from the highest bit) outputs to z(N).
+   */
+  function buildCorrectAdder(numBits: number): Gate[] {
+    const gates: Gate[] = [];
+    // Bit 0: half adder
+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+    for (let i = 1; i < numBits; i++) {
+      const pad = String(i).padStart(2, '0');
+      const prevPad = String(i - 1).padStart(2, '0');
+      gates.push({ op: 'XOR', in1: `x${pad}`, in2: `y${pad}`, out: `t${pad}` });
+      gates.push({ op: 'XOR', in1: `t${pad}`, in2: `c${prevPad}`, out: `z${pad}` });
+      gates.push({ op: 'AND', in1: `x${pad}`, in2: `y${pad}`, out: `a${pad}` });
+      gates.push({ op: 'AND', in1: `t${pad}`, in2: `c${prevPad}`, out: `b${pad}` });
+      if (i === numBits - 1) {
+        // Last bit: carry out becomes the final z output
+        const finalZ = `z${String(numBits).padStart(2, '0')}`;
+        gates.push({ op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: finalZ });
+      } else {
+        gates.push({ op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: `c${pad}` });
+      }
+    }
+
+    return gates;
+  }
+
+  /**
+   * Swap outputs of two gates.
+   */
+  function swapOutputs(gates: Gate[], out1: string, out2: string): void {
+    const g1 = gates.find((g) => g.out === out1)!;
+    const g2 = gates.find((g) => g.out === out2)!;
+    g1.out = out2;
+    g2.out = out1;
+  }
+
+  /**
+   * Verify a correct adder works before swapping.
+   */
+  function verifyAdder(numBits: number) {
+    const gates = buildCorrectAdder(numBits);
+    const maxVal = (1 << numBits) - 1;
+    // Test a few values
+    for (const [x, y] of [[0, 0], [1, 1], [maxVal, 1], [maxVal, maxVal]]) {
+      const inputs: Record<string, number> = {};
+      for (let i = 0; i < numBits; i++) {
+        const pad = String(i).padStart(2, '0');
+        inputs[`x${pad}`] = (x >> i) & 1;
+        inputs[`y${pad}`] = (y >> i) & 1;
+      }
+      const result = simulate(gates, inputs);
+      let z = 0;
+      for (let i = 0; i <= numBits; i++) {
+        const pad = String(i).padStart(2, '0');
+        z += (result[`z${pad}`] || 0) << i;
+      }
+      expect(z).toBe(x + y);
+    }
+  }
+
+  it('should verify correct 4-bit adder', () => {
+    verifyAdder(4);
+  });
+
+  it('should verify correct 8-bit adder', () => {
+    verifyAdder(8);
+  });
+
+  it('should find swapped z and intermediate wires', () => {
+    // Swaps where z outputs are swapped with intermediate wires.
+    // These are always detectable because z wires have no consumers
+    // while intermediate wires have consumers.
+    const gates = buildCorrectAdder(10);
+    swapOutputs(gates, 'z01', 'a01'); // z swapped with generate carry
+    swapOutputs(gates, 'z03', 'b03'); // z swapped with propagate carry
+    swapOutputs(gates, 'z05', 'c05'); // z swapped with carry out
+    swapOutputs(gates, 'z07', 'a07'); // z swapped with generate carry
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a01', 'a07', 'b03', 'c05', 'z01', 'z03', 'z05', 'z07'].sort()
+    );
+  });
+
+  it('should find swapped z and partial sum wires', () => {
+    const gates = buildCorrectAdder(10);
+    swapOutputs(gates, 'z02', 't02'); // z swapped with partial sum
+    swapOutputs(gates, 'z04', 't04');
+    swapOutputs(gates, 'z06', 'a06');
+    swapOutputs(gates, 'z08', 'b08');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a06', 'b08', 't02', 't04', 'z02', 'z04', 'z06', 'z08'].sort()
+    );
+  });
+
+  it('should find swapped carry chain wires', () => {
+    // Swaps between carry outputs and non-carry wires
+    const gates = buildCorrectAdder(12);
+    swapOutputs(gates, 'c01', 'a02'); // carry swapped with next bit's generate
+    swapOutputs(gates, 'c05', 'b06'); // carry swapped with next bit's propagate
+    swapOutputs(gates, 'z03', 't03'); // z swapped with partial
+    swapOutputs(gates, 'z09', 'a09'); // z swapped with generate
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a02', 'a09', 'b06', 'c01', 'c05', 't03', 'z03', 'z09'].sort()
+    );
+  });
+
+  it('should handle 45-bit adder within time limit', () => {
+    const gates = buildCorrectAdder(45);
+    swapOutputs(gates, 'z05', 'a05');
+    swapOutputs(gates, 'z20', 't20');
+    swapOutputs(gates, 'z35', 'b35');
+    swapOutputs(gates, 'z44', 'a44');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(result).toEqual(
+      ['a05', 'a44', 'b35', 't20', 'z05', 'z20', 'z35', 'z44'].sort()
+    );
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('should handle swaps involving bit 0 carry', () => {
+    // c00 (bit 0 carry, from AND) swapped with a non-carry wire
+    const gates = buildCorrectAdder(8);
+    // c00 is consumed by XOR and AND for bit 1
+    // If we swap c00 with something that's consumed by OR (like a01),
+    // then c00 would feed into OR (wrong) and a01 would feed into XOR/AND (wrong)
+    swapOutputs(gates, 'c00', 'a01');
+    swapOutputs(gates, 'z03', 'a03');
+    swapOutputs(gates, 'z05', 'b05');
+    swapOutputs(gates, 'z07', 'a07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a01', 'a03', 'a07', 'b05', 'c00', 'z03', 'z05', 'z07'].sort()
+    );
+  });
+
+  it('should find swaps between non-z wires of different types', () => {
+    // Swap between generate carry and partial sum (different consumers)
+    const gates = buildCorrectAdder(12);
+    // t02 is consumed by XOR and AND; a03 is consumed by OR
+    // After swap: t02 goes to OR (wrong), a03 goes to XOR (wrong)
+    swapOutputs(gates, 't02', 'a03');
+    swapOutputs(gates, 'c04', 'b06');
+    swapOutputs(gates, 'z08', 'a08');
+    swapOutputs(gates, 'z10', 't10');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a03', 'a08', 'b06', 'c04', 't02', 't10', 'z08', 'z10'].sort()
+    );
+  });
+
+  it('should work with randomized wire names', () => {
+    // Build a 4-bit adder with random intermediate wire names
+    const gates: Gate[] = [];
+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'abc' }); // c00 = abc
+
+    gates.push({ op: 'XOR', in1: 'x01', in2: 'y01', out: 'def' }); // t01 = def
+    gates.push({ op: 'XOR', in1: 'def', in2: 'abc', out: 'z01' });
+    gates.push({ op: 'AND', in1: 'x01', in2: 'y01', out: 'ghi' }); // a01 = ghi
+    gates.push({ op: 'AND', in1: 'def', in2: 'abc', out: 'jkl' }); // b01 = jkl
+    gates.push({ op: 'OR', in1: 'ghi', in2: 'jkl', out: 'mno' }); // c01 = mno
+
+    gates.push({ op: 'XOR', in1: 'x02', in2: 'y02', out: 'pqr' }); // t02 = pqr
+    gates.push({ op: 'XOR', in1: 'pqr', in2: 'mno', out: 'z02' });
+    gates.push({ op: 'AND', in1: 'x02', in2: 'y02', out: 'stu' }); // a02 = stu
+    gates.push({ op: 'AND', in1: 'pqr', in2: 'mno', out: 'vwx' }); // b02 = vwx
+    gates.push({ op: 'OR', in1: 'stu', in2: 'vwx', out: 'yza' }); // c02 = yza
+
+    gates.push({ op: 'XOR', in1: 'x03', in2: 'y03', out: 'bcd' }); // t03 = bcd
+    gates.push({ op: 'XOR', in1: 'bcd', in2: 'yza', out: 'z03' });
+    gates.push({ op: 'AND', in1: 'x03', in2: 'y03', out: 'efg' }); // a03 = efg
+    gates.push({ op: 'AND', in1: 'bcd', in2: 'yza', out: 'hij' }); // b03 = hij
+    gates.push({ op: 'OR', in1: 'efg', in2: 'hij', out: 'z04' }); // c03 = z04 (final carry)
+
+    // Swap z01 with ghi (a01): z comes from AND (wrong), ghi becomes non-z XOR output (wrong)
+    swapOutputs(gates, 'z01', 'ghi');
+    // Swap z03 with hij (b03): z comes from AND (wrong), hij becomes non-z XOR output (wrong)
+    swapOutputs(gates, 'z03', 'hij');
+    // Swap pqr (t02, partial sum consumed by XOR+AND) with efg (a03, consumed by OR)
+    swapOutputs(gates, 'pqr', 'efg');
+    // Swap abc (c00, consumed by XOR+AND) with stu (a02, consumed by OR)
+    swapOutputs(gates, 'abc', 'stu');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['abc', 'efg', 'ghi', 'hij', 'pqr', 'stu', 'z01', 'z03'].sort()
+    );
+  });
+});
