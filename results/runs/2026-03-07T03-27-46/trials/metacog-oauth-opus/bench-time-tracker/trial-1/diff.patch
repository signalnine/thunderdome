inalFile":"import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\nimport { TimeTracker } from \"./tracker.js\";\nimport { existsSync, rmSync, readFileSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";\n\nfunction tempFile(): string {\n  return join(\n    tmpdir(),\n    `time-tracker-test-${Date.now()}-${Math.random().toString(36).slice(2)}.json`\n  );\n}\n\ndescribe(\"TimeTracker\", () => {\n  let filePath: string;\n  let tracker: TimeTracker;\n\n  beforeEach(() => {\n    filePath = tempFile();\n    tracker = new TimeTracker({ filePath });\n  });\n\n  afterEach(() => {\n    if (existsSync(filePath)) {\n      rmSync(filePath);\n    }\n  });\n\n  describe(\"start/stop\", () => {\n    it(\"should start a timer\", () => {\n      const entry = tracker.start(\"coding\");\n      expect(entry.task).toBe(\"coding\");\n      expect(entry.start).toBeTruthy();\n      expect(entry.stop).toBeNull();\n    });\n\n    it(\"should stop a running timer\", () => {\n      tracker.start(\"coding\");\n      const entry = tracker.stop();\n      expect(entry.task).toBe(\"coding\");\n      expect(entry.stop).toBeTruthy();\n    });\n\n    it(\"should throw when starting with empty name\", () => {\n      expect(() => tracker.start(\"\")).toThrow(\"Task name must not be empty\");\n      expect(() => tracker.start(\"  \")).toThrow(\"Task name must not be empty\");\n    });\n\n    it(\"should throw when stopping with nothing running\", () => {\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n\n    it(\"should auto-stop previous timer when starting new one\", () => {\n      tracker.start(\"task-a\");\n      tracker.start(\"task-b\");\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(2);\n      expect(entries[0].task).toBe(\"task-a\");\n      expect(entries[0].stop).toBeTruthy();\n      expect(entries[1].task).toBe(\"task-b\");\n      expect(entries[1].stop).toBeNull();\n    });\n  });\n\n  describe(\"persistence\", () => {\n    it(\"should persist entries to a JSON file\", () => {\n      tracker.start(\"coding\");\n      tracker.stop();\n      expect(existsSync(filePath)).toBe(true);\n      const raw = readFileSync(filePath, \"utf-8\");\n      const data = JSON.parse(raw);\n      expect(data.entries).toHaveLength(1);\n    });\n\n    it(\"should load entries from file on construction\", () => {\n      tracker.start(\"coding\");\n      tracker.stop();\n\n      const tracker2 = new TimeTracker({ filePath });\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe(\"coding\");\n    });\n\n    it(\"should create parent directories if they don't exist\", () => {\n      const nested = join(\n        tmpdir(),\n        `tt-test-${Date.now()}`,\n        \"sub\",\n        \"data.json\"\n      );\n      const t = new TimeTracker({ filePath: nested });\n      t.start(\"test\");\n      t.stop();\n      expect(existsSync(nested)).toBe(true);\n      // cleanup\n      rmSync(join(tmpdir(), `tt-test-${nested.split(\"tt-test-\")[1].split(\"/\")[0]}`), {\n        recursive: true,\n      });\n    });\n  });\n\n  describe(\"getEntries\", () => {\n    it(\"should return all entries\", () => {\n      tracker.start(\"a\");\n      tracker.stop();\n      tracker.start(\"b\");\n      tracker.stop();\n      expect(tracker.getEntries()).toHaveLength(2);\n    });\n\n    it(\"should return a copy (not a reference)\", () => {\n      tracker.start(\"a\");\n      tracker.stop();\n      const entries = tracker.getEntries();\n      entries.pop();\n      expect(tracker.getEntries()).toHaveLength(1);\n    });\n  });\n\n  describe(\"getEntriesByDateRange\", () => {\n    it(\"should filter entries by date range\", () => {\n      tracker.start(\"old-task\");\n      tracker.stop();\n\n      const from = new Date();\n      tracker.start(\"new-task\");\n      tracker.stop();\n      const to = new Date();\n\n      const filtered = tracker.getEntriesByDateRange(from, to);\n      expect(filtered).toHaveLength(1);\n      expect(filtered[0].task).toBe(\"new-task\");\n    });\n  });\n\n  describe(\"getSummary\", () => {\n    it(\"should summarize time per task\", () => {\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"review\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThanOrEqual(0);\n      expect(summary[\"review\"]).toBeGreaterThanOrEqual(0);\n    });\n\n    it(\"should include running tasks using current time\", () => {\n      tracker.start(\"running-task\");\n      const summary = tracker.getSummary();\n      expect(summary[\"running-task\"]).toBeGreaterThanOrEqual(0);\n    });\n  });\n\n  describe(\"unicode support\", () => {\n    it(\"should handle emoji task names\", () => {\n      tracker.start(\"🚀 Deploy\");\n      tracker.stop();\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe(\"🚀 Deploy\");\n    });\n\n    it(\"should handle unicode characters\", () => {\n      tracker.start(\"café ñ 日本語\");\n      tracker.stop();\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe(\"café ñ 日本語\");\n\n      // Verify persistence preserves unicode\n      const tracker2 = new TimeTracker({ filePath });\n      expect(tracker2.getEntries()[0].task).toBe(\"café ñ 日本語\");\n    });\n\n    it(\"should handle complex emoji sequences\", () => {\n      tracker.start(\"👨‍👩‍👧‍👦 Family time\");\n      tracker.stop();\n      expect(tracker.getEntries()[0].task).toBe(\"👨‍👩‍👧‍👦 Family time\");\n    });\n  });\n\n  describe(\"isRunning / getRunning\", () => {\n    it(\"should report running state\", () => {\n      expect(tracker.isRunning()).toBe(false);\n      tracker.start(\"task\");\n      expect(tracker.isRunning()).toBe(true);\n      tracker.stop();\n      expect(tracker.isRunning()).toBe(false);\n    });\n\n    it(\"should return running entry or null\", () => {\n      expect(tracker.getRunning()).toBeNull();\n      tracker.start(\"task\");\n      const running = tracker.getRunning();\n      expect(running?.task).toBe(\"task\");\n    });\n  });\n});\n","structuredPatch":[{"oldStart":120,"oldLines":15,"newStart":120,"newLines":28,"lines":[" ","   describe(\"getEntriesByDateRange\", () => {","     it(\"should filter entries by date range\", () => {","+      // Manually create entries with known timestamps","+      const past = new Date(\"2020-01-01T00:00:00Z\");","+      const recent = new Date(\"2024-06-15T12:00:00Z\");","+","       tracker.start(\"old-task\");","       tracker.stop();","-","-      const from = new Date();","       tracker.start(\"new-task\");","       tracker.stop();","-      const to = new Date();"," ","-      const filtered = tracker.getEntriesByDateRange(from, to);","+      // Overwrite with known timestamps via re-loading","+      const entries = tracker.getEntries();","+      entries[0].start = past.toISOString();","+      entries[1].start = recent.toISOString();","+","+      // Write directly and reload","+      const { writeFileSync } = await import(\"node:fs\");","+      writeFileSync(filePath, JSON.stringify({ entries }, null, 2), \"utf-8\");","+      const tracker2 = new TimeTracker({ filePath });","+","+      const from = new Date(\"2024-01-01T00:00:00Z\");","+      const to = new Date(\"2024-12-31T23:59:59Z\");","+      const filtered = tracker2.getEntriesByDateRange(from, to);","       expect(filtered).toHaveLength(1);","       expect(filtered[0].task).toBe(\"new-task\");","     });"]}],"userModified":false,"replaceAll":false}}
