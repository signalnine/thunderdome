--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,148 @@
+import { readFileSync, writeFileSync, mkdirSync, existsSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string; // ISO 8601
+  stop: string | null; // ISO 8601 or null if still running
+}
+
+interface StoreData {
+  entries: TimeEntry[];
+}
+
+export interface TimeTrackerOptions {
+  filePath: string;
+}
+
+export class TimeTracker {
+  private readonly filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(options: TimeTrackerOptions) {
+    this.filePath = options.filePath;
+    this.entries = this.load();
+  }
+
+  /**
+   * Start a timer for the given task name.
+   * If another timer is running, it is stopped first.
+   */
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name must not be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    };
+
+    this.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  /**
+   * Stop the currently running timer.
+   */
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  /**
+   * Get all time entries.
+   */
+  getEntries(): TimeEntry[] {
+    return [...this.entries];
+  }
+
+  /**
+   * Get entries filtered by date range.
+   * Both `from` and `to` are inclusive bounds compared against the entry start time.
+   */
+  getEntriesByDateRange(from: Date, to: Date): TimeEntry[] {
+    const fromTime = from.getTime();
+    const toTime = to.getTime();
+
+    return this.entries.filter((entry) => {
+      const startTime = new Date(entry.start).getTime();
+      return startTime >= fromTime && startTime <= toTime;
+    });
+  }
+
+  /**
+   * Get a summary of total time spent per task name in milliseconds.
+   * Running tasks use the current time for their duration.
+   */
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+
+    for (const entry of this.entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop ? new Date(entry.stop).getTime() : Date.now();
+      const duration = end - start;
+
+      summary[entry.task] = (summary[entry.task] ?? 0) + duration;
+    }
+
+    return summary;
+  }
+
+  /**
+   * Check if a timer is currently running.
+   */
+  isRunning(): boolean {
+    return this.getRunningEntry() !== null;
+  }
+
+  /**
+   * Get the currently running entry, or null.
+   */
+  getRunning(): TimeEntry | null {
+    const running = this.getRunningEntry();
+    return running ? { ...running } : null;
+  }
+
+  private getRunningEntry(): TimeEntry | null {
+    return this.entries.find((e) => e.stop === null) ?? null;
+  }
+
+  private load(): TimeEntry[] {
+    if (!existsSync(this.filePath)) {
+      return [];
+    }
+
+    try {
+      const raw = readFileSync(this.filePath, "utf-8");
+      const data: StoreData = JSON.parse(raw) as StoreData;
+      return Array.isArray(data.entries) ? data.entries : [];
+    } catch {
+      return [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    if (!existsSync(dir)) {
+      mkdirSync(dir, { recursive: true });
+    }
+
+    const data: StoreData = { entries: this.entries };
+    writeFileSync(this.filePath, JSON.stringify(data, null, 2), "utf-8");
+  }
+}
