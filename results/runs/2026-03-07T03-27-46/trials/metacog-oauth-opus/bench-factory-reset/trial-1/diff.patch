);\n\n  it('handles no buttons case', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('handles no lights case', () => {\n    const result = solveToggle({\n      target: [],\n      buttons: [[0], [1]],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('solves with overlapping buttons', () => {\n    const result = solveToggle({\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2], [0, 2]],\n    });\n    expect(result).toEqual([2]);\n    expect(verifyToggle([true, false, true], [[0, 1], [1, 2], [0, 2]], result!)).toBe(true);\n  });\n\n  it('handles single button single light', () => {\n    expect(solveToggle({ target: [true], buttons: [[0]] })).toEqual([0]);\n    expect(solveToggle({ target: [false], buttons: [[0]] })).toEqual([]);\n  });\n\n  it('handles cancelling buttons', () => {\n    // Two buttons both toggle light 0. Pressing both cancels out.\n    const result = solveToggle({\n      target: [false],\n      buttons: [[0], [0]],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('returns sorted result', () => {\n    const result = solveToggle({\n      target: [true, true, true],\n      buttons: [[2], [0], [1]],\n    });\n    expect(result).toEqual([0, 1, 2]);\n  });\n\n  it('solves a larger case', () => {\n    // 10 lights, 10 buttons, each button toggles one light\n    const buttons = Array.from({ length: 10 }, (_, i) => [i]);\n    const target = Array.from({ length: 10 }, (_, i) => i % 2 === 0);\n    const result = solveToggle({ target, buttons });\n    expect(result).not.toBeNull();\n    expect(verifyToggle(target, buttons, result!)).toBe(true);\n  });\n});\n\n// ─── Part 2: Counter ───\n\ndescribe('solveCounter', () => {\n  it('solves a simple case', () => {\n    const result = solveCounter([1, 2], [[0], [1]], 3);\n    expect(result).toEqual([1, 2]);\n  });\n\n  it('returns null for impossible case', () => {\n    const result = solveCounter([1], [], 3);\n    expect(result).toBeNull();\n  });\n\n  it('returns all zeros when target is all zero', () => {\n    const result = solveCounter([0, 0], [[0], [1]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('handles modular wrapping', () => {\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('finds minimum total presses with lex tiebreak', () => {\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('solves overlapping buttons', () => {\n    const result = solveCounter([1, 2], [[0, 1], [1]], 3);\n    expect(result).toEqual([1, 1]);\n    expect(verifyCounter([1, 2], [[0, 1], [1]], 3, result!)).toBe(true);\n  });\n\n  it('handles single button single counter', () => {\n    expect(solveCounter([0], [[0]], 7)).toEqual([0]);\n    expect(solveCounter([5], [[0]], 7)).toEqual([5]);\n  });\n\n  it('returns null when impossible', () => {\n    // Button doesn't affect the counter we need to change\n    const result = solveCounter([1, 0], [[1]], 3);\n    expect(result).toBeNull();\n  });\n\n  it('solves a larger case', () => {\n    const buttons = Array.from({ length: 10 }, (_, i) => [i]);\n    const lights = Array.from({ length: 10 }, (_, i) => (i * 3) % 7);\n    const result = solveCounter(lights, buttons, 7);\n    expect(result).not.toBeNull();\n    expect(verifyCounter(lights, buttons, 7, result!)).toBe(true);\n  });\n\n  it('handles modulus 2 (equivalent to toggle)', () => {\n    // With mod 2, this is like toggle\n    const result = solveCounter([1, 1, 0], [[0], [1], [2]], 2);\n    expect(result).toEqual([1, 1, 0]);\n    expect(verifyCounter([1, 1, 0], [[0], [1], [2]], 2, result!)).toBe(true);\n  });\n\n  it('handles large prime modulus', () => {\n    const result = solveCounter([50], [[0]], 97);\n    expect(result).toEqual([50]);\n  });\n});\n\n// ─── Performance ───\n\ndescribe('performance', () => {\n  it('handles 40x40 toggle within time limit', () => {\n    const n = 40;\n    const buttons: number[][] = [];\n    for (let j = 0; j < n; j++) {\n      const affected: number[] = [];\n      for (let i = 0; i < n; i++) {\n        if ((i + j) % 3 === 0 || i === j) {\n          affected.push(i);\n        }\n      }\n      buttons.push(affected);\n    }\n    const target = Array.from({ length: n }, (_, i) => i % 2 === 0);\n\n    const start = Date.now();\n    const result = solveToggle({ target, buttons });\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    if (result !== null) {\n      expect(verifyToggle(target, buttons, result)).toBe(true);\n    }\n  });\n\n  it('handles 40x40 counter within time limit', () => {\n    const n = 40;\n    const buttons: number[][] = [];\n    for (let j = 0; j < n; j++) {\n      const affected: number[] = [];\n      for (let i = 0; i < n; i++) {\n        if ((i + j) % 3 === 0 || i === j) {\n          affected.push(i);\n        }\n      }\n      buttons.push(affected);\n    }\n    const lights = Array.from({ length: n }, (_, i) => (i * 7 + 3) % 97);\n\n    const start = Date.now();\n    const result = solveCounter(lights, buttons, 97);\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    if (result !== null) {\n      expect(verifyCounter(lights, buttons, 97, result)).toBe(true);\n    }\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":468,"cache_read_input_tokens":72563,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":468},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b77e75dc-439b-4a4b-9d58-6c5fadeedc9f","uuid":"43b5b512-a249-4258-87cc-075a6201f378"}
