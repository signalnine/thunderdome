+
+  it('returns null when impossible', () => {
+    // Button doesn't affect the counter we need to change
+    const result = solveCounter([1, 0], [[1]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('solves a larger case', () => {
+    const buttons = Array.from({ length: 10 }, (_, i) => [i]);
