+  //   [0, 3] vs [1, 2]: compare first elements: 0 < 1, so [0,3] wins.
+  //   In bits: 0b1001 vs 0b0110. Lowest differing bit is bit 0 (set in a).
+  //   a has it → a < b. So: lowest diff bit set in a means a < b.
+  const diff = a ^ b;
+  if (diff === 0n) return 0;
+  // Find lowest set bit in diff
+  const lowestDiff = diff & (-diff);
+  // If a has this bit set, a < b (a has smaller element at first difference)
+  return (a & lowestDiff) ? -1 : 1;
+}
+
+function enumMinWeight(particular: bigint, basis: bigint[], m: number): number[] {
+  const k = basis.length;
+  let best = particular;
+  const total = 1 << k;
+
+  for (let mask = 1; mask < total; mask++) {
+    let candidate = particular;
+    for (let i = 0; i < k; i++) {
+      if (mask & (1 << i)) {
+        candidate ^= basis[i];
+      }
+    }
+    if (compareSolutions(candidate, best, m) < 0) {
+      best = candidate;
+    }
+  }
+
+  return bitmaskToSorted(best, m);
+}
+
+function greedyMinWeight(particular: bigint, basis: bigint[], m: number): number[] {
+  const k = basis.length;
+  let best = particular;
+
+  // Greedy coordinate descent: repeatedly try toggling each basis vector
+  for (let iter = 0; iter < 5; iter++) {
+    let improved = false;
+    for (let i = 0; i < k; i++) {
+      const candidate = best ^ basis[i];
+      if (compareSolutions(candidate, best, m) < 0) {
+        best = candidate;
+        improved = true;
+      }
+    }
+    if (!improved) break;
+  }
+
+  return bitmaskToSorted(best, m);
+}
+
+// ─── Part 2: Counter Puzzle (GF(p)) ───
+
+function mod(a: number, p: number): number {
+  return ((a % p) + p) % p;
+}
+
+function modPow(base: number, exp: number, p: number): number {
+  let result = 1;
+  base = mod(base, p);
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % p;
+    exp >>= 1;
+    base = (base * base) % p;
+  }
+  return result;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+
+  if (n === 0) return new Array(m).fill(0);
+  if (m === 0) {
+    return lights.some(l => l !== 0) ? null : [];
+  }
+
+  // Build augmented matrix over GF(modulus)
+  const rows: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[m] = mod(lights[i], modulus);
+    rows.push(row);
+  }
+
+  // Precompute modular inverses
+  const inv = new Array(modulus).fill(0);
+  for (let a = 1; a < modulus; a++) {
+    inv[a] = modPow(a, modulus - 2, modulus);
+  }
+
+  // Gaussian elimination to RREF
+  const pivotRow: number[] = new Array(m).fill(-1);
+  let currentRow = 0;
+
+  for (let col = 0; col < m && currentRow < n; col++) {
+    let found = -1;
+    for (let r = currentRow; r < n; r++) {
+      if (rows[r][col] !== 0) {
+        found = r;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [rows[currentRow], rows[found]] = [rows[found], rows[currentRow]];
+    pivotRow[col] = currentRow;
+
+    const scale = inv[rows[currentRow][col]];
+    for (let c = col; c <= m; c++) {
+      rows[currentRow][c] = (rows[currentRow][c] * scale) % modulus;
+    }
+
+    for (let r = 0; r < n; r++) {
+      if (r !== currentRow && rows[r][col] !== 0) {
+        const factor = rows[r][col];
+        for (let c = col; c <= m; c++) {
+          rows[r][c] = mod(rows[r][c] - factor * rows[currentRow][c], modulus);
+        }
+      }
+    }
+    currentRow++;
+  }
+
+  const pivotCols: number[] = [];
+  const freeCols: number[] = [];
+  for (let col = 0; col < m; col++) {
+    if (pivotRow[col] !== -1) {
+      pivotCols.push(col);
+    } else {
+      freeCols.push(col);
+    }
+  }
+
+  // Check consistency
+  for (let r = currentRow; r < n; r++) {
+    if (rows[r][m] !== 0) {
+      return null;
+    }
+  }
+
+  const numFree = freeCols.length;
+
+  if (numFree === 0) {
+    const result = new Array(m).fill(0);
+    for (const col of pivotCols) {
+      result[col] = rows[pivotRow[col]][m];
+    }
+    return result;
+  }
+
+  // For GF(p) with free variables, enumerate p^numFree if feasible
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  if (totalCombinations <= 5_000_000) {
+    return enumMinSumCounter(rows, pivotCols, freeCols, pivotRow, m, modulus, numFree, totalCombinations);
+  }
+
+  // For large search spaces, use meet-in-the-middle or coordinate descent
+  if (numFree <= 10 || modulus <= 5) {
+    // Meet-in-the-middle for GF(p)
+    return meetInMiddleCounter(rows, pivotCols, freeCols, pivotRow, m, modulus);
+  }
+
+  return coordinateDescentCounter(rows, pivotCols, freeCols, pivotRow, m, modulus);
+}
+
+function enumMinSumCounter(
+  rows: number[][],
+  pivotCols: number[],
+  freeCols: number[],
+  pivotRow: number[],
+  m: number,
+  modulus: number,
+  numFree: number,
+  totalCombinations: number
+): number[] {
+  let bestResult: number[] | null = null;
+  let bestSum = Infinity;
+
+  const freeVals = new Array(numFree).fill(0);
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    let temp = combo;
+    for (let i = numFree - 1; i >= 0; i--) {
+      freeVals[i] = temp % modulus;
+      temp = Math.floor(temp / modulus);
+    }
+
+    const result = new Array(m).fill(0);
+    let sum = 0;
+    for (let i = 0; i < numFree; i++) {
+      result[freeCols[i]] = freeVals[i];
+      sum += freeVals[i];
+    }
+
+    if (sum > bestSum) continue; // Early prune: free vars alone exceed best
+
+    for (const col of pivotCols) {
+      const r = pivotRow[col];
+      let val = rows[r][m];
+      for (let i = 0; i < numFree; i++) {
+        val = mod(val - rows[r][freeCols[i]] * freeVals[i], modulus);
+      }
+      result[col] = val;
+      sum += val;
+    }
+
+    if (sum < bestSum || (sum === bestSum && lexSmallerArr(result, bestResult!))) {
+      bestSum = sum;
+      bestResult = [...result];
+    }
+  }
+
+  return bestResult!;
+}
+
+function meetInMiddleCounter(
+  rows: number[][],
+  pivotCols: number[],
+  freeCols: number[],
+  pivotRow: number[],
+  m: number,
+  modulus: number
+): number[] {
+  // Split free variables into two halves and enumerate each half
+  const numFree = freeCols.length;
+  const half1 = Math.floor(numFree / 2);
+  const half2 = numFree - half1;
+
+  // For first half: compute partial contribution to each pivot variable
+  // and the sum of free vars in this half
+  const firstHalfSize = Math.pow(modulus, half1);
+  const firstHalfData: { freeVals: number[], sum: number }[] = [];
+
+  for (let combo = 0; combo < firstHalfSize; combo++) {
+    const freeVals = new Array(half1).fill(0);
+    let temp = combo;
+    for (let i = half1 - 1; i >= 0; i--) {
+      freeVals[i] = temp % modulus;
+      temp = Math.floor(temp / modulus);
+    }
+    const sum = freeVals.reduce((a, b) => a + b, 0);
+    firstHalfData.push({ freeVals, sum });
+  }
+
+  let bestResult: number[] | null = null;
+  let bestSum = Infinity;
+
+  const secondHalfSize = Math.pow(modulus, half2);
+  for (let combo2 = 0; combo2 < secondHalfSize; combo2++) {
+    const freeVals2 = new Array(half2).fill(0);
+    let temp = combo2;
+    for (let i = half2 - 1; i >= 0; i--) {
+      freeVals2[i] = temp % modulus;
+      temp = Math.floor(temp / modulus);
+    }
+    const sum2 = freeVals2.reduce((a, b) => a + b, 0);
+
+    for (let idx1 = 0; idx1 < firstHalfSize; idx1++) {
+      const { freeVals: freeVals1, sum: sum1 } = firstHalfData[idx1];
+      const totalFreeSum = sum1 + sum2;
+      if (totalFreeSum > bestSum) continue;
+
+      // Compute full solution
+      const allFreeVals = [...freeVals1, ...freeVals2];
+      const result = new Array(m).fill(0);
+      for (let i = 0; i < numFree; i++) {
+        result[freeCols[i]] = allFreeVals[i];
+      }
+
+      let sum = totalFreeSum;
+      for (const col of pivotCols) {
+        const r = pivotRow[col];
+        let val = rows[r][m];
+        for (let i = 0; i < numFree; i++) {
+          val = mod(val - rows[r][freeCols[i]] * allFreeVals[i], modulus);
+        }
+        result[col] = val;
+        sum += val;
+      }
+
+      if (sum < bestSum || (sum === bestSum && lexSmallerArr(result, bestResult!))) {
+        bestSum = sum;
+        bestResult = [...result];
+      }
+    }
+  }
+
+  return bestResult!;
+}
+
+function coordinateDescentCounter(
+  rows: number[][],
+  pivotCols: number[],
+  freeCols: number[],
+  pivotRow: number[],
+  m: number,
+  modulus: number
+): number[] {
+  const numFree = freeCols.length;
+
+  let bestResult = computeSolution(rows, pivotCols, freeCols, pivotRow, m, modulus, new Array(numFree).fill(0));
+  let bestSum = bestResult.reduce((a, b) => a + b, 0);
+
+  for (let iter = 0; iter < 5; iter++) {
+    let improved = false;
+    for (let i = 0; i < numFree; i++) {
+      const currentFreeVals = freeCols.map(c => bestResult[c]);
+      for (let v = 0; v < modulus; v++) {
+        if (v === currentFreeVals[i]) continue;
+        const testFreeVals = [...currentFreeVals];
+        testFreeVals[i] = v;
+        const result = computeSolution(rows, pivotCols, freeCols, pivotRow, m, modulus, testFreeVals);
+        const sum = result.reduce((a, b) => a + b, 0);
+        if (sum < bestSum || (sum === bestSum && lexSmallerArr(result, bestResult))) {
+          bestSum = sum;
+          bestResult = result;
+          improved = true;
+        }
+      }
+    }
+    if (!improved) break;
+  }
+
+  return bestResult;
+}
+
+function computeSolution(
+  rows: number[][],
+  pivotCols: number[],
+  freeCols: number[],
+  pivotRow: number[],
+  m: number,
+  modulus: number,
+  freeVals: number[]
+): number[] {
+  const result = new Array(m).fill(0);
+  for (let i = 0; i < freeCols.length; i++) {
+    result[freeCols[i]] = freeVals[i];
+  }
+  for (const col of pivotCols) {
+    const r = pivotRow[col];
+    let val = rows[r][m];
+    for (let i = 0; i < freeCols.length; i++) {
+      val = mod(val - rows[r][freeCols[i]] * freeVals[i], modulus);
+    }
+    result[col] = val;
+  }
+  return result;
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
