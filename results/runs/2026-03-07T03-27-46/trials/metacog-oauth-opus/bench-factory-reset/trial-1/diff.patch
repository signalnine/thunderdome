+    expect(verifyCounter([1, 1, 0], [[0], [1], [2]], 2, result!)).toBe(true);
+  });
+
+  it('handles large prime modulus', () => {
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+  });
+});
