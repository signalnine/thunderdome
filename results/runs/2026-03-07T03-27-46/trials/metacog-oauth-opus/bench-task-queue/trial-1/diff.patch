reateQueue(name: string): QueueState {\n    let queue = this.queues.get(name);\n    if (!queue) {\n      queue = {\n        tasks: new Map(),\n        insertionOrder: 0,\n        insertionMap: new Map(),\n        deadLetterQueue: [],\n        concurrencyLimit: null,\n        middlewares: [],\n        handler: null,\n      };\n      this.queues.set(name, queue);\n    }\n    return queue;\n  }\n\n  private getQueue(name: string): QueueState | undefined {\n    return this.queues.get(name);\n  }\n\n  private getActiveCount(queueName: string): number {\n    const queue = this.getQueue(queueName);\n    if (!queue) return 0;\n    let count = 0;\n    for (const task of queue.tasks.values()) {\n      if (task.status === 'processing') count++;\n    }\n    return count;\n  }\n\n  private isTaskBlocked(task: Task): boolean {\n    if (task.dependencies.length === 0) return false;\n    for (const depId of task.dependencies) {\n      if (!task.resolvedDependencies.has(depId)) {\n        return true;\n      }\n    }\n    return false;\n  }\n\n  private resolveDependency(completedTaskId: string): void {\n    for (const task of this.allTasks.values()) {\n      if (task.dependencies.includes(completedTaskId)) {\n        task.resolvedDependencies.add(completedTaskId);\n      }\n    }\n  }\n\n  private detectCircularDeps(taskId: string, dependencies: string[], visited: Set<string> = new Set()): boolean {\n    if (visited.has(taskId)) return true;\n    visited.add(taskId);\n    for (const depId of dependencies) {\n      const depTask = this.allTasks.get(depId);\n      if (depTask) {\n        if (this.detectCircularDeps(taskId, depTask.dependencies, new Set(visited))) {\n          return true;\n        }\n      }\n    }\n    return false;\n  }\n\n  private wouldCreateCycle(newTaskId: string, dependencies: string[]): boolean {\n    // Check if any dependency eventually depends back on newTaskId\n    // Since newTaskId is new, we check if any dep's transitive deps include any task\n    // that depends on newTaskId. But since newTaskId is new, no existing task can depend on it.\n    // So we only need to check: do any of the dependencies form a cycle among themselves?\n    // Actually, we also need to check: do tasks that depend on us (none yet since new) ...\n    // For a new task, cycle detection means: can we reach newTaskId from any of the deps?\n    // Since newTaskId isn't in the graph yet, the answer is always no for a new task.\n    // But we should check for cycles among the provided dependencies themselves.\n\n    // Actually the real check is: do any of the tasks that we'll eventually unblock\n    // already transitively depend on one of our dependencies?\n    // Since this task is new, no one depends on it yet. So no cycle from a new task.\n    // However, we should also think about: what if dep A depends on dep B and dep B depends on dep A?\n    // That's not our problem to detect here - that would have been caught when they were created.\n\n    // The main cycle case: task depends on itself\n    if (dependencies.includes(newTaskId)) return true;\n\n    // For existing tasks that we depend on: check if they (transitively) depend on each other\n    // in a way that would create a cycle. But again, since we're new, no cycle is possible\n    // unless we depend on ourselves.\n\n    // Wait - there's another case: what if we're adding task C that depends on B,\n    // and later someone adds task D that depends on C and A, where A depends on D?\n    // That would be caught when D is added. So for a new task, we only need to\n    // worry about self-dependency.\n\n    // Actually re-reading the requirements: \"Circular dependencies (direct or indirect)\n    // must be detected and rejected at task-creation time.\"\n    // This means we need to check the FULL dependency graph.\n    // Since this is a new task, the only way to have a cycle is if it depends on itself.\n    // No existing task can reference this new task's ID since it hasn't been created yet.\n\n    return false;\n  }\n\n  // ---- Phase 1: Basic FIFO Queue ----\n\n  addTask<T = unknown>(payload: T, options?: TaskOptions): Task<T>;\n  addTask<T = unknown>(payload: T, queueName?: string, options?: TaskOptions): Task<T>;\n  addTask<T = unknown>(payload: T, queueNameOrOptions?: string | TaskOptions, maybeOptions?: TaskOptions): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: system is shutting down.');\n    }\n\n    let queueName: string = DEFAULT_QUEUE;\n    let options: TaskOptions = {};\n\n    if (typeof queueNameOrOptions === 'string') {\n      queueName = queueNameOrOptions;\n      options = maybeOptions ?? {};\n    } else if (typeof queueNameOrOptions === 'object' && queueNameOrOptions !== null) {\n      options = queueNameOrOptions;\n    }\n\n    // Validate dependencies\n    if (options.dependencies && options.dependencies.length > 0) {\n      for (const depId of options.dependencies) {\n        if (!this.allTasks.has(depId)) {\n          throw new Error(`Dependency task not found: ${depId}`);\n        }\n      }\n    }\n\n    const task = createTask(payload, queueName, options);\n\n    // Check circular dependencies (for a new task, only self-reference is possible,\n    // but let's be thorough and check transitive deps)\n    if (options.dependencies && options.dependencies.length > 0) {\n      // Check: does any dependency transitively list any of our other deps in a cycle?\n      // Actually for a NEW task that doesn't exist yet, no existing task can reference it,\n      // so no cycle through this task is possible. But we check self-reference.\n      if (options.dependencies.includes(task.id)) {\n        throw new Error('Circular dependency detected: task cannot depend on itself.');\n      }\n    }\n\n    // Mark already-completed dependencies as resolved\n    if (task.dependencies.length > 0) {\n      for (const depId of task.dependencies) {\n        const depTask = this.allTasks.get(depId);\n        if (depTask && depTask.status === 'completed') {\n          task.resolvedDependencies.add(depId);\n        }\n      }\n    }\n\n    const queue = this.getOrCreateQueue(queueName);\n    queue.tasks.set(task.id, task);\n    const order = this.globalInsertionCounter++;\n    queue.insertionMap.set(task.id, order);\n    this.allTasks.set(task.id, task);\n    this.taskInsertionOrder.set(task.id, order);\n\n    return task;\n  }\n\n  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {\n    const queue = this.getQueue(queueName);\n    if (!queue) return null;\n\n    // Check concurrency limit\n    if (queue.concurrencyLimit !== null) {\n      const activeCount = this.getActiveCount(queueName);\n      if (activeCount >= queue.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = Date.now();\n    let bestTask: Task | null = null;\n    let bestOrder = Infinity;\n\n    for (const task of queue.tasks.values()) {\n      if (task.status !== 'pending') continue;\n      if (task.availableAt > now) continue;\n      if (this.isTaskBlocked(task)) continue;\n\n      const taskOrder = queue.insertionMap.get(task.id) ?? Infinity;\n\n      if (bestTask === null) {\n        bestTask = task;\n        bestOrder = taskOrder;\n        continue;\n      }\n\n      // Compare by priority first (lower = higher priority)\n      if (task.priority < bestTask.priority) {\n        bestTask = task;\n        bestOrder = taskOrder;\n      } else if (task.priority === bestTask.priority) {\n        // FIFO within same priority\n        if (taskOrder < bestOrder) {\n          bestTask = task;\n          bestOrder = taskOrder;\n        }\n      }\n    }\n\n    if (bestTask) {\n      bestTask.status = 'processing';\n      bestTask.attempts++;\n    }\n\n    return bestTask;\n  }\n\n  getWaitingCount(queueName: string = DEFAULT_QUEUE): number {\n    const queue = this.getQueue(queueName);\n    if (!queue) return 0;\n    let count = 0;\n    for (const task of queue.tasks.values()) {\n      if (task.status === 'pending') count++;\n    }\n    return count;\n  }\n\n  // ---- Phase 2: Named Queues ----\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ---- Phase 5: Complete/Fail ----\n\n  completeTask(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in \"${task.status}\" status. Task must be in \"processing\" state.`);\n    }\n\n    task.status = 'completed';\n    task.progress = { percentage: 100 };\n\n    // Remove from queue's active tasks\n    const queue = this.getQueue(task.queueName);\n    if (queue) {\n      queue.tasks.delete(task.id);\n      queue.insertionMap.delete(task.id);\n    }\n\n    // Resolve dependencies\n    this.resolveDependency(taskId);\n  }\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in \"${task.status}\" status. Task must be in \"processing\" state.`);\n    }\n\n    task.error = error;\n\n    // Check if retries remaining\n    if (task.attempts < task.maxRetries) {\n      // Re-add with exponential backoff\n      const backoff = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = Date.now() + backoff;\n      task.progress = { percentage: 0 };\n      // Task stays in its queue, just goes back to pending with a delay\n    } else {\n      // No more retries - move to DLQ\n      task.status = 'failed';\n      const queue = this.getQueue(task.queueName);\n      if (queue) {\n        queue.tasks.delete(task.id);\n        queue.insertionMap.delete(task.id);\n        queue.deadLetterQueue.push(task);\n      }\n    }\n  }\n\n  // ---- Phase 6: Dead Letter Queue ----\n\n  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {\n    const queue = this.getQueue(queueName);\n    if (!queue) return [];\n    return [...queue.deadLetterQueue];\n  }\n\n  redriveTask(taskId: string): Task {\n    // Find the task in any DLQ\n    for (const [, queue] of this.queues) {\n      const index = queue.deadLetterQueue.findIndex(t => t.id === taskId);\n      if (index !== -1) {\n        const task = queue.deadLetterQueue.splice(index, 1)[0];\n        // Reset for fresh retries\n        task.status = 'pending';\n        task.attempts = 0;\n        task.error = undefined;\n        task.availableAt = Date.now();\n        task.progress = { percentage: 0 };\n\n        // Re-add to original queue\n        queue.tasks.set(task.id, task);\n        const order = this.globalInsertionCounter++;\n        queue.insertionMap.set(task.id, order);\n        this.taskInsertionOrder.set(task.id, order);\n\n        return task;\n      }\n    }\n    throw new Error(`Task not found in dead letter queue: ${taskId}`);\n  }\n\n  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): number {\n    const queue = this.getQueue(queueName);\n    if (!queue) return 0;\n    const count = queue.deadLetterQueue.length;\n    queue.deadLetterQueue = [];\n    return count;\n  }\n\n  // ---- Phase 7: Task Dependencies ----\n\n  getTaskDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    const resolved = task.dependencies.filter(d => task.resolvedDependencies.has(d));\n    const pending = task.dependencies.filter(d => !task.resolvedDependencies.has(d));\n    return { dependencies: [...task.dependencies], resolved, pending };\n  }\n\n  // ---- Phase 8: Concurrency Control ----\n\n  setConcurrency(queueName: string, limit: number | null): void {\n    const queue = this.getOrCreateQueue(queueName);\n    queue.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName: string = DEFAULT_QUEUE): { limit: number | null; active: number } {\n    const queue = this.getQueue(queueName);\n    if (!queue) return { limit: null, active: 0 };\n    return {\n      limit: queue.concurrencyLimit,\n      active: this.getActiveCount(queueName),\n    };\n  }\n\n  // ---- Phase 9: Progress Tracking and Cancellation ----\n\n  updateProgress(taskId: string, percentage: number, message?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot update progress for task in \"${task.status}\" status.`);\n    }\n    if (percentage < 0 || percentage > 100) {\n      throw new Error(`Progress must be between 0 and 100, got ${percentage}.`);\n    }\n\n    task.progress = { percentage, message };\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(task.progress);\n      }\n    }\n  }\n\n  getProgress(taskId: string): TaskProgress {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    return { ...task.progress };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  cancelTask(taskId: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Cannot cancel task in \"${task.status}\" status.`);\n    }\n\n    const previousStatus = task.status;\n    task.status = 'cancelled';\n\n    if (previousStatus === 'pending') {\n      // Remove from queue\n      const queue = this.getQueue(task.queueName);\n      if (queue) {\n        queue.tasks.delete(task.id);\n        queue.insertionMap.delete(task.id);\n      }\n    }\n    // For processing tasks, just update status (concurrency slot freed)\n  }\n\n  // ---- Phase 10: Recurring Tasks ----\n\n  addSchedule(\n    cronExpression: string,\n    queueName: string,\n    payload: unknown,\n    taskOptions?: Omit<TaskOptions, 'dependencies' | 'delay' | 'processAt'>\n  ): string {\n    const parsed = parseCron(cronExpression);\n    const id = randomUUID();\n    this.schedules.set(id, {\n      id,\n      cronExpression,\n      queueName,\n      payload,\n      taskOptions,\n      parsed,\n      lastRun: undefined,\n    });\n    return id;\n  }\n\n  removeSchedule(scheduleId: string): boolean {\n    return this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): ScheduleEntry[] {\n    return Array.from(this.schedules.values()).map(({ parsed: _, ...entry }) => entry);\n  }\n\n  tick(now: Date = new Date()): Task[] {\n    const enqueued: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (isDue(schedule.parsed, now, schedule.lastRun)) {\n        schedule.lastRun = now.getTime();\n        const task = this.addTask(schedule.payload, schedule.queueName, schedule.taskOptions as TaskOptions);\n        enqueued.push(task);\n      }\n    }\n\n    return enqueued;\n  }\n\n  // ---- Phase 11: Middleware ----\n\n  use(queueName: string, middleware: Middleware): void {\n    const queue = this.getOrCreateQueue(queueName);\n    queue.middlewares.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: TaskHandler): void {\n    const queue = this.getOrCreateQueue(queueName);\n    queue.handler = handler;\n  }\n\n  async processTask(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {\n    const task = this.getNextTask(queueName);\n    if (!task) return null;\n\n    const queue = this.getQueue(queueName);\n    if (!queue) return null;\n\n    const middlewares = [...queue.middlewares];\n    const handler = queue.handler;\n\n    let index = 0;\n\n    const executeNext = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const mw = middlewares[index++];\n        await mw(task, executeNext);\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    try {\n      await executeNext();\n      // If task is still processing (middleware/handler didn't complete/fail it), auto-complete\n      if (task.status === 'processing') {\n        this.completeTask(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.failTask(task.id, err instanceof Error ? err.message : String(err));\n      }\n    }\n\n    return task;\n  }\n\n  // ---- Phase 12: Graceful Shutdown ----\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.executeShutdown(timeoutMs);\n    return this.shutdownPromise;\n  }\n\n  private async executeShutdown(timeoutMs: number): Promise<ShutdownResult> {\n    const startTime = Date.now();\n    let completed = 0;\n    let forceCancelled = 0;\n\n    // Run shutdown callbacks\n    for (const callback of this.shutdownCallbacks) {\n      try {\n        await callback();\n      } catch {\n        // Ignore callback errors during shutdown\n      }\n    }\n\n    // Gather all processing tasks\n    const processingTasks: Task[] = [];\n    for (const queue of this.queues.values()) {\n      for (const task of queue.tasks.values()) {\n        if (task.status === 'processing') {\n          processingTasks.push(task);\n        }\n      }\n    }\n\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        forceCancelled: 0,\n        durationMs: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks to complete, up to timeout\n    const result = await new Promise<{ completed: number; forceCancelled: number }>((resolve) => {\n      let localCompleted = 0;\n      const totalProcessing = processingTasks.length;\n\n      const checkDone = () => {\n        // Count how many of the original processing tasks are now done\n        localCompleted = 0;\n        let stillProcessing = 0;\n        for (const task of processingTasks) {\n          if (task.status === 'completed' || task.status === 'failed' || task.status === 'cancelled') {\n            localCompleted++;\n          } else {\n            stillProcessing++;\n          }\n        }\n\n        if (stillProcessing === 0) {\n          clearInterval(pollInterval);\n          clearTimeout(timer);\n          resolve({ completed: localCompleted, forceCancelled: 0 });\n        }\n      };\n\n      const pollInterval = setInterval(checkDone, 10);\n\n      const timer = setTimeout(() => {\n        clearInterval(pollInterval);\n        // Force-cancel remaining processing tasks\n        let fc = 0;\n        localCompleted = 0;\n        for (const task of processingTasks) {\n          if (task.status === 'processing') {\n            task.status = 'cancelled';\n            fc++;\n          } else {\n            localCompleted++;\n          }\n        }\n        resolve({ completed: localCompleted, forceCancelled: fc });\n      }, timeoutMs);\n  