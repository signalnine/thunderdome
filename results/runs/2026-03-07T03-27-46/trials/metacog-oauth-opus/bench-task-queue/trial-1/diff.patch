n;\n      tq.setHandler('default', async (task) => {\n        receivedPayload = task.payload;\n      });\n\n      tq.addTask({ original: true });\n      await tq.processTask();\n\n      expect(receivedPayload).toEqual({ original: true, modified: true });\n    });\n\n    it('should mark task as failed when middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = tq.addTask('data', { maxRetries: 1, backoffDelay: 0 });\n      await tq.processTask();\n\n      // Task failed (maxRetries=1, so goes to DLQ after 1 attempt)\n      expect(task.status).toBe('failed');\n    });\n\n    it('should return null when no tasks available', async () => {\n      const result = await tq.processTask();\n      expect(result).toBeNull();\n    });\n\n    it('should maintain independent middleware stacks per queue', async () => {\n      const log: string[] = [];\n\n      tq.use('q1', async (_task, next) => {\n        log.push('q1-mw');\n        await next();\n      });\n\n      tq.use('q2', async (_task, next) => {\n        log.push('q2-mw');\n        await next();\n      });\n\n      tq.addTask('data', 'q1');\n      tq.addTask('data', 'q2');\n\n      await tq.processTask('q1');\n      expect(log).toEqual(['q1-mw']);\n\n      await tq.processTask('q2');\n      expect(log).toEqual(['q1-mw', 'q2-mw']);\n    });\n  });\n\n  // ======== Phase 12: Graceful Shutdown ========\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should stop accepting tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.addTask('data')).toThrow(/shutting down/);\n    });\n\n    it('should complete immediately when no tasks processing', async () => {\n      const result = await tq.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing 