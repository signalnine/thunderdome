throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in \"${task.status}\" status. Task must be in \"processing\" state.`);\n    }\n\n    task.status = 'completed';\n    task.progress = { percentage: 100 };\n\n    // Remove from queue's active tasks\n    const queue = this.getQueue(task.queueName);\n    if (queue) {\n      queue.tasks.delete(task.id);\n      queue.insertionMap.delete(task.id);\n    }\n\n    // Resolve dependencies\n    this.resolveDependency(taskId);\n  }\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.allTasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in \"${task.status}\" status. Task must be in \"processing\" state.`);\n    }\n\n    task.error = error;\n\n    // Check if retries remaining\n    if (task.attempts < task.maxRetries) {\n      // Re-add with exponential backoff\n      const backoff = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = Date.now() + backoff;\n      task.progress = { percentage: 0 };\n      // Task stays in its queue, just goes back to pending with a delay\n    } else {\n      // No more retries - move to DLQ\n      task.status = 'failed';\n      const queue = this.getQueue(task.queueName);\n      if (queue) {\n        queue.tasks.delete(task.id);\n        queue.insertionMap.delete(task.id);\n        queue.deadLetterQueue.push(task);\n      }\n    }\n  }\n\n  // ---- Phase 6: Dead Letter Queue ----\n\n  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {\n    const queue = this.getQueue(queueName);\n    if (!queue) return [];\n    return [...queue.deadLetterQueue];\n  }\n\n  redriveTask(taskId: string): Task {\n    // Find the task in any DLQ\n    for (const [queueName, queue] of this.queues) {\n      const ind