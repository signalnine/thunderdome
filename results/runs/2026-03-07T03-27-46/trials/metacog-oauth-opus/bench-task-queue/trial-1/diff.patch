t any of our other deps in a cycle?\n   174→      // Actually for a NEW task that doesn't exist yet, no existing task can reference it,\n   175→      // so no cycle through this task is possible. But we check self-reference.\n   176→      if (options.dependencies.includes(task.id)) {\n   177→        throw new Error('Circular dependency detected: task cannot depend on itself.');\n   178→      }\n   179→    }\n   180→\n   181→    // Mark already-completed dependencies as resolved\n   182→    if (task.dependencies.length > 0) {\n   183→      for (const depId of task.dependencies) {\n   184→        const depTask = this.allTasks.get(depId);\n   185→        if (depTask && depTask.status === 'completed') {\n   186→          task.resolvedDependencies.add(depId);\n   187→        }\n   188→      }\n   189→    }\n   190→\n   191→    const queue = this.getOrCreateQueue(queueName);\n   192→    queue.tasks.set(task.id, task);\n   193→    const order = this.globalInsertionCounter++;\n   194→    queue.insertionMap.set(task.id, order);\n   195→    this.allTasks.set(task.id, task);\n   196→    this.taskInsertionOrder.set(task.id, order);\n   197→\n   198→    return task;\n   199→  }\n   200→\n   201→  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {\n   202→    const queue = this.getQueue(queueName);\n   203→    if (!queue) return null;\n   204→\n   205→    // Check concurrency limit\n   206→    if (queue.concurrencyLimit !== null) {\n   207→      const activeCount = this.getActiveCount(queueName);\n   208→      if (activeCount >= queue.concurrencyLimit) {\n   209→        return null;\n   210→      }\n   211→    }\n   212→\n   213→    const now = Date.now();\n   214→    let bestTask: Task | null = null;\n   215→    let bestOrder = Infinity;\n   216→\n   217→    for (const task of queue.tasks.values()) {\n   218→      if (task.status !== 'pending') continue;\n   219→      if (task.availableAt > now) continue;\n   220→      if (this.isTaskBlocked(task)) continue;\n   221→\n   222→      const taskOrder = queue.insertionMap.get(task.id) ?? Infinity;\n   223→\n   224→      if (bestTask === null) {\n   225→        bestTask = task;\n   226→        bestOrder = taskOrder;\n   227→        continue;\n   228→      }\n   229→\n   230→      // Compare by priority first (lower = higher priority)\n   231→      if (task.priority < bestTask.priority) {\n   232→        bestTask = task;\n   233→        bestOrder = taskOrder;\n   234→      } else if (task.priority === bestTask.priority) {\n   235→        // FIFO within same priority\n   236→        if (taskOrder < bestOrder) {\n   237→          bestTask = task;\n   238→          bestOrder = taskOrder;\n   239→        }\n   240→      }\n   241→    }\n   242→\n   243→    if (bestTask) {\n   244→      bestTask.status = 'processing';\n   245→      bestTask.attempts++;\n   246→    }\n   247→\n   248→    return bestTask;\n   249→  }\n   250→\n   251→  getWaitingCount(queueName: string = DEFAULT_QUEUE): number {\n   252→    const queue = this.getQueue(queueName);\n   253→    if (!queue) return 0;\n   254→    let count = 0;\n   255→    for (const task of queue.tasks.values()) {\n   256→      if (task.status === 'pending') count++;\n   257→    }\n   258→    return count;\n   259→  }\n   260→\n   261→  // ---- Phase 2: Named Queues ----\n   262→\n   263→  getQueueNames(): string[] {\n   264→    return Array.from(this.queues.keys());\n   265→  }\n   266→\n   267→  // ---- Phase 5: Complete/Fail ----\n   268→\n   269→  completeTask(taskId: string): void {\n   270→    const task = this.allTasks.get(taskId);\n   271→    if (!task) {\n   272→      throw new Error(`Task not found: ${taskId}`);\n   273→    }\n   274→    if (task.status !== 'processing') {\n   275→      throw new Error(`Cannot complete task in \"${task.status}\" status. Task must be in \"processing\" state.`);\n   276→    }\n   277→\n   278→    task.status = 'completed';\n   279→    task.progress = { percentage: 100 };\n   280→\n   281→    // Remove from queue's active tasks\n   282→    const queue = this.getQueue(task.queueName);\n   283→    if (queue) {\n   284→      queue.tasks.delete(task.id);\n   285→      queue.insertionMap.delete(task.id);\n   286→    }\n   287→\n   288→    // Resolve dependencies\n   289→    this.resolveDependency(taskId);\n   290→  }\n   291→\n   292→  failTask(taskId: string, error?: string): void {\n   293→    const task = this.allTasks.get(taskId);\n   294→    if (!task) {\n   295→      throw new Error(`Task not found: ${taskId}`);\n   296→    }\n   297→    if (task.status !== 'processing') {\n   298→      throw new Error(`Cannot fail task in \"${task.status}\" status. Task must be in \"processing\" state.`);\n   299→    }\n   300→\n   301→    task.error = error;\n   302→\n   303→    // Check if retries remaining\n   304→    if (task.attempts < task.maxRetries) {\n   305→      // Re-add with exponential backoff\n   306→      const backoff = task.backoffDelay * Math.pow(2, task.attempts - 1);\n   307→      task.status = 'pending';\n   308→      task.availableAt = Date.now() + backoff;\n   309→      task.progress = { percentage: 0 };\n   310→      // Task stays in its queue, just goes back to pending with a delay\n   311→    } else {\n   312→      // No more retries - move to DLQ\n   313→      task.status = 'failed';\n   314→      const queue = this.getQueue(task.queueName);\n   315→      if (queue) {\n   316→        queue.tasks.delete(task.id);\n   317→        queue.insertionMap.delete(task.id);\n   318→        queue.deadLetterQueue.push(task);\n   319→      }\n   320→    }\n   321→  }\n   322→\n   323→  // ---- Phase 6: Dead Letter Queue ----\n   324→\n   325→  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {\n   326→    const queue = this.getQueue(queueName);\n   327→    if (!queue) return [];\n   328→    return [...queue.deadLetterQueue];\n   329→  }\n   330→\n   331→  redriveTask(taskId: string): Task {\n   332→    // Find the task in any DLQ\n   333→    for (const [, queue] of this.queues) {\n   334→      const index = queue.deadLetterQueue.findIndex(t => t.id === taskId);\n   335→      if (index !== -1) {\n   336→        const task = queue.deadLetterQueue.splice(index, 1)[0];\n   337→        // Reset for fresh retries\n   338→        task.status = 'pending';\n   339→        task.attempts = 0;\n   340→        task.error = undefined;\n   341→        task.availableAt = Date.now();\n   342→        task.progress = { percentage: 0 };\n   343→\n   344→        // Re-add to original queue\n   345→        queue.tasks.set(task.id, task);\n   346→        const order = this.globalInsertionCounter++;\n   347→        queue.insertionMap.set(task.id, order);\n   348→        this.taskInsertionOrder.set(task.id, order);\n   349→\n   350→        return task;\n   351→      }\n   352→    }\n   353→    throw new Error(`Task not found in dead letter queue: ${taskId}`);\n   354→  }\n   355→\n   356→  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): number {\n   357→    const queue = this.getQueue(queueName);\n   358→    if (!queue) return 0;\n   359→    const count = queue.deadLetterQueue.length;\n   360→    queue.deadLetterQueue = [];\n   361→    return count;\n   362→  }\n   363→\n   364→  // ---- Phase 7: Task Dependencies ----\n   365→\n   366→  getTaskDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } {\n   367→    const task = this.allTasks.get(taskId);\n   368→    if (!task) {\n   369→      throw new Error(`Task not found: ${taskId}`);\n   370→    }\n   371→    const resolved = task.dependencies.filter(d => task.resolvedDependencies.has(d));\n   372→    const pending = task.dependencies.filter(d => !task.resolvedDependencies.has(d));\n   373→    return { dependencies: [...task.dependencies], resolved, pending };\n   374→  }\n   375→\n   376→  // ---- Phase 8: Concurrency Control ----\n   377→\n   378→  setConcurrency(queueName: string, limit: number | null): void {\n   379→    const queue = this.getOrCreateQueue(queueName);\n   380→    queue.concurrencyLimit = limit;\n   381→  }\n   382→\n   383→  getConcurrency(queueName: string = DEFAULT_QUEUE): { limit: number | null; active: number } {\n   384→    const queue = this.getQueue(queueName);\n   385→    if (!queue) return { limit: null, active: 0 };\n   386→    return {\n   387→      limit: queue.concurrencyLimit,\n   388→      active: this.getActiveCount(queueName),\n   389→    };\n   390→  }\n   391→\n   392→  // ---- Phase 9: Progress Tracking and Cancellation ----\n   393→\n   394→  updateProgress(taskId: string, percentage: number, message?: string): void {\n   395→    const task = this.allTasks.get(taskId);\n   396→    if (!task) {\n   397→      throw new Error(`Task not found: ${taskId}`);\n   398→    }\n   399→    if (task.status !== 'processing') {\n   400→      throw new Error(`Cannot update progress for task in \"${task.status}\" status.`);\n   401→    }\n   402→    if (percentage < 0 || percentage > 100) {\n   403→      throw new Error(`Progress must be between 0 and 100, got ${percentage}.`);\n   404→    }\n   405→\n   406→    task.progress = { percentage, message };\n   407→\n   408→    // Notify listeners\n   409→    const listeners = this.progressListeners.get(taskId);\n   410→    if (listeners) {\n   411→      for (const listener of listeners) {\n   412→        listener(task.progress);\n   413→      }\n   414→    }\n   415→  }\n   416→\n   417→  getProgress(taskId: string): TaskProgress {\n   418→    const task = this.allTasks.get(taskId);\n   419→    if (!task) {\n   420→      throw new Error(`Task not found: ${taskId}`);\n   421→    }\n   422→    return { ...task.progress };\n   423→  }\n   424→\n   425→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   426→    const task = this.allTasks.get(taskId);\n   427→    if (!task) {\n   428→      throw new Error(`Task not found: ${taskId}`);\n   429→    }\n   430→\n   431→    if (!this.progressListeners.has(taskId)) {\n   432→      this.progressListeners.set(taskId, new Set());\n   433→    }\n   434→    this.progressListeners.get(taskId)!.add(listener);\n   435→\n   436→    // Return unsubscribe function\n   437→    return () => {\n   438→      const listeners = this.progressListeners.get(taskId);\n   439→      if (listeners) {\n   440→        listeners.delete(listener);\n   441→        if (listeners.size === 0) {\n   442→          this.progressListeners.delete(taskId);\n   443→        }\n   444→      }\n   445→    };\n   446→  }\n   447→\n   448→  cancelTask(taskId: string): void {\n   449→    const task = this.allTasks.get(taskId);\n   450→    if (!task) {\n   451→      throw new Error(`Task not found: ${taskId}`);\n   452→    }\n   453→    if (task.status !== 'pending' && task.status !== 'processing') {\n   454→      throw new Error(`Cannot cancel task in \"${task.status}\" status.`);\n   455→    }\n   456→\n   457→    const previousStatus = task.status;\n   458→    task.status = 'cancelled';\n   459→\n   460→    if (previousStatus === 'pending') {\n   461→      // Remove from queue\n   462→      const queue = this.getQueue(task.queueName);\n   463→      if (queue) {\n   464→        queue.tasks.delete(task.id);\n   465→        queue.insertionMap.delete(task.id);\n   466→      }\n   467→    }\n   468→    // For processing tasks, just update status (concurrency slot freed)\n   469→  }\n   470→\n   471→  // ---- Phase 10: Recurring Tasks ----\n   472→\n   473→  addSchedule(\n   474→    cronExpression: string,\n   475→    queueName: string,\n   476→    payload: unknown,\n   477→    taskOptions?: Omit<TaskOptions, 'dependencies' | 'delay' | 'processAt'>\n   478→  ): string {\n   479→    const parsed = parseCron(cronExpression);\n   480→    const id = randomUUID();\n   481→    this.schedules.set(id, {\n   482→      id,\n   483→      cronExpression,\n   484→      queueName,\n   485→      payload,\n   486→      taskOptions,\n   487→      parsed,\n   488→      lastRun: undefined,\n   489→    });\n   490→    return id;\n   491→  }\n   492→\n   493→  removeSchedule(scheduleId: string): boolean {\n   494→    return this.schedules.delete(scheduleId);\n   495→  }\n   496→\n   497→  getSchedules(): ScheduleEntry[] {\n   498→    return Array.from(this.schedules.values()).map(({ parsed: _, ...entry }) => entry);\n   499→  }\n   500→\n   501→  tick(now: Date = new Date()): Task[] {\n   502→    const enqueued: Task[] = [];\n   503→\n   504→    for (const schedule of this.schedules.values()) {\n   505→      if (isDue(schedule.parsed, now, schedule.lastRun)) {\n   506→        schedule.lastRun = now.getTime();\n   507→        const task = this.addTask(schedule.payload, schedule.queueName, schedule.taskOptions as TaskOptions);\n   508→        enqueued.push(task);\n   509→      }\n   510→    }\n   511→\n   512→    return enqueued;\n   513→  }\n   514→\n   515→  // ---- Phase 11: Middleware ----\n   516→\n   517→  use(queueName: string, middleware: Middleware): void {\n   518→    const queue = this.getOrCreateQueue(queueName);\n   519→    queue.middlewares.push(middleware);\n   520→  }\n   521→\n   522→  setHandler(queueName: string, handler: TaskHandler): void {\n   523→    const queue = this.getOrCreateQueue(queueName);\n   524→    queue.handler = handler;\n   525→  }\n   526→\n   527→  async processTask(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {\n   528→    const task = this.getNextTask(queueName);\n   529→    if (!task) return null;\n   530→\n   531→    const queue = this.getQueue(queueName);\n   532→    if (!queue) return null;\n   533→\n   534→    const middlewares = [...queue.middlewares];\n   535→    const handler = queue.handler;\n   536→\n   537→    let index = 0;\n   538→\n   539→    const executeNext = async (): Promise<void> => {\n   540→      if (index < middlewares.length) {\n   541→        const mw = middlewares[index++];\n   542→        await mw(task, executeNext);\n   543→      } else if (handler) {\n   544→        await handler(task);\n   545→      }\n   546→    };\n   547→\n   548→    try {\n   549→      await executeNext();\n   550→      // If task is still processing (middleware/handler didn't complete/fail it), auto-complete\n   551→      if (task.status === 'processing') {\n   552→        this.completeTask(task.id);\n   553→      }\n   554→    } catch (err) {\n   555→      if (task.status === 'processing') {\n   556→        this.failTask(task.id, err instanceof Error ? err.message : String(err));\n   557→      }\n   558→    }\n   559→\n   560→    return task;\n   561→  }\n   562→\n   563→  // ---- Phase 12: Graceful Shutdown ----\n   564→\n   565→  onShutdown(callback: () => void | Promise<void>): void {\n   566→    this.shutdownCallbacks.push(callback);\n   567→  }\n   568→\n   569→  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {\n   570→    if (this.shutdownPromise) {\n   571→      return this.shutdownPromise;\n   572→    }\n   573→\n   574→    this.isShuttingDown = true;\n   575→    this.shutdownPromise = this.executeShutdown(timeoutMs);\n   576→    return this.shutdownPromise;\n   577→  }\n   578→\n   579→  private async executeShutdown(timeoutMs: number): Promise<ShutdownResult> {\n   580→    const startTime = Date.now();\n   581→\n   582→    // Run shutdown callbacks\n   583→    for (const callback of this.shutdownCallbacks) {\n   584→      try {\n   585→        await callback();\n   586→      } catch {\n   587→        // Ignore callback errors during shutdown\n   588→      }\n   589→    }\n   590→\n   591→    // Gather all processing tasks\n   592→    const processingTasks: Task[] = [];\n   593→    for (const queue of this.queues.values()) {\n   594→      for (const task of queue.tasks.values()) {\n   595→        if (task.status === 'processing') {\n   596→          processingTasks.push(task);\n   597→        }\n   598→      }\n   599→    }\n   600→\n   601→    if (processingTasks.length === 0) {\n   602→      return {\n   603→        completed: 0,\n   604→        forceCancelled: 0,\n   605→        durationMs: Date.now() - startTime,\n   606→      };\n   607→    }\n   608→\n   609→    // Wait for processing tasks to complete, up to timeout\n   610→    const result = await new Promise<{ completed: number; forceCancelled: number }>((resolve) => {\n   611→      let localCompleted = 0;\n   612→\n   613→      const checkDone = () => {\n   614→        // Count how many of the original processing tasks are now done\n   615→        localCompleted = 0;\n   616→        let stillProcessing = 0;\n   617→        for (const task of processingTasks) {\n   618→          if (task.status === 'completed' || task.status === 'failed' || task.status === 'cancelled') {\n   619→            localCompleted++;\n   620→          } else {\n   621→            stillProcessing++;\n   622→          }\n   623→        }\n   624→\n   625→        if (stillProcessing === 0) {\n   626→          clearInterval(pollInterval);\n   627→          clearTimeout(timer);\n   628→          resolve({ completed: localCompleted, forceCancelled: 0 });\n   629→        }\n   630→      };\n   631→\n   632→      const pollInterval = setInterval(checkDone, 10);\n   633→\n   634→      const timer = setTimeout(() => {\n   635→        clearInterval(pollInterval);\n   636→        // Force-cancel remaining processing tasks\n   637→        let fc = 0;\n   638→        localCompleted = 0;\n   639→        for (const task of processingTasks) {\n   640→          if (task.status === 'processing') {\n   641→            task.status = 'cancelled';\n   642→            fc++;\n   643→          } else {\n   644→            localCompleted++;\n   645→          }\n   646→        }\n   647→        resolve({ completed: localCompleted, forceCancelled: fc });\n   648→      }, timeoutMs);\n   649→    });\n   650→\n   651→    return {\n   652→      completed: result.completed,\n   653→      forceCancelled: result.forceCancelled,\n   654→      durationMs: Date.now() - startTime,\n   655→    };\n   656→  }\n   657→\n   658→  // ---- Utility ----\n   659→\n   660→  getTask(taskId: string): Task | undefined {\n   661→    return this.allTasks.get(taskId);\n   662→  }\n   663→\n   664→  get isShutdown(): boolean {\n   665→    return this.isShuttingDown;\n   666→  }\n   667→}\n   668→"}]},"parent_tool_use_id":null,"session_id":"82fad245-a271-4167-8a97-934a9c7f30f7","uuid":"35289f54-f0c6-49de-8edd-8e73631b3e29","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/queue.ts","content":"import type {\n  Task,\n  TaskOptions,\n  TaskProgress,\n  ProgressListener,\n  Middleware,\n  TaskHandler,\n  ScheduleEntry,\n  ShutdownResult,\n} from './types.js';\nimport { createTask } from './task.js';\nimport { parseCron, isDue } from './cron.js';\nimport { randomUUID } from 'node:crypto';\n\nconst DEFAULT_QUEUE = 'default';\n\ninterface QueueState {\n  tasks: Map<string, Task>;\n  insertionOrder: number;\n  insertionMap: Map<string, number>;\n  deadLetterQueue: Task[];\n  concurrencyLimit: number | null;\n  middlewares: Middleware[];\n  handler: TaskHandler | null;\n}\n\nexport class TaskQueue {\n  private queues: Map<string, QueueState> = new Map();\n  private allTasks: Map<string, Task> = new Map();\n  private taskInsertionOrder: Map<string, number> = new Map();\n  private globalInsertionCounter = 0;\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n  private schedules: Map<string, ScheduleEntry & { parsed: ReturnType<typeof parseCron> }> = new Map();\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  // ---- Internal helpers ----\n\n  private getOrCreateQueue(name: string): QueueState {\n    let queue = this.queues.get(name);\n    if (!queue) {\n      queue = {\n        tasks: new Map(),\n        insertionOrder: 0,\n        insertionMap: new Map(),\n        deadLetterQueue: [],\n        concurrencyLimit: null,\n        middlewares: [],\n        handler: null,\n      };\n      this.queues.set(name, queue);\n    }\n    return queue;\n  }\n\n  private getQueue(name: string): QueueState | undefined {\n    return this.queues.get(name);\n  }\n\n  private getActiveCount(queueName: string): number {\n    const queue = this.getQueue(queueName);\n    if (!queue) return 0;\n    let count = 0;\n    for (const task of queue.tasks.values()) {\n      if (task.status === 'processing') count++;\n    }\n    return count;\n  }\n\n  private isTaskBlocked(task: Task): boolean {\n    if (task.dependencies.length === 0) return false;\n    for (const depId of task.dependencies) {\n      if (!task.resolvedDependencies.has(depId)) {\n        return true;\n      }\n    }\n    return false;\n  }\n\n  private resolveDependency(completedTaskId: string): void {\n    for (const task of this.allTasks.values()) {\n      if (task.dependencies.includes(completedTaskId)) {\n        task.resolvedDependencies.add(completedTaskId);\n      }\n    }\n  }\n\n  private detectCircularDeps(taskId: string, dependencies: string[], visited: Set<string> = new Set()): boolean {\n    if (visited.has(taskId)) return true;\n    visited.add(taskId);\n    for (const depId of dependencies) {\n      const depTask = this.allTasks.get(depId);\n      if (depTask) {\n        if (this.detectCircularDeps(taskId, depTask.dependencies, new Set(visited))) {\n          return true;\n        }\n      }\n    }\n    return false;\n  }\n\n  private wouldCreateCycle(newTaskId: string, dependencies: string[]): boolean {\n    // Check if any dependency eventually depends back on newTaskId\n    // Since newTaskId is new, we check if any dep's transitive deps include any task\n    // that depends on newTaskId. But since newTaskId is new, no existing task can depend on it.\n    // So we only need to check: do any of the dependencies form a cycle among themselves?\n    // Actually, we also need to check: do tasks that depend on us (none yet since n