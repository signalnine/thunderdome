+  }
+
+  setHandler(queueName: string, handler: TaskHandler): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.handler = handler;
+  }
+
+  async processTask(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {
+    const task = this.getNextTask(queueName);
+    if (!task) return null;
+
+    const queue = this.getQueue(queueName);
+    if (!queue) return null;
+
+    const middlewares = [...queue.middlewares];
+    const handler = queue.handler;
+
+    let index = 0;
+
+    const executeNext = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const mw = middlewares[index++];
+        await mw(task, executeNext);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await executeNext();
+      // If task is still processing (middleware/handler didn't complete/fail it), auto-complete
+      if (task.status === 'processing') {
+        this.completeTask(task.id);
+      }
+    } catch (err) {
+      if (task.status === 'processing') {
+        this.failTask(task.id, err instanceof Error ? err.message : String(err));
+      }
+    }
+
+    return task;
+  }
+
+  // ---- Phase 12: Graceful Shutdown ----
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShuttingDown = true;
+    this.shutdownPromise = this.executeShutdown(timeoutMs);
+    return this.shutdownPromise;
+  }
+
+  private async executeShutdown(timeoutMs: number): Promise<ShutdownResult> {
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const callback of this.shutdownCallbacks) {
+      try {
+        await callback();
+      } catch {
+        // Ignore callback errors during shutdown
+      }
+    }
+
+    // Gather all processing tasks
+    const processingTasks: Task[] = [];
+    for (const queue of this.queues.values()) {
+      for (const task of queue.tasks.values()) {
+        if (task.status === 'processing') {
+          processingTasks.push(task);
+        }
+      }
+    }
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        durationMs: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete, up to timeout
+    const result = await new Promise<{ completed: number; forceCancelled: number }>((resolve) => {
+      let localCompleted = 0;
+
+      const checkDone = () => {
+        // Count how many of the original processing tasks are now done
+        localCompleted = 0;
+        let stillProcessing = 0;
+        for (const task of processingTasks) {
+          if (task.status === 'completed' || task.status === 'failed' || task.status === 'cancelled') {
+            localCompleted++;
+          } else {
+            stillProcessing++;
+          }
+        }
+
+        if (stillProcessing === 0) {
+          clearInterval(pollInterval);
+          clearTimeout(timer);
+          resolve({ completed: localCompleted, forceCancelled: 0 });
+        }
+      };
+
+      const pollInterval = setInterval(checkDone, 10);
+
+      const timer = setTimeout(() => {
+        clearInterval(pollInterval);
+        // Force-cancel remaining processing tasks
+        let fc = 0;
+        localCompleted = 0;
+        for (const task of processingTasks) {
+          if (task.status === 'processing') {
+            task.status = 'cancelled';
+            fc++;
+          } else {
+            localCompleted++;
+          }
+        }
+        resolve({ completed: localCompleted, forceCancelled: fc });
+      }, timeoutMs);
+    });
+
+    return {
+      completed: result.completed,
+      forceCancelled: result.forceCancelled,
+      durationMs: Date.now() - startTime,
+    };
+  }
+
+  // ---- Utility ----
+
+  getTask(taskId: string): Task | undefined {
+    return this.allTasks.get(taskId);
+  }
+
+  get isShutdown(): boolean {
+    return this.isShuttingDown;
+  }
+}
diff --git a/src/task.ts b/src/task.ts
new file mode 100644
index 0000000..e38c188
--- /dev/null
+++ b/src/task.ts
@@ -0,0 +1,38 @@
+import { randomUUID } from 'node:crypto';
+import type { Task, TaskOptions } from './types.js';
+
+export function createTask<T = unknown>(
+  payload: T,
+  queueName: string,
+  options: TaskOptions = {}
+): Task<T> {
+  const now = Date.now();
+  const priority = options.priority ?? 5;
+
+  if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+    throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+  }
+
+  let availableAt = now;
+  if (options.processAt !== undefined) {
+    availableAt = options.processAt;
+  } else if (options.delay !== undefined) {
+    availableAt = now + options.delay;
+  }
+
+  return {
+    id: randomUUID(),
+    payload,
+    status: 'pending',
+    priority,
+    createdAt: now,
+    availableAt,
+    attempts: 0,
+    maxRetries: options.maxRetries ?? 3,
+    backoffDelay: options.backoffDelay ?? 1000,
+    queueName,
+    dependencies: options.dependencies ? [...options.dependencies] : [],
+    resolvedDependencies: new Set<string>(),
+    progress: { percentage: 0 },
+  };
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..69b763c
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,56 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  priority?: number;
+  delay?: number;
+  processAt?: number;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface TaskProgress {
+  percentage: number;
+  message?: string;
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  priority: number;
+  createdAt: number;
+  availableAt: number;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  queueName: string;
+  error?: string;
+  dependencies: string[];
+  resolvedDependencies: Set<string>;
+  progress: TaskProgress;
+}
+
+export type ProgressListener = (progress: TaskProgress) => void;
+
+export type Middleware<T = unknown> = (
+  task: Task<T>,
+  next: () => Promise<void>
+) => Promise<void> | void;
+
+export type TaskHandler<T = unknown> = (task: Task<T>) => Promise<void> | void;
+
+export interface ScheduleEntry {
+  id: string;
+  cronExpression: string;
+  queueName: string;
+  payload: unknown;
+  taskOptions?: Omit<TaskOptions, 'dependencies' | 'delay' | 'processAt'>;
+  lastRun?: number;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
