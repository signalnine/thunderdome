sks\n        let fc = 0;\n        localCompleted = 0;\n        for (const task of processingTasks) {\n          if (task.status === 'processing') {\n            task.status = 'cancelled';\n            fc++;\n          } else {\n            localCompleted++;\n          }\n        }\n        resolve({ completed: localCompleted, forceCancelled: fc });\n      }, timeoutMs);\n    });\n\n    return {\n      completed: result.completed,\n      forceCancelled: result.forceCancelled,\n      durationMs: Date.now() - startTime,\n    };\n  }\n\n  // ---- Utility ----\n\n  getTask(taskId: string): Task | undefined {\n    return this.allTasks.get(taskId);\n  }\n\n  get isShutdown(): boolean {\n    return this.isShuttingDown;\n  }\n}\n","structuredPatch":[{"oldStart":86,"oldLines":57,"newStart":86,"newLines":6,"lines":["     }","   }"," ","-  private detectCircularDeps(taskId: string, dependencies: string[], visited: Set<string> = new Set()): boolean {","-    if (visited.has(taskId)) return true;","-    visited.add(taskId);","-    for (const depId of dependencies) {","-      const depTask = this.allTasks.get(depId);","-      if (depTask) {","-        if (this.detectCircularDeps(taskId, depTask.dependencies, new Set(visited))) {","-          return true;","-        }","-      }","-    }","-    return false;","-  }","-","-  private wouldCreateCycle(newTaskId: string, dependencies: string[]): boolean {","-    // Check if any dependency eventually depends back on newTaskId","-    // Since newTaskId is new, we check if any dep's transitive deps include any task","-    // that depends on newTaskId. But since newTaskId is new, no existing task can depend on it.","-    // So we only need to check: do any of the dependencies form a cycle among themselves?","-    // Actually, we also need to check: do tasks that depend on us (none yet since new) ...","-    // For a new task, cycle detection means: can we reach newTaskId from any of the deps?","-    // Since newTaskId isn't in the graph yet,