@@ -0,0 +1,74 @@
+/**
+ * Minimal cron expression parser supporting:
+ * - * /N * * * * -- every N minutes (written without space: asterisk-slash-N)
+ * - 0 * * * *   -- every hour on the hour
+ * - 0 0 * * *   -- every day at midnight
+ */
+
+export interface CronSchedule {
+  type: 'every-n-minutes' | 'hourly' | 'daily';
+  interval?: number; // for every-n-minutes
+}
+
+export function parseCron(expression: string): CronSchedule {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: "${expression}". Expected 5 fields.`);
+  }
+
+  const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;
+
+  // */N * * * * -- every N minutes
+  if (minute.startsWith('*/') && hour === '*' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*') {
+    const n = parseInt(minute.slice(2), 10);
+    if (isNaN(n) || n <= 0) {
+      throw new Error(`Invalid interval in cron expression: "${expression}"`);
+    }
+    return { type: 'every-n-minutes', interval: n };
+  }
+
+  // 0 * * * * -- every hour on the hour
+  if (minute === '0' && hour === '*' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*') {
+    return { type: 'hourly' };
+  }
+
+  // 0 0 * * * -- every day at midnight
+  if (minute === '0' && hour === '0' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*') {
+    return { type: 'daily' };
+  }
+
+  throw new Error(`Unsupported cron expression: "${expression}"`);
+}
+
+export function isDue(schedule: CronSchedule, now: Date, lastRun: number | undefined): boolean {
+  if (lastRun === undefined) {
+    // Never run before, always due on first tick
+    return true;
+  }
+
+  const lastRunDate = new Date(lastRun);
+
+  switch (schedule.type) {
+    case 'every-n-minutes': {
+      const intervalMs = schedule.interval! * 60 * 1000;
+      return (now.getTime() - lastRun) >= intervalMs;
+    }
+    case 'hourly': {
+      // Due if current hour differs from last run hour (or day changed)
+      return (
+        now.getUTCHours() !== lastRunDate.getUTCHours() ||
+        now.getUTCDate() !== lastRunDate.getUTCDate() ||
+        now.getUTCMonth() !== lastRunDate.getUTCMonth() ||
+        now.getUTCFullYear() !== lastRunDate.getUTCFullYear()
+      );
+    }
+    case 'daily': {
+      // Due if current date differs from last run date
+      return (
+        now.getUTCDate() !== lastRunDate.getUTCDate() ||
+        now.getUTCMonth() !== lastRunDate.getUTCMonth() ||
+        now.getUTCFullYear() !== lastRunDate.getUTCFullYear()
+      );
+    }
+  }
+}
