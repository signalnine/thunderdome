    middlewares: [],\n    51→        handler: null,\n    52→      };\n    53→      this.queues.set(name, queue);\n    54→    }\n    55→    return queue;\n    56→  }\n    57→\n    58→  private getQueue(name: string): QueueState | undefined {\n    59→    return this.queues.get(name);\n    60→  }\n    61→\n    62→  private getActiveCount(queueName: string): number {\n    63→    const queue = this.getQueue(queueName);\n    64→    if (!queue) return 0;\n    65→    let count = 0;\n    66→    for (const task of queue.tasks.values()) {\n    67→      if (task.status === 'processing') count++;\n    68→    }\n    69→    return count;\n    70→  }\n    71→\n    72→  private isTaskBlocked(task: Task): boolean {\n    73→    if (task.dependencies.length === 0) return false;\n    74→    for (const depId of task.dependencies) {\n    75→      if (!task.resolvedDependencies.has(depId)) {\n    76→        return true;\n    77→      }\n    78→    }\n    79→    return false;\n    80→  }\n    81→\n    82→  private resolveDependency(completedTaskId: string): void {\n    83→    for (const task of this.allTasks.values()) {\n    84→      if (task.dependencies.includes(completedTaskId)) {\n    85→        task.resolvedDependencies.add(completedTaskId);\n    86→      }\n    87→    }\n    88→  }\n    89→\n    90→  private detectCircularDeps(taskId: string, dependencies: string[], visited: Set<string> = new Set()): boolean {\n    91→    if (visited.has(taskId)) return true;\n    92→    visited.add(taskId);\n    93→    for (const depId of dependencies) {\n    94→      const depTask = this.allTasks.get(depId);\n    95→      if (depTask) {\n    96→        if (this.detectCircularDeps(taskId, depTask.dependencies, new Set(visited))) {\n    97→          return true;\n    98→        }\n    99→      }\n   100→    }\n   101→    return false;\n   102→  }\n   103→\n   104→  private wouldCreateCycle(newTaskId: string, dependencies: string[]): boolean {\n   105→    // Check if any dependency eventually depends back on newTaskId\n   106→    // Since newTaskId is new, we check if any dep's transitive deps include any task\n   107→    // that depends on newTaskId. But since newTaskId is new, no existing task can depend on it.\n   108→    // So we only need to check: do any of the dependencies form a cycle among themselves?\n   109→    // Actually, we also need to check: do tasks that depend on us (none yet since new) ...\n   110→    // For a new task, cycle detection means: can we reach newTaskId from any of the deps?\n   111→    // Since newTaskId isn't in the graph yet, the answer is always no for a new task.\n   112→    // But we should check for cycles among the provided dependencies themselves.\n   113→\n   114→    // Actually the real check is: do any of the tasks that we'll eventually unblock\n   115→    // already transitively depend on one of our dependencies?\n   116→    // Since this task is new, no one depends on it yet. So no cycle from a new task.\n   117→    // However, we should also think about: what if dep A depends on dep B and dep B depends on dep A?\n   118→    // That's not our problem to detect here - that would have been caught when they were created.\n   119→\n   120→    // The main cycle case: task depends on itself\n   121→    if (dependencies.includes(newTaskId)) return true;\n   122→\n   123→    // For existing tasks that we depend on: check if they (transitively) depend on each other\n   124→    // in a way that would create a cycle. But again, since we're new, no cycle is possible\n   125→    // unless we depend on ourselves.\n   126→\n   127→    // Wait - there's another case: what if we're adding task C that depends on B,\n   128→    // and later someone adds task D that depends on C and A, where A depends on D?\n   129→    // That would be caught when D is added. So for a new task, we only need to\n   130→    // worry about self-dependency.\n   131→\n   132→    // Actually re-reading the requirements: \"Circular dependencies (direct or indirect)\n   133→    // must be detected and rejected at task-creation time.\"\n   134→    // This means we need to check the FULL dependency graph.\n   135→    // Since this is a new task, the only way to have a cycle is if it depends on itself.\n   136→    // No existing task can reference this new task's ID since it hasn't been created yet.\n   137→\n   138→    return false;\n   139→  }\n   140→\n   141→  // ---- Phase 1: Basic FIFO Queue ----\n   142→\n   143→  addTask<T = unknown>(payload: T, options?: TaskOptions): Task<T>;\n   144→  addTask<T = unknown>(payload: T, queueName?: string, options?: TaskOptions): Task<T>;\n   145→  addTask<T = unknown>(payload: T, queueNameOrOptions?: string | TaskOptions, maybeOptions?: TaskOptions): Task<T> {\n   146→    if (this.isShuttingDown) {\n   147→      throw new Error('Cannot add tasks: system is shutting down.');\n   148→    }\n   149→\n   150→    let queueName: string = DEFAULT_QUEUE;\n   151→    let options: TaskOptions = {};\n   152→\n   153→    if (typeof queueNameOrOptions === 'string') {\n   154→      queueName = queueNameOrOptions;\n   155→      options = maybeOptions ?? {};\n   156→    } else if (typeof queueNameOrOptions === 'object' && queueNameOrOptions !== null) {\n   157→      options = queueNameOrOptions;\n   158→    }\n   159→\n   160→    // Validate dependencies\n   161→    if (options.dependencies && options.dependencies.length > 0) {\n   162→      for (const depId of options.dependencies) {\n   163→        if (!this.allTasks.has(depId)) {\n   164→          throw new Error(`Dependency task not found: ${depId}`);\n   165→        }\n   166→      }\n   167→    }\n   168→\n   169→    const task = createTask(payload, queueName, options);\n   170→\n   171→    // Check circular dependencies (for a new task, only self-reference is possible,\n   172→    // but let's be thorough and check transitive deps)\n   173→    if (options.dependencies && options.dependencies.length > 0) {\n   174→      // Check: does any dependency transitively list any of our other deps in a cycle?\n   175→      // Actually for a NEW task that doesn't exist yet, no existing task can reference it,\n   176→      // so no cycle through this task is possible. But we check self-reference.\n   177→      if (options.dependencies.includes(task.id)) {\n   178→        throw new Error('Circular dependency detected: task cannot depend on itself.');\n   179→      }\n   180→    }\n   181→\n   182→    // Mark already-completed dependencies as resolved\n   183→    if (task.dependencies.length > 0) {\n   184→      for (const depId of task.dependencies) {\n   185→        const depTask = this.allTasks.get(depId);\n   186→        if (depTask && depTask.status === 'completed') {\n   187→          task.resolvedDependencies.add(depId);\n   188→        }\n   189→      }\n   190→    }\n   191→\n   192→    const queue = this.getOrCreateQueue(queueName);\n   193→    queue.tasks.set(task.id, task);\n   194→    const order = this.globalInsertionCounter++;\n   195→    queue.insertionMap.set(task.id, order);\n   196→    this.allTasks.set(task.id, task);\n   197→    this.taskInsertionOrder.set(task.id, order);\n   198→\n   199→    return task;\n   200→  }\n   201→\n   202→  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {\n   203→    const queue = this.getQueue(queueName);\n   204→    if (!queue) return null;\n   205→\n   206→    // Check concurrency limit\n   207→    if (queue.concurrencyLimit !== null) {\n   208→      const activeCount = this.getActiveCount(queueName);\n   209→      if (activeCount >= queue.concurrencyLimit) {\n   210→        return null;\n   211→      }\n   212→    }\n   213→\n   214→    const now = Date.now();\n   215→    let bestTask: Task | null = null;\n   216→    let bestOrder = Infinity;\n   217→\n   218→    for (const task of queue.tasks.values()) {\n   219→      if (task.status !== 'pending') continue;\n   220→      if (task.availableAt > now) continue;\n   221→      if (this.isTaskBlocked(task)) continue;\n   222→\n   223→      const taskOrder = queue.insertionMap.get(task.id) ?? Infinity;\n   224→\n   225→      if (bestTask === null) {\n   226→        bestTask = task;\n   227→        bestOrder = taskOrder;\n   228→        continue;\n   229→      }\n   230→\n   231→      // Compare by priority first (lower = higher priority)\n   232→      if (task.priority < bestTask.priority) {\n   233→        bestTask = task;\n   234→        bestOrder = taskOrder;\n   235→      } else if (task.priority === bestTask.priority) {\n   236→        // FIFO within same priority\n   237→        if (taskOrder < bestOrder) {\n   238→          bestTask = task;\n   239→          bestOrder = taskOrder;\n   240→        }\n   241→      }\n   242→    }\n   243→\n   244→    if (bestTask) {\n   245→      bestTask.status = 'processing';\n   246→      bestTask.attempts++;\n   247→    }\n   248→\n   249→    return bestTask;\n   250→  }\n   251→\n   252→  getWaitingCount(queueName: string = DEFAULT_QUEUE): number {\n   253→    const queue = this.getQueue(queueName);\n   254→    if (!queue) return 0;\n   255→    let count = 0;\n   256→    for (const task of queue.tasks.values()) {\n   257→      if (task.status === 'pending') count++;\n   258→    }\n   259→    return count;\n   260→  }\n   261→\n   262→  // ---- Phase 2: Named Queues ----\n   263→\n   264→  getQueueNames(): string[] {\n   265→    return Array.from(this.queues.keys());\n   266→  }\n   267→\n   268→  // ---- Phase 5: Complete/Fail ----\n   269→\n   270→  completeTask(taskId: string): void {\n   271→    const task = this.allTasks.get(taskId);\n   272→    if (!task) {\n   273→      throw new Error(`Task not found: ${taskId}`);\n   274→    }\n   275→    if (task.status !== 'processing') {\n   276→      throw new Error(`Cannot complete task in \"${task.status}\" status. Task must be in \"processing\" state.`);\n   277→    }\n   278→\n   279→    task.status = 'completed';\n   280→    task.progress = { percentage: 100 };\n   281→\n   282→    // Remove from queue's active tasks\n   283→    const queue = this.getQueue(task.queueName);\n   284→    if (queue) {\n   285→      queue.tasks.delete(task.id);\n   286→      queue.insertionMap.delete(task.id);\n   287→    }\n   288→\n   289→    // Resolve dependencies\n   290→    this.resolveDependency(taskId);\n   291→  }\n   292→\n   293→  failTask(taskId: string, error?: string): void {\n   294→    const task = this.allTasks.get(taskId);\n   295→    if (!task) {\n   296→      throw new Error(`Task not found: ${taskId}`);\n   297→    }\n   298→    if (task.status !== 'processing') {\n   299→      throw new Error(`Cannot fail task in \"${task.status}\" status. Task must be in \"processing\" state.`);\n   300→    }\n   301→\n   302→    task.error = error;\n   303→\n   304→    // Check if retries remaining\n   305→    if (task.attempts < task.maxRetries) {\n   306→      // Re-add with exponential backoff\n   307→      const backoff = task.backoffDelay * Math.pow(2, task.attempts - 1);\n   308→      task.status = 'pending';\n   309→      task.availableAt = Date.now() + backoff;\n   310→      task.progress = { percentage: 0 };\n   311→      // Task stays in its queue, just goes back to pending with a delay\n   312→    } else {\n   313→      // No more retries - move to DLQ\n   314→      task.status = 'failed';\n   315→      const queue = this.getQueue(task.queueName);\n   316→      if (queue) {\n   317→        queue.tasks.delete(task.id);\n   318→        queue.insertionMap.delete(task.id);\n   319→        queue.deadLetterQueue.push(task);\n   320→      }\n   321→    }\n   322→  }\n   323→\n   324→  // ---- Phase 6: Dead Letter Queue ----\n   325→\n   326→  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {\n   327→    const queue = this.getQueue(queueName);\n   328→    if (!queue) return [];\n   329→    return [...queue.deadLetterQueue];\n   330→  }\n   331→\n   332→  redriveTask(taskId: string): Task {\n   333→    // Find the task in any DLQ\n   334→    for (const [queueName, queue] of this.queues) {\n   335→      const index = queue.deadLetterQueue.findIndex(t => t.id === taskId);\n   336→      if (index !== -1) {\n   337→        const task = queue.deadLetterQueue.splice(index, 1)[0];\n   338→        // Reset for fresh retries\n   339→        task.status = 'pending';\n   340→        task.attempts = 0;\n   341→        task.error = undefined;\n   342→        task.availableAt = Date.now();\n   343→        task.progress = { percentage: 0 };\n   344→\n   345→        // Re-add to original queue\n   346→        queue.tasks.set(task.id, task);\n   347→        const order = this.globalInsertionCounter++;\n   348→        queue.insertionMap.set(task.id, order);\n   349→        this.taskInsertionOrder.set(task.id, order);\n   350→\n   351→        return task;\n   352→      }\n   353→    }\n   354→    throw new Error(`Task not found in dead letter queue: ${taskId}`);\n   355→  }\n   356→\n   357→  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): number {\n   358→    const queue = this.getQueue(queueName);\n   359→    if (!queue) return 0;\n   360→    const count = queue.deadLetterQueue.length;\n   361→    queue.deadLetterQueue = [];\n   362→    return count;\n   363→  }\n   364→\n   365→  // ---- Phase 7: Task Dependencies ----\n   366→\n   367→  getTaskDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } {\n   368→    const task = this.allTasks.get(taskId);\n   369→    if (!task) {\n   370→      throw new Error(`Task not found: ${taskId}`);\n   371→    }\n   372→    const resolved = task.dependencies.filter(d => task.resolvedDependencies.has(d));\n   373→    const pending = task.dependencies.filter(d => !task.resolvedDependencies.has(d));\n   374→    return { dependencies: [...task.dependencies], resolved, pending };\n   375→  }\n   376→\n   377→  // ---- Phase 8: Concurrency Control ----\n   378→\n   379→  setConcurrency(queueName: string, limit: number | null): void {\n   380→    const queue = this.getOrCreateQueue(queueName);\n   381→    queue.concurrencyLimit = limit;\n   382→  }\n   383→\n   384→  getConcurrency(queueName: string = DEFAULT_QUEUE): { limit: number | null; active: number } {\n   385→    const queue = this.getQueue(queueName);\n   386→    if (!queue) return { limit: null, active: 0 };\n   387→    return {\n   388→      limit: queue.concurrencyLimit,\n   389→      active: this.getActiveCount(queueName),\n   390→    };\n   391→  }\n   392→\n   393→  // ---- Phase 9: Progress Tracking and Cancellation ----\n   394→\n   395→  updateProgress(taskId: string, percentage: number, message?: string): void {\n   396→    const task = this.allTasks.get(taskId);\n   397→    if (!task) {\n   398→      throw new Error(`Task not found: ${taskId}`);\n   399→    }\n   400→    if (task.status !== 'processing') {\n   401→      throw new Error(`Cannot update progress for task in \"${task.status}\" status.`);\n   402→    }\n   403→    if (percentage < 0 || percentage > 100) {\n   404→      throw new Error(`Progress must be between 0 and 100, got ${percentage}.`);\n   405→    }\n   406→\n   407→    task.progress = { percentage, message };\n   408→\n   409→    // Notify listeners\n   410→    const listeners = this.progressListeners.get(taskId);\n   411→    if (listeners) {\n   412→      for (const listener of listeners) {\n   413→        listener(task.progress);\n   414→      }\n   415→    }\n   416→  }\n   417→\n   418→  getProgress(taskId: string): TaskProgress {\n   419→    const task = this.allTasks.get(taskId);\n   420→    if (!task) {\n   421→      throw new Error(`Task not found: ${taskId}`);\n   422→    }\n   423→    return { ...task.progress };\n   424→  }\n   425→\n   426→  onProgress(taskId: string, listener: ProgressListener): () => void {\n   427→    const task = this.allTasks.get(taskId);\n   428→    if (!task) {\n   429→      throw new Error(`Task not found: ${taskId}`);\n   430→    }\n   431→\n   432→    if (!this.progressListeners.has(taskId)) {\n   433→      this.progressListeners.set(taskId, new Set());\n   434→    }\n   435→    this.progressListeners.get(taskId)!.add(listener);\n   436→\n   437→    // Return unsubscribe function\n   438→    return () => {\n   439→      const listeners = this.progressListeners.get(taskId);\n   440→      if (listeners) {\n   441→        listeners.delete(listener);\n   442→        if (listeners.size === 0) {\n   443→          this.progressListeners.delete(taskId);\n   444→        }\n   445→      }\n   446→    };\n   447→  }\n   448→\n   449→  cancelTask(taskId: string): void {\n   450→    const task = this.allTasks.get(taskId);\n   451→    if (!task) {\n   452→      throw new Error(`Task not found: ${taskId}`);\n   453→    }\n   454→    if (task.status !== 'pending' && task.status !== 'processing') {\n   455→      throw new Error(`Cannot cancel task in \"${task.status}\" status.`);\n   456→    }\n   457→\n   458→    const previousStatus = task.status;\n   459→    task.status = 'cancelled';\n   460→\n   461→    if (previousStatus === 'pending') {\n   462→      // Remove from queue\n   463→      const queue = this.getQueue(task.queueName);\n   464→      if (queue) {\n   465→        queue.tasks.delete(task.id);\n   466→        queue.insertionMap.delete(task.id);\n   467→      }\n   468→    }\n   469→    // For processing tasks, just update status (concurrency slot freed)\n   470→  }\n   471→\n   472→  // ---- Phase 10: Recurring Tasks ----\n   473→\n   474→  addSchedule(\n   475→    cronExpression: string,\n   476→    queueName: string,\n   477→    payload: unknown,\n   478→    taskOptions?: Omit<TaskOptions, 'dependencies' | 'delay' | 'processAt'>\n   479→  ): string {\n   480→    const parsed = parseCron(cronExpression);\n   481→    const id = randomUUID();\n   482→    this.schedules.set(id, {\n   483→      id,\n   484→      cronExpression,\n   485→      queueName,\n   486→      payload,\n   487→      taskOptions,\n   488→      parsed,\n   489→      lastRun: undefined,\n   490→    });\n   491→    return id;\n   492→  }\n   493→\n   494→  removeSchedule(scheduleId: string): boolean {\n   495→    return this.schedules.delete(scheduleId);\n   496→  }\n   497→\n   498→  getSchedules(): ScheduleEntry[] {\n   499→    return Array.from(this.schedules.values()).map(({ parsed: _, ...entry }) => entry);\n   500→  }\n   501→\n   502→  tick(now: Date = new Date()): Task[] {\n   503→    const enqueued: Task[] = [];\n   504→\n   505→    for (const schedule of this.schedules.values()) {\n   506→      if (isDue(schedule.parsed, now, schedule.lastRun)) {\n   507→        schedule.lastRun = now.getTime();\n   508→        const task = this.addTask(schedule.payload, schedule.queueName, schedule.taskOptions as TaskOptions);\n   509→        enqueued.push(task);\n   510→      }\n   511→    }\n   512→\n   513→    return enqueued;\n   514→  }\n   515→\n   516→  // ---- Phase 11: Middleware ----\n   517→\n   518→  use(queueName: string, middleware: Middleware): void {\n   519→    const queue = this.getOrCreateQueue(queueName);\n   520→    queue.middlewares.push(middleware);\n   521→  }\n   522→\n   523→  setHandler(queueName: string, handler: TaskHandler): void {\n   524→    const queue = this.getOrCreateQueue(queueName);\n   525→    queue.handler = handler;\n   526→  }\n   527→\n   528→  async processTask(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {\n   529→    const task = this.getNextTask(queueName);\n   530→    if (!task) return null;\n   531→\n   532→    const queue = this.getQueue(queueName);\n   533→    if (!queue) return null;\n   534→\n   535→    const middlewares = [...queue.middlewares];\n   536→    const handler = queue.handler;\n   537→\n   538→    let index = 0;\n   539→\n   540→    const executeNext = async (): Promise<void> => {\n   541→      if (index < middlewares.length) {\n   542→        const mw = middlewares[index++];\n   543→        await mw(task, executeNext);\n   544→      } else if (handle