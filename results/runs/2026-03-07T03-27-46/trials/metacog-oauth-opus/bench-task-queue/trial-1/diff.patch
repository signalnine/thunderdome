he deps?\n    // Since newTaskId isn't in the graph yet, the answer is always no for a new task.\n    // But we should check for cycles among the provided dependencies themselves.\n\n    // Actually the real check is: do any of the tasks that we'll eventually unblock\n    // already transitively depend on one of our dependencies?\n    // Since this task is new, no one depends on it yet. So no cycle from a new task.\n    // However, we should also think about: what if dep A depends on dep B and dep B depends on dep A?\n    // That's not our problem to detect here - that would have been caught when they were created.\n\n    // The main cycle case: task depends on itself\n    if (dependencies.includes(newTaskId)) return true;\n\n    // For existing tasks that we depend on: check if they (transitively) depend on each other\n    // in a way that would create a cycle. But again, since we're new, no cycle is possible\n    // unless we depend on ourselves.\n\n    // Wait - there's another case: what if we're adding task C that depends on B,\n    // and later someone adds task D that depends on C and A, where A depends on D?\n    // That would be caught when D is added. So for a new task, we only need to\n    // worry about self-dependency.\n\n    // Actually re-reading the requirements: \"Circular dependencies (direct or indirect)\n    // must be detected and rejected at task-creation time.\"\n    // This means we need to check the FULL dependency graph.\n    // Since this is a new task, the only way to have a cycle is if it depends on itself.\n    // No existing task can reference this new task's ID since it hasn't been created yet.\n\n    return false;\n  }\n\n  // ---- Phase 1: Basic FIFO Queue ----\n\n  addTask<T = unknown>(payload: T, options?: TaskOptions): Task<T>;\n  addTask<T = unknown>(payload: T, queueName?: string, options?: TaskOptions): Task<T>;\n  addTask<T = unknown>(payload: T, queueNameOrOptions?: string | TaskOptions, maybeOptions?: TaskOptions): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: system is shutting down.');\n    }\n\n    let queueName: string = DEFAULT_QUEUE;\n    let options: TaskOptions = {};\n\n    if (typeof queueNameOrOptions === 'string') {\n      queueName = queueNameOrOptions;\n      options = maybeOptions ?? {};\n    } else if (typeof queueNameOrOptions === 'object' && queueNameOrOptions !== null) {\n      options = queueNameOrOptions;\n    }\n\n    // Validate dependencies\n    if (options.dependencies && options.dependencies.length > 0) {\n      for (const depId of options.dependencies) {\n        if (!this.allTasks.has(depId)) {\n          throw new Error(`Dependency task not found: ${depId}`);\n        }\n      }\n    }\n\n    const task = createTask(payload, queueName, options);\n\n    // Check circular dependencies (for a new task, only self-reference is possible,\n    // but let's be thorough and check transitive deps)\n    if (options.dependencies && options.dependencies.length > 0) {\n      // Check: does any dependency transitively list any of our other deps in a cycle?\n      // Actually for a NEW task that doesn't exist yet, no existing task can reference it,\n      // so no cycle through this task is possible. But we check self-reference.\n      if (options.dependencies.includes(task.id)) {\n        throw new Error('Circular dependency detected: task cannot depend on itself.');\n      }\n    }\n\n    // Mark already-completed dependencies as resolved\n    if (task.dependencies.length > 0) {\n      for (const depId of task.dependencies) {\n        const depTask = this.allTasks.get(depId);\n        if (depTask && depTask.status === 'completed') {\n          task.resolvedDependencies.add(depId);\n        }\n      }\n    }\n\n    const queue = this.getOrCreateQueue(queueName);\n    queue.tasks.set(task.id, task);\n    const order = this.globalInsertionCounter++;\n    queue.insertionMap.set(task.id, order);\n    this.allTasks.set(task.id, task);\n   