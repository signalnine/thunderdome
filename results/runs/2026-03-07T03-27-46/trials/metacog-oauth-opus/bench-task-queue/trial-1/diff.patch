ayload: T, queueNameOrOptions?: string | TaskOptions, maybeOptions?: TaskOptions): Task<T> {\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: system is shutting down.');\n    }\n\n    let queueName: string = DEFAULT_QUEUE;\n    let options: TaskOptions = {};\n\n    if (typeof queueNameOrOptions === 'string') {\n      queueName = queueNameOrOptions;\n      options = maybeOptions ?? {};\n    } else if (typeof queueNameOrOptions === 'object' && queueNameOrOptions !== null) {\n      options = queueNameOrOptions;\n    }\n\n    // Validate dependencies\n    if (options.dependencies && options.dependencies.length > 0) {\n      for (const depId of options.dependencies) {\n        if (!this.allTasks.has(depId)) {\n          throw new Error(`Dependency task not found: ${depId}`);\n        }\n      }\n    }\n\n    const task = createTask(payload, queueName, options);\n\n    // Check circular dependencies (for a new task, only self-reference is possible,\n    // but let's be thorough and check transitive deps)\n    if (options.dependencies && options.dependencies.length > 0) {\n      // Check: does any dependency transitively list any of our other deps in a cycle?\n      // Actually for a NEW task that doesn't exist yet, no existing task can reference it,\n      // so no cycle through this task is possible. But we check self-reference.\n      if (options.dependencies.includes(task.id)) {\n        throw new Error('Circular dependency detected: task cannot depend on itself.');\n      }\n    }\n\n    // Mark already-completed dependencies as resolved\n    if (task.dependencies.length > 0) {\n      for (const depId of task.dependencies) {\n        const depTask = this.allTasks.get(depId);\n        if (depTask && depTask.status === 'completed') {\n          task.resolvedDependencies.add(depId);\n        }\n      }\n    }\n\n    const queue = this.getOrCreateQueue(queueName);\n    queue.tasks.set(task.id, task);\n    const order = this.globalInsertionCounter+