lt.unscheduled).toHaveLength(0);\n      // Events should be in different rooms since each takes the full day\n      const roomIds = result.assignments.map((a) => a.roomId);\n      expect(new Set(roomIds).size).toBe(2);\n    });\n  });\n\n  describe(\"unscheduled events\", () => {\n    it(\"should report events that cannot be scheduled\", () => {\n      const rooms: Room[] = [{ id: \"r1\", name: \"Room 1\", capacity: 10 }];\n      const events: Event[] = [\n        { id: \"e1\", name: \"Event 1\", duration: 400 },\n        { id: \"e2\", name: \"Event 2\", duration: 400 },\n      ];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 1020,\n        gap: 15,\n      };\n      const result = schedule(events, rooms, options);\n\n      // Only one can fit in the 480-minute window with gap\n      expect(result.assignments.length + result.unscheduled.length).toBe(2);\n    });\n\n    it(\"should not throw for unschedulable events (non-cycle)\", () => {\n      const rooms: Room[] = [{ id: \"r1\", name: \"Room 1\", capacity: 1 }];\n      const events: Event[] = [\n        { id: \"e1\", name: \"Event 1\", duration: 60, attendees: 100 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.unscheduled).toContain(\"e1\");\n      expect(result.assignments).toHaveLength(0);\n    });\n  });\n\n  describe(\"complex scenarios\", () => {\n    it(\"should handle a conference-like schedule\", () => {\n      const rooms: Room[] = [\n        { id: \"main-hall\", name: \"Main Hall\", capacity: 100 },\n        { id: \"breakout-1\", name: \"Breakout 1\", capacity: 30 },\n        { id: \"breakout-2\", name: \"Breakout 2\", capacity: 30 },\n      ];\n      const events: Event[] = [\n        {\n          id: \"keynote\",\n          name: \"Keynote\",\n          duration: 90,\n          attendees: 80,\n          preferredRoom: \"main-hall\",\n        },\n        {\n          id: \"workshop-a\",\n          name: \"Workshop 