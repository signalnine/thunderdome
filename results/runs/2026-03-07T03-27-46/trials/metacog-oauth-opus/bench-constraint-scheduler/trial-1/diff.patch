e: \"Event 3\", duration: 60 },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it(\"should assign start and end times correctly based on duration\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Event 1\", duration: 90 },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n\n      const a = result.assignments[0];\n      expect(a.endTime - a.startTime).toBe(90);\n    });\n  });\n\n  describe(\"time window constraints\", () => {\n    it(\"should not schedule events that exceed the time window\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Long Event\", duration: 600 }, // 10 hours\n      ];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 1020, // 8-hour window\n      };\n      const result = schedule(events, defaultRooms, options);\n\n      expect(result.unscheduled).toContain(\"e1\");\n    });\n\n    it(\"should respect start and end time boundaries\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Event 1\", duration: 60 },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n\n      const a = result.assignments[0];\n      expect(a.startTime).toBeGreaterThanOrEqual(540);\n      expect(a.endTime).toBeLessThanOrEqual(1020);\n    });\n\n    it(\"should fit events exactly within the time window\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Exact Fit\", duration: 480 }, // exactly 8 hours\n      ];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 1020,\n      };\n      const result = schedule(events, defaultRooms, options);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n  });\n\n  describe(\"room capacity constraints\", () => {\n    it(\"should not assign events to rooms with insufficient capacity\", () => {\n      const rooms: Room[] = [{ id: \"small\", name: \"Small Room\", capacity: 5 }];\n      const events: Event[] = [\n        { id: \"e1\", name: \"Big Event\", duration: 60, attendees: 10 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.unscheduled).toContain(\"e1\");\n    });\n\n    it(\"should assign events to rooms with sufficient capacity\", () => {\n      const rooms: Room[] = [\n        { id: \"small\", name: \"Small Room\", capacity: 5 },\n        { id: \"large\", name: \"Large Room\", capacity: 50 },\n      ];\n      const events: Event[] = [\n        { id: \"e1\", name: \"Big Event\", duration: 60, attendees: 30 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe(\"large\");\n    });\n\n    it(\"should default attendees to 1 if not specified\", () => {\n      const rooms: Room[] = [\n        { id: \"tiny\", name: \"Tiny Room\", capacity: 1 },\n      ];\n      const events: Event[] = [\n        { id: \"e1\", name: \"Solo Event\", duration: 60 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe(\"room gaps\", () => {\n    it(\"should maintain default 15-minute gap between events in same room\", () => {\n      const rooms: Room[] = [{ id: \"r1\", name: \"Room 1\", capacity: 10 }];\n      const events: Event[] = [\n        { id: \"e1\", name: \"Event 1\", duration: 60 },\n        { id: \"e2\", name: \"Event 2\", duration: 60 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);\n    });\n\n    it(\"should respect custom gap setting\", () => {\n      const rooms: Room[] = [{ id: \"r1\", name: \"Room 1\", capacity: 10 }];\n      const events: Event[] = [\n        { id: \"e1\", name: \"Event 1\", duration: 60 },\n        { id: \"e2\", name: \"Event 2\", duration: 60 },\n      ];\n      const options: ScheduleOptions = {\n        ...defaultOptions,\n        gap: 30,\n      };\n      const result = schedule(events, rooms, options);\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);\n    });\n\n    it(\"should allow gap of 0\", () => {\n      const rooms: Room[] = [{ id: \"r1\", name: \"Room 1\", capacity: 10 }];\n      const events: Event[] = [\n        { id: \"e1\", name: \"Event 1\", duration: 60 },\n        { id: \"e2\", name: \"Event 2\", duration: 60 },\n      ];\n      const options: ScheduleOptions = {\n        ...defaultOptions,\n        gap: 0,\n      };\n      const result = schedule(events, rooms, options);\n\n      expect(result.assignments).toHaveLength(2);\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      // With gap=0, events can be back-to-back\n      expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime);\n    });\n  });\n\n  describe(\"prerequisites\", () => {\n    it(\"should schedule prerequisite events before dependent events\", () => {\n      const events: Event[] = [\n        { id: \"e2\", name: \"Event 2\", duration: 60, prerequisites: [\"e1\"] },\n        { id: \"e1\", name: \"Event 1\", duration: 60 },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      const e1 = result.assignments.find((a) => a.eventId === \"e1\")!;\n      const e2 = result.assignments.find((a) => a.eventId === \"e2\")!;\