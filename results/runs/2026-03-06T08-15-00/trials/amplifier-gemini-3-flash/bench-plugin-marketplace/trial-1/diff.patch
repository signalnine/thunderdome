diff --git a/src/deps.ts b/src/deps.ts
new file mode 100644
index 0000000..1473538
--- /dev/null
+++ b/src/deps.ts
@@ -0,0 +1,132 @@
+import semver from 'semver';
+import { DepsService, RegistryService, DependencyNode, PluginManifest } from './types.js';
+
+export class DependencyGraph implements DepsService {
+  buildTree(name: string, registry: RegistryService): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      throw new Error(`Plugin ${name} not found`);
+    }
+
+    return this.buildNode(manifest, registry, new Set());
+  }
+
+  private buildNode(manifest: PluginManifest, registry: RegistryService, visited: Set<string>): DependencyNode {
+    const node: DependencyNode = {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies: [],
+    };
+
+    const newVisited = new Set(visited);
+    newVisited.add(`${manifest.name}@${manifest.version}`);
+
+    for (const [depName, range] of Object.entries(manifest.dependencies)) {
+      const versions = registry.listVersions(depName);
+      const bestVersion = semver.maxSatisfying(versions, range);
+      
+      if (!bestVersion) {
+        throw new Error(`No satisfying version found for ${depName}@${range}`);
+      }
+
+      const depManifest = registry.getVersion(depName, bestVersion);
+      if (!depManifest) {
+        throw new Error(`Plugin ${depName}@${bestVersion} not found in registry`);
+      }
+
+      // We still build the node even if there's a cycle for the tree structure, 
+      // but we need to be careful about infinite recursion.
+      if (visited.has(`${depName}@${bestVersion}`)) {
+        node.dependencies.push({
+          name: depName,
+          version: bestVersion,
+          dependencies: []
+        });
+      } else {
+        node.dependencies.push(this.buildNode(depManifest, registry, newVisited));
+      }
+    }
+
+    return node;
+  }
+
+  detectCycles(name: string, registry: RegistryService): string[][] | null {
+    const cycles: string[][] = [];
+    this.findCycles(name, registry, [], new Set(), cycles);
+    return cycles.length > 0 ? cycles : null;
+  }
+
+  private findCycles(
+    name: string, 
+    registry: RegistryService, 
+    path: string[], 
+    visited: Set<string>, 
+    cycles: string[][]
+  ) {
+    if (path.includes(name)) {
+      const cycle = path.slice(path.indexOf(name));
+      cycles.push([...cycle, name]);
+      return;
+    }
+
+    if (visited.has(name)) return;
+
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    visited.add(name);
+    for (const depName of Object.keys(manifest.dependencies)) {
+      this.findCycles(depName, registry, [...path, name], visited, cycles);
+    }
+  }
+
+  topologicalSort(name: string, registry: RegistryService): string[] {
+    const sorted: string[] = [];
+    const visited = new Set<string>();
+    const tempVisited = new Set<string>();
+
+    const visit = (n: string) => {
+      if (tempVisited.has(n)) {
+        throw new Error('Circular dependency detected during topological sort');
+      }
+      if (visited.has(n)) return;
+
+      tempVisited.add(n);
+      const manifest = registry.get(n);
+      if (manifest) {
+        for (const depName of Object.keys(manifest.dependencies)) {
+          visit(depName);
+        }
+      }
+      tempVisited.delete(n);
+      visited.add(n);
+      sorted.push(n);
+    };
+
+    visit(name);
+    return sorted;
+  }
+
+  flattenDependencies(name: string, registry: RegistryService): string[] {
+    const deps = new Set<string>();
+    
+    const visit = (n: string) => {
+      const manifest = registry.get(n);
+      if (!manifest) return;
+
+      for (const depName of Object.keys(manifest.dependencies)) {
+        if (!deps.has(depName)) {
+          deps.add(depName);
+          visit(depName);
+        }
+      }
+    };
+
+    visit(name);
+    return Array.from(deps);
+  }
+
+  hasCircularDependency(name: string, registry: RegistryService): boolean {
+    return this.detectCycles(name, registry) !== null;
+  }
+}
