diff --git a/tests/marketplace.test.ts b/tests/marketplace.test.ts
new file mode 100644
index 0000000..4a7bc19
--- /dev/null
+++ b/tests/marketplace.test.ts
@@ -0,0 +1,174 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace, Marketplace } from '../src/index.js';
+import { PluginManifest } from '../src/types.js';
+
+describe('Plugin Marketplace', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should register and retrieve a plugin', () => {
+    const manifest: PluginManifest = {
+      name: 'test-plugin',
+      version: '1.0.0',
+      description: 'A test plugin',
+      author: 'Test Author',
+      dependencies: {},
+      entryPoint: '"Hello World"',
+      permissions: [],
+    };
+
+    marketplace.registry.register(manifest);
+    const retrieved = marketplace.registry.get('test-plugin');
+    expect(retrieved).toEqual(manifest);
+  });
+
+  it('should resolve versions correctly', () => {
+    marketplace.registry.register({
+      name: 'dep',
+      version: '1.0.0',
+      description: '',
+      author: '',
+      dependencies: {},
+      entryPoint: '',
+      permissions: [],
+    });
+    marketplace.registry.register({
+      name: 'dep',
+      version: '1.1.0',
+      description: '',
+      author: '',
+      dependencies: {},
+      entryPoint: '',
+      permissions: [],
+    });
+
+    const constraints = [{ name: 'dep', range: '^1.0.0' }];
+    const available = { dep: ['1.0.0', '1.1.0'] };
+    const resolved = marketplace.resolver.resolve(constraints, available);
+
+    expect(resolved[0].version).toBe('1.1.0');
+  });
+
+  it('should execute code in a sandbox', async () => {
+    const result = await marketplace.runner.execute('1 + 1');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(2);
+  });
+
+  it('should handle reviews and ratings', () => {
+    marketplace.reviews.addReview({
+      pluginName: 'test-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 5,
+      comment: 'Great!',
+    });
+    marketplace.reviews.addReview({
+      pluginName: 'test-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user2',
+      rating: 3,
+      comment: 'Okay',
+    });
+
+    expect(marketplace.reviews.getAverageRating('test-plugin')).toBe(4);
+    expect(marketplace.reviews.getReviewCount('test-plugin')).toBe(2);
+
+    const reviews = marketplace.reviews.getReviews('test-plugin');
+    marketplace.reviews.flagReview(reviews[0].id);
+
+    expect(marketplace.reviews.getAverageRating('test-plugin')).toBe(3);
+    expect(marketplace.reviews.getReviewCount('test-plugin')).toBe(1);
+  });
+
+  it('should build dependency tree and detect cycles', () => {
+    marketplace.registry.register({
+      name: 'A',
+      version: '1.0.0',
+      description: '',
+      author: '',
+      dependencies: { 'B': '1.0.0' },
+      entryPoint: '',
+      permissions: [],
+    });
+    marketplace.registry.register({
+      name: 'B',
+      version: '1.0.0',
+      description: '',
+      author: '',
+      dependencies: { 'C': '1.0.0' },
+      entryPoint: '',
+      permissions: [],
+    });
+    marketplace.registry.register({
+      name: 'C',
+      version: '1.0.0',
+      description: '',
+      author: '',
+      dependencies: { 'A': '1.0.0' },
+      entryPoint: '',
+      permissions: [],
+    });
+
+    expect(marketplace.deps.hasCircularDependency('A', marketplace.registry)).toBe(true);
+    const cycles = marketplace.deps.detectCycles('A', marketplace.registry);
+    expect(cycles).not.toBeNull();
+    expect(cycles![0]).toContain('A');
+    expect(cycles![0]).toContain('B');
+    expect(cycles![0]).toContain('C');
+  });
+
+  it('should perform install workflow', async () => {
+    marketplace.registry.register({
+      name: 'dep-a',
+      version: '1.0.0',
+      description: '',
+      author: '',
+      dependencies: {},
+      entryPoint: 'true',
+      permissions: [],
+    });
+
+    const manifest: PluginManifest = {
+      name: 'main-plugin',
+      version: '1.0.0',
+      description: 'Main',
+      author: 'Author',
+      dependencies: { 'dep-a': '^1.0.0' },
+      entryPoint: '42',
+      permissions: [],
+    };
+
+    const result = await marketplace.installPlugin(manifest);
+    expect(result.resolvedDependencies[0].name).toBe('dep-a');
+    expect(result.resolvedDependencies[0].version).toBe('1.0.0');
+    expect(result.executionResult.output).toBe(42);
+  });
+
+  it('should reject circular dependencies during install', async () => {
+    marketplace.registry.register({
+      name: 'B',
+      version: '1.0.0',
+      description: '',
+      author: '',
+      dependencies: { 'A': '1.0.0' },
+      entryPoint: '',
+      permissions: [],
+    });
+
+    const manifest: PluginManifest = {
+      name: 'A',
+      version: '1.0.0',
+      description: '',
+      author: '',
+      dependencies: { 'B': '1.0.0' },
+      entryPoint: '1',
+      permissions: [],
+    };
+
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow('Circular dependency detected');
+  });
+});
