+import { DepsService, DependencyNode, RegistryService } from '../types';
+
+export class GraphDepsService implements DepsService {
+  private registry: RegistryService;
+
+  constructor(registry: RegistryService) {
+    this.registry = registry;
+  }
+
+  buildTree(name: string, registry: RegistryService): DependencyNode {
+    const reg = registry;
+    const manifestFn = (n: string) => reg.get(n);
+    return this.buildTreeRecursive(name, manifestFn, new Set());
+  }
+
+  private buildTreeRecursive(name: string, getManifestFn: (name: string) => any, visited: Set<string>): DependencyNode {
+    if (visited.has(name)) {
+      // We've seen this node before, return a minimal node to avoid infinite recursion
+      return { name, version: 'unknown', dependencies: [] };
+    }
+    
+    visited.add(name);
+    
+    const manifest = getManifestFn(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+    
+    const dependencies: DependencyNode[] = [];
+    for (const depName of Object.keys(manifest.dependencies)) {
+      // For simplicity, we'll use the latest version that satisfies the range
+      // In a real implementation, we'd resolve this properly
+      const depManifest = getManifestFn(depName);
+      if (depManifest) {
+        dependencies.push(this.buildTreeRecursive(depName, getManifestFn, new Set(visited)));
+      } else {
+        dependencies.push({ name: depName, version: 'unknown', dependencies: [] });
+      }
+    }
+    
+    return {
+      name: manifest.name,
+      version: manifest.version,
+      dependencies,
+    };
+  }
+
+  detectCycles(name: string, registry: RegistryService): string[][] | null {
+    const visited = new Set<string>();
+    const recStack = new Set<string>();
+    const cyclePaths: string[][] = [];
+    
+    const visit = (nodeName: string, path: string[]): boolean => {
+      if (recStack.has(nodeName)) {
+        // Found a cycle
+        const cycleStartIndex = path.indexOf(nodeName);
+        if (cycleStartIndex >= 0) {
+          cyclePaths.push([...path.slice(cycleStartIndex), nodeName]);
+        }
+        return true;
+      }
+      
+      if (visited.has(nodeName)) {
+        return false;
+      }
+      
+      visited.add(nodeName);
+      recStack.add(nodeName);
+      const currentPath = [...path, nodeName];
+      
+      const manifest = registry.get(nodeName);
+      if (manifest) {
+        for (const depName of Object.keys(manifest.dependencies)) {
+          if (visit(depName, currentPath)) {
+            return true;
+          }
+        }
+      }
+      
+      recStack.delete(nodeName);
+      return false;
+    };
+    
+    if (visit(name, [])) {
+      return cyclePaths;
+    }
+    return null;
+  }
+
+  topologicalSort(name: string, registry: RegistryService): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+    const temp = new Set<string>();
+    
+    const visit = (nodeName: string): void => {
+      if (temp.has(nodeName)) {
+        throw new Error(`Circular dependency detected involving ${nodeName}`);
+      }
+      
+      if (!visited.has(nodeName)) {
+        temp.add(nodeName);
+        const manifest = registry.get(nodeName);
+        if (manifest) {
+          for (const depName of Object.keys(manifest.dependencies)) {
+            visit(depName);
+          }
+        }
+        temp.delete(nodeName);
+        visited.add(nodeName);
+        result.push(nodeName);
+      }
+    };
+    
+    visit(name);
+    return result.reverse(); // Return in correct topological order
+  }
+
+  flattenDependencies(name: string, registry: RegistryService): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+    
+    const visit = (nodeName: string): void => {
+      if (!visited.has(nodeName)) {
+        visited.add(nodeName);
+        const manifest = registry.get(nodeName);
+        if (manifest) {
+          for (const depName of Object.keys(manifest.dependencies)) {
+            visit(depName);
+          }
+        }
+        result.push(nodeName);
+      }
+    };
+    
+    visit(name);
+    // Remove the root node itself from the flattened list
+    return result.filter(n => n !== name);
+  }
+
+  hasCircularDependency(name: string, registry: RegistryService): boolean {
+    return this.detectCycles(name, registry) !== null;
+  }
+}
