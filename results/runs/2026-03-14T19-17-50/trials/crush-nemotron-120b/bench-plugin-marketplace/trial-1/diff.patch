+import DatabaseConstructor from 'better-sqlite3';
+import { ReviewService, Review } from '../types.ts';
+
+type Database = InstanceType<typeof DatabaseConstructor>;
+
+type Omit<T, K extends keyof T> = Pick<T, Exclude<keyof T, K>>;
+
+export class SqliteReviewService implements ReviewService {
+  private db: Database;
+
+  constructor(dbPath: string = ':memory:') {
+    this.db = new DatabaseConstructor(dbPath);
+    this.initializeSchema();
+  }
+
+  private initializeSchema(): void {
+    this.db.exec(`
+      CREATE TABLE IF NOT EXISTS reviews (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        pluginName TEXT NOT NULL,
+        pluginVersion TEXT NOT NULL,
+        userId TEXT NOT NULL,
+        rating INTEGER NOT NULL CHECK (rating >= 1 AND rating <= 5),
+        comment TEXT NOT NULL,
+        flagged BOOLEAN NOT NULL DEFAULT 0,
+        createdAt TEXT NOT NULL
+      );
+    `);
+  }
+
+  addReview(review: Omit<Review, 'id' | 'createdAt' | 'flagged'>): Review {
+    const now = new Date().toISOString();
+    const stmt = this.db.prepare(`
+      INSERT INTO reviews (pluginName, pluginVersion, userId, rating, comment, flagged, createdAt)
+      VALUES (@pluginName, @pluginVersion, @userId, @rating, @comment, @flagged, @createdAt)
+    `);
+    const info = stmt.run({
+      pluginName: review.pluginName,
+      pluginVersion: review.pluginVersion,
+      userId: review.userId,
+      rating: review.rating,
+      comment: review.comment,
+      flagged: false, // default not flagged
+      createdAt: now,
+    });
+    const id = info.lastInsertRowid as number;
+    return {
+      id,
+      pluginName: review.pluginName,
+      pluginVersion: review.pluginVersion,
+      userId: review.userId,
+      rating: review.rating,
+      comment: review.comment,
+      flagged: false,
+      createdAt: now,
+    };
+  }
+
+  getReviews(pluginName: string): Review[] {
+    const stmt = this.db.prepare(`
+      SELECT * FROM reviews WHERE pluginName = @pluginName ORDER BY createdAt DESC
+    `);
+    const rows = stmt.all({ pluginName }) as Record<string, unknown>[];
+    return rows.map(row => ({
+      id: Number(row.id),
+      pluginName: String(row.pluginName),
+      pluginVersion: String(row.pluginVersion),
+      userId: String(row.userId),
+      rating: Number(row.rating),
+      comment: String(row.comment),
+      flagged: Boolean(row.flagged),
+      createdAt: String(row.createdAt),
+    }));
+  }
+
+  getAverageRating(pluginName: string): number {
+    const stmt = this.db.prepare(`
+      SELECT AVG(rating) as avgRating FROM reviews 
+      WHERE pluginName = @pluginName AND flagged = 0
+    `);
+    const row = stmt.get({ pluginName }) as { avgRating: number } | null;
+    return row?.avgRating ?? 0;
+  }
+
+  flagReview(reviewId: number): void {
+    const stmt = this.db.prepare(`
+      UPDATE reviews SET flagged = 1 WHERE id = @reviewId
+    `);
+    stmt.run({ reviewId });
+  }
+
+  getFlaggedReviews(): Review[] {
+    const stmt = this.db.prepare(`
+      SELECT * FROM reviews WHERE flagged = 1 ORDER BY createdAt DESC
+    `);
+    const rows = stmt.all() as Record<string, unknown>[];
+    return rows.map(row => ({
+      id: Number(row.id),
+      pluginName: String(row.pluginName),
+      pluginVersion: String(row.pluginVersion),
+      userId: String(row.userId),
+      rating: Number(row.rating),
+      comment: String(row.comment),
+      flagged: Boolean(row.flagged),
+      createdAt: String(row.createdAt),
+    }));
+  }
+
+  removeReview(reviewId: number): boolean {
+    const stmt = this.db.prepare(`
+      DELETE FROM reviews WHERE id = @reviewId
+    `);
+    const info = stmt.run({ reviewId });
+    return info.changes > 0;
+  }
+
+  getReviewsByUser(userId: string): Review[] {
+    const stmt = this.db.prepare(`
+      SELECT * FROM reviews WHERE userId = @userId ORDER BY createdAt DESC
+    `);
+    const rows = stmt.all({ userId }) as Record<string, unknown>[];
+    return rows.map(row => ({
+      id: Number(row.id),
+      pluginName: String(row.pluginName),
+      pluginVersion: String(row.pluginVersion),
+      userId: String(row.userId),
+      rating: Number(row.rating),
+      comment: String(row.comment),
+      flagged: Boolean(row.flagged),
+      createdAt: String(row.createdAt),
+    }));
+  }
+
+  getReviewCount(pluginName: string): number {
+    const stmt = this.db.prepare(`
+      SELECT COUNT(*) as count FROM reviews WHERE pluginName = @pluginName AND flagged = 0
+    `);
+    const row = stmt.get({ pluginName }) as { count: number } | null;
+    return row?.count ?? 0;
+  }
+}
