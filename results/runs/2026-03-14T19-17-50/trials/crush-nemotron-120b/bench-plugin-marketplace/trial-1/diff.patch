+import DatabaseConstructor from 'better-sqlite3';
+import { PluginManifest, RegistryService } from '../types';
+
+type Database = InstanceType<typeof DatabaseConstructor>;
+
+export class SqliteRegistryService implements RegistryService {
+  private db: Database;
+
+  constructor(dbPath: string = ':memory:') {
+    this.db = new DatabaseConstructor(dbPath);
+    this.initializeSchema();
+  }
+
+  private initializeSchema(): void {
+    this.db.exec(`
+      CREATE TABLE IF NOT EXISTS plugins (
+        name TEXT NOT NULL,
+        version TEXT NOT NULL,
+        description TEXT NOT NULL,
+        author TEXT NOT NULL,
+        dependencies TEXT NOT NULL, -- JSON string
+        entryPoint TEXT NOT NULL,
+        permissions TEXT NOT NULL, -- JSON string
+        PRIMARY KEY (name, version)
+      );
+    `);
+  }
+
+  register(manifest: PluginManifest): void {
+    const stmt = this.db.prepare(`
+      INSERT OR REPLACE INTO plugins (name, version, description, author, dependencies, entryPoint, permissions)
+      VALUES (@name, @version, @description, @author, @dependencies, @entryPoint, @permissions)
+    `);
+    stmt.run({
+      name: manifest.name,
+      version: manifest.version,
+      description: manifest.description,
+      author: manifest.author,
+      dependencies: JSON.stringify(manifest.dependencies),
+      entryPoint: manifest.entryPoint,
+      permissions: JSON.stringify(manifest.permissions),
+    });
+  }
+
+  get(name: string): PluginManifest | null {
+    const stmt = this.db.prepare(`
+      SELECT * FROM plugins WHERE name = @name ORDER BY version DESC LIMIT 1
+    `);
+    const row = stmt.get({ name }) as Record<string, unknown> | null;
+    if (!row) return null;
+    return this.rowToManifest(row);
+  }
+
+  getVersion(name: string, version: string): PluginManifest | null {
+    const stmt = this.db.prepare(`
+      SELECT * FROM plugins WHERE name = @name AND version = @version
+    `);
+    const row = stmt.get({ name, version }) as Record<string, unknown> | null;
+    if (!row) return null;
+    return this.rowToManifest(row);
+  }
+
+  list(): PluginManifest[] {
+    const stmt = this.db.prepare(`SELECT * FROM plugins`);
+    const rows = stmt.all() as Record<string, unknown>[];
+    return rows.map(row => this.rowToManifest(row));
+  }
+
+  search(query: string): PluginManifest[] {
+    const stmt = this.db.prepare(`
+      SELECT * FROM plugins 
+      WHERE name LIKE @query OR description LIKE @query OR author LIKE @query
+    `);
+    const rows = stmt.all({ query: `%${query}%` }) as Record<string, unknown>[];
+    return rows.map(row => this.rowToManifest(row));
+  }
+
+  remove(name: string, version: string): boolean {
+    const stmt = this.db.prepare(`
+      DELETE FROM plugins WHERE name = @name AND version = @version
+    `);
+    const info = stmt.run({ name, version });
+    return info.changes > 0;
+  }
+
+  listVersions(name: string): string[] {
+    const stmt = this.db.prepare(`
+      SELECT version FROM plugins WHERE name = @name ORDER BY version
+    `);
+    const rows = stmt.all({ name }) as { version: string }[];
+    return rows.map(row => row.version);
+  }
+
+  update(name: string, version: string, updates: Partial<PluginManifest>): void {
+    const fields: string[] = [];
+    const values: { [key: string]: unknown } = { name: name, version: version };
+    const allowedUpdates: Array<keyof PluginManifest> = [
+      'description',
+      'author',
+      'dependencies',
+      'entryPoint',
+      'permissions',
+    ];
+    for (const field of allowedUpdates) {
+      if (updates[field] !== undefined) {
+        fields.push(`${field} = @${field}`);
+        if (field === 'dependencies' || field === 'permissions') {
+          values[field] = JSON.stringify(updates[field]);
+        } else {
+          values[field] = updates[field];
+        }
+      }
+    }
+    if (fields.length === 0) return;
+    const stmt = this.db.prepare(`
+      UPDATE plugins SET ${fields.join(', ')} WHERE name = @name AND version = @version
+    `);
+    stmt.run(values);
+  }
+
+  private rowToManifest(row: Record<string, unknown>): PluginManifest {
+    return {
+      name: String(row.name),
+      version: String(row.version),
+      description: String(row.description),
+      author: String(row.author),
+      dependencies: JSON.parse(String(row.dependencies)),
+      entryPoint: String(row.entryPoint),
+      permissions: JSON.parse(String(row.permissions)),
+    };
+  }
+}
