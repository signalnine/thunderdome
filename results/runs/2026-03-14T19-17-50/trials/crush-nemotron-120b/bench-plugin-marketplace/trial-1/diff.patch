+import { RunnerService, SandboxResult } from '../types.ts';
+import * as vm from 'vm';
+
+export class NodeVmRunnerService implements RunnerService {
+  async execute(code: string, context: Record<string, unknown> = {}): Promise<SandboxResult> {
+    return this.executeWithTimeout(code, 5000, context); // default 5 second timeout
+  }
+
+  async executeWithTimeout(code: string, timeoutMs: number, context: Record<string, unknown> = {}): Promise<SandboxResult> {
+    const startTime = Date.now();
+    
+    // Create a promise that rejects after timeoutMs
+    const timeoutPromise = new Promise<never>((_, reject) => {
+      setTimeout(() => reject(new Error('Script execution timed out')), timeoutMs);
+    });
+
+    // Create a promise for the script execution
+    const executionPromise = new Promise<SandboxResult>((resolve, reject) => {
+      try {
+        const sandbox = { ...context };
+        
+        // Wrap the code in a function to make return values accessible
+        const wrappedCode = `(function() { ${code} })()`;
+        
+        const script = new vm.Script(wrappedCode);
+        
+        let result: unknown;
+        let error: string | undefined;
+        
+        try {
+          result = script.runInNewContext(sandbox, {
+            timeout: timeoutMs,
+            // Disable unsafe features
+            // Note: vm module doesn't have same security options as vm2
+            // We rely on timeout and limited context for basic safety
+          });
+        } catch (err) {
+          error = err instanceof Error ? err.message : String(err);
+        }
+        
+        const endTime = Date.now();
+        const duration = endTime - startTime;
+        
+        // Rough memory estimation - Node.js vm doesn't provide detailed memory info
+        const memoryUsed = process.memoryUsage().heapUsed;
+        
+        resolve({
+          success: !error,
+          output: result,
+          duration,
+          memoryUsed,
+          error,
+        });
+      } catch (err) {
+        const endTime = Date.now();
+        const duration = endTime - startTime;
+        reject({
+          success: false,
+          output: undefined,
+          duration,
+          memoryUsed: process.memoryUsage().heapUsed,
+          error: err instanceof Error ? err.message : String(err),
+        });
+      }
+    });
+
+    // Race the execution against timeout
+    return Promise.race([executionPromise, timeoutPromise])
+      .catch(error => ({
+        success: false,
+        output: undefined,
+        duration: Date.now() - startTime,
+        memoryUsed: process.memoryUsage().heapUsed,
+        error: error instanceof Error ? error.message : String(error),
+      }));
+  }
+}
