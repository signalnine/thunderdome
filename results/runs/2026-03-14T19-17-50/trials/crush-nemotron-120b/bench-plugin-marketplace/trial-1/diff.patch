+import * as semver from 'semver';
+import { ResolverService, VersionConstraint, ResolvedVersion } from '../types.ts';
+
+export class SemverResolverService implements ResolverService {
+  satisfies(version: string, range: string): boolean {
+    return semver.satisfies(version, range);
+  }
+
+  maxSatisfying(versions: string[], range: string): string | null {
+    const validVersions = versions.filter(v => this.satisfies(v, range));
+    if (validVersions.length === 0) return null;
+    // Sort by semver version (descending) and return the highest
+    validVersions.sort((a, b) => semver.compare(b, a));
+    return validVersions[0];
+  }
+
+  validRange(range: string): boolean {
+    return semver.validRange(range) !== null;
+  }
+
+  resolve(constraints: VersionConstraint[], available: Record<string, string[]>): ResolvedVersion[] {
+    const resolved: ResolvedVersion[] = [];
+    for (const constraint of constraints) {
+      const availableVersions = available[constraint.name] || [];
+      const version = this.maxSatisfying(availableVersions, constraint.range);
+      if (version) {
+        resolved.push({
+          name: constraint.name,
+          version,
+          satisfies: constraint.range,
+        });
+      }
+      // If no version satisfies, we don't add to resolved (could throw or handle differently)
+      // Based on interface, we return only resolved versions
+    }
+    return resolved;
+  }
+}
