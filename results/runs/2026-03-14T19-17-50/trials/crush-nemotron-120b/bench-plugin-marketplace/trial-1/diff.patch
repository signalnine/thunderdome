+import { SqliteRegistryService } from './registry/registry.service.ts';
+import { SemverResolverService } from './resolver/resolver.service.ts';
+import { NodeVmRunnerService } from './runner/runner.service.ts';
+import { SqliteReviewService } from './reviews/review.service.ts';
+import { GraphDepsService } from './deps/deps.service.ts';
+import { RegistryService, ResolverService, RunnerService, ReviewService, DepsService, PluginManifest, ResolvedVersion, SandboxResult } from './types.ts';
+
+export class Marketplace {
+  constructor(
+    private registry: RegistryService,
+    private resolver: ResolverService,
+    private runner: RunnerService,
+    private review: ReviewService,
+    private deps: DepsService
+  ) {}
+
+  /** Register a plugin manifest */
+  register(manifest: PluginManifest): void {
+    this.registry.register(manifest);
+  }
+
+  /** Get a plugin by name (latest version) */
+  getPlugin(name: string): PluginManifest | null {
+    return this.registry.get(name);
+  }
+
+  /** Get a specific version of a plugin */
+  getPluginVersion(name: string, version: string): PluginManifest | null {
+    return this.registry.getVersion(name, version);
+  }
+
+  /** List all plugins */
+  listPlugins(): PluginManifest[] {
+    return this.registry.list();
+  }
+
+  /** Search plugins by query */
+  searchPlugins(query: string): PluginManifest[] {
+    return this.registry.search(query);
+  }
+
+  /** Remove a specific plugin version */
+  removePlugin(name: string, version: string): boolean {
+    return this.registry.remove(name, version);
+  }
+
+  /** Resolve version constraints */
+  resolveDependencies(constraints: { name: string; range: string }[]): ResolvedVersion[] {
+    // Get all available plugins and convert to format expected by resolver
+    const allPlugins = this.registry.list();
+    const available: Record<string, string[]> = {};
+    for (const plugin of allPlugins) {
+      if (!available[plugin.name]) {
+        available[plugin.name] = [];
+      }
+      available[plugin.name].push(plugin.version);
+    }
+    
+    return this.resolver.resolve(constraints, available);
+  }
+
+  /** Execute plugin code in sandbox */
+  async executePlugin(code: string, context: Record<string, unknown> = {}): Promise<SandboxResult> {
+    return this.runner.execute(code, context);
+  }
+
+  /** Execute plugin code in sandbox with timeout */
+  async executePluginWithTimeout(code: string, timeoutMs: number, context: Record<string, unknown> = {}): Promise<SandboxResult> {
+    return this.runner.executeWithTimeout(code, timeoutMs, context);
+  }
+
+  /** Add a review */
+  addReview(review: Omit<import('./types.ts').Review, 'id' | 'createdAt' | 'flagged'>): import('./types.ts').Review {
+    return this.review.addReview(review);
+  }
+
+  /** Get reviews for a plugin */
+  getReviews(pluginName: string): import('./types.ts').Review[] {
+    return this.review.getReviews(pluginName);
+  }
+
+  /** Get average rating for a plugin (excluding flagged reviews) */
+  getAverageRating(pluginName: string): number {
+    return this.review.getAverageRating(pluginName);
+  }
+
+  /** Flag a review */
+  flagReview(reviewId: number): void {
+    this.review.flagReview(reviewId);
+  }
+
+  /** Get flagged reviews */
+  getFlaggedReviews(): import('./types.ts').Review[] {
+    return this.review.getFlaggedReviews();
+  }
+
+  /** Remove a review */
+  removeReview(reviewId: number): boolean {
+    return this.review.removeReview(reviewId);
+  }
+
+  /** Get reviews by user */
+  getReviewsByUser(userId: string): import('./types.ts').Review[] {
+    return this.review.getReviewsByUser(userId);
+  }
+
+  /** Get review count for a plugin (excluding flagged) */
+  getReviewCount(pluginName: string): number {
+    return this.review.getReviewCount(pluginName);
+  }
+
+  /** Build dependency tree */
+  buildDependencyTree(name: string): import('./types.ts').DependencyNode {
+    return this.deps.buildTree(name, this.registry);
+  }
+
+  /** Detect circular dependencies */
+  detectCycles(name: string): string[][] | null {
+    return this.deps.detectCycles(name, this.registry);
+  }
+
+  /** Topological sort of dependencies */
+  topologicalSort(name: string): string[] {
+    return this.deps.topologicalSort(name, this.registry);
+  }
+
+  /** Flatten transitive dependencies */
+  flattenDependencies(name: string): string[] {
+    return this.deps.flattenDependencies(name, this.registry);
+  }
+
+  /** Check for circular dependency */
+  hasCircularDependency(name: string): boolean {
+    return this.deps.hasCircularDependency(name, this.registry);
+  }
+
+  /**
+   * Install a plugin: validate, register, resolve dependencies, check for cycles, execute entry point
+   */
+  async installPlugin(manifest: PluginManifest): Promise<{
+    resolvedDependencies: ResolvedVersion[];
+    executionResult: SandboxResult;
+  }> {
+    // Validate required fields
+    if (!manifest.name || !manifest.version || !manifest.entryPoint) {
+      throw new Error('Plugin manifest must have name, version, and entryPoint');
+    }
+
+    // Register the plugin
+    this.registry.register(manifest);
+
+    // Convert manifest dependencies to VersionConstraint format
+    const constraints: { name: string; range: string }[] = [];
+    for (const [name, range] of Object.entries(manifest.dependencies)) {
+      constraints.push({ name, range });
+    }
+
+    // Resolve dependencies
+    const resolved = this.resolveDependencies(constraints);
+
+    // Check for circular dependencies
+    if (this.hasCircularDependency(manifest.name)) {
+      throw new Error(`Circular dependency detected for plugin ${manifest.name}`);
+    }
+
+    // Execute the plugin's entry point
+    // We treat entryPoint as code to execute directly
+    // In a more realistic system, we might load this from a file or module system
+    const executionResult = await this.executePlugin(manifest.entryPoint, {});
+
+    return {
+      resolvedDependencies: resolved,
+      executionResult,
+    };
+  }
+}
+
+/**
+ * Create a marketplace instance with default services.
+ * @param options Optional configuration for services (e.g., database paths)
+ * @returns A Marketplace instance
+ */
+export function createMarketplace(options: {
+  registryDbPath?: string;
+  reviewDbPath?: string;
+} = {}): Marketplace {
+  const registry = new SqliteRegistryService(options.registryDbPath);
+  const resolver = new SemverResolverService();
+  const runner = new NodeVmRunnerService();
+  const review = new SqliteReviewService(options.reviewDbPath);
+  const deps = new GraphDepsService(registry);
+
+  return new Marketplace(registry, resolver, runner, review, deps);
+}
