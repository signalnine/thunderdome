@@ -0,0 +1,46 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from './store.js';
+import { ActionType, ResourceType } from './types.js';
+import { AuthRequest, requireAuth } from './auth.js';
+
+export function logActivity(
+  store: Store,
+  action: ActionType,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string,
+  details?: Record<string, unknown>
+): void {
+  store.activityLog.push({
+    id: generateId(store),
+    action,
+    userId,
+    resourceType,
+    resourceId,
+    details,
+    timestamp: new Date().toISOString(),
+  });
+}
+
+export function createActivityRouter(store: Store): Router {
+  const router = Router();
+
+  router.get('/', requireAuth, (req: AuthRequest, res: Response) => {
+    const { resourceType, resourceId } = req.query;
+
+    let logs = [...store.activityLog];
+
+    if (resourceType && typeof resourceType === 'string') {
+      logs = logs.filter((l) => l.resourceType === resourceType);
+    }
+    if (resourceId && typeof resourceId === 'string') {
+      logs = logs.filter((l) => l.resourceId === resourceId);
+    }
+
+    logs.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());
+
+    res.json(logs);
+  });
+
+  return router;
+}
