ng folder cascades to nested folders', async () => {\n      const { token } = await registerAndLogin('alice', 'pass');\n      const parent = await createFolder(token, 'Parent');\n      const child = await createFolder(token, 'Child', parent.body.id);\n      await createDocument(token, 'Doc', 'Content', child.body.id);\n\n      await request(app)\n        .delete(`/folders/${parent.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      const childRes = await request(app)\n        .get(`/folders/${child.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n      expect(childRes.status).toBe(404);\n    });\n\n    it('should reject invalid role in share request', async () => {\n      const { token: aliceToken } = await registerAndLogin('alice', 'pass');\n      const { userId: bobId } = await registerAndLogin('bob', 'pass');\n      const folder = await createFolder(aliceToken, 'Folder');\n\n      const res = await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'superadmin');\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject invalid resource type in share request', async () => {\n      const { token: aliceToken } = await registerAndLogin('alice', 'pass');\n      const { userId: bobId } = await registerAndLogin('bob', 'pass');\n\n      const res = await shareResource(aliceToken, 'invalid', '1', bobId, 'viewer');\n      expect(res.status).toBe(400);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
