--- /dev/null
+++ b/src/permissions.ts
@@ -0,0 +1,66 @@
+import { Store } from './store.js';
+import { Role, ResourceType } from './types.js';
+
+const ROLE_HIERARCHY: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string
+): Role | null {
+  let bestRole: Role | null = null;
+
+  // Check direct permissions on the resource
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === resourceType &&
+      perm.resourceId === resourceId &&
+      perm.userId === userId
+    ) {
+      if (!bestRole || ROLE_HIERARCHY[perm.role] > ROLE_HIERARCHY[bestRole]) {
+        bestRole = perm.role;
+      }
+    }
+  }
+
+  // If resource is a document, also check folder permissions
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);
+      if (folderRole && (!bestRole || ROLE_HIERARCHY[folderRole] > ROLE_HIERARCHY[bestRole])) {
+        bestRole = folderRole;
+      }
+    }
+  }
+
+  // If resource is a folder, also check parent folder permissions (inherited)
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);
+      if (parentRole && (!bestRole || ROLE_HIERARCHY[parentRole] > ROLE_HIERARCHY[bestRole])) {
+        bestRole = parentRole;
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+export function hasPermission(
+  store: Store,
+  userId: string,
+  resourceType: ResourceType,
+  resourceId: string,
+  requiredRole: Role
+): boolean {
+  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);
+  if (!effectiveRole) return false;
+  return ROLE_HIERARCHY[effectiveRole] >= ROLE_HIERARCHY[requiredRole];
+}
diff --git a/src/sharing.ts b/src/sharing.ts
new file mode 100644
index 0000000..4420871
--- /dev/null
+++ b/src/sharing.ts
@@ -0,0 +1,180 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from './store.js';
+import { AuthRequest, requireAuth } from './auth.js';
+import { hasPermission } from './permissions.js';
+import { logActivity } from './activity.js';
+import { ResourceType, Role } from './types.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+const VALID_RESOURCE_TYPES: ResourceType[] = ['folder', 'document'];
+
+export function createShareRouter(store: Store): Router {
+  const router = Router();
+
+  // Share a resource with a user
+  router.post('/', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId, targetUserId, role } = req.body;
+
+    if (!resourceType || !VALID_RESOURCE_TYPES.includes(resourceType)) {
+      res.status(400).json({ error: 'Valid resourceType (folder or document) is required' });
+      return;
+    }
+
+    if (!resourceId) {
+      res.status(400).json({ error: 'resourceId is required' });
+      return;
+    }
+
+    if (!targetUserId) {
+      res.status(400).json({ error: 'targetUserId is required' });
+      return;
+    }
+
+    if (!role || !VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Valid role (viewer, editor, or owner) is required' });
+      return;
+    }
+
+    // Check that target user exists
+    if (!store.users.has(String(targetUserId))) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Check resource exists
+    const resourceIdStr = String(resourceId);
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceIdStr)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceIdStr)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check that the sharing user has sufficient permissions
+    // Editors can share, owners can share with any role
+    if (role === 'owner') {
+      if (!hasPermission(store, userId, resourceType, resourceIdStr, 'owner')) {
+        res.status(403).json({ error: 'Only owners can grant owner role' });
+        return;
+      }
+    } else {
+      if (!hasPermission(store, userId, resourceType, resourceIdStr, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions to share' });
+        return;
+      }
+    }
+
+    const targetUserIdStr = String(targetUserId);
+
+    // Check if permission already exists for this user/resource combo
+    const existing = store.permissions.find(
+      (p) =>
+        p.resourceType === resourceType &&
+        p.resourceId === resourceIdStr &&
+        p.userId === targetUserIdStr
+    );
+
+    if (existing) {
+      const oldRole = existing.role;
+      existing.role = role;
+      logActivity(store, 'permission_updated', userId, resourceType, resourceIdStr, {
+        targetUserId: targetUserIdStr,
+        oldRole,
+        newRole: role,
+      });
+      res.json({ id: existing.id, resourceType, resourceId: resourceIdStr, userId: targetUserIdStr, role });
+    } else {
+      const id = generateId(store);
+      store.permissions.push({
+        id,
+        resourceType,
+        resourceId: resourceIdStr,
+        userId: targetUserIdStr,
+        role,
+      });
+      logActivity(store, 'permission_granted', userId, resourceType, resourceIdStr, {
+        targetUserId: targetUserIdStr,
+        role,
+      });
+      res.status(201).json({ id, resourceType, resourceId: resourceIdStr, userId: targetUserIdStr, role });
+    }
+  });
+
+  // Revoke sharing
+  router.delete('/', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId, targetUserId } = req.body;
+
+    if (!resourceType || !VALID_RESOURCE_TYPES.includes(resourceType)) {
+      res.status(400).json({ error: 'Valid resourceType is required' });
+      return;
+    }
+
+    if (!resourceId || !targetUserId) {
+      res.status(400).json({ error: 'resourceId and targetUserId are required' });
+      return;
+    }
+
+    const resourceIdStr = String(resourceId);
+    const targetUserIdStr = String(targetUserId);
+
+    // Must be owner to revoke
+    if (!hasPermission(store, userId, resourceType as ResourceType, resourceIdStr, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions to revoke sharing' });
+      return;
+    }
+
+    const idx = store.permissions.findIndex(
+      (p) =>
+        p.resourceType === resourceType &&
+        p.resourceId === resourceIdStr &&
+        p.userId === targetUserIdStr
+    );
+
+    if (idx === -1) {
+      res.status(404).json({ error: 'Permission not found' });
+      return;
+    }
+
+    store.permissions.splice(idx, 1);
+
+    logActivity(store, 'permission_revoked', userId, resourceType as ResourceType, resourceIdStr, {
+      targetUserId: targetUserIdStr,
+    });
+
+    res.status(204).send();
+  });
+
+  // Get permissions for a resource
+  router.get('/', requireAuth, (req: AuthRequest, res: Response) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId } = req.query;
+
+    if (!resourceType || !resourceId) {
+      res.status(400).json({ error: 'resourceType and resourceId query params are required' });
+      return;
+    }
+
+    const resourceIdStr = String(resourceId);
+    const resourceTypeStr = String(resourceType) as ResourceType;
+
+    if (!hasPermission(store, userId, resourceTypeStr, resourceIdStr, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const perms = store.permissions.filter(
+      (p) => p.resourceType === resourceTypeStr && p.resourceId === resourceIdStr
+    );
+
+    res.json(perms);
+  });
+
+  return router;
+}
