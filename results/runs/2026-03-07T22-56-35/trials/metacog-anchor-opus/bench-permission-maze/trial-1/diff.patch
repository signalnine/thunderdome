+++ b/src/store.ts
@@ -0,0 +1,25 @@
+import { User, Folder, Document, Permission, ActivityLogEntry } from './types.js';
+
+export interface Store {
+  users: Map<string, User>;
+  folders: Map<string, Folder>;
+  documents: Map<string, Document>;
+  permissions: Permission[];
+  activityLog: ActivityLogEntry[];
+  nextId: number;
+}
+
+export function createStore(): Store {
+  return {
+    users: new Map(),
+    folders: new Map(),
+    documents: new Map(),
+    permissions: [],
+    activityLog: [],
+    nextId: 1,
+  };
+}
+
+export function generateId(store: Store): string {
+  return String(store.nextId++);
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..9b50526
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,57 @@
+export type Role = 'viewer' | 'editor' | 'owner';
+
+export interface User {
+  id: string;
+  username: string;
+  password: string;
+  token: string | null;
+}
+
+export interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+  createdAt: string;
+}
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+  createdAt: string;
+  updatedAt: string;
+}
+
+export type ResourceType = 'folder' | 'document';
+
+export interface Permission {
+  id: string;
+  resourceType: ResourceType;
+  resourceId: string;
+  userId: string;
+  role: Role;
+}
+
+export type ActionType =
+  | 'document_created'
+  | 'document_updated'
+  | 'document_deleted'
+  | 'folder_created'
+  | 'folder_updated'
+  | 'folder_deleted'
+  | 'permission_granted'
+  | 'permission_updated'
+  | 'permission_revoked';
+
+export interface ActivityLogEntry {
+  id: string;
+  action: ActionType;
+  userId: string;
+  resourceType: ResourceType;
+  resourceId: string;
+  details?: Record<string, unknown>;
+  timestamp: string;
+}
