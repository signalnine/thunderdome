+import express from 'express';
+import { createStore } from './store.js';
+import { createAuthRouter, createAuthMiddleware } from './auth.js';
+import { createFolderRouter } from './folders.js';
+import { createDocumentRouter } from './documents.js';
+import { createShareRouter } from './sharing.js';
+import { createActivityRouter } from './activity.js';
+
+export function createApp(): express.Express {
+  const app = express();
+  const store = createStore();
+
+  app.use(express.json());
+  app.use(createAuthMiddleware(store));
+
+  app.use('/auth', createAuthRouter(store));
+  app.use('/folders', createFolderRouter(store));
+  app.use('/documents', createDocumentRouter(store));
+  app.use('/share', createShareRouter(store));
+  app.use('/activity', createActivityRouter(store));
+
+  return app;
+}
