Get folder\n  router.get('/:id', requireAuth, (req: AuthRequest, res: Response) => {\n    const userId = req.userId!;\n    const folderId = req.params.id;\n\n    const folder = store.folders.get(folderId);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'folder', folderId, 'viewer')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    // Get child folders\n    const children: typeof folder[] = [];\n    for (const f of store.folders.values()) {\n      if (f.parentId === folderId) {\n        children.push(f);\n      }\n    }\n\n    // Get documents in folder\n    const documents: { id: string; title: string; createdAt: string; updatedAt: string }[] = [];\n    for (const doc of store.documents.values()) {\n      if (doc.folderId === folderId) {\n        documents.push({\n          id: doc.id,\n          title: doc.title,\n          createdAt: doc.createdAt,\n          updatedAt: doc.updatedAt,\n        });\n      }\n    }\n\n    const role = getEffectiveRole(store, userId, 'folder', folderId);\n\n    res.json({ ...folder, children, documents, role });\n  });\n\n  // Update folder\n  router.put('/:id', requireAuth, (req: AuthRequest, res: Response) => {\n    const userId = req.userId!;\n    const folderId = req.params.id;\n\n    const folder = store.folders.get(folderId);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const { name, parentId } = req.body;\n\n    if (name !== undefined) {\n      if (typeof name !== 'string' || !name) {\n        res.status(400).json({ error: 'Folder name must be a non-empty string' });\n        return;\n      }\n      folder.name = name;\n    }\n\n    if (parentId !== undefined) {\n      if (parentId !== null) {\n        const parent = store.folders.get(String(parentId));\n        if (!parent) {\n          res.status(404).json({ error: 'Parent folder not found' });\n          return;\n        }\n        // Prevent circular references\n        if (String(parentId) === folderId) {\n          res.status(400).json({ error: 'Folder cannot be its own parent' });\n          return;\n        }\n        folder.parentId = String(parentId);\n      } else {\n        folder.parentId = null;\n      }\n    }\n\n    logActivity(store, 'folder_updated', userId, 'folder', folderId, { name: folder.name });\n\n    res.json(folder);\n  });\n\n  // Delete folder\n  router.delete('/:id', requireAuth, (req: AuthRequest, res: Response) => {\n    const userId = req.userId!;\n    const folderId = req.params.id;\n\n    const folder = store.folders.get(folderId);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, userId, 'folder', folderId, 'owner')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    // Delete all documents in folder\n    for (const [docId, doc] of store.documents) {\n      if (doc.folderId === folderId) {\n        store.documents.delete(docId);\n        store.permissions = store.permissions.filter(\n          (p) => !(p.resourceType === 'document' && p.resourceId === docId)\n        );\n      }\n    }\n\n    // Delete child folders recursively\n    const deleteChildren = (parentId: string) => {\n      for (const [childId, child] of store.folders) {\n        if (child.parentId === parentId) {\n          // Delete docs in child\n          for (const [docId, doc] of store.documents) {\n            if (doc.folderId === childId) {\n              store.documents.delete(docId);\n              store.permissions = store.permissions.filter(\n                (p) => !(p.resourceType === 'document' && p.resourceId === docId)\n              );\n            }\n          }\n          deleteChildren(childId);\n          store.folders.delete(childId);\n          store.permissions = store.permissions.filter(\n            (p) => !(p.resourceType === 'folder' && p.resourceId === childId)\n          );\n        }\n      }\n    };\n\n    deleteChildren(folderId);\n\n    // Delete folder itself\n    store.folders.delete(folderId);\n    store.permissions = store.permissions.filter(\n      (p) => !(p.resourceType === 'folder' && p.resourceId === folderId)\n    );\n\n    logActivity(store, 'folder_deleted', userId, 'folder', folderId, { name: folder.name });\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":464,"cache_read_input_tokens":23147,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":464},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"09348621-ef1a-43bb-9e7a-48190ceff927","uuid":"31064dbe-7feb-48d4-91c7-f7ada3e38dbf"}
