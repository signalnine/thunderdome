+    marketplace.reviews.addReview({
+      pluginName: 'test-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 5,
+      comment: 'Works great!',
+    });
+
+    marketplace.reviews.addReview({
+      pluginName: 'test-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user2',
+      rating: 4,
+      comment: 'Pretty good',
+    });
+
+    expect(marketplace.reviews.getAverageRating('test-plugin')).toBe(4.5);
+    expect(marketplace.reviews.getReviewCount('test-plugin')).toBe(2);
