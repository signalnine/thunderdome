+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { Marketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '"hello"',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('Marketplace Integration', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should install a simple plugin with no dependencies', async () => {
+    const manifest = makeManifest({ entryPoint: '1 + 1' });
+    const result = await marketplace.installPlugin(manifest);
+
+    expect(result.resolvedDependencies).toEqual([]);
+    expect(result.executionResult.success).toBe(true);
+    expect(result.executionResult.output).toBe(2);
+  });
+
+  it('should install a plugin with dependencies', async () => {
+    // Pre-register dependencies
+    marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.0.0' }));
+    marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.1.0' }));
+    marketplace.registry.register(makeManifest({ name: 'dep-b', version: '2.0.0' }));
+
+    const manifest = makeManifest({
+      name: 'main-plugin',
+      dependencies: {
+        'dep-a': '^1.0.0',
+        'dep-b': '^2.0.0',
+      },
+      entryPoint: '"installed"',
+    });
+
+    const result = await marketplace.installPlugin(manifest);
+    expect(result.resolvedDependencies).toHaveLength(2);
+    expect(result.resolvedDependencies[0].name).toBe('dep-a');
+    expect(result.resolvedDependencies[0].version).toBe('1.1.0');
+    expect(result.resolvedDependencies[1].name).toBe('dep-b');
+    expect(result.resolvedDependencies[1].version).toBe('2.0.0');
+    expect(result.executionResult.success).toBe(true);
+  });
+
+  it('should reject plugin with missing name', async () => {
+    const manifest = makeManifest({ name: '' });
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow('name');
+  });
+
+  it('should reject plugin with missing version', async () => {
+    const manifest = makeManifest({ version: '' });
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow('version');
+  });
+
+  it('should reject plugin with missing entryPoint', async () => {
+    const manifest = makeManifest({ entryPoint: '' });
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow('entryPoint');
+  });
+
+  it('should reject plugin with unregistered dependencies', async () => {
+    const manifest = makeManifest({
+      dependencies: { 'nonexistent': '^1.0.0' },
+    });
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow('not registered');
+  });
+
+  it('should reject plugin with circular dependencies', async () => {
+    // Register plugin B that depends on A
+    marketplace.registry.register(makeManifest({
+      name: 'plugin-b',
+      version: '1.0.0',
+      dependencies: { 'plugin-a': '^1.0.0' },
+    }));
+
+    // Install plugin A that depends on B -> circular
+    const manifest = makeManifest({
+      name: 'plugin-a',
+      version: '1.0.0',
+      dependencies: { 'plugin-b': '^1.0.0' },
+    });
+
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow('Circular dependency');
+  });
+
+  it('should handle plugin execution failure gracefully', async () => {
+    const manifest = makeManifest({
+      entryPoint: 'throw new Error("init failed")',
+    });
+    const result = await marketplace.installPlugin(manifest);
+    expect(result.executionResult.success).toBe(false);
+    expect(result.executionResult.error).toBe('init failed');
+  });
+
+  it('should expose all sub-services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+  });
+
+  it('should register plugin in registry during install', async () => {
+    const manifest = makeManifest({ entryPoint: '42' });
+    await marketplace.installPlugin(manifest);
+
+    const registered = marketplace.registry.get('test-plugin');
+    expect(registered).not.toBeNull();
+    expect(registered!.name).toBe('test-plugin');
+  });
