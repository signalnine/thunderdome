istry.register(makeManifest({ name: 'a', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'a', version: '2.0.0' }));\n    const all = registry.list();\n    expect(all).toHaveLength(3);\n  });\n\n  it('should search plugins by name', () => {\n    registry.register(makeManifest({ name: 'auth-plugin', description: 'Authentication' }));\n    registry.register(makeManifest({ name: 'db-plugin', description: 'Database' }));\n    const results = registry.search('auth');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('auth-plugin');\n  });\n\n  it('should search plugins by description', () => {\n    registry.register(makeManifest({ name: 'plug-a', description: 'Handles logging' }));\n    registry.register(makeManifest({ name: 'plug-b', description: 'Handles caching' }));\n    const results = registry.search('logging');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('plug-a');\n  });\n\n  it('should search plugins by author', () => {\n    registry.register(makeManifest({ name: 'plug-a', author: 'alice' }));\n    registry.register(makeManifest({ name: 'plug-b', author: 'bob' }));\n    const results = registry.search('alice');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('plug-a');\n  });\n\n  it('should remove a specific version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n\n    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);\n    expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();\n    expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();\n  });\n\n  it('should return false when removing nonexistent version', () => {\n    expect(registry.remove('nope', '1.0.0')).toBe(false);\n  });\n\n  it('should list versions for a plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    registry.register(makeManifest({ version: '3.0.0' }));\n    const versions = registry.listVersions('test-plugin');\n    expect(versions).toEqual(['1.0.0', '2.0.0', '3.0.0']);\n  });\n\n  it('should return empty list for unknown plugin versions', () => {\n    expect(registry.listVersions('nope')).toEqual([]);\n  });\n\n  it('should update a plugin manifest', () => {\n    registry.register(makeManifest());\n    registry.update('test-plugin', '1.0.0', { description: 'Updated description' });\n    const result = registry.get('test-plugin');\n    expect(result!.description).toBe('Updated description');\n  });\n\n  it('should throw when updating nonexistent plugin', () => {\n    expect(() => registry.update('nope', '1.0.0', {})).toThrow();\n  });\n\n  it('should throw when updating nonexistent version', () => {\n    registry.register(makeManifest());\n    expect(() => registry.update('test-plugin', '9.9.9', {})).toThrow();\n  });\n\n  it('search should be case-insensitive', () => {\n    registry.register(makeManifest({ name: 'MyPlugin' }));\n    expect(registry.search('myplugin')).toHaveLength(1);\n    expect(registry.search('MYPLUGIN')).toHaveLength(1);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":125,"cache_read_input_tokens":27206,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":125},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"00572cb4-d2a3-4e4a-9829-5774f5dff1cb","uuid":"fd3f36fe-5416-4577-ab16-ab1219cd75ef"}
