+import { describe, it, expect, beforeEach } from 'vitest';
+import { createRunner } from './index.js';
+import type { RunnerService } from '../types.js';
+
+describe('Runner', () => {
+  let runner: RunnerService;
+
+  beforeEach(() => {
+    runner = createRunner();
+  });
+
+  it('should execute simple code and return result', async () => {
+    const result = await runner.execute('1 + 2');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(3);
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+    expect(result.memoryUsed).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should execute code with context variables', async () => {
+    const result = await runner.execute('x * y', { x: 6, y: 7 });
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(42);
+  });
+
+  it('should handle errors in plugin code', async () => {
+    const result = await runner.execute('throw new Error("plugin error")');
+    expect(result.success).toBe(false);
+    expect(result.error).toBe('plugin error');
+  });
+
+  it('should handle syntax errors', async () => {
+    const result = await runner.execute('function {{{ invalid');
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  });
+
+  it('should enforce timeout', async () => {
+    const result = await runner.executeWithTimeout('while(true) {}', 100);
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  });
+
+  it('should capture console.log output', async () => {
+    const result = await runner.execute('console.log("hello world")');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe('hello world');
+  });
+
+  it('should return expression value over console output when both exist', async () => {
+    const result = await runner.execute('console.log("side effect"); 42');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(42);
+  });
+
+  it('should pass context into sandbox', async () => {
+    const result = await runner.execute('greeting + " " + name', {
+      greeting: 'Hello',
+      name: 'World',
+    });
+    expect(result.success).toBe(true);
+    expect(result.output).toBe('Hello World');
+  });
+
+  it('should isolate sandbox from main process', async () => {
+    const result = await runner.execute('typeof require');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe('undefined');
+  });
+
+  it('should report duration', async () => {
+    const result = await runner.execute('let s = 0; for(let i=0; i<1000; i++) s += i; s');
+    expect(result.success).toBe(true);
+    expect(result.duration).toBeGreaterThan(0);
+  });
+});
