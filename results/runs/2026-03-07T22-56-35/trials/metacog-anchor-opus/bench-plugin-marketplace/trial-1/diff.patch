+import { describe, it, expect, beforeEach } from 'vitest';
+import { createReviewService } from './index.js';
+import type { ReviewService } from '../types.js';
+
+describe('ReviewService', () => {
+  let reviews: ReviewService;
+
+  beforeEach(() => {
+    reviews = createReviewService();
+  });
+
+  it('should add a review and return it with id and timestamp', () => {
+    const review = reviews.addReview({
+      pluginName: 'my-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 5,
+      comment: 'Great plugin!',
+    });
+
+    expect(review.id).toBe(1);
+    expect(review.pluginName).toBe('my-plugin');
+    expect(review.rating).toBe(5);
+    expect(review.flagged).toBe(false);
+    expect(review.createdAt).toBeDefined();
+  });
+
+  it('should assign incrementing ids', () => {
+    const r1 = reviews.addReview({
+      pluginName: 'p1', pluginVersion: '1.0.0',
+      userId: 'u1', rating: 3, comment: 'ok',
+    });
+    const r2 = reviews.addReview({
+      pluginName: 'p2', pluginVersion: '1.0.0',
+      userId: 'u1', rating: 4, comment: 'good',
+    });
+    expect(r2.id).toBe(r1.id + 1);
+  });
+
+  it('should throw for invalid rating', () => {
+    expect(() => reviews.addReview({
+      pluginName: 'p', pluginVersion: '1.0.0',
+      userId: 'u', rating: 0, comment: 'bad',
+    })).toThrow();
+
+    expect(() => reviews.addReview({
+      pluginName: 'p', pluginVersion: '1.0.0',
+      userId: 'u', rating: 6, comment: 'bad',
+    })).toThrow();
+  });
+
+  it('should get reviews for a specific plugin', () => {
+    reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+    reviews.addReview({ pluginName: 'b', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: '' });
+    reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: '' });
+
+    const aReviews = reviews.getReviews('a');
+    expect(aReviews).toHaveLength(2);
+    expect(aReviews.every(r => r.pluginName === 'a')).toBe(true);
+  });
+
+  it('should compute average rating excluding flagged reviews', () => {
+    const r1 = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });
+    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u3', rating: 1, comment: 'spam' });
+
+    // Before flagging: average = (5 + 3 + 1) / 3 = 3
+    expect(reviews.getAverageRating('p')).toBe(3);
+
+    // Flag the 1-star review
+    reviews.flagReview(r1.id + 2);
+
+    // After flagging: average = (5 + 3) / 2 = 4
+    expect(reviews.getAverageRating('p')).toBe(4);
+  });
+
+  it('should return 0 average when no reviews exist', () => {
+    expect(reviews.getAverageRating('nonexistent')).toBe(0);
+  });
+
+  it('should return 0 average when all reviews are flagged', () => {
+    const r = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+    reviews.flagReview(r.id);
+    expect(reviews.getAverageRating('p')).toBe(0);
+  });
+
+  it('should flag a review', () => {
+    const r = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+    reviews.flagReview(r.id);
+    const flagged = reviews.getFlaggedReviews();
+    expect(flagged).toHaveLength(1);
+    expect(flagged[0].id).toBe(r.id);
+  });
+
+  it('should throw when flagging nonexistent review', () => {
+    expect(() => reviews.flagReview(999)).toThrow();
+  });
+
+  it('should remove a review', () => {
+    const r = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+    expect(reviews.removeReview(r.id)).toBe(true);
+    expect(reviews.getReviews('p')).toHaveLength(0);
+  });
+
+  it('should return false when removing nonexistent review', () => {
+    expect(reviews.removeReview(999)).toBe(false);
+  });
+
+  it('should get reviews by user', () => {
+    reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'alice', rating: 5, comment: '' });
+    reviews.addReview({ pluginName: 'b', pluginVersion: '1.0.0', userId: 'bob', rating: 3, comment: '' });
+    reviews.addReview({ pluginName: 'c', pluginVersion: '1.0.0', userId: 'alice', rating: 4, comment: '' });
+
+    const aliceReviews = reviews.getReviewsByUser('alice');
+    expect(aliceReviews).toHaveLength(2);
+    expect(aliceReviews.every(r => r.userId === 'alice')).toBe(true);
+  });
+
+  it('should get review count for a plugin', () => {
+    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });
+    reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });
+    reviews.addReview({ pluginName: 'other', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: '' });
+
+    expect(reviews.getReviewCount('p')).toBe(2);
+    expect(reviews.getReviewCount('other')).toBe(1);
+    expect(reviews.getReviewCount('nonexistent')).toBe(0);
+  });
+});
