onst prereqDepth = new Map<string, number>();\n  function getDepth(eventId: string): number {\n    if (prereqDepth.has(eventId)) return prereqDepth.get(eventId)!;\n    const event = eventMap.get(eventId);\n    if (!event || !event.prerequisites || event.prerequisites.length === 0) {\n      prereqDepth.set(eventId, 0);\n      return 0;\n    }\n    let maxDepth = 0;\n    for (const prereqId of event.prerequisites) {\n      if (eventMap.has(prereqId)) {\n        maxDepth = Math.max(maxDepth, getDepth(prereqId) + 1);\n      }\n    }\n    prereqDepth.set(eventId, maxDepth);\n    return maxDepth;\n  }\n  for (const event of events) {\n    getDepth(event.id);\n  }\n\n  // Count how many valid rooms each event can use (capacity-wise)\n  const validRoomCount = new Map<string, number>();\n  for (const event of events) {\n    const attendees = event.attendees ?? 1;\n    let count = 0;\n    for (const room of rooms) {\n      if (attendees <= room.capacity) count++;\n    }\n    validRoomCount.set(event.id, count);\n  }\n\n  // Collect dependents for each event (events that depend on it)\n  const dependents = new Map<string, Set<string>>();\n  for (const event of events) {\n    dependents.set(event.id, new Set());\n  }\n  for (const event of events) {\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (dependents.has(prereqId)) {\n          dependents.get(prereqId)!.add(event.id);\n        }\n      }\n    }\n  }\n\n  // Count all transitive dependents\n  const transitiveDependentCount = new Map<string, number>();\n  function countDependents(eventId: string, visited: Set<string>): number {\n    if (transitiveDependentCount.has(eventId)) return transitiveDependentCount.get(eventId)!;\n    let count = 0;\n    for (const dep of dependents.get(eventId) ?? []) {\n      if (!visited.has(dep)) {\n        visited.add(dep);\n        count += 1 + countDependents(dep, visited);\n      }\n    }\n    transitiveDependentCount.set(eventId, count);\n 