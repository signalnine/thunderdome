+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import * as fs from "node:fs";
+import * as os from "node:os";
+import * as path from "node:path";
+import { TimeTracker } from "./tracker.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "tt-"));
+  return path.join(dir, "data.json");
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    try {
+      fs.unlinkSync(filePath);
+      fs.rmdirSync(path.dirname(filePath));
+    } catch {
+      // ignore cleanup errors
+    }
+  });
+
+  it("should start and stop a timer", () => {
+    const tracker = new TimeTracker(filePath);
+    const entry = tracker.start("coding");
+    expect(entry.task).toBe("coding");
+    expect(entry.start).toBeTruthy();
+    expect(entry.stop).toBeNull();
+
+    const stopped = tracker.stop();
+    expect(stopped.task).toBe("coding");
+    expect(stopped.stop).toBeTruthy();
+  });
+
+  it("should auto-stop previous timer when starting a new one", () => {
+    const tracker = new TimeTracker(filePath);
+    tracker.start("task1");
+    tracker.start("task2");
+
+    const entries = tracker.getEntries();
+    expect(entries).toHaveLength(2);
+    expect(entries[0].task).toBe("task1");
+    expect(entries[0].stop).toBeTruthy();
+    expect(entries[1].task).toBe("task2");
+    expect(entries[1].stop).toBeNull();
+  });
+
+  it("should throw when starting with empty name", () => {
+    const tracker = new TimeTracker(filePath);
+    expect(() => tracker.start("")).toThrow();
+    expect(() => tracker.start("   ")).toThrow();
+  });
+
+  it("should throw when stopping with no running timer", () => {
+    const tracker = new TimeTracker(filePath);
+    expect(() => tracker.stop()).toThrow();
+  });
+
+  it("should persist data to disk", () => {
+    const tracker1 = new TimeTracker(filePath);
+    tracker1.start("persist-test");
+    tracker1.stop();
+
+    const tracker2 = new TimeTracker(filePath);
+    const entries = tracker2.getEntries();
+    expect(entries).toHaveLength(1);
+    expect(entries[0].task).toBe("persist-test");
+  });
+
+  it("should create parent directories if they don't exist", () => {
+    const deepPath = path.join(
+      os.tmpdir(),
+      "tt-nested-" + Date.now(),
+      "a",
+      "b",
+      "data.json"
+    );
+    const tracker = new TimeTracker(deepPath);
+    tracker.start("nested");
+    tracker.stop();
+
+    expect(fs.existsSync(deepPath)).toBe(true);
+
+    // cleanup
+    fs.unlinkSync(deepPath);
+    fs.rmdirSync(path.dirname(deepPath));
+    fs.rmdirSync(path.join(path.dirname(deepPath), ".."));
+    fs.rmdirSync(path.join(path.dirname(deepPath), "..", ".."));
+  });
+
+  it("should filter entries by date range", async () => {
+    const tracker = new TimeTracker(filePath);
+
+    const pastDate = new Date("2020-01-01T00:00:00Z");
+    const futureDate = new Date("2030-01-01T00:00:00Z");
+
+    tracker.start("now-task");
+    tracker.stop();
+
+    // All entries should be within a wide range
+    const filtered = tracker.getEntries(pastDate, futureDate);
+    expect(filtered).toHaveLength(1);
+
+    // No entries before a past range
+    const none = tracker.getEntries(futureDate);
+    expect(none).toHaveLength(0);
+  });
+
+  it("should summarize time per task", () => {
+    const tracker = new TimeTracker(filePath);
+    tracker.start("coding");
+    tracker.stop();
+    tracker.start("coding");
+    tracker.stop();
+    tracker.start("testing");
+    tracker.stop();
+
+    const summary = tracker.getSummary();
+    expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    expect(summary["testing"]).toBeGreaterThanOrEqual(0);
+    expect(Object.keys(summary)).toHaveLength(2);
+  });
+
+  it("should include running tasks in summary using current time", () => {
+    const tracker = new TimeTracker(filePath);
+    tracker.start("running-task");
+
+    const summary = tracker.getSummary();
+    expect(summary["running-task"]).toBeGreaterThanOrEqual(0);
+  });
+
+  it("should handle unicode task names", () => {
+    const tracker = new TimeTracker(filePath);
+    tracker.start("日本語タスク");
+    tracker.stop();
+    tracker.start("🚀 launch");
+    tracker.stop();
+    tracker.start("café ☕");
+    tracker.stop();
+
+    const entries = tracker.getEntries();
+    expect(entries).toHaveLength(3);
+    expect(entries[0].task).toBe("日本語タスク");
+    expect(entries[1].task).toBe("🚀 launch");
+    expect(entries[2].task).toBe("café ☕");
+
+    const summary = tracker.getSummary();
+    expect(summary["日本語タスク"]).toBeGreaterThanOrEqual(0);
+    expect(summary["🚀 launch"]).toBeGreaterThanOrEqual(0);
+    expect(summary["café ☕"]).toBeGreaterThanOrEqual(0);
+  });
+
+  it("should return a copy of entries from getEntries", () => {
+    const tracker = new TimeTracker(filePath);
+    tracker.start("task");
+    tracker.stop();
+
+    const entries1 = tracker.getEntries();
+    const entries2 = tracker.getEntries();
+    expect(entries1).not.toBe(entries2);
+  });
+});
