+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PVibhE4eQMdLiUQFCtu7AG","type":"tool_result","content":"     1â†’import { describe, it, expect } from 'vitest';\n     2â†’import { BuildEngine, createDefaultTemplate, createListTemplate } from '../src/core/index.js';\n     3â†’import { ContentFile, Plugin, SiteConfig } from '../src/core/types.js';\n     4â†’\n     5â†’const testConfig: SiteConfig = {\n     6â†’  title: 'Test Site',\n     7â†’  baseUrl: 'https://example.com',\n     8â†’  outputDir: './dist',\n     9â†’  contentDir: './content',\n    10â†’  templateDir: './templates',\n    11â†’};\n    12â†’\n    13â†’function makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n    14â†’  return {\n    15â†’    slug: 'test-post',\n    16â†’    title: 'Test Post',\n    17â†’    content: '<p>Hello world</p>',\n    18â†’    metadata: {},\n    19â†’    ...overrides,\n    20â†’  };\n    21â†’}\n    22â†’\n    23â†’function makePlugin(overrides: Partial<Plugin> = {}): Plugin {\n    24â†’  return {\n    25â†’    name: 'test-plugin',\n    26â†’    version: '1.0.0',\n    27â†’    dependencies: [],\n    28â†’    hooks: {},\n    29â†’    ...overrides,\n    30â†’  };\n    31â†’}\n    32â†’\n    33â†’describe('BuildEngine', () => {\n    34â†’  it('registers plugins', () => {\n    35â†’    const engine = new BuildEngine(testConfig);\n    36â†’    const plugin = makePlugin({ name: 'my-plugin' });\n    37â†’    engine.registerPlugin(plugin);\n    38â†’    expect(engine.getPlugins()).toHaveLength(1);\n    39â†’    expect(engine.getPlugins()[0].name).toBe('my-plugin');\n    40â†’  });\n    41â†’\n    42â†’  it('registers templates', () => {\n    43â†’    const engine = new BuildEngine(testConfig);\n    44â†’    const template = createDefaultTemplate();\n    45â†’    engine.registerTemplate(template);\n    46â†’    expect(engine.getTemplates().has('default')).toBe(true);\n    47â†’  });\n    48â†’\n    49â†’  it('builds with default template and renders HTML', async () => {\n    50â†’    const engine = new BuildEngine(testConfig);\n    51â†’    engine.registerTemplate(createDefaultTemplate());\n    52â†’    const file = makeFile({ title: 'My Post', content: '<p>Content here</p>' });\n    53â†’    const ctx = await engine.build([file]);\n    54â†’    const output = ctx.output.get('test-post.html')!;\n    55â†’    expect(output).toContain('<!DOCTYPE html>');\n    56â†’    expect(output).toContain('My Post');\n    57â†’    expect(output).toContain('<p>Content here</p>');\n    58â†’    expect(output).toContain('Test Site');\n    59â†’  });\n    60â†’\n    61â†’  it('builds with list template and renders list HTML', async () => {\n    62â†’    const engine = new BuildEngine(testConfig);\n    63â†’    engine.registerTemplate(createListTemplate());\n    64â†’    const file = makeFile({ title: 'My List', content: '<ul><li>Item</li></ul>', template: 'list' });\n    65â†’    const ctx = await engine.build([file]);\n    66â†’    const output = ctx.output.get('test-post.html')!;\n    67â†’    expect(output).toContain('<!DOCTYPE html>');\n    68â†’    expect(output).toContain('My List');\n    69â†’    expect(output).toContain('<div class=\"list\">');\n    70â†’    expect(output).toContain('<ul><li>Item</li></ul>');\n    71â†’  });\n    72â†’\n    73â†’  it('outputs raw content when no matching template', async () => {\n    74â†’    const engine = new BuildEngine(testConfig);\n    75â†’    const file = makeFile({ content: '<p>Raw content</p>' });\n    76â†’    const ctx = await engine.build([file]);\n    77â†’    expect(ctx.output.get('test-post.html')).toBe('<p>Raw content</p>');\n    78â†’  });\n    79â†’\n    80â†’  it('calls plugin beforeBuild hook', async () => {\n    81â†’    const engine = new BuildEngine(testConfig);\n    82â†’    let called = false;\n    83â†’    engine.registerPlugin(makePlugin({\n    84â†’      hooks: {\n    85â†’        beforeBuild: () => { called = true; },\n    86â†’      },\n    87â†’    }));\n    88â†’    await engine.build([]);\n    89â†’    expect(called).toBe(true);\n    90â†’  });\n    91â†’\n    92â†’  it('calls plugin transformContent hook to transform files', async () => {\n    93â†’    const engine = new BuildEngine(testConfig);\n    94â†’    engine.registerPlugin(makePlugin({\n    95â†’      hooks: {\n    96â†’        transformContent: (file) => ({\n    97â†’          ...file,\n    98â†’          content: file.content.toUpperCase(),\n    99â†’        }),\n   100â†’      },\n   101â†’    }));\n   102â†’    const ctx = await engine.build([makeFile({ content: 'hello' })]);\n   103â†’    expect(ctx.files[0].content).toBe('HELLO');\n   104â†’  });\n   105â†’\n   106â†’  it('calls plugin afterBuild hook', async () => {\n   107â†’    const engine = new BuildEngine(testConfig);\n   108â†’    let called = false;\n   109â†’    engine.registerPlugin(makePlugin({\n   110â†’      hooks: {\n   111â†’        afterBuild: () => { called = true; },\n   112â†’      },\n   113â†’    }));\n   114â†’    await engine.build([]);\n   115â†’    expect(called).toBe(true);\n   116â†’  });\n   117â†’\n   118â†’  it('executes plugins in dependency order', () => {\n   119â†’    const engine = new BuildEngine(testConfig);\n   120â†’    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n   121â†’    engine.registerPlugin(makePlugin({ name: 'a', dependencies: [] }));\n   122â†’    const order = engine.resolvePluginOrder();\n   123â†’    expect(order.map(p => p.name)).toEqual(['a', 'b']);\n   124â†’  });\n   125â†’\n   126â†’  it('throws on circular dependency', () => {\n   127â†’    const engine = new BuildEngine(testConfig);\n   128â†’    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['b'] }));\n   129â†’    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n   130â†’    expect(() => engine.resolvePluginOrder()).toThrow('Circular dependency');\n   131â†’  });\n   132â†’\n   133â†’  it('throws on missing dependency', () => {\n   134â†’    const engine = new BuildEngine(testConfig);\n   135â†’    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['missing'] }));\n   136â†’    expect(() => engine.resolvePluginOrder()).toThrow('Missing dependency');\n   137â†’  });\n   138â†’\n   139â†’  it('applies multiple plugins transformContent in order', async () => {\n   140â†’    const engine = new BuildEngine(testConfig);\n   141â†’    engine.registerPlugin(makePlugin({\n   142â†’      name: 'first',\n   143â†’      hooks: {\n   144â†’        transformContent: (file) => ({\n   145â†’          ...file,\n   146â†’          content: file.content + ' [first]',\n   147â†’        }),\n   148â†’      },\n   149â†’    }));\n   150â†’    engine.registerPlugin(makePlugin({\n   151â†’      name: 'second',\n   152â†’      hooks: {\n   153â†’        transformContent: (file) => ({\n   154â†’          ...file,\n   155â†’          content: file.content + ' [second]',\n   156â†’        }),\n   157â†’      },\n   158â†’    }));\n   159â†’    const ctx = await engine.build([makeFile({ content: 'start' })]);\n   160â†’    expect(ctx.files[0].content).toBe('start [first] [second]');\n   161â†’  });\n   162â†’\n   163â†’  it('provides shared data store in build context', async () => {\n   164â†’    const engine = new BuildEngine(testConfig);\n   165â†’    engine.registerPlugin(makePlugin({\n   166â†’      hooks: {\n   167â†’        beforeBuild: (ctx) => { ctx.data.set('key', 'value'); },\n   168â†’      },\n   169â†’    }));\n   170â†’    const ctx = await engine.build([]);\n   171â†’    expect(ctx.data.get('key')).toBe('value');\n   172â†’  });\n   173â†’\n   174â†’  it('retains file metadata through build', async () => {\n   175â†’    const engine = new BuildEngine(testConfig);\n   176â†’    const file = makeFile({\n   177â†’      metadata: { author: 'Alice', category: 'tech' },\n   178â†’      date: '2024-01-01',\n   179â†’      tags: ['js', 'node'],\n   180â†’    });\n   181â†’    const ctx = await engine.build([file]);\n   182â†’    expect(ctx.files[0].metadata).toEqual({ author: 'Alice', category: 'tech' });\n   183â†’    expect(ctx.files[0].date).toBe('2024-01-01');\n   184â†’    expect(ctx.files[0].tags).toEqual(['js', 'node']);\n   185â†’  });\n   186â†’\n   187â†’  it('produces empty output for empty file list', async () => {\n   188â†’    const engine = new BuildEngine(testConfig);\n   189â†’    engine.registerTemplate(createDefaultTemplate());\n   190â†’    const ctx = await engine.build([]);\n   191â†’    expect(ctx.output.size).toBe(0);\n   192â†’    expect(ctx.files).toHaveLength(0);\n   193â†’  });\n   194â†’});\n   195â†’"}]},"parent_tool_use_id":"toolu_01E1dTK5ExZKSAiwqfyFxFNV","session_id":"d54179d9-bde0-4fa6-ba3e-b433168874e3","uuid":"7fa7d96c-3d7a-4372-a93b-fc1938d9d83f"}
