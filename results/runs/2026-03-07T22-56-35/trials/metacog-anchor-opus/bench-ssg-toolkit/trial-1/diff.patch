mContent!(file, makeCtx());\n    49â†’    expect(result.content).toContain('data-language=\"python\"');\n    50â†’  });\n    51â†’\n    52â†’  it('handles multiple code blocks in one file', async () => {\n    53â†’    const file = makeFile({\n    54â†’      content:\n    55â†’        '<pre><code class=\"language-js\">let a = 1;</code></pre>' +\n    56â†’        '<p>Some text</p>' +\n    57â†’        '<pre><code class=\"language-py\">x = 2</code></pre>',\n    58â†’    });\n    59â†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    60â†’    expect(result.content).toContain('data-language=\"js\"');\n    61â†’    expect(result.content).toContain('data-language=\"py\"');\n    62â†’  });\n    63â†’\n    64â†’  it('handles code block with no language specified', async () => {\n    65â†’    const file = makeFile({\n    66â†’      content: '<pre><code>plain code</code></pre>',\n    67â†’    });\n    68â†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    69â†’    // Should not add highlighted class or data-language to blocks without language\n    70â†’    expect(result.content).toBe('<pre><code>plain code</code></pre>');\n    71â†’    expect(result.content).not.toContain('highlighted');\n    72â†’  });\n    73â†’\n    74â†’  it('adds highlighted class to processed blocks', async () => {\n    75â†’    const file = makeFile({\n    76â†’      content: '<pre><code class=\"language-rust\">fn main() {}</code></pre>',\n    77â†’    });\n    78â†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    79â†’    expect(result.content).toContain('highlighted');\n    80â†’  });\n    81â†’\n    82â†’  it('preserves code block content', async () => {\n    83â†’    const file = makeFile({\n    84â†’      content: '<pre><code class=\"language-ts\">const x: number = 42;</code></pre>',\n    85â†’    });\n    86â†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    87â†’    expect(result.content).toContain('const x: number = 42;');\n    88â†’  });\n    89â†’\n    90â†’  it('handles empty code blocks', async () => {\n    91â†’    const file = makeFile({\n    92â†’      content: '<pre><code class=\"language-js\"></code></pre>',\n    93â†’    });\n    94â†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    95â†’    expect(result.content).toContain('data-language=\"js\"');\n    96â†’    expect(result.content).toContain('highlighted');\n    97â†’  });\n    98â†’\n    99â†’  it('does not modify inline code', async () => {\n   100â†’    const file = makeFile({\n   101â†’      content: '<p>Use <code>console.log()</code> for debugging.</p>',\n   102â†’    });\n   103â†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n   104â†’    expect(result.content).toBe('<p>Use <code>console.log()</code> for debugging.</p>');\n   105â†’    expect(result.content).not.toContain('highlighted');\n   106â†’  });\n   107â†’});\n   108â†’"}]},"parent_tool_use_id":"toolu_01E1dTK5ExZKSAiwqfyFxFNV","session_id":"d54179d9-bde0-4fa6-ba3e-b433168874e3","uuid":"988f3fdb-f2db-4c37-b222-6762868dcc91"}
