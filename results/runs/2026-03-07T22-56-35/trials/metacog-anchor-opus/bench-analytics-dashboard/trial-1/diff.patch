@@ -0,0 +1,102 @@
+import { Router, Response } from "express";
+import { v4 as uuidv4 } from "uuid";
+import Database from "better-sqlite3";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Ingest single event
+  router.post("/", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const { name, properties, timestamp, session_id } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Event name is required", code: "BAD_REQUEST" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tid;
+    const userId = req.user!.sub;
+    const props = properties ? JSON.stringify(properties) : "{}";
+    const ts = timestamp || new Date().toISOString();
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, props, ts, userId, session_id || null);
+
+    res.status(201).json({ event: { id, tenant_id: tenantId, name, properties: properties || {}, timestamp: ts, user_id: userId, session_id: session_id || null } });
+  });
+
+  // Batch ingest events
+  router.post("/batch", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty", code: "BAD_REQUEST" });
+      return;
+    }
+
+    const tenantId = req.user!.tid;
+    const userId = req.user!.sub;
+
+    const insert = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const insertMany = db.transaction((evts: Array<{ name: string; properties?: Record<string, unknown>; timestamp?: string; session_id?: string }>) => {
+      const results: Array<{ id: string; name: string }> = [];
+      for (const evt of evts) {
+        if (!evt.name) continue;
+        const id = uuidv4();
+        const props = evt.properties ? JSON.stringify(evt.properties) : "{}";
+        const ts = evt.timestamp || new Date().toISOString();
+        insert.run(id, tenantId, evt.name, props, ts, userId, evt.session_id || null);
+        results.push({ id, name: evt.name });
+      }
+      return results;
+    });
+
+    const results = insertMany(events);
+
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  // List events for tenant
+  router.get("/", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+    const limit = parseInt(req.query.limit as string) || 100;
+    const offset = parseInt(req.query.offset as string) || 0;
+    const name = req.query.name as string | undefined;
+
+    let query = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: (string | number)[] = [tenantId];
+
+    if (name) {
+      query += " AND name = ?";
+      params.push(name);
+    }
+
+    query += " ORDER BY timestamp DESC LIMIT ? OFFSET ?";
+    params.push(limit, offset);
+
+    const events = db.prepare(query).all(...params) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      properties: string;
+      timestamp: string;
+      user_id: string | null;
+      session_id: string | null;
+    }>;
+
+    const parsed = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    res.json({ events: parsed });
+  });
+
+  return router;
+}
