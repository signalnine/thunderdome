@@ -0,0 +1,394 @@
+import { describe, it, expect, beforeEach } from "vitest";
+import request from "supertest";
+import { createApp } from "./app.js";
+import { createDb } from "./db.js";
+import type { Application } from "express";
+import type Database from "better-sqlite3";
+
+let app: Application;
+let db: Database.Database;
+
+beforeEach(() => {
+  db = createDb();
+  app = createApp(db);
+});
+
+describe("Health Check", () => {
+  it("returns ok", async () => {
+    const res = await request(app).get("/api/health");
+    expect(res.status).toBe(200);
+    expect(res.body.status).toBe("ok");
+  });
+});
+
+describe("User Management", () => {
+  it("registers a new user", async () => {
+    const res = await request(app).post("/api/users/register").send({
+      email: "admin@test.com",
+      password: "password123",
+      tenant_id: "tenant1",
+    });
+    expect(res.status).toBe(201);
+    expect(res.body.user.email).toBe("admin@test.com");
+    expect(res.body.user.tenant_id).toBe("tenant1");
+    expect(res.body.user.role).toBe("admin"); // first user is admin
+    expect(res.body.token).toBeDefined();
+  });
+
+  it("rejects duplicate email", async () => {
+    await request(app).post("/api/users/register").send({
+      email: "admin@test.com",
+      password: "password123",
+      tenant_id: "tenant1",
+    });
+    const res = await request(app).post("/api/users/register").send({
+      email: "admin@test.com",
+      password: "password456",
+      tenant_id: "tenant1",
+    });
+    expect(res.status).toBe(409);
+  });
+
+  it("logs in", async () => {
+    await request(app).post("/api/users/register").send({
+      email: "admin@test.com",
+      password: "password123",
+      tenant_id: "tenant1",
+    });
+    const res = await request(app).post("/api/users/login").send({
+      email: "admin@test.com",
+      password: "password123",
+    });
+    expect(res.status).toBe(200);
+    expect(res.body.token).toBeDefined();
+  });
+
+  it("rejects wrong password", async () => {
+    await request(app).post("/api/users/register").send({
+      email: "admin@test.com",
+      password: "password123",
+      tenant_id: "tenant1",
+    });
+    const res = await request(app).post("/api/users/login").send({
+      email: "admin@test.com",
+      password: "wrong",
+    });
+    expect(res.status).toBe(401);
+  });
+
+  it("gets profile", async () => {
+    const reg = await request(app).post("/api/users/register").send({
+      email: "admin@test.com",
+      password: "password123",
+      tenant_id: "tenant1",
+    });
+    const res = await request(app)
+      .get("/api/users/me")
+      .set("Authorization", `Bearer ${reg.body.token}`);
+    expect(res.status).toBe(200);
+    expect(res.body.user.email).toBe("admin@test.com");
+  });
+
+  it("returns 401 without auth", async () => {
+    const res = await request(app).get("/api/users/me");
+    expect(res.status).toBe(401);
+  });
+
+  it("admin can update role", async () => {
+    const admin = await request(app).post("/api/users/register").send({
+      email: "admin@test.com",
+      password: "password123",
+      tenant_id: "tenant1",
+    });
+    const viewer = await request(app).post("/api/users/register").send({
+      email: "viewer@test.com",
+      password: "password123",
+      tenant_id: "tenant1",
+    });
+    const res = await request(app)
+      .put(`/api/users/${viewer.body.user.id}/role`)
+      .set("Authorization", `Bearer ${admin.body.token}`)
+      .send({ role: "editor" });
+    expect(res.status).toBe(200);
+    expect(res.body.role).toBe("editor");
+  });
+});
+
+async function createAuthUser(tenant = "tenant1") {
+  const res = await request(app).post("/api/users/register").send({
+    email: `user-${Math.random()}@test.com`,
+    password: "password123",
+    tenant_id: tenant,
+  });
+  return res.body.token as string;
+}
+
+describe("Event Ingestion", () => {
+  it("creates a single event", async () => {
+    const token = await createAuthUser();
+    const res = await request(app)
+      .post("/api/events")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ name: "page_view", properties: { url: "/home" } });
+    expect(res.status).toBe(201);
+    expect(res.body.event.name).toBe("page_view");
+  });
+
+  it("creates batch events", async () => {
+    const token = await createAuthUser();
+    const res = await request(app)
+      .post("/api/events/batch")
+      .set("Authorization", `Bearer ${token}`)
+      .send({
+        events: [
+          { name: "page_view", properties: { url: "/home" } },
+          { name: "click", properties: { button: "signup" } },
+        ],
+      });
+    expect(res.status).toBe(201);
+    expect(res.body.inserted).toBe(2);
+  });
+
+  it("lists events", async () => {
+    const token = await createAuthUser();
+    await request(app)
+      .post("/api/events")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ name: "page_view" });
+    const res = await request(app)
+      .get("/api/events")
+      .set("Authorization", `Bearer ${token}`);
+    expect(res.status).toBe(200);
+    expect(res.body.events.length).toBeGreaterThan(0);
+  });
+
+  it("returns 401 without auth", async () => {
+    const res = await request(app)
+      .post("/api/events")
+      .send({ name: "page_view" });
+    expect(res.status).toBe(401);
+  });
+});
+
+describe("Tenant Isolation", () => {
+  it("isolates events between tenants", async () => {
+    const token1 = await createAuthUser("tenant-a");
+    const token2 = await createAuthUser("tenant-b");
+
+    await request(app)
+      .post("/api/events")
+      .set("Authorization", `Bearer ${token1}`)
+      .send({ name: "page_view" });
+
+    const res1 = await request(app)
+      .get("/api/events")
+      .set("Authorization", `Bearer ${token1}`);
+    expect(res1.body.events.length).toBe(1);
+
+    const res2 = await request(app)
+      .get("/api/events")
+      .set("Authorization", `Bearer ${token2}`);
+    expect(res2.body.events.length).toBe(0);
+  });
+});
+
+describe("Query Engine", () => {
+  it("counts events", async () => {
+    const token = await createAuthUser();
+    await request(app)
+      .post("/api/events/batch")
+      .set("Authorization", `Bearer ${token}`)
+      .send({
+        events: [
+          { name: "page_view" },
+          { name: "page_view" },
+          { name: "click" },
+        ],
+      });
+
+    const res = await request(app)
+      .post("/api/queries/count")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ event_name: "page_view" });
+    expect(res.status).toBe(200);
+    expect(res.body.count).toBe(2);
+  });
+
+  it("timeseries query", async () => {
+    const token = await createAuthUser();
+    await request(app)
+      .post("/api/events/batch")
+      .set("Authorization", `Bearer ${token}`)
+      .send({
+        events: [
+          { name: "page_view", timestamp: "2024-01-01T10:00:00Z" },
+          { name: "page_view", timestamp: "2024-01-01T11:00:00Z" },
+          { name: "page_view", timestamp: "2024-01-02T10:00:00Z" },
+        ],
+      });
+
+    const res = await request(app)
+      .post("/api/queries/timeseries")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ event_name: "page_view", interval: "day" });
+    expect(res.status).toBe(200);
+    expect(res.body.timeseries.length).toBe(2);
+  });
+
+  it("breakdown query", async () => {
+    const token = await createAuthUser();
+    await request(app)
+      .post("/api/events/batch")
+      .set("Authorization", `Bearer ${token}`)
+      .send({
+        events: [
+          { name: "page_view", properties: { url: "/home" } },
+          { name: "page_view", properties: { url: "/home" } },
+          { name: "page_view", properties: { url: "/about" } },
+        ],
+      });
+
+    const res = await request(app)
+      .post("/api/queries/breakdown")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ event_name: "page_view", property: "url" });
+    expect(res.status).toBe(200);
+    expect(res.body.breakdown.length).toBe(2);
+    expect(res.body.breakdown[0].value).toBe("/home");
+    expect(res.body.breakdown[0].count).toBe(2);
+  });
+});
+
+describe("Dashboard CRUD", () => {
+  it("creates a dashboard", async () => {
+    const token = await createAuthUser();
+    const res = await request(app)
+      .post("/api/dashboards")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ name: "My Dashboard" });
+    expect(res.status).toBe(201);
+    expect(res.body.dashboard.name).toBe("My Dashboard");
+  });
+
+  it("lists dashboards", async () => {
+    const token = await createAuthUser();
+    await request(app)
+      .post("/api/dashboards")
+      .set("Authorization", `Bearer ${token}`)
