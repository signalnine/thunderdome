red\", code: \"BAD_REQUEST\" });\n      return;\n    }\n\n    const bucket = interval || \"day\";\n    let dateFormat: string;\n    switch (bucket) {\n      case \"hour\":\n        dateFormat = \"%Y-%m-%dT%H:00:00\";\n        break;\n      case \"month\":\n        dateFormat = \"%Y-%m-01\";\n        break;\n      case \"day\":\n      default:\n        dateFormat = \"%Y-%m-%d\";\n        break;\n    }\n\n    let query = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;\n    const params: (string | number)[] = [tenantId, event_name];\n\n    if (start_date) {\n      query += \" AND timestamp >= ?\";\n      params.push(start_date);\n    }\n\n    if (end_date) {\n      query += \" AND timestamp <= ?\";\n      params.push(end_date);\n    }\n\n    if (filters && typeof filters === \"object\") {\n      for (const [key, value] of Object.entries(filters)) {\n        query += \" AND json_extract(properties, ?) = ?\";\n        params.push(`$.${key}`, String(value));\n      }\n    }\n\n    query += ` GROUP BY bucket ORDER BY bucket ASC`;\n\n    const results = db.prepare(query).all(...params) as Array<{ bucket: string; count: number }>;\n\n    res.json({ timeseries: results });\n  });\n\n  // Breakdown query\n  router.post(\"/breakdown\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    const tenantId = req.user!.tid;\n    const { event_name, property, start_date, end_date, filters } = req.body;\n\n    if (!event_name || !property) {\n      res.status(400).json({ error: \"event_name and property are required\", code: \"BAD_REQUEST\" });\n      return;\n    }\n\n    let query = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;\n    const params: (string | number)[] = [`$.${property}`, tenantId, event_name];\n\n    if (start_date) {\n      query += \" AND timestamp >= ?\";\n      params.push(start_date);\n    }\n\n    if (end_date) {\n      query += \" AND timestamp <= ?\";\n      params.push(end_date);\n    }\n\n    if (filters && typeof filters === \"object\") {\n      for (const [key, value] of Object.entries(filters)) {\n        query += \" AND json_extract(properties, ?) = ?\";\n        params.push(`$.${key}`, String(value));\n      }\n    }\n\n    query += \" AND json_extract(properties, ?) IS NOT NULL GROUP BY value ORDER BY count DESC\";\n    params.push(`$.${property}`);\n\n    const results = db.prepare(query).all(...params) as Array<{ value: string; count: number }>;\n\n    res.json({ breakdown: results });\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
