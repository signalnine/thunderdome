@@ -0,0 +1,143 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ["id", "tenant_id", "name", "properties", "timestamp", "user_id", "session_id"];
+  const rows = events.map((e) =>
+    headers.map((h) => {
+      const val = e[h as keyof EventRow];
+      if (val === null || val === undefined) return "";
+      const str = String(val);
+      if (str.includes(",") || str.includes('"') || str.includes("\n")) {
+        return `"${str.replace(/"/g, '""')}"`;
+      }
+      return str;
+    }).join(",")
+  );
+  return [headers.join(","), ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const headers = ["id", "tenant_id", "name", "owner_id", "config", "created_at", "updated_at"];
+  const rows = dashboards.map((d) =>
+    headers.map((h) => {
+      const val = d[h as keyof DashboardRow];
+      if (val === null || val === undefined) return "";
+      const str = String(val);
+      if (str.includes(",") || str.includes('"') || str.includes("\n")) {
+        return `"${str.replace(/"/g, '""')}"`;
+      }
+      return str;
+    }).join(",")
+  );
+  return [headers.join(","), ...rows].join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get("/events/json", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+    const name = req.query.event_name as string | undefined;
+
+    let query = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: string[] = [tenantId];
+
+    if (name) {
+      query += " AND name = ?";
+      params.push(name);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(query).all(...params) as EventRow[];
+    const parsed = events.map((e) => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=events.json");
+    res.json({ events: parsed });
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+    const name = req.query.event_name as string | undefined;
+
+    let query = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: string[] = [tenantId];
+
+    if (name) {
+      query += " AND name = ?";
+      params.push(name);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const events = db.prepare(query).all(...params) as EventRow[];
+    const csv = eventsToCsv(events);
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(csv);
+  });
+
+  // Export dashboards as JSON
+  router.get("/dashboards/json", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+
+    const dashboards = db.prepare(
+      "SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC"
+    ).all(tenantId) as DashboardRow[];
+
+    const parsed = dashboards.map((d) => ({
+      ...d,
+      config: JSON.parse(d.config),
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.json");
+    res.json({ dashboards: parsed });
+  });
+
+  // Export dashboards as CSV
+  router.get("/dashboards/csv", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+
+    const dashboards = db.prepare(
+      "SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC"
+    ).all(tenantId) as DashboardRow[];
+
+    const csv = dashboardsToCsv(dashboards);
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+    res.send(csv);
+  });
+
+  return router;
+}
