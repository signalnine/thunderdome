\",\n      password: \"password123\",\n      tenant_id: \"tenant1\",\n    });\n    const res = await request(app).post(\"/api/users/login\").send({\n      email: \"admin@test.com\",\n      password: \"password123\",\n    });\n    expect(res.status).toBe(200);\n    expect(res.body.token).toBeDefined();\n  });\n\n  it(\"rejects wrong password\", async () => {\n    await request(app).post(\"/api/users/register\").send({\n      email: \"admin@test.com\",\n      password: \"password123\",\n      tenant_id: \"tenant1\",\n    });\n    const res = await request(app).post(\"/api/users/login\").send({\n      email: \"admin@test.com\",\n      password: \"wrong\",\n    });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"gets profile\", async () => {\n    const reg = await request(app).post(\"/api/users/register\").send({\n      email: \"admin@test.com\",\n      password: \"password123\",\n      tenant_id: \"tenant1\",\n    });\n    const res = await request(app)\n      .get(\"/api/users/me\")\n      .set(\"Authorization\", `Bearer ${reg.body.token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.user.email).toBe(\"admin@test.com\");\n  });\n\n  it(\"returns 401 without auth\", async () => {\n    const res = await request(app).get(\"/api/users/me\");\n    expect(res.status).toBe(401);\n  });\n\n  it(\"admin can update role\", async () => {\n    const admin = await request(app).post(\"/api/users/register\").send({\n      email: \"admin@test.com\",\n      password: \"password123\",\n      tenant_id: \"tenant1\",\n    });\n    const viewer = await request(app).post(\"/api/users/register\").send({\n      email: \"viewer@test.com\",\n      password: \"password123\",\n      tenant_id: \"tenant1\",\n    });\n    const res = await request(app)\n      .put(`/api/users/${viewer.body.user.id}/role`)\n      .set(\"Authorization\", `Bearer ${admin.body.token}`)\n      .send({ role: \"editor\" });\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe(\"editor\");\n  });\n});\n\nasync function createAuthUser(tenant = \"tenant1\") {\n  const res = await request(app).post(\"/api/users/register\").send({\n    email: `user-${Math.random()}@test.com`,\n    password: \"password123\",\n    tenant_id: tenant,\n  });\n  return res.body.token as string;\n}\n\ndescribe(\"Event Ingestion\", () => {\n  it(\"creates a single event\", async () => {\n    const token = await createAuthUser();\n    const res = await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"page_view\", properties: { url: \"/home\" } });\n    expect(res.status).toBe(201);\n    expect(res.body.event.name).toBe(\"page_view\");\n  });\n\n  it(\"creates batch events\", async () => {\n    const token = await createAuthUser();\n    const res = await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" } },\n          { name: \"click\", properties: { button: \"signup\" } },\n        ],\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.inserted).toBe(2);\n  });\n\n  it(\"lists events\", async () => {\n    const token = await createAuthUser();\n    await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"page_view\" });\n    const res = await request(app)\n      .get(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBeGreaterThan(0);\n  });\n\n  it(\"returns 401 without auth\", async () => {\n    const res = await request(app)\n      .post(\"/api/events\")\n      .send({ name: \"page_view\" });\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe(\"Tenant Isolation\", () => {\n  it(\"isolates events between tenants\", async () => {\n    const token1 = await createAuthUser(\"tenant-a\");\n    const 