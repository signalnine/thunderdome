new file mode 100644
index 0000000..80d76c2
--- /dev/null
+++ b/src/routes/dashboards.ts
@@ -0,0 +1,201 @@
+import { Router, Response } from "express";
+import { v4 as uuidv4 } from "uuid";
+import Database from "better-sqlite3";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+export function createDashboardRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Create dashboard
+  router.post("/", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required", code: "BAD_REQUEST" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tid;
+    const ownerId = req.user!.sub;
+    const dashConfig = config ? JSON.stringify(config) : "{}";
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, ownerId, dashConfig);
+
+    res.status(201).json({
+      dashboard: {
+        id,
+        tenant_id: tenantId,
+        name,
+        owner_id: ownerId,
+        config: config || {},
+      },
+    });
+  });
+
+  // List dashboards for tenant
+  router.get("/", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+
+    const dashboards = db.prepare(
+      "SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC"
+    ).all(tenantId) as DashboardRow[];
+
+    const parsed = dashboards.map((d) => ({
+      ...d,
+      config: JSON.parse(d.config),
+    }));
+
+    res.json({ dashboards: parsed });
+  });
+
+  // Get single dashboard
+  router.get("/:id", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+    const { id } = req.params;
+
+    const dashboard = db.prepare(
+      "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found", code: "NOT_FOUND" });
+      return;
+    }
+
+    const widgets = db.prepare(
+      "SELECT * FROM widgets WHERE dashboard_id = ?"
+    ).all(id) as WidgetRow[];
+
+    const parsedWidgets = widgets.map((w) => ({
+      ...w,
+      config: JSON.parse(w.config),
+    }));
+
+    res.json({
+      dashboard: {
+        ...dashboard,
+        config: JSON.parse(dashboard.config),
+        widgets: parsedWidgets,
+      },
+    });
+  });
+
+  // Update dashboard
+  router.put("/:id", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+    const { id } = req.params;
+    const { name, config } = req.body;
+
+    const existing = db.prepare(
+      "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(id, tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found", code: "NOT_FOUND" });
+      return;
+    }
+
+    const newName = name || existing.name;
+    const newConfig = config ? JSON.stringify(config) : existing.config;
+
+    db.prepare(
+      "UPDATE dashboards SET name = ?, config = ?, updated_at = datetime('now') WHERE id = ?"
+    ).run(newName, newConfig, id);
+
+    res.json({
+      dashboard: {
+        id,
+        tenant_id: tenantId,
+        name: newName,
+        owner_id: existing.owner_id,
+        config: config || JSON.parse(existing.config),
+      },
+    });
+  });
+
+  // Delete dashboard
+  router.delete("/:id", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+    const { id } = req.params;
+
+    const existing = db.prepare(
+      "SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(id, tenantId) as { id: string } | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found", code: "NOT_FOUND" });
+      return;
+    }
+
+    db.prepare("DELETE FROM dashboards WHERE id = ?").run(id);
+
+    res.json({ message: "Dashboard deleted", id });
+  });
+
+  // Add widget to dashboard
+  router.post("/:id/widgets", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tid;
+    const { id: dashboardId } = req.params;
+    const { type, config, position_x, position_y, width, height } = req.body;
+
+    const dashboard = db.prepare(
+      "SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(dashboardId, tenantId) as { id: string } | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found", code: "NOT_FOUND" });
+      return;
+    }
+
+    if (!type || !["counter", "timeseries", "breakdown", "funnel"].includes(type)) {
+      res.status(400).json({ error: "Valid widget type is required (counter, timeseries, breakdown, funnel)", code: "BAD_REQUEST" });
+      return;
+    }
+
+    const widgetId = uuidv4();
+    const widgetConfig = config ? JSON.stringify(config) : "{}";
+
+    db.prepare(
+      "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+    ).run(widgetId, dashboardId, type, widgetConfig, position_x || 0, position_y || 0, width || 1, height || 1);
+
+    res.status(201).json({
+      widget: {
+        id: widgetId,
+        dashboard_id: dashboardId,
+        type,
+        config: config || {},
+        position_x: position_x || 0,
+        position_y: position_y || 0,
+        width: width || 1,
+        height: height || 1,
+      },
+    });
+  });
+
+  return router;
+}
