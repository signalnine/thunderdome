=> {\n  it(\"isolates events between tenants\", async () => {\n    const token1 = await createAuthUser(\"tenant-a\");\n    const token2 = await createAuthUser(\"tenant-b\");\n\n    await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token1}`)\n      .send({ name: \"page_view\" });\n\n    const res1 = await request(app)\n      .get(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token1}`);\n    expect(res1.body.events.length).toBe(1);\n\n    const res2 = await request(app)\n      .get(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token2}`);\n    expect(res2.body.events.length).toBe(0);\n  });\n});\n\ndescribe(\"Query Engine\", () => {\n  it(\"counts events\", async () => {\n    const token = await createAuthUser();\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\" },\n          { name: \"page_view\" },\n          { name: \"click\" },\n        ],\n      });\n\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ event_name: \"page_view\" });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(2);\n  });\n\n  it(\"timeseries query\", async () => {\n    const token = await createAuthUser();\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", timestamp: \"2024-01-01T10:00:00Z\" },\n          { name: \"page_view\", timestamp: \"2024-01-01T11:00:00Z\" },\n          { name: \"page_view\", timestamp: \"2024-01-02T10:00:00Z\" },\n        ],\n      });\n\n    const res = await request(app)\n      .post(\"/api/queries/timeseries\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ event_name: \"page_view\", interval: \"day\" });\n    expect(res.status).toBe(200);\n    expect(res.body.timeseries.length).toBe(2);\n  });\n\n  it(\"breakdown query\", async () => {\n    const token = await createAuthUser();\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" } },\n          { name: \"page_view\", properties: { url: \"/home\" } },\n          { name: \"page_view\", properties: { url: \"/about\" } },\n        ],\n      });\n\n    const res = await request(app)\n      .post(\"/api/queries/breakdown\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ event_name: \"page_view\", property: \"url\" });\n    expect(res.status).toBe(200);\n    expect(res.body.breakdown.length).toBe(2);\n    expect(res.body.breakdown[0].value).toBe(\"/home\");\n    expect(res.body.breakdown[0].count).toBe(2);\n  });\n});\n\ndescribe(\"Dashboard CRUD\", () => {\n  it(\"creates a dashboard\", async () => {\n    const token = await createAuthUser();\n    const res = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"My Dashboard\" });\n    expect(res.status).toBe(201);\n    expect(res.body.dashboard.name).toBe(\"My Dashboard\");\n  });\n\n  it(\"lists dashboards\", async () => {\n    const token = await createAuthUser();\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    const res = await request(app)\n      .get(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.dashboards.length).toBe(1);\n  });\n\n  it(\"gets a single dashboard\", async () => {\n    const token = await createAuthUser();\n    const created = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    const res = await request(app)\n      .get(`/api/dashboards/${created.body.dashboard.id}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.dashboard.name).toBe(\"Dashboard 1\");\n  });\n\n  it(\"updates a dashboard\", async () => {\n    const token = await createAuthUser();\n    const created = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    const res = await request(app)\n      .put(`/api/dashboards/${created.body.dashboard.id}`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Updated Dashboard\" });\n    expect(res.status).toBe(200);\n    expect(res.body.dashboard.name).toBe(\"Updated Dashboard\");\n  });\n\n  it(\"deletes a dashboard\", async () => {\n    const token = await createAuthUser();\n    const created = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    const res = await request(app)\n      .delete(`/api/dashboards/${created.body.dashboard.id}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n  });\n\n  it(\"adds a widget to dashboard\", async () => {\n    const token = await createAuthUser();\n    const dash = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    const res = await request(app)\n      .post(`/api/dashboards/${dash.body.dashboard.id}/widgets`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ type: \"counter\", config: { event_name: \"page_view\" } });\n    expect(res.status).toBe(201);\n    expect(res.body.widget.type).toBe(\"counter\");\n  });\n});\n\ndescribe(\"Data Export\", () => {\n  it(\"exports events as JSON\", async () => {\n    const token = await createAuthUser();\n    await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"page_view\" });\n    const res = await request(app)\n      .get(\"/api/export/events/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(1);\n  });\n\n  it(\"exports events as CSV\", async () => {\n    const token = await createAuthUser();\n    await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"page_view\" });\n    const res = await request(app)\n      .get(\"/api/export/events/csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"page_view\");\n  });\n\n  it(\"exports dashboards as JSON\", async () => {\n    const token = await createAuthUser();\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"My Dashboard\" });\n    const res = await request(app)\n      .get(\"/api/export/dashboards/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.dashboards.length).toBe(1);\n  });\n\n  it(\"exports dashboards as CSV\", async () => {\n    const token = await createAuthUser();\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"My Dashboard\" });\n    const res = await request(app)\n      .get(\"/api/export/dashboards/csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"My Dashboard\");\n  });\n});\n","structuredPatch":[],"originalFile":null}}
