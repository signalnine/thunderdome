index 0000000..d0b051a
--- /dev/null
+++ b/src/ws.ts
@@ -0,0 +1,224 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage, Server as HttpServer } from 'http';
+import { DocumentStore } from './db.js';
+import { OpComponent, applyOps, transform, validateOps, inputLength } from './ot.js';
+
+interface ClientConnection {
+  ws: WebSocket;
+  clientId: string;
+  docId: string;
+}
+
+interface DocumentSession {
+  docId: string;
+  version: number;
+  content: string;
+  clients: Map<string, ClientConnection>;
+  /** History of operations applied since version 0. Index i = operation that produced version i+1. */
+  history: OpComponent[][];
+}
+
+interface IncomingOperation {
+  type: 'operation';
+  clientId: string;
+  version: number;
+  ops: OpComponent[];
+}
+
+interface IncomingMessage2 {
+  type: string;
+  [key: string]: unknown;
+}
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  private sessions: Map<string, DocumentSession> = new Map();
+
+  constructor(
+    private server: HttpServer,
+    private store: DocumentStore,
+  ) {
+    this.wss = new WebSocketServer({ server, path: undefined });
+    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {
+      this.handleConnection(ws, req);
+    });
+  }
+
+  private getDocIdFromUrl(url: string | undefined): string | null {
+    if (!url) return null;
+    // Expected path: /ws/documents/:id or /documents/:id/ws
+    const match = url.match(/\/documents\/([^/]+)/);
+    return match ? match[1] : null;
+  }
+
+  private getOrCreateSession(docId: string): DocumentSession | null {
+    if (this.sessions.has(docId)) {
+      return this.sessions.get(docId)!;
+    }
+    const doc = this.store.getDocument(docId);
+    if (!doc) return null;
+
+    // Rebuild history from stored versions
+    const versions = this.store.getVersions(docId);
+    const history: OpComponent[][] = [];
+    for (const ver of versions) {
+      if (ver.operation) {
+        history.push(JSON.parse(ver.operation));
+      }
+    }
+
+    const session: DocumentSession = {
+      docId,
+      version: this.store.getLatestVersion(docId),
+      content: doc.content,
+      clients: new Map(),
+      history,
+    };
+    this.sessions.set(docId, session);
+    return session;
+  }
+
+  private handleConnection(ws: WebSocket, req: IncomingMessage): void {
+    const docId = this.getDocIdFromUrl(req.url);
+    if (!docId) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid URL: document ID required' }));
+      ws.close();
+      return;
+    }
+
+    const session = this.getOrCreateSession(docId);
+    if (!session) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close();
+      return;
+    }
+
+    const clientId = Math.random().toString(36).substring(2, 10);
+    const client: ClientConnection = { ws, clientId, docId };
+    session.clients.set(clientId, client);
+
+    // Send sync message with current document state
+    ws.send(JSON.stringify({
+      type: 'sync',
+      docId,
+      clientId,
+      content: session.content,
+      version: session.version,
+    }));
+
+    ws.on('message', (data: Buffer | string) => {
+      try {
+        const msg = JSON.parse(data.toString()) as IncomingMessage2;
+        if (msg.type === 'operation') {
+          this.handleOperation(session, client, msg as unknown as IncomingOperation);
+        } else {
+          ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${msg.type}` }));
+        }
+      } catch (err) {
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));
+      }
+    });
+
+    ws.on('close', () => {
+      session.clients.delete(clientId);
+      if (session.clients.size === 0) {
+        // Keep session around for a while (or we could clean it up)
+        // For simplicity, we keep it
+      }
+    });
+  }
+
+  private handleOperation(session: DocumentSession, client: ClientConnection, msg: IncomingOperation): void {
+    const { version, ops, clientId } = msg;
+
+    // Validate
+    if (typeof version !== 'number' || !Number.isInteger(version) || version < 0) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Invalid version number' }));
+      return;
+    }
+    if (version > session.version) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Version is ahead of server' }));
+      return;
+    }
+
+    const validationError = validateOps(ops);
+    if (validationError) {
+      client.ws.send(JSON.stringify({ type: 'error', message: validationError }));
+      return;
+    }
+
+    // Transform against all operations that happened since the client's version
+    let transformedOps = ops;
+    for (let v = version; v < session.version; v++) {
+      const serverOp = session.history[v];
+      if (!serverOp) {
+        client.ws.send(JSON.stringify({ type: 'error', message: 'Missing server operation for transform' }));
+        return;
+      }
+      const [clientPrime] = transform(transformedOps, serverOp);
+      transformedOps = clientPrime;
+    }
+
+    // Validate that the transformed operation matches current document length
+    const expectedLen = inputLength(transformedOps);
+    if (expectedLen !== session.content.length) {
+      client.ws.send(JSON.stringify({
+        type: 'error',
+        message: `Operation length mismatch: op expects ${expectedLen} chars, doc has ${session.content.length}`,
+      }));
+      return;
+    }
+
+    // Apply
+    try {
+      session.content = applyOps(session.content, transformedOps);
+    } catch (err) {
+      client.ws.send(JSON.stringify({
+        type: 'error',
+        message: `Failed to apply operation: ${(err as Error).message}`,
+      }));
+      return;
+    }
+
+    session.version++;
+    session.history.push(transformedOps);
+
+    // Persist
+    this.store.updateContent(session.docId, session.content);
+    this.store.saveVersion(
+      session.docId,
+      session.version,
+      session.content,
+      JSON.stringify(transformedOps),
+    );
+
+    // Acknowledge to sender
+    client.ws.send(JSON.stringify({
+      type: 'ack',
+      version: session.version,
+    }));
+
+    // Broadcast to other clients
+    for (const [cid, c] of session.clients) {
+      if (cid !== client.clientId && c.ws.readyState === WebSocket.OPEN) {
+        c.ws.send(JSON.stringify({
+          type: 'operation',
+          clientId: clientId || client.clientId,
+          version: session.version,
+          ops: transformedOps,
+        }));
+      }
+    }
+  }
+
+  closeAll(): void {
+    for (const session of this.sessions.values()) {
+      for (const client of session.clients.values()) {
+        client.ws.close();
+      }
+      session.clients.clear();
+    }
+    this.sessions.clear();
+    this.wss.close();
+  }
+}
