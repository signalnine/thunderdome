-describe('Two-Client Convergence', () => {
-  let app: AppInstance;
-  let port: number;
-
-  beforeAll(async () => {
-    app = createApp();
-    port = await app.start(0);
-  });
-
-  afterAll(async () => {
-    await app.stop();
-  });
-
-  it('Two clients editing different positions converge to same content', async () => {
-    const res = await request(app.app).post('/docs').send({ title: 'Converge', content: 'ABCDEF' });
-    const docId = res.body.id;
-
-    const c1 = await createWsClient(port, docId);
-    const sync1 = await waitForMsg(c1, 0);
-    const c2 = await createWsClient(port, docId);
-    await waitForMsg(c2, 0);
-
-    const version = (sync1 as { version: number }).version;
-
-    // Client 1 inserts at position 0
-    sendOp(c1, { type: 'insert', position: 0, text: 'X' }, version);
-    await waitForMsg(c1, 1); // ack
-    await waitForMsg(c2, 1); // broadcast
-
-    // Client 2 inserts at position 7 (after "X" was added, "XABCDEF" is 7 chars, insert at end)
-    sendOp(c2, { type: 'insert', position: 7, text: 'Y' }, version + 1);
-    await waitForMsg(c2, 2); // ack
-
-    await delay(100);
-    const doc = await request(app.app).get(`/docs/${docId}`);
-    expect(doc.body.content).toBe('XABCDEFY');
-
-    await closeClient(c1);
-    await closeClient(c2);
-  });
-
-  it('Two clients inserting at same position both insertions preserved', async () => {
-    const res = await request(app.app).post('/docs').send({ title: 'SamePos', content: '' });
-    const docId = res.body.id;
-
-    const c1 = await createWsClient(port, docId);
-    const sync1 = await waitForMsg(c1, 0);
-    const c2 = await createWsClient(port, docId);
-    await waitForMsg(c2, 0);
-    const version = (sync1 as { version: number }).version;
-
-    // Both insert at position 0
-    sendOp(c1, { type: 'insert', position: 0, text: 'A' }, version);
-    await waitForMsg(c1, 1); // ack
-    await waitForMsg(c2, 1); // broadcast
-
-    sendOp(c2, { type: 'insert', position: 0, text: 'B' }, version);
-    await waitForMsg(c2, 2); // ack
-
-    await delay(100);
-    const doc = await request(app.app).get(`/docs/${docId}`);
-    expect(doc.body.content).toContain('A');
-    expect(doc.body.content).toContain('B');
-    expect(doc.body.content.length).toBe(2);
-
-    await closeClient(c1);
-    await closeClient(c2);
-  });
-
-  it('Client A inserts, Client B deletes: both changes applied', async () => {
-    const res = await request(app.app).post('/docs').send({ title: 'InsertDelete', content: 'Hello World' });
-    const docId = res.body.id;
-
-    const c1 = await createWsClient(port, docId);
-    const sync1 = await waitForMsg(c1, 0);
-    const c2 = await createWsClient(port, docId);
-    await waitForMsg(c2, 0);
-    const version = (sync1 as { version: number }).version;
-
-    // Client 1 inserts at beginning
-    sendOp(c1, { type: 'insert', position: 0, text: 'Hey ' }, version);
-    await waitForMsg(c1, 1); // ack
-    await waitForMsg(c2, 1); // broadcast
-
-    // Client 2 deletes "World" (now at position 10 because "Hey " shifted it; "Hey Hello World")
-    // After transform: "Hey Hello World" - delete at pos 10 count 5 = "Hey Hello "
-    sendOp(c2, { type: 'delete', position: 10, count: 5 }, version + 1);
-    await waitForMsg(c2, 2); // ack
-
-    await delay(100);
-    const doc = await request(app.app).get(`/docs/${docId}`);
-    expect(doc.body.content).toContain('Hey');
-    expect(doc.body.content).not.toContain('World');
-
-    await closeClient(c1);
-    await closeClient(c2);
-  });
-
-  it('Rapid alternating edits from two clients converge', async () => {
-    const res = await request(app.app).post('/docs').send({ title: 'Rapid', content: '' });
-    const docId = res.body.id;
-
-    const c1 = await createWsClient(port, docId);
-    await waitForMsg(c1, 0); // sync
-    const c2 = await createWsClient(port, docId);
-    await waitForMsg(c2, 0); // sync
-
-    // Alternating edits - each appends a char
-    for (let i = 0; i < 5; i++) {
-      sendOp(c1, { type: 'insert', position: i * 2, text: 'A' });
-      await delay(50);
-      sendOp(c2, { type: 'insert', position: i * 2 + 1, text: 'B' });
-      await delay(50);
-    }
-
-    await delay(500);
-    const doc = await request(app.app).get(`/docs/${docId}`);
-    // All 10 characters should be present
-    expect(doc.body.content.length).toBe(10);
-
-    await closeClient(c1);
-    await closeClient(c2);
-  });
-
-  it('Both clients can fetch document and see identical content after sync', async () => {
-    const res = await request(app.app).post('/docs').send({ title: 'Identical', content: 'Start' });
-    const docId = res.body.id;
-
-    const c1 = await createWsClient(port, docId);
-    await waitForMsg(c1, 0);
-    const c2 = await createWsClient(port, docId);
-    await waitForMsg(c2, 0);
-
-    sendOp(c1, { type: 'insert', position: 5, text: ' End' });
-    await waitForMsg(c1, 1); // ack
-    await waitForMsg(c2, 1); // broadcast
-
-    await delay(100);
-    const doc1 = await request(app.app).get(`/docs/${docId}`);
-    const doc2 = await request(app.app).get(`/docs/${docId}`);
-    expect(doc1.body.content).toBe(doc2.body.content);
-    expect(doc1.body.content).toBe('Start End');
-
-    await closeClient(c1);
-    await closeClient(c2);
-  });
-
-  it('Version history contains all operations in order', async () => {
-    const res = await request(app.app).post('/docs').send({ title: 'History', content: '' });
-    const docId = res.body.id;
-
-    const client = await createWsClient(port, docId);
-    await waitForMsg(client, 0); // sync
-
-    sendOp(client, { type: 'insert', position: 0, text: 'A' });
-    await waitForMsg(client, 1);
-    sendOp(client, { type: 'insert', position: 1, text: 'B' });
-    await waitForMsg(client, 2);
-    sendOp(client, { type: 'insert', position: 2, text: 'C' });
-    await waitForMsg(client, 3);
-
-    const versions = await request(app.app).get(`/docs/${docId}/versions`);
-    expect(versions.body.length).toBeGreaterThanOrEqual(4); // version 0 + 3 edits
-    for (let i = 1; i < versions.body.length; i++) {
-      expect(versions.body[i].version).toBeGreaterThan(versions.body[i - 1].version);
-    }
-
-    await closeClient(client);
-  });
-
-  it('Concurrent edits do not lose data', async () => {
-    const res = await request(app.app).post('/docs').send({ title: 'NoLoss', content: '' });
-    const docId = res.body.id;
-
-    const c1 = await createWsClient(port, docId);
-    const sync1 = await waitForMsg(c1, 0);
-    const c2 = await createWsClient(port, docId);
-    await waitForMsg(c2, 0);
-    const version = (sync1 as { version: number }).version;
-
-    // Both send edits based on same initial version
-    sendOp(c1, { type: 'insert', position: 0, text: 'FIRST' }, version);
