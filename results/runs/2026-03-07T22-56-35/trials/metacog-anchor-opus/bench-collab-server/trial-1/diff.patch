new file mode 100644
index 0000000..d640f51
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,236 @@
+/**
+ * Operational Transformation engine.
+ *
+ * Operations are arrays of components:
+ *   - { type: 'retain', count: N }  -- skip N characters
+ *   - { type: 'insert', text: S }   -- insert string S at current position
+ *   - { type: 'delete', count: N }  -- delete N characters at current position
+ *
+ * An operation's "input length" is the sum of retain + delete counts.
+ * An operation's "output length" is the sum of retain counts + insert text lengths.
+ * A valid operation's input length must equal the document length it's applied to.
+ */
+
+export interface RetainOp {
+  type: 'retain';
+  count: number;
+}
+
+export interface InsertOp {
+  type: 'insert';
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  count: number;
+}
+
+export type OpComponent = RetainOp | InsertOp | DeleteOp;
+
+export interface Operation {
+  docId: string;
+  version: number; // the version this operation was based on
+  clientId: string;
+  ops: OpComponent[];
+}
+
+export function inputLength(ops: OpComponent[]): number {
+  let len = 0;
+  for (const op of ops) {
+    if (op.type === 'retain') len += op.count;
+    else if (op.type === 'delete') len += op.count;
+  }
+  return len;
+}
+
+export function outputLength(ops: OpComponent[]): number {
+  let len = 0;
+  for (const op of ops) {
+    if (op.type === 'retain') len += op.count;
+    else if (op.type === 'insert') len += op.text.length;
+  }
+  return len;
+}
+
+export function applyOps(doc: string, ops: OpComponent[]): string {
+  const inLen = inputLength(ops);
+  if (inLen !== doc.length) {
+    throw new Error(`Operation input length (${inLen}) does not match document length (${doc.length})`);
+  }
+  let result = '';
+  let pos = 0;
+  for (const op of ops) {
+    switch (op.type) {
+      case 'retain':
+        result += doc.slice(pos, pos + op.count);
+        pos += op.count;
+        break;
+      case 'insert':
+        result += op.text;
+        break;
+      case 'delete':
+        pos += op.count;
+        break;
+    }
+  }
+  return result;
+}
+
+/**
+ * Transform two concurrent operations so they can be applied in sequence.
+ * Given operations A and B both based on the same document state,
+ * returns [A', B'] such that apply(apply(doc, A), B') === apply(apply(doc, B), A').
+ */
+export function transform(opsA: OpComponent[], opsB: OpComponent[]): [OpComponent[], OpComponent[]] {
+  let indexA = 0;
+  let indexB = 0;
+  const aPrime: OpComponent[] = [];
+  const bPrime: OpComponent[] = [];
+
+  // Remaining portion of current component
+  let remA: OpComponent | null = opsA[indexA] ?? null;
+  let remB: OpComponent | null = opsB[indexB] ?? null;
+
+  function nextA(): OpComponent | null {
+    indexA++;
+    return opsA[indexA] ?? null;
+  }
+
+  function nextB(): OpComponent | null {
+    indexB++;
+    return opsB[indexB] ?? null;
+  }
+
+  while (remA !== null || remB !== null) {
+    // Insert in A takes priority (applied first)
+    if (remA !== null && remA.type === 'insert') {
+      aPrime.push({ type: 'insert', text: remA.text });
+      bPrime.push({ type: 'retain', count: remA.text.length });
+      remA = nextA();
+      continue;
+    }
+
+    // Insert in B
+    if (remB !== null && remB.type === 'insert') {
+      bPrime.push({ type: 'insert', text: remB.text });
+      aPrime.push({ type: 'retain', count: remB.text.length });
+      remB = nextB();
+      continue;
+    }
+
+    if (remA === null || remB === null) {
+      throw new Error('Operations do not span the same document length');
+    }
+
+    // Both retain
+    if (remA.type === 'retain' && remB.type === 'retain') {
+      const min = Math.min(remA.count, remB.count);
+      aPrime.push({ type: 'retain', count: min });
+      bPrime.push({ type: 'retain', count: min });
+      if (remA.count === remB.count) {
+        remA = nextA();
+        remB = nextB();
+      } else if (remA.count < remB.count) {
+        remB = { type: 'retain', count: remB.count - remA.count };
+        remA = nextA();
+      } else {
+        remA = { type: 'retain', count: remA.count - remB.count };
+        remB = nextB();
+      }
+    }
+    // A deletes, B retains
+    else if (remA.type === 'delete' && remB.type === 'retain') {
+      const min = Math.min(remA.count, remB.count);
+      aPrime.push({ type: 'delete', count: min });
+      // B's retain is consumed by A's delete, no output for B
+      if (remA.count === remB.count) {
+        remA = nextA();
+        remB = nextB();
+      } else if (remA.count < remB.count) {
+        remB = { type: 'retain', count: remB.count - remA.count };
+        remA = nextA();
+      } else {
+        remA = { type: 'delete', count: remA.count - remB.count };
+        remB = nextB();
+      }
+    }
+    // A retains, B deletes
+    else if (remA.type === 'retain' && remB.type === 'delete') {
+      const min = Math.min(remA.count, remB.count);
+      bPrime.push({ type: 'delete', count: min });
+      if (remA.count === remB.count) {
+        remA = nextA();
+        remB = nextB();
+      } else if (remA.count < remB.count) {
+        remB = { type: 'delete', count: remB.count - remA.count };
+        remA = nextA();
+      } else {
+        remA = { type: 'retain', count: remA.count - remB.count };
+        remB = nextB();
+      }
+    }
+    // Both delete
+    else if (remA.type === 'delete' && remB.type === 'delete') {
+      // Both deleting the same chars — no output for either
+      if (remA.count === remB.count) {
+        remA = nextA();
+        remB = nextB();
+      } else if (remA.count < remB.count) {
+        remB = { type: 'delete', count: remB.count - remA.count };
+        remA = nextA();
+      } else {
+        remA = { type: 'delete', count: remA.count - remB.count };
+        remB = nextB();
+      }
+    }
+  }
+
+  return [compact(aPrime), compact(bPrime)];
+}
+
+/** Merge consecutive same-type components. */
+function compact(ops: OpComponent[]): OpComponent[] {
+  const result: OpComponent[] = [];
+  for (const op of ops) {
+    if (result.length === 0) {
+      result.push(op);
+      continue;
+    }
+    const last = result[result.length - 1];
+    if (last.type === 'retain' && op.type === 'retain') {
+      (last as RetainOp).count += op.count;
+    } else if (last.type === 'delete' && op.type === 'delete') {
+      (last as DeleteOp).count += op.count;
+    } else if (last.type === 'insert' && op.type === 'insert') {
+      (last as InsertOp).text += op.text;
+    } else {
+      result.push(op);
+    }
+  }
+  return result;
+}
+
+/** Validate that an operation is well-formed. */
+export function validateOps(ops: OpComponent[]): string | null {
+  if (!Array.isArray(ops)) return 'ops must be an array';
+  for (const op of ops) {
+    if (!op || typeof op !== 'object') return 'each op must be an object';
+    if (op.type === 'retain') {
+      if (typeof op.count !== 'number' || op.count <= 0 || !Number.isInteger(op.count)) {
+        return 'retain count must be a positive integer';
+      }
+    } else if (op.type === 'insert') {
+      if (typeof op.text !== 'string' || op.text.length === 0) {
+        return 'insert text must be a non-empty string';
+      }
+    } else if (op.type === 'delete') {
+      if (typeof op.count !== 'number' || op.count <= 0 || !Number.isInteger(op.count)) {
+        return 'delete count must be a positive integer';
+      }
+    } else {
+      return `unknown op type: ${(op as { type: string }).type}`;
+    }
+  }
+  return null;
+}
