ession.content.length}`,\n      }));\n      return;\n    }\n\n    // Apply\n    try {\n      session.content = applyOps(session.content, transformedOps);\n    } catch (err) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: `Failed to apply operation: ${(err as Error).message}`,\n      }));\n      return;\n    }\n\n    session.version++;\n    session.history.push(transformedOps);\n\n    // Persist\n    this.store.updateContent(session.docId, session.content);\n    this.store.saveVersion(\n      session.docId,\n      session.version,\n      session.content,\n      JSON.stringify(transformedOps),\n    );\n\n    // Acknowledge to sender\n    client.ws.send(JSON.stringify({\n      type: 'ack',\n      version: session.version,\n    }));\n\n    // Broadcast to other clients\n    for (const [cid, c] of session.clients) {\n      if (cid !== client.clientId && c.ws.readyState === WebSocket.OPEN) {\n        c.ws.send(JSON.stringify({\n          type: 'operation',\n          clientId: clientId || client.clientId,\n          version: session.version,\n          ops: transformedOps,\n        }));\n      }\n    }\n  }\n\n  closeAll(): void {\n    for (const session of this.sessions.values()) {\n      for (const client of session.clients.values()) {\n        client.ws.close();\n      }\n      session.clients.clear();\n    }\n    this.sessions.clear();\n    this.wss.close();\n  }\n}\n","structuredPatch":[{"oldStart":1,"oldLines":6,"newStart":1,"newLines":5,"lines":[" import { WebSocketServer, WebSocket } from 'ws';","-import { IncomingMessage } from 'http';","-import { Server as HttpServer } from 'http';","+import { IncomingMessage, Server as HttpServer } from 'http';"," import { DocumentStore } from './db.js';"," import { OpComponent, applyOps, transform, validateOps, inputLength } from './ot.js';"," "]}],"userModified":false,"replaceAll":false}}
