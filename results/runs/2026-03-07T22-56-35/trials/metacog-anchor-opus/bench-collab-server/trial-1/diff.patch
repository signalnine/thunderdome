nc () => {\n    await app.stop();\n  });\n\n  it('should create a document', async () => {\n    const res = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Test Doc', content: 'Hello' })\n      .expect(201);\n    expect(res.body.id).toBeDefined();\n    expect(res.body.title).toBe('Test Doc');\n    expect(res.body.content).toBe('Hello');\n  });\n\n  it('should list documents', async () => {\n    await request(app.app).post('/api/documents').send({ title: 'Doc 1' });\n    await request(app.app).post('/api/documents').send({ title: 'Doc 2' });\n    const res = await request(app.app).get('/api/documents').expect(200);\n    expect(res.body.length).toBe(2);\n  });\n\n  it('should get a document by id', async () => {\n    const createRes = await request(app.app).post('/api/documents').send({ title: 'My Doc', content: 'Content' });\n    const res = await request(app.app).get(`/api/documents/${createRes.body.id}`).expect(200);\n    expect(res.body.title).toBe('My Doc');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    await request(app.app).get('/api/documents/nonexistent').expect(404);\n  });\n\n  it('should update a document', async () => {\n    const createRes = await request(app.app).post('/api/documents').send({ title: 'Original' });\n    const res = await request(app.app)\n      .put(`/api/documents/${createRes.body.id}`)\n      .send({ title: 'Updated' })\n      .expect(200);\n    expect(res.body.title).toBe('Updated');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await request(app.app).post('/api/documents').send({ title: 'To Delete' });\n    await request(app.app).delete(`/api/documents/${createRes.body.id}`).expect(204);\n    await request(app.app).get(`/api/documents/${createRes.body.id}`).expect(404);\n  });\n\n  it('should return version history', async () => {\n    const createRes = await request(app.app).post('/api/documents').send({ title: 'Versioned', content: 'v0' });\n    const res = await request(app.app).get(`/api/documents/${createRes.body.id}/versions`).expect(200);\n    expect(res.body.length).toBeGreaterThanOrEqual(1);\n    expect(res.body[0].version).toBe(0);\n  });\n\n  it('should reject document creation without title', async () => {\n    await request(app.app).post('/api/documents').send({ content: 'no title' }).expect(400);\n  });\n});\n\ndescribe('WebSocket collaboration', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should send sync message on connection', async () => {\n    const createRes = await request(app.app).post('/api/documents').send({ title: 'WS Doc', content: 'Hello' });\n    const docId = createRes.body.id;\n    const { ws, syncMsg } = await connectWs(docId);\n    expect(syncMsg.type).toBe('sync');\n    expect(syncMsg.content).toBe('Hello');\n    expect(syncMsg.version).toBe(0);\n    ws.close();\n  });\n\n  it('should apply and broadcast operations', async () => {\n    const createRes = await request(app.app).post('/api/documents').send({ title: 'Collab', content: 'Hello' });\n    const docId = createRes.body.id;\n\n    const { ws: ws1, syncMsg: sync1 } = await connectWs(docId);\n    const { ws: ws2 } = await connectWs(docId);\n\n    // Client 1 inserts \" World\" at position 5\n    const broadcastPromise = waitForMessage(ws2, 'operation');\n    sendOp(ws1, sync1.version, [\n      { type: 'retain', count: 5 },\n      { type: 'insert', text: ' World' },\n    ]);\n\n    const ackMsg = await waitForMessage(ws1, 'ack');\n    expect(ackMsg.version).toBe(1);\n\n    const broadcastMsg = await broadcastPromise;\n    expect(broadcastMsg.type).toBe('operation');\n    expect(broadcastMsg.version).toBe(1);\n\n    // Verify document content via REST\n    const docRes = await request(app.app).get(`/api/documents/${docId}`).expect(200);\n    expect(docRes.body.content).toBe('Hello World');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent edits with OT', async () => {\n    const createRes = await request(app.app).post('/api/documents').send({ title: 'OT Test', content: 'abc' });\n    const docId = createRes.body.id;\n\n    const { ws: ws1, syncMsg: sync1 } = await connectWs(docId);\n    const { ws: ws2, syncMsg: sync2 } = await connectWs(docId);\n\n    expect(sync1.version).toBe(0);\n    expect(sync2.version).toBe(0);\n\n    // Both clients send operations based on version 0\n    // Client 1: insert \"X\" at position 0 → \"Xabc\"\n    // Client 2: insert \"Y\" at end → \"abcY\"\n    // After OT, result should contain both X and Y\n\n    const ack1Promise = waitForMessage(ws1, 'ack');\n    sendOp(ws1, 0, [\n      { type: 'insert', text: 'X' },\n      { type: 'retain', count: 3 },\n    ], 'client1');\n\n    await ack1Promise;\n\n    const ack2Promise = waitForMessage(ws2, 'ack');\n    // Note: ws2 may not have received the broadcast yet, but it sends based on version 0\n    sendOp(ws2, 0, [\n      { type: 'retain', count: 3 },\n      { type: 'insert', text: 'Y' },\n    ], 'client2');\n\n    await ack2Promise;\n\n    // Verify the document contains both insertions\n    const docRes = await request(app.app).get(`/api/documents/${docId}`).expect(200);\n    const content = docRes.body.content;\n    expect(content).toContain('X');\n    expect(content).toContain('Y');\n    expect(content).toContain('abc');\n    expect(content.length).toBe(5); // \"Xabc\" + \"Y\" = \"XabcY\"\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should reject invalid operations', async () => {\n    const createRes = await request(app.app).post('/api/documents').send({ title: 'Invalid', content: 'test' });\n    const docId = createRes.body.id;\n\n    const { ws } = await connectWs(docId);\n\n    // Send malformed operation\n    ws.send(JSON.stringify({\n      type: 'operation',\n      clientId: 'bad',\n      version: 0,\n      ops: [{ type: 'unknown', count: 5 }],\n    }));\n\n    const errMsg = await waitForMessage(ws, 'error');\n    expect(errMsg.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle document not found on ws connect', async () => {\n    const ws = new WebSocket(wsUrl('nonexistent-id'));\n    const msg = await new Promise<Record<string, unknown>>((resolve) => {\n      ws.on('message', (data) => {\n        resolve(JSON.parse(data.toString()));\n      });\n    });\n    expect(msg.type).toBe('error');\n    ws.close();\n  });\n});\n\ndescribe('OT engine', () => {\n  it('should apply insert operation', () => {\n    const result = applyOps('Hello', [\n      { type: 'retain', count: 5 },\n      { type: 'insert', text: ' World' },\n    ]);\n    expect(result).toBe('Hello World');\n  });\n\n  it('should apply delete operation', () => {\n    const result = applyOps('Hello World', [\n      { type: 'retain', count: 5 },\n      { type: 'delete', count: 6 },\n    ]);\n    expect(result).toBe('Hello');\n  });\n\n  it('should transform concurrent inserts', () => {\n    // Both based on \"abc\"\n    const opA: OpComponent[] = [\n      { type: 'insert', text: 'X' },\n      { type: 'retain', count: 3 },\n    ];\n    const opB: OpComponent[] = [\n      { type: 'retain', count: 3 },\n      { type: 'insert', text: 'Y' },\n    ];\n\n    const [aPrime, bPrime] = transform(opA, opB);\n\n    // Apply A then B'\n    const resultAB = applyOps(applyOps('abc', opA), bPrime);\n    // Apply B then A'\n    const resultBA = applyOps(applyOps('abc', opB), aPrime);\n\n    expect(resultAB).toBe(resultBA);\n    expect(resultAB).toContain('X');\n    expect(resultAB).toContain('Y');\n    expect(resultAB).toContain('abc');\n  });\n\n  it('should transform concurrent inserts at same position', () => {\n    const opA: OpComponent[] = [\n      { type: 'retain', count: 2 },\n      { type: 'insert', text: 'X' },\n      { type: 'retain', count: 1 },\n    ];\n    const opB: OpComponent[] = [\n      { type: 'retain', count: 2 },\n      { type: 'insert', text: 'Y' },\n      { type: 'retain', count: 1 },\n    ];\n\n    const [aPrime, bPrime] = transform(opA, opB);\n    const resultAB = applyOps(applyOps('abc', opA), bPrime);\n    const resultBA = applyOps(applyOps('abc', opB), aPrime);\n\n    expect(resultAB).toBe(resultBA);\n    expect(resultAB).toContain('X');\n    expect(resultAB).toContain('Y');\n  });\n\n  it('should handle delete vs insert transform', () => {\n    // A deletes first char, B inserts at beginning\n    const opA: OpComponent[] = [\n      { type: 'delete', count: 1 },\n      { type: 'retain', count: 2 },\n    ];\n    const opB: OpComponent[] = [\n      { type: 'insert', text: 'Z' },\n      { type: 'retain', count: 3 },\n    ];\n\n    const [aPrime, bPrime] = transform(opA, opB);\n    const resultAB = applyOps(applyOps('abc', opA), bPrime);\n    const resultBA = applyOps(applyOps('abc', opB), aPrime);\n\n    expect(resultAB).toBe(resultBA);\n  });\n});\n\ndescribe('Concurrent clients stress test', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const createRes = await request(app.app)\n      .post('/api/documents')\n      .send({ title: 'Stress', content: '' });\n    const docId = createRes.body.id;\n\n    const NUM_CLIENTS = 10;\n    const clients: { ws: WebSocket; clientId: string; version: number }[] = [];\n\n    // Connect all clients\n    for (let i = 0; i < NUM_CLIENTS; i++) {\n      const { ws, syncMsg } = await connectWs(docId);\n      clients.push({ ws, clientId: syncMsg.clientId, version: syncMsg.version });\n    }\n\n    // Each client inserts their number, sequentially to avoid race issues\n    for (let i = 0; i < NUM_CLIENTS; i++) {\n      const client = clients[i];\n      const ackPromise = waitForMessage(client.ws, 'ack');\n\n      // Each client inserts at the end based on its current version\n      // Since content might have grown, we need the current doc length\n      const docRes = await request(app.app).get(`/api/documents/${docId}`);\n      const currentLen = docRes.body.content.length;\n      const currentVersion = i; // Each previous insert incremented the version\n\n      sendOp(client.ws, currentVersion, [\n        ...(currentLen > 0 ? [{ type: 'retain' as const, count: currentLen }] : []),\n        { type: 'insert' as const, text: String(i) },\n      ], client.clientId);\n\n      const ack = await ackPromise;\n      expect(ack.version).toBe(i + 1);\n    }\n\n    // Wait a bit for all broadcasts to settle\n    await new Promise(r => setTimeout(r, 100));\n\n    // Verify document contains all digits\n    const finalDoc = await request(app.app).get(`/api/documents/${docId}`);\n    const content = finalDoc.body.content;\n    expect(content.length).toBe(NUM_CLIENTS);\n\n    for (let i = 0; i < NUM_CLIENTS; i++) {\n      expect(content).toContain(String(i));\n    }\n\n    // Verify version history\n    const versionsRes = await request(app.app).get(`/api/documents/${docId}/versions`);\n    expect(versionsRes.body.length).toBe(NUM_CLIENTS + 1); // initial + 10 edits\n\n    // Cleanup\n    for (const client of clients) {\n      client.ws.close();\n    }\n  });\n});\n\ndescribe('Persistence', () => {\n  it('should persist documents across server restarts', async () => {\n    const fs = await import('fs');\n    const os = await import('os');\n    const path = await import('path');\n    const dbPath = path.join(os.tmpdir(), `collab-test-${Date.now()}.db`);\n\n    try {\n      // Start first server\n      let server = createApp(dbPath);\n      await server.start(0);\n\n      const res = await request(server.app)\n        .post('/api/documents')\n        .send({ title: 'Persistent', content: 'saved data' });\n      const docId = res.body.id;\n\n      await server.stop();\n\n      // Start second server with same db\n      server = createApp(dbPath);\n      await server.start(0);\n\n      const getRes = await request(server.app)\n        .get(`/api/documents/${docId}`)\n        .expect(200);\n      expect(getRes.body.title).toBe('Persistent');\n      expect(getRes.body.content).toBe('saved data');\n\n      await server.stop();\n    } finally {\n      if (fs.existsSync(dbPath)) fs.unlinkSync(dbPath);\n    }\n  });\n});\n","structuredPatch":[],"originalFile":null}}
