--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,503 @@
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  base: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  ours: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  theirs: any;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocumentState {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchData {
+  documents: Map<string, DocumentState>;
+  parentBranch: string | null;
+  forkSnapshot: Map<string, DocumentState> | null;
+}
+
+function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj)) as T;
+}
+
+let versionCounter = 0;
+function generateVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+function getNestedValue(obj: Record<string, unknown>, pathParts: string[]): unknown {
+  let current: unknown = obj;
+  for (const part of pathParts) {
+    if (current == null || typeof current !== 'object') return undefined;
+    current = (current as Record<string, unknown>)[part];
+  }
+  return current;
+}
+
+function setNestedValue(obj: Record<string, unknown>, pathParts: string[], value: unknown): void {
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < pathParts.length - 1; i++) {
+    const part = pathParts[i];
+    if (current[part] == null || typeof current[part] !== 'object') {
+      current[part] = {};
+    }
+    current = current[part] as Record<string, unknown>;
+  }
+  current[pathParts[pathParts.length - 1]] = value;
+}
+
+function deleteNestedValue(obj: Record<string, unknown>, pathParts: string[]): void {
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < pathParts.length - 1; i++) {
+    const part = pathParts[i];
+    if (current[part] == null || typeof current[part] !== 'object') return;
+    current = current[part] as Record<string, unknown>;
+  }
+  delete current[pathParts[pathParts.length - 1]];
+}
+
+function collectAllPaths(obj: unknown, prefix: string[] = []): string[][] {
+  const paths: string[][] = [];
+  if (obj == null || typeof obj !== 'object' || Array.isArray(obj)) {
+    return paths;
+  }
+  for (const key of Object.keys(obj as Record<string, unknown>)) {
+    const currentPath = [...prefix, key];
+    const value = (obj as Record<string, unknown>)[key];
+    if (value != null && typeof value === 'object' && !Array.isArray(value)) {
+      paths.push(currentPath);
+      paths.push(...collectAllPaths(value, currentPath));
+    } else {
+      paths.push(currentPath);
+    }
+  }
+  return paths;
+}
+
+function isLeafValue(val: unknown): boolean {
+  return val == null || typeof val !== 'object' || Array.isArray(val);
+}
+
+function valuesEqual(a: unknown, b: unknown): boolean {
+  return JSON.stringify(a) === JSON.stringify(b);
+}
+
+function threeWayMergeDocument(
+  base: object | null,
+  ours: object | null,
+  theirs: object | null,
+  documentId: string
+): { merged: object; conflicts: Conflict[] } {
+  const baseObj = (base ?? {}) as Record<string, unknown>;
+  const oursObj = (ours ?? {}) as Record<string, unknown>;
+  const theirsObj = (theirs ?? {}) as Record<string, unknown>;
+
+  const allPathsSet = new Set<string>();
+  const allPaths: string[][] = [];
+
+  function addPaths(obj: unknown) {
+    const paths = collectAllPaths(obj);
+    for (const p of paths) {
+      const key = p.join('.');
+      if (!allPathsSet.has(key)) {
+        allPathsSet.add(key);
+        allPaths.push(p);
+      }
+    }
+  }
+
+  addPaths(baseObj);
+  addPaths(oursObj);
+  addPaths(theirsObj);
+
+  // Filter to only leaf paths (paths whose values are leaf values in at least one version)
+  const leafPaths = allPaths.filter(p => {
+    const bVal = getNestedValue(baseObj, p);
+    const oVal = getNestedValue(oursObj, p);
+    const tVal = getNestedValue(theirsObj, p);
+    return isLeafValue(bVal) || isLeafValue(oVal) || isLeafValue(tVal);
+  });
+
+  const merged = deepClone(oursObj) as Record<string, unknown>;
+  const conflicts: Conflict[] = [];
+
+  for (const pathParts of leafPaths) {
+    const baseVal = getNestedValue(baseObj, pathParts);
+    const oursVal = getNestedValue(oursObj, pathParts);
+    const theirsVal = getNestedValue(theirsObj, pathParts);
+
+    const baseChanged = !valuesEqual(baseVal, oursVal);
+    const theirsChanged = !valuesEqual(baseVal, theirsVal);
+
+    if (!baseChanged && !theirsChanged) {
+      continue;
+    }
+
+    if (!baseChanged && theirsChanged) {
+      if (theirsVal === undefined) {
+        deleteNestedValue(merged, pathParts);
+      } else {
+        setNestedValue(merged, pathParts, deepClone(theirsVal));
+      }
+      continue;
+    }
+
+    if (baseChanged && !theirsChanged) {
+      continue;
+    }
+
+    // Both changed
+    if (valuesEqual(oursVal, theirsVal)) {
+      continue;
+    }
+
+    // Conflict
+    conflicts.push({
+      documentId,
+      path: pathParts.join('.'),
+      base: baseVal === undefined ? undefined : deepClone(baseVal),
+      ours: oursVal === undefined ? undefined : deepClone(oursVal),
+      theirs: theirsVal === undefined ? undefined : deepClone(theirsVal),
+    });
+  }
+
+  return { merged: merged as object, conflicts };
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      documents: new Map(),
+      parentBranch: null,
+      forkSnapshot: null,
+    });
+  }
+
+  private getBranchData(name?: string): BranchData {
+    const branchName = name ?? this.currentBranch;
+    const branch = this.branches.get(branchName);
+    if (!branch) {
+      throw new Error(`Branch "${branchName}" does not exist`);
+    }
+    return branch;
+  }
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    branch.documents.set(id, {
+      content: deepClone(content),
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    doc.content = deepClone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    doc.deleted = true;
+  }
+
+  getHistory(id: string): Version[] {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceBranchName = fromBranch ?? this.currentBranch;
+    const sourceBranch = this.getBranchData(sourceBranchName);
+
+    const clonedDocs = new Map<string, DocumentState>();
+    for (const [docId, docState] of sourceBranch.documents) {
+      clonedDocs.set(docId, {
+        content: deepClone(docState.content),
+        versions: docState.versions.map(v => ({
+          id: v.id,
+          timestamp: v.timestamp,
+          content: deepClone(v.content),
+        })),
+        deleted: docState.deleted,
+      });
+    }
+
+    const forkSnapshot = new Map<string, DocumentState>();
+    for (const [docId, docState] of sourceBranch.documents) {
+      forkSnapshot.set(docId, {
+        content: deepClone(docState.content),
+        versions: docState.versions.map(v => ({
+          id: v.id,
+          timestamp: v.timestamp,
+          content: deepClone(v.content),
+        })),
+        deleted: docState.deleted,
+      });
+    }
+
+    this.branches.set(name, {
+      documents: clonedDocs,
+      parentBranch: sourceBranchName,
+      forkSnapshot,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceBranchData = this.getBranchData(sourceBranch);
+    const currentBranchData = this.getBranchData();
+
+    let base: Map<string, DocumentState>;
+
+    if (sourceBranchData.parentBranch === this.currentBranch && sourceBranchData.forkSnapshot) {
+      base = sourceBranchData.forkSnapshot;
+    } else if (currentBranchData.parentBranch === sourceBranch && currentBranchData.forkSnapshot) {
+      base = currentBranchData.forkSnapshot;
+    } else {
+      base = this.findCommonAncestor(this.currentBranch, sourceBranch);
+    }
+
+    const allDocIds = new Set<string>();
+    for (const id of base.keys()) allDocIds.add(id);
+    for (const id of currentBranchData.documents.keys()) allDocIds.add(id);
+    for (const id of sourceBranchData.documents.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseDoc = base.get(docId);
+      const oursDoc = currentBranchData.documents.get(docId);
+      const theirsDoc = sourceBranchData.documents.get(docId);
+
+      const baseContent = baseDoc && !baseDoc.deleted ? baseDoc.content : null;
+      const oursContent = oursDoc && !oursDoc.deleted ? oursDoc.content : null;
+      const theirsContent = theirsDoc && !theirsDoc.deleted ? theirsDoc.content : null;
+
+      if (valuesEqual(baseContent, oursContent) && valuesEqual(baseContent, theirsContent)) {
+        continue;
+      }
+
+      if (baseContent === null && oursContent === null && theirsContent !== null) {
+        merged[docId] = deepClone(theirsContent);
+        continue;
+      }
+
+      if (baseContent === null && oursContent !== null && theirsContent === null) {
+        continue;
+      }
+
+      if (baseContent === null && oursContent !== null && theirsContent !== null) {
+        const result = threeWayMergeDocument({}, oursContent, theirsContent, docId);
+        merged[docId] = result.merged;
+        allConflicts.push(...result.conflicts);
+        continue;
+      }
+
+      if (baseContent !== null && oursContent === null && theirsContent === null) {
+        continue;
+      }
+
+      if (baseContent !== null && oursContent === null && theirsContent !== null) {
+        if (!valuesEqual(baseContent, theirsContent)) {
+          allConflicts.push({
+            documentId: docId,
+            path: '',
+            base: deepClone(baseContent),
+            ours: null,
+            theirs: deepClone(theirsContent),
+          });
+        }
+        continue;
+      }
+
+      if (baseContent !== null && oursContent !== null && theirsContent === null) {
+        if (!valuesEqual(baseContent, oursContent)) {
+          allConflicts.push({
+            documentId: docId,
+            path: '',
+            base: deepClone(baseContent),
+            ours: deepClone(oursContent),
+            theirs: null,
+          });
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      const result = threeWayMergeDocument(baseContent!, oursContent!, theirsContent!, docId);
+      merged[docId] = result.merged;
+      allConflicts.push(...result.conflicts);
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      for (const [docId, content] of Object.entries(merged)) {
+        const existingDoc = currentBranchData.documents.get(docId);
+        if (existingDoc && !existingDoc.deleted) {
+          const version: Version = {
+            id: generateVersionId(),
+            timestamp: Date.now(),
+            content: deepClone(content),
+          };
+          existingDoc.content = deepClone(content);
+          existingDoc.versions.push(version);
+        } else {
+          const version: Version = {
+            id: generateVersionId(),
+            timestamp: Date.now(),
+            content: deepClone(content),
+          };
+          currentBranchData.documents.set(docId, {
+            content: deepClone(content),
+            versions: [version],
+            deleted: false,
+          });
+        }
+      }
+
+      // Handle deletions from source branch
+      for (const docId of allDocIds) {
+        const baseDoc = base.get(docId);
+        const theirsDoc = sourceBranchData.documents.get(docId);
+        const oursDoc = currentBranchData.documents.get(docId);
+        const baseContent = baseDoc && !baseDoc.deleted ? baseDoc.content : null;
+        const oursContent = oursDoc && !oursDoc.deleted ? oursDoc.content : null;
+        const theirsContent = theirsDoc && !theirsDoc.deleted ? theirsDoc.content : null;
+
+        if (baseContent !== null && theirsContent === null && oursContent !== null) {
+          if (valuesEqual(baseContent, oursContent)) {
+            oursDoc!.deleted = true;
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+
+  private findCommonAncestor(_branch1: string, branch2: string): Map<string, DocumentState> {
+    const getAncestors = (branchName: string): string[] => {
+      const ancestors: string[] = [branchName];
+      let current = this.branches.get(branchName);
+      while (current?.parentBranch) {
+        ancestors.push(current.parentBranch);
+        current = this.branches.get(current.parentBranch);
+      }
+      return ancestors;
+    };
+
+    const ancestors1 = getAncestors(_branch1);
+    const ancestors2 = getAncestors(branch2);
+
+    for (const a of ancestors1) {
+      if (ancestors2.includes(a)) {
+        const branch1Data = this.branches.get(_branch1)!;
+        const branch2Data = this.branches.get(branch2)!;
+
+        if (branch1Data.parentBranch && ancestors2.includes(branch1Data.parentBranch)) {
+          return branch1Data.forkSnapshot ?? new Map();
+        }
+        if (branch2Data.parentBranch && ancestors1.includes(branch2Data.parentBranch)) {
+          return branch2Data.forkSnapshot ?? new Map();
+        }
+
+        return new Map();
+      }
+    }
+
+    return new Map();
+  }
+}
