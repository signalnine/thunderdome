+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('CRUD operations', () => {
+    it('should create and get a document', () => {
+      store.create('doc1', { name: 'test' });
+      expect(store.get('doc1')).toEqual({ name: 'test' });
+    });
+
+    it('should throw when creating duplicate', () => {
+      store.create('doc1', { name: 'test' });
+      expect(() => store.create('doc1', { name: 'other' })).toThrow();
+    });
+
+    it('should throw when getting non-existent', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+
+    it('should update a document', () => {
+      store.create('doc1', { name: 'test' });
+      store.update('doc1', { name: 'updated' });
+      expect(store.get('doc1')).toEqual({ name: 'updated' });
+    });
+
+    it('should throw when updating non-existent', () => {
+      expect(() => store.update('nonexistent', { name: 'x' })).toThrow();
+    });
+
+    it('should delete a document', () => {
+      store.create('doc1', { name: 'test' });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should throw when deleting non-existent', () => {
+      expect(() => store.delete('nonexistent')).toThrow();
+    });
+
+    it('should deep clone on storage and retrieval', () => {
+      const content = { nested: { value: 1 } };
+      store.create('doc1', content);
+      content.nested.value = 999;
+      const retrieved = store.get('doc1') as { nested: { value: number } };
+      expect(retrieved.nested.value).toBe(1);
+      retrieved.nested.value = 888;
+      expect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);
+    });
+  });
+
+  describe('Version History', () => {
+    it('should track versions on create', () => {
+      store.create('doc1', { name: 'v1' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(1);
+      expect(history[0].content).toEqual({ name: 'v1' });
+    });
+
+    it('should track versions on update', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      store.update('doc1', { name: 'v3' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ name: 'v1' });
+      expect(history[1].content).toEqual({ name: 'v2' });
+      expect(history[2].content).toEqual({ name: 'v3' });
+    });
+
+    it('should get specific version', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      const history = store.getHistory('doc1');
+      const v1Content = store.getVersion('doc1', history[0].id);
+      expect(v1Content).toEqual({ name: 'v1' });
+    });
+
+    it('should have unique version ids', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(history[0].id).not.toBe(history[1].id);
+    });
+  });
+
+  describe('Branching', () => {
+    it('should default to main branch', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('should create and switch branches', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    it('should list branches', () => {
+      store.createBranch('feature');
+      expect(store.listBranches()).toContain('main');
+      expect(store.listBranches()).toContain('feature');
+    });
+
+    it('should isolate changes between branches', () => {
+      store.create('doc1', { name: 'main-version' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { name: 'feature-version' });
+      expect(store.get('doc1')).toEqual({ name: 'feature-version' });
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ name: 'main-version' });
+    });
+
+    it('should create branch from specific branch', () => {
+      store.create('doc1', { name: 'main-version' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { name: 'feature-version' });
+      store.createBranch('feature2', 'feature');
+      store.switchBranch('feature2');
+      expect(store.get('doc1')).toEqual({ name: 'feature-version' });
+    });
+  });
+
+  describe('Merging', () => {
+    it('should merge non-conflicting changes', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      // Change 'a' on main
+      store.update('doc1', { a: 10, b: 2 });
+
+      // Change 'b' on feature
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, b: 20 });
+
+      // Merge feature into main
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 20 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 20 });
+    });
+
+    it('should detect conflicts', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.update('doc1', { a: 2 });
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 3 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].documentId).toBe('doc1');
+      expect(result.conflicts[0].path).toBe('a');
+      expect(result.conflicts[0].base).toBe(1);
+      expect(result.conflicts[0].ours).toBe(2);
+      expect(result.conflicts[0].theirs).toBe(3);
+      // Branch should be unchanged
+      expect(store.get('doc1')).toEqual({ a: 2 });
+    });
+
+    it('should not conflict when both sides make the same change', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.update('doc1', { a: 42 });
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 42 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it('should merge new documents from source branch', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { name: 'new' });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ name: 'new' });
+    });
+
+    it('should handle deep nested merges', () => {
+      store.create('doc1', { a: { b: { c: 1, d: 2 } } });
+      store.createBranch('feature');
+
+      store.update('doc1', { a: { b: { c: 10, d: 2 } } });
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: { b: { c: 1, d: 20 } } });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: { b: { c: 10, d: 20 } } });
+      expect(store.get('doc1')).toEqual({ a: { b: { c: 10, d: 20 } } });
+    });
+
+    it('should handle multiple documents independently', () => {
+      store.create('doc1', { x: 1 });
+      store.create('doc2', { y: 1 });
+      store.createBranch('feature');
+
+      store.update('doc1', { x: 10 });
+
+      store.switchBranch('feature');
+      store.update('doc2', { y: 20 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ x: 10 });
+      expect(store.get('doc2')).toEqual({ y: 20 });
+    });
+
+    it('merged field shows ours for conflicts', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.update('doc1', { a: 10, b: 2 });
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 20, b: 2 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(false);
+      // merged should show ours for conflicts
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 2 });
+    });
+  });
+});
