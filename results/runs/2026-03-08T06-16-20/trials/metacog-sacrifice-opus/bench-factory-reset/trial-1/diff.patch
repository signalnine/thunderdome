en for each half B value, compute the full solution and compare.\n\n  // For mod=2, halfA=20 gives 2^20=1M, halfB=20 gives 2^20=1M, total 2M evaluations.\n  // For mod=3, halfA=14 gives 3^14~5M which is too many.\n  // For larger mods with many free vars, fall back to greedy.\n\n  let halfACombinations = 1;\n  let halfAFeasible = true;\n  for (let i = 0; i < halfA; i++) {\n    halfACombinations *= mod;\n    if (halfACombinations > 5_000_000) {\n      halfAFeasible = false;\n      break;\n    }\n  }\n\n  let halfBCombinations = 1;\n  let halfBFeasible = true;\n  for (let i = 0; i < halfB; i++) {\n    halfBCombinations *= mod;\n    if (halfBCombinations > 5_000_000) {\n      halfBFeasible = false;\n      break;\n    }\n  }\n\n  if (!halfAFeasible || !halfBFeasible) {\n    // Fall back to greedy: try each free variable independently\n    return greedySolve(sys, costFn, tieBreaker);\n  }\n\n  // Enumerate all half A values\n  const halfAValues: number[][] = [];\n  const genA = (idx: number, vals: number[]): void => {\n    if (idx === halfA) {\n      halfAValues.push(vals.slice());\n      return;\n    }\n    for (let v = 0; v < mod; v++) {\n      vals[idx] = v;\n      genA(idx + 1, vals);\n    }\n  };\n  genA(0, new Array(halfA).fill(0));\n\n  let bestSolution: number[] | null = null;\n  let bestCost = Infinity;\n\n  const freeValues = new Array(numFree).fill(0);\n\n  // For each half B combination\n  const processB = (idxB: number): void => {\n    if (idxB === halfB) {\n      // Try all half A combinations\n      for (const aVals of halfAValues) {\n        for (let i = 0; i < halfA; i++) {\n          freeValues[i] = aVals[i];\n        }\n        const sol = computeSolution(sys, freeValues);\n        const cost = costFn(sol);\n        if (cost < bestCost || (cost === bestCost && bestSolution !== null && tieBreaker(sol, bestSolution) < 0)) {\n          bestCost = cost;\n          bestSolution = sol.slice();\n        }\n      }\n      return;\n    }\n    for (let v = 0; v < mod; v++) {\n      freeValues[halfA + idxB] = v;\n      processB(idxB + 1);\n    }\n  };\n\n  processB(0);\n  return bestSolution!;\n}\n\nfunction greedySolve(\n  sys: ReducedSystem,\n  costFn: (sol: number[]) => number,\n  tieBreaker: Comparator\n): number[] {\n  const { mod, freeVars } = sys;\n  const numFree = freeVars.length;\n\n  // Try each free variable independently and pick the value that\n  // minimizes cost when other free vars are 0\n  const bestFreeValues = new Array(numFree).fill(0);\n\n  for (let i = 0; i < numFree; i++) {\n    let bestVal = 0;\n    let bestValCost = Infinity;\n    let bestValSol: number[] | null = null;\n\n    for (let v = 0; v < mod; v++) {\n      bestFreeValues[i] = v;\n      const sol = computeSolution(sys, bestFreeValues);\n      const cost = costFn(sol);\n      if (cost < bestValCost || (cost === bestValCost && bestValSol !== null && tieBreaker(sol, bestValSol) < 0)) {\n        bestValCost = cost;\n        bestVal = v;\n        bestValSol = sol.slice();\n      }\n    }\n    bestFreeValues[i] = bestVal;\n  }\n\n  return computeSolution(sys, bestFreeValues);\n}\n\nfunction toggleCost(sol: number[]): number {\n  let count = 0;\n  for (const v of sol) count += v;\n  return count;\n}\n\nfunction toggleTieBreaker(a: number[], b: number[]): number {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) {\n      return b[i] - a[i];\n    }\n  }\n  return 0;\n}\n\nfunction counterCost(sol: number[]): number {\n  let sum = 0;\n  for (const v of sol) sum += v;\n  return sum;\n}\n\nfunction counterTieBreaker(a: number[], b: number[]): number {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) return a[i] - b[i];\n  }\n  return 0;\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  const matrix: number[][] = [];\n  for (let light = 0; light < numLights; light++) {\n    const row = 