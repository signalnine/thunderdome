umber, m: number): number {\n  a = ((a % m) + m) % m;\n  let result = 1;\n  let base = a;\n  let exp = m - 2;\n  while (exp > 0) {\n    if (exp & 1) {\n      result = (result * base) % m;\n    }\n    base = (base * base) % m;\n    exp >>= 1;\n  }\n  return result;\n}\n\ninterface ReducedSystem {\n  mat: number[][];\n  numVars: number;\n  mod: number;\n  pivotCol: number[];\n  freeVars: number[];\n}\n\nfunction gaussianElimination(\n  matrix: number[][],\n  numVars: number,\n  mod: number\n): ReducedSystem | null {\n  const numRows = matrix.length;\n  const numCols = numVars + 1;\n  const mat = matrix.map(row => row.slice());\n\n  const pivotCol: number[] = [];\n  let currentRow = 0;\n\n  for (let col = 0; col < numVars && currentRow < numRows; col++) {\n    let pivotRow = -1;\n    for (let row = currentRow; row < numRows; row++) {\n      if (mat[row][col] !== 0) {\n        pivotRow = row;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    if (pivotRow !== currentRow) {\n      [mat[currentRow], mat[pivotRow]] = [mat[pivotRow], mat[currentRow]];\n    }\n\n    pivotCol.push(col);\n\n    const inv = modInverse(mat[currentRow][col], mod);\n    for (let j = 0; j < numCols; j++) {\n      mat[currentRow][j] = (mat[currentRow][j] * inv) % mod;\n    }\n\n    for (let row = 0; row < numRows; row++) {\n      if (row === currentRow) continue;\n      const factor = mat[row][col];\n      if (factor === 0) continue;\n      for (let j = 0; j < numCols; j++) {\n        mat[row][j] = ((mat[row][j] - factor * mat[currentRow][j]) % mod + mod) % mod;\n      }\n    }\n\n    currentRow++;\n  }\n\n  for (let row = currentRow; row < numRows; row++) {\n    if (mat[row][numVars] !== 0) {\n      return null;\n    }\n  }\n\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numVars; col++) {\n    if (!pivotColSet.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  return { mat, numVars, mod, pivotCol, freeVars };\n}\n