+      if (c > 10_000_000) { workFeasible = false; break; }
+    }
+    if (!workFeasible) break;
+    totalWork += c;
+    if (totalWork > 10_000_000) workFeasible = false;
+  }
+
+  let bestWeight = x0Weight;
+  let bestSol = x0.slice();
+
+  if (workFeasible) {
+    // Enumerate button subsets by weight
+    for (let w = 0; w < bestWeight; w++) {
+      const indices = new Array(w);
+      let found = false;
+
+      const enumerate = (pos: number, start: number, curLo: number, curHi: number): void => {
+        if (pos === w) {
+          if (curLo === targetLo && curHi === targetHi) {
+            found = true;
+            const sol = new Array(numButtons).fill(0);
+            for (let p = 0; p < w; p++) sol[indices[p]] = 1;
+            if (w < bestWeight || toggleTieBreaker(sol, bestSol) < 0) {
+              bestWeight = w;
+              bestSol = sol;
+            }
+          }
+          return;
+        }
+        for (let btn = start; btn < numButtons; btn++) {
+          indices[pos] = btn;
+          enumerate(pos + 1, btn + 1, curLo ^ btnLo[btn], curHi ^ btnHi[btn]);
+        }
+      };
+
+      enumerate(0, 0, 0, 0);
+      if (found) break;
+    }
+  } else {
+    // MITM fallback
+    const nullBasis: number[][] = [];
+    for (let j = 0; j < numFree; j++) {
+      const fv = new Array(numFree).fill(0);
+      fv[j] = 1;
+      const nj = computeSolution(sys, fv);
+      for (let k = 0; k < numVars; k++) nj[k] ^= x0[k];
+      nullBasis.push(nj);
+    }
+
+    const halfL = Math.floor(numFree / 2);
+    const rightCount = 1 << (numFree - halfL);
+    const leftCount = 1 << halfL;
+
+    const packLo = (v: number[]): number => {
+      let lo = 0;
+      for (let k = 0; k < Math.min(numVars, 32); k++) if (v[k]) lo |= 1 << k;
+      return lo;
+    };
+    const packHi = (v: number[]): number => {
+      let hi = 0;
+      for (let k = 32; k < numVars; k++) if (v[k]) hi |= 1 << (k - 32);
+      return hi;
+    };
+
+    const basisLo = nullBasis.map(packLo);
+    const basisHi = nullBasis.map(packHi);
+    const x0Lo = packLo(x0);
+    const x0Hi = packHi(x0);
+
+    // Build left table
+    const leftVecLo = new Int32Array(leftCount);
+    const leftVecHi = new Int32Array(leftCount);
+    for (let mask = 0; mask < leftCount; mask++) {
+      let lo = x0Lo, hi = x0Hi, m = mask, idx = 0;
+      while (m > 0) {
+        if (m & 1) { lo ^= basisLo[idx]; hi ^= basisHi[idx]; }
+        m >>= 1; idx++;
+      }
+      leftVecLo[mask] = lo;
+      leftVecHi[mask] = hi;
+    }
+
+    // Build nested map for lookup: hi -> lo -> leftMask[]
+    const leftMap = new Map<number, Map<number, boolean>>();
+    for (let mask = 0; mask < leftCount; mask++) {
+      const lo = leftVecLo[mask];
+      const hi = leftVecHi[mask];
+      let inner = leftMap.get(hi);
+      if (!inner) { inner = new Map(); leftMap.set(hi, inner); }
+      inner.set(lo, true);
+    }
+
+    const hasLeft = (lo: number, hi: number): boolean => {
+      const inner = leftMap.get(hi);
+      return inner ? inner.has(lo) : false;
+    };
+
+    // For each right combo, search for nearest left vector
+    for (let rmask = 0; rmask < rightCount; rmask++) {
+      let rLo = 0, rHi = 0, m = rmask, idx = halfL;
+      while (m > 0) {
+        if (m & 1) { rLo ^= basisLo[idx]; rHi ^= basisHi[idx]; }
+        m >>= 1; idx++;
+      }
+
+      for (let d = 0; d < bestWeight && d <= numVars; d++) {
+        let found = false;
+        const positions = new Array(d);
+
+        const search = (pidx: number, start: number): void => {
+          if (pidx === d) {
+            let cLo = rLo, cHi = rHi;
+            for (let p = 0; p < d; p++) {
+              const pos = positions[p];
+              if (pos < 32) cLo ^= 1 << pos; else cHi ^= 1 << (pos - 32);
+            }
+            if (hasLeft(cLo, cHi)) {
+              found = true;
+              const solLo = cLo ^ rLo, solHi = cHi ^ rHi;
+              const sol = new Array(numVars);
+              for (let k = 0; k < Math.min(numVars, 32); k++) sol[k] = (solLo >>> k) & 1;
+              for (let k = 32; k < numVars; k++) sol[k] = (solHi >>> (k - 32)) & 1;
+              if (d < bestWeight || toggleTieBreaker(sol, bestSol) < 0) {
+                bestWeight = d;
+                bestSol = sol;
+              }
+            }
+            return;
+          }
+          for (let pos = start; pos < numVars; pos++) {
+            positions[pidx] = pos;
+            search(pidx + 1, pos + 1);
+          }
+        };
+
+        search(0, 0);
+        if (found) break;
+      }
+      if (bestWeight === 0) break;
+    }
+  }
+
+  return bestSol;
+};
+
+const counterCost = (sol: number[]): number => {
+  let sum = 0;
+  for (const v of sol) sum += v;
+  return sum;
+};
+
+const counterTieBreaker = (a: number[], b: number[]): number => {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return 0;
+};
+
+const solveCounterSystem = (sys: ReducedSystem): number[] => {
+  const { mod, freeVars } = sys;
+  const numFree = freeVars.length;
+
+  if (numFree === 0) return computeSolution(sys, []);
+
+  let totalCombinations = 1;
+  let feasible = true;
+  for (let i = 0; i < numFree; i++) {
+    totalCombinations *= mod;
+    if (totalCombinations > 5_000_000) { feasible = false; break; }
+  }
+
+  if (feasible) {
+    let bestSolution: number[] | null = null;
+    let bestCost = Infinity;
+    const freeValues = new Array(numFree).fill(0);
+
+    const enumerate = (idx: number): void => {
+      if (idx === numFree) {
+        const sol = computeSolution(sys, freeValues);
+        const cost = counterCost(sol);
+        if (cost < bestCost || (cost === bestCost && bestSolution !== null && counterTieBreaker(sol, bestSolution) < 0)) {
+          bestCost = cost;
+          bestSolution = sol.slice();
+        }
+        return;
+      }
+      for (let v = 0; v < mod; v++) {
+        freeValues[idx] = v;
+        enumerate(idx + 1);
+      }
+    };
+
+    enumerate(0);
+    return bestSolution!;
+  }
+
+  return greedyCounterSolve(sys);
+};
+
+const greedyCounterSolve = (sys: ReducedSystem): number[] => {
+  const { mod, freeVars } = sys;
+  const numFree = freeVars.length;
+  const bestFreeValues = new Array(numFree).fill(0);
+  let prevCost = Infinity;
+
+  for (let iter = 0; iter < 5; iter++) {
+    let changed = false;
+    for (let fIdx = 0; fIdx < numFree; fIdx++) {
+      let bestVal = bestFreeValues[fIdx];
+      let bestValCost = Infinity;
+      let bestValSol: number[] | null = null;
+
+      for (let v = 0; v < mod; v++) {
+        bestFreeValues[fIdx] = v;
+        const sol = computeSolution(sys, bestFreeValues);
+        const cost = counterCost(sol);
+        if (cost < bestValCost || (cost === bestValCost && bestValSol !== null && counterTieBreaker(sol, bestValSol) < 0)) {
+          bestValCost = cost;
+          bestVal = v;
+          bestValSol = sol.slice();
+        }
+      }
+      if (bestVal !== bestFreeValues[fIdx]) changed = true;
+      bestFreeValues[fIdx] = bestVal;
+    }
+
+    const cost = counterCost(computeSolution(sys, bestFreeValues));
+    if (!changed || cost >= prevCost) break;
+    prevCost = cost;
+  }
+
+  return computeSolution(sys, bestFreeValues);
+};
+
+export const solveToggle = (machine: Machine): number[] | null => {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  const matrix: number[][] = [];
+  for (let light = 0; light < numLights; light++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = target[light] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  for (let btn = 0; btn < numButtons; btn++) {
+    for (const light of buttons[btn]) {
+      matrix[light][btn] = 1;
+    }
+  }
+
+  const sys = gaussianElimination(matrix, numButtons, 2);
+  if (sys === null) return null;
+
+  const solution = solveToggleSystem(sys, target, buttons);
+  const pressed: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (solution[i] === 1) pressed.push(i);
+  }
+  return pressed;
+};
+
+export const solveCounter = (
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null => {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  const matrix: number[][] = [];
+  for (let counter = 0; counter < numCounters; counter++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = lights[counter] % modulus;
+    matrix.push(row);
+  }
+
+  for (let btn = 0; btn < numButtons; btn++) {
+    for (const counter of buttons[btn]) {
+      matrix[counter][btn] = 1;
+    }
+  }
+
+  const sys = gaussianElimination(matrix, numButtons, modulus);
+  if (sys === null) return null;
+
+  return solveCounterSystem(sys);
+};
