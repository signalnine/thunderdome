+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+const modInverse = (a: number, m: number): number => {
+  a = ((a % m) + m) % m;
+  let result = 1;
+  let base = a;
+  let exp = m - 2;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % m;
+    base = (base * base) % m;
+    exp >>= 1;
+  }
+  return result;
+};
+
+interface ReducedSystem {
+  mat: number[][];
+  numVars: number;
+  mod: number;
+  pivotCol: number[];
+  freeVars: number[];
+}
+
+const gaussianElimination = (
+  matrix: number[][],
+  numVars: number,
+  mod: number
+): ReducedSystem | null => {
+  const numRows = matrix.length;
+  const numCols = numVars + 1;
+  const mat = matrix.map(row => row.slice());
+  const pivotCol: number[] = [];
+  let currentRow = 0;
+
+  for (let col = 0; col < numVars && currentRow < numRows; col++) {
+    let pivotRow = -1;
+    for (let row = currentRow; row < numRows; row++) {
+      if (mat[row][col] !== 0) { pivotRow = row; break; }
+    }
+    if (pivotRow === -1) continue;
+
+    if (pivotRow !== currentRow)
+      [mat[currentRow], mat[pivotRow]] = [mat[pivotRow], mat[currentRow]];
+
+    pivotCol.push(col);
+
+    const inv = modInverse(mat[currentRow][col], mod);
+    for (let j = 0; j < numCols; j++)
+      mat[currentRow][j] = (mat[currentRow][j] * inv) % mod;
+
+    for (let row = 0; row < numRows; row++) {
+      if (row === currentRow) continue;
+      const factor = mat[row][col];
+      if (factor === 0) continue;
+      for (let j = 0; j < numCols; j++)
+        mat[row][j] = ((mat[row][j] - factor * mat[currentRow][j]) % mod + mod) % mod;
+    }
+    currentRow++;
+  }
+
+  for (let row = currentRow; row < numRows; row++) {
+    if (mat[row][numVars] !== 0) return null;
+  }
+
+  const pivotColSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numVars; col++) {
+    if (!pivotColSet.has(col)) freeVars.push(col);
+  }
+
+  return { mat, numVars, mod, pivotCol, freeVars };
+};
+
+const computeSolution = (sys: ReducedSystem, freeValues: number[]): number[] => {
+  const { mat, numVars, mod, pivotCol, freeVars } = sys;
+  const sol = new Array(numVars).fill(0);
+  for (let i = 0; i < freeVars.length; i++) sol[freeVars[i]] = freeValues[i];
+  for (let i = pivotCol.length - 1; i >= 0; i--) {
+    const pc = pivotCol[i];
+    let val = mat[i][numVars];
+    for (let j = 0; j < numVars; j++) {
+      if (j === pc) continue;
+      val = ((val - mat[i][j] * sol[j]) % mod + mod) % mod;
+    }
+    sol[pc] = val % mod;
+  }
+  return sol;
+};
+
