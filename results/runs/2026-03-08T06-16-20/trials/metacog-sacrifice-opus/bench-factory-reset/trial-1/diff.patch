   363→  // For each right assignment\n   364→  for (let rA = 0; rA < rightCount; rA++) {\n   365→    const rBig = BigInt(rA);\n   366→    // Compute right parity vector\n   367→    let rightParity = 0n;\n   368→    for (let k = 0; k < numVars; k++) {\n   369→      const p = popcount(rightMasksHigh[k] & rBig) & 1;\n   370→      if (p) rightParity |= 1n << BigInt(k);\n   371→    }\n   372→\n   373→    // Try to find leftPartial at Hamming distance <= bestWeight from rightParity\n   374→    // full = leftPartial XOR rightParity, weight = popcount(full)\n   375→    // We want weight to be minimum.\n   376→\n   377→    // Enumerate neighbors of rightParity at increasing distances\n   378→    // until we exceed bestWeight.\n   379→\n   380→    // For distance d, there are C(numVars, d) neighbors.\n   381→    // Check each neighbor against leftPartialSet.\n   382→\n   383→    // Start with distance 0\n   384→    for (let d = 0; d <= bestWeight && d <= numVars; d++) {\n   385→      // Generate all numVars-bit vectors at Hamming distance d from rightParity\n   386→      // and check if they're in leftPartialSet.\n   387→      const found = findAtDistance(rightParity, d, numVarsBig, leftPartialMap);\n   388→      if (found.length > 0) {\n   389→        // Weight is d for all these\n   390→        for (const { leftAssignment, full } of found) {\n   391→          const sol = bigintToSolution(full, numVars);\n   392→          if (d < bestWeight || (bestSol !== null && toggleTieBreaker(sol, bestSol) < 0)) {\n   393→            bestWeight = d;\n   394→            bestSol = sol;\n   395→          }\n   396→        }\n   397→        if (d < bestWeight) {\n   398→          bestWeight = d;\n   399→        }\n   400→        break; // Found solutions at distance d, no need to check larger distances\n   401→      }\n   402→    }\n   403→  }\n   404→\n   405→  return bestSol!;\n   406→}\n   407→\n   408→function bigintToSolution(v: bigint, n: number): number[] {\n   409→  const sol = new Array(n);\n   410→  for (let i = 0; i < n; i++) {\n   411→    sol[i] = Number((v >> BigInt(i)) & 1n);\n   412→  }\n   413→  return sol;\n   414→}\n   415→\n   416→interface FoundResult {\n   417→  leftAssignment: number;\n   418→  full: bigint;\n   419→}\n   420→\n   421→function findAtDistance(\n   422→  target: bigint,\n   423→  distance: number,\n   424→  numBits: bigint,\n   425→  leftPartialMap: Map<bigint, number[]>\n   426→): FoundResult[] {\n   427→  const results: FoundResult[] = [];\n   428→  const n = Number(numBits);\n   429→\n   430→  // Generate all n-bit vectors at Hamming distance `distance` from `target`\n   431→  // by flipping `distance` bits.\n   432→  // For d=0: just check target itself\n   433→  // For d=1: flip each of n bits\n   434→  // For d=2: flip each pair of bits\n   435→  // etc.\n   436→\n   437→  // Use recursive combination generator\n   438→  const flipPositions: number[] = new Array(distance);\n   439→\n   440→  const generate = (idx: number, start: number): void => {\n   441→    if (idx === distance) {\n   442→      let candidate = target;\n   443→      for (let i = 0; i < distance; i++) {\n   444→        candidate ^= 1n << BigInt(flipPositions[i]);\n   445→      }\n   446→      const assignments = leftPartialMap.get(candidate);\n   447→      if (assignments) {\n   448→        // full = candidate XOR target... no wait.\n   449→        // leftPartial XOR rightParity = full.\n   450→        // candidate = leftPartial, target = rightParity.\n   451→        // full = candidate XOR target.\n   452→        const full = candidate ^ target;\n   453→        for (const la of assignments) {\n   454→          results.push({ leftAssignment: la, full });\n   455→        }\n   456→      }\n   457→      return;\n   458→    }\n   459→    for (let pos = start; pos < n; pos++) {\n   460→      flipPositions[idx] = pos;\n   461→      generate(idx + 1, pos + 1);\n   462→    }\n   463→  };\n   464→\n   465→  generate(0, 0);\n   466→  return results;\n   467→}\n   468→\n   469→function solveGFpOptimized(\n   470→  sys: ReducedSystem,\n   471→  costFn: (sol: number[]) => number,\n   472→  tieBreaker: Comparator\n   473→): number[] {\n   474→  const { mod, freeVars } = sys;\n   475→  const numFree = freeVars.length;\n   476→\n   477→  if (numFree === 0) {\n   478→    return computeSolution(sys, []);\n   479→  }\n   480→\n   481→  let totalCombinations = 1;\n   482→  let feasible = true;\n   483→  for (let i = 0; i < numFree; i++) {\n   484→    totalCombinations *= mod;\n   485→    if (totalCombinations > 5_000_000) {\n   486→      feasible = false;\n   487→      break;\n   488→    }\n   489→  }\n   490→\n   491→  if (feasible) {\n   492→    let bestSolution: number[] | null = null;\n   493→    let bestCost = Infinity;\n   494→    const freeValues = new Array(numFree).fill(0);\n   495→\n   496→    const enumerate = (idx: number): void => {\n   497→      if (idx === numFree) {\n   498→        const sol = computeSolution(sys, freeValues);\n   499→        const cost = costFn(sol);\n   500→        if (cost < bestCost || (cost === bestCost && bestSolution !== null && tieBreaker(sol, bestSolution) < 0)) {\n   501→          bestCost = cost;\n   502→          bestSolution = sol.slice();\n   503→        }\n   504→        return;\n   505→      }\n   506→      for (let v = 0; v < mod; v++) {\n   507→        freeValues[idx] = v;\n   508→        enumerate(idx + 1);\n   509→      }\n   510→    };\n   511→\n   512→    enumerate(0);\n   513→    return bestSolution!;\n   514→  }\n   515→\n   516→  // For large mod with many free vars: use variable-by-variable optimization.\n   517→  // For each variable position (left to right), try all possible values and\n   518→  // pick the smallest value that's achievable with minimum total cost.\n   519→  return optimizeByVariable(sys, costFn, tieBreaker);\n   520→}\n   521→\n   522→function optimizeByVariable(\n   523→  sys: ReducedSystem,\n   524→  costFn: (sol: number[]) => number,\n   525→  tieBreaker: Comparator\n   526→): number[] {\n   527→  const { mat, numVars, mod, pivotCol, freeVars } = sys;\n   528→  const numFree = freeVars.length;\n   529→\n   530→  // Build dependency info: for each variable, express it as a linear function of free vars\n   531→  // x_k = const_k + sum_j coeff_k_j * f_j (mod p)\n   532→  const varConst = new Array(numVars).fill(0);\n   533→  const varCoeffs: number[][] = new Array(numVars);\n   534→  for (let k = 0; k < numVars; k++) {\n   535→    varCoeffs[k] = new Array(numFree).fill(0);\n   536→  }\n   537→\n   538→  // Free variables: x_{freeVars[j]} = f_j\n   539→  for (let j = 0; j < numFree; j++) {\n   540→    varConst[freeVars[j]] = 0;\n   541→    varCoeffs[freeVars[j]][j] = 1;\n   542→  }\n   543→\n   544→  // Pivot variables: x_{pivotCol[i]} = mat[i][numVars] - sum_j mat[i][freeVars[j]] * f_j\n   545→  for (let i = 0; i < pivotCol.length; i++) {\n   546→    const pc = pivotCol[i];\n   547→    varConst[pc] = mat[i][numVars];\n   548→    for (let j = 0; j < numFree; j++) {\n   549→      varCoeffs[pc][j] = (mod - mat[i][freeVars[j]]) % mod;\n   550→    }\n   551→  }\n   552→\n   553→  // Greedy: for each free variable in order, try all values and pick the one\n   554→  // that leads to the best outcome. But we process variables in output order\n   555→  // (0, 1, 2, ..., numVars-1) to optimize lex ordering.\n   556→  //\n   557→  // We need to find which free variables affect which output variables.\n   558→  // Then determine free variable values that minimize cost and give lex-smallest output.\n   559→  //\n   560→  // Multi-pass greedy: iterate through free variables multiple times,\n   561→  // each time trying all values and picking the best one considering current state.\n   562→\n   563→  // Actually, let's try a smarter greedy that respects the output ordering.\n   564→  // Process output variables left to right. For each output variable x_k:\n   565→  //   - If x_k is a free variable f_j: try all values 0..mod-1 for f_j.\n   566→  //     For each value, compute the resulting min possible total cost\n   567→  //     (fixing this and all previously fixed free vars, optimizing remaining free vars).\n   568→  //     Pick the value that: (1) allows minimum total cost, (2) among those, gives smallest x_k.\n   569→  //   - If x_k is a pivot variable: its value is determined by already-set and remaining free vars.\n   570→  //     No choice to make directly.\n   571→\n   572→  // The problem with this approach: computing \"min possible total cost with remaining free vars\"\n   573→  // requires solving a sub-problem for each candidate value, which may be expensive.\n   574→\n   575→  // Simpler approach: just use the coordinate-descent greedy.\n   576→  // Process free variables in order, for each try all values, pick best.\n   577→  // Repeat until convergence.\n   578→\n   579→  const bestFreeValues = new Array(numFree).fill(0);\n   580→\n   581→  // Initialize with all zeros\n   582→  let prevCost = Infinity;\n   583→  let prevSol: number[] | null = null;\n   584→\n   585→  for (let iter = 0; iter < 3; iter++) {\n   586→    for (let fIdx = 0; fIdx < numFree; fIdx++) {\n   587→      let bestVal = 0;\n   588→      let bestValCost = Infinity;\n   589→      let bestValSol: number[] | null = null;\n   590→\n   591→      for (let v = 0; v < mod; v++) {\n   592→        bestFreeValues[fIdx] = v;\n   593→        const sol = computeSolution(sys, bestFreeValues);\n   594→        const cost = costFn(sol);\n   595→        if (cost < bestValCost || (cost === bestValCost && bestValSol !== null && tieBreaker(sol, bestValSol) < 0)) {\n   596→          bestValCost = cost;\n   597→          bestVal = v;\n   598→          bestValSol = sol.slice();\n   599→        }\n   600→      }\n   601→      bestFreeValues[fIdx] = bestVal;\n   602→    }\n   603→\n   604→    const sol = computeSolution(sys, bestFreeValues);\n   605→    const cost = costFn(sol);\n   606→    if (prevSol !== null && cost === prevCost && tieBreaker(sol, prevSol) >= 0) {\n   607→      break; // Converged\n   608→    }\n   609→    prevCost = cost;\n   610→    prevSol = sol.slice();\n   611→  }\n   612→\n   613→  return computeSolution(sys, bestFreeValues);\n   614→}\n   615→\n   616→function toggleTieBreaker(a: number[], b: number[]): number {\n   617→  for (let i = 0; i < a.length; i++) {\n   618→    if (a[i] !== b[i]) {\n   619→      return b[i] - a[i];\n   620→    }\n   621→  }\n   622→  return 0;\n   623→}\n   624→\n   625→function counterCost(sol: number[]): number {\n   626→  let sum = 0;\n   627→  for (const v of sol) sum += v;\n   628→  return sum;\n   629→}\n   630→\n   631→function counterTieBreaker(a: number[], b: number[]): number {\n   632→  for (let i = 0; i < a.length; i++) {\n   633→    if (a[i] !== b[i]) return a[i] - b[i];\n   634→  }\n   635→  return 0;\n   636→}\n   637→\n   638→export function solveToggle(machine: Machine): number[] | null {\n   639→  const { target, buttons } = machine;\n   640→  const numLights = target.length;\n   641→  const numButtons = buttons.length;\n   642→\n   643→  const matrix: number[][] = [];\n   644→  for (let light = 0; light < numLights; light++) {\n   645→    const row = new Array(numButtons + 1).fill(0);\n   646→    row[numButtons] = target[light] ? 1 : 0;\n   647→    matrix.push(row);\n   648→  }\n   649→\n   650→  for (let btn = 0; btn < numButtons; btn++) {\n   651→    for (const light of buttons[btn]) {\n   652→      matrix[light][btn] = 1;\n   653→    }\n   654→  }\n   655→\n   656→  const sys = gaussianElimination(matrix, numButtons, 2);\n   657→  if (sys === null) return null;\n   658→\n   659→  const solution = solveToggleOptimized(sys);\n   660→\n   661→  const pressed: number[] = [];\n   662→  for (let i = 0; i < numButtons; i++) {\n   663→    if (solution[i] === 1) {\n   664→      pressed.push(i);\n   665→    }\n   666→  }\n   667→\n   668→  return pressed;\n   669→}\n   670→\n   671→export function solveCounter(\n   672→ 