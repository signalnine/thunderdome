\n  for (let i = 0; i < freeVars.length; i++) {\n    sol[freeVars[i]] = freeValues[i];\n  }\n  for (let i = pivotCol.length - 1; i >= 0; i--) {\n    const pc = pivotCol[i];\n    let val = mat[i][numVars];\n    for (let j = 0; j < numVars; j++) {\n      if (j === pc) continue;\n      val = ((val - mat[i][j] * sol[j]) % mod + mod) % mod;\n    }\n    sol[pc] = val % mod;\n  }\n  return sol;\n}\n\nfunction solveWithEnumeration(\n  sys: ReducedSystem,\n  costFn: (sol: number[]) => number,\n  tieBreaker: Comparator\n): number[] {\n  const { mod, freeVars } = sys;\n  const numFree = freeVars.length;\n\n  if (numFree === 0) {\n    return computeSolution(sys, []);\n  }\n\n  let totalCombinations = 1;\n  let feasible = true;\n  for (let i = 0; i < numFree; i++) {\n    totalCombinations *= mod;\n    if (totalCombinations > 5_000_000) {\n      feasible = false;\n      break;\n    }\n  }\n\n  if (feasible) {\n    let bestSolution: number[] | null = null;\n    let bestCost = Infinity;\n    const freeValues = new Array(numFree).fill(0);\n\n    const enumerate = (idx: number): void => {\n      if (idx === numFree) {\n        const sol = computeSolution(sys, freeValues);\n        const cost = costFn(sol);\n        if (cost < bestCost || (cost === bestCost && bestSolution !== null && tieBreaker(sol, bestSolution) < 0)) {\n          bestCost = cost;\n          bestSolution = sol.slice();\n        }\n        return;\n      }\n      for (let v = 0; v < mod; v++) {\n        freeValues[idx] = v;\n        enumerate(idx + 1);\n      }\n    };\n\n    enumerate(0);\n    return bestSolution!;\n  }\n\n  // Meet-in-the-middle for large search spaces\n  return meetInTheMiddle(sys, costFn, tieBreaker);\n}\n\nfunction meetInTheMiddle(\n  sys: ReducedSystem,\n  costFn: (sol: number[]) => number,\n  tieBreaker: Comparator\n): number[] {\n  const { mat, numVars, mod, pivotCol, freeVars } = sys;\n  const numFree = freeVars.length;\n\n  // For each pivot variable, compute its linear expression in terms of free variables:\n  // pivotVar_i = const_i + sum_j(coeff_i_j * freeVar_j) (mod)\n  // where coeff_i_j = -mat[row_i][freeVars[j]] mod m, const_i = mat[row_i][numVars]\n\n  // Build coefficient matrix: pivotCoeffs[pivotIdx][freeIdx]\n  const pivotConst: number[] = [];\n  const pivotCoeffs: number[][] = [];\n  for (let i = 0; i < pivotCol.length; i++) {\n    pivotConst.push(mat[i][numVars]);\n    const coeffs: number[] = [];\n    for (let j = 0; j < numFree; j++) {\n      coeffs.push((mod - mat[i][freeVars[j]]) % mod);\n    }\n    pivotCoeffs.push(coeffs);\n  }\n\n  // Split free variables into two halves\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n\n  // For half A, enumerate all mod^halfA combinations\n  // For each, compute partial contribution to all variables\n  // Store in a map keyed by the \"residual\" needed from half B\n\n  // Actually for meet-in-the-middle with optimization, it's complex.\n  // Let's use a simpler approach: enumerate half A, for each compute partial solution,\n  // then enumerate half B and combine.\n\n  // Since we're looking for minimum cost with lex tie-breaking,\n  // and costs are additive (sum), we can use meet-in-the-middle properly.\n\n  // But the solution values depend on both halves in a complex way (through pivot variables).\n  // Let's just enumerate half A (up to mod^20 = manageable for mod=2 or small mods),\n  // store results, then for each half B value, compute the full solution and compare.\n\n  // For mod=2, halfA=20 gives 2^20=1M, halfB=20 gives 2^20=1M, total 2M evaluations.\n  // For mod=3, halfA=14 gives 3^14~5M which is too many.\n  // For larger mods with many free vars, fall back to greedy.\n\n  let halfACombinations = 1;\n  let halfAFeasible = true;\n  for (let i = 0; i < halfA; i++) {\n    halfACombinations *= mod;\n    if (halfACombinations > 5_000_000) {\n      halfAFeasible = false;\n      break;\n    }\n  }\n\n  let halfBCombinations = 1;\n  let halfBFeasible = true;\n  for