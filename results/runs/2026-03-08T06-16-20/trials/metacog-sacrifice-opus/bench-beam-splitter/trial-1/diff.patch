+type Direction = 'down' | 'down-left' | 'down-right';
+
+function nextPos(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') {
+      return [0, col];
+    }
+  }
+  return null;
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+function collectCellsAlongBeam(
+  grid: string[][],
+  startRow: number,
+  startCol: number,
+  dir: Direction,
+  visited: Set<string>
+): [number, number] | null {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  let row = startRow;
+  let col = startCol;
+
+  while (inBounds(row, col, rows, cols)) {
+    visited.add(`${row},${col}`);
+    if (grid[row][col] === '^') {
+      return [row, col];
+    }
+    [row, col] = nextPos(row, col, dir);
+  }
+
+  return null;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const visited = new Set<string>();
+
+  visited.add(`${source[0]},${source[1]}`);
+
+  // Track which splitters have been processed to avoid redundant work
+  const processedSplitters = new Set<string>();
+
+  // Queue of beam segments to trace: (startRow, startCol, direction)
+  const queue: [number, number, Direction][] = [];
+
+  const [nextR, nextC] = nextPos(source[0], source[1], 'down');
+  if (inBounds(nextR, nextC, rows, cols)) {
+    queue.push([nextR, nextC, 'down']);
+  }
+
+  while (queue.length > 0) {
+    const [sr, sc, dir] = queue.pop()!;
+    const hitSplitter = collectCellsAlongBeam(grid, sr, sc, dir, visited);
+
+    if (hitSplitter) {
+      const key = `${hitSplitter[0]},${hitSplitter[1]}`;
+      if (!processedSplitters.has(key)) {
+        processedSplitters.add(key);
+        const [lr, lc] = nextPos(hitSplitter[0], hitSplitter[1], 'down-left');
+        const [rr, rc] = nextPos(hitSplitter[0], hitSplitter[1], 'down-right');
+        if (inBounds(lr, lc, rows, cols)) {
+          queue.push([lr, lc, 'down-left']);
+        }
+        if (inBounds(rr, rc, rows, cols)) {
+          queue.push([rr, rc, 'down-right']);
+        }
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+function traceToSplitterOrExit(
+  grid: string[][],
+  startRow: number,
+  startCol: number,
+  dir: Direction
+): [number, number] | null {
+  // Trace from (startRow, startCol) in direction dir.
+  // The starting cell itself could be a splitter if we're starting from a splitter output.
+  // But we call this with the NEXT position after a splitter, so the start cell is not a splitter
+  // (unless two splitters are adjacent diagonally).
+  const rows = grid.length;
+  const cols = grid[0].length;
+  let row = startRow;
+  let col = startCol;
+
+  while (inBounds(row, col, rows, cols)) {
+    if (grid[row][col] === '^') {
+      return [row, col];
+    }
+    [row, col] = nextPos(row, col, dir);
+  }
+
+  return null; // Exited grid
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  // Memoize: for each splitter position, how many paths emerge from it?
+  const memo = new Map<string, bigint>();
+
+  function pathsFromSplitter(row: number, col: number): bigint {
+    const key = `${row},${col}`;
+    if (memo.has(key)) return memo.get(key)!;
+
+    // To avoid infinite recursion during computation (shouldn't happen since DAG),
+    // set a sentinel
+    memo.set(key, 0n);
+
+    let total = 0n;
+
+    // Left beam: down-left
+    const [lr, lc] = nextPos(row, col, 'down-left');
+    if (inBounds(lr, lc, rows, cols)) {
+      const leftTarget = traceToSplitterOrExit(grid, lr, lc, 'down-left');
+      if (leftTarget) {
+        total += pathsFromSplitter(leftTarget[0], leftTarget[1]);
+      } else {
+        total += 1n; // Beam exits grid = 1 path
+      }
+    } else {
+      total += 1n; // Beam immediately exits = 1 path
+    }
+
+    // Right beam: down-right
+    const [rr, rc] = nextPos(row, col, 'down-right');
+    if (inBounds(rr, rc, rows, cols)) {
+      const rightTarget = traceToSplitterOrExit(grid, rr, rc, 'down-right');
+      if (rightTarget) {
+        total += pathsFromSplitter(rightTarget[0], rightTarget[1]);
+      } else {
+        total += 1n; // Beam exits grid = 1 path
+      }
+    } else {
+      total += 1n; // Beam immediately exits = 1 path
+    }
+
+    memo.set(key, total);
+    return total;
+  }
+
+  // Trace the initial beam from source downward
+  const [nextR, nextC] = nextPos(source[0], source[1], 'down');
+  if (!inBounds(nextR, nextC, rows, cols)) {
+    // Source is on the last row, beam exits immediately
+    return 1n;
+  }
+
+  const firstTarget = traceToSplitterOrExit(grid, nextR, nextC, 'down');
+  if (firstTarget) {
+    return pathsFromSplitter(firstTarget[0], firstTarget[1]);
+  } else {
+    return 1n; // Beam passes through without hitting any splitter
+  }
+}
