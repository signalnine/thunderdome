diff --git a/src/__tests__/evaluator.test.ts b/src/__tests__/evaluator.test.ts
new file mode 100644
index 0000000..9fc2b89
--- /dev/null
+++ b/src/__tests__/evaluator.test.ts
@@ -0,0 +1,125 @@
+import { describe, it, expect } from 'vitest';
+import { evaluate } from '../evaluator.js';
+import { parse } from '../parser.js';
+import type { CellValue } from '../types.js';
+
+function eval_(formula: string, cells: Record<string, CellValue> = {}): CellValue {
+  const ast = parse(formula);
+  return evaluate(ast, (ref) => cells[ref] ?? null);
+}
+
+describe('Evaluator', () => {
+  describe('literals', () => {
+    it('evaluates numbers', () => {
+      expect(eval_('42')).toBe(42);
+    });
+
+    it('evaluates decimal numbers', () => {
+      expect(eval_('3.14')).toBe(3.14);
+    });
+
+    it('evaluates strings', () => {
+      expect(eval_('"hello"')).toBe('hello');
+    });
+
+    it('evaluates true', () => {
+      expect(eval_('true')).toBe(true);
+    });
+
+    it('evaluates false', () => {
+      expect(eval_('false')).toBe(false);
+    });
+  });
+
+  describe('arithmetic', () => {
+    it('adds', () => expect(eval_('2+3')).toBe(5));
+    it('subtracts', () => expect(eval_('10-4')).toBe(6));
+    it('multiplies', () => expect(eval_('3*4')).toBe(12));
+    it('divides', () => expect(eval_('10/4')).toBe(2.5));
+    it('handles precedence', () => expect(eval_('2+3*4')).toBe(14));
+    it('handles parentheses', () => expect(eval_('(2+3)*4')).toBe(20));
+    it('handles unary minus', () => expect(eval_('-5')).toBe(-5));
+    it('handles chained operations', () => expect(eval_('1+2+3+4')).toBe(10));
+    it('handles nested parentheses', () => expect(eval_('((2+3))*((4+5))')).toBe(45));
+  });
+
+  describe('cell references', () => {
+    it('resolves cell value', () => {
+      expect(eval_('A1', { A1: 10 })).toBe(10);
+    });
+
+    it('returns null for empty cell', () => {
+      expect(eval_('A1', {})).toBeNull();
+    });
+
+    it('treats null as 0 in arithmetic', () => {
+      expect(eval_('A1+1', {})).toBe(1);
+    });
+
+    it('resolves multiple cells', () => {
+      expect(eval_('A1+B1', { A1: 10, B1: 20 })).toBe(30);
+    });
+  });
+
+  describe('comparisons', () => {
+    it('greater than true', () => expect(eval_('5>3')).toBe(true));
+    it('greater than false', () => expect(eval_('3>5')).toBe(false));
+    it('less than true', () => expect(eval_('3<5')).toBe(true));
+    it('less than false', () => expect(eval_('5<3')).toBe(false));
+    it('equal true', () => expect(eval_('5=5')).toBe(true));
+    it('equal false', () => expect(eval_('5=3')).toBe(false));
+    it('not equal true', () => expect(eval_('5<>3')).toBe(true));
+    it('not equal false', () => expect(eval_('5<>5')).toBe(false));
+    it('greater or equal true', () => expect(eval_('5>=5')).toBe(true));
+    it('greater or equal false', () => expect(eval_('4>=5')).toBe(false));
+    it('less or equal true', () => expect(eval_('3<=5')).toBe(true));
+    it('less or equal false', () => expect(eval_('6<=5')).toBe(false));
+  });
+
+  describe('functions', () => {
+    const cells: Record<string, CellValue> = { A1: 10, A2: 20, A3: 30 };
+
+    it('SUM', () => expect(eval_('SUM(A1:A3)', cells)).toBe(60));
+
+    it('SUM with empty cells', () => {
+      expect(eval_('SUM(A1:A5)', { A1: 10, A3: 30 })).toBe(40);
+    });
+
+    it('AVERAGE', () => expect(eval_('AVERAGE(A1:A3)', cells)).toBe(20));
+
+    it('AVERAGE skips non-numeric', () => {
+      expect(eval_('AVERAGE(A1:A3)', { A1: 10, A2: 'text', A3: 30 })).toBe(20);
+    });
+
+    it('MIN', () => expect(eval_('MIN(A1:A3)', cells)).toBe(10));
+    it('MAX', () => expect(eval_('MAX(A1:A3)', cells)).toBe(30));
+    it('COUNT', () => expect(eval_('COUNT(A1:A3)', cells)).toBe(3));
+
+    it('COUNT skips non-numeric', () => {
