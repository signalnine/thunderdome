+++ b/src/evaluator.ts
@@ -0,0 +1,123 @@
+import type { ASTNode, CellValue } from './types.js';
+import { expandRange } from './parser.js';
+
+function toNumber(val: CellValue): number {
+  if (val === null) return 0;
+  if (typeof val === 'boolean') return val ? 1 : 0;
+  if (typeof val === 'number') return val;
+  const n = parseFloat(val);
+  return isNaN(n) ? 0 : n;
+}
+
+function collectRangeValues(node: ASTNode, lookup: (ref: string) => CellValue): CellValue[] {
+  if (node.kind === 'range') {
+    const refs = expandRange(node.start, node.end);
+    return refs.map(lookup);
+  }
+  // Single value (e.g., SUM(A1, B1) with individual refs)
+  return [evaluate(node, lookup)];
+}
+
+function getNumericValues(args: ASTNode[], lookup: (ref: string) => CellValue): number[] {
+  const values: CellValue[] = [];
+  for (const arg of args) {
+    values.push(...collectRangeValues(arg, lookup));
+  }
+  return values.filter((v): v is number => typeof v === 'number');
+}
+
+export function evaluate(node: ASTNode, lookup: (ref: string) => CellValue): CellValue {
+  switch (node.kind) {
+    case 'number':
+      return node.value;
+
+    case 'string':
+      return node.value;
+
+    case 'boolean':
+      return node.value;
+
+    case 'cellref':
+      return lookup(node.ref);
+
+    case 'unary': {
+      const operand = evaluate(node.operand, lookup);
+      if (node.op === '-') {
+        return -toNumber(operand);
+      }
+      throw new Error(`Unknown unary operator: ${node.op}`);
+    }
+
+    case 'binary': {
+      const left = evaluate(node.left, lookup);
+      const right = evaluate(node.right, lookup);
+
+      switch (node.op) {
+        case '+': return toNumber(left) + toNumber(right);
+        case '-': return toNumber(left) - toNumber(right);
+        case '*': return toNumber(left) * toNumber(right);
+        case '/': return toNumber(left) / toNumber(right);
+        case '>': return toNumber(left) > toNumber(right);
+        case '<': return toNumber(left) < toNumber(right);
+        case '>=': return toNumber(left) >= toNumber(right);
+        case '<=': return toNumber(left) <= toNumber(right);
+        case '=': return left === right;
+        case '<>': return left !== right;
+        default:
+          throw new Error(`Unknown operator: ${node.op}`);
+      }
+    }
+
+    case 'function': {
+      const name = node.name.toUpperCase();
+
+      switch (name) {
+        case 'SUM': {
+          const nums = getNumericValues(node.args, lookup);
+          return nums.reduce((a, b) => a + b, 0);
+        }
+
+        case 'AVERAGE': {
+          const nums = getNumericValues(node.args, lookup);
+          if (nums.length === 0) return 0;
+          return nums.reduce((a, b) => a + b, 0) / nums.length;
+        }
+
+        case 'MIN': {
+          const nums = getNumericValues(node.args, lookup);
+          if (nums.length === 0) return 0;
+          return Math.min(...nums);
+        }
+
+        case 'MAX': {
+          const nums = getNumericValues(node.args, lookup);
+          if (nums.length === 0) return 0;
+          return Math.max(...nums);
+        }
+
+        case 'COUNT': {
+          const nums = getNumericValues(node.args, lookup);
+          return nums.length;
+        }
+
+        case 'IF': {
+          if (node.args.length < 3) throw new Error('IF requires 3 arguments');
+          const condition = evaluate(node.args[0], lookup);
+          const isTruthy = condition !== false && condition !== 0 && condition !== null && condition !== '';
+          return isTruthy
+            ? evaluate(node.args[1], lookup)
+            : evaluate(node.args[2], lookup);
+        }
+
+        default:
+          throw new Error(`Unknown function: ${name}`);
+      }
+    }
+
+    case 'range':
+      throw new Error('Range can only be used inside a function call');
+
+    default:
+      throw new Error(`Unknown node kind: ${(node as ASTNode).kind}`);
+  }
+}
diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..ffcf24d
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,131 @@
+import { parse, extractCellRefs } from './parser.js';
+import { evaluate } from './evaluator.js';
+import type { ASTNode, CellValue } from './types.js';
+
+interface CellData {
+  rawValue: string | number | boolean;
+  formula: ASTNode | null;
+  computedValue: CellValue;
+  deps: Set<string>;
+}
+
+export class Spreadsheet {
+  private cells = new Map<string, CellData>();
+  private reverseDeps = new Map<string, Set<string>>();
+
+  set(cell: string, value: string | number | boolean): void {
+    cell = cell.toUpperCase();
+
+    let formula: ASTNode | null = null;
+    let deps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaStr = value.slice(1);
+      formula = parse(formulaStr);
+      deps = extractCellRefs(formula);
+    }
+
+    // Check for circular references before committing
+    if (deps.size > 0) {
+      this.checkCircular(cell, deps);
+    }
+
+    // Remove old reverse dependencies
+    const oldData = this.cells.get(cell);
+    if (oldData) {
+      for (const dep of oldData.deps) {
+        this.reverseDeps.get(dep)?.delete(cell);
+      }
+    }
+
+    // Add new reverse dependencies
+    for (const dep of deps) {
+      if (!this.reverseDeps.has(dep)) {
+        this.reverseDeps.set(dep, new Set());
+      }
+      this.reverseDeps.get(dep)!.add(cell);
+    }
+
+    // Compute value
+    const computedValue = formula
+      ? evaluate(formula, (ref) => this.cells.get(ref)?.computedValue ?? null)
+      : (value as CellValue);
+
+    this.cells.set(cell, { rawValue: value, formula, computedValue, deps });
+
+    // Recompute dependents in topological order
+    this.recomputeDependents(cell);
+  }
+
+  get(cell: string): CellValue {
+    cell = cell.toUpperCase();
+    return this.cells.get(cell)?.computedValue ?? null;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    if (typeof val === 'boolean') return val ? 'TRUE' : 'FALSE';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computedValue);
+    }
+    return result;
+  }
+
+  private checkCircular(cell: string, deps: Set<string>): void {
+    const visited = new Set<string>();
+    const stack = [...deps];
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === cell) {
+        throw new Error(`Circular reference detected: ${cell}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+      const currentData = this.cells.get(current);
+      if (currentData) {
+        for (const dep of currentData.deps) {
+          stack.push(dep);
+        }
+      }
+    }
+  }
+
+  private recomputeDependents(changedCell: string): void {
+    const order = this.topoSort(changedCell);
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data?.formula) {
+        data.computedValue = evaluate(
+          data.formula,
+          (r) => this.cells.get(r)?.computedValue ?? null,
+        );
+      }
+    }
+  }
+
+  private topoSort(startCell: string): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    const visit = (cell: string): void => {
+      if (visited.has(cell)) return;
+      visited.add(cell);
+      const dependents = this.reverseDeps.get(cell);
+      if (dependents) {
+        for (const dep of dependents) {
+          visit(dep);
+        }
+      }
+      result.push(cell);
+    };
+
+    visit(startCell);
+    return result.filter((c) => c !== startCell).reverse();
+  }
+}
