@@ -0,0 +1,338 @@
+import { TokenType, Token, ASTNode } from './types.js';
+
+const CELL_REF_RE = /^[A-Z]+[0-9]+$/i;
+
+function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < input.length) {
+    const ch = input[i];
+
+    // Whitespace
+    if (ch === ' ' || ch === '\t' || ch === '\n' || ch === '\r') {
+      i++;
+      continue;
+    }
+
+    // Numbers
+    if (ch >= '0' && ch <= '9') {
+      let num = '';
+      while (i < input.length && ((input[i] >= '0' && input[i] <= '9') || input[i] === '.')) {
+        num += input[i];
+        i++;
+      }
+      tokens.push({ type: TokenType.Number, value: num });
+      continue;
+    }
+
+    // Strings
+    if (ch === '"') {
+      i++; // skip opening quote
+      let str = '';
+      while (i < input.length && input[i] !== '"') {
+        str += input[i];
+        i++;
+      }
+      i++; // skip closing quote
+      tokens.push({ type: TokenType.String, value: str });
+      continue;
+    }
+
+    // Identifiers, booleans, cell refs
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+      let word = '';
+      while (i < input.length && ((input[i] >= 'A' && input[i] <= 'Z') || (input[i] >= 'a' && input[i] <= 'z') || (input[i] >= '0' && input[i] <= '9'))) {
+        word += input[i];
+        i++;
+      }
+      const upper = word.toUpperCase();
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: TokenType.Boolean, value: upper });
+      } else if (CELL_REF_RE.test(word)) {
+        tokens.push({ type: TokenType.CellRef, value: upper });
+      } else {
+        tokens.push({ type: TokenType.Identifier, value: upper });
+      }
+      continue;
+    }
+
+    // Two-character operators
+    if (ch === '>' && i + 1 < input.length && input[i + 1] === '=') {
+      tokens.push({ type: TokenType.Gte, value: '>=' });
+      i += 2;
+      continue;
+    }
+    if (ch === '<' && i + 1 < input.length && input[i + 1] === '=') {
+      tokens.push({ type: TokenType.Lte, value: '<=' });
+      i += 2;
+      continue;
+    }
+    if (ch === '<' && i + 1 < input.length && input[i + 1] === '>') {
+      tokens.push({ type: TokenType.Neq, value: '<>' });
+      i += 2;
+      continue;
+    }
+
+    // Single-character operators
+    switch (ch) {
+      case '+': tokens.push({ type: TokenType.Plus, value: '+' }); break;
+      case '-': tokens.push({ type: TokenType.Minus, value: '-' }); break;
+      case '*': tokens.push({ type: TokenType.Star, value: '*' }); break;
+      case '/': tokens.push({ type: TokenType.Slash, value: '/' }); break;
+      case '(': tokens.push({ type: TokenType.LParen, value: '(' }); break;
+      case ')': tokens.push({ type: TokenType.RParen, value: ')' }); break;
+      case ',': tokens.push({ type: TokenType.Comma, value: ',' }); break;
+      case ':': tokens.push({ type: TokenType.Colon, value: ':' }); break;
+      case '>': tokens.push({ type: TokenType.Gt, value: '>' }); break;
+      case '<': tokens.push({ type: TokenType.Lt, value: '<' }); break;
+      case '=': tokens.push({ type: TokenType.Eq, value: '=' }); break;
+      default:
+        throw new Error(`Unexpected character: ${ch}`);
+    }
+    i++;
+  }
+
+  tokens.push({ type: TokenType.EOF, value: '' });
+  return tokens;
+}
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token {
+    return this.tokens[this.pos];
+  }
+
+  private advance(): Token {
+    const token = this.tokens[this.pos];
+    this.pos++;
+    return token;
+  }
+
+  private expect(type: TokenType): Token {
+    const token = this.peek();
+    if (token.type !== type) {
+      throw new Error(`Expected ${TokenType[type]} but got ${TokenType[token.type]} (${token.value})`);
+    }
+    return this.advance();
+  }
+
+  parse(): ASTNode {
+    const node = this.expression();
+    this.expect(TokenType.EOF);
+    return node;
+  }
+
+  private expression(): ASTNode {
+    return this.comparison();
+  }
+
+  private comparison(): ASTNode {
+    let left = this.addition();
+
+    while (
+      this.peek().type === TokenType.Gt ||
+      this.peek().type === TokenType.Lt ||
+      this.peek().type === TokenType.Gte ||
+      this.peek().type === TokenType.Lte ||
+      this.peek().type === TokenType.Eq ||
+      this.peek().type === TokenType.Neq
+    ) {
+      const op = this.advance().value;
+      const right = this.addition();
+      left = { kind: 'binary', op, left, right };
+    }
+
+    return left;
+  }
+
+  private addition(): ASTNode {
+    let left = this.multiplication();
+
+    while (this.peek().type === TokenType.Plus || this.peek().type === TokenType.Minus) {
+      const op = this.advance().value;
+      const right = this.multiplication();
+      left = { kind: 'binary', op, left, right };
+    }
+
+    return left;
+  }
+
+  private multiplication(): ASTNode {
+    let left = this.unary();
+
+    while (this.peek().type === TokenType.Star || this.peek().type === TokenType.Slash) {
+      const op = this.advance().value;
+      const right = this.unary();
+      left = { kind: 'binary', op, left, right };
+    }
+
+    return left;
+  }
+
+  private unary(): ASTNode {
+    if (this.peek().type === TokenType.Minus) {
+      this.advance();
+      const operand = this.unary();
+      return { kind: 'unary', op: '-', operand };
+    }
+    return this.primary();
+  }
+
+  private primary(): ASTNode {
+    const token = this.peek();
+
+    switch (token.type) {
+      case TokenType.Number:
+        this.advance();
+        return { kind: 'number', value: parseFloat(token.value) };
+
+      case TokenType.String:
+        this.advance();
+        return { kind: 'string', value: token.value };
+
+      case TokenType.Boolean:
+        this.advance();
+        return { kind: 'boolean', value: token.value === 'TRUE' };
+
+      case TokenType.CellRef: {
+        this.advance();
+        // Check for range (colon follows)
+        if (this.peek().type === TokenType.Colon) {
+          this.advance(); // consume colon
+          const endToken = this.expect(TokenType.CellRef);
+          return { kind: 'range', start: token.value, end: endToken.value };
+        }
+        return { kind: 'cellref', ref: token.value };
+      }
+
+      case TokenType.Identifier: {
+        // Function call
+        const name = this.advance().value;
+        this.expect(TokenType.LParen);
+        const args: ASTNode[] = [];
+        if (this.peek().type !== TokenType.RParen) {
+          args.push(this.funcArg());
+          while (this.peek().type === TokenType.Comma) {
+            this.advance(); // consume comma
+            args.push(this.funcArg());
+          }
+        }
+        this.expect(TokenType.RParen);
+        return { kind: 'function', name, args };
+      }
+
+      case TokenType.LParen: {
+        this.advance();
+        const expr = this.expression();
+        this.expect(TokenType.RParen);
+        return expr;
+      }
+
+      default:
+        throw new Error(`Unexpected token: ${TokenType[token.type]} (${token.value})`);
+    }
+  }
+
+  private funcArg(): ASTNode {
+    // Look ahead: if CellRef followed by Colon, it's a range
+    if (this.peek().type === TokenType.CellRef) {
+      const nextIdx = this.pos + 1;
+      if (nextIdx < this.tokens.length && this.tokens[nextIdx].type === TokenType.Colon) {
+        const start = this.advance(); // consume cell ref
+        this.advance(); // consume colon
+        const end = this.expect(TokenType.CellRef);
+        return { kind: 'range', start: start.value, end: end.value };
+      }
+    }
+    return this.expression();
+  }
+}
+
+export function parse(input: string): ASTNode {
+  const tokens = tokenize(input);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+export function colToNum(col: string): number {
+  let num = 0;
+  for (let i = 0; i < col.length; i++) {
+    num = num * 26 + (col.charCodeAt(i) - 64);
+  }
+  return num - 1; // 0-based
+}
+
+export function numToCol(num: number): string {
+  let result = '';
+  num++; // 1-based for conversion
+  while (num > 0) {
+    num--;
+    result = String.fromCharCode(65 + (num % 26)) + result;
+    num = Math.floor(num / 26);
+  }
+  return result;
+}
+
+export function parseCellRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: colToNum(match[1]), row: parseInt(match[2], 10) };
+}
+
+export function expandRange(start: string, end: string): string[] {
+  const s = parseCellRef(start);
+  const e = parseCellRef(end);
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+
+  const refs: string[] = [];
+  for (let col = minCol; col <= maxCol; col++) {
+    for (let row = minRow; row <= maxRow; row++) {
+      refs.push(numToCol(col) + row);
+    }
+  }
+  return refs;
+}
+
+export function extractCellRefs(node: ASTNode): Set<string> {
+  const refs = new Set<string>();
+
+  function walk(n: ASTNode): void {
+    switch (n.kind) {
+      case 'cellref':
+        refs.add(n.ref);
+        break;
+      case 'range':
+        for (const ref of expandRange(n.start, n.end)) {
+          refs.add(ref);
+        }
+        break;
+      case 'binary':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'unary':
+        walk(n.operand);
+        break;
+      case 'function':
+        for (const arg of n.args) {
+          walk(arg);
+        }
+        break;
+      // number, string, boolean: no refs
+    }
+  }
+
+  walk(node);
+  return refs;
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..2d35416
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,84 @@
+export enum TokenType {
+  Number,
+  String,
+  Boolean,
+  CellRef,
+  Identifier,
+  Plus,
+  Minus,
+  Star,
+  Slash,
+  LParen,
+  RParen,
+  Comma,
+  Colon,
+  Gt,
+  Lt,
+  Gte,
+  Lte,
+  Eq,
+  Neq,
+  EOF,
+}
+
+export interface Token {
+  type: TokenType;
+  value: string;
+}
+
+export type ASTNode =
+  | NumberLiteral
+  | StringLiteral
+  | BooleanLiteral
+  | CellRefNode
+  | BinaryOp
+  | UnaryOp
+  | FunctionCall
+  | RangeNode;
+
+export interface NumberLiteral {
+  kind: 'number';
+  value: number;
+}
+
+export interface StringLiteral {
+  kind: 'string';
+  value: string;
+}
+
+export interface BooleanLiteral {
+  kind: 'boolean';
+  value: boolean;
+}
+
+export interface CellRefNode {
+  kind: 'cellref';
+  ref: string;
+}
+
+export interface BinaryOp {
+  kind: 'binary';
+  op: string;
+  left: ASTNode;
+  right: ASTNode;
+}
+
+export interface UnaryOp {
+  kind: 'unary';
+  op: string;
+  operand: ASTNode;
+}
+
+export interface FunctionCall {
+  kind: 'function';
+  name: string;
+  args: ASTNode[];
+}
+
+export interface RangeNode {
+  kind: 'range';
+  start: string;
+  end: string;
+}
+
+export type CellValue = string | number | boolean | null;
