ll\")');\n      expect(s.get('C1')).toBe('big');\n    });\n\n    it('IF with false condition', () => {\n      const s = new Spreadsheet();\n      s.set('A1', 10);\n      s.set('C1', '=IF(A1>30,\"big\",\"small\")');\n      expect(s.get('C1')).toBe('small');\n    });\n\n    it('IF reacts to changes', () => {\n      const s = new Spreadsheet();\n      s.set('A1', 50);\n      s.set('C1', '=IF(A1>30,\"big\",\"small\")');\n      expect(s.get('C1')).toBe('big');\n\n      s.set('A1', 10);\n      expect(s.get('C1')).toBe('small');\n    });\n  });\n\n  describe('circular references', () => {\n    it('detects self-reference', () => {\n      const s = new Spreadsheet();\n      expect(() => s.set('A1', '=A1')).toThrow();\n    });\n\n    it('detects direct circular reference', () => {\n      const s = new Spreadsheet();\n      s.set('A1', '=B1');\n      expect(() => s.set('B1', '=A1')).toThrow();\n    });\n\n    it('detects indirect circular reference', () => {\n      const s = new Spreadsheet();\n      s.set('A1', '=B1');\n      s.set('B1', '=C1');\n      expect(() => s.set('C1', '=A1')).toThrow();\n    });\n\n    it('does not throw for valid chain', () => {\n      const s = new Spreadsheet();\n      s.set('A1', 10);\n      s.set('B1', '=A1');\n      s.set('C1', '=B1');\n      expect(s.get('C1')).toBe(10);\n    });\n\n    it('does not mutate state on circular reference error', () => {\n      const s = new Spreadsheet();\n      s.set('A1', '=B1');\n      s.set('B1', 42);\n      expect(s.get('A1')).toBe(42);\n\n      // Try to create a cycle — should fail\n      expect(() => s.set('B1', '=A1')).toThrow();\n\n      // B1 should still be 42\n      expect(s.get('B1')).toBe(42);\n    });\n  });\n\n  describe('getDisplay', () => {\n    it('displays numbers', () => {\n      const s = new Spreadsheet();\n      s.set('A1', 42);\n      expect(s.getDisplay('A1')).toBe('42');\n    });\n\n    it('displays decimal numbers', () => {\n      const s = new Spreadsheet();\n      s.set('A1', 3.14);\