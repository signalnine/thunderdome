+      const s = new Spreadsheet();
+      expect(s.get('A1')).toBeNull();
+    });
+
+    it('overwrites existing value', () => {
+      const s = new Spreadsheet();
+      s.set('A1', 10);
+      s.set('A1', 20);
+      expect(s.get('A1')).toBe(20);
+    });
+  });
+
+  describe('formulas', () => {
+    it('evaluates simple addition formula', () => {
+      const s = new Spreadsheet();
+      s.set('A1', 10);
+      s.set('A2', 20);
+      s.set('A3', '=A1+A2');
+      expect(s.get('A3')).toBe(30);
+    });
+
+    it('evaluates multiplication formula', () => {
+      const s = new Spreadsheet();
+      s.set('A1', 5);
+      s.set('A2', '=A1*3');
+      expect(s.get('A2')).toBe(15);
+    });
+
+    it('evaluates subtraction formula', () => {
+      const s = new Spreadsheet();
+      s.set('A1', 100);
+      s.set('A2', 30);
+      s.set('A3', '=A1-A2');
+      expect(s.get('A3')).toBe(70);
+    });
+
+    it('evaluates division formula', () => {
+      const s = new Spreadsheet();
+      s.set('A1', 100);
+      s.set('A2', 4);
+      s.set('A3', '=A1/A2');
+      expect(s.get('A3')).toBe(25);
+    });
+
+    it('evaluates formula with parentheses', () => {
+      const s = new Spreadsheet();
+      s.set('A1', 2);
+      s.set('B1', 3);
+      s.set('C1', '=(A1+B1)*2');
+      expect(s.get('C1')).toBe(10);
+    });
+
+    it('evaluates formula referencing empty cell', () => {
+      const s = new Spreadsheet();
+      s.set('A1', '=B1+1');
+      expect(s.get('A1')).toBe(1);
+    });
+  });
+
+  describe('reactive updates', () => {
+    it('updates dependents when source changes', () => {
+      const s = new Spreadsheet();
+      s.set('A1', 10);
+      s.set('A2', 20);
+      s.set('A3', '=A1+A2');
+      expect(s.get('A3')).toBe(30);
+
+      s.set('A1', 50);
+      expect(s.get('A3')).toBe(70);
+    });
+
+    it('updates transitive dependents', () => {
+      const s = new Spreadsheet();
