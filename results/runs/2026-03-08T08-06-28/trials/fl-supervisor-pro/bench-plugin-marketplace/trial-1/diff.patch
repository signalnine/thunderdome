+import { describe, it, expect, beforeEach } from 'vitest';
+import { PluginRegistry } from '../src/registry/index.js';
+import { PluginManifest } from '../src/types.js';
+import Database from 'better-sqlite3';
+
+describe('PluginRegistry', () => {
+  let registry: PluginRegistry;
+  let db: Database.Database;
+
+  beforeEach(() => {
+    // Use an in-memory database for each test to ensure isolation
+    db = new Database(':memory:');
+    registry = new PluginRegistry(':memory:'); // PluginRegistry creates its own in-memory db
+    // Since PluginRegistry creates its own in-memory db, we don't need to pass 'db' directly.
+    // However, if we wanted to manage a single db instance, the constructor would need adjustment.
+    // For now, each registry instance gets its own isolated memory db.
+  });
+
+  it('should register a plugin manifest', () => {
+    const manifest: PluginManifest = {
+      name: 'test-plugin',
+      version: '1.0.0',
+      description: 'A test plugin',
+      author: 'Test Author',
+      dependencies: {},
+      entryPoint: 'index.js',
+      permissions: ['read', 'write'],
+    };
+
+    registry.register(manifest);
+    const retrieved = registry.getVersion('test-plugin', '1.0.0');
+    expect(retrieved).toEqual(manifest);
+  });
+
+  it('should return null if plugin not found', () => {
+    const retrieved = registry.get('non-existent');
+    expect(retrieved).toBeNull();
+  });
+
