@@ -0,0 +1,77 @@
+import { describe, it, expect } from 'vitest';
+import { VersionResolver } from '../src/resolver/index.js';
+import { VersionConstraint } from '../src/types.js';
+
+describe('VersionResolver', () => {
+  const resolver = new VersionResolver();
+
+  it('should satisfy a version within a range', () => {
+    expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);
+    expect(resolver.satisfies('1.0.0', '^1.0.0')).toBe(true);
+    expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+  });
+
+  it('should find the maximum satisfying version', () => {
+    const versions = ['1.0.0', '1.2.0', '1.5.0', '2.0.0'];
+    expect(resolver.maxSatisfying(versions, '^1.0.0')).toBe('1.5.0');
+    expect(resolver.maxSatisfying(versions, '>=1.2.0 <1.5.0')).toBe('1.2.0');
+    expect(resolver.maxSatisfying(versions, '~1.2.0')).toBe('1.2.0');
+    expect(resolver.maxSatisfying(versions, '>2.0.0')).toBeNull();
+  });
+
+  it('should validate a semver range', () => {
+    expect(resolver.validRange('^1.0.0')).toBe(true);
+    expect(resolver.validRange('1.x')).toBe(true);
+    expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);
+    expect(resolver.validRange('invalid-range')).toBe(false);
+  });
+
+  it('should resolve multiple version constraints', () => {
+    const constraints: VersionConstraint[] = [
+      { name: 'plugin-a', range: '^1.0.0' },
+      { name: 'plugin-b', range: '~2.1.0' },
+      { name: 'plugin-c', range: '3.x' },
+    ];
+
+    const available: Record<string, string[]> = {
+      'plugin-a': ['1.0.0', '1.5.0', '2.0.0'],
+      'plugin-b': ['2.1.0', '2.1.5', '2.2.0'],
+      'plugin-c': ['3.0.0', '3.1.0', '4.0.0'],
+      'plugin-d': ['1.0.0'], // Not requested
+    };
+
+    const resolved = resolver.resolve(constraints, available);
+    expect(resolved).toEqual([
+      { name: 'plugin-a', version: '1.5.0', satisfies: '^1.0.0' },
+      { name: 'plugin-b', version: '2.1.5', satisfies: '~2.1.0' },
+      { name: 'plugin-c', version: '3.1.0', satisfies: '3.x' },
+    ]);
+  });
+
+  it('should handle unresolved constraints by omitting them', () => {
+    const constraints: VersionConstraint[] = [
+      { name: 'plugin-a', range: '^1.0.0' },
+      { name: 'plugin-x', range: '^1.0.0' }, // Not available
+    ];
+
+    const available: Record<string, string[]> = {
+      'plugin-a': ['1.0.0', '1.5.0'],
+    };
+
+    const resolved = resolver.resolve(constraints, available);
+    expect(resolved).toEqual([
+      { name: 'plugin-a', version: '1.5.0', satisfies: '^1.0.0' },
+    ]);
+  });
+
+  it('should handle empty available versions gracefully', () => {
+    const constraints: VersionConstraint[] = [
+      { name: 'plugin-a', range: '^1.0.0' },
+    ];
+    const available: Record<string, string[]> = {
+      'plugin-a': [],
+    };
+    const resolved = resolver.resolve(constraints, available);
+    expect(resolved).toEqual([]);
+  });
+});
