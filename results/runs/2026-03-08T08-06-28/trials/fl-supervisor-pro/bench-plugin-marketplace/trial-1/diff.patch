+import { describe, it, expect, beforeEach } from 'vitest';
+import { ReviewSystem } from '../src/reviews/index.js';
+import { Review } from '../src/types.js';
+import Database from 'better-sqlite3';
+
+describe('ReviewSystem', () => {
+  let reviewSystem: ReviewSystem;
+  let db: Database.Database;
+
+  beforeEach(() => {
+    db = new Database(':memory:');
+    reviewSystem = new ReviewSystem(':memory:'); // Each instance gets its own isolated memory db
+  });
+
+  it('should add a review', () => {
+    const newReview: Omit<Review, 'id' | 'createdAt' | 'flagged'> = {
+      pluginName: 'test-plugin',
+      pluginVersion: '1.0.0',
+      userId: 'user1',
+      rating: 5,
+      comment: 'Great plugin!',
+    };
+    const addedReview = reviewSystem.addReview(newReview);
+    expect(addedReview).toMatchObject(newReview);
+    expect(addedReview.id).toBeDefined();
+    expect(addedReview.createdAt).toBeDefined();
+    expect(addedReview.flagged).toBe(false);
+
+    const reviews = reviewSystem.getReviews('test-plugin');
+    expect(reviews.length).toBe(1);
+    expect(reviews[0]).toEqual(addedReview);
+  });
+
+  it('should retrieve reviews for a specific plugin', () => {
+    reviewSystem.addReview({ pluginName: 'plugin-a', pluginVersion: '1.0.0', userId: 'user1', rating: 4, comment: 'Good' });
+    reviewSystem.addReview({ pluginName: 'plugin-a', pluginVersion: '1.0.0', userId: 'user2', rating: 5, comment: 'Excellent' });
+    reviewSystem.addReview({ pluginName: 'plugin-b', pluginVersion: '1.0.0', userId: 'user3', rating: 3, comment: 'Meh' });
+
+    const pluginAReviews = reviewSystem.getReviews('plugin-a');
+    expect(pluginAReviews.length).toBe(2);
+    expect(pluginAReviews[0].pluginName).toBe('plugin-a');
+    expect(pluginAReviews[1].pluginName).toBe('plugin-a');
+
+    const pluginBReviews = reviewSystem.getReviews('plugin-b');
+    expect(pluginBReviews.length).toBe(1);
+    expect(pluginBReviews[0].pluginName).toBe('plugin-b');
+  });
+
+  it('should compute the average rating, excluding flagged reviews', () => {
+    const review1 = reviewSystem.addReview({ pluginName: 'avg-plugin', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: '' });
+    const review2 = reviewSystem.addReview({ pluginName: 'avg-plugin', pluginVersion: '1.0.0', userId: 'user2', rating: 3, comment: '' });
+    const review3 = reviewSystem.addReview({ pluginName: 'avg-plugin', pluginVersion: '1.0.0', userId: 'user3', rating: 1, comment: 'Spam' });
+
+    expect(reviewSystem.getAverageRating('avg-plugin')).toBe(3); // (5+3+1)/3
+
+    reviewSystem.flagReview(review3.id);
+    expect(reviewSystem.getAverageRating('avg-plugin')).toBe(4); // (5+3)/2
+  });
+
+  it('should flag a review', () => {
+    const review = reviewSystem.addReview({ pluginName: 'flag-plugin', pluginVersion: '1.0.0', userId: 'user1', rating: 1, comment: 'Bad' });
+    expect(review.flagged).toBe(false);
+
+    reviewSystem.flagReview(review.id);
+    const flaggedReviews = reviewSystem.getFlaggedReviews();
+    expect(flaggedReviews.length).toBe(1);
+    expect(flaggedReviews[0].id).toBe(review.id);
+    expect(flaggedReviews[0].flagged).toBe(true);
+  });
+
+  it('should return an empty array if no flagged reviews', () => {
+    reviewSystem.addReview({ pluginName: 'clean-plugin', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: '' });
+    expect(reviewSystem.getFlaggedReviews().length).toBe(0);
+  });
+
+  it('should remove a review', () => {
+    const review = reviewSystem.addReview({ pluginName: 'remove-plugin', pluginVersion: '1.0.0', userId: 'user1', rating: 2, comment: '' });
+    expect(reviewSystem.getReviews('remove-plugin').length).toBe(1);
+
+    const removed = reviewSystem.removeReview(review.id);
+    expect(removed).toBe(true);
+    expect(reviewSystem.getReviews('remove-plugin').length).toBe(0);
+  });
+
+  it('should return false if trying to remove a non-existent review', () => {
+    const removed = reviewSystem.removeReview(999);
+    expect(removed).toBe(false);
+  });
+
+  it('should retrieve reviews by user', () => {
+    reviewSystem.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'userA', rating: 5, comment: '' });
+    reviewSystem.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'userA', rating: 4, comment: '' });
+    reviewSystem.addReview({ pluginName: 'p3', pluginVersion: '1.0.0', userId: 'userB', rating: 3, comment: '' });
+
+    const userAReviews = reviewSystem.getReviewsByUser('userA');
+    expect(userAReviews.length).toBe(2);
+    expect(userAReviews[0].userId).toBe('userA');
+    expect(userAReviews[1].userId).toBe('userA');
+
+    const userBReviews = reviewSystem.getReviewsByUser('userB');
+    expect(userBReviews.length).toBe(1);
+    expect(userBReviews[0].userId).toBe('userB');
+  });
+
+  it('should get the count of reviews for a plugin', () => {
+    reviewSystem.addReview({ pluginName: 'count-plugin', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: '' });
+    reviewSystem.addReview({ pluginName: 'count-plugin', pluginVersion: '1.0.0', userId: 'user2', rating: 4, comment: '' });
+    reviewSystem.addReview({ pluginName: 'other-count-plugin', pluginVersion: '1.0.0', userId: 'user3', rating: 3, comment: '' });
+
+    expect(reviewSystem.getReviewCount('count-plugin')).toBe(2);
+    expect(reviewSystem.getReviewCount('other-count-plugin')).toBe(1);
+    expect(reviewSystem.getReviewCount('non-existent-plugin')).toBe(0);
+  });
+});
