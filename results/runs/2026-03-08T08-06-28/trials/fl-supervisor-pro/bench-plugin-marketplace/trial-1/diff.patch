@@ -0,0 +1,121 @@
+import Database from 'better-sqlite3';
+import { PluginManifest, RegistryService } from '../types.js';
+
+export class PluginRegistry implements RegistryService {
+  private db: Database.Database;
+
+  constructor(dbPath: string = ':memory:') {
+    this.db = new Database(dbPath);
+    this.db.exec(`
+      CREATE TABLE IF NOT EXISTS plugins (
+        name TEXT NOT NULL,
+        version TEXT NOT NULL,
+        description TEXT,
+        author TEXT,
+        dependencies TEXT,
+        entryPoint TEXT,
+        permissions TEXT,
+        PRIMARY KEY (name, version)
+      );
+    `);
+  }
+
+  register(manifest: PluginManifest): void {
+    const { name, version, description, author, dependencies, entryPoint, permissions } = manifest;
+    const stmt = this.db.prepare(`
+      INSERT INTO plugins (name, version, description, author, dependencies, entryPoint, permissions)
+      VALUES (?, ?, ?, ?, ?, ?, ?)
+      ON CONFLICT(name, version) DO UPDATE SET
+        description=excluded.description,
+        author=excluded.author,
+        dependencies=excluded.dependencies,
+        entryPoint=excluded.entryPoint,
+        permissions=excluded.permissions;
+    `);
+    stmt.run(
+      name,
+      version,
+      description,
+      author,
+      JSON.stringify(dependencies),
+      entryPoint,
+      JSON.stringify(permissions)
+    );
+  }
+
+  private mapRowToManifest(row: { name: string; version: string; description: string; author: string; dependencies: string; entryPoint: string; permissions: string; }): PluginManifest {
+    return {
+      name: row.name,
+      version: row.version,
+      description: row.description,
+      author: row.author,
+      dependencies: JSON.parse(row.dependencies),
+      entryPoint: row.entryPoint,
+      permissions: JSON.parse(row.permissions),
+    };
+  }
+
+  get(name: string): PluginManifest | null {
+    const stmt = this.db.prepare('SELECT * FROM plugins WHERE name = ? ORDER BY version DESC LIMIT 1');
+    const row = stmt.get(name);
+    return row ? this.mapRowToManifest(row as { name: string; version: string; description: string; author: string; dependencies: string; entryPoint: string; permissions: string; }) : null;
+  }
+
+  getVersion(name: string, version: string): PluginManifest | null {
+    const stmt = this.db.prepare('SELECT * FROM plugins WHERE name = ? AND version = ?');
+    const row = stmt.get(name, version);
+    return row ? this.mapRowToManifest(row as { name: string; version: string; description: string; author: string; dependencies: string; entryPoint: string; permissions: string; }) : null;
+  }
+
+  list(): PluginManifest[] {
+    const stmt = this.db.prepare('SELECT * FROM plugins');
+    return stmt.all().map((row) => this.mapRowToManifest(row as { name: string; version: string; description: string; author: string; dependencies: string; entryPoint: string; permissions: string; }));
+  }
+
+  search(query: string): PluginManifest[] {
+    const searchTerm = `%${query}%`;
+    const stmt = this.db.prepare('SELECT * FROM plugins WHERE name LIKE ? OR description LIKE ? OR author LIKE ?');
+    return stmt.all(searchTerm, searchTerm, searchTerm).map((row) => this.mapRowToManifest(row as { name: string; version: string; description: string; author: string; dependencies: string; entryPoint: string; permissions: string; }));
+  }
+
+  remove(name: string, version: string): boolean {
+    const stmt = this.db.prepare('DELETE FROM plugins WHERE name = ? AND version = ?');
+    const result = stmt.run(name, version);
+    return result.changes > 0;
+  }
+
+  listVersions(name: string): string[] {
+    const stmt = this.db.prepare('SELECT version FROM plugins WHERE name = ? ORDER BY version DESC');
+    return stmt.all(name).map((row) => (row as { version: string }).version);
+  }
+
+  update(name: string, version: string, updates: Partial<PluginManifest>): void {
+    const updateParts: string[] = [];
+    // eslint-disable-next-line @typescript-eslint/no-explicit-any
+    const params: any[] = [];
+
+    for (const key in updates) {
+      if (Object.prototype.hasOwnProperty.call(updates, key)) {
+        let value = updates[key as keyof Partial<PluginManifest>];
+        if (key === 'dependencies' || key === 'permissions') {
+          value = JSON.stringify(value);
+        }
+        updateParts.push(`${key} = ?`);
+        params.push(value);
+      }
+    }
+
+    if (updateParts.length === 0) {
+      return;
+    }
+
+    params.push(name, version);
+
+    const stmt = this.db.prepare(`
+      UPDATE plugins
+      SET ${updateParts.join(', ')}
+      WHERE name = ? AND version = ?;
+    `);
+    stmt.run(...params);
+  }
+}
