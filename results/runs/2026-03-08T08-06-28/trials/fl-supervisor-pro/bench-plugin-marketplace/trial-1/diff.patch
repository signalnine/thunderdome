+import { createContext, Script } from 'vm'; // Corrected: Using native 'vm' module
+import { RunnerService, SandboxResult } from '../types.js';
+
+export class SandboxedRunner implements RunnerService {
+  private async runInVm(
+    code: string,
+    timeoutMs: number | undefined,
+    context?: Record<string, unknown>
+  ): Promise<SandboxResult> {
+    const startTime = process.hrtime.bigint();
+    let result: SandboxResult = {
+      success: false,
+      output: null,
+      duration: 0,
+      memoryUsed: 0,
+    };
+
+    const sandbox = {
+      ...context,
+      // Add a way to capture output, e.g., console.log
+      _log: [] as string[],
+      console: {
+        // eslint-disable-next-line @typescript-eslint/no-explicit-any
+        log: (...args: any[]) => {
+          (sandbox._log).push(args.map(String).join(' '));
+        },
+        // eslint-disable-next-line @typescript-eslint/no-explicit-any
+        error: (...args: any[]) => {
+          (sandbox._log).push('ERROR: ' + args.map(String).join(' '));
+        },
+      },
+      // Expose a way for the plugin to return a value explicitly
+      _returnValue: undefined as unknown,
+      _return: (value: unknown) => {
+        sandbox._returnValue = value;
+      }
+    };
+
+    const vmContext = createContext(sandbox); // Corrected: Using createContext
+
+    let timer: NodeJS.Timeout | undefined;
+    const timeoutError = new Error(`Execution timed out after ${timeoutMs}ms`);
+
+    // Promise to handle external timeout
+    const externalTimeoutPromise = new Promise<SandboxResult>((_, reject) => {
+      if (timeoutMs !== undefined) {
+        timer = setTimeout(() => {
+          reject(timeoutError);
+        }, timeoutMs);
+      }
+    });
+
+    try {
+      const script = new Script(code);
+      // Synchronous execution with internal timeout for synchronous runaway scripts
+      const executionPromise = Promise.resolve(script.runInContext(vmContext, { timeout: timeoutMs }));
+
+      // Use Promise.race to handle both internal and external timeouts
+      await Promise.race([executionPromise, externalTimeoutPromise]);
+
+      if (timer) clearTimeout(timer);
+
+      const endTime = process.hrtime.bigint();
+      const duration = Number(endTime - startTime) / 1_000_000; // Convert nanoseconds to milliseconds
+
+      result = {
+        success: true,
+        output: sandbox._log.length > 0 ? sandbox._log.join('\n') : sandbox._returnValue,
+        duration: duration,
+        // NOTE: process.memoryUsage().heapUsed measures the host process memory, not isolated VM memory.
+        // Node.js VM module does not provide a direct way to measure memory usage of an individual VM context.
+        memoryUsed: process.memoryUsage().heapUsed,
+      };
+    } catch (error: unknown) {
+      if (timer) clearTimeout(timer);
+      const endTime = process.hrtime.bigint();
+      result.duration = Number(endTime - startTime) / 1_000_000; // Calculate duration up to error
+      if (error instanceof Error) {
+        result.error = error.message;
+      } else if (typeof error === 'string') {
+        result.error = error;
+      } else if (error && typeof error === 'object' && 'message' in error && typeof (error as { message: unknown }).message === 'string') {
+        // Handle cases where the error is an object with a message property but not an instance of Error
+        result.error = (error as { message: string }).message;
+      } else {
+        result.error = 'An unknown error occurred';
+      }
+    }
+
+    return result;
+  }
+
+  async execute(code: string, context?: Record<string, unknown>): Promise<SandboxResult> {
+    return this.runInVm(code, undefined, context);
+  }
+
+  async executeWithTimeout(
+    code: string,
+    timeoutMs: number,
+    context?: Record<string, unknown>
+  ): Promise<SandboxResult> {
+    return this.runInVm(code, timeoutMs, context);
+  }
+}
