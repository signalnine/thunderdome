@@ -0,0 +1,68 @@
+import { describe, it, expect } from 'vitest';
+import { SandboxedRunner } from '../src/runner/index.js';
+
+describe('SandboxedRunner', () => {
+  const runner = new SandboxedRunner();
+
+  it('should execute simple JavaScript code', async () => {
+    const code = 'console.log("Hello from sandbox"); _return(42);';
+    const result = await runner.execute(code);
+
+    expect(result.success).toBe(true);
+    expect(result.output).toBe('Hello from sandbox');
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+    expect(result.memoryUsed).toBeGreaterThan(0);
+    expect(result.error).toBeUndefined();
+  });
+
+  it('should pass context variables into the sandbox', async () => {
+    const code = 'const result = input.a + input.b; _return(result);';
+    const context = { input: { a: 10, b: 20 } };
+    const result = await runner.execute(code, context);
+
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(30);
+  });
+
+  it('should handle errors inside the sandbox', async () => {
+    const code = 'throw new Error("Sandbox error");';
+    const result = await runner.execute(code);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toBe('Sandbox error');
+  });
+
+  it('should enforce execution timeouts', async () => {
+    const code = 'while(true) {}'; // Infinite loop
+    const timeoutMs = 10;
+    const result = await runner.executeWithTimeout(code, timeoutMs);
+
+    expect(result.success).toBe(false);
+    expect(result.error).toMatch(/Script execution timed out after \d+ms/);
+    expect(result.duration).toBeGreaterThanOrEqual(timeoutMs);
+  });
+
+  it('should allow returning complex objects', async () => {
+    const code = '_return({ status: "ok", data: [1, 2, 3] });';
+    const result = await runner.execute(code);
+
+    expect(result.success).toBe(true);
+    expect(result.output).toEqual({ status: 'ok', data: [1, 2, 3] });
+  });
+
+  it('should capture console.error output', async () => {
+    const code = 'console.error("This is an error log");';
+    const result = await runner.execute(code);
+
+    expect(result.success).toBe(true);
+    expect(result.output).toBe('ERROR: This is an error log');
+  });
+
+  it('should default output to returnValue if console.log is not used', async () => {
+    const code = '_return("Just a return value");';
+    const result = await runner.execute(code);
+
+    expect(result.success).toBe(true);
+    expect(result.output).toBe('Just a return value');
+  });
+});
