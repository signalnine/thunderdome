+import { describe, it, expect, beforeEach } from 'vitest';
+import { DependencyGraph } from '../src/deps/index.js';
+import { PluginManifest, RegistryService, DependencyNode } from '../src/types.js';
+import * as semver from 'semver';
+
+// Mock RegistryService for testing DependencyGraph in isolation
+class MockRegistry implements RegistryService {
+  private plugins: Map<string, Map<string, PluginManifest>> = new Map();
+
+  register(manifest: PluginManifest): void {
+    if (!this.plugins.has(manifest.name)) {
+      this.plugins.set(manifest.name, new Map());
+    }
+    this.plugins.get(manifest.name)?.set(manifest.version, manifest);
+  }
+
+  get(name: string): PluginManifest | null {
+    const versions = this.plugins.get(name);
+    if (!versions) return null;
+    const sortedVersions = Array.from(versions.keys()).sort(semver.rcompare);
+    if (sortedVersions.length === 0) return null;
+    return versions.get(sortedVersions[0]) || null;
+  }
+
+  getVersion(name: string, version: string): PluginManifest | null {
+    return this.plugins.get(name)?.get(version) || null;
+  }
+
+  list(): PluginManifest[] {
+    const all: PluginManifest[] = [];
+    this.plugins.forEach(versions => versions.forEach(manifest => all.push(manifest)));
+    return all;
+  }
+
+  search(query: string): PluginManifest[] {
+    const lowerQuery = query.toLowerCase();
+    return this.list().filter(
+      p => p.name.toLowerCase().includes(lowerQuery) || p.description.toLowerCase().includes(lowerQuery)
+    );
+  }
+
+  remove(name: string, version: string): boolean {
+    return this.plugins.get(name)?.delete(version) || false;
+  }
+
+  listVersions(name: string): string[] {
+    return Array.from(this.plugins.get(name)?.keys() || []).sort(semver.rcompare);
+  }
+
+  update(name: string, version: string, updates: Partial<PluginManifest>): void {
+    const existing = this.getVersion(name, version);
+    if (existing) {
+      Object.assign(existing, updates);
+    }
+  }
+}
+
+describe('DependencyGraph', () => {
+  let depsGraph: DependencyGraph;
+  let mockRegistry: MockRegistry;
+
+  beforeEach(() => {
+    depsGraph = new DependencyGraph();
+    mockRegistry = new MockRegistry();
+  });
+
+  const registerPlugins = (manifests: PluginManifest[]) => {
+    manifests.forEach(m => mockRegistry.register(m));
+  };
+
+  it('should build a dependency tree', () => {
+    registerPlugins([
+      { name: 'plugin-a', version: '1.0.0', dependencies: { 'plugin-b': '^1.0.0' }, description: '', author: '', entryPoint: '', permissions: [] },
+      { name: 'plugin-b', version: '1.0.0', dependencies: { 'plugin-c': '^1.0.0' }, description: '', author: '', entryPoint: '', permissions: [] },
+      { name: 'plugin-c', version: '1.0.0', dependencies: {}, description: '', author: '', entryPoint: '', permissions: [] },
+    ]);
+
+    const tree = depsGraph.buildTree('plugin-a', mockRegistry);
+    expect(tree).toEqual({
+      name: 'plugin-a',
+      version: '1.0.0',
+      dependencies: [
+        {
+          name: 'plugin-b',
+          version: '1.0.0',
+          dependencies: [
+            {
+              name: 'plugin-c',
+              version: '1.0.0',
+              dependencies: [],
+            },
+          ],
+        },
+      ],
+    });
+  });
+
+  it('should handle missing plugins when building tree', () => {
+    expect(() => depsGraph.buildTree('non-existent', mockRegistry)).toThrow('Plugin non-existent not found in registry.');
+  });
+
+  it('should detect direct circular dependencies', () => {
+    registerPlugins([
+      { name: 'plugin-a', version: '1.0.0', dependencies: { 'plugin-b': '^1.0.0' }, description: '', author: '', entryPoint: '', permissions: [] },
