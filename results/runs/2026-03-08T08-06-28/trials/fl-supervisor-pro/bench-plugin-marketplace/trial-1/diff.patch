+    expect(depsGraph.hasCircularDependency('plugin-a', mockRegistry)).toBe(true);
+    const cycles = depsGraph.detectCycles('plugin-a', mockRegistry);
+    expect(cycles).toEqual([['plugin-a@1.0.0', 'plugin-b@1.0.0']]);
+  });
+
+  it('should detect indirect circular dependencies', () => {
+    registerPlugins([
+      { name: 'plugin-a', version: '1.0.0', dependencies: { 'plugin-b': '^1.0.0' }, description: '', author: '', entryPoint: '', permissions: [] },
