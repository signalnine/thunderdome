+++ b/src/index.ts
@@ -0,0 +1,95 @@
+import { PluginRegistry } from './registry/index.js';
+import { VersionResolver } from './resolver/index.js';
+import { SandboxedRunner } from './runner/index.js';
+import { ReviewSystem } from './reviews/index.js';
+import { DependencyGraph } from './deps/index.js';
+import {
+  PluginManifest,
+  RegistryService,
+  ResolverService,
+  RunnerService,
+  ReviewService,
+  DepsService,
+  SandboxResult,
+  ResolvedVersion,
+} from './types.js';
+
+export interface Marketplace {
+  registry: RegistryService;
+  resolver: ResolverService;
+  runner: RunnerService;
+  reviews: ReviewService;
+  deps: DepsService;
+  installPlugin(manifest: PluginManifest): Promise<{ resolvedDependencies: ResolvedVersion[]; sandboxResult: SandboxResult }>;
+}
+
+export function createMarketplace(dbPath: string = ':memory:'): Marketplace {
+  const registry = new PluginRegistry(dbPath);
+  const resolver = new VersionResolver();
+  const runner = new SandboxedRunner();
+  const reviews = new ReviewSystem(dbPath);
+  const deps = new DependencyGraph();
+
+  const installPlugin = async (
+    manifest: PluginManifest
+  ): Promise<{ resolvedDependencies: ResolvedVersion[]; sandboxResult: SandboxResult }> => {
+    // 1. Validate that the plugin manifest has the required fields
+    if (!manifest.name || !manifest.version || !manifest.entryPoint) {
+      throw new Error('Plugin manifest must contain name, version, and entryPoint.');
+    }
+
+    let resolvedDependencies: ResolvedVersion[] = [];
+    let sandboxResult: SandboxResult;
+
+    try {
+      // 2. Register the plugin in the catalog
+      registry.register(manifest);
+
+      // 3. Resolve its dependency versions against what's available in the registry
+      const dependencyConstraints = Object.entries(manifest.dependencies).map(([name, range]) => ({ name, range }));
+      const availableVersions: Record<string, string[]> = {};
+      for (const depName of Object.keys(manifest.dependencies)) {
+        availableVersions[depName] = registry.listVersions(depName);
+      }
+      resolvedDependencies = resolver.resolve(dependencyConstraints, availableVersions);
+
+      // It's important to also check if all expected dependencies were actually resolved.
+      // If the number of resolved dependencies is less than the number of constraints, it means some couldn't be resolved.
+      if (dependencyConstraints.length > 0 && resolvedDependencies.length !== dependencyConstraints.length) {
+        const unresolved = dependencyConstraints.filter(
+          constraint => !resolvedDependencies.some(res => res.name === constraint.name)
+        );
+        throw new Error(`Failed to resolve all dependencies. Unresolved: ${unresolved.map(u => `${u.name}@${u.range}`).join(', ')}`);
+      }
+
+      // 4. Check for circular dependencies (reject if found)
+      const hasCircular = deps.hasCircularDependency(manifest.name, registry);
+      if (hasCircular) {
+        throw new Error(`Circular dependency detected for plugin ${manifest.name}. Installation aborted.`);
+      }
+
+      // 5. Execute the plugin's entry point in the sandbox
+      sandboxResult = await runner.executeWithTimeout(manifest.entryPoint, 5000);
+    } catch (error: unknown) {
+      // Catch errors during validation, registration, dependency resolution, or circular dependency check
+      // Re-throw the error to indicate installation failure
+      if (error instanceof Error) {
+        throw error;
+      } else {
+        throw new Error(`Installation failed: ${String(error)}`);
+      }
+    }
+
+    // 6. Return the resolved dependency versions and sandbox execution result
+    return { resolvedDependencies, sandboxResult };
+  };
+
+  return {
+    registry,
+    resolver,
+    runner,
+    reviews,
+    deps,
+    installPlugin,
+  };
+}
