new file mode 100644
index 0000000..71188e9
--- /dev/null
+++ b/src/deps/index.ts
@@ -0,0 +1,187 @@
+import { DepsService, DependencyNode, RegistryService } from '../types.js';
+import * as semver from 'semver';
+
+export class DependencyGraph implements DepsService {
+  buildTree(pluginName: string, registry: RegistryService, version?: string, visited: Set<string> = new Set()): DependencyNode {
+    const manifest = version ? registry.getVersion(pluginName, version) : registry.get(pluginName);
+    if (!manifest) {
+      throw new Error(`Plugin ${pluginName}${version ? '@' + version : ''} not found in registry.`);
+    }
+
+    const nodeId = `${pluginName}@${manifest.version}`;
+    if (visited.has(nodeId)) {
+      // This indicates a cycle if we re-visit a node within the same path
+      // For buildTree, we just return an empty dependencies array to prevent infinite loops,
+      // and let detectCycles handle the actual cycle detection.
+      return { name: pluginName, version: manifest.version, dependencies: [] };
+    }
+    visited.add(nodeId);
+
+    const dependencies: DependencyNode[] = [];
+    for (const depName in manifest.dependencies) {
+      if (Object.prototype.hasOwnProperty.call(manifest.dependencies, depName)) {
+        const range = manifest.dependencies[depName];
+        const availableVersions = registry.listVersions(depName);
+        const satisfyingVersion = semver.maxSatisfying(availableVersions, range);
+
+        if (!satisfyingVersion) {
+          throw new Error(`No satisfying version found for dependency ${depName}@${range} of plugin ${pluginName}@${manifest.version}`);
+        }
+
+        dependencies.push(this.buildTree(depName, registry, satisfyingVersion as string, new Set(visited))); // Pass a copy of visited for sub-trees
+      }
+    }
+
+    return { name: pluginName, version: manifest.version, dependencies };
+  }
+
+  detectCycles(pluginName: string, registry: RegistryService): string[][] | null {
+    const cycles: string[][] = [];
+    const path: string[] = [];
+    const visited: Set<string> = new Set(); // Tracks nodes visited in the current DFS path
+
+    const dfs = (currentPluginName: string, currentPluginVersion: string, currentPath: string[]) => {
+      const nodeId = `${currentPluginName}@${currentPluginVersion}`;
+
+      if (currentPath.includes(nodeId)) {
+        const cycleStartIndex = currentPath.indexOf(nodeId);
+        cycles.push(currentPath.slice(cycleStartIndex));
+        return;
+      }
+
+      if (visited.has(nodeId)) {
+        return; // Already processed this node in a previous path, no new cycles from here.
+      }
+      visited.add(nodeId);
+
+      currentPath.push(nodeId);
+
+      const manifest = registry.getVersion(currentPluginName, currentPluginVersion);
+      if (!manifest) {
+        // This should ideally not happen if registry integrity is maintained, or error handled upstream
+        return;
+      }
+
+      for (const depName in manifest.dependencies) {
+        if (Object.prototype.hasOwnProperty.call(manifest.dependencies, depName)) {
+          const range = manifest.dependencies[depName];
+          const availableVersions = registry.listVersions(depName);
+          const satisfyingVersion = semver.maxSatisfying(availableVersions, range);
+
+          if (satisfyingVersion) {
+            dfs(depName, satisfyingVersion as string, currentPath);
+          }
+        }
+      }
+
+      currentPath.pop(); // Backtrack
+    };
+
+    const initialManifest = registry.get(pluginName); // Get latest version for initial check
+    if (!initialManifest) {
+      throw new Error(`Plugin ${pluginName} not found in registry.`);
+    }
+
+    dfs(pluginName, initialManifest.version, path);
+
+    return cycles.length > 0 ? cycles : null;
+  }
+
+  topologicalSort(pluginName: string, registry: RegistryService): string[] {
+    const sorted: string[] = [];
+    const visited: Set<string> = new Set();
+    const visiting: Set<string> = new Set(); // For cycle detection during sort
+
+    const dfs = (currentPluginName: string, currentPluginVersion: string) => {
+      const nodeId = `${currentPluginName}@${currentPluginVersion}`;
+
+      if (visiting.has(nodeId)) {
+        throw new Error(`Circular dependency detected during topological sort for plugin ${nodeId}`);
+      }
+      if (visited.has(nodeId)) {
+        return;
+      }
+
+      visiting.add(nodeId);
+
+      const manifest = registry.getVersion(currentPluginName, currentPluginVersion);
+      if (!manifest) {
+        throw new Error(`Plugin ${currentPluginName}@${currentPluginVersion} not found.`);
+      }
+
+      for (const depName in manifest.dependencies) {
+        if (Object.prototype.hasOwnProperty.call(manifest.dependencies, depName)) {
+          const range = manifest.dependencies[depName];
+          const availableVersions = registry.listVersions(depName);
+          const satisfyingVersion = semver.maxSatisfying(availableVersions, range);
+
+          if (!satisfyingVersion) {
+            throw new Error(`Cannot resolve dependency ${depName}@${range} for ${nodeId}`);
+          }
+          dfs(depName, satisfyingVersion as string);
+        }
+      }
+
+      visiting.delete(nodeId);
+      visited.add(nodeId);
+      sorted.push(nodeId); // Add after all dependencies are processed
+    };
+
+    const initialManifest = registry.get(pluginName);
+    if (!initialManifest) {
+      throw new Error(`Plugin ${pluginName} not found in registry.`);
+    }
+
+    dfs(pluginName, initialManifest.version);
+
+    return sorted;
+  }
+
+  flattenDependencies(pluginName: string, registry: RegistryService): string[] {
+    const flattened: Set<string> = new Set();
+    const visited: Set<string> = new Set();
+
+    const dfs = (currentPluginName: string, currentPluginVersion: string) => {
+      const nodeId = `${currentPluginName}@${currentPluginVersion}`;
+
+      if (visited.has(nodeId)) {
+        return;
+      }
+      visited.add(nodeId);
+
+      const manifest = registry.getVersion(currentPluginName, currentPluginVersion);
+      if (!manifest) {
+        // This case should ideally be handled upstream or indicate an invalid state
+        return;
+      }
+
+      for (const depName in manifest.dependencies) {
+        if (Object.prototype.hasOwnProperty.call(manifest.dependencies, depName)) {
+          const range = manifest.dependencies[depName];
+          const availableVersions = registry.listVersions(depName);
+          const satisfyingVersion = semver.maxSatisfying(availableVersions, range);
+
+          if (satisfyingVersion) {
+            dfs(depName, satisfyingVersion as string);
+          }
+        }
+      }
+      flattened.add(nodeId);
+    };
+
+    const initialManifest = registry.get(pluginName);
+    if (!initialManifest) {
+      throw new Error(`Plugin ${pluginName} not found in registry.`);
+    }
+
+    dfs(pluginName, initialManifest.version);
+
+    // The order might not be strictly topological, but all unique dependencies will be present
+    return Array.from(flattened);
+  }
+
+  hasCircularDependency(pluginName: string, registry: RegistryService): boolean {
+    const cycles = this.detectCycles(pluginName, registry);
+    return cycles !== null && cycles.length > 0;
+  }
+}
