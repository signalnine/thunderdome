+
+    const sorted = depsGraph.topologicalSort('plugin-a', mockRegistry);
+    const expectedSort1 = ['plugin-d@1.0.0', 'plugin-b@1.0.0', 'plugin-c@1.0.0', 'plugin-a@1.0.0'];
+    const expectedSort2 = ['plugin-d@1.0.0', 'plugin-c@1.0.0', 'plugin-b@1.0.0', 'plugin-a@1.0.0'];
+    const isValidSort = (sorted.length === expectedSort1.length && sorted.every((node, index) => node === expectedSort1[index])) ||
+                        (sorted.length === expectedSort2.length && sorted.every((node, index) => node === expectedSort2[index]));
+    expect(isValidSort).toBe(true);
+  });
+
+  it('should throw error for topological sort on circular dependency', () => {
+    registerPlugins([
+      { name: 'plugin-a', version: '1.0.0', dependencies: { 'plugin-b': '^1.0.0' }, description: '', author: '', entryPoint: '', permissions: [] },
+      { name: 'plugin-b', version: '1.0.0', dependencies: { 'plugin-a': '^1.0.0' }, description: '', author: '', entryPoint: '', permissions: [] },
