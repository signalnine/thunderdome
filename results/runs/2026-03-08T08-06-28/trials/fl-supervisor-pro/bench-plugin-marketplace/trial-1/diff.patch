+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace, Marketplace } from '../src/index.js';
+import { PluginManifest } from '../src/types.js';
+
+describe('Marketplace Integration', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    // Use a fresh in-memory database for each test suite
+    marketplace = createMarketplace(':memory:');
+  });
+
+  it('should successfully install a simple plugin', async () => {
+    const manifest: PluginManifest = {
+      name: 'simple-plugin',
+      version: '1.0.0',
+      description: 'A simple test plugin',
+      author: 'Test Author',
+      dependencies: {},
+      entryPoint: 'console.log("Plugin installed"); _return("Success");',
+      permissions: [],
+    };
+
+    const result = await marketplace.installPlugin(manifest);
+
+    expect(result.resolvedDependencies).toEqual([]);
+    expect(result.sandboxResult.success).toBe(true);
+    expect(result.sandboxResult.output).toBe('Plugin installed');
+
+    // Verify plugin is in registry
+    const registeredPlugin = marketplace.registry.getVersion('simple-plugin', '1.0.0');
+    expect(registeredPlugin).toEqual(manifest);
+  });
+
+  it('should register plugin even if sandbox execution fails', async () => {
+    const manifest: PluginManifest = {
+      name: 'failing-plugin',
+      version: '1.0.0',
+      description: 'A plugin that fails to execute',
+      author: 'Test Author',
+      dependencies: {},
+      entryPoint: 'throw new Error("Execution failed");',
+      permissions: [],
+    };
+
+    const result = await marketplace.installPlugin(manifest);
+
+    expect(result.resolvedDependencies).toEqual([]);
+    expect(result.sandboxResult.success).toBe(false);
+    expect(result.sandboxResult.error).toBe('Execution failed');
+
+    // Verify plugin is still in registry
+    const registeredPlugin = marketplace.registry.getVersion('failing-plugin', '1.0.0');
+    expect(registeredPlugin).toEqual(manifest);
+  });
+
+  it('should fail to install if manifest is invalid', async () => {
+    const invalidManifest = {
+      version: '1.0.0',
+      entryPoint: 'console.log("hi");',
+      dependencies: {},
+      permissions: [],
+      description: '',
+      author: '',
+    } as PluginManifest; // Missing name
+
+    await expect(marketplace.installPlugin(invalidManifest)).rejects.toThrow(
+      'Plugin manifest must contain name, version, and entryPoint.'
+    );
+  });
+
+  it('should resolve dependencies during installation', async () => {
+    const depManifest: PluginManifest = {
+      name: 'my-dep',
+      version: '1.0.0',
+      description: 'A dependency',
+      author: 'Dep Author',
+      dependencies: {},
+      entryPoint: '',
+      permissions: [],
+    };
+    marketplace.registry.register(depManifest);
+
+    const mainManifest: PluginManifest = {
+      name: 'main-plugin',
+      version: '1.0.0',
+      description: 'Main plugin',
+      author: 'Main Author',
+      dependencies: { 'my-dep': '^1.0.0' },
+      entryPoint: 'console.log("Main plugin running");',
+      permissions: [],
+    };
+
+    const result = await marketplace.installPlugin(mainManifest);
+
+    expect(result.resolvedDependencies).toEqual([
+      { name: 'my-dep', version: '1.0.0', satisfies: '^1.0.0' },
+    ]);
+    expect(result.sandboxResult.success).toBe(true);
+  });
+
+  it('should reject installation if circular dependency is detected', async () => {
+    const pluginA: PluginManifest = {
+      name: 'plugin-a',
+      version: '1.0.0',
+      dependencies: { 'plugin-b': '^1.0.0' },
+      description: 'Plugin A description', author: 'Author A', entryPoint: 'console.log("A");', permissions: ['read']
+    };
+    const pluginB: PluginManifest = {
+      name: 'plugin-b',
+      version: '1.0.0',
+      dependencies: { 'plugin-a': '^1.0.0' },
+      description: 'Plugin B description', author: 'Author B', entryPoint: 'console.log("B");', permissions: ['write']
+    };
+
+    // Register them first for the dependency graph to find them
+    marketplace.registry.register(pluginA);
+    marketplace.registry.register(pluginB);
+
+    // Attempt to install one which will trigger the circular dependency check
+    await expect(marketplace.installPlugin(pluginA)).rejects.toThrow(
+      'Circular dependency detected for plugin plugin-a. Installation aborted.'
+    );
+  });
+
+  it('should not throw error when installing a plugin with a dependency that is not registered yet', async () => {
+    const mainManifest: PluginManifest = {
+      name: 'main-plugin-dep-not-registered',
+      version: '1.0.0',
+      description: 'Main plugin',
+      author: 'Main Author',
+      dependencies: { 'non-existent-dep': '^1.0.0' },
+      entryPoint: 'console.log("Main plugin running");',
+      permissions: [],
+    };
+
+    // The dependency 'non-existent-dep' is not registered
+    // The current implementation of installPlugin does not check for existence of dependencies during resolution
+    // it will just return an empty resolvedDependencies array for non-existent ones.
+    // The buildTree in deps will throw an error if a dependency is truly missing and it tries to resolve it.
+
+    await expect(marketplace.installPlugin(mainManifest)).rejects.toThrow(
+      'Failed to resolve all dependencies. Unresolved: non-existent-dep@^1.0.0'
+    );
+  });
+
+  it('should fail install if dependency resolution throws an error (e.g., non-satisfying version)', async () => {
+    const depManifest: PluginManifest = {
+      name: 'dep-fail',
+      version: '1.0.0',
+      description: 'A dependency',
+      author: 'Dep Author',
+      dependencies: {},
+      entryPoint: '',
+      permissions: [],
+    };
+    marketplace.registry.register(depManifest);
+
+    const mainManifest: PluginManifest = {
+      name: 'main-plugin-fail-dep-res',
+      version: '1.0.0',
+      description: 'Main plugin',
+      author: 'Main Author',
+      dependencies: { 'dep-fail': '^2.0.0' }, // Requires 2.0.0, but only 1.0.0 is available
+      entryPoint: 'console.log("Main plugin running");',
+      permissions: [],
+    };
+
+    // The `hasCircularDependency` and `buildTree` methods in `DependencyGraph` will throw if a dependency cannot be resolved.
+    // The `installPlugin` calls `hasCircularDependency` which in turn calls the registry.
+    // However, the resolution in installPlugin happens *before* the circular dependency check.
+    // The `buildTree` is not directly called in `installPlugin` yet.
+    // The current resolve implementation just omits unresolved dependencies.
+    // So, this test will pass if `installPlugin` does not explicitly check for full dependency resolution.
+    // For now, it will pass because the resolver omits. If we change installPlugin to be stricter, this test would change.
+
+    // Re-evaluating: The prompt states "Resolve its dependency versions against what's available in the registry".
+    // If a dependency cannot be resolved, it should ideally fail. The current `VersionResolver` *omits* unresolved.
+    // The `DependencyGraph.buildTree` *throws* on unresolved.
+    // The `installPlugin` doesn't use `buildTree` directly, but the `hasCircularDependency` *does*.
+    // So, if the circular dependency check tries to build a partial graph and hits an unresolvable dependency, it *will* throw.
+
+    await expect(marketplace.installPlugin(mainManifest)).rejects.toThrow(
+      'Failed to resolve all dependencies. Unresolved: dep-fail@^2.0.0'
+    );
+
+  });
+
+});
