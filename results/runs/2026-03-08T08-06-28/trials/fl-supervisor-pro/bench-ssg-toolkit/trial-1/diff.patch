diff --git a/src/plugins/markdown-ext.ts b/src/plugins/markdown-ext.ts
new file mode 100644
index 0000000..1224810
--- /dev/null
+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,85 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+import { remark } from 'remark';
+import remarkHtml from 'remark-html';
+import remarkGfm from 'remark-gfm';
+import remarkDirective from 'remark-directive';
+import { visit } from 'unist-util-visit';
+import * as cheerio from 'cheerio';
+
+// Custom remark plugin for admonitions
+function remarkAdmonitions() {
+  return (tree: any) => {
+    visit(tree, ['containerDirective'], (node) => {
+      if (['note', 'warning', 'tip'].includes(node.name)) {
+        const data = node.data || (node.data = {});
+        data.hName = 'div';
+        data.hProperties = { class: `admonition admonition-${node.name}` };
+      }
+    });
+  };
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, ctx: BuildContext): Promise<ContentFile> => {
+        if (!file.content) {
+          return file;
+        }
+
+        let processedContent = await remark()
+          .use(remarkGfm)
+          .use(remarkDirective)
+          .use(remarkAdmonitions)
+          .use(remarkHtml, { sanitize: false })
+          .process(file.content);
+
+        const $ = cheerio.load(String(processedContent));
+
+        // Fix footnote references
+        $('sup[id^="user-content-fnref-"]').each((_index, element) => {
+          const $sup = $(element);
+          const oldSupId = $sup.attr('id');
+          const fnNumber = oldSupId ? oldSupId.replace('user-content-fnref-', '') : '';
+
+          const $a = $sup.find('a');
+          if ($a.length) {
+            $a.attr('href', `#fn-${fnNumber}`);
+            $a.removeAttr('data-footnote-ref aria-describedby class'); // Remove specific attributes
+          }
+          $sup.removeAttr('id'); // Remove id from <sup>
+        });
+
+        // Fix footnote definitions
+        $('section[data-footnotes]').each((_index, element) => {
+          const $el = $(element);
+          $el.removeAttr('data-footnotes');
+          $el.find('h2.sr-only').remove();
+
+          $el.find('li[id^="user-content-fn-"]').each((_liIndex, liElement) => {
+            const $li = $(liElement);
+            const oldId = $li.attr('id');
+            const fnNumber = oldId ? oldId.replace('user-content-fn-', '') : '';
+            $li.attr('id', `fn-${fnNumber}`);
+
+            // Unwrap <p> tags directly inside <li>
+            $li.children('p').contents().unwrap();
+            // Trim whitespace from li content
+            $li.html($li.html()?.trim() || '');
+
+            // Remove back-reference links
+            $li.find('a[data-footnote-backref]').remove();
+          });
+        });
+
+        return {
+          ...file,
+          content: $('body').html() || '',
+        };
+      },
+    },
+  };
+}
