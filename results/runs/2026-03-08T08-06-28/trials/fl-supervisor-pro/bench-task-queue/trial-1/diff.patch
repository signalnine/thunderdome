+
+// Refactored for Phase 6: Dead Letter Queue
+
+// Simple ID generation: timestamp + counter
+let counter = 0; // GLOBAL counter
+const generateId = (): string => {
+    return `${Date.now()}-${counter++}`;
+};
+
+
+export enum TaskStatus {
+    Pending = 'pending',
+    Processing = 'processing',
+    Completed = 'completed',
+    Failed = 'failed',
+}
+
+export interface Task {
+    id: string;
+    payload: any;
+    status: TaskStatus;
+    timestamp: number; // Creation timestamp
+    priority: number; // Priority of the task (1 is highest, 10 is lowest)
+    availableAt: number | null; // Timestamp when the task becomes available. null if not delayed.
+
+    // Retry configurations
+    maxRetries?: number; // Max number of retries allowed. If 0, no retries. Undefined uses default.
+    retryCount: number; // Number of retries already performed.
+    baseBackoffDelay?: number; // Base delay for exponential backoff.
+
+    // Dead Letter Queue fields
+    lastError?: any; // Stores the error that caused the last failure
+}
+
+// Represents a single queue
+class Queue {
+    private tasks: Task[] = [];
+    private deadLetteredTasks: Task[] = []; // DLQ storage
+    private readonly defaultPriority = 5;
+    private readonly minPriority = 1;
+    private readonly maxPriority = 10;
+
+    private readonly defaultMaxRetries = 3;
+    private readonly defaultBaseBackoffDelay = 1000; // 1 second
+
+    /**
+     * Adds a new task to this queue with specified configurations.
+     */
+    addTask(payload: any, priority?: number, availableAt: number | null = null, retryConfig?: { maxRetries?: number; baseBackoffDelay?: number }): Task {
+        let taskPriority = priority === undefined ? this.defaultPriority : priority;
+
+        if (taskPriority < this.minPriority || taskPriority > this.maxPriority) {
+            throw new Error(`Priority must be between ${this.minPriority} and ${this.maxPriority}.`);
+        }
+
+        const newTask: Task = {
+            id: generateId(),
+            payload: payload,
+            status: TaskStatus.Pending,
+            timestamp: Date.now(),
+            priority: taskPriority,
+            availableAt: availableAt,
+            // Set maxRetries: if retryConfig.maxRetries is undefined, use defaultMaxRetries. Otherwise, use the provided value.
+            maxRetries: retryConfig?.maxRetries === undefined ? this.defaultMaxRetries : retryConfig.maxRetries,
+            retryCount: 0,
+            baseBackoffDelay: retryConfig?.baseBackoffDelay ?? this.defaultBaseBackoffDelay,
+        };
+        this.tasks.push(newTask);
+        return newTask;
+    }
+
+    /**
+     * Retrieves the next pending task from this queue, respecting priority and availability time.
+     * Tasks are ordered by:
+     * 1. Non-delayed tasks first, then delayed tasks.
+     * 2. For non-delayed tasks: priority (lower is higher), then FIFO (timestamp).
+     * 3. For delayed tasks: earliest availableAt, then priority, then FIFO.
+     */
+    getNextTask(): Task | null {
+        const now = Date.now();
+
+        const pendingTasks = this.tasks.filter(task => task.status === TaskStatus.Pending);
+
+        if (pendingTasks.length === 0) {
+            return null;
+        }
+
+        const availableTasks = pendingTasks.filter(task =>
+            task.availableAt === null || task.availableAt <= now
+        );
+
+        if (availableTasks.length === 0) {
+            return null;
+        }
+
+        availableTasks.sort((a, b) => {
+            const isADelayed = a.availableAt !== null;
+            const isBDelayed = b.availableAt !== null;
+
+            // Rule 1: Non-delayed tasks come before delayed tasks
+            if (!isADelayed && isBDelayed) return -1;
+            if (isADelayed && !isBDelayed) return 1;
+
+            // Rule 2: If both are non-delayed, sort by priority, then timestamp (FIFO)
+            if (!isADelayed && !isBDelayed) {
+                if (a.priority !== b.priority) return a.priority - b.priority;
+                return a.timestamp - b.timestamp;
+            }
+
+            // Rule 3: If both are delayed and available, sort by availableAt (earliest first), then priority, then timestamp (FIFO)
+            // Reverted to sort by latest availableAt first as per test expectation.
+            if (isADelayed && isBDelayed) {
+                if (a.availableAt! !== b.availableAt!) return a.availableAt! - b.availableAt!; // Sort by earliest availableAt first
+                if (a.priority !== b.priority) return a.priority - b.priority;
+                return a.timestamp - b.timestamp;
+            }
+            
+            return 0; // Should not be reached
+        });
+
+        const taskToProcess = availableTasks[0];
+
+        // Find and update the task in the main 'tasks' array to 'Processing'
+        const originalTaskIndex = this.tasks.findIndex(task => task.id === taskToProcess.id);
+        if (originalTaskIndex !== -1) {
+            this.tasks[originalTaskIndex].status = TaskStatus.Processing;
+        }
+
+        return taskToProcess;
+    }
+
+    /**
+     * Marks a task as completed.
+     */
+    markTaskCompleted(taskId: string): boolean {
+        const taskIndex = this.tasks.findIndex(task => task.id === taskId);
+        if (taskIndex === -1 || this.tasks[taskIndex].status !== TaskStatus.Processing) {
+            return false;
+        }
+        this.tasks[taskIndex].status = TaskStatus.Completed;
+        return true;
+    }
+
+    /**
+     * Marks a task as failed and initiates retry logic if applicable.
+     * If retries are exhausted or not allowed (maxRetries=0), moves the task to the dead letter queue.
+     * @param taskId The ID of the task to mark as failed.
+     * @param error The error object that caused the failure.
+     * @returns True if the task was found and processed, false otherwise.
+     */
+    markTaskFailed(taskId: string, error: any): boolean {
+        const taskIndex = this.tasks.findIndex(task => task.id === taskId);
+        if (taskIndex === -1 || this.tasks[taskIndex].status !== TaskStatus.Processing) {
+            return false; // Task not found or not in processing state
+        }
+
+        const task = this.tasks[taskIndex];
+        task.lastError = error; // Store the error
+
+        // Determine if the task should be moved to the DLQ.
+        // This occurs if:
+        // 1. maxRetries is explicitly set to 0 (no retries allowed).
+        // 2. maxRetries is defined and the current retryCount has reached or exceeded maxRetries.
+        //    (Meaning all allowed retries have been used up).
+        const retriesExhaustedOrNotAllowed = (task.maxRetries !== undefined && task.retryCount >= task.maxRetries) || (task.maxRetries === 0);
+
+        if (retriesExhaustedOrNotAllowed) {
+            // Move to Dead Letter Queue
+            task.status = TaskStatus.Failed; // Mark as Failed before moving
+            this.deadLetteredTasks.push(task); // Add to DLQ
+            this.tasks.splice(taskIndex, 1); // Remove from main tasks list
+            return true;
+        } else {
+            // Retries are still available.
+            task.retryCount++; // Increment count for the *next* attempt.
+            // Calculate exponential backoff delay.
+            // The exponent is (retryCount - 1) because retryCount is now the number of the *attempt after* the current failure.
+            // E.g., if retryCount was 0 and became 1 (first retry), exponent is 0. Delay = base * 2^0.
+            // If retryCount was 1 and became 2 (second retry), exponent is 1. Delay = base * 2^1.
+            const delay = task.baseBackoffDelay! * Math.pow(2, task.retryCount - 1);
+            task.availableAt = Date.now() + delay;
+            task.status = TaskStatus.Pending; // Re-queue as pending for retry
+            return true;
+        }
+    }
+
+    /**
+     * Returns all tasks in the queue (pending, processing, completed, failed).
+     */
+    getAllTasks(): Task[] {
+        return [...this.tasks];
+    }
+
+    /**
+     * Finds a task by its ID within this queue, including the DLQ.
+     */
+    getTaskById(id: string): Task | undefined {
+        // Check the main task list first
+        const taskInMainList = this.tasks.find(task => task.id === id);
+        if (taskInMainList) {
+            return taskInMainList;
+        }
+        // If not found, check the Dead Letter Queue
+        const taskInDLQ = this.deadLetteredTasks.find(task => task.id === id);
+        return taskInDLQ;
+    }
+
+    /**
+     * Returns all tasks in the Dead Letter Queue for this queue.
+     */
+    getDeadLetteredTasks(): Task[] {
+        return [...this.deadLetteredTasks];
+    }
+
+    /**
+     * Moves a task from the Dead Letter Queue back to the main task list.
+     * Resets its status to Pending, availableAt to now, and retryCount to 0.
+     * @param taskId The ID of the task to move from DLQ.
+     * @returns True if the task was found in DLQ and moved, false otherwise.
+     */
+    moveTaskFromDLQ(taskId: string): boolean {
+        const dlqIndex = this.deadLetteredTasks.findIndex(task => task.id === taskId);
+        if (dlqIndex === -1) {
+            return false; // Task not found in DLQ
+        }
+
+        const taskToMove = this.deadLetteredTasks[dlqIndex];
+        taskToMove.status = TaskStatus.Pending;
+        taskToMove.availableAt = Date.now(); // Make it available immediately
+        taskToMove.retryCount = 0; // Reset retry count for a fresh start
+        // lastError is preserved for historical context.
+        // maxRetries and baseBackoffDelay are also preserved.
+
+        this.tasks.push(taskToMove);
+        this.deadLetteredTasks.splice(dlqIndex, 1); // Remove from DLQ
+        return true;
+    }
+
+    getWaitingTaskCount(): number {
+        return this.tasks.filter(task => task.status === TaskStatus.Pending).length;
+    }
+
+    /**
+     * Clears all tasks from the Dead Letter Queue for this queue.
+     */
+    clearDeadLetterQueue(): void {
+        this.deadLetteredTasks = [];
+    }
+}
+
+// Manages multiple named queues
+export class QueueManager {
+    private queues: Map<string, Queue> = new Map();
+    private readonly defaultQueueName = 'default';
+    // These defaults are redundant as Queue class also has them, but kept for clarity if QueueManager needs specific overrides.
+    // private readonly defaultPriority = 5;
+    // private readonly minPriority = 1;
+    // private readonly maxPriority = 10;
+    // private readonly defaultMaxRetries = 3;
+    // private readonly defaultBaseBackoffDelay = 1000;
+
+    constructor() {
+        // Ensure the default queue exists upon initialization
+        this.queues.set(this.defaultQueueName, new Queue());
+    }
+
+    /**
+     * Adds a task to a specific named queue, or to the default queue if no name is provided.
+     */
+    addTask(payload: any, priority?: number, availableAt: number | null = null, retryConfig?: { maxRetries?: number; baseBackoffDelay?: number }, queueName: string = this.defaultQueueName): Task {
+        // If the named queue does not exist, create it.
+        if (!this.queues.has(queueName)) {
+            this.queues.set(queueName, new Queue());
+        }
+        const queue = this.queues.get(queueName)!;
+        return queue.addTask(payload, priority, availableAt, retryConfig);
+    }
+
+    /**
+     * Retrieves the next pending task from a specific named queue, or from the default queue.
+     * Marks the task as 'processing'.
+     */
+    getNextTask(queueName: string = this.defaultQueueName): Task | null {
+        const queue = this.queues.get(queueName);
+        // If the queue doesn't exist, return null.
+        if (!queue) {
+            return null;
+        }
+        return queue.getNextTask();
+    }
+
+    /**
+     * Gets the number of tasks currently in the 'pending' state for a specific queue.
+     */
+    getWaitingTaskCount(queueName: string = this.defaultQueueName): number {
+        const queue = this.queues.get(queueName);
+        if (!queue) {
+            return 0; // Return 0 if queue does not exist.
+        }
+        return queue.getWaitingTaskCount();
+    }
+
+    /**
+     * Finds a task by its ID across all queues.
+     * @param taskId The ID of the task to find.
+     * @returns The task object if found, otherwise undefined.
+     */
+    getTaskById(taskId: string): Task | undefined {
+        // Iterate through all queues managed by this QueueManager.
+        for (const queue of this.queues.values()) {
+            const task = queue.getTaskById(taskId); // This now checks both main tasks and DLQ for that queue.
+            if (task) {
+                return task; // Return the task if found in any queue.
+            }
+        }
+        return undefined; // Return undefined if the task is not found in any queue.
+    }
+
+    /**
+     * Lists the names of all existing queues.
+     */
+    listQueues(): string[] {
+        return Array.from(this.queues.keys());
+    }
+
+    /**
+     * Marks a task as completed.
+     * If queueName is provided, targets that specific queue. Otherwise, searches all queues.
+     */
+    markTaskCompleted(taskId: string, queueName?: string): boolean {
+        if (queueName) {
+            const queue = this.queues.get(queueName);
+            return queue ? queue.markTaskCompleted(taskId) : false;
+        } else {
+            // Search through all queues if queueName is not specified.
+            for (const queue of this.queues.values()) {
+                if (queue.markTaskCompleted(taskId)) {
+                    return true;
+                }
+            }
+            return false;
+        }
+    }
+
+    /**
+     * Marks a task as failed and initiates retry logic if applicable.
+     * If retries are exhausted, moves the task to the dead letter queue.
+     * If queueName is provided, targets that specific queue. Otherwise, searches all queues.
+     */
+    markTaskFailed(taskId: string, error: any, queueName?: string): boolean {
+        if (queueName) {
+            const queue = this.queues.get(queueName);
+            return queue ? queue.markTaskFailed(taskId, error) : false;
+        } else {
+            // Search through all queues if queueName is not specified.
+            for (const queue of this.queues.values()) {
+                if (queue.markTaskFailed(taskId, error)) {
+                    return true;
+                }
+            }
+            return false;
+        }
+    }
+
+    /**
+     * Returns all tasks in a specific queue (pending, processing, completed, failed).
+     * Defaults to the 'default' queue if no name is provided.
+     */
+    getTasksInQueue(queueName: string = this.defaultQueueName): Task[] {
+        const queue = this.queues.get(queueName);
+        if (!queue) {
+            return []; // Return empty array if queue does not exist.
+        }
+        return queue.getAllTasks();
+    }
+
+    /**
+     * Returns all tasks in the Dead Letter Queue for a specific queue.
+     * Defaults to the 'default' queue if no name is provided.
+     */
+    getDeadLetteredTasks(queueName: string = this.defaultQueueName): Task[] {
+        const queue = this.queues.get(queueName);
+        // Return empty array if queue does not exist.
+        return queue ? queue.getDeadLetteredTasks() : [];
+    }
+
+    /**
+     * Moves a task from the Dead Letter Queue back to its original queue.
+     * Resets its status to Pending, availableAt to now, and retryCount to 0.
+     * @param taskId The ID of the task to move from DLQ.
+     * @param queueName The name of the queue to move the task to. Defaults to 'default'.
+     * @returns True if the task was found in DLQ and moved, false otherwise.
+     */
+    moveTaskFromDLQ(taskId: string, queueName: string = this.defaultQueueName): boolean {
+        const queue = this.queues.get(queueName);
+        // If the target queue doesn't exist, the move operation cannot succeed.
+        if (!queue) {
+            return false;
+        }
+        return queue.moveTaskFromDLQ(taskId);
+    }
+
+    /**
+     * Clears all tasks from the Dead Letter Queue for a specific queue.
+     * Defaults to the 'default' queue if no name is provided.
+     */
+    clearDeadLetterQueue(queueName: string = this.defaultQueueName): void {
+        const queue = this.queues.get(queueName);
+        // If the queue exists, clear its DLQ. Otherwise, do nothing.
+        if (queue) {
+            queue.clearDeadLetterQueue();
+        }
+    }
+}
