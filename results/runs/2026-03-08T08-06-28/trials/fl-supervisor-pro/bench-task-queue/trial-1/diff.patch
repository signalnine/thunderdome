@@ -0,0 +1,846 @@
+
+import { QueueManager, TaskStatus, Task } from './index.ts';
+import { vi } from 'vitest';
+
+describe('QueueManager and Named Queues', () => {
+    let queueManager: QueueManager;
+    let mockDateNow: ReturnType<typeof vi.fn>;
+    const FIXED_TIMESTAMP_BASE = 1678886400000; // Base timestamp
+
+    beforeAll(() => {
+        mockDateNow = vi.spyOn(Date, 'now').mockImplementation(() => FIXED_TIMESTAMP_BASE);
+    });
+
+    afterAll(() => {
+        mockDateNow.mockRestore();
+    });
+
+    beforeEach(() => {
+        queueManager = new QueueManager();
+    });
+
+    // --- Phase 1 & 2 Tests (Existing) ---
+    it('should initialize with a default queue', () => {
+        expect(queueManager.listQueues()).toEqual(['default']);
+        expect(queueManager.getWaitingTaskCount()).toBe(0);
+    });
+
+    it('should add tasks to the default queue', () => {
+        const task1 = queueManager.addTask({ data: 'default task 1' });
+        const task2 = queueManager.addTask({ data: 'default task 2' });
+
+        expect(task1.payload).toEqual({ data: 'default task 1' });
+        expect(task1.status).toBe(TaskStatus.Pending);
+        expect(task1.timestamp).toBe(FIXED_TIMESTAMP_BASE);
+
+        expect(task2.payload).toEqual({ data: 'default task 2' });
+        expect(task2.status).toBe(TaskStatus.Pending);
+        expect(task2.timestamp).toBe(FIXED_TIMESTAMP_BASE);
+
+        expect(queueManager.getWaitingTaskCount()).toBe(2);
+    });
+
+    it('should retrieve tasks from the default queue in FIFO order', () => {
+        const task1 = queueManager.addTask({ data: 'default task 1' });
+        const task2 = queueManager.addTask({ data: 'default task 2' });
+
+        const retrievedTask1 = queueManager.getNextTask();
+        expect(retrievedTask1?.id).toBe(task1.id);
+        expect(retrievedTask1?.status).toBe(TaskStatus.Processing);
+        expect(queueManager.getWaitingTaskCount()).toBe(1);
