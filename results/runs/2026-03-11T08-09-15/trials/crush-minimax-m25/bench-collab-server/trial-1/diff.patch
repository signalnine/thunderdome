+import express, { Express, Request, Response, NextFunction } from 'express';
+import { createServer, Server as HttpServer } from 'http';
+import { WebSocketServer } from 'ws';
+import { Database, Document, Version } from './database.js';
+
+export interface App {
+  app: Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export interface CreateAppOptions {
+  dbPath?: string;
+}
+
+function generateId(): string {
+  return Math.random().toString(36).substring(2, 15) + 
+         Math.random().toString(36).substring(2, 15);
+}
+
+export function createApp(options?: CreateAppOptions): App {
+  const db = createDatabase(options?.dbPath);
+  const app = express();
+  
+  // Middleware
+  app.use(express.json());
+  
+  // CORS headers
+  app.use((req: Request, res: Response, next: NextFunction) => {
+    res.header('Access-Control-Allow-Origin', '*');
+    res.header('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS');
+    res.header('Access-Control-Allow-Headers', 'Content-Type, Authorization');
+    if (req.method === 'OPTIONS') {
+      return res.sendStatus(200);
+    }
+    next();
+  });
+  
+  // REST API Routes
+  
+  // Create document
+  app.post('/documents', (req: Request, res: Response) => {
+    try {
+      const { title, content = '' } = req.body;
+      
+      if (!title || typeof title !== 'string') {
+        return res.status(400).json({ error: 'Title is required' });
+      }
+      
+      const id = generateId();
+      const doc = db.createDocument(id, title, content);
+      
+      res.status(201).json({
+        id: doc.id,
+        title: doc.title,
+        content: doc.content,
+        created_at: doc.created_at,
+        updated_at: doc.updated_at
+      });
+    } catch (err) {
+      console.error('Error creating document:', err);
+      res.status(500).json({ error: 'Failed to create document' });
+    }
+  });
+  
+  // List all documents
+  app.get('/documents', (_req: Request, res: Response) => {
+    try {
+      const docs = db.getAllDocuments();
+      res.json(docs.map(doc => ({
+        id: doc.id,
+        title: doc.title,
+        content: doc.content,
+        created_at: doc.created_at,
+        updated_at: doc.updated_at
+      })));
+    } catch (err) {
+      console.error('Error listing documents:', err);
+      res.status(500).json({ error: 'Failed to list documents' });
+    }
+  });
+  
+  // Get single document
+  app.get('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const doc = db.getDocument(req.params.id);
+      
+      if (!doc) {
+        return res.status(404).json({ error: 'Document not found' });
+      }
+      
+      res.json({
+        id: doc.id,
+        title: doc.title,
+        content: doc.content,
+        created_at: doc.created_at,
+        updated_at: doc.updated_at
+      });
+    } catch (err) {
+      console.error('Error getting document:', err);
+      res.status(500).json({ error: 'Failed to get document' });
+    }
+  });
+  
+  // Update document
+  app.put('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const { title, content } = req.body;
+      const existingDoc = db.getDocument(req.params.id);
+      
+      if (!existingDoc) {
+        return res.status(404).json({ error: 'Document not found' });
+      }
+      
+      const newTitle = title !== undefined ? title : existingDoc.title;
+      const newContent = content !== undefined ? content : existingDoc.content;
+      
+      const updatedDoc = db.updateDocument(req.params.id, newTitle, newContent);
+      
+      if (!updatedDoc) {
+        return res.status(404).json({ error: 'Document not found' });
+      }
+      
+      res.json({
+        id: updatedDoc.id,
+        title: updatedDoc.title,
+        content: updatedDoc.content,
+        created_at: updatedDoc.created_at,
+        updated_at: updatedDoc.updated_at
+      });
+    } catch (err) {
+      console.error('Error updating document:', err);
+      res.status(500).json({ error: 'Failed to update document' });
+    }
+  });
+  
+  // Delete document
+  app.delete('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const success = db.deleteDocument(req.params.id);
+      
+      if (!success) {
+        return res.status(404).json({ error: 'Document not found' });
+      }
+      
+      res.status(204).send();
+    } catch (err) {
+      console.error('Error deleting document:', err);
+      res.status(500).json({ error: 'Failed to delete document' });
+    }
+  });
+  
+  // Get document version history
+  app.get('/documents/:id/versions', (req: Request, res: Response) => {
+    try {
+      const doc = db.getDocument(req.params.id);
+      
+      if (!doc) {
+        return res.status(404).json({ error: 'Document not found' });
+      }
+      
+      const versions = db.getVersions(req.params.id);
+      res.json(versions);
+    } catch (err) {
+      console.error('Error getting versions:', err);
+      res.status(500).json({ error: 'Failed to get versions' });
+    }
+  });
+  
+  // Health check
+  app.get('/health', (_req: Request, res: Response) => {
+    res.json({ status: 'ok' });
+  });
+  
+  // Create HTTP server
+  const server = createServer(app);
+  
+  // Create WebSocket server
+  const wss = createWSServer(db, server);
+  
+  let serverInstance: HttpServer | null = server;
+  
+  return {
+    app,
+    
+    start: (port: number = 0): Promise<number> => {
+      return new Promise((resolve, reject) => {
+        if (!serverInstance) {
+          return reject(new Error('Server already stopped'));
+        }
+        
+        serverInstance.listen(port, () => {
+          const address = serverInstance!.address();
+          const actualPort = typeof address === 'object' && address ? address.port : port;
+          console.log(`Server started on port ${actualPort}`);
+          resolve(actualPort);
+        });
+        
+        serverInstance.on('error', (err) => {
+          reject(err);
+        });
+      });
+    },
+    
+    stop: (): Promise<void> => {
+      return new Promise((resolve) => {
+        if (!serverInstance) {
+          resolve();
+          return;
+        }
+        
+        // Close all WebSocket connections
+        closeAllConnections(wss);
+        
+        // Close WebSocket server
+        wss.close(() => {
+          // Close HTTP server
+          serverInstance!.close(() => {
+            // Close database
+            db.close();
+            serverInstance = null;
+            console.log('Server stopped');
+            resolve();
+          });
+        });
+      });
+    }
+  };
+}
