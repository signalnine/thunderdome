+import { WebSocket, WebSocketServer } from 'ws';
+import { Database, Document } from './database.js';
+import { Operation, applyOperation, transform, validateOperation } from './ot.js';
+
+interface Client {
+  ws: WebSocket;
+  documentId: string;
+  clientId: string;
+}
+
+interface WSMessage {
+  type: 'sync' | 'operation' | 'ack' | 'error' | 'client-join' | 'client-leave';
+  clientId?: string;
+  documentId?: string;
+  version?: number;
+  content?: string;
+  operation?: Operation;
+  error?: string;
+}
+
+// Track active clients per document
+const documentClients = new Map<string, Map<string, Client>>();
+
+function getDocumentClients(documentId: string): Map<string, Client> {
+  let clients = documentClients.get(documentId);
+  if (!clients) {
+    clients = new Map();
+    documentClients.set(documentId, clients);
+  }
+  return clients;
+}
+
+export function createWSServer(db: Database, server: ReturnType<typeof import('http').createServer>) {
+  const wss = new WebSocketServer({ noServer: true });
+
+  // Handle WebSocket upgrade
+  server.on('upgrade', (request, socket, head) => {
+    const url = new URL(request.url || '', `http://${request.headers.host}`);
+    const pathMatch = url.pathname.match(/^\/ws\/([^/]+)$/);
+    
+    if (pathMatch) {
+      const documentId = pathMatch[1];
+      const document = db.getDocument(documentId);
+      
+      if (!document) {
+        socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+        socket.destroy();
+        return;
+      }
+      
+      wss.handleUpgrade(request, socket, head, (ws) => {
+        wss.emit('connection', ws, request, documentId);
+      });
+    } else {
+      socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+      socket.destroy();
+    }
+  });
+
+  wss.on('connection', (ws: WebSocket, request: import('http').IncomingMessage, documentId: string) => {
+    const clientId = generateClientId();
+    const client: Client = { ws, documentId, clientId };
+    
+    // Add to document's client list
+    const clients = getDocumentClients(documentId);
+    clients.set(clientId, client);
+    
+    console.log(`Client ${clientId} connected to document ${documentId}`);
+    
+    // Send sync message with current document state
+    const document = db.getDocument(documentId);
+    if (document) {
+      const syncMessage: WSMessage = {
+        type: 'sync',
+        clientId,
+        documentId,
+        content: document.content,
+        version: (db.getLatestVersion(documentId)?.version || 0)
+      };
+      ws.send(JSON.stringify(syncMessage));
+    }
+    
+    // Broadcast client join to others
+    broadcastToDocument(documentId, {
+      type: 'client-join',
+      clientId
+    }, clientId);
+    
+    // Handle incoming messages
+    ws.on('message', (data: Buffer) => {
+      try {
+        const message = JSON.parse(data.toString()) as WSMessage;
+        handleMessage(db, client, message);
+      } catch (err) {
+        console.error('Error parsing message:', err);
+        ws.send(JSON.stringify({
+          type: 'error',
+          error: 'Invalid message format'
+        }));
+      }
+    });
+    
+    // Handle disconnect
+    ws.on('close', () => {
+      clients.delete(clientId);
+      console.log(`Client ${clientId} disconnected from document ${documentId}`);
+      
+      // Broadcast client leave to others
+      broadcastToDocument(documentId, {
+        type: 'client-leave',
+        clientId
+      }, clientId);
+      
+      // Clean up empty document client maps
+      if (clients.size === 0) {
+        documentClients.delete(documentId);
+      }
+    });
+    
+    ws.on('error', (err) => {
+      console.error(`WebSocket error for client ${clientId}:`, err);
+    });
+  });
+  
+  return wss;
+}
+
+function handleMessage(db: Database, client: Client, message: WSMessage): void {
+  const { ws, documentId, clientId } = client;
+  
+  switch (message.type) {
+    case 'operation':
+      if (!message.operation) {
+        ws.send(JSON.stringify({
+          type: 'error',
+          error: 'Missing operation'
+        }));
+        return;
+      }
+      
+      if (!validateOperation(message.operation)) {
+        ws.send(JSON.stringify({
+          type: 'error',
+          error: 'Invalid operation'
+        }));
+        return;
+      }
+      
+      // Get current document state
+      const document = db.getDocument(documentId);
+      if (!document) {
+        ws.send(JSON.stringify({
+          type: 'error',
+          error: 'Document not found'
+        }));
+        return;
+      }
+      
+      // Apply operation to local document and save version
+      const oldContent = document.content;
+      const newContent = applyOperation(oldContent, message.operation);
+      
+      // Update document in database
+      const updatedDoc = db.updateDocument(documentId, document.title, newContent);
+      if (!updatedDoc) {
+        ws.send(JSON.stringify({
+          type: 'error',
+          error: 'Failed to update document'
+        }));
+        return;
+      }
+      
+      // Broadcast operation to other clients in the same document
+      const clients = getDocumentClients(documentId);
+      const broadcastMsg: WSMessage = {
+        type: 'operation',
+        clientId,
+        documentId,
+        operation: message.operation,
+        version: (db.getLatestVersion(documentId)?.version || 0)
+      };
+      
+      clients.forEach((c, id) => {
+        if (id !== clientId && c.ws.readyState === WebSocket.OPEN) {
+          c.ws.send(JSON.stringify(broadcastMsg));
+        }
+      });
+      
+      // Send ack to sender
+      ws.send(JSON.stringify({
+        type: 'ack',
+        clientId,
+        version: (db.getLatestVersion(documentId)?.version || 0)
+      }));
+      break;
+      
+    default:
+      ws.send(JSON.stringify({
+        type: 'error',
+        error: `Unknown message type: ${message.type}`
+      }));
+  }
+}
+
+function broadcastToDocument(documentId: string, message: WSMessage, excludeClientId?: string): void {
+  const clients = getDocumentClients(documentId);
+  const msgStr = JSON.stringify(message);
+  
+  clients.forEach((client, id) => {
+    if (id !== excludeClientId && client.ws.readyState === WebSocket.OPEN) {
+      client.ws.send(msgStr);
+    }
+  });
+}
+
+function generateClientId(): string {
+  return Math.random().toString(36).substring(2, 15);
+}
+
+export function closeAllConnections(wss: WebSocketServer): void {
+  documentClients.forEach((clients) => {
+    clients.forEach((client) => {
+      if (client.ws.readyState === WebSocket.OPEN) {
+        client.ws.close();
+      }
+    });
+  });
+  documentClients.clear();
+}
