@@ -0,0 +1,186 @@
+export interface Operation {
+  type: 'insert' | 'delete' | 'replace';
+  position: number;
+  text?: string;  // For insert
+  length?: number; // For delete/replace
+  content?: string; // For replace
+}
+
+export interface TransformedPair {
+  op1Prime: Operation;
+  op2Prime: Operation;
+}
+
+/**
+ * Transform two concurrent operations so they can be applied in either order
+ * and produce the same result.
+ * 
+ * This is a simple position-based OT implementation.
+ */
+export function transform(op1: Operation, op2: Operation): TransformedPair {
+  // Clone operations to avoid mutating originals
+  const op1Prime = { ...op1 };
+  const op2Prime = { ...op2 };
+
+  // Case 1: Both insert at same position - the one with higher "timestamp" or 
+  // client ID should come after. We'll use position adjustment.
+  if (op1.type === 'insert' && op2.type === 'insert') {
+    if (op1.position <= op2.position) {
+      // op1 inserts before op2, op2 needs to shift
+      op2Prime.position += op1.text?.length || 0;
+    } else {
+      // op2 inserts before op1, op1 needs to shift
+      op1Prime.position += op2.text?.length || 0;
+    }
+  }
+  
+  // Case 2: Both delete
+  else if (op1.type === 'delete' && op2.type === 'delete') {
+    if (op1.position < op2.position) {
+      // op1 deletes before op2
+      op2Prime.position -= Math.min(op1.length || 0, op2.position - op1.position);
+    } else if (op1.position > op2.position) {
+      // op2 deletes before op1
+      op1Prime.position -= Math.min(op2.length || 0, op1.position - op2.position);
+    } else {
+      // Same position - both delete same content, one becomes no-op
+      const len1 = op1.length || 0;
+      const len2 = op2.length || 0;
+      if (len1 === len2) {
+        // Both delete same amount at same position - both become no-ops
+        op1Prime.length = 0;
+        op2Prime.length = 0;
+      } else if (len1 > len2) {
+        op1Prime.length = len1 - len2;
+        op2Prime.length = 0;
+      } else {
+        op2Prime.length = len2 - len1;
+        op1Prime.length = 0;
+      }
+    }
+  }
+  
+  // Case 3: op1 insert, op2 delete
+  else if (op1.type === 'insert' && op2.type === 'delete') {
+    if (op1.position <= op2.position) {
+      // op1 inserts before delete point
+      op2Prime.position += op1.text?.length || 0;
+    } else if (op1.position >= op2.position + (op2.length || 0)) {
+      // op1 inserts after deleted region
+      op1Prime.position -= op2.length || 0;
+    } else {
+      // op1 inserts within deleted region - move to delete start
+      op1Prime.position = op2.position;
+    }
+  }
+  
+  // Case 4: op1 delete, op2 insert
+  else if (op1.type === 'delete' && op2.type === 'insert') {
+    if (op2.position <= op1.position) {
+      // op2 inserts before delete point
+      op1Prime.position += op2.text?.length || 0;
+    } else if (op2.position >= op1.position + (op1.length || 0)) {
+      // op2 inserts after deleted region
+      op2Prime.position -= op1.length || 0;
+    } else {
+      // op2 inserts within deleted region - move to delete start
+      op2Prime.position = op1.position;
+    }
+  }
+
+  // Case 5: Replace operations
+  else if (op1.type === 'replace' && op2.type === 'replace') {
+    if (op1.position <= op2.position) {
+      op2Prime.position += (op1.content?.length || 0) - (op1.length || 0);
+    } else {
+      op1Prime.position += (op2.content?.length || 0) - (op2.length || 0);
+    }
+  }
+
+  return { op1Prime, op2Prime };
+}
+
+/**
+ * Apply an operation to a document content string
+ */
+export function applyOperation(content: string, op: Operation): string {
+  switch (op.type) {
+    case 'insert':
+      if (op.text === undefined) return content;
+      const insertPos = Math.min(op.position, content.length);
+      return content.slice(0, insertPos) + op.text + content.slice(insertPos);
+    
+    case 'delete':
+      if (!op.length) return content;
+      const deletePos = Math.min(op.position, content.length);
+      const endPos = Math.min(deletePos + op.length, content.length);
+      return content.slice(0, deletePos) + content.slice(endPos);
+    
+    case 'replace':
+      if (!op.length) return content;
+      const replacePos = Math.min(op.position, content.length);
+      const replaceEndPos = Math.min(replacePos + op.length, content.length);
+      return content.slice(0, replacePos) + (op.content || '') + content.slice(replaceEndPos);
+    
+    default:
+      return content;
+  }
+}
+
+/**
+ * Validate an operation to ensure it's well-formed
+ */
+export function validateOperation(op: unknown): op is Operation {
+  if (!op || typeof op !== 'object') return false;
+  
+  const operation = op as Record<string, unknown>;
+  
+  if (typeof operation.type !== 'string') return false;
+  if (!['insert', 'delete', 'replace'].includes(operation.type)) return false;
+  if (typeof operation.position !== 'number' || operation.position < 0) return false;
+  
+  if (operation.type === 'insert') {
+    if (typeof operation.text !== 'string') return false;
+  }
+  
+  if (operation.type === 'delete') {
+    if (typeof operation.length !== 'number' || operation.length < 0) return false;
+  }
+  
+  if (operation.type === 'replace') {
+    if (typeof operation.length !== 'number' || operation.length < 0) return false;
+    if (typeof operation.content !== 'string') return false;
+  }
+  
+  return true;
+}
+
+/**
+ * Compose two consecutive operations into one (if possible)
+ */
+export function compose(op1: Operation, op2: Operation): Operation | null {
+  // If both are inserts at same position, can compose
+  if (op1.type === 'insert' && op2.type === 'insert') {
+    if (op1.position + (op1.text?.length || 0) === op2.position) {
+      return {
+        type: 'insert',
+        position: op1.position,
+        text: (op1.text || '') + (op2.text || '')
+      };
+    }
+  }
+  
+  // If both are deletes at same position, can compose
+  if (op1.type === 'delete' && op2.type === 'delete') {
+    if (op1.position === op2.position) {
+      return {
+        type: 'delete',
+        position: op1.position,
+        length: (op1.length || 0) + (op2.length || 0)
+      };
+    }
+  }
+  
+  // Can't compose these operations
+  return null;
+}
