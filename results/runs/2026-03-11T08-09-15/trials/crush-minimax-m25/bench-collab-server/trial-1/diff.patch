+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { join } from 'path';
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export interface Database {
+  getDocument(id: string): Document | undefined;
+  getAllDocuments(): Document[];
+  createDocument(id: string, title: string, content?: string): Document;
+  updateDocument(id: string, title: string, content: string): Document | undefined;
+  deleteDocument(id: string): boolean;
+  getVersions(documentId: string): Version[];
+  addVersion(documentId: string, version: number, content: string, operation: string | null): Version;
+  getLatestVersion(documentId: string): Version | undefined;
+  close(): void;
+}
+
+export function createDatabase(dbPath?: string): Database {
+  const db = new Database(dbPath || ':memory:');
+  
+  // Initialize schema
+  const schemaPath = join(process.cwd(), 'schema.sql');
+  const schema = readFileSync(schemaPath, 'utf-8');
+  db.exec(schema);
+  
+  // Enable foreign keys
+  db.pragma('foreign_keys = ON');
+
+  return {
+    getDocument(id: string): Document | undefined {
+      return db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Document | undefined;
+    },
+
+    getAllDocuments(): Document[] {
+      return db.prepare('SELECT * FROM documents ORDER BY updated_at DESC').all() as Document[];
+    },
+
+    createDocument(id: string, title: string, content: string = ''): Document {
+      const now = new Date().toISOString();
+      db.prepare(
+        'INSERT INTO documents (id, title, content, created_at, updated_at) VALUES (?, ?, ?, ?, ?)'
+      ).run(id, title, content, now, now);
+      
+      const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Document;
+      
+      // Create initial version
+      this.addVersion(id, 1, content, null);
+      
+      return doc;
+    },
+
+    updateDocument(id: string, title: string, content: string): Document | undefined {
+      const existing = this.getDocument(id);
+      if (!existing) return undefined;
+      
+      const now = new Date().toISOString();
+      db.prepare(
+        'UPDATE documents SET title = ?, content = ?, updated_at = ? WHERE id = ?'
+      ).run(title, content, now, id);
+      
+      // Get latest version number
+      const latestVersion = this.getLatestVersion(id);
+      const newVersion = (latestVersion?.version || 0) + 1;
+      
+      // Store the operation
+      const operation = JSON.stringify({
+        type: 'replace',
+        oldContent: existing.content,
+        newContent: content
+      });
+      
+      this.addVersion(id, newVersion, content, operation);
+      
+      return db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Document;
+    },
+
+    deleteDocument(id: string): boolean {
+      const result = db.prepare('DELETE FROM documents WHERE id = ?').run(id);
+      return result.changes > 0;
+    },
+
+    getVersions(documentId: string): Version[] {
+      return db.prepare(
+        'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+      ).all(documentId) as Version[];
+    },
+
+    addVersion(documentId: string, version: number, content: string, operation: string | null): Version {
+      const now = new Date().toISOString();
+      db.prepare(
+        'INSERT INTO versions (document_id, version, content, operation, created_at) VALUES (?, ?, ?, ?, ?)'
+      ).run(documentId, version, content, operation, now);
+      
+      return db.prepare('SELECT * FROM versions WHERE document_id = ? AND version = ?').get(
+        documentId, version
+      ) as Version;
+    },
+
+    getLatestVersion(documentId: string): Version | undefined {
+      return db.prepare(
+        'SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1'
+      ).get(documentId) as Version | undefined;
+    },
+
+    close(): void {
+      db.close();
+    }
+  };
+}
