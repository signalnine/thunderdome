@@ -0,0 +1,130 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<string>();
+  const beams: Beam[] = [{ row: source[0], col: source[1], dir: 'down' }];
+
+  // Track (row, col, dir) to avoid processing duplicate beams
+  const seen = new Set<string>();
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const { row, col, dir } = beam;
+
+    if (!inBounds(row, col, rows, cols)) continue;
+
+    const stateKey = `${row},${col},${dir}`;
+    if (seen.has(stateKey)) continue;
+    seen.add(stateKey);
+
+    visited.add(`${row},${col}`);
+
+    if (grid[row][col] === '^') {
+      // Splitter: split into down-left and down-right
+      const [nlr, nlc] = advance(row, col, 'down-left');
+      const [nrr, nrc] = advance(row, col, 'down-right');
+      beams.push({ row: nlr, col: nlc, dir: 'down-left' });
+      beams.push({ row: nrr, col: nrc, dir: 'down-right' });
+    } else {
+      // Continue in current direction
+      const [nr, nc] = advance(row, col, dir);
+      beams.push({ row: nr, col: nc, dir });
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // Each beam carries a path count (bigint).
+  // When a splitter splits, both children get the parent's count.
+  // When a beam exits, its count is added to the total.
+  // We use BFS/DFS but aggregate by (row, col, dir) state to avoid
+  // exponential blowup.
+
+  let totalPaths = 0n;
+
+  // Process row by row. Since beams always advance to row+1, this is
+  // naturally topologically ordered.
+  // incoming[row] = Map<"col,dir", bigint> accumulates path counts
+  const incoming: Map<string, bigint>[] = [];
+  for (let r = 0; r < rows; r++) {
+    incoming.push(new Map());
+  }
+
+  // Seed: source at (source[0], source[1]) going 'down' with count 1
+  const sourceKey = `${source[1]},down`;
+  incoming[source[0]].set(sourceKey, 1n);
+
+  for (let r = 0; r < rows; r++) {
+    for (const [key, count] of incoming[r]) {
+      const parts = key.split(',');
+      const col = parseInt(parts[0]);
+      const dir = parts[1] as Direction;
+
+      if (grid[r][col] === '^') {
+        // Splitter: emit down-left and down-right
+        const dirs: Direction[] = ['down-left', 'down-right'];
+        for (const newDir of dirs) {
+          const [nr, nc] = advance(r, col, newDir);
+          if (inBounds(nr, nc, rows, cols)) {
+            const nk = `${nc},${newDir}`;
+            incoming[nr].set(nk, (incoming[nr].get(nk) ?? 0n) + count);
+          } else {
+            totalPaths += count;
+          }
+        }
+      } else {
+        // Continue in current direction
+        const [nr, nc] = advance(r, col, dir);
+        if (inBounds(nr, nc, rows, cols)) {
+          const nk = `${nc},${dir}`;
+          incoming[nr].set(nk, (incoming[nr].get(nk) ?? 0n) + count);
+        } else {
+          totalPaths += count;
+        }
+      }
+    }
+  }
+
+  return totalPaths;
+}
