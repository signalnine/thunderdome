@@ -0,0 +1,69 @@
+import { EventBus } from "../bus.js";
+import { Events, ProductCreatedEvent, CatalogService } from "../types.js";
+import { v4 as uuidv4 } from "uuid";
+
+/**
+ * Catalog service implementation.
+ * Stores products in-memory and emits a PRODUCT_CREATED event when a new product is added.
+ */
+export function createCatalogService(bus: EventBus): CatalogService {
+  const products = new Map<string, { id: string; name: string; price: number; category: string }>();
+
+  function createProduct(name: string, price: number, category: string): string {
+    const id = uuidv4();
+    const product = { id, name, price, category };
+    products.set(id, product);
+    const payload: ProductCreatedEvent = { productId: id, name, price, category };
+    // fire event (no await needed, fire-and-forget)
+    void bus.emit(Events.PRODUCT_CREATED, payload);
+    return id;
+  }
+
+  function getProduct(productId: string) {
+    const p = products.get(productId);
+    return p ? { ...p } : null;
+  }
+
+  function listProducts(category?: string) {
+    const result: Array<{ id: string; name: string; price: number; category: string }> = [];
+    for (const p of products.values()) {
+      if (!category || p.category === category) {
+        result.push({ ...p });
+      }
+    }
+    return result;
+  }
+
+  function searchProducts(query: string) {
+    const lower = query.toLowerCase();
+    const result: Array<{ id: string; name: string; price: number; category: string }> = [];
+    for (const p of products.values()) {
+      if (p.name.toLowerCase().includes(lower) || p.category.toLowerCase().includes(lower)) {
+        result.push({ ...p });
+      }
+    }
+    return result;
+  }
+
+  function updateProduct(productId: string, updates: Partial<{ name: string; price: number; category: string }>) {
+    const product = products.get(productId);
+    if (!product) return;
+    if (updates.name !== undefined) product.name = updates.name;
+    if (updates.price !== undefined) product.price = updates.price;
+    if (updates.category !== undefined) product.category = updates.category;
+    // optionally emit inventory or price updated events - not required by spec
+  }
+
+  function removeProduct(productId: string) {
+    return products.delete(productId);
+  }
+
+  return {
+    createProduct,
+    getProduct,
+    listProducts,
+    searchProducts,
+    updateProduct,
+    removeProduct,
+  };
+}
