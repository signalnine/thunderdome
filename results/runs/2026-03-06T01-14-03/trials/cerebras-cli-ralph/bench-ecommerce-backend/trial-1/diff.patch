+import { EventBus } from "../bus.js";
+import { Events, OrderCreatedEvent, OrderStatusChangedEvent, OrderService, OrderStatus } from "../types.js";
+import { v4 as uuidv4 } from "uuid";
+
+/**
+ * Order service implementation.
+ * Manages orders lifecycle and emits events on creation and status changes.
+ */
+export function createOrderService(bus: EventBus): OrderService {
+  interface OrderRecord {
+    id: string;
+    userId: string;
+    cartId: string;
+    total: number;
+    status: OrderStatus;
+  }
+
+  const orders = new Map<string, OrderRecord>();
+
+  function createOrder(userId: string, cartId: string, total: number): string {
+    const id = uuidv4();
+    const order: OrderRecord = { id, userId, cartId, total, status: OrderStatus.PENDING };
+    orders.set(id, order);
+    const payload: OrderCreatedEvent = { orderId: id, userId, cartId, total };
+    void bus.emit(Events.ORDER_CREATED, payload);
+    return id;
+  }
+
+  function getOrder(orderId: string) {
+    const o = orders.get(orderId);
+    if (!o) return null;
+    return { id: o.id, userId: o.userId, status: o.status, total: o.total };
+  }
+
+  function updateStatus(orderId: string, status: OrderStatus): void {
+    const o = orders.get(orderId);
+    if (!o) return;
+    const previousStatus = o.status;
+    o.status = status;
+    const payload: OrderStatusChangedEvent = { orderId, status, previousStatus };
+    void bus.emit(Events.ORDER_STATUS_CHANGED, payload);
+  }
+
+  function listOrders(userId: string) {
+    const result: Array<{ id: string; status: OrderStatus; total: number }> = [];
+    for (const o of orders.values()) {
+      if (o.userId === userId) {
+        result.push({ id: o.id, status: o.status, total: o.total });
+      }
+    }
+    return result;
+  }
+
+  return { createOrder, getOrder, updateStatus, listOrders };
+}
