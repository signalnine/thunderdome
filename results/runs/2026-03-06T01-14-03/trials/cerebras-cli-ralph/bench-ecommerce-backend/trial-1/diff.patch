@@ -0,0 +1,57 @@
+import { EventBus } from "../bus.js";
+import { Events, InventoryUpdatedEvent, LowStockAlertEvent, InventoryService } from "../types.js";
+
+/**
+ * Inventory service implementation.
+ * Tracks stock levels and low‑stock thresholds.
+ * Emits INVENTORY_UPDATED on any stock change and LOW_STOCK_ALERT when quantity falls below threshold.
+ */
+export function createInventoryService(bus: EventBus): InventoryService {
+  const stock = new Map<string, number>();
+  const lowStockThreshold = new Map<string, number>();
+
+  function emitUpdate(productId: string, quantity: number) {
+    const payload: InventoryUpdatedEvent = { productId, quantity };
+    void bus.emit(Events.INVENTORY_UPDATED, payload);
+    const threshold = lowStockThreshold.get(productId);
+    if (threshold !== undefined && quantity < threshold) {
+      const alertPayload: LowStockAlertEvent = { productId, currentQuantity: quantity, threshold };
+      void bus.emit(Events.LOW_STOCK_ALERT, alertPayload);
+    }
+  }
+
+  function setStock(productId: string, quantity: number): void {
+    stock.set(productId, quantity);
+    emitUpdate(productId, quantity);
+  }
+
+  function getStock(productId: string): number {
+    return stock.get(productId) ?? 0;
+  }
+
+  function reserve(productId: string, quantity: number): boolean {
+    const current = getStock(productId);
+    if (current < quantity) return false;
+    stock.set(productId, current - quantity);
+    emitUpdate(productId, current - quantity);
+    return true;
+  }
+
+  function release(productId: string, quantity: number): void {
+    const current = getStock(productId);
+    stock.set(productId, current + quantity);
+    emitUpdate(productId, current + quantity);
+  }
+
+  function setLowStockThreshold(productId: string, threshold: number): void {
+    lowStockThreshold.set(productId, threshold);
+  }
+
+  return {
+    setStock,
+    getStock,
+    reserve,
+    release,
+    setLowStockThreshold,
+  };
+}
