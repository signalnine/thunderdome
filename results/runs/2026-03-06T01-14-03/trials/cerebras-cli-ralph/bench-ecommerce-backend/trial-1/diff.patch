@@ -0,0 +1,59 @@
+import { EventBus } from "../bus.js";
+import { Events, PaymentProcessedEvent, PaymentService, PaymentStatus } from "../types.js";
+
+/**
+ * Payment service implementation.
+ * Simulates asynchronous payment processing with configurable outcomes.
+ */
+export interface PaymentOptions {
+  /** Probability (0-1) of success */
+  successRate?: number;
+  /** Probability (0-1) of failure (overrides success if both true) */
+  failureRate?: number;
+  /** Simulated timeout in ms */
+  timeoutMs?: number;
+}
+
+export function createPaymentService(
+  bus: EventBus,
+  options: PaymentOptions = {},
+): PaymentService {
+  const { successRate = 1, failureRate = 0, timeoutMs = 0 } = options;
+
+  function randomOutcome(): PaymentStatus {
+    const r = Math.random();
+    if (r < failureRate) return PaymentStatus.FAILED;
+    if (r < failureRate + successRate) return PaymentStatus.SUCCESS;
+    return PaymentStatus.TIMEOUT;
+  }
+
+  async function processPayment(orderId: string, amount: number) {
+    // Simulate async delay
+    await new Promise((res) => setTimeout(res, timeoutMs));
+    const status = randomOutcome();
+    const result: { status: PaymentStatus; transactionId?: string; error?: string } = { status };
+    if (status === PaymentStatus.SUCCESS) {
+      result.transactionId = `tx-${Math.random().toString(36).substring(2, 15)}`;
+    } else if (status === PaymentStatus.FAILED) {
+      result.error = "Payment failed due to insufficient funds";
+    } else if (status === PaymentStatus.TIMEOUT) {
+      result.error = "Payment processing timeout";
+    }
+    const payload: PaymentProcessedEvent = {
+      orderId,
+      status,
+      transactionId: result.transactionId,
+      error: result.error,
+    };
+    void bus.emit(Events.PAYMENT_PROCESSED, payload);
+    return result;
+  }
+
+  async function refund(transactionId: string) {
+    // Simulate async operation, assume always succeeds after brief delay
+    await new Promise((res) => setTimeout(res, 10));
+    return true;
+  }
+
+  return { processPayment, refund };
+}
