--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,93 @@
+import { EventBus } from "../bus.js";
+import { Events, AnalyticsService, OrderCreatedEvent, PaymentProcessedEvent, CartUpdatedEvent, PaymentStatus } from "../types.js";
+import { OrderStatus } from "../types.js";
+
+/**
+ * Analytics service implementation.
+ * Listens to events and provides metrics.
+ */
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let revenue = 0;
+  const cartSet = new Set<string>(); // unique carts created
+  const orderSet = new Set<string>(); // unique orders created
+  const productOrderCounts = new Map<string, number>(); // productId -> total quantity ordered
+
+  // Store last known cart items for each cartId
+  const cartItemsMap = new Map<string, Array<{ productId: string; quantity: number }>>();
+
+  // Helper to increment event count
+  function inc(event: string) {
+    eventCounts.set(event, (eventCounts.get(event) ?? 0) + 1);
+  }
+
+  // Listen to all events of interest
+  bus.on(Events.CART_UPDATED, (payload: any) => {
+    inc(Events.CART_UPDATED);
+    const p = payload as { cartId: string; userId: string; items: Array<{ productId: string; quantity: number }> };
+    // Track unique carts creation: first time we see cartId
+    if (!cartSet.has(p.cartId)) {
+      cartSet.add(p.cartId);
+    }
+    cartItemsMap.set(p.cartId, p.items);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload: any) => {
+    inc(Events.ORDER_CREATED);
+    const p = payload as OrderCreatedEvent;
+    orderSet.add(p.orderId);
+    // Store order total maybe used later for revenue on successful payment
+    // We'll map orderId to total
+    orderTotals.set(p.orderId, p.total);
+    // Also store cartId to later retrieve items for product ranking
+    orderToCart.set(p.orderId, p.cartId);
+  });
+
+  // Store order totals and mapping
+  const orderTotals = new Map<string, number>(); // orderId -> total amount
+  const orderToCart = new Map<string, string>(); // orderId -> cartId
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: any) => {
+    inc(Events.PAYMENT_PROCESSED);
+    const p = payload as PaymentProcessedEvent;
+    if (p.status === PaymentStatus.SUCCESS) {
+      // Add revenue from order total if we have it
+      const total = orderTotals.get(p.orderId) ?? 0;
+      revenue += total;
+    }
+    // For product ranking, when payment succeeds, we can count items from associated cart
+    if (p.status === PaymentStatus.SUCCESS) {
+      const cartId = orderToCart.get(p.orderId);
+      if (cartId) {
+        const items = cartItemsMap.get(cartId) ?? [];
+        for (const item of items) {
+          productOrderCounts.set(item.productId, (productOrderCounts.get(item.productId) ?? 0) + item.quantity);
+        }
+      }
+    }
+  });
+
+  function getEventCount(eventType: string): number {
+    return eventCounts.get(eventType) ?? 0;
+  }
+
+  function getRevenue(): number {
+    return revenue;
+  }
+
+  function getConversionRate(): number {
+    if (cartSet.size === 0) return 0;
+    return orderSet.size / cartSet.size;
+  }
+
+  function getTopProducts(limit: number) {
+    // Return array sorted descending by count
+    const arr = Array.from(productOrderCounts.entries())
+      .map(([productId, count]) => ({ productId, count }))
+      .sort((a, b) => b.count - a.count)
+      .slice(0, limit);
+    return arr;
+  }
+
+  return { getEventCount, getRevenue, getConversionRate, getTopProducts };
+}
diff --git a/src/cart/index.ts b/src/cart/index.ts
new file mode 100644
index 0000000..b187738
--- /dev/null
+++ b/src/cart/index.ts
@@ -0,0 +1,76 @@
+import { EventBus } from "../bus.js";
+import { Events, CartUpdatedEvent, CartService } from "../types.js";
+import { v4 as uuidv4 } from "uuid";
+
+/**
+ * Cart service implementation.
+ * Manages shopping carts per user. Emits CART_UPDATED on any change.
+ */
+export function createCartService(bus: EventBus): CartService {
+  // cartId -> { id, userId, items: Map<productId, quantity> }
+  const carts = new Map<string, { id: string; userId: string; items: Map<string, number> }>();
+
+  function emitUpdate(cartId: string, userId: string) {
+    const cart = carts.get(cartId);
+    if (!cart) return;
+    const itemsArray = Array.from(cart.items.entries()).map(([productId, quantity]) => ({ productId, quantity }));
+    const payload: CartUpdatedEvent = { cartId, userId, items: itemsArray };
+    void bus.emit(Events.CART_UPDATED, payload);
+  }
+
+  function createCart(userId: string): string {
+    const id = uuidv4();
+    carts.set(id, { id, userId, items: new Map() });
+    emitUpdate(id, userId);
+    return id;
+  }
+
+  function addItem(cartId: string, productId: string, quantity: number): void {
+    const cart = carts.get(cartId);
+    if (!cart) return;
+    const current = cart.items.get(productId) ?? 0;
+    cart.items.set(productId, current + quantity);
+    emitUpdate(cartId, cart.userId);
+  }
+
+  function removeItem(cartId: string, productId: string): void {
+    const cart = carts.get(cartId);
+    if (!cart) return;
+    cart.items.delete(productId);
+    emitUpdate(cartId, cart.userId);
+  }
+
+  function updateQuantity(cartId: string, productId: string, quantity: number): void {
+    const cart = carts.get(cartId);
+    if (!cart) return;
+    if (quantity <= 0) {
+      cart.items.delete(productId);
+    } else {
+      cart.items.set(productId, quantity);
+    }
+    emitUpdate(cartId, cart.userId);
+  }
+
+  function getCart(cartId: string) {
+    const cart = carts.get(cartId);
+    if (!cart) return null;
+    const itemsArray = Array.from(cart.items.entries()).map(([productId, quantity]) => ({ productId, quantity }));
+    return { id: cart.id, userId: cart.userId, items: itemsArray };
+  }
+
+  function clearCart(cartId: string): void {
+    const cart = carts.get(cartId);
+    if (!cart) return;
+    cart.items.clear();
+    emitUpdate(cartId, cart.userId);
+  }
+
+  return {
+    createCart,
+    addItem,
