+import { EventBus } from "../bus.js";
+import { Events, NotificationSentEvent, NotificationService, OrderCreatedEvent } from "../types.js";
+
+/**
+ * Notifications service implementation.
+ * Subscribes users to receive notifications.
+ * Listens for ORDER_STATUS_CHANGED and PAYMENT_PROCESSED events.
+ */
+export function createNotificationsService(bus: EventBus): NotificationService {
+  // Map userId -> array of notifications
+// Map orderId -> userId for notification lookup
+const orderIdToUserId = new Map<string, string>();
+  const userNotifications = new Map<string, Array<{ type: string; message: string; timestamp: number }>>();
+
+  // Simple subscription tracking (not used beyond placeholder)
+  const subscribedUsers = new Set<string>();
+
+  function subscribe(userId: string): void {
+    subscribedUsers.add(userId);
+    if (!userNotifications.has(userId)) {
+      userNotifications.set(userId, []);
+    }
+  }
+
+  function getNotifications(userId: string) {
+    return userNotifications.get(userId) ?? [];
+  }
+
+  // Helper to add notification
+  function addNotification(userId: string, type: string, message: string) {
+    const timestamp = Date.now();
+    if (!userNotifications.has(userId)) {
+      userNotifications.set(userId, []);
+    }
+    userNotifications.get(userId)!.push({ type, message, timestamp });
+    const payload: NotificationSentEvent = { userId, type, message };
+    void bus.emit(Events.NOTIFICATION_SENT, payload);
+  }
+
+  // Listen for order creation to map orderId to userId
+bus.on(Events.ORDER_CREATED, (payload: any) => {
+  const p = payload as OrderCreatedEvent;
+  orderIdToUserId.set(p.orderId, p.userId);
+});
+
+// Listen for order status changes
+  bus.on(Events.ORDER_STATUS_CHANGED, (payload: any) => {
+    const p = payload as { orderId: string; status: any; previousStatus: any };
+    const userId = orderIdToUserId.get(p.orderId);
+    if (userId) {
+      const message = `Order ${p.orderId} status changed from ${p.previousStatus} to ${p.status}`;
+      addNotification(userId, "order_status", message);
+    }
+  });
+
+  // Listen for payment processed events
+  bus.on(Events.PAYMENT_PROCESSED, (payload: any) => {
+    const p = payload as { orderId: string; status: any; transactionId?: string; error?: string };
+    // In a full implementation we'd map orderId->userId, but for now we record a generic notification.
+    const message = `Payment ${p.status} for order ${p.orderId}`;
+    // broadcast to all subscribed users (simplification)
+const userId = orderIdToUserId.get(p.orderId);
+     if (userId) {
+       addNotification(userId, "payment", message);
+     }
+  });
+
+  return { subscribe, getNotifications };
+}
