  // Store last known cart items for each cartId\n  const cartItemsMap = new Map<string, Array<{ productId: string; quantity: number }>>();\n\n  // Helper to increment event count\n  function inc(event: string) {\n    eventCounts.set(event, (eventCounts.get(event) ?? 0) + 1);\n  }\n\n  // Listen to all events of interest\n  bus.on(Events.CART_UPDATED, (payload: any) => {\n    inc(Events.CART_UPDATED);\n    const p = payload as { cartId: string; userId: string; items: Array<{ productId: string; quantity: number }> };\n    // Track unique carts creation: first time we see cartId\n    if (!cartSet.has(p.cartId)) {\n      cartSet.add(p.cartId);\n    }\n    cartItemsMap.set(p.cartId, p.items);\n  });\n\n  bus.on(Events.ORDER_CREATED, (payload: any) => {\n    inc(Events.ORDER_CREATED);\n    const p = payload as OrderCreatedEvent;\n    orderSet.add(p.orderId);\n    // Store order total maybe used later for revenue on successful payment\n    // We'll map orderId to total\n    orderTotals.set(p.orderId, p.total);\n    // Also store cartId to later retrieve items for product ranking\n    orderToCart.set(p.orderId, p.cartId);\n  });\n\n  // Store order totals and mapping\n  const orderTotals = new Map<string, number>(); // orderId -> total amount\n  const orderToCart = new Map<string, string>(); // orderId -> cartId\n\n  bus.on(Events.PAYMENT_PROCESSED, (payload: any) => {\n    inc(Events.PAYMENT_PROCESSED);\n    const p = payload as PaymentProcessedEvent;\n    if (p.status === PaymentStatus.SUCCESS) {\n      // Add revenue from order total if we have it\n      const total = orderTotals.get(p.orderId) ?? 0;\n      revenue += total;\n    }\n    // For product ranking, when payment succeeds, we can count items from associated cart\n    if (p.status === \"success\" || p.status === \"SUCCESS\") {\n      const cartId = orderToCart.get(p.orderId);\n      if (cartId) {\n        const items = cartItemsMap.get(cartId) ?? [];\n        for (const item of items) {\n          productOrderC