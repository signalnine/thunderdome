@@ -0,0 +1,61 @@
+import { EventBus } from "../bus.js";
+import { Events, PriceCalculatedEvent, PricingService } from "../types.js";
+
+/**
+ * Pricing service implementation.
+ * Tracks product prices and discount codes.
+ * Emits PRICE_CALCULATED when calculateTotal is called.
+ */
+export function createPricingService(bus: EventBus): PricingService {
+  const productPrices = new Map<string, number>(); // productId -> price
+  const discountCodes = new Map<string, number>(); // code -> percentage (0-100)
+
+  // Listen for product creation to store price
+  bus.on(Events.PRODUCT_CREATED, (payload: any) => {
+    const p = payload as { productId: string; price: number };
+    productPrices.set(p.productId, p.price);
+  });
+
+  function getPrice(productId: string): number {
+    return productPrices.get(productId) ?? 0;
+  }
+
+  function addDiscountCode(code: string, percentage: number): void {
+    discountCodes.set(code, percentage);
+  }
+
+  function calculateTotal(
+    items: Array<{ productId: string; quantity: number; price: number }>,
+    discountCode?: string,
+  ) {
+    // Use provided price per item, but fallback to stored price if missing/zero
+    let subtotal = 0;
+    for (const item of items) {
+      const unitPrice = item.price ?? getPrice(item.productId);
+      subtotal += unitPrice * item.quantity;
+    }
+
+    let discount = 0;
+    if (discountCode && discountCodes.has(discountCode)) {
+      const perc = discountCodes.get(discountCode)!;
+      discount = (subtotal * perc) / 100;
+    }
+    const afterDiscount = subtotal - discount;
+    const tax = afterDiscount * 0.1; // 10% tax
+    const total = afterDiscount + tax;
+
+    const payload: PriceCalculatedEvent = {
+      cartId: "", // caller may not care; placeholder
+      subtotal,
+      discount,
+      tax,
+      total,
+    };
+    // Emit event (cartId unknown, could be omitted but interface requires cartId)
+    void bus.emit(Events.PRICE_CALCULATED, payload);
+
+    return { subtotal, discount, tax, total };
+  }
+
+  return { calculateTotal, addDiscountCode, getPrice };
+}
