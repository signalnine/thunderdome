tock.set(productId, current + quantity);\n    emitUpdate(productId, current + quantity);\n  }\n\n  function setLowStockThreshold(productId: string, threshold: number): void {\n    lowStockThreshold.set(productId, threshold);\n  }\n\n  return {\n    setStock,\n    getStock,\n    reserve,\n    release,\n    setLowStockThreshold,\n  };\n}\n"},"output":"Wrote file successfully.","title":"src/inventory/index.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/inventory/index.ts","exists":false,"truncated":false},"time":{"start":1772759684057,"end":1772759687070}}}}
