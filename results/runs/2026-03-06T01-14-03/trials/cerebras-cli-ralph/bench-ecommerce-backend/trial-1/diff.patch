 cannot get userId here.\n    // Assuming that order service also emits ORDER_CREATED which includes userId, we could store mapping.\n    // For simplicity, we will skip notifications for status changes unless mapping exists.\n  });\n\n  // Listen for payment processed events\n  bus.on(Events.PAYMENT_PROCESSED, (payload: any) => {\n    const p = payload as { orderId: string; status: any; transactionId?: string; error?: string };\n    // In a full implementation we'd map orderId->userId, but for now we record a generic notification.\n    const message = `Payment ${p.status} for order ${p.orderId}`;\n    // broadcast to all subscribed users (simplification)\n    for (const userId of subscribedUsers) {\n      addNotification(userId, \"payment\", message);\n    }\n  });\n\n  return { subscribe, getNotifications };\n}\n"},"output":"Wrote file successfully.","title":"src/notifications/index.ts","metadata":{"diagnostics":{"/workspace/src/cart/index.ts":[],"/workspace/src/catalog/index.ts":[],"/workspace/src/inventory/index.ts":[],"/workspace/src/bus.ts":[],"/workspace/src/types.ts":[],"/workspace/src/pricing/index.ts":[],"/workspace/src/orders/index.ts":[],"/workspace/src/payment/index.ts":[{"range":{"start":{"line":29,"character":49},"end":{"line":29,"character":55}},"message":"'amount' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"},{"range":{"start":{"line":51,"character":24},"end":{"line":51,"character":37}},"message":"'transactionId' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}],"/workspace/src/notifications/index.ts":[{"range":{"start":{"line":39,"character":10},"end":{"line":39,"character":11}},"message":"'p' is declared but its value is never read.","severity":4,"code":6133,"source":"typescript"}]},"filepath":"/workspace/src/notifications/index.ts","exists":false,"truncated":false},"time":{"start":1772759796487,"end":1772759799494}}}}
