+    it('receives edit broadcasts from other clients', async () => {
+      const client2 = new WebSocket(`ws://localhost:${port}/?docId=test-doc-collab`);
+      const editsReceived: any[] = [];
+
+      client2.onmessage = (event) => {
+        const data = JSON.parse(event.data);
+        if (data.type === 'edit') {
+          editsReceived.push(data);
+        }
+      };
+
+      clientWs.onmessage = (event) => {
+        const data = JSON.parse(event.data);
+        if (data.type === 'edit') {
+          const operation = data.operation;
+          const client2Operation = {
+            type: 'insert',
+            position: 0,
+            text: 'Added text'
+          };
+
+          // Apply transformation
+          const transformed = transformOperation(client2Operation, {
+            type: 'delete',
+            position: 0,
+            length: operation.text.length
+          });
+
+          // Apply to base content
+          const newContent = applyOperation(data.content, transformed);
+
+          client2.send(JSON.stringify({
+            type: 'edit',
+            operation: transformed,
+            localVersion: data.version,
+            appliedVersion: data.version
+          }));
+        }
+      };
