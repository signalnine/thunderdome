+async function waitForVersion(db: any, docId: string, expectedVersion: number, retries = 10) {
+  for (let i = 0; i < retries; i++) {
+    const doc = db.getVersionedDocument(docId);
+    if (doc?.version === expectedVersion) return;
+    await new Promise(resolve => setTimeout(resolve, 100));
+  }
+}
+
+function addVersionHistory(db: any, docId: string, version: number, content: string) {
+  const stmt = db.db.prepare(`
+    INSERT INTO versions (document_id, version, content)
+    VALUES (?, ?, ?)
+  `);
+  stmt.run(docId, version, content);
