+export type Operation = {
+  type: 'insert' | 'delete',
+  position: number,
+  text?: string,
+  length?: number
+};
+
+// Apply operation to text
+export function applyOperation(baseText: string, op: Operation): string {
+  if (op.type === 'delete') {
+    const position = Math.min(op.position, baseText.length);
+    const length = op.length ?? 1;
+    return baseText.slice(0, position) + baseText.slice(position + length);
+  } else if (op.type === 'insert') {
+    const position = Math.min(op.position, baseText.length);
+    const text = op.text ?? '';
+    return baseText.slice(0, position) + text + baseText.slice(position);
+  }
+  return baseText;
+}
+
+// Transform applied operation against another operation (OT)
+// This handles concurrent insertions/deletions
+export function transformOperation(applied: Operation, base: Operation): Operation {
+  const posDiff = base.type === 'insert'
+    ? (base.text?.length ?? 0)
+    : -(base.length ?? 1);
+
+  const newPos = applied.position + posDiff;
+
+  if (base.type === 'insert' && applied.type === 'insert') {
+    // Two concurrent insertions - handle position shift
+    if (base.position >= applied.position) {
+      return { ...applied, position: applied.position + (base.text?.length ?? 0) };
+    }
+    return applied;
+  }
+
+  if (base.type === 'delete' && applied.type === 'delete') {
+    // Two concurrent deletions
+    const endBase = base.position + (base.length ?? 1);
+    const endApplied = applied.position + (applied.length ?? 1);
+
+    if (applied.position >= endBase) {
+      return { ...applied, position: applied.position - (base.length ?? 1) };
+    }
+    if (base.position >= endApplied) {
+      return { ...applied, position: applied.position - (base.length ?? 1) };
+    }
+    return applied;
+  }
+
+  if (base.type === 'insert' && applied.type === 'delete') {
+    // Insert after delete - position unchanged
+    return applied;
+  }
+
+  if (base.type === 'delete' && applied.type === 'insert') {
+    // Delete before insert - position unchanged (text won't be deleted)
+    return applied;
+  }
+
+  return applied;
+}
