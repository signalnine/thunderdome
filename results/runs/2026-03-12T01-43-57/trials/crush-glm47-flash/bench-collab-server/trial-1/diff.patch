+import { WebSocketServer } from 'ws';
+import { applyOperation, transformOperation, type Operation } from './ot.js';
+import { Database, getVersionedDocument, getConnectionsForDocument, type Connection } from './db.js';
+
+export function setupWebSocket(db: any) {
+  const wss = new WebSocketServer({ noServer: true });
+
+  wss.on('connection', async (ws: any, req: any) => {
+    // Parse document ID from URL query
+    const url = new URL(req.url || '', `http://${req.headers.host}`);
+    const docId = url.searchParams.get('docId');
+
+    if (!docId) {
+      ws.close(1008, 'Missing docId parameter');
+      return;
+    }
+
+    // Get current document state
+    const doc = db.getVersionedDocument(docId);
+
+    if (!doc) {
+      ws.close(1008, 'Document not found');
+      return;
+    }
+
+    // Send initial sync
+    ws.send(JSON.stringify({
+      type: 'sync',
+      id: doc.id,
+      content: doc.content,
+      version: doc.version
+    }));
+
+    // Add to active connections
+    db.addConnection(docId, ws);
+
+    ws.on('message', async (message: string) => {
+      try {
+        const parsed = JSON.parse(message);
+
+        if (parsed.type === 'edit') {
+          await handleEdit(ws, db, docId, parsed);
+        } else {
+          ws.close(1008, 'Unknown message type');
+        }
+      } catch (error) {
+        ws.send(JSON.stringify({
+          type: 'error',
+          error: 'Invalid message format'
+        }));
+      }
+    });
+
+    ws.on('close', () => {
+      db.removeConnection(docId, ws);
+    });
+  });
+
+  return wss;
+}
+
+async function handleEdit(ws: any, db: any, docId: string, data: any) {
+  const { operation, localVersion, appliedVersion } = data;
+
+  if (!operation) {
+    ws.close(1008, 'No operation provided');
+    return;
+  }
+
+  const op = transformOperation(operation, {
+    type: appliedVersion ? 'delete' : 'insert',
+    position: appliedVersion || operation.position,
+    text: operation.text,
+    length: operation.length
+  });
+
+  // Get current document content
+  const doc = db.getVersionedDocument(docId);
+  if (!doc) {
+    ws.close(1008, 'Document not found');
+    return;
+  }
+
+  // Apply the transformed operation
+  const newContent = applyOperation(doc.content, op);
+
+  // Increment version and save
+  const newVersion = db.incrementDocumentVersion(docId);
+  db.updateDocument(docId, newContent, newVersion);
+  db.addVersionHistory(docId, newVersion, newContent);
+
+  // Broadcast to all other connected clients
+  const connections = db.getConnectionsForDocument(docId);
+  const syncMessage = JSON.stringify({
+    type: 'edit',
+    id: doc.id,
+    content: newContent,
+    version: newVersion,
+    operation: op
+  });
+
+  for (const conn of connections) {
+    if (conn !== ws) {
+      const success = conn.send(syncMessage);
+      if (!success) {
+        db.removeConnection(docId, conn);
+      }
+    }
+  }
+
+  // Send confirmation back to the sender
+  ws.send(JSON.stringify({
+    type: 'edit',
+    id: doc.id,
+    content: newContent,
+    version: newVersion
+  }));
+}
