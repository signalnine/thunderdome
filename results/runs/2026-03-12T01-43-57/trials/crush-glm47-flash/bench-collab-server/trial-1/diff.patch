+      // Create 10 clients
+      for (let i = 0; i < 10; i++) {
+        const ws = new WebSocket(`ws://localhost:${port}/?docId=concurrent-doc`);
+        await new Promise((resolve) => {
+          ws.onopen = resolve;
+        });
+        clients.push(ws);
+      }
+
+      // Have clients make edits
+      const operations = [
+        'insert',
+        'delete',
+        'insert',
+        'delete',
+        'reconnect',
+        'insert',
+        'new-line',
+        'delete'
