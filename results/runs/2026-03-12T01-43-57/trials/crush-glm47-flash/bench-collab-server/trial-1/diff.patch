+import express, { Application } from 'express';
+import { createServer } from 'http';
+import { createDatabase } from './db.js';
+import { setupWebSocket as setupWebsocket } from './ws.js';
+import { restApiRouter } from './rest.js';
+
+let db: any;
+
+export function setDatabase(database: any) {
+  db = database;
+}
+
+export async function createApp(databasePath: string = 'documents.db') {
+  // Initialize database
+  const database = await createDatabase(databasePath);
+  setDatabase(database);
+
+  // Create Express app
+  const app: Application = express();
+  app.use(express.json());
+
+  // Mount REST API
+  app.use('/api', restApiRouter);
+
+  // Create HTTP server
+  const server = createServer(app);
+
+  // Setup WebSocket
+  const wss = setupWebsocket(database);
+
+  // Upgrade HTTP to WebSocket
+  server.on('upgrade', (req: any, socket: any, head: Buffer) => {
+    wss.handleUpgrade(req, socket, head, (ws: any) => {
+      wss.emit('connection', ws, req);
+    });
+  });
+
+  let portNumber = 0;
+
+  return {
+    app,
+    start,
+    stop
+  };
+
+  function start(portArg?: number) {
+    portNumber = portArg ?? 0;
+    return new Promise<number>((resolve, reject) => {
+      server.listen(portNumber, () => {
+        const address = server.address() as { port: number };
+        resolve(address.port);
+      });
+
+      server.on('error', (err: Error) => {
+        reject(err);
+      });
+    });
+  }
+
+  function stop() {
+    return new Promise<void>((resolve, reject) => {
+      server.close((err?: Error) => {
+        if (err) {
+          reject(err);
+        } else {
+          database?.db.close();
+          resolve();
+        }
+      });
+    });
+  }
+}
