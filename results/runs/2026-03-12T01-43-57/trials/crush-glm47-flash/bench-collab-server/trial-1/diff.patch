+import { Request, Response, Router } from 'express';
+
+const router = Router();
+
+// Create document
+router.post('/documents', (req: Request, res: Response) => {
+  try {
+    const { id, title, content } = req.body;
+
+    if (!id || !title || content === undefined) {
+      return res.status(400).json({ error: 'Missing required fields: id, title, content' });
+    }
+
+    // Generate ID if not provided
+    const docId = id || `doc-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
+
+    (globalThis as any).db.createDocument(docId, title, content || '');
+
+    res.status(201).json({
+      id: docId,
+      title,
+      content: content || '',
+      version: 0
+    });
+  } catch (error) {
+    res.status(500).json({ error: 'Failed to create document' });
+  }
+});
+
+// Get document by ID
+router.get('/documents/:id', (req: Request, res: Response) => {
+  try {
+    const docId = req.params.id;
+
+    const doc = (globalThis as any).db.getVersionedDocument(docId);
+
+    if (!doc) {
+      return res.status(404).json({ error: 'Document not found' });
+    }
+
+    res.json(doc);
+  } catch (error) {
+    res.status(500).json({ error: 'Failed to get document' });
+  }
+});
+
+// List all documents
+router.get('/documents', (req: Request, res: Response) => {
+  try {
+    const docIds = (globalThis as any).db.getDocuments();
+
+    if (!Array.isArray(docIds)) {
+      return res.status(500).json({ error: 'Failed to list documents' });
+    }
+
+    const documents = docIds.map((id: string) => {
+      const doc = (globalThis as any).db.getVersionedDocument(id);
+      return {
+        id: doc?.id,
+        title: doc?.title,
+        content: doc?.content,
+        version: doc?.version
+      };
+    }).filter((d: any): d is Document => d !== null && d.id !== undefined);
+
+    res.json(documents);
+  } catch (error) {
+    res.status(500).json({ error: 'Failed to list documents' });
+  }
+});
+
+// Delete document
+router.delete('/documents/:id', (req: { params: { id: string } }, res: Response) => {
+  try {
+    const docId = req.params.id;
+
+    const existing = (globalThis as any).db.getVersionedDocument(docId);
+    if (!existing) {
+      return res.status(404).json({ error: 'Document not found' });
+    }
+
+    (globalThis as any).db.deleteDocument(docId);
+
+    res.status(204).send();
+  } catch (error) {
+    res.status(500).json({ error: 'Failed to delete document' });
+  }
+});
+
+// Get version history
+router.get('/documents/:id/history', (req: { params: { id: string } }, res: Response) => {
+  try {
+    const docId = req.params.id;
+
+    const history = (globalThis as any).db.getVersionHistory(docId);
+
+    if (!history) {
+      return res.status(404).json({ error: 'Document not found' });
+    }
+
+    res.json(history);
+  } catch (error) {
+    res.status(500).json({ error: 'Failed to get version history' });
+  }
+});
+
+// Update document (manual versioning)
+router.put('/documents/:id', (req: { params: { id: string }; body: any }, res: Response) => {
+  try {
+    const docId = req.params.id;
+    const { title, content, version } = req.body;
+
+    const existing = (globalThis as any).db.getVersionedDocument(docId);
+    if (!existing) {
+      return res.status(404).json({ error: 'Document not found' });
+    }
+
+    if (version !== undefined && version !== existing.version) {
+      return res.status(409).json({
+        error: 'Version conflict',
+        expectedVersion: existing.version,
+        currentVersion: version
+      });
+    }
+
+    const newVersion = (globalThis as any).db.incrementDocumentVersion(docId);
+    (globalThis as any).db.updateDocument(docId, content || existing.content, newVersion);
+    (globalThis as any).db.addVersionHistory(docId, newVersion, content || existing.content);
+
+    res.json({
+      id: docId,
+      title: title || existing.title,
+      content: content || existing.content,
+      version: newVersion
+    });
+  } catch (error) {
+    res.status(500).json({ error: 'Failed to update document' });
+  }
+});
+
+export { router as restApiRouter };
