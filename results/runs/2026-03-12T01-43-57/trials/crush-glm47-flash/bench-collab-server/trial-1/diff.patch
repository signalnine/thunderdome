+
+describe('Collaborative Document Editor', () => {
+  let server: any;
+  let port: number;
+  let db: any;
+
+  beforeAll(async () => {
+    // Clean up test database
+    const fs = await import('fs/promises');
+    const path = await import('path');
+    const testDbPath = path.join(testDir, 'test.db');
+    await fs.rm(testDbPath.replace('/test.db', ''), { recursive: true, force: true });
+
+    server = globalThis as any;
+    ({ port, db } = await createApp(testDbPath));
