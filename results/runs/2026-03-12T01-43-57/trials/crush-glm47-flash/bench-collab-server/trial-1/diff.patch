@@ -0,0 +1,146 @@
+import Database from 'better-sqlite3';
+import { join, dirname } from 'path';
+import { promises as fs } from 'fs';
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  version: number;
+}
+
+export interface Database {
+  db: Database.Database;
+}
+
+export let db: any;
+
+export async function createDatabase(dbPath: string = 'documents.db') {
+  await fs.mkdir(dirname(dbPath), { recursive: true });
+  const database = new Database(dbPath);
+
+  // Read schema
+  const schemaPath = join(__dirname, '..', 'schema.sql');
+  const schema = await fs.readFile(schemaPath, 'utf-8');
+
+  // Execute schema
+  database.exec(schema);
+
+  // Expose database globally
+  (globalThis as any).db = { db: database };
+
+  return { db: database } as any;
+}
+
+export function getVersionedDocument(db: Database, docId: string): Document | null {
+  const stmt = db.db.prepare(`
+    SELECT id, title, content, version
+    FROM documents
+    WHERE id = ?
+  `);
+  return stmt.get(docId) as Document | null;
+}
+
+export function updateDocument(db: Database, docId: string, content: string, version: number): void {
+  const stmt = db.db.prepare(`
+    UPDATE documents
+    SET content = ?, version = ?, updated_at = datetime('now')
+    WHERE id = ?
+  `);
+  stmt.run(content, version, docId);
+}
+
+export function incrementDocumentVersion(db: Database, docId: string): number {
+  const stmt = db.db.prepare('SELECT version FROM documents WHERE id = ?');
+  const { version } = stmt.get(docId) as { version: number };
+
+  const updateStmt = db.db.prepare(`
+    UPDATE documents
+    SET version = version + 1, updated_at = datetime('now')
+    WHERE id = ?
+  `);
+  updateStmt.run(docId);
+
+  return version + 1;
+}
+
+export function addVersionHistory(
+  db: Database,
+  docId: string,
+  version: number,
+  content: string
+): void {
+  const stmt = db.db.prepare(`
+    INSERT INTO versions (document_id, version, content)
+    VALUES (?, ?, ?)
+  `);
+  stmt.run(docId, version, content);
+}
+
+export function getVersionHistory(db: Database, docId: string): any[] {
+  const stmt = db.db.prepare(`
+    SELECT version, content
+    FROM versions
+    WHERE document_id = ?
+    ORDER BY version
+  `);
+  return stmt.all(docId);
+}
+
+export function getDocuments(db: Database): string[] {
+  const stmt = db.db.prepare('SELECT id FROM documents ORDER BY id');
+  return stmt.all() as string[];
+}
+
+export function createDocument(
+  db: Database,
+  docId: string,
+  title: string,
+  content: string
+): void {
+  const stmt = db.db.prepare(`
+    INSERT INTO documents (id, title, content, version, created_at, updated_at)
+    VALUES (?, ?, ?, 0, datetime('now'), datetime('now'))
+  `);
+  stmt.run(docId, title, content);
+}
+
+export function deleteDocument(db: Database, docId: string): void {
+  const stmt = db.db.prepare('DELETE FROM documents WHERE id = ?');
+  stmt.run(docId);
+}
+
+export interface Connection {
+  documentId: string;
+  ws: any; // WebSocket instance
+}
+
+export const activeConnections = new Map<string, Connection[]>();
+
+export function addConnection(db: Database, docId: string, connectionId: string): void {
+  if (!activeConnections.has(docId)) {
+    activeConnections.set(docId, []);
+  }
+  activeConnections.get(docId)!.push({
+    documentId: docId,
+    ws: connectionId
+  });
+}
+
+export function removeConnection(db: Database, docId: string, connectionId: any): void {
+  const connections = activeConnections.get(docId);
+  if (connections) {
+    const index = connections.findIndex(c => c.ws === connectionId);
+    if (index !== -1) {
+      connections.splice(index, 1);
+    }
+    if (connections.length === 0) {
+      activeConnections.delete(docId);
+    }
+  }
+}
+
+export function getConnectionsForDocument(docId: string): any[] {
+  const connections = activeConnections.get(docId) || [];
+  return connections.map(c => c.ws);
+}
