@@ -0,0 +1,110 @@
+import semver from 'semver';
+import { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+/** Dependency graph service */
+export class SimpleDepsService implements DepsService {
+  /** Build a dependency tree for a plugin (latest version) */
+  buildTree(name: string, registry: RegistryService): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      throw new Error(`Plugin ${name} not found`);
+    }
+    // Pick the highest version for the root (already manifest)
+    const version = manifest.version;
+    const deps = this._buildDeps(manifest.dependencies, registry);
+    return { name, version, dependencies: deps };
+  }
+
+  private _buildDeps(
+    depsMap: Record<string, string>,
+    registry: RegistryService
+  ): DependencyNode[] {
+    const nodes: DependencyNode[] = [];
+    for (const [depName, range] of Object.entries(depsMap)) {
+      const manifest = this._findBestManifest(depName, range, registry);
+      if (!manifest) continue; // skip missing or unsatisfied deps
+      const childDeps = this._buildDeps(manifest.dependencies, registry);
+      nodes.push({ name: depName, version: manifest.version, dependencies: childDeps });
+    }
+    return nodes;
+  }
+
+  private _findBestManifest(
+    name: string,
+    range: string,
+    registry: RegistryService
+  ): any {
+    const versions = registry.listVersions(name);
+    const satisfying = semver.maxSatisfying(versions, range);
+    if (!satisfying) return null;
+    return registry.getVersion(name, satisfying);
+  }
+
+  /** Detect cycles, return list of cycles (each as array of plugin names) */
+  detectCycles(name: string, registry: RegistryService): string[][] | null {
+    const visited = new Set<string>();
+    const stack: string[] = [];
+    const cycles: string[][] = [];
+    const dfs = (current: string) => {
+      if (stack.includes(current)) {
+        const idx = stack.indexOf(current);
+        cycles.push(stack.slice(idx).concat(current));
+        return;
+      }
+      if (visited.has(current)) return;
+      visited.add(current);
+      stack.push(current);
+      const manifest = registry.get(current);
+      if (manifest) {
+        for (const dep of Object.keys(manifest.dependencies)) {
+          dfs(dep);
+        }
+      }
+      stack.pop();
+    };
+    dfs(name);
+    return cycles.length ? cycles : null;
+  }
+
+  /** Topological sort (dependencies first) */
+  topologicalSort(name: string, registry: RegistryService): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+    const visit = (n: string) => {
+      if (visited.has(n)) return;
+      visited.add(n);
+      const manifest = registry.get(n);
+      if (manifest) {
+        for (const dep of Object.keys(manifest.dependencies)) {
+          visit(dep);
+        }
+      }
+      result.push(n);
+    };
+    visit(name);
+    return result;
+  }
+
+  /** Flatten all transitive dependencies (unique names) */
+  flattenDependencies(name: string, registry: RegistryService): string[] {
+    const set = new Set<string>();
+    const dfs = (n: string) => {
+      if (set.has(n)) return;
+      set.add(n);
+      const manifest = registry.get(n);
+      if (manifest) {
+        for (const dep of Object.keys(manifest.dependencies)) {
+          dfs(dep);
+        }
+      }
+    };
+    dfs(name);
+    return Array.from(set);
+  }
+
+  hasCircularDependency(name: string, registry: RegistryService): boolean {
+    return this.detectCycles(name, registry) !== null;
+  }
+}
+
+export default SimpleDepsService;
