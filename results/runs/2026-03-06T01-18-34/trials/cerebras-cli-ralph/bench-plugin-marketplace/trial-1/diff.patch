+{"type":"tool_use","timestamp":1772759948303,"sessionID":"ses_33f464e28ffepf2iu3LRrjagQJ","part":{"id":"prt_cc0ba1af0001WidhOhDU8JuuFb","sessionID":"ses_33f464e28ffepf2iu3LRrjagQJ","messageID":"msg_cc0ba1484001KvmHana6S2Dcdc","type":"tool","callID":"0edffec97","tool":"write","state":{"status":"completed","input":{"filePath":"/workspace/src/reviews/reviewService.ts","content":"import Database from 'better-sqlite3';\nimport { Review, ReviewService } from '../types';\n\n/** SQLite backed review service */\nexport class SQLiteReviewService implements ReviewService {\n  private db: Database.Database;\n\n  constructor(dbPath: string = ':memory:') {\n    this.db = new Database(dbPath);\n    this.initialize();\n  }\n\n  private initialize() {\n    const stmt = `CREATE TABLE IF NOT EXISTS reviews (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      pluginName TEXT NOT NULL,\n      pluginVersion TEXT NOT NULL,\n      userId TEXT NOT NULL,\n      rating INTEGER NOT NULL,\n      comment TEXT NOT NULL,\n      flagged INTEGER NOT NULL DEFAULT 0,\n      createdAt TEXT NOT NULL\n    );`;\n    this.db.exec(stmt);\n  }\n\n  addReview(review: Omit<Review, 'id' | 'createdAt' | 'flagged'>): Review {\n    const now = new Date().toISOString();\n    const insert = this.db.prepare(\n      `INSERT INTO reviews (pluginName, pluginVersion, userId, rating, comment, flagged, createdAt)\n       VALUES (?, ?, ?, ?, ?, 0, ?);`\n    );\n    const info = insert.run(\n      review.pluginName,\n      review.pluginVersion,\n      review.userId,\n      review.rating,\n      review.comment,\n      now\n    );\n    const id = Number(info.lastInsertRowid);\n    return { id, flagged: false, createdAt: now, ...review };\n  }\n\n  getReviews(pluginName: string): Review[] {\n    const rows = this.db\n      .prepare('SELECT * FROM reviews WHERE pluginName = ?;')\n      .all(pluginName);\n    return rows.map(this.rowToReview);\n  }\n\n  getAverageRating(pluginName: string): number {\n    const row = this.db\n      .prepare('SELECT AVG(rating) as avg FROM reviews WHERE pluginName = ? AND flagged = 0;')\n      .get(pluginName);\n    return row && row.avg !== null ? Number(row.avg) : 0;\n  }\n\n  flagReview(reviewId: number): void {\n    this.db\n      .prepare('UPDATE reviews SET flagged = 1 WHERE id = ?;')\n      .run(reviewId);\n  }\n\n  getFlaggedReviews(): Review[] {\n    const rows = this.db.prepare('SELECT * FROM reviews WHERE flagged = 1;').all();\n    return rows.map(this.rowToReview);\n  }\n\n  removeReview(reviewId: number): boolean {\n    const info = this.db.prepare('DELETE FROM reviews WHERE id = ?;').run(reviewId);\n    return info.changes > 0;\n  }\n\n  getReviewsByUser(userId: string): Review[] {\n    const rows = this.db.prepare('SELECT * FROM reviews WHERE userId = ?;').all(userId);\n    return rows.map(this.rowToReview);\n  }\n\n  getReviewCount(pluginName: string): number {\n    const row = this.db\n      .prepare('SELECT COUNT(*) as cnt FROM reviews WHERE pluginName = ? AND flagged = 0;')\n      .get(pluginName);\n    return row ? Number(row.cnt) : 0;\n  }\n\n  private rowToReview(row: any): Review {\n    return {\n      id: row.id,\n      pluginName: row.pluginName,\n      pluginVersion: row.pluginVersion,\n      userId: row.userId,\n      rating: row.rating,\n      comment: row.comment,\n      flagged: !!row.flagged,\n      createdAt: row.createdAt,\n    };\n  }\n}\n\nexport default SQLiteReviewService;\n"},"output":"Wrote file successfully.","title":"src/reviews/reviewService.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/reviews/reviewService.ts","exists":false,"truncated":false},"time":{"start":1772759948296,"end":1772759948302}}}}
