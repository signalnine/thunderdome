index 0000000..c156b74
--- /dev/null
+++ b/src/runner/runner.ts
@@ -0,0 +1,52 @@
+import { Script, createContext } from 'vm';
+import { SandboxResult, RunnerService } from '../types.js';
+
+/** Simple sandbox runner using Node's vm module */
+export class VMRunner implements RunnerService {
+  async execute(code: string, context: Record<string, unknown> = {}): Promise<SandboxResult> {
+    return this._run(code, context, undefined);
+  }
+
+  async executeWithTimeout(
+    code: string,
+    timeoutMs: number,
+    context: Record<string, unknown> = {}
+  ): Promise<SandboxResult> {
+    return this._run(code, context, timeoutMs);
+  }
+
+  private async _run(
+    code: string,
+    context: Record<string, unknown>,
+    timeoutMs?: number
+  ): Promise<SandboxResult> {
+    const sandbox = { ...context };
+    const ctx = createContext(sandbox);
+    const script = new Script(code);
+    const start = Date.now();
+    const startMem = process.memoryUsage().heapUsed;
+    try {
+      const result = script.runInContext(ctx, { timeout: timeoutMs });
+      const duration = Date.now() - start;
+      const endMem = process.memoryUsage().heapUsed;
+      return {
+        success: true,
+        output: result,
+        duration,
+        memoryUsed: endMem - startMem,
+      };
+    } catch (e: any) {
+      const duration = Date.now() - start;
+      const endMem = process.memoryUsage().heapUsed;
+      return {
+        success: false,
+        output: null,
+        duration,
+        memoryUsed: endMem - startMem,
+        error: e?.message || String(e),
+      };
+    }
+  }
+}
+
+export default VMRunner;
