+++ b/src/index.ts
@@ -0,0 +1,59 @@
+import { PluginManifest, RegistryService, ResolverService, RunnerService, ReviewService, DepsService, VersionConstraint, ResolvedVersion, SandboxResult } from './types.js';
+import SQLiteRegistry from './registry/registry.js';
+import { SemverResolver } from './resolver/resolver.js';
+import VMRunner from './runner/runner.js';
+import SQLiteReviewService from './reviews/reviewService.js';
+import SimpleDepsService from './deps/depsService.js';
+
+/**
+ * Factory to create a fully wired marketplace instance.
+ */
+export function createMarketplace() {
+  const registry: RegistryService = new SQLiteRegistry();
+  const resolver: ResolverService = new SemverResolver();
+  const runner: RunnerService = new VMRunner();
+  const reviews: ReviewService = new SQLiteReviewService();
+  const deps: DepsService = new SimpleDepsService();
+
+  /**
+   * Install a plugin: validates manifest, registers, resolves deps, checks cycles,
+   * runs entry point, and returns resolution info and execution result.
+   */
+  async function installPlugin(manifest: PluginManifest): Promise<{ resolved: ResolvedVersion[]; result: SandboxResult }> {
+    // Validate required fields
+    if (!manifest.name || !manifest.version || !manifest.entryPoint) {
+      throw new Error('Manifest must include name, version, and entryPoint');
+    }
+
+    // Register plugin
+    registry.register(manifest);
+
+    // Resolve dependencies
+    const constraints: VersionConstraint[] = Object.entries(manifest.dependencies).map(([name, range]) => ({ name, range }));
+    const available: Record<string, string[]> = {};
+    for (const name of Object.keys(manifest.dependencies)) {
+      const versions = registry.listVersions(name);
+      available[name] = versions;
+    }
+    const resolved = resolver.resolve(constraints, available);
+
+    // Check for circular dependencies (including this plugin)
+    if (deps.hasCircularDependency(manifest.name, registry)) {
+      throw new Error('Circular dependency detected');
+    }
+
+    // Execute entry point code in sandbox (with resolved deps injected)
+    const context: Record<string, unknown> = {
+      // provide resolved dependencies map
+      dependencies: resolved.reduce((acc, cur) => {
+        acc[cur.name] = cur.version;
+        return acc;
+      }, {} as Record<string, string>),
+    };
+    const result = await runner.executeWithTimeout(manifest.entryPoint, 5000, context);
+
+    return { resolved, result };
+  }
+
+  return { registry, resolver, runner, reviews, deps, installPlugin };
+}
