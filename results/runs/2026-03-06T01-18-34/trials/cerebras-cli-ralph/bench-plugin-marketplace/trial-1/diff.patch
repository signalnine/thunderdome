iews(pluginName: string): Review[] {\n46:     const rows = this.db\n47:       .prepare('SELECT * FROM reviews WHERE pluginName = ?;')\n48:       .all(pluginName);\n49:     return rows.map(this.rowToReview);\n50:   }\n51: \n52:   getAverageRating(pluginName: string): number {\n53:     const row = this.db\n54:       .prepare('SELECT AVG(rating) as avg FROM reviews WHERE pluginName = ? AND flagged = 0;')\n55:       .get(pluginName);\n56:     return row && row.avg !== null ? Number(row.avg) : 0;\n57:   }\n58: \n59:   flagReview(reviewId: number): void {\n60:     this.db\n61:       .prepare('UPDATE reviews SET flagged = 1 WHERE id = ?;')\n62:       .run(reviewId);\n63:   }\n64: \n65:   getFlaggedReviews(): Review[] {\n66:     const rows = this.db.prepare('SELECT * FROM reviews WHERE flagged = 1;').all();\n67:     return rows.map(this.rowToReview);\n68:   }\n69: \n70:   removeReview(reviewId: number): boolean {\n71:     const info = this.db.prepare('DELETE FROM reviews WHERE id = ?;').run(reviewId);\n72:     return info.changes > 0;\n73:   }\n74: \n75:   getReviewsByUser(userId: string): Review[] {\n76:     const rows = this.db.prepare('SELECT * FROM reviews WHERE userId = ?;').all(userId);\n77:     return rows.map(this.rowToReview);\n78:   }\n79: \n80:   getReviewCount(pluginName: string): number {\n81:     const row = this.db\n82:       .prepare('SELECT COUNT(*) as cnt FROM reviews WHERE pluginName = ? AND flagged = 0;')\n83:       .get(pluginName);\n84:     return row ? Number(row.cnt) : 0;\n85:   }\n86: \n87:   private rowToReview(row: any): Review {\n88:     return {\n89:       id: row.id,\n90:       pluginName: row.pluginName,\n91:       pluginVersion: row.pluginVersion,\n92:       userId: row.userId,\n93:       rating: row.rating,\n94:       comment: row.comment,\n95:       flagged: !!row.flagged,\n96:       createdAt: row.createdAt,\n97:     };\n98:   }\n99: }\n100: \n101: export default SQLiteReviewService;\n102: \n\n(End of file - total 102 lines)\n</content>","