+import { describe, it, expect, beforeEach } from 'vitest';
+import SQLiteRegistry from './registry.js';
+import type { PluginManifest } from '../types.js';
+
+describe('SQLiteRegistry', () => {
+  let registry: SQLiteRegistry;
+  const pluginA: PluginManifest = {
+    name: 'pluginA',
+    version: '1.0.0',
+    description: 'Test plugin A',
+    author: 'alice',
+    dependencies: {},
+    entryPoint: 'module.exports = 42;',
+    permissions: [],
+  };
+  const pluginB: PluginManifest = {
+    ...pluginA,
+    name: 'pluginB',
+    version: '2.1.0',
+  };
+
+  beforeEach(() => {
+    registry = new SQLiteRegistry();
+    registry.register(pluginA);
+    registry.register(pluginB);
+  });
+
+  it('gets plugin by name (latest version)', () => {
+    const got = registry.get('pluginA');
+    expect(got).toBeTruthy();
+    expect(got?.name).toBe('pluginA');
+    expect(got?.version).toBe('1.0.0');
+  });
+
+  it('gets specific version', () => {
+    const got = registry.getVersion('pluginB', '2.1.0');
+    expect(got).toBeTruthy();
+    expect(got?.version).toBe('2.1.0');
+  });
+
+  it('lists versions', () => {
+    const versions = registry.listVersions('pluginA');
+    expect(versions).toContain('1.0.0');
+  });
+
+  it('searches plugins', () => {
+    const results = registry.search('plugin');
+    expect(results.length).toBeGreaterThanOrEqual(2);
+  });
+
+  it('updates a plugin manifest', () => {
+    registry.update('pluginA', '1.0.0', { description: 'updated' });
+    const updated = registry.getVersion('pluginA', '1.0.0');
+    expect(updated?.description).toBe('updated');
+  });
+
+  it('removes a plugin version', () => {
+    const removed = registry.remove('pluginA', '1.0.0');
+    expect(removed).toBe(true);
+    const after = registry.getVersion('pluginA', '1.0.0');
+    expect(after).toBeNull();
+  });
+});
diff --git a/src/registry/registry.ts b/src/registry/registry.ts
new file mode 100644
index 0000000..b6460b7
--- /dev/null
+++ b/src/registry/registry.ts
@@ -0,0 +1,77 @@
+import Database from 'better-sqlite3';
+import { PluginManifest, RegistryService } from '../types.js';
+
+/** Simple SQLite backed registry */
+export class SQLiteRegistry implements RegistryService {
+  private db: Database.Database;
+
+  constructor(dbPath: string = ':memory:') {
+    this.db = new Database(dbPath);
+    this.initialize();
+  }
+
+  private initialize() {
+    const stmt = `CREATE TABLE IF NOT EXISTS plugins (
+      name TEXT NOT NULL,
+      version TEXT NOT NULL,
+      manifest TEXT NOT NULL,
+      PRIMARY KEY (name, version)
+    );`;
+    this.db.exec(stmt);
+  }
+
+  register(manifest: PluginManifest): void {
+    const insert = this.db.prepare(
+      'INSERT OR REPLACE INTO plugins (name, version, manifest) VALUES (?, ?, ?);'
+    );
+    insert.run(manifest.name, manifest.version, JSON.stringify(manifest));
+  }
+
+  get(name: string): PluginManifest | null {
+    const row = this.db.prepare('SELECT manifest FROM plugins WHERE name = ? LIMIT 1;').get(name) as { manifest: string } | undefined
+    return row ? JSON.parse((row as unknown).manifest) : null;
+  }
+
+  getVersion(name: string, version: string): PluginManifest | null {
+const row = this.db
+       .prepare('SELECT manifest FROM plugins WHERE name = ? AND version = ?;')
+       .get(name, version) as { manifest: string } | undefined;
+    return row ? JSON.parse((row as unknown).manifest) : null;
+  }
+
+  list(): PluginManifest[] {
+    const rows = this.db.prepare('SELECT manifest FROM plugins;').all() as { manifest: string }[];
+    return rows.map((r: any) => JSON.parse(r.manifest));
+  }
+
+  search(query: string): PluginManifest[] {
+    const pattern = `%${query}%`;
+    const rows = this.db
+      .prepare('SELECT manifest FROM plugins WHERE name LIKE ?;')
+      .all(pattern);
+    return rows.map((r: any) => JSON.parse(r.manifest));
+  }
+
+  remove(name: string, version: string): boolean {
+    const info = this.db
+      .prepare('DELETE FROM plugins WHERE name = ? AND version = ?;')
+      .run(name, version);
+    return info.changes > 0;
+  }
+
+  listVersions(name: string): string[] {
+    const rows = this.db
+      .prepare('SELECT version FROM plugins WHERE name = ?;')
+      .all(name);
+    return rows.map((r: any) => r.version);
+  }
+
+  update(name: string, version: string, updates: Partial<PluginManifest>): void {
+    const existing = this.getVersion(name, version);
+    if (!existing) return;
+    const updated = { ...existing, ...updates };
+    this.register(updated);
+  }
+}
+
+export default SQLiteRegistry;
