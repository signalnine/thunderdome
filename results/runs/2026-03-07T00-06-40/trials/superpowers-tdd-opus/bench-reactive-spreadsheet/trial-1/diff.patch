+++ b/src/index.ts
@@ -0,0 +1,480 @@
+type CellValue = string | number | boolean | null;
+
+interface CellData {
+  raw: string | number | boolean;
+  formula?: string;
+}
+
+type TokenType = 'NUMBER' | 'STRING' | 'BOOLEAN' | 'CELL_REF' | 'OP' | 'LPAREN' | 'RPAREN' | 'FUNC' | 'COMMA' | 'COLON' | 'COMPARE';
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+export class Spreadsheet {
+  private cells = new Map<string, CellData>();
+  private computed = new Map<string, CellValue>();
+  private deps = new Map<string, Set<string>>(); // cell -> cells it depends on
+  private rdeps = new Map<string, Set<string>>(); // cell -> cells that depend on it
+
+  set(cell: string, value: string | number | boolean): void {
+    const upperCell = cell.toUpperCase();
+
+    // Remove old dependencies
+    const oldDeps = this.deps.get(upperCell);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        this.rdeps.get(dep)?.delete(upperCell);
+      }
+      this.deps.delete(upperCell);
+    }
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formula = value.substring(1);
+      this.cells.set(upperCell, { raw: value, formula });
+
+      // Parse to find dependencies
+      const cellDeps = this.findDependencies(formula);
+      this.deps.set(upperCell, cellDeps);
+      for (const dep of cellDeps) {
+        if (!this.rdeps.has(dep)) this.rdeps.set(dep, new Set());
+        this.rdeps.get(dep)!.add(upperCell);
+      }
+
+      // Check for circular references
+      this.checkCircular(upperCell);
+
+      // Evaluate
+      this.computed.set(upperCell, this.evaluate(formula));
+    } else {
+      this.cells.set(upperCell, { raw: value });
+      this.computed.set(upperCell, value);
+    }
+
+    // Recompute dependents
+    this.recompute(upperCell);
+  }
+
+  get(cell: string): CellValue {
+    const upperCell = cell.toUpperCase();
+    if (!this.cells.has(upperCell)) return null;
+    return this.computed.get(upperCell) ?? null;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [key] of this.cells) {
+      result.set(key, this.computed.get(key) ?? null);
+    }
+    return result;
+  }
+
+  private checkCircular(startCell: string): void {
+    const visited = new Set<string>();
+    const stack = [startCell];
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      const cellDeps = this.deps.get(current);
+      if (!cellDeps) continue;
+      for (const dep of cellDeps) {
+        if (dep === startCell) {
+          // Undo the set
+          this.cells.delete(startCell);
+          this.computed.delete(startCell);
+          const deps = this.deps.get(startCell);
+          if (deps) {
+            for (const d of deps) {
+              this.rdeps.get(d)?.delete(startCell);
+            }
+          }
+          this.deps.delete(startCell);
+          throw new Error('Circular reference detected');
+        }
+        if (!visited.has(dep)) {
+          visited.add(dep);
+          stack.push(dep);
+        }
+      }
+    }
+  }
+
+  private recompute(changedCell: string): void {
+    const toRecompute = this.getTopologicalOrder(changedCell);
+    for (const cell of toRecompute) {
+      const data = this.cells.get(cell);
+      if (data?.formula) {
+        this.computed.set(cell, this.evaluate(data.formula));
+      }
+    }
+  }
+
+  private getTopologicalOrder(startCell: string): string[] {
+    const result: string[] = [];
+    const visited = new Set<string>();
+
+    const visit = (cell: string) => {
+      if (visited.has(cell)) return;
+      visited.add(cell);
+      const dependents = this.rdeps.get(cell);
+      if (dependents) {
+        for (const dep of dependents) {
+          visit(dep);
+        }
+      }
+      result.push(cell);
+    };
+
+    visit(startCell);
+    // Remove startCell itself from recompute list, reverse for correct order
+    return result.filter(c => c !== startCell).reverse();
+  }
+
+  private findDependencies(formula: string): Set<string> {
+    const deps = new Set<string>();
+    const tokens = this.tokenize(formula);
+    for (const token of tokens) {
+      if (token.type === 'CELL_REF') {
+        deps.add(token.value.toUpperCase());
+      }
+    }
+    // Expand ranges
+    for (let i = 0; i < tokens.length; i++) {
+      if (tokens[i].type === 'CELL_REF' && i + 2 < tokens.length && tokens[i + 1].type === 'COLON' && tokens[i + 2].type === 'CELL_REF') {
+        const rangeCells = this.expandRange(tokens[i].value.toUpperCase(), tokens[i + 2].value.toUpperCase());
+        for (const rc of rangeCells) {
+          deps.add(rc);
+        }
+      }
+    }
+    return deps;
+  }
+
+  private tokenize(formula: string): Token[] {
+    const tokens: Token[] = [];
+    let i = 0;
+    while (i < formula.length) {
+      const ch = formula[i];
+
+      if (/\s/.test(ch)) {
+        i++;
+        continue;
+      }
+
+      // String literal
+      if (ch === '"') {
+        let str = '';
+        i++; // skip opening quote
+        while (i < formula.length && formula[i] !== '"') {
+          str += formula[i];
+          i++;
+        }
+        i++; // skip closing quote
+        tokens.push({ type: 'STRING', value: str });
+        continue;
+      }
+
+      // Number
+      if (/\d/.test(ch) || (ch === '.' && i + 1 < formula.length && /\d/.test(formula[i + 1]))) {
+        let num = '';
+        while (i < formula.length && (/\d/.test(formula[i]) || formula[i] === '.')) {
+          num += formula[i];
+          i++;
+        }
+        tokens.push({ type: 'NUMBER', value: num });
+        continue;
+      }
+
+      // Comparison operators (must check before single-char ops)
+      if (ch === '<' && i + 1 < formula.length && formula[i + 1] === '>') {
+        tokens.push({ type: 'COMPARE', value: '<>' });
+        i += 2;
+        continue;
+      }
+      if (ch === '<' && i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push({ type: 'COMPARE', value: '<=' });
+        i += 2;
+        continue;
+      }
+      if (ch === '>' && i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push({ type: 'COMPARE', value: '>=' });
+        i += 2;
+        continue;
+      }
+      if (ch === '<' || ch === '>') {
+        tokens.push({ type: 'COMPARE', value: ch });
+        i++;
+        continue;
+      }
+
+      // Cell reference or function or boolean
+      if (/[A-Za-z]/.test(ch)) {
+        let ident = '';
+        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+          ident += formula[i];
+          i++;
+        }
+        const upper = ident.toUpperCase();
+        if (upper === 'TRUE') {
+          tokens.push({ type: 'BOOLEAN', value: 'true' });
+        } else if (upper === 'FALSE') {
+          tokens.push({ type: 'BOOLEAN', value: 'false' });
+        } else if (i < formula.length && formula[i] === '(') {
+          tokens.push({ type: 'FUNC', value: upper });
+        } else if (/^[A-Z]+\d+$/.test(upper)) {
+          tokens.push({ type: 'CELL_REF', value: upper });
+        } else {
+          // Might be a function without parens or identifier — treat as cell ref
+          tokens.push({ type: 'CELL_REF', value: upper });
+        }
+        continue;
+      }
+
+      if (ch === '(') { tokens.push({ type: 'LPAREN', value: '(' }); i++; continue; }
+      if (ch === ')') { tokens.push({ type: 'RPAREN', value: ')' }); i++; continue; }
+      if (ch === ',') { tokens.push({ type: 'COMMA', value: ',' }); i++; continue; }
+      if (ch === ':') { tokens.push({ type: 'COLON', value: ':' }); i++; continue; }
+
+      if (ch === '=' ) {
+        tokens.push({ type: 'COMPARE', value: '=' });
+        i++;
+        continue;
+      }
+
+      if ('+-*/'.includes(ch)) {
+        tokens.push({ type: 'OP', value: ch });
+        i++;
+        continue;
+      }
+
+      i++; // skip unknown
+    }
+    return tokens;
+  }
+
+  private evaluate(formula: string): CellValue {
+    const tokens = this.tokenize(formula);
+    let pos = 0;
+
+    const peek = (): Token | null => tokens[pos] ?? null;
+    const consume = (): Token => tokens[pos++];
+
+    const parseExpression = (): CellValue => {
+      return parseComparison();
+    };
+
+    const parseComparison = (): CellValue => {
+      let left = parseAddSub();
+      while (peek()?.type === 'COMPARE') {
+        const op = consume().value;
+        const right = parseAddSub();
+        const l = typeof left === 'number' ? left : 0;
+        const r = typeof right === 'number' ? right : 0;
+        switch (op) {
+          case '>': left = l > r; break;
+          case '<': left = l < r; break;
+          case '>=': left = l >= r; break;
+          case '<=': left = l <= r; break;
+          case '=': left = left === right; break;
+          case '<>': left = left !== right; break;
+        }
+      }
+      return left;
+    };
+
+    const parseAddSub = (): CellValue => {
+      let left = parseMulDiv();
+      while (peek()?.type === 'OP' && (peek()!.value === '+' || peek()!.value === '-')) {
+        const op = consume().value;
+        const right = parseMulDiv();
+        const l = typeof left === 'number' ? left : 0;
+        const r = typeof right === 'number' ? right : 0;
+        left = op === '+' ? l + r : l - r;
+      }
+      return left;
+    };
+
+    const parseMulDiv = (): CellValue => {
+      let left = parseUnary();
+      while (peek()?.type === 'OP' && (peek()!.value === '*' || peek()!.value === '/')) {
+        const op = consume().value;
+        const right = parseUnary();
+        const l = typeof left === 'number' ? left : 0;
+        const r = typeof right === 'number' ? right : 0;
+        left = op === '*' ? l * r : l / r;
+      }
+      return left;
+    };
+
+    const parseUnary = (): CellValue => {
+      if (peek()?.type === 'OP' && peek()!.value === '-') {
+        consume();
+        const val = parsePrimary();
+        return typeof val === 'number' ? -val : 0;
+      }
+      return parsePrimary();
+    };
+
+    const parsePrimary = (): CellValue => {
+      const token = peek();
+      if (!token) return 0;
+
+      if (token.type === 'NUMBER') {
+        consume();
+        return parseFloat(token.value);
+      }
+
+      if (token.type === 'STRING') {
+        consume();
+        return token.value;
+      }
+
+      if (token.type === 'BOOLEAN') {
+        consume();
+        return token.value === 'true';
+      }
+
+      if (token.type === 'CELL_REF') {
+        consume();
+        const val = this.get(token.value);
+        return val ?? 0;
+      }
+
+      if (token.type === 'FUNC') {
+        return parseFunction();
+      }
+
+      if (token.type === 'LPAREN') {
+        consume(); // (
+        const val = parseExpression();
+        if (peek()?.type === 'RPAREN') consume(); // )
+        return val;
+      }
+
+      consume();
+      return 0;
+    };
+
+    const parseRange = (): CellValue[] => {
+      const start = consume(); // CELL_REF
+      if (peek()?.type === 'COLON') {
+        consume(); // :
+        const end = consume(); // CELL_REF
+        const cells = this.expandRange(start.value, end.value);
+        return cells.map(c => this.get(c) ?? 0);
+      }
+      return [this.get(start.value) ?? 0];
+    };
+
+    const parseArgList = (): CellValue[] => {
+      const values: CellValue[] = [];
+      if (peek()?.type === 'CELL_REF') {
+        // Check if this is a range
+        const saved = pos;
+        if (pos + 2 < tokens.length && tokens[pos + 1]?.type === 'COLON' && tokens[pos + 2]?.type === 'CELL_REF') {
+          values.push(...parseRange());
+        } else {
+          pos = saved;
+          values.push(parseExpression());
+        }
+      } else {
+        values.push(parseExpression());
+      }
+
+      while (peek()?.type === 'COMMA') {
+        consume(); // ,
+        if (peek()?.type === 'CELL_REF' && pos + 2 < tokens.length && tokens[pos + 1]?.type === 'COLON' && tokens[pos + 2]?.type === 'CELL_REF') {
+          values.push(...parseRange());
+        } else {
+          values.push(parseExpression());
+        }
+      }
+      return values;
+    };
+
+    const parseFunction = (): CellValue => {
+      const funcToken = consume(); // FUNC
+      consume(); // LPAREN
+
+      const funcName = funcToken.value;
+
+      if (funcName === 'IF') {
+        const condition = parseExpression();
+        if (peek()?.type === 'COMMA') consume();
+        const trueVal = parseExpression();
+        if (peek()?.type === 'COMMA') consume();
+        const falseVal = parseExpression();
+        if (peek()?.type === 'RPAREN') consume();
+        return condition ? trueVal : falseVal;
+      }
+
+      const args = parseArgList();
+      if (peek()?.type === 'RPAREN') consume();
+
+      const nums = args.filter((v): v is number => typeof v === 'number');
+
+      switch (funcName) {
+        case 'SUM':
+          return nums.reduce((a, b) => a + b, 0);
+        case 'AVERAGE':
+          return nums.length === 0 ? 0 : nums.reduce((a, b) => a + b, 0) / nums.length;
+        case 'MIN':
+          return nums.length === 0 ? 0 : Math.min(...nums);
+        case 'MAX':
+          return nums.length === 0 ? 0 : Math.max(...nums);
+        case 'COUNT':
+          return nums.length;
+        default:
+          return 0;
+      }
+    };
+
+    return parseExpression();
+  }
+
+  private expandRange(startRef: string, endRef: string): string[] {
+    const start = this.parseRef(startRef);
+    const end = this.parseRef(endRef);
+    const cells: string[] = [];
+    const minCol = Math.min(start.col, end.col);
+    const maxCol = Math.max(start.col, end.col);
+    const minRow = Math.min(start.row, end.row);
+    const maxRow = Math.max(start.row, end.row);
+    for (let col = minCol; col <= maxCol; col++) {
+      for (let row = minRow; row <= maxRow; row++) {
+        cells.push(this.colToLetters(col) + row);
+      }
+    }
+    return cells;
+  }
+
+  private parseRef(ref: string): { col: number; row: number } {
+    const match = ref.match(/^([A-Z]+)(\d+)$/);
+    if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+    return { col: this.lettersToCol(match[1]), row: parseInt(match[2]) };
+  }
+
+  private lettersToCol(letters: string): number {
+    let col = 0;
+    for (let i = 0; i < letters.length; i++) {
+      col = col * 26 + (letters.charCodeAt(i) - 64);
+    }
+    return col;
+  }
+
+  private colToLetters(col: number): string {
+    let result = '';
+    while (col > 0) {
+      const remainder = (col - 1) % 26;
+      result = String.fromCharCode(65 + remainder) + result;
+      col = Math.floor((col - 1) / 26);
+    }
+    return result;
+  }
+}
