ase 'SUM':","+          return nums.reduce((a, b) => a + b, 0);","+        case 'AVERAGE':","+          return nums.length === 0 ? 0 : nums.reduce((a, b) => a + b, 0) / nums.length;","+        case 'MIN':","+          return nums.length === 0 ? 0 : Math.min(...nums);","+        case 'MAX':","+          return nums.length === 0 ? 0 : Math.max(...nums);","+        case 'COUNT':","+          return nums.length;","+        default:","+          return 0;","+      }","+    };","+","+    return parseExpression();","+  }","+","+  private expandRange(startRef: string, endRef: string): string[] {","+    const start = this.parseRef(startRef);","+    const end = this.parseRef(endRef);","+    const cells: string[] = [];","+    const minCol = Math.min(start.col, end.col);","+    const maxCol = Math.max(start.col, end.col);","+    const minRow = Math.min(start.row, end.row);","+    const maxRow = Math.max(start.row, end.row);","+    for (let col = minCol; col <= maxCol; col++) {","+      for (let row = minRow; row <= maxRow; row++) {","+        cells.push(this.colToLetters(col) + row);","+      }","+    }","+    return cells;","+  }","+","+  private parseRef(ref: string): { col: number; row: number } {","+    const match = ref.match(/^([A-Z]+)(\\d+)$/);","+    if (!match) throw new Error(`Invalid cell reference: ${ref}`);","+    return { col: this.lettersToCol(match[1]), row: parseInt(match[2]) };","+  }","+","+  private lettersToCol(letters: string): number {","+    let col = 0;","+    for (let i = 0; i < letters.length; i++) {","+      col = col * 26 + (letters.charCodeAt(i) - 64);","+    }","+    return col;","+  }","+","+  private colToLetters(col: number): string {","+    let result = '';","+    while (col > 0) {","+      const remainder = (col - 1) % 26;","+      result = String.fromCharCode(65 + remainder) + result;","+      col = Math.floor((col - 1) / 26);","+    }","+    return result;","+  }"," }"]}],"originalFile":"export class Spreadsheet {\n  private cells = new Map