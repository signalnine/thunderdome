\n\n  test('set and get string values', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 'hello');\n    expect(sheet.get('A1')).toBe('hello');\n  });\n\n  test('set and get boolean values', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', true);\n    expect(sheet.get('A1')).toBe(true);\n    sheet.set('A2', false);\n    expect(sheet.get('A2')).toBe(false);\n  });\n\n  test('getDisplay returns string representation of values', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 42);\n    expect(sheet.getDisplay('A1')).toBe('42');\n    sheet.set('A2', 'hello');\n    expect(sheet.getDisplay('A2')).toBe('hello');\n    sheet.set('A3', true);\n    expect(sheet.getDisplay('A3')).toBe('true');\n    sheet.set('A4', false);\n    expect(sheet.getDisplay('A4')).toBe('false');\n  });\n\n  test('getDisplay returns empty string for empty cells', () => {\n    const sheet = new Spreadsheet();\n    expect(sheet.getDisplay('A1')).toBe('');\n  });\n\n  test('getCells returns map of all non-empty cells', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('B1', 'hello');\n    sheet.set('C1', true);\n    const cells = sheet.getCells();\n    expect(cells).toBeInstanceOf(Map);\n    expect(cells.size).toBe(3);\n    expect(cells.get('A1')).toBe(10);\n    expect(cells.get('B1')).toBe('hello');\n    expect(cells.get('C1')).toBe(true);\n  });\n\n  test('getCells returns empty map when no cells set', () => {\n    const sheet = new Spreadsheet();\n    const cells = sheet.getCells();\n    expect(cells.size).toBe(0);\n  });\n\n  test('formula with literal number', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=42');\n    expect(sheet.get('A1')).toBe(42);\n  });\n\n  test('formula adding two cell references', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 20);\n    sheet.set('A3', '=A1+A2');\n    expect(sheet.get('A3')).toBe(30);\n  });\n\n  test('formula with subtraction', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 50);\n    sheet.set('A2', 20);\n    sheet.set('A3', '=A1-A2');\n    expect(sheet.get('A3')).toBe(30);\n  });\n\n  test('formula with multiplication', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('A2', 6);\n    sheet.set('A3', '=A1*A2');\n    expect(sheet.get('A3')).toBe(30);\n  });\n\n  test('formula with division', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 100);\n    sheet.set('A2', 4);\n    sheet.set('A3', '=A1/A2');\n    expect(sheet.get('A3')).toBe(25);\n  });\n\n  test('formula respects operator precedence', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 2);\n    sheet.set('A2', 3);\n    sheet.set('A3', 4);\n    sheet.set('A4', '=A1+A2*A3');\n    expect(sheet.get('A4')).toBe(14); // 2 + (3*4) = 14, not (2+3)*4 = 20\n  });\n\n  test('formula with parentheses overrides precedence', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 2);\n    sheet.set('A2', 3);\n    sheet.set('A3', '=(A1+A2)*2');\n    expect(sheet.get('A3')).toBe(10); // (2+3)*2 = 10\n  });\n\n  test('nested parentheses', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=((2+3)*2)+1');\n    expect(sheet.get('A1')).toBe(11);\n  });\n\n  test('reactive update when dependency changes', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 20);\n    sheet.set('A3', '=A1+A2');\n    expect(sheet.get('A3')).toBe(30);\n\n    sheet.set('A1', 50);\n    expect(sheet.get('A3')).toBe(70); // reactively updated\n  });\n\n  test('reactive update propagates through getDisplay', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 20);\n    sheet.set('A3', '=A1+A2');\n    expect(sheet.getDisplay('A3')).toBe('30');\n\n    sheet.set('A1', 50);\n    expect(sheet.getDisplay('A3')).toBe('70');\n  });\n\n  test('detects direct circular reference', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=B1');\n    expect(() => sheet.set('B1', '=A1')).toThrow();\n  });\n\n  test('detects self-referencing circular reference', () => {\n    const sheet = new Spreadsheet();\n    expect(() => sheet.set('A1', '=A1')).toThrow();\n  });\n\n  test('detects indirect circular reference', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', '=B1');\n    sheet.set('B1', '=C1');\n    expect(() => sheet.set('C1', '=A1')).toThrow();\n  });\n\n  test('SUM with column range', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 20);\n    sheet.set('A3', 30);\n    sheet.set('B1', '=SUM(A1:A3)');\n    expect(sheet.get('B1')).toBe(60);\n  });\n\n  test('SUM with row range', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 1);\n    sheet.set('B1', 2);\n    sheet.set('C1', 3);\n    sheet.set('D1', '=SUM(A1:C1)');\n    expect(sheet.get('D1')).toBe(6);\n  });\n\n  test('AVERAGE function', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 20);\n    sheet.set('A3', 30);\n    sheet.set('B1', '=AVERAGE(A1:A3)');\n    expect(sheet.get('B1')).toBe(20);\n  });\n\n  test('MIN function', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 5);\n    sheet.set('A3', 30);\n    sheet.set('B1', '=MIN(A1:A3)');\n    expect(sheet.get('B1')).toBe(5);\n  });\n\n  test('MAX function', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 5);\n    sheet.set('A3', 30);\n    sheet.set('B1', '=MAX(A1:A3)');\n    expect(sheet.get('B1')).toBe(30);\n  });\n\n  test('COUNT function', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('A2', 20);\n    sheet.set('A3', 30);\n    sheet.set('B1', '=COUNT(A1:A3)');\n    expect(sheet.get('B1')).toBe(3);\n  });\n\n  test('IF function with true condition', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 50);\n    sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n    expect(sheet.get('C1')).toBe('big');\n  });\n\n  test('IF function with false condition', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 10);\n    sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n    expect(sheet.get('C1')).toBe('small');\n  });\n\n  test('IF with less than comparison', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 5);\n    sheet.set('B1', '=IF(A1<10, \"low\", \"high\")');\n    expect(sheet.get('B1')).toBe('low');\n  });\n\n  test('IF with equality comparison', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 42);\n    sheet.set('B1', '=IF(A1=42, \"yes\", \"no\")');\n    expect(sheet.get('B1')).toBe('yes');\n  });\n\n  test('IF with not-equal comparison', () => {\n    const sheet = new Spreadsheet();\n    sheet.set('A1', 42);\n    sheet.set('B1', '=IF(A1<>42, \"diff\", \"same\")');\n    expect(sheet.get('B1')).toBe('same');\n  });\n});\n","structuredPatch":[{"oldStart":261,"oldLines":4,"newStart":261,"newLines":19,"lines":["     sheet.set('B1', '=IF(A1<>42, \"diff\", \"same\")');","     expect(sheet.get('B1')).toBe('same');","   });","+","+  test('SUM with block range (2D)', () => {","+    const sheet = new Spreadsheet();","+    sheet.set('A1', 1);","+    sheet.set('A2', 2);","+    sheet.set('A3', 3);","+    sheet.set('B1', 4);","+    sheet.set('B2', 5);","+    sheet.set('B3', 6);","+    sheet.set('C1', 7);","+    sheet.set('C2', 8);","+    sheet.set('C3', 9);","+    sheet.set('D1', '=SUM(A1:C3)');","+    expect(sheet.get('D1')).toBe(45); // 1+2+3+4+5+6+7+8+9 = 45","+  });"," });"]}],"userModified":false,"replaceAll":false}}
