+      target: [true, true, false, true],
+      buttons: [
+        [0, 1],
+        [1, 2, 3],
+        [0, 3],
+      ],
+    };
+
+    // Solve earlier: b0 XOR b2 = 1 (light 0), b0 XOR b1 = 1 (light 1), b1 = 0 (light 2), b1 XOR b2 = 1 (light 3)
+    // From b1 = 0, b0 = 1, b2 = 1, and 0 XOR 1 = 1 OK!
+    // Solution: press buttons 0 and 2
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 2]);
+  });
+
+  it("should handle 1x1 case", () => {
+    const machine = {
+      target: [true],
+      buttons: [[0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
