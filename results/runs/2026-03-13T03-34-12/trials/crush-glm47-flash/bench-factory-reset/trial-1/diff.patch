+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+enum State {
+  FOUND,
+  NOT_FOUND,
+  BACKUP,
+}
+
+type ButtonCombo = [number, number][];
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  if (n === 0) return [];
+  if (m === 0) {
+    return target.every((t) => !t) ? [] : null;
+  }
+
+  const buttonMask = buttons.map((toggle) => {
+    let mask = 0n;
+    for (const light of toggle) {
+      mask |= 1n << BigInt(light);
+    }
+    return mask;
+  });
+
+  const mid = Math.floor((m + 1) / 2);
+
+  MapState: for (let axis1Mask = 0; axis1Mask < (1 << (m - mid)); axis1Mask++) {
+    const partial: ButtonCombo = [];
+    let weight1 = 0;
+
+    for (let i = 0; i < m - mid; i++) {
+      if ((axis1Mask >> i) & 1) {
+        weight1++;
+        partial.push([i, 1]);
+      }
+    }
+
+    const lights1: number[] = Array(n).fill(0);
+    for (let b = 0; b < m - mid; b++) {
+      if ((axis1Mask >> b) & 1) {
+        const mask = buttonMask[b];
+        for (let l = 0; l < n; l++) {
+          const bit = Number((mask >> BigInt(l)) & 1n);
+          lights1[l] ^= bit;
+        }
+      }
+    }
+
+    const states1: Map<string, ButtonCombo[]> = new Map();
+
+    for (let mask2 = 0; mask2 < (1 << mid); mask2++) {
+      const weights: number[] = [];
+      const autoLights: number[] = Array(n).fill(0);
+      let used = false;
+
+      for (let a = 0; a < mid; a++) {
+        if ((mask2 >> a) & 1) {
+          used = true;
+          const b = (m - mid) + a;
+          weights.push(1);
+          const mask = buttonMask[b];
+          for (let l = 0; l < n; l++) {
+            const bit = Number((mask >> BigInt(l)) & 1n);
+            autoLights[l] ^= bit;
+          }
+        }
+      }
+
+      if (!used) continue;
+
+      const diffZeros: number[] = [];
+      for (let l = 0; l < n; l++) {
+        const diff = (target[l] ? 1 : 0) - (lights1[l] + autoLights[l]);
+        if (diff !== 0) diffZeros.push(l);
+      }
+
+      if (diffZeros.length > 0) continue;
+
+      const totalWeight = weight1 + weights.reduce((a, b) => a + b, 0);
+      const key = weights.reverse().join("|");
+      const entry = states1.get(key);
+
+      if (entry === undefined) {
+        if (totalWeight < 40) {
+          const newEntry: ButtonCombo[] = [[...partial]];
+          for (const w of weights) {
+            newEntry[0].push([(m - mid) + weights.indexOf(w), w]);
+          }
+          states1.set(key, newEntry);
+        } else {
+          states1.set(key, []);
+        }
+      } else if (totalWeight < 40) {
+        const newEntry: ButtonCombo[] = [[...partial]];
+        for (const w of weights) {
+          newEntry[0].push([(m - mid) + weights.indexOf(w), w]);
+        }
+        states1.set(key, newEntry);
+      }
+    }
+
+    if (states1.size > 0) {
+      const stack: number[] = [];
+
+      for (let mask2 = (1 << mid) - 1; mask2 >= 0; mask2--) {
+        const weights: number[] = [];
+        const autoLights: number[] = Array(n).fill(0);
+        let used = false;
+
+        for (let a = 0; a < mid; a++) {
+          if ((mask2 >> a) & 1) {
+            used = true;
+            const b = (m - mid) + a;
+            weights.push(1);
+            const mask = buttonMask[b];
+            for (let l = 0; l < n; l++) {
+              const bit = Number((mask >> BigInt(l)) & 1n);
+              autoLights[l] ^= bit;
+            }
+          }
+        }
+
+        if (!used) continue;
+
+        const diffZeros: number[] = [];
+        for (let l = 0; l < n; l++) {
+          const diff = (target[l] ? 1 : 0) - (lights1[l] + autoLights[l]);
+          if (diff !== 0) diffZeros.push(l);
+        }
+
+        if (diffZeros.length > 0) continue;
+
+        const fullWeight = weight1 + weights.reduce((a, b) => a + b, 0);
+        const key = weights.reverse().join("|");
+        const entry = states1.get(key);
+
+        if (entry !== undefined) {
+          const result: number[] = [];
+
+          const stackCombined = [...partial];
+          for (const w of weights) {
+            stackCombined.push([(m - mid) + weights.indexOf(w), w]);
+          }
+          stackCombined.sort((a, b) => a[0] - b[0]);
+
+          for (const [b, _] of stackCombined) {
+            result.push(b);
+          }
+
+          if (result.length <= 20) {
+            const finalLights = new Float64Array(n);
+            for (let l = 0; l < n; l++) {
+              finalLights[l] = target[l] ? 1 : 0;
+            }
+            for (const b of result) {
+              const mask = buttonMask[b];
+              for (let l = 0; l < n; l++) {
+                const bit = Number((mask >> BigInt(l)) & 1n);
+                finalLights[l] ^= bit;
+              }
+            }
+
+            const allMatch = finalLights.every((l, idx) => {
+              const expected = target[idx] ? 1 : 0;
+              return l === expected;
+            });
+            if (allMatch) {
+              return result;
+            }
+          }
+
+          break;
+        }
+      }
+    }
+  }
+  return null;
+}
