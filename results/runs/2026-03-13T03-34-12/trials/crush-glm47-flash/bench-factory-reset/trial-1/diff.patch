+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+
+  if (n === 0) return [];
+
+  if (m === 0) {
+    return lights.every((l) => l === 0) ? new Array(m).fill(0) : null;
+  }
+
+  const A: number[][] = Array.from({ length: n }, () => Array(m).fill(0));
+  for (let i = 0; i < m; i++) {
+    for (const j of buttons[i]) {
+      A[j][i] = 1;
+    }
+  }
+
+  const augmented = A.map((row, i) => [...row, lights[i] % modulus]);
+
+  return solveLinearSystem(augmented, modulus);
+}
+
+function solveLinearSystem(matrix: number[][], modulus: number): number[] | null {
+  let m = matrix.length;
+  let n = matrix[0].length - 1;
+
+  const x: number[] = Array(n).fill(0);
+
+  let rank = 0;
+
+  for (let col = 0; col < n; col++) {
+    let pivot = -1;
+    for (let row = rank; row < m; row++) {
+      if (matrix[row][col] !== 0) {
+        pivot = row;
+        break;
+      }
+    }
+
+    if (pivot === -1) continue;
+
+    const temp = [matrix[rank]];
+    matrix[rank] = matrix[pivot];
+    matrix[pivot] = temp[0];
+
+    const a = matrix[rank][col];
+    const inv = modularInverse(a, modulus);
+    const newRow = matrix[rank].map((v) => (inv * v) % modulus);
+    const newRhs = (inv * matrix[rank][n]) % modulus;
+    matrix[rank] = newRow;
+    matrix[rank][n] = newRhs;
+
+    for (let row = 0; row < m; row++) {
+      if (row !== rank && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        const factorMod = (modulus - factor) % modulus;
+
+        for (let c = 0; c < n; c++) {
+          matrix[row][c] = (matrix[row][c] + factorMod * newRow[c]) % modulus;
+        }
+        matrix[row][n] = (matrix[row][n] + factorMod * newRhs) % modulus;
+      }
+    }
+
+    rank++;
+  }
+
+  for (let row = 0; row < m; row++) {
+    const leadingIndicator = matrix[row].findIndex((v) => v !== 0);
+    if (leadingIndicator < 0) {
+      if (matrix[row][n] !== 0) return null;
+    }
+  }
+
+  if (rank === n) {
+    const x: number[] = Array(n).fill(0);
+    for (let row = 0; row < rank; row++) {
+      const c = matrix[row].reduce((sum: number, v: number, i: number) => {
+        if (i < n && i !== row) {
+          return (sum + v * x[i]) % modulus;
+        }
+        return sum;
+      }, 0);
+      x[row] = (matrix[row][n] - c + modulus) % modulus;
+    }
+    return x;
+  }
+
+  if (m < n) {
+    const x: number[] = Array(n).fill(0);
+    for (let row = 0; row < m; row++) {
+      const leadingIndicator = matrix[row].findIndex((v) => v !== 0);
+      if (leadingIndicator < 0) {
+        if (row < n) x[row] = matrix[row][n];
+      } else {
+        const c = matrix[row].reduce((sum: number, v: number, i: number) => {
+          if (i < n && i !== leadingIndicator) {
+            return (sum + v * x[i]) % modulus;
+          }
+          return sum;
+        }, 0);
+        x[leadingIndicator] = (matrix[row][n] - c + modulus) % modulus;
+      }
+    }
+    return x;
+  }
+
+  return x;
+}
+
+function modularInverse(a: number, p: number): number {
+  let old = [a, 1];
+  let current = [p, 0];
+
+  while (current[0] !== 0) {
+    const q = Math.floor(old[0] / current[0]);
+    const newOld = [current[0], current[1]];
+    const newCurrent = [old[0] - q * current[0], old[1] - q * current[1]];
+    old = newOld;
+    current = newCurrent;
+  }
+
+  const g = old[0];
+  if (g !== 1) throw new Error("No inverse");
+  return (old[1] % p + p) % p;
+}
