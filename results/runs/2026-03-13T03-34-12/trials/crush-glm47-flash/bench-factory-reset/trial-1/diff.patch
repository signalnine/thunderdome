+    // button 0: [1, 2], button 1: [2, 0]
+    // Count[0] = c0*1 + c1*0 = c0 mod 5 = 1 ✓
+    // Count[1] = c0*1 + c1*1 = c0+c1 mod 5 = 3 + c1 = 2 → c1 = 4
+    // Count[2] = c0*0 + c1*1 = c1 = 0 ✓
+    // So: c0=1, c1=4
