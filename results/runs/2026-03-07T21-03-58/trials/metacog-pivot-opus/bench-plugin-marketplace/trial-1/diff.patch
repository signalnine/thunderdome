plugin');\n    });\n\n    it('should throw when name is missing', async () => {\n      await expect(\n        marketplace.installPlugin(makeManifest({ name: '' }))\n      ).rejects.toThrow(/name/);\n    });\n\n    it('should throw when version is missing', async () => {\n      await expect(\n        marketplace.installPlugin(makeManifest({ version: '' }))\n      ).rejects.toThrow(/version/);\n    });\n\n    it('should throw when entryPoint is missing', async () => {\n      await expect(\n        marketplace.installPlugin(makeManifest({ entryPoint: '' }))\n      ).rejects.toThrow(/entryPoint/);\n    });\n\n    it('should resolve dependencies against registry', async () => {\n      // First register the dependency\n      marketplace.registry.register(\n        makeManifest({\n          name: 'dep-plugin',\n          version: '1.0.0',\n          entryPoint: '\"dep\"',\n        })\n      );\n      marketplace.registry.register(\n        makeManifest({\n          name: 'dep-plugin',\n          version: '1.5.0',\n          entryPoint: '\"dep\"',\n        })\n      );\n\n      const manifest = makeManifest({\n        name: 'main-plugin',\n        dependencies: { 'dep-plugin': '^1.0.0' },\n        entryPoint: '\"main\"',\n      });\n\n      const result = await marketplace.installPlugin(manifest);\n      expect(result.resolvedDependencies).toHaveLength(1);\n      expect(result.resolvedDependencies[0].name).toBe('dep-plugin');\n      expect(result.resolvedDependencies[0].version).toBe('1.5.0');\n    });\n\n    it('should reject plugins with circular dependencies', async () => {\n      // Register plugin B that depends on A\n      marketplace.registry.register(\n        makeManifest({\n          name: 'plugin-b',\n          version: '1.0.0',\n          dependencies: { 'plugin-a': '^1.0.0' },\n          entryPoint: '\"b\"',\n        })\n      );\n\n      // Try to install plugin A that depends on B\n      const manifest = makeManifest({\n        name: 'plugin-a',\n        version: '1.0.0',\n        dependencies: { 'plugin-b': '^1.0.0' },\n        entryPoint: '\"a\"',\n      });\n\n      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(\n        /[Cc]ircular/\n      );\n\n      // Plugin A should be removed from registry after failure\n      expect(marketplace.registry.get('plugin-a')).toBeNull();\n    });\n\n    it('should execute the entry point in sandbox', async () => {\n      const manifest = makeManifest({\n        entryPoint: '2 * 21',\n      });\n\n      const result = await marketplace.installPlugin(manifest);\n      expect(result.executionResult.success).toBe(true);\n      expect(result.executionResult.output).toBe(42);\n    });\n\n    it('should return failure if entryPoint throws', async () => {\n      const manifest = makeManifest({\n        entryPoint: 'throw new Error(\"fail\")',\n      });\n\n      const result = await marketplace.installPlugin(manifest);\n      expect(result.executionResult.success).toBe(false);\n      expect(result.executionResult.error).toBe('fail');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":366,"cache_read_input_tokens":28873,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":366},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"dfec3d66-94fc-44bd-a30b-efc442c2df13","uuid":"96f54cc7-b93b-4a0f-a75f-bbe8d56fbd44"}
