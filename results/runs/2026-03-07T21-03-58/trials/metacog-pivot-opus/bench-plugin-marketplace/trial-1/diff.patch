 average for no reviews', () => {\n    expect(reviews.getAverageRating('nonexistent')).toBe(0);\n  });\n\n  it('should flag and list flagged reviews', () => {\n    const review = reviews.addReview({\n      pluginName: 'p1',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 1,\n      comment: 'Bad',\n    });\n\n    reviews.flagReview(review.id);\n\n    const flagged = reviews.getFlaggedReviews();\n    expect(flagged).toHaveLength(1);\n    expect(flagged[0].flagged).toBe(true);\n  });\n\n  it('should remove reviews', () => {\n    const review = reviews.addReview({\n      pluginName: 'p1',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'OK',\n    });\n\n    expect(reviews.removeReview(review.id)).toBe(true);\n    expect(reviews.getReviews('p1')).toHaveLength(0);\n  });\n\n  it('should return false when removing nonexistent review', () => {\n    expect(reviews.removeReview(99999)).toBe(false);\n  });\n\n  it('should get reviews by user', () => {\n    reviews.addReview({\n      pluginName: 'p1',\n      pluginVersion: '1.0.0',\n      userId: 'alice',\n      rating: 5,\n      comment: 'OK',\n    });\n    reviews.addReview({\n      pluginName: 'p2',\n      pluginVersion: '1.0.0',\n      userId: 'alice',\n      rating: 4,\n      comment: 'Good',\n    });\n    reviews.addReview({\n      pluginName: 'p1',\n      pluginVersion: '1.0.0',\n      userId: 'bob',\n      rating: 3,\n      comment: 'Meh',\n    });\n\n    const aliceReviews = reviews.getReviewsByUser('alice');\n    expect(aliceReviews).toHaveLength(2);\n\n    const bobReviews = reviews.getReviewsByUser('bob');\n    expect(bobReviews).toHaveLength(1);\n  });\n\n  it('should count reviews for a plugin', () => {\n    reviews.addReview({\n      pluginName: 'p1',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'OK',\n    });\n    reviews.addReview({\n      pluginName: 'p1',\n      pluginVersion: '1.0.0',\n      userId: 'user2',\n      rating: 4,\n      comment: 'OK',\n    });\n\n    expect(reviews.getReviewCount('p1')).toBe(2);\n    expect(reviews.getReviewCount('nonexistent')).toBe(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":366,"cache_read_input_tokens":28873,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":366},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"dfec3d66-94fc-44bd-a30b-efc442c2df13","uuid":"5b94f138-ee3a-4316-b86f-1622d8e5efaf"}
