+
+    it('should resolve dependencies against registry', async () => {
+      // First register the dependency
+      marketplace.registry.register(
+        makeManifest({
+          name: 'dep-plugin',
+          version: '1.0.0',
+          entryPoint: '"dep"',
+        })
+      );
+      marketplace.registry.register(
+        makeManifest({
+          name: 'dep-plugin',
+          version: '1.5.0',
+          entryPoint: '"dep"',
+        })
+      );
+
+      const manifest = makeManifest({
