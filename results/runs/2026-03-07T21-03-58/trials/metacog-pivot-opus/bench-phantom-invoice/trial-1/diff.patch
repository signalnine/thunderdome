ineItem = db.prepare(`\n    51‚Üí    INSERT INTO line_items (invoice_id, description, quantity, unit_price)\n    52‚Üí    VALUES (?, ?, ?, ?)\n    53‚Üí  `);\n    54‚Üí\n    55‚Üí  const result = insertInvoice.run(\n    56‚Üí    data.customer_id,\n    57‚Üí    data.date,\n    58‚Üí    data.subtotal,\n    59‚Üí    data.discount_rate,\n    60‚Üí    data.tax_rate,\n    61‚Üí    data.total,\n    62‚Üí    data.status || 'draft',\n    63‚Üí  );\n    64‚Üí\n    65‚Üí  const invoiceId = result.lastInsertRowid as number;\n    66‚Üí\n    67‚Üí  if (data.line_items) {\n    68‚Üí    for (const item of data.line_items) {\n    69‚Üí      insertLineItem.run(invoiceId, item.description, item.quantity, item.unit_price);\n    70‚Üí    }\n    71‚Üí  }\n    72‚Üí\n    73‚Üí  return invoiceId;\n    74‚Üí}\n    75‚Üí\n    76‚Üí/**\n    77‚Üí * Retrieve all invoices for a specific customer.\n    78‚Üí */\n    79‚Üíexport function getInvoicesByCustomer(\n    80‚Üí  db: Database.Database,\n    81‚Üí  customerId: string,\n    82‚Üí): Invoice[] {\n    83‚Üí  const stmt = db.prepare(`\n    84‚Üí    SELECT * FROM invoices\n    85‚Üí    WHERE customer_id = ?\n    86‚Üí    ORDER BY date ASC\n    87‚Üí  `);\n    88‚Üí  return stmt.all(customerId) as Invoice[];\n    89‚Üí}\n    90‚Üí"}]},"parent_tool_use_id":null,"session_id":"37c6a327-79af-453e-a9da-801844b16dfd","uuid":"7b5cb041-a530-49d7-b402-2e8e9f6baf82","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/db/queries.ts","content":"import type Database from 'better-sqlite3';\nimport type { Invoice, LineItem } from '../models/invoice.js';\n\n/**\n * Retrieve invoices within a date range (inclusive on both ends).\n */\nexport function getInvoicesByDateRange(\n  db: Database.Database,\n  startDate: string,\n  endDate: string,\n): Invoice[] {\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE date >= ? AND date < ?\n    ORDER BY date ASC\n  `);\n  return stmt.all(startDate, endDate) as Invoice[];\n}\n\n/**\n * Retrieve a single invoice by ID, including its line items.\n */\nexport function getInvoiceById(\n  db: Database.Database,\n  id: number,\n): (Invoice & { line_items: LineItem[] }) | undefined {\n  const invoiceStmt = db.prepare('SELECT * FROM invoices WHERE id = ?');\n  const invoice = invoiceStmt.get(id) as Invoice | undefined;\n\n  if (!invoice) return undefined;\n\n  const itemsStmt = db.prepare('SELECT * FROM line_items WHERE invoice_id = ?');\n  const line_items = itemsStmt.all(id) as LineItem[];\n\n  return { ...invoice, line_items };\n}\n\n/**\n * Create a new invoice with line items.\n */\nexport function createInvoice(\n  db: Database.Database,\n  data: Invoice & { line_items?: LineItem[] },\n): number {\n  const insertInvoice = db.prepare(`\n    INSERT INTO invoices (customer_id, date, subtotal, discount_rate, tax_rate, total, status)\n    VALUES (?, ?, ?, ?, ?, ?, ?)\n  `);\n\n  const insertLineItem = db.prepare(`\n    INSERT INTO line_items (invoice_id, description, quantity, unit_price)\n    VALUES (?, ?, ?, ?)\n  `);\n\n  const result = insertInvoice.run(\n    data.customer_id,\n    data.date,\n    data.subtotal,\n    data.discount_rate,\n    data.tax_rate,\n    data.total,\n    data.status || 'draft',\n  );\n\n  const invoiceId = result.lastInsertRowid as number;\n\n  if (data.line_items) {\n    for (const item of data.line_items) {\n      insertLineItem.run(invoiceId, item.description, item.quantity, item.unit_price);\n    }\n  }\n\n  return invoiceId;\n}\n\n/**\n * Retrieve all invoices for a specific customer.\n */\nexport function getInvoicesByCustomer(\n  db: Database.Database,\n  customerId: string,\n): Invoice[] {\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE customer_id = ?\n    ORDER BY date ASC\n  `);\n  return stmt.all(customerId) as Invoice[];\n}\n","numLines":90,"startLine":1,"totalLines":90}}}
