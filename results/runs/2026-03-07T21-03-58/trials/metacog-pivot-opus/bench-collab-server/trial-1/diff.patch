new file mode 100644
index 0000000..774dd26
--- /dev/null
+++ b/src/websocket.ts
@@ -0,0 +1,205 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage } from 'http';
+import { Server as HttpServer } from 'http';
+import { DocumentManager } from './documents.js';
+import { randomUUID } from 'crypto';
+
+interface ClientConnection {
+  id: string;
+  ws: WebSocket;
+  docId: string;
+}
+
+/**
+ * Messages from client to server:
+ * - { type: 'operation', operation: Operation }
+ *
+ * Messages from server to client:
+ * - { type: 'sync', content: string, version: number }
+ * - { type: 'operation', operation: Operation, version: number }
+ * - { type: 'ack', version: number }
+ * - { type: 'error', message: string }
+ */
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  private manager: DocumentManager;
+  /** Map of docId -> Set of client connections */
+  private rooms: Map<string, Set<ClientConnection>> = new Map();
+
+  constructor(server: HttpServer, manager: DocumentManager) {
+    this.manager = manager;
+    this.wss = new WebSocketServer({ server });
+
+    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {
+      this.handleConnection(ws, req);
+    });
+  }
+
+  private handleConnection(ws: WebSocket, req: IncomingMessage): void {
+    // Extract document ID from URL path: /ws/:docId or /documents/:docId/ws
+    const url = req.url || '';
+    const docId = this.extractDocId(url);
+
+    if (!docId) {
+      ws.send(JSON.stringify({ type: 'error', message: 'No document ID in URL path' }));
+      ws.close(1008, 'No document ID');
+      return;
+    }
+
+    // Check that document exists
+    const doc = this.manager.getDocument(docId);
+    if (!doc) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close(1008, 'Document not found');
+      return;
+    }
+
+    // Activate document for real-time collaboration
+    this.manager.activateDocument(docId);
+
+    const client: ClientConnection = {
+      id: randomUUID(),
+      ws,
+      docId,
+    };
+
+    // Add to room
+    if (!this.rooms.has(docId)) {
+      this.rooms.set(docId, new Set());
+    }
+    this.rooms.get(docId)!.add(client);
+
+    // Send sync message with current state
+    const state = this.manager.getDocumentState(docId);
+    if (state) {
+      ws.send(
+        JSON.stringify({
+          type: 'sync',
+          content: state.content,
+          version: state.version,
+        })
+      );
+    }
+
+    // Handle incoming messages
+    ws.on('message', (data: Buffer | string) => {
+      this.handleMessage(client, data);
+    });
+
+    // Handle disconnection
+    ws.on('close', () => {
+      this.handleDisconnect(client);
+    });
+
+    ws.on('error', () => {
+      this.handleDisconnect(client);
+    });
+  }
+
+  private extractDocId(url: string): string | null {
+    // Match /ws/:docId
+    const wsMatch = url.match(/^\/ws\/([^/?]+)/);
+    if (wsMatch) return wsMatch[1];
+
+    // Match /documents/:docId/ws
+    const docMatch = url.match(/^\/documents\/([^/?]+)\/ws/);
+    if (docMatch) return docMatch[1];
+
+    return null;
+  }
+
+  private handleMessage(client: ClientConnection, data: Buffer | string): void {
+    let message: Record<string, unknown>;
+    try {
+      message = JSON.parse(typeof data === 'string' ? data : data.toString());
+    } catch {
+      client.ws.send(
+        JSON.stringify({ type: 'error', message: 'Invalid JSON' })
+      );
+      return;
+    }
+
+    if (message.type === 'operation') {
+      this.handleOperation(client, message.operation);
+    } else {
+      client.ws.send(
+        JSON.stringify({
+          type: 'error',
+          message: `Unknown message type: ${message.type}`,
+        })
+      );
+    }
+  }
+
+  private handleOperation(
+    client: ClientConnection,
+    rawOp: unknown
+  ): void {
+    const result = this.manager.applyOperation(client.docId, rawOp);
+
+    if ('error' in result) {
+      client.ws.send(
+        JSON.stringify({ type: 'error', message: result.error })
+      );
+      return;
+    }
+
+    // Send ack to the originating client
+    client.ws.send(
+      JSON.stringify({
+        type: 'ack',
+        version: result.version,
+      })
+    );
+
+    // Broadcast the operation to all other clients in the room
+    const room = this.rooms.get(client.docId);
+    if (room) {
+      const broadcastMsg = JSON.stringify({
+        type: 'operation',
+        operation: result.op,
+        version: result.version,
+      });
+
+      for (const peer of room) {
+        if (peer.id !== client.id && peer.ws.readyState === WebSocket.OPEN) {
+          peer.ws.send(broadcastMsg);
+        }
+      }
+    }
+  }
+
+  private handleDisconnect(client: ClientConnection): void {
+    const room = this.rooms.get(client.docId);
+    if (room) {
+      room.delete(client);
+      if (room.size === 0) {
+        this.rooms.delete(client.docId);
+        // Deactivate document when no clients are connected
+        this.manager.deactivateDocument(client.docId);
+      }
+    }
+  }
+
+  /**
+   * Close all connections and shut down the WebSocket server.
+   */
+  close(): Promise<void> {
+    return new Promise((resolve) => {
+      // Close all client connections
+      for (const room of this.rooms.values()) {
+        for (const client of room) {
+          if (client.ws.readyState === WebSocket.OPEN) {
+            client.ws.close(1001, 'Server shutting down');
+          }
+        }
+      }
+      this.rooms.clear();
+
+      this.wss.close(() => {
+        resolve();
+      });
+    });
+  }
+}
