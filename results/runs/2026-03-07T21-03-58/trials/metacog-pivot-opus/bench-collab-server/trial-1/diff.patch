{ error: 'Document not found' });\n      return;\n    }\n    res.status(204).send();\n  });\n\n  // Get version history for a document\n  router.get('/documents/:id/versions', (req: Request, res: Response) => {\n    const doc = manager.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versions = manager.getVersionHistory(req.params.id);\n    res.json(versions);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":403,"cache_read_input_tokens":27985,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":403},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"78cee83b-0336-424e-ae96-53cdb5ab5317","uuid":"4a3b8c35-467d-4eaf-ab49-1dcc7373f766"}
