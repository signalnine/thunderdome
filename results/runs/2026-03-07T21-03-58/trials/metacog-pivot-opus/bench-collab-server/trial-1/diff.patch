+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01UXezWdHzrixNhBHKpqtX1n","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0129nDwnsh8wPu9vgYMLi8b5","name":"Write","input":{"file_path":"/workspace/src/ot.ts","content":"/**\n * Operational Transform (OT) engine for collaborative text editing.\n *\n * Operations are arrays of components:\n * - number > 0: retain N characters\n * - string: insert the string at current position\n * - number < 0: delete |N| characters\n *\n * The total \"input length\" of an operation (sum of retains + |deletes|) must\n * equal the length of the document it's applied to.\n */\n\nexport type OTComponent = number | string;\nexport type OTOperation = OTComponent[];\n\nexport interface Operation {\n  type: 'insert' | 'delete';\n  position: number;\n  text?: string;      // for insert\n  length?: number;    // for delete\n  version: number;    // document version this op was based on\n}\n\n/**\n * Apply a simple operation (insert/delete) to a document string.\n */\nexport function applyOperation(doc: string, op: Operation): string {\n  if (op.type === 'insert') {\n    const text = op.text || '';\n    const pos = Math.min(Math.max(0, op.position), doc.length);\n    return doc.slice(0, pos) + text + doc.slice(pos);\n  } else if (op.type === 'delete') {\n    const len = op.length || 0;\n    const pos = Math.min(Math.max(0, op.position), doc.length);\n    const end = Math.min(pos + len, doc.length);\n    return doc.slice(0, pos) + doc.slice(end);\n  }\n  return doc;\n}\n\n/**\n * Transform operation `op` against a previously applied operation `other`.\n * Returns a new operation that accounts for `other` having already been applied.\n *\n * This is the core of OT: if two clients both edit at version V,\n * and the server applies op1 first, then op2 must be transformed against op1\n * before being applied, so both clients converge.\n */\nexport function transformOperation(op: Operation, other: Operation): Operation {\n  const transformed = { ...op };\n\n  if (other.type === 'insert') {\n    const insertLen = (other.text || '').length;\n    if (op.type === 'insert') {\n      // Both inserts: if op is at or after other's position, shift right\n      if (op.position > other.position) {\n        transformed.position = op.position + insertLen;\n      } else if (op.position === other.position) {\n        // Tie-breaking: earlier op wins (the other op was applied first, so shift us right)\n        transformed.position = op.position + insertLen;\n      }\n    } else if (op.type === 'delete') {\n      if (op.position >= other.position) {\n        transformed.position = op.position + insertLen;\n      } else {\n        // Delete starts before insert position\n        const deleteEnd = op.position + (op.length || 0);\n        if (deleteEnd > other.position) {\n          // Delete spans across the insert point - keep the delete position,\n          // but increase length to account for inserted text? No - we shouldn't\n          // delete text that was just inserted. Keep the original delete range\n          // but shift the part after the insert.\n          // Actually, the standard OT approach: the delete doesn't touch the\n          // newly inserted text. We split: delete before insert stays, delete\n          // after insert shifts by insertLen. But since we use simple ops,\n          // we just keep position and length the same - the inserted text\n          // pushes the latter part of the deleted range, but since the delete\n          // started before the insert, position stays.\n          // The delete length stays the same since we're deleting original chars.\n          transformed.position = op.position;\n        }\n      }\n    }\n  } else if (other.type === 'delete') {\n    const otherLen = other.length || 0;\n    const otherEnd = other.position + otherLen;\n\n    if (op.type === 'insert') {\n      if (op.position <= other.position) {\n        // Insert before delete: no change needed\n      } else if (op.position >= otherEnd) {\n        // Insert after deleted region: shift left\n        transformed.position = op.position - otherLen;\n      } else {\n        // Insert within deleted region: move to delete position\n        transformed.position = other.position;\n      }\n    } else if (op.type === 'delete') {\n      if (op.position >= otherEnd) {\n        // Our delete is entirely after the other delete\n        transformed.position = op.position - otherLen;\n      } else if (op.position + (op.length || 0) <= other.position) {\n        // Our delete is entirely before the other delete: no change\n      } else {\n        // Overlapping deletes\n        const opEnd = op.position + (op.length || 0);\n        const overlapStart = Math.max(op.position, other.position);\n        const overlapEnd = Math.min(opEnd, otherEnd);\n        const overlap = Math.max(0, overlapEnd - overlapStart);\n\n        transformed.position = Math.min(op.position, other.position);\n        transformed.length = (op.length || 0) - overlap;\n\n        // Adjust position if other delete was before us\n        if (other.position < op.position) {\n          transformed.position = op.position - (overlapStart - other.position);\n        }\n\n        if (transformed.length <= 0) {\n          // Nothing left to delete\n          transformed.length = 0;\n        }\n      }\n    }\n  }\n\n  return transformed;\n}\n\n/**\n * Transform an operation against multiple sequential operations.\n * Used when a client sends an op based on version V, but the server\n * has already applied operations V+1, V+2, ..., V+N.\n */\nexport function transformOperationAgainstMany(\n  op: Operation,\n  others: Operation[]\n): Operation {\n  let transformed = op;\n  for (const other of others) {\n    transformed = transformOperation(transformed, other);\n  }\n  return transformed;\n}\n\n/**\n * Validate that an operation is well-formed.\n */\nexport function validateOperation(\n  op: unknown\n): op is Operation {\n  if (!op || typeof op !== 'object') return false;\n  const o = op as Record<string, unknown>;\n  if (o.type !== 'insert' && o.type !== 'delete') return false;\n  if (typeof o.position !== 'number' || o.position < 0) return false;\n  if (!Number.isInteger(o.position)) return false;\n  if (typeof o.version !== 'number' || o.version < 0) return false;\n  if (!Number.isInteger(o.version)) return false;\n  if (o.type === 'insert') {\n    if (typeof o.text !== 'string' || o.text.length === 0) return false;\n  }\n  if (o.type === 'delete') {\n    if (typeof o.length !== 'number' || o.length <= 0) return false;\n    if (!Number.isInteger(o.length)) return false;\n  }\n  return true;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":403,"cache_read_input_tokens":23211,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":403},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"78cee83b-0336-424e-ae96-53cdb5ab5317","uuid":"7214d46f-8f9c-4e9f-a6b8-3d9eacc985fb"}
