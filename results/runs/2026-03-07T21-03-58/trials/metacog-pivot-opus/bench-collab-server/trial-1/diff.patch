   active.operations.push(appliedOp);\n   216→\n   217→    // Persist to DB\n   218→    this.store.addVersion(docId, active.version, newContent, appliedOp);\n   219→\n   220→    return { op: appliedOp, version: active.version, content: newContent };\n   221→  }\n   222→\n   223→  /**\n   224→   * Deactivate a document (when no more clients are connected).\n   225→   * Ensures final state is persisted.\n   226→   */\n   227→  deactivateDocument(docId: string): void {\n   228→    const active = this.activeDocs.get(docId);\n   229→    if (active) {\n   230→      // Final content is already persisted via addVersion calls\n   231→      this.activeDocs.delete(docId);\n   232→    }\n   233→  }\n   234→\n   235→  /**\n   236→   * Check if a document is active in memory.\n   237→   */\n   238→  isActive(docId: string): boolean {\n   239→    return this.activeDocs.has(docId);\n   240→  }\n   241→}\n   242→"}]},"parent_tool_use_id":null,"session_id":"78cee83b-0336-424e-ae96-53cdb5ab5317","uuid":"fbac20a1-a9ef-4193-b306-863af92b0a17","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/documents.ts","content":"import { DocumentStore, DocumentRow } from './db.js';\nimport {\n  Operation,\n  applyOperation,\n  transformOperationAgainstMany,\n  validateOperation,\n} from './ot.js';\n\n/**\n * In-memory document state for real-time collaboration.\n * Tracks the current content, version, and operation history\n * for each active document session.\n */\ninterface ActiveDocument {\n  id: string;\n  content: string;\n  version: number;\n  /** Operations applied since version 0, indexed by version number */\n  operations: Operation[];\n}\n\nexport class DocumentManager {\n  private store: DocumentStore;\n  private activeDocs: Map<string, ActiveDocument> = new Map();\n\n  constructor(store: DocumentStore) {\n    this.store = store;\n  }\n\n  // --- REST CRUD ---\n\n  createDocument(title: string, content: string = ''): DocumentRow {\n    return this.store.createDocument(ti