tion[] = [op];\n    if (op.version < active.version) {\n      const missedOps = active.operations.slice(op.version);\n      transformedOps = transformOperationAgainstMany(op, missedOps);\n    } else if (op.version > active.version) {\n      return {\n        error: `Operation version ${op.version} is ahead of server version ${active.version}`,\n      };\n    }\n\n    // Filter out no-op deletes\n    transformedOps = transformedOps.filter((t) => {\n      if (t.type === 'delete' && (t.length || 0) <= 0) return false;\n      return true;\n    });\n\n    if (transformedOps.length === 0) {\n      // All ops were no-ops\n      return {\n        op,\n        version: active.version,\n        content: active.content,\n      };\n    }\n\n    // Clamp positions to valid range\n    for (const t of transformedOps) {\n      if (t.type === 'insert') {\n        t.position = Math.min(Math.max(0, t.position), active.content.length);\n      }\n    }\n\n    // Apply all transformed operations sequentially\n    const newContent = applyOperations(active.content, transformedOps);\n    active.version++;\n    active.content = newContent;\n\n    // Use the original operation type for the recorded op (for broadcasting)\n    const appliedOp: Operation = {\n      ...op,\n      version: active.version,\n    };\n    active.operations.push(appliedOp);\n\n    // Persist to DB\n    this.store.addVersion(docId, active.version, newContent, appliedOp);\n\n    return { op: appliedOp, version: active.version, content: newContent };\n  }","originalFile":"import { DocumentStore, DocumentRow } from './db.js';\nimport {\n  Operation,\n  applyOperations,\n  transformOperationAgainstMany,\n  validateOperation,\n} from './ot.js';\n\n/**\n * In-memory document state for real-time collaboration.\n * Tracks the current content, version, and operation history\n * for each active document session.\n */\ninterface ActiveDocument {\n  id: string;\n  content: string;\n  version: number;\n  /** Operations applied since version 0, indexed by version number */\n  operations: Operation[];\n}\n\nexport class DocumentManager {\n  private store: DocumentStore;\n  private activeDocs: Map<string, ActiveDocument> = new Map();\n\n  constructor(store: DocumentStore) {\n    this.store = store;\n  }\n\n  // --- REST CRUD ---\n\n  createDocument(title: string, content: string = ''): DocumentRow {\n    return this.store.createDocument(title, content);\n  }\n\n  getDocument(id: string): DocumentRow | undefined {\n    // If the document is active in memory, return the latest content\n    const active = this.activeDocs.get(id);\n    if (active) {\n      const doc = this.store.getDocument(id);\n      if (doc) {\n        return { ...doc, content: active.content };\n      }\n    }\n    return this.store.getDocument(id);\n  }\n\n  listDocuments(): DocumentRow[] {\n    const docs = this.store.listDocuments();\n    // Overlay active in-memory content\n    return docs.map((doc) => {\n      const active = this.activeDocs.get(doc.id);\n      if (active) {\n        return { ...doc, content: active.content };\n      }\n      return doc;\n    });\n  }\n\n  updateDocument(\n    id: string,\n    title: string,\n    content: string\n  ): DocumentRow | undefined {\n    const result = this.store.updateDocument(id, title, content);\n    if (result) {\n      // If document is active, update in-memory state too\n      const active = this.activeDocs.get(id);\n      if (active) {\n        active.content = content;\n        active.version++;\n        active.operations.push({\n          type: 'insert',\n          position: 0,\n          text: content,\n          version: active.version,\n        });\n      }\n    }\n    return result;\n  }\n\n  deleteDocument(id: string): boolean {\n    this.activeDocs.delete(id);\n    return this.store.deleteDocument(id);\n  }\n\n  getVersionHistory(\n    docId: string\n  ): Array<{\n    version: number;\n    content: string;\n    operation: unknown;\n    created_at: string;\n  }> {\n    return this.store.getVersions(docId).map((v) => ({\n      version: v.version,\n      content: v.content,\n      operation: v.operation ? JSON.parse(v.operation) : null,\n      created_at: v.created_at,\n    }));\n  }\n\n  // --- Real-time collaboration ---\n\n  /**\n   * Activate a document for real-time editing.\n   * Loads current state from DB into memory.\n   */\n  activateDocument(docId: string): ActiveDocument | null {\n    if (this.activeDocs.has(docId)) {\n      return this.activeDocs.get(docId)!;\n    }\n\n    const doc = this.store.getDocument(docId);\n    if (!doc) return null;\n\n    const latestVersion = this.store.getLatestVersion(docId);\n    const version = latestVersion ? latestVersion.version : 0;\n\n    const active: ActiveDocument = {\n      id: docId,\n      content: doc.content,\n      version,\n      operations: [],\n    };\n\n    this.activeDocs.set(docId, active);\n    return active;\n  }\n\n  /**\n   * Get current document state for sync message.\n   */\n  getDocumentState(docId: string): { content: string; version: number } | null {\n    const active = this.activeDocs.get(docId);\n    if (active) {\n      return { content: active.content, version: active.version };\n    }\n    const doc = this.store.getDocument(docId);\n    if (!doc) return null;\n    const latestVersion = this.store.getLatestVersion(docId);\n    return { content: doc.content, version: latestVersion?.version ?? 0 };\n  }\n\n  private store_getLatestVersion(docId: string) {\n    return this.store.getLatestVersion(docId);\n  }\n\n  /**\n   * Apply an operation from a client.\n   * Handles OT: transforms the op against any operations that occurred\n   * between the client's base version and the current server version.\n   *\n   * Returns the transformed operation and new version, or null on error.\n   */\n  applyOperation(\n    docId: string,\n    rawOp: unknown\n  ): { op: Operation; version: number; content: string } | { error: string } {\n    if (!validateOperation(rawOp)) {\n      return { error: 'Invalid operation' };\n    }\n\n    const op = rawOp as Operation;\n\n    let active = this.activeDocs.get(docId);\n    if (!active) {\n      const activated = this.activateDocument(docId);\n      if (!activated) {\n        return { error: 'Document not found' };\n      }\n      active = activated;\n    }\n\n    // Transform against operations that happened since the client's base version\n    let transformed = op;\n    if (op.version < active.version) {\n      const missedOps = active.operations.slice(op.version);\n      transformed = transformOperationAgainstMany(op, missedOps);\n    } else if (op.version > active.version) {\n      return { error: `Operation version ${op.version} is ahead of server version ${active.version}` };\n    }\n\n    // Validate the operation against current document state\n    if (transformed.type === 'insert') {\n      if (transformed.position > active.content.length) {\n        transformed.position = active.content.length;\n      }\n    } else if (transformed.type === 'delete') {\n      if (transformed.position >= active.content.length) {\n        return { error: 'Delete position out of bounds' };\n      }\n      const deleteLen = transformed.length || 0;\n      if (transformed.position + deleteLen > active.content.length) {\n        transformed.length = active.content.length - transformed.position;\n      }\n      if ((transformed.length || 0) <= 0) {\n        // No-op delete\n        return {\n          op: transformed,\n          version: active.version,\n          content: active.content,\n        };\n      }\n    }\n\n    // Apply the transformed operation\n    const newContent = applyOperation(active.content, transformed);\n    active.version++;\n    active.content = newContent;\n\n    // Record the operation with the new version\n    const appliedOp: Operation = { ...transformed, version: active.version };\n    active.operations.push(appliedOp);\n\n    // Persist to DB\n    this.store.addVersion(docId, active.version, newContent, appliedOp);\n\n    return { op: appliedOp, version: active.version, content: newContent };\n  }\n\n  /**\n   * Deactivate a document (when no more clients are connected).\n   * Ensures final state is persisted.\n   */\n  deactivateDocument(docId: string): void {\n    const active = this.activeDocs.get(docId);\n    if (active) {\n      // Final content is already persisted via addVersion calls\n      this.activeDocs.delete(docId);\n    }\n  }\n\n  /**\n   * Check if a document is active in memory.\n   */\n  isActive(docId: string): boolean {\n    return this.activeDocs.has(docId);\n  }\n}\n","structuredPatch":[{"oldStart":143,"oldLines":10,"newStart":143,"newLines":6,"lines":["     return { content: doc.content, version: latestVersion?.version ?? 0 };","   }"," ","-  private store_getLatestVersion(docId: string) {","-    return this.store.getLatestVersion(docId);","-  }","-","   /**","    * Apply an operation from a client.","    * Handles OT: transforms the op against any operations that occurred"]},{"oldStart":174,"oldLines":44,"newStart":170,"newLines":48,"lines":["     }"," ","     // Transform against operations that happened since the client's base version","-    let transformed = op;","+    let transformedOps: Operation[] = [op];","     if (op.version < active.version) {","       const missedOps = active.operations.slice(op.version);","-      transformed = transformOperationAgainstMany(op, missedOps);","+      transformedOps = transformOperationAgainstMany(op, missedOps);","     } else if (op.version > active.version) {","-      return { error: `Operation version ${op.version} is ahead of server version ${active.version}` };","+      return {","+        error: `Operation version ${op.version} is ahead of server version ${active.version}`,","+      };","     }"," ","-    // Validate the operation against current document state","-    if (transformed.type === 'insert') {","-      if (transformed.position > active.content.length) {",