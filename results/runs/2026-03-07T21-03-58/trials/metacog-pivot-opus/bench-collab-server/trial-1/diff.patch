 return connectAndSync(docId).then(({ ws }) => ws);\n}\n\nfunction waitForMessage(\n  ws: WebSocket,\n  filter?: (msg: Record<string, unknown>) => boolean\n): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error('Timeout waiting for message')), 5000);\n    const handler = (data: WebSocket.Data) => {\n      const msg = JSON.parse(data.toString());\n      if (!filter || filter(msg)) {\n        clearTimeout(timeout);\n        ws.off('message', handler);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n  });\n}","originalFile":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport request from 'supertest';\nimport WebSocket from 'ws';\nimport { createApp, AppInstance } from './server.js';\n\nlet app: AppInstance;\nlet port: number;\n\nfunction wsUrl(docId: string): string {\n  return `ws://localhost:${port}/ws/${docId}`;\n}\n\nfunction connectWs(docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(wsUrl(docId));\n    ws.on('open', () => resolve(ws));\n    ws.on('error', (err) => reject(err));\n  });\n}\n\nfunction waitForMessage(\n  ws: WebSocket,\n  filter?: (msg: Record<string, unknown>) => boolean\n): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timeout = setTimeout(() => reject(new Error('Timeout waiting for message')), 5000);\n    const handler = (data: WebSocket.Data) => {\n      const msg = JSON.parse(data.toString());\n      if (!filter || filter(msg)) {\n        clearTimeout(timeout);\n        ws.off('message', handler);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n  });\n}\n\nfunction sendOp(ws: WebSocket, op: Record<string, unknown>): void {\n  ws.send(JSON.stringify({ type: 'operation', operation: op }));\n}\n\ndescribe('Collaborative Document Editor', () => {\n  beforeEach(async () => {\n    app = createApp(); // in-memory database\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  describe('REST API', () => {\n    it('should create a document', async () => {\n      const res = await request(app.app)\n        .post('/documents')\n        .send({ title: 'Test Doc', content: 'Hello' })\n        .expect(201);\n\n      expect(res.body.id).toBeDefined();\n      expect(res.body.title).toBe('Test Doc');\n      expect(res.body.content).toBe('Hello');\n    });\n\n    it('should list documents', async () => {\n      await request(app.app)\n        .post('/documents')\n        .send({ title: 'Doc 1', content: 'A' })\n        .expect(201);\n      await request(app.app)\n        .post('/documents')\n        .send({ title: 'Doc 2', content: 'B' })\n        .expect(201);\n\n      const res = await request(app.app).get('/documents').expect(200);\n      expect(res.body.length).toBe(2);\n    });\n\n    it('should get a single document', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'My Doc', content: 'Content here' })\n        .expect(201);\n\n      const res = await request(app.app)\n        .get(`/documents/${createRes.body.id}`)\n        .expect(200);\n\n      expect(res.body.title).toBe('My Doc');\n      expect(res.body.content).toBe('Content here');\n    });\n\n    it('should update a document', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'Original', content: 'old' })\n        .expect(201);\n\n      const res = await request(app.app)\n        .put(`/documents/${createRes.body.id}`)\n        .send({ title: 'Updated', content: 'new' })\n        .expect(200);\n\n      expect(res.body.title).toBe('Updated');\n      expect(res.body.content).toBe('new');\n    });\n\n    it('should delete a document', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'To Delete', content: '' })\n        .expect(201);\n\n      await request(app.app)\n        .delete(`/documents/${createRes.body.id}`)\n        .expect(204);\n\n      await request(app.app)\n        .get(`/documents/${createRes.body.id}`)\n        .expect(404);\n    });\n\n    it('should return 404 for non-existent document', async () => {\n      await request(app.app).get('/documents/nonexistent').expect(404);\n    });\n\n    it('should reject document creation without title', async () => {\n      await request(app.app)\n        .post('/documents')\n        .send({ content: 'no title' })\n        .expect(400);\n    });\n\n    it('should return version history', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'Versioned', content: 'v0' })\n        .expect(201);\n\n      const res = await request(app.app)\n        .get(`/documents/${createRes.body.id}/versions`)\n        .expect(200);\n\n      expect(res.body.length).toBeGreaterThanOrEqual(1);\n      expect(res.body[0].version).toBe(0);\n    });\n  });\n\n  describe('WebSocket Collaboration', () => {\n    it('should send sync message on connect', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'WS Test', content: 'Hello World' })\n        .expect(201);\n\n      const ws = await connectWs(createRes.body.id);\n      const msg = await waitForMessage(ws, (m) => m.type === 'sync');\n\n      expect(msg.type).toBe('sync');\n      expect(msg.content).toBe('Hello World');\n      expect(msg.version).toBe(0);\n\n      ws.close();\n    });\n\n    it('should apply an insert operation and broadcast', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'Collab', content: 'Hello' })\n        .expect(201);\n      const docId = createRes.body.id;\n\n      // Connect two clients\n      const ws1 = await connectWs(docId);\n      const sync1 = await waitForMessage(ws1, (m) => m.type === 'sync');\n      expect(sync1.content).toBe('Hello');\n\n      const ws2 = await connectWs(docId);\n      const sync2 = await waitForMessage(ws2, (m) => m.type === 'sync');\n      expect(sync2.content).toBe('Hello');\n\n      // Client 1 inserts \" World\" at position 5\n      const broadcastPromise = waitForMessage(ws2, (m) => m.type === 'operation');\n      sendOp(ws1, { type: 'insert', position: 5, text: ' World', version: 0 });\n\n      // Client 1 should get an ack\n      const ack = await waitForMessage(ws1, (m) => m.type === 'ack');\n      expect(ack.version).toBe(1);\n\n      // Client 2 should get the broadcast\n      const broadcast = await broadcastPromise;\n      expect(broadcast.type).toBe('operation');\n      expect(broadcast.version).toBe(1);\n\n      // Verify via REST\n      const docRes = await request(app.app)\n        .get(`/documents/${docId}`)\n        .expect(200);\n      expect(docRes.body.content).toBe('Hello World');\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('should apply a delete operation', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'Del Test', content: 'Hello World' })\n        .expect(201);\n      const docId = createRes.body.id;\n\n      const ws = await connectWs(docId);\n      await waitForMessage(ws, (m) => m.type === 'sync');\n\n      sendOp(ws, { type: 'delete', position: 5, length: 6, version: 0 });\n\n      const ack = await waitForMessage(ws, (m) => m.type === 'ack');\n      expect(ack.version).toBe(1);\n\n      const docRes = await request(app.app)\n        .get(`/documents/${docId}`)\n        .expect(200);\n      expect(docRes.body.content).toBe('Hello');\n\n      ws.close();\n    });\n\n    it('should reject invalid operations', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'Invalid', content: 'Test' })\n        .expect(201);\n\n      const ws = await connectWs(docId(createRes));\n      await waitForMessage(ws, (m) => m.type === 'sync');\n\n      // Send invalid operation (missing required fields)\n      ws.send(JSON.stringify({ type: 'operation', operation: { type: 'insert' } }));\n      const errMsg = await waitForMessage(ws, (m) => m.type === 'error');\n      expect(errMsg.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('should reject invalid JSON', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'BadJSON', content: '' })\n        .expect(201);\n\n      const ws = await connectWs(docId(createRes));\n      await waitForMessage(ws, (m) => m.type === 'sync');\n\n      ws.send('not json at all');\n      const errMsg = await waitForMessage(ws, (m) => m.type === 'error');\n      expect(errMsg.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('should close connection for non-existent document', async () => {\n      const ws = new WebSocket(`ws://localhost:${port}/ws/nonexistent`);\n\n      await new Promise<void>((resolve) => {\n        ws.on('close', () => resolve());\n      });\n    });\n  });\n\n  describe('Concurrent Editing (OT)', () => {\n    it('should handle two simultaneous inserts at the same position', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'Concurrent', content: 'AB' })\n        .expect(201);\n      const docId = createRes.body.id;\n\n      const ws1 = await connectWs(docId);\n      await waitForMessage(ws1, (m) => m.type === 'sync');\n\n      const ws2 = await connectWs(docId);\n      await waitForMessage(ws2, (m) => m.type === 'sync');\n\n      // Both clients insert at position 1, both based on version 0\n      sendOp(ws1, { type: 'insert', position: 1, text: 'X', version: 0 });\n      const ack1 = await waitForMessage(ws1, (m) => m.type === 'ack');\n      expect(ack1.version).toBe(1);\n\