=== 'sync');\n      expect(sync2.content).toBe('Hello');\n\n      // Client 1 inserts \" World\" at position 5\n      const broadcastPromise = waitForMessage(ws2, (m) => m.type === 'operation');\n      sendOp(ws1, { type: 'insert', position: 5, text: ' World', version: 0 });\n\n      // Client 1 should get an ack\n      const ack = await waitForMessage(ws1, (m) => m.type === 'ack');\n      expect(ack.version).toBe(1);\n\n      // Client 2 should get the broadcast\n      const broadcast = await broadcastPromise;\n      expect(broadcast.type).toBe('operation');\n      expect(broadcast.version).toBe(1);\n\n      // Verify via REST\n      const docRes = await request(app.app)\n        .get(`/documents/${docId}`)\n        .expect(200);\n      expect(docRes.body.content).toBe('Hello World');\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('should apply a delete operation', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'Del Test', content: 'Hello World' })\n        .expect(201);\n      const docId = createRes.body.id;\n\n      const ws = await connectWs(docId);\n      await waitForMessage(ws, (m) => m.type === 'sync');\n\n      sendOp(ws, { type: 'delete', position: 5, length: 6, version: 0 });\n\n      const ack = await waitForMessage(ws, (m) => m.type === 'ack');\n      expect(ack.version).toBe(1);\n\n      const docRes = await request(app.app)\n        .get(`/documents/${docId}`)\n        .expect(200);\n      expect(docRes.body.content).toBe('Hello');\n\n      ws.close();\n    });\n\n    it('should reject invalid operations', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'Invalid', content: 'Test' })\n        .expect(201);\n\n      const ws = await connectWs(docId(createRes));\n      await waitForMessage(ws, (m) => m.type === 'sync');\n\n      // Send invalid operation (missing required fields)\n      ws.send(JSON.stringify({ type: 'operation', operation: { type: 'insert' } }));\n      const errMsg = await waitForMessage(ws, (m) => m.type === 'error');\n      expect(errMsg.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('should reject invalid JSON', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'BadJSON', content: '' })\n        .expect(201);\n\n      const ws = await connectWs(docId(createRes));\n      await waitForMessage(ws, (m) => m.type === 'sync');\n\n      ws.send('not json at all');\n      const errMsg = await waitForMessage(ws, (m) => m.type === 'error');\n      expect(errMsg.type).toBe('error');\n\n      ws.close();\n    });\n\n    it('should close connection for non-existent document', async () => {\n      const ws = new WebSocket(`ws://localhost:${port}/ws/nonexistent`);\n\n      await new Promise<void>((resolve) => {\n        ws.on('close', () => resolve());\n      });\n    });\n  });\n\n  describe('Concurrent Editing (OT)', () => {\n    it('should handle two simultaneous inserts at the same position', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'Concurrent', content: 'AB' })\n        .expect(201);\n      const docId = createRes.body.id;\n\n      const ws1 = await connectWs(docId);\n      await waitForMessage(ws1, (m) => m.type === 'sync');\n\n      const ws2 = await connectWs(docId);\n      await waitForMessage(ws2, (m) => m.type === 'sync');\n\n      // Both clients insert at position 1, both based on version 0\n      sendOp(ws1, { type: 'insert', position: 1, text: 'X', version: 0 });\n      const ack1 = await waitForMessage(ws1, (m) => m.type === 'ack');\n      expect(ack1.version).toBe(1);\n\n      sendOp(ws2, { type: 'insert', position: 1, text: 'Y', version: 0 });\n      const ack2 = await waitForMessage(ws2, (m) => m.type === 'ack');\n      expect(ack2.version).toBe(2);\n\n      // Both inserts should be preserved\n      const docRes = await request(app.app)\n        .get(`/documents/${docId}`)\n        .expect(200);\n\n      const content = docRes.body.content;\n      expect(content).toContain('X');\n      expect(content).toContain('Y');\n      expect(content).toContain('A');\n      expect(content).toContain('B');\n      expect(content.length).toBe(4); // AB + X + Y\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('should handle insert and delete at overlapping positions', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'InsertDelete', content: 'ABCDEF' })\n        .expect(201);\n      const docId = createRes.body.id;\n\n      const ws1 = await connectWs(docId);\n      await waitForMessage(ws1, (m) => m.type === 'sync');\n\n      const ws2 = await connectWs(docId);\n      await waitForMessage(ws2, (m) => m.type === 'sync');\n\n      // Client 1: insert \"X\" at position 3 (between C and D), version 0\n      sendOp(ws1, { type: 'insert', position: 3, text: 'X', version: 0 });\n      await waitForMessage(ws1, (m) => m.type === 'ack');\n\n      // Client 2: delete 2 chars at position 2 (CD), version 0\n      // After OT against client 1's insert, this delete should still remove original chars\n      sendOp(ws2, { type: 'delete', position: 2, length: 2, version: 0 });\n      await waitForMessage(ws2, (m) => m.type === 'ack');\n\n      const docRes = await request(app.app)\n        .get(`/documents/${docId}`)\n        .expect(200);\n\n      // The insert X should be preserved, CD should be deleted\n      const content = docRes.body.content;\n      expect(content).toContain('A');\n      expect(content).toContain('B');\n      expect(content).toContain('X');\n      expect(content).toContain('E');\n      expect(content).toContain('F');\n\n      ws1.close();\n      ws2.close();\n    });\n\n    it('should handle 10 concurrent clients without corruption', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'Many Clients', content: '' })\n        .expect(201);\n      const docId = createRes.body.id;\n\n      const clients: WebSocket[] = [];\n\n      // Connect 10 clients\n      for (let i = 0; i < 10; i++) {\n        const ws = await connectWs(docId);\n        await waitForMessage(ws, (m) => m.type === 'sync');\n        clients.push(ws);\n      }\n\n      // Each client inserts a unique character, sequentially to avoid race conditions\n      for (let i = 0; i < 10; i++) {\n        const ws = clients[i];\n        sendOp(ws, {\n          type: 'insert',\n          position: 0,\n          text: String(i),\n          version: i,\n        });\n        // Wait for ack\n        await waitForMessage(ws, (m) => m.type === 'ack');\n      }\n\n      // Small delay for all broadcasts to settle\n      await new Promise((r) => setTimeout(r, 200));\n\n      // Verify the document contains all 10 characters\n      const docRes = await request(app.app)\n        .get(`/documents/${docId}`)\n        .expect(200);\n\n      const content = docRes.body.content;\n      expect(content.length).toBe(10);\n      for (let i = 0; i < 10; i++) {\n        expect(content).toContain(String(i));\n      }\n\n      // Clean up\n      for (const ws of clients) {\n        ws.close();\n      }\n    });\n  });\n\n  describe('Persistence', () => {\n    it('should persist documents and versions across server restarts', async () => {\n      const tmpDb = `/tmp/test-collab-${Date.now()}.db`;\n\n      // Start first server\n      const app1 = createApp(tmpDb);\n      const port1 = await app1.start(0);\n\n      // Create a document\n      const createRes = await request(app1.app)\n        .post('/documents')\n        .send({ title: 'Persistent', content: 'Original' })\n        .expect(201);\n      const docId = createRes.body.id;\n\n      // Make an edit via WebSocket\n      const ws = new WebSocket(`ws://localhost:${port1}/ws/${docId}`);\n      await new Promise<void>((resolve, reject) => {\n        ws.on('open', () => resolve());\n        ws.on('error', (err) => reject(err));\n      });\n      await new Promise<void>((resolve) => {\n        ws.on('message', (data) => {\n          const msg = JSON.parse(data.toString());\n          if (msg.type === 'sync') resolve();\n        });\n      });\n\n      sendOp(ws, { type: 'insert', position: 8, text: ' Content', version: 0 });\n      await new Promise<void>((resolve) => {\n        ws.on('message', (data) => {\n          const msg = JSON.parse(data.toString());\n          if (msg.type === 'ack') resolve();\n        });\n      });\n\n      ws.close();\n      await app1.stop();\n\n      // Start second server with same DB\n      const app2 = createApp(tmpDb);\n      await app2.start(0);\n\n      // Verify document persisted\n      const docRes = await request(app2.app)\n        .get(`/documents/${docId}`)\n        .expect(200);\n\n      expect(docRes.body.title).toBe('Persistent');\n      expect(docRes.body.content).toBe('Original Content');\n\n      // Verify version history persisted\n      const versionsRes = await request(app2.app)\n        .get(`/documents/${docId}/versions`)\n        .expect(200);\n\n      expect(versionsRes.body.length).toBeGreaterThanOrEqual(2);\n\n      await app2.stop();\n\n      // Clean up\n      const { unlinkSync } = await import('fs');\n      try {\n        unlinkSync(tmpDb);\n        unlinkSync(tmpDb + '-wal');\n        unlinkSync(tmpDb + '-shm');\n      } catch {\n        // ignore\n      }\n    });\n  });\n\n  describe('Version History', () => {\n    it('should track version history through WebSocket edits', async () => {\n      const createRes = await request(app.app)\n        .post('/documents')\n        .send({ title: 'History', content: '' })\n        .expect(201);\n      const docId = createRes.body.id;\n\n      const ws = await connectWs(docId);\n      await waitForMessage(ws, (m) => m.type === 'sync');\n\n      // Make several edits\n      sendOp(ws, { type: 'insert', position: 0, text: 'Hello', version: 0 });\n      await waitForMessage(ws, (m) => m.type === 'ack');\n\n      sendOp(ws, { type: 'insert', position: 5, text: ' World', version: 1 });\n      await waitForMessage(ws, (m) => m.type === 'ack');\n\n      sendOp(ws, { type: 'insert', position: 11, text: '!', version: 2 });\n      await waitForMessage(ws, (m) => m.type === 'ack');\n\n      const versionsRes = await request(app.app)\n        .get(`/documents/${docId}/versions`)\n        .expect(200);\n\n      // Version 0 (initial) + 3 edits = 4 versions\n      expect(versionsRes.body.length).toBe(4);\n      expect(versionsRes.body[3].content).toBe('Hello World!');\n\n      ws.close();\n    });\n  });\n});\n\n// Helper to extract docId from supertest response\nfunction docId(res: request.Response): string {\n  return res.body.id;\n}\n","structuredPatch":[],"originalFile":null}}
