osition: op.position,\n            length: beforeLen,\n          });\n        }\n        if (afterLen > 0) {\n          parts.push({\n            ...op,\n            position: other.position + insertLen - (beforeLen > 0 ? beforeLen : 0),\n            length: afterLen,\n          });\n        }\n\n        // After applying the first delete, positions shift.\n        // Let's recalculate: after part 1 deletes [op.position, other.position),\n        // the insert text starts at (op.position) now, so part 2 should delete\n        // at (op.position + insertLen) for afterLen chars.\n        if (parts.length === 2) {\n          parts[1].position = parts[0].position + insertLen;\n        } else if (parts.length === 1 && beforeLen === 0) {\n          // Only the \"after\" part: delete starts after the insert\n          parts[0].position = other.position + insertLen;\n        }\n\n        return parts.length > 0 ? parts : [{ ...op, length: 0 }];\n      }\n    }\n  } else {\n    // other is delete\n    const otherLen = other.length || 0;\n    const otherEnd = other.position + otherLen;\n\n    if (op.type === 'insert') {\n      if (op.position <= other.position) {\n        // Insert before or at delete start: no change\n        return [{ ...op }];\n      } else if (op.position >= otherEnd) {\n        // Insert after deleted region: shift left\n        return [{ ...op, position: op.position - otherLen }];\n      } else {\n        // Insert within deleted region: move to delete position\n        return [{ ...op, position: other.position }];\n      }\n    } else {\n      // Both deletes\n      const opLen = op.length || 0;\n      const opEnd = op.position + opLen;\n\n      if (op.position >= otherEnd) {\n        // Our delete is entirely after the other delete\n        return [{ ...op, position: op.position - otherLen }];\n      } else if (opEnd <= other.position) {\n        // Our delete is entirely before the other delete: no change\n        return [{ ...op }];\n      } else {\