@@ -0,0 +1,202 @@
+/**
+ * Operational Transform (OT) engine for collaborative text editing.
+ *
+ * Uses simple insert/delete operations with server-authoritative OT.
+ */
+
+export interface Operation {
+  type: 'insert' | 'delete';
+  position: number;
+  text?: string; // for insert
+  length?: number; // for delete
+  version: number; // document version this op was based on
+}
+
+/**
+ * Apply a simple operation (insert/delete) to a document string.
+ */
+export function applyOperation(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const text = op.text || '';
+    const pos = Math.min(Math.max(0, op.position), doc.length);
+    return doc.slice(0, pos) + text + doc.slice(pos);
+  } else if (op.type === 'delete') {
+    const len = op.length || 0;
+    const pos = Math.min(Math.max(0, op.position), doc.length);
+    const end = Math.min(pos + len, doc.length);
+    return doc.slice(0, pos) + doc.slice(end);
+  }
+  return doc;
+}
+
+/**
+ * Apply multiple operations sequentially to a document.
+ */
+export function applyOperations(doc: string, ops: Operation[]): string {
+  let result = doc;
+  for (const op of ops) {
+    result = applyOperation(result, op);
+  }
+  return result;
+}
+
+/**
+ * Transform operation `op` against a previously applied operation `other`.
+ * Returns an array of operations (may be split if a delete spans an insert).
+ *
+ * This is the core of OT: if two clients both edit at version V,
+ * and the server applies op1 first, then op2 must be transformed against op1
+ * before being applied, so both clients converge.
+ */
+export function transformOperation(
+  op: Operation,
+  other: Operation
+): Operation[] {
+  if (other.type === 'insert') {
+    const insertLen = (other.text || '').length;
+
+    if (op.type === 'insert') {
+      if (op.position >= other.position) {
+        // Our insert is at or after the other insert: shift right
+        return [{ ...op, position: op.position + insertLen }];
+      }
+      // Our insert is before the other insert: no change
+      return [{ ...op }];
+    } else {
+      // op is delete, other is insert
+      const deleteEnd = op.position + (op.length || 0);
+
+      if (op.position >= other.position) {
+        // Delete starts at or after insert: shift right
+        return [{ ...op, position: op.position + insertLen }];
+      } else if (deleteEnd <= other.position) {
+        // Delete ends before insert: no change needed
+        return [{ ...op }];
+      } else {
+        // Delete spans the insert point. We must split the delete
+        // into two parts to preserve the inserted text.
+        // Part 1: delete from op.position to other.position
+        // Part 2: delete from (other.position + insertLen) for remaining length
+        const beforeLen = other.position - op.position;
+        const afterLen = deleteEnd - other.position;
+        const parts: Operation[] = [];
+
+        if (beforeLen > 0) {
+          parts.push({
+            ...op,
+            position: op.position,
+            length: beforeLen,
+          });
+        }
+        if (afterLen > 0) {
+          parts.push({
+            ...op,
+            position: other.position + insertLen - (beforeLen > 0 ? beforeLen : 0),
+            length: afterLen,
+          });
+        }
+
+        // After applying the first delete, positions shift.
+        // Let's recalculate: after part 1 deletes [op.position, other.position),
+        // the insert text starts at (op.position) now, so part 2 should delete
+        // at (op.position + insertLen) for afterLen chars.
+        if (parts.length === 2) {
+          parts[1].position = parts[0].position + insertLen;
+        } else if (parts.length === 1 && beforeLen === 0) {
+          // Only the "after" part: delete starts after the insert
+          parts[0].position = other.position + insertLen;
+        }
+
+        return parts.length > 0 ? parts : [{ ...op, length: 0 }];
+      }
+    }
+  } else {
+    // other is delete
+    const otherLen = other.length || 0;
+    const otherEnd = other.position + otherLen;
+
+    if (op.type === 'insert') {
+      if (op.position <= other.position) {
+        // Insert before or at delete start: no change
+        return [{ ...op }];
+      } else if (op.position >= otherEnd) {
+        // Insert after deleted region: shift left
+        return [{ ...op, position: op.position - otherLen }];
+      } else {
+        // Insert within deleted region: move to delete position
+        return [{ ...op, position: other.position }];
+      }
+    } else {
+      // Both deletes
+      const opLen = op.length || 0;
+      const opEnd = op.position + opLen;
+
+      if (op.position >= otherEnd) {
+        // Our delete is entirely after the other delete
+        return [{ ...op, position: op.position - otherLen }];
+      } else if (opEnd <= other.position) {
+        // Our delete is entirely before the other delete: no change
+        return [{ ...op }];
+      } else {
+        // Overlapping deletes - reduce our delete by the overlap
+        const overlapStart = Math.max(op.position, other.position);
+        const overlapEnd = Math.min(opEnd, otherEnd);
+        const overlap = Math.max(0, overlapEnd - overlapStart);
+        const newLen = opLen - overlap;
+
+        if (newLen <= 0) {
+          // Entire delete was already handled by the other delete
+          return [{ ...op, position: op.position, length: 0 }];
+        }
+
+        // New position: shift left by amount of other's delete before our start
+        let newPos = op.position;
+        if (other.position < op.position) {
+          newPos = op.position - Math.min(otherLen, op.position - other.position);
+        }
+
+        return [{ ...op, position: newPos, length: newLen }];
+      }
+    }
+  }
+}
+
+/**
+ * Transform an operation against multiple sequential operations.
+ * Returns an array of operations to apply.
+ */
+export function transformOperationAgainstMany(
+  op: Operation,
+  others: Operation[]
+): Operation[] {
+  let ops: Operation[] = [op];
+  for (const other of others) {
+    const newOps: Operation[] = [];
+    for (const o of ops) {
+      newOps.push(...transformOperation(o, other));
+    }
+    ops = newOps;
+  }
+  return ops;
+}
+
+/**
+ * Validate that an operation is well-formed.
+ */
+export function validateOperation(op: unknown): op is Operation {
+  if (!op || typeof op !== 'object') return false;
+  const o = op as Record<string, unknown>;
+  if (o.type !== 'insert' && o.type !== 'delete') return false;
+  if (typeof o.position !== 'number' || o.position < 0) return false;
+  if (!Number.isInteger(o.position)) return false;
+  if (typeof o.version !== 'number' || o.version < 0) return false;
+  if (!Number.isInteger(o.version)) return false;
+  if (o.type === 'insert') {
+    if (typeof o.text !== 'string' || o.text.length === 0) return false;
+  }
+  if (o.type === 'delete') {
+    if (typeof o.length !== 'number' || o.length <= 0) return false;
+    if (!Number.isInteger(o.length)) return false;
+  }
+  return true;
+}
