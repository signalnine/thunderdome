@@ -0,0 +1,68 @@
+import express from 'express';
+import { createServer, Server as HttpServer } from 'http';
+import { createDatabase, DocumentStore } from './db.js';
+import { DocumentManager } from './documents.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './websocket.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath);
+  const store = new DocumentStore(db);
+  const manager = new DocumentManager(store);
+
+  const app = express();
+  app.use(express.json());
+
+  // Mount REST routes
+  const router = createRouter(manager);
+  app.use('/api', router);
+  // Also mount at root for convenience
+  app.use(router);
+
+  // Health check
+  app.get('/health', (_req, res) => {
+    res.json({ status: 'ok' });
+  });
+
+  let httpServer: HttpServer;
+  let collabServer: CollaborationServer;
+
+  return {
+    app,
+
+    async start(port?: number): Promise<number> {
+      httpServer = createServer(app);
+      collabServer = new CollaborationServer(httpServer, manager);
+
+      return new Promise((resolve) => {
+        httpServer.listen(port ?? 0, () => {
+          const addr = httpServer.address();
+          const actualPort =
+            typeof addr === 'object' && addr ? addr.port : port ?? 0;
+          resolve(actualPort);
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      if (collabServer) {
+        await collabServer.close();
+      }
+      if (httpServer) {
+        await new Promise<void>((resolve, reject) => {
+          httpServer.close((err) => {
+            if (err) reject(err);
+            else resolve();
+          });
+        });
+      }
+      store.close();
+    },
+  };
+}
