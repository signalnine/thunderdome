@@ -0,0 +1,181 @@
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+import { readFileSync } from 'fs';
+import { resolve, dirname } from 'path';
+import { fileURLToPath } from 'url';
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDatabase(dbPath?: string): Database.Database {
+  const db = new Database(dbPath || ':memory:');
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  // Load schema
+  const __dirname = dirname(fileURLToPath(import.meta.url));
+  const schemaPath = resolve(__dirname, '..', 'schema.sql');
+  try {
+    const schema = readFileSync(schemaPath, 'utf-8');
+    db.exec(schema);
+  } catch {
+    // If schema file not found, create tables inline
+    db.exec(`
+      CREATE TABLE IF NOT EXISTS documents (
+        id TEXT PRIMARY KEY,
+        title TEXT NOT NULL,
+        content TEXT NOT NULL DEFAULT '',
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+      CREATE TABLE IF NOT EXISTS versions (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+        version INTEGER NOT NULL,
+        content TEXT NOT NULL,
+        operation TEXT,
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        UNIQUE(document_id, version)
+      );
+      CREATE TABLE IF NOT EXISTS active_connections (
+        id TEXT PRIMARY KEY,
+        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+        connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+    `);
+  }
+
+  return db;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+
+  private stmts: {
+    insertDoc: Database.Statement;
+    getDoc: Database.Statement;
+    listDocs: Database.Statement;
+    updateDoc: Database.Statement;
+    deleteDoc: Database.Statement;
+    insertVersion: Database.Statement;
+    getVersions: Database.Statement;
+    getLatestVersion: Database.Statement;
+    getVersionsSince: Database.Statement;
+  };
+
+  constructor(db: Database.Database) {
+    this.db = db;
+
+    this.stmts = {
+      insertDoc: db.prepare(
+        'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+      ),
+      getDoc: db.prepare('SELECT * FROM documents WHERE id = ?'),
+      listDocs: db.prepare(
+        'SELECT * FROM documents ORDER BY updated_at DESC'
+      ),
+      updateDoc: db.prepare(
+        "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+      ),
+      deleteDoc: db.prepare('DELETE FROM documents WHERE id = ?'),
+      insertVersion: db.prepare(
+        'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+      ),
+      getVersions: db.prepare(
+        'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+      ),
+      getLatestVersion: db.prepare(
+        'SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1'
+      ),
+      getVersionsSince: db.prepare(
+        'SELECT * FROM versions WHERE document_id = ? AND version > ? ORDER BY version ASC'
+      ),
+    };
+  }
+
+  createDocument(title: string, content: string = ''): DocumentRow {
+    const id = randomUUID();
+    this.stmts.insertDoc.run(id, title, content);
+    // Create initial version
+    this.stmts.insertVersion.run(id, 0, content, null);
+    return this.stmts.getDoc.get(id) as DocumentRow;
+  }
+
+  getDocument(id: string): DocumentRow | undefined {
+    return this.stmts.getDoc.get(id) as DocumentRow | undefined;
+  }
+
+  listDocuments(): DocumentRow[] {
+    return this.stmts.listDocs.all() as DocumentRow[];
+  }
+
+  updateDocument(
+    id: string,
+    title: string,
+    content: string
+  ): DocumentRow | undefined {
+    const existing = this.getDocument(id);
+    if (!existing) return undefined;
+    this.stmts.updateDoc.run(title, content, id);
+    return this.stmts.getDoc.get(id) as DocumentRow;
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.stmts.deleteDoc.run(id);
+    return result.changes > 0;
+  }
+
+  addVersion(
+    documentId: string,
+    version: number,
+    content: string,
+    operation: unknown
+  ): void {
+    this.stmts.insertVersion.run(
+      documentId,
+      version,
+      content,
+      operation ? JSON.stringify(operation) : null
+    );
+    // Also update the document content
+    const doc = this.getDocument(documentId);
+    if (doc) {
+      this.stmts.updateDoc.run(doc.title, content, documentId);
+    }
+  }
+
+  getVersions(documentId: string): VersionRow[] {
+    return this.stmts.getVersions.all(documentId) as VersionRow[];
+  }
+
+  getLatestVersion(documentId: string): VersionRow | undefined {
+    return this.stmts.getLatestVersion.get(documentId) as
+      | VersionRow
+      | undefined;
+  }
+
+  getVersionsSince(documentId: string, sinceVersion: number): VersionRow[] {
+    return this.stmts.getVersionsSince.all(
+      documentId,
+      sinceVersion
+    ) as VersionRow[];
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
