en = (other.text || '').length;\n\n    if (op.type === 'insert') {\n      if (op.position >= other.position) {\n        // Our insert is at or after the other insert: shift right\n        return [{ ...op, position: op.position + insertLen }];\n      }\n      // Our insert is before the other insert: no change\n      return [{ ...op }];\n    } else {\n      // op is delete, other is insert\n      const deleteEnd = op.position + (op.length || 0);\n\n      if (op.position >= other.position) {\n        // Delete starts at or after insert: shift right\n        return [{ ...op, position: op.position + insertLen }];\n      } else if (deleteEnd <= other.position) {\n        // Delete ends before insert: no change needed\n        return [{ ...op }];\n      } else {\n        // Delete spans the insert point. We must split the delete\n        // into two parts to preserve the inserted text.\n        // Part 1: delete from op.position to other.position\n        // Part 2: delete from (other.position + insertLen) for remaining length\n        const beforeLen = other.position - op.position;\n        const afterLen = deleteEnd - other.position;\n        const parts: Operation[] = [];\n\n        if (beforeLen > 0) {\n          parts.push({\n            ...op,\n            position: op.position,\n            length: beforeLen,\n          });\n        }\n        if (afterLen > 0) {\n          parts.push({\n            ...op,\n            position: other.position + insertLen - (beforeLen > 0 ? beforeLen : 0),\n            length: afterLen,\n          });\n        }\n\n        // After applying the first delete, positions shift.\n        // Let's recalculate: after part 1 deletes [op.position, other.position),\n        // the insert text starts at (op.position) now, so part 2 should delete\n        // at (op.position + insertLen) for afterLen chars.\n        if (parts.length === 2) {\n          parts[1].position = parts[0].position + insertLen;\n        } else if (parts.length === 1 &&