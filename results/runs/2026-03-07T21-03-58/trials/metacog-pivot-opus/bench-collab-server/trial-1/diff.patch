position + otherLen;\n\n    if (op.type === 'insert') {\n      if (op.position <= other.position) {\n        // Insert before delete: no change needed\n      } else if (op.position >= otherEnd) {\n        // Insert after deleted region: shift left\n        transformed.position = op.position - otherLen;\n      } else {\n        // Insert within deleted region: move to delete position\n        transformed.position = other.position;\n      }\n    } else if (op.type === 'delete') {\n      if (op.position >= otherEnd) {\n        // Our delete is entirely after the other delete\n        transformed.position = op.position - otherLen;\n      } else if (op.position + (op.length || 0) <= other.position) {\n        // Our delete is entirely before the other delete: no change\n      } else {\n        // Overlapping deletes\n        const opEnd = op.position + (op.length || 0);\n        const overlapStart = Math.max(op.position, other.position);\n        const overlapEnd = Math.min(opEnd, otherEnd);\n        const overlap = Math.max(0, overlapEnd - overlapStart);\n\n        transformed.position = Math.min(op.position, other.position);\n        transformed.length = (op.length || 0) - overlap;\n\n        // Adjust position if other delete was before us\n        if (other.position < op.position) {\n          transformed.position = op.position - (overlapStart - other.position);\n        }\n\n        if (transformed.length <= 0) {\n          // Nothing left to delete\n          transformed.length = 0;\n        }\n      }\n    }\n  }\n\n  return transformed;\n}\n\n/**\n * Transform an operation against multiple sequential operations.\n * Used when a client sends an op based on version V, but the server\n * has already applied operations V+1, V+2, ..., V+N.\n */\nexport function transformOperationAgainstMany(\n  op: Operation,\n  others: Operation[]\n): Operation {\n  let transformed = op;\n  for (const other of others) {\n    transformed = transformOperation(transformed, other);\n  }\n  return transformed;\n}\n\n/**\n * Validate that an operation is well-formed.\n */\nexport function validateOperation(\n  op: unknown\n): op is Operation {\n  if (!op || typeof op !== 'object') return false;\n  const o = op as Record<string, unknown>;\n  if (o.type !== 'insert' && o.type !== 'delete') return false;\n  if (typeof o.position !== 'number' || o.position < 0) return false;\n  if (!Number.isInteger(o.position)) return false;\n  if (typeof o.version !== 'number' || o.version < 0) return false;\n  if (!Number.isInteger(o.version)) return false;\n  if (o.type === 'insert') {\n    if (typeof o.text !== 'string' || o.text.length === 0) return false;\n  }\n  if (o.type === 'delete') {\n    if (typeof o.length !== 'number' || o.length <= 0) return false;\n    if (!Number.isInteger(o.length)) return false;\n  }\n  return true;\n}\n","structuredPatch":[],"originalFile":null}}
