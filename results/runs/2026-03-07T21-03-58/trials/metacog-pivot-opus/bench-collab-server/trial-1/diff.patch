+++ b/src/collab.test.ts
@@ -0,0 +1,507 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import WebSocket from 'ws';
+import { createApp, AppInstance } from './server.js';
+
+let app: AppInstance;
+let port: number;
+
+function wsUrl(docId: string): string {
+  return `ws://localhost:${port}/ws/${docId}`;
+}
+
+/**
+ * Connect to a document's WebSocket and wait for the sync message.
+ */
+function connectAndSync(
+  docId: string,
+  wsPort?: number
+): Promise<{ ws: WebSocket; syncMsg: Record<string, unknown> }> {
+  return new Promise((resolve, reject) => {
+    const p = wsPort ?? port;
+    const ws = new WebSocket(`ws://localhost:${p}/ws/${docId}`);
+    const timeout = setTimeout(
+      () => reject(new Error('Timeout connecting')),
+      5000
+    );
+    ws.on('error', (err) => {
+      clearTimeout(timeout);
+      reject(err);
+    });
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === 'sync') {
+        clearTimeout(timeout);
+        resolve({ ws, syncMsg: msg });
+      }
+    });
+  });
+}
+
+function waitForMessage(
+  ws: WebSocket,
+  filter?: (msg: Record<string, unknown>) => boolean
+): Promise<Record<string, unknown>> {
+  return new Promise((resolve, reject) => {
+    const timeout = setTimeout(
+      () => reject(new Error('Timeout waiting for message')),
+      5000
+    );
+    const handler = (data: WebSocket.Data) => {
+      const msg = JSON.parse(data.toString());
+      if (!filter || filter(msg)) {
+        clearTimeout(timeout);
+        ws.off('message', handler);
+        resolve(msg);
+      }
+    };
+    ws.on('message', handler);
+  });
+}
+
+function sendOp(ws: WebSocket, op: Record<string, unknown>): void {
+  ws.send(JSON.stringify({ type: 'operation', operation: op }));
+}
+
+describe('Collaborative Document Editor', () => {
+  beforeEach(async () => {
+    app = createApp();
+    port = await app.start(0);
+  });
+
+  afterEach(async () => {
+    await app.stop();
+  });
+
+  describe('REST API', () => {
+    it('should create a document', async () => {
+      const res = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Test Doc', content: 'Hello' })
+        .expect(201);
+
+      expect(res.body.id).toBeDefined();
+      expect(res.body.title).toBe('Test Doc');
+      expect(res.body.content).toBe('Hello');
+    });
+
+    it('should list documents', async () => {
+      await request(app.app)
+        .post('/documents')
+        .send({ title: 'Doc 1', content: 'A' })
+        .expect(201);
+      await request(app.app)
+        .post('/documents')
+        .send({ title: 'Doc 2', content: 'B' })
+        .expect(201);
+
+      const res = await request(app.app).get('/documents').expect(200);
+      expect(res.body.length).toBe(2);
+    });
+
+    it('should get a single document', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'My Doc', content: 'Content here' })
+        .expect(201);
+
+      const res = await request(app.app)
+        .get(`/documents/${createRes.body.id}`)
+        .expect(200);
+
+      expect(res.body.title).toBe('My Doc');
+      expect(res.body.content).toBe('Content here');
+    });
+
+    it('should update a document', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Original', content: 'old' })
+        .expect(201);
+
+      const res = await request(app.app)
+        .put(`/documents/${createRes.body.id}`)
+        .send({ title: 'Updated', content: 'new' })
+        .expect(200);
+
+      expect(res.body.title).toBe('Updated');
+      expect(res.body.content).toBe('new');
+    });
+
+    it('should delete a document', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'To Delete', content: '' })
+        .expect(201);
+
+      await request(app.app)
+        .delete(`/documents/${createRes.body.id}`)
+        .expect(204);
+
+      await request(app.app)
+        .get(`/documents/${createRes.body.id}`)
+        .expect(404);
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      await request(app.app).get('/documents/nonexistent').expect(404);
+    });
+
+    it('should reject document creation without title', async () => {
+      await request(app.app)
+        .post('/documents')
+        .send({ content: 'no title' })
+        .expect(400);
+    });
+
+    it('should return version history', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Versioned', content: 'v0' })
+        .expect(201);
+
+      const res = await request(app.app)
+        .get(`/documents/${createRes.body.id}/versions`)
+        .expect(200);
+
+      expect(res.body.length).toBeGreaterThanOrEqual(1);
+      expect(res.body[0].version).toBe(0);
+    });
+  });
+
+  describe('WebSocket Collaboration', () => {
+    it('should send sync message on connect', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'WS Test', content: 'Hello World' })
+        .expect(201);
+
+      const { ws, syncMsg } = await connectAndSync(createRes.body.id);
+
+      expect(syncMsg.type).toBe('sync');
+      expect(syncMsg.content).toBe('Hello World');
+      expect(syncMsg.version).toBe(0);
+
+      ws.close();
+    });
+
+    it('should apply an insert operation and broadcast', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Collab', content: 'Hello' })
+        .expect(201);
+      const id = createRes.body.id;
+
+      const { ws: ws1, syncMsg: sync1 } = await connectAndSync(id);
+      expect(sync1.content).toBe('Hello');
+
+      const { ws: ws2, syncMsg: sync2 } = await connectAndSync(id);
+      expect(sync2.content).toBe('Hello');
+
+      // Set up broadcast listener BEFORE sending the operation
+      const broadcastPromise = waitForMessage(
+        ws2,
+        (m) => m.type === 'operation'
+      );
+
+      sendOp(ws1, {
+        type: 'insert',
+        position: 5,
+        text: ' World',
+        version: 0,
+      });
+
+      // Client 1 should get an ack
+      const ack = await waitForMessage(ws1, (m) => m.type === 'ack');
+      expect(ack.version).toBe(1);
+
+      // Client 2 should get the broadcast
+      const broadcast = await broadcastPromise;
+      expect(broadcast.type).toBe('operation');
+      expect(broadcast.version).toBe(1);
+
+      // Verify via REST
+      const docRes = await request(app.app)
+        .get(`/documents/${id}`)
+        .expect(200);
+      expect(docRes.body.content).toBe('Hello World');
+
+      ws1.close();
+      ws2.close();
+    });
+
+    it('should apply a delete operation', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Del Test', content: 'Hello World' })
+        .expect(201);
+      const id = createRes.body.id;
+
+      const { ws } = await connectAndSync(id);
+
+      sendOp(ws, { type: 'delete', position: 5, length: 6, version: 0 });
+      const ack = await waitForMessage(ws, (m) => m.type === 'ack');
+      expect(ack.version).toBe(1);
+
+      const docRes = await request(app.app)
+        .get(`/documents/${id}`)
+        .expect(200);
+      expect(docRes.body.content).toBe('Hello');
+
+      ws.close();
+    });
+
+    it('should reject invalid operations', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Invalid', content: 'Test' })
+        .expect(201);
+
+      const { ws } = await connectAndSync(createRes.body.id);
+
+      ws.send(
+        JSON.stringify({ type: 'operation', operation: { type: 'insert' } })
+      );
+      const errMsg = await waitForMessage(ws, (m) => m.type === 'error');
+      expect(errMsg.type).toBe('error');
+
+      ws.close();
+    });
+
+    it('should reject invalid JSON', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'BadJSON', content: '' })
+        .expect(201);
+
+      const { ws } = await connectAndSync(createRes.body.id);
+
+      ws.send('not json at all');
+      const errMsg = await waitForMessage(ws, (m) => m.type === 'error');
+      expect(errMsg.type).toBe('error');
+
+      ws.close();
+    });
+
+    it('should close connection for non-existent document', async () => {
+      const ws = new WebSocket(wsUrl('nonexistent'));
+
+      await new Promise<void>((resolve) => {
+        ws.on('close', () => resolve());
+      });
+    });
+  });
+
+  describe('Concurrent Editing (OT)', () => {
+    it('should handle two simultaneous inserts at the same position', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Concurrent', content: 'AB' })
+        .expect(201);
+      const id = createRes.body.id;
+
+      const { ws: ws1 } = await connectAndSync(id);
+      const { ws: ws2 } = await connectAndSync(id);
+
+      // Both clients insert at position 1, both based on version 0
+      sendOp(ws1, { type: 'insert', position: 1, text: 'X', version: 0 });
+      const ack1 = await waitForMessage(ws1, (m) => m.type === 'ack');
+      expect(ack1.version).toBe(1);
+
+      // Wait for ws2 to receive the broadcast so it doesn't interfere
+      await waitForMessage(ws2, (m) => m.type === 'operation');
+
+      sendOp(ws2, { type: 'insert', position: 1, text: 'Y', version: 0 });
+      const ack2 = await waitForMessage(ws2, (m) => m.type === 'ack');
+      expect(ack2.version).toBe(2);
+
+      const docRes = await request(app.app)
+        .get(`/documents/${id}`)
+        .expect(200);
+
+      const content = docRes.body.content;
+      expect(content).toContain('X');
+      expect(content).toContain('Y');
+      expect(content).toContain('A');
+      expect(content).toContain('B');
+      expect(content.length).toBe(4);
+
+      ws1.close();
+      ws2.close();
+    });
+
+    it('should handle insert and delete at overlapping positions', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'InsertDelete', content: 'ABCDEF' })
+        .expect(201);
+      const id = createRes.body.id;
+
+      const { ws: ws1 } = await connectAndSync(id);
+      const { ws: ws2 } = await connectAndSync(id);
+
+      // Client 1: insert "X" at position 3 (between C and D), version 0
+      sendOp(ws1, { type: 'insert', position: 3, text: 'X', version: 0 });
+      await waitForMessage(ws1, (m) => m.type === 'ack');
+
+      // Client 2: delete 2 chars at position 2 (CD), version 0
+      sendOp(ws2, { type: 'delete', position: 2, length: 2, version: 0 });
+      await waitForMessage(ws2, (m) => m.type === 'ack');
+
+      const docRes = await request(app.app)
+        .get(`/documents/${id}`)
+        .expect(200);
+
+      const content = docRes.body.content;
+      expect(content).toContain('A');
+      expect(content).toContain('B');
+      expect(content).toContain('X');
+      expect(content).toContain('E');
+      expect(content).toContain('F');
+
+      ws1.close();
+      ws2.close();
+    });
+
+    it('should handle 10 concurrent clients without corruption', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'Many Clients', content: '' })
+        .expect(201);
+      const id = createRes.body.id;
+
+      const clients: WebSocket[] = [];
+
+      // Connect 10 clients
+      for (let i = 0; i < 10; i++) {
+        const { ws } = await connectAndSync(id);
+        clients.push(ws);
+      }
+
+      // Each client inserts a unique character sequentially
+      for (let i = 0; i < 10; i++) {
+        const ws = clients[i];
+        sendOp(ws, {
+          type: 'insert',
+          position: 0,
+          text: String(i),
+          version: i,
+        });
+        await waitForMessage(ws, (m) => m.type === 'ack');
+      }
+
+      // Small delay for all broadcasts to settle
+      await new Promise((r) => setTimeout(r, 200));
+
+      const docRes = await request(app.app)
+        .get(`/documents/${id}`)
+        .expect(200);
+
+      const content = docRes.body.content;
+      expect(content.length).toBe(10);
+      for (let i = 0; i < 10; i++) {
+        expect(content).toContain(String(i));
+      }
+
+      for (const ws of clients) {
+        ws.close();
+      }
+    });
+  });
+
+  describe('Persistence', () => {
+    it('should persist documents and versions across server restarts', async () => {
+      const tmpDb = `/tmp/test-collab-${Date.now()}.db`;
+
+      // Start first server
+      const app1 = createApp(tmpDb);
+      const port1 = await app1.start(0);
+
+      // Create a document
+      const createRes = await request(app1.app)
+        .post('/documents')
+        .send({ title: 'Persistent', content: 'Original' })
+        .expect(201);
+      const id = createRes.body.id;
+
+      // Make an edit via WebSocket
+      const { ws } = await connectAndSync(id, port1);
+
+      sendOp(ws, {
+        type: 'insert',
+        position: 8,
+        text: ' Content',
+        version: 0,
+      });
+      await waitForMessage(ws, (m) => m.type === 'ack');
+
+      ws.close();
+      await new Promise((r) => setTimeout(r, 100));
+      await app1.stop();
+
+      // Start second server with same DB
+      const app2 = createApp(tmpDb);
+      await app2.start(0);
+
+      const docRes = await request(app2.app)
+        .get(`/documents/${id}`)
+        .expect(200);
+
+      expect(docRes.body.title).toBe('Persistent');
+      expect(docRes.body.content).toBe('Original Content');
+
+      const versionsRes = await request(app2.app)
+        .get(`/documents/${id}/versions`)
+        .expect(200);
+
+      expect(versionsRes.body.length).toBeGreaterThanOrEqual(2);
+
+      await app2.stop();
+
+      // Clean up
+      const { unlinkSync } = await import('fs');
+      try {
+        unlinkSync(tmpDb);
+        unlinkSync(tmpDb + '-wal');
+        unlinkSync(tmpDb + '-shm');
+      } catch {
+        // ignore
+      }
+    });
+  });
+
+  describe('Version History', () => {
+    it('should track version history through WebSocket edits', async () => {
+      const createRes = await request(app.app)
+        .post('/documents')
+        .send({ title: 'History', content: '' })
+        .expect(201);
+      const id = createRes.body.id;
+
+      const { ws } = await connectAndSync(id);
+
+      sendOp(ws, { type: 'insert', position: 0, text: 'Hello', version: 0 });
+      await waitForMessage(ws, (m) => m.type === 'ack');
+
+      sendOp(ws, {
+        type: 'insert',
+        position: 5,
+        text: ' World',
+        version: 1,
+      });
+      await waitForMessage(ws, (m) => m.type === 'ack');
+
+      sendOp(ws, { type: 'insert', position: 11, text: '!', version: 2 });
+      await waitForMessage(ws, (m) => m.type === 'ack');
+
+      const versionsRes = await request(app.app)
+        .get(`/documents/${id}/versions`)
+        .expect(200);
+
+      expect(versionsRes.body.length).toBe(4);
+      expect(versionsRes.body[3].content).toBe('Hello World!');
+
+      ws.close();
+    });
+  });
+});
