+type Direction = -1 | 0 | 1;
+
+interface Beam {
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): number {
+  const topRow = grid[0];
+  for (let c = 0; c < topRow.length; c++) {
+    if (topRow[c] === "S") return c;
+  }
+  return -1;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0]?.length ?? 0;
+  if (rows === 0 || cols === 0) return 0;
+
+  const sourceCol = findSource(grid);
+  if (sourceCol === -1) return 0;
+
+  const visited = new Set<number>();
+  const key = (r: number, c: number): number => r * cols + c;
+
+  // Track beams as a set of (col, direction) pairs per row
+  // Use a Map to deduplicate beams with same col and direction
+  let beams = new Map<string, Beam>();
+
+  // Source cell is visited
+  visited.add(key(0, sourceCol));
+  // Initial beam: at source, direction is down (0)
+  // The beam starts at the source and moves down from there
+  // We process from row 0: the source emits a beam going down.
+  // The source cell itself is row 0. The beam's next position is row 1.
+  // But first, check if the source cell is a splitter (it's 'S', not '^', so no).
+
+  beams.set(`${sourceCol},0`, { col: sourceCol, dir: 0 });
+
+  // Process: each beam at current conceptual position moves to next row
+  // Start: beams are "at" row 0 (source), need to move to row 1, 2, ...
+  for (let row = 1; row < rows; row++) {
+    const nextBeams = new Map<string, Beam>();
+
+    for (const beam of beams.values()) {
+      const newCol = beam.col + beam.dir;
+
+      // Check bounds
+      if (newCol < 0 || newCol >= cols) continue;
+
+      visited.add(key(row, newCol));
+
+      if (grid[row][newCol] === "^") {
+        // Splitter: beam splits into down-left and down-right
+        const keyLeft = `${newCol},-1`;
+        const keyRight = `${newCol},1`;
+        if (!nextBeams.has(keyLeft)) {
+          nextBeams.set(keyLeft, { col: newCol, dir: -1 });
+        }
+        if (!nextBeams.has(keyRight)) {
+          nextBeams.set(keyRight, { col: newCol, dir: 1 });
+        }
+      } else {
+        // Continue in same direction
+        const beamKey = `${newCol},${beam.dir}`;
+        if (!nextBeams.has(beamKey)) {
+          nextBeams.set(beamKey, { col: newCol, dir: beam.dir });
+        }
+      }
+    }
+
+    beams = nextBeams;
+    if (beams.size === 0) break;
+  }
+
+  return visited.size;
+}
+
+interface BeamWithCount {
+  col: number;
+  dir: Direction;
+  paths: bigint;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0]?.length ?? 0;
+  if (rows === 0 || cols === 0) return 0n;
+
+  const sourceCol = findSource(grid);
+  if (sourceCol === -1) return 0n;
+
+  // Track beams with path counts
+  // Key: "col,dir" -> number of paths
+  let beams = new Map<string, BeamWithCount>();
+
+  beams.set(`${sourceCol},0`, { col: sourceCol, dir: 0, paths: 1n });
+
+  let totalPaths = 0n;
+
+  for (let row = 1; row < rows; row++) {
+    const nextBeams = new Map<string, BeamWithCount>();
+
+    for (const beam of beams.values()) {
+      const newCol = beam.col + beam.dir;
+
+      // Check bounds - beam exits grid
+      if (newCol < 0 || newCol >= cols) {
+        totalPaths += beam.paths;
+        continue;
+      }
+
+      if (grid[row][newCol] === "^") {
+        // Splitter: each path splits into 2
+        const keyLeft = `${newCol},-1`;
+        const keyRight = `${newCol},1`;
+
+        const existLeft = nextBeams.get(keyLeft);
+        if (existLeft) {
+          existLeft.paths += beam.paths;
+        } else {
+          nextBeams.set(keyLeft, { col: newCol, dir: -1, paths: beam.paths });
+        }
+
+        const existRight = nextBeams.get(keyRight);
+        if (existRight) {
+          existRight.paths += beam.paths;
+        } else {
+          nextBeams.set(keyRight, { col: newCol, dir: 1, paths: beam.paths });
+        }
+      } else {
+        // Continue in same direction
+        const beamKey = `${newCol},${beam.dir}`;
+        const exist = nextBeams.get(beamKey);
+        if (exist) {
+          exist.paths += beam.paths;
+        } else {
+          nextBeams.set(beamKey, {
+            col: newCol,
+            dir: beam.dir,
+            paths: beam.paths,
+          });
+        }
+      }
+    }
+
+    beams = nextBeams;
+    if (beams.size === 0) break;
+  }
+
+  // Any beams still active after processing the last row exit through the bottom
+  for (const beam of beams.values()) {
+    totalPaths += beam.paths;
+  }
+
+  return totalPaths;
+}
