+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Modular arithmetic helpers for GF(p).
+ */
+function mod(a: number, p: number): number {
+  return ((a % p) + p) % p;
+}
+
+/**
+ * Compute modular inverse of a mod p using extended Euclidean algorithm.
+ * Only valid when p is prime and a != 0 mod p.
+ */
+function modInverse(a: number, p: number): number {
+  a = mod(a, p);
+  if (a === 0) throw new Error("No inverse for 0");
+  // Fermat's little theorem: a^(p-2) mod p
+  let result = 1;
+  let base = a;
+  let exp = p - 2;
+  while (exp > 0) {
+    if (exp & 1) result = mod(result * base, p);
+    base = mod(base * base, p);
+    exp >>= 1;
+  }
+  return result;
+}
+
+/**
+ * Solve a system of linear equations Ax = b over GF(p).
+ *
+ * A is a numLights x numButtons matrix (A[light][button] = coefficient).
+ * b is the target vector of length numLights.
+ *
+ * Returns: { particular: number[], nullBasis: number[][] } or null if no solution.
+ * particular[i] = value for button i in a particular solution.
+ * nullBasis = array of vectors spanning the null space.
+ * pivotCols = which columns are pivot columns (for tracking free variables).
+ */
+function solveLinearSystem(
+  A: number[][],
+  b: number[],
+  numButtons: number,
+  p: number
+): { particular: number[]; nullBasis: number[][]; pivotCols: number[] } | null {
+  const numLights = A.length;
+
+  // Build augmented matrix [A | b]
+  const aug: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1);
+    for (let j = 0; j < numButtons; j++) {
+      row[j] = mod(A[i][j], p);
+    }
+    row[numButtons] = mod(b[i], p);
+    aug.push(row);
+  }
+
+  // Gaussian elimination with partial pivoting
+  const pivotCols: number[] = [];
+  let pivotRow = 0;
+
+  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {
+    // Find pivot in this column
+    let found = -1;
+    for (let row = pivotRow; row < numLights; row++) {
+      if (aug[row][col] !== 0) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue; // Free variable
+
+    // Swap rows
+    if (found !== pivotRow) {
+      [aug[pivotRow], aug[found]] = [aug[found], aug[pivotRow]];
+    }
+
+    pivotCols.push(col);
+
+    // Scale pivot row so pivot = 1
+    const inv = modInverse(aug[pivotRow][col], p);
+    for (let j = col; j <= numButtons; j++) {
+      aug[pivotRow][j] = mod(aug[pivotRow][j] * inv, p);
+    }
+
+    // Eliminate all other rows
+    for (let row = 0; row < numLights; row++) {
+      if (row === pivotRow) continue;
+      const factor = aug[row][col];
+      if (factor === 0) continue;
+      for (let j = col; j <= numButtons; j++) {
+        aug[row][j] = mod(aug[row][j] - factor * aug[pivotRow][j], p);
+      }
+    }
+
+    pivotRow++;
+  }
+
+  // Check for inconsistency: any row with all-zero coefficients but non-zero RHS
+  for (let row = pivotRow; row < numLights; row++) {
+    if (aug[row][numButtons] !== 0) {
+      return null; // No solution
+    }
+  }
+
+  // Extract particular solution (set free variables to 0)
+  const particular = new Array(numButtons).fill(0);
+  for (let i = 0; i < pivotCols.length; i++) {
+    particular[pivotCols[i]] = aug[i][numButtons];
+  }
+
+  // Find free variables
+  const pivotSet = new Set(pivotCols);
+  const freeCols: number[] = [];
+  for (let j = 0; j < numButtons; j++) {
+    if (!pivotSet.has(j)) freeCols.push(j);
+  }
+
+  // Extract null space basis vectors
+  const nullBasis: number[][] = [];
+  for (const freeCol of freeCols) {
+    const vec = new Array(numButtons).fill(0);
+    vec[freeCol] = 1;
+    // For each pivot column, find the coefficient
+    for (let i = 0; i < pivotCols.length; i++) {
+      vec[pivotCols[i]] = mod(-aug[i][freeCol], p);
+    }
+    nullBasis.push(vec);
+  }
+
+  return { particular, nullBasis, pivotCols };
+}
+
+/**
+ * Enumerate all combinations of null space vectors (each coefficient 0..p-1)
+ * and find the solution with minimum total weight, breaking ties lexicographically.
+ *
+ * For up to 40 free variables with modulus up to 97, full enumeration is infeasible.
+ * However, with 40 buttons and 40 lights, the number of free variables is typically small.
+ * With k free variables, we enumerate p^k solutions.
+ *
+ * Strategy: If k is small enough (p^k <= ~10M), enumerate all. Otherwise, we need
+ * a smarter approach. Given the constraint of 40 buttons and 40 lights, if the system
+ * is well-determined, k should be small.
+ */
+function findOptimalSolution(
+  particular: number[],
+  nullBasis: number[][],
+  p: number,
+  scoreFn: (solution: number[]) => { weight: number; key: number[] }
+): number[] {
+  const numButtons = particular.length;
+  const k = nullBasis.length;
+
+  if (k === 0) {
+    return particular.map(v => mod(v, p));
+  }
+
+  // Check feasibility of enumeration
+  let totalCombinations = 1;
+  const MAX_ENUM = 10_000_000;
+  let feasible = true;
+  for (let i = 0; i < k; i++) {
+    totalCombinations *= p;
+    if (totalCombinations > MAX_ENUM) {
+      feasible = false;
+      break;
+    }
+  }
+
+  if (!feasible) {
+    // For large search spaces, use a heuristic approach
+    // Try to find good solutions by trying each free variable independently
+    return heuristicOptimal(particular, nullBasis, p, scoreFn);
+  }
+
+  // Enumerate all combinations
+  const coeffs = new Array(k).fill(0);
+  let bestSolution: number[] | null = null;
+  let bestWeight = Infinity;
+  let bestKey: number[] = [];
+
+  const currentSolution = particular.map(v => mod(v, p));
+
+  const evaluate = () => {
+    const { weight, key } = scoreFn(currentSolution);
+    if (
+      weight < bestWeight ||
+      (weight === bestWeight && compareLex(key, bestKey) < 0)
+    ) {
+      bestWeight = weight;
+      bestKey = key.slice();
+      bestSolution = currentSolution.slice();
+    }
+  };
+
+  evaluate();
+
+  // Incrementally enumerate by advancing coefficients
+  for (let iter = 1; iter < totalCombinations; iter++) {
+    // Increment coefficients (like counting in base p)
+    let carry = 0;
+    for (let i = k - 1; i >= 0; i--) {
+      const oldCoeff = coeffs[i];
+      const newCoeff = oldCoeff + (i === k - 1 ? 1 : carry);
+      if (newCoeff >= p) {
+        coeffs[i] = 0;
+        carry = 1;
+        // Undo old coefficient, apply new (0)
+        const diff = mod(-oldCoeff, p);
+        for (let j = 0; j < numButtons; j++) {
+          currentSolution[j] = mod(currentSolution[j] + diff * nullBasis[i][j], p);
+        }
+      } else {
+        coeffs[i] = newCoeff;
+        carry = 0;
+        // Apply increment of 1 for this basis vector
+        for (let j = 0; j < numButtons; j++) {
+          currentSolution[j] = mod(currentSolution[j] + nullBasis[i][j], p);
+        }
+        break;
+      }
+    }
+
+    evaluate();
+  }
+
+  return bestSolution!;
+}
+
+/**
+ * Heuristic for large search spaces: try to optimize each free variable independently.
+ */
+function heuristicOptimal(
+  particular: number[],
+  nullBasis: number[][],
+  p: number,
+  scoreFn: (solution: number[]) => { weight: number; key: number[] }
+): number[] {
+  let current = particular.map(v => mod(v, p));
+  let bestScore = scoreFn(current);
+
+  // Greedy: for each null basis vector, try all p coefficients
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (let i = 0; i < nullBasis.length; i++) {
+      let bestCoeff = 0;
+      const baseline = current.slice();
+      let bestForThis = bestScore;
+
+      for (let c = 1; c < p; c++) {
+        const candidate = baseline.map((v, j) => mod(v + c * nullBasis[i][j], p));
+        const score = scoreFn(candidate);
+        if (
+          score.weight < bestForThis.weight ||
+          (score.weight === bestForThis.weight && compareLex(score.key, bestForThis.key) < 0)
+        ) {
+          bestForThis = score;
+          bestCoeff = c;
+        }
+      }
+
+      if (bestCoeff !== 0) {
+        current = baseline.map((v, j) => mod(v + bestCoeff * nullBasis[i][j], p));
+        bestScore = bestForThis;
+        improved = true;
+      }
+    }
+  }
+
+  return current;
+}
+
+function compareLex(a: number[], b: number[]): number {
+  const len = Math.max(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    const av = i < a.length ? a[i] : -1;
+    const bv = i < b.length ? b[i] : -1;
+    if (av < bv) return -1;
+    if (av > bv) return 1;
+  }
+  return 0;
+}
+
+/**
+ * Part 1: Toggle Puzzle
+ *
+ * Solve over GF(2). Each button is pressed 0 or 1 times.
+ * Returns sorted button indices that should be pressed, or null.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+  const p = 2;
+
+  // Build coefficient matrix A[light][button]
+  const A: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons).fill(0);
+    A.push(row);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const light of buttons[j]) {
+      if (light >= 0 && light < numLights) {
+        A[light][j] = 1;
+      }
+    }
+  }
+
+  // Target vector
+  const b = target.map(t => (t ? 1 : 0));
+
+  const result = solveLinearSystem(A, b, numButtons, p);
+  if (result === null) return null;
+
+  const { particular, nullBasis } = result;
+
+  // Find optimal: minimize number of 1s (buttons pressed), then lex smallest index set
+  const optimal = findOptimalSolution(particular, nullBasis, p, (sol) => {
+    const weight = sol.reduce((s, v) => s + v, 0);
+    // For lex comparison of index sets, build the pressed indices
+    const pressed: number[] = [];
+    for (let i = 0; i < sol.length; i++) {
+      if (sol[i] === 1) pressed.push(i);
+    }
+    return { weight, key: pressed };
+  });
+
+  // Extract pressed button indices
+  const pressed: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (optimal[i] === 1) pressed.push(i);
+  }
+  return pressed;
+}
+
+/**
+ * Part 2: Counter Puzzle
+ *
+ * Solve over GF(p) where p is prime. Each button pressed 0..p-1 times.
+ * Returns array of press counts, or null.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+  const p = modulus;
+
+  // Build coefficient matrix A[light][button]
+  const A: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons).fill(0);
+    A.push(row);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const light of buttons[j]) {
+      if (light >= 0 && light < numLights) {
+        A[light][j] = mod(A[light][j] + 1, p);
+      }
+    }
+  }
+
+  // Target vector
+  const b = lights.map(v => mod(v, p));
+
+  const result = solveLinearSystem(A, b, numButtons, p);
+  if (result === null) return null;
+
+  const { particular, nullBasis } = result;
+
+  // Find optimal: minimize total presses (sum), then lex smallest
+  const optimal = findOptimalSolution(particular, nullBasis, p, (sol) => {
+    const weight = sol.reduce((s, v) => s + v, 0);
+    return { weight, key: sol };
+  });
+
+  return optimal;
+}
