+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from '../src/index.js';
+import type { Machine } from '../src/index.js';
+
+describe('solveToggle', () => {
+  it('should return empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should handle single button single light', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should return null when no solution exists (example from task)', () => {
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should find minimum button presses', () => {
+    // 2 lights, 3 buttons
+    // Button 0: [0] - toggles light 0
+    // Button 1: [1] - toggles light 1
+    // Button 2: [0, 1] - toggles both
+    // Target: [true, true]
+    // Solutions: [0,1] (2 presses) or [2] (1 press)
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0, 1]],
+    };
+    expect(solveToggle(machine)).toEqual([2]);
+  });
+
+  it('should return lex smallest when tied on press count', () => {
+    // 2 lights, 2 buttons that do the same thing
+    // Button 0: [0, 1]
+    // Button 1: [0, 1]
+    // Target: [true, true]
+    // Either button alone works, pick button 0 (lex smallest)
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0, 1]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should handle larger example', () => {
+    // 3 lights, 3 buttons (identity-like)
+    const machine: Machine = {
+      target: [true, false, true],
+      buttons: [[0], [1], [2]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 2]);
+  });
+
+  it('should handle all lights on', () => {
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0], [1], [2]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1, 2]);
+  });
+
+  it('should handle no buttons', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should handle no buttons with all-off target', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should handle overlapping buttons', () => {
+    // Light 0 needs to be on, Light 1 needs to be off
+    // Button 0: [0, 1], Button 1: [1]
+    // Press both: light 0 toggled once (on), light 1 toggled twice (off)
+    const machine: Machine = {
+      target: [true, false],
+      buttons: [[0, 1], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('should handle XOR cancellation', () => {
+    // 2 lights, target [false, false]
+    // No buttons needed
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [[0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+});
+
+describe('solveToggle stress', () => {
+  it('should handle 40 lights x 40 buttons (identity)', () => {
+    const n = 40;
+    const target = new Array(n).fill(true);
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+    }
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(result!.length).toBe(n);
+    for (let i = 0; i < n; i++) {
+      expect(result![i]).toBe(i);
+    }
+  });
+
+  it('should handle 40 lights x 40 buttons with no solution', () => {
+    // All buttons toggle light 0 only. Target has light 1 on.
+    const n = 40;
+    const target = new Array(n).fill(false);
+    target[1] = true;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([0]);
+    }
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine);
+    expect(result).toBeNull();
+  });
+
+  it('should handle 40 lights x 40 buttons with many free variables (p=2)', () => {
+    // All buttons toggle the same set of lights
+    const n = 40;
+    const target = new Array(n).fill(false);
+    target[0] = true;
+    target[1] = true;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([0, 1]);
+    }
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine);
+    // Any single button press gives [on, on, ...off] which matches
+    // Should return [0] as the lex smallest single-press solution
+    expect(result).toEqual([0]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 3);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should handle single button single counter', () => {
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('should return null when no solution exists', () => {
+    // Counter 0 needs value 1, but no button affects it
+    const result = solveCounter([1, 0], [[1]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('should find minimum total presses', () => {
+    // 1 counter, target = 1, modulus = 5
+    // Button 0: affects counter 0
+    // Press 1 time (total=1) or 6 mod 5 = 1 (but max press is 4)
+    const result = solveCounter([1], [[0]], 5);
+    expect(result).toEqual([1]);
+  });
+
+  it('should handle modular arithmetic', () => {
+    // 1 counter, target = 4, modulus = 5
+    // Button 0: affects counter 0
+    // Press 4 times: total = 4
+    // But also: pressing (p-1) = 4 times gives value 4 mod 5 = 4
+    const result = solveCounter([4], [[0]], 5);
+    expect(result).toEqual([4]);
+  });
+
+  it('should handle multiple buttons affecting same counter', () => {
+    // 1 counter, target = 3, modulus = 5
+    // Button 0: [0], Button 1: [0]
+    // Solutions: (0,3) sum=3, (1,2) sum=3, (2,1) sum=3, (3,0) sum=3
+    // Min sum = 3, lex smallest = [0, 3]
+    const result = solveCounter([3], [[0], [0]], 5);
+    expect(result).toEqual([0, 3]);
+  });
+
+  it('should handle two counters', () => {
+    // 2 counters, target = [1, 2], modulus = 3
+    // Button 0: [0], Button 1: [1]
+    // Independent: press button 0 once, button 1 twice
+    const result = solveCounter([1, 2], [[0], [1]], 3);
+    expect(result).toEqual([1, 2]);
+  });
+
+  it('should handle prime modulus = 2 (binary)', () => {
+    const result = solveCounter([1, 1], [[0], [1]], 2);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('should handle larger modulus', () => {
+    // modulus = 97
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+  });
+
+  it('should find lex smallest when tied on total presses', () => {
+    // 2 counters, target = [1, 1], modulus = 3
+    // Button 0: [0, 1] (affects both)
+    // Button 1: [0, 1] (affects both)
+    // Pressing button 0 once: [1,1] done. sum=1
+    // Pressing button 1 once: [1,1] done. sum=1
+    // Both have sum 1, lex smallest coefficient vector is [0, 1]
+    const result = solveCounter([1, 1], [[0, 1], [0, 1]], 3);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should handle empty buttons with zero target', () => {
+    const result = solveCounter([0, 0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  it('should handle empty buttons with non-zero target', () => {
+    const result = solveCounter([1], [], 5);
+    expect(result).toBeNull();
+  });
+
+  it('should handle counter with modulus 7 and overlapping buttons', () => {
+    // 3 counters, 3 buttons, modulus 7
+    // Button 0: [0, 1]
+    // Button 1: [1, 2]
+    // Button 2: [0, 2]
