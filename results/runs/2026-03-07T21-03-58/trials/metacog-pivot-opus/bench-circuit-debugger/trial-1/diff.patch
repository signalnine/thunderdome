c: 0 });\n  });\n\n  it('should simulate XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n  });\n\n  it('should handle dependency chains', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n  });\n\n  it('should simulate a 2-bit adder', () => {\n    // 2-bit adder: x + y = z\n    const gates: Gate[] = [\n      // Bit 0 (half adder)\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1 (full adder)\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n\n    // 1 + 1 = 2 (binary: 01 + 01 = 10)\n    const result1 = simulate(gates, { x00: 1, x01: 0, y00: 1, y01: 0 });\n    expect(result1['z00']).toBe(0);\n    expect(result1['z01']).toBe(1);\n    expect(result1['z02']).toBe(0);\n\n    // 3 + 3 = 6 (binary: 11 + 11 = 110)\n    const result2 = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n    expect(result2['z00']).toBe(0);\n    expect(result2['z01']).toBe(1);\n    expect(result2['z02']).toBe(1);\n\n    // 2 + 1 = 3 (binary: 10 + 01 = 011)\n    const result3 = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });\n    expect(result3['z00']).toBe(1);\n    expect(result3['z01']).toBe(1);\n    expect(result3['z02']).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function makeCorrectAdder(numBits: number): Gate[] {\n    const gates: Gate[] = [];\n    // Bit 0 (half adder)\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n    for (let i = 1; i < numBits; i++) {\n      const bit = String(i).padStart(2, '0');\n      const prevBit = String(i - 1).padStart(2, '0');\n      gates.push({ op: 'XOR', in1: `x${bit}`, in2: `y${bit}`, out: `t${bit}` });\n      gates.push({ op: 'XOR', in1: `t${bit}`, in2: `c${prevBit}`, out: `z${bit}` });\n      gates.push({ op: 'AND', in1: `x${bit}`, in2: `y${bit}`, out: `a${bit}` });\n      gates.push({ op: 'AND', in1: `t${bit}`, in2: `c${prevBit}`, out: `b${bit}` });\n      gates.push({ op: 'OR', in1: `a${bit}`, in2: `b${bit}`, out: `c${bit}` });\n    }\n\n    // Last z bit is the final carry\n    const lastBit = String(numBits - 1).padStart(2, '0');\n    const lastZ = String(numBits).padStart(2, '0');\n    // Replace the last carry output to be zNN\n    const lastGate = gates.find(g => g.out === `c${lastBit}`);\n    if (lastGate) lastGate.out = `z${lastZ}`;\n\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n    return gates.map(g => {\n      if (g.out === wire1) return { ...g, out: wire2 };\n      if (g.out === wire2) return { ...g, out: wire1 };\n      return { ...g };\n    });\n  }\n\n  it('should find 4 pairs of swapped wires in an 8-bit adder', () => {\n    let gates = makeCorrectAdder(8);\n    // Swap 4 pairs\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z03', 't03');\n    gates = swapOutputs(gates, 'b05', 'c05');\n    gates = swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a07', 'b05', 'c05', 't03', 'z01', 'z03', 'z07']);\n  });\n\n  it('should find swapped wires in a larger circuit', () => {\n    let gates = makeCorrectAdder(16);\n    gates = swapOutputs(gates, 'z02', 'a02');\n    gates = swapOutputs(gates, 'z10', 'b10');\n    gates = swapOutputs(gates, 't05', 'c05');\n    gates = swapOutputs(gates, 'a12', 'b12');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a02', 'a12', 'b10', 'b12', 'c05', 't05', 'z02', 'z10']);\n  });\n});\n"}}
