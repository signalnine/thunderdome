+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Find the number of input bits by looking at x-wires referenced
+  const xBits = new Set<string>();
+  for (const g of gates) {
+    if (g.in1.startsWith('x')) xBits.add(g.in1);
+    if (g.in2.startsWith('x')) xBits.add(g.in2);
+  }
+  const numBits = xBits.size;
+  const lastZ = 'z' + String(numBits).padStart(2, '0');
+
+  // Helper: check if a gate takes xNN and yNN as inputs (in either order)
+  function isXYGate(gate: Gate): boolean {
+    return (
+      (gate.in1.startsWith('x') && gate.in2.startsWith('y')) ||
+      (gate.in1.startsWith('y') && gate.in2.startsWith('x'))
+    );
+  }
+
+  // Helper: find gate that uses a given wire as input with a specific op
+  function findGateUsingWireWithOp(
+    wire: string,
+    op: Gate['op']
+  ): Gate | undefined {
+    return gates.find(
+      (g) => g.op === op && (g.in1 === wire || g.in2 === wire)
+    );
+  }
+
+  const swapped = new Set<string>();
+
+  // Structural rules for a ripple-carry adder:
+  //
+  // Rule 1: All z-outputs (except lastZ) must come from XOR gates.
+  //
+  // Rule 2: XOR gates whose inputs are xNN/yNN (bit != 0) should NOT output
+  //   to z directly, and should be used by both a XOR and AND gate downstream.
+  //
+  // Rule 3: XOR gates whose inputs are NOT xNN/yNN should output to z.
+  //
+  // Rule 4: AND gates (except x00 AND y00) should feed into an OR gate.
+  //
+  // Rule 5: OR gates should feed into both XOR and AND gates (carry propagation),
+  //   unless the output is the lastZ.
+
+  for (const gate of gates) {
+    const out = gate.out;
+
+    if (out.startsWith('z') && out !== lastZ) {
+      // Rule 1: z-outputs (except last) must be XOR
+      if (gate.op !== 'XOR') {
+        swapped.add(out);
+      }
+    }
+
+    if (gate.op === 'XOR') {
+      if (isXYGate(gate)) {
+        const bitStr = gate.in1.substring(1);
+        if (bitStr === '00') {
+          if (out !== 'z00') {
+            swapped.add(out);
+          }
+        } else {
+          // Should not output to z directly
+          if (out.startsWith('z')) {
+            swapped.add(out);
+          }
+          // Should be used as input to another XOR and another AND
+          const usedByXOR = findGateUsingWireWithOp(out, 'XOR');
+          const usedByAND = findGateUsingWireWithOp(out, 'AND');
+          if (!usedByXOR && !usedByAND) {
+            swapped.add(out);
+          }
+        }
+      } else {
+        // Non-xy XOR gate: its output should be a z-wire
+        if (!out.startsWith('z')) {
+          swapped.add(out);
+        }
+      }
+    }
+
+    if (gate.op === 'AND') {
+      if (isXYGate(gate)) {
+        const bitStr = gate.in1.substring(1);
+        if (bitStr === '00') {
+          // c00 feeds the next stage directly, not through OR
+          continue;
+        }
+      }
+      // Output should feed into an OR gate
+      const usedByOR = findGateUsingWireWithOp(out, 'OR');
+      if (!usedByOR) {
+        if (out !== lastZ) {
+          swapped.add(out);
+        }
+      }
+    }
+
+    if (gate.op === 'OR') {
+      // OR gate output is a carry wire. It should feed into XOR and AND
+      // of the next stage, unless it's the last z output.
+      if (out === lastZ) {
+        // Fine - final carry becomes MSB
+        continue;
+      }
+      // Should not be a z output (those come from XOR)
+      if (out.startsWith('z')) {
+        swapped.add(out);
+      }
+      // Should feed into both XOR and AND gates
+      const usedByXOR = findGateUsingWireWithOp(out, 'XOR');
+      const usedByAND = findGateUsingWireWithOp(out, 'AND');
+      if (!usedByXOR || !usedByAND) {
+        if (!out.startsWith('z')) {
+          swapped.add(out);
+        }
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
