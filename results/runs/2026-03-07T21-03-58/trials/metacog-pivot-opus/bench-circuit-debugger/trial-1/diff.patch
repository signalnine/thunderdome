put\n  function isXY(wire: string): boolean {\n    return wire.startsWith('x') || wire.startsWith('y');\n  }\n\n  // Helper: check if a gate takes xNN and yNN as inputs (in either order)\n  function isXYGate(gate: Gate): boolean {\n    return (\n      (gate.in1.startsWith('x') && gate.in2.startsWith('y')) ||\n      (gate.in1.startsWith('y') && gate.in2.startsWith('x'))\n    );\n  }\n\n  // Helper: find gate that uses a given wire as input with a specific op\n  function findGateUsingWireWithOp(\n    wire: string,\n    op: Gate['op']\n  ): Gate | undefined {\n    return gates.find(\n      (g) => g.op === op && (g.in1 === wire || g.in2 === wire)\n    );\n  }\n\n  // Helper: find all gates that use a given wire as input\n  function findGatesUsingWire(wire: string): Gate[] {\n    return gates.filter((g) => g.in1 === wire || g.in2 === wire);\n  }\n\n  const swapped = new Set<string>();\n\n  // Structural rules for a ripple-carry adder:\n  //\n  // Rule 1: All z-outputs (except lastZ) must come from XOR gates.\n  //   If a z-output comes from a non-XOR gate, that z-wire is swapped.\n  //\n  // Rule 2: XOR gates whose inputs are both xNN/yNN (except bit 0) should\n  //   NOT output to z directly. If they do, that z-wire is swapped.\n  //\n  // Rule 3: XOR gates whose inputs are NOT xNN/yNN should output to z.\n  //   If they don't, their output is swapped.\n  //\n  // Rule 4: AND gates (except x00 AND y00) should feed into an OR gate.\n  //   If an AND gate's output doesn't feed any OR gate, its output is swapped.\n  //\n  // Rule 5: XOR gates whose inputs are xNN/yNN should feed into another XOR\n  //   and another AND gate. If the output doesn't feed into a XOR gate\n  //   (and it's not bit 0), then its output may be swapped.\n\n  for (const gate of gates) {\n    const out = gate.out;\n\n    if (out.startsWith('z') && out !== lastZ) {\n      // Rule 1: z-outputs (except last) must be XOR\n      if (gate.op !== 'XOR') {\n        swapped.add(out);\n      }\n    }\n\n    if (gate.op === 'XOR') {\n      if (isXYGate(gate)) {\n        // This is an xNN XOR yNN gate (partial sum)\n        // For bit 0, output should be z00\n        // For other bits, output should NOT be z directly\n        const bitStr = gate.in1.substring(1);\n        if (bitStr === '00') {\n          if (out !== 'z00') {\n            swapped.add(out);\n          }\n        } else {\n          // Should not output to z directly\n          if (out.startsWith('z')) {\n            swapped.add(out);\n          }\n          // Should be used as input to another XOR and another AND\n          const usedByXOR = findGateUsingWireWithOp(out, 'XOR');\n          const usedByAND = findGateUsingWireWithOp(out, 'AND');\n          if (!usedByXOR && !usedByAND) {\n            // This output is definitely wrong\n            swapped.add(out);\n          }\n        }\n      } else {\n        // Non-xy XOR gate: its output should be a z-wire\n        if (!out.startsWith('z')) {\n          swapped.add(out);\n        }\n      }\n    }\n\n    if (gate.op === 'AND') {\n      // AND gate outputs should feed into OR gates (carry chain)\n      // Exception: x00 AND y00 -> c00 which feeds the next stage\n      if (isXYGate(gate)) {\n        const bitStr = gate.in1.substring(1);\n        if (bitStr === '00') {\n          // c00: should feed into XOR and AND of bit 1, not into OR\n          // Actually c00 feeds bit 1's XOR and AND directly\n          // Skip this special case\n          continue;\n        }\n      }\n      // Output should feed into an OR gate\n      const usedByOR = findGateUsingWireWithOp(out, 'OR');\n      if (!usedByOR) {\n        // Unless the output is the last z (which shouldn't happen for AND)\n        if (out !== lastZ) {\n          swapped.add(out);\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[],"originalFile":null}}
