    tq.addTask('b', { queue: 'q2' });\n   101→      tq.addTask('c'); // default\n   102→\n   103→      const names = tq.getQueueNames();\n   104→      expect(names).toContain('q1');\n   105→      expect(names).toContain('q2');\n   106→      expect(names).toContain('default');\n   107→    });\n   108→\n   109→    it('should return null from non-existent queue', () => {\n   110→      expect(tq.getNextTask('nonexistent')).toBeNull();\n   111→    });\n   112→\n   113→    it('should return null from empty queue', () => {\n   114→      tq.addTask('task', { queue: 'q1' });\n   115→      tq.getNextTask('q1');\n   116→      expect(tq.getNextTask('q1')).toBeNull();\n   117→    });\n   118→  });\n   119→\n   120→  // ===== Phase 3: Priority =====\n   121→  describe('Phase 3: Priority', () => {\n   122→    it('should default priority to 5', () => {\n   123→      const task = tq.addTask('default');\n   124→      expect(task.priority).toBe(5);\n   125→    });\n   126→\n   127→    it('should return higher priority tasks first', () => {\n   128→      tq.addTask('low', { priority: 10 });\n   129→      tq.addTask('high', { priority: 1 });\n   130→      tq.addTask('medium', { priority: 5 });\n   131→\n   132→      expect(tq.getNextTask()?.payload).toBe('high');\n   133→      expect(tq.getNextTask()?.payload).toBe('medium');\n   134→      expect(tq.getNextTask()?.payload).toBe('low');\n   135→    });\n   136→\n   137→    it('should maintain FIFO for same priority', () => {\n   138→      tq.addTask('first', { priority: 3 });\n   139→      tq.addTask('second', { priority: 3 });\n   140→      tq.addTask('third', { priority: 3 });\n   141→\n   142→      expect(tq.getNextTask()?.payload).toBe('first');\n   143→      expect(tq.getNextTask()?.payload).toBe('second');\n   144→      expect(tq.getNextTask()?.payload).toBe('third');\n   145→    });\n   146→\n   147→    it('should reject invalid priority values', () => {\n   148→      expect(() => tq.addTask('x', { priority: 0 })).toThrow();\n   1