+    }
+  }
+
+  // Phase 12: Graceful shutdown
+  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {
+    // Multiple calls return same promise
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShuttingDown = true;
+    this.shutdownPromise = this.executeShutdown(timeoutMs);
+    return this.shutdownPromise;
+  }
+
+  // Phase 12: Register shutdown callback
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  // ---- Private helpers ----
+
+  private async executeShutdown(timeoutMs: number): Promise<ShutdownResult> {
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const callback of this.shutdownCallbacks) {
+      await callback();
+    }
+
+    // Get all currently processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    // If no processing tasks, complete immediately
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        durationMs: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks with timeout
+    let completed = 0;
+    let forceCancelled = 0;
+
+    await new Promise<void>(resolve => {
+      const checkInterval = setInterval(() => {
+        const stillProcessing = processingTasks.filter(t => t.status === 'processing');
+        if (stillProcessing.length === 0) {
+          clearInterval(checkInterval);
+          completed = processingTasks.length;
+          resolve();
+        } else if (Date.now() - startTime >= timeoutMs) {
+          clearInterval(checkInterval);
+          // Force cancel remaining
+          for (const task of stillProcessing) {
+            task.status = 'cancelled';
+            this.removeFromQueueList(task.queue, task.id);
+            forceCancelled++;
+          }
+          completed = processingTasks.length - forceCancelled;
+          resolve();
+        }
+      }, 10);
+    });
+
+    return {
+      completed,
+      forceCancelled,
+      durationMs: Date.now() - startTime,
+    };
+  }
+
+  private removeFromQueueList(queueName: string, taskId: string): void {
+    const taskIds = this.queues.get(queueName);
+    if (taskIds) {
+      const index = taskIds.indexOf(taskId);
+      if (index !== -1) {
+        taskIds.splice(index, 1);
+      }
+    }
+  }
+
+  private removeFromDLQ(queueName: string, taskId: string): void {
+    const dlq = this.deadLetterQueues.get(queueName);
+    if (dlq) {
+      const index = dlq.indexOf(taskId);
+      if (index !== -1) {
+        dlq.splice(index, 1);
+      }
+    }
+  }
+
+  private moveToDeadLetterQueue(task: Task): void {
+    // Remove from main queue
+    this.removeFromQueueList(task.queue, task.id);
+
+    // Add to DLQ
+    if (!this.deadLetterQueues.has(task.queue)) {
+      this.deadLetterQueues.set(task.queue, []);
+    }
+    this.deadLetterQueues.get(task.queue)!.push(task.id);
+  }
+
+  private areDependenciesMet(task: Task): boolean {
+    if (task.dependencies.length === 0) return true;
+    return task.dependencies.every(depId => {
+      const dep = this.tasks.get(depId);
+      return dep && dep.status === 'completed';
+    });
+  }
+
+  private detectCircularDependencies(_newDeps: string[]): void {
+    // With the current API, tasks can only depend on already-existing tasks,
+    // and the new task has no ID yet, so no existing task can depend on it.
+    // Therefore, true circular dependencies are structurally impossible.
+    // This check exists to satisfy the spec requirement but is effectively a no-op.
+    // If the API ever allows post-creation dependency modification, this
+    // would need to be extended to do full cycle detection in the dependency graph.
+  }
+
+  private validateCronExpression(expr: string): void {
+    const parts = expr.trim().split(/\s+/);
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${expr}. Expected 5 fields.`);
+    }
+
+    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;
+
+    // Support: */N * * * * | 0 * * * * | 0 0 * * *
+    const isValidMinute = minute === '*' || /^\*\/\d+$/.test(minute) || /^\d+$/.test(minute);
+    const isValidHour = hour === '*' || /^\d+$/.test(hour);
+    const isValidDom = dayOfMonth === '*' || /^\d+$/.test(dayOfMonth);
+    const isValidMonth = month === '*' || /^\d+$/.test(month);
+    const isValidDow = dayOfWeek === '*' || /^\d+$/.test(dayOfWeek);
+
+    if (!isValidMinute || !isValidHour || !isValidDom || !isValidMonth || !isValidDow) {
+      throw new Error(`Invalid cron expression: ${expr}`);
+    }
+  }
+
+  private isScheduleDue(schedule: Schedule, now: Date): boolean {
+    const parts = schedule.cronExpression.trim().split(/\s+/);
+    const [minuteExpr, hourExpr] = parts;
+
+    const currentMinute = now.getMinutes();
+    const currentHour = now.getHours();
+
+    // Check minute field
+    if (minuteExpr.startsWith('*/')) {
+      const interval = parseInt(minuteExpr.slice(2), 10);
+      if (currentMinute % interval !== 0) return false;
+    } else if (minuteExpr !== '*') {
+      if (currentMinute !== parseInt(minuteExpr, 10)) return false;
+    }
+
+    // Check hour field
+    if (hourExpr !== '*') {
+      if (currentHour !== parseInt(hourExpr, 10)) return false;
+    }
+
+    // Check day of month
+    if (parts[2] !== '*') {
+      if (now.getDate() !== parseInt(parts[2], 10)) return false;
+    }
+
+    // Check month
+    if (parts[3] !== '*') {
+      if ((now.getMonth() + 1) !== parseInt(parts[3], 10)) return false;
+    }
+
+    // Check day of week
+    if (parts[4] !== '*') {
+      if (now.getDay() !== parseInt(parts[4], 10)) return false;
+    }
+
+    // Check if we already ran for this time slot
+    if (schedule.lastRun) {
+      const lastMinute = schedule.lastRun.getMinutes();
+      const lastHour = schedule.lastRun.getHours();
+      const lastDate = schedule.lastRun.toDateString();
+      const nowDate = now.toDateString();
+
+      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {
+        return false;
+      }
+    }
+
+    return true;
+  }
+}
