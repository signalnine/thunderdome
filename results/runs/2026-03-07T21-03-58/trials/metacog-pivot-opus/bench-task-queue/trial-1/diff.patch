return null when no tasks are available', () => {\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should return null when all tasks are processing', () => {\n      tq.addTask('task');\n      tq.getNextTask();\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should track pending count', () => {\n      expect(tq.getPendingCount()).toBe(0);\n      tq.addTask('a');\n      tq.addTask('b');\n      expect(tq.getPendingCount()).toBe(2);\n      tq.getNextTask();\n      expect(tq.getPendingCount()).toBe(1);\n    });\n\n    it('should transition task to processing state on retrieval', () => {\n      const added = tq.addTask('task');\n      const retrieved = tq.getNextTask();\n      expect(retrieved?.id).toBe(added.id);\n      expect(retrieved?.status).toBe('processing');\n    });\n  });\n\n  // ===== Phase 2: Named Queues =====\n  describe('Phase 2: Named Queues', () => {\n    it('should add tasks to named queues', () => {\n      tq.addTask('email', { queue: 'emails' });\n      tq.addTask('sms', { queue: 'sms' });\n\n      expect(tq.getPendingCount('emails')).toBe(1);\n      expect(tq.getPendingCount('sms')).toBe(1);\n    });\n\n    it('should retrieve from specific queue only', () => {\n      tq.addTask('email-task', { queue: 'emails' });\n      tq.addTask('sms-task', { queue: 'sms' });\n\n      const task = tq.getNextTask('emails');\n      expect(task?.payload).toBe('email-task');\n      expect(tq.getNextTask('emails')).toBeNull();\n      expect(tq.getNextTask('sms')).not.toBeNull();\n    });\n\n    it('should use default queue when no name given', () => {\n      tq.addTask('default-task');\n      const task = tq.getNextTask();\n      expect(task?.payload).toBe('default-task');\n      expect(task?.queue).toBe('default');\n    });\n\n    it('should list all queue names', () => {\n      tq.addTask('a', { queue: 'q1' });\n      tq.addTask('b', { queue: 'q2' });\n      tq.addTask('c'); // default\n\n      const names = tq.getQueueNames();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n      expect(names).toContain('default');\n    });\n\n    it('should return null from non-existent queue', () => {\n      expect(tq.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should return null from empty queue', () => {\n      tq.addTask('task', { queue: 'q1' });\n      tq.getNextTask('q1');\n      expect(tq.getNextTask('q1')).toBeNull();\n    });\n  });\n\n  // ===== Phase 3: Priority =====\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = tq.addTask('default');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first', () => {\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n      tq.addTask('medium', { priority: 5 });\n\n      expect(tq.getNextTask()?.payload).toBe('high');\n      expect(tq.getNextTask()?.payload).toBe('medium');\n      expect(tq.getNextTask()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO for same priority', () => {\n      tq.addTask('first', { priority: 3 });\n      tq.addTask('second', { priority: 3 });\n      tq.addTask('third', { priority: 3 });\n\n      expect(tq.getNextTask()?.payload).toBe('first');\n      expect(tq.getNextTask()?.payload).toBe('second');\n      expect(tq.getNextTask()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => tq.addTask('x', { priority: 0 })).toThrow();\n      expect(() => tq.addTask('x', { priority: 11 })).toThrow();\n      expect(() => tq.addTask('x', { priority: 1.5 })).toThrow();\n      expect(() => tq.addTask('x', { priority: -1 })).toThrow();\n    });\n\n    it('should maintain priority per queue', () => {\n      tq.addTask('q1-low', { queue: 'q1', priority: 10 });\n      tq.addTask('q1-high', { queue: 'q1', priority: 1 });\n      tq.addTask('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(tq.getNextTask('q1')?.payload).toBe('q1-high');\n      expect(tq.getNextTask('q2')?.payload).toBe('q2-low');\n    });\n\n    it('should expose priority on task object', () => {\n      const task = tq.addTask('task', { priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n  });\n\n  // ===== Phase 4: Delayed Tasks =====\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their availability time', () => {\n      tq.addTask('delayed', { delay: 10000 });\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should return delayed tasks after their availability time', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.addTask('available', { availableAt: past });\n      const task = tq.getNextTask();\n      expect(task?.payload).toBe('available');\n    });\n\n    it('should prefer non-delayed tasks over unavailable delayed ones', () => {\n      tq.addTask('delayed', { delay: 100000 });\n      tq.addTask('immediate');\n\n      const task = tq.getNextTask();\n      expect(task?.payload).toBe('immediate');\n    });\n\n    it('should order available delayed tasks by availability time', () => {\n      const now = Date.now();\n      tq.addTask('later', { availableAt: new Date(now - 100) });\n      tq.addTask('sooner', { availableAt: new Date(now - 200) });\n\n      expect(tq.getNextTask()?.payload).toBe('sooner');\n      expect(tq.getNextTask()?.payload).toBe('later');\n    });\n\n    it('should indicate availability time on task object', () => {\n      const futureTime = new Date(Date.now() + 5000);\n      const task = tq.addTask('delayed', { availableAt: futureTime });\n      expect(task.availableAt.getTime()).toBe(futureTime.getTime());\n    });\n\n    it('should handle delay in milliseconds', () => {\n      const before = Date.now();\n      const task = tq.addTask('delayed', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(before + 5000);\n    });\n\n    it('should work with named queues', () => {\n      tq.addTask('delayed', { queue: 'q1', delay: 100000 });\n      tq.addTask('immediate', { queue: 'q1' });\n\n      expect(tq.getNextTask('q1')?.payload).toBe('immediate');\n    });\n  });\n\n  // ===== Phase 5: Retry with Backoff =====\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a processing task', () => {\n      tq.addTask('task');\n      const retrieved = tq.getNextTask()!;\n      tq.completeTask(retrieved.id);\n      expect(tq.getTask(retrieved.id)?.status).toBe('completed');\n    });\n\n    it('should fail and retry a task with backoff', () => {\n      tq.addTask('task', { maxRetries: 3, backoffDelay: 1000 });\n      const t1 = tq.getNextTask()!;\n      expect(t1.attempts).toBe(1);\n\n      tq.failTask(t1.id, 'error1');\n      // Task should be re-queued with delay\n      const taskState = tq.getTask(t1.id)!;\n      expect(taskState.status).toBe('pending');\n      expect(taskState.failureCount).toBe(1);\n      // Not available immediately due to backoff\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should use exponential backoff', () => {\n      tq.addTask('task', { maxRetries: 3, backoffDelay: 1000 });\n\n      // Attempt 1\n      const t1 = tq.getNextTask()!;\n      const beforeFail = Date.now();\n      tq.failTask(t1.id, 'err');\n      const afterFail = tq.getTask(t1.id)!;\n      // backoff = 1000 * 2^(1-1) = 1000ms\n      expect(afterFail.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 1000);\n    });\n\n    it('should track attempt count', () => {\n      tq.addTask('task', { maxRetries: 3, backoffDelay: 0 });\n      const t1 = tq.getNextTask()!;\n      expect(t1.attempts).toBe(1);\n    });\n\n    it('should exhaust retries and leave task failed', () => {\n      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n\n      // First and only attempt\n      const t1 = tq.getNextTask()!;\n      expect(t1.attempts).toBe(1);\n      tq.failTask(t1.id, 'final error');\n\n      const finalState = tq.getTask(t1.id)!;\n      expect(finalState.status).toBe('failed');\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = tq.addTask('task', { queue: 'q1', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      const t1 = tq.getNextTask('q1')!;\n      tq.failTask(t1.id, 'err');\n\n      const retried = tq.getTask(t1.id)!;\n      expect(retried.queue).toBe('q1');\n      expect(retried.priority).toBe(2);\n    });\n\n    it('should default maxRetries to 3', () => {\n      const task = tq.addTask('task');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should default backoffDelay to 1000', () => {\n      const task = tq.addTask('task');\n      expect(task.backoffDelay).toBe(1000);\n    });\n\n    it('should throw when completing non-processing task', () => {\n      const task = tq.addTask('task');\n      expect(() => tq.completeTask(task.id)).toThrow();\n    });\n\n    it('should throw when failing non-processing task', () => {\n      const task = tq.addTask('task');\n      expect(() => tq.failTask(task.id)).toThrow();\n    });\n  });\n\n  // ===== Phase 6: Dead Letter Queue =====\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move exhausted-retry tasks to DLQ', () => {\n      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n      const t1 = tq.getNextTask()!;\n      tq.failTask(t1.id, 'fatal');\n\n      const dlqTasks = tq.getDeadLetterTasks();\n      expect(dlqTasks).toHaveLength(1);\n      expect(dlqTasks[0].id).toBe(task.id);\n      expect(dlqTasks[0].lastError).toBe('fatal');\n    });\n\n    it('should retain error info and failure count', () => {\n      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n      const t1 = tq.getNextTask()!;\n      tq.failTask(t1.id, 'error message');\n\n      const dlqTasks = tq.getDeadLetterTasks();\n      expect(dlqTasks[0].lastError).toBe('error message');\n      expect(dlqTasks[0].failureCount).toBe(1);\n    });\n\n    it('should retry dead-lettered tasks', () => {\n      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n      const t1 = tq.getNextTask()!;\n      tq.failTask(t1.id, 'err');\n\n      const retried = tq.retryDeadLetterTask(t1.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempts).toBe(0);\n      expect(retried.failureCount).toBe(0);\n\n      // Should be retrievable again\n      const t2 = tq.getNextTask()!;\n      expect(t2.id).toBe(task.id);\n\n      // DLQ should be empty\n      expect(tq.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should clear DLQ for a queue', () => {\n      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n      const t1 = tq.getNextTask()!;\n      tq.failTask(t1.id, 'err');\n\n      expect(tq.getDeadLetterTasks()).toHaveLength(1);\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should have independent DLQs per queue', () => {\n      const t1 = tq.addTask('task1', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n      const t2 = tq.addTask('task2', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n\n      tq.failTask(tq.getNextTask('q1')!.id, 'err');\n      tq.failTask(tq.getNextTask('q2')!.id, 'err');\n\n      expect(tq.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n\n      tq.clearDeadLetterQueue('q1');\n      expect(tq.getDeadLetterTasks('q1')).toHaveLength(0);\n      expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n  });\n\n  // ===== Phase 7: Task Dependencies =====\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.addTask('dependency');\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      // Should get the dependency first (not the dependent)\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(dep.id);\n\n      // Dependent should not be available\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.addTask('dependency');\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n\n      // Now dependent should be available\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(dependent.id);\n    });\n\n    it('should reject circular dependencies', () => {\n      const t1 = tq.addTask('t1');\n      const t2 = tq.addTask('t2', { dependencies: [t1.id] });\n      expect(() => tq.addTask('t3', { dependencies: [t2.id, t1.id] })).not.toThrow();\n    });\n\n    it('should reject non-existent dependencies', () => {\n      expect(() => tq.addTask('task', { dependencies: ['nonexistent-id'] })).toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = tq.addTask('dependency', { maxRetries: 1, backoffDelay: 0 });\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      const task = tq.getNextTask()!;\n      tq.failTask(task.id, 'err');\n\n      // Dependent stays blocked (failed dep doesn't unblock)\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = tq.addTask('dep1');\n      const dep2 = tq.addTask('dep2');\n      const dependent = tq.addTask('task', { dependencies: [dep1.id, dep2.id] });\n\n      const status = tq.getDependencyStatus(dependent.id);\n      expect(status).toHaveLength(2);\n      expect(status[0].status).toBe('pending');\n      expect(status[1].status).toBe('pending');\n\n      // Complete one dependency\n      tq.getNextTask();\n      const processing = tq.getDependencyStatus(dependent.id);\n      expect(processing.some(s => s.status === 'processing')).toBe(true);\n    });\n  });\n\n  // ===== Phase 8: Concurrency Control =====\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing tasks', () => {\n      tq.setConcurrency('default', 2);\n      tq.addTask('t1');\n      tq.addTask('t2');\n      tq.addTask('t3');\n\n      expect(tq.getNextTask()).not.toBeNull();\n      expect(tq.getNextTask()).not.toBeNull();\n      expect(tq.getNextTask()).toBeNull(); // limit reached\n    });\n\n    it('should free slot on task completion', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('t1');\n      tq.addTask('t2');\n\n      const t1 = tq.getNextTask()!;\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.completeTask(t1.id);\n      expect(tq.getNextTask()).not.toBeNull();\n    });\n\n    it('should free slot on task failure', () => {\n      tq.setConcurrency('default', 1);\n      const task = tq.addTask('t1', { maxRetries: 1, backoffDelay: 0 });\n      tq.addTask('t2');\n\n      const t1 = tq.getNextTask()!;\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.failTask(t1.id, 'err'); // Exhausted, goes to DLQ\n\n      expect(tq.getNextTask()).not.toBeNull();\n    });\n\n    it('should default to unlimited concurrency', () => {\n      for (let i = 0; i < 100; i++) {\n        tq.addTask(`task-${i}`);\n      }\n      for (let i = 0; i < 100; i++) {\n        expect(tq.getNextTask()).not.toBeNull();\n      }\n    });\n\n    it('should query concurrency limit and active count', () => {\n      tq.setConcurrency('default', 5);\n      expect(tq.getConcurrencyLimit('default')).toBe(5);\n      expect(tq.getActiveCount('default')).toBe(0);\n\n      tq.addTask('task');\n      tq.getNextTask();\n      expect(tq.getActiveCount('default')).toBe(1);\n    });\n\n    it('should still respect priority ordering with concurrency', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n\n      const task = tq.getNextTask()!;\n      expect(task.payload).toBe('high');\n    });\n  });\n\n  // ===== Phase 9: Progress and Cancellation =====\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report and query progress', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n\n      tq.reportProgress(task.id, 50, 'halfway');\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should reject invalid progress values', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n\n      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('should notify progress listeners', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n\n      const updates: { progress: number; message?: string }[] = [];\n      tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      tq.reportProgress(task.id, 25, 'quarter');\n      tq.reportProgress(task.id, 75, 'three quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0].progress).toBe(25);\n      expect(updates[1].progress).toBe(75);\n    });\n\n    it('should support unsubscribe', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n\n      let callCount = 0;\n      const unsubscribe = tq.onProgress(task.id, () => callCount++);\n\n      tq.reportProgress(task.id, 50);\n      unsubscribe();\n      tq.reportProgress(task.id, 100);\n\n      expect(callCount).toBe(1);\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = tq.addTask('task');\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n      expect(tq.getPendingCount()).toBe(0);\n    });\n\n    it('should cancel processing tasks', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.addTask('task', { maxRetries: 3 });\n      const t = tq.getNextTask()!;\n      tq.cancelTask(t.id);\n\n      // Should not be available even though retries remain\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should throw when cancelling completed task', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n      expect(() => tq.cancelTask(task.id)).toThrow();\n    });\n  });\n\n  // ===== Phase 10: Recurring Tasks =====\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(schedule.id).toBe('s1');\n      expect(schedule.cronExpression).toBe('*/5 * * * *');\n    });\n\n    it('should list active schedules', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', 'payload1');\n      tq.addSchedule('s2', '0 * * * *', 'default', 'payload2');\n\n      const schedules = tq.getSchedules();\n      expect(schedules).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', 'payload');\n      tq.removeSchedule('s1');\n      expect(tq.getSchedules()).toHaveLength(0);\n    });\n\n    it('should throw when removing non-existent schedule', () => {\n      expect(() => tq.removeSchedule('nonexistent')).toThrow();\n    });\n\n    it('should enqueue tasks on tick for due schedules', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'recurring' });\n\n      // Tick at a time divisible by 5 minutes\n      const tickTime = new Date(2024, 0, 1, 12, 0, 0); // 12:00\n      const tasks = tq.tick(tickTime);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'recurring' });\n    });\n\n    it('should not enqueue tasks when not due', () => {\n      tq.addSchedule('s1', '0 * * * *', 'default', 'payload');\n\n      // Tick at 12:30 - not on the hour\n      const tickTime = new Date(2024, 0, 1, 12, 30, 0);\n      const tasks = tq.tick(tickTime);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not double-enqueue for same time slot', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', 'payload');\n\n      const tickTime = new Date(2024, 0, 1, 12, 0, 0);\n      tq.tick(tickTime);\n      const tasks2 = tq.tick(tickTime);\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', 'payload');\n      tq.tick(new Date(2024, 0, 1, 12, 0, 0));\n      tq.removeSchedule('s1');\n      const tasks = tq.tick(new Date(2024, 0, 1, 12, 5, 0));\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should validate cron expressions', () => {\n      expect(() => tq.addSchedule('s', 'invalid', 'default', 'p')).toThrow();\n      expect(() => tq.addSchedule('s', '* *', 'default', 'p')).toThrow();\n    });\n\n    it('should handle every day at midnight', () => {\n      tq.addSchedule('s1', '0 0 * * *', 'default', 'midnight');\n\n      const midnight = new Date(2024, 0, 1, 0, 0, 0);\n      expect(tq.tick(midnight)).toHaveLength(1);\n\n      const noon = new Date(2024, 0, 1, 12, 0, 0);\n      expect(tq.tick(noon)).toHaveLength(0);\n    });\n  });\n\n  // ===== Phase 11: Middleware =====\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should pass tasks through middleware', async () => {\n      const order: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push('middleware1');\n        await next();\n      });\n      tq.use('default', async (_task, next) => {\n        order.push('middleware2');\n        await next();\n      });\n      tq.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n      await tq.processTask(task.id);\n\n      expect(order).toEqual(['middleware1', 'middleware2', 'handler']);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      let handlerCalled = false;\n\n      tq.use('default', async () => {\n        // intentionally not calling next\n      });\n      tq.setHandler('default', async () => {\n        handlerCalled = true;\n      });\n\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n      await tq.processTask(task.id);\n\n      expect(handlerCalled).toBe(false);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      tq.use('default', async (task, next) => {\n        (task.payload as Record<string, unknown>).modified = true;\n        await next();\n      });\n\n      let receivedPayload: unknown;\n      tq.setHandler('default', async (task) => {\n        receivedPayload = task.payload;\n      });\n\n      tq.addTask({ original: true });\n      const task = tq.getNextTask()!;\n      await tq.processTask(task.id);\n\n      expect(receivedPayload).toEqual({ original: true, modified: true });\n    });\n\n    it('should mark task as failed if middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const added = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n      const task = tq.getNextTask()!;\n      await tq.processTask(task.id);\n\n      const state = tq.getTask(task.id)!;\n      // After 1 attempt with maxRetries=1, task should be failed\n      expect(state.status).toBe('failed');\n      expect(state.lastError).toBe('middleware error');\n    });\n\n    it('should have independent middleware stacks per queue', async () => {\n      const q1Order: string[] = [];\n      const q2Order