+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FnXKGK66dMVJn8SYUFPk7x","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01DjqQNAQbJEWXcvQokHXtNi","name":"Write","input":{"file_path":"/workspace/src/TaskQueue.ts","content":"import { randomUUID } from 'node:crypto';\nimport type {\n  Task,\n  TaskStatus,\n  AddTaskOptions,\n  Schedule,\n  MiddlewareFn,\n  HandlerFn,\n  ProgressListener,\n  ShutdownResult,\n} from './types.js';\n\nconst DEFAULT_QUEUE = 'default';\n\nexport class TaskQueue {\n  private tasks: Map<string, Task> = new Map();\n  private queues: Map<string, string[]> = new Map(); // queue name -> task IDs in insertion order\n  private deadLetterQueues: Map<string, string[]> = new Map(); // queue name -> dead task IDs\n  private concurrencyLimits: Map<string, number> = new Map(); // queue name -> max concurrency\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map(); // task ID -> listeners\n  private schedules: Map<string, Schedule> = new Map();\n  private middlewares: Map<string, MiddlewareFn[]> = new Map(); // queue name -> middleware stack\n  private handlers: Map<string, HandlerFn> = new Map(); // queue name -> handler\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n  private isShuttingDown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private insertionCounter = 0;\n  private taskInsertionOrder: Map<string, number> = new Map(); // task ID -> insertion order\n\n  // Phase 1: Add a task with payload\n  addTask<T = unknown>(payload: T, options?: AddTaskOptions): Task<T> {\n    // Phase 12: reject after shutdown\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: queue system is shutting down');\n    }\n\n    const queue = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? 5;\n\n    // Phase 3: validate priority\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {