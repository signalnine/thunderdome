   return Array.from(this.queues.keys());\n  }\n\n  // Phase 5: Complete a task\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Remove from queue list\n    this.removeFromQueueList(task.queue, taskId);\n\n    // Phase 7: check if any dependent tasks are now unblocked\n    // (this happens naturally when getNextTask checks dependencies)\n  }\n\n  // Phase 5: Fail a task\n  failTask(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.lastError = error;\n    task.failureCount += 1;\n\n    // Check if task was cancelled (Phase 9) - never retry cancelled tasks\n    if (task.status === 'cancelled') {\n      return;\n    }\n\n    // Phase 5: retry with backoff\n    if (task.attempts < task.maxRetries) {\n      // Re-queue with backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n      delete task.progressMessage;\n      // Task stays in the queue list\n    } else {\n      // Retries exhausted\n      task.status = 'failed';\n\n      // Phase 6: move to DLQ\n      this.moveToDeadLetterQueue(task);\n    }\n  }\n\n  // Phase 6: Get dead letter queue tasks\n  getDeadLetterTasks(queueName?: string): Task[] {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const dlq = this.deadLetterQueues.get(queue);\n    if (!dlq) return [];\n    return dlq\n      .map(id => this.tasks.get(id))\n      .filter((t): t is Task => t !== undefined);\n  }\n\n  // Phase 6: Retry a dead-lettered task\n  retryDeadLetterTask(taskId: string): Task {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'failed') {\n      throw new Error(`Task ${taskId} is not in the dead letter queue`);\n    }\n\n    // Check it's actually in the DLQ\n    const dlq = this.deadLetterQueues.get(task.queue);\n    if (!dlq || !dlq.includes(taskId)) {\n      throw new Error(`Task ${taskId} is not in the dead letter queue`);\n    }\n\n    // Remove from DLQ\n    this.removeFromDLQ(task.queue, taskId);\n\n    // Reset for fresh retries\n    task.status = 'pending';\n    task.attempts = 0;\n    task.failureCount = 0;\n    task.progress = 0;\n    delete task.progressMessage;\n    delete task.lastError;\n    task.availableAt = new Date();\n\n    // Add back to queue\n    if (!this.queues.has(task.queue)) {\n      this.queues.set(task.queue, []);\n    }\n    this.queues.get(task.queue)!.push(taskId);\n    this.taskInsertionOrder.set(taskId, this.insertionCounter++);\n\n    return task;\n  }\n\n  // Phase 6: Clear DLQ for a queue\n  clearDeadLetterQueue(queueName?: string): void {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const dlq = this.deadLetterQueues.get(queue);\n    if (dlq) {\n      for (const id of dlq) {\n        this.tasks.delete(id);\n        this.taskInsertionOrder.delete(id);\n      }\n      this.deadLetterQueues.set(queue, []);\n    }\n  }\n\n  // Phase 7: Get task by ID\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  // Phase 7: Check dependency status\n  getDependencyStatus(taskId: string): { dependency: string; status: TaskStatus }[] {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    return task.dependencies.map(depId => {\n      const dep = this.tasks.get(depId);\n      return {\n        dependency: depId,\n        status: dep ? dep.status : 'failed' as TaskStatus,\n      };\n    });\n  }\n\n  // Phase 8: Set concurrency limit\n  setConcurrency(queueName: string, limit: number): void {\n    if (limit < 1 || !Number.isInteger(limit)) {\n      throw new Error(`Invalid concurrency limit: ${limit}`);\n    }\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  // Phase 8: Get concurrency limit\n  getConcurrencyLimit(queueName?: string): number | undefined {\n    return this.concurrencyLimits.get(queueName ?? DEFAULT_QUEUE);\n  }\n\n  // Phase 8: Get active (processing) count\n  getActiveCount(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const taskIds = this.queues.get(queue);\n    if (!taskIds) return 0;\n    return taskIds.filter(id => {\n      const task = this.tasks.get(id);\n      return task && task.status === 'processing';\n    }).length;\n  }\n\n  // Phase 9: Report progress\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress value: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  // Phase 9: Get progress\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  // Phase 9: Subscribe to progress updates\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  // Phase 9: Cancel a task\n  cancelTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Task ${taskId} cannot be cancelled (current: ${task.status})`);\n    }\n\n    task.status = 'cancelled';\n\n    // If pending, remove from queue\n    this.removeFromQueueList(task.queue, taskId);\n  }\n\n  // Phase 10: Add a recurring schedule\n  addSchedule(\n    id: string,\n    cronExpression: string,\n    queue: string,\n    payload: unknown,\n    taskOptions?: Omit<AddTaskOptions, 'queue' | 'delay' | 'availableAt' | 'dependencies'>\n  ): Schedule {\n    // Validate cron expression\n    this.validateCronExpression(cronExpression);\n\n    const schedule: Schedule = {\n      id,\n      cronExpression,\n      queue,\n      payload,\n      taskOptions,\n    };\n\n    this.schedules.set(id, schedule);\n    return schedule;\n  }\n\n  // Phase 10: Remove a schedule\n  removeSchedule(id: string): void {\n    if (!this.schedules.has(id)) {\n      throw new Error(`Schedule not found: ${id}`);\n    }\n    this.schedules.delete(id);\n  }\n\n  // Phase 10: List active schedules\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  // Phase 10: Tick - check schedules and enqueue due tasks\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const createdTasks: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.isScheduleDue(schedule, currentTime)) {\n        const task = this.addTask(schedule.payload, {\n          queue: schedule.queue,\n          ...schedule.taskOptions,\n        });\n        createdTasks.push(task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return createdTasks;\n  }\n\n  // Phase 11: Register middleware for a queue\n  use(queueName: string, middleware: MiddlewareFn): void {\n    if (!this.middlewares.has(queueName)) {\n      this.middlewares.set(queueName, []);\n    }\n    this.middlewares.get(queueName)!.push(middleware);\n  }\n\n  // Phase 11: Register handler for a queue\n  setHandler(queueName: string, handler: HandlerFn): void {\n    this.handlers.set(queueName, handler);\n  }\n\n  // Phase 11: Process a task through middleware pipeline and handler\n  async processTask(taskId: string): Promise<void> {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state`);\n    }\n\n    const middlewares = this.middlewares.get(task.queue) ?? [];\n    const handler = this.handlers.get(task.queue);\n\n    try {\n      let index = 0;\n      let nextCalled = false;\n\n      const executeNext = async (): Promise<void> => {\n        if (index < middlewares.length) {\n          const currentMiddleware = middlewares[index];\n          index++;\n          nextCalled = false;\n          await currentMiddleware(task, async () => {\n            nextCalled = true;\n            await executeNext();\n          });\n          // If middleware didn't call next, processing is skipped\n          if (!nextCalled && index <= middlewares.length) {\n            return;\n          }\n        } else if (handler) {\n          await handler(task);\n        }\n      };\n\n      await executeNext();\n    } catch (error) {\n      const errorMessage = error instanceof Error ? error.message : String(error);\n      this.failTask(taskId, errorMessage);\n      return;\n    }\n  }\n\n  // Phase 12: Graceful shutdown\n  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {\n    // Multiple calls return same promise\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShuttingDown = true;\n    this.shutdownPromise = this.executeShutdown(timeoutMs);\n    return this.shutdownPromise;\n  }\n\n  // Phase 12: Register shutdown callback\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  // ---- Private helpers ----\n\n  private async executeShutdown(timeoutMs: number): Promise<ShutdownResult> {\n    const startTime = Date.now();\n\n    // Run shutdown callbacks\n    for (const callback of this.shutdownCallbacks) {\n      await callback();\n    }\n\n    // Get all currently processing tasks\n    const processingTasks: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        processingTasks.push(task);\n      }\n    }\n\n    // If no processing tasks, complete immediately\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        forceCancelled: 0,\n        durationMs: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks with timeout\n    let completed = 0;\n    let forceCancelled = 0;\n\n    await new Promise<void>(resolve => {\n      const checkInterval = setInterval(() => {\n        const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n        if (stillProcessing.length === 0) {\n          clearInterval(checkInterval);\n          completed = processingTasks.length;\n          resolve();\n        } else if (Date.now() - startTime >= timeoutMs) {\n          clearInterval(checkInterval);\n          // Force cancel remaining\n          for (const task of stillProcessing) {\n            task.status = 'cancelled';\n            this.removeFromQueueList(task.queue, task.id);\n            forceCancelled++;\n          }\n          completed = processingTasks.length - forceCancelled;\n          resolve();\n        }\n      }, 10);\n    });\n\n    return {\n      completed,\n      forceCancelled,\n      durationMs: Date.now() - startTime,\n    };\n  }\n\n  private removeFromQueueList(queueName: string, taskId: string): void {\n    const taskIds = this.queues.get(queueName);\n    if (taskIds) {\n      const index = taskIds.indexOf(taskId);\n      if (index !== -1) {\n        taskIds.splice(index, 1);\n      }\n    }\n  }\n\n  private moveToDeadLetterQueue(task: Task): void {\n    // Remove from main queue\n    this.removeFromQueueList(task.queue, task.id);\n\n    // Add to DLQ\n    if (!this.deadLetterQueues.has(task.queue)) {\n      this.deadLetterQueues.set(task.queue, []);\n    }\n    this.deadLetterQueues.get(task.queue)!.push(task.id);\n  }\n\n  private areDependenciesMet(task: Task): boolean {\n    if (task.dependencies.length === 0) return true;\n    return task.dependencies.every(depId => {\n      const dep = this.tasks.get(depId);\n      return dep && dep.status === 'completed';\n    });\n  }\n\n  private detectCircularDependencies(newDeps: string[]): void {\n    // BFS/DFS to check if any dependency chain creates a cycle\n    const visited = new Set<string>();\n    const stack = [...newDeps];\n\n    while (stack.length > 0) {\n      const currentId = stack.pop()!;\n      if (visited.has(currentId)) continue;\n      visited.add(currentId);\n\n      const currentTask = this.tasks.get(currentId);\n      if (currentTask && currentTask.dependencies.length > 0) {\n        for (const depId of currentTask.dependencies) {\n          if (newDeps.includes(depId)) {\n            //