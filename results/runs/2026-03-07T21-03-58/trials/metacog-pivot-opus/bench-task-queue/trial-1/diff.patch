ion order\n\n  // Phase 1: Add a task with payload\n  addTask<T = unknown>(payload: T, options?: AddTaskOptions): Task<T> {\n    // Phase 12: reject after shutdown\n    if (this.isShuttingDown) {\n      throw new Error('Cannot add tasks: queue system is shutting down');\n    }\n\n    const queue = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? 5;\n\n    // Phase 3: validate priority\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Phase 7: validate dependencies\n    const dependencies = options?.dependencies ?? [];\n    if (dependencies.length > 0) {\n      for (const depId of dependencies) {\n        if (!this.tasks.has(depId)) {\n          throw new Error(`Dependency task not found: ${depId}`);\n        }\n      }\n      // Check for circular dependencies\n      this.detectCircularDependencies(dependencies);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n\n    // Phase 4: handle delay\n    if (options?.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    } else if (options?.availableAt != null) {\n      availableAt = options.availableAt;\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      createdAt: now,\n      queue,\n      priority,\n      availableAt,\n      attempts: 0,\n      maxRetries: options?.maxRetries ?? 3,\n      backoffDelay: options?.backoffDelay ?? 1000,\n      failureCount: 0,\n      dependencies,\n      progress: 0,\n    };\n\n    this.tasks.set(task.id, task as Task);\n    this.taskInsertionOrder.set(task.id, this.insertionCounter++);\n\n    // Ensure queue exists\n    if (!this.queues.has(queue)) {\n      this.queues.set(queue, []);\n    }\n    this.queues.get(queue)!.push(task.id);\n\n    return task;\n  }\n\n  // Phase 1: Get next task from queue\n  getNextTask(queueName?: string): Task | null {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const taskIds = this.queues.get(queue);\n    if (!taskIds || taskIds.length === 0) {\n      return null;\n    }\n\n    // Phase 8: check concurrency limit\n    const limit = this.concurrencyLimits.get(queue);\n    if (limit !== undefined) {\n      const activeCount = this.getActiveCount(queue);\n      if (activeCount >= limit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n\n    // Find eligible tasks: pending, available, not blocked by dependencies\n    const eligible = taskIds.filter(id => {\n      const task = this.tasks.get(id);\n      if (!task || task.status !== 'pending') return false;\n      // Phase 4: check availability time\n      if (task.availableAt > now) return false;\n      // Phase 7: check dependencies\n      if (!this.areDependenciesMet(task)) return false;\n      return true;\n    });\n\n    if (eligible.length === 0) {\n      return null;\n    }\n\n    // Phase 3: sort by priority (ascending, 1 = highest), then by availability time, then FIFO\n    eligible.sort((aId, bId) => {\n      const a = this.tasks.get(aId)!;\n      const b = this.tasks.get(bId)!;\n\n      // Priority first (lower number = higher priority)\n      if (a.priority !== b.priority) {\n        return a.priority - b.priority;\n      }\n\n      // Phase 4: availability time\n      const aTime = a.availableAt.getTime();\n      const bTime = b.availableAt.getTime();\n      if (aTime !== bTime) {\n        return aTime - bTime;\n      }\n\n      // FIFO by insertion order\n      const aOrder = this.taskInsertionOrder.get(aId) ?? 0;\n      const bOrder = this.taskInsertionOrder.get(bId) ?? 0;\n      return aOrder - bOrder;\n    });\n\n    const selectedId = eligible[0];\n    const task = this.tasks.get(selectedId)!;\n    task.status = 'processing';\n    task.attempts += 1;\n\n    return task;\n  }\n\n  // Phase 1: Get pending task count\n  getPendingCount(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const taskIds = this.queues.get(queue);\n    if (!taskIds) return 0;\n    return taskIds.filter(id => {\n      const task = this.tasks.get(id);\n      return task && task.status === 'pending';\n    }).length;\n  }\n\n  // Phase 2: List all queue names\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // Phase 5: Complete a task\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Remove from queue list\n    this.removeFromQueueList(task.queue, taskId);\n\n    // Phase 7: check if any dependent tasks are now unblocked\n    // (this happens naturally when getNextTask checks dependencies)\n  }\n\n  // Phase 5: Fail a task\n  failTask(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);\n    }\n\n    task.lastError = error;\n    task.failureCount += 1;\n\n    // Check if task was cancelled (Phase 9) - never retry cancelled tasks\n    if (task.status === 'cancelled') {\n      return;\n    }\n\n    // Phase 5: retry with backoff\n    if (task.attempts < task.maxRetries) {\n      // Re-queue with backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n      delete task.progressMessage;\n      // Task stays in the queue list\n    } else {\n      // Retries exhausted\n      ta