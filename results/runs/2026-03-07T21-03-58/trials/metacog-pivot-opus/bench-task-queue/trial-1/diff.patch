+  AddTaskOptions,
+  Schedule,
+  MiddlewareFn,
+  HandlerFn,
+  ProgressListener,
+  ShutdownResult,
+} from './types.js';
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..e379c80
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,50 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  createdAt: Date;
+  queue: string;
+  priority: number;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  lastError?: string;
+  failureCount: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+  delayMs?: number;
+  scheduledTime?: Date;
+}
+
+export interface AddTaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: Omit<AddTaskOptions, 'queue' | 'delay' | 'availableAt' | 'dependencies'>;
+  lastRun?: Date;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFn = (task: Task) => Promise<void>;
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
