ter', { availableAt: new Date(now - 100) });\n   194→      tq.addTask('sooner', { availableAt: new Date(now - 200) });\n   195→\n   196→      expect(tq.getNextTask()?.payload).toBe('sooner');\n   197→      expect(tq.getNextTask()?.payload).toBe('later');\n   198→    });\n   199→\n   200→    it('should indicate availability time on task object', () => {\n   201→      const futureTime = new Date(Date.now() + 5000);\n   202→      const task = tq.addTask('delayed', { availableAt: futureTime });\n   203→      expect(task.availableAt.getTime()).toBe(futureTime.getTime());\n   204→    });\n   205→\n   206→    it('should handle delay in milliseconds', () => {\n   207→      const before = Date.now();\n   208→      const task = tq.addTask('delayed', { delay: 5000 });\n   209→      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(before + 5000);\n   210→    });\n   211→\n   212→    it('should work with named queues', () => {\n   213→      tq.addTask('delayed', { queue: 'q1', delay: 100000 });\n   214→      tq.addTask('immediate', { queue: 'q1' });\n   215→\n   216→      expect(tq.getNextTask('q1')?.payload).toBe('immediate');\n   217→    });\n   218→  });\n   219→\n   220→  // ===== Phase 5: Retry with Backoff =====\n   221→  describe('Phase 5: Retry with Backoff', () => {\n   222→    it('should complete a processing task', () => {\n   223→      const task = tq.addTask('task');\n   224→      const retrieved = tq.getNextTask()!;\n   225→      tq.completeTask(retrieved.id);\n   226→      expect(tq.getTask(retrieved.id)?.status).toBe('completed');\n   227→    });\n   228→\n   229→    it('should fail and retry a task with backoff', () => {\n   230→      const task = tq.addTask('task', { maxRetries: 3, backoffDelay: 1000 });\n   231→      const t1 = tq.getNextTask()!;\n   232→      expect(t1.attempts).toBe(1);\n   233→\n   234→      tq.failTask(t1.id, 'error1');\n   235→      // Task should be re-queued with delay\n   236→      const taskState = tq.getTask(t1.id)!;\n   237→      expect(taskState.status).toBe('pending');\n   238→      expect(taskState.failureCount).toBe(1);\n   239→      // Not available immediately due to backoff\n   240→      expect(tq.getNextTask()).toBeNull();\n   241→    });\n   242→\n   243→    it('should use exponential backoff', () => {\n   244→      const task = tq.addTask('task', { maxRetries: 3, backoffDelay: 1000 });\n   245→\n   246→      // Attempt 1\n   247→      const t1 = tq.getNextTask()!;\n   248→      const beforeFail = Date.now();\n   249→      tq.failTask(t1.id, 'err');\n   250→      const afterFail = tq.getTask(t1.id)!;\n   251→      // backoff = 1000 * 2^(1-1) = 1000ms\n   252→      expect(afterFail.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 1000);\n   253→    });\n   254→\n   255→    it('should track attempt count', () => {\n   256→      const task = tq.addTask('task', { maxRetries: 3, backoffDelay: 0 });\n   257→      const t1 = tq.getNextTask()!;\n   258→      expect(t1.attempts).toBe(1);\n   259→    });\n   260→\n   261→    it('should exhaust retries and leave task failed', () => {\n   262→      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n   263→\n   264→      // First and only attempt\n   265→      const t1 = tq.getNextTask()!;\n   266→      expect(t1.attempts).toBe(1);\n   267→      tq.failTask(t1.id, 'final error');\n   268→\n   269→      const finalState = tq.getTask(t1.id)!;\n   270→      expect(finalState.status).toBe('failed');\n   271→    });\n   272→\n   273→    it('should keep original queue and priority on retry', () => {\n   274→      const task = tq.addTask('task', { queue: 'q1', priority: 2, maxRetries: 3, backoffDelay: 0 });\n   275→      const t1 = tq.getNextTask('q1')!;\n   276→      tq.failTask(t1.id, 'err');\n   277→\n   278→      const retried = tq.getTask(t1.id)!;\n   279→      expect(retried.queue).toBe('q1');\n   280→      expect(retried.priority).toBe(2);\n   281→    });\n   282→\n   283→    it('should default maxRetries to 3', () => {\n   284→      const task = tq.addTask('task');\n   285→      expect(task.maxRetries).toBe(3);\n   286→    });\n   287→\n   288→    it('should default backoffDelay to 1000', () => {\n   289→      const task = tq.addTask('task');\n   290→      expect(task.backoffDelay).toBe(1000);\n   291→    });\n   292→\n   293→    it('should throw when completing non-processing task', () => {\n   294→      const task = tq.addTask('task');\n   295→      expect(() => tq.completeTask(task.id)).toThrow();\n   296→    });\n   297→\n   298→    it('should throw when failing non-processing task', () => {\n   299→      const task = tq.addTask('task');\n   300→      expect(() => tq.failTask(task.id)).toThrow();\n   301→    });\n   302→  });\n   303→\n   304→  // ===== Phase 6: Dead Letter Queue =====\n   305→  describe('Phase 6: Dead Letter Queue', () => {\n   306→    it('should move exhausted-retry tasks to DLQ', () => {\n   307→      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n   308→      const t1 = tq.getNextTask()!;\n   309→      tq.failTask(t1.id, 'fatal');\n   310→\n   311→      const dlqTasks = tq.getDeadLetterTasks();\n   312→      expect(dlqTasks).toHaveLength(1);\n   313→      expect(dlqTasks[0].id).toBe(task.id);\n   314→      expect(dlqTasks[0].lastError).toBe('fatal');\n   315→    });\n   316→\n   317→    it('should retain error info and failure count', () => {\n   318→      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n   319→      const t1 = tq.getNextTask()!;\n   320→      tq.failTask(t1.id, 'error message');\n   321→\n   322→      const dlqTasks = tq.getDeadLetterTasks();\n   323→      expect(dlqTasks[0].lastError).toBe('error message');\n   324→      expect(dlqTasks[0].failureCount).toBe(1);\n   325→    });\n   326→\n   327→    it('should retry dead-lettered tasks', () => {\n   328→      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n   329→      const t1 = tq.getNextTask()!;\n   330→      tq.failTask(t1.id, 'err');\n   331→\n   332→      const retried = tq.retryDeadLetterTask(t1.id);\n   333→      expect(retried.status).toBe('pending');\n   334→      expect(retried.attempts).toBe(0);\n   335→      expect(retried.failureCount).toBe(0);\n   336→\n   337→      // Should be retrievable again\n   338→      const t2 = tq.getNextTask()!;\n   339→      expect(t2.id).toBe(task.id);\n   340→\n   341→      // DLQ should be empty\n   342→      expect(tq.getDeadLetterTasks()).toHaveLength(0);\n   343→    });\n   344→\n   345→    it('should clear DLQ for a queue', () => {\n   346→      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n   347→      const t1 = tq.getNextTask()!;\n   348→      tq.failTask(t1.id, 'err');\n   349→\n   350→      expect(tq.getDeadLetterTasks()).toHaveLength(1);\n   351→      tq.clearDeadLetterQueue();\n   352→      expect(tq.getDeadLetterTasks()).toHaveLength(0);\n   353→    });\n   354→\n   355→    it('should have independent DLQs per queue', () => {\n   356→      const t1 = tq.addTask('task1', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n   357→      const t2 = tq.addTask('task2', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n   358→\n   359→      tq.failTask(tq.getNextTask('q1')!.id, 'err');\n   360→      tq.failTask(tq.getNextTask('q2')!.id, 'err');\n   361→\n   362→      expect(tq.getDeadLetterTasks('q1')).toHaveLength(1);\n   363→      expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n   364→\n   365→      tq.clearDeadLetterQueue('q1');\n   366→      expect(tq.getDeadLetterTasks('q1')).toHaveLength(0);\n   367→      expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n   368→    });\n   369→  });\n   370→\n   371→  // ===== Phase 7: Task Dependencies =====\n   372→  describe('Phase 7: Task Dependencies', () => {\n   373→    it('should block tasks with unresolved dependencies', () => {\n   374→      const dep = tq.addTask('dependency');\n   375→      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n   376→\n   377→      // Should get the dependency first (not the dependent)\n   378→      const next = tq.getNextTask();\n   379→      expect(next?.id).toBe(dep.id);\n   380→\n   381→      // Dependent should not be available\n   382→      expect(tq.getNextTask()).toBeNull();\n   383→    });\n   384→\n   385→    it('should unblock tasks when dependencies complete', () => {\n   386→      const dep = tq.addTask('dependency');\n   387→      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n   388→\n   389→      const task = tq.getNextTask()!;\n   390→      tq.completeTask(task.id);\n   391→\n   392→      // Now dependent should be available\n   393→      const next = tq.getNextTask();\n   394→      expect(next?.id).toBe(dependent.id);\n   395→    });\n   396→\n   397→    it('should reject circular dependencies', () => {\n   398→      const t1 = tq.addTask('t1');\n   399→      const t2 = tq.addTask('t2', { dependencies: [t1.id] });\n   400→      expect(() => tq.addTask('t3', { dependencies: [t2.id, t1.id] })).not.toThrow();\n   401→    });\n   402→\n   403→    it('should reject non-existent dependencies', () => {\n   404→      expect(() => tq.addTask('task', { dependencies: ['nonexistent-id'] })).toThrow();\n   405→    });\n   406→\n   407→    it('should keep dependents blocked when dependency fails', () => {\n   408→      const dep = tq.addTask('dependency', { maxRetries: 1, backoffDelay: 0 });\n   409→      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n   410→\n   411→      const task = tq.getNextTask()!;\n   412→      tq.failTask(task.id, 'err');\n   413→\n   414→      // Dependent stays blocked (failed dep doesn't unblock)\n   415→      expect(tq.getNextTask()).toBeNull();\n   416→    });\n   417→\n   418→    it('should inspect dependency status', () => {\n   419→      const dep1 = tq.addTask('dep1');\n   420→      const dep2 = tq.addTask('dep2');\n   421→      const dependent = tq.addTask('task', { dependencies: [dep1.id, dep2.id] });\n   422→\n   423→      const status = tq.getDependencyStatus(dependent.id);\n   424→      expect(status).toHaveLength(2);\n   425→      expect(status[0].status).toBe('pending');\n   426→      expect(status[1].status).toBe('pending');\n   427→\n   428→      // Complete one dependency\n   429→      tq.getNextTask();\n   430→      const processing = tq.getDependencyStatus(dependent.id);\n   431→      expect(processing.some(s => s.status === 'processing')).toBe(true);\n   432→    });\n   433→  });\n   434→\n   435→  // ===== Phase 8: Concurrency Control =====\n   436→  describe('Phase 8: Concurrency Control', () => {\n   437→    it('should limit concurrent processing tasks', () => {\n   438→      tq.setConcurrency('default', 2);\n   439→      tq.addTask('t1');\n   440→      tq.addTask('t2');\n   441→      tq.addTask('t3');\n   442→\n   443→      expect(tq.getNextTask()).not.toBeNull();\n   444→      expect(tq.getNextTask()).not.toBeNull();\n   445→      expect(tq.getNextTask()).toBeNull(); // limit reached\n   446→    });\n   447→\n   448→    it('should free slot on task completion', () => {\n   449→      tq.setConcurrency('default', 1);\n   450→      tq.addTask('t1');\n   451→      tq.addTask('t2');\n   452→\n   453→      const t1 = tq.getNextTask()!;\n   454→      expect(tq.getNextTask()).toBeNull();\n   455→\n   456→      tq.completeTask(t1.id);\n   457→      expect(tq.getNextTask()).not.toBeNull();\n   458→    });\n   459→\n   460→    it('should free slot on task failure', () => {\n   461→      tq.setConcurrency('default', 1);\n   462→      const task = tq.addTask('t1', { maxRetries: 1, backoffDelay: 0 });\n   463→      tq.addTask('t2');\n   464→\n   465→      const t1 = tq.getNextTask()!;\n   466→      expect(tq.getNextTask()).toBeNull();\n   467→\n   468→      tq.failTask(t1.id, 'err'); // Exhausted, goes to DLQ\n   469→\n   470→      expect(tq.getNextTask()).not.toBeNull();\n   471→    });\n   472→\n   473→    it('should default to unlimited concurrency', () => {\n   474→      for (let i = 0; i < 100; i++) {\n   475→        tq.addTask(`task-${i}`);\n   476→      }\n   477→      for (let i = 0; i < 100; i++) {\n   478→        expect(tq.getNextTask()).not.toBeNull();\n   479→      }\n   480→    });\n   481→\n   482→    it('should query concurrency limit and active count', () => {\n   483→      tq.setConcurrency('default', 5);\n   484→      expect(tq.getConcurrencyLimit('default')).toBe(5);\n   485→      expect(tq.getActiveCount('default')).toBe(0);\n   486→\n   487→      tq.addTask('task');\n   488→      tq.getNextTask();\n   489→      expect(tq.getActiveCount('default')).toBe(1);\n   490→    });\n   491→\n   492→    it('should still respect priority ordering with concurrency', () => {\n   493→      tq.setConcurrency('default', 1);\n   494→      tq.addTask('low', { priority: 10 });\n   495→      tq.addTask('high', { priority: 1 });\n   496→\n   497→      const task = tq.getNextTask()!;\n   498→      expect(task.payload).toBe('high');\n   499→    });\n   500→  });\n   501→\n   502→  // ===== Phase 9: Progress and Cancellation =====\n   503→  describe('Phase 9: Progress and Cancellation', () => {\n   504→    it('should report and query progress', () => {\n   505→      tq.addTask('task');\n   506→      const task = tq.getNextTask()!;\n   507→\n   508→      tq.reportProgress(task.id, 50, 'halfway');\n   509→      const progress = tq.getProgress(task.id);\n   510→      expect(progress.progress).toBe(50);\n   511→      expect(progress.message).toBe('halfway');\n   512→    });\n   513→\n   514→    it('should reject invalid progress values', () => {\n   515→      tq.addTask('task');\n   516→      const task = tq.getNextTask()!;\n   517→\n   518→      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n   519→      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n   520→    });\n   521→\n   522→    it('should notify progress listeners', () => {\n   523→      tq.addTask('task');\n   524→      const task = tq.getNextTask()!;\n   525→\n   526→      const updates: { progress: number; message?: string }[] = [];\n   527→      tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n   528→\n   529→      tq.reportProgress(task.id, 25, 'quarter');\n   530→      tq.reportProgress(task.id, 75, 'three quarters');\n   531→\n   532→      expect(updates).toHaveLength(2);\n   533→      expect(updates[0].progress).toBe(25);\n   534→      expect(updates[1].progress).toBe(75);\n   535→    });\n   536→\n   537→    it('should support unsubscribe', () => {\n   538→      tq.addTask('task');\n   539→      const task = tq.getNextTask()!;\n   540→\n   541→      let callCount = 0;\n   542→      const unsubscribe = tq.onProgress(task.id, () => callCount++);\n   543→\n   544→      tq.reportProgress(task.id, 50);\n   545→      unsubscribe();\n   546→      tq.reportProgress(task.id, 100);\n   547→\n   548→      expect(callCount).toBe(1);\n   549→    });\n   550→\n   551→    it('should cancel pending tasks', () => {\n   552→      const task = tq.addTask('task');\n   553→      tq.cancelTask(task.id);\n   554→\n   555→      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n   556→      expect(tq.getNextTask()).toBeNull();\n   557→      expect(tq.getPendingCount()).toBe(0);\n   558→    });\n   559→\n   560→    it('should cancel processing tasks', () => {\n   561→      tq.addTask('task');\n   562→      const task = tq.getNextTask()!;\n   563→      tq.cancelTask(task.id);\n   564→\n   565→      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n   566→    });\n   567→\n   568→    it('should not retry cancelled tasks', () => {\n   569→      const task = tq.addTask('task', { maxRetries: 3 });\n   570→      const t = tq.getNextTask()!;\n   571→      tq.cancelTask(t.id);\n   572→\n   573→      // Should not be available even though retries remain\n   574→      expect(tq.getNextTask()).toBeNull();\n   575→    });\n   576→\n   577→    it('should throw when cancelling completed task', () => {\n   578→      tq.addTask('task');\n   579→      const task = tq.getNextTask()!;\n   580→      tq.completeTask(task.id);\n   581→      expect(() => tq.cancelTask(task.id)).toThrow();\n   582→    });\n   583→  });\n   584→\n   585→  // ===== Phase 10: Recurring Tasks =====\n   586→  describe('Phase 10: Recurring Tasks', () => {\n   587→    it('should create a schedule', () => {\n   588→      const schedule = tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'cleanup' });\n   589→      expect(schedule.id).toBe('s1');\n   590→      expect(schedule.cronExpression).toBe('*/5 * * * *');\n   591→    });\n   592→\n   593→    it('should list active schedules', () => {\n   594→      tq.addSchedule('s1', '*/5 * * * *', 'default', 'payload1');\n   595→      tq.addSchedule('s2', '0 * * * *', 'default', 'payload2');\n   596→\n   597→      const schedules = tq.getSchedules();\n   598→      expect(schedules).toHaveLength(2);\n   599→    });\n   600→\n   601→    it('should remove a schedule', () => {\n   602→      tq.addSchedule('s1', '*/5 * * * *', 'default', 'payload');\n   603→      tq.removeSchedule('s1');\n   604→      expect(tq.getSchedules()).toHaveLength(0);\n   605→    });\n   606→\n   607→    it('should throw when removing non-existent schedule', () => {\n   608→      expect(() => tq.removeSchedule('nonexistent')).toThrow();\n   609→    });\n   610→\n   611→    it('should enqueue tasks on tick for due schedules', () => {\n   612→      tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'recurring' });\n   613→\n   614→      // Tick at a time divisible by 5 minutes\n   615→      const tickTime = new Date(2024, 0, 1, 12, 0, 0); // 12:00\n   616→      const tasks = tq.tick(tickTime);\n   617→      expect(tasks).toHaveLength(1);\n   618→      expect(tasks[0].payload).toEqual({ type: 'recurring' });\n   619→    });\n   620→\n   621→    it('should not enqueue tasks when not due', () => {\n   622→      tq.addSchedule('s1', '0 * * * *', 'default', 'payload');\n   623→\n   624→      // Tick at 12:30 - not on the hour\n   625→      const tickTime = new Date(2024, 0, 1, 12, 30, 0);\n   626→      const tasks = tq.tick(tickTime);\n   627→      expect(tasks).toHaveLength(0);\n   628→    });\n   629→\n   630→    it('should not double-enqueue for same time slot', () => {\n   631→      tq.addSchedule('s1', '*/5 * * * *', 'default', 'payload');\n   632→\n   633→      const tickTime = new Date(2024, 0, 1, 12, 0, 0);\n   634→      tq.tick(tickTime);\n   635→      const tasks2 = tq.tick(tickTime);\n   636→      expect(tasks2).toHaveLength(0);\n   637→    });\n   638→\n   639→    it('should stop creating tasks after schedule removal', () => {\n   640→      tq.addSchedule('s1', '*/5 * * * *', 'default', 'payload');\n   641→      tq.tick(new Date(2024, 0, 1, 12, 0, 0));\n   642→      tq.removeSchedule('s1');\n   643→      const tasks = tq.tick(new Date(2024, 0, 1, 12, 5, 0));\n   644→      expect(tasks).toHaveLength(0);\n   645→    });\n   646→\n   647→    it('should validate cron expressions', () => {\n   648→      expect(() => tq.addSchedule('s', 'invalid', 'default', 'p')).toThrow();\n   649→      expect(() => tq.addSchedule('s', '* *', 'default', 'p')).toThrow();\n   650→    });\n   651→\n   652→    it('should handle every day at midnight', () => {\n   653→      tq.addSchedule('s1', '0 0 * * *', 'default', 'midnight');\n   654→\n   655→      const midnight = new Date(2024, 0, 1, 0, 0, 0);\n   656→      expect(tq.tick(midnight)).toHaveLength(1);\n   657→\n   658→      const noon = new Date(2024, 0, 1, 12, 0, 0);\n   659→      expect(tq.tick(noon)).toHaveLength(0);\n   660→    });\n   661→  });\n   662→\n   663→  // ===== Phase 11: Middleware =====\n   664→  describe('Phase 11: Middleware Pipeline', () => {\n   665→    it('should pass tasks through middleware', async () => {\n   666→      const order: string[] = [];\n   667→\n   668→      tq.use('default', async (_task, next) => {\n   669→        order.push('middleware1');\n   670→        await next();\n   671→      });\n   672→      tq.use('default', async (_task, next) => {\n   673→        order.push('middleware2');\n   674→        await next();\n   675→      });\n   676→      tq.setHandler('default', async () => {\n   677→        order.push('handler');\n   678→      });\n   679→\n   680→      tq.addTask('task');\n   681→      const task = tq.getNextTask()!;\n   682→      await tq.processTask(task.id);\n   683→\n   684→      expect(order).toEqual(['middleware1', 'middleware2', 'handler']);\n   685→    });\n   686→\n   687→    it('should skip processing if middleware does not call next', async () => {\n   688→      let handlerCalled = false;\n   689→\n   690→      tq.use('default', async () => {\n   691→        // intentionally not calling next\n   692→      });\n   693→      tq.setHandler('default', async () => {\n   694→        handlerCalled = true;\n   695→      });\n   696→\n   697→      tq.addTask('task');\n   698→      const task = tq.getNextTask()!;\n   699→      await tq.processTask(task.id);\n   700→\n   701→      expect(handlerCalled).toBe(false);\n   702→    });\n   703→\n   704→    it('should allow middleware to modify task', async () => {\n   705→      tq.use('default', async (task, next) => {\n   706→        (task.payload as Record<string, unknown>).modified = true;\n   707→        await next();\n   708→      });\n   709→\n   710→      let receivedPayload: unknown;\n   711→      tq.setHandler('default', async (task) => {\n   712→        receivedPayload = task.payload;\n   713→      });\n   714→\n   715→      tq.addTask({ original: true });\n   716→      const task = tq.getNextTask()!;\n   717→      await tq.processTask(task.id);\n   718→\n   719→      expect(receivedPayload).toEqual({ original: true, modified: true });\n   720→    });\n   721→\n   722→    it('should mark task as failed if middleware throws', async () => {\n   723→      tq.use('default', async () => {\n   724→        throw new Error('middleware error');\n   725→      });\n   726→\n   727→      const added = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n   728→      const task = tq.getNextTask()!;\n   729→      await tq.processTask(task.id);\n   730→\n   731→      const state = tq.getTask(task.id)!;\n   732→      // After 1 attempt with maxRetries=1, task should be failed\n   733→      expect(state.status).toBe('failed');\n   734→      expect(state.lastError).toBe('middleware error');\n   735→    });\n   736→\n   737→    it('should have independent middleware stacks per queue', async () => {\n   738→      const q1Order: string[] = [];\n   739→      const q2Order: string[] = [];\n   740→\n   741→      tq.use('q1', async (_task, next) => {\n   742→        q1Order.push('q1-mw');\n   743→        await next();\n   744→      });\n   745→      tq.use('q2', async (_task, next) => {\n   746→        q2Order.push('q2-mw');\n   747→        await next();\n   748→      });\n   749→      tq.setHandler('q1', async () => { q1Order.push('q1-handler'); });\n   750→      tq.setHandler('q2', async () => { q2Order.push('q2-handler'); });\n   751→\n   752→      tq.addTask('t1', { queue: 'q1' });\n   753→      tq.addTask('t2', { queue: 'q2' });\n   754→\n   755→      const t1 = tq.getNextTask('q1')!;\n   756→      const t2 = tq.getNextTask('q2')!;\n   757→\n   758→      await tq.processTask(t1.id);\n   759→      await tq.processTask(t2.id);\n   760→\n   761→      expect(q1Order).toEqual(['q1-mw', 'q1-handler']);\n   762→      expect(q2Order).toEqual(['q2-mw', 'q2-handler']);\n   763→    });\n   764→  });\n   765→\n   766→  // ===== Phase 12: Graceful Shutdown =====\n   767→  describe('Phase 12: Graceful Shutdown', () => {\n   768→    it('should reject new tasks after shutdown', async () => {\n   769→      await tq.shutdown();\n   770→      expect(() => tq.addTask('task')).toThrow(/shutting down/);\n   771→    });\n   772→\n   773→    it('should complete immediately when no tasks are processing', async () => {\n   774→      const result = await tq.shutdown();\n   775→      expect(result.completed).toBe(0);\n   776→      expect(result.forceCancelled).toBe(0);\n   777→      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n   778→    });\n   779→\n   780→    it('should wait for processing tasks', async () => {\n   781→      tq.addTask('task');\n   782→      const task = tq.getNextTask()!;\n   783→\n   784→      // Complete task asynchronously\n   785→      setTimeout(() => tq.completeTask(task.id), 50);\n   786→\n   787→      const result = await tq.shutdown(5000);\n   788→      expect(result.completed).toBe(1);\n   789→      expect(result.forceCancelled).toBe(0);\n   790→    });\n   791→\n   792→    it('should force cancel tasks on timeout', async () => {\n   793→      tq.addTask('task');\n   794→      const task = tq.getNextTask()!;\n   795→      // Don't complete the task\n   796→\n   797→      const result = await tq.shutdown(50);\n   798→      expect(result.forceCancelled).toBe(1);\n   799→      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n   800→    });\n   801→\n   802→    it('should be safe to call shutdown multiple times', async () => {\n   803→      const r1 = tq.shutdown();\n   804→      const r2 = tq.shutdown();\n   805→      const [result1, result2] = await Promise.all([r1, r2]);\n   806→      expect(result1).toBe(result2);\n   807→    });\n   808→\n   809→    it('should run shutdown callbacks', async () => {\n   810→      let callbackRan = false;\n   811→      tq.onShutdown(() => { callbackRan = true; });\n   812→\n   813→      await tq.shutdown();\n   814→      expect(callbackRan).toBe(true);\n   815→    });\n   816→\n   817→    it('should report shutdown duration', async () => {\n   818→      const result = await tq.shutdown();\n   819→      expect(typeof result.durationMs).toBe('number');\n   820→      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n   821→    });\n   822→  });\n   823→});\n   824→"}]},"parent_tool_use_id":null,"session_id":"fedb1abd-b75b-4c9e-a669-33cc658aaf55","uuid":"16b70df8-879e-4001-b220-2e401a0b6607","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/TaskQueue.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueue } from './TaskQueue.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ===== Phase 1: Basic FIFO Queue =====\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = tq.addTask({ message: 'hello' });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign unique IDs to tasks', () => {\n      const t1 = tq.addTask('a');\n      const t2 = tq.addTask('b');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      tq.addTask('first');\n      tq.addTask('second');\n      tq.addTask('third');\n\n      const t1 = tq.getNextTask();\n      expect(t1?.payload).toBe('first');\n      expect(t1?.status).toBe('processing');\n\n      const t2 = tq.getNextTask();\n      expect(t2?.payload).toBe('second');\n\n      const t3 = tq.getNextTask();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should return null when all tasks are processing', () => {\n      tq.addTask('task');\n      tq.getNextTask();\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should track pending count', () => {\n      expect(tq.getPendingCount()).toBe(0);\n      tq.addTask('a');\n      tq.addTask('b');\n      expect(tq.getPendingCount()).toBe(2);\n      tq.getNextTask();\n      expect(tq.getPendingCount()).toBe(1);\n    });\n\n    it('should transition task to processing state on retrieval', () => {\n      const added = tq.addTask('task');\n      const retrieved = tq.getNextTask();\n      expect(retrieved?.id).toBe(added.id);\n      expect(retrieved?.status).toBe('processing');\n    });\n  });\n\n  // ===== Phase 2: Named Queues =====\n  describe('Phase 2: Named Queues', () => {\n    it('should add tasks to named queues', () => {\n      tq.addTask('email', { queue: 'emails' });\n      tq.addTask('sms', { queue: 'sms' });\n\n      expect(tq.getPendingCount('emails')).toBe(1);\n      expect(tq.getPendingCount('sms')).toBe(1);\n    });\n\n    it('should retrieve from specific queue only', () => {\n      tq.addTask('email-task', { queue: 'emails' });\n      tq.addTask('sms-task', { queue: 'sms' });\n\n      const task = tq.getNextTask('emails');\n      expect(task?.payload).toBe('email-task');\n      expect(tq.getNextTask('emails')).toBeNull();\n      expect(tq.getNextTask('sms')).not.toBeNull();\n    });\n\n    it('should use default queue when no name given', () => {\n      tq.addTask('default-task');\n      const task = tq.getNextTask();\n      expect(task?.payload).toBe('default-task');\n      expect(task?.queue).toBe('default');\n    });\n\n    it('should list all queue names', () => {\n      tq.addTask('a', { queue: 'q1' });\n      tq.addTask('b', { queue: 'q2' });\n      tq.addTask('c'); // default\n\n      const names = tq.getQueueNames();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n      expect(names).toContain('default');\n    });\n\n    it('should return null from non-existent queue', () => {\n      expect(tq.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should return null from empty queue', () => {\n      tq.addTask('task', { queue: 'q1' });\n      tq.getNextTask('q1');\n      expect(tq.getNextTask('q1')).toBeNull();\n    });\n  });\n\n  // ===== Phase 3: Priority =====\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = tq.addTask('default');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first', () => {\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n      tq.addTask('medium', { priority: 5 });\n\n      expect(tq.getNextTask()?.payload).toBe('high');\n      expect(tq.getNextTask()?.payload).toBe('medium');\n      expect(tq.getNextTask()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO for same priority', () => {\n      tq.addTask('first', { priority: 3 });\n      tq.addTask('second', { priority: 3 });\n      tq.addTask('third', { priority: 3 });\n\n      expect(tq.getNextTask()?.payload).toBe('first');\n      expect(tq.getNextTask()?.payload).toBe('second');\n      expect(tq.getNextTask()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => tq.addTask('x', { priority: 0 })).toThrow();\n      expect(() => tq.addTask('x', { priority: 11 })).toThrow();\n      expect(() => tq.addTask('x', { priority: 1.5 })).toThrow();\n      expect(() => tq.addTask('x', { priority: -1 })).toThrow();\n    });\n\n    it('should maintain priority per queue', () => {\n      tq.addTask('q1-low', { queue: 'q1', priority: 10 });\n      tq.addTask('q1-high', { queue: 'q1', priority: 1 });\n      tq.addTask('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(tq.getNextTask('q1')?.payload).toBe('q1-high');\n      expect(tq.getNextTask('q2')?.payload).toBe('q2-low');\n    });\n\n    it('should expose priority on task object', () => {\n      const task = tq.addTask('task', { priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n  });\n\n  // ===== Phase 4: Delayed Tasks =====\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their availability time', () => {\n      tq.addTask('delayed', { delay: 10000 });\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should return delayed tasks after their availability time', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.addTask('available', { availableAt: past });\n      const task = tq.getNextTask();\n      expect(task?.payload).toBe('available');\n    });\n\n    it('should prefer non-delayed tasks over unavailable delayed ones', () => {\n      tq.addTask('delayed', { delay: 100000 });\n      tq.addTask('immediate');\n\n      const task = tq.getNextTask();\n      expect(task?.payload).toBe('immediate');\n    });\n\n    it('should order available delayed tasks by availability time', () => {\n      const now = Date.now();\n      tq.addTask('later', { availableAt: new Date(now - 100) });\n      tq.addTask('sooner', { availableAt: new Date(now - 200) });\n\n      expect(tq.getNextTask()?.payload).toBe('sooner');\n      expect(tq.getNextTask()?.payload).toBe('later');\n    });\n\n    it('should indicate availability time on task object', () => {\n      const futureTime = new Date(Date.now() + 5000);\n      const task = tq.addTask('delayed', { availableAt: futureTime });\n      expect(task.availableAt.getTime()).toBe(futureTime.getTime());\n    });\n\n    it('should handle delay in milliseconds', () => {\n      const before = Date.now();\n      const task = tq.addTask('delayed', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(before + 5000);\n    });\n\n    it('should work with named queues', () => {\n      tq.addTask('delayed', { queue: 'q1', delay: 100000 });\n      tq.addTask('immediate', { queue: 'q1' });\n\n      expect(tq.getNextTask('q1')?.payload).toBe('immediate');\n    });\n  });\n\n  // ===== Phase 5: Retry with Backoff =====\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a processing task', () => {\n      const task = tq.addTask('task');\n      const retrieved = tq.getNextTask()!;\n      tq.completeTask(retrieved.id);\n      expect(tq.getTask(retrieved.id)?.status).toBe('completed');\n    });\n\n    it('should fail and retry a task with backoff', () => {\n      const task = tq.addTask('task', { maxRetries: 3, backoffDelay: 1000 });\n      const t1 = tq.getNextTask()!;\n      expect(t1.attempts).toBe(1);\n\n      tq.failTask(t1.id, 'error1');\n      // Task should be re-queued with delay\n      const taskState = tq.getTask(t1.id)!;\n      expect(taskState.status).toBe('pending');\n      expect(taskState.failureCount).toBe(1);\n      // Not available immediately due to backoff\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should use exponential backoff', () => {\n      const task = tq.addTask('task', { maxRetries: 3, backoffDelay: 1000 });\n\n      // Attempt 1\n      const t1 = tq.getNextTask()!;\n      const beforeFail = Date.now();\n      tq.failTask(t1.id, 'err');\n      const afterFail = tq.getTask(t1.id)!;\n      // backoff = 1000 * 2^(1-1) = 1000ms\n      expect(afterFail.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 1000);\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.addTask('task', { maxRetries: 3, backoffDelay: 0 });\n      const t1 = tq.getNextTask()!;\n      expect(t1.attempts).toBe(1);\n    });\n\n    it('should exhaust retries and leave task failed', () => {\n      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n\n      // First and only attempt\n      const t1 = tq.getNextTask()!;\n      expect(t1.attempts).toBe(1);\n      tq.failTask(t1.id, 'final error');\n\n      const finalState = tq.getTask(t1.id)!;\n      expect(finalState.status).toBe('failed');\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = tq.addTask('task', { queue: 'q1', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      const t1 = tq.getNextTask('q1')!;\n      tq.failTask(t1.id, 'err');\n\n      const retried = tq.getTask(t1.id)!;\n      expect(retried.queue).toBe('q1');\n      expect(retried.priority).toBe(2);\n    });\n\n    it('should default maxRetries to 3', () => {\n      const task = tq.addTask('task');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should default backoffDelay to 1000', () => {\n      const task = tq.addTask('task');\n      expect(task.backoffDelay).toBe(1000);\n    });\n\n    it('should throw when completing non-processing task', () => {\n      const task = tq.addTask('task');\n      expect(() => tq.completeTask(task.id)).toThrow();\n    });\n\n    it('should throw when failing non-processing task', () => {\n      const task = tq.addTask('task');\n      expect(() => tq.failTask(task.id)).toThrow();\n    });\n  });\n\n  // ===== Phase 6: Dead Letter Queue =====\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move exhausted-retry tasks to DLQ', () => {\n      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n      const t1 = tq.getNextTask()!;\n      tq.failTask(t1.id, 'fatal');\n\n      const dlqTasks = tq.getDeadLetterTasks();\n      expect(dlqTasks).toHaveLength(1);\n      expect(dlqTasks[0].id).toBe(task.id);\n      expect(dlqTasks[0].lastError).toBe('fatal');\n    });\n\n    it('should retain error info and failure count', () => {\n      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n      const t1 = tq.getNextTask()!;\n      tq.failTask(t1.id, 'error message');\n\n      const dlqTasks = tq.getDeadLetterTasks();\n      expect(dlqTasks[0].lastError).toBe('error message');\n      expect(dlqTasks[0].failureCount).toBe(1);\n    });\n\n    it('should retry dead-lettered tasks', () => {\n      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n      const t1 = tq.getNextTask()!;\n      tq.failTask(t1.id, 'err');\n\n      const retried = tq.retryDeadLetterTask(t1.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempts).toBe(0);\n      expect(retried.failureCount).toBe(0);\n\n      // Should be retrievable again\n      const t2 = tq.getNextTask()!;\n      expect(t2.id).toBe(task.id);\n\n      // DLQ should be empty\n      expect(tq.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should clear DLQ for a queue', () => {\n      const task = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n      const t1 = tq.getNextTask()!;\n      tq.failTask(t1.id, 'err');\n\n      expect(tq.getDeadLetterTasks()).toHaveLength(1);\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should have independent DLQs per queue', () => {\n      const t1 = tq.addTask('task1', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n      const t2 = tq.addTask('task2', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n\n      tq.failTask(tq.getNextTask('q1')!.id, 'err');\n      tq.failTask(tq.getNextTask('q2')!.id, 'err');\n\n      expect(tq.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n\n      tq.clearDeadLetterQueue('q1');\n      expect(tq.getDeadLetterTasks('q1')).toHaveLength(0);\n      expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n  });\n\n  // ===== Phase 7: Task Dependencies =====\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.addTask('dependency');\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      // Should get the dependency first (not the dependent)\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(dep.id);\n\n      // Dependent should not be available\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.addTask('dependency');\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n\n      // Now dependent should be available\n      const next = tq.getNextTask();\n      expect(next?.id).toBe(dependent.id);\n    });\n\n    it('should reject circular dependencies', () => {\n      const t1 = tq.addTask('t1');\n      const t2 = tq.addTask('t2', { dependencies: [t1.id] });\n      expect(() => tq.addTask('t3', { dependencies: [t2.id, t1.id] })).not.toThrow();\n    });\n\n    it('should reject non-existent dependencies', () => {\n      expect(() => tq.addTask('task', { dependencies: ['nonexistent-id'] })).toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = tq.addTask('dependency', { maxRetries: 1, backoffDelay: 0 });\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      const task = tq.getNextTask()!;\n      tq.failTask(task.id, 'err');\n\n      // Dependent stays blocked (failed dep doesn't unblock)\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = tq.addTask('dep1');\n      const dep2 = tq.addTask('dep2');\n      const dependent = tq.addTask('task', { dependencies: [dep1.id, dep2.id] });\n\n      const status = tq.getDependencyStatus(dependent.id);\n      expect(status).toHaveLength(2);\n      expect(status[0].status).toBe('pending');\n      expect(status[1].status).toBe('pending');\n\n      // Complete one dependency\n      tq.getNextTask();\n      const processing = tq.getDependencyStatus(dependent.id);\n      expect(processing.some(s => s.status === 'processing')).toBe(true);\n    });\n  });\n\n  // ===== Phase 8: Concurrency Control =====\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing tasks', () => {\n      tq.setConcurrency('default', 2);\n      tq.addTask('t1');\n      tq.addTask('t2');\n      tq.addTask('t3');\n\n      expect(tq.getNextTask()).not.toBeNull();\n      expect(tq.getNextTask()).not.toBeNull();\n      expect(tq.getNextTask()).toBeNull(); // limit reached\n    });\n\n    it('should free slot on task completion', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('t1');\n      tq.addTask('t2');\n\n      const t1 = tq.getNextTask()!;\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.completeTask(t1.id);\n      expect(tq.getNextTask()).not.toBeNull();\n    });\n\n    it('should free slot on task failure', () => {\n      tq.setConcurrency('default', 1);\n      const task = tq.addTask('t1', { maxRetries: 1, backoffDelay: 0 });\n      tq.addTask('t2');\n\n      const t1 = tq.getNextTask()!;\n      expect(tq.getNextTask()).toBeNull();\n\n      tq.failTask(t1.id, 'err'); // Exhausted, goes to DLQ\n\n      expect(tq.getNextTask()).not.toBeNull();\n    });\n\n    it('should default to unlimited concurrency', () => {\n      for (let i = 0; i < 100; i++) {\n        tq.addTask(`task-${i}`);\n      }\n      for (let i = 0; i < 100; i++) {\n        expect(tq.getNextTask()).not.toBeNull();\n      }\n    });\n\n    it('should query concurrency limit and active count', () => {\n      tq.setConcurrency('default', 5);\n      expect(tq.getConcurrencyLimit('default')).toBe(5);\n      expect(tq.getActiveCount('default')).toBe(0);\n\n      tq.addTask('task');\n      tq.getNextTask();\n      expect(tq.getActiveCount('default')).toBe(1);\n    });\n\n    it('should still respect priority ordering with concurrency', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n\n      const task = tq.getNextTask()!;\n      expect(task.payload).toBe('high');\n    });\n  });\n\n  // ===== Phase 9: Progress and Cancellation =====\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report and query progress', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n\n      tq.reportProgress(task.id, 50, 'halfway');\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should reject invalid progress values', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n\n      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('should notify progress listeners', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n\n      const updates: { progress: number; message?: string }[] = [];\n      tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      tq.reportProgress(task.id, 25, 'quarter');\n      tq.reportProgress(task.id, 75, 'three quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0].progress).toBe(25);\n      expect(updates[1].progress).toBe(75);\n    });\n\n    it('should support unsubscribe', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n\n      let callCount = 0;\n      const unsubscribe = tq.onProgress(task.id, () => callCount++);\n\n      tq.reportProgress(task.id, 50);\n      unsubscribe();\n      tq.reportProgress(task.id, 100);\n\n      expect(callCount).toBe(1);\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = tq.addTask('task');\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n      expect(tq.getPendingCount()).toBe(0);\n    });\n\n    it('should cancel processing tasks', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.addTask('task', { maxRetries: 3 });\n      const t = tq.getNextTask()!;\n      tq.cancelTask(t.id);\n\n      // Should not be available even though retries remain\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should throw when cancelling completed task', () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n      tq.completeTask(task.id);\n      expect(() => tq.cancelTask(task.id)).toThrow();\n    });\n  });\n\n  // ===== Phase 10: Recurring Tasks =====\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(schedule.id).toBe('s1');\n      expect(schedule.cronExpression).toBe('*/5 * * * *');\n    });\n\n    it('should list active schedules', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', 'payload1');\n      tq.addSchedule('s2', '0 * * * *', 'default', 'payload2');\n\n      const schedules = tq.getSchedules();\n      expect(schedules).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', 'payload');\n      tq.removeSchedule('s1');\n      expect(tq.getSchedules()).toHaveLength(0);\n    });\n\n    it('should throw when removing non-existent schedule', () => {\n      expect(() => tq.removeSchedule('nonexistent')).toThrow();\n    });\n\n    it('should enqueue tasks on tick for due schedules', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'recurring' });\n\n      // Tick at a time divisible by 5 minutes\n      const tickTime = new Date(2024, 0, 1, 12, 0, 0); // 12:00\n      const tasks = tq.tick(tickTime);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'recurring' });\n    });\n\n    it('should not enqueue tasks when not due', () => {\n      tq.addSchedule('s1', '0 * * * *', 'default', 'payload');\n\n      // Tick at 12:30 - not on the hour\n      const tickTime = new Date(2024, 0, 1, 12, 30, 0);\n      const tasks = tq.tick(tickTime);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not double-enqueue for same time slot', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', 'payload');\n\n      const tickTime = new Date(2024, 0, 1, 12, 0, 0);\n      tq.tick(tickTime);\n      const tasks2 = tq.tick(tickTime);\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', 'payload');\n      tq.tick(new Date(2024, 0, 1, 12, 0, 0));\n      tq.removeSchedule('s1');\n      const tasks = tq.tick(new Date(2024, 0, 1, 12, 5, 0));\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should validate cron expressions', () => {\n      expect(() => tq.addSchedule('s', 'invalid', 'default', 'p')).toThrow();\n      expect(() => tq.addSchedule('s', '* *', 'default', 'p')).toThrow();\n    });\n\n    it('should handle every day at midnight', () => {\n      tq.addSchedule('s1', '0 0 * * *', 'default', 'midnight');\n\n      const midnight = new Date(2024, 0, 1, 0, 0, 0);\n      expect(tq.tick(midnight)).toHaveLength(1);\n\n      const noon = new Date(2024, 0, 1, 12, 0, 0);\n      expect(tq.tick(noon)).toHaveLength(0);\n    });\n  });\n\n  // ===== Phase 11: Middleware =====\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should pass tasks through middleware', async () => {\n      const order: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push('middleware1');\n        await next();\n      });\n      tq.use('default', async (_task, next) => {\n        order.push('middleware2');\n        await next();\n      });\n      tq.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n      await tq.processTask(task.id);\n\n      expect(order).toEqual(['middleware1', 'middleware2', 'handler']);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      let handlerCalled = false;\n\n      tq.use('default', async () => {\n        // intentionally not calling next\n      });\n      tq.setHandler('default', async () => {\n        handlerCalled = true;\n      });\n\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n      await tq.processTask(task.id);\n\n      expect(handlerCalled).toBe(false);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      tq.use('default', async (task, next) => {\n        (task.payload as Record<string, unknown>).modified = true;\n        await next();\n      });\n\n      let receivedPayload: unknown;\n      tq.setHandler('default', async (task) => {\n        receivedPayload = task.payload;\n      });\n\n      tq.addTask({ original: true });\n      const task = tq.getNextTask()!;\n      await tq.processTask(task.id);\n\n      expect(receivedPayload).toEqual({ original: true, modified: true });\n    });\n\n    it('should mark task as failed if middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const added = tq.addTask('task', { maxRetries: 1, backoffDelay: 0 });\n      const task = tq.getNextTask()!;\n      await tq.processTask(task.id);\n\n      const state = tq.getTask(task.id)!;\n      // After 1 attempt with maxRetries=1, task should be failed\n      expect(state.status).toBe('failed');\n      expect(state.lastError).toBe('middleware error');\n    });\n\n    it('should have independent middleware stacks per queue', async () => {\n      const q1Order: string[] = [];\n      const q2Order: string[] = [];\n\n      tq.use('q1', async (_task, next) => {\n        q1Order.push('q1-mw');\n        await next();\n      });\n      tq.use('q2', async (_task, next) => {\n        q2Order.push('q2-mw');\n        await next();\n      });\n      tq.setHandler('q1', async () => { q1Order.push('q1-handler'); });\n      tq.setHandler('q2', async () => { q2Order.push('q2-handler'); });\n\n      tq.addTask('t1', { queue: 'q1' });\n      tq.addTask('t2', { queue: 'q2' });\n\n      const t1 = tq.getNextTask('q1')!;\n      const t2 = tq.getNextTask('q2')!;\n\n      await tq.processTask(t1.id);\n      await tq.processTask(t2.id);\n\n      expect(q1Order).toEqual(['q1-mw', 'q1-handler']);\n      expect(q2Order).toEqual(['q2-mw', 'q2-handler']);\n    });\n  });\n\n  // ===== Phase 12: Graceful Shutdown =====\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.addTask('task')).toThrow(/shutting down/);\n    });\n\n    it('should complete immediately when no tasks are processing', async () => {\n      const result = await tq.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks', async () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n\n      // Complete task asynchronously\n      setTimeout(() => tq.completeTask(task.id), 50);\n\n      const result = await tq.shutdown(5000);\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force cancel tasks on timeout', async () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n      // Don't complete the task\n\n      const result = await tq.shutdown(50);\n      expect(result.forceCancelled).toBe(1);\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should be safe to call shutdown multiple times', async () => {\n      const r1 = tq.shutdown();\n      const r2 = tq.shutdown();\n      const [result1, result2] = await Promise.all([r1, r2]);\n      expect(result1).toBe(result2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let callbackRan = false;\n      tq.onShutdown(() => { callbackRan = true; });\n\n      await tq.shutdown();\n      expect(callbackRan).toBe(true)