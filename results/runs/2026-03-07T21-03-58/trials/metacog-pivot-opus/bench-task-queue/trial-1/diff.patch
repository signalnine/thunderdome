ck day of month\n    if (parts[2] !== '*') {\n      if (now.getDate() !== parseInt(parts[2], 10)) return false;\n    }\n\n    // Check month\n    if (parts[3] !== '*') {\n      if ((now.getMonth() + 1) !== parseInt(parts[3], 10)) return false;\n    }\n\n    // Check day of week\n    if (parts[4] !== '*') {\n      if (now.getDay() !== parseInt(parts[4], 10)) return false;\n    }\n\n    // Check if we already ran for this time slot\n    if (schedule.lastRun) {\n      const lastMinute = schedule.lastRun.getMinutes();\n      const lastHour = schedule.lastRun.getHours();\n      const lastDate = schedule.lastRun.toDateString();\n      const nowDate = now.toDateString();\n\n      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n}\n","structuredPatch":[{"oldStart":594,"oldLines":6,"newStart":594,"newLines":16,"lines":["     }","   }"," ","+  private removeFromDLQ(queueName: string, taskId: string): void {","+    const dlq = this.deadLetterQueues.get(queueName);","+    if (dlq) {","+      const index = dlq.indexOf(taskId);","+      if (index !== -1) {","+        dlq.splice(index, 1);","+      }","+    }","+  }","+","   private moveToDeadLetterQueue(task: Task): void {","     // Remove from main queue","     this.removeFromQueueList(task.queue, task.id);"]}],"userModified":false,"replaceAll":false}}
