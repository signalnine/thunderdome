t with maxRetries=1, task should be failed\n      expect(state.status).toBe('failed');\n      expect(state.lastError).toBe('middleware error');\n    });\n\n    it('should have independent middleware stacks per queue', async () => {\n      const q1Order: string[] = [];\n      const q2Order: string[] = [];\n\n      tq.use('q1', async (_task, next) => {\n        q1Order.push('q1-mw');\n        await next();\n      });\n      tq.use('q2', async (_task, next) => {\n        q2Order.push('q2-mw');\n        await next();\n      });\n      tq.setHandler('q1', async () => { q1Order.push('q1-handler'); });\n      tq.setHandler('q2', async () => { q2Order.push('q2-handler'); });\n\n      tq.addTask('t1', { queue: 'q1' });\n      tq.addTask('t2', { queue: 'q2' });\n\n      const t1 = tq.getNextTask('q1')!;\n      const t2 = tq.getNextTask('q2')!;\n\n      await tq.processTask(t1.id);\n      await tq.processTask(t2.id);\n\n      expect(q1Order).toEqual(['q1-mw', 'q1-handler']);\n      expect(q2Order).toEqual(['q2-mw', 'q2-handler']);\n    });\n  });\n\n  // ===== Phase 12: Graceful Shutdown =====\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.addTask('task')).toThrow(/shutting down/);\n    });\n\n    it('should complete immediately when no tasks are processing', async () => {\n      const result = await tq.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks', async () => {\n      tq.addTask('task');\n      const task = tq.getNextTask()!;\n\n      // Complete task asynchronously\n      setTimeout(() => tq.completeTask(task.id), 50);\n\n      const result = await tq.shutdown(5000);\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force cancel t