+    const task: Task<T> = {
+      id: randomUUID(),
+      payload,
+      status: 'pending',
+      createdAt: now,
+      queue,
+      priority,
+      availableAt,
+      attempts: 0,
+      maxRetries: options?.maxRetries ?? 3,
+      backoffDelay: options?.backoffDelay ?? 1000,
+      failureCount: 0,
+      dependencies,
+      progress: 0,
