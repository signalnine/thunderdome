        { id: 'e1', name: 'Part 1', duration: 60 },\n        { id: 'e2', name: 'Part 2', duration: 60, prerequisites: ['e1'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const gap = a2.startTime - a1.endTime;\n      expect(gap).toBeGreaterThanOrEqual(15); // default gap\n    });\n\n    it('should handle chain of prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Step 1', duration: 30 },\n        { id: 'e2', name: 'Step 2', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Step 3', duration: 30, prerequisites: ['e2'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(3);\n\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const a3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime);\n      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime);\n    });\n\n    it('should handle multiple prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Prereq A', duration: 30 },\n        { id: 'e2', name: 'Prereq B', duration: 30 },\n        { id: 'e3', name: 'Main', duration: 30, prerequisites: ['e1', 'e2'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(3);\n\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const a3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(a3.startTime).toBeGreaterThanOrEqual(a1.endTime);\n      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime);\n    });\n\n    it('should not schedule event if prerequisite cannot be scheduled', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Big Prereq', duration: 60, attendees: 200 }, // too many attendees\n        { id: 'e2', name: 'Dependent', duration: 30, prerequisites: ['e1'] },\n      ];\n      const rooms: Room[] = [{ id: 'r1', name: 'Room', capacity: 50 }];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.unscheduled).toContain('e1');\n      expect(result.unscheduled).toContain('e2');\n    });\n  });\n\n  describe('prerequisite cycles', () => {\n    it('should throw error on self-referencing prerequisite', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Self Ref', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw error on direct cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'A', duration: 30, prerequisites: ['e2'] },\n        { id: 'e2', name: 'B', duration: 30, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw error on indirect cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'A', duration: 30, prerequisites: ['e3'] },\n        { id: 'e2', name: 'B', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'C', duration: 30, prerequisites: ['e2'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n  });\n\n  describe('preferred rooms', () => {\n    it('should honor preferred room when possible', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'room-b' },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n\n    it('should use non-preferred room when preferred is full', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 420, preferredRoom: 'room-a' }, // fills most of the day\n        { id: 'e2', name: 'Event 2', duration: 420, preferredRoom: 'room-a' }, // also wants room-a\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n      // At least one event should be in the non-preferred room\n      const roomIds = result.assignments.map(a => a.roomId);\n      expect(roomIds).toContain('room-b');\n    });\n\n    it('should ignore preferred room when capacity does not allow it', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Big Event', duration: 60, attendees: 40, preferredRoom: 'room-b' },\n      ];\n      // room-b has capacity 30, so this event can't fit\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-a');\n    });\n  });\n\n  describe('batch optimization', () => {\n    it('should maximize number of events scheduled', () => {\n      // Scenario: 1 room, 2-hour window, three 50-minute events\n      // With 15-min gaps: 50 + 15 + 50 = 115 minutes needed for 2 events (fits in 120)\n      // 50 + 15 + 50 + 15 + 50 = 180 minutes for 3 (doesn't fit)\n      const rooms: Room[] = [{ id: 'r1', name: 'Room', capacity: 50 }];\n      const options: ScheduleOptions = { startTime: 0, endTime: 120 };\n      const events: Event[] = [\n        { id: 'e1', name: 'A', duration: 50 },\n        { id: 'e2', name: 'B', duration: 50 },\n        { id: 'e3', name: 'C', duration: 50 },\n      ];\n      const result = schedule(events, rooms, options);\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(1);\n    });\n\n    it('should prefer scheduling more short events over fewer long ones', () => {\n      // 1 room, window = 120 min\n      // Option A: one 120-min event = 1 event\n      // Option B: two 50-min events with 15-min gap = 2 events\n      // Scheduler should prefer scheduling 2 events\n      const rooms: Room[] = [{ id: 'r1', name: 'Room', capacity: 50 }];\n      const options: ScheduleOptions = { startTime: 0, endTime: 120 };\n      const events: Event[] = [\n        { id: 'long', name: 'Long Event', duration: 120 },\n        { id: 'short1', name: 'Short 1', duration: 50 },\n        { id: 'short2', name: 'Short 2', duration: 50 },\n      ];\n      const result = schedule(events, rooms, options);\n      // Should schedule at least 2 events (the two short ones)\n      expect(result.assignments.length).toBeGreaterThanOrEqual(2);\n    });\n  });\n\n  describe('complex scenarios', () => {\n    it('should handle many events across multiple rooms', () => {\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room 1', capacity: 100 },\n        { id: 'r2', name: 'Room 2', capacity: 50 },\n        { id: 'r3', name: 'Room 3', capacity: 25 },\n      ];\n      const events: Event[] = Array.from({ length: 10 }, (_, i) => ({\n        id: `e${i + 1}`,\n        name: `Event ${i + 1}`,\n        duration: 45,\n        attendees: 10,\n      }));\n      const result = schedule(events, rooms, defaultOptions);\n      // With 3 rooms and 8-hour windows, should fit all 10 events\n      expect(result.assignments.length).toBe(10);\n    });\n\n    it('should handle events with different capacity requirements', () => {\n      const rooms: Room[] = [\n        { id: 'small', name: 'Small', capacity: 10 },\n        { id: 'large', name: 'Large', capacity: 100 },\n      ];\n      const events: Event[] = [\n        { id: 'e1', name: 'Small Meeting', duration: 60, attendees: 5 },\n        { id: 'e2', name: 'Big Conference', duration: 60, attendees: 80 },\n        { id: 'e3', name: 'Small 