 \"constrained\" an event is. Higher = more constrained = schedule first.\n */\nfunction constraintScore(event: Event, rooms: Room[]): number {\n  let score = 0;\n  const attendees = event.attendees ?? 1;\n\n  // Fewer rooms that can fit = more constrained\n  const fittingRooms = rooms.filter(r => r.capacity >= attendees).length;\n  score += (rooms.length - fittingRooms) * 100;\n\n  // Longer events are more constrained\n  score += event.duration;\n\n  // Events with preferred rooms are slightly more constrained\n  if (event.preferredRoom) score += 50;\n\n  return score;\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  const gap = options.gap ?? 15;\n  const { startTime: windowStart, endTime: windowEnd } = options;\n\n  // Handle empty inputs\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  if (rooms.length === 0) {\n    return { assignments: [], unscheduled: events.map(e => e.id) };\n  }\n\n  // Step 1: Topological sort (throws on cycles)\n  const topoOrder = topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Step 2: Build dependency graph info\n  // For each event, who depends on it (children)\n  const dependents = new Map<string, Set<string>>();\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereqId of e.prerequisites) {\n        if (!dependents.has(prereqId)) {\n          dependents.set(prereqId, new Set());\n        }\n        dependents.get(prereqId)!.add(e.id);\n      }\n    }\n  }\n\n  // Step 3: Use a greedy approach with multiple strategies and pick the best result\n  // Strategy: try different orderings and pick the one that schedules the most events\n\n  function greedySchedule(eventOrder: string[]): { assignments: Assignment[]; unscheduled: string[] } {\n    const assignments: Assignment[] = [];\n    const assignmentMap = new Map<string, Assignment>();\n    const unscheduled: string[] = [];\n\n    for (const eventId of eventOrder) {\n      const event = eventMap.get(eventId);\n      if (!event) continue;\n\n      // Check all prerequisites are assigned\n      if (!allPrereqsAssigned(event, assignmentMap)) {\n        unscheduled.push(eventId);\n        continue;\n      }\n\n      // Check event fits in time window at all\n      if (event.duration > windowEnd - windowStart) {\n        unscheduled.push(eventId);\n        continue;\n      }\n\n      const placements = findPlacements(event, rooms, assignments, assignmentMap, gap, windowEnd, windowStart);\n\n      if (placements.length > 0) {\n        const best = placements[0];\n        const assignment: Assignment = {\n          eventId: event.id,\n          roomId: best.roomId,\n          startTime: best.startTime,\n          endTime: best.startTime + event.duration,\n        };\n        assignments.push(assignment);\n        assignmentMap.set(event.id, assignment);\n      } else {\n        unscheduled.push(eventId);\n      }\n    }\n\n    return { assignments, unscheduled };\n  }\n\n  // Generate multiple orderings respecting topological order\n\n  // Ordering 1: topological order (dependencies first), then by constraint score\n  const order1 = [...topoOrder];\n\n  // Ordering 2: topological order but sorted by constraint score within each \"level\"\n  const order2 = buildLevelOrder(events, eventMap, topoOrder, rooms, false);\n\n  // Ordering 3: reverse constraint priority (least constrained first)\n  const order3 = buildLevelOrder(events, eventMap, topoOrder, rooms, true);\n\n  // Ordering 4: shortest duration first (within topological constraints)\n  const order4 = buildCustomOrder(events, eventMap, topoOrder, (a, b) => {\n    return a.duration - b.duration;\n  });\n\n  // Ordering 5: longest duration first (within topological constraints)\n  const order5 = buildCustomOrder(events, eventMap, topoOrder, (a, b) => {\n    return b.duration - a.duration;\n  });\n\n  const results = [\n    greedySchedule(order1),\n    greedySchedule(order2),\n    greedySchedule(order3),\n    greedySchedule(order4),\n    greedySchedule(order5),\n  ];\n\n  // Pick the result with the most events scheduled\n  let best = results[0];\n  for (let i = 1; i < results.length; i++) {\n    if (results[i].assignments.length > best.assignments.length) {\n      best = results[i];\n    }\n  }\n\n  return best;\n}\n\n/**\n * Build an ordering that respects topological order but sorts within levels\n * by constraint score.\n */\nfunction buildLevelOrder(\n  events: Event[],\n  eventMap: Map<string, Event>,\n  _topoOrder: string[],\n  rooms: Room[],\n  reverse: boolean\n): string[] {\n  // Compute in-degrees\n  const inDegree = new Map<string, number>();\n  const adjList = new Map<string, string[]>();\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n    adjList.set(e.id, []);\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereqId of e.prerequisites) {\n        if (eventMap.has(prereqId)) {\n          const count = inDegree.get(e.id) ?? 0;\n          inDegree.set(e.id, count + 1);\n          if (!adjList.has(prereqId)) {\n            adjList.set(prereqId, []);\n          }\n          adjList.get(prereqId)!.push(e.id);\n        }\n      }\n    }\n  }\n\n  const order: string[] = [];\n  const queue: string[] = [];\n\n  for (const e of events) {\n    if ((inDegree.get(e.id) ?? 0) === 0) {\n      queue.push(e.id);\n    }\n  }\n\n  while (queue.length > 0) {\n    // Sort current level by constraint score\n    queue.sort((a, b) => {\n      const scoreA = constraintScore(eventMap.get(a)!, rooms);\n      const scoreB = constraintScore(eventMap.get(b)!, rooms);\n      return reverse ? scoreA - scoreB : scoreB - scoreA;\n    });\n\n    // Process all items at current level\n    const currentLevel = [...queue];\n    queue.length = 0;\n\n    for (const id of currentLevel) {\n      order.push(id);\n      for (const depId of adjList.get(id) ?? []) {\n        const deg = (inDegree.get(depId) ?? 1) - 1;\n        inDegree.set(depId, deg);\n        if (deg === 0) {\n          queue.push(depId);\n        }\n      }\n    }\n  }\n\n  return order;\n}\n\n/**\n * Build a custom ordering that respects topological constraints\n * but sorts by a custom comparator within each level.\n */\nfunction buildCustomOrder(\n  events: Event[],\n  eventMap: Map<string, Event>,\n  _topoOrder: string[],\n  comparator: (a: Event, b: Event) => number\n): string[] {\n  const inDegree = new Map<string, number>();\n  const adjList = new Map<string, string[]>();\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n    adjList.set(e.id, []);\n  }\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereqId of e.prerequisites) {\n        if (eventMap.has(prereqId)) {\n          const count = inDegree.get(e.id) ?? 0;\n          inDegree.set(e.id, count + 1);\n          if (!adjList.has(prereqId)) {\n            adjList.set(prereqId, []);\n          }\n          adjList.get(prereqId)!.push(e.id);\n        }\n      }\n    }\n  }\n\n  const order: string[] = [];\n  const queue: string[] = [];\n\n  for (const e of events) {\n    if ((inDegree.get(e.id) ?? 0) === 0) {\n      queue.push(e.id);\n    }\n  }\n\n  while (queue.length > 0) {\n    queue.sort((a, b) => comparator(eventMap.get(a)!, eventMap.get(b)!));\n\n    const currentLevel = [...queue];\n    queue.length = 0;\n\n    for (const id of currentLevel) {\n      order.push(id);\n      for (const depId of adjList.get(id) ?? []) {\n        const deg = (inDegree.get(depId) ?? 1) - 1;\n        inDegree.set(depId, deg);\n        if (deg === 0) {\n          queue.push(depId);\n        }\n      }\n    }\n  }\n\n  return order;\n}\n","structuredPatch":[],"originalFile":null}}
