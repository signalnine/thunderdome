+import type { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+
+/**
+ * Detect cycles in the prerequisite graph using DFS.
+ * Throws an error if a cycle is found (including self-references).
+ * Returns a topological ordering of events.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Check for self-references explicitly
+  for (const e of events) {
+    if (e.prerequisites?.includes(e.id)) {
+      throw new Error(`Cycle detected: event "${e.id}" has a self-referencing prerequisite`);
+    }
+  }
+
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const e of events) {
+    color.set(e.id, WHITE);
+  }
+
+  const order: string[] = [];
+
+  function dfs(id: string): void {
+    color.set(id, GRAY);
+    const event = eventMap.get(id);
+    if (event?.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        const prereqColor = color.get(prereqId);
+        if (prereqColor === GRAY) {
+          throw new Error(`Cycle detected in prerequisites involving event "${prereqId}"`);
+        }
+        if (prereqColor === WHITE) {
+          dfs(prereqId);
+        }
+        // If prereqColor is undefined (prereq not in event list), skip - it's a dangling reference
+      }
+    }
+    color.set(id, BLACK);
+    order.push(id);
+  }
+
+  for (const e of events) {
+    if (color.get(e.id) === WHITE) {
+      dfs(e.id);
+    }
+  }
+
+  return order;
+}
+
+/**
+ * Find the earliest start time for an event given its prerequisites.
+ */
+function getEarliestStartAfterPrereqs(
+  event: Event,
+  assignments: Map<string, Assignment>,
+  gap: number,
+  windowStart: number
+): number {
+  let earliest = windowStart;
+  if (event.prerequisites) {
+    for (const prereqId of event.prerequisites) {
+      const prereqAssignment = assignments.get(prereqId);
+      if (prereqAssignment) {
+        earliest = Math.max(earliest, prereqAssignment.endTime + gap);
+      }
+      // If prerequisite is not yet assigned (unscheduled), this event can't be placed
+      // The caller handles this by checking all prereqs are assigned
+    }
+  }
+  return earliest;
+}
+
+/**
+ * Check whether all prerequisites for an event have been assigned.
+ */
+function allPrereqsAssigned(event: Event, assignments: Map<string, Assignment>): boolean {
+  if (!event.prerequisites) return true;
+  for (const prereqId of event.prerequisites) {
+    if (!assignments.has(prereqId)) return false;
+  }
+  return true;
+}
+
+/**
+ * Get available time slots in a room after a given start time.
+ * Returns sorted list of [slotStart, slotEnd] intervals.
+ */
+function getAvailableSlots(
+  roomId: string,
+  roomSchedule: Assignment[],
+  earliest: number,
+  windowEnd: number,
+  gap: number,
+  duration: number
+): number[] {
+  // Get events in this room, sorted by start time
+  const roomEvents = roomSchedule.filter(a => a.roomId === roomId).sort((a, b) => a.startTime - b.startTime);
+
+  const candidateStarts: number[] = [];
+
+  if (roomEvents.length === 0) {
+    // Room is empty, can start at earliest
+    if (earliest + duration <= windowEnd) {
+      candidateStarts.push(earliest);
+    }
+    return candidateStarts;
+  }
+
+  // Before first event
+  const firstEvent = roomEvents[0];
+  if (earliest + duration + gap <= firstEvent.startTime) {
+    candidateStarts.push(earliest);
+  }
+
+  // Between events
+  for (let i = 0; i < roomEvents.length - 1; i++) {
+    const gapStart = roomEvents[i].endTime + gap;
+    const gapEnd = roomEvents[i + 1].startTime - gap;
+    const slotStart = Math.max(earliest, gapStart);
+    if (slotStart + duration <= gapEnd + gap) {
+      // Check: slotStart + duration + gap <= roomEvents[i+1].startTime
+      if (slotStart + duration + gap <= roomEvents[i + 1].startTime) {
+        candidateStarts.push(slotStart);
+      }
+    }
+  }
+
+  // After last event
+  const lastEvent = roomEvents[roomEvents.length - 1];
+  const afterLast = Math.max(earliest, lastEvent.endTime + gap);
+  if (afterLast + duration <= windowEnd) {
+    candidateStarts.push(afterLast);
+  }
+
+  return candidateStarts;
+}
+
+/**
+ * Find all possible placements for an event (room + start time).
+ * Returns placements sorted: preferred room first, then earliest start time.
+ */
+function findPlacements(
+  event: Event,
+  rooms: Room[],
+  assignments: Assignment[],
+  assignmentMap: Map<string, Assignment>,
+  gap: number,
+  windowEnd: number,
+  windowStart: number
+): Array<{ roomId: string; startTime: number }> {
+  const attendees = event.attendees ?? 1;
+  const earliest = getEarliestStartAfterPrereqs(event, assignmentMap, gap, windowStart);
+
+  const placements: Array<{ roomId: string; startTime: number; preferred: boolean }> = [];
+
+  for (const room of rooms) {
+    if (room.capacity < attendees) continue;
+
+    const starts = getAvailableSlots(room.id, assignments, earliest, windowEnd, gap, event.duration);
+    for (const start of starts) {
+      placements.push({
+        roomId: room.id,
+        startTime: start,
+        preferred: event.preferredRoom === room.id,
+      });
+    }
+  }
+
+  // Sort: preferred room first, then earliest start
+  placements.sort((a, b) => {
+    if (a.preferred !== b.preferred) return a.preferred ? -1 : 1;
+    return a.startTime - b.startTime;
+  });
+
+  return placements.map(p => ({ roomId: p.roomId, startTime: p.startTime }));
+}
+
+/**
+ * Score how "constrained" an event is. Higher = more constrained = schedule first.
+ */
+function constraintScore(event: Event, rooms: Room[]): number {
+  let score = 0;
+  const attendees = event.attendees ?? 1;
+
+  // Fewer rooms that can fit = more constrained
+  const fittingRooms = rooms.filter(r => r.capacity >= attendees).length;
+  score += (rooms.length - fittingRooms) * 100;
+
+  // Longer events are more constrained
+  score += event.duration;
+
+  // Events with preferred rooms are slightly more constrained
+  if (event.preferredRoom) score += 50;
+
+  return score;
+}
+
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  const gap = options.gap ?? 15;
+  const { startTime: windowStart, endTime: windowEnd } = options;
+
+  // Handle empty inputs
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  if (rooms.length === 0) {
+    return { assignments: [], unscheduled: events.map(e => e.id) };
+  }
+
+  // Step 1: Topological sort (throws on cycles)
+  const topoOrder = topologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Step 2: Build dependency graph info
+  // For each event, who depends on it (children)
+  const dependents = new Map<string, Set<string>>();
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const prereqId of e.prerequisites) {
+        if (!dependents.has(prereqId)) {
+          dependents.set(prereqId, new Set());
+        }
+        dependents.get(prereqId)!.add(e.id);
+      }
+    }
+  }
+
+  // Step 3: Use a greedy approach with multiple strategies and pick the best result
+  // Strategy: try different orderings and pick the one that schedules the most events
+
+  function greedySchedule(eventOrder: string[]): { assignments: Assignment[]; unscheduled: string[] } {
+    const assignments: Assignment[] = [];
+    const assignmentMap = new Map<string, Assignment>();
+    const unscheduled: string[] = [];
+
+    for (const eventId of eventOrder) {
+      const event = eventMap.get(eventId);
+      if (!event) continue;
+
+      // Check all prerequisites are assigned
+      if (!allPrereqsAssigned(event, assignmentMap)) {
+        unscheduled.push(eventId);
+        continue;
+      }
+
+      // Check event fits in time window at all
+      if (event.duration > windowEnd - windowStart) {
+        unscheduled.push(eventId);
+        continue;
+      }
+
+      const placements = findPlacements(event, rooms, assignments, assignmentMap, gap, windowEnd, windowStart);
+
+      if (placements.length > 0) {
+        const best = placements[0];
+        const assignment: Assignment = {
+          eventId: event.id,
+          roomId: best.roomId,
+          startTime: best.startTime,
+          endTime: best.startTime + event.duration,
+        };
+        assignments.push(assignment);
+        assignmentMap.set(event.id, assignment);
+      } else {
+        unscheduled.push(eventId);
+      }
+    }
+
+    return { assignments, unscheduled };
+  }
+
+  // Generate multiple orderings respecting topological order
+
+  // Ordering 1: topological order (dependencies first), then by constraint score
+  const order1 = [...topoOrder];
+
+  // Ordering 2: topological order but sorted by constraint score within each "level"
+  const order2 = buildLevelOrder(events, eventMap, topoOrder, rooms, false);
+
+  // Ordering 3: reverse constraint priority (least constrained first)
+  const order3 = buildLevelOrder(events, eventMap, topoOrder, rooms, true);
+
+  // Ordering 4: shortest duration first (within topological constraints)
+  const order4 = buildCustomOrder(events, eventMap, topoOrder, (a, b) => {
+    return a.duration - b.duration;
+  });
+
+  // Ordering 5: longest duration first (within topological constraints)
+  const order5 = buildCustomOrder(events, eventMap, topoOrder, (a, b) => {
+    return b.duration - a.duration;
+  });
+
+  const results = [
+    greedySchedule(order1),
+    greedySchedule(order2),
+    greedySchedule(order3),
+    greedySchedule(order4),
+    greedySchedule(order5),
+  ];
+
+  // Pick the result with the most events scheduled
+  let best = results[0];
+  for (let i = 1; i < results.length; i++) {
+    if (results[i].assignments.length > best.assignments.length) {
+      best = results[i];
+    }
+  }
+
+  return best;
+}
+
+/**
+ * Build an ordering that respects topological order but sorts within levels
+ * by constraint score.
+ */
+function buildLevelOrder(
+  events: Event[],
+  eventMap: Map<string, Event>,
+  _topoOrder: string[],
+  rooms: Room[],
+  reverse: boolean
+): string[] {
+  // Compute in-degrees
+  const inDegree = new Map<string, number>();
+  const adjList = new Map<string, string[]>();
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    adjList.set(e.id, []);
+  }
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const prereqId of e.prerequisites) {
+        if (eventMap.has(prereqId)) {
+          const count = inDegree.get(e.id) ?? 0;
+          inDegree.set(e.id, count + 1);
+          if (!adjList.has(prereqId)) {
+            adjList.set(prereqId, []);
+          }
+          adjList.get(prereqId)!.push(e.id);
+        }
+      }
+    }
+  }
+
+  const order: string[] = [];
+  const queue: string[] = [];
+
+  for (const e of events) {
+    if ((inDegree.get(e.id) ?? 0) === 0) {
+      queue.push(e.id);
+    }
+  }
+
+  while (queue.length > 0) {
+    // Sort current level by constraint score
+    queue.sort((a, b) => {
+      const scoreA = constraintScore(eventMap.get(a)!, rooms);
+      const scoreB = constraintScore(eventMap.get(b)!, rooms);
+      return reverse ? scoreA - scoreB : scoreB - scoreA;
+    });
+
+    // Process all items at current level
+    const currentLevel = [...queue];
+    queue.length = 0;
+
+    for (const id of currentLevel) {
+      order.push(id);
+      for (const depId of adjList.get(id) ?? []) {
+        const deg = (inDegree.get(depId) ?? 1) - 1;
+        inDegree.set(depId, deg);
+        if (deg === 0) {
+          queue.push(depId);
+        }
+      }
+    }
+  }
+
+  return order;
+}
+
+/**
+ * Build a custom ordering that respects topological constraints
+ * but sorts by a custom comparator within each level.
+ */
+function buildCustomOrder(
+  events: Event[],
+  eventMap: Map<string, Event>,
+  _topoOrder: string[],
+  comparator: (a: Event, b: Event) => number
+): string[] {
+  const inDegree = new Map<string, number>();
+  const adjList = new Map<string, string[]>();
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    adjList.set(e.id, []);
+  }
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const prereqId of e.prerequisites) {
+        if (eventMap.has(prereqId)) {
+          const count = inDegree.get(e.id) ?? 0;
+          inDegree.set(e.id, count + 1);
+          if (!adjList.has(prereqId)) {
+            adjList.set(prereqId, []);
+          }
+          adjList.get(prereqId)!.push(e.id);
+        }
+      }
+    }
+  }
+
+  const order: string[] = [];
+  const queue: string[] = [];
+
+  for (const e of events) {
+    if ((inDegree.get(e.id) ?? 0) === 0) {
+      queue.push(e.id);
+    }
+  }
+
+  while (queue.length > 0) {
+    queue.sort((a, b) => comparator(eventMap.get(a)!, eventMap.get(b)!));
+
+    const currentLevel = [...queue];
+    queue.length = 0;
+
+    for (const id of currentLevel) {
+      order.push(id);
+      for (const depId of adjList.get(id) ?? []) {
+        const deg = (inDegree.get(depId) ?? 1) - 1;
+        inDegree.set(depId, deg);
+        if (deg === 0) {
+          queue.push(depId);
+        }
+      }
+    }
+  }
+
+  return order;
+}
