index 0000000..5d2801b
--- /dev/null
+++ b/src/scheduler.test.ts
@@ -0,0 +1,455 @@
+import { describe, it, expect } from 'vitest';
+import { schedule } from './scheduler.js';
+import type { Event, Room, ScheduleOptions } from './types.js';
+
+const defaultOptions: ScheduleOptions = {
+  startTime: 540, // 9:00 AM
+  endTime: 1020,  // 5:00 PM
+};
+
+const defaultRooms: Room[] = [
+  { id: 'room-a', name: 'Room A', capacity: 50 },
+  { id: 'room-b', name: 'Room B', capacity: 30 },
+];
+
+describe('schedule', () => {
+  describe('basic scheduling', () => {
+    it('should schedule a single event', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+      const result = schedule(events, defaultRooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+      expect(result.assignments[0].eventId).toBe('e1');
+      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);
+    });
+
+    it('should schedule multiple events', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+        { id: 'e2', name: 'Event 2', duration: 60 },
+        { id: 'e3', name: 'Event 3', duration: 60 },
+      ];
+      const result = schedule(events, defaultRooms, defaultOptions);
+      expect(result.assignments).toHaveLength(3);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should handle empty events list', () => {
+      const result = schedule([], defaultRooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should handle empty rooms list', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+      const result = schedule(events, [], defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['e1']);
+    });
+  });
+
+  describe('time window constraints', () => {
+    it('should schedule events within the time window', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 60 },
+      ];
+      const result = schedule(events, defaultRooms, defaultOptions);
+      const a = result.assignments[0];
+      expect(a.startTime).toBeGreaterThanOrEqual(defaultOptions.startTime);
+      expect(a.endTime).toBeLessThanOrEqual(defaultOptions.endTime);
+    });
+
+    it('should not schedule event that exceeds time window', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 600 }, // 10 hours, window is 8 hours
+      ];
+      const options: ScheduleOptions = {
+        startTime: 540,
+        endTime: 1020,
+      };
+      const result = schedule(events, defaultRooms, options);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toContain('e1');
+    });
+
+    it('should fit events tightly in narrow window', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Event 1', duration: 30 },
+        { id: 'e2', name: 'Event 2', duration: 30 },
+      ];
+      const rooms: Room[] = [{ id: 'r1', name: 'Room 1', capacity: 10 }];
+      // Window: 75 minutes, need 30 + 15 gap + 30 = 75
+      const options: ScheduleOptions = {
+        startTime: 0,
+        endTime: 75,
+      };
+      const result = schedule(events, rooms, options);
+      expect(result.assignments).toHaveLength(2);
+      expect(result.unscheduled).toHaveLength(0);
