roomId)!;\n\n        // Time window\n        expect(a.startTime).toBeGreaterThanOrEqual(options.startTime);\n        expect(a.endTime).toBeLessThanOrEqual(options.endTime);\n\n        // Duration\n        expect(a.endTime - a.startTime).toBe(event.duration);\n\n        // Capacity\n        expect(room.capacity).toBeGreaterThanOrEqual(event.attendees ?? 1);\n\n        // Prerequisites\n        if (event.prerequisites) {\n          for (const prereqId of event.prerequisites) {\n            const prereqAssignment = result.assignments.find(pa => pa.eventId === prereqId);\n            if (prereqAssignment) {\n              expect(a.startTime).toBeGreaterThanOrEqual(prereqAssignment.endTime + options.gap!);\n            }\n          }\n        }\n      }\n\n      // Room gaps\n      for (const room of rooms) {\n        const roomAssignments = result.assignments\n          .filter(a => a.roomId === room.id)\n          .sort((a, b) => a.startTime - b.startTime);\n        for (let i = 0; i < roomAssignments.length - 1; i++) {\n          const gap = roomAssignments[i + 1].startTime - roomAssignments[i].endTime;\n          expect(gap).toBeGreaterThanOrEqual(options.gap!);\n        }\n      }\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":256,"cache_read_input_tokens":26404,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":256},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"556ff0cf-b194-4787-898d-09248e94841c","uuid":"395ff62a-537d-4dc8-94e1-dbb2c3c72865"}
