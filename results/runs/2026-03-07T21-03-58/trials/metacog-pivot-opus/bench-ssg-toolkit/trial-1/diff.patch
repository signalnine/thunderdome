+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DNxyHB9A4sqZTbwzn126TB","type":"tool_result","content":"     1â†’import { describe, it, expect } from 'vitest';\n     2â†’import { createAssetPipelinePlugin } from '../../src/plugins/asset-pipeline.js';\n     3â†’import { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n     4â†’\n     5â†’const testConfig: SiteConfig = {\n     6â†’  title: 'Test Site',\n     7â†’  baseUrl: 'https://example.com',\n     8â†’  outputDir: './dist',\n     9â†’  contentDir: './content',\n    10â†’  templateDir: './templates',\n    11â†’};\n    12â†’\n    13â†’function makeCtx(): BuildContext {\n    14â†’  return {\n    15â†’    config: testConfig,\n    16â†’    files: [],\n    17â†’    output: new Map(),\n    18â†’    assets: new Map(),\n    19â†’    data: new Map(),\n    20â†’  };\n    21â†’}\n    22â†’\n    23â†’function makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n    24â†’  return {\n    25â†’    slug: 'test',\n    26â†’    title: 'Test',\n    27â†’    content: '',\n    28â†’    metadata: {},\n    29â†’    ...overrides,\n    30â†’  };\n    31â†’}\n    32â†’\n    33â†’describe('asset-pipeline plugin', () => {\n    34â†’  const plugin = createAssetPipelinePlugin();\n    35â†’\n    36â†’  it('rewrites relative image URLs to /assets/ path', async () => {\n    37â†’    const file = makeFile({ content: '<img src=\"./image.png\" alt=\"test\">' });\n    38â†’    const ctx = makeCtx();\n    39â†’    const result = await plugin.hooks.transformContent!(file, ctx);\n    40â†’    expect(result.content).toContain('src=\"/assets/image.png\"');\n    41â†’    expect(result.content).not.toContain('src=\"./image.png\"');\n    42â†’  });\n    43â†’\n    44â†’  it('rewrites relative link URLs to /assets/ path', async () => {\n    45â†’    const file = makeFile({ content: '<a href=\"./doc.pdf\">Download</a>' });\n    46â†’    const ctx = makeCtx();\n    47â†’    const result = await plugin.hooks.transformContent!(file, ctx);\n    48â†’    expect(result.content).toContain('href=\"/assets/doc.pdf\"');\n    49â†’    expect(result.content).not.toContain('href=\"./doc.pdf\"');\n    50â†’  });\n    51â†’\n    52â†’  it('leaves absolute URLs unchanged', async () => {\n    53â†’    const file = makeFile({ content: '<img src=\"https://cdn.example.com/image.png\">' });\n    54â†’    const ctx = makeCtx();\n    55â†’    const result = await plugin.hooks.transformContent!(file, ctx);\n    56â†’    expect(result.content).toContain('src=\"https://cdn.example.com/image.png\"');\n    57â†’  });\n    58â†’\n    59â†’  it('generates asset manifest in ctx.data', async () => {\n    60â†’    const file = makeFile({ content: '<img src=\"./photo.jpg\">' });\n    61â†’    const ctx = makeCtx();\n    62â†’    await plugin.hooks.transformContent!(file, ctx);\n    63â†’    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    64â†’    expect(manifest).toBeDefined();\n    65â†’    expect(manifest.assets).toContain('photo.jpg');\n    66â†’  });\n    67â†’\n    68â†’  it('handles files with no asset references', async () => {\n    69â†’    const file = makeFile({ content: '<p>No assets here</p>' });\n    70â†’    const ctx = makeCtx();\n    71â†’    const result = await plugin.hooks.transformContent!(file, ctx);\n    72â†’    expect(result.content).toBe('<p>No assets here</p>');\n    73â†’  });\n    74â†’\n    75â†’  it('handles multiple assets in one file', async () => {\n    76â†’    const file = makeFile({\n    77â†’      content: '<img src=\"./a.png\"><img src=\"./b.jpg\"><a href=\"./c.pdf\">link</a>',\n    78â†’    });\n    79â†’    const ctx = makeCtx();\n    80â†’    await plugin.hooks.transformContent!(file, ctx);\n    81â†’    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    82â†’    expect(manifest.assets).toContain('a.png');\n    83â†’    expect(manifest.assets).toContain('b.jpg');\n    84â†’    expect(manifest.asset