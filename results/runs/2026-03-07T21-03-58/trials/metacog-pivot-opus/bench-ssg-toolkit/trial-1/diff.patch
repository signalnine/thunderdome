+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,125 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processAdmonitions(text: string): string {
+  return text.replace(/^:::(note|warning|tip)\n([\s\S]*?)^:::/gm, (_match, type: string, body: string) => {
+    return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+  });
+}
+
+function processFootnotes(text: string): { text: string; footnotes: { id: string; content: string }[] } {
+  const footnotes: { id: string; content: string }[] = [];
+
+  // Extract footnote definitions
+  const withoutDefs = text.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, (_match, id: string, content: string) => {
+    footnotes.push({ id, content });
+    return '';
+  });
+
+  // Replace footnote references
+  const withRefs = withoutDefs.replace(/\[\^(\d+)\]/g, (_match, id: string) => {
+    return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+  });
+
+  return { text: withRefs, footnotes };
+}
+
+function markdownToHtml(markdown: string): string {
+  if (!markdown) return '';
+
+  let text = markdown;
+
+  // Process admonitions first (before markdown conversion)
+  text = processAdmonitions(text);
+
+  // Process footnotes
+  const { text: processedText, footnotes } = processFootnotes(text);
+  text = processedText;
+
+  // Convert headers
+  text = text.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
+  text = text.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
+  text = text.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
+  text = text.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
+  text = text.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
+  text = text.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');
+
+  // Convert code blocks (fenced)
+  text = text.replace(/```(\w+)?\n([\s\S]*?)```/gm, (_match, lang: string | undefined, code: string) => {
+    if (lang) {
+      return `<pre><code class="language-${lang}">${code.trim()}</code></pre>`;
+    }
+    return `<pre><code>${code.trim()}</code></pre>`;
+  });
+
+  // Convert inline code
+  text = text.replace(/`([^`]+)`/g, '<code>$1</code>');
+
+  // Convert bold
+  text = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+
+  // Convert italic
+  text = text.replace(/\*(.+?)\*/g, '<em>$1</em>');
+
+  // Convert links
+  text = text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
+
+  // Convert images
+  text = text.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1">');
+
+  // Convert paragraphs (non-empty lines not already wrapped in tags)
+  const lines = text.split('\n');
+  const result: string[] = [];
+  let inBlock = false;
+
+  for (let i = 0; i < lines.length; i++) {
+    const line = lines[i].trim();
+    if (!line) {
+      result.push('');
+      continue;
+    }
+    if (line.startsWith('<h') || line.startsWith('<pre') || line.startsWith('<div') ||
+        line.startsWith('<ul') || line.startsWith('<ol') || line.startsWith('<li') ||
+        line.startsWith('<blockquote') || line.startsWith('</')) {
+      inBlock = line.startsWith('<pre') || line.startsWith('<div');
+      result.push(line);
+      continue;
+    }
+    if (inBlock) {
+      result.push(line);
+      if (line.includes('</pre>') || line.includes('</div>')) {
+        inBlock = false;
+      }
+      continue;
+    }
+    result.push(`<p>${line}</p>`);
+  }
+
+  text = result.join('\n');
+
+  // Clean up empty lines
+  text = text.replace(/\n{3,}/g, '\n\n').trim();
+
+  // Add footnotes section if any
+  if (footnotes.length > 0) {
+    const items = footnotes.map(fn => `<li id="fn-${fn.id}">${fn.content}</li>`).join('\n');
+    text += `\n<section class="footnotes">\n<ol>\n${items}\n</ol>\n</section>`;
+  }
+
+  return text;
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        return {
+          ...file,
+          content: markdownToHtml(file.content),
+        };
+      },
+    },
+  };
+}
diff --git a/src/plugins/rss-feed.ts b/src/plugins/rss-feed.ts
