    47â†’    expect(result.content).toContain('<sup><a href=\"#fn-1\">1</a></sup>');\n    48â†’  });\n    49â†’\n    50â†’  it('renders footnote section at bottom of content', async () => {\n    51â†’    const file = makeFile({ content: 'Text[^1] and more[^2].\\n\\n[^1]: First note.\\n[^2]: Second note.' });\n    52â†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    53â†’    expect(result.content).toContain('<section class=\"footnotes\">');\n    54â†’    expect(result.content).toContain('<li id=\"fn-1\">First note.</li>');\n    55â†’    expect(result.content).toContain('<li id=\"fn-2\">Second note.</li>');\n    56â†’  });\n    57â†’\n    58â†’  it('converts :::note container to admonition div', async () => {\n    59â†’    const file = makeFile({ content: ':::note\\nThis is a note.\\n:::' });\n    60â†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    61â†’    expect(result.content).toContain('<div class=\"admonition admonition-note\">');\n    62â†’    expect(result.content).toContain('This is a note.');\n    63â†’  });\n    64â†’\n    65â†’  it('converts :::warning container to admonition div', async () => {\n    66â†’    const file = makeFile({ content: ':::warning\\nBe careful!\\n:::' });\n    67â†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    68â†’    expect(result.content).toContain('<div class=\"admonition admonition-warning\">');\n    69â†’    expect(result.content).toContain('Be careful!');\n    70â†’  });\n    71â†’\n    72â†’  it('converts :::tip container to admonition div', async () => {\n    73â†’    const file = makeFile({ content: ':::tip\\nHelpful hint.\\n:::' });\n    74â†’    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    75â†’    expect(result.content).toContain('<div class=\"admonition admonition-tip\">');\n    76â†’    expect(result.content).toContain('Helpful hint.');\n    77â†’  });\n    78â†’\n    79â†’  it('preserves existin