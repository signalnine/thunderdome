ent).toContain('<strong>bold</strong>');\n  });\n\n  it('handles footnotes with [^1] syntax', async () => {\n    const file = makeFile({ content: 'Some text[^1] here.\\n\\n[^1]: This is the footnote.' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<sup><a href=\"#fn-1\">1</a></sup>');\n  });\n\n  it('renders footnote section at bottom of content', async () => {\n    const file = makeFile({ content: 'Text[^1] and more[^2].\\n\\n[^1]: First note.\\n[^2]: Second note.' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<section class=\"footnotes\">');\n    expect(result.content).toContain('<li id=\"fn-1\">First note.</li>');\n    expect(result.content).toContain('<li id=\"fn-2\">Second note.</li>');\n  });\n\n  it('converts :::note container to admonition div', async () => {\n    const file = makeFile({ content: ':::note\\nThis is a note.\\n:::' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<div class=\"admonition admonition-note\">');\n    expect(result.content).toContain('This is a note.');\n  });\n\n  it('converts :::warning container to admonition div', async () => {\n    const file = makeFile({ content: ':::warning\\nBe careful!\\n:::' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<div class=\"admonition admonition-warning\">');\n    expect(result.content).toContain('Be careful!');\n  });\n\n  it('converts :::tip container to admonition div', async () => {\n    const file = makeFile({ content: ':::tip\\nHelpful hint.\\n:::' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<div class=\"admonition admonition-tip\">');\n    expect(result.content).toContain('Helpful hint.');\n  });\n\n  it('preserves existing HTML in content', async () => {\n    const file = makeFile({ content: '<div class=\"custom\">Already HTML</div>' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('Already HTML');\n  });\n\n  it('handles empty content', async () => {\n    const file = makeFile({ content: '' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toBeDefined();\n  });\n});\n","numLines":91,"startLine":1,"totalLines":91}}}
