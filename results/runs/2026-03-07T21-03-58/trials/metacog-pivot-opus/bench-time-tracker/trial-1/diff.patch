@@ -0,0 +1,18 @@
+import * as fs from "node:fs";
+import * as path from "node:path";
+import type { TimeTrackerData } from "./types.js";
+
+export function loadData(filePath: string): TimeTrackerData {
+  try {
+    const raw = fs.readFileSync(filePath, "utf-8");
+    return JSON.parse(raw) as TimeTrackerData;
+  } catch {
+    return { entries: [] };
+  }
+}
+
+export function saveData(filePath: string, data: TimeTrackerData): void {
+  const dir = path.dirname(filePath);
+  fs.mkdirSync(dir, { recursive: true });
+  fs.writeFileSync(filePath, JSON.stringify(data, null, 2), "utf-8");
+}
diff --git a/src/tracker.ts b/src/tracker.ts
new file mode 100644
index 0000000..561964d
--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,86 @@
+import { loadData, saveData } from "./storage.js";
+import type { TimeEntry, TimeSummary, TimeTrackerData } from "./types.js";
+
+export class TimeTracker {
+  private data: TimeTrackerData;
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.data = loadData(filePath);
+  }
+
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Stop any currently running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    };
+
+    this.data.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    if (!from && !to) {
+      return [...this.data.entries];
+    }
+
+    return this.data.entries.filter((entry) => {
+      const entryStart = new Date(entry.start);
+      if (from && entryStart < from) return false;
+      if (to && entryStart > to) return false;
+      return true;
+    });
+  }
+
+  getSummary(from?: Date, to?: Date): TimeSummary {
+    const entries = this.getEntries(from, to);
+    const summary: TimeSummary = {};
+
+    for (const entry of entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  getRunningEntry(): TimeEntry | null {
+    return this.data.entries.find((e) => e.stop === null) ?? null;
+  }
+
+  private save(): void {
+    saveData(this.filePath, this.data);
+  }
+}
