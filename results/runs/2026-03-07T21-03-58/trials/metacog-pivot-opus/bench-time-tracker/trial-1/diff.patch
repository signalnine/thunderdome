getEntries();\n    expect(entries).toHaveLength(2);\n    expect(entries[0].task).toBe(\"task1\");\n    expect(entries[0].stop).not.toBeNull();\n    expect(entries[1].task).toBe(\"task2\");\n    expect(entries[1].stop).toBeNull();\n  });\n\n  it(\"should persist data to disk\", () => {\n    const tracker1 = new TimeTracker(fp);\n    tracker1.start(\"persisted\");\n    tracker1.stop();\n\n    const tracker2 = new TimeTracker(fp);\n    const entries = tracker2.getEntries();\n    expect(entries).toHaveLength(1);\n    expect(entries[0].task).toBe(\"persisted\");\n  });\n\n  it(\"should create parent directories automatically\", () => {\n    const nested = path.join(os.tmpdir(), \"tt-nested\", \"a\", \"b\", \"data.json\");\n    try {\n      const tracker = new TimeTracker(nested);\n      tracker.start(\"deep\");\n      tracker.stop();\n      expect(fs.existsSync(nested)).toBe(true);\n    } finally {\n      fs.rmSync(path.join(os.tmpdir(), \"tt-nested\"), {\n        recursive: true,\n        force: true,\n      });\n    }\n  });\n\n  it(\"should filter entries by date range\", async () => {\n    const tracker = new TimeTracker(fp);\n\n    // Create an entry in the past\n    const past = new Date(\"2020-01-01T00:00:00Z\");\n    const now = new Date();\n\n    tracker.start(\"old-task\");\n    tracker.stop();\n\n    // Manually manipulate the data to have a known past entry\n    const raw = JSON.parse(fs.readFileSync(fp, \"utf-8\"));\n    raw.entries[0].start = past.toISOString();\n    raw.entries[0].stop = new Date(\"2020-01-01T01:00:00Z\").toISOString();\n    // Add a recent entry\n    raw.entries.push({\n      task: \"recent-task\",\n      start: now.toISOString(),\n      stop: new Date(now.getTime() + 3600000).toISOString(),\n    });\n    fs.writeFileSync(fp, JSON.stringify(raw));\n\n    const tracker2 = new TimeTracker(fp);\n\n    // Filter to only recent\n    const recent = tracker2.getEntries(new Date(\"2024-01-01\"));\n    expect(recent).toHaveLength(1);\n    expect(recent[0].task).toBe(\"recent-task\");\n\n    // Filter to only old\n    const old = tracker2.getEntries(undefined, new Date(\"2021-01-01\"));\n    expect(old).toHaveLength(1);\n    expect(old[0].task).toBe(\"old-task\");\n\n    // All entries\n    const all = tracker2.getEntries();\n    expect(all).toHaveLength(2);\n  });\n\n  it(\"should summarize time per task\", () => {\n    const tracker = new TimeTracker(fp);\n\n    // Write known data directly\n    const data = {\n      entries: [\n        {\n          task: \"coding\",\n          start: \"2024-01-01T00:00:00.000Z\",\n          stop: \"2024-01-01T01:00:00.000Z\",\n        },\n        {\n          task: \"coding\",\n          start: \"2024-01-01T02:00:00.000Z\",\n          stop: \"2024-01-01T03:00:00.000Z\",\n        },\n        {\n          task: \"review\",\n          start: \"2024-01-01T04:00:00.000Z\",\n          stop: \"2024-01-01T04:30:00.000Z\",\n        },\n      ],\n    };\n    fs.writeFileSync(fp, JSON.stringify(data));\n\n    const tracker2 = new TimeTracker(fp);\n    const summary = tracker2.getSummary();\n\n    expect(summary[\"coding\"]).toBe(2 * 3600000); // 2 hours\n    expect(summary[\"review\"]).toBe(30 * 60000); // 30 minutes\n  });\n\n  it(\"should include running tasks in summary using current time\", () => {\n    const tracker = new TimeTracker(fp);\n    const before = Date.now();\n    tracker.start(\"running-task\");\n    const summary = tracker.getSummary();\n    const after = Date.now();\n\n    expect(summary[\"running-task\"]).toBeGreaterThanOrEqual(0);\n    expect(summary[\"running-task\"]).toBeLessThanOrEqual(after - before + 100);\n  });\n\n  it(\"should support unicode and emoji task names\", () => {\n    const tracker = new TimeTracker(fp);\n    tracker.start(\"日本語タスク 🚀\");\n    tracker.stop();\n\n    tracker.start(\"émojis 😀🎉✨\");\n    tracker.stop();\n\n    const entries = tracker.getEntries();\n    expect(entries).toHaveLength(2);\n    expect(entries[0].task).toBe(\"日本語タスク 🚀\")