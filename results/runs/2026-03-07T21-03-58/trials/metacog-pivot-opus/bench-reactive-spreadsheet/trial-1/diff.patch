+// ---- Cell Reference Utilities ----
+
+function columnToNumber(col: string): number {
+  let result = 0;
+  for (let i = 0; i < col.length; i++) {
+    result = result * 26 + (col.charCodeAt(i) - 64);
+  }
+  return result;
+}
+
+function numberToColumn(num: number): string {
+  let result = '';
+  while (num > 0) {
+    num--;
+    result = String.fromCharCode(65 + (num % 26)) + result;
+    num = Math.floor(num / 26);
+  }
+  return result;
+}
+
+function parseRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: columnToNumber(match[1]), row: parseInt(match[2], 10) };
+}
+
+function formatRef(col: number, row: number): string {
+  return numberToColumn(col) + row;
+}
+
+function expandRange(start: string, end: string): string[] {
+  const s = parseRef(start);
+  const e = parseRef(end);
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+  const cells: string[] = [];
+  for (let c = minCol; c <= maxCol; c++) {
+    for (let r = minRow; r <= maxRow; r++) {
+      cells.push(formatRef(c, r));
+    }
+  }
+  return cells;
+}
+
+// ---- Tokenizer ----
+
+type TokenType =
+  | 'NUMBER'
+  | 'STRING'
+  | 'BOOLEAN'
+  | 'CELL_REF'
+  | 'RANGE'
+  | 'FUNC'
+  | 'OP'
+  | 'COMPARE'
+  | 'LPAREN'
+  | 'RPAREN'
+  | 'COMMA';
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+function tokenize(formula: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < formula.length) {
+    if (formula[i] === ' ') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (formula[i] === '"') {
+      let str = '';
+      i++; // skip opening quote
+      while (i < formula.length && formula[i] !== '"') {
+        str += formula[i];
+        i++;
+      }
+      i++; // skip closing quote
+      tokens.push({ type: 'STRING', value: str });
+      continue;
+    }
+
+    // Number
+    if (/\d/.test(formula[i]) || (formula[i] === '.' && i + 1 < formula.length && /\d/.test(formula[i + 1]))) {
+      let num = '';
+      while (i < formula.length && (/\d/.test(formula[i]) || formula[i] === '.')) {
+        num += formula[i];
+        i++;
+      }
+      tokens.push({ type: 'NUMBER', value: num });
+      continue;
+    }
+
+    // Identifiers: cell refs, ranges, functions, booleans
+    if (/[A-Za-z]/.test(formula[i])) {
+      let ident = '';
+      while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+        ident += formula[i];
+        i++;
+      }
+      const upper = ident.toUpperCase();
+
+      // Check for range (IDENT:IDENT)
+      if (formula[i] === ':' && /^[A-Z]+\d+$/i.test(ident)) {
+        i++; // skip ':'
+        let ident2 = '';
+        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+          ident2 += formula[i];
+          i++;
+        }
+        tokens.push({ type: 'RANGE', value: upper + ':' + ident2.toUpperCase() });
+        continue;
+      }
+
+      // Boolean
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: 'BOOLEAN', value: upper });
+        continue;
+      }
+
+      // Function (followed by '(')
+      if (formula[i] === '(' && ['SUM', 'AVERAGE', 'MIN', 'MAX', 'COUNT', 'IF'].includes(upper)) {
+        tokens.push({ type: 'FUNC', value: upper });
+        continue;
+      }
+
+      // Cell reference
+      if (/^[A-Z]+\d+$/.test(upper)) {
+        tokens.push({ type: 'CELL_REF', value: upper });
+        continue;
+      }
+
+      throw new Error(`Unknown identifier: ${ident}`);
+    }
+
+    // Comparison operators
+    if (formula[i] === '<') {
+      if (formula[i + 1] === '=') {
+        tokens.push({ type: 'COMPARE', value: '<=' });
+        i += 2;
+      } else if (formula[i + 1] === '>') {
+        tokens.push({ type: 'COMPARE', value: '<>' });
+        i += 2;
+      } else {
+        tokens.push({ type: 'COMPARE', value: '<' });
+        i++;
+      }
+      continue;
+    }
+    if (formula[i] === '>') {
+      if (formula[i + 1] === '=') {
+        tokens.push({ type: 'COMPARE', value: '>=' });
+        i += 2;
+      } else {
+        tokens.push({ type: 'COMPARE', value: '>' });
+        i++;
+      }
+      continue;
+    }
+    if (formula[i] === '=') {
+      tokens.push({ type: 'COMPARE', value: '=' });
+      i++;
+      continue;
+    }
+
+    // Arithmetic operators
+    if ('+-*/'.includes(formula[i])) {
+      tokens.push({ type: 'OP', value: formula[i] });
+      i++;
+      continue;
+    }
+
+    if (formula[i] === '(') {
+      tokens.push({ type: 'LPAREN', value: '(' });
+      i++;
+      continue;
+    }
+    if (formula[i] === ')') {
+      tokens.push({ type: 'RPAREN', value: ')' });
+      i++;
+      continue;
+    }
+    if (formula[i] === ',') {
+      tokens.push({ type: 'COMMA', value: ',' });
+      i++;
+      continue;
+    }
+
+    throw new Error(`Unexpected character: ${formula[i]}`);
+  }
+
+  return tokens;
+}
+
+// ---- AST ----
+
+type ASTNode =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'cell_ref'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'binary'; op: string; left: ASTNode; right: ASTNode }
+  | { type: 'function'; name: string; args: ASTNode[] }
+  | { type: 'unary'; op: string; operand: ASTNode };
+
+// ---- Parser (recursive descent) ----
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token | undefined {
+    return this.tokens[this.pos];
+  }
+
+  private consume(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  private expect(type: TokenType): Token {
+    const t = this.consume();
+    if (!t || t.type !== type) {
+      throw new Error(`Expected ${type}, got ${t?.type ?? 'end of input'}`);
+    }
+    return t;
+  }
+
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    if (this.pos < this.tokens.length) {
+      throw new Error(`Unexpected token: ${this.tokens[this.pos].value}`);
+    }
+    return node;
+  }
+
+  private parseComparison(): ASTNode {
+    let left = this.parseAddSub();
+    while (this.peek()?.type === 'COMPARE') {
+      const op = this.consume().value;
+      const right = this.parseAddSub();
+      left = { type: 'binary', op, left, right };
+    }
+    return left;
+  }
+
+  private parseAddSub(): ASTNode {
+    let left = this.parseMulDiv();
+    while (this.peek()?.type === 'OP' && (this.peek()!.value === '+' || this.peek()!.value === '-')) {
+      const op = this.consume().value;
+      const right = this.parseMulDiv();
+      left = { type: 'binary', op, left, right };
+    }
+    return left;
+  }
+
+  private parseMulDiv(): ASTNode {
+    let left = this.parseUnary();
+    while (this.peek()?.type === 'OP' && (this.peek()!.value === '*' || this.peek()!.value === '/')) {
+      const op = this.consume().value;
+      const right = this.parseUnary();
+      left = { type: 'binary', op, left, right };
+    }
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    if (this.peek()?.type === 'OP' && (this.peek()!.value === '-' || this.peek()!.value === '+')) {
+      const op = this.consume().value;
+      const operand = this.parseUnary();
+      return { type: 'unary', op, operand };
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const t = this.peek();
+    if (!t) throw new Error('Unexpected end of formula');
+
+    if (t.type === 'NUMBER') {
+      this.consume();
+      return { type: 'number', value: parseFloat(t.value) };
+    }
+
+    if (t.type === 'STRING') {
+      this.consume();
+      return { type: 'string', value: t.value };
+    }
+
+    if (t.type === 'BOOLEAN') {
+      this.consume();
+      return { type: 'boolean', value: t.value === 'TRUE' };
+    }
+
+    if (t.type === 'RANGE') {
+      this.consume();
+      const [start, end] = t.value.split(':');
+      return { type: 'range', start, end };
+    }
+
+    if (t.type === 'CELL_REF') {
+      this.consume();
+      return { type: 'cell_ref', ref: t.value };
+    }
+
+    if (t.type === 'FUNC') {
+      const name = this.consume().value;
+      this.expect('LPAREN');
+      const args: ASTNode[] = [];
+      if (this.peek()?.type !== 'RPAREN') {
+        args.push(this.parseComparison());
+        while (this.peek()?.type === 'COMMA') {
+          this.consume();
+          args.push(this.parseComparison());
+        }
+      }
+      this.expect('RPAREN');
+      return { type: 'function', name, args };
+    }
+
+    if (t.type === 'LPAREN') {
+      this.consume();
+      const node = this.parseComparison();
+      this.expect('RPAREN');
+      return node;
+    }
+
+    throw new Error(`Unexpected token: ${t.value}`);
+  }
+}
+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  return new Parser(tokens).parse();
+}
+
+// ---- Dependency Extraction ----
+
+function extractDeps(node: ASTNode): Set<string> {
+  const deps = new Set<string>();
+
+  function walk(n: ASTNode): void {
+    switch (n.type) {
+      case 'cell_ref':
+        deps.add(n.ref);
+        break;
+      case 'range':
+        for (const cell of expandRange(n.start, n.end)) {
+          deps.add(cell);
+        }
+        break;
+      case 'binary':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'unary':
+        walk(n.operand);
+        break;
+      case 'function':
+        for (const arg of n.args) {
+          walk(arg);
+        }
+        break;
+      // number, string, boolean: no deps
+    }
+  }
+
+  walk(node);
+  return deps;
+}
+
+// ---- Cell Types ----
+
+type CellValue = string | number | boolean | null;
+
+interface CellData {
+  rawValue: string | number | boolean;
+  formula: ASTNode | null;
+  computed: CellValue;
+  deps: Set<string>;
+}
+
+// ---- Spreadsheet ----
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Map from cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+    const oldData = this.cells.get(ref);
+
+    // Remove old dependency links
+    if (oldData) {
+      for (const dep of oldData.deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    let formula: ASTNode | null = null;
+    let deps = new Set<string>();
+    let computed: CellValue;
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value.substring(1));
+      deps = extractDeps(formula);
+
+      // Check for circular reference before committing
+      this.checkCircular(ref, deps);
+
+      // Register new dependency links
+      for (const dep of deps) {
+        if (!this.dependents.has(dep)) {
+          this.dependents.set(dep, new Set());
+        }
+        this.dependents.get(dep)!.add(ref);
+      }
+
+      computed = this.evaluate(formula);
+    } else {
+      computed = value;
+    }
+
+    this.cells.set(ref, { rawValue: value, formula, computed, deps });
+
+    // Propagate changes to dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = cell.toUpperCase();
+    const data = this.cells.get(ref);
+    return data ? data.computed : null;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computed);
+    }
+    return result;
+  }
+
+  private checkCircular(target: string, deps: Set<string>): void {
+    const visited = new Set<string>();
+
+    const dfs = (cell: string): void => {
+      if (cell === target) {
+        throw new Error(`Circular reference detected involving ${target}`);
+      }
+      if (visited.has(cell)) return;
+      visited.add(cell);
+
+      const cellData = this.cells.get(cell);
+      if (cellData) {
+        for (const dep of cellData.deps) {
+          dfs(dep);
+        }
+      }
+    };
+
+    for (const dep of deps) {
+      dfs(dep);
+    }
+  }
+
+  private propagate(changed: string): void {
+    // Topological order of cells to recompute
+    const order: string[] = [];
+    const visited = new Set<string>();
+
+    const dfs = (cell: string): void => {
+      if (visited.has(cell)) return;
+      visited.add(cell);
+      const deps = this.dependents.get(cell);
+      if (deps) {
+        for (const dep of deps) {
+          dfs(dep);
+        }
+      }
+      order.push(cell);
+    };
+
+    // Start from the dependents of the changed cell
+    const directDeps = this.dependents.get(changed);
+    if (!directDeps || directDeps.size === 0) return;
+
+    for (const dep of directDeps) {
+      dfs(dep);
+    }
+
+    // Recompute in reverse topological order
+    for (let i = order.length - 1; i >= 0; i--) {
+      const ref = order[i];
+      const data = this.cells.get(ref);
+      if (data?.formula) {
+        data.computed = this.evaluate(data.formula);
+      }
+    }
+  }
+
+  private evaluate(node: ASTNode): CellValue {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'cell_ref': {
+        const val = this.get(node.ref);
+        return val === null ? 0 : val;
+      }
+      case 'unary': {
+        const operand = this.evaluate(node.operand);
+        if (node.op === '-') return -(operand as number);
+        return operand as number;
+      }
+      case 'binary':
+        return this.evaluateBinary(node.op, node.left, node.right);
+      case 'function':
+        return this.evaluateFunction(node.name, node.args);
+      case 'range':
+        throw new Error('Range cannot be used outside of a function');
+    }
+  }
+
+  private evaluateBinary(op: string, left: ASTNode, right: ASTNode): CellValue {
+    const l = this.evaluate(left);
+    const r = this.evaluate(right);
+
+    switch (op) {
+      case '+': return (l as number) + (r as number);
+      case '-': return (l as number) - (r as number);
+      case '*': return (l as number) * (r as number);
+      case '/': return (l as number) / (r as number);
+      case '>': return (l as number) > (r as number);
+      case '<': return (l as number) < (r as number);
+      case '>=': return (l as number) >= (r as number);
+      case '<=': return (l as number) <= (r as number);
+      case '=': return l === r;
+      case '<>': return l !== r;
+      default: throw new Error(`Unknown operator: ${op}`);
+    }
+  }
+
+  private resolveRangeValues(node: ASTNode): number[] {
+    if (node.type === 'range') {
+      const cells = expandRange(node.start, node.end);
+      const values: number[] = [];
+      for (const cell of cells) {
+        const val = this.get(cell);
+        if (typeof val === 'number') {
+          values.push(val);
+        }
+      }
+      return values;
+    }
+    // Single value
+    const val = this.evaluate(node);
+    if (typeof val === 'number') return [val];
+    return [];
+  }
+
+  private evaluateFunction(name: string, args: ASTNode[]): CellValue {
+    switch (name) {
+      case 'SUM': {
+        const values = this.resolveRangeValues(args[0]);
+        return values.reduce((a, b) => a + b, 0);
+      }
+      case 'AVERAGE': {
+        const values = this.resolveRangeValues(args[0]);
+        if (values.length === 0) return 0;
+        return values.reduce((a, b) => a + b, 0) / values.length;
+      }
+      case 'MIN': {
+        const values = this.resolveRangeValues(args[0]);
+        return Math.min(...values);
+      }
+      case 'MAX': {
+        const values = this.resolveRangeValues(args[0]);
+        return Math.max(...values);
+      }
+      case 'COUNT': {
+        const values = this.resolveRangeValues(args[0]);
+        return values.length;
+      }
+      case 'IF': {
+        const condition = this.evaluate(args[0]);
+        if (condition) {
+          return this.evaluate(args[1]);
+        }
+        return this.evaluate(args[2]);
+      }
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+}
