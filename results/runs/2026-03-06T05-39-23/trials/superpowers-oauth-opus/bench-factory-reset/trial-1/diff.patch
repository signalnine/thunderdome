@@ -0,0 +1,614 @@
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve the toggle puzzle using Gaussian elimination over GF(2).
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix [A | t] over GF(2) using BigInt bitmasks
+  const matrix: bigint[] = [];
+  for (let i = 0; i < numLights; i++) {
+    let row = 0n;
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row |= 1n << BigInt(j);
+      }
+    }
+    if (target[i]) {
+      row |= 1n << BigInt(numButtons);
+    }
+    matrix.push(row);
+  }
+
+  // Gaussian elimination (reduced row echelon form)
+  const pivotCol: number[] = [];
+  let currentRow = 0;
+  for (let col = 0; col < numButtons; col++) {
+    let pivotRow = -1;
+    for (let r = currentRow; r < numLights; r++) {
+      if ((matrix[r] >> BigInt(col)) & 1n) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+    [matrix[currentRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[currentRow]];
+    for (let r = 0; r < numLights; r++) {
+      if (r !== currentRow && (matrix[r] >> BigInt(col)) & 1n) {
+        matrix[r] ^= matrix[currentRow];
+      }
+    }
+    pivotCol.push(col);
+    currentRow++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check for inconsistency
+  for (let r = rank; r < numLights; r++) {
+    if ((matrix[r] >> BigInt(numButtons)) & 1n) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < numButtons; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+
+  const numFree = freeVars.length;
+
+  // Unique solution
+  if (numFree === 0) {
+    const result: number[] = [];
+    for (let r = 0; r < rank; r++) {
+      if ((matrix[r] >> BigInt(numButtons)) & 1n) result.push(pivotCol[r]);
+    }
+    return result.sort((a, b) => a - b);
+  }
+
+  // Precompute: for each free variable, which pivot rows it affects (as bigint bitmask)
+  const freeEffects: bigint[] = [];
+  for (let f = 0; f < numFree; f++) {
+    let effect = 0n;
+    for (let r = 0; r < rank; r++) {
+      if ((matrix[r] >> BigInt(freeVars[f])) & 1n) {
+        effect |= 1n << BigInt(r);
+      }
+    }
+    freeEffects.push(effect);
+  }
+
+  // Base pivot state (when all free vars = 0)
+  let basePivotState = 0n;
+  for (let r = 0; r < rank; r++) {
+    if ((matrix[r] >> BigInt(numButtons)) & 1n) {
+      basePivotState |= 1n << BigInt(r);
+    }
+  }
+
+  if (numFree <= 20) {
+    return solveToggleDirect(pivotCol, freeVars, freeEffects, basePivotState, rank, numFree);
+  }
+
+  return solveToggleMITM(pivotCol, freeVars, freeEffects, basePivotState, rank, numFree);
+}
+
+function popcountBigInt(n: bigint): number {
+  let count = 0;
+  while (n > 0n) {
+    n &= n - 1n;
+    count++;
+  }
+  return count;
+}
+
+function solveToggleDirect(
+  pivotCol: number[],
+  freeVars: number[],
+  freeEffects: bigint[],
+  basePivotState: bigint,
+  rank: number,
+  numFree: number
+): number[] {
+  const totalCombinations = 1 << numFree;
+  let bestSolution: number[] | null = null;
+  let bestCount = Infinity;
+
+  let currentPivotState = basePivotState;
+  let currentFreeCount = 0;
+
+  // mask = 0
+  {
+    const pivotCount = popcountBigInt(currentPivotState);
+    const total = pivotCount;
+    bestCount = total;
+    bestSolution = buildToggleSolution(pivotCol, currentPivotState, freeVars, 0, rank);
+  }
+
+  for (let mask = 1; mask < totalCombinations; mask++) {
+    // Gray code: find the bit that changed
+    const changedBit = ctz(mask);
+    const bitNowSet = (mask >> changedBit) & 1;
+
+    currentPivotState ^= freeEffects[changedBit];
+    if (bitNowSet) currentFreeCount++;
+    else currentFreeCount--;
+
+    const pivotCount = popcountBigInt(currentPivotState);
+    const total = currentFreeCount + pivotCount;
+
+    if (total < bestCount) {
+      bestCount = total;
+      bestSolution = buildToggleSolution(pivotCol, currentPivotState, freeVars, mask, rank);
+    } else if (total === bestCount) {
+      const candidate = buildToggleSolution(pivotCol, currentPivotState, freeVars, mask, rank);
+      if (lexSmaller(candidate, bestSolution!)) {
+        bestSolution = candidate;
+      }
+    }
+  }
+
+  return bestSolution!;
+}
+
+function solveToggleMITM(
+  pivotCol: number[],
+  freeVars: number[],
+  freeEffects: bigint[],
+  basePivotState: bigint,
+  rank: number,
+  numFree: number
+): number[] {
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+  const sizeA = 1 << halfA;
+  const sizeB = 1 << halfB;
+
+  // For each half-A mask, compute the XOR effect on pivot state and free count.
+  // Group by effect signature. For a given half-B, the combined pivot state is:
+  // basePivotState XOR effectA XOR effectB
+  // Total buttons pressed = freeCountA + freeCountB + popcount(basePivotState XOR effectA XOR effectB)
+  //
+  // For fixed B (fixed effectB, freeCountB):
+  // let target = basePivotState XOR effectB
+  // cost = freeCountA + popcount(target XOR effectA) + freeCountB
+  //
+  // We want to minimize freeCountA + popcount(target XOR effectA).
+  // For a given effectA value, the minimum freeCountA over all masks producing that effect is best.
+  // So we group by effectA and keep min freeCountA (and lex-best mask for ties).
+
+  const tableA = new Map<bigint, { freeCount: number; mask: number }>();
+
+  {
+    let effectA = 0n;
+    // mask = 0
+    tableA.set(0n, { freeCount: 0, mask: 0 });
+
+    for (let maskA = 1; maskA < sizeA; maskA++) {
+      const changedBit = ctz(maskA);
+      effectA ^= freeEffects[changedBit];
+      const freeCount = popcount32(maskA);
+
+      const existing = tableA.get(effectA);
+      if (!existing || freeCount < existing.freeCount ||
+          (freeCount === existing.freeCount && maskA < existing.mask)) {
+        tableA.set(effectA, { freeCount, mask: maskA });
+      }
+    }
+  }
+
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  // Convert tableA to array for faster iteration
+  const tableAEntries = Array.from(tableA.entries());
+
+  {
+    let effectB = 0n;
+
+    for (let maskB = 0; maskB < sizeB; maskB++) {
+      if (maskB > 0) {
+        const changedBit = ctz(maskB);
+        effectB ^= freeEffects[halfA + changedBit];
+      }
+
+      const freeCountB = popcount32(maskB);
+      const target = basePivotState ^ effectB;
+
+      for (let i = 0; i < tableAEntries.length; i++) {
+        const [effectA, aEntry] = tableAEntries[i];
+        const pivotCount = popcountBigInt(target ^ effectA);
+        const total = aEntry.freeCount + freeCountB + pivotCount;
+
+        if (total < bestTotal) {
+          bestTotal = total;
+          bestSolution = buildToggleSolutionMITM(
+            pivotCol, freeVars, halfA, aEntry.mask, maskB,
+            basePivotState ^ effectA ^ effectB, rank
+          );
+        } else if (total === bestTotal) {
+          const candidate = buildToggleSolutionMITM(
+            pivotCol, freeVars, halfA, aEntry.mask, maskB,
+            basePivotState ^ effectA ^ effectB, rank
+          );
+          if (lexSmaller(candidate, bestSolution!)) {
+            bestSolution = candidate;
+          }
+        }
+      }
+    }
+  }
+
+  return bestSolution!;
+}
+
+function buildToggleSolution(
+  pivotCol: number[],
+  pivotState: bigint,
+  freeVars: number[],
+  freeMask: number,
+  rank: number
+): number[] {
+  const result: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    if ((pivotState >> BigInt(r)) & 1n) result.push(pivotCol[r]);
+  }
+  for (let f = 0; f < freeVars.length; f++) {
+    if ((freeMask >> f) & 1) result.push(freeVars[f]);
+  }
+  result.sort((a, b) => a - b);
+  return result;
+}
+
+function buildToggleSolutionMITM(
+  pivotCol: number[],
+  freeVars: number[],
+  halfA: number,
+  maskA: number,
+  maskB: number,
+  pivotState: bigint,
+  rank: number
+): number[] {
+  const result: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    if ((pivotState >> BigInt(r)) & 1n) result.push(pivotCol[r]);
+  }
+  for (let f = 0; f < halfA; f++) {
+    if ((maskA >> f) & 1) result.push(freeVars[f]);
+  }
+  for (let f = halfA; f < freeVars.length; f++) {
+    if ((maskB >> (f - halfA)) & 1) result.push(freeVars[f]);
+  }
+  result.sort((a, b) => a - b);
+  return result;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+/**
+ * Solve the counter puzzle using Gaussian elimination over GF(p).
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) row[j] = 1;
+    }
+    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotCol: number[] = [];
+  let currentRow = 0;
+
+  for (let col = 0; col < numButtons; col++) {
+    let pivotRow = -1;
+    for (let r = currentRow; r < numCounters; r++) {
+      if (matrix[r][col] !== 0) { pivotRow = r; break; }
+    }
+    if (pivotRow === -1) continue;
+
+    [matrix[currentRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[currentRow]];
+
+    const inv = modPow(matrix[currentRow][col], modulus - 2, modulus);
+    for (let j = 0; j <= numButtons; j++) {
+      matrix[currentRow][j] = (matrix[currentRow][j] * inv) % modulus;
+    }
+
+    for (let r = 0; r < numCounters; r++) {
+      if (r !== currentRow && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let j = 0; j <= numButtons; j++) {
+          matrix[r][j] = (((matrix[r][j] - factor * matrix[currentRow][j]) % modulus) + modulus) % modulus;
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    currentRow++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check for inconsistency
+  for (let r = rank; r < numCounters; r++) {
+    if (matrix[r][numButtons] !== 0) return null;
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < numButtons; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+
+  // Unique solution
+  if (freeVars.length === 0) {
+    const result = new Array(numButtons).fill(0);
+    for (let r = 0; r < rank; r++) {
+      result[pivotCol[r]] = matrix[r][numButtons];
+    }
+    return result;
+  }
+
+  const numFree = freeVars.length;
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  if (totalCombinations <= 5_000_000) {
+    return solveCounterDirect(matrix, pivotCol, freeVars, numButtons, modulus, rank, numFree);
+  }
+
+  return solveCounterMITM(matrix, pivotCol, freeVars, numButtons, modulus, rank, numFree);
+}
+
+function solveCounterDirect(
+  matrix: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  numButtons: number,
+  modulus: number,
+  rank: number,
+  numFree: number
+): number[] {
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  // Use incremental enumeration (odometer)
+  const freeValues = new Array(numFree).fill(0);
+  let done = false;
+
+  while (!done) {
+    const solution = new Array(numButtons).fill(0);
+    let total = 0;
+
+    for (let f = 0; f < numFree; f++) {
+      solution[freeVars[f]] = freeValues[f];
+      total += freeValues[f];
+    }
+
+    // Early pruning: free var total alone exceeds best (pivot vals are non-negative)
+    if (total <= bestTotal) {
+      for (let r = 0; r < rank; r++) {
+        let val = matrix[r][numButtons];
+        for (let f = 0; f < numFree; f++) {
+          val = (((val - matrix[r][freeVars[f]] * freeValues[f]) % modulus) + modulus) % modulus;
+        }
+        solution[pivotCol[r]] = val;
+        total += val;
+      }
+
+      if (total < bestTotal || (total === bestTotal && lexSmallerArr(solution, bestSolution!))) {
+        bestTotal = total;
+        bestSolution = [...solution];
+      }
+    }
+
+    // Increment odometer
+    done = true;
+    for (let f = 0; f < numFree; f++) {
+      freeValues[f]++;
+      if (freeValues[f] < modulus) {
+        done = false;
+        break;
+      }
+      freeValues[f] = 0;
+    }
+  }
+
+  return bestSolution!;
+}
+
+function solveCounterMITM(
+  matrix: number[][],
+  pivotCol: number[],
+  freeVars: number[],
+  numButtons: number,
+  modulus: number,
+  rank: number,
+  numFree: number
+): number[] {
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+  const sizeA = Math.pow(modulus, halfA);
+  const sizeB = Math.pow(modulus, halfB);
+
+  // For each half-A assignment, compute:
+  // - contribution to each pivot row: contribA[r] = sum(matrix[r][freeVars[f]] * freeA[f]) mod p
+  // - partial total = sum of freeA values
+  //
+  // Group by contribution signature. For same signature, keep lowest partial total (lex smallest assignment for ties).
+  //
+  // For each half-B assignment:
+  // - contribB[r] = sum(matrix[r][freeVars[halfA+f]] * freeB[f]) mod p
+  // - pivotVal[r] = (matrix[r][numButtons] - contribA[r] - contribB[r]) mod p
+  // - total = sumFreeA + sumFreeB + sum(pivotVal[r])
+  //
+  // For fixed B, we need the A with contribA such that total is minimized.
+  // The pivot total depends on contribA, so we can't avoid iterating over all A signatures.
+  // But the number of unique signatures is bounded by min(sizeA, p^rank).
+  // When sizeA is large but rank is small, many A assignments map to the same signature,
+  // so we get a speedup.
+
+  // Build table A
+  const tableA = new Map<string, { total: number; freeValues: number[] }>();
+  const freeValuesA = new Array(halfA).fill(0);
+
+  for (let combo = 0; combo < sizeA; combo++) {
+    if (combo > 0) {
+      // Increment odometer
+      for (let f = 0; f < halfA; f++) {
+        freeValuesA[f]++;
+        if (freeValuesA[f] < modulus) break;
+        freeValuesA[f] = 0;
+      }
+    }
+
+    const contribs = new Array(rank);
+    for (let r = 0; r < rank; r++) {
+      let c = 0;
+      for (let f = 0; f < halfA; f++) {
+        c = (c + matrix[r][freeVars[f]] * freeValuesA[f]) % modulus;
+      }
+      contribs[r] = c;
+    }
+
+    let partialTotal = 0;
+    for (let f = 0; f < halfA; f++) partialTotal += freeValuesA[f];
+
+    const key = contribs.join(',');
+    const existing = tableA.get(key);
+    if (!existing || partialTotal < existing.total ||
+        (partialTotal === existing.total && lexSmallerArr(freeValuesA, existing.freeValues))) {
+      tableA.set(key, { total: partialTotal, freeValues: [...freeValuesA] });
+    }
+  }
+
+  const tableAEntries = Array.from(tableA.entries());
+
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+  const freeValuesB = new Array(halfB).fill(0);
+
+  for (let combo = 0; combo < sizeB; combo++) {
+    if (combo > 0) {
+      for (let f = 0; f < halfB; f++) {
+        freeValuesB[f]++;
+        if (freeValuesB[f] < modulus) break;
+        freeValuesB[f] = 0;
+      }
+    }
+
+    const contribsB = new Array(rank);
+    for (let r = 0; r < rank; r++) {
+      let c = 0;
+      for (let f = 0; f < halfB; f++) {
+        c = (c + matrix[r][freeVars[halfA + f]] * freeValuesB[f]) % modulus;
+      }
+      contribsB[r] = c;
+    }
+
+    let partialTotalB = 0;
+    for (let f = 0; f < halfB; f++) partialTotalB += freeValuesB[f];
+
+    // Early skip: if partialTotalB alone >= bestTotal, no A can help
+    if (partialTotalB >= bestTotal) continue;
+
+    for (let i = 0; i < tableAEntries.length; i++) {
+      const [key, aEntry] = tableAEntries[i];
+
+      // Early skip
+      if (aEntry.total + partialTotalB >= bestTotal) continue;
+
+      const contribsA = key.split(',');
+      let pivotTotal = 0;
+      for (let r = 0; r < rank; r++) {
+        const val = (((matrix[r][numButtons] - Number(contribsA[r]) - contribsB[r]) % modulus) + modulus * 2) % modulus;
+        pivotTotal += val;
+      }
+
+      const total = aEntry.total + partialTotalB + pivotTotal;
+
+      if (total < bestTotal) {
+        bestTotal = total;
+        const solution = new Array(numButtons).fill(0);
+        for (let f = 0; f < halfA; f++) solution[freeVars[f]] = aEntry.freeValues[f];
+        for (let f = 0; f < halfB; f++) solution[freeVars[halfA + f]] = freeValuesB[f];
+        for (let r = 0; r < rank; r++) {
+          solution[pivotCol[r]] = (((matrix[r][numButtons] - Number(contribsA[r]) - contribsB[r]) % modulus) + modulus * 2) % modulus;
+        }
+        bestSolution = solution;
+      } else if (total === bestTotal) {
+        const solution = new Array(numButtons).fill(0);
+        for (let f = 0; f < halfA; f++) solution[freeVars[f]] = aEntry.freeValues[f];
+        for (let f = 0; f < halfB; f++) solution[freeVars[halfA + f]] = freeValuesB[f];
+        for (let r = 0; r < rank; r++) {
+          solution[pivotCol[r]] = (((matrix[r][numButtons] - Number(contribsA[r]) - contribsB[r]) % modulus) + modulus * 2) % modulus;
+        }
+        if (lexSmallerArr(solution, bestSolution!)) {
+          bestSolution = solution;
+        }
+      }
+    }
+  }
+
+  return bestSolution!;
+}
+
+function modPow(base: number, exp: number, mod: number): number {
+  let result = 1;
+  base = ((base % mod) + mod) % mod;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % mod;
+    exp >>= 1;
+    if (exp > 0) base = (base * base) % mod;
+  }
+  return result;
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function popcount32(n: number): number {
+  n = n - ((n >> 1) & 0x55555555);
+  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);
+  n = (n + (n >> 4)) & 0x0f0f0f0f;
+  return (n * 0x01010101) >> 24;
+}
+
+function ctz(n: number): number {
+  if (n === 0) return 32;
+  let count = 0;
+  while ((n & 1) === 0) { count++; n >>= 1; }
+  return count;
+}
