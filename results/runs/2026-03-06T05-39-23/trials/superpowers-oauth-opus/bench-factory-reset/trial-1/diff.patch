+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+// Helper to verify a toggle solution
+function verifyToggle(machine: Machine, buttons: number[]): boolean {
+  const state = new Array(machine.target.length).fill(false);
+  for (const b of buttons) {
+    for (const light of machine.buttons[b]) {
+      state[light] = !state[light];
+    }
+  }
+  return state.every((v, i) => v === machine.target[i]);
+}
+
+// Helper to verify a counter solution
+function verifyCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+  presses: number[]
+): boolean {
+  const state = new Array(lights.length).fill(0);
+  for (let b = 0; b < presses.length; b++) {
+    for (const counter of buttons[b]) {
+      state[counter] = (state[counter] + presses[b]) % modulus;
+    }
+  }
+  return state.every((v, i) => v === lights[i]);
+}
+
+describe('solveToggle', () => {
+  it('should return empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0], [1], [2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should return null when no solution exists', () => {
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should solve a simple single-button case', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should find minimum button presses', () => {
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0], [1], [0, 1]],
+    });
+    expect(result).toEqual([2]);
+  });
+
+  it('should return lexicographically smallest on tie', () => {
+    const result = solveToggle({
+      target: [true, false],
+      buttons: [[0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle larger cases', () => {
+    const result = solveToggle({
+      target: [true, false, true, false],
+      buttons: [[0, 2], [1, 3], [0, 1, 2, 3]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle no buttons case', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should handle no buttons with all-off target', () => {
+    const result = solveToggle({
+      target: [false, false],
+      buttons: [],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should handle overlapping buttons that are linearly dependent', () => {
+    const result = solveToggle({
+      target: [true, true, true],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should handle identity buttons (each controls one light)', () => {
+    const machine: Machine = {
+      target: [true, false, true, true, false],
+      buttons: [[0], [1], [2], [3], [4]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 2, 3]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should handle all buttons toggling same light', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0], [0], [0]],
+    };
+    const result = solveToggle(machine);
+    // Need odd number of presses. Minimum = 1. Lex smallest = [0].
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should handle many free variables with direct enumeration', () => {
+    // 2 lights, 15 buttons, most buttons toggle light 0
+    const buttons: number[][] = [];
+    for (let i = 0; i < 15; i++) {
+      buttons.push([0]);
+    }
+    buttons.push([1]); // button 15 toggles light 1
+
+    const machine: Machine = {
+      target: [true, true],
+      buttons,
+    };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine, result!)).toBe(true);
+    // Minimum presses: 2 (one for light 0, one for light 1)
+    expect(result!.length).toBe(2);
+  });
+
+  it('should handle 10 lights and 10 buttons - unique solution', () => {
+    // Each button toggles exactly one light (identity matrix)
+    const n = 10;
+    const target = Array.from({ length: n }, (_, i) => i % 2 === 0);
+    const buttons = Array.from({ length: n }, (_, i) => [i]);
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('should handle redundant buttons correctly', () => {
+    // Button 0: [0], Button 1: [1], Button 2: [0,1] (redundant: b2 = b0 XOR b1)
+    // Target: [true, true]
+    // Solutions: {0,1} (2 presses), {2} (1 press)
+    // Minimum: [2]
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0, 1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([2]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0], [1], [2]], 5);
+    expect(result).toEqual([0, 0, 0]);
+  });
+
+  it('should solve a simple single-button case', () => {
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('should handle modular arithmetic', () => {
+    const result = solveCounter([0], [[0]], 5);
+    expect(result).toEqual([0]);
+  });
+
+  it('should return null when no solution exists', () => {
+    const result = solveCounter([1, 0], [[1]], 5);
+    expect(result).toBeNull();
+  });
+
+  it('should find minimum total presses', () => {
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should return lexicographically smallest on tie', () => {
+    const result = solveCounter([1, 1], [[0], [1]], 3);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('should handle multiple buttons affecting same counter', () => {
+    const result = solveCounter([2], [[0], [0]], 7);
+    expect(result).toEqual([0, 2]);
+  });
+
+  it('should handle no buttons with zero target', () => {
+    const result = solveCounter([0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  it('should handle no buttons with non-zero target', () => {
+    const result = solveCounter([1], [], 5);
+    expect(result).toBeNull();
+  });
+
+  it('should verify solution correctness for larger case', () => {
+    // 3 counters, 4 buttons, mod 5
+    const lights = [2, 3, 1];
+    const buttons = [[0, 1], [1, 2], [0, 2], [0]];
+    const result = solveCounter(lights, buttons, 5);
+    expect(result).not.toBeNull();
+    expect(verifyCounter(lights, buttons, 5, result!)).toBe(true);
+  });
+
+  it('should handle mod 2 (essentially toggle-like)', () => {
+    const result = solveCounter([1, 1, 0], [[0], [1], [2]], 2);
+    expect(result).toEqual([1, 1, 0]);
+  });
+
+  it('should handle large modulus', () => {
+    // mod 97 with a simple system
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+    expect(verifyCounter([50], [[0]], 97, result!)).toBe(true);
+  });
+
+  it('should handle unique solution with multiple counters', () => {
+    // Identity-like system: each button affects one counter
+    const lights = [3, 1, 4, 1, 5];
+    const buttons = [[0], [1], [2], [3], [4]];
+    const result = solveCounter(lights, buttons, 7);
+    expect(result).toEqual([3, 1, 4, 1, 5]);
+    expect(verifyCounter(lights, buttons, 7, result!)).toBe(true);
+  });
+
+  it('should find minimum total when multiple solutions exist', () => {
+    // 1 counter, target 4, mod 5
+    // Button 0: affects counter 0
+    // Solution: press 4 times (total=4). But also pressing 9 times wraps, but max is mod-1=4.
+    const result = solveCounter([4], [[0]], 5);
+    expect(result).toEqual([4]);
+  });
+
+  it('should handle system with no free variables but non-trivial', () => {
+    // 2 counters, 2 buttons, mod 5
+    // Button 0 affects both counters, button 1 affects counter 1 only
+    // Equations: x0 ≡ target[0], x0 + x1 ≡ target[1]
+    // target = [2, 4]
+    // x0 = 2, x1 = (4 - 2) % 5 = 2
+    const lights = [2, 4];
+    const buttons = [[0, 1], [1]];
+    const result = solveCounter(lights, buttons, 5);
+    expect(result).not.toBeNull();
+    expect(verifyCounter(lights, buttons, 5, result!)).toBe(true);
+  });
+});
+
+describe('solveToggle - performance', () => {
+  it('should handle 20 buttons, 20 lights within time limit', () => {
+    const n = 20;
+    const buttons: number[][] = [];
+    const target: boolean[] = [];
+
+    // Create a system where button i toggles lights i and (i+1)%n
+    for (let i = 0; i < n; i++) {
+      buttons.push([i, (i + 1) % n]);
+    }
+    for (let i = 0; i < n; i++) {
+      target.push(i % 3 === 0);
+    }
+
+    const machine: Machine = { target, buttons };
+    const start = Date.now();
+    const result = solveToggle(machine);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    if (result !== null) {
+      expect(verifyToggle(machine, result)).toBe(true);
+    }
+  });
+
+  it('should handle 40 buttons, 40 lights (full rank) within time limit', () => {
+    const n = 40;
+    const buttons: number[][] = [];
+    const target: boolean[] = [];
+
+    // Identity-like: each button toggles one light
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+      target.push(i % 2 === 0);
+    }
+
+    const machine: Machine = { target, buttons };
+    const start = Date.now();
+    const result = solveToggle(machine);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+});
+
+describe('solveCounter - performance', () => {
+  it('should handle 20 buttons, 20 counters within time limit', () => {
+    const n = 20;
+    const buttons: number[][] = [];
+    const lights: number[] = [];
+    const mod = 7;
+
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+      lights.push(i % mod);
+    }
+
+    const start = Date.now();
+    const result = solveCounter(lights, buttons, mod);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).not.toBeNull();
+    expect(verifyCounter(lights, buttons, mod, result!)).toBe(true);
+  });
+
+  it('should handle 40 buttons, 40 counters (full rank) within time limit', () => {
+    const n = 40;
+    const buttons: number[][] = [];
+    const lights: number[] = [];
+    const mod = 97;
+
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+      lights.push((i * 7 + 3) % mod);
+    }
+
+    const start = Date.now();
+    const result = solveCounter(lights, buttons, mod);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).not.toBeNull();
+    expect(verifyCounter(lights, buttons, mod, result!)).toBe(true);
+  });
+});
