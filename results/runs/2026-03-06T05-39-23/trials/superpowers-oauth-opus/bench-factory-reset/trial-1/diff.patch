g ties.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | t] over GF(2)\n  // matrix[i] is a bigint representing row i\n  // Bits 0..numButtons-1 are the coefficients, bit numButtons is the target\n  const matrix: bigint[] = [];\n\n  for (let i = 0; i < numLights; i++) {\n    let row = 0n;\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row |= 1n << BigInt(j);\n      }\n    }\n    if (target[i]) {\n      row |= 1n << BigInt(numButtons);\n    }\n    matrix.push(row);\n  }\n\n  // Gaussian elimination\n  const pivotCol: number[] = [];\n  let currentRow = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    let pivotRow = -1;\n    for (let r = currentRow; r < numLights; r++) {\n      if ((matrix[r] >> BigInt(col)) & 1n) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    [matrix[currentRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[currentRow]];\n\n    for (let r = 0; r < numLights; r++) {\n      if (r !== currentRow && (matrix[r] >> BigInt(col)) & 1n) {\n        matrix[r] ^= matrix[currentRow];\n      }\n    }\n\n    pivotCol.push(col);\n    currentRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < numLights; r++) {\n    if ((matrix[r] >> BigInt(numButtons)) & 1n) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (!pivotSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  // If no free variables, unique solution\n  if (freeVars.length === 0) {\n    const result: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if ((matrix[r] >> BigInt(numButtons)) & 1n) {\n        result.push(pivotCol[r]);\n      }\n    }\n    return result.sort((a, b) => a - b);\n  }\n\n  const numFree = freeVars.length;\n\n  // For small number of free vars, enumerate directly\n  if (numFree <= 20) {\n    return solveToggleDirect(matrix, pivotCol, freeVars, numButtons, rank);\n  }\n\n  // For large number of free vars, use meet-in-the-middle\n  return solveToggleMITM(matrix, pivotCol, freeVars, numButtons, rank);\n}\n\nfunction solveToggleDirect(\n  matrix: bigint[],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  rank: number\n): number[] {\n  const numFree = freeVars.length;\n  const totalCombinations = 1 << numFree;\n  let bestSolution: number[] | null = null;\n  let bestCount = Infinity;\n\n  // Precompute which pivot rows are affected by each free variable (as bitmask over pivot rows)\n  const freeAffectsPivot: boolean[][] = [];\n  for (let f = 0; f < numFree; f++) {\n    const affects: boolean[] = [];\n    for (let r = 0; r < rank; r++) {\n      affects.push(!!((matrix[r] >> BigInt(freeVars[f])) & 1n));\n    }\n    freeAffectsPivot.push(affects);\n  }\n\n  // Base pivot values (when all free vars = 0)\n  const basePivotVals: number[] = [];\n  for (let r = 0; r < rank; r++) {\n    basePivotVals.push(Number((matrix[r] >> BigInt(numButtons)) & 1n));\n  }\n\n  // Use Gray code enumeration for efficiency\n  const pivotVals = [...basePivotVals];\n  let currentFreeCount = 0;\n  let currentPivotCount = pivotVals.reduce((a, b) => a + b, 0);\n\n  // Check mask=0\n  {\n    const total = currentPivotCount;\n    if (total < bestCount) {\n      bestCount = total;\n      bestSolution = buildToggleSolution(pivotCol, pivotVals, freeVars, 0, rank);\n    }\n  }\n\n  for (let mask = 1; mask < totalCombinations; mask++) {\n    // Find which bit changed (Gray code transition)\n    const changedBit = ctz(mask);\n    const bitSet = (mask >> changedBit) & 1;\n\n    // Update counts\n    if (bitSet) {\n      currentFreeCount++;\n    } else {\n      currentFreeCount--;\n    }\n\n    // Update pivot values\n    for (let r = 0; r < rank; r++) {\n      if (freeAffectsPivot[changedBit][r]) {\n        if (pivotVals[r]) {\n          pivotVals[r] = 0;\n          currentPivotCount--;\n        } else {\n          pivotVals[r] = 1;\n          currentPivotCount++;\n        }\n      }\n    }\n\n    const total = currentFreeCount + currentPivotCount;\n\n    if (total < bestCount) {\n      bestCount = total;\n      bestSolution = buildToggleSolution(pivotCol, pivotVals, freeVars, mask, rank);\n    } else if (total === bestCount) {\n      const candidate = buildToggleSolution(pivotCol, pivotVals, freeVars, mask, rank);\n      if (lexSmaller(candidate, bestSolution!)) {\n        bestSolution = candidate;\n      }\n    }\n  }\n\n  return bestSolution!;\n}\n\nfunction buildToggleSolution(\n  pivotCol: number[],\n  pivotVals: number[],\n  freeVars: number[],\n  freeMask: number,\n  rank: number\n): number[] {\n  const result: number[] = [];\n  for (let r = 0; r < rank; r++) {\n    if (pivotVals[r]) result.push(pivotCol[r]);\n  }\n  for (let f = 0; f < freeVars.length; f++) {\n    if ((freeMask >> f) & 1) result.push(freeVars[f]);\n  }\n  result.sort((a, b) => a - b);\n  return result;\n}\n\nfunction solveToggleMITM(\n  matrix: bigint[],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  rank: number\n): number[] {\n  const numFree = freeVars.length;\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n\n  // For each half-A assignment, compute:\n  // - Number of free vars set to 1\n  // - Effect on each pivot variable (XOR contribution)\n  // Key: pivot contribution signature (bitmask over rank pivot rows)\n  // Value: best (fewest free presses, lex smallest assignment)\n  //\n  // For a given half-B assignment with its own pivot contributions,\n  // the combined pivot value for row r = basePivotVal[r] XOR contribA[r] XOR contribB[r]\n  // Total = freeCountA + freeCountB + popcount(basePivot XOR contribA XOR contribB)\n  //\n  // We want to minimize total. For fixed B (fixed contribB and freeCountB),\n  // we want to minimize freeCountA + popcount(basePivot XOR contribA XOR contribB)\n  // = freeCountA + popcount((basePivot XOR contribB) XOR contribA)\n  //\n  // Let target = basePivot XOR contribB. Then we want to minimize:\n  // freeCountA + popcount(target XOR contribA)\n  //\n  // For each contribA, the \"cost\" is freeCountA + popcount(target XOR contribA).\n  // We can precompute for each contribA its cost for any target as:\n  // freeCountA + popcount(target XOR contribA)\n  //\n  // But target changes with each B. Instead, we can group by contribA and\n  // for each contribA value, store the minimum freeCountA and lex-smallest assignment.\n  // Then for each B, we compute target and find the contribA that minimizes\n  // freeCountA + popcount(target XOR contribA).\n  //\n  // Since rank <= 40, contribA is a bitmask of up to 40 bits.\n  // We have at most 2^halfA entries. For each B, we'd need to search all of them.\n  // That's 2^halfA * 2^halfB = 2^numFree, no improvement.\n  //\n  // Better approach: group contribA values by their value, keeping only the best\n  // (minimum freeCountA, lex smallest) for each contribA value.\n  // Then for each B, iterate over all unique contribA values.\n  // The number of unique contribA values <= min(2^halfA, 2^rank).\n\n  // Compute base pivot values\n  const basePivotMask = computePivotMask(matrix, numButtons, rank);\n\n  // Build table A: map from contribA (number) to {freeCount, assignment (as number mask over halfA free vars)}\n  const sizeA = 1 << halfA;\n  // contribA -> {freeCount, mask}\n  // Since we want minimum total, we need minimum freeCount for each contribA\n  // (popcount part depends on target which varies with B)\n  // Actually we need ALL freeCount values per contribA to optimize properly...\n  // No: for a given contribA value, different assignments may give different freeCounts.\n  // We want the one with minimum freeCount. Among ties, lex smallest full solution.\n\n  // But minimum freeCount is always best for any target, since:\n  // cost = freeCountA + popcount(target XOR contribA)\n  // For fixed contribA, lower freeCountA always gives lower cost.\n  // So keeping only minimum freeCountA per contribA is correct!\n\n  const tableA = new Map<number, { freeCount: number; mask: number }>();\n\n  for (let maskA = 0; maskA < sizeA; maskA++) {\n    const freeCount = popcount32(maskA);\n    const contribA = computeFreeContribToggle(matrix, freeVars, 0, halfA, maskA, rank);\n\n    const existing = tableA.get(contribA);\n    if (!existing || freeCount < existing.freeCount ||\n        (freeCount === existing.freeCount && maskA < existing.mask)) {\n      tableA.set(contribA, { freeCount, mask: maskA });\n    }\n  }\n\n  // For each half-B assignment, find the best matching half-A\n  const sizeB = 1 << halfB;\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  for (let maskB = 0; maskB < sizeB; maskB++) {\n    const freeCountB = popcount32(maskB);\n    const contribB = computeFreeContribToggle(matrix, freeVars, halfA, numFree, maskB, rank);\n    const target = basePivotMask ^ contribB;\n\n    // Find best contribA: minimize freeCountA + popcount(target XOR contribA)\n    for (const [contribA, aEntry] of tableA) {\n      const pivotCount = popcount32(target ^ contribA) + popcount32hi(target ^ contribA, rank);\n      const total = aEntry.freeCount + freeCountB + pivotCount;\n\n      if (total < bestTotal) {\n        bestTotal = total;\n        bestSolution = buildToggleSolutionMITM(\n          pivotCol, freeVars, halfA, aEntry.mask, maskB,\n          basePivotMask ^ contribA ^ contribB, rank\n        );\n      } else if (total === bestTotal) {\n        const candidate = buildToggleSolutionMITM(\n          pivotCol, freeVars, halfA, aEntry.mask, maskB,\n          basePivotMask ^ contribA ^ contribB, rank\n        );\n        if (lexSmaller(candidate, bestSolution!)) {\n          bestSolution = candidate;\n        }\n      }\n    }\n  }\n\n  return bestSolution!;\n}\n\nfunction computePivotMask(matrix: bigint[], numButtons: number, rank: number): number {\n  let mask = 0;\n  for (let r = 0; r < rank; r++) {\n    if ((matrix[r] >> BigInt(numButtons)) & 1n) {\n      mask |= (1 << r);\n    }\n  }\n  return mask;\n}\n\nfunction computeFreeContribToggle(\n  matrix: bigint[],\n  freeVars: number[],\n  startIdx: number,\n  endIdx: number,\n  mask: number,\n  rank: number\n): number {\n  let contrib = 0;\n  for (let f = startIdx; f < endIdx; f++) {\n    if ((mask >> (f - startIdx)) & 1) {\n      for (let r = 0; r < rank; r++) {\n        if ((matrix[r] >> BigInt(freeVars[f])) & 1n) {\n          contrib ^= (1 << r);\n        }\n      }\n    }\n  }\n  return contrib;\n}\n\nfunction buildToggleSolutionMITM(\n  pivotCol: number[],\n  freeVars: number[],\n  halfA: number,\n  maskA: number,\n  maskB: number,\n  pivotMask: number,\n  rank: number\n): number[] {\n  const result: number[] = [];\n  for (let r = 0; r < rank; r++) {\n    if ((pivotMask >> r) & 1) result.push(pivotCol[r]);\n  }\n  for (let f = 0; f < halfA; f++) {\n    if ((maskA >> f) & 1) result.push(freeVars[f]);\n  }\n  const numFree = freeVars.length;\n  for (let f = halfA; f < numFree; f++) {\n    if ((maskB >> (f - halfA)) & 1) result.push(freeVars[f]);\n  }\n  result.sort((a, b) => a - b);\n  return result;\n}\n\nfunction popcount32(n: number): number {\n  n = n - ((n >> 1) & 0x55555555);\n  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);\n  n = (n + (n >> 4)) & 0x0f0f0f0f;\n  return (n * 0x01010101) >> 24;\n}\n\n// For rank > 32, we'd need to handle higher bits, but rank <= 40\nfunction popcount32hi(_n: number, _rank: number): number {\n  // rank <= 40, but JS bitwise ops work on 32 bits\n  // We need to handle bits 32-39 separately\n  // For now, since rank <= 40, and we use number (which loses precision above 32 bits for bitwise),\n  // we should actually use BigInt for the pivot mask when rank > 32\n  return 0; // Placeholder - we'll fix this properly\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (i >= b.length) return false;\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return a.length < b.length;\n}\n\n/**\n * Solve the counter puzzle using Gaussian elimination over GF(p).\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | t] over GF(modulus)\n  const matrix: number[][] = [];\n\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n\n  function modInverse(a: number, p: number): number {\n    return modPow(((a % p) + p) % p, p - 2, p);\n  }\n\n  function modPow(base: number, exp: number, mod: number): number {\n    let result = 1;\n    base = base % mod;\n    while (exp > 0) {\n      if (exp & 1) {\n        result = (result * base) % mod;\n      }\n      exp >>= 1;\n      base = (base * base) % mod;\n    }\n    return result;\n  }\n\n  // Gaussian elimination\n  const pivotCol: number[] = [];\n  let currentRow = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    let pivotRow = -1;\n    for (let r = currentRow; r < numCounters; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    [matrix[currentRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[currentRow]];\n\n    const inv = modInverse(matrix[currentRow][col], modulus);\n    for (let j = 0; j <= numButtons; j++) {\n      matrix[currentRow][j] = (matrix[currentRow][j] * inv) % modulus;\n    }\n\n    for (let r = 0; r < numCounters; r++) {\n      if (r !== currentRow && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let j = 0; j <= numButtons; j++) {\n          matrix[r][j] = (((matrix[r][j] - factor * matrix[currentRow][j]) % modulus) + modulus) % modulus;\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    currentRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < numCounters; r++) {\n    if (matrix[r][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (!pivotSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  // If no free variables, unique solution\n  if (freeVars.length === 0) {\n    const result = new Array(numButtons).fill(0);\n    for (let r = 0; r < rank; r++) {\n      result[pivotCol[r]] = matrix[r][numButtons];\n    }\n    return result;\n  }\n\n  const numFree = freeVars.length;\n  const totalCombinations = Math.pow(modulus, numFree);\n\n  if (totalCombinations <= 10_000_000) {\n    return solveCounterDirect(matrix, pivotCol, freeVars, numButtons, modulus, rank);\n  }\n\n  return solveCounterMITM(matrix, pivotCol, freeVars, numButtons, modulus, rank);\n}\n\nfunction solveCounterDirect(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  modulus: number,\n  rank: number\n): number[] {\n  const numFree = freeVars.length;\n  const totalCombinations = Math.pow(modulus, numFree);\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  for (let combo = 0; combo < totalCombinations; combo++) {\n    const freeValues = new Array(numFree).fill(0);\n    let temp = combo;\n    for (let f = 0; f < numFree; f++) {\n      freeValues[f] = temp % modulus;\n      temp = Math.floor(temp / modulus);\n    }\n\n    const solution = new Array(numButtons).fill(0);\n    for (let f = 0; f < numFree; f++) {\n      solution[freeVars[f]] = freeValues[f];\n    }\n\n    for (let r = 0; r < rank; r++) {\n      let val = matrix[r][numButtons];\n      for (let f = 0; f < numFree; f++) {\n        val = (((val - matrix[r][freeVars[f]] * freeValues[f]) % modulus) + modulus) % modulus;\n      }\n      solution[pivotCol[r]] = val;\n    }\n\n    let total = 0;\n    for (let j = 0; j < numButtons; j++) {\n      total += solution[j];\n    }\n\n    if (total < bestTotal || (total === bestTotal && lexSmallerArr(solution, bestSolution!))) {\n      bestTotal = total;\n      bestSolution = [...solution];\n    }\n  }\n\n  return bestSolution!;\n}\n\nfunction solveCounterMITM(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  modulus: number,\n  rank: number\n): number[] {\n  const numFree = freeVars.length;\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n\n  // For the meet-in-the-middle approach:\n  // pivot_val[r] = (matrix[r][numButtons] - contribA[r] - contribB[r]) mod p\n  // where contribA[r] = sum(matrix[r][freeVars[f]] * freeA[f]) for f in halfA\n  //       contribB[r] = sum(matrix[r][freeVars[halfA+f]] * freeB[f]) for f in halfB\n  //\n  // total = sum(freeA) + sum(freeB) + sum(pivot_vals)\n  //\n  // For fixed B, the needed contribA[r] values are determined to get specific pivot vals.\n  // But pivot vals contribute to total, so we can't fix them in advance.\n  //\n  // Alternative: encode contribA as a vector mod p (up to rank entries).\n  // For each contribA signature, store the minimum sum(freeA).\n  // Then for each B, we need to find the contribA signature that minimizes:\n  //   sum(freeA) + sum((baseVal[r] - contribA[r] - contribB[r]) mod p for all r)\n  //\n  // This doesn't decompose nicely. But we can still enumerate:\n  // For each B combination, for each unique contribA signature, compute total.\n  // #unique contribA signatures <= p^rank, but also <= sizeA.\n  // sizeA = p^halfA. If halfA < rank, then #unique signatures = sizeA (all different potentially).\n  // So we iterate sizeA * sizeB = p^numFree... back to brute force.\n  //\n  // We need a different decomposition. Let's think about it differently.\n  //\n  // Actually, the key insight: for meet-in-the-middle, we group by contribA vector.\n  // For a given B, we compute the \"needed\" contribution for each contribA to get\n  // pivot vals. But we don't pick a specific contribA to match -- instead we just\n  // need to iterate over all contribA entries and compute the total.\n  //\n  // The saving comes when many A assignments map to the same contribA signature.\n  // We only keep the best A per signature, reducing the inner loop.\n  // #unique signatures <= min(sizeA, p^rank).\n  // With rank up to 40 and p up to 97, p^rank can be huge.\n  // But sizeA = p^halfA, and halfA ~ numFree/2.\n  // If numFree = 10 and p = 97, sizeA = 97^5 ~ 8.6 billion -- too large.\n  //\n  // Hmm. Let me reconsider. With 40 buttons and 40 counters, rank = 40,\n  // numFree = 0. The free variables only appear when we have more buttons than\n  // independent equations. With 40 lights constraining 40 buttons, if the system\n  // has full rank, numFree = 0.\n  //\n  // But we could have rank < numButtons if buttons are linearly dependent.\n  // In the worst case: 40 buttons, 0 lights, rank = 0, numFree = 40.\n  // With modulus 97, that's 97^40 -- no algorithm can enumerate this.\n  //\n  // But wait: if rank = 0 (no constraints), then ALL pivot values are zero,\n  // and we just need to minimize sum of free variable values.\n  // Each free variable independently contributes, and the minimum is when\n  // each is set to 0. So the answer is all zeros.\n  //\n  // More generally, if there are no pivot variables depending on the free variables,\n  // the minimum is always to set free variables to 0.\n  //\n  // If there ARE pivot variables, eac