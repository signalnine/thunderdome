esent buttons, last column is target\n  // We use bit manipulation with BigInt for efficiency\n\n  // matrix[i] is a bigint representing row i\n  // Bits 0..numButtons-1 are the coefficients, bit numButtons is the target\n  const matrix: bigint[] = [];\n\n  for (let i = 0; i < numLights; i++) {\n    let row = 0n;\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row |= 1n << BigInt(j);\n      }\n    }\n    if (target[i]) {\n      row |= 1n << BigInt(numButtons);\n    }\n    matrix.push(row);\n  }\n\n  // Gaussian elimination with partial pivoting\n  // pivotCol[r] = column index of pivot in row r\n  const pivotCol: number[] = [];\n  let currentRow = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    // Find pivot row\n    let pivotRow = -1;\n    for (let r = currentRow; r < numLights; r++) {\n      if ((matrix[r] >> BigInt(col)) & 1n) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    // Swap rows\n    [matrix[currentRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[currentRow]];\n\n    // Eliminate column from all other rows\n    for (let r = 0; r < numLights; r++) {\n      if (r !== currentRow && (matrix[r] >> BigInt(col)) & 1n) {\n        matrix[r] ^= matrix[currentRow];\n      }\n    }\n\n    pivotCol.push(col);\n    currentRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency: any row with all zero coefficients but non-zero target\n  for (let r = rank; r < numLights; r++) {\n    if ((matrix[r] >> BigInt(numButtons)) & 1n) {\n      return null; // No solution\n    }\n  }\n\n  // Identify free variables (columns not in pivotCol)\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (!pivotSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  // If no free variables, there's exactly one solution\n  if (freeVars.length === 0) {\n    const result: number[] = [];\n    for (let