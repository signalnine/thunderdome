;\n      // Subtract contributions of free variables\n      for (let f = 0; f < numFree; f++) {\n        if ((matrix[r] >> BigInt(freeVars[f])) & 1n) {\n          val ^= freeValues.get(freeVars[f])!;\n        }\n      }\n      if (val) {\n        solution.push(pivotCol[r]);\n      }\n    }\n\n    solution.sort((a, b) => a - b);\n\n    if (\n      solution.length < bestCount ||\n      (solution.length === bestCount && lexSmaller(solution, bestSolution!))\n    ) {\n      bestCount = solution.length;\n      bestSolution = solution;\n    }\n  }\n\n  return bestSolution;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\n/**\n * Solve the counter puzzle using Gaussian elimination over GF(p).\n *\n * For each counter i: sum of x_j for all buttons j that affect counter i ≡ lights[i] (mod p)\n *\n * We want the solution with minimum total presses (sum of x_j),\n * and lexicographically smallest among ties.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | t] over GF(modulus)\n  // matrix[i][j] = coefficient of button j in equation for counter i\n  // matrix[i][numButtons] = target value for counter i\n  const matrix: number[][] = [];\n\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n\n  // Compute modular inverse using Fermat's little theorem (p is prime)\n  function modInverse(a: number, p: number): number {\n    return modPow(((a % p) + p) % p, p - 2, p);\n  }\n\n  function modPow(base: