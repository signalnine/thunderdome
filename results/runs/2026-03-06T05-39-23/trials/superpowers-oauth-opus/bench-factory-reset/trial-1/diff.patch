   for (let r = currentRow; r < numLights; r++) {\n    51→      if ((matrix[r] >> BigInt(col)) & 1n) {\n    52→        pivotRow = r;\n    53→        break;\n    54→      }\n    55→    }\n    56→    if (pivotRow === -1) continue;\n    57→\n    58→    // Swap rows\n    59→    [matrix[currentRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[currentRow]];\n    60→\n    61→    // Eliminate column from all other rows\n    62→    for (let r = 0; r < numLights; r++) {\n    63→      if (r !== currentRow && (matrix[r] >> BigInt(col)) & 1n) {\n    64→        matrix[r] ^= matrix[currentRow];\n    65→      }\n    66→    }\n    67→\n    68→    pivotCol.push(col);\n    69→    currentRow++;\n    70→  }\n    71→\n    72→  const rank = pivotCol.length;\n    73→\n    74→  // Check for inconsistency: any row with all zero coefficients but non-zero target\n    75→  for (let r = rank; r < numLights; r++) {\n    76→    if ((matrix[r] >> BigInt(numButtons)) & 1n) {\n    77→      return null; // No solution\n    78→    }\n    79→  }\n    80→\n    81→  // Identify free variables (columns not in pivotCol)\n    82→  const pivotSet = new Set(pivotCol);\n    83→  const freeVars: number[] = [];\n    84→  for (let j = 0; j < numButtons; j++) {\n    85→    if (!pivotSet.has(j)) {\n    86→      freeVars.push(j);\n    87→    }\n    88→  }\n    89→\n    90→  // If no free variables, there's exactly one solution\n    91→  if (freeVars.length === 0) {\n    92→    const result: number[] = [];\n    93→    for (let r = 0; r < rank; r++) {\n    94→      if ((matrix[r] >> BigInt(numButtons)) & 1n) {\n    95→        result.push(pivotCol[r]);\n    96→      }\n    97→    }\n    98→    return result.sort((a, b) => a - b);\n    99→  }\n   100→\n   101→  // With free variables, enumerate all 2^freeVars.length combinations\n   102→  // to find minimum presses, then lexicographically smallest\n   103→  let bestSolution: number[] | null = null;\n   104→  let bestCount = Infinity;\n   105→\n   106→  const numFree = 