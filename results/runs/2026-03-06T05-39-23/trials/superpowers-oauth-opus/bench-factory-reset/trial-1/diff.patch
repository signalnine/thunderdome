ution\n    const result = solveToggle({\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('should solve a simple single-button case', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should find minimum button presses', () => {\n    // 2 lights, both need to be on\n    // Button 0: toggles light 0\n    // Button 1: toggles light 1\n    // Button 2: toggles both lights 0 and 1\n    // Solutions: {0,1} (2 presses) or {2} (1 press)\n    // Minimum is {2}\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0], [1], [0, 1]],\n    });\n    expect(result).toEqual([2]);\n  });\n\n  it('should return lexicographically smallest on tie', () => {\n    // 2 lights, target: [true, false]\n    // Button 0: toggles light 0\n    // Button 1: toggles light 0\n    // Both {0} and {1} are valid with 1 press each\n    // Lexicographically smallest: [0]\n    const result = solveToggle({\n      target: [true, false],\n      buttons: [[0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle larger cases', () => {\n    // 4 lights, target: [true, false, true, false]\n    // Button 0: toggles [0, 2]\n    // Button 1: toggles [1, 3]\n    // Button 2: toggles [0, 1, 2, 3]\n    // Solution: {0} toggles [0,2] -> [on, off, on, off] = target!\n    const result = solveToggle({\n      target: [true, false, true, false],\n      buttons: [[0, 2], [1, 3], [0, 1, 2, 3]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle no buttons case', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('should handle no buttons with all-off target', () => {\n    const result = solveToggle({\n      target: [false, false],\n      buttons: [],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('should handle overlapping buttons', () => {\n    // 3 lights, target: [true, true, true]\n    // Button 0: [0, 1]\n    // Button 1: [1, 2]\n    // Button 2: [0, 2]\n    // Pressing all three: each light toggled exactly twice = off. Not solution.\n    // Pressing 0 and 1: [on, off, on] - no\n    // Pressing 0 and 2: [off, on, on] - no\n    // Pressing 1 and 2: [on, on, off] - no\n    // Pressing just 0: [on, on, off] - no\n    // Pressing just 1: [off, on, on] - no\n    // Pressing just 2: [on, off, on] - no\n    // No single or double combo works... let's check all three:\n    // 0+1+2: light 0 toggled by 0,2 = 2 times (off), light 1 toggled by 0,1 = 2 times (off), light 2 toggled by 1,2 = 2 times (off)\n    // So all three = all off. No solution exists.\n    const result = solveToggle({\n      target: [true, true, true],\n      buttons: [[0, 1], [1, 2], [0, 2]],\n    });\n    expect(result).toBeNull();\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('should return all zeros when target is all zeros', () => {\n    const result = solveCounter([0, 0, 0], [[0], [1], [2]], 5);\n    expect(result).toEqual([0, 0, 0]);\n  });\n\n  it('should solve a simple single-button case', () => {\n    // Counter 0 needs value 3, button 0 increments counter 0\n    // Press button 0 three times\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('should handle modular arithmetic', () => {\n    // Counter 0 needs value 0, button 0 increments counter 0\n    // Modulus 5: pressing 0 times gives 0, pressing 5 times gives 0\n    // Minimum total: 0\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('should return null when no solution exists', () => {\n    // Counter 0 needs value 1, but no buttons affect it\n    const result = solveCounter([1, 0], [[1]], 5);\n    expect(result).toBeNull();\n  });\n\n  it('should find minimum total presses', () => {\n    // 1 counter needs value 1, mod 5\n    // Button 0: affects counter 0\n    // Button 1: affects counter 0\n    // Solutions: x0 + x1 ≡ 1 (mod 5)\n    // Minimum total: x0 + x1 where x0 + x1 ≡ 1 (mod 5)\n    // Best: x0=1, x1=0 (total=1) or x0=0, x1=1 (total=1)\n    // Lex smallest: [0, 1]\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('should return lexicographically smallest on tie', () => {\n    // 2 counters, targets [1, 1], mod 3\n    // Button 0: affects counter 0\n    // Button 1: affects counter 1\n    // Unique solution: [1, 1]\n    const result = solveCounter([1, 1], [[0], [1]], 3);\n    expect(result).toEqual([1, 1]);\n  });\n\n  it('should handle multiple buttons affecting same counter', () => {\n    // 1 counter needs value 2, mod 7\n    // Button 0: affects counter 0\n    // Button 1: affects counter 0\n    // x0 + x1 ≡ 2 (mod 7), minimize x0 + x1\n    // Minimum total = 2: (0,2), (1,1), (2,0)\n    // Lex smallest: [0, 2]\n    const result = solveCounter([2], [[0], [0]], 7);\n    expect(result).toEqual([0, 2]);\n  });\n\n  it('should handle no buttons with zero target', () => {\n    const result = solveCounter([0], [], 5);\n    expect(result).toEqual([]);\n  });\n\n  it('should handle no buttons with non-zero target', () => {\n    const result = solveCounter([1], [], 5);\n    expect(result).toBeNull();\n  });\n});\n"}}
