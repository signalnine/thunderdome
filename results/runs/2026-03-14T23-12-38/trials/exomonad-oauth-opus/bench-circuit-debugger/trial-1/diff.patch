index 0000000..dfc2ef4
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,205 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (changed && remaining.length > 0) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND': wires[gate.out] = a & b; break;
+          case 'OR':  wires[gate.out] = a | b; break;
+          case 'XOR': wires[gate.out] = a ^ b; break;
+        }
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Build lookup structures
+  const gateByOut = new Map<string, Gate>();
+  for (const g of gates) {
+    gateByOut.set(g.out, g);
+  }
+
+  // Find the number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2, g.out]) {
+      const m = w.match(/^[xyz](\d+)$/);
+      if (m) {
+        const n = parseInt(m[1]);
+        if (n > maxBit) maxBit = n;
+      }
+    }
+  }
+
+  // Helper: find gate by op and inputs (order-independent)
+  function findGate(op: Gate['op'], in1: string, in2: string): Gate | undefined {
+    for (const g of gates) {
+      if (g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) || (g.in1 === in2 && g.in2 === in1))) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  // For a correct ripple-carry adder:
+  // Bit 0: z00 = x00 XOR y00, c00 = x00 AND y00
+  // Bit i (i>0): ti = xi XOR yi, zi = ti XOR c(i-1), ai = xi AND yi, bi = ti AND c(i-1), ci = ai OR bi
+  // Last z bit = last carry
+  //
+  // Strategy: walk through the adder structure bit by bit, identifying what each wire
+  // *should* be, and detecting when an output is wrong (swapped).
+
+  const swapped = new Set<string>();
+
+  // We'll track the carry wire name for each bit
+  let carry = '';
+
+  for (let i = 0; i <= maxBit; i++) {
+    const xi = `x${i.toString().padStart(2, '0')}`;
+    const yi = `y${i.toString().padStart(2, '0')}`;
+    const zi = `z${i.toString().padStart(2, '0')}`;
+
+    if (i === 0) {
+      // Bit 0: z00 = x00 XOR y00
+      const xorGate = findGate('XOR', xi, yi);
+      if (xorGate && xorGate.out !== zi) {
+        // z00 output is swapped with something
+        swapped.add(xorGate.out);
+        swapped.add(zi);
+        swapOutputs(xorGate.out, zi);
+      }
+      // c00 = x00 AND y00
+      const andGate = findGate('AND', xi, yi);
+      carry = andGate!.out;
+    } else {
+      // ti = xi XOR yi
+      const xorGate = findGate('XOR', xi, yi);
+      if (!xorGate) continue;
+      let ti = xorGate.out;
+
+      // ai = xi AND yi
+      const andGate = findGate('AND', xi, yi);
+      if (!andGate) continue;
+      let ai = andGate.out;
+
+      // zi = ti XOR carry
+      let sumGate = findGate('XOR', ti, carry);
+
+      if (!sumGate) {
+        // One of ti or carry might be swapped.
+        // Check if there's an XOR gate using carry - then ti is wrong
+        // Check if there's an XOR gate using ti - then carry is wrong
+        // Or check what gate outputs zi - and figure out what's wrong from there
+
+        // Look at what gate produces zi
+        const ziGate = gateByOut.get(zi);
+        if (ziGate && ziGate.op === 'XOR') {
+          // One of ziGate's inputs should be carry, the other should be ti
+          // If one matches carry, then ti is swapped
+          if (ziGate.in1 === carry || ziGate.in2 === carry) {
+            const correctTi = ziGate.in1 === carry ? ziGate.in2 : ziGate.in1;
+            swapped.add(ti);
+            swapped.add(correctTi);
+            swapOutputs(ti, correctTi);
+            ti = correctTi;
+          } else if (ziGate.in1 === ti || ziGate.in2 === ti) {
+            const correctCarry = ziGate.in1 === ti ? ziGate.in2 : ziGate.in1;
+            swapped.add(carry);
+            swapped.add(correctCarry);
+            swapOutputs(carry, correctCarry);
+            carry = correctCarry;
+          }
+          sumGate = ziGate;
+        } else {
+          // ziGate isn't an XOR, so zi itself might be swapped
+          // Try finding the XOR gate that uses both ti and carry
+          // It must exist but output something other than zi
+          // Actually let's search for any XOR that has carry as input
+          const candidates = gates.filter(g => g.op === 'XOR' && (g.in1 === carry || g.in2 === carry));
+          if (candidates.length === 1) {
+            const cand = candidates[0];
+            const otherIn = cand.in1 === carry ? cand.in2 : cand.in1;
+            if (otherIn !== ti) {
+              // ti is swapped
+              swapped.add(ti);
+              swapped.add(otherIn);
+              swapOutputs(ti, otherIn);
+              ti = otherIn;
+            }
+            sumGate = cand;
+          }
+        }
+      }
+
+      if (sumGate && sumGate.out !== zi) {
+        // The sum gate's output should be zi but it's swapped
+        const oldSumOut = sumGate.out;
+        swapped.add(oldSumOut);
+        swapped.add(zi);
+        swapOutputs(oldSumOut, zi);
+        // After swap, re-lookup ai since it might have been zi
+        if (ai === zi) {
+          ai = oldSumOut;
+        }
+      }
+
+      // bi = ti AND carry
+      const propGate = findGate('AND', ti, carry);
+      const bi = propGate ? propGate.out : '';
+
+      // ci = ai OR bi
+      let carryGate = findGate('OR', ai, bi);
+      if (!carryGate && bi) {
+        // ai might be swapped - look for OR gate with bi
+        const orCandidates = gates.filter(g => g.op === 'OR' && (g.in1 === bi || g.in2 === bi));
+        if (orCandidates.length === 1) {
+          const cand = orCandidates[0];
+          const correctAi = cand.in1 === bi ? cand.in2 : cand.in1;
+          if (correctAi !== ai) {
+            swapped.add(ai);
+            swapped.add(correctAi);
+            swapOutputs(ai, correctAi);
+            ai = correctAi;
+          }
+          carryGate = cand;
+        }
+      }
+
+      carry = carryGate ? carryGate.out : '';
+    }
+  }
+
+  return [...swapped].sort();
+
+  function swapOutputs(a: string, b: string): void {
+    const gateA = gateByOut.get(a);
+    const gateB = gateByOut.get(b);
+    if (gateA) gateA.out = b;
+    if (gateB) gateB.out = a;
+    // Update the lookup map
+    if (gateA) gateByOut.set(b, gateA);
+    if (gateB) gateByOut.set(a, gateB);
+    if (!gateA) gateByOut.delete(b);
+    if (!gateB) gateByOut.delete(a);
+  }
+}
diff --git a/tests/index.test.ts b/tests/index.test.ts
new file mode 100644
index 0000000..0229f87
--- /dev/null
+++ b/tests/index.test.ts
@@ -0,0 +1,138 @@
+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from '../src/index.js';
+
+describe('simulate', () => {
+  it('should simulate basic gates', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'a', in2: 'b', out: 'd' },
+      { op: 'XOR', in1: 'a', in2: 'b', out: 'e' },
+    ];
+    const result = simulate(gates, { a: 1, b: 0 });
+    expect(result.c).toBe(0);
+    expect(result.d).toBe(1);
+    expect(result.e).toBe(1);
+  });
+
+  it('should handle dependency chains', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x', in2: 'y', out: 'mid' },
+      { op: 'AND', in1: 'mid', in2: 'z', out: 'out' },
+    ];
+    const result = simulate(gates, { x: 1, y: 0, z: 1 });
+    expect(result.mid).toBe(1);
+    expect(result.out).toBe(1);
+  });
+
+  it('should simulate a correct 4-bit adder (2+3=5)', () => {
+    const gates: Gate[] = [
+      // Bit 0
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+      // Bit 2
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },
+      // Bit 3
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },
+      // Final carry
+      { op: 'OR', in1: 'c03', in2: 'c03', out: 'z04' }, // hack: just pass c03 through
+    ];
+    // Actually z04 should just be c03. Let me fix - use an identity gate isn't possible.
+    // The spec says c03 -> z04 but we can't have a direct wire. In a real circuit,
+    // z04 is just the last carry. Let's adjust: remove the last gate and just rename c03 -> z04
+    const gatesFixed: Gate[] = [
+      // Bit 0
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+      // Bit 2
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },
+      // Bit 3
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' }, // last carry IS z04
+    ];
+
+    // 2 = 0010, 3 = 0011, sum = 5 = 00101
+    const inputs: Record<string, number> = {
+      x00: 0, x01: 1, x02: 0, x03: 0, // 2
+      y00: 1, y01: 1, y02: 0, y03: 0, // 3
+    };
+    const result = simulate(gatesFixed, inputs);
+    expect(result.z00).toBe(1); // 5 = 0101
+    expect(result.z01).toBe(0);
+    expect(result.z02).toBe(1);
+    expect(result.z03).toBe(0);
+    expect(result.z04).toBe(0);
+  });
+});
+
+describe('findSwappedWires', () => {
+  it('should find swapped wires in a 4-bit adder', () => {
+    // Correct 4-bit adder, then swap 4 pairs
+    const gates: Gate[] = [
+      // Bit 0
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },
+      // Bit 2
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },
+      // Bit 3
+      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },
+    ];
+
+    // Swap 4 pairs (must not create dependency cycles):
+    // Swap 1: z00 <-> z01
+    gates[0].out = 'z01';  // was z00
+    gates[3].out = 'z00';  // was z01
+    // Swap 2: z02 <-> z03
+    gates[8].out = 'z03';  // was z02
+    gates[13].out = 'z02'; // was z03
+    // Swap 3: a01 <-> c00
+    gates[4].out = 'c00';  // was a01
