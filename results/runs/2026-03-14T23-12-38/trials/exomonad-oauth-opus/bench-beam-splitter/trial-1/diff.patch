diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..bd95ba2
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,120 @@
+type Dir = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Dir;
+}
+
+function step(dir: Dir): [number, number] {
+  switch (dir) {
+    case 'down': return [1, 0];
+    case 'down-left': return [1, -1];
+    case 'down-right': return [1, 1];
+  }
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+
+  // Find source
+  let sourceCol = -1;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      sourceCol = c;
+      break;
+    }
+  }
+  if (sourceCol === -1) return 0;
+
+  const visited = new Set<number>();
+  visited.add(0 * cols + sourceCol); // source cell
+
+  const beams: Beam[] = [{ row: 0, col: sourceCol, dir: 'down' }];
+
+  while (beams.length > 0) {
+    const next: Beam[] = [];
+    for (const beam of beams) {
+      const [dr, dc] = step(beam.dir);
+      const nr = beam.row + dr;
+      const nc = beam.col + dc;
+
+      if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) continue;
+
+      visited.add(nr * cols + nc);
+
+      if (grid[nr][nc] === '^') {
+        next.push({ row: nr, col: nc, dir: 'down-left' });
+        next.push({ row: nr, col: nc, dir: 'down-right' });
+      } else {
+        next.push({ row: nr, col: nc, dir: beam.dir });
+      }
+    }
+    beams.length = 0;
+    beams.push(...next);
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+
+  // Find source
+  let sourceCol = -1;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      sourceCol = c;
+      break;
+    }
+  }
+  if (sourceCol === -1) return 0n;
+
+  // Track beam counts per (row, col, dir) to avoid enumerating paths.
+  // We use a map from state to count of beams in that state.
+  type State = string; // `${row},${col},${dir}`
+
+  let current = new Map<State, bigint>();
+  current.set(`0,${sourceCol},down`, 1n);
+
+  let totalPaths = 0n;
+
+  while (current.size > 0) {
+    const next = new Map<State, bigint>();
+
+    for (const [state, count] of current) {
+      const parts = state.split(',');
+      const row = parseInt(parts[0]);
+      const col = parseInt(parts[1]);
+      const dir = parts[2] as Dir;
+
+      const [dr, dc] = step(dir);
+      const nr = row + dr;
+      const nc = col + dc;
+
+      if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+        // Beam exits grid — counts as a completed path
+        totalPaths += count;
+        continue;
+      }
+
+      if (grid[nr][nc] === '^') {
+        const keyL = `${nr},${nc},down-left`;
+        const keyR = `${nr},${nc},down-right`;
+        next.set(keyL, (next.get(keyL) ?? 0n) + count);
+        next.set(keyR, (next.get(keyR) ?? 0n) + count);
+      } else {
+        const key = `${nr},${nc},${dir}`;
+        next.set(key, (next.get(key) ?? 0n) + count);
+      }
+    }
+
+    current = next;
+  }
+
+  return totalPaths;
+}
