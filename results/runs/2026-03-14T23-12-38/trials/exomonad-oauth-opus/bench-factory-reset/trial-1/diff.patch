index 0000000..650c885
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,552 @@
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function popcount(n: bigint): number {
+  let count = 0;
+  while (n) {
+    n &= n - 1n;
+    count++;
+  }
+  return count;
+}
+
+// For same-weight bitmasks: lower differing bit set = lex-smaller sorted index set
+function lexSmallerMask(a: bigint, b: bigint): boolean {
+  const diff = a ^ b;
+  if (diff === 0n) return false;
+  const lowestDiff = diff & (-diff);
+  return (a & lowestDiff) !== 0n;
+}
+
+function bitmaskToArray(mask: bigint, maxBit: number): number[] {
+  const result: number[] = [];
+  for (let i = 0; i < maxBit; i++) {
+    if (mask & (1n << BigInt(i))) {
+      result.push(i);
+    }
+  }
+  return result;
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  if (m === 0) {
+    return target.every(t => !t) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(2) using BigInt bitmasks
+  const rows: bigint[] = [];
+  for (let i = 0; i < n; i++) {
+    let row = 0n;
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row |= 1n << BigInt(j);
+      }
+    }
+    if (target[i]) {
+      row |= 1n << BigInt(m);
+    }
+    rows.push(row);
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotCols: number[] = [];
+  let rank = 0;
+
+  for (let col = 0; col < m; col++) {
+    const colBit = 1n << BigInt(col);
+    let pivotR = -1;
+    for (let row = rank; row < n; row++) {
+      if (rows[row] & colBit) {
+        pivotR = row;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    [rows[rank], rows[pivotR]] = [rows[pivotR], rows[rank]];
+    pivotCols.push(col);
+
+    for (let row = 0; row < n; row++) {
+      if (row !== rank && (rows[row] & colBit)) {
+        rows[row] ^= rows[rank];
+      }
+    }
+    rank++;
+  }
+
+  // Check consistency
+  const targetBit = 1n << BigInt(m);
+  for (let row = rank; row < n; row++) {
+    if (rows[row] & targetBit) return null;
+  }
+
+  // Identify free variables
+  const pivotColSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let col = 0; col < m; col++) {
+    if (!pivotColSet.has(col)) freeVars.push(col);
+  }
+
+  const k = freeVars.length;
+
+  // Compute particular solution (all free vars = 0)
+  let base = 0n;
+  for (let r = 0; r < rank; r++) {
+    if (rows[r] & targetBit) {
+      base |= 1n << BigInt(pivotCols[r]);
+    }
+  }
+
+  // Compute null space basis vectors
+  const nullBasis: bigint[] = [];
+  for (let j = 0; j < k; j++) {
+    let vec = 1n << BigInt(freeVars[j]);
+    for (let r = 0; r < rank; r++) {
+      if (rows[r] & (1n << BigInt(freeVars[j]))) {
+        vec |= 1n << BigInt(pivotCols[r]);
+      }
+    }
+    nullBasis.push(vec);
+  }
+
+  if (k <= 25) {
+    return grayCodeEnumerate(base, nullBasis, k, m);
+  } else {
+    // k > 25 implies rank < 15. Enumerate over pivot configurations.
+    return pivotEnumerate(rows, rank, pivotCols, freeVars, base, m);
+  }
+}
+
+function grayCodeEnumerate(base: bigint, nullBasis: bigint[], k: number, m: number): number[] {
+  let bestWeight = popcount(base);
+  let bestSol = base;
+
+  if (k > 0) {
+    let sol = base;
+    const total = 1 << k;
+    for (let i = 1; i < total; i++) {
+      const bit = 31 - Math.clz32(i & -i);
+      sol ^= nullBasis[bit];
+      const w = popcount(sol);
+      if (w < bestWeight || (w === bestWeight && lexSmallerMask(sol, bestSol))) {
+        bestWeight = w;
+        bestSol = sol;
+      }
+    }
+  }
+
+  return bitmaskToArray(bestSol, m);
+}
+
+function pivotEnumerate(
+  rows: bigint[], rank: number, pivotCols: number[],
+  freeVars: number[], base: bigint, m: number
+): number[] {
+  const r = rank;
+  const k = freeVars.length;
+
+  // Build inner matrix M (r rows, k cols) and augment with r identity cols
+  // M[i][j] = 1 if original RREF row i has coefficient for freeVars[j]
+  const innerAug: number[][] = [];
+  for (let i = 0; i < r; i++) {
+    const row: number[] = [];
+    for (let j = 0; j < k; j++) {
+      row.push((rows[i] & (1n << BigInt(freeVars[j]))) ? 1 : 0);
+    }
+    // Augment with identity for transformation tracking
+    for (let j = 0; j < r; j++) {
+      row.push(i === j ? 1 : 0);
+    }
+    innerAug.push(row);
+  }
+
+  // GE on inner matrix (first k columns) over GF(2)
+  const innerPivotCols: number[] = [];
+  let innerRank = 0;
+
+  for (let col = 0; col < k; col++) {
+    let pivotR = -1;
+    for (let row = innerRank; row < r; row++) {
+      if (innerAug[row][col]) {
+        pivotR = row;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    [innerAug[innerRank], innerAug[pivotR]] = [innerAug[pivotR], innerAug[innerRank]];
+    innerPivotCols.push(col);
+
+    for (let row = 0; row < r; row++) {
+      if (row !== innerRank && innerAug[row][col]) {
+        for (let c = 0; c < k + r; c++) {
+          innerAug[row][c] ^= innerAug[innerRank][c];
+        }
+      }
+    }
+    innerRank++;
+  }
+
+  // basePivots[i] = whether base has pivotCols[i] set
+  const basePivots: number[] = [];
+  for (let i = 0; i < r; i++) {
+    basePivots.push((base & (1n << BigInt(pivotCols[i]))) ? 1 : 0);
+  }
+
+  let bestWeight = m + 1;
+  let bestSol = 0n;
+
+  for (let dMask = 0; dMask < (1 << r); dMask++) {
+    // b[i] = basePivots[i] XOR d[i], where d[i] = (dMask >> i) & 1
+    // Check consistency: for rows innerRank..r-1, P*b must be 0
+    let consistent = true;
+    for (let row = innerRank; row < r; row++) {
+      let val = 0;
+      for (let i = 0; i < r; i++) {
+        const b_i = basePivots[i] ^ ((dMask >> i) & 1);
+        if (innerAug[row][k + i] && b_i) val ^= 1;
+      }
+      if (val) { consistent = false; break; }
+    }
+    if (!consistent) continue;
+
+    // Compute free button presses from inner pivot variables
+    let sol = 0n;
+    for (let row = 0; row < innerRank; row++) {
+      let val = 0;
+      for (let i = 0; i < r; i++) {
+        const b_i = basePivots[i] ^ ((dMask >> i) & 1);
+        if (innerAug[row][k + i] && b_i) val ^= 1;
+      }
+      if (val) {
+        sol |= 1n << BigInt(freeVars[innerPivotCols[row]]);
+      }
+    }
+
+    // Add pivot buttons from d
+    for (let i = 0; i < r; i++) {
+      if ((dMask >> i) & 1) {
+        sol |= 1n << BigInt(pivotCols[i]);
+      }
+    }
+
+    const w = popcount(sol);
+    if (w < bestWeight || (w === bestWeight && lexSmallerMask(sol, bestSol))) {
+      bestWeight = w;
+      bestSol = sol;
+    }
+  }
+
+  return bitmaskToArray(bestSol, m);
+}
+
+function modPow(base: number, exp: number, mod: number): number {
+  let result = 1;
+  base = ((base % mod) + mod) % mod;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % mod;
+    exp >>= 1;
+    base = (base * base) % mod;
+  }
+  return result;
+}
+
+function modInverse(a: number, p: number): number {
+  return modPow(a, p - 2, p);
+}
+
+function lexSmallerArray(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+
+  if (m === 0) {
+    return lights.every(v => ((v % modulus) + modulus) % modulus === 0) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(modulus)
+  const matrix: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[m] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(modulus)
+  const pivotCols: number[] = [];
+  let rank = 0;
+
+  for (let col = 0; col < m; col++) {
+    let pivotR = -1;
+    for (let row = rank; row < n; row++) {
+      if (matrix[row][col] !== 0) {
+        pivotR = row;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    [matrix[rank], matrix[pivotR]] = [matrix[pivotR], matrix[rank]];
+
+    const inv = modInverse(matrix[rank][col], modulus);
+    for (let c = 0; c <= m; c++) {
+      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;
+    }
+
+    pivotCols.push(col);
+
+    for (let row = 0; row < n; row++) {
+      if (row !== rank && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let c = 0; c <= m; c++) {
+          matrix[row][c] = (((matrix[row][c] - factor * matrix[rank][c]) % modulus) + modulus) % modulus;
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Check consistency
+  for (let row = rank; row < n; row++) {
+    if (matrix[row][m] !== 0) return null;
+  }
+
+  // Free variables
+  const pivotColSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let col = 0; col < m; col++) {
+    if (!pivotColSet.has(col)) freeVars.push(col);
+  }
+
+  const k = freeVars.length;
+
+  // Extract coefficients for pivot computation
+  const pivotTarget: number[] = [];
+  const pivotCoeffs: number[][] = [];
+  for (let r = 0; r < rank; r++) {
+    pivotTarget.push(matrix[r][m]);
+    const coeffs: number[] = [];
+    for (let j = 0; j < k; j++) {
+      coeffs.push(matrix[r][freeVars[j]]);
+    }
+    pivotCoeffs.push(coeffs);
+  }
+
+  if (k <= 4 || (k <= 6 && modulus <= 7)) {
+    return counterEnumerate(pivotTarget, pivotCoeffs, pivotCols, freeVars, k, m, rank, modulus);
+  } else {
+    // For large k: enumerate over desired pivot values (modulus^rank configs)
+    return counterPivotEnumerate(matrix, pivotTarget, pivotCoeffs, pivotCols, freeVars, k, m, rank, modulus);
+  }
+}
+
+function counterEnumerate(
+  pivotTarget: number[], pivotCoeffs: number[][], pivotCols: number[],
+  freeVars: number[], k: number, m: number, rank: number, modulus: number
+): number[] | null {
+  let bestCost = Infinity;
+  let bestResult: number[] | null = null;
+
+  const freeValues = new Array(k).fill(0);
+  const totalCombinations = k === 0 ? 1 : Math.pow(modulus, k);
+
+  for (let iter = 0; iter < totalCombinations; iter++) {
+    const result = new Array(m).fill(0);
+    let cost = 0;
+
+    for (let j = 0; j < k; j++) {
+      result[freeVars[j]] = freeValues[j];
+      cost += freeValues[j];
+    }
+
+    if (cost >= bestCost) {
+      // Increment and skip
+      if (k > 0) incrementBase(freeValues, k, modulus);
+      continue;
+    }
+
+    for (let r = 0; r < rank; r++) {
+      let val = pivotTarget[r];
+      for (let j = 0; j < k; j++) {
+        val -= pivotCoeffs[r][j] * freeValues[j];
+      }
+      val = ((val % modulus) + modulus) % modulus;
+      result[pivotCols[r]] = val;
+      cost += val;
+    }
+
+    if (cost < bestCost || (cost === bestCost && lexSmallerArray(result, bestResult!))) {
+      bestCost = cost;
+      bestResult = result.slice();
+    }
+
+    if (k > 0) incrementBase(freeValues, k, modulus);
+  }
+
+  return bestResult;
+}
+
+function incrementBase(values: number[], k: number, base: number): void {
+  for (let j = k - 1; j >= 0; j--) {
+    values[j]++;
+    if (values[j] < base) return;
+    values[j] = 0;
+  }
+}
+
+function counterPivotEnumerate(
+  matrix: number[][], pivotTarget: number[], pivotCoeffs: number[][],
+  pivotCols: number[], freeVars: number[], k: number, m: number,
+  rank: number, modulus: number
+): number[] | null {
+  // For large k with small rank: enumerate over desired pivot values
+  // Then solve for free variables with minimum total presses
+
+  // Build inner matrix M over GF(p): rank rows, k cols
+  // M[i][j] = pivotCoeffs[i][j] (coefficient of freeVars[j] in pivot equation i)
+  // After inner GE, inner-free vars are set to 0 for minimum cost
+
+  // Inner augmented matrix: [M | I_rank]
+  const innerAug: number[][] = [];
+  for (let i = 0; i < rank; i++) {
+    const row: number[] = [...pivotCoeffs[i]];
+    for (let j = 0; j < rank; j++) {
+      row.push(i === j ? 1 : 0);
+    }
+    innerAug.push(row);
+  }
+
+  // GE on inner matrix over GF(p)
+  const innerPivotCols: number[] = [];
+  let innerRank = 0;
+
+  for (let col = 0; col < k; col++) {
+    let pivotR = -1;
+    for (let row = innerRank; row < rank; row++) {
+      if (innerAug[row][col] !== 0) {
+        pivotR = row;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    [innerAug[innerRank], innerAug[pivotR]] = [innerAug[pivotR], innerAug[innerRank]];
+
+    const inv = modInverse(innerAug[innerRank][col], modulus);
+    for (let c = 0; c < k + rank; c++) {
+      innerAug[innerRank][c] = (innerAug[innerRank][c] * inv) % modulus;
+    }
+
+    innerPivotCols.push(col);
+
+    for (let row = 0; row < rank; row++) {
+      if (row !== innerRank && innerAug[row][col] !== 0) {
+        const factor = innerAug[row][col];
+        for (let c = 0; c < k + rank; c++) {
+          innerAug[row][c] = (((innerAug[row][c] - factor * innerAug[innerRank][c]) % modulus) + modulus) % modulus;
+        }
+      }
+    }
+    innerRank++;
+  }
+
+  // Enumerate over desired pivot values
+  const pivotValues = new Array(rank).fill(0);
+  const totalConfigs = Math.pow(modulus, rank);
+
+  let bestCost = Infinity;
+  let bestResult: number[] | null = null;
+
+  for (let iter = 0; iter < totalConfigs; iter++) {
+    // b[i] = pivotTarget[i] - pivotValues[i] (what the free vars must produce)
+    // Actually: pivot equation i says:
+    //   x[pivotCols[i]] = pivotTarget[i] - sum_j(pivotCoeffs[i][j] * c[j]) mod p
+    // We want x[pivotCols[i]] = pivotValues[i]
+    // So: sum_j(pivotCoeffs[i][j] * c[j]) = pivotTarget[i] - pivotValues[i] mod p
+    // b[i] = (pivotTarget[i] - pivotValues[i] + modulus) % modulus
+
+    let pivotCost = 0;
+    for (let i = 0; i < rank; i++) {
+      pivotCost += pivotValues[i];
+    }
+    if (pivotCost >= bestCost) {
+      incrementBase(pivotValues, rank, modulus);
+      continue;
+    }
+
+    // Check consistency and compute free var values
+    let consistent = true;
+    const result = new Array(m).fill(0);
+    let cost = pivotCost;
+
+    // Set pivot button values
+    for (let i = 0; i < rank; i++) {
+      result[pivotCols[i]] = pivotValues[i];
+    }
+
+    // Compute RHS for inner system
+    const rhs: number[] = [];
+    for (let i = 0; i < rank; i++) {
+      rhs.push(((pivotTarget[i] - pivotValues[i]) % modulus + modulus) % modulus);
+    }
+
+    // Apply transformation P to rhs
+    const transformedRhs: number[] = [];
+    for (let row = 0; row < rank; row++) {
+      let val = 0;
+      for (let i = 0; i < rank; i++) {
+        val = (val + innerAug[row][k + i] * rhs[i]) % modulus;
+      }
+      transformedRhs.push(val);
+    }
+
+    // Check consistency (rows innerRank..rank-1)
+    for (let row = innerRank; row < rank; row++) {
+      if (transformedRhs[row] !== 0) {
+        consistent = false;
+        break;
+      }
+    }
+
+    if (consistent) {
+      // Set inner pivot free vars
+      for (let row = 0; row < innerRank; row++) {
+        const freeIdx = freeVars[innerPivotCols[row]];
+        result[freeIdx] = transformedRhs[row];
+        cost += transformedRhs[row];
+      }
+      // Inner-free vars stay 0
+
+      if (cost < bestCost || (cost === bestCost && lexSmallerArray(result, bestResult!))) {
+        bestCost = cost;
+        bestResult = result.slice();
+      }
+    }
+
+    incrementBase(pivotValues, rank, modulus);
+  }
+
+  return bestResult;
+}
