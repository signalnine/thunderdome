--- /dev/null
+++ b/src/index.test.ts
@@ -0,0 +1,86 @@
+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  it('returns empty array when target is all off', () => {
+    expect(solveToggle({ target: [false, false], buttons: [[0], [1]] })).toEqual([]);
+  });
+
+  it('returns null when no solution exists', () => {
+    // From the example in the spec
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('solves a simple case', () => {
+    // Light 0 needs to be on. Button 0 toggles light 0.
+    expect(solveToggle({ target: [true], buttons: [[0]] })).toEqual([0]);
+  });
+
+  it('finds minimum presses', () => {
+    // Target: [true, true]. Buttons: 0->[0,1], 1->[0], 2->[1]
+    // Button 0 alone does it (1 press) vs buttons 1+2 (2 presses)
+    expect(solveToggle({
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]],
+    })).toEqual([0]);
+  });
+
+  it('handles no buttons needed', () => {
+    expect(solveToggle({ target: [], buttons: [] })).toEqual([]);
+  });
+
+  it('returns lex smallest for tied solutions', () => {
+    // Target: [true]. Buttons: 0->[0], 1->[0]. Both are 1-press solutions.
+    // Lex smallest is [0].
+    expect(solveToggle({ target: [true], buttons: [[0], [0]] })).toEqual([0]);
+  });
+
+  it('handles a 4-light system', () => {
+    // Target: [T, F, T, F]. Button 0: [0,2]. Press button 0.
+    expect(solveToggle({
+      target: [true, false, true, false],
+      buttons: [[0, 2], [1, 3]],
+    })).toEqual([0]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns zeros when target is all zero', () => {
+    expect(solveCounter([0, 0], [[0], [1]], 5)).toEqual([0, 0]);
+  });
+
+  it('solves simple increment', () => {
+    // Counter 0 needs value 3. Button 0 increments counter 0. Mod 5.
+    expect(solveCounter([3], [[0]], 5)).toEqual([3]);
+  });
+
+  it('returns null when impossible', () => {
+    // Counter 0 needs value 1, but no button affects it.
+    expect(solveCounter([1], [[], []], 3)).toBeNull();
+  });
+
+  it('finds minimum total presses', () => {
+    // Counter 0 needs value 1 mod 5. Button 0 affects counter 0.
+    // Press 1 time (cost 1) vs 6 times (impossible since max is p-1=4).
+    expect(solveCounter([1], [[0]], 5)).toEqual([1]);
+  });
+
+  it('handles modular arithmetic', () => {
+    // Counter 0 needs value 0 mod 3. Button 0 affects counter 0.
+    // Press 0 times (cost 0).
+    expect(solveCounter([0], [[0]], 3)).toEqual([0]);
+  });
+
+  it('handles multiple buttons and counters', () => {
+    // Counters: [2, 1] mod 3
+    // Button 0: affects [0, 1] (increments both)
+    // Button 1: affects [0]
+    // Press button 0 once: counters = [1, 1]. Press button 1 once: counters = [2, 1].
+    // Total presses: 2. Result: [1, 1].
+    expect(solveCounter([2, 1], [[0, 1], [0]], 3)).toEqual([1, 1]);
+  });
+});
diff --git a/src/index.ts b/src/index.ts
