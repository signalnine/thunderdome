+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  it('returns null when no solution exists', () => {
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('returns empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('solves a simple case', () => {
+    const result = solveToggle({
+      target: [true, false],
+      buttons: [[0], [1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('finds minimum buttons', () => {
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('handles single button toggling multiple lights', () => {
+    const result = solveToggle({
+      target: [true, true, true],
+      buttons: [[0, 1, 2]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('handles overlapping toggles', () => {
+    const result = solveToggle({
+      target: [true, false],
+      buttons: [[0, 1], [1]],
+    });
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('handles no buttons', () => {
+    expect(solveToggle({ target: [false], buttons: [] })).toEqual([]);
+    expect(solveToggle({ target: [true], buttons: [] })).toBeNull();
+  });
+
+  it('handles empty target', () => {
+    expect(solveToggle({ target: [], buttons: [[]] })).toEqual([]);
+  });
+
+  it('returns lexicographically smallest when tied on press count', () => {
+    // Target: [true]
+    // Button 0: [0], Button 1: [0]
+    // Both solve it with 1 press, but [0] is lex smaller than [1]
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('handles larger puzzles', () => {
+    // 10 lights, 10 buttons, each button toggles one light
+    const buttons = Array.from({ length: 10 }, (_, i) => [i]);
+    const target = Array.from({ length: 10 }, (_, i) => i % 2 === 0);
+    const result = solveToggle({ target, buttons });
+    expect(result).toEqual([0, 2, 4, 6, 8]);
+  });
+
+  it('verifies solution correctness', () => {
+    const target = [true, false, true, true, false];
+    const buttons = [[0, 2], [1, 3], [2, 4], [0, 1, 4], [3]];
+    const result = solveToggle({ target, buttons });
+    if (result !== null) {
+      // Verify the solution
+      const state = new Array(5).fill(false);
+      for (const btnIdx of result) {
+        for (const light of buttons[btnIdx]) {
+          state[light] = !state[light];
+        }
+      }
+      expect(state).toEqual(target);
+    }
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns zeros when target is all zero', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('solves a simple case', () => {
+    const result = solveCounter([2, 0], [[0], [1]], 5);
+    expect(result).toEqual([2, 0]);
