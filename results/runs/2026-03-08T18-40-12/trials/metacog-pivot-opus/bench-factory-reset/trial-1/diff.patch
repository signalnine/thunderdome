;\n\n    const totalCombinations = 1 << numFree;\n    for (let mask = 0; mask < totalCombinations; mask++) {\n      const count = fastCount(mask);\n\n      if (count < bestCount) {\n        bestCount = count;\n        bestSol = getSolution(mask);\n      } else if (count === bestCount) {\n        const sol = getSolution(mask);\n        if (bestSol === null || lexSmaller(sol, bestSol)) {\n          bestSol = sol;\n        }\n      }\n    }\n\n    if (bestSol === null) return null;\n    return solToIndices(bestSol);\n  }","originalFile":"export interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve toggle puzzle over GF(2) using Gaussian elimination.\n * Find minimum set of buttons, lexicographically smallest if tied.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | target] over GF(2)\n  // Rows = lights, Columns = buttons + 1 (augmented column)\n  // We represent each row as a bigint bitmask for efficient XOR operations.\n  const rows: bigint[] = [];\n  for (let light = 0; light < numLights; light++) {\n    let row = 0n;\n    if (target[light]) {\n      row |= 1n << BigInt(numButtons);\n    }\n    rows.push(row);\n  }\n\n  for (let btn = 0; btn < numButtons; btn++) {\n    for (const light of buttons[btn]) {\n      if (light >= 0 && light < numLights) {\n        rows[light] |= 1n << BigInt(btn);\n      }\n    }\n  }\n\n  // Gaussian elimination over GF(2) - reduced row echelon form\n  const pivotCol: number[] = [];\n  const pivotRow: number[] = new Array(numButtons).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    let found = -1;\n    for (let r = rank; r < numLights; r++) {\n      if ((rows[r] >> BigInt(col)) & 1n) {\n        found = r;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [rows[rank], rows[found]] = [rows[found], rows[rank]];\n\n    for (let r = 0; r < numLights; r++) {\n      if (r !== rank && (rows[r] >> BigInt(col)) & 1n) {\n        rows[r] ^= rows[rank];\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = rank;\n    rank++;\n  }\n\n  // Check consistency\n  for (let r = rank; r < numLights; r++) {\n    if ((rows[r] >> BigInt(numButtons)) & 1n) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  const pivotSet = new Set(pivotCol);\n  for (let col = 0; col < numButtons; col++) {\n    if (!pivotSet.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // For each pivot variable, precompute: its base value (from augmented column)\n  // and which free variables affect it (from the row)\n  const pivotBase: number[] = new Array(pivotCol.length);\n  const pivotFreeEffect: number[][] = []; // pivotFreeEffect[i] = list of free var indices that affect pivot i\n  for (let i = 0; i < pivotCol.length; i++) {\n    const c = pivotCol[i];\n    const r = pivotRow[c];\n    pivotBase[i] = Number((rows[r] >> BigInt(numButtons)) & 1n);\n    const effects: number[] = [];\n    for (let j = 0; j < numFree; j++) {\n      if ((rows[r] >> BigInt(freeVars[j])) & 1n) {\n        effects.push(j);\n      }\n    }\n    pivotFreeEffect.push(effects);\n  }\n\n  function getSolution(freeMask: number): number[] {\n    const sol = new Array(numButtons).fill(0);\n    for (let i = 0; i < numFree; i++) {\n      sol[freeVars[i]] = (freeMask >> i) & 1;\n    }\n    for (let i = 0; i < pivotCol.length; i++) {\n      let val = pivotBase[i];\n      for (const fi of pivotFreeEffect[i]) {\n        val ^= (freeMask >> fi) & 1;\n      }\n      sol[pivotCol[i]] = val;\n    }\n    return sol;\n  }\n\n  function countOnes(sol: number[]): number {\n    let c = 0;\n    for (let i = 0; i < sol.length; i++) c += sol[i];\n    return c;\n  }\n\n  if (numFree <= 25) {\n    // Direct enumeration\n    let bestSol: number[] | null = null;\n    let bestCount = numButtons + 1;\n\n    const totalCombinations = 1 << numFree;\n    for (let mask = 0; mask < totalCombinations; mask++) {\n      const sol = getSolution(mask);\n      const count = countOnes(sol);\n\n      if (count < bestCount || (count === bestCount && bestSol !== null && lexSmaller(sol, bestSol))) {\n        bestCount = count;\n        bestSol = sol;\n      }\n    }\n\n    if (bestSol === null) return null;\n    return solToIndices(bestSol);\n  }\n\n  // Meet in the middle for large free variable counts\n  return meetInMiddleToggle(numButtons, numFree, freeVars, pivotCol, pivotBase, pivotFreeEffect);\n}\n\nfunction solToIndices(sol: number[]): number[] {\n  const result: number[] = [];\n  for (let i = 0; i < sol.length; i++) {\n    if (sol[i]) result.push(i);\n  }\n  return result;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  const aIdx: number[] = [];\n  const bIdx: number[] = [];\n  for (let i = 0; i < a.length; i++) {\n    if (a[i]) aIdx.push(i);\n    if (b[i]) bIdx.push(i);\n  }\n  const len = Math.min(aIdx.length, bIdx.length);\n  for (let i = 0; i < len; i++) {\n    if (aIdx[i] < bIdx[i]) return true;\n    if (aIdx[i] > bIdx[i]) return false;\n  }\n  return aIdx.length < bIdx.length;\n}\n\nfunction meetInMiddleToggle(\n  numButtons: number,\n  numFree: number,\n  freeVars: number[],\n  pivotCol: number[],\n  pivotBase: number[],\n  pivotFreeEffect: number[][]\n): number[] {\n  // Split free variables into two halves\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n\n  // For each assignment of the first half, compute the resulting partial solution\n  // and store: for each possible \"effect signature\" on pivot vars, the best (min count) first-half assignment\n\n  // The effect of free vars on each pivot variable is XOR.\n  // For a given first-half assignment, each pivot var has a partial XOR contribution.\n  // We can encode this as a bitmask over pivot variables.\n\n  function getEffectSignature(freeMask: number, startFree: number, endFree: number): number {\n    let sig = 0;\n    for (let i = 0; i < pivotCol.length; i++) {\n      let contribution = 0;\n      for (const fi of pivotFreeEffect[i]) {\n        if (fi >= startFree && fi < endFree) {\n          contribution ^= (freeMask >> (fi - startFree)) & 1;\n        }\n      }\n      sig |= contribution << i;\n    }\n    return sig;\n  }\n\n  function countFreeOnes(mask: number, count: number): number {\n    let c = 0;\n    for (let i = 0; i < count; i++) {\n      c += (mask >> i) & 1;\n    }\n    return c;\n  }\n\n  // First half: enumerate all 2^half1 assignments\n  // For each, compute: number of free vars set + for each pivot, the XOR contribution\n  // Group by effect signature, keep the best (minimum total buttons including free vars set)\n\n  // But we also need to count the total buttons pressed for the full solution.\n  // Total = free vars set in half1 + free vars set in half2 + pivot vars that are 1\n  // pivot var i = pivotBase[i] XOR effect_from_half1[i] XOR effect_from_half2[i]\n  // So pivot var i is 1 when: pivotBase[i] XOR sig1[i] XOR sig2[i] = 1\n  //   i.e., sig1[i] XOR sig2[i] = pivotBase[i] XOR 1 (to make it 1) or pivotBase[i] (to make it 0)\n  // We want to minimize ones.\n\n  // For a given sig1 and sig2, each pivot var i contributes 1 if pivotBase[i] ^ sig1_bit_i ^ sig2_bit_i = 1\n  // Total = freeOnes1 + freeOnes2 + count of pivots where pivotBase[i] ^ sig1[i] ^ sig2[i] = 1\n\n  // For the meet in the middle: for each sig1 from half1, we want to find the sig2 from half2\n  // that minimizes total.\n  // pivotContrib = popcount(baseSig XOR sig1 XOR sig2) where baseSig encodes pivotBase\n  // Total = freeOnes1 + freeOnes2 + popcount(baseSig ^ sig1 ^ sig2)\n\n  // Let key = baseSig ^ sig1. Then we want sig2 to minimize: freeOnes2 + popcount(key ^ sig2)\n  // This is independent for each key.\n\n  // So: precompute for half2, for each sig2: the best (minimu