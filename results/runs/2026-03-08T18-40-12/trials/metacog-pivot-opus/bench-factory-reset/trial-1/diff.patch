+describe('performance', () => {
+  it('solves 40x40 toggle puzzle within time limit', () => {
+    // 40 lights, 40 buttons, each button toggles a unique light
+    const n = 40;
+    const buttons = Array.from({ length: n }, (_, i) => [i]);
+    const target = Array.from({ length: n }, () => true);
+    const start = Date.now();
+    const result = solveToggle({ target, buttons });
+    const elapsed = Date.now() - start;
+    expect(result).not.toBeNull();
+    expect(result!.length).toBe(n);
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('solves toggle with many free variables', () => {
+    // 5 lights, 20 buttons, lots of free variables
+    const buttons: number[][] = [];
+    for (let i = 0; i < 20; i++) {
+      buttons.push([i % 5]);
+    }
+    const target = [true, true, true, true, true];
+    const start = Date.now();
+    const result = solveToggle({ target, buttons });
+    const elapsed = Date.now() - start;
+    expect(elapsed).toBeLessThan(5000);
+    if (result !== null) {
+      // Verify
+      const state = new Array(5).fill(false);
+      for (const btnIdx of result) {
+        for (const light of buttons[btnIdx]) {
+          state[light] = !state[light];
+        }
+      }
+      expect(state).toEqual(target);
+    }
+  });
