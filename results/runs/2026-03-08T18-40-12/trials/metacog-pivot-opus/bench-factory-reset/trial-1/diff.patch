+  const numRestarts = Math.min(100, Math.ceil(5_000_000 / (numFree * modulus)));
+  for (let restart = 0; restart < numRestarts; restart++) {
+    const start = new Array(numFree);
+    for (let i = 0; i < numFree; i++) {
+      start[i] = Math.floor(rng() * modulus);
+    }
+    optimizeFromStart(start);
+  }
+
+  return bestSol;
+}
+
+function seedRandom(seed: number): () => number {
+  let s = seed;
+  return () => {
+    s = (s * 1664525 + 1013904223) & 0x7fffffff;
+    return s / 0x7fffffff;
+  };
+}
