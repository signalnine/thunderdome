er-sqlite3\": \"^7.6.0\",\n    \"@types/express\": \"^4.17.0\",\n    \"supertest\": \"^7.0.0\",\n    \"@types/supertest\": \"^6.0.0\",\n    \"tsx\": \"^4.0.0\"\n  }\n}\n","numLines":29,"startLine":1,"totalLines":29}}}
