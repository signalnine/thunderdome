+export interface User {
+  id: string;
+  username: string;
+  password: string;
+  token: string | null;
+}
+
+export type Role = 'viewer' | 'editor' | 'owner';
+
+export interface Permission {
+  userId: string;
+  role: Role;
+}
+
+export interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+  permissions: Permission[];
+}
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+  permissions: Permission[];
+}
+
+export interface ActivityLog {
+  id: string;
+  action: string;
+  userId: string;
+  resourceType: 'document' | 'folder';
+  resourceId: string;
+  timestamp: string;
+}
