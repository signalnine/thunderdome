s.find((p) => p.userId === userId);\n    if (existing) {\n      existing.role = role as Role;\n    } else {\n      folder.permissions.push({ userId, role: role as Role });\n    }\n    store.activityLog.push({\n      id: store.generateId(),\n      action: 'folder_shared',\n      userId: user.id,\n      resourceType: 'folder',\n      resourceId: folder.id,\n      timestamp: new Date().toISOString(),\n    });\n    res.json({ message: 'Shared successfully' });\n  });\n\n  router.post('/documents/:id/share', (req, res) => {\n    const user = (req as any).user as User;\n    const { userId, role } = req.body;\n    if (!userId || !role) {\n      res.status(400).json({ error: 'userId and role are required' });\n      return;\n    }\n    if (!['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'Invalid role' });\n      return;\n    }\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const targetUser = store.users.get(userId);\n    if (!targetUser) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    const effectiveRole = getEffectiveRole(store, user.id, 'document', doc.id);\n    if (!hasPermission(effectiveRole, 'editor')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    if (role === 'owner' && effectiveRole !== 'owner') {\n      res.status(403).json({ error: 'Only owners can assign owner role' });\n      return;\n    }\n    const existing = doc.permissions.find((p) => p.userId === userId);\n    if (existing) {\n      existing.role = role as Role;\n    } else {\n      doc.permissions.push({ userId, role: role as Role });\n    }\n    store.activityLog.push({\n      id: store.generateId(),\n      action: 'document_shared',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: doc.id,\n      timestamp: new Date().toISOString(),\n    });\n    res.json({ message: 'Shared successfully' });\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":7,"oldLines":7,"newStart":7,"newLines":7,"lines":["   const router = Router();"," ","   router.post('/folders/:id/share', (req, res) => {","-    const user = (req as any).user as User;","+    const user = req.user!;","     const { userId, role } = req.body;","     if (!userId || !role) {","       res.status(400).json({ error: 'userId and role are required' });"]},{"oldStart":54,"oldLines":7,"newStart":54,"newLines":7,"lines":["   });"," ","   router.post('/documents/:id/share', (req, res) => {","-    const user = (req as any).user as User;","+    const user = req.user!;","     const { userId, role } = req.body;","     if (!userId || !role) {","       res.status(400).json({ error: 'userId and role are required' });"]}],"userModified":false,"replaceAll":true}}
