+### Task 8: App Entry Point (createApp)
+
+**Files:**
+- Create: `src/app.ts`
+
+**Step 1: Create the app factory**
+
+```typescript
+// src/app.ts
+import express from 'express';
+import { createStore } from './store.js';
+import { authMiddleware } from './middleware.js';
+import { authRoutes } from './routes/auth.js';
+import { folderRoutes } from './routes/folders.js';
+import { documentRoutes } from './routes/documents.js';
+import { shareRoutes } from './routes/share.js';
+import { activityRoutes } from './routes/activity.js';
+
+export function createApp() {
+  const app = express();
+  const store = createStore();
+
+  app.use(express.json());
+
+  // Public routes
+  app.use('/auth', authRoutes(store));
+
+  // Protected routes
+  app.use('/folders', authMiddleware(store), folderRoutes(store));
+  app.use('/documents', authMiddleware(store), documentRoutes(store));
+  app.use('/', authMiddleware(store), shareRoutes(store));
+  app.use('/activity', authMiddleware(store), activityRoutes(store));
+
+  return app;
+}
+```
