+// src/routes/folders.ts
+import { Router } from 'express';
+import { Store } from '../store.js';
+import { getEffectiveRole, hasPermission } from '../permissions.js';
+import { User } from '../types.js';
+
+export function folderRoutes(store: Store): Router {
+  const router = Router();
+
+  router.post('/', (req, res) => {
+    const user = (req as any).user as User;
+    const { name, parentId } = req.body;
+    if (!name) {
+      res.status(400).json({ error: 'Name is required' });
+      return;
+    }
+    if (parentId) {
+      const parent = store.folders.get(parentId);
+      if (!parent) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      const role = getEffectiveRole(store, user.id, 'folder', parentId);
+      if (!hasPermission(role, 'editor')) {
+        res.status(403).json({ error: 'Forbidden' });
+        return;
+      }
+    }
+    const id = store.generateId();
+    const folder = { id, name, parentId: parentId || null, ownerId: user.id, permissions: [] };
+    store.folders.set(id, folder);
+    res.status(201).json(folder);
+  });
+
+  router.get('/:id', (req, res) => {
+    const user = (req as any).user as User;
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    const role = getEffectiveRole(store, user.id, 'folder', folder.id);
+    if (!hasPermission(role, 'viewer')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    res.json(folder);
+  });
+
+  router.put('/:id', (req, res) => {
+    const user = (req as any).user as User;
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    const role = getEffectiveRole(store, user.id, 'folder', folder.id);
+    if (!hasPermission(role, 'editor')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    if (req.body.name) folder.name = req.body.name;
+    if (req.body.parentId !== undefined) folder.parentId = req.body.parentId || null;
+    res.json(folder);
+  });
+
+  router.delete('/:id', (req, res) => {
+    const user = (req as any).user as User;
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    const role = getEffectiveRole(store, user.id, 'folder', folder.id);
+    if (!hasPermission(role, 'owner')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    store.folders.delete(folder.id);
+    res.status(204).send();
+  });
+
+  return router;
+}
+```
