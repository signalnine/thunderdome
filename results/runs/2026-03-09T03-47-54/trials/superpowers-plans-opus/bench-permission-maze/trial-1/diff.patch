+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_011st3njoWyxZxtZAjuUDSu4","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018TwEiZRcdLMdsZm7CJpbv2","name":"Write","input":{"file_path":"/workspace/docs/plans/2026-03-09-permission-maze.md","content":"# Permission Maze Implementation Plan\n\n> **For Claude:** REQUIRED SUB-SKILL: Use superpowers:executing-plans to implement this plan task-by-task.\n\n**Goal:** Build a document management API with users, hierarchical folders, documents, sharing permissions, and activity logging.\n\n**Architecture:** Express.js REST API with in-memory storage using Maps. Middleware handles auth token validation. Permissions cascade from folders to documents, with the most permissive role winning when multiple grants exist.\n\n**Tech Stack:** Express.js, TypeScript, Vitest + Supertest for testing\n\n---\n\n### Task 1: Project Scaffolding - Types and Storage\n\n**Files:**\n- Create: `src/types.ts`\n- Create: `src/store.ts`\n\n**Step 1: Create type definitions**\n\n```typescript\n// src/types.ts\nexport interface User {\n  id: string;\n  username: string;\n  password: string;\n  token: string | null;\n}\n\nexport type Role = 'viewer' | 'editor' | 'owner';\n\nexport interface Permission {\n  userId: string;\n  role: Role;\n}\n\nexport interface Folder {\n  id: string;\n  name: string;\n  parentId: string | null;\n  ownerId: string;\n  permissions: Permission[];\n}\n\nexport interface Document {\n  id: string;\n  title: string;\n  content: string;\n  folderId: string;\n  ownerId: string;\n  permissions: Permission[];\n}\n\nexport interface ActivityLog {\n  id: string;\n  action: string;\n  userId: string;\n  resourceType: 'document' | 'folder';\n  resourceId: string;\n  timestamp: string;\n}\n```\n\n**Step 2: Create in-memory store**\n\n```typescript\n// src/store.ts\nimport { User, Folder, Document, ActivityLog } from './types.js';\n\nexport function createStore() {\n  return {\n    users: new Map<string, User>(),\n    folders: new Map<string, Folder>(),\n    documents: new Map<string, Document>(),\n    activityLog: [] as ActivityLog[],\n    nextId: 1,\n    generateId(): string {\n      return String(this.nextId++);\n    },\n  };\n}\n\nexport type Store = ReturnType<typeof createStore>;\n```\n\n---\n\n### Task 2: Auth Middleware and User Routes\n\n**Files:**\n- Create: `src/middleware.ts`\n- Create: `src/routes/auth.ts`\n\n**Step 1: Create auth middleware**\n\n```typescript\n// src/middleware.ts\nimport { Request, Response, NextFunction } from 'express';\nimport { Store } from './store.js';\n\nexport function authMiddleware(store: Store) {\n  return (req: Request, res: Response, next: NextFunction) => {\n    const authHeader = req.headers.authorization;\n    if (!authHeader || !authHeader.startsWith('Bearer ')) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    const token = authHeader.slice(7);\n    let foundUser = null;\n    for (const user of store.users.values()) {\n      if (user.token === token) {\n        foundUser = user;\n        break;\n      }\n    }\n    if (!foundUser) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    (req as any).user = foundUser;\n    next();\n  };\n}\n```\n\n**Step 2: Create auth routes**\n\n```typescript\n// src/routes/auth.ts\nimport { Router } from 'express';\nimport { Store } from '../store.js';\nimport crypto from 'crypto';\n\nexport function authRoutes(store: Store): Router {\n  const router = Router();\n\n  router.post('/register', (req, res) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'Username and password required' });\n      return;\n    }\n    for (const user of store.users.values()) {\n      if (user.username === username) {\n        res.status(409).json({ error: 'Username already exists' });\n        return;\n      }\n    }\n    const id = store.generateId();\n    const user = { id, username, password, token: null };\n    store.users.set(id, user);\n    res.status(201).json({ id, username });\n  });\n\n  router.post('/login', (req, res) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'Username and password required' });\n      return;\n    }\n    let foundUser = null;\n    for (const user of store.users.values()) {\n      if (user.username === username && user.password === password) {\n        foundUser = user;\n        break;\n      }\n    }\n    if (!foundUser) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n    const token = crypto.randomUUID();\n    foundUser.token = token;\n    res.json({ token, userId: foundUser.id });\n  });\n\n  return router;\n}\n```\n\n---\n\n### Task 3: Permission Helper Utilities\n\n**Files:**\n- Create: `src/permissions.ts`\n\n**Step 1: Create permission helpers**\n\n```typescript\n// src/permissions.ts\nimport { Store } from './store.js';\nimport { Role } from './types.js';\n\nconst ROLE_LEVELS: Record<Role, number> = {\n  viewer: 1,\n  editor: 2,\n  owner: 3,\n};\n\nexport function getEffectiveRole(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string\n): Role | null {\n  let roles: Role[] = [];\n\n  if (resourceType === 'document') {\n    const doc = store.documents.get(resourceId);\n    if (!doc) return null;\n    if (doc.ownerId === userId) return 'owner';\n    // Direct document permissions\n    for (const p of doc.permissions) {\n      if (p.userId === userId) roles.push(p.role);\n    }\n    // Folder permissions (inherited)\n    const folderRole = getEffectiveFolderRole(store, userId, doc.folderId);\n    if (folderRole) roles.push(folderRole);\n  } else {\n    const folder = store.folders.get(resourceId);\n    if (!folder) return null;\n    if (folder.ownerId === userId) return 'owner';\n    const folderRole = getEffectiveFolderRole(store, userId, resourceId);\n    if (folderRole) roles.push(folderRole);\n  }\n\n  if (roles.length === 0) return null;\n  return roles.reduce((best, r) => ROLE_LEVELS[r] > ROLE_LEVELS[best] ? r : best);\n}\n\nfunction getEffectiveFolderRole(store: Store, userId: string, folderId: string): Role | null {\n  let roles: Role[] = [];\n  let currentId: string | null = folderId;\n\n  while (currentId) {\n    const folder = store.folders.get(currentId);\n    if (!folder) break;\n    if (folder.ownerId === userId) return 'owner';\n    for (const p of folder.permissions) {\n      if (p.userId === userId) roles.push(p.role);\n    }\n    currentId = folder.parentId;\n  }\n\n  if (roles.length === 0) return null;\n  return roles.reduce((best, r) => ROLE_LEVELS[r] > ROLE_LEVELS[best] ? r : best);\n}\n\nexport function hasPermission(role: Role | null, required: Role): boolean {\n  if (!role) return false;\n  return ROLE_LEVELS[role] >= ROLE_LEVELS[required];\n}\n```\n\n---\n\n### Task 4: Folder Routes\n\n**Files:**\n- Create: `src/routes/folders.ts`\n\n**Step 1: Create folder CRUD routes**\n\n```typescript\n// src/routes/folders.ts\nimport { Router } from 'express';\nimport { Store } from '../store.js';\nimport { getEffectiveRole, hasPermission } from '../permissions.js';\nimport { User } from '../types.js';\n\nexport function folderRoutes(store: Store): Router {\n  const router = Router();\n\n  router.post('/', (req, res) => {\n    const user = (req as any).user as User;\n    const { name, parentId } = req.body;\n    if (!name) {\n      res.status(400).json({ error: 'Name is required' });\n      return;\n    }\n    if (parentId) {\n      const parent = store.folders.get(parentId);\n      if (!parent) {\n        res.status(404).json({ error: 'Parent folder not found' });\n        return;\n      }\n      const role = getEffectiveRole(store, user.id, 'folder', parentId);\n      if (!hasPermission(role, 'editor')) {\n        res.status(403).json({ error: 'Forbidden' });\n        return;\n      }\n    }\n    const id = store.generateId();\n    const folder = { id, name, parentId: parentId || null, ownerId: user.id, permissions: [] };\n    store.folders.set(id, folder);\n    res.status(201).json(folder);\n  });\n\n  router.get('/:id', (req, res) => {\n    const user = (req as any).user as User;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'folder', folder.id);\n    if (!hasPermission(role, 'viewer')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    res.json(folder);\n  });\n\n  router.put('/:id', (req, res) => {\n    const user = (req as any).user as User;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'folder', folder.id);\n    if (!hasPermission(role, 'editor')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    if (req.body.name) folder.name = req.body.name;\n    if (req.body.parentId !== undefined) folder.parentId = req.body.parentId || null;\n    res.json(folder);\n  });\n\n  router.delete('/:id', (req, res) => {\n    const user = (req as any).user as User;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'folder', folder.id);\n    if (!hasPermission(role, 'owner')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    store.folders.delete(folder.id);\n    res.status(204).send();\n  });\n\n  return router;\n}\n```\n\n---\n\n### Task 5: Document Routes\n\n**Files:**\n- Create: `src/routes/documents.ts`\n\n**Step 1: Create document CRUD routes**\n\n```typescript\n// src/routes/documents.ts\nimport { Router } from 'express';\nimport { Store } from '../store.js';\nimport { getEffectiveRole, hasPermission } from '../permissions.js';\nimport { User } from '../types.js';\n\nexport function documentRoutes(store: Store): Router {\n  const router = Router();\n\n  router.post('/', (req, res) => {\n    const user = (req as any).user as User;\n    const { title, content, folderId } = req.body;\n    if (!title || content === undefined || !folderId) {\n      res.status(400).json({ error: 'Title, content, and folderId are required' });\n      return;\n    }\n    const folder = store.folders.get(folderId);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'folder', folderId);\n    if (!hasPermission(role, 'editor')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    const id = store.generateId();\n    const doc = { id, title, content, folderId, ownerId: user.id, permissions: [] };\n    store.documents.set(id, doc);\n    store.activityLog.push({\n      id: store.generateId(),\n      action: 'document_created',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: id,\n      timestamp: new Date().toISOString(),\n    });\n    res.status(201).json(doc);\n  });\n\n  router.get('/:id', (req, res) => {\n    const user = (req as any).user as User;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'document', doc.id);\n    if (!hasPermission(role, 'viewer')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    res.json(doc);\n  });\n\n  router.put('/:id', (req, res) => {\n    const user = (req as any).user as User;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'document', doc.id);\n    if (!hasPermission(role, 'editor')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    if (req.body.title) doc.title = req.body.title;\n    if (req.body.content !== undefined) doc.content = req.body.content;\n    store.activityLog.push({\n      id: store.generateId(),\n      action: 'document_updated',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: doc.id,\n      timestamp: new Date().toISOString(),\n    });\n    res.json(doc);\n  });\n\n  router.delete('/:id', (req, res) => {\n    const user = (req as any).user as User;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'document', doc.id);\n    if (!hasPermission(role, 'owner')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    store.documents.delete(doc.id);\n    store.activityLog.push({\n      id: store.generateId(),\n      action: 'document_deleted',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: doc.id,\n      timestamp: new Date().toISOString(),\n    });\n    res.status(204).send();\n  });\n\n  return router;\n}\n```\n\n---\n\n### Task 6: Sharing Routes\n\n**Files:**\n- Create: `src/routes/share.ts`\n\n**Step 1: Create sharing routes**\n\n```typescript\n// src/routes/share.ts\nimport { Router } from 'express';\nimport { Store } from '../store.js';\nimport { getEffectiveRole, hasPermission } from '../permissions.js';\nimport { User, Role } from '../types.js';\n\nexport function shareRoutes(store: Store): Router {\n  const router = Router();\n\n  router.post('/folders/:id/share', (req, res) => {\n    const user = (req as any).user as User;\n    const { userId, role } = req.body;\n    if (!userId || !role) {\n      res.status(400).json({ error: 'userId and role are required' });\n      return;\n    }\n    if (!['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'Invalid role' });\n      return;\n    }\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    const targetUser = store.users.get(userId);\n    if (!targetUser) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    const effectiveRole = getEffectiveRole(store, user.id, 'folder', folder.id);\n    if (!hasPermission(effectiveRole, 'editor')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    // Only owners can assign owner role\n    if (role === 'owner' && effectiveRole !== 'owner') {\n      res.status(403).json({ error: 'Only owners can assign owner role' });\n      return;\n    }\n    const existing = folder.permissions.find(p => p.userId === userId);\n    if (existing) {\n      existing.role = role as Role;\n    } else {\n      folder.permissions.push({ userId, role: role as Role });\n    }\n    store.activityLog.push({\n      id: store.generateId(),\n      action: 'folder_shared',\n      userId: user.id,\n      resourceType: 'folder',\n      resourceId: folder.id,\n      timestamp: new Date().toISOString(),\n    });\n    res.json({ message: 'Shared successfully' });\n  });\n\n  router.post('/documents/:id/share', (req, res) => {\n    const user = (req as any).user as User;\n    const { userId, role } = req.body;\n    if (!userId || !role) {\n      res.status(400).json({ error: 'userId and role are required' });\n      return;\n    }\n    if (!['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'Invalid role' });\n      return;\n    }\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const targetUser = store.users.get(userId);\n    if (!targetUser) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    const effectiveRole = getEffectiveRole(store, user.id, 'document', doc.id);\n    if (!hasPermission(effectiveRole, 'editor')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    if (role === 'owner' && effectiveRole !== 'owner') {\n      res.status(403).json({ error: 'Only owners can assign owner role' });\n      return;\n    }\n    const existing = doc.permissions.find(p => p.userId === userId);\n    if (existing) {\n      existing.role = role as Role;\n    } else {\n      doc.permissions.push({ userId, role: role as Role });\n    }\n    store.activityLog.push({\n      id: store.generateId(),\n      action: 'document_shared',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: doc.id,\n      timestamp: new Date().toISOString(),\n    });\n    res.json({ message: 'Shared successfully' });\n  });\n\n  return router;\n}\n```\n\n---\n\n### Task 7: Activity Log Routes\n\n**Files:**\n- Create: `src/routes/activity.ts`\n\n**Step 1: Create activity log route**\n\n```typescript\n// src/routes/activity.ts\nimport { Router } from 'express';\nimport { Store } from '../store.js';\n\nexport function activityRoutes(store: Store): Router {\n  const router = Router();\n\n  router.get('/', (_req, res) => {\n    res.json(store.activityLog);\n  });\n\n  return router;\n}\n```\n\n---\n\n### Task 8: App Entry Point (createApp)\n\n**Files:**\n- Create: `src/app.ts`\n\n**Step 1: Create the app factory**\n\n```typescript\n// src/app.ts\nimport express from 'express';\nimport { createStore } from './store.js';\nimport { authMiddleware } from './middleware.js';\nimport { authRoutes } from './routes/auth.js';\nimport { folderRoutes } from './routes/folders.js';\nimport { documentRoutes } from './routes/documents.js';\nimport { shareRoutes } from './routes/share.js';\nimport { activityRoutes } from './routes/activity.js';\n\nexport function createApp() {\n  const app = express();\n  const store = createStore();\n\n  app.use(express.json());\n\n  // Public routes\n  app.use('/auth', authRoutes(store));\n\n  // Protected routes\n  app.use('/folders', authMiddleware(store), folderRoutes(store));\n  app.use('/documents', authMiddleware(store), documentRoutes(store));\n  app.use('/', authMiddleware(store), shareRoutes(store));\n  app.use('/activity', authMiddleware(store), activityRoutes(store));\n\n  return app;\n}\n```\n\n---\n\n### Task 9: Tests\n\n**Files:**\n- Create: `src/app.test.ts`\n\nWrite comprehensive tests covering auth, folder CRUD, document CRUD, sharing, permission inheritance, and activity log.\n\n---\n\n### Task 10: Build, Lint, Test\n\nRun:\n- `npm run build`\n- `npm run lint`\n- `npm test`\n\nFix any issues.\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":119,"cache_read_input_tokens":20834,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":119},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f2c904c3-f823-4091-b445-4f42d79d2a5a","uuid":"7fc60ac0-52ac-4bab-8a71-cdb9acd2ff1a"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018TwEiZRcdLMdsZm7CJpbv2","type":"tool_result","content":"File created successfully at: /workspace/docs/plans/2026-03-09-permission-maze.md"}]},"parent_tool_use_id":null,"session_id":"f2c904c3-f823-4091-b445-4f42d79d2a5a","uuid":"e7e3be64-8178-465f-a866-5ee39d1d0c48","tool_use_result":{"type":"create","filePath":"/workspace/docs/plans/2026-03-09-permission-maze.md","content":"# Permission Maze Implementation Plan\n\n> **For Claude:** REQUIRED SUB-SKILL: Use superpowers:executing-plans to implement this plan task-by-task.\n\n**Goal:** Build a document management API with users, hierarchical folders, documents, sharing permissions, and activity logging.\n\n**Architecture:** Express.js REST API with in-memory storage using Maps. Middleware handles auth token validation. Permissions cascade from folders to documents, with the most permissive role winning when multiple grants exist.\n\n**Tech Stack:** Express.js, TypeScript, Vitest + Supertest for testing\n\n---\n\n### Task 1: Project Scaffolding - Types and Storage\n\n**Files:**\n- Create: `src/types.ts`\n- Create: `src/store.ts`\n\n**Step 1: Create type definitions**\n\n```typescript\n// src/types.ts\nexport interface User {\n  id: string;\n  username: string;\n  password: string;\n  token: string | null;\n}\n\nexport type Role = 'viewer' | 'editor' | 'owner';\n\nexport interface Permission {\n  userId: string;\n  role: Role;\n}\n\nexport interface Folder {\n  id: string;\n  name: string;\n  parentId: string | null;\n  ownerId: string;\n  permissions: Permission[];\n}\n\nexport interface Document {\n  id: string;\n  title: string;\n  content: string;\n  folderId: string;\n  ownerId: string;\n  permissions: Permission[];\n}\n\nexport interface ActivityLog {\n  id: string;\n  action: string;\n  userId: string;\n  resourceType: 'document' | 'folder';\n  resourceId: string;\n  timestamp: string;\n}\n```\n\n**Step 2: Create in-memory store**\n\n```typescript\n// src/store.ts\nimport { User, Folder, Document, ActivityLog } from './types.js';\n\nexport function createStore() {\n  return {\n    users: new Map<string, User>(),\n    folders: new Map<string, Folder>(),\n    documents: new Map<string, Document>(),\n    activityLog: [] as ActivityLog[],\n    nextId: 1,\n    generateId(): string {\n      return String(this.nextId++);\n    },\n  };\n}\n\nexport type Store = ReturnType<typeof createStore>;\n```\n\n---\n\n### Task 2: Auth Middleware and User Routes\n\n**Files:**\n- Create: `src/middleware.ts`\n- Create: `src/routes/auth.ts`\n\n**Step 1: Create auth middleware**\n\n```typescript\n// src/middleware.ts\nimport { Request, Response, NextFunction } from 'express';\nimport { Store } from './store.js';\n\nexport function authMiddleware(store: Store) {\n  return (req: Request, res: Response, next: NextFunction) => {\n    const authHeader = req.headers.authorization;\n    if (!authHeader || !authHeader.startsWith('Bearer ')) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    const token = authHeader.slice(7);\n    let foundUser = null;\n    for (const user of store.users.values()) {\n      if (user.token === token) {\n        foundUser = user;\n        break;\n      }\n    }\n    if (!foundUser) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    (req as any).user = foundUser;\n    next();\n  };\n}\n```\n\n**Step 2: Create auth routes**\n\n```typescript\n// src/routes/auth.ts\nimport { Router } from 'express';\nimport { Store } from '../store.js';\nimport crypto from 'crypto';\n\nexport function authRoutes(store: Store): Router {\n  const router = Router();\n\n  router.post('/register', (req, res) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'Username and password required' });\n      return;\n    }\n    for (const user of store.users.values()) {\n      if (user.username === username) {\n        res.status(409).json({ error: 'Username already exists' });\n        return;\n      }\n    }\n    const id = store.generateId();\n    const user = { id, username, password, token: null };\n    store.users.set(id, user);\n    res.status(201).json({ id, username });\n  });\n\n  router.post('/login', (req, res) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'Username and password required' });\n      return;\n    }\n    let foundUser = null;\n    for (const user of store.users.values()) {\n      if (user.username === username && user.password === password) {\n        foundUser = user;\n        break;\n      }\n    }\n    if (!foundUser) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n    const token = crypto.randomUUID();\n    foundUser.token = token;\n    res.json({ token, userId: foundUser.id });\n  });\n\n  return router;\n}\n```\n\n---\n\n### Task 3: Permission Helper Utilities\n\n**Files:**\n- Create: `src/permissions.ts`\n\n**Step 1: Create permission helpers**\n\n```typescript\n// src/permissions.ts\nimport { Store } from './store.js';\nimport { Role } from './types.js';\n\nconst ROLE_LEVELS: Record<Role, number> = {\n  viewer: 1,\n  editor: 2,\n  owner: 3,\n};\n\nexport function getEffectiveRole(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string\n): Role | null {\n  let roles: Role[] = [];\n\n  if (resourceType === 'document') {\n    const doc = store.documents.get(resourceId);\n    if (!doc) return null;\n    if (doc.ownerId === userId) return 'owner';\n    // Direct document permissions\n    for (const p of doc.permissions) {\n      if (p.userId === userId) roles.push(p.role);\n    }\n    // Folder permissions (inherited)\n    const folderRole = getEffectiveFolderRole(store, userId, doc.folderId);\n    if (folderRole) roles.push(folderRole);\n  } else {\n    const folder = store.folders.get(resourceId);\n    if (!folder) return null;\n    if (folder.ownerId === userId) return 'owner';\n    const folderRole = getEffectiveFolderRole(store, userId, resourceId);\n    if (folderRole) roles.push(folderRole);\n  }\n\n  if (roles.length === 0) return null;\n  return roles.reduce((best, r) => ROLE_LEVELS[r] > ROLE_LEVELS[best] ? r : best);\n}\n\nfunction getEffectiveFolderRole(store: Store, userId: string, folderId: string): Role | null {\n  let roles: Role[] = [];\n  let currentId: string | null = folderId;\n\n  while (currentId) {\n    const folder = store.folders.get(currentId);\n    if (!folder) break;\n    if (folder.ownerId === userId) return 'owner';\n    for (const p of folder.permissions) {\n      if (p.userId === userId) roles.push(p.role);\n    }\n    currentId = folder.parentId;\n  }\n\n  if (roles.length === 0) return null;\n  return roles.reduce((best, r) => ROLE_LEVELS[r] > ROLE_LEVELS[best] ? r : best);\n}\n\nexport function hasPermission(role: Role | null, required: Role): boolean {\n  if (!role) return false;\n  return ROLE_LEVELS[role] >= ROLE_LEVELS[required];\n}\n```\n\n---\n\n### Task 4: Folder Routes\n\n**Files:**\n- Create: `src/routes/folders.ts`\n\n**Step 1: Create folder CRUD routes**\n\n```typescript\n// src/routes/folders.ts\nimport { Router } from 'express';\nimport { Store } from '../store.js';\nimport { getEffectiveRole, hasPermission } from '../permissions.js';\nimport { User } from '../types.js';\n\nexport function folderRoutes(store: Store): Router {\n  const router = Router();\n\n  router.post('/', (req, res) => {\n    const user = (req as any).user as User;\n    const { name, parentId } = req.body;\n    if (!name) {\n      res.status(400).json({ error: 'Name is required' });\n      return;\n    }\n    if (parentId) {\n      const parent = store.folders.get(parentId);\n      if (!parent) {\n        res.status(404).json({ error: 'Parent folder not found' });\n        return;\n      }\n      const role = getEffectiveRole(store, user.id, 'folder', parentId);\n      if (!hasPermission(role, 'editor')) {\n        res.status(403).json({ error: 'Forbidden' });\n        return;\n      }\n    }\n    const id = store.generateId();\n    const folder = { id, name, parentId: parentId || null, ownerId: user.id, permissions: [] };\n    store.folders.set(id, folder);\n    res.status(201).json(folder);\n  });\n\n  router.get('/:id', (req, res) => {\n    const user = (req as any).user as User;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'folder', folder.id);\n    if (!hasPermission(role, 'viewer')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    res.json(folder);\n  });\n\n  router.put('/:id', (req, res) => {\n    const user = (req as any).user as User;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'folder', folder.id);\n    if (!hasPermission(role, 'editor')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    if (req.body.name) folder.name = req.body.name;\n    if (req.body.parentId !== undefined) folder.parentId = req.body.parentId || null;\n    res.json(folder);\n  });\n\n  router.delete('/:id', (req, res) => {\n    const user = (req as any).user as User;\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'folder', folder.id);\n    if (!hasPermission(role, 'owner')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    store.folders.delete(folder.id);\n    res.status(204).send();\n  });\n\n  return router;\n}\n```\n\n---\n\n### Task 5: Document Routes\n\n**Files:**\n- Create: `src/routes/documents.ts`\n\n**Step 1: Create document CRUD routes**\n\n```typescript\n// src/routes/documents.ts\nimport { Router } from 'express';\nimport { Store } from '../store.js';\nimport { getEffectiveRole, hasPermission } from '../permissions.js';\nimport { User } from '../types.js';\n\nexport function documentRoutes(store: Store): Router {\n  const router = Router();\n\n  router.post('/', (req, res) => {\n    const user = (req as any).user as User;\n    const { title, content, folderId } = req.body;\n    if (!title || content === undefined || !folderId) {\n      res.status(400).json({ error: 'Title, content, and folderId are required' });\n      return;\n    }\n    const folder = store.folders.get(folderId);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'folder', folderId);\n    if (!hasPermission(role, 'editor')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    const id = store.generateId();\n    const doc = { id, title, content, folderId, ownerId: user.id, permissions: [] };\n    store.documents.set(id, doc);\n    store.activityLog.push({\n      id: store.generateId(),\n      action: 'document_created',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: id,\n      timestamp: new Date().toISOString(),\n    });\n    res.status(201).json(doc);\n  });\n\n  router.get('/:id', (req, res) => {\n    const user = (req as any).user as User;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'document', doc.id);\n    if (!hasPermission(role, 'viewer')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    res.json(doc);\n  });\n\n  router.put('/:id', (req, res) => {\n    const user = (req as any).user as User;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'document', doc.id);\n    if (!hasPermission(role, 'editor')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    if (req.body.title) doc.title = req.body.title;\n    if (req.body.content !== undefined) doc.content = req.body.content;\n    store.activityLog.push({\n      id: store.generateId(),\n      action: 'document_updated',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: doc.id,\n      timestamp: new Date().toISOString(),\n    });\n    res.json(doc);\n  });\n\n  router.delete('/:id', (req, res) => {\n    const user = (req as any).user as User;\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const role = getEffectiveRole(store, user.id, 'document', doc.id);\n    if (!hasPermission(role, 'owner')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    store.documents.delete(doc.id);\n    store.activityLog.push({\n      id: store.generateId(),\n      action: 'document_deleted',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: doc.id,\n      timestamp: new Date().toISOString(),\n    });\n    res.status(204).send();\n  });\n\n  return router;\n}\n```\n\n---\n\n### Task 6: Sharing Routes\n\n**Files:**\n- Create: `src/routes/share.ts`\n\n**Step 1: Create sharing routes**\n\n```typescript\n// src/routes/share.ts\nimport { Router } from 'express';\nimport { Store } from '../store.js';\nimport { getEffectiveRole, hasPermission } from '../permissions.js';\nimport { User, Role } from '../types.js';\n\nexport function shareRoutes(store: Store): Router {\n  const router = Router();\n\n  router.post('/folders/:id/share', (req, res) => {\n    const user = (req as any).user as User;\n    const { userId, role } = req.body;\n    if (!userId || !role) {\n      res.status(400).json({ error: 'userId and role are required' });\n      return;\n    }\n    if (!['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'Invalid role' });\n      return;\n    }\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    const targetUser = store.users.get(userId);\n    if (!targetUser) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    const effectiveRole = getEffectiveRole(store, user.id, 'folder', folder.id);\n    if (!hasPermission(effectiveRole, 'editor')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    // Only owners can assign owner role\n    if (role === 'owner' && effectiveRole !== 'owner') {\n      res.status(403).json({ error: 'Only owners can assign owner role' });\n      return;\n    }\n    const existing = folder.permissions.find(p => p.userId === userId);\n    if (existing) {\n      existing.role = role as Role;\n    } else {\n      folder.permissions.push({ userId, role: role as Role });\n    }\n    store.activityLog.push({\n      id: store.generateId(),\n      action: 'folder_shared',\n      userId: user.id,\n      resourceType: 'folder',\n      resourceId: folder.id,\n      timestamp: new Date().toISOString(),\n    });\n    res.json({ message: 'Shared successfully' });\n  });\n\n  router.post('/documents/:id/share', (req, res) => {\n    const user = (req as any).user as User;\n    const { userId, role } = req.body;\n    if (!userId || !role) {\n      res.status(400).json({ error: 'userId and role are required' });\n      return;\n    }\n    if (!['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'Invalid role' });\n      return;\n    }\n    const doc = store.documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const targetUser = store.users.get(userId);\n    if (!targetUser) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    const effectiveRole = getEffectiveRole(store, user.id, 'document', doc.id);\n    if (!hasPermission(effectiveRole, 'editor')) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    if (role === 'owner' && effectiveRole !== 'owner') {\n      res.status(403).json({ error: 'Only owners can assign owner role' });\n      return;\n    }\n    const existing = doc.permissions.find(p => p.userId === userId);\n    if (existing) {\n      existing.role = role as Role;\n    } else {\n      doc.permissions.push({ userId, role: role as Role });\n    }\n    store.activityLog.push({\n      id: store.generateId(),\n      action: 'document_shared',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: doc.id,\n      timestamp: new Date().toISOString(),\n    });\n    res.json({ message: 'Shared successfully' });\n  });\n\n  return router;\n}\n```\n\n---\n\n### Task 7: Activity Log Routes\n\n**Files:**\n- Create: `src/routes/activity.ts`\n\n**Step 1: Create activity log route**\n\n```typescript\n// src/routes/activity.ts\nimport { Router } from 'express';\nimport { Store } from '../store.js';\n\nexport function activityRoutes(store: Store): Router {\n  const router = Router();\n\n  router.get('/', (_req, res) => {\n    res.json(store.activityLog);\n  });\n\n  return router;\n}\n```\n\n---\n\n### Task 8: App Entry Point (createApp)\n\n**Files:**\n- Create: `src/app.ts`\n\n**Step 1: Create the app factory**\n\n```typescript\n// src/app.ts\nimport express from 'express';\nimport { createStore } from './store.js';\nimport { authMiddleware } from './middleware.js';\nimport { authRoutes } from './routes/auth.js';\nimport { folderRoutes } from './routes/folders.js';\nimport { documentRoutes } from './routes/documents.js';\nimport { shareRoutes } from './routes/share.js';\nimport { activityRoutes } from './routes/activity.js';\n\nexport function createApp() {\n  const app = express();\n  const store = createStore();\n\n  app.use(express.json());\n\n  // Public routes\n  app.use('/auth', authRoutes(store));\n\n  // Protected routes\n  app.use('/folders', authMiddleware(store), folderRoutes(store));\n  app.use('/documents', authMiddleware(store), documentRoutes(store));\n  app.use('/', authMiddleware(store), shareRoutes(store));\n  app.use('/activity', authMiddleware(store), activityRoutes(store));\n\n  return app;\n}\n```\n\n---\n\n### Task 9: Tests\n\n**Files:**\n- Create: `src/app.test.ts`\n\nWrite comprehensive tests covering auth, folder CRUD, document CRUD, sharing, permission inheritance, and activity log.\n\n---\n\n### Task 10: Build, Lint, Test\n\nRun:\n- `npm run build`\n- `npm run lint`\n- `npm test`\n\nFix any issues.\n","structuredPatch":[],"originalFile":null}}
