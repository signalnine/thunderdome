trix[r][numButtons]);\n    const deps: number[] = [];\n    for (let fi = 0; fi < numFree; fi++) {\n      if (matrix[r][freeVars[fi]] === 1) {\n        deps.push(fi);\n      }\n    }\n    pivotDepArr.push(deps);\n  }\n\n  if (numFree <= 22) {\n    // Use bitmask enumeration (fast, fits in 32-bit int)\n    // Also precompute bitmask version of deps for speed\n    const pivotDepsMask: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      let mask = 0;\n      for (const fi of pivotDepArr[r]) {\n        mask |= (1 << fi);\n      }\n      pivotDepsMask.push(mask);\n    }\n    return enumerateToggleDirect(pivotCol, freeVars, pivotConstArr, pivotDepsMask, numButtons, rank, numFree);\n  } else {\n    return enumerateToggleMITM(pivotCol, freeVars, pivotConstArr, pivotDepArr, numButtons, rank, numFree);\n  }\n}\n\nfunction enumerateToggleDirect(\n  pivotCol: number[],\n  freeVars: number[],\n  pivotConst: number[],\n  pivotDepsMask: number[],\n  numButtons: number,\n  rank: number,\n  numFree: number\n): number[] {\n  let bestPressed: number[] = [];\n  let bestWeight = Infinity;\n\n  const totalCombinations = 1 << numFree;\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    let weight = popcount(mask);\n\n    for (let r = 0; r < rank; r++) {\n      const val = pivotConst[r] ^ (popcount(pivotDepsMask[r] & mask) & 1);\n      weight += val;\n    }\n\n    if (weight < bestWeight) {\n      bestWeight = weight;\n      bestPressed = buildToggleSolutionBitmask(mask, pivotCol, freeVars, pivotConst, pivotDepsMask, numButtons, rank, numFree);\n    } else if (weight === bestWeight) {\n      const pressed = buildToggleSolutionBitmask(mask, pivotCol, freeVars, pivotConst, pivotDepsMask, numButtons, rank, numFree);\n      if (lexSmallerIndices(pressed, bestPressed)) {\n        bestPressed = pressed;\n      }\n    }\n  }\n\n  return bestPressed;\n}\n\nfunction buildToggleSolutionBitmask(\n  mask: number,\n  pivotCol: number[],\n  freeVars: number[],\n  pivotConst: number[],\n  pivotDepsMask: number[],\n  numButtons: number,\n  rank: number,\n  numFree: number\n): number[] {\n  const solution = new Array(numButtons).fill(0);\n  for (let i = 0; i < numFree; i++) {\n    solution[freeVars[i]] = (mask >> i) & 1;\n  }\n  for (let r = 0; r < rank; r++) {\n    solution[pivotCol[r]] = pivotConst[r] ^ (popcount(pivotDepsMask[r] & mask) & 1);\n  }\n  return toPressed(solution, numButtons);\n}\n\nfunction enumerateToggleMITM(\n  pivotCol: number[],\n  freeVars: number[],\n  pivotConst: number[],\n  pivotDepArr: number[][],\n  numButtons: number,\n  rank: number,\n  numFree: number\n): number[] {\n  // Split free variables into two halves\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n\n  // For each pivot row r, split its dependencies into A-half and B-half\n  const depsA: number[][] = []; // depsA[r] = list of free var indices in A that affect pivot r\n  const depsB: number[][] = []; // depsB[r] = list of free var indices in B (relative to halfA)\n  for (let r = 0; r < rank; r++) {\n    const da: number[] = [];\n    const db: number[] = [];\n    for (const fi of pivotDepArr[r]) {\n      if (fi < halfA) {\n        da.push(fi);\n      } else {\n        db.push(fi - halfA);\n      }\n    }\n    depsA.push(da);\n    depsB.push(db);\n  }\n\n  // For A half, use bitmask deps (halfA ≤ 20, fits in 32-bit)\n  const depsAmask: number[] = [];\n  for (let r = 0; r < rank; r++) {\n    let m = 0;\n    for (const fi of depsA[r]) {\n      m |= (1 << fi);\n    }\n    depsAmask.push(m);\n  }\n\n  // For B half, use bitmask deps (halfB ≤ 20, fits in 32-bit)\n  const depsBmask: number[] = [];\n  for (let r = 0; r < rank; r++) {\n    let m = 0;\n    for (const fi of depsB[r]) {\n      m |= (1 << fi);\n    }\n    depsBmask.push(m);\n  }\n\n  // Pack pivot constants into a BigInt signature\n  let constSig = 0n;\n  for (let r = 0; r < rank; r++) {\n    if (pivotConst[r]) {\n      constSig |= (1n << BigInt(r));\n    }\n  }\n\n  // Build A-hal