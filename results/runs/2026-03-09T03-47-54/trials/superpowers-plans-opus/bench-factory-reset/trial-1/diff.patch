+import { describe, it, expect } from 'vitest';
+import { solveToggle, Machine } from './index.js';
+
+describe('solveToggle', () => {
+  it('returns empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]]
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('returns null from the spec example (no solution)', () => {
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]]
+    };
+    // From the spec: b1=0 (from light 2), b0=1 (from light 1), b2=0 (from light 0)
+    // Check light 3: b1 XOR b2 = 0 XOR 0 = 0 != 1 → no solution
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('solves a simple single-button case', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0]]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('returns null when a single light cannot be reached', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: []
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('solves a case needing two buttons', () => {
+    // Lights: [true, true]
+    // Button 0: toggles [0]
+    // Button 1: toggles [1]
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1]]
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('finds the minimum number of presses', () => {
+    // Light 0 needs to be on.
+    // Button 0: toggles [0]
+    // Button 1: toggles [0]
+    // Button 2: toggles [0]
+    // Pressing any single button works (1 press), pressing all three also works (3 presses)
+    // Minimum is 1 press. Lexicographically smallest single button is [0].
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0], [0]]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('returns lexicographically smallest solution when tied on count', () => {
+    // Light 0 needs to be on.
+    // Button 0: toggles [0]
+    // Button 1: toggles [0]
+    // Both are single-press solutions: [0] or [1]. Lex smallest is [0].
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('handles overlapping buttons correctly', () => {
+    // Lights: 3, target [true, false, true]
+    // Button 0: toggles [0, 1]
+    // Button 1: toggles [1, 2]
+    // Press both: light 0 = on, light 1 = on XOR on = off, light 2 = on → [true, false, true] ✓
+    const machine: Machine = {
+      target: [true, false, true],
+      buttons: [[0, 1], [1, 2]]
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('handles case with no buttons needed (empty target)', () => {
+    const machine: Machine = {
+      target: [],
+      buttons: []
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('handles case where pressing no buttons is optimal', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [[0], [1]]
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('handles a larger case', () => {
+    // 5 lights, target [true, true, true, true, true]
+    // Button 0: [0, 1, 2, 3, 4] — toggles all
+    // Pressing button 0 alone gives all true
+    const machine: Machine = {
+      target: [true, true, true, true, true],
+      buttons: [[0, 1, 2, 3, 4]]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('handles multiple free variables', () => {
+    // 1 light, target [true]
+    // Button 0: [0], Button 1: [0], Button 2: [0], Button 3: [0]
+    // Many solutions with 1 press: [0], [1], [2], [3]
+    // Minimum presses = 1, lex smallest = [0]
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0], [0], [0]]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('prefers fewer buttons even if lex order is worse', () => {
+    // 2 lights, target [true, true]
+    // Button 0: [0, 1] (1 press → solution)
+    // Button 1: [0]
+    // Button 2: [1]
+    // Solution with 1 press: [0] → [true, true] ✓
+    // Solution with 2 presses: [1, 2] → [true, true] ✓
+    // Should return [0] (fewer presses)
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+});
