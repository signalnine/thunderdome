      solution[pivotCol[r]] = matrix[r][numButtons];\n    }\n    return toPressed(solution, numButtons);\n  }\n\n  // For each pivot row r, pivot variable = matrix[r][numButtons] XOR sum(matrix[r][freeVars[i]] * freeVars[i]_value)\n  // Precompute the dependency mask: which free variables affect each pivot\n  // pivotDeps[r] = bitmask of which free variables affect pivot r\n  // pivotConst[r] = the constant term (matrix[r][numButtons])\n  const pivotConst: number[] = [];\n  const pivotDeps: number[] = []; // bitmask over free variable indices\n  for (let r = 0; r < rank; r++) {\n    pivotConst.push(matrix[r][numButtons]);\n    let deps = 0;\n    for (let fi = 0; fi < numFree; fi++) {\n      if (matrix[r][freeVars[fi]] === 1) {\n        deps |= (1 << fi);\n      }\n    }\n    pivotDeps.push(deps);\n  }\n\n  if (numFree <= 22) {\n    return enumerateToggleDirect(pivotCol, freeVars, pivotConst, pivotDeps, numButtons, rank, numFree);\n  } else {\n    return enumerateToggleMITM(pivotCol, freeVars, pivotConst, pivotDeps, numButtons, rank, numFree);\n  }\n}\n\nfunction enumerateToggleDirect(\n  pivotCol: number[],\n  freeVars: number[],\n  pivotConst: number[],\n  pivotDeps: number[],\n  numButtons: number,\n  rank: number,\n  numFree: number\n): number[] | null {\n  let bestPressed: number[] | null = null;\n  let bestWeight = Infinity;\n\n  const totalCombinations = 1 << numFree;\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    let weight = popcount(mask); // weight from free variables\n\n    // Compute pivot variable values and their weight\n    for (let r = 0; r < rank; r++) {\n      const depBits = pivotDeps[r] & mask;\n      const val = pivotConst[r] ^ (popcount(depBits) & 1);\n      weight += val;\n    }\n\n    if (weight < bestWeight) {\n      bestWeight = weight;\n      bestPressed = buildToggleSolution(mask, pivotCol, freeVars, pivotConst, pivotDeps, numButtons, rank, numFree);\n    } else if (weight === bestWeight) {\n      const pressed = buildToggleSolution(mask, pivotCol, freeVars, pivotConst, pivotDeps, numButtons, rank, numFree);\n      if (lexSmallerIndices(pressed, bestPressed!)) {\n        bestPressed = pressed;\n      }\n    }\n  }\n\n  return bestPressed;\n}\n\nfunction enumerateToggleMITM(\n  pivotCol: number[],\n  freeVars: number[],\n  pivotConst: number[],\n  pivotDeps: number[],\n  numButtons: number,\n  rank: number,\n  numFree: number\n): number[] | null {\n  // Split free variables into two halves\n  const halfA = Math.min(numFree, Math.floor(numFree / 2));\n  const halfB = numFree - halfA;\n  const maskA = (1 << halfA) - 1; // bits for A half\n\n  // For each A assignment, compute:\n  // - weight contribution from A free vars\n  // - for each pivot, the partial XOR from A free vars\n  // Group by (partial pivot state) -> store best (weight_A, maskA_val)\n  // Partial pivot state: for each pivot r, the parity of (deps_A_r & a_mask)\n  // This is a rank-bit value\n\n  // But rank can be up to 40, so we can't use a simple integer.\n  // Use a string key or split into chunks.\n\n  // Actually, rank ≤ numLights ≤ 40. If numFree > 22 then rank < numButtons.\n  // We need to be careful with large rank values.\n\n  // For the MITM approach, we iterate all 2^halfA A assignments and\n  // all 2^halfB B assignments. For each, we compute weights.\n  // Total: 2^halfA + 2^halfB iterations for building,\n  // then 2^halfB * |A_groups| for the combination step.\n\n  // With halfA ≈ halfB ≈ 20, we have ~1M entries per half.\n  // |A_groups| ≤ 2^rank, but rank can be up to 40.\n  // If rank > 20, iterating all A groups per B entry is too slow.\n\n  // Alternative: enumerate both halves and combine directly.\n  // Group A by (pivot_state_A, weight_A). For each B, compute pivot_state_B,\n  // then the desired pivot_state_A to minimize total weight.\n\n  // Actually, for the toggle problem, the total weight formula is:\n  // weight = weight_free_A + weight_free_B + sum_r(pivotConst[r] XOR parA[r] XOR parB[r])\n  // where parA[r] = parity of (pivotDeps[r] & maskA_val) and parB[r] = parity of (pivotDeps[r] >> halfA & maskB_val)\n\n  // Key insight: sum_r(c_r XOR a_r XOR b_r) where c_r, a_r, b_r are bits\n  // = popcount(c XOR a XOR b) where c, a, b are bit vectors\n\n  // So if we pack the pivot parity contributions into bit vectors:\n  // total_weight = popcountFree(maskA_val) + popcountFree(maskB_val) + popcount(C XOR A_sig XOR B_sig)\n  // where C = packed pivotConst, A_sig = packed parity contributions from A, B_sig from B\n\n  // For each A, compute A_sig (rank bits), weight_free_A = popcount(maskA_val)\n  // Store in map: A_sig -> minimum weight_free_A (and the corresponding maskA_val for lex order)\n\n  // For each B, compute B_sig, weight_free_B.\n  // Then total = weight_free_A + weight_free_B + popcount(C XOR A_sig XOR B_sig)\n  //            = weight_free_A + popcount((C XOR B_sig) XOR A_sig) + weight_free_B\n\n  // For a fixed B, we want to minimize: weight_free_A + popcount(target_sig XOR A_sig)\n  // where target_sig = C XOR B_sig.\n\n  // This requires iterating all distinct A_sig values, which is at most min(2^halfA, 2^rank).\n  // With halfA ≤ 20, at most ~1M values. With 2^halfB ≤ 1M B entries,\n  // total work is 1M * 1M = 10^12 if we iterate all A entries per B. Too slow.\n\n  // BUT: we can group A entries by A_sig and store only the best per group.\n  // Number of distinct A_sig values ≤ min(2^halfA, 2^rank).\n  // For each B entry, iterate all A groups (at most 2^rank or 2^halfA groups).\n  // Total: 2^halfB * min(2^halfA, 2^rank).\n\n  // With halfA = halfB = 20 and rank = 20: 2^20 * 2^20 = 2^40 - still too slow.\n  // With halfA = halfB = 20 and rank = 10: 2^20 * 2^10 = 2^30 ≈ 1B - borderline (~2-3 sec)\n  // With halfA = halfB = 20 and rank = 5:  2^20 * 2^5 = 2^25 ≈ 33M - fast\n\n  // For the case where rank is large and free vars are also large,\n  // we're essentially stuck. But rank + free_vars = numButtons ≤ 40,\n  // and rank ≤ numLights ≤ 40. If free vars = 30, then rank ≤ 10 (since numButtons ≤ 40).\n  // So rank = numButtons - numFree ≤ 40 - numFree.\n  // For numFree = 30, rank ≤ 10. Total: 2^15 * 2^10 = 2^25 ≈ 33M. Fast!\n  // For numFree = 25, rank ≤ 15. Total: 2^12 * 2^15 = 2^27 ≈ 128M. OK for 5s.\n  // For numFree = 23, rank ≤ 17. Total: 2^11 * 2^17 = 2^28 ≈ 256M. Borderline.\n  // For numFree = 22, rank ≤ 18. Total: 2^11 * 2^18 = 2^29 ≈ 512M. Tight.\n\n  // Actually, rank = numButtons - numFree, and numButtons ≤ 40, numFree ≤ 40.\n  // So rank + numFree ≤ 40 (assuming numButtons ≤ 40).\n  // Total work for MITM: 2^(halfB) * min(2^halfA, 2^rank) ≤ 2^(ceil(numFree/2)) * 2^rank\n  // = 2^(ceil(numFree/2) + rank)\n  // Since rank + numFree ≤ 40: ceil(numFree/2) + rank ≤ ceil(numFree/2) + 40 - numFree\n  // = 40 - floor(numFree/2) ≤ 40 - 11 = 29 for numFree ≥ 23.\n  // So total ≤ 2^29 ≈ 512M for numFree = 23 (worst case).\n  // For numFree = 40, rank = 0, total = 2^20 * 1 = 1M. Very fast.\n\n  // This is feasible! Let's implement it.\n\n  // Pack pivot constants into a bigint-style representation\n  // Since rank ≤ 40, use a pair of numbers or BigInt\n  // Let's use BigInt for simplicity\n\n  let constSig = 0n;\n  for (let r = 0; r < rank; r++) {\n    if (pivotConst[r]) {\n      constSig |= (1n << BigInt(r));\n    }\n  }\n\n  // Build A half: compute A_sig for each A assignment\n  // A_sig[r] = parity of (pivotDeps_A[r] & a_mask)\n  // where pivotDeps_A[r] = pivotDeps[r] & maskA (lower halfA bits)\n  const pivotDepsA: number[] = [];\n  for (let r = 0; r < rank; r++) {\n    pivotDepsA.push(pivotDeps[r] & maskA);\n  }\n\n  // Map from A_sig (as bigint) to { bestWeightA, bestMaskA, allEntries }\n  type AEntry = { weightA: number; maskA: number };\n  const aGroups = new Map<bigint, AEntry>();\n\n  const totalA = 1 << halfA;\n  for (let a = 0; a < totalA; a++) {\n    const weightA = popcount(a);\n    let aSig = 0n;\n    for (let r = 0; r < rank; r++) {\n      if (popcount(pivotDepsA[r] & a) & 1) {\n        aSig |= (1n << BigInt(r));\n      }\n    }\n\n    const existing = aGroups.get(aSig);\n    if (!existing || weightA < existing.weightA) {\n      aGroups.set(aSig, { weightA, maskA: a });\n    }\n    // Note: for lexicographic tie-breaking on button indices, we'd need to store\n    // all entries with the same weight. For simplicity, we store the one that\n    // produces the lexicographically smallest pressed-button list.\n    // Since we iterate a from 0 upward, lower a values set lower-indexed free vars first.\n    // We'll refine this below.\n  }\n\n  // Build B half dependencies\n  const pivotDepsB: number[] = [];\n  for (let r = 0; r < rank; r++) {\n    pivotDepsB.push(pivotDeps[r] >> halfA);\n  }\n\n  let bestWeight = Infinity;\n  let bestMaskA = 0;\n  let bestMaskB = 0;\n\n  const totalB = 1 << halfB;\n  for (let b = 0; b < totalB; b++) {\n    const weightB = popcount(b);\n\n    let bSig = 0n;\n    for (let r = 0; r < rank; r++) {\n      if (popcount(pivotDepsB[r] & b) & 1) {\n        bSig |= (1n << BigInt(r));\n      }\n    }\n\n    // For each A group, compute total weight\n    for (const [aSig, entry] of aGroups) {\n      const pivotSig = constSig ^ aSig ^ bSig;\n      let pivotWeight = 0;\n      let tmp = pivotSig;\n      while (tmp > 0n) {\n        pivotWeight += Number(tmp & 1n);\n        tmp >>= 1n;\n      }\n\n      const totalWeight = entry.weightA + weightB + pivotWeight;\n      if (totalWeight < bestWeight) {\n        bestWeight = totalWeight;\n        bestMaskA = entry.maskA;\n        bestMaskB = b;\n      } else if (totalWeight === bestWeight) {\n        // Compare lex order of pressed indices\n        const currentPressed = buildToggleSolutionFromMasks(\n          entry.maskA, b, halfA, pivotCol, freeVars, pivotConst, pivotDeps, numButtons, rank, numFree\n        );\n        const bestPressedSoFar = buildToggleSolutionFromMasks(\n          bestMaskA, bestMaskB, halfA, pivotCol, freeVars, pivotConst, pivotDeps, numButtons, rank, numFree\n        );\n        if (lexSmallerIndices(currentPressed, bestPressedSoFar)) {\n          bestMaskA = entry.maskA;\n          bestMaskB = b;\n        }\n      }\n    }\n  }\n\n  return buildToggleSolutionFromMasks(\n    bestMaskA, bestMaskB, halfA, pivotCol, freeVars, pivotConst, pivotDeps, numButtons, rank, numFree\n  );\n}\n\nfunction buildToggleSolutionFromMasks(\n  maskA: number,\n  maskB: number,\n  halfA: number,\n  pivotCol: number[],\n  freeVars: number[],\n  pivotConst: number[],\n  pivotDeps: number[],\n  numButtons: number,\n  rank: number,\n  numFree: number\n): number[] {\n  const fullMask = maskA | (maskB << halfA);\n  return buildToggleSolution(fullMask, pivotCol, freeVars, pivotConst, pivotDeps, numButtons, rank, numFree);\n}\n\nfunction buildToggleSolution(\n  mask: number,\n  pivotCol: number[],\n  freeVars: number[],\n  pivotConst: number[],\n  pivotDeps: number[],\n  numButtons: number,\n  rank: number,\n  numFree: number\n): number[] {\n  const solution = new Array(numButtons).fill(0);\n  for (let i = 0; i < numFree; i++) {\n    solution[freeVars[i]] = (mask >> i) & 1;\n  }\n  for (let r = 0; r < rank; r++) {\n    const depBits = pivotDeps[r] & mask;\n    solution[pivotCol[r]] = pivotConst[r] ^ (popcount(depBits) & 1);\n  }\n  return toPressed(solution, numButtons);\n}\n\nfunction toPressed(solution: number[], numButtons: number): number[] {\n  const pressed: number[] = [];\n  for (let i = 0; i < numButtons; i++) {\n    if (solution[i] === 1) pressed.push(i);\n  }\n  return pressed;\n}\n\nfunction popcount(n: number): number {\n  n = n - ((n >> 1) & 0x55555555);\n  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);\n  return (((n + (n >> 4)) & 0x0F0F0F0F) * 0x01010101) >> 24;\n}\n\nfunction lexSmallerIndices(a: number[], b: number[]): boolean {\n  const len = Math.max(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    const ai = i < a.length ? a[i] : Infinity;\n    const bi = i < b.length ? b[i] : Infinity;\n    if (ai < bi) return true;\n    if (ai > bi) return false;\n  }\n  return false;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix over GF(modulus)\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(modulus)\n  const pivotCol: number[] = [];\n  let currentRow = 0;\n\n  for (let col = 0; col < numButtons && currentRow < numCounters; col++) {\n    let pivotRow = -1;\n    for (let row = currentRow; row < numCounters; row++) {\n      if (matrix[row][col] !== 0) {\n        pivotRow = row;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    [matrix[currentRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[currentRow]];\n\n    const pivotVal = matrix[currentRow][col];\n    const inv = modInverse(pivotVal, modulus);\n    for (let k = 0; k <= numButtons; k++) {\n      matrix[currentRow][k] = (matrix[currentRow][k] * inv) % modulus;\n    }\n\n    for (let row = 0; row < numCounters; row++) {\n      if (row !== currentRow && matrix[row][col] !== 0) {\n        const factor = matrix[row][col];\n        for (let k = 0; k <= numButtons; k++) {\n          matrix[row][k] = ((matrix[row][k] - factor * matrix[currentRow][k]) % modulus + modulus) % modulus;\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    currentRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check consistency\n  for (le