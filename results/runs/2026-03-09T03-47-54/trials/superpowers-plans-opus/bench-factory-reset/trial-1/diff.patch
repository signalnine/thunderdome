+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    // Minimum presses: 5 (one per light).
+    // Buttons 0-4 each toggle a unique light, so pressing [0,1,2,3,4] works.
