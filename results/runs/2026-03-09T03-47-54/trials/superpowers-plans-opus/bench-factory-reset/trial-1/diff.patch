+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+describe('solveToggle stress tests', () => {
+  it('handles 40 lights, 40 buttons with unique solution (full rank)', () => {
+    // Each button toggles exactly one unique light (identity matrix)
+    const numLights = 40;
+    const target = new Array(numLights).fill(true);
+    const buttons: number[][] = [];
+    for (let i = 0; i < numLights; i++) {
+      buttons.push([i]);
+    }
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    // All buttons must be pressed
+    expect(result!.length).toBe(40);
+    expect(result).toEqual(Array.from({ length: 40 }, (_, i) => i));
+  });
+
+  it('handles 40 buttons all toggling same light (many free vars)', () => {
+    // 1 light, 40 buttons all toggling light 0
+    // Target: true (light 0 must be on)
+    // Need odd number of presses. Minimum = 1.
+    // Lex smallest single button press is [0].
+    const buttons: number[][] = [];
+    for (let i = 0; i < 40; i++) {
+      buttons.push([0]);
+    }
+    const machine: Machine = {
+      target: [true],
+      buttons
+    };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(result!.length).toBe(1);
+    expect(result).toEqual([0]);
+  });
+
+  it('handles 5 lights, 30 buttons with free variables', () => {
+    // 5 lights, 30 buttons. Each button toggles lights at index i % 5.
+    // Rank will be at most 5, so up to 25 free variables.
