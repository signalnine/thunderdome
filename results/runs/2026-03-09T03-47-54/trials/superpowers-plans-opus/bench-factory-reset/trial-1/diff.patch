+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix over GF(2): numLights rows x (numButtons + 1) cols
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(2) — reduced row echelon form
+  const pivotCol: number[] = [];
+  let currentRow = 0;
+  for (let col = 0; col < numButtons && currentRow < numLights; col++) {
+    let pivotRow = -1;
+    for (let row = currentRow; row < numLights; row++) {
+      if (matrix[row][col] === 1) {
+        pivotRow = row;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    [matrix[currentRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[currentRow]];
+
+    for (let row = 0; row < numLights; row++) {
+      if (row !== currentRow && matrix[row][col] === 1) {
+        for (let k = 0; k <= numButtons; k++) {
+          matrix[row][k] ^= matrix[currentRow][k];
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    currentRow++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check consistency
+  for (let row = rank; row < numLights; row++) {
+    if (matrix[row][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotSet.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const solution = new Array(numButtons).fill(0);
+    for (let r = 0; r < rank; r++) {
+      solution[pivotCol[r]] = matrix[r][numButtons];
+    }
+    return toPressed(solution, numButtons);
+  }
+
+  // Precompute: for each pivot row, which free vars affect it and the constant
+  const pivotConstArr: number[] = [];
+  const pivotDepArr: number[][] = []; // pivotDepArr[r] = list of free var indices that affect pivot r
+  for (let r = 0; r < rank; r++) {
+    pivotConstArr.push(matrix[r][numButtons]);
+    const deps: number[] = [];
+    for (let fi = 0; fi < numFree; fi++) {
+      if (matrix[r][freeVars[fi]] === 1) {
+        deps.push(fi);
+      }
+    }
+    pivotDepArr.push(deps);
+  }
+
+  if (numFree <= 22) {
+    // Use bitmask enumeration (fast, fits in 32-bit int)
+    // Also precompute bitmask version of deps for speed
+    const pivotDepsMask: number[] = [];
+    for (let r = 0; r < rank; r++) {
+      let mask = 0;
+      for (const fi of pivotDepArr[r]) {
+        mask |= (1 << fi);
+      }
+      pivotDepsMask.push(mask);
+    }
+    return enumerateToggleDirect(pivotCol, freeVars, pivotConstArr, pivotDepsMask, numButtons, rank, numFree);
+  } else {
+    return enumerateToggleMITM(pivotCol, freeVars, pivotConstArr, pivotDepArr, numButtons, rank, numFree);
+  }
+}
+
+function enumerateToggleDirect(
+  pivotCol: number[],
+  freeVars: number[],
+  pivotConst: number[],
+  pivotDepsMask: number[],
+  numButtons: number,
+  rank: number,
+  numFree: number
+): number[] {
+  let bestPressed: number[] = [];
+  let bestWeight = Infinity;
+
+  const totalCombinations = 1 << numFree;
+  for (let mask = 0; mask < totalCombinations; mask++) {
+    let weight = popcount(mask);
+
+    for (let r = 0; r < rank; r++) {
+      const val = pivotConst[r] ^ (popcount(pivotDepsMask[r] & mask) & 1);
+      weight += val;
+    }
+
+    if (weight < bestWeight) {
+      bestWeight = weight;
+      bestPressed = buildToggleSolutionBitmask(mask, pivotCol, freeVars, pivotConst, pivotDepsMask, numButtons, rank, numFree);
+    } else if (weight === bestWeight) {
+      const pressed = buildToggleSolutionBitmask(mask, pivotCol, freeVars, pivotConst, pivotDepsMask, numButtons, rank, numFree);
+      if (lexSmallerIndices(pressed, bestPressed)) {
+        bestPressed = pressed;
+      }
+    }
+  }
+
+  return bestPressed;
+}
+
+function buildToggleSolutionBitmask(
+  mask: number,
+  pivotCol: number[],
+  freeVars: number[],
+  pivotConst: number[],
+  pivotDepsMask: number[],
+  numButtons: number,
+  rank: number,
+  numFree: number
+): number[] {
+  const solution = new Array(numButtons).fill(0);
+  for (let i = 0; i < numFree; i++) {
+    solution[freeVars[i]] = (mask >> i) & 1;
+  }
+  for (let r = 0; r < rank; r++) {
+    solution[pivotCol[r]] = pivotConst[r] ^ (popcount(pivotDepsMask[r] & mask) & 1);
+  }
+  return toPressed(solution, numButtons);
+}
+
+function enumerateToggleMITM(
+  pivotCol: number[],
+  freeVars: number[],
+  pivotConst: number[],
+  pivotDepArr: number[][],
+  numButtons: number,
+  rank: number,
+  numFree: number
+): number[] {
+  // Split free variables into two halves (each ≤ 20)
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+
+  // For each pivot row, compute bitmask deps for A and B halves
+  const depsAmask: number[] = [];
+  const depsBmask: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    let ma = 0;
+    let mb = 0;
+    for (const fi of pivotDepArr[r]) {
+      if (fi < halfA) {
+        ma |= (1 << fi);
+      } else {
+        mb |= (1 << (fi - halfA));
+      }
+    }
+    depsAmask.push(ma);
+    depsBmask.push(mb);
+  }
+
+  // Pack pivot constants into an integer signature (rank ≤ 18 when numFree > 22)
+  let constSig = 0;
+  for (let r = 0; r < rank; r++) {
+    if (pivotConst[r]) {
+      constSig |= (1 << r);
+    }
+  }
+
+  // Build A-half table: signature (rank-bit int) -> best (weight, maskA)
+  // Use array indexed by signature for fast lookup (max 2^18 = 262144 entries)
+  const sigSize = 1 << rank;
+  const aWeights = new Int32Array(sigSize).fill(-1); // -1 = not set
+  const aMasks = new Int32Array(sigSize);
+
+  const totalA = 1 << halfA;
+  for (let a = 0; a < totalA; a++) {
+    const weightA = popcount(a);
+    let aSig = 0;
+    for (let r = 0; r < rank; r++) {
+      if (popcount(depsAmask[r] & a) & 1) {
+        aSig |= (1 << r);
+      }
+    }
+
+    if (aWeights[aSig] === -1 || weightA < aWeights[aSig]) {
+      aWeights[aSig] = weightA;
+      aMasks[aSig] = a;
+    }
+  }
+
+  // Iterate B-half, combine with A entries
+  let bestWeight = Infinity;
+  let bestMaskA = 0;
+  let bestMaskB = 0;
+
+  const totalB = 1 << halfB;
+  for (let b = 0; b < totalB; b++) {
+    const weightB = popcount(b);
+    if (weightB >= bestWeight) continue; // pruning: can't possibly beat best
+
+    let bSig = 0;
+    for (let r = 0; r < rank; r++) {
+      if (popcount(depsBmask[r] & b) & 1) {
+        bSig |= (1 << r);
+      }
+    }
+
+    // Iterate all possible A signatures
+    for (let aSig = 0; aSig < sigSize; aSig++) {
+      if (aWeights[aSig] === -1) continue;
+
+      const pivotSig = constSig ^ aSig ^ bSig;
+      const pivotWeight = popcount(pivotSig);
+      const totalWeight = aWeights[aSig] + weightB + pivotWeight;
+
+      if (totalWeight < bestWeight) {
+        bestWeight = totalWeight;
+        bestMaskA = aMasks[aSig];
+        bestMaskB = b;
+      } else if (totalWeight === bestWeight) {
+        const currentPressed = buildToggleSolutionMITM(
+          aMasks[aSig], b, halfA, pivotCol, freeVars, pivotConst, pivotDepArr, numButtons, rank, numFree
+        );
+        const bestPressedSoFar = buildToggleSolutionMITM(
+          bestMaskA, bestMaskB, halfA, pivotCol, freeVars, pivotConst, pivotDepArr, numButtons, rank, numFree
+        );
+        if (lexSmallerIndices(currentPressed, bestPressedSoFar)) {
+          bestMaskA = aMasks[aSig];
+          bestMaskB = b;
+        }
+      }
+    }
+  }
+
+  return buildToggleSolutionMITM(
+    bestMaskA, bestMaskB, halfA, pivotCol, freeVars, pivotConst, pivotDepArr, numButtons, rank, numFree
+  );
+}
+
+function buildToggleSolutionMITM(
+  maskA: number,
+  maskB: number,
+  halfA: number,
+  pivotCol: number[],
+  freeVars: number[],
+  pivotConst: number[],
+  pivotDepArr: number[][],
+  numButtons: number,
+  rank: number,
+  numFree: number
+): number[] {
+  const solution = new Array(numButtons).fill(0);
+  // Set A-half free vars from maskA
+  for (let i = 0; i < halfA; i++) {
+    solution[freeVars[i]] = (maskA >> i) & 1;
+  }
+  // Set B-half free vars from maskB
+  for (let i = halfA; i < numFree; i++) {
+    solution[freeVars[i]] = (maskB >> (i - halfA)) & 1;
+  }
+  // Compute pivot variables
+  for (let r = 0; r < rank; r++) {
+    let val = pivotConst[r];
+    for (const fi of pivotDepArr[r]) {
+      val ^= solution[freeVars[fi]];
+    }
+    solution[pivotCol[r]] = val;
+  }
+  return toPressed(solution, numButtons);
+}
+
+function toPressed(solution: number[], numButtons: number): number[] {
+  const pressed: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (solution[i] === 1) pressed.push(i);
+  }
+  return pressed;
+}
+
+function popcount(n: number): number {
+  n = n - ((n >> 1) & 0x55555555);
+  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);
+  return (((n + (n >> 4)) & 0x0F0F0F0F) * 0x01010101) >> 24;
+}
+
+function lexSmallerIndices(a: number[], b: number[]): boolean {
+  const len = Math.max(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    const ai = i < a.length ? a[i] : Infinity;
+    const bi = i < b.length ? b[i] : Infinity;
+    if (ai < bi) return true;
+    if (ai > bi) return false;
+  }
+  return false;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix over GF(modulus)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(modulus)
+  const pivotCol: number[] = [];
+  let currentRow = 0;
+
+  for (let col = 0; col < numButtons && currentRow < numCounters; col++) {
+    let pivotRow = -1;
+    for (let row = currentRow; row < numCounters; row++) {
+      if (matrix[row][col] !== 0) {
+        pivotRow = row;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    [matrix[currentRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[currentRow]];
+
+    const pivotVal = matrix[currentRow][col];
+    const inv = modInverse(pivotVal, modulus);
+    for (let k = 0; k <= numButtons; k++) {
+      matrix[currentRow][k] = (matrix[currentRow][k] * inv) % modulus;
+    }
+
+    for (let row = 0; row < numCounters; row++) {
+      if (row !== currentRow && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let k = 0; k <= numButtons; k++) {
+          matrix[row][k] = ((matrix[row][k] - factor * matrix[currentRow][k]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    currentRow++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check consistency
+  for (let row = rank; row < numCounters; row++) {
+    if (matrix[row][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotSet.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const solution = new Array(numButtons).fill(0);
+    for (let r = 0; r < rank; r++) {
+      solution[pivotCol[r]] = matrix[r][numButtons];
+    }
+    return solution;
+  }
+
+  // Precompute dependency coefficients
+  const pivotCoeffs: number[][] = [];
+  const pivotConsts: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    pivotConsts.push(matrix[r][numButtons]);
+    const coeffs: number[] = [];
+    for (let fi = 0; fi < numFree; fi++) {
+      coeffs.push(matrix[r][freeVars[fi]]);
+    }
+    pivotCoeffs.push(coeffs);
+  }
+
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  if (totalCombinations <= 5_000_000) {
+    return enumerateCounterDirect(
+      pivotCol, freeVars, pivotConsts, pivotCoeffs,
+      numButtons, rank, numFree, modulus
+    );
+  } else {
+    return enumerateCounterMITM(
+      pivotCol, freeVars, pivotConsts, pivotCoeffs,
+      numButtons, rank, numFree, modulus
+    );
+  }
+}
+
+function enumerateCounterDirect(
+  pivotCol: number[],
+  freeVars: number[],
+  pivotConsts: number[],
+  pivotCoeffs: number[][],
+  numButtons: number,
+  rank: number,
+  numFree: number,
+  modulus: number
+): number[] {
+  let bestSolution: number[] | null = null;
+  let bestWeight = Infinity;
+
+  const assignment = new Array(numFree).fill(0);
+
+  for (;;) {
+    const solution = new Array(numButtons).fill(0);
+    let weight = 0;
+
+    for (let i = 0; i < numFree; i++) {
+      solution[freeVars[i]] = assignment[i];
+      weight += assignment[i];
+    }
+
+    for (let r = 0; r < rank; r++) {
+      let val = pivotConsts[r];
+      for (let fi = 0; fi < numFree; fi++) {
+        val = ((val - pivotCoeffs[r][fi] * assignment[fi]) % modulus + modulus) % modulus;
+      }
+      solution[pivotCol[r]] = val;
+      weight += val;
+    }
+
+    if (weight < bestWeight || (weight === bestWeight && lexSmaller(solution, bestSolution!))) {
+      bestWeight = weight;
+      bestSolution = [...solution];
+    }
+
+    let carry = true;
+    for (let i = 0; i < numFree && carry; i++) {
+      assignment[i]++;
+      if (assignment[i] >= modulus) {
+        assignment[i] = 0;
+      } else {
+        carry = false;
+      }
+    }
+    if (carry) break;
+  }
+
+  return bestSolution!;
+}
+
+function enumerateCounterMITM(
+  pivotCol: number[],
+  freeVars: number[],
+  pivotConsts: number[],
+  pivotCoeffs: number[][],
+  numButtons: number,
+  rank: number,
+  numFree: number,
+  modulus: number
+): number[] {
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+
+  // For each A assignment, compute partial pivot contributions and weight
+  // Group by signature (partial pivot contributions mod p) -> keep best per group
+  type AEntry = { weightA: number; assignA: number[] };
+  const aGroups = new Map<string, AEntry>();
+
+  const assignmentA = new Array(halfA).fill(0);
+  for (;;) {
+    let weightA = 0;
+    for (let i = 0; i < halfA; i++) {
+      weightA += assignmentA[i];
+    }
+
+    const partials: number[] = [];
+    for (let r = 0; r < rank; r++) {
+      let partial = 0;
+      for (let fi = 0; fi < halfA; fi++) {
+        partial = (partial + pivotCoeffs[r][fi] * assignmentA[fi]) % modulus;
+      }
+      partials.push(partial);
+    }
+
+    const key = partials.join(',');
+    const existing = aGroups.get(key);
+    if (!existing || weightA < existing.weightA ||
+        (weightA === existing.weightA && lexSmaller(assignmentA, existing.assignA))) {
+      aGroups.set(key, { weightA, assignA: [...assignmentA] });
+    }
+
+    let carry = true;
+    for (let i = 0; i < halfA && carry; i++) {
+      assignmentA[i]++;
+      if (assignmentA[i] >= modulus) {
+        assignmentA[i] = 0;
+      } else {
+        carry = false;
+      }
+    }
+    if (carry) break;
+  }
+
+  let bestSolution: number[] | null = null;
+  let bestWeight = Infinity;
+
+  const assignmentB = new Array(halfB).fill(0);
+  for (;;) {
+    let weightB = 0;
+    for (let i = 0; i < halfB; i++) {
+      weightB += assignmentB[i];
+    }
+
+    const partialsB: number[] = [];
+    for (let r = 0; r < rank; r++) {
+      let partial = 0;
+      for (let fi = halfA; fi < numFree; fi++) {
+        partial = (partial + pivotCoeffs[r][fi] * assignmentB[fi - halfA]) % modulus;
+      }
+      partialsB.push(partial);
+    }
+
+    for (const [key, entry] of aGroups) {
+      const partialsA = key.split(',').map(Number);
+
+      let pivotWeight = 0;
+      for (let r = 0; r < rank; r++) {
+        const val = ((pivotConsts[r] - partialsA[r] - partialsB[r]) % modulus + modulus * 2) % modulus;
+        pivotWeight += val;
+      }
+
+      const totalWeight = entry.weightA + weightB + pivotWeight;
+      if (totalWeight < bestWeight) {
+        bestWeight = totalWeight;
+        bestSolution = buildCounterSolution(
+          entry.assignA, assignmentB, pivotCol, freeVars, pivotConsts, pivotCoeffs, numButtons, rank, numFree, modulus
+        );
+      } else if (totalWeight === bestWeight) {
+        const candidate = buildCounterSolution(
+          entry.assignA, assignmentB, pivotCol, freeVars, pivotConsts, pivotCoeffs, numButtons, rank, numFree, modulus
+        );
+        if (lexSmaller(candidate, bestSolution!)) {
+          bestSolution = candidate;
+        }
+      }
+    }
+
+    let carry = true;
+    for (let i = 0; i < halfB && carry; i++) {
+      assignmentB[i]++;
+      if (assignmentB[i] >= modulus) {
+        assignmentB[i] = 0;
+      } else {
+        carry = false;
+      }
+    }
+    if (carry) break;
+  }
+
+  return bestSolution!;
+}
+
+function buildCounterSolution(
+  assignA: number[],
+  assignB: number[],
+  pivotCol: number[],
+  freeVars: number[],
+  pivotConsts: number[],
+  pivotCoeffs: number[][],
+  numButtons: number,
+  rank: number,
+  numFree: number,
+  modulus: number
+): number[] {
+  const solution = new Array(numButtons).fill(0);
+  const halfA = assignA.length;
+  for (let i = 0; i < halfA; i++) {
+    solution[freeVars[i]] = assignA[i];
+  }
+  for (let i = 0; i < assignB.length; i++) {
+    solution[freeVars[halfA + i]] = assignB[i];
+  }
+
+  for (let r = 0; r < rank; r++) {
+    let val = pivotConsts[r];
+    for (let fi = 0; fi < numFree; fi++) {
+      val = ((val - pivotCoeffs[r][fi] * solution[freeVars[fi]]) % modulus + modulus) % modulus;
+    }
+    solution[pivotCol[r]] = val;
+  }
+
+  return solution;
+}
+
+function modInverse(a: number, m: number): number {
+  let [old_r, r] = [((a % m) + m) % m, m];
+  let [old_s, s] = [1, 0];
+
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+
+  return ((old_s % m) + m) % m;
+}
