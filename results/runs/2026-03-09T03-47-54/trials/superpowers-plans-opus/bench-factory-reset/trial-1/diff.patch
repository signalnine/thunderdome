+import { describe, it, expect } from 'vitest';
+import { solveCounter } from './index.js';
+
+describe('solveCounter', () => {
+  it('returns all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('solves a simple single-button case', () => {
+    // Counter 0 needs to be 3 (mod 5)
+    // Button 0 increments counter 0
+    // Press button 0 three times → counter 0 = 3
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('returns null when no solution exists', () => {
+    // Counter 0 needs to be 1, counter 1 needs to be 0
+    // Button 0 increments both counters 0 and 1
+    // Pressing button 0 any number of times gives equal values for both
+    // So counter 0 = 1, counter 1 = 0 is impossible
+    const result = solveCounter([1, 0], [[0, 1]], 5);
+    expect(result).toBeNull();
+  });
+
+  it('solves a two-button case', () => {
+    // Counters: [2, 3] mod 5
+    // Button 0: increments [0]
+    // Button 1: increments [1]
+    // Solution: press button 0 twice, button 1 three times
+    const result = solveCounter([2, 3], [[0], [1]], 5);
+    expect(result).toEqual([2, 3]);
+  });
+
+  it('finds minimum total presses', () => {
+    // Counter 0 needs to be 1 (mod 5)
+    // Button 0: increments [0]
+    // Button 1: increments [0]
+    // Solutions: b0=1,b1=0 (sum=1), b0=0,b1=1 (sum=1), b0=2,b1=4 (sum=6), etc.
+    // Minimum sum = 1, lex smallest with sum 1 is [0, 1] (b0=0, b1=1)
+    // Wait: [1, 0] vs [0, 1] — lex smallest is [0, 1]
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('returns lex smallest when tied on total presses', () => {
+    // Counter 0 needs to be 1 (mod 3)
+    // Button 0: increments [0]
+    // Button 1: increments [0]
+    // Min sum solutions with sum=1: b0=0,b1=1 → [0,1] or b0=1,b1=0 → [1,0]
+    // Lex smallest is [0, 1]
+    const result = solveCounter([1], [[0], [0]], 3);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('handles modulus 2 (similar to toggle)', () => {
+    // Counter 0 needs to be 1, counter 1 needs to be 1 (mod 2)
+    // Button 0: [0], Button 1: [1]
+    // Solution: [1, 1]
+    const result = solveCounter([1, 1], [[0], [1]], 2);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('handles wrapping correctly', () => {
+    // Counter 0 needs to be 0 (mod 5)
+    // Button 0: increments [0]
+    // Pressing 0 times → counter = 0, pressing 5 times → counter = 0 (but max is 4)
+    // So pressing 0 times is the answer
+    const result = solveCounter([0], [[0]], 5);
+    expect(result).toEqual([0]);
+  });
+
+  it('handles overlapping buttons', () => {
+    // Counters: [1, 1] mod 3
+    // Button 0: [0, 1] (increments both)
+    // Solution: press button 0 once → both = 1
+    const result = solveCounter([1, 1], [[0, 1]], 3);
+    expect(result).toEqual([1]);
+  });
+
+  it('handles empty counters', () => {
+    const result = solveCounter([], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  it('handles larger modulus', () => {
+    // Counter 0 needs to be 50 (mod 97)
+    // Button 0: [0]
+    // Solution: press 50 times
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+  });
+
+  it('finds solution with multiple counters and buttons', () => {
+    // Counters: [1, 2, 0] mod 5
+    // Button 0: [0]
+    // Button 1: [1]
+    // Button 2: [2]
+    // Solution: [1, 2, 0]
+    const result = solveCounter([1, 2, 0], [[0], [1], [2]], 5);
+    expect(result).toEqual([1, 2, 0]);
+  });
+
+  it('handles case where fewer presses preferred via modular arithmetic', () => {
+    // Counter 0 needs to be 4 (mod 5)
+    // Button 0: increments [0]
+    // Pressing 4 times → counter = 4 (sum=4)
+    // That's the only option since there's only one button
+    const result = solveCounter([4], [[0]], 5);
+    expect(result).toEqual([4]);
+  });
+});
