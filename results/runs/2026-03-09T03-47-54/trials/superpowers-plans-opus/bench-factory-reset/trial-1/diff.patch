+
+  it('handles modulus 97 with unique solution', () => {
+    const lights = [50, 33, 77];
+    const buttons: number[][] = [[0], [1], [2]];
+    const result = solveCounter(lights, buttons, 97);
+    expect(result).toEqual([50, 33, 77]);
+  });
+
+  it('handles no solution with counters', () => {
+    // 2 counters, 1 button that increments both
+    // Target: [1, 2] mod 5 — impossible since both counters always have same value
+    const result = solveCounter([1, 2], [[0, 1]], 5);
+    expect(result).toBeNull();
+  });
+
+  it('handles large modulus with free variables', () => {
+    // 1 counter, 3 buttons all incrementing counter 0
+    // Target: 1 mod 97
+    // Solutions: any (b0, b1, b2) where b0+b1+b2 ≡ 1 (mod 97)
+    // Minimum total: 1 (e.g., [0, 0, 1] or [0, 1, 0] or [1, 0, 0])
+    // Lex smallest with sum 1: [0, 0, 1]
+    const result = solveCounter([1], [[0], [0], [0]], 97);
+    expect(result).not.toBeNull();
+    const sum = result!.reduce((a, b) => a + b, 0);
+    expect(sum % 97).toBe(1);
+    expect(sum).toBe(1);
