new file mode 100644
index 0000000..2ea1436
--- /dev/null
+++ b/src/tracker.test.ts
@@ -0,0 +1,258 @@
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import * as fs from "node:fs";
+import * as path from "node:path";
+import * as os from "node:os";
+import { TimeTracker } from "./tracker.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "time-tracker-test-"));
+  return path.join(dir, "data.json");
+}
+
+function cleanup(filePath: string): void {
+  try {
+    fs.rmSync(path.dirname(filePath), { recursive: true, force: true });
+  } catch {
+    // ignore
+  }
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    cleanup(filePath);
+  });
+
+  describe("start", () => {
+    it("should create a new entry when starting a timer", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+      expect(entries[0].start).toBeTruthy();
+      expect(entries[0].end).toBeNull();
+    });
+
+    it("should throw when starting with an empty name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("")).toThrow();
+    });
+
+    it("should throw when starting with a whitespace-only name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("   ")).toThrow();
+    });
+
+    it("should auto-stop the previous timer when starting a new one", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("task1");
+      expect(entries[0].end).not.toBeNull();
+      expect(entries[1].task).toBe("task2");
+      expect(entries[1].end).toBeNull();
+    });
+  });
+
+  describe("stop", () => {
+    it("should stop the running timer", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].end).not.toBeNull();
+    });
+
+    it("should throw when stopping with no running timer", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.stop()).toThrow();
+    });
+
+    it("should throw when stopping after already stopped", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow();
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to disk", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+
+      // Read file directly
+      const data = JSON.parse(fs.readFileSync(filePath, "utf-8"));
+      expect(data).toHaveLength(1);
+      expect(data[0].task).toBe("coding");
+    });
+
+    it("should load entries from disk on construction", () => {
+      const tracker1 = new TimeTracker(filePath);
+      tracker1.start("coding");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+      expect(entries[0].end).not.toBeNull();
+    });
+
+    it("should create parent directories if they don't exist", () => {
+      const deepPath = path.join(
+        os.tmpdir(),
+        "time-tracker-deep-" + Date.now(),
+        "a",
+        "b",
+        "c",
+        "data.json"
+      );
+      const tracker = new TimeTracker(deepPath);
+      tracker.start("coding");
+      tracker.stop();
+
+      expect(fs.existsSync(deepPath)).toBe(true);
+
+      // Cleanup
+      fs.rmSync(path.join(os.tmpdir(), path.basename(path.resolve(deepPath, "../../../.."))), {
+        recursive: true,
+        force: true,
+      });
+    });
+
+    it("should handle missing file gracefully on construction", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(tracker.getEntries()).toHaveLength(0);
+    });
+  });
+
+  describe("getEntriesByDateRange", () => {
+    it("should filter entries by date range", () => {
+      // Write entries directly for deterministic dates
+      const entries = [
+        { task: "old", start: "2024-01-01T00:00:00.000Z", end: "2024-01-01T01:00:00.000Z" },
+        { task: "mid", start: "2024-06-15T00:00:00.000Z", end: "2024-06-15T01:00:00.000Z" },
+        { task: "new", start: "2024-12-31T00:00:00.000Z", end: "2024-12-31T01:00:00.000Z" },
+      ];
+      fs.writeFileSync(filePath, JSON.stringify(entries), "utf-8");
+
+      const tracker2 = new TimeTracker(filePath);
+      const filtered = tracker2.getEntriesByDateRange(
+        new Date("2024-06-01T00:00:00.000Z"),
+        new Date("2024-07-01T00:00:00.000Z")
+      );
+
+      expect(filtered).toHaveLength(1);
+      expect(filtered[0].task).toBe("mid");
+    });
+
+    it("should return empty array when no entries match", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+
+      const filtered = tracker.getEntriesByDateRange(
+        new Date("2020-01-01"),
+        new Date("2020-12-31")
+      );
+      expect(filtered).toHaveLength(0);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations for the same task", () => {
+      const entries = [
+        { task: "coding", start: "2024-01-01T00:00:00.000Z", end: "2024-01-01T01:00:00.000Z" },
+        { task: "coding", start: "2024-01-01T02:00:00.000Z", end: "2024-01-01T03:00:00.000Z" },
+        { task: "meeting", start: "2024-01-01T04:00:00.000Z", end: "2024-01-01T04:30:00.000Z" },
+      ];
+      fs.writeFileSync(filePath, JSON.stringify(entries), "utf-8");
+
+      const tracker = new TimeTracker(filePath);
+      const summary = tracker.getSummary();
+
+      expect(summary["coding"]).toBe(2 * 60 * 60 * 1000); // 2 hours
+      expect(summary["meeting"]).toBe(30 * 60 * 1000); // 30 minutes
+    });
+
+    it("should use current time for running tasks", () => {
+      // Write an entry with a start time 1 second in the past
+      const oneSecAgo = new Date(Date.now() - 1000).toISOString();
+      const entries = [{ task: "coding", start: oneSecAgo, end: null }];
+      fs.writeFileSync(filePath, JSON.stringify(entries), "utf-8");
+
+      const tracker = new TimeTracker(filePath);
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(900);
+      expect(summary["coding"]).toBeLessThan(5000);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("编码任务");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("编码任务");
+    });
+
+    it("should handle emoji task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("🚀 Deploy");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("🚀 Deploy");
+    });
+
+    it("should persist and reload unicode names", () => {
+      const tracker1 = new TimeTracker(filePath);
+      tracker1.start("café ☕ break");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("café ☕ break");
+    });
+
+    it("should summarize unicode task names correctly", () => {
+      const entries = [
+        { task: "🎯 focus", start: "2024-01-01T00:00:00.000Z", end: "2024-01-01T01:00:00.000Z" },
+        { task: "🎯 focus", start: "2024-01-01T02:00:00.000Z", end: "2024-01-01T03:00:00.000Z" },
+      ];
+      fs.writeFileSync(filePath, JSON.stringify(entries), "utf-8");
+
+      const tracker = new TimeTracker(filePath);
+      const summary = tracker.getSummary();
+      expect(summary["🎯 focus"]).toBe(2 * 60 * 60 * 1000);
+    });
+  });
+
+  describe("getEntries returns copies", () => {
+    it("should return a copy of entries, not a reference", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      entries.pop();
+      expect(tracker.getEntries()).toHaveLength(1);
+    });
+  });
+});
