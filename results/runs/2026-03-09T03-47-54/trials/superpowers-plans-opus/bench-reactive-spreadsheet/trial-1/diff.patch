+import { describe, it, expect } from 'vitest';
+import { Spreadsheet } from '../index.js';
+
+describe('Spreadsheet', () => {
+  describe('basic values', () => {
+    it('stores and retrieves numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('stores and retrieves strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('stores and retrieves booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+    });
+
+    it('returns null for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.get('A1')).toBe(null);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('displays numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('displays strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('displays booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('TRUE');
+    });
+
+    it('displays empty cells as empty string', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('displays formula results', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('formulas', () => {
+    it('evaluates simple addition', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('evaluates with parentheses', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 5);
+      sheet.set('C1', '=(A1+B1)*2');
+      expect(sheet.get('C1')).toBe(30);
+    });
+
+    it('evaluates SUM', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('A3', 3);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(6);
+    });
+
+    it('evaluates AVERAGE', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=AVERAGE(A1:A3)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+
+    it('evaluates MIN and MAX', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 2);
+      sheet.set('A3', 8);
+      sheet.set('B1', '=MIN(A1:A3)');
+      sheet.set('B2', '=MAX(A1:A3)');
+      expect(sheet.get('B1')).toBe(2);
+      expect(sheet.get('B2')).toBe(8);
+    });
+
+    it('evaluates COUNT', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('A2', 'text');
+      sheet.set('A3', 3);
+      sheet.set('B1', '=COUNT(A1:A3)');
+      expect(sheet.get('B1')).toBe(2);
+    });
+
+    it('evaluates IF', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 50);
+      sheet.set('C1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('C1')).toBe('big');
+
+      sheet.set('A1', 10);
+      expect(sheet.get('C1')).toBe('small');
+    });
+  });
+
+  describe('reactive updates', () => {
+    it('updates dependents when a cell changes', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+    });
+
+    it('updates transitive dependents', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('B1', '=A1*2');
+      sheet.set('C1', '=B1+10');
+      expect(sheet.get('C1')).toBe(20);
+
+      sheet.set('A1', 10);
+      expect(sheet.get('B1')).toBe(20);
+      expect(sheet.get('C1')).toBe(30);
+    });
+
+    it('updates multiple dependents', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('B1', '=A1+1');
+      sheet.set('C1', '=A1+2');
+      sheet.set('D1', '=B1+C1');
+
+      sheet.set('A1', 10);
+      expect(sheet.get('B1')).toBe(11);
+      expect(sheet.get('C1')).toBe(12);
+      expect(sheet.get('D1')).toBe(23);
+    });
+
+    it('handles range dependencies reactively', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('A3', 3);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(6);
+
+      sheet.set('A2', 10);
+      expect(sheet.get('B1')).toBe(14);
+    });
+  });
+
+  describe('circular reference detection', () => {
+    it('detects direct circular reference', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=B1');
+      expect(() => sheet.set('B1', '=A1')).toThrow();
+    });
+
+    it('detects self-reference', () => {
+      const sheet = new Spreadsheet();
+      expect(() => sheet.set('A1', '=A1')).toThrow();
+    });
+
+    it('detects indirect circular reference', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=B1');
+      sheet.set('B1', '=C1');
+      expect(() => sheet.set('C1', '=A1')).toThrow();
+    });
+
+    it('allows overwriting a formula cell without false cycle', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1');
+      sheet.set('B1', '=A1+1'); // should not throw
+      expect(sheet.get('B1')).toBe(11);
+    });
+  });
+
+  describe('getCells', () => {
+    it('returns all non-empty cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+
+      const cells = sheet.getCells();
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+      expect(cells.size).toBe(3);
+    });
+  });
+
+  describe('case insensitivity', () => {
+    it('handles case-insensitive cell references', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('a1', 10);
+      expect(sheet.get('A1')).toBe(10);
+    });
+  });
+
+  describe('block ranges', () => {
+    it('evaluates SUM over a 2D block range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('B1', 3);
+      sheet.set('B2', 4);
+      sheet.set('C1', '=SUM(A1:B2)');
+      expect(sheet.get('C1')).toBe(10);
+    });
+  });
+});
