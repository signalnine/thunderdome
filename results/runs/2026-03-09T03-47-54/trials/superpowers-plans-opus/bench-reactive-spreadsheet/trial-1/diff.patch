+import { describe, it, expect } from 'vitest';
+import { parse, ASTNode } from '../parser.js';
+
+describe('parse', () => {
+  it('parses a number', () => {
+    const ast = parse('42');
+    expect(ast).toEqual({ type: 'number', value: 42 });
+  });
+
+  it('parses a string', () => {
+    const ast = parse('"hello"');
+    expect(ast).toEqual({ type: 'string', value: 'hello' });
+  });
+
+  it('parses a boolean', () => {
+    expect(parse('true')).toEqual({ type: 'boolean', value: true });
+  });
+
+  it('parses a cell reference', () => {
+    const ast = parse('A1');
+    expect(ast).toEqual({ type: 'cell', ref: 'A1' });
+  });
+
+  it('parses addition', () => {
+    const ast = parse('A1+B1');
+    expect(ast).toEqual({
+      type: 'binary',
+      op: '+',
+      left: { type: 'cell', ref: 'A1' },
+      right: { type: 'cell', ref: 'B1' },
+    });
+  });
+
+  it('respects operator precedence (* before +)', () => {
+    const ast = parse('A1+B1*2') as Extract<ASTNode, { type: 'binary' }>;
+    expect(ast.type).toBe('binary');
+    expect(ast.op).toBe('+');
+    const right = ast.right as Extract<ASTNode, { type: 'binary' }>;
+    expect(right.type).toBe('binary');
+    expect(right.op).toBe('*');
+  });
+
+  it('parses parentheses', () => {
+    const ast = parse('(A1+B1)*2') as Extract<ASTNode, { type: 'binary' }>;
+    expect(ast.type).toBe('binary');
+    expect(ast.op).toBe('*');
+    const left = ast.left as Extract<ASTNode, { type: 'binary' }>;
+    expect(left.type).toBe('binary');
+    expect(left.op).toBe('+');
+  });
+
+  it('parses function calls with ranges', () => {
+    const ast = parse('SUM(A1:A5)');
+    expect(ast).toEqual({
+      type: 'function',
+      name: 'SUM',
+      args: [{ type: 'range', start: 'A1', end: 'A5' }],
+    });
+  });
+
+  it('parses IF with three arguments', () => {
+    const ast = parse('IF(A1>0,1,2)') as Extract<ASTNode, { type: 'function' }>;
+    expect(ast.type).toBe('function');
+    expect(ast.name).toBe('IF');
+    expect(ast.args).toHaveLength(3);
+  });
+
+  it('parses comparison operators', () => {
+    const ast = parse('A1>=10');
+    expect(ast).toEqual({
+      type: 'binary',
+      op: '>=',
+      left: { type: 'cell', ref: 'A1' },
+      right: { type: 'number', value: 10 },
+    });
+  });
+});
