p<string, any> {\n    throw new Error('Not implemented');\n  }\n}\n```\n\n**Step 3: Verify build works**\n\nRun: `npx tsc --noEmit`\nExpected: No errors\n\n---\n\n### Task 2: Cell Reference Parser\n\n**Files:**\n- Create: `src/cell-utils.ts`\n- Create: `src/__tests__/cell-utils.test.ts`\n\n**Step 1: Write the failing tests**\n\n```typescript\n// src/__tests__/cell-utils.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { parseCellRef, colLetterToIndex, indexToColLetter } from '../cell-utils';\n\ndescribe('colLetterToIndex', () => {\n  it('converts single letters', () => {\n    expect(colLetterToIndex('A')).toBe(0);\n    expect(colLetterToIndex('B')).toBe(1);\n    expect(colLetterToIndex('Z')).toBe(25);\n  });\n\n  it('converts double letters', () => {\n    expect(colLetterToIndex('AA')).toBe(26);\n    expect(colLetterToIndex('AB')).toBe(27);\n    expect(colLetterToIndex('AZ')).toBe(51);\n    expect(colLetterToIndex('BA')).toBe(52);\n  });\n});\n\ndescribe('indexToColLetter', () => {\n  it('converts single-letter indices', () => {\n    expect(indexToColLetter(0)).toBe('A');\n    expect(indexToColLetter(25)).toBe('Z');\n  });\n\n  it('converts double-letter indices', () => {\n    expect(indexToColLetter(26)).toBe('AA');\n    expect(indexToColLetter(27)).toBe('AB');\n    expect(indexToColLetter(51)).toBe('AZ');\n    expect(indexToColLetter(52)).toBe('BA');\n  });\n});\n\ndescribe('parseCellRef', () => {\n  it('parses simple cell references', () => {\n    expect(parseCellRef('A1')).toEqual({ col: 0, row: 0 });\n    expect(parseCellRef('B2')).toEqual({ col: 1, row: 1 });\n    expect(parseCellRef('Z100')).toEqual({ col: 25, row: 99 });\n  });\n\n  it('parses multi-letter columns', () => {\n    expect(parseCellRef('AA1')).toEqual({ col: 26, row: 0 });\n    expect(parseCellRef('AB5')).toEqual({ col: 27, row: 4 });\n  });\n\n  it('is case-insensitive', () => {\n    expect(parseCellRef('a1')).toEqual({ col: 0, row: 0 });\n    expect(parseCellRef('aa1')).toEqual({ col: 26, row: 0 });\n  });\n});\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `npx vitest run src/__tests__/cell-utils.test.ts`\nExpected: FAIL — module not found\n\n**Step 3: Implement cell-utils**\n\n```typescript\n// src/cell-utils.ts\nexport interface CellRef {\n  col: number; // 0-based\n  row: number; // 0-based\n}\n\nexport function colLetterToIndex(letters: string): number {\n  let result = 0;\n  const upper = letters.toUpperCase();\n  for (let i = 0; i < upper.length; i++) {\n    result = result * 26 + (upper.charCodeAt(i) - 64);\n  }\n  return result - 1;\n}\n\nexport function indexToColLetter(index: number): string {\n  let result = '';\n  let n = index + 1;\n  while (n > 0) {\n    n--;\n    result = String.fromCharCode(65 + (n % 26)) + result;\n    n = Math.floor(n / 26);\n  }\n  return result;\n}\n\nexport function parseCellRef(ref: string): CellRef {\n  const match = ref.toUpperCase().match(/^([A-Z]+)(\\d+)$/);\n  if (!match) throw new Error(`Invalid cell reference: ${ref}`);\n  return {\n    col: colLetterToIndex(match[1]),\n    row: parseInt(match[2], 10) - 1,\n  };\n}\n\nexport function cellRefToString(col: number, row: number): string {\n  return `${indexToColLetter(col)}${row + 1}`;\n}\n\nexport function expandRange(start: string, end: string): string[] {\n  const s = parseCellRef(start);\n  const e = parseCellRef(end);\n  const cells: string[] = [];\n  const minCol = Math.min(s.col, e.col);\n  const maxCol = Math.max(s.col, e.col);\n  const minRow = Math.min(s.row, e.row);\n  const maxRow = Math.max(s.row, e.row);\n  for (let r = minRow; r <= maxRow; r++) {\n    for (let c = minCol; c <= maxCol; c++) {\n      cells.push(cellRefToString(c, r));\n    }\n  }\n  return cells;\n}\n```\n\n**Step 4: Run tests to verify they pass**\n\nRun: `npx vitest run src/__tests__/cell-utils.test.ts`\nExpected: All PASS\n\n---\n\n### Task 3: Formula Tokenizer\n\n**Files:**\n- Create: `src/tokenizer.ts`\n- Create: `src/__tests__/tokenizer.test.ts`\n\n**