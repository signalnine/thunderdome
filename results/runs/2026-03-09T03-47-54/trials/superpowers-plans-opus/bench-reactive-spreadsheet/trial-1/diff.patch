ect(sheet.getDisplay('A3')).toBe('30');\n    });\n  });\n\n  describe('formulas', () => {\n    it('evaluates simple addition', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('evaluates with parentheses', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', 5);\n      sheet.set('C1', '=(A1+B1)*2');\n      expect(sheet.get('C1')).toBe(30);\n    });\n\n    it('evaluates SUM', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(6);\n    });\n\n    it('evaluates AVERAGE', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=AVERAGE(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n\n    it('evaluates MIN and MAX', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('A2', 2);\n      sheet.set('A3', 8);\n      sheet.set('B1', '=MIN(A1:A3)');\n      sheet.set('B2', '=MAX(A1:A3)');\n      expect(sheet.get('B1')).toBe(2);\n      expect(sheet.get('B2')).toBe(8);\n    });\n\n    it('evaluates COUNT', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 'text');\n      sheet.set('A3', 3);\n      sheet.set('B1', '=COUNT(A1:A3)');\n      expect(sheet.get('B1')).toBe(2);\n    });\n\n    it('evaluates IF', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 50);\n      sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('C1')).toBe('big');\n\n      sheet.set('A1', 10);\n      expect(sheet.get('C1')).toBe('small');\n    });\n  });\n\n  describe('reactive updates', () => {\n    it('updates dependents when