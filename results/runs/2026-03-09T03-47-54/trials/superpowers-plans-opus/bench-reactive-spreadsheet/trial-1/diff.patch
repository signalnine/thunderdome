+```typescript
+// src/index.ts
+import { parse, ASTNode } from './parser';
+import { evaluate } from './evaluator';
+import { extractDependencies } from './dependencies';
+
+interface CellData {
+  rawValue: string | number | boolean;
+  formula: ASTNode | null;
+  computedValue: string | number | boolean | null;
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Maps cell -> set of cells it depends on
+  private dependencies: Map<string, Set<string>> = new Map();
+  // Maps cell -> set of cells that depend on it (reverse graph)
+  private dependents: Map<string, Set<string>> = new Map();
+
+  private normalizeRef(ref: string): string {
+    return ref.toUpperCase();
+  }
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = this.normalizeRef(cell);
+    let formula: ASTNode | null = null;
+    let newDeps: string[] = [];
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parse(value.substring(1));
+      newDeps = extractDependencies(formula);
+    }
+
+    // Check for circular dependency before committing
+    if (newDeps.length > 0) {
+      this.checkCircular(ref, new Set(newDeps));
+    }
+
+    // Remove old dependency edges
+    this.removeDependencyEdges(ref);
+
+    // Add new dependency edges
+    this.dependencies.set(ref, new Set(newDeps));
+    for (const dep of newDeps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    // Store cell data
+    const computedValue = formula
+      ? evaluate(formula, (r) => this.get(r))
+      : value;
+
+    this.cells.set(ref, { rawValue: value, formula, computedValue });
+
+    // Reactively update all dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const ref = this.normalizeRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computedValue ?? null;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    if (typeof value === 'boolean') return value ? 'TRUE' : 'FALSE';
+    return String(value);
+  }
+
+  getCells(): Map<string, any> {
+    const result = new Map<string, any>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computedValue);
+    }
+    return result;
+  }
+
+  private removeDependencyEdges(ref: string): void {
+    const oldDeps = this.dependencies.get(ref);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+    this.dependencies.delete(ref);
+  }
+
+  private checkCircular(ref: string, newDeps: Set<string>): void {
+    // BFS/DFS from each newDep to see if we can reach ref
+    const visited = new Set<string>();
+    const stack = [...newDeps];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === ref) {
+        throw new Error(`Circular reference detected involving ${ref}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      const deps = this.dependencies.get(current);
+      if (deps) {
+        for (const dep of deps) {
+          stack.push(dep);
+        }
+      }
+    }
+  }
+
+  private propagate(changedRef: string): void {
+    // Topological sort of all dependents to recalculate in correct order
+    const order = this.topologicalSort(changedRef);
+
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data?.formula) {
+        data.computedValue = evaluate(data.formula, (r) => this.get(r));
+      }
+    }
+  }
+
+  private topologicalSort(startRef: string): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    const visit = (ref: string) => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+      result.push(ref);
+    };
+
+    visit(startRef);
+    // Remove the start ref itself (it's already computed),
+    // and reverse so dependents come after their dependencies
+    return result.filter(r => r !== startRef);
+  }
+}
+```
