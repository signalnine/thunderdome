+import { describe, it, expect } from 'vitest';
+import { evaluate } from '../evaluator.js';
+import { parse } from '../parser.js';
+
+const makeGetter = (cells: Record<string, string | number | boolean | null>) => (ref: string) => cells[ref] ?? null;
+
+describe('evaluate', () => {
+  it('evaluates numbers', () => {
+    expect(evaluate(parse('42'), makeGetter({}))).toBe(42);
+  });
+
+  it('evaluates strings', () => {
+    expect(evaluate(parse('"hello"'), makeGetter({}))).toBe('hello');
+  });
+
+  it('evaluates booleans', () => {
+    expect(evaluate(parse('true'), makeGetter({}))).toBe(true);
+  });
+
+  it('evaluates cell references', () => {
+    expect(evaluate(parse('A1'), makeGetter({ A1: 10 }))).toBe(10);
+  });
+
+  it('evaluates addition', () => {
+    expect(evaluate(parse('A1+B1'), makeGetter({ A1: 10, B1: 20 }))).toBe(30);
+  });
+
+  it('evaluates multiplication with precedence', () => {
+    expect(evaluate(parse('A1+B1*2'), makeGetter({ A1: 10, B1: 5 }))).toBe(20);
+  });
+
+  it('evaluates parentheses', () => {
+    expect(evaluate(parse('(A1+B1)*2'), makeGetter({ A1: 10, B1: 5 }))).toBe(30);
+  });
+
+  it('evaluates SUM', () => {
+    expect(evaluate(parse('SUM(A1:A3)'), makeGetter({ A1: 1, A2: 2, A3: 3 }))).toBe(6);
+  });
+
+  it('evaluates AVERAGE', () => {
+    expect(evaluate(parse('AVERAGE(A1:A3)'), makeGetter({ A1: 1, A2: 2, A3: 3 }))).toBe(2);
+  });
+
+  it('evaluates MIN', () => {
+    expect(evaluate(parse('MIN(A1:A3)'), makeGetter({ A1: 3, A2: 1, A3: 2 }))).toBe(1);
+  });
+
+  it('evaluates MAX', () => {
+    expect(evaluate(parse('MAX(A1:A3)'), makeGetter({ A1: 3, A2: 1, A3: 2 }))).toBe(3);
+  });
+
+  it('evaluates COUNT', () => {
+    expect(evaluate(parse('COUNT(A1:A3)'), makeGetter({ A1: 1, A2: 'text', A3: 3 }))).toBe(2);
+  });
+
+  it('evaluates IF true branch', () => {
+    expect(evaluate(parse('IF(A1>5,1,2)'), makeGetter({ A1: 10 }))).toBe(1);
+  });
+
+  it('evaluates IF false branch', () => {
+    expect(evaluate(parse('IF(A1>5,1,2)'), makeGetter({ A1: 3 }))).toBe(2);
+  });
+
+  it('evaluates comparison operators', () => {
+    const get = makeGetter({ A1: 10 });
+    expect(evaluate(parse('A1>5'), get)).toBe(true);
+    expect(evaluate(parse('A1<5'), get)).toBe(false);
+    expect(evaluate(parse('A1>=10'), get)).toBe(true);
+    expect(evaluate(parse('A1<=10'), get)).toBe(true);
+    expect(evaluate(parse('A1=10'), get)).toBe(true);
+    expect(evaluate(parse('A1<>10'), get)).toBe(false);
+  });
+
+  it('returns null for empty cell reference', () => {
+    expect(evaluate(parse('A1'), makeGetter({}))).toBe(null);
+  });
+
+  it('treats null as 0 in arithmetic', () => {
+    expect(evaluate(parse('A1+1'), makeGetter({}))).toBe(1);
+  });
+});
diff --git a/src/__tests__/parser.test.ts b/src/__tests__/parser.test.ts
