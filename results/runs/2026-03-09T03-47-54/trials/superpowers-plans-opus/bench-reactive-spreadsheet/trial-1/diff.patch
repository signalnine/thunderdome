+++ b/src/dependencies.ts
@@ -0,0 +1,35 @@
+import { ASTNode } from './parser.js';
+import { expandRange } from './cell-utils.js';
+
+export function extractDependencies(node: ASTNode): string[] {
+  const deps = new Set<string>();
+
+  function walk(n: ASTNode): void {
+    switch (n.type) {
+      case 'number':
+      case 'string':
+      case 'boolean':
+        break;
+      case 'cell':
+        deps.add(n.ref);
+        break;
+      case 'range':
+        for (const cell of expandRange(n.start, n.end)) {
+          deps.add(cell);
+        }
+        break;
+      case 'binary':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'function':
+        for (const arg of n.args) {
+          walk(arg);
+        }
+        break;
+    }
+  }
+
+  walk(node);
+  return Array.from(deps);
+}
diff --git a/src/evaluator.ts b/src/evaluator.ts
new file mode 100644
index 0000000..c1284ca
--- /dev/null
+++ b/src/evaluator.ts
@@ -0,0 +1,85 @@
+import { ASTNode } from './parser.js';
+import { expandRange } from './cell-utils.js';
+
+type CellGetter = (ref: string) => string | number | boolean | null;
+
+function toNumber(val: string | number | boolean | null): number {
+  if (val === null) return 0;
+  if (typeof val === 'boolean') return val ? 1 : 0;
+  if (typeof val === 'string') {
+    const n = parseFloat(val);
+    return isNaN(n) ? 0 : n;
+  }
+  return val;
+}
+
+export function evaluate(node: ASTNode, getCellValue: CellGetter): string | number | boolean | null {
+  switch (node.type) {
+    case 'number':
+      return node.value;
+    case 'string':
+      return node.value;
+    case 'boolean':
+      return node.value;
+    case 'cell':
+      return getCellValue(node.ref);
+
+    case 'binary': {
+      const left = evaluate(node.left, getCellValue);
+      const right = evaluate(node.right, getCellValue);
+      switch (node.op) {
+        case '+': return toNumber(left) + toNumber(right);
+        case '-': return toNumber(left) - toNumber(right);
+        case '*': return toNumber(left) * toNumber(right);
+        case '/': return toNumber(left) / toNumber(right);
+        case '>': return toNumber(left) > toNumber(right);
+        case '<': return toNumber(left) < toNumber(right);
+        case '>=': return toNumber(left) >= toNumber(right);
+        case '<=': return toNumber(left) <= toNumber(right);
+        case '=': return left === right || toNumber(left) === toNumber(right);
+        case '<>': return left !== right && toNumber(left) !== toNumber(right);
+        default: throw new Error(`Unknown operator: ${node.op}`);
+      }
+    }
+
+    case 'function': {
+      const { name, args } = node;
+      if (name === 'IF') {
+        const condition = evaluate(args[0], getCellValue);
+        return condition ? evaluate(args[1], getCellValue) : evaluate(args[2], getCellValue);
+      }
+
+      // Aggregate functions: resolve ranges to value arrays
+      const values: (string | number | boolean | null)[] = [];
+      for (const arg of args) {
+        if (arg.type === 'range') {
+          const cells = expandRange(arg.start, arg.end);
+          for (const cell of cells) {
+            values.push(getCellValue(cell));
+          }
+        } else {
+          values.push(evaluate(arg, getCellValue));
+        }
+      }
+
+      const nums = values.filter((v): v is number => typeof v === 'number');
+
+      switch (name) {
+        case 'SUM': return nums.reduce((a, b) => a + b, 0);
+        case 'AVERAGE': return nums.length ? nums.reduce((a, b) => a + b, 0) / nums.length : 0;
+        case 'MIN': return Math.min(...nums);
+        case 'MAX': return Math.max(...nums);
+        case 'COUNT': return nums.length;
+        default: throw new Error(`Unknown function: ${name}`);
+      }
+    }
+
+    case 'range':
+      throw new Error('Range can only be used inside functions');
+
+    default: {
+      const _exhaustive: never = node;
+      throw new Error(`Unknown node type: ${_exhaustive}`);
+    }
+  }
+}
diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..417d4b0
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,147 @@
+import { parse, ASTNode } from './parser.js';
+import { evaluate } from './evaluator.js';
+import { extractDependencies } from './dependencies.js';
+
+interface CellData {
+  rawValue: string | number | boolean;
+  formula: ASTNode | null;
+  computedValue: string | number | boolean | null;
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Maps cell -> set of cells it depends on
+  private dependencies: Map<string, Set<string>> = new Map();
+  // Maps cell -> set of cells that depend on it (reverse graph)
+  private dependents: Map<string, Set<string>> = new Map();
+
+  private normalizeRef(ref: string): string {
+    return ref.toUpperCase();
+  }
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = this.normalizeRef(cell);
+    let formula: ASTNode | null = null;
+    let newDeps: string[] = [];
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parse(value.substring(1));
+      newDeps = extractDependencies(formula);
+    }
+
+    // Check for circular dependency before committing
+    if (newDeps.length > 0) {
+      this.checkCircular(ref, new Set(newDeps));
+    }
+
+    // Remove old dependency edges
+    this.removeDependencyEdges(ref);
+
+    // Add new dependency edges
+    this.dependencies.set(ref, new Set(newDeps));
+    for (const dep of newDeps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    // Store cell data
+    const computedValue = formula
+      ? evaluate(formula, (r) => this.get(r))
+      : value;
+
+    this.cells.set(ref, { rawValue: value, formula, computedValue });
+
+    // Reactively update all dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const ref = this.normalizeRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computedValue ?? null;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    if (typeof value === 'boolean') return value ? 'TRUE' : 'FALSE';
+    return String(value);
+  }
+
+  getCells(): Map<string, string | number | boolean | null> {
+    const result = new Map<string, string | number | boolean | null>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computedValue);
+    }
+    return result;
+  }
+
+  private removeDependencyEdges(ref: string): void {
+    const oldDeps = this.dependencies.get(ref);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+    this.dependencies.delete(ref);
+  }
+
+  private checkCircular(ref: string, newDeps: Set<string>): void {
+    // DFS from each newDep following the dependency graph to see if we can reach ref
+    const visited = new Set<string>();
+    const stack = [...newDeps];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === ref) {
+        throw new Error(`Circular reference detected involving ${ref}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      const deps = this.dependencies.get(current);
+      if (deps) {
+        for (const dep of deps) {
+          stack.push(dep);
+        }
+      }
+    }
+  }
+
+  private propagate(changedRef: string): void {
+    // Topological sort of all dependents to recalculate in correct order
+    const order = this.topologicalSort(changedRef);
+
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data?.formula) {
+        data.computedValue = evaluate(data.formula, (r) => this.get(r));
+      }
+    }
+  }
+
+  private topologicalSort(startRef: string): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    const visit = (ref: string) => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+      result.push(ref);
+    };
+
+    visit(startRef);
+    // Remove the start ref itself (it's already computed),
+    // and reverse so leaf dependents come after their dependencies
+    return result.filter(r => r !== startRef).reverse();
+  }
+}
