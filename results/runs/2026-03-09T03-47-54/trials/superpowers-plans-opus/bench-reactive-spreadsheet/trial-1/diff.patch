+import { describe, it, expect } from 'vitest';
+import { tokenize, TokenType } from '../tokenizer.js';
+
+describe('tokenize', () => {
+  it('tokenizes numbers', () => {
+    const tokens = tokenize('42');
+    expect(tokens).toEqual([{ type: TokenType.Number, value: '42' }]);
+  });
+
+  it('tokenizes decimal numbers', () => {
+    const tokens = tokenize('3.14');
+    expect(tokens).toEqual([{ type: TokenType.Number, value: '3.14' }]);
+  });
+
+  it('tokenizes cell references', () => {
+    const tokens = tokenize('A1');
+    expect(tokens).toEqual([{ type: TokenType.CellRef, value: 'A1' }]);
+  });
+
+  it('tokenizes multi-letter cell refs', () => {
+    const tokens = tokenize('AA10');
+    expect(tokens).toEqual([{ type: TokenType.CellRef, value: 'AA10' }]);
+  });
+
+  it('tokenizes operators', () => {
+    const tokens = tokenize('A1+B1');
+    expect(tokens).toEqual([
+      { type: TokenType.CellRef, value: 'A1' },
+      { type: TokenType.Operator, value: '+' },
+      { type: TokenType.CellRef, value: 'B1' },
+    ]);
+  });
+
+  it('tokenizes comparison operators', () => {
+    expect(tokenize('A1>=10')).toEqual([
+      { type: TokenType.CellRef, value: 'A1' },
+      { type: TokenType.Operator, value: '>=' },
+      { type: TokenType.Number, value: '10' },
+    ]);
+    expect(tokenize('A1<>B1')).toEqual([
+      { type: TokenType.CellRef, value: 'A1' },
+      { type: TokenType.Operator, value: '<>' },
+      { type: TokenType.CellRef, value: 'B1' },
+    ]);
+  });
+
+  it('tokenizes parentheses', () => {
+    const tokens = tokenize('(A1+B1)*2');
+    expect(tokens.map((t: { value: string }) => t.value)).toEqual(['(', 'A1', '+', 'B1', ')', '*', '2']);
+  });
+
+  it('tokenizes function names', () => {
+    const tokens = tokenize('SUM(A1:A5)');
+    expect(tokens).toEqual([
+      { type: TokenType.Function, value: 'SUM' },
+      { type: TokenType.LParen, value: '(' },
+      { type: TokenType.CellRef, value: 'A1' },
+      { type: TokenType.Colon, value: ':' },
+      { type: TokenType.CellRef, value: 'A5' },
+      { type: TokenType.RParen, value: ')' },
+    ]);
+  });
+
+  it('tokenizes commas', () => {
+    const tokens = tokenize('IF(A1>0,1,2)');
+    expect(tokens.map((t: { type: TokenType }) => t.type)).toContain(TokenType.Comma);
+  });
+
+  it('tokenizes string literals', () => {
+    const tokens = tokenize('"hello"');
+    expect(tokens).toEqual([{ type: TokenType.String, value: 'hello' }]);
+  });
+
+  it('tokenizes boolean values', () => {
+    expect(tokenize('true')).toEqual([{ type: TokenType.Boolean, value: 'true' }]);
+    expect(tokenize('false')).toEqual([{ type: TokenType.Boolean, value: 'false' }]);
+  });
+});
