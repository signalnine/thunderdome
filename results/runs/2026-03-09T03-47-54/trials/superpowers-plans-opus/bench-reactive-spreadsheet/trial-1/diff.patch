se('A1+1'), makeGetter({}))).toBe(1);\n  });\n});\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `npx vitest run src/__tests__/evaluator.test.ts`\n\n**Step 3: Implement evaluator**\n\n```typescript\n// src/evaluator.ts\nimport { ASTNode } from './parser';\nimport { expandRange } from './cell-utils';\n\ntype CellGetter = (ref: string) => string | number | boolean | null;\n\nfunction toNumber(val: string | number | boolean | null): number {\n  if (val === null) return 0;\n  if (typeof val === 'boolean') return val ? 1 : 0;\n  if (typeof val === 'string') {\n    const n = parseFloat(val);\n    return isNaN(n) ? 0 : n;\n  }\n  return val;\n}\n\nexport function evaluate(node: ASTNode, getCellValue: CellGetter): string | number | boolean | null {\n  switch (node.type) {\n    case 'number':\n      return node.value;\n    case 'string':\n      return node.value;\n    case 'boolean':\n      return node.value;\n    case 'cell':\n      return getCellValue(node.ref);\n\n    case 'binary': {\n      const left = evaluate(node.left, getCellValue);\n      const right = evaluate(node.right, getCellValue);\n      switch (node.op) {\n        case '+': return toNumber(left) + toNumber(right);\n        case '-': return toNumber(left) - toNumber(right);\n        case '*': return toNumber(left) * toNumber(right);\n        case '/': return toNumber(left) / toNumber(right);\n        case '>': return toNumber(left) > toNumber(right);\n        case '<': return toNumber(left) < toNumber(right);\n        case '>=': return toNumber(left) >= toNumber(right);\n        case '<=': return toNumber(left) <= toNumber(right);\n        case '=': return left === right || toNumber(left) === toNumber(right);\n        case '<>': return left !== right && toNumber(left) !== toNumber(right);\n        default: throw new Error(`Unknown operator: ${node.op}`);\n      }\n    }\n\n    case 'function': {\n      const { name, args } = node;\n      if (name === 'IF') {\n        const condition = evaluate(args[0], getCellValue);\n        return condition ? evaluate(args[1], getCellValue) : evaluate(args[2], getCellValue);\n      }\n\n      // Aggregate functions: resolve ranges to value arrays\n      const values: (string | number | boolean | null)[] = [];\n      for (const arg of args) {\n        if (arg.type === 'range') {\n          const cells = expandRange(arg.start, arg.end);\n          for (const cell of cells) {\n            values.push(getCellValue(cell));\n          }\n        } else {\n          values.push(evaluate(arg, getCellValue));\n        }\n      }\n\n      const nums = values.filter((v): v is number => typeof v === 'number');\n\n      switch (name) {\n        case 'SUM': return nums.reduce((a, b) => a + b, 0);\n        case 'AVERAGE': return nums.length ? nums.reduce((a, b) => a + b, 0) / nums.length : 0;\n        case 'MIN': return Math.min(...nums);\n        case 'MAX': return Math.max(...nums);\n        case 'COUNT': return nums.length;\n        default: throw new Error(`Unknown function: ${name}`);\n      }\n    }\n\n    case 'range':\n      throw new Error('Range can only be used inside functions');\n\n    default:\n      throw new Error(`Unknown node type: ${(node as any).type}`);\n  }\n}\n```\n\n**Step 4: Run tests**\n\nRun: `npx vitest run src/__tests__/evaluator.test.ts`\nExpected: All PASS\n\n---\n\n### Task 6: Dependency Extraction\n\n**Files:**\n- Create: `src/dependencies.ts`\n- Create: `src/__tests__/dependencies.test.ts`\n\n**Step 1: Write the failing tests**\n\n```typescript\n// src/__tests__/dependencies.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { extractDependencies } from '../dependencies';\nimport { parse } from '../parser';\n\ndescribe('extractDependencies', () => {\n  it('returns empty for literals', () => {\n    expect(extractDependencies(parse('42'))).toEqual([]);\n    expect(extractDependencies(parse('\"hello\"'))).toEqual([]);\n  });\n\n  it('extracts single cell ref', () => {\n    expect(extractDependencies(parse('A1'))).toEqual(['A1']);\n  });\n\n  it('extracts multiple refs from expression', () => {\n    const deps = extractDependencies(parse('A1+B1'));\n    expect(deps.sort()).toEqual(['A1', 'B1']);\n  });\n\n  it('extracts refs from ranges', () => {\n    const deps = extractDependencies(parse('SUM(A1:A3)'));\n    expect(deps.sort()).toEqual(['A1', 'A2', 'A3']);\n  });\n\n  it('extracts refs from IF', () => {\n    const deps = extractDependencies(parse('IF(A1>0,B1,C1)'));\n    expect(deps.sort()).toEqual(['A1', 'B1', 'C1']);\n  });\n});\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `npx vitest run src/__tests__/dependencies.test.ts`\n\n**Step 3: Implement dependency extraction**\n\n```typescript\n// src/dependencies.ts\nimport { ASTNode } from './parser';\nimport { expandRange } from './cell-utils';\n\nexport function extractDependencies(node: ASTNode): string[] {\n  const deps = new Set<string>();\n\n  function walk(n: ASTNode): void {\n    switch (n.type) {\n      case 'number':\n      case 'string':\n      case 'boolean':\n        break;\n      case 'cell':\n        deps.add(n.ref);\n        break;\n      case 'range':\n        for (const cell of expandRange(n.start, n.end)) {\n          deps.add(cell);\n        }\n        break;\n      case 'binary':\n        walk(n.left);\n        walk(n.right);\n        break;\n      case 'function':\n        for (const arg of n.args) {\n          walk(arg);\n        }\n        break;\n    }\n  }\n\n  walk(node);\n  return Array.from(deps);\n}\n```\n\n**Step 4: Run tests**\n\nRun: `npx vitest run src/__tests__/dependencies.test.ts`\nExpected: All PASS\n\n---\n\n### Task 7: Spreadsheet Class (Full Integration)\n\n**Files:**\n- Modify: `src/index.ts`\n- Create: `src/__tests__/spreadsheet.test.ts`\n\n**Step 1: Write comprehensive integration tests**\n\n```typescript\n// src/__tests__/spreadsheet.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { Spreadsheet } from '../index';\n\ndescribe('Spreadsheet', () => {\n  describe('basic values', () => {\n    it('stores and retrieves numbers', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 42);\n      expect(sheet.get('A1')).toBe(42);\n    });\n\n    it('stores and retrieves strings', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 'hello');\n      expect(sheet.get('A1')).toBe('hello');\n    });\n\n    it('stores and retrieves booleans', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', true);\n      expect(sheet.get('A1')).toBe(true);\n    });\n\n    it('returns null for empty cells', () => {\n      const sheet = new Spreadsheet();\n      expect(sheet.get('A1')).toBe(null);\n    });\n  });\n\n  describe('getDisplay', () => {\n    it('displays numbers', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 42);\n      expect(sheet.getDisplay('A1')).toBe('42');\n    });\n\n    it('displays strings', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 'hello');\n      expect(sheet.getDisplay('A1')).toBe('hello');\n    });\n\n    it('displays booleans', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', true);\n      expect(sheet.getDisplay('A1')).toBe('TRUE');\n    });\n\n    it('displays empty cells as empty string', () => {\n      const sheet = new Spreadsheet();\n      expect(sheet.getDisplay('A1')).toBe('');\n    });\n\n    it('displays formula results', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.getDisplay('A3')).toBe('30');\n    });\n  });\n\n  describe('formulas', () => {\n    it('evaluates simple addition', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n    });\n\n    it('evaluates with parentheses', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', 5);\n      sheet.set('C1', '=(A1+B1)*2');\n      expect(sheet.get('C1')).toBe(30);\n    });\n\n    it('evaluates SUM', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(6);\n    });\n\n    it('evaluates AVERAGE', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=AVERAGE(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n\n    it('evaluates MIN and MAX', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('A2', 2);\n      sheet.set('A3', 8);\n      sheet.set('B1', '=MIN(A1:A3)');\n      sheet.set('B2', '=MAX(A1:A3)');\n      expect(sheet.get('B1')).toBe(2);\n      expect(sheet.get('B2')).toBe(8);\n    });\n\n    it('evaluates COUNT', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 'text');\n      sheet.set('A3', 3);\n      sheet.set('B1', '=COUNT(A1:A3)');\n      expect(sheet.get('B1')).toBe(2);\n    });\n\n    it('evaluates IF', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 50);\n      sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('C1')).toBe('big');\n\n      sheet.set('A1', 10);\n      expect(sheet.get('C1')).toBe('small');\n    });\n  });\n\n  describe('reactive updates', () => {\n    it('updates dependents when a cell changes', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n    });\n\n    it('updates transitive dependents', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n     