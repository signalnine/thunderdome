+
+  it('extracts single cell ref', () => {
+    expect(extractDependencies(parse('A1'))).toEqual(['A1']);
+  });
+
+  it('extracts multiple refs from expression', () => {
+    const deps = extractDependencies(parse('A1+B1'));
+    expect(deps.sort()).toEqual(['A1', 'B1']);
+  });
+
+  it('extracts refs from ranges', () => {
