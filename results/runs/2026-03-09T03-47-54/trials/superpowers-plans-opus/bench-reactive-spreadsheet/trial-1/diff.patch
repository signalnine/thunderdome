+
+### Task 2: Cell Reference Parser
+
+**Files:**
+- Create: `src/cell-utils.ts`
+- Create: `src/__tests__/cell-utils.test.ts`
+
+**Step 1: Write the failing tests**
+
+```typescript
+// src/__tests__/cell-utils.test.ts
+import { describe, it, expect } from 'vitest';
+import { parseCellRef, colLetterToIndex, indexToColLetter } from '../cell-utils';
+
+describe('colLetterToIndex', () => {
+  it('converts single letters', () => {
+    expect(colLetterToIndex('A')).toBe(0);
+    expect(colLetterToIndex('B')).toBe(1);
+    expect(colLetterToIndex('Z')).toBe(25);
+  });
+
+  it('converts double letters', () => {
+    expect(colLetterToIndex('AA')).toBe(26);
+    expect(colLetterToIndex('AB')).toBe(27);
+    expect(colLetterToIndex('AZ')).toBe(51);
+    expect(colLetterToIndex('BA')).toBe(52);
+  });
+});
+
+describe('indexToColLetter', () => {
+  it('converts single-letter indices', () => {
+    expect(indexToColLetter(0)).toBe('A');
+    expect(indexToColLetter(25)).toBe('Z');
+  });
+
+  it('converts double-letter indices', () => {
+    expect(indexToColLetter(26)).toBe('AA');
+    expect(indexToColLetter(27)).toBe('AB');
+    expect(indexToColLetter(51)).toBe('AZ');
+    expect(indexToColLetter(52)).toBe('BA');
+  });
+});
+
