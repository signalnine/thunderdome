${node.op}`);\n      }\n    }\n\n    case 'function': {\n      const { name, args } = node;\n      if (name === 'IF') {\n        const condition = evaluate(args[0], getCellValue);\n        return condition ? evaluate(args[1], getCellValue) : evaluate(args[2], getCellValue);\n      }\n\n      // Aggregate functions: resolve ranges to value arrays\n      const values: (string | number | boolean | null)[] = [];\n      for (const arg of args) {\n        if (arg.type === 'range') {\n          const cells = expandRange(arg.start, arg.end);\n          for (const cell of cells) {\n            values.push(getCellValue(cell));\n          }\n        } else {\n          values.push(evaluate(arg, getCellValue));\n        }\n      }\n\n      const nums = values.filter((v): v is number => typeof v === 'number');\n\n      switch (name) {\n        case 'SUM': return nums.reduce((a, b) => a + b, 0);\n        case 'AVERAGE': return nums.length ? nums.reduce((a, b) => a + b, 0) / nums.length : 0;\n        case 'MIN': return Math.min(...nums);\n        case 'MAX': return Math.max(...nums);\n        case 'COUNT': return nums.length;\n        default: throw new Error(`Unknown function: ${name}`);\n      }\n    }\n\n    case 'range':\n      throw new Error('Range can only be used inside functions');\n\n    default:\n      throw new Error(`Unknown node type: ${(node as any).type}`);\n  }\n}\n```\n\n**Step 4: Run tests**\n\nRun: `npx vitest run src/__tests__/evaluator.test.ts`\nExpected: All PASS\n\n---\n\n### Task 6: Dependency Extraction\n\n**Files:**\n- Create: `src/dependencies.ts`\n- Create: `src/__tests__/dependencies.test.ts`\n\n**Step 1: Write the failing tests**\n\n```typescript\n// src/__tests__/dependencies.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { extractDependencies } from '../dependencies';\nimport { parse } from '../parser';\n\ndescribe('extractDependencies', () => {\n  it('returns empty for literals', () => {\n    expect(extractDependencies(parse('42')