+**Implementation:** Uses `better-sqlite3` with an in-memory database for persistence.
+
+```typescript
+// src/reviews/index.ts
+import Database from 'better-sqlite3';
+import type { Review, ReviewService } from '../types.js';
+
+export function createReviewService(): ReviewService {
+  const db = new Database(':memory:');
+  db.pragma('journal_mode = WAL');
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS reviews (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      pluginName TEXT NOT NULL,
+      pluginVersion TEXT NOT NULL,
+      userId TEXT NOT NULL,
+      rating INTEGER NOT NULL CHECK(rating >= 1 AND rating <= 5),
+      comment TEXT NOT NULL,
+      flagged INTEGER NOT NULL DEFAULT 0,
+      createdAt TEXT NOT NULL
+    )
+  `);
+
+  return {
+    addReview(review: Omit<Review, 'id' | 'createdAt' | 'flagged'>): Review {
+      const createdAt = new Date().toISOString();
+      const stmt = db.prepare(
+        `INSERT INTO reviews (pluginName, pluginVersion, userId, rating, comment, flagged, createdAt)
+         VALUES (?, ?, ?, ?, ?, 0, ?)`
+      );
+      const result = stmt.run(review.pluginName, review.pluginVersion, review.userId, review.rating, review.comment, createdAt);
+      return {
+        id: Number(result.lastInsertRowid),
+        pluginName: review.pluginName,
+        pluginVersion: review.pluginVersion,
+        userId: review.userId,
+        rating: review.rating,
+        comment: review.comment,
+        flagged: false,
+        createdAt,
+      };
+    },
+
+    getReviews(pluginName: string): Review[] {
+      const rows = db.prepare('SELECT * FROM reviews WHERE pluginName = ?').all(pluginName) as Array<Record<string, unknown>>;
+      return rows.map(mapRow);
+    },
+
+    getAverageRating(pluginName: string): number {
+      const row = db.prepare('SELECT AVG(rating) as avg FROM reviews WHERE pluginName = ? AND flagged = 0').get(pluginName) as { avg: number | null } | undefined;
+      return row?.avg ?? 0;
+    },
+
+    flagReview(reviewId: number): void {
+      db.prepare('UPDATE reviews SET flagged = 1 WHERE id = ?').run(reviewId);
+    },
+
+    getFlaggedReviews(): Review[] {
+      const rows = db.prepare('SELECT * FROM reviews WHERE flagged = 1').all() as Array<Record<string, unknown>>;
+      return rows.map(mapRow);
+    },
+
+    removeReview(reviewId: number): boolean {
+      const result = db.prepare('DELETE FROM reviews WHERE id = ?').run(reviewId);
+      return result.changes > 0;
+    },
+
+    getReviewsByUser(userId: string): Review[] {
+      const rows = db.prepare('SELECT * FROM reviews WHERE userId = ?').all(userId) as Array<Record<string, unknown>>;
+      return rows.map(mapRow);
+    },
+
+    getReviewCount(pluginName: string): number {
+      const row = db.prepare('SELECT COUNT(*) as count FROM reviews WHERE pluginName = ?').get(pluginName) as { count: number };
+      return row.count;
+    },
+  };
+}
+
+function mapRow(row: Record<string, unknown>): Review {
+  return {
+    id: row.id as number,
+    pluginName: row.pluginName as string,
+    pluginVersion: row.pluginVersion as string,
+    userId: row.userId as string,
+    rating: row.rating as number,
+    comment: row.comment as string,
+    flagged: (row.flagged as number) === 1,
+    createdAt: row.createdAt as string,
+  };
+}
+```
