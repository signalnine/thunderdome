+### Task 4: Sandboxed Runner (`src/runner/index.ts`)
+
+**Files:**
+- Create: `src/runner/index.ts`
+- Test: `src/runner/index.test.ts`
+
+**Implementation:** Uses Node.js `vm` module with `vm.Script` and `vm.createContext`.
+
+```typescript
+// src/runner/index.ts
+import vm from 'node:vm';
+import type { SandboxResult, RunnerService } from '../types.js';
+
+export function createRunner(): RunnerService {
+  async function execute(code: string, context: Record<string, unknown> = {}): Promise<SandboxResult> {
+    return executeWithTimeout(code, 5000, context);
+  }
+
+  async function executeWithTimeout(
+    code: string,
+    timeoutMs: number,
+    context: Record<string, unknown> = {}
+  ): Promise<SandboxResult> {
+    const startMem = process.memoryUsage().heapUsed;
+    const start = performance.now();
+    try {
+      const sandbox = { ...context, __result: undefined as unknown };
+      const wrappedCode = `__result = (function() { ${code} })();`;
+      const ctx = vm.createContext(sandbox);
+      const script = new vm.Script(wrappedCode);
+      script.runInContext(ctx, { timeout: timeoutMs });
+      const duration = performance.now() - start;
+      const endMem = process.memoryUsage().heapUsed;
+      return {
+        success: true,
+        output: sandbox.__result,
+        duration,
+        memoryUsed: Math.max(0, endMem - startMem),
+      };
+    } catch (err: unknown) {
+      const duration = performance.now() - start;
+      const endMem = process.memoryUsage().heapUsed;
+      return {
+        success: false,
+        output: null,
+        duration,
+        memoryUsed: Math.max(0, endMem - startMem),
+        error: err instanceof Error ? err.message : String(err),
+      };
+    }
+  }
+
+  return { execute, executeWithTimeout };
+}
+```
