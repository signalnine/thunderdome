+import { describe, it, expect } from 'vitest';
+import { createRunner } from './index.js';
+
+describe('Sandboxed Runner', () => {
+  const runner = createRunner();
+
+  it('should execute simple code and return result', async () => {
+    const result = await runner.execute('return 2 + 3;');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(5);
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+    expect(result.memoryUsed).toBeDefined();
+  });
+
+  it('should pass context variables into sandbox', async () => {
+    const result = await runner.execute('return x + y;', { x: 10, y: 20 });
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(30);
+  });
+
+  it('should return error for invalid code', async () => {
+    const result = await runner.execute('throw new Error("boom");');
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('boom');
+  });
+
+  it('should return error for syntax errors', async () => {
+    const result = await runner.execute('this is not valid js {{{');
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  });
+
+  it('should enforce timeout', async () => {
+    const result = await runner.executeWithTimeout('while(true) {}', 100);
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  });
+
+  it('should handle code that returns undefined', async () => {
+    const result = await runner.execute('var a = 1;');
+    expect(result.success).toBe(true);
+    expect(result.output).toBeUndefined();
+  });
+
+  it('should handle string return values', async () => {
+    const result = await runner.execute('return "hello world";');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe('hello world');
+  });
+
+  it('should handle object return values', async () => {
+    const result = await runner.execute('return { a: 1, b: 2 };');
+    expect(result.success).toBe(true);
+    expect(result.output).toEqual({ a: 1, b: 2 });
+  });
+
+  it('should isolate sandbox from host', async () => {
+    const result = await runner.execute('return typeof require;');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe('undefined');
+  });
+});
