+import { describe, it, expect } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: 'return 42;',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  it('should create a marketplace with all services', () => {
+    const marketplace = createMarketplace();
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+    expect(marketplace.installPlugin).toBeTypeOf('function');
+  });
+
+  describe('installPlugin()', () => {
+    it('should register and execute a simple plugin', async () => {
+      const marketplace = createMarketplace();
+      const manifest = makeManifest({ entryPoint: 'return "hello";' });
+      const { resolved, result } = await marketplace.installPlugin(manifest);
+      expect(resolved).toHaveLength(0);
+      expect(result.success).toBe(true);
+      expect(result.output).toBe('hello');
+    });
+
+    it('should reject plugins without a name', async () => {
+      const marketplace = createMarketplace();
+      const manifest = makeManifest({ name: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(
+        'name, version, and entryPoint'
+      );
+    });
+
+    it('should reject plugins without a version', async () => {
+      const marketplace = createMarketplace();
+      const manifest = makeManifest({ version: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(
+        'name, version, and entryPoint'
+      );
+    });
+
+    it('should reject plugins without an entryPoint', async () => {
+      const marketplace = createMarketplace();
+      const manifest = makeManifest({ entryPoint: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(
+        'name, version, and entryPoint'
+      );
+    });
+
+    it('should resolve dependencies when available', async () => {
+      const marketplace = createMarketplace();
+
+      // Register a dependency first
+      marketplace.registry.register(
+        makeManifest({ name: 'dep-lib', version: '1.2.0' })
+      );
+
+      // Install plugin with dependency
+      const manifest = makeManifest({
+        name: 'my-plugin',
+        dependencies: { 'dep-lib': '^1.0.0' },
+      });
+      const { resolved, result } = await marketplace.installPlugin(manifest);
+      expect(result.success).toBe(true);
+      expect(resolved).toHaveLength(1);
+      expect(resolved[0].name).toBe('dep-lib');
+      expect(resolved[0].version).toBe('1.2.0');
+    });
+
+    it('should reject plugins with circular dependencies', async () => {
+      const marketplace = createMarketplace();
+
+      // Register plugin A that depends on B
+      marketplace.registry.register(
+        makeManifest({
+          name: 'plugin-a',
+          version: '1.0.0',
+          dependencies: { 'plugin-b': '^1.0.0' },
+        })
+      );
+
+      // Install plugin B that depends on A (creates cycle)
+      const manifest = makeManifest({
+        name: 'plugin-b',
+        version: '1.0.0',
+        dependencies: { 'plugin-a': '^1.0.0' },
+      });
+
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(
+        'Circular dependency detected'
+      );
+    });
+
+    it('should handle plugin execution failure', async () => {
+      const marketplace = createMarketplace();
+      const manifest = makeManifest({
+        entryPoint: 'throw new Error("crash");',
+      });
+      const { result } = await marketplace.installPlugin(manifest);
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('crash');
+    });
+  });
+});
