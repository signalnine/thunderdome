ng: review.rating,\n        comment: review.comment,\n        flagged: false,\n        createdAt,\n      };\n    },\n\n    getReviews(pluginName: string): Review[] {\n      const rows = db\n        .prepare('SELECT * FROM reviews WHERE pluginName = ?')\n        .all(pluginName) as Array<Record<string, unknown>>;\n      return rows.map(mapRow);\n    },\n\n    getAverageRating(pluginName: string): number {\n      const row = db\n        .prepare(\n          'SELECT AVG(rating) as avg FROM reviews WHERE pluginName = ? AND flagged = 0'\n        )\n        .get(pluginName) as { avg: number | null } | undefined;\n      return row?.avg ?? 0;\n    },\n\n    flagReview(reviewId: number): void {\n      db.prepare('UPDATE reviews SET flagged = 1 WHERE id = ?').run(reviewId);\n    },\n\n    getFlaggedReviews(): Review[] {\n      const rows = db\n        .prepare('SELECT * FROM reviews WHERE flagged = 1')\n        .all() as Array<Record<string, unknown>>;\n      return rows.map(mapRow);\n    },\n\n    removeReview(reviewId: number): boolean {\n      const result = db.prepare('DELETE FROM reviews WHERE id = ?').run(reviewId);\n      return result.changes > 0;\n    },\n\n    getReviewsByUser(userId: string): Review[] {\n      const rows = db\n        .prepare('SELECT * FROM reviews WHERE userId = ?')\n        .all(userId) as Array<Record<string, unknown>>;\n      return rows.map(mapRow);\n    },\n\n    getReviewCount(pluginName: string): number {\n      const row = db\n        .prepare('SELECT COUNT(*) as count FROM reviews WHERE pluginName = ?')\n        .get(pluginName) as { count: number };\n      return row.count;\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":388,"cache_read_input_tokens":27875,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":388},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"p