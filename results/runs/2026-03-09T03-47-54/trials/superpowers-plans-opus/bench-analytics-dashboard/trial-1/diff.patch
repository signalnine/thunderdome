+import { Router, Response } from 'express';
+import { getDb } from '../db.js';
+import { authMiddleware, AuthRequest } from '../auth.js';
+
+const router = Router();
+
+router.use(authMiddleware);
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = 'id,name,properties,timestamp,user_id,session_id';
+  const rows = events.map(e =>
+    `${e.id},${e.name},"${e.properties.replace(/"/g, '""')}",${e.timestamp},${e.user_id ?? ''},${e.session_id ?? ''}`
+  );
+  return [header, ...rows].join('\n');
+}
+
+function dashboardToCsv(dashboard: DashboardRow, widgets: { id: string; type: string; config: string }[]): string {
+  const lines: string[] = [];
+  lines.push('dashboard_id,dashboard_name,widget_id,widget_type,widget_config');
+  if (widgets.length === 0) {
+    lines.push(`${dashboard.id},${dashboard.name},,,`);
+  } else {
+    for (const w of widgets) {
+      lines.push(
+        `${dashboard.id},${dashboard.name},${w.id},${w.type},"${w.config.replace(/"/g, '""')}"`
+      );
+    }
+  }
+  return lines.join('\n');
+}
+
+// GET /export/events
+router.get('/events', (req: AuthRequest, res: Response) => {
+  const format = (req.query.format as string) || 'json';
+  const db = getDb();
+
+  const events = db.prepare('SELECT * FROM events WHERE tenant_id = ? ORDER BY timestamp DESC').all(
+    req.user!.tenantId
+  ) as EventRow[];
+
+  if (format === 'csv') {
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+    res.send(eventsToCsv(events));
+  } else {
+    res.json({
+      events: events.map(e => ({
+        id: e.id,
+        name: e.name,
+        properties: JSON.parse(e.properties),
+        timestamp: e.timestamp,
+        userId: e.user_id,
+        sessionId: e.session_id,
+      })),
+    });
+  }
+});
+
+// GET /export/dashboards/:id
+router.get('/dashboards/:id', (req: AuthRequest, res: Response) => {
+  const format = (req.query.format as string) || 'json';
+  const db = getDb();
+
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(
+    req.params.id,
+    req.user!.tenantId
+  ) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(dashboard.id) as {
+    id: string;
+    dashboard_id: string;
+    type: string;
+    config: string;
+    position_x: number;
+    position_y: number;
+    width: number;
+    height: number;
+  }[];
+
+  if (format === 'csv') {
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', `attachment; filename="dashboard-${dashboard.id}.csv"`);
+    res.send(dashboardToCsv(dashboard, widgets));
+  } else {
+    res.json({
+      id: dashboard.id,
+      name: dashboard.name,
+      tenantId: dashboard.tenant_id,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+      widgets: widgets.map(w => ({
+        id: w.id,
+        type: w.type,
+        config: JSON.parse(w.config),
+        positionX: w.position_x,
+        positionY: w.position_y,
+        width: w.width,
+        height: w.height,
+      })),
+    });
+  }
+});
+
+export default router;
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..058dc4e
