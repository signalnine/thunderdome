+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01VepZBzUd6FiAAwy41Zjb8U","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01231JmB6T2w4dAjYjrbTXSx","name":"Write","input":{"file_path":"/workspace/src/routes/dashboards.ts","content":"import { Router, Response } from 'express';\nimport { v4 as uuidv4 } from 'uuid';\nimport { getDb } from '../db.js';\nimport { authMiddleware, AuthRequest } from '../auth.js';\n\nconst router = Router();\n\nrouter.use(authMiddleware);\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\n// GET /dashboards\nrouter.get('/', (req: AuthRequest, res: Response) => {\n  const db = getDb();\n  const rows = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?').all(req.user!.tenantId) as DashboardRow[];\n\n  res.json({\n    dashboards: rows.map(r => ({\n      id: r.id,\n      tenantId: r.tenant_id,\n      name: r.name,\n      ownerId: r.owner_id,\n      config: JSON.parse(r.config),\n      createdAt: r.created_at,\n      updatedAt: r.updated_at,\n    })),\n  });\n});\n\n// GET /dashboards/:id\nrouter.get('/:id', (req: AuthRequest, res: Response) => {\n  const db = getDb();\n  const row = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(\n    req.params.id,\n    req.user!.tenantId\n  ) as DashboardRow | undefined;\n\n  if (!row) {\n    res.status(404).json({ error: 'Dashboard not found' });\n    return;\n  }\n\n  const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(row.id) as {\n    id: string;\n    dashboard_id: string;\n    type: string;\n    config: string;\n    position_x: number;\n    position_y: number;\n    width: number;\n    height: number;\n  }[];\n\n  res.json({\n    id: row.id,\n    tenantId: row.tenant_id,\n    name: row.name,\n    ownerId: row.owner_id,\n    config: JSON.parse(row.config),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n    widgets: widgets.map(w => ({\n      id: w.id,\n      dashboardId: w.dashboard_id,\n      type: w.type,\n      config: JSON.parse(w.config),\n      positionX: w.position_x,\n      positionY: w.position_y,\n      width: w.width,\n      height: w.height,\n    })),\n  });\n});\n\n// POST /dashboards\nrouter.post('/', (req: AuthRequest, res: Response) => {\n  const { name, config, widgets } = req.body;\n\n  if (!name) {\n    res.status(400).json({ error: 'Dashboard name is required' });\n    return;\n  }\n\n  const db = getDb();\n  const id = uuidv4();\n  const now = new Date().toISOString();\n  const dashboardConfig = config ? JSON.stringify(config) : '{}';\n\n  db.prepare(\n    'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'\n  ).run(id, req.user!.tenantId, name, req.user!.userId, dashboardConfig, now, now);\n\n  if (Array.isArray(widgets)) {\n    const stmt = db.prepare(\n      'INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)'\n    );\n    for (const w of widgets) {\n      stmt.run(\n        uuidv4(),\n        id,\n        w.type || 'counter',\n        w.config ? JSON.stringify(w.config) : '{}',\n        w.positionX ?? 0,\n        w.positionY ?? 0,\n        w.width ?? 1,\n        w.height ?? 1\n      );\n    }\n  }\n\n  res.status(201).json({ id, name, tenantId: req.user!.tenantId });\n});\n\n// PUT /dashboards/:id\nrouter.put('/:id', (req: AuthRequest, res: Response) => {\n  const db = getDb();\n  const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(\n    req.params.id,\n    req.user!.tenantId\n  ) as DashboardRow | undefined;\n\n  if (!existing) {\n    res.status(404).json({ error: 'Dashboard not found' });\n    return;\n  }\n\n  const { name, config } = req.body;\n  const now = new Date().toISOString();\n\n  db.prepare('UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?').run(\n    name ?? existing.name,\n    config ? JSON.stringify(config) : existing.config,\n    now,\n    req.params.id\n  );\n\n  res.json({ id: req.params.id, name: name ?? existing.name, updatedAt: now });\n});\n\n// DELETE /dashboards/:id\nrouter.delete('/:id', (req: AuthRequest, res: Response) => {\n  const db = getDb();\n  const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(\n    req.params.id,\n    req.user!.tenantId\n  ) as DashboardRow | undefined;\n\n  if (!existing) {\n    res.status(404).json({ error: 'Dashboard not found' });\n    return;\n  }\n\n  db.prepare('DELETE FROM dashboards WHERE id = ?').run(req.params.id);\n\n  res.json({ deleted: true, id: req.params.id });\n});\n\nexport default router;\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":402,"cache_read_input_tokens":29081,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":402},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e6faec88-b091-4073-812f-92ae52fa59a2","uuid":"cb390c94-14a8-4eb4-8248-4754a730b3f3"}
