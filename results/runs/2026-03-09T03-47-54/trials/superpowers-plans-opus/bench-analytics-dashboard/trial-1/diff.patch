+  const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(
+    req.params.id,
+    req.user!.tenantId
+  ) as DashboardRow | undefined;
+
+  if (!existing) {
+    res.status(404).json({ error: 'Dashboard not found' });
