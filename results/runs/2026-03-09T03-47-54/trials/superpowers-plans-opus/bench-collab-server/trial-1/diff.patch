@@ -0,0 +1,60 @@
+import express from 'express';
+import { createServer, Server as HTTPServer } from 'http';
+import { createDatabase, DocumentStore } from './database.js';
+import { createRouter } from './routes.js';
+import { setupWebSocket, WSHandler } from './websocket.js';
+import Database from 'better-sqlite3';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db: Database.Database = createDatabase(dbPath);
+  const store = new DocumentStore(db);
+
+  const app = express();
+  app.use(express.json());
+
+  const router = createRouter(store);
+  app.use(router);
+
+  let httpServer: HTTPServer | null = null;
+  let wsHandler: WSHandler | null = null;
+
+  return {
+    app,
+
+    async start(port?: number): Promise<number> {
+      httpServer = createServer(app);
+      wsHandler = setupWebSocket(httpServer, store);
+
+      return new Promise((resolve) => {
+        httpServer!.listen(port ?? 0, () => {
+          const addr = httpServer!.address();
+          const actualPort = typeof addr === 'object' && addr ? addr.port : 0;
+          resolve(actualPort);
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      if (wsHandler) {
+        wsHandler.close();
+        wsHandler = null;
+      }
+      if (httpServer) {
+        await new Promise<void>((resolve, reject) => {
+          httpServer!.close((err) => {
+            if (err) reject(err);
+            else resolve();
+          });
+        });
+        httpServer = null;
+      }
+      db.close();
+    },
+  };
+}
