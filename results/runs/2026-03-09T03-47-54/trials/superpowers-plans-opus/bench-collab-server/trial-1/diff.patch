@@ -0,0 +1,221 @@
+import { Server as HTTPServer } from 'http';
+import { WebSocketServer, WebSocket } from 'ws';
+import { URL } from 'url';
+import { DocumentStore } from './database.js';
+import { Operation, applyOp, validateOp, transformOp } from './ot.js';
+
+interface ClientInfo {
+  ws: WebSocket;
+  documentId: string;
+}
+
+interface DocumentState {
+  version: number;
+  /** Buffer of operations since version 0: ops[i] produced version i+1 */
+  history: Operation[];
+}
+
+export interface WSHandler {
+  wss: WebSocketServer;
+  close(): void;
+}
+
+/**
+ * Message types from client to server:
+ * { type: 'operation', operation: Operation, version: number }
+ *   - version is the client's last known server version when they generated the op
+ *
+ * Message types from server to client:
+ * { type: 'sync', content: string, version: number }
+ * { type: 'operation', operation: Operation, version: number, clientId: string }
+ * { type: 'ack', version: number }
+ * { type: 'error', message: string }
+ */
+
+export function setupWebSocket(server: HTTPServer, store: DocumentStore): WSHandler {
+  const wss = new WebSocketServer({ server });
+
+  // Map of documentId -> set of connected clients
+  const rooms = new Map<string, Set<ClientInfo>>();
+
+  // Map of documentId -> server-side document state (version + op history for transforms)
+  const docStates = new Map<string, DocumentState>();
+
+  function getDocState(documentId: string): DocumentState {
+    let state = docStates.get(documentId);
+    if (!state) {
+      const version = store.getLatestVersion(documentId);
+      state = { version, history: [] };
+      docStates.set(documentId, state);
+    }
+    return state;
+  }
+
+  function broadcast(documentId: string, message: object, exclude?: WebSocket): void {
+    const room = rooms.get(documentId);
+    if (!room) return;
+    const data = JSON.stringify(message);
+    for (const client of room) {
+      if (client.ws !== exclude && client.ws.readyState === WebSocket.OPEN) {
+        client.ws.send(data);
+      }
+    }
+  }
+
+  wss.on('connection', (ws: WebSocket, req) => {
+    // Parse document ID from URL path: /ws/documents/:id
+    let documentId: string | null = null;
+    try {
+      const url = new URL(req.url || '', `http://${req.headers.host || 'localhost'}`);
+      const match = url.pathname.match(/^\/ws\/documents\/([^/]+)$/);
+      if (match) {
+        documentId = match[1];
+      }
+    } catch {
+      // URL parsing failed
+    }
+
+    if (!documentId) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid WebSocket path. Use /ws/documents/:id' }));
+      ws.close();
+      return;
+    }
+
+    // Verify document exists
+    const doc = store.getById(documentId);
+    if (!doc) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close();
+      return;
+    }
+
+    const clientInfo: ClientInfo = { ws, documentId };
+
+    // Add to room
+    if (!rooms.has(documentId)) {
+      rooms.set(documentId, new Set());
+    }
+    rooms.get(documentId)!.add(clientInfo);
+
+    // Send current document state
+    const state = getDocState(documentId);
+    ws.send(JSON.stringify({
+      type: 'sync',
+      content: doc.content,
+      version: state.version,
+    }));
+
+    ws.on('message', (data) => {
+      let msg: { type: string; operation?: Operation; version?: number };
+      try {
+        msg = JSON.parse(data.toString());
+      } catch {
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));
+        return;
+      }
+
+      if (msg.type !== 'operation') {
+        ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${msg.type}` }));
+        return;
+      }
+
+      if (!msg.operation || typeof msg.version !== 'number') {
+        ws.send(JSON.stringify({ type: 'error', message: 'Operation message must include operation and version' }));
+        return;
+      }
+
+      const currentDoc = store.getById(documentId!);
+      if (!currentDoc) {
+        ws.send(JSON.stringify({ type: 'error', message: 'Document no longer exists' }));
+        return;
+      }
+
+      const docState = getDocState(documentId!);
+      let op = msg.operation;
+      const clientVersion = msg.version;
+
+      // Transform the incoming op against all operations that happened since the client's version
+      if (clientVersion < docState.version) {
+        // Need to transform against ops[clientVersion..docState.version-1]
+        const startIdx = clientVersion;
+        const opsToTransformAgainst = docState.history.slice(startIdx);
+        for (const pastOp of opsToTransformAgainst) {
+          op = transformOp(op, pastOp);
+        }
+      }
+
+      // Validate the (possibly transformed) operation against current document
+      // Skip validation for zero-count deletes (result of OT on overlapping deletes)
+      if (op.type === 'delete' && op.count === 0) {
+        // No-op delete, just ack
+        const newVersion = docState.version;
+        ws.send(JSON.stringify({ type: 'ack', version: newVersion }));
+        return;
+      }
+
+      const validationError = validateOp(op, currentDoc.content.length);
+      if (validationError) {
+        ws.send(JSON.stringify({ type: 'error', message: validationError }));
+        return;
+      }
+
+      // Apply the operation
+      const newContent = applyOp(currentDoc.content, op);
+      const newVersion = docState.version + 1;
+
+      // Persist
+      store.updateContent(documentId!, newContent, JSON.stringify(op), newVersion);
+
+      // Update in-memory state
+      docState.version = newVersion;
+      docState.history.push(op);
+
+      // ACK to sender
+      ws.send(JSON.stringify({ type: 'ack', version: newVersion }));
+
+      // Broadcast to others
+      broadcast(documentId!, {
+        type: 'operation',
+        operation: op,
+        version: newVersion,
+      }, ws);
+    });
+
+    ws.on('close', () => {
+      const room = rooms.get(documentId!);
+      if (room) {
+        room.delete(clientInfo);
+        if (room.size === 0) {
+          rooms.delete(documentId!);
+          docStates.delete(documentId!);
+        }
+      }
+    });
+
+    ws.on('error', () => {
+      // Clean up on error
+      const room = rooms.get(documentId!);
+      if (room) {
+        room.delete(clientInfo);
+        if (room.size === 0) {
+          rooms.delete(documentId!);
+          docStates.delete(documentId!);
+        }
+      }
+    });
+  });
+
+  return {
+    wss,
+    close() {
+      for (const [, room] of rooms) {
+        for (const client of room) {
+          client.ws.close();
+        }
+      }
+      rooms.clear();
+      docStates.clear();
+      wss.close();
+    },
+  };
+}
