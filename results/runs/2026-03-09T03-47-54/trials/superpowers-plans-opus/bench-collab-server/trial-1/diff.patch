: 10, text: 'x' }, 5)).not.toBeNull();\n  });\n\n  it('rejects delete beyond document', () => {\n    expect(validateOp({ type: 'delete', position: 3, count: 5 }, 5)).not.toBeNull();\n  });\n\n  it('rejects empty insert text', () => {\n    expect(validateOp({ type: 'insert', position: 0, text: '' }, 5)).not.toBeNull();\n  });\n\n  it('rejects negative position', () => {\n    expect(validateOp({ type: 'insert', position: -1, text: 'x' }, 5)).not.toBeNull();\n  });\n\n  it('rejects zero count delete', () => {\n    expect(validateOp({ type: 'delete', position: 0, count: 0 }, 5)).not.toBeNull();\n  });\n});\n\ndescribe('transformOp', () => {\n  it('transforms insert-insert: op1 after op2', () => {\n    const op1: Operation = { type: 'insert', position: 5, text: 'a' };\n    const op2: Operation = { type: 'insert', position: 3, text: 'b' };\n    const result = transformOp(op1, op2);\n    expect(result.type).toBe('insert');\n    if (result.type === 'insert') {\n      expect(result.position).toBe(6); // shifted by 1 (length of 'b')\n    }\n  });\n\n  it('transforms insert-insert: op1 before op2', () => {\n    const op1: Operation = { type: 'insert', position: 2, text: 'a' };\n    const op2: Operation = { type: 'insert', position: 5, text: 'b' };\n    const result = transformOp(op1, op2);\n    if (result.type === 'insert') {\n      expect(result.position).toBe(2); // no shift\n    }\n  });\n\n  it('transforms insert-delete: insert before delete', () => {\n    const op1: Operation = { type: 'insert', position: 2, text: 'x' };\n    const op2: Operation = { type: 'delete', position: 5, count: 3 };\n    const result = transformOp(op1, op2);\n    if (result.type === 'insert') {\n      expect(result.position).toBe(2);\n    }\n  });\n\n  it('transforms insert-delete: insert after delete', () => {\n    const op1: Operation = { type: 'insert', position: 8, text: 'x' };\n    const op2: Operation = { type: 'delete', position: 2, count: 3 };\n    const result = transformOp(op1, op2);\n    if (result.type === 'insert') {\n      expect(result.position).toBe(5); // 8 - 3\n    }\n  });\n\n  it('transforms delete-insert: delete before insert', () => {\n    const op1: Operation = { type: 'delete', position: 0, count: 2 };\n    const op2: Operation = { type: 'insert', position: 5, text: 'abc' };\n    const result = transformOp(op1, op2);\n    if (result.type === 'delete') {\n      expect(result.position).toBe(0);\n      expect(result.count).toBe(2);\n    }\n  });\n\n  it('transforms delete-insert: delete after insert', () => {\n    const op1: Operation = { type: 'delete', position: 5, count: 2 };\n    const op2: Operation = { type: 'insert', position: 3, text: 'abc' };\n    const result = transformOp(op1, op2);\n    if (result.type === 'delete') {\n      expect(result.position).toBe(8); // 5 + 3\n      expect(result.count).toBe(2);\n    }\n  });\n\n  it('transforms delete-delete: non-overlapping, op1 after op2', () => {\n    const op1: Operation = { type: 'delete', position: 8, count: 2 };\n    const op2: Operation = { type: 'delete', position: 2, count: 3 };\n    const result = transformOp(op1, op2);\n    if (result.type === 'delete') {\n      expect(result.position).toBe(5); // 8 - 3\n      expect(result.count).toBe(2);\n    }\n  });\n\n  it('transforms delete-delete: fully overlapping (op1 within op2)', () => {\n    const op1: Operation = { type: 'delete', position: 3, count: 2 };\n    const op2: Operation = { type: 'delete', position: 2, count: 5 };\n    const result = transformOp(op1, op2);\n    if (result.type === 'delete') {\n      expect(result.count).toBe(0); // nothing left to delete\n    }\n  });\n\n  it('convergence: two concurrent inserts produce same result', () => {\n    const doc = 'hello';\n    const op1: Operation = { type: 'insert', position: 0, text: 'A' };\n    const op2: Operation = { type: 'insert', position: 5, text: 'B' };\n\n    // Path 1: apply op1 then transformed op2\n    const op2t = transformOp(op2, op1);\n    const result1 