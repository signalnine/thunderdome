+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { join, dirname } from 'path';
+import { fileURLToPath } from 'url';
+
+const __dirname = dirname(fileURLToPath(import.meta.url));
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDatabase(dbPath?: string): Database.Database {
+  const db = new Database(dbPath || ':memory:');
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  const schemaPath = join(__dirname, '..', 'schema.sql');
+  const schema = readFileSync(schemaPath, 'utf-8');
+  db.exec(schema);
+
+  return db;
+}
+
+export class DocumentStore {
+  private db: Database.Database;
+
+  constructor(db: Database.Database) {
+    this.db = db;
+  }
+
+  create(id: string, title: string, content: string = ''): DocumentRow {
+    this.db.prepare(
+      `INSERT INTO documents (id, title, content) VALUES (?, ?, ?)`
+    ).run(id, title, content);
+
+    // Create initial version (version 0)
+    this.db.prepare(
+      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, 0, ?, NULL)`
+    ).run(id, content);
+
+    return this.getById(id)!;
+  }
+
+  getById(id: string): DocumentRow | undefined {
+    return this.db.prepare(
+      `SELECT * FROM documents WHERE id = ?`
+    ).get(id) as DocumentRow | undefined;
+  }
+
+  list(): DocumentRow[] {
+    return this.db.prepare(
+      `SELECT * FROM documents ORDER BY updated_at DESC`
+    ).all() as DocumentRow[];
+  }
+
+  update(id: string, fields: { title?: string; content?: string }): DocumentRow | undefined {
+    const doc = this.getById(id);
+    if (!doc) return undefined;
+
+    const title = fields.title ?? doc.title;
+    const content = fields.content ?? doc.content;
+
+    this.db.prepare(
+      `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`
+    ).run(title, content, id);
+
+    return this.getById(id)!;
+  }
+
+  updateContent(id: string, content: string, operation: string, version: number): void {
+    this.db.prepare(
+      `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`
+    ).run(content, id);
+
+    this.db.prepare(
+      `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`
+    ).run(id, version, content, operation);
+  }
+
+  delete(id: string): boolean {
+    const result = this.db.prepare(
+      `DELETE FROM documents WHERE id = ?`
+    ).run(id);
+    return result.changes > 0;
+  }
+
+  getVersions(documentId: string): VersionRow[] {
+    return this.db.prepare(
+      `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`
+    ).all(documentId) as VersionRow[];
+  }
+
+  getLatestVersion(documentId: string): number {
+    const row = this.db.prepare(
+      `SELECT MAX(version) as max_version FROM versions WHERE document_id = ?`
+    ).get(documentId) as { max_version: number | null } | undefined;
+    return row?.max_version ?? 0;
+  }
+}
