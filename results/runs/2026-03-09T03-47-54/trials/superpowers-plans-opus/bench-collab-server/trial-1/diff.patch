@@ -0,0 +1,130 @@
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+/**
+ * Apply a single operation to a document string.
+ */
+export function applyOp(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    return content.slice(0, pos) + op.text + content.slice(pos);
+  } else {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    const count = Math.min(op.count, content.length - pos);
+    return content.slice(0, pos) + content.slice(pos + count);
+  }
+}
+
+/**
+ * Validate that an operation is well-formed and applicable to a document of the given length.
+ */
+export function validateOp(op: Operation, contentLength: number): string | null {
+  if (!op || typeof op !== 'object') return 'Operation must be an object';
+  if (op.type !== 'insert' && op.type !== 'delete') return 'Operation type must be "insert" or "delete"';
+  if (typeof op.position !== 'number' || !Number.isInteger(op.position)) return 'Position must be an integer';
+  if (op.position < 0) return 'Position must be non-negative';
+
+  if (op.type === 'insert') {
+    if (typeof op.text !== 'string') return 'Insert operation must have a text string';
+    if (op.text.length === 0) return 'Insert text must not be empty';
+    if (op.position > contentLength) return `Position ${op.position} is beyond document length ${contentLength}`;
+  } else {
+    if (typeof op.count !== 'number' || !Number.isInteger(op.count)) return 'Delete count must be an integer';
+    if (op.count <= 0) return 'Delete count must be positive';
+    if (op.position > contentLength) return `Position ${op.position} is beyond document length ${contentLength}`;
+    if (op.position + op.count > contentLength) return `Delete range exceeds document length`;
+  }
+
+  return null;
+}
+
+/**
+ * Transform op1 against op2 — returns a new op1' such that:
+ *   apply(apply(doc, op2), op1') === apply(apply(doc, op1), op2')
+ *
+ * This is the standard OT transform for positional insert/delete operations.
+ * op1 is the incoming operation, op2 is the already-applied operation.
+ */
+export function transformOp(op1: Operation, op2: Operation): Operation {
+  if (op1.type === 'insert' && op2.type === 'insert') {
+    // Both inserts: if op1 inserts at or after op2's position, shift right
+    if (op1.position > op2.position || (op1.position === op2.position && op1.text > op2.text)) {
+      return { ...op1, position: op1.position + op2.text.length };
+    }
+    return { ...op1 };
+  }
+
+  if (op1.type === 'insert' && op2.type === 'delete') {
+    // Insert against delete
+    if (op1.position <= op2.position) {
+      return { ...op1 };
+    }
+    if (op1.position >= op2.position + op2.count) {
+      return { ...op1, position: op1.position - op2.count };
+    }
+    // Insert was inside the deleted range — move to delete position
+    return { ...op1, position: op2.position };
+  }
+
+  if (op1.type === 'delete' && op2.type === 'insert') {
+    // Delete against insert
+    if (op1.position >= op2.position) {
+      return { ...op1, position: op1.position + op2.text.length };
+    }
+    if (op1.position + op1.count <= op2.position) {
+      return { ...op1 };
+    }
+    // Delete range spans the insert point — expand to account for inserted text
+    // The delete was from op1.position to op1.position+op1.count
+    // op2 inserted text at op2.position (which is within our delete range)
+    // After op2's insert, we need to delete around the inserted text
+    // We split: delete before insert + delete after insert (skip inserted text)
+    // But OT typically handles this as: increase count by inserted text length
+    // Actually, standard OT: the delete range shifts and doesn't delete the newly inserted text
+    // We delete what was there before, not the new insert
+    return { ...op1, count: op1.count + op2.text.length };
+  }
+
+  // Both deletes
+  if (op1.type === 'delete' && op2.type === 'delete') {
+    // op2 was already applied; adjust op1
+    if (op1.position >= op2.position + op2.count) {
+      // op1 is entirely after op2's range
+      return { ...op1, position: op1.position - op2.count };
+    }
+    if (op1.position + op1.count <= op2.position) {
+      // op1 is entirely before op2's range
+      return { ...op1 };
+    }
+    // Overlapping deletes
+    if (op1.position >= op2.position && op1.position + op1.count <= op2.position + op2.count) {
+      // op1 is entirely within op2 — nothing left to delete
+      return { type: 'delete', position: op2.position, count: 0 };
+    }
+    if (op1.position <= op2.position && op1.position + op1.count >= op2.position + op2.count) {
+      // op1 fully contains op2
+      return { type: 'delete', position: op1.position, count: op1.count - op2.count };
+    }
+    if (op1.position < op2.position) {
+      // op1 starts before op2 but overlaps
+      const overlap = op1.position + op1.count - op2.position;
+      return { type: 'delete', position: op1.position, count: op1.count - overlap };
+    }
+    // op1 starts inside op2 but extends beyond
+    const overlap = op2.position + op2.count - op1.position;
+    return { type: 'delete', position: op2.position, count: op1.count - overlap };
+  }
+
+  return { ...op1 } as Operation;
+}
