diff --git a/src/__tests__/api.test.ts b/src/__tests__/api.test.ts
new file mode 100644
index 0000000..3b94a6b
--- /dev/null
+++ b/src/__tests__/api.test.ts
@@ -0,0 +1,120 @@
+import { describe, it, expect, beforeAll, afterAll } from 'vitest';
+import request from 'supertest';
+import { createApp, AppInstance } from '../server.js';
+
+let app: AppInstance;
+
+beforeAll(async () => {
+  app = createApp(':memory:');
+  await app.start();
+});
+
+afterAll(async () => {
+  await app.stop();
+});
+
+describe('REST API', () => {
+  let docId: string;
+
+  it('creates a document', async () => {
+    const res = await request(app.app)
+      .post('/documents')
+      .send({ title: 'Test Doc', content: 'Hello World' })
+      .expect(201);
+
+    expect(res.body.id).toBeDefined();
+    expect(res.body.title).toBe('Test Doc');
+    expect(res.body.content).toBe('Hello World');
+    docId = res.body.id;
+  });
+
+  it('rejects document without title', async () => {
+    await request(app.app)
+      .post('/documents')
+      .send({ content: 'No title' })
+      .expect(400);
+  });
+
+  it('lists documents', async () => {
+    const res = await request(app.app)
+      .get('/documents')
+      .expect(200);
+
+    expect(Array.isArray(res.body)).toBe(true);
+    expect(res.body.length).toBeGreaterThanOrEqual(1);
+  });
+
+  it('gets a document by id', async () => {
+    const res = await request(app.app)
+      .get(`/documents/${docId}`)
+      .expect(200);
+
+    expect(res.body.id).toBe(docId);
+    expect(res.body.title).toBe('Test Doc');
+  });
+
+  it('returns 404 for non-existent document', async () => {
+    await request(app.app)
+      .get('/documents/nonexistent')
+      .expect(404);
+  });
+
+  it('updates a document', async () => {
+    const res = await request(app.app)
+      .put(`/documents/${docId}`)
+      .send({ title: 'Updated Title', content: 'Updated Content' })
+      .expect(200);
+
+    expect(res.body.title).toBe('Updated Title');
+    expect(res.body.content).toBe('Updated Content');
+  });
+
+  it('partially updates a document (title only)', async () => {
+    const res = await request(app.app)
+      .put(`/documents/${docId}`)
+      .send({ title: 'New Title' })
+      .expect(200);
+
+    expect(res.body.title).toBe('New Title');
+    expect(res.body.content).toBe('Updated Content');
+  });
+
+  it('returns 404 updating non-existent document', async () => {
+    await request(app.app)
+      .put('/documents/nonexistent')
+      .send({ title: 'X' })
+      .expect(404);
+  });
+
+  it('gets version history', async () => {
+    const res = await request(app.app)
+      .get(`/documents/${docId}/versions`)
+      .expect(200);
+
+    expect(Array.isArray(res.body)).toBe(true);
+    expect(res.body.length).toBeGreaterThanOrEqual(1);
+    expect(res.body[0].document_id).toBe(docId);
+  });
+
+  it('returns 404 for versions of non-existent document', async () => {
+    await request(app.app)
+      .get('/documents/nonexistent/versions')
+      .expect(404);
+  });
+
+  it('deletes a document', async () => {
+    await request(app.app)
+      .delete(`/documents/${docId}`)
+      .expect(204);
+
+    await request(app.app)
+      .get(`/documents/${docId}`)
+      .expect(404);
+  });
+
+  it('returns 404 deleting non-existent document', async () => {
+    await request(app.app)
+      .delete('/documents/nonexistent')
+      .expect(404);
+  });
+});
diff --git a/src/__tests__/ot.test.ts b/src/__tests__/ot.test.ts
new file mode 100644
index 0000000..0946b02
--- /dev/null
+++ b/src/__tests__/ot.test.ts
@@ -0,0 +1,174 @@
+import { describe, it, expect } from 'vitest';
+import { applyOp, validateOp, transformOp, Operation } from '../ot.js';
+
+describe('applyOp', () => {
+  it('inserts text at the beginning', () => {
+    expect(applyOp('hello', { type: 'insert', position: 0, text: 'say ' })).toBe('say hello');
+  });
+
+  it('inserts text in the middle', () => {
+    expect(applyOp('helo', { type: 'insert', position: 3, text: 'l' })).toBe('hello');
+  });
+
+  it('inserts text at the end', () => {
+    expect(applyOp('hello', { type: 'insert', position: 5, text: ' world' })).toBe('hello world');
+  });
+
+  it('deletes text from the beginning', () => {
+    expect(applyOp('hello world', { type: 'delete', position: 0, count: 6 })).toBe('world');
+  });
+
+  it('deletes text from the middle', () => {
+    expect(applyOp('hello world', { type: 'delete', position: 5, count: 1 })).toBe('helloworld');
+  });
+
+  it('deletes text from the end', () => {
+    expect(applyOp('hello world', { type: 'delete', position: 5, count: 6 })).toBe('hello');
+  });
+
+  it('handles empty document insert', () => {
+    expect(applyOp('', { type: 'insert', position: 0, text: 'hi' })).toBe('hi');
+  });
+
+  it('clamps position for insert', () => {
+    expect(applyOp('ab', { type: 'insert', position: 100, text: 'c' })).toBe('abc');
+  });
+});
+
+describe('validateOp', () => {
+  it('accepts valid insert', () => {
+    expect(validateOp({ type: 'insert', position: 0, text: 'hi' }, 0)).toBeNull();
+  });
+
+  it('accepts valid delete', () => {
+    expect(validateOp({ type: 'delete', position: 0, count: 2 }, 5)).toBeNull();
+  });
+
+  it('rejects insert beyond document', () => {
+    expect(validateOp({ type: 'insert', position: 10, text: 'x' }, 5)).not.toBeNull();
+  });
+
+  it('rejects delete beyond document', () => {
+    expect(validateOp({ type: 'delete', position: 3, count: 5 }, 5)).not.toBeNull();
+  });
+
+  it('rejects empty insert text', () => {
+    expect(validateOp({ type: 'insert', position: 0, text: '' }, 5)).not.toBeNull();
+  });
+
+  it('rejects negative position', () => {
+    expect(validateOp({ type: 'insert', position: -1, text: 'x' }, 5)).not.toBeNull();
+  });
+
+  it('rejects zero count delete', () => {
+    expect(validateOp({ type: 'delete', position: 0, count: 0 }, 5)).not.toBeNull();
+  });
+});
+
+describe('transformOp', () => {
+  it('transforms insert-insert: op1 after op2', () => {
+    const op1: Operation = { type: 'insert', position: 5, text: 'a' };
+    const op2: Operation = { type: 'insert', position: 3, text: 'b' };
+    const result = transformOp(op1, op2);
+    expect(result.type).toBe('insert');
+    if (result.type === 'insert') {
+      expect(result.position).toBe(6); // shifted by 1 (length of 'b')
+    }
+  });
+
+  it('transforms insert-insert: op1 before op2', () => {
+    const op1: Operation = { type: 'insert', position: 2, text: 'a' };
+    const op2: Operation = { type: 'insert', position: 5, text: 'b' };
+    const result = transformOp(op1, op2);
+    if (result.type === 'insert') {
+      expect(result.position).toBe(2); // no shift
+    }
+  });
+
+  it('transforms insert-delete: insert before delete', () => {
+    const op1: Operation = { type: 'insert', position: 2, text: 'x' };
+    const op2: Operation = { type: 'delete', position: 5, count: 3 };
+    const result = transformOp(op1, op2);
+    if (result.type === 'insert') {
+      expect(result.position).toBe(2);
+    }
+  });
+
+  it('transforms insert-delete: insert after delete', () => {
+    const op1: Operation = { type: 'insert', position: 8, text: 'x' };
+    const op2: Operation = { type: 'delete', position: 2, count: 3 };
+    const result = transformOp(op1, op2);
+    if (result.type === 'insert') {
+      expect(result.position).toBe(5); // 8 - 3
+    }
+  });
+
+  it('transforms delete-insert: delete before insert', () => {
+    const op1: Operation = { type: 'delete', position: 0, count: 2 };
+    const op2: Operation = { type: 'insert', position: 5, text: 'abc' };
+    const result = transformOp(op1, op2);
+    if (result.type === 'delete') {
+      expect(result.position).toBe(0);
+      expect(result.count).toBe(2);
+    }
+  });
+
+  it('transforms delete-insert: delete after insert', () => {
+    const op1: Operation = { type: 'delete', position: 5, count: 2 };
+    const op2: Operation = { type: 'insert', position: 3, text: 'abc' };
+    const result = transformOp(op1, op2);
+    if (result.type === 'delete') {
+      expect(result.position).toBe(8); // 5 + 3
+      expect(result.count).toBe(2);
+    }
+  });
+
+  it('transforms delete-delete: non-overlapping, op1 after op2', () => {
+    const op1: Operation = { type: 'delete', position: 8, count: 2 };
+    const op2: Operation = { type: 'delete', position: 2, count: 3 };
+    const result = transformOp(op1, op2);
+    if (result.type === 'delete') {
+      expect(result.position).toBe(5); // 8 - 3
+      expect(result.count).toBe(2);
+    }
+  });
+
+  it('transforms delete-delete: fully overlapping (op1 within op2)', () => {
+    const op1: Operation = { type: 'delete', position: 3, count: 2 };
+    const op2: Operation = { type: 'delete', position: 2, count: 5 };
+    const result = transformOp(op1, op2);
+    if (result.type === 'delete') {
+      expect(result.count).toBe(0); // nothing left to delete
+    }
+  });
+
+  it('convergence: two concurrent inserts produce same result', () => {
+    const doc = 'hello';
+    const op1: Operation = { type: 'insert', position: 0, text: 'A' };
+    const op2: Operation = { type: 'insert', position: 5, text: 'B' };
+
+    // Path 1: apply op1 then transformed op2
+    const op2t = transformOp(op2, op1);
+    const result1 = applyOp(applyOp(doc, op1), op2t);
+
+    // Path 2: apply op2 then transformed op1
+    const op1t = transformOp(op1, op2);
+    const result2 = applyOp(applyOp(doc, op2), op1t);
+
+    expect(result1).toBe(result2);
+  });
+
+  it('convergence: insert and delete produce same result', () => {
+    const doc = 'hello world';
+    const op1: Operation = { type: 'insert', position: 5, text: ' dear' };
+    const op2: Operation = { type: 'delete', position: 5, count: 6 };
+
+    const op2t = transformOp(op2, op1);
+    const result1 = applyOp(applyOp(doc, op1), op2t);
+
+    const op1t = transformOp(op1, op2);
+    const result2 = applyOp(applyOp(doc, op2), op1t);
+
+    expect(result1).toBe(result2);
+  });
+});
diff --git a/src/__tests__/websocket.test.ts b/src/__tests__/websocket.test.ts
