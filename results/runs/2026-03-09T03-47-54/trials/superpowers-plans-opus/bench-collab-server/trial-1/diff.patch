(op.count <= 0) return 'Delete count must be positive';\n    if (op.position > contentLength) return `Position ${op.position} is beyond document length ${contentLength}`;\n    if (op.position + op.count > contentLength) return `Delete range exceeds document length`;\n  }\n\n  return null;\n}\n\n/**\n * Transform op1 against op2 — returns a new op1' such that:\n *   apply(apply(doc, op2), op1') === apply(apply(doc, op1), op2')\n *\n * This is the standard OT transform for positional insert/delete operations.\n * op1 is the incoming operation, op2 is the already-applied operation.\n */\nexport function transformOp(op1: Operation, op2: Operation): Operation {\n  if (op1.type === 'insert' && op2.type === 'insert') {\n    // Both inserts: if op1 inserts at or after op2's position, shift right\n    if (op1.position > op2.position || (op1.position === op2.position && op1.text > op2.text)) {\n      return { ...op1, position: op1.position + op2.text.length };\n    }\n    return { ...op1 };\n  }\n\n  if (op1.type === 'insert' && op2.type === 'delete') {\n    // Insert against delete\n    if (op1.position <= op2.position) {\n      return { ...op1 };\n    }\n    if (op1.position >= op2.position + op2.count) {\n      return { ...op1, position: op1.position - op2.count };\n    }\n    // Insert was inside the deleted range — move to delete position\n    return { ...op1, position: op2.position };\n  }\n\n  if (op1.type === 'delete' && op2.type === 'insert') {\n    // Delete against insert\n    if (op1.position >= op2.position) {\n      return { ...op1, position: op1.position + op2.text.length };\n    }\n    if (op1.position + op1.count <= op2.position) {\n      return { ...op1 };\n    }\n    // Delete range spans the insert point — expand to account for inserted text\n    // The delete was from op1.position to op1.position+op1.count\n    // op2 inserted text at op2.position (which is within our delete range)\n    // After op2's insert, we need to delete around the inserted text\n  