   const res = await request(app.app)\n      .post('/documents')\n      .send({ title: 'WS Test', content: 'hello' })\n      .expect(201);\n    docId = res.body.id;\n  });\n\n  it('sends sync message on connection', async () => {\n    const ws = await connectWs(docId);\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe(0);\n    ws.close();\n  });\n\n  it('rejects connection for non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n    expect(msg.message).toContain('not found');\n  });\n\n  it('rejects connection with invalid path', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/invalid`);\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n  });\n\n  it('applies an insert operation and acks', async () => {\n    const ws = await connectWs(docId);\n    await waitForMessage(ws); // sync\n\n    const ackPromise = waitForMessage(ws);\n    sendOp(ws, { type: 'insert', position: 5, text: ' world' }, 0);\n    const ack = await ackPromise;\n\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(1);\n\n    // Verify via REST\n    const res = await request(app.app).get(`/documents/${docId}`).expect(200);\n    expect(res.body.content).toBe('hello world');\n\n    ws.close();\n  });\n\n  it('applies a delete operation and acks', async () => {\n    const ws = await connectWs(docId);\n    await waitForMessage(ws); // sync\n\n    const ackPromise = waitForMessage(ws);\n    sendOp(ws, { type: 'delete', position: 0, count: 2 }, 0);\n    const ack = await ackPromise;\n\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(1);\n\n    const res = await request(app.app).get(`/documents/${docId}`).expect(200);\n    expect(res.body.content).toBe('llo');\n\n    ws.close();\n  });\n\n  it('broadcasts operations to other clients', async () => {\n    const ws1 = await connectWs(docId);\n    const ws2 = await connectWs(docId);\n    await waitForMessage(ws1); // sync\n    await waitForMessage(ws2); // sync\n\n    const broadcastPromise = waitForMessage(ws2);\n    const ackPromise = waitForMessage(ws1);\n\n    sendOp(ws1, { type: 'insert', position: 5, text: '!' }, 0);\n\n    const ack = await ackPromise;\n    expect(ack.type).toBe('ack');\n\n    const broadcast = await broadcastPromise;\n    expect(broadcast.type).toBe('operation');\n    expect((broadcast.operation as Record<string, unknown>).type).toBe('insert');\n    expect(broadcast.version).toBe(1);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('handles concurrent edits with OT', async () => {\n    const ws1 = await connectWs(docId);\n    const ws2 = await connectWs(docId);\n    await waitForMessage(ws1); // sync\n    await waitForMessage(ws2); // sync\n\n    // Both clients send operations based on version 0\n    // Client 1 inserts 'A' at position 0\n    // Client 2 inserts 'B' at position 5 (end of \"hello\")\n\n    const ack1Promise = waitForMessage(ws1);\n    sendOp(ws1, { type: 'insert', position: 0, text: 'A' }, 0);\n    const ack1 = await ack1Promise;\n    expect(ack1.type).toBe('ack');\n    expect(ack1.version).toBe(1);\n\n    // ws2 hasn't received ws1's broadcast yet, sends based on version 0\n    const ack2Promise = waitForMessage(ws2);\n    // Skip broadcast from ws1 if it arrives first\n    const ws2Msgs: Record<string, unknown>[] = [];\n    const collectMsgs = new Promise<void>((resolve) => {\n      const handler = (data: WebSocket.Data) => {\n        const msg = JSON.parse(data.toString());\n        ws2Msgs.push(msg);\n        if (msg.type === 'ack') {\n          ws2.removeListener('message', handler);\n          resolve();\n        }\n      };\n      ws2.on('message', handler);\n    });\n\n    sendOp(ws2, { type: 'insert', position: 5, text: 'B' }, 0);\n    await collectMsgs;\n\n    // Verify final document via REST\n    const res = await request(app.app).get(`/documents/${docId}`).expect(200);\n    // After OT: 'A' inserted at 0, 'B' inserted at end → \"AhelloB\"\n    expect(res.body.content).toBe('AhelloB');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('records version history', async () => {\n    const ws = await connectWs(docId);\n    await waitForMessage(ws); // sync\n\n    const ack1 = waitForMessage(ws);\n    sendOp(ws, { type: 'insert', position: 5, text: '!' }, 0);\n    await ack1;\n\n    const ack2 = waitForMessage(ws);\n    sendOp(ws, { type: 'insert', position: 0, text: 'Say ' }, 1);\n    await ack2;\n\n    ws.close();\n\n    const res = await request(app.app).get(`/documents/${docId}/versions`).expect(200);\n    expect(res.body.length).toBeGreaterThanOrEqual(3); // version 0, 1, 2\n  });\n\n  it('rejects malformed operations', async () => {\n    const ws = await connectWs(docId);\n    await waitForMessage(ws); // sync\n\n    const errPromise = waitForMessage(ws);\n    ws.send(JSON.stringify({ type: 'operation', operation: { type: 'invalid' }, version: 0 }));\n    const err = await errPromise;\n\n    expect(err.type).toBe('error');\n    ws.close();\n  });\n\n  it('rejects invalid JSON', async () => {\n    const ws = await connectWs(docId);\n    await waitForMessage(ws); // sync\n\n    const errPromise = waitForMessage(ws);\n    ws.send('not json');\n    const err = await errPromise;\n\n    expect(err.type).toBe('error');\n    ws.close();\n  });\n\n  it('handles 10 concurrent clients', async () => {\n    // Create a doc for this test\n    const createRes = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Concurrency Test', content: '' })\n      .expect(201);\n    const testDocId = createRes.body.id;\n\n    const clients: WebSocket[] = [];\n    const syncs: Promise<Record<string, unknown>>[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(testDocId);\n      syncs.push(waitForMessage(ws));\n      clients.push(ws);\n    }\n    await Promise.all(syncs);\n\n    // Each client inserts a character at position 0\n    const acks: Promise<Record<string, unknown>>[] = [];\n    for (let i = 0; i < 10; i++) {\n      // Collect messages until we get an ack\n      const ackPromise = new Promise<Record<string, unknown>>((resolve) => {\n        const handler = (data: WebSocket.Data) => {\n          const msg = JSON.parse(data.toString());\n          if (msg.type === 'ack') {\n            clients[i].removeListener('message', handler);\n            resolve(msg);\n          }\n        };\n        clients[i].on('message', handler);\n      });\n      acks.push(ackPromise);\n      sendOp(clients[i], { type: 'insert', position: 0, text: String(i) }, 0);\n    }\n\n    await Promise.all(acks);\n\n    // Verify document via REST - should have all 10 digits\n    const res = await request(app.app).get(`/documents/${testDocId}`).expect(200);\n    const content = res.body.content as string;\n    expect(content.length).toBe(10);\n\n    // Every digit 0-9 should be present\n    for (let i = 0; i < 10; i++) {\n      expect(content).toContain(String(i));\n    }\n\n    for (const ws of clients) {\n      ws.close();\n    }\n  });\n});\n","structuredPatch":[{"oldStart":5,"oldLines":12,"newStart":5,"newLines":10,"lines":[" "," let app: AppInstance;"," let port: number;","-let baseUrl: string;"," "," beforeAll(async () => {","   app = createApp(':memory:');","   port = await app.start();","-  baseUrl = `http://localhost:${port}`;"," });"," "," afterAll(async () => {"]}],"userModified":false,"replaceAll":false}}
