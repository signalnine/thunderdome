+import { Event, Room, ScheduleOptions, ScheduleResult, Assignment } from './types.js';
+
+function topologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map(e => e.id));
+  const graph = new Map<string, string[]>();
+  const inDegree = new Map<string, number>();
+
+  for (const event of events) {
+    graph.set(event.id, []);
+    inDegree.set(event.id, 0);
+  }
+
+  for (const event of events) {
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        if (prereq === event.id) {
+          throw new Error('Prerequisite cycle detected: self-reference');
+        }
+        if (!eventIds.has(prereq)) {
+          // Prerequisite references non-existent event - skip
+          continue;
+        }
+        graph.get(prereq)!.push(event.id);
+        inDegree.set(event.id, inDegree.get(event.id)! + 1);
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, degree] of inDegree) {
+    if (degree === 0) queue.push(id);
+  }
+
+  const sorted: string[] = [];
+  while (queue.length > 0) {
+    const id = queue.shift()!;
+    sorted.push(id);
+    for (const neighbor of graph.get(id)!) {
+      const newDegree = inDegree.get(neighbor)! - 1;
+      inDegree.set(neighbor, newDegree);
+      if (newDegree === 0) queue.push(neighbor);
+    }
+  }
+
+  if (sorted.length !== events.length) {
+    throw new Error('Prerequisite cycle detected');
+  }
+
+  return sorted;
+}
+
+function findEarliestSlot(
+  slots: { start: number; end: number }[],
+  earliestStart: number,
+  duration: number,
+  gap: number,
+  endTime: number,
+): number | null {
+  if (earliestStart + duration > endTime) return null;
+
+  if (slots.length === 0) {
+    return earliestStart;
+  }
+
+  // Try to fit starting from earliestStart, checking against all existing slots
+  let candidateStart = earliestStart;
+
+  // Sort slots by start time
+  const sortedSlots = [...slots].sort((a, b) => a.start - b.start);
+
+  // Try before first slot
+  if (candidateStart + duration + gap <= sortedSlots[0].start) {
+    return candidateStart;
+  }
+
+  // Try between slots and after slots
+  for (let i = 0; i < sortedSlots.length; i++) {
+    // Must start after this slot ends + gap
+    candidateStart = Math.max(candidateStart, sortedSlots[i].end + gap);
+
+    if (candidateStart + duration > endTime) return null;
+
+    // Check if fits before next slot
+    if (i + 1 < sortedSlots.length) {
+      if (candidateStart + duration + gap <= sortedSlots[i + 1].start) {
+        return candidateStart;
+      }
+    } else {
+      // After last slot - just check end time
+      if (candidateStart + duration <= endTime) {
+        return candidateStart;
+      }
+    }
+  }
+
+  return null;
+}
+
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  const gap = options.gap ?? 15;
+
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  // Validate prerequisites and get topological ordering
+  const sorted = topologicalSort(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  // Try greedy scheduling first, then try to improve with backtracking
+  const result = greedySchedule(sorted, eventMap, rooms, options, gap);
+
+  // If some events are unscheduled, try different orderings to maximize
+  if (result.unscheduled.length > 0) {
+    const betterResult = tryOptimize(sorted, eventMap, rooms, options, gap);
+    if (betterResult.assignments.length > result.assignments.length) {
+      return betterResult;
+    }
+  }
+
+  return result;
+}
+
+function greedySchedule(
+  sorted: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number,
+): ScheduleResult {
+  const roomSchedules = new Map<string, { start: number; end: number }[]>();
+  for (const room of rooms) {
+    roomSchedules.set(room.id, []);
+  }
+
+  const assignments: Assignment[] = [];
+  const assignmentMap = new Map<string, Assignment>();
+  const unscheduled: string[] = [];
+
+  for (const eventId of sorted) {
+    const event = eventMap.get(eventId)!;
+    const attendees = event.attendees ?? 1;
+
+    // Determine earliest start based on prerequisites
+    let earliestStart = options.startTime;
+    let prereqFailed = false;
+
+    if (event.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        const prereqAssignment = assignmentMap.get(prereqId);
+        if (!prereqAssignment) {
+          // Check if prereq exists in event list
+          if (eventMap.has(prereqId)) {
+            prereqFailed = true;
+            break;
+          }
+          // Non-existent prereq - ignore
+          continue;
+        }
+        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);
+      }
+    }
+
+    if (prereqFailed || earliestStart + event.duration > options.endTime) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    // Sort rooms: preferred room first, then by capacity (smallest sufficient first)
+    const eligibleRooms = rooms
+      .filter(r => r.capacity >= attendees)
+      .sort((a, b) => {
+        if (event.preferredRoom === a.id) return -1;
+        if (event.preferredRoom === b.id) return 1;
+        return a.capacity - b.capacity;
+      });
+
+    let bestAssignment: Assignment | null = null;
+
+    for (const room of eligibleRooms) {
+      const slots = roomSchedules.get(room.id)!;
+      const startTime = findEarliestSlot(slots, earliestStart, event.duration, gap, options.endTime);
+
+      if (startTime !== null) {
+        const candidate: Assignment = {
+          eventId,
+          roomId: room.id,
+          startTime,
+          endTime: startTime + event.duration,
+        };
+
+        if (event.preferredRoom === room.id) {
+          bestAssignment = candidate;
+          break;
+        }
+
+        if (!bestAssignment || startTime < bestAssignment.startTime) {
+          bestAssignment = candidate;
+        }
+      }
+    }
+
+    if (bestAssignment) {
+      assignments.push(bestAssignment);
+      assignmentMap.set(eventId, bestAssignment);
+      const slots = roomSchedules.get(bestAssignment.roomId)!;
+      slots.push({ start: bestAssignment.startTime, end: bestAssignment.endTime });
+      slots.sort((a, b) => a.start - b.start);
+    } else {
+      unscheduled.push(eventId);
+    }
+  }
+
+  return { assignments, unscheduled };
+}
+
+function tryOptimize(
+  sorted: string[],
+  eventMap: Map<string, Event>,
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number,
+): ScheduleResult {
+  // Try scheduling by sorting events by duration (shortest first) to pack more events
+  // while respecting topological order
+  let bestResult = greedySchedule(sorted, eventMap, rooms, options, gap);
+
+  // Build dependency info for ordering constraints
+  const dependsOn = new Map<string, Set<string>>();
+  const allDeps = new Map<string, Set<string>>();
+
+  for (const eventId of sorted) {
+    const event = eventMap.get(eventId)!;
+    dependsOn.set(eventId, new Set(event.prerequisites?.filter(p => eventMap.has(p)) || []));
+  }
+
+  // Compute transitive dependencies
+  for (const eventId of sorted) {
+    const trans = new Set<string>();
+    const stack = [...(dependsOn.get(eventId) || [])];
+    while (stack.length > 0) {
+      const dep = stack.pop()!;
+      if (!trans.has(dep)) {
+        trans.add(dep);
+        for (const d of dependsOn.get(dep) || []) {
+          stack.push(d);
+        }
+      }
+    }
+    allDeps.set(eventId, trans);
+  }
+
+  // Generate alternative orderings that respect topological constraints
+  // Strategy: sort by duration (shortest first) while respecting dependencies
+  const byDuration = [...sorted].sort((a, b) => {
+    // If a depends on b, b must come first
+    if (allDeps.get(a)?.has(b)) return 1;
+    if (allDeps.get(b)?.has(a)) return -1;
+    return (eventMap.get(a)!.duration) - (eventMap.get(b)!.duration);
+  });
+
+  // Verify this is a valid topological order
+  const positioned = new Map<string, number>();
+  for (let i = 0; i < byDuration.length; i++) {
+    positioned.set(byDuration[i], i);
+  }
+  let valid = true;
+  for (const eventId of byDuration) {
+    for (const dep of dependsOn.get(eventId) || []) {
+      if (positioned.get(dep)! >= positioned.get(eventId)!) {
+        valid = false;
+        break;
+      }
+    }
+    if (!valid) break;
+  }
+
+  if (valid) {
+    const altResult = greedySchedule(byDuration, eventMap, rooms, options, gap);
+    if (altResult.assignments.length > bestResult.assignments.length) {
+      bestResult = altResult;
+    }
+  }
+
+  // Strategy: sort by number of dependents (most dependents first) - schedule critical path first
+  const dependentCount = new Map<string, number>();
+  for (const eventId of sorted) {
+    dependentCount.set(eventId, 0);
+  }
+  for (const eventId of sorted) {
+    for (const dep of allDeps.get(eventId) || []) {
+      dependentCount.set(dep, (dependentCount.get(dep) || 0) + 1);
+    }
+  }
+
+  const byDependents = [...sorted].sort((a, b) => {
+    if (allDeps.get(a)?.has(b)) return 1;
+    if (allDeps.get(b)?.has(a)) return -1;
+    return (dependentCount.get(b) || 0) - (dependentCount.get(a) || 0);
+  });
+
+  // Verify topological validity
+  const positioned2 = new Map<string, number>();
+  for (let i = 0; i < byDependents.length; i++) {
+    positioned2.set(byDependents[i], i);
+  }
+  let valid2 = true;
+  for (const eventId of byDependents) {
+    for (const dep of dependsOn.get(eventId) || []) {
+      if (positioned2.get(dep)! >= positioned2.get(eventId)!) {
+        valid2 = false;
+        break;
+      }
+    }
+    if (!valid2) break;
+  }
+
+  if (valid2) {
+    const altResult = greedySchedule(byDependents, eventMap, rooms, options, gap);
+    if (altResult.assignments.length > bestResult.assignments.length) {
+      bestResult = altResult;
+    }
+  }
+
+  return bestResult;
+}
