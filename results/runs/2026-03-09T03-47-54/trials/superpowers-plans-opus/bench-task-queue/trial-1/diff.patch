+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01SWgFwwjxhC8tWo6tNpiZMf","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0113YKd2VduCgNGcuGHL8aKw","name":"Write","input":{"file_path":"/workspace/tests/phase-06.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\ndescribe('Phase 06: Dead Letter Queue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  it('should move task to DLQ after retries exhausted', () => {\n    const task = queue.enqueue('data', { maxRetries: 1, backoffDelay: 0 });\n    const d1 = queue.dequeue()!;\n    queue.fail(d1.id, 'fatal error');\n\n    const dlq = queue.getDeadLetters();\n    expect(dlq).toHaveLength(1);\n    expect(dlq[0].id).toBe(task.id);\n  });\n\n  it('should view dead-lettered tasks for a queue', () => {\n    const task = queue.enqueue('data', { queue: 'emails', maxRetries: 1, backoffDelay: 0 });\n    const d1 = queue.dequeue('emails')!;\n    queue.fail(d1.id, 'err');\n\n    const dlq = queue.getDeadLetters('emails');\n    expect(dlq).toHaveLength(1);\n\n    const defaultDlq = queue.getDeadLetters();\n    expect(defaultDlq).toHaveLength(0);\n  });\n\n  it('should retain error info on dead-lettered tasks', () => {\n    const task = queue.enqueue('data', { maxRetries: 1, backoffDelay: 0 });\n    const d1 = queue.dequeue()!;\n    queue.fail(d1.id, 'specific error message');\n\n    const dlq = queue.getDeadLetters();\n    expect(dlq[0].error).toBe('specific error message');\n  });\n\n  it('should track failure count', () => {\n    const task = queue.enqueue('data', { maxRetries: 2, backoffDelay: 0 });\n\n    const d1 = queue.dequeue()!;\n    queue.fail(d1.id, 'err1');\n    const d2 = queue.dequeue()!;\n    queue.fail(d2.id, 'err2');\n\n    const dlq = queue.getDeadLetters();\n    expect(dlq[0].failCount).toBe(2);\n  });\n\n  it('should retry a dead-lettered task', () => {\n    const task = queue.enqueue('data', { maxRetries: 1, backoffDelay: 0 });\n    const d1 = queue.dequeue()!;\n    queue.fail(d1.id, 'err');\n\n    expect(queue.getDeadLetters()).toHaveLength(1);\n\n    const retried = queue.retryDeadLetter(task.id);\n    expect(retried.status).toBe('pending');\n    expect(retried.attempts).toBe(0);\n\n    expect(queue.getDeadLetters()).toHaveLength(0);\n\n    // Should be dequeued again\n    const dequeued = queue.dequeue();\n    expect(dequeued).not.toBeNull();\n    expect(dequeued!.id).toBe(task.id);\n  });\n\n  it('should clear all dead-lettered tasks for a queue', () => {\n    const t1 = queue.enqueue('d1', { maxRetries: 1, backoffDelay: 0 });\n    queue.fail(queue.dequeue()!.id, 'err');\n\n    const t2 = queue.enqueue('d2', { maxRetries: 1, backoffDelay: 0 });\n    queue.fail(queue.dequeue()!.id, 'err');\n\n    expect(queue.getDeadLetters()).toHaveLength(2);\n\n    queue.clearDeadLetters();\n    expect(queue.getDeadLetters()).toHaveLength(0);\n  });\n\n  it('should have independent DLQs per queue', () => {\n    const t1 = queue.enqueue('d1', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n    queue.fail(queue.dequeue('q1')!.id, 'err');\n\n    const t2 = queue.enqueue('d2', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n    queue.fail(queue.dequeue('q2')!.id, 'err');\n\n    expect(queue.getDeadLetters('q1')).toHaveLength(1);\n    expect(queue.getDeadLetters('q2')).toHaveLength(1);\n\n    queue.clearDeadLetters('q1');\n    expect(queue.getDeadLetters('q1')).toHaveLength(0);\n    expect(queue.getDeadLetters('q2')).toHaveLength(1);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":120,"cache_read_input_tokens":36434,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":120},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null