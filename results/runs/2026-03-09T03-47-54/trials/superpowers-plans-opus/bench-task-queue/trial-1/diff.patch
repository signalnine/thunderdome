diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..e45a13f
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,626 @@
+import { randomUUID } from 'node:crypto';
+
+// ─── Types ──────────────────────────────────────────────────────────────────
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task<T = unknown> {
+  id: string;
+  status: TaskStatus;
+  payload: T;
+  createdAt: Date;
+  queue: string;
+  priority: number;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  failCount: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+}
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  runAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  lastRun?: Date;
+}
+
+export type Middleware = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type Handler = (task: Task) => Promise<void>;
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  shutdownTime: number;
+}
+
+// ─── Internal State ─────────────────────────────────────────────────────────
+
+interface QueueState {
+  concurrencyLimit: number; // 0 = unlimited
+  middlewares: Middleware[];
+  handler: Handler | null;
+  deadLetters: string[];    // task IDs in DLQ
+}
+
+const DEFAULT_QUEUE = 'default';
+
+// ─── TaskQueue Class ────────────────────────────────────────────────────────
+
+export class TaskQueue {
+  private tasks: Map<string, Task> = new Map();
+  private queues: Map<string, QueueState> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private progressListeners: Map<string, Set<(progress: number, message?: string) => void>> = new Map();
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+  private isShuttingDown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private insertionOrder = 0;
+  private taskOrder: Map<string, number> = new Map();
+
+  // ─── Queue State Management ─────────────────────────────────────────────
+
+  private getOrCreateQueue(name: string): QueueState {
+    let q = this.queues.get(name);
+    if (!q) {
+      q = {
+        concurrencyLimit: 0,
+        middlewares: [],
+        handler: null,
+        deadLetters: [],
+      };
+      this.queues.set(name, q);
+    }
+    return q;
+  }
+
+  // ─── Phase 1: Basic FIFO Queue ─────────────────────────────────────────
+
+  enqueue<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {
+    if (this.isShuttingDown) {
+      throw new Error('Queue is shutting down, cannot accept new tasks');
+    }
+
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+
+    // Phase 3: Validate priority
+    const priority = options.priority ?? 5;
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Phase 4: Calculate availableAt
+    let availableAt = new Date();
+    if (options.runAt) {
+      availableAt = options.runAt;
+    } else if (options.delay && options.delay > 0) {
+      availableAt = new Date(Date.now() + options.delay);
+    }
+
+    // Phase 7: Validate dependencies
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      const depTask = this.tasks.get(depId);
+      if (!depTask) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+    // Circular dependency detection is checked after task creation would form cycles
+    // But since this is a new task, it can't form a cycle unless deps point back to it (impossible for new task)
+    // We still validate no indirect cycles if somehow re-adding
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      status: 'pending',
+      payload,
+      createdAt: new Date(),
+      queue: queueName,
+      priority,
+      availableAt,
+      attempts: 0,
+      maxRetries: options.maxRetries ?? 3,
+      backoffDelay: options.backoffDelay ?? 1000,
+      failCount: 0,
+      dependencies,
+      progress: 0,
+    };
+
+    this.tasks.set(task.id, task as Task);
+    this.taskOrder.set(task.id, this.insertionOrder++);
+    this.getOrCreateQueue(queueName);
+
+    return task;
+  }
+
+  dequeue(queueName?: string): Task | null {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const queueState = this.queues.get(name);
+    if (!queueState) return null;
+
+    // Phase 8: Check concurrency limit
+    if (queueState.concurrencyLimit > 0) {
+      const activeCount = this.getActiveCount(name);
+      if (activeCount >= queueState.concurrencyLimit) {
+        return null;
+      }
+    }
+
+    // Get all pending tasks for this queue
+    const pending: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.queue === name && task.status === 'pending') {
+        // Phase 4: Filter by availability
+        if (task.availableAt > new Date()) continue;
+
+        // Phase 7: Filter by dependencies
+        if (!this.areDependenciesMet(task)) continue;
+
+        pending.push(task);
+      }
+    }
+
+    if (pending.length === 0) return null;
+
+    // Sort: priority ascending, then availableAt ascending, then insertion order ascending
+    pending.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      const aTime = a.availableAt.getTime();
+      const bTime = b.availableAt.getTime();
+      if (aTime !== bTime) return aTime - bTime;
+      return (this.taskOrder.get(a.id) ?? 0) - (this.taskOrder.get(b.id) ?? 0);
+    });
+
+    const task = pending[0];
+    task.status = 'processing';
+    task.attempts += 1;
+
+    return task;
+  }
+
+  size(queueName?: string): number {
+    const name = queueName ?? DEFAULT_QUEUE;
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.queue === name && task.status === 'pending') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  getTask(id: string): Task | null {
+    return this.tasks.get(id) ?? null;
+  }
+
+  // ─── Phase 2: Named Queues ─────────────────────────────────────────────
+
+  getQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // ─── Phase 5: Complete / Fail ──────────────────────────────────────────
+
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot complete task with status: ${task.status}`);
+    }
+    task.status = 'completed';
+
+    // Phase 7: Check if any blocked tasks are now unblocked (handled in dequeue filtering)
+    // No explicit action needed since dequeue dynamically checks dependencies
+  }
+
+  fail(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot fail task with status: ${task.status}`);
+    }
+
+    task.error = error;
+    task.failCount += 1;
+
+    if (task.attempts < task.maxRetries) {
+      // Re-queue with backoff delay
+      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.progress = 0;
+      task.progressMessage = undefined;
+    } else {
+      // Exhausted retries
+      task.status = 'failed';
+
+      // Phase 6: Move to DLQ
+      const queueState = this.getOrCreateQueue(task.queue);
+      queueState.deadLetters.push(task.id);
+    }
+  }
+
+  // ─── Phase 6: Dead Letter Queue ────────────────────────────────────────
+
+  getDeadLetters(queueName?: string): Task[] {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const queueState = this.queues.get(name);
+    if (!queueState) return [];
+    return queueState.deadLetters
+      .map(id => this.tasks.get(id))
+      .filter((t): t is Task => t !== undefined);
+  }
+
+  retryDeadLetter(taskId: string): Task {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    const queueState = this.queues.get(task.queue);
+    if (!queueState) throw new Error(`Queue not found: ${task.queue}`);
+
+    const dlqIndex = queueState.deadLetters.indexOf(taskId);
+    if (dlqIndex === -1) {
+      throw new Error(`Task is not in dead letter queue: ${taskId}`);
+    }
+
+    // Remove from DLQ
+    queueState.deadLetters.splice(dlqIndex, 1);
+
+    // Reset task for fresh retries
+    task.status = 'pending';
+    task.attempts = 0;
+    task.error = undefined;
+    task.availableAt = new Date();
+    task.progress = 0;
+    task.progressMessage = undefined;
+
+    return task;
+  }
+
+  clearDeadLetters(queueName?: string): void {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const queueState = this.queues.get(name);
+    if (!queueState) return;
+
+    // Remove tasks from the tasks map too
+    for (const id of queueState.deadLetters) {
+      this.tasks.delete(id);
+    }
+    queueState.deadLetters = [];
+  }
+
+  // ─── Phase 7: Task Dependencies ────────────────────────────────────────
+
+  private areDependenciesMet(task: Task): boolean {
+    for (const depId of task.dependencies) {
+      const dep = this.tasks.get(depId);
+      if (!dep || dep.status !== 'completed') {
+        return false;
+      }
+    }
+    return true;
+  }
+
+  getDependencyStatus(taskId: string): { resolved: string[]; unresolved: string[] } {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    const resolved: string[] = [];
+    const unresolved: string[] = [];
+
+    for (const depId of task.dependencies) {
+      const dep = this.tasks.get(depId);
+      if (dep && dep.status === 'completed') {
+        resolved.push(depId);
+      } else {
+        unresolved.push(depId);
+      }
+    }
+
+    return { resolved, unresolved };
+  }
+
+  // ─── Phase 8: Concurrency Control ──────────────────────────────────────
+
+  setConcurrency(queueName: string, limit: number): void {
+    const queueState = this.getOrCreateQueue(queueName);
+    queueState.concurrencyLimit = limit;
+  }
+
+  getConcurrency(queueName: string): { limit: number; active: number } {
+    const queueState = this.queues.get(queueName);
+    const limit = queueState?.concurrencyLimit ?? 0;
+    return { limit, active: this.getActiveCount(queueName) };
+  }
+
+  private getActiveCount(queueName: string): number {
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.queue === queueName && task.status === 'processing') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  // ─── Phase 9: Progress and Cancellation ─────────────────────────────────
+
+  updateProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot update progress for task with status: ${task.status}`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+
+    // Notify listeners
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(progress, message);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, callback: (progress: number, message?: string) => void): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    const listeners = this.progressListeners.get(taskId)!;
+    listeners.add(callback);
+
+    // Return unsubscribe function
+    return () => {
+      listeners.delete(callback);
+      if (listeners.size === 0) {
+        this.progressListeners.delete(taskId);
+      }
+    };
+  }
+
+  cancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Cannot cancel task with status: ${task.status}`);
+    }
+
+    task.status = 'cancelled';
+  }
+
+  // ─── Phase 10: Recurring Tasks (Cron) ──────────────────────────────────
+
+  addSchedule(id: string, options: { cron: string; queue?: string; payload: unknown }): Schedule {
+    if (this.isShuttingDown) {
+      throw new Error('Queue is shutting down, cannot add schedules');
+    }
+
+    // Validate cron expression
+    this.parseCron(options.cron);
+
+    const schedule: Schedule = {
+      id,
+      cron: options.cron,
+      queue: options.queue ?? DEFAULT_QUEUE,
+      payload: options.payload,
+    };
+
+    this.schedules.set(id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(id: string): void {
+    this.schedules.delete(id);
+  }
+
+  getSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const enqueued: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (this.shouldRun(schedule, currentTime)) {
+        const task = this.enqueue(schedule.payload, { queue: schedule.queue });
+        enqueued.push(task);
+        schedule.lastRun = currentTime;
+      }
+    }
+
+    return enqueued;
+  }
+
+  private parseCron(expr: string): { minute: string; hour: string } {
+    const parts = expr.split(/\s+/);
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${expr}`);
+    }
+    return { minute: parts[0], hour: parts[1] };
+  }
+
+  private shouldRun(schedule: Schedule, now: Date): boolean {
+    const { minute, hour } = this.parseCron(schedule.cron);
+
+    const currentMinute = now.getMinutes();
+    const currentHour = now.getHours();
+
+    // Check minute field
+    if (!this.matchesCronField(minute, currentMinute)) return false;
+    // Check hour field
+    if (!this.matchesCronField(hour, currentHour)) return false;
+
+    // Prevent running more than once per matching time
+    if (schedule.lastRun) {
+      const lastMinute = schedule.lastRun.getMinutes();
+      const lastHour = schedule.lastRun.getHours();
+      const lastDate = schedule.lastRun.toDateString();
+      const nowDate = now.toDateString();
+
+      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {
+        return false;
+      }
+    }
+
+    return true;
+  }
+
+  private matchesCronField(field: string, value: number): boolean {
+    if (field === '*') return true;
+
+    // */N pattern
+    const stepMatch = field.match(/^\*\/(\d+)$/);
+    if (stepMatch) {
+      const step = parseInt(stepMatch[1], 10);
+      return value % step === 0;
+    }
+
+    // Exact number
+    const num = parseInt(field, 10);
+    if (!isNaN(num)) {
+      return value === num;
+    }
+
+    return false;
+  }
+
+  // ─── Phase 11: Middleware Pipeline ──────────────────────────────────────
+
+  use(queueName: string, middleware: Middleware): void {
+    const queueState = this.getOrCreateQueue(queueName);
+    queueState.middlewares.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: Handler): void {
+    const queueState = this.getOrCreateQueue(queueName);
+    queueState.handler = handler;
+  }
+
+  async process(taskId: string): Promise<void> {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot process task with status: ${task.status}`);
+    }
+
+    const queueState = this.queues.get(task.queue);
+    if (!queueState) throw new Error(`Queue not found: ${task.queue}`);
+
+    const middlewares = [...queueState.middlewares];
+    const handler = queueState.handler;
+
+    let index = 0;
+    const executeNext = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const mw = middlewares[index++];
+        await mw(task, executeNext);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await executeNext();
+    } catch (err) {
+      const errorMessage = err instanceof Error ? err.message : String(err);
+      this.fail(taskId, errorMessage);
+    }
+  }
+
+  // ─── Phase 12: Graceful Shutdown ────────────────────────────────────────
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(options: { timeout?: number } = {}): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShuttingDown = true;
+    this.shutdownPromise = this.performShutdown(options);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(options: { timeout?: number }): Promise<ShutdownResult> {
+    const startTime = Date.now();
+    const timeout = options.timeout ?? 30000;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Get all currently processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    let completed = 0;
+    let forceCancelled = 0;
+
+    if (processingTasks.length > 0) {
+      // Wait for processing tasks up to timeout
+      const waitStart = Date.now();
+
+      await new Promise<void>((resolve) => {
+        const checkInterval = setInterval(() => {
+          const allDone = processingTasks.every(t => t.status !== 'processing');
+          const elapsed = Date.now() - waitStart;
+
+          if (allDone || elapsed >= timeout) {
+            clearInterval(checkInterval);
+            resolve();
+          }
+        }, 10);
+      });
+
+      // Count results
+      for (const task of processingTasks) {
+        if (task.status === 'processing') {
+          // Force cancel
+          task.status = 'cancelled';
+          forceCancelled++;
+        } else {
+          completed++;
+        }
+      }
+    }
+
+    const shutdownTime = Date.now() - startTime;
+
+    return {
+      completed,
+      forceCancelled,
+      shutdownTime,
+    };
+  }
+}
