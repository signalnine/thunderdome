pendencies: ['fake-id'] })).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":120,"cache_read_input_tokens":36434,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":120},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8e9b18e3-d417-40dd-a916-cccdbff74ed8","uuid":"f7f75674-c324-4cf7-9110-c7e65ce609e6"}
