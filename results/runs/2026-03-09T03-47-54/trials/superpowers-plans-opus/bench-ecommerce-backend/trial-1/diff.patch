{ productId: id, name, price, category } satisfies ProductCreatedEvent);\n      return id;\n    },\n    getProduct(productId) {\n      return products.get(productId) ?? null;\n    },\n    listProducts(category?) {\n      const all = [...products.values()];\n      return category ? all.filter(p => p.category === category) : all;\n    },\n    searchProducts(query) {\n      const q = query.toLowerCase();\n      return [...products.values()].filter(p => p.name.toLowerCase().includes(q));\n    },\n    updateProduct(productId, updates) {\n      const product = products.get(productId);\n      if (!product) return;\n      if (updates.name !== undefined) product.name = updates.name;\n      if (updates.price !== undefined) product.price = updates.price;\n      if (updates.category !== undefined) product.category = updates.category;\n    },\n    removeProduct(productId) {\n      return products.delete(productId);\n    },\n  };\n}\n```\n\n---\n\n### Task 3: Implement Inventory Service\n\n**Files:**\n- Create: `src/inventory/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { EventBus } from '../bus.js';\nimport { InventoryService, Events, InventoryUpdatedEvent, LowStockAlertEvent } from '../types.js';\n\nexport function createInventoryService(bus: EventBus): InventoryService {\n  const stock = new Map<string, number>();\n  const reserved = new Map<string, number>();\n  const thresholds = new Map<string, number>();\n\n  function checkLowStock(productId: string): void {\n    const threshold = thresholds.get(productId);\n    if (threshold === undefined) return;\n    const current = (stock.get(productId) ?? 0) - (reserved.get(productId) ?? 0);\n    if (current < threshold) {\n      bus.emit(Events.LOW_STOCK_ALERT, { productId, currentQuantity: current, threshold } satisfies LowStockAlertEvent);\n    }\n  }\n\n  return {\n    setStock(productId, quantity) {\n      stock.set(productId, quantity);\n      bus.emit(Events.INVENTORY_UPDATED, { productId, quantity } satisfies InventoryUpdatedEvent);\n      checkLowStock(productId);\n    },\n    getStock(productId) {\n      return (stock.get(productId) ?? 0) - (reserved.get(productId) ?? 0);\n    },\n    reserve(productId, quantity) {\n      const available = (stock.get(productId) ?? 0) - (reserved.get(productId) ?? 0);\n      if (available < quantity) return false;\n      reserved.set(productId, (reserved.get(productId) ?? 0) + quantity);\n      checkLowStock(productId);\n      return true;\n    },\n    release(productId, quantity) {\n      const current = reserved.get(productId) ?? 0;\n      reserved.set(productId, Math.max(0, current - quantity));\n    },\n    setLowStockThreshold(productId, threshold) {\n      thresholds.set(productId, threshold);\n      checkLowStock(productId);\n    },\n  };\n}\n```\n\n---\n\n### Task 4: Implement Cart Service\n\n**Files:**\n- Create: `src/cart/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { v4 as uuidv4 } from 'uuid';\nimport { EventBus } from '../bus.js';\nimport { CartService, Events, CartUpdatedEvent } from '../types.js';\n\nexport function createCartService(bus: EventBus): CartService {\n  const carts = new Map<string, { id: string; userId: string; items: Array<{ productId: string; quantity: number }> }>();\n\n  function emitUpdate(cart: { id: string; userId: string; items: Array<{ productId: string; quantity: number }> }): void {\n    bus.emit(Events.CART_UPDATED, { cartId: cart.id, userId: cart.userId, items: [...cart.items] } satisfies CartUpdatedEvent);\n  }\n\n  return {\n    createCart(userId) {\n      const id = uuidv4();\n      carts.set(id, { id, userId, items: [] });\n      return id;\n    },\n    addItem(cartId, productId, quantity) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      const existing = cart.items.find(i => i.productId === productId);\n      if (existing) {\n        existing.quantity += quantity;\n      } else {\n        cart.items.push({ productId, quantity });\n      }\n      emitUpdate(cart);\n    },\n    removeItem(cartId, productId) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      cart.items = cart.items.filter(i => i.productId !== productId);\n      emitUpdate(cart);\n    },\n    getCart(cartId) {\n      const cart = carts.get(cartId);\n      if (!cart) return null;\n      return { id: cart.id, userId: cart.userId, items: [...cart.items] };\n    },\n    clearCart(cartId) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      cart.items = [];\n      emitUpdate(cart);\n    },\n    updateQuantity(cartId, productId, quantity) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      const existing = cart.items.find(i => i.productId === productId);\n      if (existing) {\n        existing.quantity = quantity;\n        emitUpdate(cart);\n      }\n    },\n  };\n}\n```\n\n---\n\n### Task 5: Implement Pricing Service\n\n**Files:**\n- Create: `src/pricing/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { EventBus } from '../bus.js';\nimport { PricingService, Events, ProductCreatedEvent } from '../types.js';\n\nexport function createPricingService(bus: EventBus): PricingService {\n  const prices = new Map<string, number>();\n  const discountCodes = new Map<string, number>();\n\n  bus.on(Events.PRODUCT_CREATED, (payload: unknown) => {\n    const event = payload as ProductCreatedEvent;\n    prices.set(event.productId, event.price);\n  });\n\n  return {\n    calculateTotal(items, discountCode?) {\n      let subtotal = 0;\n      for (const item of items) {\n        subtotal += item.price * item.quantity;\n      }\n      let discount = 0;\n      if (discountCode) {\n        const pct = discountCodes.get(discountCode);\n        if (pct !== undefined) {\n          discount = subtotal * (pct / 100);\n        }\n      }\n      const afterDiscount = subtotal - discount;\n      const tax = afterDiscount * 0.1;\n      const total = afterDiscount + tax;\n      return {\n        subtotal: Math.round(subtotal * 100) / 100,\n        discount: Math.round(discount * 100) / 100,\n        tax: Math.round(tax * 100) / 100,\n        total: Math.round(total * 100) / 100,\n      };\n    },\n    addDiscountCode(code, percentage) {\n      discountCodes.set(code, percentage);\n    },\n    getPrice(productId) {\n      return prices.get(productId) ?? 0;\n    },\n  };\n}\n```\n\n---\n\n### Task 6: Implement Orders Service\n\n**Files:**\n- Create: `src/orders/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { v4 as uuidv4 } from 'uuid';\nimport { EventBus } from '../bus.js';\nimport { OrderService, OrderStatus, Events, OrderCreatedEvent, OrderStatusChangedEvent } from '../types.js';\n\nexport function createOrderService(bus: EventBus): OrderService {\n  const orders = new Map<string, { id: string; userId: string; cartId: string; status: OrderStatus; total: number }>();\n\n  return {\n    createOrder(userId, cartId, total) {\n      const id = uuidv4();\n      orders.set(id, { id, userId, cartId, status: OrderStatus.PENDING, total });\n      bus.emit(Events.ORDER_CREATED, { orderId: id, userId, cartId, total } satisfies OrderCreatedEvent);\n      return id;\n    },\n    getOrder(orderId) {\n      const order = orders.get(orderId);\n      if (!order) return null;\n      return { id: order.id, userId: order.userId, status: order.status, total: order.total };\n    },\n    updateStatus(orderId, status) {\n      const order = orders.get(orderId);\n      if (!order) return;\n      const previousStatus = order.status;\n      order.status = status;\n      bus.emit(Events.ORDER_STATUS_CHANGED, { orderId, status, previousStatus } satisfies OrderStatusChangedEvent);\n    },\n    listOrders(userId) {\n      return [...orders.values()]\n        .filter(o => o.userId === userId)\n        .map(o => ({ id: o.id, status: o.status, total: o.total }));\n    },\n  };\n}\n```\n\n---\n\n### Task 7: Implement Payment Service\n\n**Files:**\n- Create: `src/payment/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { v4 as uuidv4 } from 'uuid';\nimport { EventBus } from '../bus.js';\nimport { PaymentService, PaymentStatus, Events, PaymentProcessedEvent } from '../types.js';\n\ninterface PaymentOptions {\n  simulateFailure?: boolean;\n  simulateTimeout?: boolean;\n}\n\nexport function createPaymentService(bus: EventBus, options: PaymentOptions = {}): PaymentService {\n  const transactions = new Map<string, { orderId: string; amount: number; status: PaymentStatus }>();\n\n  return {\n    async processPayment(orderId, amount) {\n      let status: PaymentStatus;\n      let transactionId: string | undefined;\n      let error: string | undefined;\n\n      if (options.simulateTimeout) {\n        status = PaymentStatus.TIMEOUT;\n        error = 'Payment timed out';\n      } else if (options.simulateFailure) {\n        status = PaymentStatus.FAILED;\n        error = 'Payment failed';\n      } else {\n        status = PaymentStatus.SUCCESS;\n        transactionId = uuidv4();\n        transactions.set(transactionId, { orderId, amount, status });\n      }\n\n      const event: PaymentProcessedEvent = { orderId, status, transactionId, error };\n      await bus.emit(Events.PAYMENT_PROCESSED, event);\n\n      return { status, transactionId, error };\n    },\n    async refund(transactionId) {\n      const tx = transactions.get(transactionId);\n      if (!tx) return false;\n      tx.status = PaymentStatus.FAILED;\n      transactions.delete(transactionId);\n      return true;\n    },\n  };\n}\n```\n\n---\n\n### Task 8: Implement Notifications Service\n\n**Files:**\n- Create: `src/notifications/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { EventBus } from '../bus.js';\nimport { NotificationService, Events, OrderStatusChangedEvent, PaymentProcessedEvent, OrderCreatedEvent } from '../types.js';\n\nexport function createNotificationService(bus: EventBus): NotificationService {\n  const subscribers = new Set<string>();\n  const notifications = new Map<string, Array<{ type: string; message: string; timestamp: number }>>();\n  const orderUserMap = new Map<string, string>();\n\n  function addNotification(userId: string, type: string, message: string): void {\n    if (!subscribers.has(userId)) return;\n    if (!notifications.has(userId)) notifications.set(userId, []);\n    notifications.get(userId)!.push({ type, message, timestamp: Date.now() });\n    bus.emit(Events.NOTIFICATION_SENT, { userId, type, message });\n  }\n\n  bus.on(Events.ORDER_CREATED, (payload: unknown) => {\n    const event = payload as OrderCreatedEvent;\n    orderUserMap.set(event.orderId, event.userId);\n  });\n\n  bus.on(Events.ORDER_STATUS_CHANGED, (payload: unknown) => {\n    const event = payload as OrderStatusChangedEvent;\n    const userId = orderUserMap.get(event.orderId);\n    if (userId) {\n      addNotification(userId, 'order_status', `Order ${event.orderId} status changed from ${event.previousStatus} to ${event.status}`);\n    }\n  });\n\n  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {\n    const event = payload as PaymentProcessedEvent;\n    const userId = orderUserMap.get(event.orderId);\n    if (userId) {\n      addNotification(userId, 'payment', `Payment for order ${event.orderId}: ${event.status}`);\n    }\n  });\n\n  return {\n    subscribe(userId) {\n      subscribers.add(userId);\n    },\n    getNotifications(userId) {\n      return notifications.get(userId) ?? [];\n    },\n  };\n}\n```\n\n---\n\n### Task 9: Implement Analytics Service\n\n**Files:**\n- Create: `src/analytics/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { EventBus } from '../bus.js';\nimport { AnalyticsService, Events, OrderCreatedEvent, PaymentProcessedEvent, PaymentStatus } from '../types.js';\n\nexport function createAnalyticsService(bus: EventBus): AnalyticsService {\n  const eventCounts = new Map<string, number>();\n  let revenue = 0;\n  const uniqueCarts = new Set<string>();\n  let orderCount = 0;\n  const productCounts = new Map<string, number>();\n\n  // Track all events\n  const allEvents = Object.values(Events);\n  for (const eventName of allEvents) {\n    bus.on(eventName, (_payload: unknown) => {\n      eventCounts.set(eventName, (eventCounts.get(eventName) ?? 0) + 1);\n    });\n  }\n\n  bus.on(Events.CART_UPDATED, (payload: unknown) => {\n    const event = payload as { cartId: string };\n    uniqueCarts.add(event.cartId);\n  });\n\n  bus.on(Events.ORDER_CREATED, (payload: unknown) => {\n    const event = payload as OrderCreatedEvent;\n    orderCount++;\n    uniqueCarts.add(event.cartId);\n  });\n\n  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {\n    const event = payload as PaymentProcessedEvent & { amount?: number };\n    if (event.status === PaymentStatus.SUCCESS) {\n      // We need the amount from somewhere - listen to orders\n    }\n  });\n\n  // Track revenue from successful payments - need order totals\n  const orderTotals = new Map<string, number>();\n\n  bus.on(Events.ORDER_CREATED, (payload: unknown) => {\n    const event = payload as OrderCreatedEvent;\n    orderTotals.set(event.orderId, event.total);\n  });\n\n  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {\n    const event = payload as PaymentProcessedEvent;\n    if (event.status === PaymentStatus.SUCCESS) {\n      const total = orderTotals.get(event.orderId) ?? 0;\n      revenue += total;\n    }\n  });\n\n  // Track product quantities from orders - need cart data\n  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();\n\n  bus.on(Events.CART_UPDATED, (payload: unknown) => {\n    const event = payload as { cartId: string; items: Array<{ productId: string; quantity: number }> };\n    cartItems.set(event.cartId, event.items);\n  });\n\n  bus.on(Events.ORDER_CREATED, (payload: unknown) => {\n    const event = payload as OrderCreatedEvent;\n    const items = cartItems.get(event.cartId) ?? [];\n    for (const item of items) {\n      productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);\n    }\n  });\n\n  return {\n    getEventCount(eventType) {\n      return eventCounts.get(eventType) ?? 0;\n    },\n    getRevenue() {\n      return revenue;\n    },\n    getConversionRate() {\n      if (uniqueCarts.size === 0) return 0;\n      return orderCount / uniqueCarts.size;\n    },\n    getTopProducts(limit) {\n      return [...productCounts.entries()]\n        .map(([productId, count]) => ({ productId, count }))\n        .sort((a, b) => b.count - a.count)\n        .slice(0, limit);\n    },\n  };\n}\n```\n\n---\n\n### Task 10: Create src/index.ts barrel export\n\n**Files:**\n- Create: `src/index.ts`\n\n**Implementation:**\n\n```typescript\nexport { createCatalogService } from './catalog/index.js';\nexport { createInventoryService } from './inventory/index.js';\nexport { createCartService } from './cart/index.js';\nexport { createPricingService } from './pricing/index.js';\nexport { createOrderService } from './orders/index.js';\nexport { createPaymentService } from './payment/index.js';\nexport { createNotificationService } from './notifications/index.js';\nexport { createAnalyticsService } from './analytics/index.js';\n```\n\n---\n\n### Task 11: Build and lint\n\n**Step 1:** Run `npm run build`\n**Step 2:** Run `npm run lint`\n**Step 3:** Fix any errors.\n\n---\n\n### Task 12: Write comprehensive tests\n\n**Files:**\n- Create: `tests/services.test.ts`\n\nWrite tests covering:\n- Catalog CRUD operations and search\n- Inventory stock management, reservation, and low-stock alerts\n- Cart item consolidation and operations\n- Pricing calculation with discounts and tax\n- Order lifecycle and status changes\n- Payment success/failure/timeout scenarios and refunds\n- Notification delivery for order and payment events\n- Analytics event counting, revenue, conversion rate, top products\n- End-to-end integration flow across all services\n\n---\n\n### Task 13: Run tests and fix any issues\n\nRun: `npm run test`\nFix any failures.\n","structuredPatch":[],"originalFile":null}}
