alog = createCatalogService(bus);\n  });\n\n  it('should create a product and return an id', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(id).toBeTruthy();\n  });\n\n  it('should retrieve a product by id', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    const product = catalog.getProduct(id);\n    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n\n  it('should return null for unknown product', () => {\n    expect(catalog.getProduct('nonexistent')).toBeNull();\n  });\n\n  it('should list all products', () => {\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    expect(catalog.listProducts()).toHaveLength(2);\n  });\n\n  it('should list products filtered by category', () => {\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n    const results = catalog.listProducts('cat1');\n    expect(results).toHaveLength(2);\n    expect(results.every(p => p.category === 'cat1')).toBe(true);\n  });\n\n  it('should search products by name', () => {\n    catalog.createProduct('Blue Widget', 1, 'gadgets');\n    catalog.createProduct('Red Widget', 2, 'gadgets');\n    catalog.createProduct('Green Gizmo', 3, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(2);\n  });\n\n  it('should update a product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { name: 'Super Widget', price: 19.99 });\n    const product = catalog.getProduct(id);\n    expect(product!.name).toBe('Super Widget');\n    expect(product!.price).toBe(19.99);\n    expect(product!.category).toBe('gadgets');\n  });\n\n  it('should remove a product', () => {\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct(id)).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PRODUCT_CREATED)).toBe(true);\n    const event = log.find(e => e.event === Events.PRODUCT_CREATED);\n    expect((event!.payload as { name: string }).name).toBe('Widget');\n  });\n});\n\ndescribe('Inventory Service', () => {\n  let bus: EventBus;\n  let inventory: ReturnType<typeof createInventoryService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    inventory = createInventoryService(bus);\n  });\n\n  it('should set and get stock', () => {\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product', () => {\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock successfully', () => {\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve when insufficient stock', () => {\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(3);\n  });\n\n  it('should release reserved stock', () => {\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit inventory:updated event on setStock', () => {\n    inventory.setStock('p1', 50);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.INVENTORY_UPDATED)).toBe(true);\n  });\n\n  it('should emit low stock alert when threshold is breached', () => {\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.reserve('p1', 7);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.LOW_STOCK_ALERT)).toBe(true);\n  });\n\n  it('should not emit low stock alert when above threshold', () => {\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.reserve('p1', 2);\n    const log = bus.getLog();\n    const alerts = log.filter(e => e.event === Events.LOW_STOCK_ALERT);\n    expect(alerts).toHaveLength(0);\n  });\n});\n\ndescribe('Cart Service', () => {\n  let bus: EventBus;\n  let cart: ReturnType<typeof createCartService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    cart = createCartService(bus);\n  });\n\n  it('should create a cart', () => {\n    const id = cart.createCart('user1');\n    expect(id).toBeTruthy();\n  });\n\n  it('should add items to a cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('should consolidate items for same product', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].quantity).toBe(5);\n  });\n\n  it('should remove items from a cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].productId).toBe('p2');\n  });\n\n  it('should clear a cart', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    const c = cart.getCart(id);\n    expect(c!.items).toHaveLength(0);\n  });\n\n  it('should update item quantity', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    const c = cart.getCart(id);\n    expect(c!.items[0].quantity).toBe(10);\n  });\n\n  it('should return null for unknown cart', () => {\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n\n  it('should emit cart:updated events', () => {\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.CART_UPDATED)).toBe(true);\n  });\n});\n\ndescribe('Pricing Service', () => {\n  let bus: EventBus;\n  let pricing: ReturnType<typeof createPricingService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    pricing = createPricingService(bus);\n  });\n\n  it('should calculate total with tax', () => {\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code', () => {\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9);\n    expect(result.total).toBe(99);\n  });\n\n  it('should ignore unknown discount codes', () => {\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n\n  it('should track prices from product:created events', async () => {\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 25, category: 'gadgets' });\n    expect(pricing.getPrice('p1')).toBe(25);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('Orders Service', () => {\n  let bus: EventBus;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    orders = createOrderService(bus);\n  });\n\n  it('should create an order in pending status', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    const order = orders.getOrder(id);\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(100);\n  });\n\n  it('should update order status', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should emit order:created event', () => {\n    orders.createOrder('user1', 'cart1', 100);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.ORDER_CREATED)).toBe(true);\n  });\n\n  it('should emit order:status_changed event with previous status', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    const log = bus.getLog();\n    const event = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(event).toBeTruthy();\n    const payload = event!.payload as { orderId: string; status: string; previousStatus: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n    expect(payload.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should cancel an order', () => {\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('should list orders by user', () => {\n    orders.createOrder('user1', 'cart1', 50);\n    orders.createOrder('user1', 'cart2', 75);\n    orders.createOrder('user2', 'cart3', 100);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for unknown order', () => {\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n});\n\ndescribe('Payment Service', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeTruthy();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should fail to refund unknown transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('Notifications Service', () => {\n  let bus: EventBus;\n  let notifications: ReturnType<typeof createNotificationService>;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    notifications = createNotificationService(bus);\n    orders = createOrderService(bus);\n  });\n\n  it('should deliver notifications to subscribed users on order status change', () => {\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n    expect(notifs.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should deliver notifications on payment events', async () => {\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    const payment = createPaymentService(bus);\n    await payment.processPayment(orderId, 100);\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('should not notify unsubscribed users', () => {\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n\n  it('should return empty array for user with no notifications', () => {\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n});\n\ndescribe('Analytics Service', () => {\n  let bus: EventBus;\n  let analytics: ReturnType<typeof createAnalyticsService>;\n  let catalog: ReturnType<typeof createCatalogService>;\n  let cartService: ReturnType<typeof createCartService>;\n  let orders: ReturnType<typeof createOrderService>;\n\n  beforeEach(() => {\n    bus = new EventBus();\n    analytics = createAnalyticsService(bus);\n    catalog = createCatalogService(bus);\n    cartService = createCartService(bus);\n    orders = createOrderService(bus);\n  });\n\n  it('should count events by type', () => {\n    catalog.createProduct('A', 10, 'cat1');\n    catalog.createProduct('B', 20, 'cat1');\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    const payment = createPaymentService(bus);\n    await payment.processPayment(orderId, 100);\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not track revenue from failed payments', async () => {\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    await payment.processPayment(orderId, 100);\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', () => {\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, 'p1', 1);\n    orders.createOrder('user1', cartId, 50);\n    // 1 order / 1 unique cart = 1.0\n    expect(analytics.getConversionRate()).toBe(1);\n  });\n\n  it('should return 0 conversion rate when no carts', () => {\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should rank top products by order quantity', () => {\n    const p1 = catalog.createProduct('A', 10, 'cat1');\n    const p2 = catalog.createProduct('B', 20, 'cat1');\n\n    const cartId1 = cartService.createCart('user1');\n    cartService.addItem(cartId1, p1, 5);\n    cartService.addItem(cartId1, p2, 2);\n    orders.createOrder('user1', cartId1, 90);\n\n    const cartId2 = cartService.createCart('user2');\n    cartService.addItem(cartId2, p2, 10);\n    orders.createOrder('user2', cartId2, 200);\n\n    const top = analytics.getTopProducts(2);\n    expect(top[0].productId).toBe(p2);\n    expect(top[0].count).toBe(12);\n    expect(top[1].productId).toBe(p1);\n    expect(top[1].count).toBe(5);\n  });\n});\n\ndescribe('Integration: End-to-end flow', () => {\n  it('should complete a full purchase flow', async () => {\n    const bus = new EventBus();\n\n    // Initialize all services\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orderService = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 49, 'electronics');\n\n    // Set inventory\n    inventory.setStock(p1, 10);\n    inventory.setStock(p2, 50);\n\n    // Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, p1, 1);\n    cartService.addItem(cartId, p2, 2);\n\n    // Calculate price\n    const cartData = cartService.getCart(cartId)!;\n    const items = cartData.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const totals = pricing.calculateTotal(items);\n    expect(totals.subtotal).toBe(1097);\n    expect(totals.tax).toBeCloseTo(109.7);\n    expect(totals.total).toBeCloseTo(1206.7);\n\n    // Reserve inventory\n    for (const item of cartData.items) {\n      expect(inventory.reserve(item.productId, item.quantity)).toBe(true);\n    }\n\n    // Create order\n    const orderId = orderService.createOrder('user1', cartId, totals.total);\n    const order = orderService.getOrder(orderId)!;\n    expect(order.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, totals.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orderService.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orderService.updateStatus(orderId, OrderStatus.SHIPPED);\n    orderService.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    expect(orderService.getOrder(orderId)!.status).toBe(OrderStatus.DELIVERED);\n\n    // Check notifications were delivered\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n    expect(notifs.some(n => n.type === 'order_status')).toBe(true);\n\n    // Check analytics\n    expect(analytics.getRevenue()).toBeCloseTo(1206.7);\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n\n    const topProducts = analytics.getTopProducts(2);\n    expect(topProducts).toHaveLength(2);\n\n    // Check inventory was properly reduced\n    expect(inventory.getStock(p1)).toBe(9);\n    expect(inventory.getStock(p2)).toBe(48);\n  });\n});\n","structuredPatch":[{"oldStart":444,"oldLines":10,"newStart":444,"newLines":12,"lines":["     expect(analytics.getRevenue()).toBe(0);","   });"," ","-  it('should calculate conversion rate', () => {","+  it('should calculate conversion rate', async () => {","     const cartId = cartService.createCart('user1');","     cartService.addItem(cartId, 'p1', 1);","     orders.createOrder('user1', cartId, 50);","+    // Allow async event handlers to complete","+    await new Promise(r => setTimeout(r, 0));","     // 1 order / 1 unique cart = 1.0","     expect(analytics.getConversionRate()).toBe(1);","   });"]}],"userModified":false,"replaceAll":false}}
