+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UoK6FyPCah15uNamjRfnCr","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { createRssFeedPlugin } from '../../src/plugins/rss-feed.js';\n     3→import { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n     4→\n     5→const testConfig: SiteConfig = {\n     6→  title: 'Test Site',\n     7→  baseUrl: 'https://example.com',\n     8→  outputDir: './dist',\n     9→  contentDir: './content',\n    10→  templateDir: './templates',\n    11→};\n    12→\n    13→function makeCtx(files: ContentFile[] = [], data?: Map<string, unknown>): BuildContext {\n    14→  return {\n    15→    config: testConfig,\n    16→    files,\n    17→    output: new Map(),\n    18→    assets: new Map(),\n    19→    data: data || new Map(),\n    20→  };\n    21→}\n    22→\n    23→function makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n    24→  return {\n    25→    slug: 'test',\n    26→    title: 'Test',\n    27→    content: '<p>HTML content</p>',\n    28→    metadata: {},\n    29→    ...overrides,\n    30→  };\n    31→}\n    32→\n    33→describe('rss-feed plugin', () => {\n    34→  const plugin = createRssFeedPlugin();\n    35→\n    36→  it('generates valid RSS 2.0 XML', async () => {\n    37→    const files = [makeFile({ slug: 'post-1', title: 'Post 1', date: '2024-01-01' })];\n    38→    const ctx = makeCtx(files);\n    39→    await plugin.hooks.afterBuild!(ctx);\n    40→    const feed = ctx.output.get('feed.xml')!;\n    41→    expect(feed).toContain('<?xml version=\"1.0\"');\n    42→    expect(feed).toContain('<rss version=\"2.0\">');\n    43→    expect(feed).toContain('<channel>');\n    44→    expect(feed).toContain('<item>');\n    45→    expect(feed).toContain('</rss>');\n    46→  });\n    47→\n    48→  it('feed items contain HTML content not raw markdown', async () => {\n    49→    const files = [\n    50→      makeFile({\n    51→  