+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from '../src/index.js';
+
+function makeGrid(rows: number, cols: number): string[][] {
+  return Array.from({ length: rows }, () => Array(cols).fill('.'));
+}
+
+describe('countBeamCells', () => {
+  it('straight beam, no splitters', () => {
+    const grid = makeGrid(4, 5);
+    grid[0][1] = 'S';
+    // Beam: (0,1) (1,1) (2,1) (3,1)
+    expect(countBeamCells(grid)).toBe(4);
+  });
+
+  it('single splitter (TASK.md example 1)', () => {
+    const grid = makeGrid(4, 5);
+    grid[0][1] = 'S';
+    grid[2][1] = '^';
+    // (0,1) (1,1) (2,1) -> split to (3,0) and (3,2)
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('two splitters (TASK.md example 2)', () => {
+    const grid = makeGrid(4, 5);
+    grid[0][1] = 'S';
+    grid[1][1] = '^';
+    grid[2][0] = '^';
+    grid[2][2] = '^';
+    // (0,1) (1,1)->split (2,0)->split (2,2)->split
+    // (3,-1)absorbed, (3,1), (3,1), (3,3)
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('splitter at left edge absorbs left beam', () => {
+    const grid = makeGrid(4, 3);
+    grid[0][0] = 'S';
+    grid[2][0] = '^';
+    // (0,0) (1,0) (2,0)->split: (3,-1)absorbed, (3,1)
+    expect(countBeamCells(grid)).toBe(4);
+  });
+
+  it('no source returns 0', () => {
+    const grid = makeGrid(5, 5);
+    expect(countBeamCells(grid)).toBe(0);
+  });
+
+  it('single-row grid', () => {
+    const grid = makeGrid(1, 5);
+    grid[0][2] = 'S';
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('single-column with splitter', () => {
+    const grid = makeGrid(6, 1);
+    grid[0][0] = 'S';
+    grid[2][0] = '^';
+    // (0,0) (1,0) (2,0)->split: both beams go out of bounds
+    expect(countBeamCells(grid)).toBe(3);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('no splitters — single path', () => {
+    const grid = makeGrid(5, 5);
+    grid[0][2] = 'S';
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('one splitter — two paths', () => {
+    const grid = makeGrid(4, 5);
+    grid[0][1] = 'S';
+    grid[2][1] = '^';
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('two splitters — four paths', () => {
+    const grid = makeGrid(4, 5);
+    grid[0][1] = 'S';
+    grid[1][1] = '^';
+    grid[2][0] = '^';
+    grid[2][2] = '^';
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('no source returns 0n', () => {
+    const grid = makeGrid(5, 5);
+    expect(countBeamPaths(grid)).toBe(0n);
+  });
+
+  it('single-row grid', () => {
+    const grid = makeGrid(1, 5);
+    grid[0][2] = 'S';
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('single-column with splitter — both beams absorbed', () => {
+    const grid = makeGrid(6, 1);
+    grid[0][0] = 'S';
+    grid[2][0] = '^';
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+});
