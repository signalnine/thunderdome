+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+function findSource(grid: string[][]): { row: number; col: number } | null {
+  for (let r = 0; r < grid.length; r++) {
+    for (let c = 0; c < grid[0].length; c++) {
+      if (grid[r][c] === 'S') return { row: r, col: c };
+    }
+  }
+  return null;
+}
+
+/**
+ * Count the number of distinct cells visited by any beam.
+ */
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<string>();
+  const seen = new Set<string>();
+  const stack: Beam[] = [{ row: source.row, col: source.col, dir: 'down' }];
+
+  while (stack.length > 0) {
+    const beam = stack.pop()!;
+    const key = `${beam.row},${beam.col},${beam.dir}`;
+    if (seen.has(key)) continue;
+    seen.add(key);
+    visited.add(`${beam.row},${beam.col}`);
+
+    if (grid[beam.row][beam.col] === '^') {
+      const lr = beam.row + 1;
+      const lc = beam.col - 1;
+      const rc = beam.col + 1;
+      if (inBounds(lr, lc, rows, cols)) {
+        stack.push({ row: lr, col: lc, dir: 'down-left' });
+      }
+      if (inBounds(lr, rc, rows, cols)) {
+        stack.push({ row: lr, col: rc, dir: 'down-right' });
+      }
+    } else {
+      let nr: number, nc: number;
+      switch (beam.dir) {
+        case 'down': nr = beam.row + 1; nc = beam.col; break;
+        case 'down-left': nr = beam.row + 1; nc = beam.col - 1; break;
+        case 'down-right': nr = beam.row + 1; nc = beam.col + 1; break;
+      }
+      if (inBounds(nr, nc, rows, cols)) {
+        stack.push({ row: nr, col: nc, dir: beam.dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+/**
+ * Count the total number of distinct source-to-exit paths.
+ * Uses row-by-row counter propagation with bigint for arbitrary precision.
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  const makeKey = (col: number, dir: Direction): string => `${col},${dir}`;
+
+  let current = new Map<string, bigint>();
+  current.set(makeKey(source.col, 'down'), 1n);
+  let totalExited = 0n;
+
+  for (let r = source.row; r < rows; r++) {
+    const next = new Map<string, bigint>();
+
+    for (const [key, count] of current) {
+      const [colStr, dir] = key.split(',') as [string, Direction];
+      const col = parseInt(colStr, 10);
+
+      if (grid[r][col] === '^') {
+        const leftCol = col - 1;
+        const rightCol = col + 1;
+        const nextRow = r + 1;
+
+        if (nextRow < rows && leftCol >= 0 && leftCol < cols) {
+          const k = makeKey(leftCol, 'down-left');
+          next.set(k, (next.get(k) ?? 0n) + count);
+        } else {
+          totalExited += count;
+        }
+
+        if (nextRow < rows && rightCol >= 0 && rightCol < cols) {
+          const k = makeKey(rightCol, 'down-right');
+          next.set(k, (next.get(k) ?? 0n) + count);
+        } else {
+          totalExited += count;
+        }
+      } else {
+        let nextCol: number;
+        switch (dir) {
+          case 'down': nextCol = col; break;
+          case 'down-left': nextCol = col - 1; break;
+          case 'down-right': nextCol = col + 1; break;
+        }
+        const nextRow = r + 1;
+
+        if (nextRow < rows && nextCol >= 0 && nextCol < cols) {
+          const k = makeKey(nextCol, dir);
+          next.set(k, (next.get(k) ?? 0n) + count);
+        } else {
+          totalExited += count;
+        }
+      }
+    }
+
+    current = next;
+  }
+
+  // Beams still active after the last row exit the grid
+  for (const [, count] of current) {
+    totalExited += count;
+  }
+
+  return totalExited;
+}
