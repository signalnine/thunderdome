+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit of logic gates given initial wire values.
+ * Returns a map of all wire values after the circuit settles.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+  let progress = true;
+
+  while (remaining.length > 0 && progress) {
+    progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 swap pairs in a broken binary adder circuit.
+ *
+ * Uses structural rules that a correct ripple-carry adder must satisfy:
+ * 1. z-output gates must be XOR (except the final carry bit, which is OR)
+ * 2. Non-input XOR gates that don't output to z are invalid
+ * 3. Input XOR gates (except bit 0) must feed into another XOR
+ * 4. AND gates (except bit 0) must feed into an OR gate
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  const swapped = new Set<string>();
+
+  // Find the highest z-bit to identify the final carry
+  let maxZ = 0;
+  for (const gate of gates) {
+    if (gate.out.startsWith('z')) {
+      const num = parseInt(gate.out.slice(1), 10);
+      if (num > maxZ) maxZ = num;
+    }
+  }
+  const finalZ = `z${String(maxZ).padStart(2, '0')}`;
+
+  // Build a lookup: wire -> gates that use it as input
+  const wireToConsumers = new Map<string, Gate[]>();
+  for (const gate of gates) {
+    for (const inp of [gate.in1, gate.in2]) {
+      if (!wireToConsumers.has(inp)) wireToConsumers.set(inp, []);
+      wireToConsumers.get(inp)!.push(gate);
+    }
+  }
+
+  function hasInputWires(gate: Gate): boolean {
+    return (
+      gate.in1.startsWith('x') ||
+      gate.in1.startsWith('y') ||
+      gate.in2.startsWith('x') ||
+      gate.in2.startsWith('y')
+    );
+  }
+
+  function isBitZero(gate: Gate): boolean {
+    return (
+      (gate.in1 === 'x00' || gate.in1 === 'y00') &&
+      (gate.in2 === 'x00' || gate.in2 === 'y00')
+    );
+  }
+
+  for (const gate of gates) {
+    // Rule 1a: z-output gates must be XOR (except final carry)
+    if (gate.out.startsWith('z') && gate.out !== finalZ) {
+      if (gate.op !== 'XOR') {
+        swapped.add(gate.out);
+      }
+    }
+
+    // Rule 1b: final z must be OR (it's the last carry)
+    if (gate.out === finalZ) {
+      if (gate.op !== 'OR') {
+        swapped.add(gate.out);
+      }
+    }
+
+    // Rule 2: XOR gates that don't have input wires and don't output to z are wrong
+    if (gate.op === 'XOR' && !hasInputWires(gate) && !gate.out.startsWith('z')) {
+      swapped.add(gate.out);
+    }
+
+    // Rule 3: XOR gates with x/y inputs (except bit 0) must feed into another XOR
+    if (gate.op === 'XOR' && hasInputWires(gate) && !isBitZero(gate)) {
+      const consumers = wireToConsumers.get(gate.out) || [];
+      const feedsXOR = consumers.some((c) => c.op === 'XOR');
+      if (!feedsXOR) {
+        swapped.add(gate.out);
+      }
+    }
+
+    // Rule 4: AND gates (except bit 0) must feed into an OR
+    if (gate.op === 'AND' && !isBitZero(gate)) {
+      const consumers = wireToConsumers.get(gate.out) || [];
+      const feedsOR = consumers.some((c) => c.op === 'OR');
+      if (!feedsOR) {
+        swapped.add(gate.out);
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
