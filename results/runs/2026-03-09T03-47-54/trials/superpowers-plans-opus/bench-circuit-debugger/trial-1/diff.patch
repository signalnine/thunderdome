\n          case 'OR':  wires[gate.out] = a | b; break;\n          case 'XOR': wires[gate.out] = a ^ b; break;\n        }\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n  }\n\n  return wires;\n}\n```\n\nThe simulate function works by iteratively processing gates whose inputs are available, removing them from the remaining list. This handles dependency ordering automatically since the circuit is acyclic.\n\n**Step 2: Run build to verify it compiles**\n\nRun: `npm run build`\nExpected: Successful compilation\n\n---\n\n### Task 2: Implement findSwappedWires function\n\n**Files:**\n- Modify: `src/index.ts`\n\n**Step 1: Add findSwappedWires function**\n\nThe approach uses 4 structural rules that a correct ripple-carry adder must satisfy:\n\n1. **z-output gates must be XOR** (except the final carry bit z[N], which must be OR)\n2. **Non-input, non-z XOR gates are invalid** — XOR gates that don't read x/y inputs and don't output to z wires violate the adder structure\n3. **Input XOR gates must feed into another XOR** — the partial sum (x XOR y) must feed into a second XOR with carry-in (except bit 0 which has no carry)\n4. **AND gates must feed into OR** — both generate-carry and propagate-carry AND gates must feed into an OR gate for carry computation (except bit 0)\n\nAny gate output that violates these rules is a swapped wire.\n\n```typescript\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped = new Set<string>();\n\n  // Find final carry bit (highest z)\n  let maxZ = 0;\n  for (const gate of gates) {\n    if (gate.out.startsWith('z')) {\n      const num = parseInt(gate.out.slice(1), 10);\n      if (num > maxZ) maxZ = num;\n    }\n  }\n  const finalZ = `z${String(maxZ).padStart(2, '0')}`;\n\n  // Build consumer lookup: wire -> gates using it as input\n  const wireToConsumers = new Map<string, Gate[]>();\n  for (const gate of gates) {\n    for (const inp of [gate.in1, gate.in2]) {\n      if (!wireToConsumers.has(inp)) wireToConsumers.set(inp, []);\n      wireToConsumers.get(inp)!.push(gate);\n    }\n  }\n\n  // Helper predicates\n  const hasInputWires = (g: Gate) =>\n    g.in1.startsWith('x') || g.in1.startsWith('y') ||\n    g.in2.startsWith('x') || g.in2.startsWith('y');\n\n  const isBitZero = (g: Gate) =>\n    (g.in1 === 'x00' || g.in1 === 'y00') &&\n    (g.in2 === 'x00' || g.in2 === 'y00');\n\n  for (const gate of gates) {\n    // Rule 1a: z-outputs (except final) must be XOR\n    if (gate.out.startsWith('z') && gate.out !== finalZ && gate.op !== 'XOR') {\n      swapped.add(gate.out);\n    }\n\n    // Rule 1b: final z must be OR\n    if (gate.out === finalZ && gate.op !== 'OR') {\n      swapped.add(gate.out);\n    }\n\n    // Rule 2: Non-input XOR that doesn't output z is wrong\n    if (gate.op === 'XOR' && !hasInputWires(gate) && !gate.out.startsWith('z')) {\n      swapped.add(gate.out);\n    }\n\n    // Rule 3: Input XOR (except bit 0) must feed another XOR\n    if (gate.op === 'XOR' && hasInputWires(gate) && !isBitZero(gate)) {\n      const consumers = wireToConsumers.get(gate.out) || [];\n      if (!consumers.some(c => c.op === 'XOR')) {\n        swapped.add(gate.out);\n      }\n    }\n\n    // Rule 4: AND (except bit 0) must feed an OR\n    if (gate.op === 'AND' && !isBitZero(gate)) {\n      const consumers = wireToConsumers.get(gate.out) || [];\n      if (!consumers.some(c => c.op === 'OR')) {\n        swapped.add(gate.out);\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n```\n\n**Step 2: Run build**\n\nRun: `npm run build`\nExpected: Successful compilation\n\n---\n\n### Task 3: Run all tests and validate\n\n**Step 1: Run unit tests**\n\nRun: `npm test`\nExpected: All tests pass\n\n**Step 2: Run lint**\n\nRun: `npm run lint`\nExpected: No lint errors\n\n**Step 3: Run build**\n\nRun: `npm run build`\nExpected: Successful build\n\n**Step 4: Run validation tests**\n\nRun: `npx vitest run --config validation-vitest.config.ts`\nExpected: All validation tests pass\