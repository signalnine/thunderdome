+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013XMo7HMgYnVQeR82BvPFZx","type":"tool_result","content":"     1→export interface StockRecord {\n     2→  productId: string;\n     3→  available: number;\n     4→  reserved: number;\n     5→}\n     6→\n     7→export class InventoryRepository {\n     8→  private store: Map<string, StockRecord> = new Map();\n     9→\n    10→  setStock(productId: string, available: number): void {\n    11→    const existing = this.store.get(productId);\n    12→    this.store.set(productId, {\n    13→      productId,\n    14→      available,\n    15→      reserved: existing?.reserved ?? 0,\n    16→    });\n    17→  }\n    18→\n    19→  getStock(productId: string): StockRecord | undefined {\n    20→    const record = this.store.get(productId);\n    21→    return record ? { ...record } : undefined;\n    22→  }\n    23→\n    24→  reserve(productId: string, quantity: number): boolean {\n    25→    const record = this.store.get(productId);\n    26→    if (!record || record.available < quantity) return false;\n    27→    record.available -= quantity;\n    28→    record.reserved += quantity;\n    29→    return true;\n    30→  }\n    31→\n    32→  release(productId: string, quantity: number): boolean {\n    33→    const record = this.store.get(productId);\n    34→    if (!record || record.reserved < quantity) return false;\n    35→    record.reserved -= quantity;\n    36→    record.available += quantity;\n    37→    return true;\n    38→  }\n    39→\n    40→  clear(): void {\n    41→    this.store.clear();\n    42→  }\n    43→}\n    44→"}]},"parent_tool_use_id":"toolu_01Q2xSvkcU8hS4eT8UuAAcTp","session_id":"944ab92e-e50e-4104-bfa6-fb96e82393e4","uuid":"a1407e23-2a62-4224-aafa-d6cbf2eaffc4"}
