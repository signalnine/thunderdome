+++ b/src/task-queue.ts
@@ -0,0 +1,248 @@
+import { Queue } from './queue.js';
+import { Scheduler } from './scheduler.js';
+import type { Task, TaskOptions, Middleware, TaskHandler, Schedule } from './types.js';
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+export class TaskQueue {
+  private queues: Map<string, Queue> = new Map();
+  private scheduler: Scheduler = new Scheduler();
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+  private isShuttingDown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+
+  private getQueue(name: string): Queue {
+    if (!this.queues.has(name)) {
+      this.queues.set(name, new Queue(name));
+    }
+    return this.queues.get(name)!;
+  }
+
+  add(payload: unknown, options: TaskOptions & { queue?: string } = {}): Task {
+    if (this.isShuttingDown) {
+      throw new Error('Cannot add tasks while shutting down');
+    }
+
+    const queueName = options.queue ?? 'default';
+    const queue = this.getQueue(queueName);
+
+    const { queue: _, ...taskOptions } = options;
+    return queue.add(payload, taskOptions);
+  }
+
+  retrieve(queueName: string = 'default'): Task | null {
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+    return queue.retrieve();
+  }
+
+  complete(taskId: string, queueName: string = 'default'): void {
+    const queue = this.queues.get(queueName);
+    if (!queue) return;
+    queue.complete(taskId);
+  }
+
+  fail(taskId: string, error?: string, queueName: string = 'default'): void {
+    const queue = this.queues.get(queueName);
+    if (!queue) return;
+    queue.fail(taskId, error);
+  }
+
+  cancel(taskId: string, queueName: string = 'default'): boolean {
+    const queue = this.queues.get(queueName);
+    if (!queue) return false;
+    return queue.cancel(taskId);
+  }
+
+  updateProgress(taskId: string, progress: number, message?: string, queueName: string = 'default'): void {
+    const queue = this.queues.get(queueName);
+    if (!queue) return;
+    queue.updateProgress(taskId, progress, message);
+  }
+
+  subscribeToProgress(taskId: string, listener: Parameters<Queue['subscribeToProgress']>[1], queueName: string = 'default'): () => void {
+    const queue = this.queues.get(queueName);
+    if (!queue) return () => {};
+    return queue.subscribeToProgress(taskId, listener);
+  }
+
+  getProgress(taskId: string, queueName: string = 'default'): ReturnType<Queue['getProgress']> {
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+    return queue.getProgress(taskId);
+  }
+
+  getDependencyStatus(taskId: string, queueName: string = 'default'): ReturnType<Queue['getDependencyStatus']> {
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+    return queue.getDependencyStatus(taskId);
+  }
+
+  getTask(taskId: string, queueName: string = 'default'): Task | undefined {
+    const queue = this.queues.get(queueName);
+    if (!queue) return undefined;
+    return queue.getTask(taskId);
+  }
+
+  listQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  getWaitingCount(queueName: string = 'default'): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+    return queue.getWaitingCount();
+  }
+
+  getPendingCount(queueName: string = 'default'): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+    return queue.getPendingCount();
+  }
+
+  getDeadLetterQueue(queueName: string = 'default'): ReturnType<Queue['getDeadLetterQueue']> {
+    const queue = this.queues.get(queueName);
+    if (!queue) return [];
+    return queue.getDeadLetterQueue();
+  }
+
+  redriveDeadLetter(taskId: string, queueName: string = 'default'): Task | null {
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+    return queue.redriveDeadLetter(taskId);
+  }
+
+  clearDeadLetter(queueName: string = 'default'): void {
+    const queue = this.queues.get(queueName);
+    if (!queue) return;
+    queue.clearDeadLetter();
+  }
+
+  setConcurrencyLimit(queueName: string, limit: number): void {
+    const queue = this.getQueue(queueName);
+    queue.setConcurrencyLimit(limit);
+  }
+
+  getConcurrencyLimit(queueName: string = 'default'): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return Infinity;
+    return queue.getConcurrencyLimit();
+  }
+
+  getActiveCount(queueName: string = 'default'): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+    return queue.getActiveCount();
+  }
+
+  addMiddleware(queueName: string, middleware: Middleware): void {
+    const queue = this.getQueue(queueName);
+    queue.addMiddleware(middleware);
+  }
+
+  setHandler(queueName: string, handler: TaskHandler): void {
+    const queue = this.getQueue(queueName);
+    queue.setHandler(handler);
+  }
+
+  async process(task: Task): Promise<void> {
+    const queue = this.queues.get(task.queueName);
+    if (!queue) throw new Error(`Queue ${task.queueName} does not exist`);
+    await queue.process(task);
+  }
+
+  createSchedule(queueName: string, cronExpression: string, payload: unknown): Schedule {
+    return this.scheduler.create(queueName, cronExpression, payload);
+  }
+
+  removeSchedule(scheduleId: string): boolean {
+    return this.scheduler.remove(scheduleId);
+  }
+
+  listSchedules(): Schedule[] {
+    return this.scheduler.list();
+  }
+
+  tick(): void {
+    const tasks = this.scheduler.tick();
+    for (const { queueName, payload } of tasks) {
+      this.add(payload, { queue: queueName });
+    }
+  }
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeout: number = 30000): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.shutdownPromise = this.doShutdown(timeout);
+    return this.shutdownPromise;
+  }
+
+  private async doShutdown(timeout: number): Promise<ShutdownResult> {
+    this.isShuttingDown = true;
+    const startTime = Date.now();
+
+    for (const callback of this.shutdownCallbacks) {
+      try {
+        await callback();
+      } catch {
+        // Ignore errors from shutdown callbacks
+      }
+    }
+
+    let forceCancelled = 0;
+
+    const checkInterval = 100;
+    const maxWaitTime = timeout;
+
+    while (Date.now() - startTime < maxWaitTime) {
+      let allIdle = true;
+      for (const queue of this.queues.values()) {
+        if (queue.getProcessingCount() > 0) {
+          allIdle = false;
+          break;
+        }
+      }
+
+      if (allIdle) {
+        break;
+      }
+
+      await new Promise(resolve => setTimeout(resolve, checkInterval));
+    }
+
+    for (const queue of this.queues.values()) {
+      const processing = queue.getProcessingTasks();
+      for (const task of processing) {
+        queue.cancel(task.id);
+        forceCancelled++;
+      }
+    }
+
+    let completed = 0;
+    for (const queue of this.queues.values()) {
+      completed += queue.getAllTasks().filter(t => t.status === 'completed').length;
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+
+  getProcessingTasks(queueName: string = 'default'): Task[] {
+    const queue = this.queues.get(queueName);
+    if (!queue) return [];
+    return queue.getProcessingTasks();
+  }
+}
