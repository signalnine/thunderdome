index 0000000..7ccbeab
--- /dev/null
+++ b/src/index.test.ts
@@ -0,0 +1,488 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from './index.js';
+
+describe('TaskQueue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  describe('Phase 1: Basic FIFO Queue', () => {
+    it('should add tasks and return task objects', () => {
+      const task = queue.add({ data: 'test' });
+      expect(task).toBeDefined();
+      expect(task.id).toBeDefined();
+      expect(task.status).toBe('pending');
+      expect(task.createdAt).toBeGreaterThan(0);
+      expect(task.payload).toEqual({ data: 'test' });
+    });
+
+    it('should retrieve tasks in FIFO order', () => {
+      queue.add({ data: 'first' });
+      queue.add({ data: 'second' });
+
+      const task1 = queue.retrieve();
+      const task2 = queue.retrieve();
+
+      expect(task1?.payload).toEqual({ data: 'first' });
+      expect(task2?.payload).toEqual({ data: 'second' });
+    });
+
+    it('should transition task to processing on retrieve', () => {
+      queue.add({ data: 'test' });
+      const task = queue.retrieve();
+
+      expect(task?.status).toBe('processing');
+    });
+
+    it('should return null when no tasks available', () => {
+      const task = queue.retrieve();
+      expect(task).toBeNull();
+    });
+
+    it('should report waiting count', () => {
+      expect(queue.getWaitingCount()).toBe(0);
+      queue.add({ data: 'test' });
+      expect(queue.getWaitingCount()).toBe(1);
+      queue.retrieve();
+      expect(queue.getWaitingCount()).toBe(0);
+    });
+  });
+
+  describe('Phase 2: Named Queues', () => {
+    it('should support multiple named queues', () => {
+      queue.add({ data: 'default' });
+      queue.add({ data: 'email' }, { queue: 'email' });
+      queue.add({ data: 'sms' }, { queue: 'sms' });
+
+      expect(queue.getWaitingCount('default')).toBe(1);
+      expect(queue.getWaitingCount('email')).toBe(1);
+      expect(queue.getWaitingCount('sms')).toBe(1);
+    });
+
+    it('should retrieve from specific queue', () => {
