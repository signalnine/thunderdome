+      expect(schedule.queueName).toBe('default');
+    });
+
+    it('should list schedules', () => {
+      queue.createSchedule('default', '*/5 * * * *', { data: '1' });
+      queue.createSchedule('email', '0 * * * *', { data: '2' });
