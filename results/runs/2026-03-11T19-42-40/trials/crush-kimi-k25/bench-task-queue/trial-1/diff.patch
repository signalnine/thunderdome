@@ -0,0 +1,40 @@
+import type { Task, TaskOptions } from './types.js';
+
+let idCounter = 0;
+
+export function generateId(): string {
+  return `${Date.now()}-${++idCounter}-${Math.random().toString(36).slice(2, 9)}`;
+}
+
+export function createTask(payload: unknown, queueName: string, options: TaskOptions = {}): Task {
+  const now = Date.now();
+  const priority = options.priority ?? 5;
+
+  if (priority < 1 || priority > 10) {
+    throw new Error('Priority must be between 1 and 10');
+  }
+
+  let availableAt = now;
+  if (options.delay) {
+    availableAt = now + options.delay;
+  } else if (options.scheduledAt) {
+    availableAt = options.scheduledAt;
+  }
+
+  return {
+    id: generateId(),
+    payload,
+    status: 'pending',
+    createdAt: now,
+    queueName,
+    priority,
+    availableAt,
+    attempts: 0,
+    maxRetries: options.maxRetries ?? 3,
+    baseDelay: options.baseDelay ?? 1000,
+    dependencies: options.dependencies ?? [],
+    completedDependencies: [],
+    progress: 0,
+    progressMessage: '',
+  };
+}
