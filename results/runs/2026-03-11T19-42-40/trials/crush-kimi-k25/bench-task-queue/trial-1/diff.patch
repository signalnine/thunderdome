+    });
+  });
+
+  describe('Phase 11: Middleware', () => {
+    it('should process middleware in order', async () => {
+      const order: string[] = [];
+
+      queue.addMiddleware('default', async (task, next) => {
+        order.push('mw1-before');
+        await next();
+        order.push('mw1-after');
+      });
+
+      queue.addMiddleware('default', async (task, next) => {
+        order.push('mw2-before');
+        await next();
+        order.push('mw2-after');
+      });
+
+      queue.setHandler('default', async () => {
+        order.push('handler');
+      });
+
+      queue.add({ data: 'test' });
