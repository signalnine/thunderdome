+++ b/src/scheduler.ts
@@ -0,0 +1,121 @@
+import type { Schedule } from './types.js';
+
+interface CronSchedule {
+  id: string;
+  queueName: string;
+  payload: unknown;
+  lastRunAt: number;
+  nextRunAt: number;
+  getNextRun: (from: number) => number;
+}
+
+export class Scheduler {
+  private schedules: Map<string, CronSchedule> = new Map();
+  private idCounter = 0;
+
+  create(queueName: string, cronExpression: string, payload: unknown): Schedule {
+    const getNextRun = this.parseCron(cronExpression);
+    const now = Date.now();
+    const id = `schedule-${++this.idCounter}`;
+
+    const schedule: CronSchedule = {
+      id,
+      queueName,
+      payload,
+      lastRunAt: 0,
+      nextRunAt: getNextRun(now),
+      getNextRun,
+    };
+
+    this.schedules.set(id, schedule);
+
+    return {
+      id,
+      queueName,
+      cronExpression,
+      payload,
+      lastRunAt: 0,
+    };
+  }
+
+  remove(scheduleId: string): boolean {
+    return this.schedules.delete(scheduleId);
+  }
+
+  list(): Schedule[] {
+    return Array.from(this.schedules.values()).map(s => ({
+      id: s.id,
+      queueName: s.queueName,
+      cronExpression: '',
+      payload: s.payload,
+      lastRunAt: s.lastRunAt,
+    }));
+  }
+
+  tick(): Array<{ queueName: string; payload: unknown }> {
+    const now = Date.now();
+    const due: Array<{ queueName: string; payload: unknown }> = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (now >= schedule.nextRunAt) {
+        due.push({
+          queueName: schedule.queueName,
+          payload: schedule.payload,
+        });
+        schedule.lastRunAt = now;
+        schedule.nextRunAt = schedule.getNextRun(now);
+      }
+    }
+
+    return due;
+  }
+
+  private parseCron(expression: string): (from: number) => number {
+    const parts = expression.trim().split(' ');
+
+    if (parts.length !== 5) {
+      throw new Error('Invalid cron expression: expected 5 parts (minute hour day month weekday)');
+    }
+
+    const [minutePart] = parts;
+
+    if (minutePart.startsWith('*/')) {
+      const interval = parseInt(minutePart.slice(2), 10);
+      if (isNaN(interval) || interval <= 0 || interval > 60) {
+        throw new Error('Invalid cron interval');
+      }
+      return (from: number) => {
+        const date = new Date(from);
+        const currentMinute = date.getMinutes();
+        const nextMinute = Math.ceil((currentMinute + 1) / interval) * interval;
+        date.setMinutes(nextMinute, 0, 0);
+        if (nextMinute >= 60) {
+          date.setHours(date.getHours() + 1);
+          date.setMinutes(0);
+        }
+        return date.getTime();
+      };
+    }
+
+    if (minutePart === '0') {
+      const hourPart = parts[1];
+      if (hourPart === '0') {
+        return (from: number) => {
+          const date = new Date(from);
+          date.setDate(date.getDate() + 1);
+          date.setHours(0, 0, 0, 0);
+          return date.getTime();
+        };
+      }
+      if (hourPart === '*') {
+        return (from: number) => {
+          const date = new Date(from);
+          date.setHours(date.getHours() + 1, 0, 0, 0);
+          return date.getTime();
+        };
+      }
+    }
+
+    throw new Error(`Unsupported cron expression: ${expression}`);
+  }
+}
