+++ b/src/types.ts
@@ -0,0 +1,62 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task {
+  id: string;
+  payload: unknown;
+  status: TaskStatus;
+  createdAt: number;
+  queueName: string;
+  priority: number;
+  availableAt: number;
+  attempts: number;
+  maxRetries: number;
+  baseDelay: number;
+  dependencies: string[];
+  completedDependencies: string[];
+  progress: number;
+  progressMessage: string;
+  error?: string;
+}
+
+export interface TaskOptions {
+  priority?: number;
+  delay?: number;
+  scheduledAt?: number;
+  maxRetries?: number;
+  baseDelay?: number;
+  dependencies?: string[];
+}
+
+export interface QueueStats {
+  pending: number;
+  processing: number;
+  completed: number;
+  failed: number;
+  cancelled: number;
+}
+
+export interface DeadLetterTask extends Task {
+  deadLetteredAt: number;
+  finalError: string;
+}
+
+export type Middleware = (task: Task, next: () => Promise<void>) => Promise<void>;
+
+export type TaskHandler = (task: Task) => Promise<void>;
+
+export interface Schedule {
+  id: string;
+  queueName: string;
+  cronExpression: string;
+  payload: unknown;
+  lastRunAt: number;
+}
+
+export interface ProgressUpdate {
+  taskId: string;
+  progress: number;
+  message: string;
+  timestamp: number;
+}
+
+export type ProgressListener = (update: ProgressUpdate) => void;
