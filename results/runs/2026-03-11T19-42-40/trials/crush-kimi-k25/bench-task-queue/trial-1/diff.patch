+      const schedules = queue.listSchedules();
+      expect(schedules).toHaveLength(2);
+    });
+
+    it('should remove schedules', () => {
+      const schedule = queue.createSchedule('default', '*/5 * * * *', { data: 'test' });
+      const removed = queue.removeSchedule(schedule.id);
