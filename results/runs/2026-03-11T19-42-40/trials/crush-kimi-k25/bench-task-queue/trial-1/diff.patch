+import type { Task, DeadLetterTask, Middleware, TaskHandler, ProgressListener, ProgressUpdate } from './types.js';
+import { createTask } from './task.js';
+import type { TaskOptions } from './types.js';
+
+interface DependencyNode {
+  task: Task;
+  remainingDeps: Set<string>;
+}
+
+export class Queue {
+  readonly name: string;
+  private tasks: Map<string, Task> = new Map();
+  private pending: Set<string> = new Set();
+  private processing: Set<string> = new Set();
+  private completed: Set<string> = new Set();
+  private failed: Set<string> = new Set();
+  private cancelled: Set<string> = new Set();
+  private deadLetter: DeadLetterTask[] = [];
+  private blockedTasks: Map<string, DependencyNode> = new Map();
+  private concurrencyLimit: number = Infinity;
+  private middleware: Middleware[] = [];
+  private handler: TaskHandler | null = null;
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+
+  constructor(name: string) {
+    this.name = name;
+  }
+
+  add(payload: unknown, options: TaskOptions = {}): Task {
+    const task = createTask(payload, this.name, options);
+
+    if (task.dependencies.length > 0) {
+      for (const depId of task.dependencies) {
+        if (!this.tasks.has(depId)) {
+          throw new Error(`Dependency ${depId} does not exist`);
+        }
+      }
+      const remainingDeps = new Set(task.dependencies);
+      this.blockedTasks.set(task.id, { task, remainingDeps });
+    }
+
+    this.tasks.set(task.id, task);
+    this.pending.add(task.id);
+
+    return task;
+  }
+
+  retrieve(): Task | null {
+    if (this.processing.size >= this.concurrencyLimit) {
+      return null;
+    }
+
+    const now = Date.now();
+    const available: Task[] = [];
+
+    for (const id of this.pending) {
+      const task = this.tasks.get(id)!;
+      if (task.availableAt <= now && !this.blockedTasks.has(id)) {
+        available.push(task);
+      }
+    }
+
+    if (available.length === 0) {
+      return null;
+    }
+
+    available.sort((a, b) => {
+      if (a.priority !== b.priority) {
+        return a.priority - b.priority;
+      }
+      if (a.availableAt !== b.availableAt) {
+        return a.availableAt - b.availableAt;
+      }
+      return a.createdAt - b.createdAt;
+    });
+
+    const task = available[0];
+    this.pending.delete(task.id);
+    this.processing.add(task.id);
+    task.status = 'processing';
+    task.attempts++;
+
+    return task;
+  }
+
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task || task.status !== 'processing') {
+      return;
+    }
+
+    task.status = 'completed';
+    task.progress = 100;
+    this.processing.delete(taskId);
+    this.completed.add(taskId);
+
+    this.unblockDependents(taskId);
+  }
+
+  fail(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task || task.status !== 'processing') {
+      return;
+    }
+
+    task.error = error;
+
+    if (task.attempts <= task.maxRetries) {
+      const backoffDelay = task.baseDelay * Math.pow(2, task.attempts - 1);
+      task.availableAt = Date.now() + backoffDelay;
+      task.status = 'pending';
+      this.processing.delete(taskId);
+      this.pending.add(taskId);
+    } else {
+      task.status = 'failed';
+      this.processing.delete(taskId);
+      this.failed.add(taskId);
+
+      const deadLetterTask: DeadLetterTask = {
+        ...task,
+        deadLetteredAt: Date.now(),
+        finalError: error ?? 'Unknown error',
+      };
+      this.deadLetter.push(deadLetterTask);
+    }
+  }
+
+  cancel(taskId: string): boolean {
+    const task = this.tasks.get(taskId);
+    if (!task || (task.status !== 'pending' && task.status !== 'processing')) {
+      return false;
+    }
+
+    task.status = 'cancelled';
+
+    if (this.pending.has(taskId)) {
+      this.pending.delete(taskId);
+    } else if (this.processing.has(taskId)) {
+      this.processing.delete(taskId);
+    }
+
+    this.cancelled.add(taskId);
+    this.blockedTasks.delete(taskId);
+
+    return true;
+  }
+
+  updateProgress(taskId: string, progress: number, message: string = ''): void {
+    const task = this.tasks.get(taskId);
+    if (!task || task.status !== 'processing') {
+      return;
+    }
+
+    task.progress = Math.max(0, Math.min(100, progress));
+    task.progressMessage = message;
+
+    const update: ProgressUpdate = {
+      taskId,
+      progress: task.progress,
+      message,
+      timestamp: Date.now(),
+    };
+
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      listeners.forEach(listener => listener(update));
+    }
+  }
+
+  subscribeToProgress(taskId: string, listener: ProgressListener): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(listener);
+
+    return () => {
+      this.progressListeners.get(taskId)?.delete(listener);
+    };
+  }
+
+  getProgress(taskId: string): { progress: number; message: string } | null {
+    const task = this.tasks.get(taskId);
+    if (!task) return null;
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  getDependencyStatus(taskId: string): { blocked: boolean; remaining: string[] } | null {
+    const node = this.blockedTasks.get(taskId);
+    if (!node) {
+      const task = this.tasks.get(taskId);
+      if (!task) return null;
+      return { blocked: false, remaining: [] };
+    }
+    return { blocked: true, remaining: Array.from(node.remainingDeps) };
+  }
+
+  private unblockDependents(completedTaskId: string): void {
+    for (const [blockedId, node] of this.blockedTasks) {
+      if (node.remainingDeps.has(completedTaskId)) {
+        node.remainingDeps.delete(completedTaskId);
+        node.task.completedDependencies.push(completedTaskId);
+
+        if (node.remainingDeps.size === 0) {
+          this.blockedTasks.delete(blockedId);
+        }
+      }
+    }
+  }
+
+  getPendingCount(): number {
+    let count = 0;
+    const now = Date.now();
+    for (const id of this.pending) {
+      const task = this.tasks.get(id)!;
+      if (task.availableAt <= now && !this.blockedTasks.has(id)) {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  getWaitingCount(): number {
+    return this.pending.size;
+  }
+
+  getProcessingCount(): number {
+    return this.processing.size;
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return this.tasks.get(taskId);
+  }
+
+  getDeadLetterQueue(): DeadLetterTask[] {
+    return [...this.deadLetter];
+  }
+
+  redriveDeadLetter(taskId: string): Task | null {
+    const index = this.deadLetter.findIndex(t => t.id === taskId);
+    if (index === -1) return null;
+
+    this.deadLetter.splice(index, 1);
+
+    const task = this.tasks.get(taskId);
+    if (!task) return null;
+
+    task.status = 'pending';
+    task.attempts = 0;
+    task.error = undefined;
+    task.availableAt = Date.now();
+
+    this.failed.delete(taskId);
+    this.pending.add(taskId);
+
+    return task;
+  }
+
+  clearDeadLetter(): void {
+    for (const deadTask of this.deadLetter) {
+      this.tasks.delete(deadTask.id);
+      this.failed.delete(deadTask.id);
+    }
+    this.deadLetter = [];
+  }
+
+  setConcurrencyLimit(limit: number): void {
+    this.concurrencyLimit = limit;
+  }
+
+  getConcurrencyLimit(): number {
+    return this.concurrencyLimit;
+  }
+
+  getActiveCount(): number {
+    return this.processing.size;
+  }
+
+  addMiddleware(middleware: Middleware): void {
+    this.middleware.push(middleware);
+  }
+
+  setHandler(handler: TaskHandler): void {
+    this.handler = handler;
+  }
+
+  async process(task: Task): Promise<void> {
+    if (!this.handler) {
+      throw new Error('No handler set for queue');
+    }
+
+    let index = 0;
+    const executeNext = async (): Promise<void> => {
+      if (index < this.middleware.length) {
+        const mw = this.middleware[index++];
+        await mw(task, executeNext);
+      } else {
+        await this.handler!(task);
+      }
+    };
+
+    await executeNext();
+  }
+
+  getProcessingTasks(): Task[] {
+    return Array.from(this.processing)
+      .map(id => this.tasks.get(id)!)
+      .filter(Boolean);
+  }
+
+  getAllTasks(): Task[] {
+    return Array.from(this.tasks.values());
+  }
+}
