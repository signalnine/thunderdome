@@ -0,0 +1,204 @@
+type Direction = 'down' | 'downLeft' | 'downRight';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+/**
+ * Count the number of distinct cells visited by any beam.
+ * Uses BFS to track all visited cells.
+ */
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  // Find the source 'S' on the top row
+  let startCol = -1;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      startCol = c;
+      break;
+    }
+  }
+
+  if (startCol === -1) return 0;
+
+  const visited = new Set<string>();
+  const queue: Beam[] = [{ row: 0, col: startCol, dir: 'down' }];
+
+  while (queue.length > 0) {
+    const { row, col, dir } = queue.shift()!;
+
+    // Check if already processed this exact beam state
+    const stateKey = `${row},${col},${dir}`;
+    if (visited.has(stateKey)) continue;
+    visited.add(stateKey);
+
+    // Mark cell as visited
+    const cellKey = `${row},${col}`;
+    visited.add(cellKey);
+
+    // Calculate next position based on current cell and direction
+    let nextRow: number;
+    let nextCol: number;
+    let nextDir: Direction;
+
+    const cell = grid[row][col];
+
+    if (cell === '^') {
+      // Splitter: splits into two diagonal beams
+      // Both go down-left and down-right
+      const leftBeam: Beam = { row: row + 1, col: col - 1, dir: 'downLeft' };
+      const rightBeam: Beam = { row: row + 1, col: col + 1, dir: 'downRight' };
+
+      // Add left beam if within bounds
+      if (leftBeam.row < rows && leftBeam.col >= 0 && leftBeam.col < cols) {
+        queue.push(leftBeam);
+      }
+
+      // Add right beam if within bounds
+      if (rightBeam.row < rows && rightBeam.col >= 0 && rightBeam.col < cols) {
+        queue.push(rightBeam);
+      }
+
+      continue;
+    } else {
+      // Continue in current direction
+      if (dir === 'down') {
+        nextRow = row + 1;
+        nextCol = col;
+        nextDir = 'down';
+      } else if (dir === 'downLeft') {
+        nextRow = row + 1;
+        nextCol = col - 1;
+        nextDir = 'downLeft';
+      } else {
+        // downRight
+        nextRow = row + 1;
+        nextCol = col + 1;
+        nextDir = 'downRight';
+      }
+    }
+
+    // Check if next position is within bounds
+    if (nextRow < rows && nextCol >= 0 && nextCol < cols) {
+      queue.push({ row: nextRow, col: nextCol, dir: nextDir });
+    }
+  }
+
+  // Count unique cells (not beam states)
+  const uniqueCells = new Set<string>();
+  for (const key of visited) {
+    if (!key.includes('down')) {
+      uniqueCells.add(key);
+    }
+  }
+
+  return uniqueCells.size;
+}
+
+/**
+ * Count the total number of distinct source-to-exit paths.
+ * Uses dynamic programming with memoization - processes bottom-up since
+ * all beams move downward.
+ * dp[r][c][dir] = number of paths exiting when a beam arrives at (r,c) from direction dir
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  // Find the source 'S' on the top row
+  let startCol = -1;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      startCol = c;
+      break;
+    }
+  }
+
+  if (startCol === -1) return 0n;
+
+  // dp[r][c][dir] = number of paths from (r,c) when arrived from direction dir
+  // dir: 0 = down, 1 = downLeft, 2 = downRight
+  // This represents: beam is at (r,c), came from direction dir, now what happens?
+  const dp: bigint[][][] = Array(rows)
+    .fill(null)
+    .map(() =>
+      Array(cols)
+        .fill(null)
+        .map(() => [0n, 0n, 0n])
+    );
+
+  // Process from bottom to top
+  for (let r = rows - 1; r >= 0; r--) {
+    for (let c = 0; c < cols; c++) {
+      const _cell = grid[r][c];
+
+      for (let dir = 0; dir < 3; dir++) {
+        // Calculate next position based on what happens at current cell
+        let nextR: number;
+        let nextC: number;
+
+        if (_cell === '^') {
+          // Splitter: splits into down-left and down-right
+          // The incoming direction doesn't matter, always splits the same way
+          // This path becomes two paths
+          const leftR = r + 1;
+          const leftC = c - 1;
+          const rightR = r + 1;
+          const rightC = c + 1;
+
+          let paths = 0n;
+
+          // Left branch (downLeft)
+          if (leftR >= rows || leftC < 0 || leftC >= cols) {
+            paths += 1n; // Exits grid
+          } else {
+            paths += dp[leftR][leftC][1]; // Arrive at left cell from downLeft
+          }
+
+          // Right branch (downRight)
+          if (rightR >= rows || rightC < 0 || rightC >= cols) {
+            paths += 1n; // Exits grid
+          } else {
+            paths += dp[rightR][rightC][2]; // Arrive at right cell from downRight
+          }
+
+          dp[r][c][dir] = paths;
+        } else {
+          // Not a splitter: continue in current direction
+          if (dir === 0) {
+            // down
+            nextR = r + 1;
+            nextC = c;
+          } else if (dir === 1) {
+            // downLeft
+            nextR = r + 1;
+            nextC = c - 1;
+          } else {
+            // downRight
+            nextR = r + 1;
+            nextC = c + 1;
+          }
+
+          // Check if next position is outside the grid (absorbed = exit)
+          if (nextR >= rows || nextC < 0 || nextC >= cols) {
+            dp[r][c][dir] = 1n;
+          } else {
+            // Continue to next cell in same direction
+            dp[r][c][dir] = dp[nextR][nextC][dir];
+          }
+        }
+      }
+    }
+  }
+
+  // The beam starts at (0, startCol) going down (dir = 0)
+  return dp[0][startCol][0];
+}
