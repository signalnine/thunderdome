+import { Router } from 'express';
+import type { Response } from 'express';
+import { createEvent, createEvents } from '../db.js';
+import { generateId, authMiddleware, AuthenticatedRequest } from '../auth.js';
+import type { Event } from '../types.js';
+
+const router = Router();
+
+// Ingest single event
+router.post('/', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { name, properties = {}, timestamp, session_id } = req.body;
+    
+    if (!name) {
+      res.status(400).json({ error: 'Event name is required' });
+      return;
+    }
+    
+    const event: Event = {
+      id: generateId(),
+      tenant_id: req.user.tenant_id,
+      name,
+      properties: properties || {},
+      timestamp: timestamp || new Date().toISOString(),
+      user_id: req.user.id,
+      session_id,
+    };
+    
+    createEvent(event);
+    
+    res.status(201).json({
+      id: event.id,
+      name: event.name,
+      timestamp: event.timestamp,
+    });
+  } catch (error) {
+    console.error('Event ingestion error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Batch ingest events
+router.post('/batch', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { events } = req.body;
+    
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: 'Events array is required' });
+      return;
+    }
+    
+    if (events.length > 1000) {
+      res.status(400).json({ error: 'Maximum 1000 events per batch' });
+      return;
+    }
+    
+    const eventObjects: Event[] = events.map(eventData => ({
+      id: generateId(),
+      tenant_id: req.user!.tenant_id,
+      name: eventData.name,
+      properties: eventData.properties || {},
+      timestamp: eventData.timestamp || new Date().toISOString(),
+      user_id: req.user!.id,
+      session_id: eventData.session_id,
+    }));
+    
+    createEvents(eventObjects);
+    
+    res.status(201).json({
+      count: eventObjects.length,
+      ids: eventObjects.map(e => e.id),
+    });
+  } catch (error) {
+    console.error('Batch ingestion error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+export default router;
