+import { Router } from 'express';
+import type { Response } from 'express';
+import { countEvents, getTimeseries, getBreakdown, queryEvents } from '../db.js';
+import { authMiddleware, AuthenticatedRequest } from '../auth.js';
+
+const router = Router();
+
+// Count events
+router.get('/count', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { name, startDate, endDate } = req.query as {
+      name?: string;
+      startDate?: string;
+      endDate?: string;
+    };
+    
+    const count = countEvents(req.user.tenant_id, {
+      name,
+      startDate,
+      endDate,
+    });
+    
+    res.json({ count });
+  } catch (error) {
+    console.error('Count query error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Timeseries
+router.get('/timeseries', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { name, startDate, endDate, granularity = 'day' } = req.query as {
+      name?: string;
+      startDate?: string;
+      endDate?: string;
+      granularity?: 'day' | 'hour' | 'month';
+    };
+    
+    if (granularity && !['day', 'hour', 'month'].includes(granularity)) {
+      res.status(400).json({ error: 'Invalid granularity. Must be day, hour, or month' });
+      return;
+    }
+    
+    const data = getTimeseries(req.user.tenant_id, {
+      name,
+      startDate,
+      endDate,
+    }, granularity);
+    
+    res.json({ data });
+  } catch (error) {
+    console.error('Timeseries query error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Breakdown by property
+router.get('/breakdown', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { property, name, startDate, endDate } = req.query as {
+      property: string;
+      name?: string;
+      startDate?: string;
+      endDate?: string;
+    };
+    
+    if (!property) {
+      res.status(400).json({ error: 'Property is required' });
+      return;
+    }
+    
+    const data = getBreakdown(req.user.tenant_id, property, {
+      name,
+      startDate,
+      endDate,
+    });
+    
+    res.json({ data });
+  } catch (error) {
+    console.error('Breakdown query error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Query events (raw data)
+router.get('/events', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { name, startDate, endDate, limit = '1000' } = req.query as {
+      name?: string;
+      startDate?: string;
+      endDate?: string;
+      limit?: string;
+    };
+    
+    const events = queryEvents(req.user.tenant_id, {
+      name,
+      startDate,
+      endDate,
+    }).slice(0, parseInt(limit, 10));
+    
+    res.json({ events });
+  } catch (error) {
+    console.error('Events query error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+export default router;
