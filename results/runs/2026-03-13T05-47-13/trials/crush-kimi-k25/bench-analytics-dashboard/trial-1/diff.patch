@@ -0,0 +1,148 @@
+import { Router } from 'express';
+import type { Response } from 'express';
+import { queryEvents, getDashboardsByTenant, getDashboardById, getWidgetsByDashboard } from '../db.js';
+import { authMiddleware, AuthenticatedRequest } from '../auth.js';
+import type { Event, Dashboard } from '../types.js';
+
+const router = Router();
+
+// Export events as JSON
+router.get('/events.json', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { name, startDate, endDate } = req.query as {
+      name?: string;
+      startDate?: string;
+      endDate?: string;
+    };
+    
+    const events = queryEvents(req.user.tenant_id, {
+      name,
+      startDate,
+      endDate,
+    });
+    
+    res.setHeader('Content-Type', 'application/json');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.json"');
+    res.json({ events });
+  } catch (error) {
+    console.error('Export events JSON error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Export events as CSV
+router.get('/events.csv', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { name, startDate, endDate } = req.query as {
+      name?: string;
+      startDate?: string;
+      endDate?: string;
+    };
+    
+    const events = queryEvents(req.user.tenant_id, {
+      name,
+      startDate,
+      endDate,
+    });
+    
+    // CSV header
+    const headers = ['id', 'name', 'timestamp', 'user_id', 'session_id', 'properties'];
+    
+    // CSV rows
+    const rows = events.map((event: Event) => [
+      event.id,
+      event.name,
+      event.timestamp,
+      event.user_id || '',
+      event.session_id || '',
+      JSON.stringify(event.properties),
+    ]);
+    
+    // Escape and quote values
+    const escapeCsv = (value: string): string => {
+      if (value.includes(',') || value.includes('"') || value.includes('\n')) {
+        return `"${value.replace(/"/g, '""')}"`;
+      }
+      return value;
+    };
+    
+    const csv = [
+      headers.join(','),
+      ...rows.map(row => row.map(String).map(escapeCsv).join(',')),
+    ].join('\n');
+    
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+    res.send(csv);
+  } catch (error) {
+    console.error('Export events CSV error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Export dashboards as JSON
+router.get('/dashboards.json', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const dashboards = getDashboardsByTenant(req.user.tenant_id);
+    const dashboardsWithWidgets = dashboards.map((dashboard: Dashboard) => ({
+      ...dashboard,
+      widgets: getWidgetsByDashboard(dashboard.id),
+    }));
+    
+    res.setHeader('Content-Type', 'application/json');
+    res.setHeader('Content-Disposition', 'attachment; filename="dashboards.json"');
+    res.json({ dashboards: dashboardsWithWidgets });
+  } catch (error) {
+    console.error('Export dashboards JSON error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Export single dashboard as JSON
+router.get('/dashboards/:id.json', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { id } = req.params;
+    const dashboard = getDashboardById(id);
+    
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+    
+    if (dashboard.tenant_id !== req.user.tenant_id) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    
+    const widgets = getWidgetsByDashboard(id);
+    
+    res.setHeader('Content-Type', 'application/json');
+    res.setHeader('Content-Disposition', `attachment; filename="dashboard-${id}.json"`);
+    res.json({ dashboard: { ...dashboard, widgets } });
+  } catch (error) {
+    console.error('Export dashboard JSON error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+export default router;
