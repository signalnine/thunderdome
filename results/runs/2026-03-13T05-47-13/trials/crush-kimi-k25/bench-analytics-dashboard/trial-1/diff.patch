+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from './app.js';
+import { closeDb } from './db.js';
+
+describe('Analytics Dashboard API', () => {
+  let app: ReturnType<typeof createApp>;
+  let _authToken: string;
+  let _userId: string;
+  const tenantId = 'test-tenant';
+
+  beforeEach(() => {
+    // Close any existing db and create fresh app for each test
+    try { closeDb(); } catch { /* ignore */ }
+    app = createApp();
+  });
+
+  describe('Health Check', () => {
+    it('should return ok status', async () => {
+      const res = await request(app).get('/health');
+      expect(res.status).toBe(200);
+      expect(res.body).toEqual({ status: 'ok' });
+    });
+  });
+
+  describe('User Management', () => {
+    it('should register a new user', async () => {
+      const res = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'test@example.com', password: 'password123', tenant_id: tenantId });
+      
+      expect(res.status).toBe(201);
+      expect(res.body.user).toBeDefined();
+      expect(res.body.user.email).toBe('test@example.com');
+      expect(res.body.user.tenant_id).toBe(tenantId);
+      expect(res.body.token).toBeDefined();
+      
+      _authToken = res.body.token;
+      _userId = res.body.user.id;
+    });
+
+    it('should login with valid credentials', async () => {
+      // First register
+      await request(app)
+        .post('/api/users/register')
+        .send({ email: 'login@test.com', password: 'password123', tenant_id: tenantId });
+      
+      // Then login
+      const res = await request(app)
+        .post('/api/users/login')
+        .send({ email: 'login@test.com', password: 'password123' });
+      
+      expect(res.status).toBe(200);
+      expect(res.body.user).toBeDefined();
+      expect(res.body.token).toBeDefined();
+    });
+
+    it('should reject login with invalid credentials', async () => {
+      const res = await request(app)
+        .post('/api/users/login')
+        .send({ email: 'nonexistent@test.com', password: 'wrong' });
+      
+      expect(res.status).toBe(401);
+    });
+
+    it('should get user profile with auth', async () => {
+      // Register first
+      const regRes = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'profile@test.com', password: 'password123', tenant_id: tenantId });
+      
+      const token = regRes.body.token;
+      
+      const res = await request(app)
+        .get('/api/users/me')
+        .set('Authorization', `Bearer ${token}`);
+      
+      expect(res.status).toBe(200);
+      expect(res.body.user.email).toBe('profile@test.com');
+    });
+
+    it('should reject profile request without auth', async () => {
+      const res = await request(app).get('/api/users/me');
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe('Data Ingestion', () => {
+    let token: string;
+
+    beforeEach(async () => {
+      const res = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'events@test.com', password: 'password123', tenant_id: tenantId });
+      token = res.body.token;
+    });
+
+    it('should ingest a single event', async () => {
+      const res = await request(app)
+        .post('/api/events')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'page_view', properties: { url: '/home' } });
+      
+      expect(res.status).toBe(201);
+      expect(res.body.id).toBeDefined();
+      expect(res.body.name).toBe('page_view');
+    });
+
+    it('should ingest batch events', async () => {
+      const res = await request(app)
+        .post('/api/events/batch')
+        .set('Authorization', `Bearer ${token}`)
+        .send({
+          events: [
+            { name: 'click', properties: { button: 'signup' } },
+            { name: 'click', properties: { button: 'login' } },
+          ]
+        });
+      
+      expect(res.status).toBe(201);
+      expect(res.body.count).toBe(2);
+      expect(res.body.ids).toHaveLength(2);
+    });
+
+    it('should reject events without auth', async () => {
+      const res = await request(app)
+        .post('/api/events')
+        .send({ name: 'page_view' });
+      
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe('Query Engine', () => {
+    let token: string;
+
+    beforeEach(async () => {
+      const res = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'query@test.com', password: 'password123', tenant_id: tenantId });
+      token = res.body.token;
+      
+      // Add some events
+      await request(app)
+        .post('/api/events/batch')
+        .set('Authorization', `Bearer ${token}`)
+        .send({
+          events: [
+            { name: 'page_view', properties: { url: '/home' } },
+            { name: 'page_view', properties: { url: '/about' } },
+            { name: 'click', properties: { button: 'signup' } },
+          ]
+        });
+    });
+
+    it('should count events', async () => {
+      const res = await request(app)
+        .get('/api/analytics/count?name=page_view')
+        .set('Authorization', `Bearer ${token}`);
+      
+      expect(res.status).toBe(200);
+      expect(res.body.count).toBe(2);
+    });
+
+    it('should get timeseries data', async () => {
+      const res = await request(app)
+        .get('/api/analytics/timeseries?granularity=day')
+        .set('Authorization', `Bearer ${token}`);
+      
+      expect(res.status).toBe(200);
+      expect(res.body.data).toBeDefined();
+      expect(Array.isArray(res.body.data)).toBe(true);
+    });
+
+    it('should get breakdown by property', async () => {
+      const res = await request(app)
+        .get('/api/analytics/breakdown?property=url')
+        .set('Authorization', `Bearer ${token}`);
+      
+      expect(res.status).toBe(200);
+      expect(res.body.data).toBeDefined();
+      expect(Array.isArray(res.body.data)).toBe(true);
+    });
+
+    it('should query raw events', async () => {
+      const res = await request(app)
+        .get('/api/analytics/events')
+        .set('Authorization', `Bearer ${token}`);
+      
+      expect(res.status).toBe(200);
+      expect(res.body.events).toBeDefined();
+      expect(Array.isArray(res.body.events)).toBe(true);
+    });
+  });
+
+  describe('Dashboard Management', () => {
+    let token: string;
+
+    beforeEach(async () => {
+      const res = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'dashboard@test.com', password: 'password123', tenant_id: tenantId });
+      token = res.body.token;
+    });
+
+    it('should create a dashboard', async () => {
+      const res = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'My Dashboard', config: { theme: 'dark' } });
+      
+      expect(res.status).toBe(201);
+      expect(res.body.dashboard).toBeDefined();
+      expect(res.body.dashboard.name).toBe('My Dashboard');
+    });
+
+    it('should list dashboards', async () => {
+      // Create a dashboard first
+      await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Test Dashboard' });
+      
+      const res = await request(app)
+        .get('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`);
+      
+      expect(res.status).toBe(200);
+      expect(res.body.dashboards).toBeDefined();
+      expect(Array.isArray(res.body.dashboards)).toBe(true);
+      expect(res.body.dashboards.length).toBeGreaterThan(0);
+    });
+
+    it('should add widget to dashboard', async () => {
+      // Create dashboard
+      const dashRes = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Widget Dashboard' });
+      
+      const dashboardId = dashRes.body.dashboard.id;
+      
+      // Add widget
+      const res = await request(app)
+        .post(`/api/dashboards/${dashboardId}/widgets`)
+        .set('Authorization', `Bearer ${token}`)
+        .send({ type: 'counter', config: { eventName: 'page_view' } });
+      
+      expect(res.status).toBe(201);
+      expect(res.body.widget).toBeDefined();
+      expect(res.body.widget.type).toBe('counter');
+    });
+  });
+
+  describe('Data Export', () => {
+    let token: string;
+
+    beforeEach(async () => {
+      const res = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'export@test.com', password: 'password123', tenant_id: tenantId });
