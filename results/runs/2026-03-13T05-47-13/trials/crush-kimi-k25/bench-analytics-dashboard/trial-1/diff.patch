+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { join } from 'path';
+import type { User, Event, Dashboard, Widget } from './types.js';
+
+let db: Database.Database | null = null;
+
+export function getDb(): Database.Database {
+  if (!db) {
+    throw new Error('Database not initialized. Call initDb() first.');
+  }
+  return db;
+}
+
+export function initDb(dbPath = ':memory:'): Database.Database {
+  db = new Database(dbPath);
+  db.pragma('journal_mode = WAL');
+  
+  // Load and execute schema
+  const schemaPath = join(process.cwd(), 'schema.sql');
+  const schema = readFileSync(schemaPath, 'utf-8');
+  db.exec(schema);
+  
+  return db;
+}
+
+export function closeDb(): void {
+  if (db) {
+    db.close();
+    db = null;
+  }
+}
+
+// User operations
+export function createUser(user: User): void {
+  const db = getDb();
+  const stmt = db.prepare(`
+    INSERT INTO users (id, email, password_hash, tenant_id, role, created_at)
+    VALUES (?, ?, ?, ?, ?, ?)
+  `);
+  stmt.run(user.id, user.email, user.password_hash, user.tenant_id, user.role, user.created_at);
+}
+
+export function getUserByEmail(email: string): User | undefined {
+  const db = getDb();
+  const stmt = db.prepare('SELECT * FROM users WHERE email = ?');
+  return stmt.get(email) as User | undefined;
+}
+
+export function getUserById(id: string): User | undefined {
+  const db = getDb();
+  const stmt = db.prepare('SELECT * FROM users WHERE id = ?');
+  return stmt.get(id) as User | undefined;
+}
+
+export function getUsersByTenant(tenantId: string): User[] {
+  const db = getDb();
+  const stmt = db.prepare('SELECT * FROM users WHERE tenant_id = ?');
+  return stmt.all(tenantId) as User[];
+}
+
+export function updateUserRole(userId: string, role: string): void {
+  const db = getDb();
+  const stmt = db.prepare('UPDATE users SET role = ? WHERE id = ?');
+  stmt.run(role, userId);
+}
+
+// Event operations
+export function createEvent(event: Event): void {
+  const db = getDb();
+  const stmt = db.prepare(`
+    INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id)
+    VALUES (?, ?, ?, ?, ?, ?, ?)
+  `);
+  stmt.run(
+    event.id,
+    event.tenant_id,
+    event.name,
+    JSON.stringify(event.properties),
+    event.timestamp,
+    event.user_id ?? null,
+    event.session_id ?? null
+  );
+}
+
+export function createEvents(events: Event[]): void {
+  const db = getDb();
+  const stmt = db.prepare(`
+    INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id)
+    VALUES (?, ?, ?, ?, ?, ?, ?)
+  `);
+  
+  const insert = db.transaction((eventsList: Event[]) => {
+    for (const event of eventsList) {
+      stmt.run(
+        event.id,
+        event.tenant_id,
+        event.name,
+        JSON.stringify(event.properties),
+        event.timestamp,
+        event.user_id ?? null,
+        event.session_id ?? null
+      );
+    }
+  });
+  
+  insert(events);
+}
+
+export function getEventsByTenant(tenantId: string, limit = 1000): Event[] {
+  const db = getDb();
+  const stmt = db.prepare(`
+    SELECT * FROM events 
+    WHERE tenant_id = ? 
+    ORDER BY timestamp DESC 
+    LIMIT ?
+  `);
+  const rows = stmt.all(tenantId, limit) as Array<Record<string, unknown>>;
+  return rows.map(row => ({
+    ...row,
+    properties: JSON.parse(row.properties as string)
+  })) as Event[];
+}
+
+export function queryEvents(
+  tenantId: string, 
+  filters: { name?: string; startDate?: string; endDate?: string }
+): Event[] {
+  const db = getDb();
+  let sql = 'SELECT * FROM events WHERE tenant_id = ?';
+  const params: (string | number)[] = [tenantId];
+  
+  if (filters.name) {
+    sql += ' AND name = ?';
+    params.push(filters.name);
+  }
+  if (filters.startDate) {
+    sql += ' AND timestamp >= ?';
+    params.push(filters.startDate);
+  }
+  if (filters.endDate) {
+    sql += ' AND timestamp <= ?';
+    params.push(filters.endDate);
+  }
+  
+  sql += ' ORDER BY timestamp DESC';
+  
+  const stmt = db.prepare(sql);
+  const rows = stmt.all(...params) as Array<Record<string, unknown>>;
+  return rows.map(row => ({
+    ...row,
+    properties: JSON.parse(row.properties as string)
+  })) as Event[];
+}
+
+export function countEvents(
+  tenantId: string,
+  filters: { name?: string; startDate?: string; endDate?: string }
+): number {
+  const db = getDb();
+  let sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+  const params: (string | number)[] = [tenantId];
+  
+  if (filters.name) {
+    sql += ' AND name = ?';
+    params.push(filters.name);
+  }
+  if (filters.startDate) {
+    sql += ' AND timestamp >= ?';
+    params.push(filters.startDate);
+  }
+  if (filters.endDate) {
+    sql += ' AND timestamp <= ?';
+    params.push(filters.endDate);
+  }
+  
+  const stmt = db.prepare(sql);
+  const result = stmt.get(...params) as { count: number };
+  return result.count;
+}
+
+export function getTimeseries(
+  tenantId: string,
+  filters: { name?: string; startDate?: string; endDate?: string },
+  granularity: 'day' | 'hour' | 'month' = 'day'
+): Array<{ bucket: string; count: number }> {
+  const db = getDb();
+  
+  let dateFormat: string;
+  switch (granularity) {
+    case 'hour':
+      dateFormat = "%Y-%m-%d %H:00";
+      break;
+    case 'month':
+      dateFormat = "%Y-%m";
+      break;
+    case 'day':
+    default:
+      dateFormat = "%Y-%m-%d";
+  }
+  
+  let sql = `
+    SELECT strftime(?, timestamp) as bucket, COUNT(*) as count 
+    FROM events 
+    WHERE tenant_id = ?
+  `;
+  const params: (string | number)[] = [dateFormat, tenantId];
+  
+  if (filters.name) {
+    sql += ' AND name = ?';
+    params.push(filters.name);
+  }
+  if (filters.startDate) {
+    sql += ' AND timestamp >= ?';
+    params.push(filters.startDate);
+  }
+  if (filters.endDate) {
+    sql += ' AND timestamp <= ?';
+    params.push(filters.endDate);
+  }
+  
+  sql += ' GROUP BY bucket ORDER BY bucket';
+  
+  const stmt = db.prepare(sql);
+  return stmt.all(...params) as Array<{ bucket: string; count: number }>;
+}
+
+export function getBreakdown(
+  tenantId: string,
+  property: string,
+  filters: { name?: string; startDate?: string; endDate?: string }
+): Array<{ value: string; count: number }> {
+  // First get all matching events
+  const events = queryEvents(tenantId, filters);
+  
+  // Then compute breakdown in memory (SQLite doesn't have good JSON path support for arbitrary keys)
+  const counts = new Map<string, number>();
+  
+  for (const event of events) {
+    const value = event.properties[property];
+    if (value !== undefined) {
+      const key = String(value);
+      counts.set(key, (counts.get(key) || 0) + 1);
+    }
+  }
+  
+  return Array.from(counts.entries())
+    .map(([value, count]) => ({ value, count }))
+    .sort((a, b) => b.count - a.count);
+}
+
+// Dashboard operations
+export function createDashboard(dashboard: Dashboard): void {
+  const db = getDb();
+  const stmt = db.prepare(`
+    INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at)
+    VALUES (?, ?, ?, ?, ?, ?, ?)
+  `);
+  stmt.run(
+    dashboard.id,
+    dashboard.tenant_id,
+    dashboard.name,
+    dashboard.owner_id,
+    JSON.stringify(dashboard.config),
+    dashboard.created_at,
+    dashboard.updated_at
+  );
+}
+
+export function getDashboardById(id: string): Dashboard | undefined {
+  const db = getDb();
+  const stmt = db.prepare('SELECT * FROM dashboards WHERE id = ?');
+  const row = stmt.get(id) as Record<string, unknown> | undefined;
+  if (!row) return undefined;
+  return {
+    ...row,
+    config: JSON.parse(row.config as string)
+  } as Dashboard;
+}
+
+export function getDashboardsByTenant(tenantId: string): Dashboard[] {
+  const db = getDb();
+  const stmt = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC');
+  const rows = stmt.all(tenantId) as Array<Record<string, unknown>>;
+  return rows.map(row => ({
+    ...row,
+    config: JSON.parse(row.config as string)
+  })) as Dashboard[];
+}
+
+export function updateDashboard(id: string, updates: Partial<Dashboard>): void {
+  const db = getDb();
+  const sets: string[] = [];
+  const values: unknown[] = [];
+  
+  if (updates.name !== undefined) {
+    sets.push('name = ?');
+    values.push(updates.name);
+  }
+  if (updates.config !== undefined) {
+    sets.push('config = ?');
+    values.push(JSON.stringify(updates.config));
+  }
+  sets.push('updated_at = ?');
+  values.push(new Date().toISOString());
+  values.push(id);
+  
+  const sql = `UPDATE dashboards SET ${sets.join(', ')} WHERE id = ?`;
+  const stmt = db.prepare(sql);
+  stmt.run(...values);
+}
+
+export function deleteDashboard(id: string): void {
+  const db = getDb();
+  const stmt = db.prepare('DELETE FROM dashboards WHERE id = ?');
+  stmt.run(id);
+}
+
+// Widget operations
+export function createWidget(widget: Widget): void {
+  const db = getDb();
+  const stmt = db.prepare(`
+    INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height)
+    VALUES (?, ?, ?, ?, ?, ?, ?, ?)
+  `);
+  stmt.run(
+    widget.id,
+    widget.dashboard_id,
+    widget.type,
+    JSON.stringify(widget.config),
+    widget.position_x,
+    widget.position_y,
+    widget.width,
+    widget.height
+  );
+}
+
+export function getWidgetsByDashboard(dashboardId: string): Widget[] {
+  const db = getDb();
+  const stmt = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?');
+  const rows = stmt.all(dashboardId) as Array<Record<string, unknown>>;
+  return rows.map(row => ({
+    ...row,
+    config: JSON.parse(row.config as string)
+  })) as Widget[];
+}
+
+export function deleteWidget(id: string): void {
+  const db = getDb();
+  const stmt = db.prepare('DELETE FROM widgets WHERE id = ?');
+  stmt.run(id);
+}
