+import { Router } from 'express';
+import type { Response } from 'express';
+import { createDashboard, getDashboardById, getDashboardsByTenant, updateDashboard, deleteDashboard, createWidget, getWidgetsByDashboard, deleteWidget } from '../db.js';
+import { generateId, authMiddleware, AuthenticatedRequest } from '../auth.js';
+import type { Dashboard, Widget } from '../types.js';
+
+const router = Router();
+
+// List dashboards
+router.get('/', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const dashboards = getDashboardsByTenant(req.user.tenant_id);
+    res.json({ dashboards });
+  } catch (error) {
+    console.error('List dashboards error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Get single dashboard
+router.get('/:id', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { id } = req.params;
+    const dashboard = getDashboardById(id);
+    
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+    
+    if (dashboard.tenant_id !== req.user.tenant_id) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    
+    const widgets = getWidgetsByDashboard(id);
+    
+    res.json({ dashboard: { ...dashboard, widgets } });
+  } catch (error) {
+    console.error('Get dashboard error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Create dashboard
+router.post('/', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { name, config = {} } = req.body;
+    
+    if (!name) {
+      res.status(400).json({ error: 'Dashboard name is required' });
+      return;
+    }
+    
+    const now = new Date().toISOString();
+    const dashboard: Dashboard = {
+      id: generateId(),
+      tenant_id: req.user.tenant_id,
+      name,
+      owner_id: req.user.id,
+      config: config || {},
+      created_at: now,
+      updated_at: now,
+    };
+    
+    createDashboard(dashboard);
+    
+    res.status(201).json({ dashboard });
+  } catch (error) {
+    console.error('Create dashboard error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Update dashboard
+router.patch('/:id', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { id } = req.params;
+    const { name, config } = req.body;
+    
+    const dashboard = getDashboardById(id);
+    
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+    
+    if (dashboard.tenant_id !== req.user.tenant_id) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    
+    // Only admin, editor, or owner can update
+    if (req.user.role === 'viewer' && dashboard.owner_id !== req.user.id) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+    
+    updateDashboard(id, { name, config });
+    
+    const updated = getDashboardById(id)!;
+    res.json({ dashboard: updated });
+  } catch (error) {
+    console.error('Update dashboard error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Delete dashboard
+router.delete('/:id', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { id } = req.params;
+    const dashboard = getDashboardById(id);
+    
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+    
+    if (dashboard.tenant_id !== req.user.tenant_id) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    
+    // Only admin or owner can delete
+    if (req.user.role !== 'admin' && dashboard.owner_id !== req.user.id) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+    
+    deleteDashboard(id);
+    
+    res.status(204).send();
+  } catch (error) {
+    console.error('Delete dashboard error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Add widget to dashboard
+router.post('/:id/widgets', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { id } = req.params;
+    const dashboard = getDashboardById(id);
+    
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+    
+    if (dashboard.tenant_id !== req.user.tenant_id) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    
+    // Only admin, editor, or owner can add widgets
+    if (req.user.role === 'viewer' && dashboard.owner_id !== req.user.id) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+    
+    const { type, config = {}, position_x = 0, position_y = 0, width = 1, height = 1 } = req.body;
+    
+    if (!type || !['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) {
+      res.status(400).json({ error: 'Valid widget type is required (counter, timeseries, breakdown, funnel)' });
+      return;
+    }
+    
+    const widget: Widget = {
+      id: generateId(),
+      dashboard_id: id,
+      type,
+      config: config || {},
+      position_x,
+      position_y,
+      width,
+      height,
+    };
+    
+    createWidget(widget);
+    
+    res.status(201).json({ widget });
+  } catch (error) {
+    console.error('Create widget error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Remove widget from dashboard
+router.delete('/:id/widgets/:widgetId', authMiddleware, (req: AuthenticatedRequest, res: Response) => {
+  try {
+    if (!req.user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    
+    const { id, widgetId } = req.params;
+    const dashboard = getDashboardById(id);
+    
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+    
+    if (dashboard.tenant_id !== req.user.tenant_id) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    
+    // Only admin, editor, or owner can remove widgets
+    if (req.user.role === 'viewer' && dashboard.owner_id !== req.user.id) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+    
+    deleteWidget(widgetId);
+    
+    res.status(204).send();
+  } catch (error) {
+    console.error('Delete widget error:', error);
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+export default router;
