st('all lights off target (no presses needed)', () => {\n    const result = solveToggle({\n      target: [false, false, false],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([]);\n  });\n\n  test('simple solvable case', () => {\n    const result = solveToggle({\n      target: [true, false],\n      buttons: [[0], [1], [0, 1]],\n    });\n    // Button 0 alone works: [true, false]\n    expect(result).toEqual([0]);\n    expect(verifyToggle([true, false], [[0], [1], [0, 1]], result!)).toBe(true);\n  });\n\n  test('requires two buttons', () => {\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0], [1]],\n    });\n    expect(result).toEqual([0, 1]);\n    expect(verifyToggle([true, true], [[0], [1]], result!)).toBe(true);\n  });\n\n  test('minimum presses preferred', () => {\n    // Target: [true, true]\n    // Button 0: [0, 1] (toggles both)\n    // Button 1: [0]\n    // Button 2: [1]\n    // Solution with 1 press: button 0\n    // Solution with 2 presses: buttons 1, 2\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0, 1], [0], [1]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  test('lexicographic tiebreaker', () => {\n    // Target: [true]\n    // Button 0: [0]\n    // Button 1: [0]\n    // Both are solutions with 1 press. Lexicographically, [0] < [1]\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  test('larger system', () => {\n    const result = solveToggle({\n      target: [true, true, true, true, true],\n      buttons: [[0], [1], [2], [3], [4]],\n    });\n    expect(result).toEqual([0, 1, 2, 3, 4]);\n    expect(verifyToggle(\n      [true, true, true, true, true],\n      [[0], [1], [2], [3], [4]],\n      result!\n    )).toBe(true);\n  });\n\n  test('impossible system', () => {\n    const result = solveToggle({\n      target: [true, false],\n      buttons: [[0, 1]],\n    });\n    expect(result).toBeNull();\n  });\n\n  test('empty buttons with non-trivial target', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [],\n    });\n    expect(result).toBeNull();\n  });\n\n  test('empty buttons with all-false target', () => {\n    const result = solveToggle({\n      target: [false, false],\n      buttons: [],\n    });\n    expect(result).toEqual([]);\n  });\n\n  test('20 independent lights and buttons', () => {\n    const n = 20;\n    const target = new Array(n).fill(true);\n    const buttons = Array.from({ length: n }, (_, i) => [i]);\n    const result = solveToggle({ target, buttons });\n    expect(result).not.toBeNull();\n    expect(result!.length).toBe(n);\n    expect(verifyToggle(target, buttons, result!)).toBe(true);\n  });\n\n  test('overlapping buttons choose fewer presses', () => {\n    // 3 lights, target all on\n    // Button 0: [0, 1, 2] - toggles all\n    // Button 1: [0]\n    // Button 2: [1]\n    // Button 3: [2]\n    // Best: button 0 (1 press) vs buttons 1,2,3 (3 presses)\n    const result = solveToggle({\n      target: [true, true, true],\n      buttons: [[0, 1, 2], [0], [1], [2]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  test('performance with 30 buttons', () => {\n    const n = 30;\n    const target: boolean[] = [];\n    const buttons: number[][] = [];\n    // Create a diagonal system for quick solve\n    for (let i = 0; i < n; i++) {\n      target.push(true);\n      buttons.push([i]);\n    }\n    const start = Date.now();\n    const result = solveToggle({ target, buttons });\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).not.toBeNull();\n    expect(verifyToggle(target, buttons, result!)).toBe(true);\n  });\n});\n\ndescribe('solveCounter', () => {\n  test('single counter, single button, mod 2', () => {\n    const result = solveCounter([1], [[0]], 2);\n    expect(result).toEqual([1]);\n  });\n\n  test('all zeros target', () => {\n  