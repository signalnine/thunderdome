;\n   320→\n   321→  if (numFree === 0) {\n   322→    const sol = buildCounterSolution(matrix, pivotCol, freeVars, numButtons, rank, [], modulus);\n   323→    return sol;\n   324→  }\n   325→\n   326→  // Estimate feasibility of direct enumeration\n   327→  const totalCombinations = Math.pow(modulus, numFree);\n   328→  if (totalCombinations <= 10_000_000) {\n   329→    return solveCounterDirect(matrix, pivotCol, freeVars, numButtons, rank, modulus, numFree);\n   330→  }\n   331→  // Fall back to greedy for large free variable sets\n   332→  return solveCounterGreedy(matrix, pivotCol, freeVars, numButtons, rank, modulus);\n   333→}\n   334→\n   335→function modInverse(a: number, p: number): number {\n   336→  return modPow(((a % p) + p) % p, p - 2, p);\n   337→}\n   338→\n   339→function modPow(base: number, exp: number, mod: number): number {\n   340→  let result = 1;\n   341→  base = base % mod;\n   342→  while (exp > 0) {\n   343→    if (exp & 1) result = (result * base) % mod;\n   344→    exp >>= 1;\n   345→    base = (base * base) % mod;\n   346→  }\n   347→  return result;\n   348→}\n   349→\n   350→function buildCounterSolution(\n   351→  matrix: number[][], pivotCol: number[], freeVars: number[],\n   352→  numButtons: number, rank: number, freeValues: number[], modulus: number\n   353→): number[] {\n   354→  const sol = new Array(numButtons).fill(0);\n   355→  for (let fi = 0; fi < freeVars.length; fi++) {\n   356→    sol[freeVars[fi]] = freeValues[fi];\n   357→  }\n   358→  for (let r = rank - 1; r >= 0; r--) {\n   359→    const pc = pivotCol[r];\n   360→    let val = matrix[r][numButtons];\n   361→    for (let col = 0; col < numButtons; col++) {\n   362→      if (col !== pc) {\n   363→        val = (((val - matrix[r][col] * sol[col]) % modulus) + modulus) % modulus;\n   364→      }\n   365→    }\n   366→    sol[pc] = val;\n   367→  }\n   368→  return sol;\n   369→}\n   370→\n   371→function sumArr(a: number[]): number {\n   372→  let s = 0;\n   373→  for (