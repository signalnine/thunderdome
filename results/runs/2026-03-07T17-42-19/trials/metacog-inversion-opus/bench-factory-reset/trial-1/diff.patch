< numLights; row++) {\n      if ((rows[row] >> BigInt(col)) & 1n) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [rows[rank], rows[found]] = [rows[found], rows[rank]];\n\n    // Eliminate this column from all other rows\n    for (let row = 0; row < numLights; row++) {\n      if (row !== rank && ((rows[row] >> BigInt(col)) & 1n)) {\n        rows[row] ^= rows[rank];\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = rank;\n    rank++;\n  }\n\n  // Check for inconsistency: any row with all zero coefficients but nonzero augmented bit\n  for (let row = rank; row < numLights; row++) {\n    if ((rows[row] >> BigInt(numButtons)) & 1n) {\n      return null; // No solution\n    }\n  }\n\n  // Identify free variables (columns that don't have pivots)\n  const freeVars: number[] = [];\n  const isPivot = new Array(numButtons).fill(false);\n  for (const col of pivotCol) {\n    isPivot[col] = true;\n  }\n  for (let col = 0; col < numButtons; col++) {\n    if (!isPivot[col]) {\n      freeVars.push(col);\n    }\n  }\n\n  // Enumerate all 2^freeVars.length combinations to find minimum presses,\n  // then lexicographically smallest\n  const numFree = freeVars.length;\n\n  // For up to ~20 free variables, brute force is feasible (2^20 = 1M).\n  // For more, we need a smarter approach, but with 40 buttons/lights,\n  // rank can be at most 40, so free vars <= 40 - rank.\n  // In worst case, free vars could be large. We'll use a smarter approach\n  // if numFree > 25.\n\n  let bestSolution: number[] | null = null;\n  let bestCount = numButtons + 1;\n\n  if (numFree <= 25) {\n    // Enumerate all free variable assignments\n    const totalCombinations = 1 << numFree;\n\n    for (let mask = 0; mask < totalCombinations; mask++) {\n      const solution = new Array(numButtons).fill(0);\n\n      // Set free variables\n      for (let fi = 0; fi < numFree; fi++) {\n        if (mask & (1 << fi)) {\n          solution[freeVars[fi]] = 1;\n        }\n      }\n\n      // Compute pivot variables from the reduced row echelon form\n      for (let r = rank - 1; r >= 0; r--) {\n        const pc = pivotCol[r];\n        let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n        // XOR with all other set variables in this row\n        for (let col = 0; col < numButtons; col++) {\n          if (col !== pc && solution[col] === 1 && ((rows[r] >> BigInt(col)) & 1n)) {\n            val ^= 1;\n          }\n        }\n        solution[pc] = val;\n      }\n\n      // Count presses\n      let count = 0;\n      for (let j = 0; j < numButtons; j++) {\n        count += solution[j];\n      }\n\n      if (count < bestCount) {\n        bestCount = count;\n        bestSolution = solution;\n      } else if (count === bestCount && bestSolution !== null) {\n        // Lexicographic comparison: prefer the one with smaller indices pressed\n        // Build the pressed arrays and compare\n        const current: number[] = [];\n        const best: number[] = [];\n        for (let j = 0; j < numButtons; j++) {\n          if (solution[j]) current.push(j);\n          if (bestSolution[j]) best.push(j);\n        }\n        if (lexSmaller(current, best)) {\n          bestSolution = solution;\n        }\n      }\n    }\n  } else {\n    // For large free variable sets, use a greedy/heuristic approach.\n    // However, with up to 40 buttons and 40 lights, rank is at most 40,\n    // so numFree = numButtons - rank. If numButtons = 40 and rank = 0,\n    // numFree = 40 which is too large for brute force.\n    // We need a meet-in-the-middle approach for this case.\n    bestSolution = solveToggleLargeFree(rows, pivotCol, pivotRow, freeVars, numButtons, rank);\n    if (bestSolution === null) {\n      // Shouldn't happen if we got past consistency check\n      return null;\n    }\n  }\n\n  if (bestSolution === null) return null;\n\n  const result: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (bestSolution[j]) result.push(j);\n  }\n  return result;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  const len = Math.min(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return a.length < b.length;\n}\n\n/**\n * Meet-in-the-middle approach for large free variable sets.\n * Split free variables into two halves, enumerate each, and combine.\n */\nfunction solveToggleLargeFree(\n  rows: bigint[],\n  pivotCol: number[],\n  _pivotRow: number[],\n  freeVars: number[],\n  numButtons: number,\n  rank: number\n): number[] | null {\n  const numFree = freeVars.length;\n  const halfA = Math.min(Math.floor(numFree / 2), 20);\n  const halfB = numFree - halfA;\n\n  if (halfB > 20) {\n    // Even meet-in-the-middle won't work for 40+ free vars\n    // Fall back to trying all-zeros for free vars (minimum solution without free vars)\n    return computeSolutionFromFreeAssignment(rows, pivotCol, freeVars, numButtons, rank, new Array(numFree).fill(0));\n  }\n\n  // For each half-A assignment, compute the effect on pivot variables\n  // and store in a map: pivotEffect -> (bestCount, bestAssignment)\n  const mapA = new Map<string, { count: number; freeAssign: number[]; pivotVals: number[] }>();\n\n  const combA = 1 << halfA;\n  for (let maskA = 0; maskA < combA; maskA++) {\n    const freeAssign = new Array(numFree).fill(0);\n    for (let i = 0; i < halfA; i++) {\n      if (maskA & (1 << i)) freeAssign[i] = 1;\n    }\n\n    // Compute partial pivot values from the A-half free vars\n    const partialPivot = new Array(rank).fill(0);\n    for (let r = 0; r < rank; r++) {\n      for (let fi = 0; fi < halfA; fi++) {\n        if (freeAssign[fi] && ((rows[r] >> BigInt(freeVars[fi])) & 1n)) {\n          partialPivot[r] ^= 1;\n        }\n      }\n    }\n\n    let freeCount = 0;\n    for (let i = 0; i < halfA; i++) {\n      freeCount += freeAssign[i];\n    }\n\n    const key = partialPivot.join(',');\n    const existing = mapA.get(key);\n    if (!existing || freeCount < existing.count) {\n      mapA.set(key, { count: freeCount, freeAssign: freeAssign.slice(), pivotVals: partialPivot });\n    }\n  }\n\n  let bestSolution: number[] | null = null;\n  let bestCount = numButtons + 1;\n\n  const combB = 1 << halfB;\n  for (let maskB = 0; maskB < combB; maskB++) {\n    const freeAssign = new Array(numFree).fill(0);\n    for (let i = 0; i < halfB; i++) {\n      if (maskB & (1 << i)) freeAssign[halfA + i] = 1;\n    }\n\n    // Compute partial pivot values from B-half\n    const partialPivotB = new Array(rank).fill(0);\n    for (let r = 0; r < rank; r++) {\n      let val = Number((rows[r] >> BigInt(numButtons)) & 1n); // RHS\n      for (let fi = halfA; fi < numFree; fi++) {\n        if (freeAssign[fi] && ((rows[r] >> BigInt(freeVars[fi])) & 1n)) {\n          val ^= 1;\n        }\n      }\n      partialPivotB[r] = val;\n    }\n\n    // We need partialPivotA XOR partialPivotB to give us the pivot values\n    // pivot[r] = RHS[r] XOR (sum of free vars affecting row r)\n    // = partialPivotB[r] XOR partialPivotA[r]\n    // And the count is the sum of all 1s in the solution.\n\n    // Actually, let's just iterate over mapA entries\n    // For each B assignment, we need to find the A assignment such that:\n    // pivot[r] = RHS[r] XOR freeA_effect[r] XOR freeB_effect[r]\n    // And we want to minimize total count.\n\n    // The key we stored for A is just the partial effect of A on pivots.\n    // We need the full solution: pivot[r] = RHS XOR effectA XOR effectB\n    // Count = freeAcount + freeBcount + sum(pivot values)\n\n    // This is complex. Let's simplify: just enumerate all combB and for each,\n    // compute the full solution directly.\n\n    // Try all A combinations (but we cached them)\n    for (let maskA2 = 0; maskA2 < combA; maskA2++) {\n      const fullAssign = freeAssign.slice();\n      for (let i = 0; i < halfA; i++) {\n        if (maskA2 & (1 << i)) {\n          fullAssign[i] = 1;\n        }\n      }\n\n      const sol = computeSolutionFromFreeAssignment(rows, pivotCol, freeVars, numButtons, rank, fullAssign);\n      if (sol === null) continue;\n\n      let count = 0;\n      for (let j = 0; j < numButtons; j++) count += sol[j];\n\n      if (count < bestCount || (count === bestCount && bestSolution !== null && lexSmallerSol(sol, bestSolution, numButtons))) {\n        bestCount = count;\n        bestSolution = sol;\n      }\n    }\n  }\n\n  return bestSolution;\n}\n\nfunction computeSolutionFromFreeAssignment(\n  rows: bigint[],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  rank: number,\n  freeAssign: number[]\n): number[] {\n  const solution = new Array(numButtons).fill(0);\n\n  for (let fi = 0; fi < freeVars.length; fi++) {\n    solution[freeVars[fi]] = freeAssign[fi];\n  }\n\n  for (let r = rank - 1; r >= 0; r--) {\n    const pc = pivotCol[r];\n    let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n    for (let col = 0; col < numButtons; col++) {\n      if (col !== pc && solution[col] === 1 && ((rows[r] >> BigInt(col)) & 1n)) {\n        val ^= 1;\n      }\n    }\n    solution[pc] = val;\n  }\n\n  return solution;\n}\n\nfunction lexSmallerSol(a: number[], b: number[], n: number): boolean {\n  const aa: number[] = [];\n  const bb: number[] = [];\n  for (let j = 0; j < n; j++) {\n    if (a[j]) aa.push(j);\n    if (b[j]) bb.push(j);\n  }\n  return lexSmaller(aa, bb);\n}\n\n\n/**\n * Solve the counter puzzle using Gaussian elimination over GF(p).\n *\n * We model as: for each counter i:\n *   sum of x_j for buttons j affecting counter i ≡ target[i] (mod p)\n *\n * Where x_j ∈ {0, ..., p-1} is the number of times button j is pressed.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix over GF(p)\n  // Each row has numButtons coefficient columns + 1 augmented column\n  const matrix: number[][] = [];\n\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n\n  for (let j = 0; j < numButtons; j++) {\n    for (const counterIdx of buttons[j]) {\n      if (counterIdx < numCounters) {\n        matrix[counterIdx][j] = (matrix[counterIdx][j] + 1) % modulus;\n      }\n    }\n  }\n\n  // Compute modular inverse using Fermat's little theorem (p is prime)\n  function modInverse(a: number, p: number): number {\n    return modPow(((a % p) + p) % p, p - 2, p);\n  }\n\n  function modPow(base: number, exp: number, mod: number): number {\n    let result = 1;\n    base = base % mod;\n    while (exp > 0) {\n      if (exp & 1) result = (result * base) % mod;\n      exp >>= 1;\n      base = (base * base) % mod;\n    }\n    return result;\n  }\n\n  // Gaussian elimination over GF(p)\n  const pivotCol: number[] = [];\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    // Find pivot row\n    let found = -1;\n    for (let row = rank; row < numCounters; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n\n    // Scale pivot row so pivot element = 1\n    const inv = modInverse(matrix[rank][col], modulus);\n    for (let c = 0; c <= numButtons; c++) {\n      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;\n    }\n\n    // Eliminate this column from all other rows\n    for (let row = 0; row < numCounters; row++) {\n      if (row !== rank && matrix[row][col] !== 0) {\n        const factor = matrix[row][col];\n        for (let c = 0; c <= numButtons; c++) {\n          matrix[row][c] = (((matrix[row][c] - factor * matrix[rank][c]) % modulus) + modulus) % modulus;\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    rank++;\n  }\n\n  // Check for inconsistency\n  for (let row = rank; row < numCounters; row++) {\n    if (matrix[row][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const isPivot = new Array(numButtons).fill(false);\n  for (const col of pivotCol) {\n    isPivot[col] = true;\n  }\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (!isPivot[col]) freeVars.push(col);\n  }\n\n  const numFree = freeVars.length;\n\n  // For counter puzzle, we need to enumerate p^numFree combinations.\n  // With p up to 97 and potentially many free vars, this could be huge.\n  // For small numFree, brute force. For larger, we need meet-in-the-middle or other.\n\n  // Estimate feasibility\n  const totalCombinations = Math.pow(modulus, numFree);\n\n  if (numFree === 0 || totalCombinations <= 5_000_000) {\n    // Direct enumeration\n    let bestSolution: number[] | null = null;\n    let bestTotal = Infinity;\n\n    const freeValues = new Array(numFree).fill(0);\n\n    let done = false;\n    while (!done) {\n      const sol = computeCounterSolution(matrix, pivotCol, freeVars, numButtons, rank, freeValues, modulus);\n      let total = 0;\n      for (let j = 0; j < numButtons; j++) total += sol[j];\n\n      if (total < bestTotal || (total === bestTotal && bestSolution !== null && lexSmallerArr(sol, bestSolution))) {\n        bestTotal = total;\n        bestSolution = sol.slice();\n      }\n\n      // Increment freeValues (odometer style)\n      let carry = true;\n      for (let fi = numFree - 1; fi >= 0 && carry; fi--) {\n        freeValues[fi]++;\n        if (freeValues[fi] >= modulus) {\n          freeValues[fi] = 0;\n        } else {\n          carry = false;\n        }\n      }\n      if (carry) done = true;\n    }\n    return bestSolution;\n  } else {\n    // Meet-in-the-middle for larger free variable sets\n    return solveCounterMITM(matrix, pivotCol, freeVars, numButtons, rank, modulus);\n  }\n}\n\nfunction computeCounterSolution(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  rank: number,\n  freeValues: number[],\n  modulus: number\n): number[] {\n  const solution = new Array(numButtons).fill(0);\n\n  for (let fi = 0; fi < freeVars.length; fi++) {\n    solution[freeVars[fi]] = freeValues[fi];\n  }\n\n  for (let r = rank - 1; r >= 0; r--) {\n    const pc = pivotCol[r];\n    let val = matrix[r][numButtons]; // RHS\n    for (let col = 0; col < numButtons; col++) {\n      if (col !== pc) {\n        val = (((val - matrix[r][col] * solution[col]) % modulus) + modulus) % modulus;\n      }\n    }\n    solution[pc] = val;\n  }\n\n  return solution;\n}\n\nfunction lexSmallerArr(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\n/**\n * Meet-in-the-middle for counter puzzle with many free variables.\n */\nfunction solveCounterMITM(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  rank: number,\n  modulus: number\n): number[] | null {\n  const numFree = freeVars.length;\n  const halfA = Math.floor(numFree / 2);\n  // const halfB = numFree - halfA; // unused\n\n  // For each assignment of first-half free vars, compute the \"effect\" on pivot vars\n  // Effect = the partial sum contribution from first-half free vars\n  // Store: effectKey -> best (freeValues, count)\n\n  type MapEntry = { freeValues: number[]; count: number };\n  const mapA = new Map<string, MapEntry[]>();\n\n  const combA = Math.pow(modulus, halfA);\n  const freeValuesA = new Array(halfA).fill(0);\n\n  for (let iter = 0; iter < combA; iter++) {\n    // Compute effect of A-half on pivots\n    const effect = new Array(rank).fill(0);\n    let countA = 0;\n    for (let fi = 0; fi < halfA; fi++) {\n      countA += freeValuesA[fi];\n      for (let r = 0; r < rank; r++) {\n 