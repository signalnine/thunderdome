ions: (1,0) total=1, (0,1) total=1, (2,4) total=6, etc.\n    // Min total = 1, lex smallest = [0, 1]\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).not.toBeNull();\n    expect(verifyCounter([1], [[0], [0]], result!, 5)).toBe(true);\n    const total = result!.reduce((a, b) => a + b, 0);\n    expect(total).toBe(1);\n    // Lex smallest with total 1: [0, 1] because it has 0 first\n    expect(result).toEqual([0, 1]);\n  });\n\n  test('mod 7 system', () => {\n    const result = solveCounter([3, 5], [[0], [1]], 7);\n    expect(result).toEqual([3, 5]);\n    expect(verifyCounter([3, 5], [[0], [1]], result!, 7)).toBe(true);\n  });\n});\n","numLines":176,"startLine":1,"totalLines":176}}}
