);\n    expect(result).toEqual([0]);\n  });\n\n  test('all lights off target (no presses needed)', () => {\n    const result = solveToggle({\n      target: [false, false, false],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([]);\n  });\n\n  test('simple solvable case', () => {\n    const result = solveToggle({\n      target: [true, false],\n      buttons: [[0], [1], [0, 1]],\n    });\n    // Button 0 alone works: [true, false]\n    expect(result).toEqual([0]);\n    expect(verifyToggle([true, false], [[0], [1], [0, 1]], result!)).toBe(true);\n  });\n\n  test('requires two buttons', () => {\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0], [1]],\n    });\n    expect(result).toEqual([0, 1]);\n    expect(verifyToggle([true, true], [[0], [1]], result!)).toBe(true);\n  });\n\n  test('minimum presses preferred', () => {\n    // Target: [true, true]\n    // Button 0: [0, 1] (toggles both)\n    // Button 1: [0]\n    // Button 2: [1]\n    // Solution with 1 press: button 0\n    // Solution with 2 presses: buttons 1, 2\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0, 1], [0], [1]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  test('lexicographic tiebreaker', () => {\n    // Target: [true]\n    // Button 0: [0]\n    // Button 1: [0]\n    // Both are solutions with 1 press. Lexicographically, [0] < [1]\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  test('larger system', () => {\n    const result = solveToggle({\n      target: [true, true, true, true, true],\n      buttons: [[0], [1], [2], [3], [4]],\n    });\n    expect(result).toEqual([0, 1, 2, 3, 4]);\n    expect(verifyToggle(\n      [true, true, true, true, true],\n      [[0], [1], [2], [3], [4]],\n      result!\n    )).toBe(true);\n  });\n\n  test('impossible system', () => {\n    // Two buttons toggle the same light. Target: light on.\n    // Pressing both cancels out. Pressing one works.\n    // Actually this IS solvable. Let me make a truly impossible one.\n    // Light 0 and light 1 always toggled together. Target: [true, false]\n    const result = solveToggle({\n      target: [true, false],\n      buttons: [[0, 1]],\n    });\n    expect(result).toBeNull();\n  });\n});\n\ndescribe('solveCounter', () => {\n  test('single counter, single button, mod 2', () => {\n    const result = solveCounter([1], [[0]], 2);\n    expect(result).toEqual([1]);\n  });\n\n  test('all zeros target', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 3);\n    expect(result).toEqual([0, 0]);\n  });\n\n  test('simple mod 3', () => {\n    const result = solveCounter([2], [[0]], 3);\n    expect(result).toEqual([2]);\n    expect(verifyCounter([2], [[0]], result!, 3)).toBe(true);\n  });\n\n  test('two counters, two buttons, mod 5', () => {\n    // Counter 0 affected by button 0\n    // Counter 1 affected by button 1\n    // Target: [3, 4]\n    const result = solveCounter([3, 4], [[0], [1]], 5);\n    expect(result).toEqual([3, 4]);\n    expect(verifyCounter([3, 4], [[0], [1]], result!, 5)).toBe(true);\n  });\n\n  test('impossible counter system', () => {\n    // Button 0 affects both counters. Target: [1, 2] with mod 3\n    // We need x0 ≡ 1 (mod 3) and x0 ≡ 2 (mod 3) - impossible\n    const result = solveCounter([1, 2], [[0, 1]], 3);\n    expect(result).toBeNull();\n  });\n\n  test('minimum total presses', () => {\n    // Counter 0 affected by buttons 0 and 1\n    // Target: [1], mod 5\n    // Button 0 presses x0, button 1 presses x1\n    // x0 + x1 ≡ 1 (mod 5)\n    // Solutions: (1,0) total=1, (0,1) total=1, (2,4) total=6, etc.\n    // Min total = 1, lex smallest = [0, 1]\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).not.toBeNull();\n    expect(verifyCounter([1], [[0], [0]], result!, 5)).toBe(true);\n    const total = result!.reduce((a, b) => a + b, 0);\n    expect(total).toBe(1);\n    // Lex smallest with total 1: [0, 1] because it has 0 first\n    expect(result).toEqual([0, 1]);\n  });\n\n  test('mod 7 system', () => {\n    const result = solveCounter([3, 5], [[0], [1]], 7);\n    expect(result).toEqual([3, 5]);\n    expect(verifyCounter([3, 5], [[0], [1]], result!, 7)).toBe(true);\n  });\n});\n","structuredPatch":[{"oldStart":106,"oldLines":16,"newStart":106,"newLines":69,"lines":["   });"," ","   test('impossible system', () => {","-    // Two buttons toggle the same light. Target: light on.","-    // Pressing both cancels out. Pressing one works.","-    // Actually this IS solvable. Let me make a truly impossible one.","-    // Light 0 and light 1 always toggled together. Target: [true, false]","     const result = solveToggle({","       target: [true, false],","       buttons: [[0, 1]],","     });","     expect(result).toBeNull();","   });","+","+  test('empty buttons with non-trivial target', () => {","+    const result = solveToggle({","+      target: [true],","+      buttons: [],","+    });","+    expect(result).toBeNull();","+  });","+","+  test('empty buttons with all-false target', () => {","+    const result = solveToggle({","+      target: [false, false],","+      buttons: [],","+    });","+    expect(result).toEqual([]);","+  });","+","+  test('20 independent lights and buttons', () => {","+    const n = 20;","+    const target = new Array(n).fill(true);","+    const buttons = Array.from({ length: n }, (_, i) => [i]);","+    const result = solveToggle({ target, buttons });","+    expect(result).not.toBeNull();","+    expect(result!.length).toBe(n);","+    expect(verifyToggle(target, buttons, result!)).toBe(true);","+  });","+","+  test('overlapping buttons choose fewer presses', () => {","+    // 3 lights, target all on","+    // Button 0: [0, 1, 2] - toggles all","+    // Button 1: [0]","+    // Button 2: [1]","+    // Button 3: [2]","+    // Best: button 0 (1 press) vs buttons 1,2,3 (3 presses)","+    const result