1→  numButtons: number,\n   202→  rank: number\n   203→): number[] | null {\n   204→  const numFree = freeVars.length;\n   205→  const halfA = Math.min(Math.floor(numFree / 2), 20);\n   206→  const halfB = numFree - halfA;\n   207→\n   208→  if (halfB > 20) {\n   209→    // Even meet-in-the-middle won't work for 40+ free vars\n   210→    // Fall back to trying all-zeros for free vars (minimum solution without free vars)\n   211→    return computeSolutionFromFreeAssignment(rows, pivotCol, freeVars, numButtons, rank, new Array(numFree).fill(0));\n   212→  }\n   213→\n   214→  // For each half-A assignment, compute the effect on pivot variables\n   215→  // and store in a map: pivotEffect -> (bestCount, bestAssignment)\n   216→  const mapA = new Map<string, { count: number; freeAssign: number[]; pivotVals: number[] }>();\n   217→\n   218→  const combA = 1 << halfA;\n   219→  for (let maskA = 0; maskA < combA; maskA++) {\n   220→    const freeAssign = new Array(numFree).fill(0);\n   221→    for (let i = 0; i < halfA; i++) {\n   222→      if (maskA & (1 << i)) freeAssign[i] = 1;\n   223→    }\n   224→\n   225→    // Compute partial pivot values from the A-half free vars\n   226→    const partialPivot = new Array(rank).fill(0);\n   227→    for (let r = 0; r < rank; r++) {\n   228→      for (let fi = 0; fi < halfA; fi++) {\n   229→        if (freeAssign[fi] && ((rows[r] >> BigInt(freeVars[fi])) & 1n)) {\n   230→          partialPivot[r] ^= 1;\n   231→        }\n   232→      }\n   233→    }\n   234→\n   235→    let freeCount = 0;\n   236→    for (let i = 0; i < halfA; i++) {\n   237→      freeCount += freeAssign[i];\n   238→    }\n   239→\n   240→    const key = partialPivot.join(',');\n   241→    const existing = mapA.get(key);\n   242→    if (!existing || freeCount < existing.count) {\n   243→      mapA.set(key, { count: freeCount, freeAssign: freeAssign.slice(), pivotVals: partialPivot });\n   244→    }\n   245→  }\n   246→\n   247→  let bestSolution: number[] | null = null;\n   248→  let bestCount = numButtons + 1;\n   249→\n   250→  const combB = 1 << halfB;\n   251→  for (let maskB = 0; maskB < combB; maskB++) {\n   252→    const freeAssign = new Array(numFree).fill(0);\n   253→    for (let i = 0; i < halfB; i++) {\n   254→      if (maskB & (1 << i)) freeAssign[halfA + i] = 1;\n   255→    }\n   256→\n   257→    // Compute partial pivot values from B-half\n   258→    const partialPivotB = new Array(rank).fill(0);\n   259→    for (let r = 0; r < rank; r++) {\n   260→      let val = Number((rows[r] >> BigInt(numButtons)) & 1n); // RHS\n   261→      for (let fi = halfA; fi < numFree; fi++) {\n   262→        if (freeAssign[fi] && ((rows[r] >> BigInt(freeVars[fi])) & 1n)) {\n   263→          val ^= 1;\n   264→        }\n   265→      }\n   266→      partialPivotB[r] = val;\n   267→    }\n   268→\n   269→    // We need partialPivotA XOR partialPivotB to give us the pivot values\n   270→    // pivot[r] = RHS[r] XOR (sum of free vars affecting row r)\n   271→    // = partialPivotB[r] XOR partialPivotA[r]\n   272→    // And the count is the sum of all 1s in the solution.\n   273→\n   274→    // Actually, let's just iterate over mapA entries\n   275→    // For each B assignment, we need to find the A assignment such that:\n   276→    // pivot[r] = RHS[r] XOR freeA_effect[r] XOR freeB_effect[r]\n   277→    // And we want to minimize total count.\n   278→\n   279→    // The key we stored for A is just the partial effect of A on pivots.\n   280→    // We need the full solution: pivot[r] = RHS XOR effectA XOR effectB\n   281→    // Count = freeAcount + freeBcount + sum(pivot values)\n   282→\n   283→    // This is complex. Let's simplify: just enumerate all combB and for each,\n   284→    // compute the full solution directly.\n   285→\n   286→    // Try all A combinations (but we cached them)\n   287→    for (let maskA2 = 0; maskA2 < combA; maskA2++) {\n   288→      const fullAssign = freeAssign.slice();\n   289→      for (let i = 0; i < halfA; i++) {\n   290→        if (maskA2 & (1 << i)) {\n   291→          fullAssign[i] = 1;\n   292→        }\n   293→      }\n   294→\n   295→      const sol = computeSolutionFromFreeAssignment(rows, pivotCol, freeVars, numButtons, rank, fullAssign);\n   296→      if (sol === null) continue;\n   297→\n   298→      let count = 0;\n   299→      for (let j = 0; j < numButtons; j++) count += sol[j];\n   300→\n   301→      if (count < bestCount || (count === bestCount && bestSolution !== null && lexSmallerSol(sol, bestSolution, numButtons))) {\n   302→        bestCount = count;\n   303→        bestSolution = sol;\n   304→      }\n   305→    }\n   306→  }\n   307→\n   308→  return bestSolution;\n   309→}\n   310→\n   311→function computeSolutionFromFreeAssignment(\n   312→  rows: bigint[],\n   313→  pivotCol: number[],\n   314→  freeVars: number[],\n   315→  numButtons: number,\n   316→  rank: number,\n   317→  freeAssign: number[]\n   318→): number[] {\n   319→  const solution = new Array(numButtons).fill(0);\n   320→\n   321→  for (let fi = 0; fi < freeVars.length; fi++) {\n   322→    solution[freeVars[fi]] = freeAssign[fi];\n   323→  }\n   324→\n   325→  for (let r = rank - 1; r >= 0; r--) {\n   326→    const pc = pivotCol[r];\n   327→    let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n   328→    for (let col = 0; col < numButtons; col++) {\n   329→      if (col !== pc && solution[col] === 1 && ((rows[r] >> BigInt(col)) & 1n)) {\n   330→        val ^= 1;\n   331→      }\n   332→    }\n   333→    solution[pc] = val;\n   334→  }\n   335→\n   336→  return solution;\n   337→}\n   338→\n   339→function lexSmallerSol(a: number[], b: number[], n: number): boolean {\n   340→  const aa: number[] = [];\n   341→  const bb: number[] = [];\n   342→  for (let j = 0; j < n; j++) {\n   343→    if (a[j]) aa.push(j);\n   344→    if (b[j]) bb.push(j);\n   345→  }\n   346→  return lexSmaller(aa, bb);\n   347→}\n   348→\n   349→\n   350→/**\n   351→ * Solve the counter puzzle using Ga