nd = -1;\n   407→    for (let row = rank; row < numCounters; row++) {\n   408→      if (matrix[row][col] !== 0) {\n   409→        found = row;\n   410→        break;\n   411→      }\n   412→    }\n   413→    if (found === -1) continue;\n   414→\n   415→    // Swap rows\n   416→    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n   417→\n   418→    // Scale pivot row so pivot element = 1\n   419→    const inv = modInverse(matrix[rank][col], modulus);\n   420→    for (let c = 0; c <= numButtons; c++) {\n   421→      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;\n   422→    }\n   423→\n   424→    // Eliminate this column from all other rows\n   425→    for (let row = 0; row < numCounters; row++) {\n   426→      if (row !== rank && matrix[row][col] !== 0) {\n   427→        const factor = matrix[row][col];\n   428→        for (let c = 0; c <= numButtons; c++) {\n   429→          matrix[row][c] = (((matrix[row][c] - factor * matrix[rank][c]) % modulus) + modulus) % modulus;\n   430→        }\n   431→      }\n   432→    }\n   433→\n   434→    pivotCol.push(col);\n   435→    rank++;\n   436→  }\n   437→\n   438→  // Check for inconsistency\n   439→  for (let row = rank; row < numCounters; row++) {\n   440→    if (matrix[row][numButtons] !== 0) {\n   441→      return null;\n   442→    }\n   443→  }\n   444→\n   445→  // Identify free variables\n   446→  const isPivot = new Array(numButtons).fill(false);\n   447→  for (const col of pivotCol) {\n   448→    isPivot[col] = true;\n   449→  }\n   450→  const freeVars: number[] = [];\n   451→  for (let col = 0; col < numButtons; col++) {\n   452→    if (!isPivot[col]) freeVars.push(col);\n   453→  }\n   454→\n   455→  const numFree = freeVars.length;\n   456→\n   457→  // For counter puzzle, we need to enumerate p^numFree combinations.\n   458→  // With p up to 97 and potentially many free vars, this could be huge.\n   459→  // For small numFree, brute force. For larger, we need meet-in-the-middle or other.\n   460→\n   461→  // Estimate feasibility\n   462→  const totalCombinations = Math.pow(modulus, numFree);\n   463→\n   464→  if (numFree === 0 || totalCombinations <= 5_000_000) {\n   465→    // Direct enumeration\n   466→    let bestSolution: number[] | null = null;\n   467→    let bestTotal = Infinity;\n   468→\n   469→    const freeValues = new Array(numFree).fill(0);\n   470→\n   471→    let done = false;\n   472→    while (!done) {\n   473→      const sol = computeCounterSolution(matrix, pivotCol, freeVars, numButtons, rank, freeValues, modulus);\n   474→      let total = 0;\n   475→      for (let j = 0; j < numButtons; j++) total += sol[j];\n   476→\n   477→      if (total < bestTotal || (total === bestTotal && bestSolution !== null && lexSmallerArr(sol, bestSolution))) {\n   478→        bestTotal = total;\n   479→        bestSolution = sol.slice();\n   480→      }\n   481→\n   482→      // Increment freeValues (odometer style)\n   483→      let carry = true;\n   484→      for (let fi = numFree - 1; fi >= 0 && carry; fi--) {\n   485→        freeValues[fi]++;\n   486→        if (freeValues[fi] >= modulus) {\n   487→          freeValues[fi] = 0;\n   488→        } else {\n   489→          carry = false;\n   490→        }\n   491→      }\n   492→      if (carry) done = true;\n   493→    }\n   494→    return bestSolution;\n   495→  } else {\n   496→    // Meet-in-the-middle for larger free variable sets\n   497→    return solveCounterMITM(matrix, pivotCol, freeVars, numButtons, rank, modulus);\n   498→  }\n   499→}\n   500→\n   501→function computeCounterSolution(\n   502→  matrix: number[][],\n   503→  pivotCol: number[],\n   504→  freeVars: number[],\n   505→  numButtons: number,\n   506→  rank: number,\n   507→  freeValues: number[],\n   508→  modulus: number\n   509→): number[] {\n   510→  const solution = new Array(numButtons).fill(0);\n   511→\n   512→  for (let fi = 0; fi < freeVars.length; fi++) {\n   513→    solution[freeVars[fi]] = freeValues[fi];\n   514→  }\n   515→\n   516→  for (let r = rank - 1; r >= 0; r--) {\n   517→    const pc = pivotCol[r];\n   518→    let val = matrix[r][numButtons]; // RHS\n   519→    for (let col = 0; col < numButtons; col++) {\n   520→      if (col !== pc) {\n   521→        val = (((val - matrix[r][col] * solution[col]) % modulus) + modulus) % modulus;\n   522→      }\n   523→    }\n   524→    solution[pc] = val;\n   525→  }\n   526→\n   527→  return solution;\n   528→}\n   529→\n   530→function lexSmallerArr(a: number[], b: number[]): boolean {\n   531→  for (let i = 0; i < a.length; i++) {\n   532→    if (a[i] < b[i]) return true;\n   533→    if (a[i] > b[i]) return false;\n   534→  }\n   535→  return false;\n   536→}\n   537→\n   538→/**\n   539→ * Meet-in-the-middle for counter puzzle with many free variables.\n   540→ */\n   541→function solveCounterMITM(\n   542→  matrix: number[][],\n   543→  pivotCol: number[],\n   544→  freeVars: number[],\n   545→  numButtons: number,\n   546→  rank: number,\n   547→  modulus: number\n   548→): number[] | null {\n   549→  const numFree = freeVars.length;\n   550→  const halfA = Math.floor(numFree / 2);\n   551→  // const halfB = numFree - halfA; // unused\n   552→\n   553→  // For each assignment of first-half free vars, compute the \"effect\" on pivot vars\n   554→  // Effect = the partial sum contribution from first-half free vars\n   555→  // Store: effectKey -> best (freeValues, count)\n   556→\n   557→  type MapEntry = { freeValues: number[]; count: number };\n   558→  const mapA = new Map<string, MapEntry[]>();\n   559→\n   560→  const combA = Math.pow(modulus, halfA);\n   561→  const freeValuesA = new Array(halfA).fill(0);\n   562→\n   563→  for (let iter = 0; iter < combA; iter++) {\n   564→    // Compute effect of A-half on pivots\n   565→    const effect = new Array(rank).fill(0);\n   566→    let countA = 0;\n   567→    for (let fi = 0; fi < halfA; fi++) {\n   568→      countA += freeValuesA[fi];\n   569→      for (let r = 0; r < rank; r++) {\n   570→        effect[r] = (effect[r] + matrix[r][freeVars[fi]] * freeValuesA[fi]) % modulus;\n   571→      }\n   572→    }\n   573→\n   574→    const key = effect.join(',');\n   575→    const entry: MapEntry = { freeValues: freeValuesA.slice(), count: countA };\n   576→    const existing = mapA.get(key);\n   577→    if (existing) {\n   578→      existing.push(entry);\n   579→    } else {\n   580→      mapA.set(key, [entry]);\n   581→    }\n   582→\n   583→    // Increment\n   584→    for (let fi = halfA - 1; fi >= 0; fi--) {\n   585→      freeValuesA[fi]++;\n   586→      if (freeValuesA[fi] >= modulus) {\n   587→        freeValuesA[fi] = 0;\n   588→      } else {\n   589→        break;\n   590→      }\n   591→    }\n   592→  }\n   593→\n   594→  // For each assignment of second-half free vars, compute the \"needed\" effect\n   595→  // and look up in the map\n   596→  const halfB = numFree - halfA;\n   597→  const combB = Math.pow(modulus, halfB);\n   598→  const freeValuesB = new Array(halfB).fill(0);\n   599→\n   600→  let bestSolution: number[] | null = null;\n   601→  let bestTotal = Infinity;\n   602→\n   603→  for (let iter = 0; iter < combB; iter++) {\n   604→    // Compute needed A-effect: for each pivot row r,\n   605→    // pivot[r] = RHS[r] - sum(A_effect) - sum(B_effect) - pivot_contributions (mod p)\n   606→    // We need the A-effect such that the total sum is minimized.\n   607→\n   608→    // The B-effect on pivots:\n   609→    const effectB = new Array(rank).fill(0);\n   610→    let countB = 0;\n   611→    for (let fi = 0; fi < halfB; fi++) {\n   612→      countB += freeValuesB[fi];\n   613→      for (let r = 0; r < rank; r++) {\n   614→        effectB[r] = (effectB[r] + matrix[r][freeVars[halfA + fi]] * freeValuesB[fi]) % modulus;\n   615→      }\n   616→    }\n   617→\n   618→    // We need A-effect such that:\n   619→    // For each pivot r: pivot_val = (RHS[r] - effectA[r] - effectB[r]) mod p\n   620→    // And the pivot_val contributes to the total count.\n   621→    // The \"needed\" A-effect key would require matching against specific pivot values,\n   622→    // which is complex. Let's just compute the full solution for each combination.\n   623→\n   624→    // Actually, the needed key: we want effectA such that the resulting pivot values\n   625→    // (and total count) are minimized. This doesn't map to a simple key lookup.\n   626→    // For MITM to work here, we'd need a different formulation.\n   627→\n   628→    // Fallback: enumerate B, and for each B, try the solution with all-zero A\n   629→    // and a few heuristic A values. This won't guarantee optimality.\n   630→\n   631→    // Better approach: for each B assignment, compute the resulting pivot values\n   632→    // for each possible A assignment. The pivot values are fully determined by\n   633→    // effectA + effectB + RHS. So we need to minimize:\n   634→    // countA + countB + sum of pivot_values\n   635→    // where pivot_values[r] = (RHS[r] - effectA[r] - effectB[r]) mod p\n   636→\n   637→    // For the MITM, we precomputed effectA. The needed_effectA key:\n   638→    // We want to minimize countA + sum((RHS[r] - effectA[r] - effectB[r]) mod p)\n   639→    // This depends on effectA in a non-trivial way, so a simple hash lookup won't work.\n   640→\n   641→    // Let's just do full enumeration if feasible, or use a smarter method.\n   642→    // For now, try all A entries for each B (which is combA * combB = original complexity).\n   643→    // But we can prune by keeping only the best A for each effect key.\n   644→\n   645→    // Actually, let's reformulate: compute for this B what the \"residual\" is\n   646→    const residual = new Array(rank).fill(0);\n   647→    for (let r = 0; r < rank; r++) {\n   648→      residual[r] = (((matrix[r][numButtons] - effectB[r]) % modulus) + modulus) % modulus;\n   649→    }\n   650→\n   651→    // For a given A-effect, pivot[r] = (residual[r] - effectA[r]) mod p\n   652→    // Total = countA + countB + sum_r(pivot[r])\n   653→    // We want to minimize this.\n   654→\n   655→    // Iterate over mapA keys to find the best\n   656→    for (const [key, entries] of mapA) {\n   657→      const effectA = key.split(',').map(Number);\n   658→      // Compute pivot values\n   659→      let pivotSum = 0;\n   660→      for (let r = 0; r < rank; r++) {\n   661→        pivotSum += (((residual[r] - effectA[r]) % modulus) + modulus) % modulus;\n   662→      }\n   663→\n   664→      // Find the best entry (lowest countA, then lexicographically)\n   665→      for (const entry of entries) {\n   666→        const total = entry.count + countB + pivotSum;\n   667→        if (total < bestTotal) {\n   668→          bestTotal = total;\n   669→          // Build the full solution\n   670→          const fullFreeValues = new Array(numFree).fill(0);\n   671→          for (let fi = 0; fi < halfA; fi++) fullFreeValues[fi] = entry.freeValues[fi];\n   672→          for (let fi = 0; fi < halfB; fi++) fullFreeValues[halfA + fi] = freeValuesB[fi];\n   673→          bestSolution = computeCounterSolution(matrix, pivotCol, freeVars, numButtons, rank, fullFreeValues, modulus);\n   674→        } else if (total === bestTotal && bestSolution !== null) {\n   675→          const fullFreeValues = new Array(numFree).fill(0);\n   676→          for (let fi = 0; fi < halfA; fi++) fullFreeValues[fi] = entry.freeValues[fi];\n   677→          for (let fi = 0; fi < halfB; fi++) fullFreeValues[halfA + fi] = freeValuesB[fi];\n   678→          const sol = computeCounterSolution(matrix, pivotCol, freeVars, numButtons, rank, fullFreeValues, modulus);\n   679→          if (lexSmallerArr(sol, bestSolution)) {\n   680→            bestSolution = sol;\n   681→          }\n   682→        }\n   683→      }\n   684→    }\n   685→\n   686→    // Increment B\n   687→    for (let fi = halfB - 1; fi >= 0; fi--) {\n   688→      freeValuesB[fi]++;\n   689→      if (freeValuesB[fi] >= modulus) {\n   690→      