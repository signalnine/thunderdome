@@ -0,0 +1,475 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+describe('Spreadsheet', () => {
+  let sheet: Spreadsheet;
+
+  beforeEach(() => {
+    sheet = new Spreadsheet();
+  });
+
+  describe('basic values', () => {
+    it('should store and retrieve numbers', () => {
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should store and retrieve floating point numbers', () => {
+      sheet.set('A1', 3.14);
+      expect(sheet.get('A1')).toBe(3.14);
+    });
+
+    it('should store and retrieve strings', () => {
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should store and retrieve booleans', () => {
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      expect(sheet.get('A1')).toBe(null);
+    });
+
+    it('should handle case-insensitive cell refs', () => {
+      sheet.set('a1', 10);
+      expect(sheet.get('A1')).toBe(10);
+      expect(sheet.get('a1')).toBe(10);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('should display numbers as strings', () => {
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should display strings', () => {
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should display booleans', () => {
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should display empty string for empty cells', () => {
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('should display computed formula values', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('getCells', () => {
+    it('should return all non-empty cells', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(3);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+    });
+  });
+
+  describe('simple formulas', () => {
+    it('should evaluate addition', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate subtraction', () => {
+      sheet.set('A1', 50);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate multiplication', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate division', () => {
+      sheet.set('A1', 100);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(25);
+    });
+
+    it('should respect operator precedence', () => {
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=A1+A2*A3');
+      expect(sheet.get('A4')).toBe(14); // 2 + (3*4)
+    });
+
+    it('should handle parentheses', () => {
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=(A1+A2)*A3');
+      expect(sheet.get('A4')).toBe(20); // (2+3)*4
+    });
+
+    it('should handle numeric literals in formulas', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+5');
+      expect(sheet.get('A2')).toBe(15);
+    });
+
+    it('should handle unary minus', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=-A1');
+      expect(sheet.get('A2')).toBe(-10);
+    });
+
+    it('should handle formulas referencing empty cells as 0', () => {
+      sheet.set('A1', 10);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(10); // A2 is empty = 0
+    });
+  });
+
+  describe('reactive updates', () => {
+    it('should update dependent cells when source changes', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+    });
+
+    it('should propagate changes through chains', () => {
+      sheet.set('A1', 5);
+      sheet.set('A2', '=A1*2');
+      sheet.set('A3', '=A2+10');
+      expect(sheet.get('A2')).toBe(10);
+      expect(sheet.get('A3')).toBe(20);
+
+      sheet.set('A1', 10);
+      expect(sheet.get('A2')).toBe(20);
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should update multiple dependents', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1+1');
+      sheet.set('C1', '=A1+2');
+      sheet.set('D1', '=A1+3');
+
+      sheet.set('A1', 100);
+      expect(sheet.get('B1')).toBe(101);
+      expect(sheet.get('C1')).toBe(102);
+      expect(sheet.get('D1')).toBe(103);
+    });
+
+    it('should handle diamond dependency patterns', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1+1');
+      sheet.set('C1', '=A1+2');
+      sheet.set('D1', '=B1+C1');
+
+      expect(sheet.get('D1')).toBe(23); // (10+1) + (10+2)
+
+      sheet.set('A1', 20);
+      expect(sheet.get('D1')).toBe(43); // (20+1) + (20+2)
+    });
+
+    it('should handle overwriting a formula with a value', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+5');
+      expect(sheet.get('A2')).toBe(15);
+
+      sheet.set('A2', 99);
+      expect(sheet.get('A2')).toBe(99);
+
+      // Changing A1 should no longer affect A2
+      sheet.set('A1', 100);
+      expect(sheet.get('A2')).toBe(99);
+    });
+  });
+
+  describe('SUM function', () => {
+    it('should sum a column range', () => {
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(60);
+    });
+
+    it('should sum a row range', () => {
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', 30);
+      sheet.set('D1', '=SUM(A1:C1)');
+      expect(sheet.get('D1')).toBe(60);
+    });
+
+    it('should sum a block range', () => {
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('B1', 3);
