+// ── Cell Reference Utilities ────────────────────────────────────────────────
+
+function columnToIndex(col: string): number {
+  let index = 0;
+  for (let i = 0; i < col.length; i++) {
+    index = index * 26 + (col.charCodeAt(i) - 64);
+  }
+  return index - 1; // 0-based
+}
+
+function indexToColumn(index: number): string {
+  let col = '';
+  let n = index + 1; // 1-based
+  while (n > 0) {
+    n--;
+    col = String.fromCharCode(65 + (n % 26)) + col;
+    n = Math.floor(n / 26);
+  }
+  return col;
+}
+
+function parseCellRef(ref: string): { col: string; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: match[1], row: parseInt(match[2], 10) };
+}
+
+function expandRange(start: string, end: string): string[] {
+  const s = parseCellRef(start);
+  const e = parseCellRef(end);
+  const colStart = columnToIndex(s.col);
+  const colEnd = columnToIndex(e.col);
+  const rowStart = s.row;
+  const rowEnd = e.row;
+  const cells: string[] = [];
+  for (let c = Math.min(colStart, colEnd); c <= Math.max(colStart, colEnd); c++) {
+    for (let r = Math.min(rowStart, rowEnd); r <= Math.max(rowStart, rowEnd); r++) {
+      cells.push(indexToColumn(c) + r);
+    }
+  }
+  return cells;
+}
+
+// ── Tokenizer ───────────────────────────────────────────────────────────────
+
+type TokenType =
+  | 'NUMBER'
+  | 'STRING'
+  | 'BOOLEAN'
+  | 'CELL_REF'
+  | 'RANGE'
+  | 'FUNCTION'
+  | 'OPERATOR'
+  | 'COMPARISON'
+  | 'LPAREN'
+  | 'RPAREN'
+  | 'COMMA'
+  | 'EOF';
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+function tokenize(formula: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < formula.length) {
+    // Skip whitespace
+    if (formula[i] === ' ' || formula[i] === '\t') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (formula[i] === '"') {
+      let str = '';
+      i++; // skip opening quote
+      while (i < formula.length && formula[i] !== '"') {
+        str += formula[i];
+        i++;
+      }
+      if (i < formula.length) i++; // skip closing quote
+      tokens.push({ type: 'STRING', value: str });
+      continue;
+    }
+
+    // Number
+    if (/\d/.test(formula[i]) || (formula[i] === '.' && i + 1 < formula.length && /\d/.test(formula[i + 1]))) {
+      let num = '';
+      while (i < formula.length && (/\d/.test(formula[i]) || formula[i] === '.')) {
+        num += formula[i];
+        i++;
+      }
+      tokens.push({ type: 'NUMBER', value: num });
+      continue;
+    }
+
+    // Identifiers: cell refs, ranges, functions, booleans
+    if (/[A-Za-z]/.test(formula[i])) {
+      let ident = '';
+      while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+        ident += formula[i];
+        i++;
+      }
+
+      // Check for range (e.g., A1:B2)
+      if (formula[i] === ':') {
+        i++; // skip ':'
+        let endRef = '';
+        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+          endRef += formula[i];
+          i++;
+        }
+        tokens.push({ type: 'RANGE', value: ident.toUpperCase() + ':' + endRef.toUpperCase() });
+        continue;
+      }
+
+      const upper = ident.toUpperCase();
+
+      // Boolean
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: 'BOOLEAN', value: upper });
+        continue;
+      }
+
+      // Function name (followed by '(')
+      if (i < formula.length && formula[i] === '(') {
+        tokens.push({ type: 'FUNCTION', value: upper });
+        continue;
+      }
+
+      // Cell reference (letters followed by digits)
+      if (/^[A-Z]+\d+$/.test(upper)) {
+        tokens.push({ type: 'CELL_REF', value: upper });
+        continue;
+      }
+
+      // Fallback: treat as cell ref or error
+      tokens.push({ type: 'CELL_REF', value: upper });
+      continue;
+    }
+
+    // Comparison operators
+    if (formula[i] === '<') {
+      if (i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push({ type: 'COMPARISON', value: '<=' });
+        i += 2;
+      } else if (i + 1 < formula.length && formula[i + 1] === '>') {
+        tokens.push({ type: 'COMPARISON', value: '<>' });
+        i += 2;
+      } else {
+        tokens.push({ type: 'COMPARISON', value: '<' });
+        i++;
+      }
+      continue;
+    }
+    if (formula[i] === '>') {
+      if (i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push({ type: 'COMPARISON', value: '>=' });
+        i += 2;
+      } else {
+        tokens.push({ type: 'COMPARISON', value: '>' });
+        i++;
+      }
+      continue;
+    }
+    if (formula[i] === '=') {
+      tokens.push({ type: 'COMPARISON', value: '=' });
+      i++;
+      continue;
+    }
+
+    // Arithmetic operators
+    if ('+-*/'.includes(formula[i])) {
+      tokens.push({ type: 'OPERATOR', value: formula[i] });
+      i++;
+      continue;
+    }
+
+    // Parentheses
+    if (formula[i] === '(') {
+      tokens.push({ type: 'LPAREN', value: '(' });
+      i++;
+      continue;
+    }
+    if (formula[i] === ')') {
+      tokens.push({ type: 'RPAREN', value: ')' });
+      i++;
+      continue;
+    }
+
+    // Comma
+    if (formula[i] === ',') {
+      tokens.push({ type: 'COMMA', value: ',' });
+      i++;
+      continue;
+    }
+
+    // Unknown character — skip
+    i++;
+  }
+
+  tokens.push({ type: 'EOF', value: '' });
+  return tokens;
+}
+
+// ── AST Nodes ───────────────────────────────────────────────────────────────
+
+type ASTNode =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'cell_ref'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'binary_op'; op: string; left: ASTNode; right: ASTNode }
+  | { type: 'unary_minus'; operand: ASTNode }
+  | { type: 'function_call'; name: string; args: ASTNode[] }
+  | { type: 'comparison'; op: string; left: ASTNode; right: ASTNode };
+
+// ── Parser (Recursive Descent) ──────────────────────────────────────────────
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token {
+    return this.tokens[this.pos];
+  }
+
+  private advance(): Token {
+    const token = this.tokens[this.pos];
+    this.pos++;
+    return token;
+  }
+
+  private expect(type: TokenType): Token {
+    const token = this.peek();
+    if (token.type !== type) {
+      throw new Error(`Expected ${type} but got ${token.type} (${token.value})`);
+    }
+    return this.advance();
+  }
+
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    return node;
+  }
+
+  private parseComparison(): ASTNode {
+    let left = this.parseExpression();
+    while (this.peek().type === 'COMPARISON') {
+      const op = this.advance().value;
+      const right = this.parseExpression();
+      left = { type: 'comparison', op, left, right };
+    }
+    return left;
+  }
+
+  private parseExpression(): ASTNode {
+    let left = this.parseTerm();
+    while (this.peek().type === 'OPERATOR' && (this.peek().value === '+' || this.peek().value === '-')) {
+      const op = this.advance().value;
+      const right = this.parseTerm();
+      left = { type: 'binary_op', op, left, right };
+    }
+    return left;
+  }
+
+  private parseTerm(): ASTNode {
+    let left = this.parseUnary();
+    while (this.peek().type === 'OPERATOR' && (this.peek().value === '*' || this.peek().value === '/')) {
+      const op = this.advance().value;
+      const right = this.parseUnary();
+      left = { type: 'binary_op', op, left, right };
+    }
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    if (this.peek().type === 'OPERATOR' && this.peek().value === '-') {
+      this.advance();
+      const operand = this.parseUnary();
+      return { type: 'unary_minus', operand };
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const token = this.peek();
+
+    switch (token.type) {
+      case 'NUMBER': {
+        this.advance();
+        return { type: 'number', value: parseFloat(token.value) };
+      }
+      case 'STRING': {
+        this.advance();
+        return { type: 'string', value: token.value };
+      }
+      case 'BOOLEAN': {
+        this.advance();
+        return { type: 'boolean', value: token.value === 'TRUE' };
+      }
+      case 'CELL_REF': {
+        this.advance();
+        return { type: 'cell_ref', ref: token.value };
+      }
+      case 'RANGE': {
+        this.advance();
+        const [start, end] = token.value.split(':');
+        return { type: 'range', start, end };
+      }
+      case 'FUNCTION': {
+        const name = this.advance().value;
+        this.expect('LPAREN');
+        const args: ASTNode[] = [];
+        if (this.peek().type !== 'RPAREN') {
+          args.push(this.parseComparison());
+          while (this.peek().type === 'COMMA') {
+            this.advance();
+            args.push(this.parseComparison());
+          }
+        }
+        this.expect('RPAREN');
+        return { type: 'function_call', name, args };
+      }
+      case 'LPAREN': {
+        this.advance();
+        const expr = this.parseComparison();
+        this.expect('RPAREN');
+        return expr;
+      }
+      default:
+        throw new Error(`Unexpected token: ${token.type} (${token.value})`);
+    }
+  }
+}
+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+// ── Extract dependencies from AST ──────────────────────────────────────────
+
+function extractDependencies(ast: ASTNode): Set<string> {
+  const deps = new Set<string>();
+
+  function walk(node: ASTNode): void {
+    switch (node.type) {
+      case 'cell_ref':
+        deps.add(node.ref);
+        break;
+      case 'range': {
+        const cells = expandRange(node.start, node.end);
+        for (const cell of cells) {
+          deps.add(cell);
+        }
+        break;
+      }
+      case 'binary_op':
+      case 'comparison':
+        walk(node.left);
+        walk(node.right);
+        break;
+      case 'unary_minus':
+        walk(node.operand);
+        break;
+      case 'function_call':
+        for (const arg of node.args) {
+          walk(arg);
+        }
+        break;
+      // number, string, boolean have no deps
+    }
+  }
+
+  walk(ast);
+  return deps;
+}
+
+// ── Evaluate AST ────────────────────────────────────────────────────────────
+
+type CellValue = string | number | boolean | null;
+
+function evaluateAST(ast: ASTNode, getCellValue: (ref: string) => CellValue): CellValue {
+  switch (ast.type) {
+    case 'number':
+      return ast.value;
+    case 'string':
+      return ast.value;
+    case 'boolean':
+      return ast.value;
+    case 'cell_ref':
+      return getCellValue(ast.ref);
+    case 'unary_minus': {
+      const val = evaluateAST(ast.operand, getCellValue);
+      if (typeof val === 'number') return -val;
+      return null;
+    }
+    case 'binary_op': {
+      const left = evaluateAST(ast.left, getCellValue);
+      const right = evaluateAST(ast.right, getCellValue);
+      const l = typeof left === 'number' ? left : 0;
+      const r = typeof right === 'number' ? right : 0;
+      switch (ast.op) {
+        case '+': return l + r;
+        case '-': return l - r;
+        case '*': return l * r;
+        case '/': return r === 0 ? null : l / r;
+        default: return null;
+      }
+    }
+    case 'comparison': {
+      const left = evaluateAST(ast.left, getCellValue);
+      const right = evaluateAST(ast.right, getCellValue);
+      switch (ast.op) {
+        case '>': return (left as number) > (right as number);
+        case '<': return (left as number) < (right as number);
+        case '>=': return (left as number) >= (right as number);
+        case '<=': return (left as number) <= (right as number);
+        case '=': return left === right;
+        case '<>': return left !== right;
+        default: return false;
+      }
+    }
+    case 'range': {
+      // A bare range evaluates to the array of values (used inside functions)
+      const cells = expandRange(ast.start, ast.end);
+      return cells.map(c => getCellValue(c)) as unknown as CellValue;
+    }
+    case 'function_call':
+      return evaluateFunction(ast.name, ast.args, getCellValue);
+    default:
+      return null;
+  }
+}
+
+function resolveValues(args: ASTNode[], getCellValue: (ref: string) => CellValue): CellValue[] {
+  const values: CellValue[] = [];
+  for (const arg of args) {
+    if (arg.type === 'range') {
+      const cells = expandRange(arg.start, arg.end);
+      for (const cell of cells) {
+        values.push(getCellValue(cell));
+      }
+    } else {
+      values.push(evaluateAST(arg, getCellValue));
+    }
+  }
+  return values;
+}
+
+function evaluateFunction(
+  name: string,
+  args: ASTNode[],
+  getCellValue: (ref: string) => CellValue
+): CellValue {
+  switch (name) {
+    case 'SUM': {
+      const values = resolveValues(args, getCellValue);
+      let sum = 0;
+      for (const v of values) {
+        if (typeof v === 'number') sum += v;
+      }
+      return sum;
+    }
+    case 'AVERAGE': {
+      const values = resolveValues(args, getCellValue);
+      let sum = 0;
+      let count = 0;
+      for (const v of values) {
+        if (typeof v === 'number') {
+          sum += v;
+          count++;
+        }
+      }
+      return count === 0 ? null : sum / count;
+    }
+    case 'MIN': {
+      const values = resolveValues(args, getCellValue);
+      let min: number | null = null;
+      for (const v of values) {
+        if (typeof v === 'number') {
+          if (min === null || v < min) min = v;
+        }
+      }
+      return min;
+    }
+    case 'MAX': {
+      const values = resolveValues(args, getCellValue);
+      let max: number | null = null;
+      for (const v of values) {
+        if (typeof v === 'number') {
+          if (max === null || v > max) max = v;
+        }
+      }
+      return max;
+    }
+    case 'COUNT': {
+      const values = resolveValues(args, getCellValue);
+      let count = 0;
+      for (const v of values) {
+        if (typeof v === 'number') count++;
+      }
+      return count;
+    }
+    case 'IF': {
+      if (args.length < 3) return null;
+      const condition = evaluateAST(args[0], getCellValue);
+      if (condition === true || (typeof condition === 'number' && condition !== 0)) {
+        return evaluateAST(args[1], getCellValue);
+      } else {
+        return evaluateAST(args[2], getCellValue);
+      }
+    }
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
+
+// ── Spreadsheet ─────────────────────────────────────────────────────────────
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  computed: CellValue;
+  dependencies: Set<string>;
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Reverse dependency map: cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+    const oldData = this.cells.get(ref);
+
+    // Remove old dependency edges
+    if (oldData) {
+      for (const dep of oldData.dependencies) {
+        const depSet = this.dependents.get(dep);
+        if (depSet) {
+          depSet.delete(ref);
+        }
+      }
+    }
+
+    // Parse formula or store raw value
+    let formula: ASTNode | null = null;
+    let dependencies = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaStr = value.slice(1);
+      formula = parseFormula(formulaStr);
+      dependencies = extractDependencies(formula);
+    }
+
+    // Add new dependency edges
+    for (const dep of dependencies) {
+      let depSet = this.dependents.get(dep);
+      if (!depSet) {
+        depSet = new Set();
+        this.dependents.set(dep, depSet);
+      }
+      depSet.add(ref);
+    }
+
+    // Create cell data (computed value will be set during evaluation)
+    const cellData: CellData = {
+      raw: value,
+      formula,
+      computed: null,
+      dependencies,
+    };
+    this.cells.set(ref, cellData);
+
+    // Check for circular references before evaluating
+    this.detectCycle(ref);
+
+    // Evaluate the cell and propagate changes
+    this.recalculate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = cell.toUpperCase();
+    const data = this.cells.get(ref);
+    return data ? data.computed : null;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null || value === undefined) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computed);
+    }
+    return result;
+  }
+
+  private detectCycle(startRef: string): void {
+    const visited = new Set<string>();
+    const stack = new Set<string>();
+
+    const dfs = (ref: string): void => {
+      if (stack.has(ref)) {
+        throw new Error(`Circular reference detected involving ${ref}`);
+      }
+      if (visited.has(ref)) return;
+
+      visited.add(ref);
+      stack.add(ref);
+
+      const data = this.cells.get(ref);
+      if (data) {
+        for (const dep of data.dependencies) {
+          dfs(dep);
+        }
+      }
+
+      stack.delete(ref);
+    };
+
+    dfs(startRef);
+  }
+
+  private recalculate(changedRef: string): void {
+    // Get the topological order of cells that need recalculation
+    const order = this.getRecalcOrder(changedRef);
+
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (!data) continue;
+
+      if (data.formula) {
+        data.computed = evaluateAST(data.formula, (r) => {
+          const d = this.cells.get(r);
+          return d ? d.computed : null;
+        });
+      } else {
+        data.computed = data.raw as CellValue;
+      }
+    }
+  }
+
+  private getRecalcOrder(startRef: string): string[] {
+    // BFS to find all affected cells, then topological sort
+    const affected = new Set<string>();
+    const queue: string[] = [startRef];
+    affected.add(startRef);
+
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const deps = this.dependents.get(current);
+      if (deps) {
+        for (const dep of deps) {
+          if (!affected.has(dep)) {
+            affected.add(dep);
+            queue.push(dep);
+          }
+        }
+      }
+    }
+
+    // Topological sort of affected cells
+    // A cell must be evaluated after all its dependencies
+    const sorted: string[] = [];
+    const visited = new Set<string>();
+    const visiting = new Set<string>();
+
+    const visit = (ref: string): void => {
+      if (visited.has(ref)) return;
+      if (!affected.has(ref)) return;
+      if (visiting.has(ref)) return; // cycle already checked
+
+      visiting.add(ref);
+
+      const data = this.cells.get(ref);
+      if (data) {
+        for (const dep of data.dependencies) {
+          if (affected.has(dep)) {
+            visit(dep);
+          }
+        }
+      }
+
+      visiting.delete(ref);
+      visited.add(ref);
+      sorted.push(ref);
+    };
+
+    for (const ref of affected) {
+      visit(ref);
+    }
+
+    return sorted;
+  }
+}
