dle complex expressions in IF', () => {\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('B1', '=IF(A1+A2>25, A1*A2, A1+A2)');\n      expect(sheet.get('B1')).toBe(200); // 10+20>25 is true, so 10*20=200\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
