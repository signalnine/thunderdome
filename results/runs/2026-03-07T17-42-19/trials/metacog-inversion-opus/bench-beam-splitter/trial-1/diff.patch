+// Direction constants
+const DOWN = 0;
+const DOWN_LEFT = 1;
+const DOWN_RIGHT = 2;
+
+type Direction = typeof DOWN | typeof DOWN_LEFT | typeof DOWN_RIGHT;
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function nextPosition(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case DOWN:       return [row + 1, col];
+    case DOWN_LEFT:  return [row + 1, col - 1];
+    case DOWN_RIGHT: return [row + 1, col + 1];
+  }
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') {
+      return [0, col];
+    }
+  }
+  return null;
+}
+
+function isInBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+  if (cols === 0) return 0;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<number>();
+  const cellKey = (r: number, c: number) => r * cols + c;
+
+  // Track (row, col, direction) to avoid reprocessing the same beam state
+  const seen = new Set<number>();
+  const stateKey = (r: number, c: number, d: Direction) => (r * cols + c) * 3 + d;
+
+  // Start: source cell is visited, beam starts moving down from source
+  visited.add(cellKey(source[0], source[1]));
+
+  const queue: Beam[] = [];
+
+  // The beam starts at the source and moves down
+  const [nextRow, nextCol] = nextPosition(source[0], source[1], DOWN);
+  if (isInBounds(nextRow, nextCol, rows, cols)) {
+    queue.push({ row: nextRow, col: nextCol, dir: DOWN });
+  }
+
+  while (queue.length > 0) {
+    const beam = queue.pop()!;
+    const { row, col, dir } = beam;
+
+    const sk = stateKey(row, col, dir);
+    if (seen.has(sk)) continue;
+    seen.add(sk);
+
+    visited.add(cellKey(row, col));
+
+    const cell = grid[row][col];
+
+    if (cell === '^') {
+      // Split into down-left and down-right
+      const [lr, lc] = nextPosition(row, col, DOWN_LEFT);
+      if (isInBounds(lr, lc, rows, cols)) {
+        queue.push({ row: lr, col: lc, dir: DOWN_LEFT });
+      }
+      const [rr, rc] = nextPosition(row, col, DOWN_RIGHT);
+      if (isInBounds(rr, rc, rows, cols)) {
+        queue.push({ row: rr, col: rc, dir: DOWN_RIGHT });
+      }
+    } else {
+      // Continue in current direction
+      const [nr, nc] = nextPosition(row, col, dir);
+      if (isInBounds(nr, nc, rows, cols)) {
+        queue.push({ row: nr, col: nc, dir: dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+  if (cols === 0) return 0n;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // We propagate beams with path counts.
+  // Each beam state (row, col, direction) carries a count of how many paths
+  // reach it. When hitting a splitter, both children get the same count.
+  // When a beam exits the grid, its count is added to total paths.
+  //
+  // We process row by row to ensure correct ordering (beams always move downward).
+
+  // For each (col, direction), track the number of paths arriving at the current row
+  // direction: 0=down, 1=down-left, 2=down-right
+  // Use a map for sparse representation
+
+  type StateMap = Map<number, bigint>;
+  const makeKey = (col: number, dir: Direction) => col * 3 + dir;
+
+  let totalPaths = 0n;
+
+  // Initialize: beam starts at source going down
+  // The source itself is row 0. The beam moves to row 1.
+  // But first, check if source is on a splitter (it's 'S', not '^', so no).
+
+  // Process row by row. At each row, we have incoming beams.
+  // We resolve what happens at that row (splitter or pass-through),
+  // then compute what goes to the next row.
+
+  // Start: at row 0, col source[1], direction DOWN
+  // But the source is 'S', not a splitter. So the beam continues down.
+  // The beam at (0, source[1]) with direction DOWN will move to (1, source[1]).
+
+  let current: StateMap = new Map();
+  current.set(makeKey(source[1], DOWN), 1n);
+
+  for (let row = 0; row < rows; row++) {
+    const next: StateMap = new Map();
+
+    const addToNext = (col: number, dir: Direction, count: bigint) => {
+      // Compute next position
+      const [nr, nc] = nextPosition(row, col, dir);
+      if (!isInBounds(nr, nc, rows, cols)) {
+        // Beam exits the grid - these are completed paths
+        totalPaths += count;
+      } else {
+        const key = makeKey(nc, dir);
+        next.set(key, (next.get(key) ?? 0n) + count);
+      }
+    };
+
+    for (const [key, count] of current) {
+      const col = Math.floor(key / 3);
+      const dir = (key % 3) as Direction;
+
+      const cell = grid[row][col];
+
+      if (cell === '^') {
+        // Split: down-left and down-right, each gets the full count
+        addToNext(col, DOWN_LEFT, count);
+        addToNext(col, DOWN_RIGHT, count);
+      } else {
+        // Continue in current direction (including 'S' and '.')
+        addToNext(col, dir, count);
+      }
+    }
+
+    current = next;
+  }
+
+  // Any beams still in 'current' after processing the last row would exit,
+  // but they've already been handled by addToNext since nextPosition would be out of bounds.
+  // Actually, after processing row = rows-1, all next positions will have row = rows which is out of bounds.
+  // So totalPaths already includes everything. But let's be safe:
+  // (This shouldn't happen given the loop above, but just in case)
+
+  return totalPaths;
+}
