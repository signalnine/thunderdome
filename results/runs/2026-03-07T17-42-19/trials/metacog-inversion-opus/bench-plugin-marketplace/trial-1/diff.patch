t('B', { C: '^1.0.0' }));\n      registry.register(makeManifest('C'));\n\n      const order = depsService.topologicalSort('A', registry);\n      expect(order.indexOf('C')).toBeLessThan(order.indexOf('B'));\n      expect(order.indexOf('B')).toBeLessThan(order.indexOf('A'));\n    });\n\n    it('should handle single plugin', () => {\n      registry.register(makeManifest('A'));\n      const order = depsService.topologicalSort('A', registry);\n      expect(order).toEqual(['A']);\n    });\n  });\n\n  describe('flattenDependencies', () => {\n    it('should return all transitive dependencies', () => {\n      registry.register(makeManifest('A', { B: '^1.0.0' }));\n      registry.register(makeManifest('B', { C: '^1.0.0' }));\n      registry.register(makeManifest('C'));\n\n      const deps = depsService.flattenDependencies('A', registry);\n      expect(deps).toContain('B');\n      expect(deps).toContain('C');\n      expect(deps).not.toContain('A');\n    });\n\n    it('should return empty for plugin with no dependencies', () => {\n      registry.register(makeManifest('A'));\n      expect(depsService.flattenDependencies('A', registry)).toHaveLength(0);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":124,"cache_read_input_tokens":27861,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":124},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"53fc4e3c-12e9-4e33-827d-5df25e7d0a75","uuid":"501a61e8-6139-4efa-8426-fdea51d6a5c5"}
