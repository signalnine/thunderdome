ned();\n    });\n\n    it('should succeed within timeout', async () => {\n      const result = await runner.executeWithTimeout('42', 1000);\n      expect(result.success).toBe(true);\n      expect(result.output).toBe(42);\n    });\n  });\n\n  describe('sandbox isolation', () => {\n    it('should not have access to process', async () => {\n      const result = await runner.execute('typeof process');\n      expect(result.success).toBe(true);\n      expect(result.output).toBe('undefined');\n    });\n\n    it('should not have access to require', async () => {\n      const result = await runner.execute('typeof require');\n      expect(result.success).toBe(true);\n      expect(result.output).toBe('undefined');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":124,"cache_read_input_tokens":27861,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":124},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"53fc4e3c-12e9-4e33-827d-5df25e7d0a75","uuid":"9660ef29-991c-4df7-bc48-219d61fddc75"}
