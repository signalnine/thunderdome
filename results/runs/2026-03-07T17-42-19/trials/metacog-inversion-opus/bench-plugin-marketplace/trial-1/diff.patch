+import { describe, it, expect, beforeEach } from 'vitest';
+import { createRegistry } from './index.js';
+import type { PluginManifest, RegistryService } from '../types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: 'console.log("hello")',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('RegistryService', () => {
+  let registry: RegistryService;
+
+  beforeEach(() => {
+    registry = createRegistry();
+  });
+
+  it('should register and retrieve a plugin', () => {
+    const manifest = makeManifest();
+    registry.register(manifest);
+    const result = registry.get('test-plugin');
+    expect(result).not.toBeNull();
+    expect(result!.name).toBe('test-plugin');
+    expect(result!.version).toBe('1.0.0');
+  });
+
+  it('should return null for unknown plugins', () => {
+    expect(registry.get('nonexistent')).toBeNull();
+  });
+
+  it('should register multiple versions of the same plugin', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    const versions = registry.listVersions('test-plugin');
+    expect(versions).toContain('1.0.0');
+    expect(versions).toContain('2.0.0');
+  });
+
+  it('should get a specific version', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    const v1 = registry.getVersion('test-plugin', '1.0.0');
+    expect(v1!.version).toBe('1.0.0');
+    const v2 = registry.getVersion('test-plugin', '2.0.0');
+    expect(v2!.version).toBe('2.0.0');
+  });
+
+  it('should return null for unknown version', () => {
+    registry.register(makeManifest());
+    expect(registry.getVersion('test-plugin', '9.9.9')).toBeNull();
+  });
+
+  it('should list all plugins', () => {
+    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));
+    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));
+    const all = registry.list();
+    expect(all).toHaveLength(2);
+  });
+
+  it('should search by name', () => {
+    registry.register(makeManifest({ name: 'auth-plugin', description: 'Auth stuff' }));
+    registry.register(makeManifest({ name: 'logging-plugin', description: 'Logging stuff' }));
+    const results = registry.search('auth');
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('auth-plugin');
+  });
+
+  it('should search by description', () => {
+    registry.register(makeManifest({ name: 'foo', description: 'handles authentication' }));
+    registry.register(makeManifest({ name: 'bar', description: 'handles logging' }));
+    const results = registry.search('authentication');
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('foo');
+  });
+
+  it('should search case-insensitively', () => {
+    registry.register(makeManifest({ name: 'MyPlugin', description: 'desc' }));
+    expect(registry.search('myplugin')).toHaveLength(1);
+    expect(registry.search('MYPLUGIN')).toHaveLength(1);
+  });
+
+  it('should remove a specific version', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);
+    expect(registry.listVersions('test-plugin')).toEqual(['2.0.0']);
+  });
+
+  it('should return false when removing nonexistent version', () => {
+    expect(registry.remove('nonexistent', '1.0.0')).toBe(false);
+  });
+
+  it('should update a plugin', () => {
+    registry.register(makeManifest());
+    registry.update('test-plugin', '1.0.0', { description: 'Updated description' });
+    const plugin = registry.getVersion('test-plugin', '1.0.0');
+    expect(plugin!.description).toBe('Updated description');
+  });
+
+  it('should throw when updating nonexistent plugin', () => {
+    expect(() => registry.update('nonexistent', '1.0.0', {})).toThrow();
+  });
+
+  it('should return copies, not references', () => {
+    registry.register(makeManifest());
+    const a = registry.get('test-plugin');
+    const b = registry.get('test-plugin');
+    expect(a).toEqual(b);
+    expect(a).not.toBe(b);
+  });
+});
