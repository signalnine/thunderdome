+import { readFileSync, writeFileSync, mkdirSync, existsSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string; // ISO 8601
+  stop: string | null; // ISO 8601, null if still running
+}
+
+interface TrackerData {
+  entries: TimeEntry[];
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.entries = this.load();
+  }
+
+  private load(): TimeEntry[] {
+    try {
+      if (existsSync(this.filePath)) {
+        const raw = readFileSync(this.filePath, "utf-8");
+        const data: TrackerData = JSON.parse(raw) as TrackerData;
+        return data.entries;
+      }
+    } catch {
+      // If file is corrupted or unreadable, start fresh
+    }
+    return [];
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    if (!existsSync(dir)) {
+      mkdirSync(dir, { recursive: true });
+    }
+    const data: TrackerData = { entries: this.entries };
+    writeFileSync(this.filePath, JSON.stringify(data, null, 2), "utf-8");
+  }
+
+  /**
+   * Start a new timer. If a timer is already running, it is stopped first.
+   */
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name must not be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    this.entries.push({
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    });
+
+    this.save();
+  }
+
+  /**
+   * Stop the currently running timer.
+   */
+  stop(): void {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+  }
+
+  /**
+   * Get the currently running entry, or null.
+   */
+  private getRunningEntry(): TimeEntry | null {
+    for (let i = this.entries.length - 1; i >= 0; i--) {
+      if (this.entries[i].stop === null) {
+        return this.entries[i];
+      }
+    }
+    return null;
+  }
+
+  /**
+   * Get all entries, optionally filtered by date range.
+   * Both `from` and `to` are inclusive.
+   */
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    if (!from && !to) {
+      return [...this.entries];
+    }
+
+    return this.entries.filter((entry) => {
+      const entryStart = new Date(entry.start);
+      if (from && entryStart < from) {
+        return false;
+      }
+      if (to && entryStart > to) {
+        return false;
+      }
+      return true;
+    });
+  }
+
+  /**
+   * Get a summary of total time spent per task name, in milliseconds.
+   * Running tasks use the current time for their duration.
+   */
+  getSummary(from?: Date, to?: Date): Record<string, number> {
+    const entries = this.getEntries(from, to);
+    const summary: Record<string, number> = {};
+
+    for (const entry of entries) {
+      const start = new Date(entry.start).getTime();
+      const stop = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = stop - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  /**
+   * Check if a timer is currently running.
+   */
+  isRunning(): boolean {
+    return this.getRunningEntry() !== null;
+  }
+
+  /**
+   * Get the currently running task name, or null.
+   */
+  currentTask(): string | null {
+    const running = this.getRunningEntry();
+    return running ? running.task : null;
+  }
+}
