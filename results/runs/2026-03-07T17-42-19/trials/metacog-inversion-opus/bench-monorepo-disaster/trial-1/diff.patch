+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N9RWC79Kke2wEr8E3uWpaP","type":"tool_result","content":"     1→/**\n     2→ * @monorepo/core - Shared business logic\n     3→ */\n     4→\n     5→// Types\n     6→export type { User, CreateUserInput, UserFilters, Role, Permission } from './types.js';\n     7→\n     8→// User management\n     9→export {\n    10→  registerUser,\n    11→  validateUser,\n    12→  getUserById,\n    13→  getAllUsers,\n    14→  canUserPerformAction,\n    15→  getDefaultConnection,\n    16→  resetDefaultConnection,\n    17→} from './user.js';\n    18→\n    19→// Validation\n    20→export {\n    21→  createUserSchema,\n    22→  userIdSchema,\n    23→  userFiltersSchema,\n    24→  roleSchema,\n    25→  validateCreateUser,\n    26→  validateUserId,\n    27→} from './validation.js';\n    28→\n    29→// Database\n    30→export {\n    31→  createDatabase,\n    32→  createTables,\n    33→  insertUser,\n    34→  findUserById,\n    35→  findAllUsers,\n    36→  type DatabaseConnection,\n    37→} from './database.js';\n    38→\n    39→// Permissions\n    40→export {\n    41→  hasPermission,\n    42→  getAllPermissions,\n    43→  canManageUsers,\n    44→  canWrite,\n    45→  canDelete,\n    46→  requirePermission,\n    47→} from './permissions.js';\n    48→"}]},"parent_tool_use_id":"toolu_01BZGkR6Hq8KSfKTjz5SEMXF","session_id":"af07b67b-3485-4d4c-8975-1d69b71b592f","uuid":"627a3f1b-20c8-4625-91fa-46925f268a3e"}
