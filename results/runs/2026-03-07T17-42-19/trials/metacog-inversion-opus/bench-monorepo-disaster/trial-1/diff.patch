teUser({ name: '', email: 'not-an-email', role: 'hacker' });\n    expect(invalid.valid).toBe(false);\n    expect(invalid.errors).toBeDefined();\n  });\n});\n```\n\n#### /workspace/packages/core/tests/validation.test.ts\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport {\n  validateCreateUser,\n  validateUserId,\n  userFiltersSchema,\n} from '../src/validation.js';\n\ndescribe('Validation', () => {\n  it('validates a correct user input', () => {\n    const result = validateCreateUser({\n      name: 'Alice',\n      email: 'alice@example.com',\n      role: 'admin',\n    });\n    expect(result.success).toBe(true);\n    expect(result.data).toEqual({\n      name: 'Alice',\n      email: 'alice@example.com',\n      role: 'admin',\n    });\n  });\n\n  it('rejects invalid email', () => {\n    const result = validateCreateUser({\n      name: 'Alice',\n      email: 'not-an-email',\n      role: 'admin',\n    });\n    expect(result.success).toBe(false);\n    expect(result.errors).toContain('Invalid email address');\n  });\n\n  it('uses z.pipe() to coerce string user ID to number', () => {\n    const result = validateUserId('42');\n    expect(result.success).toBe(true);\n    expect(result.data).toBe(42);\n  });\n\n  it('rejects non-numeric user ID via z.pipe()', () => {\n    const result = validateUserId('abc');\n    expect(result.success).toBe(false);\n  });\n\n  it('parses user filters with string-to-number coercion via z.pipe()', () => {\n    const result = userFiltersSchema.safeParse({\n      role: 'admin',\n      limit: '50',\n      offset: '10',\n    });\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.limit).toBe(50);\n      expect(result.data.offset).toBe(10);\n    }\n  });\n});\n```\n\n---\n\n### API Package (/workspace/packages/api/)\n\n#### /workspace/packages/api/package.json\n```json\n{\n  \"name\": \"@monorepo/api\",\n  \"version\": \"1.0.0\",\n  \"type\": \"module\",\n  \"main\": \"./dist/index.js\",\n