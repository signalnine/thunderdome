n  }\n}\n```\n\n#### /workspace/packages/worker/tsconfig.json\n```json\n{\n  \"compilerOptions\": {\n    \"target\": \"ES2022\",\n    \"module\": \"Node16\",\n    \"moduleResolution\": \"Node16\",\n    \"outDir\": \"./dist\",\n    \"rootDir\": \"./src\",\n    \"strict\": true,\n    \"composite\": true,\n    \"declaration\": true,\n    \"declarationMap\": true,\n    \"sourceMap\": true,\n    \"esModuleInterop\": true,\n    \"skipLibCheck\": true,\n    \"forceConsistentCasingInFileNames\": true\n  },\n  \"include\": [\"src/**/*.ts\"],\n  \"exclude\": [\"node_modules\", \"dist\", \"tests\"],\n  \"references\": [\n    { \"path\": \"../core\" }\n  ]\n}\n```\n\n#### /workspace/packages/worker/src/index.ts\n```typescript\n/**\n * Worker entry point.\n * Runs background jobs on a schedule.\n */\n\nimport { Scheduler } from './scheduler.js';\nimport { syncJob } from './jobs/sync.js';\nimport { cleanupJob } from './jobs/cleanup.js';\n\nexport function createWorker(): Scheduler {\n  const scheduler = new Scheduler();\n\n  // Register jobs\n  scheduler.register('sync', syncJob, 60_000); // Every 60 seconds\n  scheduler.register('cleanup', async () => { await cleanupJob(); }, 300_000); // Every 5 minutes\n\n  return scheduler;\n}\n\n// Start worker if run directly\nconst isMainModule = process.argv[1]?.includes('worker/dist/index.js');\nif (isMainModule) {\n  console.log('Starting worker...');\n  const worker = createWorker();\n  worker.start();\n\n  process.on('SIGINT', () => {\n    console.log('Shutting down worker...');\n    worker.stop();\n    process.exit(0);\n  });\n}\n```\n\n#### /workspace/packages/worker/src/scheduler.ts\n```typescript\n/**\n * Simple job scheduler for background tasks.\n */\n\nexport interface JobDefinition {\n  name: string;\n  handler: () => Promise<void> | void;\n  intervalMs: number;\n  timer?: ReturnType<typeof setInterval>;\n  lastRun?: Date;\n  runCount: number;\n  errors: string[];\n}\n\nexport class Scheduler {\n  private jobs: Map<string, JobDefinition> = new Map();\n  private running = false;\n\n  register(\n    name: string,\n    handler: () => Promise<void> | void,\n    intervalMs: number\n  ): void {\n    this.jobs.set(name, {\n      name,\n      handler,\n      intervalMs,\n      runCount: 0,\n      errors: [],\n    });\n  }\n\n  start(): void {\n    if (this.running) return;\n    this.running = true;\n\n    for (const [, job] of this.jobs) {\n      job.timer = setInterval(async () => {\n        try {\n          await job.handler();\n          job.lastRun = new Date();\n          job.runCount++;\n        } catch (err) {\n          job.errors.push(\n            err instanceof Error ? err.message : String(err)\n          );\n        }\n      }, job.intervalMs);\n    }\n  }\n\n  stop(): void {\n    if (!this.running) return;\n    this.running = false;\n\n    for (const [, job] of this.jobs) {\n      if (job.timer) {\n        clearInterval(job.timer);\n        job.timer = undefined;\n      }\n    }\n  }\n\n  async runOnce(name: string): Promise<void> {\n    const job = this.jobs.get(name);\n    if (!job) {\n      throw new Error(`Job '${name}' not found`);\n    }\n\n    await job.handler();\n    job.lastRun = new Date();\n    job.runCount++;\n  }\n\n  getStatus(): Array<{\n    name: string;\n    lastRun: Date | undefined;\n    runCount: number;\n    errorCount: number;\n  }> {\n    return Array.from(this.jobs.values()).map((job) => ({\n      name: job.name,\n      lastRun: job.lastRun,\n      runCount: job.runCount,\n      errorCount: job.errors.length,\n    }));\n  }\n\n  isRunning(): boolean {\n    return this.running;\n  }\n}\n```\n\n#### /workspace/packages/worker/src/jobs/sync.ts\n```typescript\n/**\n * Data sync job.\n * Syncs external user data into the local database.\n */\n\nimport {\n  createUser,\n  getUserById,\n  getAllUsers,\n  type CreateUserInput,\n} from '@monorepo/core';\n\ninterface ExternalUser {\n  name: string;\n  email: string;\n  role: 'admin' | 'user' | 'viewer';\n}\n\n// Simulated external data source\nfunction fetchExternalUsers(): ExternalUser[] {\n  return [\n    { name: 'External User 1', email: 'ext1@example.com', role: 'user' },\n    { name: 'External User 2', email: 'ext2@example.com', role: 'viewer' },\n  ];\n}\n\nexport async function syncJob(): Promise<void> {\n  const externalUsers = fetchExternalUsers();\n  const existingUsers = getAllUsers();\n  const existingEmails = new Set(existingUsers.map((u) => u.email));\n\n  let synced = 0;\n  let skipped = 0;\n\n  for (const extUser of externalUsers) {\n    if (existingEmails.has(extUser.email)) {\n      skipped++;\n      continue;\n    }\n\n    const input: CreateUserInput = {\n      name: extUser.name,\n      email: extUser.email,\n      role: extUser.role,\n    };\n\n    try {\n      const newUser = createUser(input);\n      if (newUser.id) {\n        synced++;\n      }\n    } catch (err) {\n      console.error(`Failed to sync user ${extUser.email}:`, err);\n    }\n  }\n\n  console.log(`Sync complete: ${synced} synced, ${skipped} skipped`);\n}\n\nexport async function syncSingleUser(userId: number): Promise<boolean> {\n  const user = getUserById(userId);\n  if (!user) {\n    console.error(`User ${userId} not found for sync`);\n    return false;\n  }\n\n  // In a real app, we'd sync to an external service here\n  console.log(`Synced user ${user.name} (${user.email})`);\n  return true;\n}\n```\n\n#### /workspace/packages/worker/src/jobs/cleanup.ts\n```typescript\n/**\n * Cleanup job.\n * Removes stale data and performs maintenance tasks.\n */\n\nimport { getAllUsers } from '@monorepo/core';\n\nexport interface CleanupResult {\n  staleRecords: number;\n  cleanedUp: number;\n  duration: number;\n}\n\nexport async function cleanupJob(): Promise<CleanupResult> {\n  const startTime = Date.now();\n\n  // Get all users to check for stale records\n  const users = getAllUsers();\n\n  let staleRecords = 0;\n  let cleanedUp = 0;\n\n  for (const user of users) {\n    const createdDate = new Date(user.createdAt);\n    const now = new Date();\n    const daysSinceCreation =\n      (now.getTime() - createdDate.getTime()) / (1000 * 60 * 60 * 24);\n\n    // Mark records older than 365 days as stale (simulation)\n    if (daysSinceCreation > 365) {\n      staleRecords++;\n      // In a real app, we'd archive or delete\n      cleanedUp++;\n    }\n  }\n\n  const duration = Date.now() - startTime;\n\n  console.log(\n    `Cleanup complete: ${staleRecords} stale, ${cleanedUp} cleaned in ${duration}ms`\n  );\n\n  return { staleRecords, cleanedUp, duration };\n}\n\nexport function getCleanupThresholdDays(): number {\n  return 365;\n}\n```\n\n#### /workspace/packages/worker/tests/scheduler.test.ts\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { Scheduler } from '../src/scheduler.js';\n\ndescribe('Scheduler', () => {\n  let scheduler: Scheduler;\n\n  beforeEach(() => {\n    scheduler = new Scheduler();\n  });\n\n  it('registers a job', () => {\n    scheduler.register('test', () => {}, 1000);\n    const status = scheduler.getStatus();\n    expect(status).toHaveLength(1);\n    expect(status[0].name).toBe('test');\n  });\n\n  it('runs a job once', async () => {\n    let ran = false;\n    scheduler.register('test', () => { ran = true; }, 1000);\n    await scheduler.runOnce('test');\n    expect(ran).toBe(true);\n  });\n\n  it('tracks run count', async () => {\n    scheduler.register('test', () => {}, 1000);\n    await scheduler.runOnce('test');\n    await scheduler.runOnce('test');\n    const status = scheduler.getStatus();\n    expect(status[0].runCount).toBe(2);\n  });\n\n  it('throws for unknown job', async () => {\n    await expect(scheduler.runOnce('nonexistent')).rejects.toThrow(\n      \"Job 'nonexistent' not found\"\n    );\n  });\n\n  it('starts and stops', () => {\n    scheduler.register('test', () => {}, 60000);\n    scheduler.start();\n    expect(scheduler.isRunning()).toBe(true);\n    scheduler.stop();\n    expect(scheduler.isRunning()).toBe(false);\n  });\n});\n```\n\n#### /workspace/packages/worker/tests/sync.test.ts\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { syncJob, syncSingleUser } from '../src/jobs/sync.js';\nimport {\n  registerUser,\n  getAllUsers,\n  resetDefaultConnection,\n} from '@monorepo/core';\n\ndescribe('Sync Job', () => {\n  beforeEach(() => {\n    resetDefaultConnection();\n  });\n\n  it('syncs external users into the database', async () => {\n    await syncJob();\n    const users = getAllUsers();\n    expect(users.length).toBeGreaterThan(0);\n  });\n\n  it('skips already existing users on re-run', async () => {\n    await syncJob();\n    const countAfterFirst = getAllUsers().length;\n    await syncJob();\n    const countAfterSecond = getAllUsers().length;\n    expect(countAfterSecond).toBe(countAfterFirst);\n  });\n\n  it('syncs a single user by id', async () => {\n    const user = registerUser({\n      name: 'Sync Test',\n      email: 'sync@test.com',\n      role: 'user',\n    });\n    const result = await syncSingleUser(user.id);\n    expect(result).toBe(true);\n  });\n\n  it('returns false for nonexistent user sync', async () => {\n    const result = await syncSingleUser(999);\n    expect(result).toBe(false);\n  });\n});\n```\n\n#### /workspace/packages/worker/tests/cleanup.test.ts\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport { cleanupJob, getCleanupThresholdDays } from '../src/jobs/cleanup.js';\nimport { resetDefaultConnection } from '@monorepo/core';\n\ndescribe('Cleanup Job', () => {\n  beforeEach(() => {\n    resetDefaultConnection();\n  });\n\n  it('runs cleanup without errors', async () => {\n    const result = await cleanupJob();\n    expect(result).toBeDefined();\n    expect(result.duration).toBeGreaterThanOrEqual(0);\n  });\n\n  it('returns correct cleanup threshold', () => {\n    expect(getCleanupThresholdDays()).toBe(365);\n  });\n});\n```\n\n---\n\n### Tests Directory\n\n###