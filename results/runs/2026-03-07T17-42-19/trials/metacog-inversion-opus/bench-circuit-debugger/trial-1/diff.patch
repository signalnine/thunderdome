t;\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n    if (!progress) {\n      break;\n    }\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Inversion thinking: instead of asking \"what does a correct circuit look like?\",\n  // ask \"what structural violations indicate a swap?\"\n  //\n  // A ripple-carry adder has strict structural rules. Any violation = swapped wire.\n  // We apply rules iteratively, swapping wires back when we find pairs,\n  // until all 4 swaps are identified.\n\n  // Find the number of input bits\n  let maxBit = 0;\n  for (const gate of gates) {\n    for (const wire of [gate.in1, gate.in2]) {\n      const m = wire.match(/^x(\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));\n    }\n  }\n  const numBits = maxBit + 1;\n\n  // Work with a mutable copy so we can fix swaps as we find them\n  const mutableGates = gates.map((g) => ({ ...g }));\n\n  const swappedWires: string[] = [];\n\n  // Swap two output wires in the gate list\n  const swapOutputs = (wire1: string, wire2: string) => {\n    const g1 = mutableGates.find((g) => g.out === wire1);\n    const g2 = mutableGates.find((g) => g.out === wire2);\n    if (g1 && g2) {\n      g1.out = wire2;\n      g2.out = wire1;\n      swappedWires.push(wire1, wire2);\n    }\n  };\n\n  // Build lookup helpers (refreshed after each swap)\n  const buildLookups = () => {\n    const byOutput = new Map<string, Gate>();\n    for (const g of mutableGates) {\n      byOutput.set(g.out, g);\n    }\n\n    const findGate = (\n      op: string,\n      in1: string,\n      in2: string\n    ): Gate | undefined => {\n      return mutableGates.find(\n        (g) =>\n          g.op === op &&\n          ((g.in1 === in1 && g.in2 === in2) ||\n            (g.in1 === in2 && g.in2 === in1))\n      );\n    };\n\n    // Find a gate that uses a specific wire as input and has a specific op\n    const findGateWithInput = (\n      op: string,\n      input: string\n    ): Gate | undefined => {\n      return mutableGates.find(\n        (g) => g.op === op && (g.in1 === input || g.in2 === input)\n      );\n    };\n\n    return { byOutput, findGate, findGateWithInput };\n  };\n\n  // Iteratively apply structural rules and fix swaps\n  // We need to find exactly 4 swaps (8 wires)\n  for (let iteration = 0; iteration < 4 && swappedWires.length < 8; iteration++) {\n    const { byOutput, findGate, findGateWithInput } = buildLookups();\n    let foundSwap = false;\n\n    const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n    // Rule 1: z-outputs (except last) must be produced by XOR\n    for (let bit = 0; bit < numBits; bit++) {\n      const zWire = `z${String(bit).padStart(2, '0')}`;\n      const gate = byOutput.get(zWire);\n      if (gate && gate.op !== 'XOR') {\n        // This z-output is produced by wrong gate type\n        // Find the wire that SHOULD be here: for bit 0, it's x00 XOR y00\n        // For bit > 0, it's partialSum XOR carry\n        if (bit === 0) {\n          const correctGate = findGate(\n            'XOR',\n            `x${String(bit).padStart(2, '0')}`,\n            `y${String(bit).padStart(2, '0')}`\n          );\n          if (correctGate) {\n            swapOutputs(zWire, correctGate.out);\n            foundSwap = true;\n            break;\n          }\n        } else {\n          // For bit > 0, find the XOR gate whose inputs include the partial sum for this bit\n          const xWire = `x${String(bit).padStart(2, '0')}`;\n          const yWire = `y${String(bit).padStart(2, '0')}`;\n          const partialSumGate = findGate('XOR', xWire, yWire);\n          if (partialSumGate) {\n            // Find XOR gate that uses partialSumGate.out as input\n            const zCandidate = findGateWithInput('XOR', partialSumGate.out);\n            if (\n              zCandidate &&\n              zCandidate.out !== zWire &&\n              zCandidate !== partialSumGate\n            ) {\n              swap