+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  while (remaining.length > 0) {
+    let progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      const v1 = wires[gate.in1];
+      const v2 = wires[gate.in2];
+      if (v1 !== undefined && v2 !== undefined) {
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = v1 & v2;
+            break;
+          case 'OR':
+            result = v1 | v2;
+            break;
+          case 'XOR':
+            result = v1 ^ v2;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        progress = true;
+      }
+    }
+    if (!progress) {
+      break;
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Find max input bit
+  let maxBit = 0;
+  for (const gate of gates) {
+    for (const wire of [gate.in1, gate.in2]) {
+      const m = wire.match(/^x(\d+)$/);
+      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));
+    }
+  }
+  const numBits = maxBit + 1;
+  const lastZ = `z${String(numBits).padStart(2, '0')}`;
+
+  // Work with mutable gates - fix swaps as we find them
+  const mGates = gates.map((g) => ({ ...g }));
+  const swappedWires: string[] = [];
+
+  const doSwap = (w1: string, w2: string) => {
+    const g1 = mGates.find((g) => g.out === w1);
+    const g2 = mGates.find((g) => g.out === w2);
+    if (g1 && g2) {
+      g1.out = w2;
+      g2.out = w1;
+      swappedWires.push(w1, w2);
+    }
+  };
+
+  // Helpers rebuild after each swap
+  const lookup = () => {
+    const find = (op: string, a: string, b: string): Gate | undefined =>
+      mGates.find(
+        (g) =>
+          g.op === op &&
+          ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a))
+      );
+
+    const findByInput = (op: string, wire: string): Gate | undefined =>
+      mGates.find(
+        (g) => g.op === op && (g.in1 === wire || g.in2 === wire)
+      );
+
+    return { find, findByInput };
+  };
+
+  const pad = (n: number) => String(n).padStart(2, '0');
+
+  // Iteratively find and fix swaps
+  for (let iter = 0; iter < 8 && swappedWires.length < 8; iter++) {
+    const { find, findByInput } = lookup();
+    let found = false;
+
+    // Walk the full adder chain, checking each bit's structure
+    let carry: string | undefined;
+
+    // Bit 0: half adder
+    // x00 XOR y00 -> z00
+    const xor0 = find('XOR', 'x00', 'y00');
+    const and0 = find('AND', 'x00', 'y00');
+    if (!xor0 || !and0) break;
+
+    if (xor0.out !== 'z00') {
+      // z00 is swapped with whatever xor0 currently outputs
+      doSwap(xor0.out, 'z00');
+      found = true;
+    }
+    if (found) continue;
+
+    carry = and0.out;
+
+    // Bits 1..numBits-1: full adders
+    for (let bit = 1; bit < numBits; bit++) {
+      const x = `x${pad(bit)}`;
+      const y = `y${pad(bit)}`;
+      const z = `z${pad(bit)}`;
+
+      const xyXor = find('XOR', x, y);
+      const xyAnd = find('AND', x, y);
+      if (!xyXor || !xyAnd || !carry) break;
+
+      const ps = xyXor.out; // partial sum wire
+
+      // Check: ps XOR carry -> z
+      const zGate = find('XOR', ps, carry);
+      if (!zGate) {
+        // Either ps or carry is in the wrong place.
+        // Check if there's an XOR using carry (not the xy XOR)
+        const xorUsingCarry = mGates.find(
+          (g) =>
+            g.op === 'XOR' &&
+            g !== xyXor &&
+            (g.in1 === carry || g.in2 === carry)
+        );
+        if (xorUsingCarry) {
+          // The other input should be ps but isn't
+          const other =
+            xorUsingCarry.in1 === carry
+              ? xorUsingCarry.in2
+              : xorUsingCarry.in1;
+          doSwap(ps, other);
+          found = true;
+          break;
+        }
+        // Check if there's an XOR using ps (not the xy XOR)
+        const xorUsingPS = mGates.find(
+          (g) =>
+            g.op === 'XOR' &&
+            g !== xyXor &&
+            (g.in1 === ps || g.in2 === ps)
+        );
+        if (xorUsingPS) {
+          const other =
+            xorUsingPS.in1 === ps ? xorUsingPS.in2 : xorUsingPS.in1;
+          doSwap(carry, other);
+          found = true;
+          break;
+        }
+        break;
+      }
+
+      // Check: zGate should output z
+      if (zGate.out !== z) {
+        doSwap(zGate.out, z);
+        found = true;
+        break;
+      }
+
+      // Check: ps AND carry -> propagate
+      const curPS = xyXor.out;
+      const propGate = find('AND', curPS, carry);
+      if (!propGate) {
+        // Similar logic: one of curPS or carry is wrong, but we already
+        // verified they work for XOR. Since AND uses the same pair,
+        // this shouldn't happen unless the AND gate itself doesn't exist.
+        // Look for AND using carry
+        const andUsingCarry = mGates.find(
+          (g) =>
+            g.op === 'AND' &&
+            g !== xyAnd &&
+            (g.in1 === carry || g.in2 === carry)
+        );
+        if (andUsingCarry) {
+          const other =
+            andUsingCarry.in1 === carry
+              ? andUsingCarry.in2
+              : andUsingCarry.in1;
+          doSwap(curPS, other);
+          found = true;
+          break;
+        }
+        break;
+      }
+      const propagate = propGate.out;
+
+      // Check: generate (xyAnd.out) OR propagate -> carry_out
+      const generate = xyAnd.out;
+      const carryOutGate = find('OR', generate, propagate);
+      if (!carryOutGate) {
+        // One of generate or propagate is wrong
+        const orUsingGen = findByInput('OR', generate);
+        if (orUsingGen) {
+          const other =
+            orUsingGen.in1 === generate
+              ? orUsingGen.in2
+              : orUsingGen.in1;
+          doSwap(propagate, other);
+          found = true;
+          break;
+        }
+        const orUsingProp = findByInput('OR', propagate);
+        if (orUsingProp) {
+          const other =
+            orUsingProp.in1 === propagate
+              ? orUsingProp.in2
+              : orUsingProp.in1;
+          doSwap(generate, other);
+          found = true;
+          break;
+        }
+        break;
+      }
+
+      carry = carryOutGate.out;
+    }
+
+    if (found) continue;
+
+    // Check the final carry -> last z
+    if (carry && carry !== lastZ) {
+      doSwap(carry, lastZ);
+      continue;
+    }
+
+    // If we get here without finding a swap, we're done or stuck
+    break;
+  }
+
+  return swappedWires.sort();
+}
