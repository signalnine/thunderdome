cribe('simulate', () => {\n  it('should simulate AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should simulate OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should simulate XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, d: 0, c: 1, e: 1,\n    });\n    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({\n      a: 0, b: 1, d: 0, c: 0, e: 0,\n    });\n  });\n\n  it('should handle gates listed in reverse dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, d: 0, c: 1, e: 1,\n    });\n  });\n\n  it('should simulate a 2-bit adder', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n    // 1 + 1 = 2 (01 + 01 = 010)\n    const r1 = simulate(gates, { x00: 1, x01: 0, y00: 1, y01: 0 });\n    expect(r1.z00).toBe(0);\n    expect(r1.z01).toBe(1);\n    expect(r1.z02).toBe(0);\n\n    // 3 + 3 = 6 (11 + 11 = 110)\n    const r2 = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n    expect(r2.z00).toBe(0);\n    expect(r2.z01).toBe(1);\n    expect(r2.z02).toBe(1);\n\n    // 2 + 1 = 3 (10 + 01 = 011)\n    const r3 = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });\n    expect(r3.z00).toBe(1);\n    expect(r3.z01).toBe(1);\n    expect(r3.z02).toBe(0);\n  });\n});\n\n// Build a correct N-bit adder with wire names that use prefixed labels\nfunction buildAdder(numBits: number): Gate[] {\n  const gates: Gate[] = [];\n  const pad = (n: number) => String(n).padStart(2, '0');\n\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `z${pad(0)}` });\n  gates.push({ op: 'AND', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `c${pad(0)}` });\n\n  for (let i = 1; i < numBits; i++) {\n    const x = `x${pad(i)}`;\n    const y = `y${pad(i)}`;\n    const z = `z${pad(i)}`;\n    const t = `t${pad(i)}`;\n    const a = `a${pad(i)}`;\n    const b = `b${pad(i)}`;\n    const c = `c${pad(i)}`;\n    const cPrev = `c${pad(i - 1)}`;\n\n    gates.push({ op: 'XOR', in1: x, in2: y, out: t });\n    gates.push({ op: 'XOR', in1: t, in2: cPrev, out: z });\n    gates.push({ op: 'AND', in1: x, in2: y, out: a });\n    gates.push({ op: 'AND', in1: t, in2: cPrev, out: b });\n    gates.push({ op: 'OR', in1: a, in2: b, out: c });\n  }\n\n  // Last carry -> last z\n  const lastBit = numBits - 1;\n  const lastCarryGate = gates.find(g => g.out === `c${pad(lastBit)}`);\n  if (lastCarryGate) {\n    lastCarryGate.out = `z${pad(numBits)}`;\n  }\n\n  return gates;\n}\n\n// Get all output wire names from a gate list\nfunction getOutputWires(gates: Gate[]): string[] {\n  return gates.map(g => g.out);\n}\n\n// Swap two output wires\nfunction swapWires(gates: Gate[], w1: string, w2: string): Gate[] {\n  return gates.map(g => {\n    if (g.out === w1) return { ...g, out: w2 };\n    if (g.out === w2) return { ...g, out: w1 };\n    return { ...g };\n  });\n}\n\nfunction shuffleGates(gates: Gate[]): Gate[] {\n  const shuffled = [...gates];\n  for (let i = shuffled.length - 1; i > 0; i--) {\n    const j = Math.floor(Math.random() * (i + 1));\n    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];\n  }\n  return shuffled;\n}\n\ndescribe('findSwappedWires', () => {\n  it('should find swapped wires in a 4-bit adder', () => {\n    // 4-bit adder wires:\n    // z00, c00, t01, z01, a01, b01, c01, t02, z02, a02, b02, c02, t03, z03, a03, b03, z04\n    // Note: z04 was renamed from c03\n    let gates = buildAdder(4);\n    // Swap 1: z01 <-> a01 (z-output with AND generate)\n    // Swap 2: z02 <-> b02 (z-output with AND propagate)\n    // Swap 3: t03 <-> z03 (partial sum with z-output in same bit)\n    // Swap 4: c00 <-> z04 (first carry with last z)\n    gates = swapWires(gates, 'z01', 'a01');\n    gates = swapWires(gates, 'z02', 'b02');\n    gates = swapWires(gates, 't03', 'z03');\n    gates = swapWires(gates, 'c00', 'z04');\n    gates = shuffleGates(gates);\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'b02', 'c00', 't03', 'z01', 'z02', 'z03', 'z04'].sort());\n  });\n\n  it('should find swapped wires in an 8-bit adder', () => {\n    let gates = buildAdder(8);\n    // Swap 1: z03 <-> a03 (z with generate)\n    // Swap 2: z05 <-> t05 (z with partial sum, different bit context - same bit here)\n    // Swap 3: c02 <-> b03 (carry of bit 2 with propagate of bit 3)\n    // Swap 4: z08 <-> a07 (last z with generate of bit 7)\n    gates = swapWires(gates, 'z03', 'a03');\n    gates = swapWires(gates, 'z05', 't05');\n    gates = swapWires(gates, 'c02', 'b03');\n    gates = swapWires(gates, 'z08', 'a07');\n    gates = shuffleGates(gates);\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a03', 'a07', 'b03', 'c02', 't05', 'z03', 'z05', 'z08'].sort());\n  });\n\n  it('should find swapped wires where partial sum is swapped with carry', () => {\n    let gates = buildAdder(10);\n    // Swap 1: t02 <-> c01 (partial sum of bit 2 swapped with carry of bit 1)\n    // Swap 2: z05 <-> a05 (z with generate)\n    // Swap 3: t08 <-> z08 (partial sum with z of same bit)\n    // Swap 4: z10 <-> c08 (last z with carry of bit 8)\n    gates = swapWires(gates, 't02', 'c01');\n    gates = swapWires(gates, 'z05', 'a05');\n    gates = swapWires(gates, 't08', 'z08');\n    gates = swapWires(gates, 'z10', 'c08');\n    gates = shuffleGates(gates);\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a05', 'c01', 'c08', 't02', 't08', 'z05', 'z08', 'z10'].sort());\n  });\n\n  it('should handle a 45-bit adder within 5 seconds', () => {\n    let gates = buildAdder(45);\n    // Swap 1: z05 <-> a05\n    // Swap 2: z20 <-> t20\n    // Swap 3: c30 <-> b31 (carry of 30 with propagate of 31)\n    // Swap 4: z45 <-> c43 (last z with carry of 43)\n    gates = swapWires(gates, 'z05', 'a05');\n    gates = swapWires(gates, 'z20', 't20');\n    gates = swapWires(gates, 'c30', 'b31');\n    gates = swapWires(gates, 'z45', 'c43');\n    gates = shuffleGates(gates);\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(['a05', 'b31', 'c30', 'c43', 't20', 'z05', 'z20', 'z45'].sort());\n  });\n\n  it('should verify the fixed circuit produces correct results', () => {\n    let gates = buildAdder(4);\n    // Verify the unswapped adder works\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 0, x03: 1, // 11 = 1011\n      y00: 1, y01: 0, y02: 1, y03: 0, // 5 = 0101\n    };\n    const result = simulate(gates, inputs);\n    // 11 + 5 = 16 = 10000\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(0);\n    expect(result.z04).toBe(1);\n  });\n});\n","structuredPatch":[{"oldStart":174,"oldLines":20,"newStart":174,"newLines":20,"lines":["     expect(result).toEqual(['a03', 'a07', 'b03', 'c02', 't05', 'z03', 'z05', 'z08'].sort());","   });"," ","-  it('should find swapped wires where partial sum is swapped with carry', () => {","+  it('should find swapped wires with carry and generate cross-bit swap', () => {","     let gates = buildAdder(10);","-    // Swap 1: t02 <-> c01 (partial sum of bit 2 swapped with carry of bit 1)","+    // Swap 1: c02 <-> a04 (carry of bit 2 swapped with generate of bit 4)","     // Swap 2: z05 <-> a05 (z with generate)","     // Swap 3: t08 <-> z08 (partial sum with z of same bit)","-    // Swap 4: z10 <-> c08 (last z with carry of bit 8)","-    gates = swapWires(gates, 't02', 'c01');","+    // Swap 4: z10 <-> b09 (last z with propagate of bit 9)","+    gates = swapWires(gates, 'c02', 'a04');","     gates = swapWires(gates, 'z05', 'a05');","     gates = swapWires(gates, 't08', 'z08');","-    gates = swapWires(gates, 'z10', 'c08');","+    gates = swapWires(gates, 'z10', 'b09');","     gates = shuffleGates(gates);"," ","     const result = findSwappedWires(gates);","-    expect(result).toEqual(['a05', 'c01', 'c08', 't02', 't08', 'z05', 'z08', 'z10'].sort());","+    expect(result).toEqual(['a04', 'a05', 'b09', 'c02', 't08', 'z05', 'z08', 'z1