Bit + 1;\n\n  // Work with a mutable copy so we can fix swaps as we find them\n  const mutableGates = gates.map((g) => ({ ...g }));\n\n  const swappedWires: string[] = [];\n\n  // Swap two output wires in the gate list\n  const swapOutputs = (wire1: string, wire2: string) => {\n    const g1 = mutableGates.find((g) => g.out === wire1);\n    const g2 = mutableGates.find((g) => g.out === wire2);\n    if (g1 && g2) {\n      g1.out = wire2;\n      g2.out = wire1;\n      swappedWires.push(wire1, wire2);\n    }\n  };\n\n  // Build lookup helpers (refreshed after each swap)\n  const buildLookups = () => {\n    const byOutput = new Map<string, Gate>();\n    for (const g of mutableGates) {\n      byOutput.set(g.out, g);\n    }\n\n    const findGate = (\n      op: string,\n      in1: string,\n      in2: string\n    ): Gate | undefined => {\n      return mutableGates.find(\n        (g) =>\n          g.op === op &&\n          ((g.in1 === in1 && g.in2 === in2) ||\n            (g.in1 === in2 && g.in2 === in1))\n      );\n    };\n\n    // Find a gate that uses a specific wire as input and has a specific op\n    const findGateWithInput = (\n      op: string,\n      input: string\n    ): Gate | undefined => {\n      return mutableGates.find(\n        (g) => g.op === op && (g.in1 === input || g.in2 === input)\n      );\n    };\n\n    return { byOutput, findGate, findGateWithInput };\n  };\n\n  // Iteratively apply structural rules and fix swaps\n  // We need to find exactly 4 swaps (8 wires)\n  for (let iteration = 0; iteration < 4 && swappedWires.length < 8; iteration++) {\n    const { byOutput, findGate, findGateWithInput } = buildLookups();\n    let foundSwap = false;\n\n    const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n    // Rule 1: z-outputs (except last) must be produced by XOR\n    for (let bit = 0; bit < numBits; bit++) {\n      const zWire = `z${String(bit).padStart(2, '0')}`;\n      const gate = byOutput.get(zWire);\n      if (gate && gate.op !== 'XOR') {\n        // This z-output is produced by wrong gate type\n        // Find the wire that SHOULD be here: for bit 0, it's x00 XOR y00\n        // For bit > 0, it's partialSum XOR carry\n        if (bit === 0) {\n          const correctGate = findGate(\n            'XOR',\n            `x${String(bit).padStart(2, '0')}`,\n            `y${String(bit).padStart(2, '0')}`\n          );\n          if (correctGate) {\n            swapOutputs(zWire, correctGate.out);\n            foundSwap = true;\n            break;\n          }\n        } else {\n          // For bit > 0, find the XOR gate whose inputs include the partial sum for this bit\n          const xWire = `x${String(bit).padStart(2, '0')}`;\n          const yWire = `y${String(bit).padStart(2, '0')}`;\n          const partialSumGate = findGate('XOR', xWire, yWire);\n          if (partialSumGate) {\n            // Find XOR gate that uses partialSumGate.out as input\n            const zCandidate = findGateWithInput('XOR', partialSumGate.out);\n            if (\n              zCandidate &&\n              zCandidate.out !== zWire &&\n              zCandidate !== partialSumGate\n            ) {\n              swapOutputs(zWire, zCandidate.out);\n              foundSwap = true;\n              break;\n            }\n          }\n        }\n      }\n    }\n    if (foundSwap) continue;\n\n    // Rule 2: XOR gates with x/y inputs (bit > 0) should NOT output z directly\n    for (const gate of mutableGates) {\n      if (gate.op !== 'XOR') continue;\n      const m1 = gate.in1.match(/^([xy])(\\d+)$/);\n      const m2 = gate.in2.match(/^([xy])(\\d+)$/);\n      if (!m1 || !m2 || m1[2] !== m2[2] || m1[1] === m2[1]) continue;\n      const bitNum = parseInt(m1[2]);\n      if (bitNum === 0) continue;\n      if (/^z\\d+$/.test(gate.out)) {\n        // This x XOR y gate outputs directly to z, which is wrong for bit > 0\n        // The correct output for this gate is the partial sum wire\n        // The z output should come from a different XOR gate\n        // Find the XOR gate that should produce this z\n        const zBit = parseInt(gate.out.slice(1));\n        const zWire = gate.out;\n        // The z-producing gate should be XOR of (partial sum for zBit) and carry\n        // Since this gate IS the partial sum for bitNum, and bitNum != zBit necessarily,\n        // we need to find what should actually output to zWire\n        // But actually, let's find the gate that uses this partial sum as input (another XOR)\n        const downstreamXOR = mutableGates.find(\n          (g) =>\n            g.op === 'XOR' &&\n            g !== gate &&\n            (g.in1 === gate.out || g.in2 === gate.out)\n        );\n        if (downstreamXOR) {\n          // This is confusing - the wire name is currently z, but downstream uses it\n          // Actually, we should look for what this gate's output should be swapped with\n          // The downstream XOR uses gate.out as input, and should output to z\n          // But gate.out IS a z wire, so... let's think differently\n          //\n          // The actual fix: find the XOR gate that should produce z[zBit]\n          const xz = `x${String(zBit).padStart(2, '0')}`;\n          const yz = `y${String(zBit).padStart(2, '0')}`;\n          const partialForZ = findGate('XOR', xz, yz);\n          if (partialForZ) {\n            const zProducer = findGateWithInput('XOR', partialForZ.out);\n            if (zProducer && zProducer !== partialForZ) {\n              swapOutputs(zWire, zProducer.out);\n              foundSwap = true;\n              break;\n            }\n          }\n        }\n        if (!foundSwap) {\n          // Simpler approach: just mark this as swapped and find partner later\n          // Actually, find what gate uses this gate's output as input\n          // The partial sum for bit bitNum should feed into XOR with carry -> z[bitNum]\n          // and into AND with carry -> propagate\n          // Since gate.out is wrongly z, the real partial sum wire name is somewhere else\n          // and what should be z is that other wire\n          // Find the gate that should output z[bitNum]\n          const xb = `x${String(bitNum).padStart(2, '0')}`;\n          const yb = `y${String(bitNum).padStart(2, '0')}`;\n          // This gate IS xb XOR yb, but outputs z[zBit]\n          // We need the XOR gate whose inputs use something and carry, and whose output\n          // should be z[zBit]\n          // Let's try: find what currently produces the partial sum wire for z[zBit]\n          const xzb = `x${String(zBit).padStart(2, '0')}`;\n          const yzb = `y${String(zBit).padStart(2, '0')}`;\n          const psForZ = findGate('XOR', xzb, yzb);\n          if (psForZ) {\n            const zProd = findGateWithInput('XOR', psForZ.out);\n            if (zProd && zProd !== psForZ) {\n              swapOutputs(zWire, zProd.out);\n              foundSwap = true;\n              break;\n            }\n          }\n        }\n      }\n    }\n    if (foundSwap) continue;\n\n    // Rule 3: Non-x/y XOR gates should output z\n    for (const gate of mutableGates) {\n      if (gate.op !== 'XOR') continue;\n      const m1 = gate.in1.match(/^[xy]\\d+$/);\n      const m2 = gate.in2.match(/^[xy]\\d+$/);\n      if (m1 && m2) continue; // skip x/y XOR gates\n      if (/^z\\d+$/.test(gate.out)) continue; // already outputs z, fine\n\n      // This non-x/y XOR gate should output z but doesn't\n      // Find which z it should output to: look at its inputs\n      // One input should be a partial sum (x XOR y) for some bit\n      // The corresponding z should be the output\n      const in1Gate = byOutput.get(gate.in1);\n      const in2Gate = byOutput.get(gate.in2);\n\n      let targetBit = -1;\n      if (in1Gate && in1Gate.op === 'XOR') {\n        const m = in1Gate.in1.match(/^[xy](\\d+)$/);\n        if (m) targetBit = parseInt(m[1]);\n      }\n      if (targetBit === -1 && in2Gate && in2Gate.op === 'XOR') {\n        const m = in2Gate.in1.match(/^[xy](\\d+)$/