ps = xyXor.out; // partial sum wire\n\n      // Check: ps XOR carry -> z\n      let zGate = find('XOR', ps, carry);\n      if (!zGate) {\n        // Either ps or carry is in the wrong place.\n        // Check if there's an XOR using carry (not the xy XOR)\n        const xorUsingCarry = mGates.find(\n          (g) =>\n            g.op === 'XOR' &&\n            g !== xyXor &&\n            (g.in1 === carry || g.in2 === carry)\n        );\n        if (xorUsingCarry) {\n          // The other input should be ps but isn't\n          const other =\n            xorUsingCarry.in1 === carry\n              ? xorUsingCarry.in2\n              : xorUsingCarry.in1;\n          doSwap(ps, other);\n          found = true;\n          break;\n        }\n        // Check if there's an XOR using ps (not the xy XOR)\n        const xorUsingPS = mGates.find(\n          (g) =>\n            g.op === 'XOR' &&\n            g !== xyXor &&\n            (g.in1 === ps || g.in2 === ps)\n        );\n        if (xorUsingPS) {\n          const other =\n            xorUsingPS.in1 === ps ? xorUsingPS.in2 : xorUsingPS.in1;\n          doSwap(carry, other);\n          found = true;\n          break;\n        }\n        break;\n      }\n\n      // Check: zGate should output z\n      if (zGate.out !== z) {\n        doSwap(zGate.out, z);\n        found = true;\n        break;\n      }\n\n      // Check: ps AND carry -> propagate\n      // Need to re-lookup ps since it might have been swapped\n      const curPS = xyXor.out;\n      const propGate = find('AND', curPS, carry);\n      if (!propGate) break;\n      const propagate = propGate.out;\n\n      // Check: generate (xyAnd.out) OR propagate -> carry_out\n      const generate = xyAnd.out;\n      const carryOutGate = find('OR', generate, propagate);\n      if (!carryOutGate) {\n        // One of generate or propagate is wrong\n        const orUsingGen = findByInput('OR', generate);\n        if (orUsingGen) {\n          const other =\n            orUsingGen.in1 === generate\n              ? orUsingGen.in2\n              : orUsingGen.in1;\n          doSwap(propagate, other);\n          found = true;\n          break;\n        }\n        const orUsingProp = findByInput('OR', propagate);\n        if (orUsingProp) {\n          const other =\n            orUsingProp.in1 === propagate\n              ? orUsingProp.in2\n              : orUsingProp.in1;\n          doSwap(generate, other);\n          found = true;\n          break;\n        }\n        break;\n      }\n\n      carry = carryOutGate.out;\n    }\n\n    if (found) continue;\n\n    // Check the final carry -> last z\n    if (carry && carry !== lastZ) {\n      doSwap(carry, lastZ);\n      continue;\n    }\n\n    // If we get here without finding a swap, we're done or stuck\n    break;\n  }\n\n  return swappedWires.sort();\n}\n","structuredPatch":[{"oldStart":128,"oldLines":7,"newStart":128,"newLines":7,"lines":["       const ps = xyXor.out; // partial sum wire"," ","       // Check: ps XOR carry -> z","-      let zGate = find('XOR', ps, carry);","+      const zGate = find('XOR', ps, carry);","       if (!zGate) {","         // Either ps or carry is in the wrong place.","         // Check if there's an XOR using carry (not the xy XOR)"]}],"userModified":false,"replaceAll":false}}
