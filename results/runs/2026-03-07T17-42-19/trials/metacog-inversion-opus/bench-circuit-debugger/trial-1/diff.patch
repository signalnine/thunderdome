         swapOutputs(partialSum, otherInput);\n          foundSwap = true;\n          break;\n        }\n\n        // Check: does any XOR gate use partialSum as input (not the x/y XOR)?\n        const xorWithPS = mutableGates.find(\n          (g) =>\n            g.op === 'XOR' &&\n            g !== partialSumGate &&\n            (g.in1 === partialSum || g.in2 === partialSum)\n        );\n        if (xorWithPS) {\n          const otherInput =\n            xorWithPS.in1 === partialSum\n              ? xorWithPS.in2\n              : xorWithPS.in1;\n          // otherInput should be carry but isn't -> carry is swapped with otherInput\n          swapOutputs(carry, otherInput);\n          foundSwap = true;\n          break;\n        }\n\n        break;\n      }\n\n      // Find propagate: partialSum AND carry\n      const propagateGate = findGate('AND', partialSum, carry);\n      if (!propagateGate) break;\n      const propagate = propagateGate.out;\n\n      // Find carry out: generate OR propagate\n      const carryOutGate = findGate('OR', generate, propagate);\n      if (!carryOutGate) {\n        // Try to find an OR gate with generate\n        const orWithGen = findGateWithInput('OR', generate);\n        if (orWithGen) {\n          const otherInput =\n            orWithGen.in1 === generate ? orWithGen.in2 : orWithGen.in1;\n          // otherInput should be propagate -> propagate is swapped\n          swapOutputs(propagate, otherInput);\n          foundSwap = true;\n          break;\n        }\n        // Try with propagate\n        const orWithProp = findGateWithInput('OR', propagate);\n        if (orWithProp) {\n          const otherInput =\n            orWithProp.in1 === propagate\n              ? orWithProp.in2\n              : orWithProp.in1;\n          swapOutputs(generate, otherInput);\n          foundSwap = true;\n          break;\n        }\n        break;\n      }\n\n      carry = carryOutGate.out;\n\n      // Verify: if this is the last bit, carry should be t