9→\n   860→// ============================================================\n   861→// Persistence Tests\n   862→// ============================================================\n   863→\n   864→describe('Persistence', () => {\n   865→  const dbPath = '/tmp/test-collab-persist-' + Date.now() + '.db';\n   866→\n   867→  it('Document survives server restart', async () => {\n   868→    const app1 = createApp(dbPath);\n   869→    await app1.start(0);\n   870→\n   871→    await request(app1.app).post('/docs').send({ title: 'Persistent', content: 'data' });\n   872→    const docs1 = await request(app1.app).get('/docs');\n   873→    expect(docs1.body.length).toBe(1);\n   874→\n   875→    await app1.stop();\n   876→\n   877→    const app2 = createApp(dbPath);\n   878→    await app2.start(0);\n   879→\n   880→    const docs2 = await request(app2.app).get('/docs');\n   881→    expect(docs2.body.length).toBe(1);\n   882→    expect(docs2.body[0].title).toBe('Persistent');\n   883→    expect(docs2.body[0].content).toBe('data');\n   884→\n   885→    await app2.stop();\n   886→  });\n   887→\n   888→  it('Edit history survives server restart', async () => {\n   889→    const app1 = createApp(dbPath);\n   890→    await app1.start(0);\n   891→\n   892→    const docs = await request(app1.app).get('/docs');\n   893→    const docId = docs.body[0].id;\n   894→    const versions1 = await request(app1.app).get(`/docs/${docId}/versions`);\n   895→\n   896→    await app1.stop();\n   897→\n   898→    const app2 = createApp(dbPath);\n   899→    await app2.start(0);\n   900→\n   901→    const versions2 = await request(app2.app).get(`/docs/${docId}/versions`);\n   902→    expect(versions2.body.length).toBe(versions1.body.length);\n   903→\n   904→    await app2.stop();\n   905→  });\n   906→\n   907→  it('Active connections cleared on restart', async () => {\n   908→    const app1 = createApp(dbPath);\n   909→    const port1 = await app1.start(0);\n   910→\n   911→    const docs = await request(app1.app).get('/docs');\n   912→    const docId = docs.body[0].id;\n   913→\n   914→    const client = await createWsClient(port1, docId);\n   915→    await waitForMsg(client, 0);\n   916→\n   917→    const connsBefore = app1.db.prepare('SELECT COUNT(*) as cnt FROM active_connections').get() as { cnt: number };\n   918→    expect(connsBefore.cnt).toBeGreaterThan(0);\n   919→\n   920→    await closeClient(client);\n   921→    await app1.stop();\n   922→\n   923→    const app2 = createApp(dbPath);\n   924→    await app2.start(0);\n   925→\n   926→    const connsAfter = app2.db.prepare('SELECT COUNT(*) as cnt FROM active_connections').get() as { cnt: number };\n   927→    expect(connsAfter.cnt).toBe(0);\n   928→\n   929→    await app2.stop();\n   930→  });\n   931→});"}]},"parent_tool_use_id":null,"session_id":"a385afca-4d5c-4f6f-afb7-d1f1b6ecbdbd","uuid":"68f8998c-c4ff-4373-8602-403bbfd2ff28","tool_use_result":{"type":"text","file":{"filePath":"/tmp/.claude/projects/-workspace/a385afca-4d5c-4f6f-afb7-d1f1b6ecbdbd/tool-results/toolu_01W1m7KGBrgosixpQRP7r46c.txt","content":"import { describe, it, expect, beforeAll, afterAll } from 'vitest';\nimport request from 'supertest';\nimport WebSocket from 'ws';\nimport { createApp, type AppInstance } from '../src/server.js';\n\n// ============================================================\n// Test Helpers\n// ============================================================\n\ninterface WsClient {\n  ws: WebSocket;\n  messages: Record<string, unknown>[];\n}\n\nfunction createWsClient(port: number, docId: string): Promise<WsClient> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(`ws://localhost:${port}/${docId}`);\n    const messages: Record<string, unknown>[] = [];\n    ws.on('message', (data) => {\n      messages.push(JSON.parse(data.toString()));\n    });\n    ws.on('open', () => resolve({ ws, messages }));\n    ws.on('error', reject);\n  });\n}\n\n/** Wait for the messages array to have at least `idx + 1` entries, then return messages[idx]. */\nfunction waitForMsg(client: WsClient, idx: number, timeout = 3000): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    if (client.messages.length > idx) {\n      resolve(client.messages[idx]);\n      return;\n    }\n    const timer = setTimeout(\n      () => reject(new Error(`Timed out waiting for message at index ${idx} (have ${client.messages.length})`)),\n      timeout\n    );\n    const interval = setInterval(() => {\n      if (client.messages.length > idx) {\n        clearTimeout(timer);\n        clearInterval(interval);\n        resolve(client.messages[idx]);\n      }\n    }, 5);\n  });\n}\n\n\nfunction delay(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction sendOp(client: WsClient, operation: Record<string, unknown>, version?: number) {\n  const msg: Record<string, unknown> = { type: 'operation', operation };\n  if (version !== undefined) msg.version = version;\n  client.ws.send(JSON.stringify(msg));\n}\n\nfunction closeClient(client: WsClient): Promise<void> {\n  return new Promise((resolve) => {\n    if (client.ws.readyState === WebSocket.CLOSED || client.ws.readyState === WebSocket.CLOSING) {\n      resolve();\n      return;\n    }\n    client.ws.on('close', () => resolve());\n    client.ws.close();\n  });\n}\n\n// ============================================================\n// REST CRUD Tests\n// ============================================================\n\ndescribe('REST CRUD', () => {\n  let app: AppInstance;\n\n  beforeAll(async () => {\n    app = createApp();\n    await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('POST /docs creates document with title', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Test Doc' });\n    expect(res.status).toBe(201);\n    expect(res.body.title).toBe('Test Doc');\n  });\n\n  it('POST /docs returns id, title, content, timestamps', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Full Doc' });\n    expect(res.body).toHaveProperty('id');\n    expect(res.body).toHaveProperty('title');\n    expect(res.body).toHaveProperty('content');\n    expect(res.body).toHaveProperty('created_at');\n    expect(res.body).toHaveProperty('updated_at');\n  });\n\n  it('GET /docs lists all documents', async () => {\n    const res = await request(app.app).get('/docs');\n    expect(res.status).toBe(200);\n    expect(Array.isArray(res.body)).toBe(true);\n    expect(res.body.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it('GET /docs/:id returns specific document', async () => {\n    const created = await request(app.app).post('/docs').send({ title: 'Specific' });\n    const res = await request(app.app).get(`/docs/${created.body.id}`);\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Specific');\n  });\n\n  it('GET /docs/:id returns 404 for non-existent', async () => {\n    const res = await request(app.app).get('/docs/nonexistent-id');\n    expect(res.status).toBe(404);\n  });\n\n  it('PUT /docs/:id updates title', async () => {\n    const created = await request(app.app).post('/docs').send({ title: 'Old Title' });\n    const res = await request(app.app).put(`/docs/${created.body.id}`).send({ title: 'New Title' });\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('New Title');\n  });\n\n  it('DELETE /docs/:id removes document', async () => {\n    const created = await request(app.app).post('/docs').send({ title: 'To Delete' });\n    const res = await request(app.app).delete(`/docs/${created.body.id}`);\n    expect(res.status).toBe(204);\n    const check = await request(app.app).get(`/docs/${created.body.id}`);\n    expect(check.status).toBe(404);\n  });\n\n  it('DELETE /docs/:id returns 404 for non-existent', async () => {\n    const res = await request(app.app).delete('/docs/nonexistent-id');\n    expect(res.status).toBe(404);\n  });\n\n  it('GET /docs/:id/versions lists version history', async () => {\n    const created = await request(app.app).post('/docs').send({ title: 'Versioned' });\n    const res = await request(app.app).get(`/docs/${created.body.id}/versions`);\n    expect(res.status).toBe(200);\n    expect(Array.isArray(res.body)).toBe(true);\n    expect(res.body.length).toBeGreaterThanOrEqual(1);\n    expect(res.body[0].version).toBe(0);\n  });\n\n  it('GET /docs/:id/versions/:version returns specific version content', async () => {\n    const created = await request(app.app).post('/docs').send({ title: 'Versioned2' });\n    const res = await request(app.app).get(`/docs/${created.body.id}/versions/0`);\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveProperty('content');\n    expect(res.body.version).toBe(0);\n  });\n});\n\n// ============================================================\n// WebSocket Lifecycle Tests\n// ============================================================\n\ndescribe('WebSocket Lifecycle', () => {\n  let app: AppInstance;\n  let port: number;\n  let docId: string;\n\n  beforeAll(async () => {\n    app = createApp();\n    port = await app.start(0);\n    const res = await request(app.app).post('/docs').send({ title: 'WS Doc' });\n    docId = res.body.id;\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('Client connects to ws://.../:docId', async () => {\n    const client = await createWsClient(port, docId);\n    expect(client.ws.readyState).toBe(WebSocket.OPEN);\n    await waitForMsg(client, 0);\n    await closeClient(client);\n  });\n\n  it('Client receives current document content on connect', async () => {\n    const client = await createWsClient(port, docId);\n    const msg = await waitForMsg(client, 0);\n    expect(msg.type).toBe('sync');\n    expect(msg).toHaveProperty('content');\n    expect(msg).toHaveProperty('version');\n    await closeClient(client);\n  });\n\n  it('Client sends edit operation and receives acknowledgment', async () => {\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n    sendOp(client, { type: 'insert', position: 0, text: 'Hello' });\n    const ack = await waitForMsg(client, 1);\n    expect(ack.type).toBe('ack');\n    expect(ack).toHaveProperty('version');\n    await closeClient(client);\n  });\n\n  it('Server broadcasts operation to other clients in same document', async () => {\n    const c1 = await createWsClient(port, docId);\n    await waitForMsg(c1, 0); // sync\n    const c2 = await createWsClient(port, docId);\n    await waitForMsg(c2, 0); // sync\n\n    sendOp(c1, { type: 'insert', position: 0, text: 'Broadcast' });\n    await waitForMsg(c1, 1); // ack for c1\n\n    const broadcast = await waitForMsg(c2, 1); // broadcast for c2\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast).toHaveProperty('operation');\n\n    await closeClient(c1);\n    await closeClient(c2);\n  });\n\n  it('Client does not receive own operations back as broadcast', async () => {\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    sendOp(client, { type: 'insert', position: 0, text: 'Self' });\n    const msg = await waitForMsg(client, 1);\n    // Should get ack, not operation broadcast\n    expect(msg.type).toBe('ack');\n\n    await closeClient(client);\n  });\n\n  it('Client disconnects cleanly', async () => {\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n    await closeClient(client);\n    expect(client.ws.readyState).toBe(WebSocket.CLOSED);\n  });\n\n  it('Multiple clients can join same document', async () => {\n    const clients: WsClient[] = [];\n    for (let i = 0; i < 3; i++) {\n      const c = await createWsClient(port, docId);\n      await waitForMsg(c, 0); // sync\n      clients.push(c);\n    }\n    expect(clients.length).toBe(3);\n    for (const c of clients) {\n      expect(c.ws.readyState).toBe(WebSocket.OPEN);\n      await closeClient(c);\n    }\n  });\n\n  it('Client joining different document does not receive other doc edits', async () => {\n    const res2 = await request(app.app).post('/docs').send({ title: 'Other Doc' });\n    const otherDocId = res2.body.id;\n\n    const c1 = await createWsClient(port, docId);\n    await waitForMsg(c1, 0); // sync\n    const c2 = await createWsClient(port, otherDocId);\n    await waitForMsg(c2, 0); // sync\n\n    sendOp(c1, { type: 'insert', position: 0, text: 'Private' });\n    await waitForMsg(c1, 1); // ack\n\n    // Give time for potential unwanted messages\n    await delay(200);\n\n    // c2 should only have the sync message (index 0), nothing else\n    expect(c2.messages.length).toBe(1);\n\n    await closeClient(c1);\n    await closeClient(c2);\n  });\n});\n\n// ============================================================\n// Single Client Editing Tests\n// ============================================================\n\ndescribe('Single Client Editing', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('Insert at beginning of document', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Begin', content: 'World' });\n    const docId = res.body.id;\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    sendOp(client, { type: 'insert', position: 0, text: 'Hello ' });\n    await waitForMsg(client, 1); // ack\n\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content).toBe('Hello World');\n\n    await closeClient(client);\n  });\n\n  it('Insert at end of document', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'End', content: 'Hello' });\n    const docId = res.body.id;\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    sendOp(client, { type: 'insert', position: 5, text: ' World' });\n    await waitForMsg(client, 1); // ack\n\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content).toBe('Hello World');\n\n    await closeClient(client);\n  });\n\n  it('Insert in middle of document', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Mid', content: 'Helo World' });\n    const docId = res.body.id;\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    sendOp(client, { type: 'insert', position: 3, text: 'l' });\n    await waitForMsg(client, 1); // ack\n\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content).toBe('Hello World');\n\n    await closeClient(client);\n  });\n\n  it('Delete range from document', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Del', content: 'Hello Cruel World' });\n    const docId = res.body.id;\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    sendOp(client, { type: 'delete', position: 5, count: 6 });\n    await waitForMsg(client, 1); // ack\n\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content).toBe('Hello World');\n\n    await closeClient(client);\n  });\n\n  it('Multiple sequential edits build up content correctly', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Sequential' });\n    const docId = res.body.id;\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync (msg 0)\n\n    sendOp(client, { type: 'insert', position: 0, text: 'A' });\n    await waitForMsg(client, 1); // ack (msg 1)\n    sendOp(client, { type: 'insert', position: 1, text: 'B' });\n    await waitForMsg(client, 2); // ack (msg 2)\n    sendOp(client, { type: 'insert', position: 2, text: 'C' });\n    await waitForMsg(client, 3); // ack (msg 3)\n\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content).toBe('ABC');\n\n    await closeClient(client);\n  });\n\n  it('Version is incremented after each edit', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Version' });\n    const docId = res.body.id;\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    sendOp(client, { type: 'insert', position: 0, text: 'A' });\n    const ack1 = await waitForMsg(client, 1);\n    sendOp(client, { type: 'insert', position: 1, text: 'B' });\n    const ack2 = await waitForMsg(client, 2);\n\n    expect((ack2 as { version: number }).version).toBeGreaterThan(\n      (ack1 as { version: number }).version\n    );\n\n    await closeClient(client);\n  });\n});\n\n// ============================================================\n// Two-Client Convergence Tests\n// ============================================================\n\ndescribe('Two-Client Convergence', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('Two clients editing different positions converge to same content', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Converge', content: 'ABCDEF' });\n    const docId = res.body.id;\n\n    const c1 = await createWsClient(port, docId);\n    const sync1 = await waitForMsg(c1, 0);\n    const c2 = await createWsClient(port, docId);\n    await waitForMsg(c2, 0);\n\n    const version = (sync1 as { version: number }).version;\n\n    // Client 1 inserts at position 0\n    sendOp(c1, { type: 'insert', position: 0, text: 'X' }, version);\n    await waitForMsg(c1, 1); // ack\n    await waitForMsg(c2, 1); // broadcast\n\n    // Client 2 inserts at position 7 (after \"X\" was added, \"XABCDEF\" is 7 chars, insert at end)\n    sendOp(c2, { type: 'insert', position: 7, text: 'Y' }, version + 1);\n    await waitForMsg(c2, 2); // ack\n\n    await delay(100);\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content).toBe('XABCDEFY');\n\n    await closeClient(c1);\n    await closeClient(c2);\n  });\n\n  it('Two clients inserting at same position both insertions preserved', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'SamePos', content: '' });\n    const docId = res.body.id;\n\n    const c1 = await createWsClient(port, docId);\n    const sync1 = await waitForMsg(c1, 0);\n    const c2 = await createWsClient(port, docId);\n    await waitForMsg(c2, 0);\n    const version = (sync1 as { version: number }).version;\n\n    // Both insert at position 0\n    sendOp(c1, { type: 'insert', position: 0, text: 'A' }, version);\n    await waitForMsg(c1, 1); // ack\n    await waitForMsg(c2, 1); // broadcast\n\n    sendOp(c2, { type: 'insert', position: 0, text: 'B' }, version);\n    await waitForMsg(c2, 2); // ack\n\n    await delay(100);\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content).toContain('A');\n    expect(doc.body.content).toContain('B');\n    expect(doc.body.content.length).toBe(2);\n\n    await closeClient(c1);\n    await closeClient(c2);\n  });\n\n  it('Client A inserts, Client B deletes: both changes applied', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'InsertDelete', content: 'Hello World' });\n    const docId = res.body.id;\n\n    const c1 = await createWsClient(port, docId);\n    const sync1 = await waitForMsg(c1, 0);\n    const c2 = await createWsClient(port, docId);\n    await waitForMsg(c2, 0);\n    const version = (sync1 as { version: number }).version;\n\n    // Client 1 inserts at beginning\n    sendOp(c1, { type: 'insert', position: 0, text: 'Hey ' }, version);\n    await waitForMsg(c1, 1); // ack\n    await waitForMsg(c2, 1); // broadcast\n\n    // Client 2 deletes \"World\" (now at position 10 because \"Hey \" shifted it; \"Hey Hello World\")\n    // After transform: \"Hey Hello World\" - delete at pos 10 count 5 = \"Hey Hello \"\n    sendOp(c2, { type: 'delete', position: 10, count: 5 }, version + 1);\n    await waitForMsg(c2, 2); // ack\n\n    await delay(100);\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content).toContain('Hey');\n    expect(doc.body.content).not.toContain('World');\n\n    await closeClient(c1);\n    await closeClient(c2);\n  });\n\n  it('Rapid alternating edits from two clients converge', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Rapid', content: '' });\n    const docId = res.body.id;\n\n    const c1 = await createWsClient(port, docId);\n    await waitForMsg(c1, 0); // sync\n    const c2 = await createWsClient(port, docId);\n    await waitForMsg(c2, 0); // sync\n\n    // Alternating edits - each appends a char\n    for (let i = 0; i < 5; i++) {\n      sendOp(c1, { type: 'insert', position: i * 2, text: 'A' });\n      await delay(50);\n      sendOp(c2, { type: 'insert', position: i * 2 + 1, text: 'B' });\n      await delay(50);\n    }\n\n    await delay(500);\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    // All 10 characters should be present\n    expect(doc.body.content.length).toBe(10);\n\n    await closeClient(c1);\n    await closeClient(c2);\n  });\n\n  it('Both clients can fetch document and see identical content after sync', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Identical', content: 'Start' });\n    const docId = res.body.id;\n\n    const c1 = await createWsClient(port, docId);\n    await waitForMsg(c1, 0);\n    const c2 = await createWsClient(port, docId);\n    await waitForMsg(c2, 0);\n\n    sendOp(c1, { type: 'insert', position: 5, text: ' End' });\n    await waitForMsg(c1, 1); // ack\n    await waitForMsg(c2, 1); // broadcast\n\n    await delay(100);\n    const doc1 = await request(app.app).get(`/docs/${docId}`);\n    const doc2 = await request(app.app).get(`/docs/${docId}`);\n    expect(doc1.body.content).toBe(doc2.body.content);\n    expect(doc1.body.content).toBe('Start End');\n\n    await closeClient(c1);\n    await closeClient(c2);\n  });\n\n  it('Version history contains all operations in order', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'History', content: '' });\n    const docId = res.body.id;\n\n    const client = await createWsClient(port, docId);\n    await waitForMsg(client, 0); // sync\n\n    sendOp(client, { type: 'insert', position: 0, text: 'A' });\n    await waitForMsg(client, 1);\n    sendOp(client, { type: 'insert', position: 1, text: 'B' });\n    await waitForMsg(client, 2);\n    sendOp(client, { type: 'insert', position: 2, text: 'C' });\n    await waitForMsg(client, 3);\n\n    const versions = await request(app.app).get(`/docs/${docId}/versions`);\n    expect(versions.body.length).toBeGreaterThanOrEqual(4); // version 0 + 3 edits\n    for (let i = 1; i < versions.body.length; i++) {\n      expect(versions.body[i].version).toBeGreaterThan(versions.body[i - 1].version);\n    }\n\n    await closeClient(client);\n  });\n\n  it('Concurrent edits do not lose data', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'NoLoss', content: '' });\n    const docId = res.body.id;\n\n    const c1 = await createWsClient(port, docId);\n    const sync1 = await waitForMsg(c1, 0);\n    const c2 = await createWsClient(port, docId);\n    await waitForMsg(c2, 0);\n    const version = (sync1 as { version: number }).version;\n\n    // Both send edits based on same initial version\n    sendOp(c1, { type: 'insert', position: 0, text: 'FIRST' }, version);\n    sendOp(c2, { type: 'insert', position: 0, text: 'SECOND' }, version);\n\n    // Wait for messages to settle\n    await delay(500);\n\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content).toContain('FIRST');\n    expect(doc.body.content).toContain('SECOND');\n\n    await closeClient(c1);\n    await closeClient(c2);\n  });\n\n  it('Edit at end of document while other edits beginning', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'EndBegin', content: 'MIDDLE' });\n    const docId = res.body.id;\n\n    const c1 = await createWsClient(port, docId);\n    const sync1 = await waitForMsg(c1, 0);\n    const c2 = await createWsClient(port, docId);\n    await waitForMsg(c2, 0);\n    const version = (sync1 as { version: number }).version;\n\n    sendOp(c1, { type: 'insert', position: 0, text: 'START' }, version);\n    await waitForMsg(c1, 1); // ack\n    await waitForMsg(c2, 1); // broadcast\n\n    // After c1's edit, doc is \"STARTMIDDLE\" (11 chars)\n    sendOp(c2, { type: 'insert', position: 11, text: 'END' }, version + 1);\n    await waitForMsg(c2, 2); // ack\n\n    await delay(100);\n    const doc = await request(app.app).get(`/docs/${docId}`);\n    expect(doc.body.content).toBe('STARTMIDDLEEND');\n\n    await closeClient(c1);\n    await closeClient(c2);\n  });\n});\n\n// ============================================================\n// Stress Tests\n// ============================================================\n\ndescribe('Stress Test', () => {\n  let app: AppInstance;\n  let port: number;\n\n  beforeAll(async () => {\n    app = createApp();\n    port = await app.start(0);\n  });\n\n  afterAll(async () => {\n    await app.stop();\n  });\n\n  it('10 clients connect to same document simultaneously', async () => {\n    const res = await request(app.app).post('/docs').send({ title: 'Stress' });\n    const docId = res.body.id;\n\n    const clients: WsClient[] = [];\n    for (let i = 0; i < 10; i++) {\n      const c = await createWsClient(port, docId);\n      await waitForMsg(c, 0); // 