`/docs/${docId}/versions`);\n   558→    expect(versions.body.length).toBeGreaterThanOrEqual(4); // version 0 + 3 edits\n   559→    for (let i = 1; i < versions.body.length; i++) {\n   560→      expect(versions.body[i].version).toBeGreaterThan(versions.body[i - 1].version);\n   561→    }\n   562→\n   563→    await closeClient(client);\n   564→  });\n   565→\n   566→  it('Concurrent edits do not lose data', async () => {\n   567→    const res = await request(app.app).post('/docs').send({ title: 'NoLoss', content: '' });\n   568→    const docId = res.body.id;\n   569→\n   570→    const c1 = await createWsClient(port, docId);\n   571→    const sync1 = await waitForMsg(c1, 0);\n   572→    const c2 = await createWsClient(port, docId);\n   573→    await waitForMsg(c2, 0);\n   574→    const version = (sync1 as { version: number }).version;\n   575→\n   576→    // Both send edits based on same initial version\n   577→    sendOp(c1, { type: 'insert', position: 0, text: 'FIRST' }, version);\n   578→    sendOp(c2, { type: 'insert', position: 0, text: 'SECOND' }, version);\n   579→\n   580→    // Wait for messages to settle\n   581→    await delay(500);\n   582→\n   583→    const doc = await request(app.app).get(`/docs/${docId}`);\n   584→    expect(doc.body.content).toContain('FIRST');\n   585→    expect(doc.body.content).toContain('SECOND');\n   586→\n   587→    await closeClient(c1);\n   588→    await closeClient(c2);\n   589→  });\n   590→\n   591→  it('Edit at end of document while other edits beginning', async () => {\n   592→    const res = await request(app.app).post('/docs').send({ title: 'EndBegin', content: 'MIDDLE' });\n   593→    const docId = res.body.id;\n   594→\n   595→    const c1 = await createWsClient(port, docId);\n   596→    const sync1 = await waitForMsg(c1, 0);\n   597→    const c2 = await createWsClient(port, docId);\n   598→    await waitForMsg(c2, 0);\n   599→    const version = (sync1 as { version: number }).version;\n   600→\n   601→    sendOp(c1, { type: 'insert', position: 0, text: 'START' }, version);\n   602→    await waitForMsg(c1, 1); // ack\n   603→    await waitForMsg(c2, 1); // broadcast\n   604→\n   605→    // After c1's edit, doc is \"STARTMIDDLE\" (11 chars)\n   606→    sendOp(c2, { type: 'insert', position: 11, text: 'END' }, version + 1);\n   607→    await waitForMsg(c2, 2); // ack\n   608→\n   609→    await delay(100);\n   610→    const doc = await request(app.app).get(`/docs/${docId}`);\n   611→    expect(doc.body.content).toBe('STARTMIDDLEEND');\n   612→\n   613→    await closeClient(c1);\n   614→    await closeClient(c2);\n   615→  });\n   616→});\n   617→\n   618→// ============================================================\n   619→// Stress Tests\n   620→// ============================================================\n   621→\n   622→describe('Stress Test', () => {\n   623→  let app: AppInstance;\n   624→  let port: number;\n   625→\n   626→  beforeAll(async () => {\n   627→    app = createApp();\n   628→    port = await app.start(0);\n   629→  });\n   630→\n   631→  afterAll(async () => {\n   632→    await app.stop();\n   633→  });\n   634→\n   635→  it('10 clients connect to same document simultaneously', async () => {\n   636→    const res = await request(app.app).post('/docs').send({ title: 'Stress' });\n   637→    const docId = res.body.id;\n   638→\n   639→    const clients: WsClient[] = [];\n   640→    for (let i = 0; i < 10; i++) {\n   641→      const c = await createWsClient(port, docId);\n   642→      await waitForMsg(c, 0); // sync\n   643→      clients.push(c);\n   644→    }\n   645→\n   646→    expect(clients.length).toBe(10);\n   647→    for (const c of clients) {\n   648→      expect(c.ws.readyState).toBe(WebSocket.OPEN);\n   649→    }\n   650→\n   651→    for (const c of clients) await closeClient(c);\n   652→  });\n   653→\n   654→  it('10 clients each send an edit, all edits present in final document', async () => {\n   655→    const res = await request(app.app).post('/do