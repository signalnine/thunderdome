@@ -0,0 +1,118 @@
+import { Router, json } from 'express';
+import { randomUUID } from 'crypto';
+import type Database from 'better-sqlite3';
+
+export function createRouter(db: Database.Database): Router {
+  const router = Router();
+  router.use(json());
+
+  // Create document
+  router.post('/docs', (req, res) => {
+    const { title, content } = req.body as { title?: string; content?: string };
+    if (!title) {
+      res.status(400).json({ error: 'title is required' });
+      return;
+    }
+    const id = randomUUID();
+    const docContent = content ?? '';
+    const now = new Date().toISOString().replace('T', ' ').replace('Z', '');
+
+    db.prepare(
+      'INSERT INTO documents (id, title, content, created_at, updated_at) VALUES (?, ?, ?, datetime(?), datetime(?))'
+    ).run(id, title, docContent, now, now);
+
+    // Create initial version (version 0)
+    db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation, created_at) VALUES (?, 0, ?, NULL, datetime(?))'
+    ).run(id, docContent, now);
+
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Record<string, unknown>;
+    res.status(201).json(doc);
+  });
+
+  // List all documents
+  router.get('/docs', (_req, res) => {
+    const docs = db.prepare('SELECT * FROM documents ORDER BY created_at DESC').all();
+    res.json(docs);
+  });
+
+  // Get specific document
+  router.get('/docs/:id', (req, res) => {
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/docs/:id', (req, res) => {
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const { title, content } = req.body as { title?: string; content?: string };
+    const updates: string[] = [];
+    const values: unknown[] = [];
+    if (title !== undefined) {
+      updates.push('title = ?');
+      values.push(title);
+    }
+    if (content !== undefined) {
+      updates.push('content = ?');
+      values.push(content);
+    }
+    if (updates.length > 0) {
+      updates.push("updated_at = datetime('now')");
+      values.push(req.params.id);
+      db.prepare(`UPDATE documents SET ${updates.join(', ')} WHERE id = ?`).run(...values);
+    }
+    const updated = db.prepare('SELECT * FROM documents WHERE id = ?').get(req.params.id);
+    res.json(updated);
+  });
+
+  // Delete document
+  router.delete('/docs/:id', (req, res) => {
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    db.prepare('DELETE FROM documents WHERE id = ?').run(req.params.id);
+    res.status(204).send();
+  });
+
+  // Get version history for a document
+  router.get('/docs/:id/versions', (req, res) => {
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+    ).all(req.params.id);
+    res.json(versions);
+  });
+
+  // Get specific version
+  router.get('/docs/:id/versions/:version', (req, res) => {
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const version = db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? AND version = ?'
+    ).get(req.params.id, parseInt(req.params.version, 10));
+    if (!version) {
+      res.status(404).json({ error: 'Version not found' });
+      return;
+    }
+    res.json(version);
+  });
+
+  return router;
+}
