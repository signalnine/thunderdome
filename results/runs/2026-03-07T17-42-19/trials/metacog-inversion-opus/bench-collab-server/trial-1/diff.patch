     }\n    44→    }, 5);\n    45→  });\n    46→}\n    47→\n    48→\n    49→function delay(ms: number): Promise<void> {\n    50→  return new Promise((resolve) => setTimeout(resolve, ms));\n    51→}\n    52→\n    53→function sendOp(client: WsClient, operation: Record<string, unknown>, version?: number) {\n    54→  const msg: Record<string, unknown> = { type: 'operation', operation };\n    55→  if (version !== undefined) msg.version = version;\n    56→  client.ws.send(JSON.stringify(msg));\n    57→}\n    58→\n    59→function closeClient(client: WsClient): Promise<void> {\n    60→  return new Promise((resolve) => {\n    61→    if (client.ws.readyState === WebSocket.CLOSED || client.ws.readyState === WebSocket.CLOSING) {\n    62→      resolve();\n    63→      return;\n    64→    }\n    65→    client.ws.on('close', () => resolve());\n    66→    client.ws.close();\n    67→  });\n    68→}\n    69→\n    70→// ============================================================\n    71→// REST CRUD Tests\n    72→// ============================================================\n    73→\n    74→describe('REST CRUD', () => {\n    75→  let app: AppInstance;\n    76→\n    77→  beforeAll(async () => {\n    78→    app = createApp();\n    79→    await app.start(0);\n    80→  });\n    81→\n    82→  afterAll(async () => {\n    83→    await app.stop();\n    84→  });\n    85→\n    86→  it('POST /docs creates document with title', async () => {\n    87→    const res = await request(app.app).post('/docs').send({ title: 'Test Doc' });\n    88→    expect(res.status).toBe(201);\n    89→    expect(res.body.title).toBe('Test Doc');\n    90→  });\n    91→\n    92→  it('POST /docs returns id, title, content, timestamps', async () => {\n    93→    const res = await request(app.app).post('/docs').send({ title: 'Full Doc' });\n    94→    expect(res.body).toHaveProperty('id');\n    95→    expect(res.body).toHaveProperty('title');\n    96→    expect(res.body).toHaveProperty('content');\n    97→    expect(res.body).toHaveProperty('created_at');\n    98→    expect(res.body).toHaveProperty('updated_at');\n    99→  });\n   100→\n   101→  it('GET /docs lists all documents', async () => {\n   102→    const res = await request(app.app).get('/docs');\n   103→    expect(res.status).toBe(200);\n   104→    expect(Array.isArray(res.body)).toBe(true);\n   105→    expect(res.body.length).toBeGreaterThanOrEqual(2);\n   106→  });\n   107→\n   108→  it('GET /docs/:id returns specific document', async () => {\n   109→    const created = await request(app.app).post('/docs').send({ title: 'Specific' });\n   110→    const res = await request(app.app).get(`/docs/${created.body.id}`);\n   111→    expect(res.status).toBe(200);\n   112→    expect(res.body.title).toBe('Specific');\n   113→  });\n   114→\n   115→  it('GET /docs/:id returns 404 for non-existent', async () => {\n   116→    const res = await request(app.app).get('/docs/nonexistent-id');\n   117→    expect(res.status).toBe(404);\n   118→  });\n   119→\n   120→  it('PUT /docs/:id updates title', async () => {\n   121→    const created = await request(app.app).post('/docs').send({ title: 'Old Title' });\n   122→    const res = await request(app.app).put(`/docs/${created.body.id}`).send({ title: 'New Title' });\n   123→    expect(res.status).toBe(200);\n   124→    expect(res.body.title).toBe('New Title');\n   125→  });\n   126→\n   127→  it('DELETE /docs/:id removes document', async () => {\n   128→    const created = await request(app.app).post('/docs').send({ title: 'To Delete' });\n   129→    const res = await request(app.app).delete(`/docs/${created.body.id}`);\n   130→    expect(res.status).toBe(204);\n   131→    const check = await request(app.app).get(`/docs/${created.body.id}`);\n   132→    expect(check.status).toBe(404);\n   133→  });\n   134→\n   135→  it('DELETE /docs/:id returns 404 for non-existent', async () => {\n   136→    const res = await request(app.app).delete('/docs/nonexistent-id');\n   137→    expect(res.status).toBe(404);\n   138→  });\n   139→\n   140→  it('GET /docs/:id/versions lists version history', async () => {\n   141→    const created = await request(app.app).post('/docs').send({ title: 'Versioned' });\n   142→    const res = await request(app.app).get(`/docs/${created.body.id}/versions`);\n   143→    expect(res.status).toBe(200);\n   144→    expect(Array.isArray(res.body)).toBe(true);\n   145→    expect(res.body.length).toBeGreaterThanOrEqual(1);\n   146→    expect(res.body[0].version).toBe(0);\n   147→  });\n   148→\n   149→  it('GET /docs/:id/versions/:version returns specific version content', async () => {\n   150→    const created = await request(app.app).post('/docs').send({ title: 'Versioned2' });\n   151→    const res = await request(app.app).get(`/docs/${created.body.id}/versions/0`);\n   152→    expect(res.status).toBe(200);\n   153→    expect(res.body).toHaveProperty('content');\n   154→    expect(res.body.version).toBe(0);\n   155→  });\n   156→});\n   157→\n   158→// ============================================================\n   159→// WebSocket Lifecycle Tests\n   160→// ============================================================\n   161→\n   162→describe('WebSocket Lifecycle', () => {\n   163→  let app: AppInstance;\n   164→  let port: number;\n   165→  let docId: string;\n   166→\n   167→  beforeAll(async () => {\n   168→    app = createApp();\n   169→    port = await app.start(0);\n   170→    const res = await request(app.app).post('/docs').send({ title: 'WS Doc' });\n   171→    docId = res.body.id;\n   172→  });\n   173→\n   174→  afterAll(async () => {\n   175→    await app.stop();\n   176→  });\n   177→\n   178→  it('Client connects to ws://.../:docId', async () => {\n   179→    const client = await createWsClient(port, docId);\n   180→    expect(client.ws.readyState).toBe(WebSocket.OPEN);\n   181→    await waitForMsg(client, 0);\n   182→    await closeClient(client);\n   183→  });\n   184→\n   185→  it('Client receives current document content on connect', async () => {\n   186→    const client = await createWsClient(port, docId);\n   187→    const msg = await waitForMsg(client, 0);\n   188→    expect(msg.type).toBe('sync');\n   189→    expect(msg).toHaveProperty('content');\n   190→    expect(msg).toHaveProperty('version');\n   191→    await closeClient(client);\n   192→  });\n   193→\n   194→  it('Client sends edit operation and receives acknowledgment', async () => {\n   195→    const client = await createWsClient(port, docId);\n   196→    await waitForMsg(client, 0); // sync\n   197→    sendOp(client, { type: 'insert', position: 0, text: 'Hello' });\n   198→    const ack = await waitForMsg(client, 1);\n   199→    expect(ack.type).toBe('ack');\n   200→    expect(ack).toHaveProperty('version');\n   201→    await closeClient(client);\n   202→  });\n   203→\n   204→  it('Server broadcasts operation to other clients in same document', async () => {\n   205→    const c1 = await createWsClient(port, docId);\n   206→    await waitForMsg(c1, 0); // sync\n   207→    const c2 = await createWsClient(port, docId);\n   208→    await waitForMsg(c2, 0); // sync\n   209→\n   210→    sendOp(c1, { type: 'insert', position: 0, text: 'Broadcast' });\n   211→    await waitForMsg(c1, 1); // ack for c1\n   212→\n   213→    const broadcast = await waitForMsg(c2, 1); // broadcast for c2\n   214→    expect(broadcast.type).toBe('operation');\n   215→    expect(broadcast).toHaveProperty('operation');\n   216→\n   217→    await closeClient(c1);\n   218→    await closeClient(c2);\n   219→  });\n   220→\n   221→  it('Client does not receive own operations back as broadcast', async () => {\n   222→    const client = await createWsClient(port, docId);\n   223→    await waitForMsg(client, 0); // sync\n   224→\n   225→    sendOp(client, { type: 'insert', position: 0, text: 'Self' });\n   226→    const msg = await waitForMsg(client, 1);\n   227→    // Should get ack, not operation broadcast\n   228→    expect(msg.type).toBe('ack');\n   229→\n   230→    await closeClient(client);\n   231→  });\n   232→\n   233→  it('Client disconnects cleanly', async () => {\n   234→    const client = await createWsClient(port, docId);\n   235→    await waitForMsg(client, 0); // sync\n   236→    await closeClient(client);\n   237→    expect(client.ws.readyState).toBe(WebSocket.CLOSED);\n   238→  });\n   239→\n   240→  it('Multiple clients can join same document', async () => {\n   241→    const clients: WsClient[] = [];\n   242→    for (let i = 0; i < 3; i++) {\n   243→      const c = await createWsClient(port, docId);\n   244→      await waitForMsg(c, 0); // sync\n   245→      clients.push(c);\n   246→    }\n   247→    expect(clients.length).toBe(3);\n   248→    for (const c of clients) {\n   249→      expect(c.ws.readyState).toBe(WebSocket.OPEN);\n   250→      await closeClient(c);\n   251→    }\n   252→  });\n   253→\n   254→  it('Client joining different document does not receive other doc edits', async () => {\n   255→    const res2 = await request(app.app).post('/docs').send({ title: 'Other Doc' });\n   256→    const otherDocId = res2.body.id;\n   257→\n   258→    const c1 = await createWsClient(port, docId);\n   259→    await waitForMsg(c1, 0); // sync\n   260→    const c2 = await createWsClient(port, otherDocId);\n   261→    await waitForMsg(c2, 0); // sync\n   262→\n   263→    sendOp(c1, { type: 'insert', position: 0, text: 'Private' });\n   264→    await waitForMsg(c1, 1); // ack\n   265→\n   266→    // Give time for potential unwanted messages\n   267→    await delay(200);\n   268→\n   269→    // c2 should only have the sync message (index 0), nothing else\n   270→    expect(c2.messages.length).toBe(1);\n   271→\n   272→    await closeClient(c1);\n   273→    await closeClient(c2);\n   274→  });\n   275→});\n   276→\n   277→// ============================================================\n   278→// Single Client Editing Tests\n   279→// ============================================================\n   280→\n   281→describe('Single Client Editing', () => {\n   282→  let app: AppInstance;\n   283→  let port: number;\n   284→\n   285→  beforeAll(async () => {\n   286→    app = createApp();\n   287→    port = await app.start(0);\n   288→  });\n   289→\n   290→  afterAll(async () => {\n   291→    await app.stop();\n   292→  });\n   293→\n   294→  it('Insert at beginning of document', async () => {\n   295→    const res = await request(app.app).post('/docs').send({ title: 'Begin', content: 'World' });\n   296→    const docId = res.body.id;\n   297→    const client = await createWsClient(port, docId);\n   298→    await waitForMsg(client, 0); // sync\n   299→\n   300→    sendOp(client, { type: 'insert', position: 0, text: 'Hello ' });\n   301→    await waitForMsg(client, 1); // ack\n   302→\n   303→    const doc = await request(app.app).get(`/docs/${docId}`);\n   304→    expect(doc.body.content).toBe('Hello World');\n   305→\n   306→    await closeClient(client);\n   307→  });\n   308→\n   309→  it('Insert at end of document', async () => {\n   310→    const res = await request(app.app).post('/docs').send({ title: 'End', content: 'Hello' });\n   311→    const docId = res.body.id;\n   312→    const client = await createWsClient(port, docId);\n   313→    await waitForMsg(client, 0); // sync\n   314→\n   315→    sendOp(client, { type: 'insert', position: 5, text: ' World' });\n   316→    await waitForMsg(client, 1); // ack\n   317→\n   318→    const doc = await request(app.app).get(`/docs/${docId}`);\n   319→    expect(doc.body.content).toBe('Hello World');\n   320→\n   321→    await closeClient(client);\n   322→  });\n   323→\n   324→  it('Insert in middle of document', async () => {\n   325→    const res = await request(app.app).post('/docs').send({ title: 'Mid', content: 'Helo World' });\n   326→    const docId = res.body.id;\n   327→    const client = await createWsClient(port, docId);\n   328→    await waitForMsg(client, 0); // sync\n   329→\n   330→    sendOp(client, { type: 'insert', position: 3, text: 'l' });\n   331→    await waitForMsg(client, 1); // ack\n   332→\n   333→    const doc = await request(app.app).get(`/docs/${docId}`);\n   334→    expect(doc.body.content).toBe('Hello World');\n   335→\n   336→    await closeClient(client);\n   337→  });\n   338→\n   339→  it('Delete range from document', async () => {\n   340→    const res = await request(app.app).post('/docs').send({ title: 'Del', content: 'Hello Cruel World' });\n   341→    const docId = res.body.id;\n   342→    const client = await createWsClient(port, docId);\n   343→    await waitForMsg(client, 0); // sync\n   344→\n   345→    sendOp(client, { type: 'delete', position: 5, count: 6 });\n   346→    await waitForMsg(client, 1); // ack\n   347→\n   348→    const doc = await request(app.app).get(`/docs/${docId}`);\n   349→    expect(doc.body.content).toBe('Hello World');\n   350→\n   351→    await closeClient(client);\n   352→  });\n   353→\n   354→  it('Multiple sequential edits build up content correctly', async () => {\n   355→    const res = await request(app.app).post('/docs').send({ title: 'Sequential' });\n   356→    const docId = res.body.id;\n   357→    const client = await createWsClient(port, docId);\n   358→    await waitForMsg(client, 0); // sync (msg 0)\n   359→\n   360→    sendOp(client, { type: 'insert', position: 0, text: 'A' });\n   361→    await waitForMsg(client, 1); // ack (msg 1)\n   362→    sendOp(client, { type: 'insert', position: 1, text: 'B' });\n   363→    await waitForMsg(client, 2); // ack (msg 2)\n   364→    sendOp(client, { type: 'insert', position: 2, text: 'C' });\n   365→    await waitForMsg(client, 3); // ack (msg 3)\n   366→\n   367→    const doc = await request(app.app).get(`/docs/${docId}`);\n   368→    expect(doc.body.content).toBe('ABC');\n   369→\n   370→    await closeClient(client);\n   371→  });\n   372→\n   373→  it('Version is incremented after each edit', async () => {\n   374→    const res = await request(app.app).post('/docs').send({ title: 'Version' });\n   375→    const docId = res.body.id;\n   376→    const client = await createWsClient(port, docId);\n   377→    await waitForMsg(client, 0); // sync\n   378→\n   379→    sendOp(client, { type: 'insert', position: 0, text: 'A' });\n   380→    const ack1 = await waitForMsg(client, 1);\n   381→    sendOp(client, { type: 'insert', position: 1, text: 'B' });\n   382→    const ack2 = await waitForMsg(client, 2);\n   383→\n   384→    expect((ack2 as { version: number }).version).toBeGreaterThan(\n   385→      (ack1 as { version: number }).version\n   386→    );\n   387→\n   388→    await closeClient(client);\n   389→  });\n   390→});\n   391→\n   392→// ============================================================\n   393→// Two-Client Convergence Tests\n   394→// ============================================================\n   395→\n   396→describe('Two-Client Convergence', () => {\n   397→  let app: AppInstance;\n   398→  let port: number;\n   399→\n   400→  beforeAll(async () => {\n   401→    app = createApp();\n   402→    port = await app.start(0);\n   403→  });\n   404→\n   405→  afterAll(async () => {\n   406→    await app.stop();\n   407→  });\n   408→\n   409→  it('Two clients editing different positions converge to same content', async () => {\n   410→    const res = await request(app.app).post('/docs').send({ title: 'Converge', content: 'ABCDEF' });\n   411→    const docId = res.body.id;\n   412→\n   413→    const c1 = await createWsClient(port, docId);\n   414→    const sync1 = await waitForMsg(c1, 0);\n   415→    const c2 = await createWsClient(port, docId);\n   416→    await waitForMsg(c2, 0);\n   417→\n   418→    const version = (sync1 as { version: number }).version;\n   419→\n   420→    // Client 1 inserts at position 0\n   421→    sendOp(c1, { type: 'insert', position: 0, text: 'X' }, version);\n   422→    await waitForMsg(c1, 1); // ack\n   423→    await waitForMsg(c2, 1); // broadcast\n   424→\n   425→    // Client 2 inserts at position 7 (after \"X\" was added, \"XABCDEF\" is 7 chars, insert at end)\n   426→    sendOp(c2, { type: 'insert', position: 7, text: 'Y' }, version + 1);\n   427→    await waitForMsg(c2, 2); // ack\n   428→\n   429→    await delay(100);\n   430→    const doc = await request(app.app).get(`/docs/${docId}`);\n   431→    expect(doc.body.content).toBe('XABCDEFY');\n   432→\n   433→    await closeClient(c1);\n   434→    await closeClient(c2);\n   435→  });\n   436→\n   437→  it('Two clients inserting at same position both insertions preserved', async () => {\n   438→    const res = await request(app.app).post('/docs').send({ title: 'SamePos', content: '' });\n   439→    const docId = res.body.id;\n   440→\n   441→    const c1 = await createWsClient(port, docId);\n   442→    const sync1 = await waitForMsg(c1, 0);\n   443→    const c2 = await createWsClient(port, docId);\n   444→    await waitForMsg(c2, 0);\n   445→    const version = (sync1 as { version: number }).version;\n   446→\n   447→    // Both insert at position 0\n   448→    sendOp(c1, { type: 'insert', position: 0, text: 'A' }, version);\n   449→    await waitForMsg(c1, 1); // ack\n   450→    await waitForMsg(c2, 1); // broadcast\n   451→\n   452→    sendOp(c2, { type: 'insert', position: 0, text: 'B' }, version);\n   453→    await waitForMsg(c2, 2); // ack\n   454→\n   455→    await delay(100);\n   456→    const doc = await request(app.app).get(`/docs/${docId}`);\n   457→    expect(doc.body.content).toContain('A');\n   458→    expect(doc.body.content).toContain('B');\n   459→    expect(doc.body.content.length).toBe(2);\n   460→\n   461→    await closeClient(c1);\n   462→    await closeClient(c2);\n   463→  });\n   464→\n   465→  it('Client A inserts, Client B deletes: both changes applied', async () => {\n   466→    const res = await request(app.app).post('/docs').send({ title: 'InsertDelete', content: 'Hello World' });\n   467→    const docId = res.body.id;\n   468→\n   469→    const c1 = await createWsClient(port, docId);\n   470→    const sync1 = await waitForMsg(c1, 0);\n   471→    const c2 = await createWsClient(port, docId);\n   472→    await waitForMsg(c2, 0);\n   473→    const version = (sync1 as { version: number }).version;\n   474→\n   475→    // Client 1 inserts at beginning\n   476→    sendOp(c1, { type: 'insert', position: 0, text: 'Hey ' }, version);\n   477→    await waitForMsg(c1, 1); // ack\n   478→    await waitForMsg(c2, 1); // broadcast\n   479→\n   480→    // Client 2 deletes \"World\" (now at position 10 because \"Hey \" shifted it; \"Hey Hello World\")\n   481→    // After transform: \"Hey Hello World\" - delete at pos 10 count 5 = \"Hey Hello \"\n   482→    sendOp(c2, { type: 'delete', position: 10, count: 5 }, version + 1);\n   483→    await waitForMsg(c2, 2); // ack\n   484→\n   485→    await delay(100);\n   486→    const doc = await request(app.app).get(`/docs/${docId}`);\n   487→    expect(doc.body.content).toContain('Hey');\n   488→    expect(doc.body.content).not.toContain('World');\n   489→\n   490→    await closeClient(c1);\n   491→    await closeClient(c2);\n   492→  });\n   493→\n   494→  it('Rapid alternating edits from two clients converge', async () => {\n   495→    const res = await request(app.app).post('/docs').send({ title: 'Rapid', content: '' });\n   496→    const docId = res.body.id;\n   497→\n   498→    const c1 = await createWsClient(port, docId);\n   499→    await waitForMsg(c1, 0); // sync\n   500→    const c2 = await createWsClient(port, docId);\n   501→    await waitForMsg(c2, 0); // sync\n   502→\n   503→    // Alternating edits - each appends a char\n   504→    for (let i = 0; i < 5; i++) {\n   505→      sendOp(c1, { type: 'insert', position: i * 2, text: 'A' });\n   506→      await delay(50);\n   507→      sendOp(c2, { type: 'insert', position: i * 2 + 1, text: 'B' });\n   508→      await delay(50);\n   509→    }\n   510→\n   511→    await delay(500);\n   512→    const doc = await request(app.app).get(`/