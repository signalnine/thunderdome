nt(c);\n   706→    }\n   707→\n   708→    for (const ct of contents) {\n   709→      expect(ct).toBe(contents[0]);\n   710→    }\n   711→    expect(contents[0]).toContain('SHARED');\n   712→  });\n   713→\n   714→  it('Server handles rapid-fire edits without crashing', async () => {\n   715→    const res = await request(app.app).post('/docs').send({ title: 'RapidFire', content: '' });\n   716→    const docId = res.body.id;\n   717→\n   718→    const client = await createWsClient(port, docId);\n   719→    await waitForMsg(client, 0); // sync\n   720→\n   721→    // Send 50 rapid edits\n   722→    for (let i = 0; i < 50; i++) {\n   723→      sendOp(client, { type: 'insert', position: i, text: 'x' });\n   724→    }\n   725→\n   726→    await delay(2000);\n   727→    const doc = await request(app.app).get(`/docs/${docId}`);\n   728→    expect(doc.body.content.length).toBe(50);\n   729→\n   730→    await closeClient(client);\n   731→  });\n   732→\n   733→  it('All clients can disconnect without error', async () => {\n   734→    const res = await request(app.app).post('/docs').send({ title: 'Disconnect' });\n   735→    const docId = res.body.id;\n   736→\n   737→    const clients: WsClient[] = [];\n   738→    for (let i = 0; i < 10; i++) {\n   739→      const c = await createWsClient(port, docId);\n   740→      await waitForMsg(c, 0);\n   741→      clients.push(c);\n   742→    }\n   743→\n   744→    // Disconnect all at once\n   745→    await Promise.all(clients.map((c) => closeClient(c)));\n   746→\n   747→    // Server should still be healthy\n   748→    const check = await request(app.app).get('/docs');\n   749→    expect(check.status).toBe(200);\n   750→  });\n   751→});\n   752→\n   753→// ============================================================\n   754→// Error Handling Tests\n   755→// ============================================================\n   756→\n   757→describe('Error Handling', () => {\n   758→  let app: AppInstance;\n   759→  let port: number;\n   