@@ -0,0 +1,56 @@
+import express from 'express';
+import { createServer, type Server as HttpServer } from 'http';
+import type Database from 'better-sqlite3';
+import { createDatabase } from './db.js';
+import { createRouter } from './routes.js';
+import { setupWebSocket } from './ws.js';
+
+export interface AppInstance {
+  app: express.Express;
+  db: Database.Database;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath);
+  const app = express();
+  const router = createRouter(db);
+  app.use(router);
+
+  const httpServer: HttpServer = createServer(app);
+  const { wss, closeAll } = setupWebSocket(httpServer, db);
+
+  let started = false;
+
+  async function start(port = 0): Promise<number> {
+    return new Promise((resolve, reject) => {
+      httpServer.listen(port, () => {
+        started = true;
+        const addr = httpServer.address();
+        const actualPort = typeof addr === 'object' && addr ? addr.port : port;
+        resolve(actualPort);
+      });
+      httpServer.on('error', reject);
+    });
+  }
+
+  async function stop(): Promise<void> {
+    return new Promise((resolve) => {
+      closeAll();
+      wss.close(() => {
+        if (started) {
+          httpServer.close(() => {
+            db.close();
+            resolve();
+          });
+        } else {
+          db.close();
+          resolve();
+        }
+      });
+    });
+  }
+
+  return { app, db, start, stop };
+}
diff --git a/src/ws.ts b/src/ws.ts
new file mode 100644
index 0000000..2f5d0e9
--- /dev/null
+++ b/src/ws.ts
@@ -0,0 +1,206 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import type { Server as HttpServer } from 'http';
+import type Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+import { type Operation, applyOperation, validateOperation, transformOperation } from './ot.js';
+
+interface ClientInfo {
+  id: string;
+  ws: WebSocket;
+  docId: string;
+}
+
+interface DocumentState {
+  version: number;
+  clients: Map<string, ClientInfo>;
+  // History of operations applied since version 0, indexed by version number
+  operationLog: Operation[];
+}
+
+export function setupWebSocket(server: HttpServer, db: Database.Database): {
+  wss: WebSocketServer;
+  closeAll: () => void;
+} {
+  const wss = new WebSocketServer({ server });
+  const documents = new Map<string, DocumentState>();
+
+  function getDocState(docId: string): DocumentState {
+    let state = documents.get(docId);
+    if (!state) {
+      // Load the current version from db
+      const maxVersion = db.prepare(
+        'SELECT COALESCE(MAX(version), 0) as maxVer FROM versions WHERE document_id = ?'
+      ).get(docId) as { maxVer: number };
+
+      // Load all operations from version history for OT
+      const versions = db.prepare(
+        'SELECT version, operation FROM versions WHERE document_id = ? AND operation IS NOT NULL ORDER BY version ASC'
+      ).all(docId) as { version: number; operation: string }[];
+
+      const opLog: Operation[] = [];
+      for (const v of versions) {
+        if (v.operation) {
+          opLog.push(JSON.parse(v.operation));
+        }
+      }
+
+      state = {
+        version: maxVersion.maxVer,
+        clients: new Map(),
+        operationLog: opLog,
+      };
+      documents.set(docId, state);
+    }
+    return state;
+  }
+
+  wss.on('connection', (ws, req) => {
+    const url = req.url ?? '/';
+    const docId = url.slice(1); // Remove leading '/'
+
+    // Check if document exists
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(docId) as
+      | { id: string; content: string }
+      | undefined;
+
+    if (!doc) {
+      ws.send(JSON.stringify({ type: 'error', message: `Document not found: ${docId}` }));
+      ws.close();
+      return;
+    }
+
+    const clientId = randomUUID();
+    const state = getDocState(docId);
+    const clientInfo: ClientInfo = { id: clientId, ws, docId };
+    state.clients.set(clientId, clientInfo);
+
+    // Track in db
+    db.prepare('INSERT INTO active_connections (id, document_id) VALUES (?, ?)').run(clientId, docId);
+
+    // Send sync message
+    ws.send(JSON.stringify({
+      type: 'sync',
+      content: doc.content,
+      version: state.version,
+    }));
+
+    ws.on('message', (data) => {
+      let msg: Record<string, unknown>;
+      try {
+        msg = JSON.parse(data.toString());
+      } catch {
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));
+        return;
+      }
+
+      if (msg.type !== 'operation') {
+        ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${msg.type}` }));
+        return;
+      }
+
+      const rawOp = msg.operation as Record<string, unknown> | undefined;
+      if (!rawOp) {
+        ws.send(JSON.stringify({ type: 'error', message: 'Missing operation' }));
+        return;
+      }
+
+      // Validate operation type
+      if (rawOp.type !== 'insert' && rawOp.type !== 'delete') {
+        ws.send(JSON.stringify({ type: 'error', message: `Invalid operation type: ${rawOp.type}` }));
+        return;
+      }
+
+      let op: Operation;
+      if (rawOp.type === 'insert') {
+        op = { type: 'insert', position: rawOp.position as number, text: rawOp.text as string };
+      } else {
+        op = { type: 'delete', position: rawOp.position as number, count: rawOp.count as number };
+      }
+
+      // Get the client's base version for OT
+      const clientVersion = typeof msg.version === 'number' ? msg.version : state.version;
+
+      // Transform the operation against all operations that happened since clientVersion
+      let transformedOp: Operation | null = op;
+      if (clientVersion < state.version) {
+        // We need to transform against operations [clientVersion+1 .. state.version]
+        // operationLog stores operations by their resulting version
+        // Version 1 is at index 0 (first op after version 0), etc.
+        // The operation at index i produced version (startVersion + i + 1)
+        // Actually, let's track more carefully. operationLog has one entry per version after 0.
+        // So operationLog[0] produced version 1, operationLog[1] produced version 2, etc.
+        // We need to find the right starting index.
+        const startIdx = clientVersion; // operations from version clientVersion to state.version-1
+        for (let i = startIdx; i < state.version && transformedOp !== null; i++) {
+          const idx = i; // index in operationLog
+          if (idx < state.operationLog.length) {
+            transformedOp = transformOperation(transformedOp, state.operationLog[idx]);
+          }
+        }
+      }
+
+      if (transformedOp === null) {
+        // Operation became a no-op after transformation
+        state.version++;
+        ws.send(JSON.stringify({ type: 'ack', version: state.version }));
+        return;
+      }
+
+      // Get current document content
+      const currentDoc = db.prepare('SELECT content FROM documents WHERE id = ?').get(docId) as { content: string };
+
+      // Validate the transformed operation against current content
+      const error = validateOperation(currentDoc.content, transformedOp);
+      if (error) {
+        ws.send(JSON.stringify({ type: 'error', message: error }));
+        return;
+      }
+
+      // Apply the operation
+      const newContent = applyOperation(currentDoc.content, transformedOp);
+      state.version++;
+      state.operationLog.push(transformedOp);
+
+      // Update document
+      db.prepare("UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?").run(newContent, docId);
+
+      // Store version
+      db.prepare(
+        "INSERT INTO versions (document_id, version, content, operation, created_at) VALUES (?, ?, ?, ?, datetime('now'))"
+      ).run(docId, state.version, newContent, JSON.stringify(transformedOp));
+
+      // Send ack to sender
+      ws.send(JSON.stringify({ type: 'ack', version: state.version }));
+
+      // Broadcast to other clients
+      const broadcastMsg = JSON.stringify({
+        type: 'operation',
+        operation: transformedOp,
+        version: state.version,
+      });
+
+      for (const [cid, client] of state.clients) {
+        if (cid !== clientId && client.ws.readyState === WebSocket.OPEN) {
+          client.ws.send(broadcastMsg);
+        }
+      }
+    });
+
+    ws.on('close', () => {
+      state.clients.delete(clientId);
+      db.prepare('DELETE FROM active_connections WHERE id = ?').run(clientId);
+      if (state.clients.size === 0) {
+        documents.delete(docId);
+      }
+    });
+  });
+
+  function closeAll() {
+    for (const client of wss.clients) {
+      client.close();
+    }
+    wss.close();
+  }
+
+  return { wss, closeAll };
+}
