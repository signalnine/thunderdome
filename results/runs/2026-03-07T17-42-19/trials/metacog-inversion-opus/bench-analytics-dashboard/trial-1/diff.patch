+++ b/src/routes/dashboards.ts
@@ -0,0 +1,218 @@
+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import { authMiddleware } from '../auth.js';
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+export function createDashboardRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Create dashboard
+  router.post('/', authMiddleware, (req: Request, res: Response): void => {
+    const { name, config } = req.body;
+    const tenantId = req.user!.tenantId;
+    const ownerId = req.user!.userId;
+
+    if (!name) {
+      res.status(400).json({ error: 'Dashboard name is required' });
+      return;
+    }
+
+    const id = uuidv4();
+    const dashConfig = JSON.stringify(config || {});
+    const now = new Date().toISOString();
+
+    db.prepare(
+      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, ownerId, dashConfig, now, now);
+
+    res.status(201).json({
+      id,
+      tenantId,
+      name,
+      ownerId,
+      config: config || {},
+      createdAt: now,
+      updatedAt: now,
+    });
+  });
+
+  // List dashboards for tenant
+  router.get('/', authMiddleware, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboards = db
+      .prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC')
+      .all(tenantId) as DashboardRow[];
+
+    res.json({
+      dashboards: dashboards.map((d) => ({
+        id: d.id,
+        tenantId: d.tenant_id,
+        name: d.name,
+        ownerId: d.owner_id,
+        config: JSON.parse(d.config),
+        createdAt: d.created_at,
+        updatedAt: d.updated_at,
+      })),
+    });
+  });
+
+  // Get single dashboard
+  router.get('/:id', authMiddleware, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { id } = req.params;
+
+    const dashboard = db
+      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const widgets = db
+      .prepare('SELECT * FROM widgets WHERE dashboard_id = ?')
+      .all(id) as WidgetRow[];
+
+    res.json({
+      id: dashboard.id,
+      tenantId: dashboard.tenant_id,
+      name: dashboard.name,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+      widgets: widgets.map((w) => ({
+        id: w.id,
+        dashboardId: w.dashboard_id,
+        type: w.type,
+        config: JSON.parse(w.config),
+        positionX: w.position_x,
+        positionY: w.position_y,
+        width: w.width,
+        height: w.height,
+      })),
+    });
+  });
+
+  // Update dashboard
+  router.put('/:id', authMiddleware, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { id } = req.params;
+    const { name, config } = req.body;
+
+    const existing = db
+      .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(id, tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const updatedName = name || existing.name;
+    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare('UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?').run(
+      updatedName,
+      updatedConfig,
+      now,
+      id
+    );
+
+    res.json({
+      id,
+      tenantId,
+      name: updatedName,
+      ownerId: existing.owner_id,
+      config: JSON.parse(updatedConfig),
+      createdAt: existing.created_at,
+      updatedAt: now,
+    });
+  });
+
+  // Delete dashboard
+  router.delete('/:id', authMiddleware, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { id } = req.params;
+
+    const existing = db
+      .prepare('SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(id, tenantId) as { id: string } | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    // Delete widgets first (though ON DELETE CASCADE should handle this)
+    db.prepare('DELETE FROM widgets WHERE dashboard_id = ?').run(id);
+    db.prepare('DELETE FROM dashboards WHERE id = ?').run(id);
+
+    res.status(204).send();
+  });
+
+  // Add widget to dashboard
+  router.post('/:id/widgets', authMiddleware, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { id: dashboardId } = req.params;
+    const { type, config, positionX, positionY, width, height } = req.body;
+
+    const dashboard = db
+      .prepare('SELECT id FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(dashboardId, tenantId) as { id: string } | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    if (!type || !['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) {
+      res.status(400).json({ error: 'Valid widget type is required (counter, timeseries, breakdown, funnel)' });
+      return;
+    }
+
+    const widgetId = uuidv4();
+    const widgetConfig = JSON.stringify(config || {});
+
+    db.prepare(
+      'INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)'
+    ).run(widgetId, dashboardId, type, widgetConfig, positionX || 0, positionY || 0, width || 1, height || 1);
+
+    res.status(201).json({
+      id: widgetId,
+      dashboardId,
+      type,
+      config: config || {},
+      positionX: positionX || 0,
+      positionY: positionY || 0,
+      width: width || 1,
+      height: height || 1,
+    });
+  });
+
+  return router;
+}
