ards/${dashboardId}`)\n        .set('Authorization', `Bearer ${token1}`);\n      expect(res.status).toBe(204);\n    });\n  });\n\n  describe('Data Export', () => {\n    it('should export events as JSON', async () => {\n      const res = await request(app)\n        .get('/api/export/events/json')\n        .set('Authorization', `Bearer ${token1}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events).toBeDefined();\n      expect(res.body.events.length).toBe(4); // tenant1 has 4 events total\n    });\n\n    it('should export events as CSV', async () => {\n      const res = await request(app)\n        .get('/api/export/events/csv')\n        .set('Authorization', `Bearer ${token1}`);\n      expect(res.status).toBe(200);\n      expect(res.headers['content-type']).toMatch(/text\\/csv/);\n      expect(res.text).toContain('id,name,properties,timestamp');\n    });\n\n    it('should export events with tenant isolation', async () => {\n      const res = await request(app)\n        .get('/api/export/events/json')\n        .set('Authorization', `Bearer ${token2}`);\n      expect(res.status).toBe(200);\n      expect(res.body.events.length).toBe(1); // tenant2 has only 1 event\n    });\n\n    it('should export dashboards as JSON', async () => {\n      const res = await request(app)\n        .get('/api/export/dashboards/json')\n        .set('Authorization', `Bearer ${token1}`);\n      expect(res.status).toBe(200);\n      expect(res.body.dashboards).toBeDefined();\n    });\n\n    it('should export dashboards as CSV', async () => {\n      const res = await request(app)\n        .get('/api/export/dashboards/csv')\n        .set('Authorization', `Bearer ${token1}`);\n      expect(res.status).toBe(200);\n      expect(res.headers['content-type']).toMatch(/text\\/csv/);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
