@@ -0,0 +1,256 @@
+import { describe, it, expect, beforeAll } from 'vitest';
+import request from 'supertest';
+import { createApp } from './app.js';
+import type { Express } from 'express';
+
+describe('Analytics Dashboard API', () => {
+  let app: Express;
+  let token1: string;
+  let token2: string;
+
+  beforeAll(() => {
+    app = createApp(':memory:');
+  });
+
+  describe('User Management', () => {
+    it('should register a new user', async () => {
+      const res = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'admin@tenant1.com', password: 'pass123', tenantId: 'tenant1', role: 'admin' });
+      expect(res.status).toBe(201);
+      expect(res.body.user.email).toBe('admin@tenant1.com');
+      expect(res.body.user.tenantId).toBe('tenant1');
+      expect(res.body.user.role).toBe('admin');
+      expect(res.body.token).toBeDefined();
+      token1 = res.body.token;
+    });
+
+    it('should register a second tenant user', async () => {
+      const res = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'admin@tenant2.com', password: 'pass123', tenantId: 'tenant2', role: 'admin' });
+      expect(res.status).toBe(201);
+      token2 = res.body.token;
+    });
+
+    it('should reject duplicate email', async () => {
+      const res = await request(app)
+        .post('/api/users/register')
+        .send({ email: 'admin@tenant1.com', password: 'pass123', tenantId: 'tenant1' });
+      expect(res.status).toBe(409);
+    });
+
+    it('should login', async () => {
+      const res = await request(app)
+        .post('/api/users/login')
+        .send({ email: 'admin@tenant1.com', password: 'pass123' });
+      expect(res.status).toBe(200);
+      expect(res.body.token).toBeDefined();
+    });
+
+    it('should reject bad credentials', async () => {
+      const res = await request(app)
+        .post('/api/users/login')
+        .send({ email: 'admin@tenant1.com', password: 'wrong' });
+      expect(res.status).toBe(401);
+    });
+
+    it('should get profile', async () => {
+      const res = await request(app)
+        .get('/api/users/profile')
+        .set('Authorization', `Bearer ${token1}`);
+      expect(res.status).toBe(200);
+      expect(res.body.email).toBe('admin@tenant1.com');
+    });
+
+    it('should return 401 without auth', async () => {
+      const res = await request(app).get('/api/users/profile');
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe('Event Ingestion', () => {
+    it('should ingest a single event', async () => {
+      const res = await request(app)
+        .post('/api/events')
+        .set('Authorization', `Bearer ${token1}`)
+        .send({ name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-15T10:00:00Z' });
+      expect(res.status).toBe(201);
+      expect(res.body.id).toBeDefined();
+    });
+
+    it('should ingest batch events', async () => {
+      const events = [
+        { name: 'page_view', properties: { url: '/about' }, timestamp: '2024-01-15T11:00:00Z' },
+        { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-16T10:00:00Z' },
+        { name: 'click', properties: { button: 'signup' }, timestamp: '2024-01-16T12:00:00Z' },
+      ];
+      const res = await request(app)
+        .post('/api/events/batch')
+        .set('Authorization', `Bearer ${token1}`)
+        .send({ events });
+      expect(res.status).toBe(201);
+      expect(res.body.inserted).toBe(3);
+    });
+
+    it('should ingest events for tenant2', async () => {
+      const res = await request(app)
+        .post('/api/events')
+        .set('Authorization', `Bearer ${token2}`)
+        .send({ name: 'page_view', properties: { url: '/secret' }, timestamp: '2024-01-15T10:00:00Z' });
+      expect(res.status).toBe(201);
+    });
+
+    it('should reject unauthenticated event ingestion', async () => {
+      const res = await request(app)
+        .post('/api/events')
+        .send({ name: 'page_view' });
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe('Query Engine', () => {
+    it('should count events', async () => {
+      const res = await request(app)
+        .post('/api/queries/count')
+        .set('Authorization', `Bearer ${token1}`)
+        .send({ eventName: 'page_view' });
+      expect(res.status).toBe(200);
+      expect(res.body.count).toBe(3); // 3 page_views for tenant1
+    });
+
+    it('should count with tenant isolation', async () => {
+      const res = await request(app)
+        .post('/api/queries/count')
+        .set('Authorization', `Bearer ${token2}`)
+        .send({ eventName: 'page_view' });
+      expect(res.status).toBe(200);
+      expect(res.body.count).toBe(1); // only 1 page_view for tenant2
+    });
+
+    it('should return timeseries', async () => {
+      const res = await request(app)
+        .post('/api/queries/timeseries')
+        .set('Authorization', `Bearer ${token1}`)
+        .send({ eventName: 'page_view', interval: 'day' });
+      expect(res.status).toBe(200);
+      expect(res.body.data.length).toBeGreaterThan(0);
+    });
+
+    it('should return breakdown', async () => {
+      const res = await request(app)
+        .post('/api/queries/breakdown')
+        .set('Authorization', `Bearer ${token1}`)
+        .send({ eventName: 'page_view', property: 'url' });
+      expect(res.status).toBe(200);
+      expect(res.body.data.length).toBeGreaterThan(0);
+      expect(res.body.property).toBe('url');
+    });
+  });
+
+  describe('Dashboards', () => {
+    let dashboardId: string;
+
+    it('should create a dashboard', async () => {
+      const res = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token1}`)
+        .send({ name: 'My Dashboard', config: { theme: 'dark' } });
+      expect(res.status).toBe(201);
+      expect(res.body.name).toBe('My Dashboard');
+      dashboardId = res.body.id;
+    });
+
+    it('should list dashboards', async () => {
+      const res = await request(app)
+        .get('/api/dashboards')
+        .set('Authorization', `Bearer ${token1}`);
+      expect(res.status).toBe(200);
+      expect(res.body.dashboards.length).toBe(1);
+    });
+
+    it('should get single dashboard', async () => {
+      const res = await request(app)
+        .get(`/api/dashboards/${dashboardId}`)
+        .set('Authorization', `Bearer ${token1}`);
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('My Dashboard');
+    });
+
+    it('should enforce tenant isolation on dashboards', async () => {
+      const res = await request(app)
+        .get(`/api/dashboards/${dashboardId}`)
+        .set('Authorization', `Bearer ${token2}`);
+      expect(res.status).toBe(404);
+    });
+
+    it('should update a dashboard', async () => {
+      const res = await request(app)
+        .put(`/api/dashboards/${dashboardId}`)
+        .set('Authorization', `Bearer ${token1}`)
+        .send({ name: 'Updated Dashboard' });
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('Updated Dashboard');
+    });
+
