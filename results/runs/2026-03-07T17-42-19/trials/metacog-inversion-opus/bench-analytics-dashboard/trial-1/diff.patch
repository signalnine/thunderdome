+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { authMiddleware } from '../auth.js';
+
+export function createQueryRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Count events matching filter
+  router.post('/count', authMiddleware, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, filters } = req.body as {
+      eventName?: string;
+      startDate?: string;
+      endDate?: string;
+      filters?: Record<string, unknown>;
+    };
+
+    let sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    if (filters) {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ` AND json_extract(properties, ?) = ?`;
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query - bucket events over time
+  router.post('/timeseries', authMiddleware, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, interval, filters } = req.body as {
+      eventName?: string;
+      startDate?: string;
+      endDate?: string;
+      interval?: string;
+      filters?: Record<string, unknown>;
+    };
+
+    // Default interval is 'day'
+    const bucket = interval || 'day';
+    let dateFormat: string;
+    switch (bucket) {
+      case 'hour':
+        dateFormat = '%Y-%m-%dT%H:00:00';
+        break;
+      case 'month':
+        dateFormat = '%Y-%m-01';
+        break;
+      case 'week':
+        // Group by start of week (using weekday 0 = Sunday in SQLite)
+        dateFormat = '%Y-%W';
+        break;
+      case 'day':
+      default:
+        dateFormat = '%Y-%m-%d';
+        break;
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    if (filters) {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ` AND json_extract(properties, ?) = ?`;
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += ' GROUP BY bucket ORDER BY bucket ASC';
+
+    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+    res.json({ data: results, interval: bucket });
+  });
+
+  // Breakdown query - group event counts by property
+  router.post('/breakdown', authMiddleware, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, property, startDate, endDate, filters } = req.body as {
+      eventName?: string;
+      property: string;
+      startDate?: string;
+      endDate?: string;
+      filters?: Record<string, unknown>;
+    };
+
+    if (!property) {
+      res.status(400).json({ error: 'property field is required for breakdown queries' });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as property_value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [`$.${property}`, tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    if (filters) {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ` AND json_extract(properties, ?) = ?`;
+        params.push(`$.${key}`, value as string);
+      }
+    }
+
+    sql += ' GROUP BY property_value ORDER BY count DESC';
+
+    const results = db.prepare(sql).all(...params) as Array<{
+      property_value: string | null;
+      count: number;
+    }>;
+    res.json({ data: results, property });
+  });
+
+  return router;
+}
diff --git a/src/routes/users.ts b/src/routes/users.ts
new file mode 100644
index 0000000..74a4aec
--- /dev/null
+++ b/src/routes/users.ts
@@ -0,0 +1,132 @@
+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import { createHash } from 'crypto';
+import { signToken, authMiddleware, requireRole } from '../auth.js';
+
+function hashPassword(password: string): string {
+  return createHash('sha256').update(password).digest('hex');
+}
+
+export function createUserRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Register
+  router.post('/register', (req: Request, res: Response): void => {
+    const { email, password, tenantId, role } = req.body;
+
+    if (!email || !password || !tenantId) {
+      res.status(400).json({ error: 'email, password, and tenantId are required' });
+      return;
+    }
+
+    const existing = db.prepare('SELECT id FROM users WHERE email = ?').get(email);
+    if (existing) {
+      res.status(409).json({ error: 'Email already registered' });
+      return;
+    }
+
+    const id = uuidv4();
+    const passwordHash = hashPassword(password);
+    const userRole = role && ['admin', 'viewer', 'editor'].includes(role) ? role : 'viewer';
+
+    db.prepare(
+      'INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)'
+    ).run(id, email, passwordHash, tenantId, userRole);
+
+    const token = signToken({ userId: id, email, tenantId, role: userRole });
+
+    res.status(201).json({
+      user: { id, email, tenantId, role: userRole },
+      token,
+    });
+  });
+
+  // Login
+  router.post('/login', (req: Request, res: Response): void => {
+    const { email, password } = req.body;
+
+    if (!email || !password) {
+      res.status(400).json({ error: 'email and password are required' });
+      return;
+    }
+
+    const user = db.prepare('SELECT * FROM users WHERE email = ?').get(email) as
+      | { id: string; email: string; password_hash: string; tenant_id: string; role: string }
+      | undefined;
+
+    if (!user || user.password_hash !== hashPassword(password)) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    const token = signToken({
+      userId: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+    });
+
+    res.json({
+      user: { id: user.id, email: user.email, tenantId: user.tenant_id, role: user.role },
+      token,
+    });
+  });
+
+  // Get profile
+  router.get('/profile', authMiddleware, (req: Request, res: Response): void => {
+    const user = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?').get(
+      req.user!.userId
+    ) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;
+
+    if (!user) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenantId: user.tenant_id,
+      role: user.role,
+      createdAt: user.created_at,
+    });
+  });
+
+  // Change user role (admin only)
+  router.put(
+    '/:userId/role',
+    authMiddleware,
+    requireRole('admin'),
+    (req: Request, res: Response): void => {
+      const { userId } = req.params;
+      const { role } = req.body;
+
+      if (!role || !['admin', 'viewer', 'editor'].includes(role)) {
+        res.status(400).json({ error: 'Valid role (admin, viewer, editor) is required' });
+        return;
+      }
+
+      // Ensure target user is in same tenant
+      const targetUser = db.prepare('SELECT id, tenant_id FROM users WHERE id = ?').get(userId) as
+        | { id: string; tenant_id: string }
+        | undefined;
+
+      if (!targetUser) {
+        res.status(404).json({ error: 'User not found' });
+        return;
+      }
+
+      if (targetUser.tenant_id !== req.user!.tenantId) {
+        res.status(403).json({ error: 'Cannot modify users in other tenants' });
+        return;
+      }
+
+      db.prepare('UPDATE users SET role = ? WHERE id = ?').run(role, userId);
+
+      res.json({ id: userId, role });
+    }
+  );
+
+  return router;
+}
