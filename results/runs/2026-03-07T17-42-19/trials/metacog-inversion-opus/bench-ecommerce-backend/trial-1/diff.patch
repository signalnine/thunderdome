+describe('Integration', () => {
+  it('full e-commerce flow: create product, add to cart, order, pay, notify', async () => {
+    const catalog = createCatalogService(bus);
+    const inventory = createInventoryService(bus);
+    const cartService = createCartService(bus);
+    const pricing = createPricingService(bus);
+    const orders = createOrderService(bus);
+    const payment = createPaymentService(bus);
+    const notifications = createNotificationService(bus);
+    const analytics = createAnalyticsService(bus);
+
+    // Subscribe user for notifications
+    notifications.subscribe('user1');
+
+    // Create products
+    const productId = catalog.createProduct('Laptop', 999.99, 'electronics');
+    inventory.setStock(productId, 10);
+
+    // Add to cart
+    const cartId = cartService.createCart('user1');
+    cartService.addItem(cartId, productId, 1);
+
+    // Calculate price
+    const price = pricing.getPrice(productId);
+    expect(price).toBe(999.99);
+    const totals = pricing.calculateTotal([{ productId, quantity: 1, price }]);
+    expect(totals.total).toBeCloseTo(1099.99, 1);
+
+    // Create order
+    const orderId = orders.createOrder('user1', cartId, totals.total);
+    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.PENDING);
+
+    // Reserve inventory
+    expect(inventory.reserve(productId, 1)).toBe(true);
+    expect(inventory.getStock(productId)).toBe(9);
+
+    // Process payment
+    const paymentResult = await payment.processPayment(orderId, totals.total);
+    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);
+
+    // Update order status
+    orders.updateStatus(orderId, OrderStatus.CONFIRMED);
+    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.CONFIRMED);
+
+    // Check notifications
+    const notifs = notifications.getNotifications('user1');
+    expect(notifs.length).toBeGreaterThanOrEqual(3); // order_created, payment, order_status
+
+    // Check analytics
+    expect(analytics.getRevenue()).toBe(totals.total);
+    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(1);
+    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);
+  });
