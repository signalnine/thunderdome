+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../src/bus.js';
+import {
+  createCatalogService,
+  createInventoryService,
+  createCartService,
+  createPricingService,
+  createOrderService,
+  createPaymentService,
+  createNotificationService,
+  createAnalyticsService,
+} from '../src/index.js';
+import { OrderStatus, PaymentStatus, Events } from '../src/types.js';
+
+let bus: EventBus;
+
+beforeEach(() => {
+  bus = new EventBus();
+});
+
+describe('CatalogService', () => {
+  it('should create and retrieve products', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    const product = catalog.getProduct(id);
+    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });
+  });
+
+  it('should list products by category', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Widget', 9.99, 'gadgets');
+    catalog.createProduct('Gizmo', 19.99, 'gadgets');
+    catalog.createProduct('Book', 5.99, 'books');
+    expect(catalog.listProducts('gadgets')).toHaveLength(2);
+    expect(catalog.listProducts('books')).toHaveLength(1);
+    expect(catalog.listProducts()).toHaveLength(3);
+  });
+
+  it('should search products by name or category', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Widget', 9.99, 'gadgets');
+    catalog.createProduct('Super Widget', 19.99, 'electronics');
+    expect(catalog.searchProducts('widget')).toHaveLength(2);
+    expect(catalog.searchProducts('gadgets')).toHaveLength(1);
+  });
+
+  it('should update products', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    catalog.updateProduct(id, { price: 14.99 });
+    expect(catalog.getProduct(id)!.price).toBe(14.99);
+  });
+
