derId);\n    if (userId) {\n      addNotification(userId, 'payment', `Payment for order ${event.orderId}: ${event.status}.`);\n    }\n  });\n\n  return {\n    subscribe(userId: string): void {\n      subscribers.add(userId);\n    },\n\n    getNotifications(userId: string) {\n      return [...(notifications.get(userId) ?? [])];\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":380,"cache_read_input_tokens":25931,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":380},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3bc2f85a-10eb-4c63-bd3d-36ddc646c9c5","uuid":"c33ed7fb-9f37-4e0d-b1e2-8e85a61fe374"}
