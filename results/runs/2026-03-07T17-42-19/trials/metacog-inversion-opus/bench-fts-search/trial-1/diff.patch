ationError('Search query is required');\n      }\n\n      const sanitized = sanitizePlainTerms(q);\n      if (!sanitized || sanitized.trim() === '') {\n        res.json({ results: [] });\n        return;\n      }\n\n      // Use prefix matching with * for autocomplete\n      const prefixQuery = sanitized.split(/\\s+/).map(term => `${term}*`).join(' ');\n\n      const suggestStmt = db.prepare(`\n        SELECT notes.id, notes.title\n        FROM notes_fts\n        JOIN notes ON notes.id = notes_fts.rowid\n        WHERE notes_fts MATCH ?\n        ORDER BY bm25(notes_fts)\n        LIMIT 5\n      `);\n      const results = suggestStmt.all(prefixQuery) as SuggestResult[];\n\n      res.json({ results });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes - List all notes (with optional tag filter)\n  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {","originalFile":"import { Router, Request, Response, NextFunction } from 'express';\nimport Database from 'better-sqlite3';\nimport { Note, NoteInput } from './models.js';\nimport { NotFoundError, ValidationError } from './errors.js';\n\nexport function createRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // GET /notes - List all notes (with optional tag filter)\n  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const tag = req.query.tag as string | undefined;\n\n      let notes: Note[];\n      if (tag) {\n        // Use a join with json_each for tag filtering\n        const tagStmt = db.prepare(`\n          SELECT DISTINCT notes.* FROM notes, json_each(notes.tags)\n          WHERE json_each.value = ?\n          ORDER BY created_at DESC\n        `);\n        notes = tagStmt.all(tag) as Note[];\n      } else {\n        const stmt = db.prepare('SELECT * FROM notes ORDER BY created_at DESC');\n        notes = stmt.all() as Note[];\n      }\n\n      res.json({ notes });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes/:id - Get single note\n  router.get('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const stmt = db.prepare('SELECT * FROM notes WHERE id = ?');\n      const note = stmt.get(id) as Note | undefined;\n\n      if (!note) {\n        throw new NotFoundError('Note not found');\n      }\n\n      res.json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // POST /notes - Create note\n  router.post('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const input = req.body as NoteInput;\n\n      if (!input.title || input.title.trim() === '') {\n        throw new ValidationError('Title is required');\n      }\n      if (!input.body || input.body.trim() === '') {\n        throw new ValidationError('Body is required');\n      }\n\n      const tags = input.tags ? JSON.stringify(input.tags) : '[]';\n      const stmt = db.prepare(`\n        INSERT INTO notes (title, body, tags) VALUES (?, ?, ?)\n      `);\n      const result = stmt.run(input.title, input.body, tags);\n\n      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(result.lastInsertRowid) as Note;\n      res.status(201).json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // PUT /notes/:id - Update note\n  router.put('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n\n      if (!existing) {\n        throw new NotFoundError('Note not found');\n      }\n\n      const input = req.body as Partial<NoteInput>;\n      const title = input.title ?? existing.title;\n      const body = input.body ?? existing.body;\n      const tags = input.tags ? JSON.stringify(input.tags) : existing.tags;\n\n      const stmt = db.prepare(`\n        UPDATE notes SET title = ?, body = ?, tags = ?, updated_at = datetime('now')\n        WHERE id = ?\n      `);\n      stmt.run(title, body, tags, id);\n\n      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note;\n      res.json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // DELETE /notes/:id - Delete note\n  router.delete('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n\n      if (!existing) {\n        throw new NotFoundError('Note not found');\n      }\n\n      db.prepare('DELETE FROM notes WHERE id = ?').run(id);\n      res.status(204).send();\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":1,"oldLines":11,"newStart":1,"newLines":124,"lines":[" import { Router, Request, Response, NextFunction } from 'express';"," import Database from 'better-sqlite3';","-import { Note, NoteInput } from './models.js';","+import { Note, NoteInput, SearchResult, SuggestResult } from './models.js';"," import { NotFoundError, ValidationError } from './errors.js';"," ","+function sanitizeFtsQuery(query: string): string {","+  // Preserve quoted phrases, sanitize everything else","+  const parts: string[] = [];","+  const regex = /\"[^\"]*\"/g;","+  let lastIndex = 0;","+  let match: RegExpExecArray | null;","+","+  while ((match = regex.exec(query)) !== null) {","+    // Process text before the quoted phrase","+    const before = query.slice(lastIndex, match.index);","+    if (before.trim()) {","+      parts.push(sanitizePlainTerms(before));","+    }","+    // Keep the quoted phrase as-is","+    parts.push(match[0]);","+    lastIndex = regex.lastIndex;","+  }","+","+  // Process remaining text after last quoted phrase","+  const remaining = query.slice(lastIndex);","+  if (remaining.trim()) {","+    parts.push(sanitizePlainTerms(remaining));","+  }","+","+  return parts.join(' ');","+}","+","+function sanitizePlainTerms(text: string): string {","+  // Remove FTS5 special operators and characters, keep only word characters and spaces","+  return text","+    .replace(/[^\\w\\s]/g, ' ')","+    .replace(/\\s+/g, ' ')","+    .trim();","+}","+"," export function createRoutes(db: Database.Database): Router {","   const router = Router();"," ","+  // GET /notes/search - Full-text search","+  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {","+    try {","+      const q = req.query.q as string | undefined;","+      if (!q || q.trim() === '') {","+        throw new ValidationError('Search query is required');","+      }","+","+      const page = Math.max(1, parseInt(req.query.page as string) || 1);","+      const perPage = 20;","+      const offset = (page - 1) * perPage;","+","+      const sanitized = sanitizeFtsQuery(q);","+      if (!sanitized || sanitized.trim() === '') {","+        res.json({ results: [], total: 0, page, perPage });","+        return;","+      }","+","+      // Count total results","+      const countStmt = db.prepare(`","+        SELECT COUNT(*) as total FROM notes_fts WHERE notes_fts MATCH ?","+      `);","+      const { total } = countStmt.get(sanitized) as { total: number };","+","+      // Get paginated results with BM25 ranking and snippets","+      const searchStmt = db.prepare(`","+        SELECT","+          notes.id,","+          notes.title,","+          snippet(notes_fts, 1, '<mark>', '</mark>', '...', 32) as snippet,","+          bm25(notes_fts) as rank","+        FROM notes_fts","+        JOIN notes ON notes.id = notes_fts.rowid","+        WHERE notes_fts MATCH ?","+        ORDER BY rank","+        LIMIT ? OFFSET ?","+      `);","+      const results = searchStmt.all(sanitized, perPage, offset) as SearchResult[];","+","+      res.json({ results, total, page, perPage });","+    } catch (err) {","+      next(err);","+    }","+  });","+","+  // GET /notes/search/suggest - Autocomplete suggestions","+  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {","+    try {","+      const q = req.query.q as string | undefined;","+      if (!q || q.trim() === '') {","+        throw new ValidationError('Search query is required');","+      }","+","+      const sanitized = sanitizePlainTerms(q);","+      if (!sanitized || sanitized.trim() === '') {","+        res.json({ results: [] });","+        return;","+      }","+","+      // Use prefix matching with * for autocomplete","+      const prefixQuery = sanitized.split(/\\s+/).map(term => `${term}*`).join(' ');","+","+      const suggestStmt = db.prepare(`","+        SELECT notes.id, notes.title","+        FROM notes_fts","+        JOIN notes ON notes.id = notes_fts.rowid","+        WHERE notes_fts MATCH ?","+        ORDER BY bm25(notes_fts)","+        LIMIT 5","+      `);","+      const results = suggestStmt.all(prefixQuery) as SuggestResult[];","+","+      res.json({ results });","+    } catch (err) {","+      next(err);","+    }","+  });","+","   // GET /notes - List all notes (with optional tag filter)","   router.get('/notes', (req: Request, res: Response, next: NextFunction) => {","     try {"]}],"userModified":false,"replaceAll":false}}
