+function sanitizeFtsQuery(query: string): string {
+  // Preserve quoted phrases, sanitize everything else
+  const parts: string[] = [];
+  const regex = /"[^"]*"/g;
+  let lastIndex = 0;
+  let match: RegExpExecArray | null;
+
+  while ((match = regex.exec(query)) !== null) {
+    // Process text before the quoted phrase
+    const before = query.slice(lastIndex, match.index);
+    if (before.trim()) {
+      parts.push(sanitizePlainTerms(before));
+    }
+    // Keep the quoted phrase as-is
+    parts.push(match[0]);
+    lastIndex = regex.lastIndex;
+  }
+
+  // Process remaining text after last quoted phrase
+  const remaining = query.slice(lastIndex);
+  if (remaining.trim()) {
+    parts.push(sanitizePlainTerms(remaining));
+  }
+
+  return parts.join(' ');
