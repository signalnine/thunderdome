+import { describe, it, expect, vi, beforeEach } from 'vitest';
+import { TaskQueue } from './TaskQueue.js';
+
+describe('TaskQueue', () => {
+  let queue: TaskQueue;
+
+  beforeEach(() => {
+    queue = new TaskQueue();
+  });
+
+  // ═══════════════════════════════════════════════════════════
+  // Phase 1: Basic FIFO Queue
+  // ═══════════════════════════════════════════════════════════
+
+  describe('Phase 1: Basic Queue', () => {
+    it('should add a task and return it with an id, status, and createdAt', () => {
+      const task = queue.add({ message: 'hello' });
+      expect(task.id).toBeDefined();
+      expect(task.status).toBe('pending');
+      expect(task.createdAt).toBeInstanceOf(Date);
+      expect(task.payload).toEqual({ message: 'hello' });
+    });
+
+    it('should assign unique IDs to each task', () => {
+      const t1 = queue.add('task1');
+      const t2 = queue.add('task2');
+      expect(t1.id).not.toBe(t2.id);
+    });
+
+    it('should retrieve tasks in FIFO order', () => {
+      queue.add('first');
+      queue.add('second');
+      queue.add('third');
+
+      const t1 = queue.next();
+      const t2 = queue.next();
+      const t3 = queue.next();
+      expect(t1?.payload).toBe('first');
+      expect(t2?.payload).toBe('second');
+      expect(t3?.payload).toBe('third');
+    });
+
+    it('should transition task to processing when retrieved', () => {
+      queue.add('work');
+      const task = queue.next();
+      expect(task?.status).toBe('processing');
+      expect(task?.attempt).toBe(1);
+    });
+
+    it('should return null when queue is empty', () => {
+      expect(queue.next()).toBeNull();
+    });
+
+    it('should report correct size', () => {
+      expect(queue.size()).toBe(0);
+      queue.add('a');
+      queue.add('b');
+      expect(queue.size()).toBe(2);
+      queue.next();
+      expect(queue.size()).toBe(1);
+    });
+
+    it('should get task by id', () => {
+      const added = queue.add('test');
+      const fetched = queue.getTask(added.id);
+      expect(fetched).not.toBeNull();
+      expect(fetched!.payload).toBe('test');
+    });
+
+    it('should return null for non-existent task', () => {
+      expect(queue.getTask('nonexistent')).toBeNull();
+    });
