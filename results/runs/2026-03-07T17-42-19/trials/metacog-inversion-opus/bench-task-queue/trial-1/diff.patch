──────────────────────\n\n  getQueues(): string[] {\n    return [...this.queues.keys()];\n  }\n\n  // ─── Phase 5: Complete / Fail ───────────────────────────────\n\n  complete(taskId: string): TaskData {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    task.status = 'completed';\n    this.decrementProcessing(task.queue);\n\n    // Phase 7: unblock dependents\n    this.onTaskCompleted(task.id);\n\n    return this.cloneTask(task);\n  }\n\n  fail(taskId: string, error?: string): TaskData {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error ?? 'Unknown error';\n    this.decrementProcessing(task.queue);\n\n    // Check if retries remain\n    if (task.attempt < task.maxRetries) {\n      // Re-enqueue with exponential backoff delay\n      const delayMs = task.backoff * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delayMs);\n      this.ensureQueue(task.queue);\n      this.queues.get(task.queue)!.push(task.id);\n      return this.cloneTask(task);\n    }\n\n    // No retries left\n    task.status = 'failed';\n\n    // Phase 6: move to DLQ\n    this.addToDLQ(task);\n\n    return this.cloneTask(task);\n  }\n\n  // ─── Phase 6: Dead Letter Queue ─────────────────────────────\n\n  getDLQ(queueName?: string): TaskData[] {\n    const name = queueName ?? 'default';\n    const dlq = this.dlqs.get(name);\n    if (!dlq) return [];\n    return dlq\n      .map(id => this.tasks.get(id))\n      .filter((t): t is TaskData => !!t)\n      .map(t => this.cloneTask(t));\n  }\n\n  retryFromDLQ(taskId: string): TaskData {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'failed') {\n      throw new Error(`Task is not in dead letter queue: ${taskId}`);\n    }\n\n    // Remove from DLQ\n    const dlq = this.dlqs.get(task.queue);\n    if (dlq) {\n      const idx = dlq.indexOf(taskId);\n      if (idx !== -1) dlq.splice(idx, 1);\n    }\n\n    // Reset and re-enqueue\n    task.status = 'pending';\n    task.attempt = 0;\n    task.error = undefined;\n    task.availableAt = new Date();\n    task.progress = 0;\n    task.progressMessage = undefined;\n    this.ensureQueue(task.queue);\n    this.queues.get(task.queue)!.push(task.id);\n\n    return this.cloneTask(task);\n  }\n\n  clearDLQ(queueName?: string): void {\n    const name = queueName ?? 'default';\n    const dlq = this.dlqs.get(name);\n    if (dlq) {\n      for (const id of dlq) {\n        this.tasks.delete(id);\n        this.taskOrder.delete(id);\n      }\n      dlq.length = 0;\n    }\n  }\n\n  // ─── Phase 7: Dependencies ──────────────────────────────────\n\n  getDependencyStatus(taskId: string): { resolved: string[]; unresolved: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n\n    const resolved: string[] = [];\n    const unresolved: string[] = [];\n\n    for (const depId of task.dependsOn) {\n      const dep = this.tasks.get(depId);\n      if (dep && dep.status === 'completed') {\n        resolved.push(depId);\n      } else {\n        unresolved.push(depId);\n      }\n    }\n\n    return { resolved, unresolved };\n  }\n\n  // ─── Phase 8: Concurrency Control ──────────────────────────\n\n  setConcurrency(queueName: string, limit: number): void {\n    if (!this.queueConfigs.has(queueName)) {\n      this.queueConfigs.set(queueName, { concurrency: limit });\n    } else {\n      this.queueConfigs.get(queueName)!.concurrency = limit;\n    }\n    this.ensureQueue(queueName);\n  }\n\n  getConcurrency(queueName: string): number {\n    return this.queueConfigs.get(queueName)?.concurrency ?? 0;\n  }\n\n  getActiveCount(queueName: string): number {\n    return this.processingCount.get(queueName) ?? 0;\n  }\n\n  // ─── Phase 9: Progress & Cancellation ──────────────────────\n\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Can only report progress for processing tasks`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Progress must be between 0 and 100`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    const event: ProgressEvent = { taskId, progress, message };\n\n    // Notify task-specific listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(event);\n      }\n    }\n\n    // Notify global listeners\n    for (const listener of this.globalProgressListeners) {\n      listener(event);\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    return () => {\n      const set = this.progressListeners.get(taskId);\n      if (set) {\n        set.delete(listener);\n        if (set.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  onProgressGlobal(listener: ProgressListener): () => void {\n    this.globalProgressListeners.add(listener);\n    return () => {\n      this.globalProgressListeners.delete(listener);\n    };\n  }\n\n  cancel(taskId: string): TaskData {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task not found: ${taskId}`);\n    }\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Cannot cancel task in status: ${task.status}`);\n    }\n\n    const wasPending = task.status === 'pending';\n    task.status = 'cancelled';\n    task.cancelled = true;\n\n    if (wasPending) {\n      // Remove from queue\n      const queue = this.queues.get(task.queue);\n      if (queue) {\n        const idx = queue.indexOf(taskId);\n        if (idx !== -1) queue.splice(idx, 1);\n      }\n      // Also remove from blocked registrations\n      for (const depId of task.dependsOn) {\n        const waiters = this.blockedTasks.get(depId);\n        if (waiters) {\n          waiters.delete(taskId);\n        }\n      }\n    } else {\n      // Was processing\n      this.decrementProcessing(task.queue);\n    }\n\n    return this.cloneTask(task);\n  }\n\n  // ─── Phase 10: Recurring Tasks ─────────────────────────────\n\n  addSchedule(\n    cron: string,\n    queue: string,\n    taskTemplate: { payload: unknown; options?: Omit<TaskOptions, 'queue'> }\n  ): string {\n    if (this._isShutdown) {\n      throw new Error('Queue system is shut down.');\n    }\n\n    const parsed = parseCron(cron);\n    const id = randomUUID();\n    this.schedules.set(id, {\n      id,\n      cron,\n      parsed,\n      queue,\n      taskTemplate,\n    });\n    return id;\n  }\n\n  removeSchedule(scheduleId: string): boolean {\n    return this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): ScheduleEntry[] {\n    return [...this.schedules.values()].map(s => ({\n      id: s.id,\n      cron: s.cron,\n      queue: s.queue,\n      taskTemplate: s.taskTemplate,\n      lastRun: s.lastRun,\n    }));\n  }\n\n  tick(now?: Date): TaskData[] {\n    const time = now ?? new Date();\n    const created: TaskData[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (shouldFire(schedule.parsed, time, schedule.lastRun)) {\n        schedule.lastRun = time;\n        const opts: TaskOptions = {\n          ...(schedule.taskTemplate.options ?? {}),\n          queue: schedule.queue,\n        };\n        const task = this.add(schedule.taskTemplate.payload, opts);\n        created.push(task);\n      }\n    }\n\n    return created;\n  }\n\n  // ─── Phase 11: Middleware ───────────────────────────────────\n\n  use(queueName: string, fn: MiddlewareFn): void {\n    if (!this.middleware.has(queueName)) {\n      this.middleware.set(queueName, []);\n    }\n    this.middleware.get(queueName)!.push(fn);\n  }\n\n  registerProcessor(queueName: string, fn: ProcessorFn): void {\n    this.processors.set(queueName, fn);\n  }\n\n  async process(queueName?: string): Promise<TaskData | null> {\n    const name = queueName ?? 'default';\n    const task = this.next(name);\n    if (!task) return null;\n\n    const internalTask = this.tasks.get(task.id)!;\n    const middlewareStack = this.middleware.get(name) ?? [];\n    const processor = this.processors.get(name);\n\n    try {\n      await this.executeMiddleware(middlewareStack, internalTask, 0, async () => {\n        if (processor) {\n          await processor(internalTask);\n        }\n      });\n\n      // If still processing after middleware + processor, auto-complete\n      if (internalTask.status === 'processing') {\n        this.complete(task.id);\n      }\n    } catch (err) {\n      // Middleware or processor error -> fail\n      if (internalTask.status === 'processing') {\n        this.fail(task.id, err instanceof Error ? err.message : String(err));\n      }\n    }\n\n    return this.cloneTask(this.tasks.get(task.id)!);\n  }\n\n  private async executeMiddleware(\n    stack: MiddlewareFn[],\n    task: TaskData,\n    index: number,\n    final: () => Promise<void>\n  ): Promise<void> {\n    if (index >= stack.length) {\n      await final();\n      return;\n    }\n\n    const fn = stack[index];\n    let nextCalled = false;\n    await fn(task, async () => {\n      if (nextCalled) return;\n      nextCalled = true;\n      await this.executeMiddleware(stack, task, index + 1, final);\n    });\n  }\n\n  // ─── Phase 12: Graceful Shutdown ───────────────────────────\n\n  get isShutdown(): boolean {\n    return this._isShutdown;\n  }\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(timeout: number = 30000): Promise<ShutdownResult> {\n    if (this._shutdownPromise) {\n      return this._shutdownPromise;\n    }\n\n    this._isShutdown = true;\n    this._shutdownPromise = this.executeShutdown(timeout);\n    return this._shutdownPromise;\n  }\n\n  private async executeShutdown(timeout: number): Promise<ShutdownResult> {\n    const start = Date.now();\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      try {\n        await cb();\n      } catch {\n        // Ignore callback errors during shutdown\n      }\n    }\n\n    // Find all currently processing tasks\n    const processingTasks: TaskData[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        processingTasks.push(task);\n      }\n    }\n\n    if (processingTasks.length === 0) {\n      return { completed: 0, forceCancelled: 0, duration: Date.now() - start };\n    }\n\n    // Wait for processing tasks to complete, up to timeout\n    let completed = 0;\n    let forceCancelled = 0;\n\n    const waitStart = Date.now();\n\n    // Poll until all processing tasks are done or timeout\n    while (Date.now() - waitStart < timeout) {\n      let allDone = true;\n      for (const task of processingTasks) {\n        const current = this.tasks.get(task.id);\n        if (current && current.status === 'processing') {\n          allDone = false;\n          break;\n        }\n      }\n      if (allDone) break;\n      await new Promise(resolve => setTimeout(resolve, 50));\n    }\n\n    // Count results and force-cancel remaining\n    for (const task of processingTasks) {\n      const current = this.tasks.get(task.id);\n      if (!current) continue;\n\n      if (current.status === 'processing') {\n        current.status = 'cancelled';\n        current.cancelled = true;\n        this.decrementProcessing(current.queue);\n        forceCancelled++;\n      } else {\n        completed++;\n      }\n    }\n\n    return { completed, forceCancelled, duration: Date.now() - start };\n  }\n\n  // ─── Internal Helpers ──────────────────────────────────────\n\n  private ensureQueue(name: string): void {\n    if (!this.queues.has(name)) {\n      this.queues.set(name, []);\n    }\n  }\n\n  private decrementProcessing(queue: string): void {\n    const current = this.processingCount.get(queue) ?? 0;\n    if (current > 0) {\n      this.processingCount.set(queue, current - 1);\n    }\n  }\n\n  private addToDLQ(task: TaskData): void {\n    if (!this.dlqs.has(task.queue)) {\n      this.dlqs.set(task.queue, []);\n    }\n    this.dlqs.get(task.queue)!.push(task.id);\n  }\n\n  private validateDependencies(task: TaskData): void {\n    // Check all deps exist\n    for (const depId of task.dependsOn) {\n      if (!this.tasks.has(depId)) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Check for circular dependencies\n    this.checkCircularDeps(task.id, task.dependsOn, new Set());\n  }\n\n  private checkCircularDeps(taskId: string, deps: string[], visited: Set<string>): void {\n    for (const depId of deps) {\n      if (depId === taskId) {\n        throw new Error('Circular dependency detected');\n      }\n      if (visited.has(depId)) continue;\n      visited.add(depId);\n\n      const depTask = this.tasks.get(depId);\n      if (depTask && depTask.dependsOn.length > 0) {\n        this.checkCircularDeps(taskId, depTask.dependsOn, visited);\n      }\n    }\n  }\n\n  private getUnresolvedDeps(task: TaskData): string[] {\n    return task.dependsOn.filter(depId => {\n      const dep = this.tasks.get(depId);\n      return !dep || dep.status !== 'completed';\n    });\n  }\n\n  private onTaskCompleted(taskId: string): void {\n    const waitingTaskIds = this.blockedTasks.get(taskId);\n    if (!waitingTaskIds) return;\n\n    for (const waiterId of waitingTaskIds) {\n      const waiter = this.tasks.get(waiterId);\n      if (!waiter || waiter.status !== 'pending') continue;\n\n      const unresolvedDeps = this.getUnresolvedDeps(waiter);\n      if (unresolvedDeps.length === 0) {\n        // Unblock: add to ready queue\n        this.ensureQueue(waiter.queue);\n        this.queues.get(waiter.queue)!.push(waiter.id);\n      }\n    }\n\n    this.blockedTasks.delete(taskId);\n  }\n\n  private cloneTask(task: TaskData): TaskData {\n    return {\n      ...task,\n      createdAt: new Date(task.createdAt.getTime()),\n      availableAt: new Date(task.availableAt.getTime()),\n      dependsOn: [...task.dependsOn],\n    };\n  }\n}\n","structuredPatch":[],"originalFile":null}}
