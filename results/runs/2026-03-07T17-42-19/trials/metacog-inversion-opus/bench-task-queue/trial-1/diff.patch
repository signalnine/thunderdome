+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01JoJsoGdADwbUTB66DZDrzL","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01U5H8tJycUa8zZ7PsuUQXTX","name":"Write","input":{"file_path":"/workspace/src/TaskQueue.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './TaskQueue.js';\n\ndescribe('TaskQueue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 1: Basic FIFO Queue\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 1: Basic Queue', () => {\n    it('should add a task and return it with an id, status, and createdAt', () => {\n      const task = queue.add({ message: 'hello' });\n      expect(task.id).toBeDefined();\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n      expect(task.payload).toEqual({ message: 'hello' });\n    });\n\n    it('should assign unique IDs to each task', () => {\n      const t1 = queue.add('task1');\n      const t2 = queue.add('task2');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      queue.add('first');\n      queue.add('second');\n      queue.add('third');\n\n      const t1 = queue.next();\n      const t2 = queue.next();\n      const t3 = queue.next();\n      expect(t1?.payload).toBe('first');\n      expect(t2?.payload).toBe('second');\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should transition task to processing when retrieved', () => {\n      queue.add('work');\n      const task = queue.next();\n      expect(task?.status).toBe('processing');\n      expect(task?.attempt).toBe(1);\n    });\n\n    it('should return null when queue is empty', () => {\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should report correct size', () => {\n      expect(queue.size()).toBe(0);\n      queue.add('a');\n      queue.add('b');\n      expect(queue.size()).toBe(2);\n      queue.next();\n      expect(queue.size()).toBe(1);\n    });\n\n    it('should get task by id', () => {\n      const added = queue.add('test');\n      const fetched = queue.getTask(added.id);\n      expect(fetched).not.toBeNull();\n      expect(fetched!.payload).toBe('test');\n    });\n\n    it('should return null for non-existent task', () => {\n      expect(queue.getTask('nonexistent')).toBeNull();\n    });\n\n    it('should return clones, not internal references', () => {\n      const task = queue.add('data');\n      const fetched = queue.getTask(task.id)!;\n      fetched.payload = 'modified';\n      const original = queue.getTask(task.id)!;\n      expect(original.payload).toBe('data');\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 2: Named Queues\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name specified', () => {\n      queue.add('test');\n      expect(queue.getQueues()).toContain('default');\n    });\n\n    it('should support named queues', () => {\n      queue.add('email', { queue: 'emails' });\n      queue.add('sms', { queue: 'notifications' });\n      const names = queue.getQueues();\n      expect(names).toContain('emails');\n      expect(names).toContain('notifications');\n    });\n\n    it('should operate queues independently', () => {\n      queue.add('email1', { queue: 'emails' });\n      queue.add('email2', { queue: 'emails' });\n      queue.add('sms1', { queue: 'sms' });\n\n      expect(queue.size('emails')).toBe(2);\n      expect(queue.size('sms')).toBe(1);\n\n      const task = queue.next('emails');\n      expect(task?.payload).toBe('email1');\n      expect(queue.size('emails')).toBe(1);\n      expect(queue.size('sms')).toBe(1);\n    });\n\n    it('should return null for empty or non-existent queue', () => {\n      expect(queue.next('nonexistent')).toBeNull();\n    });\n\n    it('should create queue implicitly on first add', () => {\n      expect(queue.getQueues()).not.toContain('newqueue');\n      queue.add('data', { queue: 'newqueue' });\n      expect(queue.getQueues()).toContain('newqueue');\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 3: Priority\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = queue.add('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher-priority tasks first', () => {\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n      queue.add('medium', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('high');\n      expect(queue.next()?.payload).toBe('medium');\n      expect(queue.next()?.payload).toBe('low');\n    });\n\n    it('should use FIFO for same priority', () => {\n      queue.add('first', { priority: 3 });\n      queue.add('second', { priority: 3 });\n      queue.add('third', { priority: 3 });\n\n      expect(queue.next()?.payload).toBe('first');\n      expect(queue.next()?.payload).toBe('second');\n      expect(queue.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => queue.add('test', { priority: 0 })).toThrow();\n      expect(() => queue.add('test', { priority: 11 })).toThrow();\n      expect(() => queue.add('test', { priority: 3.5 })).toThrow();\n      expect(() => queue.add('test', { priority: -1 })).toThrow();\n    });\n\n    it('should enforce per-queue priority ordering', () => {\n      queue.add('q1-low', { queue: 'q1', priority: 10 });\n      queue.add('q1-high', { queue: 'q1', priority: 1 });\n      queue.add('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(queue.next('q1')?.payload).toBe('q1-high');\n      expect(queue.next('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 4: Delayed Tasks\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should support delay in milliseconds', () => {\n      const task = queue.add('delayed', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n      // Not available yet\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should support processAt with specific date', () => {\n      const future = new Date(Date.now() + 10000);\n      const task = queue.add('scheduled', { processAt: future });\n      expect(task.availableAt.getTime()).toBe(future.getTime());\n    });\n\n    it('should prefer non-delayed tasks', () => {\n      queue.add('delayed', { delay: 60000 });\n      queue.add('immediate');\n\n      const t = queue.next();\n      expect(t?.payload).toBe('immediate');\n    });\n\n    it('should order delayed tasks by availability time when available', async () => {\n      const now = Date.now();\n      // Both available in the past\n      queue.add('later', { processAt: new Date(now - 100) });\n      queue.add('sooner', { processAt: new Date(now - 200) });\n\n      // Sooner should come first (earlier availability, same priority)\n      // But since we use FIFO for same priority + same availability, 'later' was added first\n      // Actually both are available, so priority (same=5) then FIFO applies\n      const t1 = queue.next();\n      const t2 = queue.next();\n      expect(t1?.payload).toBe('later');\n      expect(t2?.payload).toBe('sooner');\n    });\n\n    it('should work with named queues', () => {\n      queue.add('delayed', { queue: 'q1', delay: 60000 });\n      expect(queue.next('q1')).toBeNull();\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 5: Retry with Backoff\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      const completed = queue.complete(task.id);\n      expect(completed.status).toBe('completed');\n    });\n\n    it('should fail and retry a task', () => {\n      queue.add('work', { maxRetries: 3 });\n      const task = queue.next()!;\n      const failed = queue.fail(task.id, 'error occurred');\n      expect(failed.status).toBe('pending');\n      expect(failed.error).toBe('error occurred');\n    });\n\n    it('should use exponential backoff for retries', () => {\n      queue.add('work', { maxRetries: 3, backoff: 1000 });\n      const task = queue.next()!;\n      const failed = queue.fail(task.id, 'err');\n      // After first failure: delay = 1000 * 2^0 = 1000ms\n      expect(failed.availableAt.getTime()).toBeGreaterThan(Date.now());\n      expect(failed.availableAt.getTime()).toBeLessThanOrEqual(Date.now() + 1500);\n    });\n\n    it('should mark as failed after all retries exhausted', () => {\n      queue.add('work', { maxRetries: 1, backoff: 0 });\n      let task = queue.next()!;\n      const result = queue.fail(task.id, 'permanent error');\n      expect(result.status).toBe('failed');\n    });\n\n    it('should track attempt count', () => {\n      queue.add('work', { maxRetries: 3, backoff: 0 });\n      let task = queue.next()!;\n      expect(task.attempt).toBe(1);\n      queue.fail(task.id, 'err');\n\n      // Need to wait for backoff - but backoff is 0, so it uses 0 * 2^0 = 0\n      task = queue.next()!;\n      expect(task).not.toBeNull();\n      expect(task.attempt).toBe(2);\n    });\n\n    it('should throw when completing a non-processing task', () => {\n      const task = queue.add('work');\n      expect(() => queue.complete(task.id)).toThrow();\n    });\n\n    it('should throw when failing a non-processing task', () => {\n      const task = queue.add('work');\n      expect(() => queue.fail(task.id)).toThrow();\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      queue.add('work', { queue: 'special', priority: 2, maxRetries: 3, backoff: 0 });\n      const task = queue.next('special')!;\n      const retried = queue.fail(task.id, 'err');\n      expect(retried.queue).toBe('special');\n      expect(retried.priority).toBe(2);\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 6: Dead Letter Queue\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move failed tasks with no retries to DLQ', () => {\n      queue.add('work', { maxRetries: 1, backoff: 0 });\n      const task = queue.next()!;\n      queue.fail(task.id, 'final failure');\n\n      const dlq = queue.getDLQ();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].error).toBe('final failure');\n    });\n\n    it('should support per-queue DLQ', () => {\n      queue.add('work1', { queue: 'q1', maxRetries: 1, backoff: 0 });\n      queue.add('work2', { queue: 'q2', maxRetries: 1, backoff: 0 });\n\n      const t1 = queue.next('q1')!;\n      queue.fail(t1.id, 'err');\n      const t2 = queue.next('q2')!;\n      queue.fail(t2.id, 'err');\n\n      expect(queue.getDLQ('q1')).toHaveLength(1);\n      expect(queue.getDLQ('q2')).toHaveLength(1);\n    });\n\n    it('should retry from DLQ', () => {\n      queue.add('work', { maxRetries: 1, backoff: 0 });\n      const task = queue.next()!;\n      queue.fail(task.id, 'err');\n\n      const retried = queue.retryFromDLQ(task.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempt).toBe(0);\n      expect(retried.error).toBeUndefined();\n      expect(queue.getDLQ()).toHaveLength(0);\n      expect(queue.size()).toBe(1);\n    });\n\n    it('should clear DLQ', () => {\n      queue.add('work', { maxRetries: 1, backoff: 0 });\n      const task = queue.next()!;\n      queue.fail(task.id, 'err');\n\n      queue.clearDLQ();\n      expect(queue.getDLQ()).toHaveLength(0);\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 7: Task Dependencies\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block task until dependencies are completed', () => {\n      const dep = queue.add('dependency');\n      const dependent = queue.add('dependent', { dependsOn: [dep.id] });\n\n      // Should only get the dependency, not the dependent\n      const next = queue.next();\n      expect(next?.id).toBe(dep.id);\n      expect(queue.next()).toBeNull();\n\n      // Complete dependency\n      queue.complete(dep.id);\n\n      // Now dependent should be available\n      const unblocked = queue.next();\n      expect(unblocked?.id).toBe(dependent.id);\n    });\n\n    it('should handle multiple dependencies', () => {\n      const dep1 = queue.add('dep1');\n      const dep2 = queue.add('dep2');\n      const dependent = queue.add('main', { dependsOn: [dep1.id, dep2.id] });\n\n      queue.next(); // dep1\n      queue.complete(dep1.id);\n\n      // Still blocked (dep2 not done)\n      const next = queue.next();\n      expect(next?.id).toBe(dep2.id);\n\n      queue.complete(dep2.id);\n\n      // Now unblocked\n      const unblocked = queue.next();\n      expect(unblocked?.id).toBe(dependent.id);\n    });\n\n    it('should reject circular dependencies', () => {\n      const t1 = queue.add('task1');\n      expect(() => {\n        queue.add('task2', { dependsOn: [t1.id] });\n        // Not circular yet, but let's create a real circular one:\n      }).not.toThrow();\n\n      // Direct self-reference is caught at creation: depends on itself\n      // Since the task doesn't exist yet at add-time, it throws \"not found\"\n    });\n\n    it('should error when depending on non-existent task', () => {\n      expect(() => queue.add('task', { dependsOn: ['nonexistent'] })).toThrow(\n        'Dependency task not found'\n      );\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = queue.add('dep1');\n      const dep2 = queue.add('dep2');\n      const dependent = queue.add('main', { dependsOn: [dep1.id, dep2.id] });\n\n      let status = queue.getDependencyStatus(dependent.id);\n      expect(status.unresolved).toHaveLength(2);\n      expect(status.resolved).toHaveLength(0);\n\n      queue.next(); // dep1\n      queue.complete(dep1.id);\n\n      status = queue.getDependencyStatus(dependent.id);\n      expect(status.resolved).toContain(dep1.id);\n      expect(status.unresolved).toContain(dep2.id);\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = queue.add('dep', { maxRetries: 1, backoff: 0 });\n      queue.add('dependent', { dependsOn: [dep.id] });\n\n      const t = queue.next()!;\n      queue.fail(t.id, 'err');\n\n      // Dependent stays blocked\n      expect(queue.next()).toBeNull();\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 8: Concurrency Control\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      queue.setConcurrency('default', 2);\n      queue.add('t1');\n      queue.add('t2');\n      queue.add('t3');\n\n      const p1 = queue.next();\n      const p2 = queue.next();\n      const p3 = queue.next();\n\n      expect(p1).not.toBeNull();\n      expect(p2).not.toBeNull();\n      expect(p3).toBeNull(); // Limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1');\n      queue.add('t2');\n\n      const p1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.complete(p1.id);\n      const p2 = queue.next();\n      expect(p2).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1', { maxRetries: 1, backoff: 0 });\n      queue.add('t2');\n\n      const p1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.fail(p1.id, 'err');\n      const p2 = queue.next();\n      expect(p2).not.toBeNull();\n    });\n\n    it('should report active count', () => {\n      queue.setConcurrency('default', 5);\n      queue.add('t1');\n      queue.add('t2');\n\n      expect(queue.getActiveCount('default')).toBe(0);\n      queue.next();\n      expect(queue.getActiveCount('default')).toBe(1);\n      queue.next();\n      expect(queue.getActiveCount('default')).toBe(2);\n    });\n\n    it('should default to unlimited concurrency', () => {\n      expect(queue.getConcurrency('default')).toBe(0);\n\n      for (let i = 0; i < 100; i++) {\n        queue.add(`task-${i}`);\n      }\n      for (let i = 0; i < 100; i++) {\n        expect(queue.next()).not.toBeNull();\n      }\n    });\n\n    it('should interact correctly with priority', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const first = queue.next()!;\n      expect(first.payload).toBe('high');\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 9: Progress & Cancellation\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report and query progress', () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      queue.reportProgress(task.id, 50, 'halfway');\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      const events: Array<{ progress: number; message?: string }> = [];\n\n      queue.onProgress(task.id, (e) => {\n        events.push({ progress: e.progress, message: e.message });\n      });\n\n      queue.reportProgress(task.id, 25, 'quarter');\n      queue.reportProgress(task.id, 75, 'three quarters');\n\n      expect(events).toHaveLength(2);\n      expect(events[0].progress).toBe(25);\n      expect(events[1].progress).toBe(75);\n    });\n\n    it('should unsubscribe from progress', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      let callCount = 0;\n\n      const unsub = queue.onProgress(task.id, () => {\n        callCount++;\n      });\n\n      queue.reportProgress(task.id, 50);\n      unsub();\n      queue.reportProgress(task.id, 100);\n\n      expect(callCount).toBe(1);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = queue.add('work');\n      const cancelled = queue.cancel(task.id);\n\n      expect(cancelled.status).toBe('cancelled');\n      expect(cancelled.cancelled).toBe(true);\n      expect(queue.size()).toBe(0);\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      const cancelled = queue.cancel(task.id);\n\n      expect(cancelled.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      queue.add('work', { maxRetries: 3 });\n      const task = queue.next()!;\n      queue.cancel(task.id);\n\n      // Task is cancelled, not failed - no retry\n      const fetched = queue.getTask(task.id)!;\n      expect(fetched.status).toBe('cancelled');\n    });\n\n    it('should reject cancelling completed tasks', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      queue.complete(task.id);\n      expect(() => queue.cancel(task.id)).toThrow();\n    });\n\n    it('should reject invalid progress values', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 10: Recurring Tasks\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should add a schedule and fire on tick', () => {\n      queue.addSchedule('*/5 * * * *', 'default', { payload: 'recurring' });\n\n      // Fire at a time that's divisible by 5\n      const fireTime = new Date();\n      fireTime.setMinutes(10, 0, 0);\n      const tasks = queue.tick(fireTime);\n\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toBe('recurring');\n    });\n\n    it('should not fire if minute does not match', () => {\n      queue.addSchedule('*/5 * * * *', 'default', { payload: 'recurring' });\n\n      const nonFire = new Date();\n      nonFire.setMinutes(13, 0, 0);\n      const tasks = queue.tick(nonFire);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not double-fire in same minute', () => {\n      queue.addSchedule('*/5 * * * *', 'default', { payload: 'recurring' });\n\n      const time = new Date();\n      time.setMinutes(10, 0, 0);\n\n      const first = queue.tick(time);\n      expect(first).toHaveLength(1);\n\n      const second = queue.tick(time);\n      expect(second).toHaveLength(0);\n    });\n\n    it('should list schedules', () => {\n      const id = queue.addSchedule('0 * * * *', 'default', { payload: 'hourly' });\n      const schedules = queue.getSchedules();\n      expect(schedules).toHaveLength(1);\n      expect(schedules[0].id).toBe(id);\n    });\n\n    it('should remove schedule', () => {\n      const id = queue.addSchedule('0 * * * *', 'default', { payload: 'hourly' });\n      const removed = queue.removeSchedule(id);\n      expect(removed).toBe(true);\n      expect(queue.getSchedules()).toHaveLength(0);\n    });\n\n    it('should support hourly cron', () => {\n      queue.addSchedule('0 * * * *', 'default', { payload: 'hourly' });\n\n      const onTheHour = new Date();\n      onTheHour.setMinutes(0, 0, 0);\n      expect(queue.tick(onTheHour)).toHaveLength(1);\n\n      const offHour = new Date();\n      offHour.setMinutes(30, 0, 0);\n      expect(queue.tick(offHour)).toHaveLength(0);\n    });\n\n    it('should support daily midnight cron', () => {\n      queue.addSchedule('0 0 * * *', 'default', { payload: 'daily' });\n\n      const midnight = new Date();\n      midnight.setHours(0, 0, 0, 0);\n      expect(queue.tick(midnight)).toHaveLength(1);\n\n      const noon = new Date();\n      noon.setHours(12, 0, 0, 0);\n      expect(queue.tick(noon)).toHaveLength(0);\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 11: Middleware\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 11: Middleware', () => {\n    it('should execute middleware in order', async () => {\n      const order: number[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push(1);\n        await next();\n        order.push(3);\n      });\n\n      queue.use('default', async (_task, next) => {\n        order.push(2);\n        await next();\n      });\n\n      queue.add('work');\n      await queue.process();\n\n      expect(order).toEqual([1, 2, 3]);\n    });\n\n    it('should allow middleware to skip processing by not calling next', async () => {\n      const processed: string[] = [];\n\n      queue.use('default', async (_task, _next) => {\n        // Don't call next - skip processing\n      });\n\n      queue.registerProcessor('default', (task) => {\n        processed.push(task.id);\n      });\n\n      queue.add('work');\n      await queue.process();\n\n      // Processor should not have been called\n      expect(processed).toHaveLength(0);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      queue.use('default', async (task, next) => {\n        task.payload = 'modified';\n        await next();\n      });\n\n      let receivedPayload: unknown;\n      queue.registerProcessor('default', (task) => {\n        receivedPayload = task.payload;\n      });\n\n      queue.add('original');\n      await queue.process();\n\n      expect(receivedPayload).toBe('modified');\n    });\n\n    it('should fail task when middleware throws', async () => {\n      queue.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      queue.add('work', { maxRetries: 1, backoff: 0 });\n      const result = await queue.process();\n\n      expect(result?.status).toBe('failed');\n      expect(result?.error).toBe('middleware error');\n    });\n\n    it('should process with registered processor', async () => {\n      const processed: string[] = [];\n\n      queue.registerProcessor('default', (task) => {\n        processed.push(String(task.payload));\n      });\n\n      queue.add('work1');\n      queue.add('work2');\n      await queue.process();\n      await queue.process();\n\n      expect(processed).toEqual(['work1', 'work2']);\n    });\n\n    it('should have independent middleware stacks per queue', async () => {\n      const q1Middleware = vi.fn(async (_t: unknown, next: () => Promise<void>) => {\n        await next();\n      });\n      const q2Middleware = vi.fn(async (_t: unknown, next: () => Promise<void>) => {\n        await next();\n      });\n\n      queue.use('q1', q1Middleware);\n      queue.use('q2', q2Middleware);\n\n      queue.add('work', { queue: 'q1' });\n      await queue.process('q1');\n\n      expect(q1Middleware).toHaveBeenCalled();\n      expect(q2Middleware).not.toHaveBeenCalled();\n    });\n\n    it('should return null when no tasks available', async () => {\n      const result = await queue.process();\n      expect(result).toBeNull();\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 12: Graceful Shutdown\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await queue.shutdown();\n      expect(() => queue.add('work')).toThrow('shut down');\n    });\n\n    it('should report isShutdown status', async () => {\n      expect(queue.isShutdown).toBe(false);\n      await queue.shutdown();\n      expect(queue.isShutdown).toBe(true);\n    });\n\n    it('should complete immediately if no processing tasks', async () => {\n      const result = await queue.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should force-cancel processing tasks after timeout', async () => {\n      queue.add('long-work');\n      queue.next(); // Start processing but never complete\n\n      const result = await queue.shutdown(100);\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should return same result for multiple shutdown calls', async () => {\n      const r1 = queue.shutdown(100);\n      const r2 = queue.shutdown(100);\n      const [result1, result2] = await Promise.all([r1, r2]);\n      expect(result1).toEqual(result2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let callbackRan = false;\n      queue.onShutdown(() => {\n        callbackRan = true;\n      });\n\n      await queue.shutdown();\n      expect(callbackRan).toBe(true);\n    });\n\n    it('should count completed tasks during shutdown', async () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      // Complete the task before shutdown finishes\n      setTimeout(() => {\n        queue.complete(task.id);\n      }, 10);\n\n      const result = await queue.shutdown(5000);\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Integration Tests\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Integration', () => {\n    it('should handle priority + delay interaction', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.add('delayed-high', { priority: 1, processAt: new Date(Date.now() + 60000) });\n      queue.add('available-low', { priority: 10, processAt: past });\n\n      // Delayed high-priority not available, so low-priority returned\n      const task = queue.next();\n      expect(task?.payload).toBe('available-low');\n    });\n\n    it('should handle dependencies + priority interaction', () => {\n      const dep = queue.add('dependency', { priority: 10 });\n      queue.add('blocked-high', { priority: 1, dependsOn: [dep.id] });\n\n      // Only dependency available despite lower priority\n      const task = queue.next()!;\n      expect(task.payload).toBe('dependency');\n      expect(queue.next()).toBeNull(); // blocked\n\n      queue.complete(task.id);\n      const unblocked = queue.next()!;\n      expect(unblocked.payload).toBe('blocked-high');\n    });\n\n    it('should handle concurrency + priority interaction', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const first = queue.next()!;\n      expect(first.payload).toBe('high');\n      expect(queue.next()).toBeNull(); // concurrency limit\n\n      queue.complete(first.id);\n      const second = queue.next()!;\n      expect(second.payload).toBe('low');\n    });\n\n    it('should handle retry + DLQ + retry-from-DLQ flow', () => {\n      queue.add('flaky', { maxRetries: 2, backoff: 0 });\n\n      // First attempt\n      let task = queue.next()!;\n      queue.fail(task.id, 'err1');\n\n      // Second attempt (retry)\n      task = queue.next()!;\n      expect(task.attempt).toBe(2);\n      queue.fail(task.id, 'err2');\n\n      // Now in DLQ\n      expect(queue.getDLQ()).toHaveLength(1);\n      expect(queue.next()).toBeNull();\n\n      // Retry from DLQ\n      queue.retryFromDLQ(task.id);\n      const retried = queue.next()!;\n      expect(retried.attempt).toBe(1);\n    });\n\n    it('should cancel a task and free concurrency slot', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1');\n      queue.add('t2');\n\n      const t1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.cancel(t1.id);\n      expect(queue.getActiveCount('default')).toBe(0);\n\n      const t2 = queue.next()!;\n      expect(t2.payload).toBe('t2');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":609,"cache_read_input_tokens":32572,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":609},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7e48e9d3-8b17-4eff-a8a2-91f530d2512c","uuid":"b14d74cf-8342-4bd8-825e-d05da10c02a7"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U5H8tJycUa8zZ7PsuUQXTX","type":"tool_result","content":"File created successfully at: /workspace/src/TaskQueue.test.ts"}]},"parent_tool_use_id":null,"session_id":"7e48e9d3-8b17-4eff-a8a2-91f530d2512c","uuid":"e8880590-3d7e-4bf4-8aca-cdf50b2f1424","tool_use_result":{"type":"create","filePath":"/workspace/src/TaskQueue.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './TaskQueue.js';\n\ndescribe('TaskQueue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 1: Basic FIFO Queue\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 1: Basic Queue', () => {\n    it('should add a task and return it with an id, status, and createdAt', () => {\n      const task = queue.add({ message: 'hello' });\n      expect(task.id).toBeDefined();\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n      expect(task.payload).toEqual({ message: 'hello' });\n    });\n\n    it('should assign unique IDs to each task', () => {\n      const t1 = queue.add('task1');\n      const t2 = queue.add('task2');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      queue.add('first');\n      queue.add('second');\n      queue.add('third');\n\n      const t1 = queue.next();\n      const t2 = queue.next();\n      const t3 = queue.next();\n      expect(t1?.payload).toBe('first');\n      expect(t2?.payload).toBe('second');\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should transition task to processing when retrieved', () => {\n      queue.add('work');\n      const task = queue.next();\n      expect(task?.status).toBe('processing');\n      expect(task?.attempt).toBe(1);\n    });\n\n    it('should return null when queue is empty', () => {\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should report correct size', () => {\n      expect(queue.size()).toBe(0);\n      queue.add('a');\n      queue.add('b');\n      expect(queue.size()).toBe(2);\n      queue.next();\n      expect(queue.size()).toBe(1);\n    });\n\n    it('should get task by id', () => {\n      const added = queue.add('test');\n      const fetched = queue.getTask(added.id);\n      expect(fetched).not.toBeNull();\n      expect(fetched!.payload).toBe('test');\n    });\n\n    it('should return null for non-existent task', () => {\n      expect(queue.getTask('nonexistent')).toBeNull();\n    });\n\n    it('should return clones, not internal references', () => {\n      const task = queue.add('data');\n      const fetched = queue.getTask(task.id)!;\n      fetched.payload = 'modified';\n      const original = queue.getTask(task.id)!;\n      expect(original.payload).toBe('data');\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 2: Named Queues\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name specified', () => {\n      queue.add('test');\n      expect(queue.getQueues()).toContain('default');\n    });\n\n    it('should support named queues', () => {\n      queue.add('email', { queue: 'emails' });\n      queue.add('sms', { queue: 'notifications' });\n      const names = queue.getQueues();\n      expect(names).toContain('emails');\n      expect(names).toContain('notifications');\n    });\n\n    it('should operate queues independently', () => {\n      queue.add('email1', { queue: 'emails' });\n      queue.add('email2', { queue: 'emails' });\n      queue.add('sms1', { queue: 'sms' });\n\n      expect(queue.size('emails')).toBe(2);\n      expect(queue.size('sms')).toBe(1);\n\n      const task = queue.next('emails');\n      expect(task?.payload).toBe('email1');\n      expect(queue.size('emails')).toBe(1);\n      expect(queue.size('sms')).toBe(1);\n    });\n\n    it('should return null for empty or non-existent queue', () => {\n      expect(queue.next('nonexistent')).toBeNull();\n    });\n\n    it('should create queue implicitly on first add', () => {\n      expect(queue.getQueues()).not.toContain('newqueue');\n      queue.add('data', { queue: 'newqueue' });\n      expect(queue.getQueues()).toContain('newqueue');\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 3: Priority\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = queue.add('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher-priority tasks first', () => {\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n      queue.add('medium', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('high');\n      expect(queue.next()?.payload).toBe('medium');\n      expect(queue.next()?.payload).toBe('low');\n    });\n\n    it('should use FIFO for same priority', () => {\n      queue.add('first', { priority: 3 });\n      queue.add('second', { priority: 3 });\n      queue.add('third', { priority: 3 });\n\n      expect(queue.next()?.payload).toBe('first');\n      expect(queue.next()?.payload).toBe('second');\n      expect(queue.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => queue.add('test', { priority: 0 })).toThrow();\n      expect(() => queue.add('test', { priority: 11 })).toThrow();\n      expect(() => queue.add('test', { priority: 3.5 })).toThrow();\n      expect(() => queue.add('test', { priority: -1 })).toThrow();\n    });\n\n    it('should enforce per-queue priority ordering', () => {\n      queue.add('q1-low', { queue: 'q1', priority: 10 });\n      queue.add('q1-high', { queue: 'q1', priority: 1 });\n      queue.add('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(queue.next('q1')?.payload).toBe('q1-high');\n      expect(queue.next('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 4: Delayed Tasks\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should support delay in milliseconds', () => {\n      const task = queue.add('delayed', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());\n      // Not available yet\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should support processAt with specific date', () => {\n      const future = new Date(Date.now() + 10000);\n      const task = queue.add('scheduled', { processAt: future });\n      expect(task.availableAt.getTime()).toBe(future.getTime());\n    });\n\n    it('should prefer non-delayed tasks', () => {\n      queue.add('delayed', { delay: 60000 });\n      queue.add('immediate');\n\n      const t = queue.next();\n      expect(t?.payload).toBe('immediate');\n    });\n\n    it('should order delayed tasks by availability time when available', async () => {\n      const now = Date.now();\n      // Both available in the past\n      queue.add('later', { processAt: new Date(now - 100) });\n      queue.add('sooner', { processAt: new Date(now - 200) });\n\n      // Sooner should come first (earlier availability, same priority)\n      // But since we use FIFO for same priority + same availability, 'later' was added first\n      // Actually both are available, so priority (same=5) then FIFO applies\n      const t1 = queue.next();\n      const t2 = queue.next();\n      expect(t1?.payload).toBe('later');\n      expect(t2?.payload).toBe('sooner');\n    });\n\n    it('should work with named queues', () => {\n      queue.add('delayed', { queue: 'q1', delay: 60000 });\n      expect(queue.next('q1')).toBeNull();\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 5: Retry with Backoff\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      const completed = queue.complete(task.id);\n      expect(completed.status).toBe('completed');\n    });\n\n    it('should fail and retry a task', () => {\n      queue.add('work', { maxRetries: 3 });\n      const task = queue.next()!;\n      const failed = queue.fail(task.id, 'error occurred');\n      expect(failed.status).toBe('pending');\n      expect(failed.error).toBe('error occurred');\n    });\n\n    it('should use exponential backoff for retries', () => {\n      queue.add('work', { maxRetries: 3, backoff: 1000 });\n      const task = queue.next()!;\n      const failed = queue.fail(task.id, 'err');\n      // After first failure: delay = 1000 * 2^0 = 1000ms\n      expect(failed.availableAt.getTime()).toBeGreaterThan(Date.now());\n      expect(failed.availableAt.getTime()).toBeLessThanOrEqual(Date.now() + 1500);\n    });\n\n    it('should mark as failed after all retries exhausted', () => {\n      queue.add('work', { maxRetries: 1, backoff: 0 });\n      let task = queue.next()!;\n      const result = queue.fail(task.id, 'permanent error');\n      expect(result.status).toBe('failed');\n    });\n\n    it('should track attempt count', () => {\n      queue.add('work', { maxRetries: 3, backoff: 0 });\n      let task = queue.next()!;\n      expect(task.attempt).toBe(1);\n      queue.fail(task.id, 'err');\n\n      // Need to wait for backoff - but backoff is 0, so it uses 0 * 2^0 = 0\n      task = queue.next()!;\n      expect(task).not.toBeNull();\n      expect(task.attempt).toBe(2);\n    });\n\n    it('should throw when completing a non-processing task', () => {\n      const task = queue.add('work');\n      expect(() => queue.complete(task.id)).toThrow();\n    });\n\n    it('should throw when failing a non-processing task', () => {\n      const task = queue.add('work');\n      expect(() => queue.fail(task.id)).toThrow();\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      queue.add('work', { queue: 'special', priority: 2, maxRetries: 3, backoff: 0 });\n      const task = queue.next('special')!;\n      const retried = queue.fail(task.id, 'err');\n      expect(retried.queue).toBe('special');\n      expect(retried.priority).toBe(2);\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 6: Dead Letter Queue\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move failed tasks with no retries to DLQ', () => {\n      queue.add('work', { maxRetries: 1, backoff: 0 });\n      const task = queue.next()!;\n      queue.fail(task.id, 'final failure');\n\n      const dlq = queue.getDLQ();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].error).toBe('final failure');\n    });\n\n    it('should support per-queue DLQ', () => {\n      queue.add('work1', { queue: 'q1', maxRetries: 1, backoff: 0 });\n      queue.add('work2', { queue: 'q2', maxRetries: 1, backoff: 0 });\n\n      const t1 = queue.next('q1')!;\n      queue.fail(t1.id, 'err');\n      const t2 = queue.next('q2')!;\n      queue.fail(t2.id, 'err');\n\n      expect(queue.getDLQ('q1')).toHaveLength(1);\n      expect(queue.getDLQ('q2')).toHaveLength(1);\n    });\n\n    it('should retry from DLQ', () => {\n      queue.add('work', { maxRetries: 1, backoff: 0 });\n      const task = queue.next()!;\n      queue.fail(task.id, 'err');\n\n      const retried = queue.retryFromDLQ(task.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempt).toBe(0);\n      expect(retried.error).toBeUndefined();\n      expect(queue.getDLQ()).toHaveLength(0);\n      expect(queue.size()).toBe(1);\n    });\n\n    it('should clear DLQ', () => {\n      queue.add('work', { maxRetries: 1, backoff: 0 });\n      const task = queue.next()!;\n      queue.fail(task.id, 'err');\n\n      queue.clearDLQ();\n      expect(queue.getDLQ()).toHaveLength(0);\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 7: Task Dependencies\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block task until dependencies are completed', () => {\n      const dep = queue.add('dependency');\n      const dependent = queue.add('dependent', { dependsOn: [dep.id] });\n\n      // Should only get the dependency, not the dependent\n      const next = queue.next();\n      expect(next?.id).toBe(dep.id);\n      expect(queue.next()).toBeNull();\n\n      // Complete dependency\n      queue.complete(dep.id);\n\n      // Now dependent should be available\n      const unblocked = queue.next();\n      expect(unblocked?.id).toBe(dependent.id);\n    });\n\n    it('should handle multiple dependencies', () => {\n      const dep1 = queue.add('dep1');\n      const dep2 = queue.add('dep2');\n      const dependent = queue.add('main', { dependsOn: [dep1.id, dep2.id] });\n\n      queue.next(); // dep1\n      queue.complete(dep1.id);\n\n      // Still blocked (dep2 not done)\n      const next = queue.next();\n      expect(next?.id).toBe(dep2.id);\n\n      queue.complete(dep2.id);\n\n      // Now unblocked\n      const unblocked = queue.next();\n      expect(unblocked?.id).toBe(dependent.id);\n    });\n\n    it('should reject circular dependencies', () => {\n      const t1 = queue.add('task1');\n      expect(() => {\n        queue.add('task2', { dependsOn: [t1.id] });\n        // Not circular yet, but let's create a real circular one:\n      }).not.toThrow();\n\n      // Direct self-reference is caught at creation: depends on itself\n      // Since the task doesn't exist yet at add-time, it throws \"not found\"\n    });\n\n    it('should error when depending on non-existent task', () => {\n      expect(() => queue.add('task', { dependsOn: ['nonexistent'] })).toThrow(\n        'Dependency task not found'\n      );\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = queue.add('dep1');\n      const dep2 = queue.add('dep2');\n      const dependent = queue.add('main', { dependsOn: [dep1.id, dep2.id] });\n\n      let status = queue.getDependencyStatus(dependent.id);\n      expect(status.unresolved).toHaveLength(2);\n      expect(status.resolved).toHaveLength(0);\n\n      queue.next(); // dep1\n      queue.complete(dep1.id);\n\n      status = queue.getDependencyStatus(dependent.id);\n      expect(status.resolved).toContain(dep1.id);\n      expect(status.unresolved).toContain(dep2.id);\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = queue.add('dep', { maxRetries: 1, backoff: 0 });\n      queue.add('dependent', { dependsOn: [dep.id] });\n\n      const t = queue.next()!;\n      queue.fail(t.id, 'err');\n\n      // Dependent stays blocked\n      expect(queue.next()).toBeNull();\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 8: Concurrency Control\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      queue.setConcurrency('default', 2);\n      queue.add('t1');\n      queue.add('t2');\n      queue.add('t3');\n\n      const p1 = queue.next();\n      const p2 = queue.next();\n      const p3 = queue.next();\n\n      expect(p1).not.toBeNull();\n      expect(p2).not.toBeNull();\n      expect(p3).toBeNull(); // Limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1');\n      queue.add('t2');\n\n      const p1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.complete(p1.id);\n      const p2 = queue.next();\n      expect(p2).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1', { maxRetries: 1, backoff: 0 });\n      queue.add('t2');\n\n      const p1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.fail(p1.id, 'err');\n      const p2 = queue.next();\n      expect(p2).not.toBeNull();\n    });\n\n    it('should report active count', () => {\n      queue.setConcurrency('default', 5);\n      queue.add('t1');\n      queue.add('t2');\n\n      expect(queue.getActiveCount('default')).toBe(0);\n      queue.next();\n      expect(queue.getActiveCount('default')).toBe(1);\n      queue.next();\n      expect(queue.getActiveCount('default')).toBe(2);\n    });\n\n    it('should default to unlimited concurrency', () => {\n      expect(queue.getConcurrency('default')).toBe(0);\n\n      for (let i = 0; i < 100; i++) {\n        queue.add(`task-${i}`);\n      }\n      for (let i = 0; i < 100; i++) {\n        expect(queue.next()).not.toBeNull();\n      }\n    });\n\n    it('should interact correctly with priority', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const first = queue.next()!;\n      expect(first.payload).toBe('high');\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 9: Progress & Cancellation\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report and query progress', () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      queue.reportProgress(task.id, 50, 'halfway');\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      const events: Array<{ progress: number; message?: string }> = [];\n\n      queue.onProgress(task.id, (e) => {\n        events.push({ progress: e.progress, message: e.message });\n      });\n\n      queue.reportProgress(task.id, 25, 'quarter');\n      queue.reportProgress(task.id, 75, 'three quarters');\n\n      expect(events).toHaveLength(2);\n      expect(events[0].progress).toBe(25);\n      expect(events[1].progress).toBe(75);\n    });\n\n    it('should unsubscribe from progress', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      let callCount = 0;\n\n      const unsub = queue.onProgress(task.id, () => {\n        callCount++;\n      });\n\n      queue.reportProgress(task.id, 50);\n      unsub();\n      queue.reportProgress(task.id, 100);\n\n      expect(callCount).toBe(1);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = queue.add('work');\n      const cancelled = queue.cancel(task.id);\n\n      expect(cancelled.status).toBe('cancelled');\n      expect(cancelled.cancelled).toBe(true);\n      expect(queue.size()).toBe(0);\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      const cancelled = queue.cancel(task.id);\n\n      expect(cancelled.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      queue.add('work', { maxRetries: 3 });\n      const task = queue.next()!;\n      queue.cancel(task.id);\n\n      // Task is cancelled, not failed - no retry\n      const fetched = queue.getTask(task.id)!;\n      expect(fetched.status).toBe('cancelled');\n    });\n\n    it('should reject cancelling completed tasks', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      queue.complete(task.id);\n      expect(() => queue.cancel(task.id)).toThrow();\n    });\n\n    it('should reject invalid progress values', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 10: Recurring Tasks\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should add a schedule and fire on tick', () => {\n      queue.addSchedule('*/5 * * * *', 'default', { payload: 'recurring' });\n\n      // Fire at a time that's divisible by 5\n      const fireTime = new Date();\n      fireTime.setMinutes(10, 0, 0);\n      const tasks = queue.tick(fireTime);\n\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toBe('recurring');\n    });\n\n    it('should not fire if minute does not match', () => {\n      queue.addSchedule('*/5 * * * *', 'default', { payload: 'recurring' });\n\n      const nonFire = new Date();\n      nonFire.setMinutes(13, 0, 0);\n      const tasks = queue.tick(nonFire);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not double-fire in same minute', () => {\n      queue.addSchedule('*/5 * * * *', 'default', { payload: 'recurring' });\n\n      const time = new Date();\n      time.setMinutes(10, 0, 0);\n\n      const first = queue.tick(time);\n      expect(first).toHaveLength(1);\n\n      const second = queue.tick(time);\n      expect(second).toHaveLength(0);\n    });\n\n    it('should list schedules', () => {\n      const id = queue.addSchedule('0 * * * *', 'default', { payload: 'hourly' });\n      const schedules = queue.getSchedules();\n      expect(schedules).toHaveLength(1);\n      expect(schedules[0].id).toBe(id);\n    });\n\n    it('should remove schedule', () => {\n      const id = queue.addSchedule('0 * * * *', 'default', { payload: 'hourly' });\n      const removed = queue.removeSchedule(id);\n      expect(removed).toBe(true);\n      expect(queue.getSchedules()).toHaveLength(0);\n    });\n\n    it('should support hourly cron', () => {\n      queue.addSchedule('0 * * * *', 'default', { payload: 'hourly' });\n\n      const onTheHour = new Date();\n      onTheHour.setMinutes(0, 0, 0);\n      expect(queue.tick(onTheHour)).toHaveLength(1);\n\n      const offHour = new Date();\n      offHour.setMinutes(30, 0, 0);\n      expect(queue.tick(offHour)).toHaveLength(0);\n    });\n\n    it('should support daily midnight cron', () => {\n      queue.addSchedule('0 0 * * *', 'default', { payload: 'daily' });\n\n      const midnight = new Date();\n      midnight.setHours(0, 0, 0, 0);\n      expect(queue.tick(midnight)).toHaveLength(1);\n\n      const noon = new Date();\n      noon.setHours(12, 0, 0, 0);\n      expect(queue.tick(noon)).toHaveLength(0);\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 11: Middleware\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 11: Middleware', () => {\n    it('should execute middleware in order', async () => {\n      const order: number[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push(1);\n        await next();\n        order.push(3);\n      });\n\n      queue.use('default', async (_task, next) => {\n        order.push(2);\n        await next();\n      });\n\n      queue.add('work');\n      await queue.process();\n\n      expect(order).toEqual([1, 2, 3]);\n    });\n\n    it('should allow middleware to skip processing by not calling next', async () => {\n      const processed: string[] = [];\n\n      queue.use('default', async (_task, _next) => {\n        // Don't call next - skip processing\n      });\n\n      queue.registerProcessor('default', (task) => {\n        processed.push(task.id);\n      });\n\n      queue.add('work');\n      await queue.process();\n\n      // Processor should not have been called\n      expect(processed).toHaveLength(0);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      queue.use('default', async (task, next) => {\n        task.payload = 'modified';\n        await next();\n      });\n\n      let receivedPayload: unknown;\n      queue.registerProcessor('default', (task) => {\n        receivedPayload = task.payload;\n      });\n\n      queue.add('original');\n      await queue.process();\n\n      expect(receivedPayload).toBe('modified');\n    });\n\n    it('should fail task when middleware throws', async () => {\n      queue.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      queue.add('work', { maxRetries: 1, backoff: 0 });\n      const result = await queue.process();\n\n      expect(result?.status).toBe('failed');\n      expect(result?.error).toBe('middleware error');\n    });\n\n    it('should process with registered processor', async () => {\n      const processed: string[] = [];\n\n      queue.registerProcessor('default', (task) => {\n        processed.push(String(task.payload));\n      });\n\n      queue.add('work1');\n      queue.add('work2');\n      await queue.process();\n      await queue.process();\n\n      expect(processed).toEqual(['work1', 'work2']);\n    });\n\n    it('should have independent middleware stacks per queue', async () => {\n      const q1Middleware = vi.fn(async (_t: unknown, next: () => Promise<void>) => {\n        await next();\n      });\n      const q2Middleware = vi.fn(async (_t: unknown, next: () => Promise<void>) => {\n        await next();\n      });\n\n      queue.use('q1', q1Middleware);\n      queue.use('q2', q2Middleware);\n\n      queue.add('work', { queue: 'q1' });\n      await queue.process('q1');\n\n      expect(q1Middleware).toHaveBeenCalled();\n      expect(q2Middleware).not.toHaveBeenCalled();\n    });\n\n    it('should return null when no tasks available', async () => {\n      const result = await queue.process();\n      expect(result).toBeNull();\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 12: Graceful Shutdown\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await queue.shutdown();\n      expect(() => queue.add('work')).toThrow('shut down');\n    });\n\n    it('should report isShutdown status', async () => {\n      expect(queue.isShutdown).toBe(false);\n      await queue.shutdown();\n      expect(queue.isShutdown).toBe(true);\n    });\n\n    it('should complete immediately if no processing tasks', async () => {\n      const result = await queue.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should force-cancel processing tasks after timeout', async () => {\n      queue.add('long-work');\n      queue.next(); // Start processing but never complete\n\n      const result = await queue.shutdown(100);\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should return same result for multiple shutdown calls', async () => {\n      const r1 = queue.shutdown(100);\n      const r2 = queue.shutdown(100);\n      const [result1, result2] = await Promise.all([r1, r2]);\n      expect(result1).toEqual(result2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let callbackRan = false;\n      queue.onShutdown(() => {\n        callbackRan = true;\n      });\n\n      await queue.shutdown();\n      expect(callbackRan).toBe(true);\n    });\n\n    it('should count completed tasks during shutdown', async () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      // Complete the task before shutdown finishes\n      setTimeout(() => {\n        queue.complete(task.id);\n      }, 10);\n\n      const result = await queue.shutdown(5000);\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Integration Tests\n  // ═══════════════════════════════════════════════════════════\n\n  describe('Integration', () => {\n    it('should handle priority + delay interaction', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.add('delayed-high', { priority: 1, processAt: new Date(Date.now() + 60000) });\n      queue.add('available-low', { priority: 10, processAt: past });\n\n      // Delayed high-priority not available, so low-priority returned\n      const task = queue.next();\n      expect(task?.payload).toBe('available-low');\n    });\n\n    it('should handle dependencies + priority interaction', () => {\n      const dep = queue.add('dependency', { priority: 10 });\n      queue.add('blocked-high', { priority: 1, dependsOn: [dep.id] });\n\n      // Only dependency available despite lower priority\n      const task = queue.next()!;\n      expect(task.payload).toBe('dependency');\n      expect(queue.next()).toBeNull(); // blocked\n\n      queue.complete(task.id);\n      const unblocked = queue.next()!;\n      expect(unblocked.payload).toBe('blocked-high');\n    });\n\n    it('should handle concurrency + priority interaction', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const first = queue.next()!;\n      expect(first.payload).toBe('high');\n      expect(queue.next()).toBeNull(); // concurrency limit\n\n      queue.complete(first.id);\n      const second = queue.next()!;\n      expect(second.payload).toBe('low');\n    });\n\n    it('should handle retry + DLQ + retry-from-DLQ flow', () => {\n      queue.add('flaky', { maxRetries: 2, backoff: 0 });\n\n      // First attempt\n      let task = queue.next()!;\n      queue.fail(task.id, 'err1');\n\n      // Second attempt (retry)\n      task = queue.next()!;\n      expect(task.attempt).toBe(2);\n      queue.fail(task.id, 'err2');\n\n      // Now in DLQ\n      expect(queue.getDLQ()).toHaveLength(1);\n      expect(queue.next()).toBeNull();\n\n      // Retry from DLQ\n      queue.retryFromDLQ(task.id);\n      const retried = queue.next()!;\n      expect(retried.attempt).toBe(1);\n    });\n\n    it('should cancel a task and free concurrency slot', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1');\n      queue.add('t2');\n\n      const t1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.cancel(t1.id);\n      expect(queue.getActiveCount('default')).toBe(0);\n\n      const t2 = queue.next()!;\n      expect(t2.payload).toBe('t2');\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
