@@ -0,0 +1,86 @@
+/**
+ * Minimal cron expression parser supporting:
+ *   - * /N * * * *   (every N minutes)  -- written as asterisk-slash-N
+ *   - 0 * * * *      (every hour on the hour)
+ *   - 0 0 * * *      (every day at midnight)
+ *
+ * We only look at the minute and hour fields. All other fields are wildcards.
+ */
+
+export interface ParsedCron {
+  minute: { type: 'any' } | { type: 'exact'; value: number } | { type: 'interval'; every: number };
+  hour: { type: 'any' } | { type: 'exact'; value: number };
+}
+
+export function parseCron(expr: string): ParsedCron {
+  const parts = expr.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: "${expr}". Expected 5 fields.`);
+  }
+
+  const [minField, hourField] = parts;
+
+  let minute: ParsedCron['minute'];
+  if (minField === '*') {
+    minute = { type: 'any' };
+  } else if (minField.startsWith('*/')) {
+    const n = parseInt(minField.slice(2), 10);
+    if (isNaN(n) || n <= 0 || n > 59) {
+      throw new Error(`Invalid cron minute interval: "${minField}"`);
+    }
+    minute = { type: 'interval', every: n };
+  } else {
+    const v = parseInt(minField, 10);
+    if (isNaN(v) || v < 0 || v > 59) {
+      throw new Error(`Invalid cron minute value: "${minField}"`);
+    }
+    minute = { type: 'exact', value: v };
+  }
+
+  let hour: ParsedCron['hour'];
+  if (hourField === '*') {
+    hour = { type: 'any' };
+  } else {
+    const v = parseInt(hourField, 10);
+    if (isNaN(v) || v < 0 || v > 23) {
+      throw new Error(`Invalid cron hour value: "${hourField}"`);
+    }
+    hour = { type: 'exact', value: v };
+  }
+
+  return { minute, hour };
+}
+
+export function shouldFire(parsed: ParsedCron, now: Date, lastRun: Date | undefined): boolean {
+  const currentMin = now.getMinutes();
+  const currentHour = now.getHours();
+
+  // Check hour constraint
+  if (parsed.hour.type === 'exact' && parsed.hour.value !== currentHour) {
+    return false;
+  }
+
+  // Check minute constraint
+  if (parsed.minute.type === 'exact' && parsed.minute.value !== currentMin) {
+    return false;
+  }
+
+  if (parsed.minute.type === 'interval') {
+    if (currentMin % parsed.minute.every !== 0) {
+      return false;
+    }
+  }
+
+  // Guard against double-firing within same minute
+  if (lastRun) {
+    const lastMin = lastRun.getMinutes();
+    const lastHour = lastRun.getHours();
+    const lastDate = lastRun.toDateString();
+    const nowDate = now.toDateString();
+    if (lastMin === currentMin && lastHour === currentHour && lastDate === nowDate) {
+      return false;
+    }
+  }
+
+  return true;
+}
