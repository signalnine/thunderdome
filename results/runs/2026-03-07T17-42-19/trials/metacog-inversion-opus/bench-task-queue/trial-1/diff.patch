+export { TaskQueue } from './TaskQueue.js';
+export {
+  TaskData,
+  TaskOptions,
+  TaskStatus,
+  ScheduleEntry,
+  MiddlewareFn,
+  ProcessorFn,
+  ProgressEvent,
+  ProgressListener,
+  ShutdownResult,
+  createTask,
+} from './types.js';
+export { parseCron, shouldFire } from './cron.js';
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..a3ba53b
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,88 @@
+import { randomUUID } from 'node:crypto';
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  maxRetries?: number;
+  backoff?: number;
+  dependsOn?: string[];
+}
+
+export interface TaskData {
+  id: string;
+  payload: unknown;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoff: number;
+  error?: string;
+  dependsOn: string[];
+  progress: number;
+  progressMessage?: string;
+  cancelled: boolean;
+}
+
+export function createTask(payload: unknown, options: TaskOptions = {}): TaskData {
+  const now = new Date();
+  const priority = options.priority ?? 5;
+
+  if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+    throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+  }
+
+  let availableAt = now;
+  if (options.processAt) {
+    availableAt = options.processAt;
+  } else if (options.delay != null && options.delay > 0) {
+    availableAt = new Date(now.getTime() + options.delay);
+  }
+
+  return {
+    id: randomUUID(),
+    payload,
+    status: 'pending',
+    queue: options.queue ?? 'default',
+    priority,
+    createdAt: now,
+    availableAt,
+    attempt: 0,
+    maxRetries: options.maxRetries ?? 3,
+    backoff: options.backoff ?? 1000,
+    dependsOn: options.dependsOn ? [...options.dependsOn] : [],
+    progress: 0,
+    cancelled: false,
+  };
+}
+
+export interface ScheduleEntry {
+  id: string;
+  cron: string;
+  queue: string;
+  taskTemplate: { payload: unknown; options?: Omit<TaskOptions, 'queue'> };
+  lastRun?: Date;
+}
+
+export type MiddlewareFn = (task: TaskData, next: () => Promise<void>) => Promise<void>;
+export type ProcessorFn = (task: TaskData) => Promise<void> | void;
+
+export interface ProgressEvent {
+  taskId: string;
+  progress: number;
+  message?: string;
