+import { v4 as uuidv4 } from 'uuid';
+import { getDB } from './db';
+
+export interface UserRegister {
+  email: string;
+  password: string;
+  tenantId: string;
+}
+
+export interface UserLogin {
+  email: string;
+  password: string;
+}
+
+export interface User {
+  id: string;
+  email: string;
+  role: string;
+  tenantId: string;
+  createdAt: string;
+  passwordHash?: string;
+}
+
+function validateRole(role: string): role is 'admin' | 'viewer' | 'editor' {
+  return ['admin', 'viewer', 'editor'].includes(role);
+}
+
+function hashPassword(password: string): string {
+  const Crypto = require('crypto');
+  const hash = Crypto.createHash('sha256').update(password).digest('hex');
+  return `sha256:${hash}`;
+}
+
+function registerUser({ email, password, tenantId }: UserRegister): User {
+  const passwordHash = hashPassword(password);
+  const userId = uuidv4();
+
+  const db = getDB();
+  db.prepare('INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)').run(userId, email, passwordHash, tenantId, 'viewer');
+
+  return {
+    id: userId,
+    email,
+    role: 'viewer',
+    tenantId,
+    createdAt: new Date().toISOString(),
+    passwordHash,
+  };
+}
+
+function loginUser({ email, password }: UserLogin): { token: string; user: Omit<User, 'passwordHash'> } {
+  const db = getDB();
+  const authData = db.prepare('SELECT id, email, password_hash, tenant_id, role FROM users WHERE email = ?').get(email) as
+    | (Pick<User, 'id' | 'email' | 'passwordHash' | 'tenantId' | 'role'> & { passwordHash: string })
+    | undefined;
+
+  if (!authData || authData.passwordHash !== hashPassword(password)) {
+    throw new Error('Invalid credentials');
+  }
+
+  db.prepare('UPDATE users SET role = ? WHERE id = ?').run(authData.role, authData.id);
+  const user = db.prepare('SELECT id, email, role, tenant_id, created_at FROM users WHERE id = ?').get(authData.id) as User;
+
+  const { app } = require('./app');
+  const { generateJWT } = require('./auth');
+  const token = generateJWT(app, user.id, user.tenantId, user.role);
+
+  return {
+    token,
+    user: {
+      id: user.id,
+      email: user.email,
+      role: user.role,
+      tenantId: user.tenantId,
+      createdAt: user.created_at,
+    },
+  };
+}
+
+function getUserById(userId: string): User {
+  const db = getDB();
+  const user = db.prepare('SELECT id, email, role, tenant_id, created_at FROM users WHERE id = ?').get(userId) as User;
+  if (!user) {
+    throw new Error('User not found');
+  }
+  return user;
+}
+
+function getUsersByTenant(tenantId: string): User[] {
+  const db = getDB();
+  return db.prepare('SELECT id, email, role, tenant_id, created_at FROM users WHERE tenant_id = ?').all(tenantId) as User[];
+}
+
+const updateUserRole = (userId: string, role: string): void => {
+  if (!validateRole(role)) {
+    throw new Error('Invalid role');
+  }
+
+  const db = getDB();
+  const result = db.prepare('SELECT id FROM users WHERE id = ? AND role = ?').get(userId, role);
+  if (!result) {
+    throw new Error('User not found or already has this role');
+  }
+
+  db.prepare('UPDATE users SET role = ? WHERE id = ?').run(role, userId);
+};
+
+export const validateRole = validateRole;
+
+function generateJWT(userId: string, tenantId: string, role?: string): Promise<string> {
+  const tokenPayload: any = {
+    sub: userId,
+    tid: tenantId,
+    iat: Math.floor(Date.now() / 1000),
+    exp: Math.floor(Date.now() / 1000) + (86400 * 30),
+  };
+  if (role) {
+    tokenPayload.role = role;
+  }
+  const JWT_SECRET = process.env.JWT_SECRET || 'dev-secret-change-in-production';
+  return (require('jsonwebtoken').sign(tokenPayload, JWT_SECRET));
+}
+
+function verifyJWTToken(token: string): Promise<any> {
+  try {
+    const JWT_SECRET = process.env.JWT_SECRET || 'dev-secret-change-in-production';
+    return (require('jsonwebtoken').verify(token, JWT_SECRET));
+  } catch {
+    throw new Error('Invalid or expired token');
+  }
+}
+
+export const { validateRole, hashPassword, registerUser, loginUser, getUserById, getUsersByTenant, updateUserRole, generateJWT, verifyJWTToken };
+
+export default getUserById;
