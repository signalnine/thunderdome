+import { v4 as uuidv4 } from 'uuid';
+import { getDB as getDBImport } from './db';
+
+const _DB = getDBImport();
+
+export interface Dashboard {
+  id: string;
+  tenantId: string;
+  name: string;
+  ownerId: string;
+  config: Record<string, any>;
+  createdAt: string;
+  updatedAt: string;
+}
+
+export function createDashboard(name: string, tenantId: string, ownerId: string): Dashboard {
+  const id = uuidv4();
+  const config = {};
+
+  _DB.prepare('INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)').run(id, tenantId, name, ownerId, JSON.stringify(config), new Date().toISOString(), new Date().toISOString());
+
+  return {
+    id,
+    tenantId,
+    name,
+    ownerId,
+    config,
+    createdAt: new Date().toISOString(),
+    updatedAt: new Date().toISOString(),
+  };
+}
+
+export function getDashboard(id: string): Dashboard {
+  const dashboard = _DB.prepare('SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE id = ?').get(id) as Dashboard;
+  if (!dashboard) {
+    throw new Error('Dashboard not found');
+  }
+  return dashboard;
+}
+
+export function getDashboardsByTenant(tenantId: string): Dashboard[] {
+  return _DB.prepare('SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ? ORDER BY updated_at DESC').all(tenantId) as Dashboard[];
+}
+
+export function deleteDashboard(id: string): void {
+  _DB.prepare('DELETE FROM dashboards WHERE id = ?').run(id);
+}
+
+export default getDashboard;
