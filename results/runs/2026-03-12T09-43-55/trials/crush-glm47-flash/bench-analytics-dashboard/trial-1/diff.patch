+import { v4 as uuidv4 } from 'uuid';
+import { getDB as getDBImport } from './db';
+
+const _DB = getDBImport();
+
+export interface Event {
+  id: string;
+  tenantId: string;
+  name: string;
+  properties: Record<string, any>;
+  timestamp: string;
+  userId?: string;
+  sessionId?: string;
+}
+
+export interface EventIngest {
+  name: string;
+  properties?: Record<string, any>;
+  timestamp?: string;
+  sessionId?: string;
+}
+
+export function ingestEvent(event: EventIngest, userId?: string, tenantId: string = 'unknown'): Event {
+  const id = uuidv4();
+  const timestamp = event.timestamp || new Date().toISOString();
+  const properties = event.properties || {};
+
+  _DB.prepare('INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)').run(id, tenantId, event.name, JSON.stringify(properties), timestamp, userId, event.sessionId);
+
+  return {
+    id,
+    tenantId,
+    name: event.name,
+    properties,
+    timestamp,
+    userId,
+    sessionId: event.sessionId,
+  };
+}
+
+export function ingestBatchEvents(events: EventIngest[], user?: { id: string; tenantId: string }): Event[] {
+  const stmt = _DB.prepare(`
+    INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id)
+    VALUES ${events.map(() => '(?, ?, ?, ?, ?, ?, ?)').join(', ')}
+  `);
+
+  const params: any[] = [];
+  events.forEach(event => {
+    params.push(
+      uuidv4(),
+      user?.tenantId || 'batch',
+      event.name,
+      JSON.stringify(event.properties || {}),
+      event.timestamp || new Date().toISOString(),
+      user?.id,
+      event.sessionId,
+    );
+  });
+
+  stmt.run(...params);
+
+  return events.map(() => ({
+    id: uuidv4(),
+    tenantId: user?.tenantId || 'batch',
+    name: '',
+    properties: {},
+    timestamp: '',
+    userId: user?.id,
+    sessionId: undefined,
+  }));
+}
+
+export function getEventsByTenant(tenantId: string, limit = 100): Event[] {
+  return _DB.prepare('SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ? ORDER BY timestamp DESC LIMIT ?').all(tenantId, limit) as Event[];
+}
+
+export function deleteEventsByTenant(tenantId: string): number {
+  return _DB.prepare('DELETE FROM events WHERE tenant_id = ?').run(tenantId).changes;
+}
+
+export default ingestEvent;
