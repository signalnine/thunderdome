+import { getDB as getDBImport } from './db';
+import { getDashboardsByTenant } from './dashboards';
+import { countEvents, QueryFilters } from './query';
+
+const _DB = getDBImport();
+
+export interface ExportOptions {
+  format: 'json' | 'csv';
+  filters?: QueryFilters;
+  limit?: number;
+}
+
+function exportToCSV<T>(headers: string[], rows: T[]): string {
+  if (rows.length === 0) {
+    return `${headers.join(',')}\n`;
+  }
+
+  const headerRow = headers.join(',');
+  const dataRows = rows.map(row => {
+    const values = Object.values(row).map((value: any) => {
+      if (typeof value === 'object') {
+        return `"${JSON.stringify(value).replace(/"/g, '""')}"`;
+      }
+      return `"${String(value).replace(/"/g, '""')}"`;
+    });
+    return values.join(',');
+  });
+
+  return `${headerRow}\n${dataRows.join('\n')}`;
+}
+
+export function exportEvents(tenantId: string, options: ExportOptions = { format: 'json' }): any {
+  const { format, limit = 1000 } = options;
+  const events = getDashboardsByTenant(tenantId, limit);
+
+  if (format === 'json') {
+    return events;
+  } else if (format === 'csv') {
+    const headers = events.length > 0 ? Object.keys(events[0]) : [];
+    return exportToCSV(headers as string[], events);
+  } else {
+    throw new Error('Unsupported export format');
+  }
+}
+
+export function exportDashboards(tenantId: string, format: 'json' | 'csv' = 'json'): any {
+  const dashboards = getDashboardsByTenant(tenantId);
+
+  if (format === 'json') {
+    return dashboards;
+  } else if (format === 'csv') {
+    const headers = dashboards.length > 0 ? Object.keys(dashboards[0]) : [];
+    return exportToCSV(headers as string[], dashboards);
+  } else {
+    throw new Error('Unsupported export format');
+  }
+}
+
+export function exportQueryResults(tenantId: string, format: 'json' | 'csv' = 'json', filters: QueryFilters = {}): any {
+  const count = countEvents(tenantId, filters);
+  const events = getDashboardsByTenant(tenantId, 1000);
+
+  if (format === 'json') {
+    return { count, events };
+  } else if (format === 'csv') {
+    if (events.length === 0) {
+      return 'id,tenant_id,name,properties,timestamp,user_id,session_id\n';
+    }
+
+    const headers = Object.keys(events[0]);
+    const dataRows = events.map(event => {
+      const values = Object.values(event).map(value => {
+        if (typeof value === 'object') {
+          return `"${JSON.stringify(value).replace(/"/g, '""')}"`;
+        }
+        return `"${String(value).replace(/"/g, '""')}"`;
+      });
+      return `${count},${values.join(',')}`;
+    });
+
+    const headerRow = headers.join(',');
+    return `${headerRow}\n${dataRows.join('\n')}`;
+  } else {
+    throw new Error('Unsupported export format');
+  }
+}
+
+export default exportEvents;
