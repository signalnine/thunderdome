+import express, { Application, Request, Response, NextFunction } from 'express';
+import { authMiddleware, AuthRequest, AuthRequest as AuthRequestInterface } from './middleware';
+import { registerUser, getUserById, updateRole as updateUserRole } from './users';
+import { ingestEvent, ingestBatchEvents } from './events';
+import { countEvents, queryTimeseries, queryBreakdown } from './query';
+import { createDashboard, getDashboard, getDashboardsByTenant, deleteDashboard } from './dashboards';
+import { _exportEvents as exportEvents, _exportDashboards as exportDashboards, _exportQueryResults as exportQueryResults } from './export';
+import { errorHandler } from './error-handler';
+import { getDB } from './db';
+
+const _express = require('express');
+const _jsonwebtoken = require('jsonwebtoken');
+
+const _DB = getDB();
+const app = _express();
+
+app.use(_express.json());
+
+app.post('/api/register', (req: AuthRequestInterface, res: Response) => {
+  const { email, password, tenantId } = req.body;
+  if (!email || !password || !tenantId) {
+    return res.status(400).json({ error: 'Missing required fields', code: 'BAD_REQUEST' });
+  }
+
+  try {
+    const user = registerUser({ email, password, tenantId });
+    const token = generateJWT(app, user.id, user.tenantId, user.role);
+    res.json({ token, user });
+  } catch (error: any) {
+    if (error.message === 'Invalid credentials') {
+      res.status(400).json({ error: 'Invalid credentials', code: 'UNAUTHORIZED' });
+    } else {
+      res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+    }
+  }
+});
+
+app.post('/api/login', (req: AuthRequestInterface, res: Response) => {
+  const { email, password, tenantId } = req.body;
+  if (!email || !password || !tenantId) {
+    return res.status(400).json({ error: 'Missing required fields', code: 'BAD_REQUEST' });
+  }
+
+  try {
+    const user = registerUser({ email, password, tenantId });
+    const token = generateJWT(app, user.id, user.tenantId, user.role);
+    res.json({ token, user });
+  } catch (error: any) {
+    res.status(401).json({ error: error.message, code: 'UNAUTHORIZED' });
+  }
+});
+
+app.get('/api/me', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const user = getUserById(req.user!.id);
+    res.json(user);
+  } catch (error: any) {
+    res.status(404).json({ error: error.message, code: 'NOT_FOUND' });
+  }
+});
+
+app.post('/api/events', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const event = ingestEvent(req.body, req.user!.id, req.user!.tenantId);
+    res.json(event);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+  }
+});
+
+app.post('/api/events/batch', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const events = ingestBatchEvents(req.body as any[], { id: req.user!.id, tenantId: req.user!.tenantId });
+    res.json(events);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+  }
+});
+
+app.get('/api/events', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const filters: any = {};
+    if (req.query.eventName) filters.eventName = req.query.eventName as string;
+    if (req.query.sessionId) filters.sessionId = req.query.sessionId as string;
+
+    const query = 'SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ? ORDER BY timestamp DESC LIMIT ?';
+    const events = _DB.prepare(query).all(req.user!.tenantId, 100);
+    res.json(events);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+  }
+});
+
+app.get('/api/query/count', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const filters: any = {};
+    if (req.query.eventName) filters.eventName = req.query.eventName as string;
+    if (req.query.sessionId) filters.sessionId = req.query.sessionId as string;
+
+    const count = countEvents(req.user!.tenantId, filters);
+    res.json({ count });
+  } catch (error: any) {
+    res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+  }
+});
+
+app.get('/api/query/timeseries', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const eventName = req.query.eventName as string;
+    const startTime = req.query.startTime as string;
+    const endTime = req.query.endTime as string;
+    const bucketSize = (req.query.bucketSize as 'hour' | 'day') || 'hour';
+
+    const timeseries = queryTimeseries(req.user!.tenantId, eventName, startTime, endTime, bucketSize);
+    res.json(timeseries);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+  }
+});
+
+app.get('/api/query/breakdown', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const eventName = req.query.eventName as string;
+    const propertyKey = req.query.propertyKey as string;
+    if (!propertyKey) {
+      return res.status(400).json({ error: 'Property key required', code: 'BAD_REQUEST' });
+    }
+
+    const breakdown = queryBreakdown(req.user!.tenantId, eventName);
+    res.json(breakdown);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+  }
+});
+
+app.post('/api/dashboards', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const { name } = req.body;
+    if (!name) {
+      return res.status(400).json({ error: 'Name is required', code: 'BAD_REQUEST' });
+    }
+
+    const dashboard = createDashboard(name, req.user!.tenantId, req.user!.id);
+    res.json(dashboard);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+  }
+});
+
+app.get('/api/dashboards', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const dashboards = getDashboardsByTenant(req.user!.tenantId);
+    res.json(dashboards);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+  }
+});
+
+app.get('/api/dashboards/:id', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const dashboard = getDashboard(req.params.id);
+    res.json(dashboard);
+  } catch (error: any) {
+    res.status(404).json({ error: error.message, code: 'NOT_FOUND' });
+  }
+});
+
+app.delete('/api/dashboards/:id', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    deleteDashboard(req.params.id);
+    res.json({ message: 'Dashboard deleted successfully' });
+  } catch (error: any) {
+    res.status(404).json({ error: error.message, code: 'NOT_FOUND' });
+  }
+});
+
+app.get('/api/users/role/:userId', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const user = getUserById(req.params.userId);
+    res.json(user);
+  } catch (error: any) {
+    res.status(404).json({ error: error.message, code: 'NOT_FOUND' });
+  }
+});
+
+app.put('/api/users/:userId/role', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const { role } = req.body;
+    if (!['admin', 'editor', 'viewer'].includes(role)) {
+      return res.status(400).json({ error: 'Invalid role', code: 'BAD_REQUEST' });
+    }
+
+    if (req.user!.role !== 'admin') {
+      return res.status(403).json({ error: 'Access denied: only admins can change roles', code: 'FORBIDDEN' });
+    }
+
+    updateUserRole(req.params.userId, role);
+    res.json({ message: 'Role updated successfully', userId: req.params.userId, role });
+  } catch (error: any) {
+    res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+  }
+});
+
+app.get('/api/export/events', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const format = req.query.format as 'json' | 'csv' || 'json';
+    const limit = req.query.limit ? parseInt(req.query.limit as string) : undefined;
+
+    const options: any = { format, limit };
+    const result = exportEvents(req.user!.tenantId, options);
+
+    if (format === 'json') {
+      res.setHeader('Content-Type', 'application/json');
+      res.setHeader('Content-Disposition', 'attachment; filename=events.json');
+    } else {
+      res.setHeader('Content-Type', 'text/csv; charset=utf-8');
+      res.setHeader('Content-Disposition', 'attachment; filename=events.csv');
+    }
+
+    res.send(result);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+  }
+});
+
+app.get('/api/export/dashboards', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const format = req.query.format as 'json' | 'csv' || 'json';
+
+    const result = exportDashboards(req.user!.tenantId, format);
+
+    if (format === 'json') {
+      res.setHeader('Content-Type', 'application/json');
+      res.setHeader('Content-Disposition', 'attachment; filename=dashboards.json');
+    } else {
+      res.setHeader('Content-Type', 'text/csv; charset=utf-8');
+      res.setHeader('Content-Disposition', 'attachment; filename=dashboards.csv');
+    }
+
+    res.send(result);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+  }
+});
+
+app.get('/api/export/query', authMiddleware, (req: AuthRequestInterface, res: Response) => {
+  try {
+    const format = req.query.format as 'json' | 'csv' || 'json';
+    const limit = req.query.limit ? parseInt(req.query.limit as string) : undefined;
+
+    const filters: any = {};
+    if (req.query.eventName) filters.eventName = req.query.eventName as string;
+    if (req.query.sessionId) filters.sessionId = req.query.sessionId as string;
+
+    const result = exportQueryResults(req.user!.tenantId, format, filters, limit);
+
+    if (format === 'json') {
+      res.setHeader('Content-Type', 'application/json');
+      res.setHeader('Content-Disposition', 'attachment; filename=query-results.json');
+    } else {
+      res.setHeader('Content-Type', 'text/csv; charset=utf-8');
+      res.setHeader('Content-Disposition', 'attachment; filename=query-results.csv');
+    }
+
+    res.send(result);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message, code: 'BAD_REQUEST' });
+  }
+});
+
+app.use((error: Error, req: AuthRequestInterface, res: Response, next: NextFunction) => {
+  console.error('Unhandled error:', error);
+  res.status(500).json({ error: 'Internal server error', code: 'INTERNAL_ERROR' });
+});
+
+export const generateJWT = (appInstance: Application, userId: string, tenantId: string, role?: string): string => {
+  const tokenPayload: any = {
+    sub: userId,
+    tid: tenantId,
+    iat: Math.floor(Date.now() / 1000),
+    exp: Math.floor(Date.now() / 1000) + (86400 * 30),
+  };
+  if (role) {
+    tokenPayload.role = role;
+  }
+  const JWT_SECRET = process.env.JWT_SECRET || 'dev-secret-change-in-production';
+  return _jsonwebtoken.sign(tokenPayload, JWT_SECRET);
+};
+
+export { generateJWT as generateToken };
+
+export function createApp(): Application {
+  return app;
+}
+
+export default app;
