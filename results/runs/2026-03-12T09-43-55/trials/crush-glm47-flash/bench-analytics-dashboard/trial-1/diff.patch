+import { getDB as getDBImport } from './db';
+
+const _DB = getDBImport();
+
+export interface QueryFilters {
+  eventName?: string;
+  propertyKey?: string;
+  propertyValue?: string;
+  startDate?: string;
+  endDate?: string;
+  sessionId?: string;
+}
+
+export interface CountResult {
+  count: number;
+}
+
+export interface TimeseriesResult {
+  timestamp: string;
+  count: number;
+}
+
+export interface BreakdownResult {
+  propertyValue: string;
+  count: number;
+}
+
+export function countEvents(tenantId: string, filters: QueryFilters = {}): number {
+  let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+  const params: any[] = [tenantId];
+
+  if (filters.eventName) {
+    query += ' AND name = ?';
+    params.push(filters.eventName);
+  }
+
+  if (filters.propertyKey && filters.propertyValue) {
+    query += ` AND properties LIKE ?`;
+    params.push(`%"${filters.propertyKey}":"${filters.propertyValue}"%`);
+  }
+
+  if (filters.sessionId) {
+    query += ' AND session_id = ?';
+    params.push(filters.sessionId);
+  }
+
+  const result = _DB.prepare(query).get(...params) as { count: number };
+  return result.count;
+}
+
+export function queryTimeseries(
+  tenantId: string,
+  eventName?: string,
+  startTime?: string,
+  endTime?: string,
+  bucketSize: 'hour' | 'day' = 'hour',
+): TimeseriesResult[] {
+  let query = `
+    SELECT
+      datetime(timestamp, 'unixepoch', 'localtime', 'UTC') as timestamp,
+      COUNT(*) as count
+    FROM events
+    WHERE tenant_id = ?
+  `;
+  const params: any[] = [tenantId];
+
+  if (eventName) {
+    query += ' AND name = ?';
+    params.push(eventName);
+  }
+
+  if (startTime) {
+    query += ' AND timestamp >= ?';
+    params.push(startTime);
+  }
+
+  if (endTime) {
+    query += ' AND timestamp <= ?';
+    params.push(endTime);
+  }
+
+  query += ' GROUP BY ';
+
+  switch (bucketSize) {
+    case 'hour':
+      query += 'timestamp';
+      break;
+    case 'day':
+      query += "strftime('%Y-%m-%d', timestamp)";
+      break;
+  }
+
+  query += ' ORDER BY timestamp ASC';
+
+  return _DB.prepare(query).all(...params) as TimeseriesResult[];
+}
+
+export function queryBreakdown(tenantId: string, eventName?: string): BreakdownResult[] {
+  let query = `
+    SELECT
+      properties,
+      COUNT(*) as count
+    FROM events
+    WHERE tenant_id = ?
+  `;
+
+  if (eventName) {
+    query += ' AND name = ?';
+  }
+
+  query += ' GROUP BY properties ORDER BY count DESC LIMIT 50';
+
+  try {
+    if (eventName) {
+      const stmt = _DB.prepare(query).bind(tenantId, eventName);
+      const results = stmt.all() as { properties: string; count: number }[];
+
+      if (results && results.length > 0) {
+        return results.map((r) => ({
+          propertyValue: r.properties,
+          count: r.count,
+        }));
+      }
+    } else {
+      const results = _DB.prepare(query).bind(tenantId).all() as { properties: string; count: number }[];
+      if (results && results.length > 0) {
+        return results.map((r) => ({
+          propertyValue: r.properties,
+          count: r.count,
+        }));
+      }
+    }
+  } catch {
+    return [];
+  }
+
+  return [];
+}
+
+export function getEventsForQuery(tenantId: string, filters: QueryFilters = {}, limit = 1000): any[] {
+  return getDashboardsByTenant(tenantId, limit);
+}
+
+export default countEvents;
+
+export function getDashboardsByTenant(tenantId: string, limit = 1000): any[] {
+  return _DB.prepare('SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ? ORDER BY timestamp DESC LIMIT ?').all(tenantId, limit);
+}
+
+export function getEventsForQuery(tenantId: string, filters: QueryFilters = {}, limit = 1000): any[] {
+  return getDashboardsByTenant(tenantId, limit);
+}
