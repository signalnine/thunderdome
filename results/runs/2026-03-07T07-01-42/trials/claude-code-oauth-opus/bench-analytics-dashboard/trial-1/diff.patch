@@ -0,0 +1,51 @@
+import { Request } from 'express';
+
+export interface User {
+  id: string;
+  email: string;
+  password_hash: string;
+  tenant_id: string;
+  role: 'admin' | 'viewer' | 'editor';
+  created_at: string;
+}
+
+export interface AnalyticsEvent {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+export interface Dashboard {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Widget {
+  id: string;
+  dashboard_id: string;
+  type: 'counter' | 'timeseries' | 'breakdown' | 'funnel';
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+export interface JwtPayload {
+  userId: string;
+  tenantId: string;
+  role: string;
+}
+
+export interface AuthenticatedRequest extends Request {
+  user?: JwtPayload;
+}
