@@ -0,0 +1,119 @@
+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+import { AuthenticatedRequest, Dashboard } from '../types.js';
+import { authenticateToken } from '../middleware/auth.js';
+
+export function createDashboardRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Create dashboard
+  router.post('/', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: 'Dashboard name is required' });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const ownerId = req.user!.userId;
+    const dashConfig = config ? JSON.stringify(config) : '{}';
+    const now = new Date().toISOString();
+
+    db.prepare(
+      'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, ownerId, dashConfig, now, now);
+
+    res.status(201).json({
+      id,
+      tenant_id: tenantId,
+      name,
+      owner_id: ownerId,
+      config: config || {},
+      created_at: now,
+      updated_at: now,
+    });
+  });
+
+  // List dashboards for tenant
+  router.get('/', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?').all(tenantId) as Dashboard[];
+
+    res.json({
+      dashboards: dashboards.map(d => ({
+        ...d,
+        config: JSON.parse(d.config),
+      })),
+    });
+  });
+
+  // Get single dashboard
+  router.get('/:id', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(req.params.id, tenantId) as Dashboard | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    res.json({
+      ...dashboard,
+      config: JSON.parse(dashboard.config),
+    });
+  });
+
+  // Update dashboard
+  router.put('/:id', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { name, config } = req.body;
+
+    const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(req.params.id, tenantId) as Dashboard | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const updatedName = name || existing.name;
+    const updatedConfig = config !== undefined ? JSON.stringify(config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare('UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?')
+      .run(updatedName, updatedConfig, now, req.params.id);
+
+    res.json({
+      id: req.params.id,
+      tenant_id: tenantId,
+      name: updatedName,
+      owner_id: existing.owner_id,
+      config: JSON.parse(updatedConfig),
+      created_at: existing.created_at,
+      updated_at: now,
+    });
+  });
+
+  // Delete dashboard
+  router.delete('/:id', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+
+    const existing = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(req.params.id, tenantId) as Dashboard | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    db.prepare('DELETE FROM dashboards WHERE id = ?').run(req.params.id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
