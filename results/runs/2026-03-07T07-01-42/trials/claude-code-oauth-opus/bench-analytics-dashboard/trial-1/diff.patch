+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from './app.js';
+import { createDatabase } from './database.js';
+import type { Application } from 'express';
+import type Database from 'better-sqlite3';
+
+let app: Application;
+let db: Database.Database;
+
+beforeEach(() => {
+  db = createDatabase();
+  app = createApp(db);
+});
+
+describe('Health', () => {
+  it('GET /api/health returns ok', async () => {
+    const res = await request(app).get('/api/health');
+    expect(res.status).toBe(200);
+    expect(res.body.status).toBe('ok');
+  });
+});
+
+describe('User Management', () => {
+  it('registers a user', async () => {
+    const res = await request(app)
+      .post('/api/users/register')
+      .send({ email: 'test@example.com', password: 'pass123', tenant_id: 'tenant1' });
+    expect(res.status).toBe(201);
+    expect(res.body.email).toBe('test@example.com');
+    expect(res.body.token).toBeDefined();
+    expect(res.body.role).toBe('viewer');
+  });
+
+  it('rejects duplicate email', async () => {
+    await request(app)
+      .post('/api/users/register')
+      .send({ email: 'test@example.com', password: 'pass123', tenant_id: 'tenant1' });
+    const res = await request(app)
+      .post('/api/users/register')
+      .send({ email: 'test@example.com', password: 'pass456', tenant_id: 'tenant1' });
+    expect(res.status).toBe(409);
+  });
+
+  it('logs in a user', async () => {
+    await request(app)
+      .post('/api/users/register')
+      .send({ email: 'test@example.com', password: 'pass123', tenant_id: 'tenant1' });
+    const res = await request(app)
+      .post('/api/users/login')
+      .send({ email: 'test@example.com', password: 'pass123' });
+    expect(res.status).toBe(200);
+    expect(res.body.token).toBeDefined();
+  });
+
+  it('rejects wrong password', async () => {
+    await request(app)
+      .post('/api/users/register')
+      .send({ email: 'test@example.com', password: 'pass123', tenant_id: 'tenant1' });
+    const res = await request(app)
+      .post('/api/users/login')
+      .send({ email: 'test@example.com', password: 'wrong' });
+    expect(res.status).toBe(401);
+  });
+
+  it('returns 401 for unauthenticated profile access', async () => {
+    const res = await request(app).get('/api/users/me');
+    expect(res.status).toBe(401);
+  });
+
+  it('returns user profile', async () => {
+    const reg = await request(app)
+      .post('/api/users/register')
+      .send({ email: 'test@example.com', password: 'pass123', tenant_id: 'tenant1' });
+    const res = await request(app)
+      .get('/api/users/me')
+      .set('Authorization', `Bearer ${reg.body.token}`);
+    expect(res.status).toBe(200);
+    expect(res.body.email).toBe('test@example.com');
+  });
+
+  it('admin can change user role', async () => {
+    const admin = await request(app)
+      .post('/api/users/register')
+      .send({ email: 'admin@example.com', password: 'pass123', tenant_id: 'tenant1', role: 'admin' });
+    const viewer = await request(app)
+      .post('/api/users/register')
+      .send({ email: 'viewer@example.com', password: 'pass123', tenant_id: 'tenant1' });
+
+    const res = await request(app)
+      .put(`/api/users/${viewer.body.id}/role`)
+      .set('Authorization', `Bearer ${admin.body.token}`)
+      .send({ role: 'editor' });
+    expect(res.status).toBe(200);
+    expect(res.body.role).toBe('editor');
+  });
+
+  it('non-admin cannot change user role', async () => {
+    const viewer = await request(app)
+      .post('/api/users/register')
+      .send({ email: 'viewer@example.com', password: 'pass123', tenant_id: 'tenant1' });
+    const other = await request(app)
+      .post('/api/users/register')
+      .send({ email: 'other@example.com', password: 'pass123', tenant_id: 'tenant1' });
+
+    const res = await request(app)
+      .put(`/api/users/${other.body.id}/role`)
+      .set('Authorization', `Bearer ${viewer.body.token}`)
+      .send({ role: 'editor' });
+    expect(res.status).toBe(403);
+  });
+});
+
+async function registerAndLogin(appInstance: Application, email: string, tenantId: string, role = 'viewer') {
+  const res = await request(appInstance)
+    .post('/api/users/register')
+    .send({ email, password: 'pass123', tenant_id: tenantId, role });
+  return res.body.token as string;
+}
+
+describe('Event Ingestion', () => {
+  it('ingests a single event', async () => {
+    const token = await registerAndLogin(app, 'test@example.com', 'tenant1');
+    const res = await request(app)
+      .post('/api/events')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'page_view', properties: { url: '/home' } });
+    expect(res.status).toBe(201);
+    expect(res.body.name).toBe('page_view');
+  });
+
+  it('ingests batch events', async () => {
+    const token = await registerAndLogin(app, 'test@example.com', 'tenant1');
+    const res = await request(app)
+      .post('/api/events/batch')
+      .set('Authorization', `Bearer ${token}`)
+      .send({
+        events: [
+          { name: 'page_view', properties: { url: '/home' } },
+          { name: 'click', properties: { button: 'signup' } },
+        ],
+      });
+    expect(res.status).toBe(201);
+    expect(res.body.inserted).toBe(2);
+  });
+
+  it('returns 401 without auth', async () => {
+    const res = await request(app)
+      .post('/api/events')
+      .send({ name: 'page_view' });
+    expect(res.status).toBe(401);
+  });
+});
+
+describe('Query Engine', () => {
+  let token: string;
+
+  beforeEach(async () => {
+    token = await registerAndLogin(app, 'test@example.com', 'tenant1');
+    await request(app)
+      .post('/api/events/batch')
+      .set('Authorization', `Bearer ${token}`)
+      .send({
+        events: [
+          { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-01T10:00:00Z' },
+          { name: 'page_view', properties: { url: '/about' }, timestamp: '2024-01-01T14:00:00Z' },
+          { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-02T10:00:00Z' },
+          { name: 'click', properties: { button: 'signup' }, timestamp: '2024-01-01T12:00:00Z' },
+        ],
+      });
+  });
+
+  it('counts events', async () => {
+    const res = await request(app)
+      .post('/api/queries/count')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ event_name: 'page_view' });
+    expect(res.status).toBe(200);
+    expect(res.body.count).toBe(3);
+  });
+
+  it('counts events with date filter', async () => {
+    const res = await request(app)
+      .post('/api/queries/count')
+      .set('Authorization', `Bearer ${token}`)
+      .send({
+        event_name: 'page_view',
+        start_date: '2024-01-01T00:00:00Z',
+        end_date: '2024-01-01T23:59:59Z',
+      });
+    expect(res.status).toBe(200);
+    expect(res.body.count).toBe(2);
+  });
+
+  it('returns timeseries data', async () => {
+    const res = await request(app)
+      .post('/api/queries/timeseries')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ event_name: 'page_view', interval: 'day' });
+    expect(res.status).toBe(200);
+    expect(res.body.data.length).toBe(2);
+  });
+
+  it('returns breakdown data', async () => {
+    const res = await request(app)
+      .post('/api/queries/breakdown')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ event_name: 'page_view', property: 'url' });
+    expect(res.status).toBe(200);
+    expect(res.body.data.length).toBe(2);
+  });
+
+  it('enforces tenant isolation in queries', async () => {
+    const otherToken = await registerAndLogin(app, 'other@example.com', 'tenant2');
+    const res = await request(app)
+      .post('/api/queries/count')
+      .set('Authorization', `Bearer ${otherToken}`)
+      .send({ event_name: 'page_view' });
+    expect(res.status).toBe(200);
+    expect(res.body.count).toBe(0);
+  });
+});
+
+describe('Dashboard CRUD', () => {
+  let token: string;
+
+  beforeEach(async () => {
+    token = await registerAndLogin(app, 'test@example.com', 'tenant1');
+  });
+
+  it('creates a dashboard', async () => {
+    const res = await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'My Dashboard', config: { theme: 'dark' } });
+    expect(res.status).toBe(201);
+    expect(res.body.name).toBe('My Dashboard');
+  });
+
+  it('lists dashboards', async () => {
+    await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Dashboard 1' });
+    await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Dashboard 2' });
+
+    const res = await request(app)
+      .get('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`);
+    expect(res.status).toBe(200);
+    expect(res.body.dashboards.length).toBe(2);
+  });
+
+  it('gets a single dashboard', async () => {
+    const created = await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'My Dashboard' });
+
+    const res = await request(app)
+      .get(`/api/dashboards/${created.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+    expect(res.status).toBe(200);
+    expect(res.body.name).toBe('My Dashboard');
+  });
+
+  it('updates a dashboard', async () => {
+    const created = await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'My Dashboard' });
+
+    const res = await request(app)
+      .put(`/api/dashboards/${created.body.id}`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Updated Dashboard' });
+    expect(res.status).toBe(200);
+    expect(res.body.name).toBe('Updated Dashboard');
+  });
+
+  it('deletes a dashboard', async () => {
+    const created = await request(app)
+      .post('/api/dashboards')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'My Dashboard' });
+
+    const res = await request(app)
+      .delete(`/api/dashboards/${created.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+    expect(res.status).toBe(204);
+
+    const get = await request(app)
+      .get(`/api/dashboards/${created.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
