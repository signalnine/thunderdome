@@ -0,0 +1,153 @@
+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { AuthenticatedRequest, AnalyticsEvent, Dashboard } from '../types.js';
+import { authenticateToken } from '../middleware/auth.js';
+
+function escapeCSVField(value: string): string {
+  if (value.includes(',') || value.includes('"') || value.includes('\n')) {
+    return `"${value.replace(/"/g, '""')}"`;
+  }
+  return value;
+}
+
+function eventsToCSV(events: AnalyticsEvent[]): string {
+  const headers = ['id', 'tenant_id', 'name', 'properties', 'timestamp', 'user_id', 'session_id'];
+  const rows = events.map(e =>
+    headers.map(h => escapeCSVField(String(e[h as keyof AnalyticsEvent] ?? ''))).join(',')
+  );
+  return [headers.join(','), ...rows].join('\n');
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get('/events/json', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: string[] = [tenantId];
+
+    if (event_name) {
+      sql += ' AND name = ?';
+      params.push(String(event_name));
+    }
+
+    if (start_date) {
+      sql += ' AND timestamp >= ?';
+      params.push(String(start_date));
+    }
+
+    if (end_date) {
+      sql += ' AND timestamp <= ?';
+      params.push(String(end_date));
+    }
+
+    sql += ' ORDER BY timestamp DESC';
+
+    const events = db.prepare(sql).all(...params) as AnalyticsEvent[];
+    const parsed = events.map(e => ({
+      ...e,
+      properties: JSON.parse(e.properties),
+    }));
+
+    res.setHeader('Content-Type', 'application/json');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.json"');
+    res.json({ events: parsed });
+  });
+
+  // Export events as CSV
+  router.get('/events/csv', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { event_name, start_date, end_date } = req.query;
+
+    let sql = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: string[] = [tenantId];
+
+    if (event_name) {
+      sql += ' AND name = ?';
+      params.push(String(event_name));
+    }
+
+    if (start_date) {
+      sql += ' AND timestamp >= ?';
+      params.push(String(start_date));
+    }
+
+    if (end_date) {
+      sql += ' AND timestamp <= ?';
+      params.push(String(end_date));
+    }
+
+    sql += ' ORDER BY timestamp DESC';
+
+    const events = db.prepare(sql).all(...params) as AnalyticsEvent[];
+    const csv = eventsToCSV(events);
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+    res.send(csv);
+  });
+
+  // Export dashboard as JSON
+  router.get('/dashboards/:id/json', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(req.params.id, tenantId) as Dashboard | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?')
+      .all(req.params.id) as Record<string, unknown>[];
+
+    res.setHeader('Content-Type', 'application/json');
+    res.setHeader('Content-Disposition', `attachment; filename="dashboard-${dashboard.id}.json"`);
+    res.json({
+      dashboard: {
+        ...dashboard,
+        config: JSON.parse(dashboard.config),
+      },
+      widgets: widgets.map(w => ({
+        ...w,
+        config: typeof w.config === 'string' ? JSON.parse(w.config) : w.config,
+      })),
+    });
+  });
+
+  // Export dashboard as CSV
+  router.get('/dashboards/:id/csv', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(req.params.id, tenantId) as Dashboard | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?')
+      .all(req.params.id) as Record<string, unknown>[];
+
+    const headers = ['id', 'dashboard_id', 'type', 'config', 'position_x', 'position_y', 'width', 'height'];
+    const rows = widgets.map(w =>
+      headers.map(h => escapeCSVField(String(w[h] ?? ''))).join(',')
+    );
+    const csv = [
+      `# Dashboard: ${escapeCSVField(dashboard.name)}`,
+      `# ID: ${dashboard.id}`,
+      '',
+      headers.join(','),
+      ...rows,
+    ].join('\n');
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', `attachment; filename="dashboard-${dashboard.id}.csv"`);
+    res.send(csv);
+  });
+
+  return router;
+}
