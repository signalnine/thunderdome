 FROM dashboards WHERE id = ?').run(req.params.id);\n\n    res.status(204).send();\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1391,"cache_read_input_tokens":26805,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1391},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5d52e529-f10a-42d7-be12-ca878a07e7c1","uuid":"ed166bff-ead7-4c99-9ba7-5e2358a5f641"}
