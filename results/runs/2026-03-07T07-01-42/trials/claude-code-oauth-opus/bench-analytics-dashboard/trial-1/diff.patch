+++ b/src/routes/queries.ts
@@ -0,0 +1,151 @@
+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { AuthenticatedRequest } from '../types.js';
+import { authenticateToken } from '../middleware/auth.js';
+
+interface CountResult {
+  count: number;
+}
+
+interface TimeseriesRow {
+  period: string;
+  count: number;
+}
+
+interface BreakdownRow {
+  value: string | null;
+  count: number;
+}
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post('/count', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const { event_name, start_date, end_date, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    let sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+    const params: (string | number)[] = [tenantId];
+
+    if (event_name) {
+      sql += ' AND name = ?';
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += ' AND timestamp >= ?';
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += ' AND timestamp <= ?';
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ` AND json_extract(properties, ?) = ?`;
+        params.push(`$.${key}`, String(value));
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as CountResult;
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post('/timeseries', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const { event_name, start_date, end_date, interval, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    let dateFormat: string;
+    switch (interval) {
+      case 'hour':
+        dateFormat = '%Y-%m-%dT%H:00:00';
+        break;
+      case 'month':
+        dateFormat = '%Y-%m-01';
+        break;
+      case 'week':
+        dateFormat = '%Y-%W';
+        break;
+      default:
+        dateFormat = '%Y-%m-%d';
+        break;
+    }
+
+    let sql = `SELECT strftime('${dateFormat}', timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: (string | number)[] = [tenantId];
+
+    if (event_name) {
+      sql += ' AND name = ?';
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += ' AND timestamp >= ?';
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += ' AND timestamp <= ?';
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ` AND json_extract(properties, ?) = ?`;
+        params.push(`$.${key}`, String(value));
+      }
+    }
+
+    sql += ' GROUP BY period ORDER BY period ASC';
+
+    const results = db.prepare(sql).all(...params) as TimeseriesRow[];
+    res.json({ data: results });
+  });
+
+  // Breakdown query
+  router.post('/breakdown', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const { event_name, property, start_date, end_date, filters } = req.body;
+    const tenantId = req.user!.tenantId;
+
+    if (!property) {
+      res.status(400).json({ error: 'property is required for breakdown queries' });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: (string | number)[] = [`$.${property}`, tenantId];
+
+    if (event_name) {
+      sql += ' AND name = ?';
+      params.push(event_name);
+    }
+
+    if (start_date) {
+      sql += ' AND timestamp >= ?';
+      params.push(start_date);
+    }
+
+    if (end_date) {
+      sql += ' AND timestamp <= ?';
+      params.push(end_date);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ` AND json_extract(properties, ?) = ?`;
+        params.push(`$.${key}`, String(value));
+      }
+    }
+
+    sql += ' GROUP BY value ORDER BY count DESC';
+
+    const results = db.prepare(sql).all(...params) as BreakdownRow[];
+    res.json({ data: results });
+  });
+
+  return router;
+}
diff --git a/src/routes/users.ts b/src/routes/users.ts
new file mode 100644
index 0000000..2247efb
--- /dev/null
+++ b/src/routes/users.ts
@@ -0,0 +1,131 @@
+import { Router, Response } from 'express';
+import Database from 'better-sqlite3';
+import { createHash } from 'crypto';
+import jwt from 'jsonwebtoken';
+import { v4 as uuidv4 } from 'uuid';
+import { AuthenticatedRequest, User } from '../types.js';
+import { authenticateToken, requireRole, JWT_SECRET } from '../middleware/auth.js';
+
+function hashPassword(password: string): string {
+  return createHash('sha256').update(password).digest('hex');
+}
+
+export function createUserRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Register
+  router.post('/register', (req: AuthenticatedRequest, res: Response): void => {
+    const { email, password, tenant_id, role } = req.body;
+
+    if (!email || !password || !tenant_id) {
+      res.status(400).json({ error: 'email, password, and tenant_id are required' });
+      return;
+    }
+
+    const existing = db.prepare('SELECT id FROM users WHERE email = ?').get(email);
+    if (existing) {
+      res.status(409).json({ error: 'Email already registered' });
+      return;
+    }
+
+    const id = uuidv4();
+    const password_hash = hashPassword(password);
+    const userRole = role && ['admin', 'viewer', 'editor'].includes(role) ? role : 'viewer';
+
+    db.prepare(
+      'INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)'
+    ).run(id, email, password_hash, tenant_id, userRole);
+
+    const token = jwt.sign(
+      { userId: id, tenantId: tenant_id, role: userRole },
+      JWT_SECRET,
+      { expiresIn: '24h' }
+    );
+
+    res.status(201).json({
+      id,
+      email,
+      tenant_id,
+      role: userRole,
+      token,
+    });
+  });
+
+  // Login
+  router.post('/login', (req: AuthenticatedRequest, res: Response): void => {
+    const { email, password } = req.body;
+
+    if (!email || !password) {
+      res.status(400).json({ error: 'email and password are required' });
+      return;
+    }
+
+    const user = db.prepare('SELECT * FROM users WHERE email = ?').get(email) as User | undefined;
+
+    if (!user || user.password_hash !== hashPassword(password)) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    const token = jwt.sign(
+      { userId: user.id, tenantId: user.tenant_id, role: user.role },
+      JWT_SECRET,
+      { expiresIn: '24h' }
+    );
+
+    res.json({
+      id: user.id,
+      email: user.email,
+      tenant_id: user.tenant_id,
+      role: user.role,
+      token,
+    });
+  });
+
+  // Get profile
+  router.get('/me', authenticateToken, (req: AuthenticatedRequest, res: Response): void => {
+    const user = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?')
+      .get(req.user!.userId) as Omit<User, 'password_hash'> | undefined;
+
+    if (!user) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+
+    res.json(user);
+  });
+
+  // Update user role (admin only)
+  router.put(
+    '/:userId/role',
+    authenticateToken,
+    requireRole('admin'),
+    (req: AuthenticatedRequest, res: Response): void => {
+      const { userId } = req.params;
+      const { role } = req.body;
+
+      if (!role || !['admin', 'viewer', 'editor'].includes(role)) {
+        res.status(400).json({ error: 'Valid role is required (admin, viewer, editor)' });
+        return;
+      }
+
+      const targetUser = db.prepare('SELECT * FROM users WHERE id = ?').get(userId) as User | undefined;
+
+      if (!targetUser) {
+        res.status(404).json({ error: 'User not found' });
+        return;
+      }
+
+      if (targetUser.tenant_id !== req.user!.tenantId) {
+        res.status(403).json({ error: 'Cannot modify users outside your tenant' });
+        return;
+      }
+
+      db.prepare('UPDATE users SET role = ? WHERE id = ?').run(role, userId);
+
+      res.json({ id: userId, role });
+    }
+  );
+
+  return router;
+}
