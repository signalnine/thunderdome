us();\n  });\n\n  it('should count events', async () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat');\n    catalog.createProduct('B', 2, 'cat');\n    await new Promise(r => setTimeout(r, 10));\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    await new Promise(r => setTimeout(r, 10));\n    await payment.processPayment(orderId, 50);\n    expect(analytics.getRevenue()).toBe(50);\n  });\n\n  it('should not count revenue from failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    await new Promise(r => setTimeout(r, 10));\n    await payment.processPayment(orderId, 50);\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cartService = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const cart1 = cartService.createCart('user1');\n    cartService.addItem(cart1, 'p1', 1);\n    await new Promise(r => setTimeout(r, 10));\n\n    const cart2 = cartService.createCart('user2');\n    cartService.addItem(cart2, 'p2', 1);\n    await new Promise(r => setTimeout(r, 10));\n\n    orders.createOrder('user1', cart1, 10);\n    await new Promise(r => setTimeout(r, 10));\n\n    // 1 order / 2 unique carts = 0.5\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should rank top products', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cartService = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const cart1 = cartService.createCart('user1');\n    cartService.addItem(cart1, 'p1', 3);\n    cartService.addItem(cart1, 'p2', 1);\n    await new Promise(r => setTimeout(r, 10));\n    orders.createOrder('user1', cart1, 40);\n    await new Promise(r => setTimeout(r, 10));\n\n    const top = analytics.getTopProducts(10);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(3);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(1);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n});\n\ndescribe('Integration: Full E2E Flow', () => {\n  it('should process a complete order flow', async () => {\n    const bus = new EventBus();\n\n    // Create all services\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cart = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999.99, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29.99, 'electronics');\n    await new Promise(r => setTimeout(r, 10));\n\n    // Set inventory\n    inventory.setStock(p1, 10);\n    inventory.setStock(p2, 50);\n    inventory.setLowStockThreshold(p1, 2);\n\n    // Create cart and add items\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, p1, 1);\n    cart.addItem(cartId, p2, 2);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Calculate price\n    const price1 = pricing.getPrice(p1);\n    const price2 = pricing.getPrice(p2);\n    const items = [\n      { productId: p1, quantity: 1, price: price1 },\n      { productId: p2, quantity: 2, price: price2 },\n    ];\n    const total = pricing.calculateTotal(items);\n    expect(total.subtotal).toBeCloseTo(1059.97, 2);\n    expect(total.tax).toBeCloseTo(105.997, 1);\n\n    // Reserve inventory\n    expect(inventory.reserve(p1, 1)).toBe(true);\n    expect(inventory.reserve(p2, 2)).toBe(true);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, total.total);\n    await new Promise(r => setTimeout(r, 10));\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const payResult = await payment.processPayment(orderId, total.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n    await new Promise(r => setTimeout(r, 50));\n\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.DELIVERED);\n\n    // Check notifications\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(3); // order_created + payment + status changes\n\n    // Check analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n    expect(analytics.getRevenue()).toBe(total.total);\n    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n\n    const topProducts = analytics.getTopProducts(5);\n    expect(topProducts.length).toBe(2);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":103,"cache_read_input_tokens":35016,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral