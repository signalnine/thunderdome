diff --git a/tests/services.test.ts b/tests/services.test.ts
new file mode 100644
index 0000000..9949482
--- /dev/null
+++ b/tests/services.test.ts
@@ -0,0 +1,614 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { EventBus } from '../src/bus.js';
+import {
+  createCatalogService,
+  createInventoryService,
+  createCartService,
+  createPricingService,
+  createOrderService,
+  createPaymentService,
+  createNotificationService,
+  createAnalyticsService,
+} from '../src/index.js';
+import { Events, OrderStatus, PaymentStatus } from '../src/types.js';
+
+describe('CatalogService', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('should create a product and return an id', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    expect(id).toBeTruthy();
+  });
+
+  it('should retrieve a product by id', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('Widget', 9.99, 'gadgets');
+    const product = catalog.getProduct(id);
+    expect(product).toEqual({ id, name: 'Widget', price: 9.99, category: 'gadgets' });
+  });
+
+  it('should return null for unknown product', () => {
+    const catalog = createCatalogService(bus);
+    expect(catalog.getProduct('nope')).toBeNull();
+  });
+
+  it('should list all products', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('A', 1, 'cat1');
+    catalog.createProduct('B', 2, 'cat2');
+    expect(catalog.listProducts()).toHaveLength(2);
+  });
+
+  it('should filter products by category', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('A', 1, 'cat1');
+    catalog.createProduct('B', 2, 'cat2');
+    catalog.createProduct('C', 3, 'cat1');
+    expect(catalog.listProducts('cat1')).toHaveLength(2);
+  });
+
+  it('should search products by name', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('Blue Widget', 1, 'cat1');
+    catalog.createProduct('Red Gadget', 2, 'cat2');
+    const results = catalog.searchProducts('widget');
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('Blue Widget');
+  });
+
+  it('should search products by category', () => {
+    const catalog = createCatalogService(bus);
+    catalog.createProduct('A', 1, 'electronics');
+    catalog.createProduct('B', 2, 'books');
+    const results = catalog.searchProducts('electro');
+    expect(results).toHaveLength(1);
+  });
+
+  it('should update a product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('A', 1, 'cat1');
+    catalog.updateProduct(id, { name: 'B', price: 2 });
+    const p = catalog.getProduct(id);
+    expect(p!.name).toBe('B');
+    expect(p!.price).toBe(2);
+    expect(p!.category).toBe('cat1');
+  });
+
+  it('should remove a product', () => {
+    const catalog = createCatalogService(bus);
+    const id = catalog.createProduct('A', 1, 'cat1');
+    expect(catalog.removeProduct(id)).toBe(true);
+    expect(catalog.getProduct(id)).toBeNull();
+    expect(catalog.removeProduct(id)).toBe(false);
+  });
+
+  it('should emit PRODUCT_CREATED event', async () => {
+    const catalog = createCatalogService(bus);
+    const events: unknown[] = [];
+    bus.on(Events.PRODUCT_CREATED, (p) => { events.push(p); });
+    catalog.createProduct('X', 5, 'cat');
+    // Allow async event to settle
+    await new Promise(r => setTimeout(r, 10));
+    expect(events).toHaveLength(1);
+  });
+});
+
+describe('InventoryService', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('should set and get stock', () => {
+    const inv = createInventoryService(bus);
+    inv.setStock('p1', 100);
+    expect(inv.getStock('p1')).toBe(100);
+  });
+
+  it('should return 0 for unknown product', () => {
+    const inv = createInventoryService(bus);
+    expect(inv.getStock('p1')).toBe(0);
+  });
+
+  it('should reserve stock', () => {
+    const inv = createInventoryService(bus);
+    inv.setStock('p1', 10);
+    expect(inv.reserve('p1', 5)).toBe(true);
+    expect(inv.reserve('p1', 6)).toBe(false);
+    expect(inv.reserve('p1', 5)).toBe(true);
+  });
+
+  it('should release reserved stock', () => {
+    const inv = createInventoryService(bus);
+    inv.setStock('p1', 10);
+    inv.reserve('p1', 8);
+    inv.release('p1', 3);
+    expect(inv.reserve('p1', 5)).toBe(true);
+  });
+
+  it('should emit low stock alert', async () => {
+    const inv = createInventoryService(bus);
+    const alerts: unknown[] = [];
+    bus.on(Events.LOW_STOCK_ALERT, (p) => { alerts.push(p); });
+
+    inv.setLowStockThreshold('p1', 5);
+    inv.setStock('p1', 3);
+    await new Promise(r => setTimeout(r, 10));
+    expect(alerts).toHaveLength(1);
+  });
+
+  it('should not emit alert when stock is above threshold', async () => {
+    const inv = createInventoryService(bus);
+    const alerts: unknown[] = [];
+    bus.on(Events.LOW_STOCK_ALERT, (p) => { alerts.push(p); });
+
+    inv.setLowStockThreshold('p1', 5);
+    inv.setStock('p1', 10);
+    await new Promise(r => setTimeout(r, 10));
+    expect(alerts).toHaveLength(0);
+  });
+});
+
+describe('CartService', () => {
+  let bus: EventBus;
+
+  beforeEach(() => {
+    bus = new EventBus();
+  });
+
+  it('should create a cart', () => {
+    const cart = createCartService(bus);
+    const id = cart.createCart('user1');
+    expect(id).toBeTruthy();
+    const c = cart.getCart(id);
+    expect(c).toEqual({ id, userId: 'user1', items: [] });
