ush({\n   273→          roomId: room.id,\n   274→          startTime: start,\n   275→          preferred: event.preferredRoom === room.id,\n   276→        });\n   277→      }\n   278→    }\n   279→\n   280→    // Sort: preferred room first, then earliest start, then smallest room\n   281→    const roomCapMap = new Map(rooms.map((r) => [r.id, r.capacity]));\n   282→    placements.sort((a, b) => {\n   283→      if (a.preferred !== b.preferred) return a.preferred ? -1 : 1;\n   284→      if (a.startTime !== b.startTime) return a.startTime - b.startTime;\n   285→      return (roomCapMap.get(a.roomId) ?? 0) - (roomCapMap.get(b.roomId) ?? 0);\n   286→    });\n   287→\n   288→    return placements;\n   289→  }\n   290→\n   291→  function placeEvent(eventId: string, roomId: string, startTime: number): void {\n   292→    const event = eventMap.get(eventId)!;\n   293→    const assignment: Assignment = {\n   294→      eventId,\n   295→      roomId,\n   296→      startTime,\n   297→      endTime: startTime + event.duration,\n   298→    };\n   299→    assignmentMap.set(eventId, assignment);\n   300→    const schedule = roomSchedules.get(roomId)!;\n   301→    schedule.push(assignment);\n   302→    schedule.sort((a, b) => a.startTime - b.startTime);\n   303→  }\n   304→\n   305→  function removeEvent(eventId: string): void {\n   306→    const assignment = assignmentMap.get(eventId);\n   307→    if (!assignment) return;\n   308→    assignmentMap.delete(eventId);\n   309→    const schedule = roomSchedules.get(assignment.roomId)!;\n   310→    const idx = schedule.findIndex((a) => a.eventId === eventId);\n   311→    if (idx !== -1) schedule.splice(idx, 1);\n   312→  }\n   313→\n   314→  // Schedule events in topological order, using backtracking for\n   315→  // events at the same prerequisite depth level.\n   316→  // Group events by their depth level.\n   317→  const depthLevels = new Map<number, string[]>();\n   318→  for (const id of topoOrder) {\n   319→    const d = depth.get(id)