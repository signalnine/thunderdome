+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+/**
+ * Detect cycles in the prerequisite graph using DFS.
+ * Throws if a cycle (including self-references) is found.
+ */
+function detectCycles(events: Event[]): void {
+  const eventIds = new Set(events.map((e) => e.id));
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const id of eventIds) color.set(id, WHITE);
+
+  const prereqMap = new Map<string, string[]>();
+  for (const event of events) {
+    const prereqs = (event.prerequisites ?? []).filter((p) => eventIds.has(p));
+    prereqMap.set(event.id, prereqs);
+  }
+
+  function dfs(node: string): void {
+    color.set(node, GRAY);
+    for (const dep of prereqMap.get(node) ?? []) {
+      const c = color.get(dep);
+      if (c === GRAY) {
+        throw new Error(`Prerequisite cycle detected involving event "${dep}"`);
+      }
+      if (c === WHITE) {
+        dfs(dep);
+      }
+    }
+    color.set(node, BLACK);
+  }
+
+  // Check self-references explicitly first
+  for (const event of events) {
+    if (event.prerequisites?.includes(event.id)) {
+      throw new Error(`Prerequisite cycle detected involving event "${event.id}"`);
+    }
+  }
+
+  for (const id of eventIds) {
+    if (color.get(id) === WHITE) {
+      dfs(id);
+    }
+  }
+}
+
+/**
+ * Topological sort using Kahn's algorithm.
+ * Returns event IDs in an order respecting prerequisites.
+ * Only considers prerequisites that reference events in the input set.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map((e) => e.id));
+  const inDegree = new Map<string, number>();
+  const adjList = new Map<string, string[]>();
+
+  for (const id of eventIds) {
+    inDegree.set(id, 0);
+    adjList.set(id, []);
+  }
+
+  for (const event of events) {
+    for (const prereq of event.prerequisites ?? []) {
+      if (eventIds.has(prereq)) {
+        adjList.get(prereq)!.push(event.id);
+        inDegree.set(event.id, (inDegree.get(event.id) ?? 0) + 1);
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const result: string[] = [];
+  while (queue.length > 0) {
+    const node = queue.shift()!;
+    result.push(node);
+    for (const neighbor of adjList.get(node) ?? []) {
+      const newDeg = (inDegree.get(neighbor) ?? 1) - 1;
+      inDegree.set(neighbor, newDeg);
+      if (newDeg === 0) queue.push(neighbor);
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Find the earliest start time for an event in a given room,
+ * considering room occupancy and prerequisite completion times.
+ */
+function findEarliestStart(
+  event: Event,
+  room: Room,
+  roomSchedules: Map<string, Assignment[]>,
+  assignmentMap: Map<string, Assignment>,
+  options: ScheduleOptions,
+  gap: number
+): number | null {
+  const attendees = event.attendees ?? 1;
+  if (attendees > room.capacity) return null;
+
+  // Earliest start based on prerequisites
+  let earliest = options.startTime;
+  for (const prereqId of event.prerequisites ?? []) {
+    const prereqAssignment = assignmentMap.get(prereqId);
+    if (prereqAssignment) {
+      earliest = Math.max(earliest, prereqAssignment.endTime + gap);
+    }
+    // If a prereq exists in the event list but isn't assigned, we still
+    // respect ordering — it might get scheduled later or be unscheduled.
+    // We handle this at a higher level.
+  }
+
+  const endLimit = options.endTime;
+  const duration = event.duration;
+
+  if (earliest + duration > endLimit) return null;
+
+  const roomAssignments = roomSchedules.get(room.id) ?? [];
+
+  // If room has no events, earliest is fine
+  if (roomAssignments.length === 0) {
+    return earliest;
+  }
+
+  // Room assignments are sorted by startTime. Find a slot.
+  // Try before the first event
+  if (earliest + duration + gap <= roomAssignments[0].startTime) {
+    return earliest;
+  }
+
+  // Try between existing events
+  for (let i = 0; i < roomAssignments.length; i++) {
+    const slotStart = Math.max(earliest, roomAssignments[i].endTime + gap);
+    const nextStart = i + 1 < roomAssignments.length
+      ? roomAssignments[i + 1].startTime
+      : endLimit + gap; // allow fitting at the end
+
+    if (slotStart + duration <= Math.min(nextStart - gap, endLimit) + gap) {
+      // Check: if there's a next event, we need slotStart + duration + gap <= nextStart
+      // If no next event, we just need slotStart + duration <= endLimit
+      if (i + 1 < roomAssignments.length) {
+        if (slotStart + duration + gap <= roomAssignments[i + 1].startTime) {
+          if (slotStart + duration <= endLimit) {
+            return slotStart;
+          }
+        }
+      } else {
+        if (slotStart + duration <= endLimit) {
+          return slotStart;
+        }
+      }
+    }
+  }
+
+  // Try after the last event
+  const lastEnd = roomAssignments[roomAssignments.length - 1].endTime;
+  const slotStart = Math.max(earliest, lastEnd + gap);
+  if (slotStart + duration <= endLimit) {
+    return slotStart;
+  }
+
+  return null;
+}
+
+/**
+ * Main scheduling function.
+ * Uses a multi-pass approach:
+ * 1. Greedy pass with multiple sort orderings to find a good baseline
+ * 2. Iterative improvement: try swapping/replacing events to fit more
+ */
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  detectCycles(events);
+
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  const gap = options.gap ?? 15;
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  const topoOrder = topologicalSort(events);
+
+  // Build prerequisite depth (longest chain to root)
+  const prereqDepth = new Map<string, number>();
+  for (const id of topoOrder) {
+    const event = eventMap.get(id)!;
+    let maxD = 0;
+    for (const prereqId of event.prerequisites ?? []) {
+      if (prereqDepth.has(prereqId)) {
+        maxD = Math.max(maxD, prereqDepth.get(prereqId)! + 1);
+      }
+    }
+    prereqDepth.set(id, maxD);
+  }
+
+  // Count direct dependents for each event
+  const dependentsCount = new Map<string, number>();
+  for (const event of events) {
+    dependentsCount.set(event.id, 0);
+  }
+  for (const event of events) {
+    for (const prereqId of event.prerequisites ?? []) {
+      if (dependentsCount.has(prereqId)) {
+        dependentsCount.set(prereqId, dependentsCount.get(prereqId)! + 1);
+      }
+    }
+  }
+
+  // Count total transitive dependents
+  const transitiveDeps = new Map<string, number>();
+  const reverseOrder = [...topoOrder].reverse();
+  for (const id of reverseOrder) {
+    let count = 0;
+    // Find all events that have this as a prerequisite
+    for (const event of events) {
+      if (event.prerequisites?.includes(id)) {
+        count += 1 + (transitiveDeps.get(event.id) ?? 0);
+      }
+    }
+    transitiveDeps.set(id, count);
+  }
+
+  const roomCapMap = new Map(rooms.map((r) => [r.id, r.capacity]));
+
+  // State management
+  class ScheduleState {
+    roomSchedules = new Map<string, Assignment[]>();
+    assignmentMap = new Map<string, Assignment>();
+
+    constructor() {
+      for (const room of rooms) {
+        this.roomSchedules.set(room.id, []);
+      }
+    }
+
+    clone(): ScheduleState {
+      const s = new ScheduleState();
+      for (const [roomId, assignments] of this.roomSchedules) {
+        s.roomSchedules.set(roomId, [...assignments]);
+      }
+      for (const [eventId, assignment] of this.assignmentMap) {
+        s.assignmentMap.set(eventId, { ...assignment });
+      }
+      return s;
+    }
+
+    prereqsSatisfied(event: Event): boolean {
+      for (const prereqId of event.prerequisites ?? []) {
+        if (eventMap.has(prereqId) && !this.assignmentMap.has(prereqId)) {
+          return false;
+        }
+      }
+      return true;
+    }
+
+    findEarliestStart(event: Event, room: Room): number | null {
+      return findEarliestStart(event, room, this.roomSchedules, this.assignmentMap, options, gap);
+    }
+
+    getPlacements(event: Event): Array<{ roomId: string; startTime: number }> {
+      const placements: Array<{ roomId: string; startTime: number; preferred: boolean }> = [];
+      for (const room of rooms) {
+        const start = this.findEarliestStart(event, room);
+        if (start !== null) {
+          placements.push({
+            roomId: room.id,
+            startTime: start,
+            preferred: event.preferredRoom === room.id,
+          });
+        }
+      }
+      placements.sort((a, b) => {
+        if (a.preferred !== b.preferred) return a.preferred ? -1 : 1;
+        if (a.startTime !== b.startTime) return a.startTime - b.startTime;
+        return (roomCapMap.get(a.roomId) ?? 0) - (roomCapMap.get(b.roomId) ?? 0);
+      });
+      return placements;
+    }
+
+    placeEvent(eventId: string, roomId: string, startTime: number): void {
+      const event = eventMap.get(eventId)!;
+      const assignment: Assignment = {
+        eventId,
+        roomId,
+        startTime,
+        endTime: startTime + event.duration,
+      };
+      this.assignmentMap.set(eventId, assignment);
+      const sched = this.roomSchedules.get(roomId)!;
+      sched.push(assignment);
+      sched.sort((a, b) => a.startTime - b.startTime);
+    }
+
+    removeEvent(eventId: string): void {
+      const assignment = this.assignmentMap.get(eventId);
+      if (!assignment) return;
+      this.assignmentMap.delete(eventId);
+      const sched = this.roomSchedules.get(assignment.roomId)!;
+      const idx = sched.findIndex((a) => a.eventId === eventId);
+      if (idx !== -1) sched.splice(idx, 1);
+    }
+  }
+
+  /**
+   * Run a greedy scheduling pass with the given event ordering.
+   * Returns the state after scheduling.
+   */
+  function greedyPass(orderedIds: string[]): ScheduleState {
+    const state = new ScheduleState();
+
+    // Process in topological layers to respect prerequisites
+    // Build layers from the ordered IDs
+    const scheduled = new Set<string>();
+    const pending = new Set(orderedIds);
+
+    // Keep iterating until no more events can be placed
+    let progress = true;
+    while (progress && pending.size > 0) {
+      progress = false;
+      for (const eventId of orderedIds) {
+        if (!pending.has(eventId)) continue;
+        const event = eventMap.get(eventId)!;
+        if (!state.prereqsSatisfied(event)) continue;
+
+        const placements = state.getPlacements(event);
+        if (placements.length > 0) {
+          state.placeEvent(eventId, placements[0].roomId, placements[0].startTime);
+          scheduled.add(eventId);
+          pending.delete(eventId);
+          progress = true;
+        }
+      }
+    }
+
+    return state;
+  }
+
+  // Generate multiple event orderings to try
+  function generateOrderings(): string[][] {
+    const orderings: string[][] = [];
+
+    // Ordering 1: by dependents count (most dependents first), then shortest
+    const order1 = [...topoOrder];
+    order1.sort((a, b) => {
+      const dA = prereqDepth.get(a) ?? 0;
+      const dB = prereqDepth.get(b) ?? 0;
+      if (dA !== dB) return dA - dB;
+      const depA = transitiveDeps.get(a) ?? 0;
+      const depB = transitiveDeps.get(b) ?? 0;
+      if (depA !== depB) return depB - depA;
+      return (eventMap.get(a)!.duration) - (eventMap.get(b)!.duration);
+    });
+    orderings.push(order1);
+
+    // Ordering 2: shortest duration first
+    const order2 = [...topoOrder];
+    order2.sort((a, b) => {
+      const dA = prereqDepth.get(a) ?? 0;
+      const dB = prereqDepth.get(b) ?? 0;
+      if (dA !== dB) return dA - dB;
+      return (eventMap.get(a)!.duration) - (eventMap.get(b)!.duration);
+    });
+    orderings.push(order2);
+
+    // Ordering 3: longest duration first
+    const order3 = [...topoOrder];
+    order3.sort((a, b) => {
+      const dA = prereqDepth.get(a) ?? 0;
+      const dB = prereqDepth.get(b) ?? 0;
+      if (dA !== dB) return dA - dB;
+      return (eventMap.get(b)!.duration) - (eventMap.get(a)!.duration);
+    });
+    orderings.push(order3);
+
+    // Ordering 4: fewest rooms that fit (most constrained by capacity first)
+    const order4 = [...topoOrder];
+    order4.sort((a, b) => {
+      const dA = prereqDepth.get(a) ?? 0;
+      const dB = prereqDepth.get(b) ?? 0;
+      if (dA !== dB) return dA - dB;
+      const attA = eventMap.get(a)!.attendees ?? 1;
+      const attB = eventMap.get(b)!.attendees ?? 1;
+      const fittingA = rooms.filter((r) => r.capacity >= attA).length;
+      const fittingB = rooms.filter((r) => r.capacity >= attB).length;
+      if (fittingA !== fittingB) return fittingA - fittingB;
+      return (eventMap.get(b)!.duration) - (eventMap.get(a)!.duration);
+    });
+    orderings.push(order4);
+
+    // Ordering 5: most attendees first
+    const order5 = [...topoOrder];
+    order5.sort((a, b) => {
+      const dA = prereqDepth.get(a) ?? 0;
+      const dB = prereqDepth.get(b) ?? 0;
+      if (dA !== dB) return dA - dB;
+      const attA = eventMap.get(a)!.attendees ?? 1;
+      const attB = eventMap.get(b)!.attendees ?? 1;
+      return attB - attA;
+    });
+    orderings.push(order5);
+
+    return orderings;
+  }
+
+  // Run all orderings and pick the best
+  const orderings = generateOrderings();
+  let bestState: ScheduleState | null = null;
+  let bestCount = -1;
+
+  for (const ordering of orderings) {
+    const state = greedyPass(ordering);
+    if (state.assignmentMap.size > bestCount) {
+      bestCount = state.assignmentMap.size;
+      bestState = state;
+    }
+    if (bestCount === events.length) break;
+  }
+
+  // Iterative improvement: try to schedule more events
+  if (bestState && bestCount < events.length) {
+    const unscheduledIds = events
+      .map((e) => e.id)
+      .filter((id) => !bestState!.assignmentMap.has(id));
+
+    for (const unschedId of unscheduledIds) {
+      const unschedEvent = eventMap.get(unschedId)!;
+
+      // Check if prerequisites are satisfied
+      if (!bestState.prereqsSatisfied(unschedEvent)) continue;
+
+      // Try placing directly first
+      const directPlacements = bestState.getPlacements(unschedEvent);
+      if (directPlacements.length > 0) {
+        bestState.placeEvent(unschedId, directPlacements[0].roomId, directPlacements[0].startTime);
+        bestCount++;
+        continue;
+      }
+
+      // Try removing one scheduled event to fit this + re-place the removed one
+      let improved = false;
+      const currentAssignments = [...bestState.assignmentMap.entries()];
+      for (const [scheduledId, scheduledAssignment] of currentAssignments) {
+        // Don't remove events with dependents that are scheduled
+        const scheduledEvent = eventMap.get(scheduledId)!;
+        let hasDependents = false;
+        for (const ev of events) {
+          if (ev.prerequisites?.includes(scheduledId) && bestState.assignmentMap.has(ev.id)) {
+            hasDependents = true;
+            break;
+          }
+        }
+        if (hasDependents) continue;
+
+        // Try removing scheduled event and placing unscheduled event
+        const savedAssignment = { ...scheduledAssignment };
+        bestState.removeEvent(scheduledId);
+
+        const placements = bestState.getPlacements(unschedEvent);
+        if (placements.length > 0) {
+          bestState.placeEvent(unschedId, placements[0].roomId, placements[0].startTime);
+
+          // Try to re-place the removed event
+          const rePlacements = bestState.getPlacements(scheduledEvent);
+          if (rePlacements.length > 0) {
+            bestState.placeEvent(scheduledId, rePlacements[0].roomId, rePlacements[0].startTime);
+            bestCount++;
+            improved = true;
+            break;
+          }
+
+          // Couldn't re-place, check if we gained (net zero, but might enable others)
+          bestState.removeEvent(unschedId);
+        }
+
+        // Restore the removed event
+        bestState.placeEvent(scheduledId, savedAssignment.roomId, savedAssignment.startTime);
+      }
+
+      if (improved) continue;
+
+      // Try removing one scheduled event to fit this (net swap, might enable others)
+      const currentAssignments2 = [...bestState.assignmentMap.entries()];
+      for (const [sId1] of currentAssignments2) {
+        let hasDep1 = false;
+        for (const ev of events) {
+          if (ev.prerequisites?.includes(sId1) && bestState.assignmentMap.has(ev.id)) {
+            hasDep1 = true;
+            break;
+          }
+        }
+        if (hasDep1) continue;
+
+        const saved1 = { ...bestState.assignmentMap.get(sId1)! };
+        bestState.removeEvent(sId1);
+
+        const p1 = bestState.getPlacements(unschedEvent);
+        if (p1.length > 0) {
+          bestState.placeEvent(unschedId, p1[0].roomId, p1[0].startTime);
+          const rp1 = bestState.getPlacements(eventMap.get(sId1)!);
+          if (rp1.length > 0) {
+            bestState.placeEvent(sId1, rp1[0].roomId, rp1[0].startTime);
+            bestCount++;
+            improved = true;
+          } else {
+            bestState.removeEvent(unschedId);
+          }
+        }
+
+        if (!improved) {
+          bestState.placeEvent(sId1, saved1.roomId, saved1.startTime);
+        }
+        if (improved) break;
+      }
+    }
+  }
+
+  if (!bestState) {
+    return { assignments: [], unscheduled: events.map((e) => e.id) };
+  }
+
+  const scheduledIds = new Set(bestState.assignmentMap.keys());
+  const unscheduled = events.map((e) => e.id).filter((id) => !scheduledIds.has(id));
+
+  return {
+    assignments: [...bestState.assignmentMap.values()],
+    unscheduled,
+  };
+}
