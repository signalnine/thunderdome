nts.map((e) => e.id));\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const id of eventIds) color.set(id, WHITE);\n\n  const prereqMap = new Map<string, string[]>();\n  for (const event of events) {\n    const prereqs = (event.prerequisites ?? []).filter((p) => eventIds.has(p));\n    prereqMap.set(event.id, prereqs);\n  }\n\n  function dfs(node: string): void {\n    color.set(node, GRAY);\n    for (const dep of prereqMap.get(node) ?? []) {\n      const c = color.get(dep);\n      if (c === GRAY) {\n        throw new Error(`Prerequisite cycle detected involving event \"${dep}\"`);\n      }\n      if (c === WHITE) {\n        dfs(dep);\n      }\n    }\n    color.set(node, BLACK);\n  }\n\n  // Check self-references explicitly first\n  for (const event of events) {\n    if (event.prerequisites?.includes(event.id)) {\n      throw new Error(`Prerequisite cycle detected involving event \"${event.id}\"`);\n    }\n  }\n\n  for (const id of eventIds) {\n    if (color.get(id) === WHITE) {\n      dfs(id);\n    }\n  }\n}\n\n/**\n * Topological sort using Kahn's algorithm.\n * Returns event IDs in an order respecting prerequisites.\n * Only considers prerequisites that reference events in the input set.\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventIds = new Set(events.map((e) => e.id));\n  const inDegree = new Map<string, number>();\n  const adjList = new Map<string, string[]>();\n\n  for (const id of eventIds) {\n    inDegree.set(id, 0);\n    adjList.set(id, []);\n  }\n\n  for (const event of events) {\n    for (const prereq of event.prerequisites ?? []) {\n      if (eventIds.has(prereq)) {\n        adjList.get(prereq)!.push(event.id);\n        inDegree.set(event.id, (inDegree.get(event.id) ?? 0) + 1);\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const result: string[] = [];\n  while (queue.length > 0) {\n    const node = queue.shift()!;\n    result.push(node);\n    for (const neighbor of adjList.get(node) ?? []) {\n      const newDeg = (inDegree.get(neighbor) ?? 1) - 1;\n      inDegree.set(neighbor, newDeg);\n      if (newDeg === 0) queue.push(neighbor);\n    }\n  }\n\n  return result;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * considering room occupancy and prerequisite completion times.\n */\nfunction findEarliestStart(\n  event: Event,\n  room: Room,\n  roomSchedules: Map<string, Assignment[]>,\n  assignmentMap: Map<string, Assignment>,\n  options: ScheduleOptions,\n  gap: number\n): number | null {\n  const attendees = event.attendees ?? 1;\n  if (attendees > room.capacity) return null;\n\n  // Earliest start based on prerequisites\n  let earliest = options.startTime;\n  for (const prereqId of event.prerequisites ?? []) {\n    const prereqAssignment = assignmentMap.get(prereqId);\n    if (prereqAssignment) {\n      earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n    }\n    // If a prereq exists in the event list but isn't assigned, we still\n    // respect ordering — it might get scheduled later or be unscheduled.\n    // We handle this at a higher level.\n  }\n\n  const endLimit = options.endTime;\n  const duration = event.duration;\n\n  if (earliest + duration > endLimit) return null;\n\n  const roomAssignments = roomSchedules.get(room.id) ?? [];\n\n  // If room has no events, earliest is fine\n  if (roomAssignments.length === 0) {\n    return earliest;\n  }\n\n  // Room assignments are sorted by startTime. Find a slot.\n  // Try before the first event\n  if (earliest + duration + gap <= roomAssignments[0].startTime) {\n    return earliest;\n  }\n\n  // Try between existing events\n  for (let i = 0; i < roomAssignments.length; i++) {\n    const slotStart = Math.max(earliest, roomAssignments[i].endTime + gap);\n    const nextStart = i + 1 < roomAssignments.length\n      ? roomAssignments[i + 1].startTime\n      : endLimit + gap; // allow fitting at the end\n\n    if (slotStart + duration <= Math.min(nextStart - gap, endLimit) + gap) {\n      // Check: if there's a next event, we need slotStart + duration + gap <= nextStart\n      // If no next event, we just need slotStart + duration <= endLimit\n      if (i + 1 < roomAssignments.length) {\n        if (slotStart + duration + gap <= roomAssignments[i + 1].startTime) {\n          if (slotStart + duration <= endLimit) {\n            return slotStart;\n          }\n        }\n      } else {\n        if (slotStart + duration <= endLimit) {\n          return slotStart;\n        }\n      }\n    }\n  }\n\n  // Try after the last event\n  const lastEnd = roomAssignments[roomAssignments.length - 1].endTime;\n  const slotStart = Math.max(earliest, lastEnd + gap);\n  if (slotStart + duration <= endLimit) {\n    return slotStart;\n  }\n\n  return null;\n}\n\n/**\n * Main scheduling function.\n */\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  // Validate and detect cycles\n  detectCycles(events);\n\n  const gap = options.gap ?? 15;\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  // Topological order\n  const topoOrder = topologicalSort(events);\n\n  // Build prerequisite depth (longest chain) for prioritization\n  const depth = new Map<string, number>();\n  for (const id of topoOrder) {\n    const event = eventMap.get(id)!;\n    let maxDepth = 0;\n    for (const prereqId of event.prerequisites ?? []) {\n      if (depth.has(prereqId)) {\n        maxDepth = Math.max(maxDepth, depth.get(prereqId)! + 1);\n      }\n    }\n    depth.set(id, maxDepth);\n  }\n\n  // Count how many events depend on each event (dependents count)\n  const dependentsCount = new Map<string, number>();\n  for (const event of events) {\n    dependentsCount.set(event.id, 0);\n  }\n  for (const event of events) {\n    for (const prereqId of event.prerequisites ?? []) {\n      if (dependentsCount.has(prereqId)) {\n        dependentsCount.set(prereqId, dependentsCount.get(prereqId)! + 1);\n      }\n    }\n  }\n\n  // Use backtracking with pruning for optimal scheduling\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) {\n    roomSchedules.set(room.id, []);\n  }\n\n  const assignmentMap = new Map<string, Assignment>();\n  const unscheduled: string[] = [];\n\n  // Check if all prerequisites of an event are assigned\n  function prereqsSatisfied(event: Event): boolean {\n    for (const prereqId of event.prerequisites ?? []) {\n      if (eventMap.has(prereqId) && !assignmentMap.has(prereqId)) {\n        return false;\n      }\n    }\n    return true;\n  }\n\n  // Get all possible placements for an event, sorted by preference\n  function getPlacements(event: Event): Array<{ roomId: string; startTime: number }> {\n    const placements: Array<{ roomId: string; startTime: number; preferred: boolean }> = [];\n\n    for (const room of rooms) {\n      const start = findEarliestStart(event, room, roomSchedules, assignmentMap, options, gap);\n      if (start !== null) {\n        placements.push({\n          roomId: room.id,\n          startTime: start,\n          preferred: event.preferredRoom === room.id,\n        });\n      }\n    }\n\n    // Sort: preferred room first, then earliest start, then smallest room\n    const roomCapMap = new Map(rooms.map((r) => [r.id, r.capacity]));\n    placements.sort((a, b) => {\n      if (a.preferred !== b.preferred) return a.preferred ? -1 : 1;\n      if (a.startTime !== b.startTime) return a.startTime - b.startTime;\n      return (roomCapMap.get(a.roomId) ?? 0) - (roomCapMap.get(b.roomId) ?? 0);\n    });\n\n    return placements;\n  }\n\n  function placeEvent(eventId: string, roomId: string, startTime: number): void {\n    const event = eventMap.get(eventId)!;\n    const assignment: Assignment = {\n      eventId,\n      roomId,\n      startTime,\n      endTime: startTime + event.duration,\n    };\n    assignmentMap.set(eventId, assignment);\n    const schedule = roomSchedules.get(roomId)!;\n    schedule.push(assignment);\n    schedule.sort((a, b) => a.startTime - b.startTime);\n  }\n\n  function removeEvent(eventId: string): void {\n    const assignment = assignmentMap.get(eventId);\n    if (!assignment) return;\n    assignmentMap.delete(eventId);\n    const schedule = roomSchedules.get(assignment.roomId)!;\n    const idx = schedule.findIndex((a) => a.eventId === eventId);\n    if (idx !== -1) schedule.splice(idx, 1);\n  }\n\n  // Schedule events in topological order, using backtracking for\n  // events at the same prerequisite depth level.\n  // Group events by their depth level.\n  const depthLevels = new Map<number, string[]>();\n  for (const id of topoOrder) {\n    const d = depth.get(id) ?? 0;\n    if (!depthLevels.has(d)) depthLevels.set(d, []);\n    depthLevels.get(d)!.push(id);\n  }\n\n  const maxDepth = Math.max(...[...depth.values()], 0);\n\n  // Process each depth level in order\n  for (let d = 0; d <= maxDepth; d++) {\n    const levelEvents = depthLevels.get(d) ?? [];\n    if (levelEvents.length === 0) continue;\n\n    // Sort events within a level: more dependents first, then larger attendees,\n    // then longer duration (harder to place events first)\n    levelEvents.sort((a, b) => {\n      const depA = dependentsCount.get(a) ?? 0;\n      const depB = dependentsCount.get(b) ?? 0;\n      if (depA !== depB) return depB - depA;\n\n      const attA = eventMap.get(a)!.attendees ?? 1;\n      const attB = eventMap.get(b)!.attendees ?? 1;\n      if (attA !== attB) return attB - attA;\n\n      const durA = eventMap.get(a)!.duration;\n      const durB = eventMap.get(b)!.duration;\n      return durB - durA;\n    });\n\n    // Try to schedule all events in this level using backtracking\n    scheduleLevel(levelEvents, 0);\n  }\n\n  /**\n   * Backtracking scheduler for a set of events at the same depth level.\n   * Returns the maximum number of events that can be placed.\n   */\n  function scheduleLevel(eventIds: string[], index: number): number {\n    if (index >= eventIds.length) return 0;\n\n    const eventId = eventIds[index];\n    const event = eventMap.get(eventId)!;\n\n    if (!prereqsSatisfied(event)) {\n      unscheduled.push(eventId);\n      return scheduleLevel(eventIds, index + 1);\n    }\n\n    const placements = getPlacements(event);\n\n    if (placements.length === 0) {\n      // Can't place this event, skip it\n      unscheduled.push(eventId);\n      return scheduleLevel(eventIds, index + 1);\n    }\n\n    // Try placing this event and see how many total we can schedule\n    let bestCount = -1;\n    let bestPlacement: { roomId: string; startTime: number } | null = null;\n\n    // Optimization: if only one placement, just use it\n    if (placements.length === 1) {\n      placeEvent(eventId, placements[0].roomId, placements[0].startTime);\n      const rest = scheduleLevel(eventIds, index + 1);\n      return 1 + rest;\n    }\n\n    // Try each placement, pick the one that maximizes total scheduled\n    // Limit backtracking to avoid exponential blowup\n    const maxTries = Math.min(placements.length, rooms.length <= 10 ? 6 : 3);\n\n    for (let i = 0; i < maxTries; i++) {\n      const placement = placements[i];\n      placeEvent(eventId, placement.roomId, placement.startTime);\n\n      // Count how many remaining events can be placed\n      const remaining = eventIds.slice(index + 1);\n      let count = 0;\n      const tempAssignments: Assignment[] = [];\n\n      for (const rid of remaining) {\n        const rev = eventMap.get(rid)!;\n        if (!prereqsSatisfied(rev)) continue;\n        const rPlacements = getPlacements(rev);\n        if (rPlacements.length > 0) {\n          count++;\n          // Tentatively place to get accurate count\n          placeEvent(rid, rPlacements[0].roomId, rPlacements[0].startTime);\n          tempAssignments.push(assignmentMap.get(rid)!);\n        }\n      }\n\n      // Remove tentative placements\n      for (const ta of tempAssignments) {\n        removeEvent(ta.eventId);\n      }\n\n      if (1 + count > bestCount) {\n        bestCount = 1 + count;\n        bestPlacement = placement;\n      }\n\n      removeEvent(eventId);\n\n      // If we can place all remaining events, no need to try more\n      if (count === eventIds.length - index - 1) break;\n    }\n\n    // Also consider skipping this event entirely\n    {\n      const remaining = eventIds.slice(index + 1);\n      let count = 0;\n      const tempAssignments: Assignment[] = [];\n\n      for (const rid of remaining) {\n        const rev = eventMap.get(rid)!;\n        if (!prereqsSatisfied(rev)) continue;\n        const rPlacements = getPlacements(rev);\n        if (rPlacements.length > 0) {\n          count++;\n          placeEvent(rid, rPlacements[0].roomId, rPlacements[0].startTime);\n          tempAssignments.push(assignmentMap.get(rid)!);\n        }\n      }\n\n      for (const ta of tempAssignments) {\n        removeEvent(ta.eventId);\n      }\n\n      if (count > bestCount) {\n        // Better to skip this event\n        unscheduled.push(eventId);\n        return scheduleLevel(eventIds, index + 1);\n      }\n    }\n\n    // Use the best placement\n    if (bestPlacement) {\n      placeEvent(eventId, bestPlacement.roomId, bestPlacement.startTime);\n      const rest = scheduleLevel(eventIds, index + 1);\n      return 1 + rest;\n    }\n\n    unscheduled.push(eventId);\n    return scheduleLevel(eventIds, index + 1);\n  }\n\n  return {\n    assignments: [...assignmentMap.values()],\n    unscheduled,\n  };\n}\n","structuredPatch":[{"oldStart":205,"oldLines":7,"newStart":205,"newLines":6,"lines":["   rooms: Room[],","   options: ScheduleOptions"," ): ScheduleResult {","-  // Validate and detect cycles","   detectCycles(events);"," ","   const gap = options.gap ?? 15;"]},{"oldStart":214,"oldLines":10,"newStart":213,"n