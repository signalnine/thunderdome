// Skip\n  console.log(`${indent}  trying skip ${eventId}...`);\n  const skipResult = backtrack(eventIds, index + 1, depth + 1);\n  console.log(`${indent}  skipResult.placed = ${JSON.stringify([...skipResult.placed])}`);\n\n  if (placements.length === 0) {\n    console.log(`${indent}  no placements, return skip`);\n    return skipResult;\n  }\n\n  if (skipResult.placed.size === remaining - 1) {\n    console.log(`${indent}  skip already optimal`);\n    return skipResult;\n  }\n\n  let bestResult = skipResult;\n\n  for (let i = 0; i < placements.length; i++) {\n    const p = placements[i];\n    console.log(`${indent}  trying place ${eventId} at ${p.startTime}...`);\n    placeEvent(eventId, p.roomId, p.startTime);\n\n    const gr = greedyCount(eventIds.slice(index + 1));\n    console.log(`${indent}  greedyRest=${gr}, 1+gr=${1+gr}, bestResult.placed.size=${bestResult.placed.size}`);\n    \n    if (1 + gr > bestResult.placed.size) {\n      console.log(`${indent}  worth trying, recursing...`);\n      const subResult = backtrack(eventIds, index + 1, depth + 1);\n      console.log(`${indent}  subResult.placed = ${JSON.stringify([...subResult.placed])}`);\n      \n      if (1 + subResult.placed.size > bestResult.placed.size) {\n        const np = new Set(subResult.placed);\n        np.add(eventId);\n        const na = new Map(subResult.assignments);\n        na.set(eventId, { roomId: p.roomId, startTime: p.startTime });\n        bestResult = { placed: np, assignments: na };\n        console.log(`${indent}  updated bestResult to ${JSON.stringify([...bestResult.placed])}`);\n      }\n    }\n\n    removeEvent(eventId);\n    if (bestResult.placed.size === remaining) break;\n  }\n\n  console.log(`${indent}  -> returning placed=${JSON.stringify([...bestResult.placed])}`);\n  return bestResult;\n}\n\nconst levelEvents = ['A', 'C'];\nconst result = backtrack(levelEvents, 0);\nconsole.log('\\nFinal result:');\nconsole.log('placed:', [...result.placed]);\nconsole.log('assignments:', [