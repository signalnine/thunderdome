  119→}\n   120→\n   121→/**\n   122→ * Find the earliest start time for an event in a given room,\n   123→ * considering room occupancy and prerequisite completion times.\n   124→ */\n   125→function findEarliestStart(\n   126→  event: Event,\n   127→  room: Room,\n   128→  roomSchedules: Map<string, Assignment[]>,\n   129→  assignmentMap: Map<string, Assignment>,\n   130→  options: ScheduleOptions,\n   131→  gap: number\n   132→): number | null {\n   133→  const attendees = event.attendees ?? 1;\n   134→  if (attendees > room.capacity) return null;\n   135→\n   136→  // Earliest start based on prerequisites\n   137→  let earliest = options.startTime;\n   138→  for (const prereqId of event.prerequisites ?? []) {\n   139→    const prereqAssignment = assignmentMap.get(prereqId);\n   140→    if (prereqAssignment) {\n   141→      earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n   142→    }\n   143→    // If a prereq exists in the event list but isn't assigned, we still\n   144→    // respect ordering — it might get scheduled later or be unscheduled.\n   145→    // We handle this at a higher level.\n   146→  }\n   147→\n   148→  const endLimit = options.endTime;\n   149→  const duration = event.duration;\n   150→\n   151→  if (earliest + duration > endLimit) return null;\n   152→\n   153→  const roomAssignments = roomSchedules.get(room.id) ?? [];\n   154→\n   155→  // If room has no events, earliest is fine\n   156→  if (roomAssignments.length === 0) {\n   157→    return earliest;\n   158→  }\n   159→\n   160→  // Room assignments are sorted by startTime. Find a slot.\n   161→  // Try before the first event\n   162→  if (earliest + duration + gap <= roomAssignments[0].startTime) {\n   163→    return earliest;\n   164→  }\n   165→\n   166→  // Try between existing events\n   167→  for (let i = 0; i < roomAssignments.length; i++) {\n   168→    const slotStart = Math.max(earliest, roomAssignments[i].endTime + gap);\n   169→    const nextStart = i + 1 < roomAssignments.length\n   170→      ? roomAssignments[i + 1].startTime\n   171→      : endLimit + gap; // allow fitting at the end\n   172→\n   173→    if (slotStart + duration <= Math.min(nextStart - gap, endLimit) + gap) {\n   174→      // Check: if there's a next event, we need slotStart + duration + gap <= nextStart\n   175→      // If no next event, we just need slotStart + duration <= endLimit\n   176→      if (i + 1 < roomAssignments.length) {\n   177→        if (slotStart + duration + gap <= roomAssignments[i + 1].startTime) {\n   178→          if (slotStart + duration <= endLimit) {\n   179→            return slotStart;\n   180→          }\n   181→        }\n   182→      } else {\n   183→        if (slotStart + duration <= endLimit) {\n   184→          return slotStart;\n   185→        }\n   186→      }\n   187→    }\n   188→  }\n   189→\n   190→  // Try after the last event\n   191→  const lastEnd = roomAssignments[roomAssignments.length - 1].endTime;\n   192→  const slotStart = Math.max(earliest, lastEnd + gap);\n   193→  if (slotStart + duration <= endLimit) {\n   194→    return slotStart;\n   195→  }\n   196→\n   197→  return null;\n   198→}\n   199→\n   200→/**\n   201→ * Main scheduling function.\n   202→ */\n   203→export function schedule(\n   204→  events: Event[],\n   205→  rooms: Room[],\n   206→  options: ScheduleOptions\n   207→): ScheduleResult {\n   208→  // Validate and detect cycles\n   209→  detectCycles(events);\n   210→\n   211→  const gap = options.gap ?? 15;\n   212→  const eventMap = new Map<string, Event>();\n   213→  for (const event of events) {\n   214→    eventMap.set(event.id, event);\n   215→  }\n   216→\n   217→  // Topological order\n   218→  const topoOrder = topologicalSort(events);\n   219→\n   220→  // Build prerequisite depth (longest chain) for prioritization\n   221→  const depth = new Map<string, number>();\n   222→  for (const id of topoOrder) {\n   223→    const event = eventMap.get(id)!;\n   224→    let maxDepth = 0;\