  const levelResult = backtrack(levelEvents, 0);\n    // Apply the best solution\n    for (const eid of levelEvents) {\n      if (!levelResult.placed.has(eid)) {\n        allUnscheduled.push(eid);\n      }\n    }\n    // Place the chosen assignments\n    for (const [eid, assignment] of levelResult.assignments) {\n      placeEvent(eid, assignment.roomId, assignment.startTime);\n    }\n  }\n\n  /**\n   * Backtracking search that maximizes the number of placed events.\n   * Returns the set of placed event IDs and their assignments.\n   */\n  function backtrack(\n    eventIds: string[],\n    index: number,\n    currentBest = { count: 0 }\n  ): { placed: Set<string>; assignments: Map<string, { roomId: string; startTime: number }> } {\n    if (index >= eventIds.length) {\n      return { placed: new Set(), assignments: new Map() };\n    }\n\n    const remaining = eventIds.length - index;\n    const currentPlaced = eventIds.length - remaining;\n\n    // Upper bound pruning: even if we place all remaining, can we beat current best?\n    // (currentPlaced here is how many we've tentatively placed before this call)\n\n    const eventId = eventIds[index];\n    const event = eventMap.get(eventId)!;\n\n    // If prerequisites not satisfied, skip\n    if (!prereqsSatisfied(event)) {\n      const result = backtrack(eventIds, index + 1, currentBest);\n      return result;\n    }\n\n    const placements = getPlacements(event);\n\n    // Option 1: skip this event\n    const skipResult = backtrack(eventIds, index + 1, currentBest);\n\n    if (placements.length === 0) {\n      return skipResult;\n    }\n\n    // If skipping already achieves placing all remaining-1 events, no point trying to place\n    if (skipResult.placed.size === remaining - 1) {\n      return skipResult;\n    }\n\n    // Option 2: try placing this event in each available slot\n    let bestResult = skipResult;\n\n    // Limit placements to try (for performance)\n    const maxTries = Math.min(placements.length, 8);\n\n