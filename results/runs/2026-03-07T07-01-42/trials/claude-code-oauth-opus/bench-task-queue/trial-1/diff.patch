veLength(1);\n\n      tq.removeSchedule(schedule.id);\n\n      const t2 = new Date('2024-01-01T00:10:00');\n      expect(tq.tick(t2)).toHaveLength(0);\n    });\n  });\n\n  // ─── Phase 11: Middleware ───\n\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware before handler', async () => {\n      const order: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push('middleware');\n        await next();\n      });\n      tq.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      tq.addTask({ payload: 'test' });\n      await tq.processTask();\n\n      expect(order).toEqual(['middleware', 'handler']);\n    });\n\n    it('should run multiple middlewares in order', async () => {\n      const order: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push('mw1');\n        await next();\n      });\n      tq.use('default', async (_task, next) => {\n        order.push('mw2');\n        await next();\n      });\n      tq.setHandler('default', async () => {\n        order.push('handler');\n      });\n\n      tq.addTask({ payload: 'test' });\n      await tq.processTask();\n\n      expect(order).toEqual(['mw1', 'mw2', 'handler']);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      const handlerCalled = vi.fn();\n\n      tq.use('default', async () => {\n        // Deliberately not calling next\n      });\n      tq.setHandler('default', handlerCalled);\n\n      tq.addTask({ payload: 'test' });\n      const task = await tq.processTask();\n\n      expect(handlerCalled).not.toHaveBeenCalled();\n      // Task should still be completed since middleware didn't throw\n      expect(task!.status).toBe('completed');\n    });\n\n    it('should allow middleware to modify task', async () => {\n      tq.use('default', async (task, next) => {\n        (task as any).payload = 'modified';\n        await next();\n      });\n\n      let receivedPayload: unknown;\n      tq.setHandler('default', async (task) => {\n        receivedPayload = task.payload;\n      });\n\n      tq.addTask({ payload: 'original' });\n      await tq.processTask();\n\n      expect(receivedPayload).toBe('modified');\n    });\n\n    it('should mark task as failed when middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      tq.addTask({ payload: 'test', maxRetries: 1 });\n      const task = await tq.processTask();\n\n      expect(task!.status).toBe('failed');\n      expect(task!.lastError).toBe('middleware error');\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const q1Calls: string[] = [];\n      const q2Calls: string[] = [];\n\n      tq.use('q1', async (_task, next) => {\n        q1Calls.push('q1-mw');\n        await next();\n      });\n      tq.use('q2', async (_task, next) => {\n        q2Calls.push('q2-mw');\n        await next();\n      });\n\n      tq.addTask({ payload: 'a', queue: 'q1' });\n      tq.addTask({ payload: 'b', queue: 'q2' });\n\n      await tq.processTask('q1');\n      await tq.processTask('q2');\n\n      expect(q1Calls).toEqual(['q1-mw']);\n      expect(q2Calls).toEqual(['q2-mw']);\n    });\n\n    it('should return null if no task available', async () => {\n      const result = await tq.processTask();\n      expect(result).toBeNull();\n    });\n\n    it('should auto-complete tasks after handler runs', async () => {\n      tq.setHandler('default', async () => {\n        // do work\n      });\n\n      tq.addTask({ payload: 'test' });\n      const task = await tq.processTask();\n      expect(task!.status).toBe('completed');\n    });\n  });\n\n  // ─── Phase 12: Graceful Shutdown ───\n\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.addTask({ payload: 'x' })).toThrow();