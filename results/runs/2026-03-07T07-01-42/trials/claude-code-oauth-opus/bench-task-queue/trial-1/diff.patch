+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01TrWQaZVir7mLJJSpf1WcNF","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EwFFK7mjrFLeUxwFSbJJE4","name":"Write","input":{"file_path":"/workspace/src/TaskQueue.test.ts","content":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from './TaskQueue.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ─── Phase 1: Basic FIFO Queue ───\n\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object with id, status, and createdAt', () => {\n      const task = tq.addTask({ payload: { message: 'hello' } });\n      expect(task.id).toBeDefined();\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n      expect(task.payload).toEqual({ message: 'hello' });\n    });\n\n    it('should generate unique IDs for each task', () => {\n      const t1 = tq.addTask({ payload: 'a' });\n      const t2 = tq.addTask({ payload: 'b' });\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve the oldest pending task in FIFO order', () => {\n      tq.addTask({ payload: 'first' });\n      tq.addTask({ payload: 'second' });\n      const task = tq.getTask();\n      expect(task).not.toBeNull();\n      expect(task!.payload).toBe('first');\n      expect(task!.status).toBe('processing');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(tq.getTask()).toBeNull();\n    });\n\n    it('should return null after all tasks are retrieved', () => {\n      tq.addTask({ payload: 'only' });\n      tq.getTask();\n      expect(tq.getTask()).toBeNull();\n    });\n\n    it('should count pending tasks', () => {\n      expect(tq.getTaskCount()).toBe(0);\n      tq.addTask({ payload: 'a' });\n      tq.addTask({ payload: 'b' });\n      expect(tq.getTaskCount()).toBe(2);\n      tq.getTask();\n      expect(tq.getTaskCount()).toBe(1);\n    });\n\n    it('should retrieve a task by ID', () => {\n      const task = tq.addTask({ payload: 'test' });\n      const found = tq.getTaskById(task.id);\n      expect(found).toBeDefined();\n      expect(found!.id).toBe(task.id);\n    });\n  });\n\n  // ─── Phase 2: Named Queues ───\n\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name is given', () => {\n      tq.addTask({ payload: 'a' });\n      const task = tq.getTask();\n      expect(task).not.toBeNull();\n      expect(task!.queue).toBe('default');\n    });\n\n    it('should support multiple independent named queues', () => {\n      tq.addTask({ payload: 'email', queue: 'email' });\n      tq.addTask({ payload: 'sms', queue: 'sms' });\n\n      expect(tq.getTaskCount('email')).toBe(1);\n      expect(tq.getTaskCount('sms')).toBe(1);\n\n      const emailTask = tq.getTask('email');\n      expect(emailTask!.payload).toBe('email');\n\n      const smsTask = tq.getTask('sms');\n      expect(smsTask!.payload).toBe('sms');\n    });\n\n    it('should return null for non-existent queues', () => {\n      expect(tq.getTask('nonexistent')).toBeNull();\n    });\n\n    it('should list all queue names', () => {\n      tq.addTask({ payload: 'a', queue: 'alpha' });\n      tq.addTask({ payload: 'b', queue: 'beta' });\n      const names = tq.getQueueNames();\n      expect(names).toContain('alpha');\n      expect(names).toContain('beta');\n    });\n\n    it('should implicitly create queues on first task', () => {\n      expect(tq.getQueueNames()).toEqual([]);\n      tq.addTask({ payload: 'x', queue: 'new-queue' });\n      expect(tq.getQueueNames()).toContain('new-queue');\n    });\n  });\n\n  // ─── Phase 3: Priority ───\n\n  describe('Phase 3: Priority', () => {\n    it('should default to priority 5', () => {\n      const task = tq.addTask({ payload: 'x' });\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first (lower number)', () => {\n      tq.addTask({ payload: 'low', priority: 10 });\n      tq.addTask({ payload: 'high', priority: 1 });\n      tq.addTask({ payload: 'mid', priority: 5 });\n\n      expect(tq.getTask()!.payload).toBe('high');\n      expect(tq.getTask()!.payload).toBe('mid');\n      expect(tq.getTask()!.payload).toBe('low');\n    });\n\n    it('should maintain FIFO order within same priority', () => {\n      tq.addTask({ payload: 'first', priority: 3 });\n      tq.addTask({ payload: 'second', priority: 3 });\n      tq.addTask({ payload: 'third', priority: 3 });\n\n      expect(tq.getTask()!.payload).toBe('first');\n      expect(tq.getTask()!.payload).toBe('second');\n      expect(tq.getTask()!.payload).toBe('third');\n    });\n\n    it('should reject invalid priorities', () => {\n      expect(() => tq.addTask({ payload: 'x', priority: 0 })).toThrow();\n      expect(() => tq.addTask({ payload: 'x', priority: 11 })).toThrow();\n      expect(() => tq.addTask({ payload: 'x', priority: 3.5 })).toThrow();\n    });\n\n    it('should accept valid edge priorities', () => {\n      expect(() => tq.addTask({ payload: 'x', priority: 1 })).not.toThrow();\n      expect(() => tq.addTask({ payload: 'x', priority: 10 })).not.toThrow();\n    });\n\n    it('should maintain priority ordering per queue', () => {\n      tq.addTask({ payload: 'q1-low', queue: 'q1', priority: 8 });\n      tq.addTask({ payload: 'q1-high', queue: 'q1', priority: 2 });\n      tq.addTask({ payload: 'q2-low', queue: 'q2', priority: 9 });\n      tq.addTask({ payload: 'q2-high', queue: 'q2', priority: 1 });\n\n      expect(tq.getTask('q1')!.payload).toBe('q1-high');\n      expect(tq.getTask('q2')!.payload).toBe('q2-high');\n    });\n  });\n\n  // ─── Phase 4: Delayed Tasks ───\n\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return a delayed task before its availability time', () => {\n      tq.addTask({ payload: 'delayed', delay: 60000 });\n      expect(tq.getTask()).toBeNull();\n    });\n\n    it('should return a delayed task after its time has passed', () => {\n      const pastTime = new Date(Date.now() - 1000);\n      tq.addTask({ payload: 'ready', processAt: pastTime });\n      const task = tq.getTask();\n      expect(task).not.toBeNull();\n      expect(task!.payload).toBe('ready');\n    });\n\n    it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {\n      tq.addTask({ payload: 'delayed', delay: 60000 });\n      tq.addTask({ payload: 'immediate' });\n      const task = tq.getTask();\n      expect(task!.payload).toBe('immediate');\n    });\n\n    it('should expose availableAt on the task object', () => {\n      const task = tq.addTask({ payload: 'x', delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should order delayed tasks by availability time, then priority, then FIFO', () => {\n      const t1 = new Date(Date.now() - 3000);\n      const t2 = new Date(Date.now() - 2000);\n      const t3 = new Date(Date.now() - 1000);\n\n      tq.addTask({ payload: 'later', processAt: t3 });\n      tq.addTask({ payload: 'earliest', processAt: t1 });\n      tq.addTask({ payload: 'middle', processAt: t2 });\n\n      expect(tq.getTask()!.payload).toBe('earliest');\n      expect(tq.getTask()!.payload).toBe('middle');\n      expect(tq.getTask()!.payload).toBe('later');\n    });\n\n    it('should work correctly with named queues', () => {\n      tq.addTask({ payload: 'q1-delayed', queue: 'q1', delay: 60000 });\n      tq.addTask({ payload: 'q1-ready', queue: 'q1' });\n\n      expect(tq.getTask('q1')!.payload).toBe('q1-ready');\n      expect(tq.getTask('q1')).toBeNull();\n    });\n  });\n\n  // ─── Phase 5: Retry with Backoff ───\n\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark a task as completed', () => {\n      tq.addTask({ payload: 'test' });\n      const task = tq.getTask()!;\n      tq.completeTask(task.id);\n      expect(tq.getTaskById(task.id)!.status).toBe('completed');\n    });\n\n    it('should mark a task as failed and requeue with delay when retries remain', () => {\n      tq.addTask({ payload: 'retry-me', maxRetries: 3, backoffDelay: 100 });\n      const task = tq.getTask()!;\n      tq.failTask(task.id, 'oops');\n\n      const updated = tq.getTaskById(task.id)!;\n      expect(updated.status).toBe('pending');\n      expect(updated.lastError).toBe('oops');\n      expect(updated.failCount).toBe(1);\n      expect(updated.attempt).toBe(1);\n      // Should be delayed (backoff)\n      expect(updated.availableAt.getTime()).toBeGreaterThan(Date.now() - 50);\n    });\n\n    it('should use exponential backoff formula', () => {\n      tq.addTask({ payload: 'exp', maxRetries: 3, backoffDelay: 1000 });\n      const task = tq.getTask()!;\n\n      // First failure: delay = 1000 * 2^0 = 1000\n      tq.failTask(task.id, 'fail1');\n      const afterFirst = tq.getTaskById(task.id)!;\n      const expectedDelay1 = 1000;\n      expect(afterFirst.availableAt.getTime()).toBeGreaterThanOrEqual(Date.now() + expectedDelay1 - 100);\n    });\n\n    it('should track attempt count', () => {\n      tq.addTask({ payload: 'attempt', maxRetries: 5, backoffDelay: 0 });\n      const task = tq.getTask()!;\n      expect(task.attempt).toBe(1);\n    });\n\n    it('should remain failed after exhausting retries', () => {\n      const task = tq.addTask({ payload: 'doomed', maxRetries: 2, backoffDelay: 0 });\n\n      // Attempt 1\n      const t1 = tq.getTask()!;\n      expect(t1.attempt).toBe(1);\n      tq.failTask(t1.id, 'fail1');\n      expect(tq.getTaskById(task.id)!.status).toBe('pending');\n\n      // Attempt 2 (use processAt to make it immediately available)\n      const updated = tq.getTaskById(task.id)!;\n      updated.availableAt = new Date(Date.now() - 1000);\n      const t2 = tq.getTask()!;\n      expect(t2.attempt).toBe(2);\n      tq.failTask(t2.id, 'fail2');\n\n      expect(tq.getTaskById(task.id)!.status).toBe('failed');\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      tq.addTask({ payload: 'prio', queue: 'special', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      const task = tq.getTask('special')!;\n      tq.failTask(task.id, 'err');\n      const updated = tq.getTaskById(task.id)!;\n      expect(updated.queue).toBe('special');\n      expect(updated.priority).toBe(2);\n    });\n\n    it('should error when completing a non-processing task', () => {\n      const task = tq.addTask({ payload: 'x' });\n      expect(() => tq.completeTask(task.id)).toThrow();\n    });\n\n    it('should error on non-existent task', () => {\n      expect(() => tq.completeTask('nonexistent')).toThrow();\n      expect(() => tq.failTask('nonexistent')).toThrow();\n    });\n  });\n\n  // ─── Phase 6: Dead Letter Queue ───\n\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move tasks to DLQ after exhausting retries', () => {\n      tq.addTask({ payload: 'dead', maxRetries: 1, backoffDelay: 0 });\n      const task = tq.getTask()!;\n      tq.failTask(task.id, 'fatal');\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq.length).toBe(1);\n      expect(dlq[0].task.id).toBe(task.id);\n      expect(dlq[0].error).toBe('fatal');\n      expect(dlq[0].failCount).toBe(1);\n    });\n\n    it('should retain error information in DLQ entries', () => {\n      tq.addTask({ payload: 'err', maxRetries: 1, backoffDelay: 0 });\n      const task = tq.getTask()!;\n      tq.failTask(task.id, 'specific error message');\n\n      const dlq = tq.getDeadLetterTasks();\n      expect(dlq[0].error).toBe('specific error message');\n    });\n\n    it('should requeue a dead-lettered task', () => {\n      tq.addTask({ payload: 'requeue-me', maxRetries: 1, backoffDelay: 0 });\n      const task = tq.getTask()!;\n      tq.failTask(task.id, 'err');\n\n      expect(tq.getDeadLetterTasks().length).toBe(1);\n\n      const requeued = tq.requeue(task.id);\n      expect(requeued.status).toBe('pending');\n      expect(requeued.attempt).toBe(0);\n      expect(requeued.failCount).toBe(0);\n\n      expect(tq.getDeadLetterTasks().length).toBe(0);\n    });\n\n    it('should clear all DLQ tasks for a queue', () => {\n      tq.addTask({ payload: 'a', maxRetries: 1, backoffDelay: 0 });\n      tq.addTask({ payload: 'b', maxRetries: 1, backoffDelay: 0 });\n      const t1 = tq.getTask()!;\n      const t2 = tq.getTask()!;\n      tq.failTask(t1.id, 'e1');\n      tq.failTask(t2.id, 'e2');\n\n      expect(tq.getDeadLetterTasks().length).toBe(2);\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterTasks().length).toBe(0);\n    });\n\n    it('should have independent DLQ per named queue', () => {\n      tq.addTask({ payload: 'a', queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n      tq.addTask({ payload: 'b', queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n      const t1 = tq.getTask('q1')!;\n      const t2 = tq.getTask('q2')!;\n      tq.failTask(t1.id, 'e1');\n      tq.failTask(t2.id, 'e2');\n\n      expect(tq.getDeadLetterTasks('q1').length).toBe(1);\n      expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n\n      tq.clearDeadLetterQueue('q1');\n      expect(tq.getDeadLetterTasks('q1').length).toBe(0);\n      expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n    });\n\n    it('should error when requeuing non-existent DLQ task', () => {\n      expect(() => tq.requeue('nonexistent')).toThrow();\n    });\n  });\n\n  // ─── Phase 7: Task Dependencies ───\n\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.addTask({ payload: 'dependency' });\n      tq.addTask({ payload: 'dependent', dependencies: [dep.id] });\n\n      // Should get the dependency first since the dependent is blocked\n      const task = tq.getTask()!;\n      expect(task.payload).toBe('dependency');\n\n      // Dependent should not be available yet\n      expect(tq.getTask()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.addTask({ payload: 'dep' });\n      tq.addTask({ payload: 'blocked', dependencies: [dep.id] });\n\n      const depTask = tq.getTask()!;\n      tq.completeTask(depTask.id);\n\n      // Now the dependent should be available\n      const task = tq.getTask()!;\n      expect(task.payload).toBe('blocked');\n    });\n\n    it('should error on non-existent dependency', () => {\n      expect(() => tq.addTask({ payload: 'x', dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = tq.addTask({ payload: 'dep', maxRetries: 1, backoffDelay: 0 });\n      tq.addTask({ payload: 'blocked', dependencies: [dep.id] });\n\n      const depTask = tq.getTask()!;\n      tq.failTask(depTask.id, 'failed');\n\n      // Dependent remains blocked\n      expect(tq.getTask()).toBeNull();\n    });\n\n    it('should support multiple dependencies', () => {\n      const dep1 = tq.addTask({ payload: 'dep1' });\n      const dep2 = tq.addTask({ payload: 'dep2' });\n      tq.addTask({ payload: 'needs-both', dependencies: [dep1.id, dep2.id] });\n\n      const d1 = tq.getTask()!;\n      tq.completeTask(d1.id);\n\n      // Still blocked because dep2 isn't complete\n      expect(tq.getTask()!.payload).toBe('dep2');\n      expect(tq.getTask()).toBeNull();\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = tq.addTask({ payload: 'dep1' });\n      const dep2 = tq.addTask({ payload: 'dep2' });\n      const dependent = tq.addTask({ payload: 'dependent', dependencies: [dep1.id, dep2.id] });\n\n      const status = tq.getDependencyStatus(dependent.id);\n      expect(status).toHaveLength(2);\n      expect(status[0].status).toBe('pending');\n      expect(status[1].status).toBe('pending');\n\n      const d1 = tq.getTask()!;\n      tq.completeTask(d1.id);\n\n      const status2 = tq.getDependencyStatus(dependent.id);\n      expect(status2.find(s => s.dependency === dep1.id)!.status).toBe('completed');\n      expect(status2.find(s => s.dependency === dep2.id)!.status).toBe('pending');\n    });\n  });\n\n  // ─── Phase 8: Concurrency Control ───\n\n  describe('Phase 8: Concurrency Control', () => {\n    it('should default to unlimited concurrency', () => {\n      tq.addTask({ payload: 'a' });\n      tq.addTask({ payload: 'b' });\n      tq.addTask({ payload: 'c' });\n\n      expect(tq.getTask()).not.toBeNull();\n      expect(tq.getTask()).not.toBeNull();\n      expect(tq.getTask()).not.toBeNull();\n    });\n\n    it('should limit concurrent processing tasks', () => {\n      tq.setConcurrency('default', 2);\n      tq.addTask({ payload: 'a' });\n      tq.addTask({ payload: 'b' });\n      tq.addTask({ payload: 'c' });\n\n      expect(tq.getTask()).not.toBeNull();\n      expect(tq.getTask()).not.toBeNull();\n      expect(tq.getTask()).toBeNull(); // Limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask({ payload: 'a' });\n      tq.addTask({ payload: 'b' });\n\n      const task = tq.getTask()!;\n      expect(tq.getTask()).toBeNull();\n\n      tq.completeTask(task.id);\n      expect(tq.getTask()).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask({ payload: 'a', maxRetries: 1, backoffDelay: 0 });\n      tq.addTask({ payload: 'b' });\n\n      const task = tq.getTask()!;\n      expect(tq.getTask()).toBeNull();\n\n      tq.failTask(task.id, 'err');\n      // Task got re-queued with delay, so 'b' should be available\n      const next = tq.getTask()!;\n      expect(next.payload).toBe('b');\n    });\n\n    it('should query concurrency limit and active count', () => {\n      tq.setConcurrency('default', 3);\n      expect(tq.getConcurrency()).toBe(3);\n      expect(tq.getActiveCount()).toBe(0);\n\n      tq.addTask({ payload: 'a' });\n      tq.getTask();\n      expect(tq.getActiveCount()).toBe(1);\n    });\n\n    it('should still respect priority under concurrency limits', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask({ payload: 'low', priority: 8 });\n      tq.addTask({ payload: 'high', priority: 2 });\n\n      const task = tq.getTask()!;\n      expect(task.payload).toBe('high');\n    });\n  });\n\n  // ─── Phase 9: Progress & Cancellation ───\n\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should update and query progress', () => {\n      tq.addTask({ payload: 'work' });\n      const task = tq.getTask()!;\n\n      tq.updateProgress(task.id, 50, 'halfway');\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should reject invalid progress values', () => {\n      tq.addTask({ payload: 'work' });\n      const task = tq.getTask()!;\n\n      expect(() => tq.updateProgress(task.id, -1)).toThrow();\n      expect(() => tq.updateProgress(task.id, 101)).toThrow();\n    });\n\n    it('should notify progress listeners', () => {\n      tq.addTask({ payload: 'work' });\n      const task = tq.getTask()!;\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      tq.updateProgress(task.id, 25, 'quarter');\n      tq.updateProgress(task.id, 75, 'three-quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n      expect(updates[1]).toEqual({ progress: 75, message: 'three-quarters' });\n    });\n\n    it('should support unsubscribing from progress', () => {\n      tq.addTask({ payload: 'work' });\n      const task = tq.getTask()!;\n\n      let count = 0;\n      const unsub = tq.onProgress(task.id, () => count++);\n\n      tq.updateProgress(task.id, 25);\n      unsub();\n      tq.updateProgress(task.id, 50);\n\n      expect(count).toBe(1);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = tq.addTask({ payload: 'cancel-me' });\n      tq.cancelTask(task.id);\n      expect(tq.getTaskById(task.id)!.status).toBe('cancelled');\n      expect(tq.getTask()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      tq.addTask({ payload: 'work' });\n      const task = tq.getTask()!;\n      tq.cancelTask(task.id);\n      expect(tq.getTaskById(task.id)!.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      tq.addTask({ payload: 'work', maxRetries: 3 });\n      const task = tq.getTask()!;\n      tq.cancelTask(task.id);\n\n      // Task should be cancelled, not retried\n      expect(tq.getTaskById(task.id)!.status).toBe('cancelled');\n      expect(tq.getTask()).toBeNull();\n    });\n\n    it('should error when cancelling completed task', () => {\n      tq.addTask({ payload: 'done' });\n      const task = tq.getTask()!;\n      tq.completeTask(task.id);\n      expect(() => tq.cancelTask(task.id)).toThrow();\n    });\n  });\n\n  // ─── Phase 10: Recurring Tasks ───\n\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cron).toBe('*/5 * * * *');\n      expect(schedule.queue).toBe('default');\n    });\n\n    it('should list schedules', () => {\n      tq.addSchedule('*/5 * * * *', 'default', 'a');\n      tq.addSchedule('0 * * * *', 'default', 'b');\n      expect(tq.getSchedules()).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', 'a');\n      tq.removeSchedule(schedule.id);\n      expect(tq.getSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick when