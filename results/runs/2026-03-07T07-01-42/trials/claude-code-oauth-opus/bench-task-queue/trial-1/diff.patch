+export { TaskQueue } from './TaskQueue.js';
+export type {
+  Task,
+  TaskStatus,
+  AddTaskOptions,
+  DeadLetterEntry,
+  Schedule,
+  MiddlewareFn,
+  HandlerFn,
+  ProgressListener,
+  ShutdownCallback,
+  ShutdownOptions,
+  ShutdownResult,
+} from './types.js';
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..126beff
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,61 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  createdAt: Date;
+  queue: string;
+  priority: number;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  lastError?: string;
+  failCount: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+}
+
+export interface AddTaskOptions<T = unknown> {
+  payload: T;
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface DeadLetterEntry<T = unknown> {
+  task: Task<T>;
+  error: string;
+  failCount: number;
+  deadLetteredAt: Date;
+}
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  lastRun: Date | null;
+  createdAt: Date;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFn = (task: Task) => Promise<void> | void;
+export type ProgressListener = (progress: number, message?: string) => void;
+export type ShutdownCallback = () => void | Promise<void>;
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
