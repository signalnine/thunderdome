+import { describe, it, expect, beforeEach, vi } from 'vitest';
+import { TaskQueue } from './TaskQueue.js';
+
+describe('TaskQueue', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  // ─── Phase 1: Basic FIFO Queue ───
+
+  describe('Phase 1: Basic FIFO Queue', () => {
+    it('should add a task and return a task object with id, status, and createdAt', () => {
+      const task = tq.addTask({ payload: { message: 'hello' } });
+      expect(task.id).toBeDefined();
+      expect(task.status).toBe('pending');
+      expect(task.createdAt).toBeInstanceOf(Date);
+      expect(task.payload).toEqual({ message: 'hello' });
+    });
+
+    it('should generate unique IDs for each task', () => {
+      const t1 = tq.addTask({ payload: 'a' });
+      const t2 = tq.addTask({ payload: 'b' });
+      expect(t1.id).not.toBe(t2.id);
+    });
+
+    it('should retrieve the oldest pending task in FIFO order', () => {
+      tq.addTask({ payload: 'first' });
+      tq.addTask({ payload: 'second' });
+      const task = tq.getTask();
+      expect(task).not.toBeNull();
+      expect(task!.payload).toBe('first');
+      expect(task!.status).toBe('processing');
+    });
+
+    it('should return null when no tasks are available', () => {
+      expect(tq.getTask()).toBeNull();
+    });
+
+    it('should return null after all tasks are retrieved', () => {
+      tq.addTask({ payload: 'only' });
+      tq.getTask();
+      expect(tq.getTask()).toBeNull();
+    });
+
+    it('should count pending tasks', () => {
+      expect(tq.getTaskCount()).toBe(0);
+      tq.addTask({ payload: 'a' });
+      tq.addTask({ payload: 'b' });
+      expect(tq.getTaskCount()).toBe(2);
+      tq.getTask();
+      expect(tq.getTaskCount()).toBe(1);
+    });
+
+    it('should retrieve a task by ID', () => {
+      const task = tq.addTask({ payload: 'test' });
+      const found = tq.getTaskById(task.id);
+      expect(found).toBeDefined();
+      expect(found!.id).toBe(task.id);
+    });
+  });
+
+  // ─── Phase 2: Named Queues ───
+
+  describe('Phase 2: Named Queues', () => {
+    it('should use default queue when no name is given', () => {
+      tq.addTask({ payload: 'a' });
+      const task = tq.getTask();
+      expect(task).not.toBeNull();
+      expect(task!.queue).toBe('default');
+    });
+
+    it('should support multiple independent named queues', () => {
+      tq.addTask({ payload: 'email', queue: 'email' });
+      tq.addTask({ payload: 'sms', queue: 'sms' });
+
+      expect(tq.getTaskCount('email')).toBe(1);
+      expect(tq.getTaskCount('sms')).toBe(1);
+
+      const emailTask = tq.getTask('email');
+      expect(emailTask!.payload).toBe('email');
+
+      const smsTask = tq.getTask('sms');
+      expect(smsTask!.payload).toBe('sms');
+    });
+
+    it('should return null for non-existent queues', () => {
+      expect(tq.getTask('nonexistent')).toBeNull();
+    });
+
+    it('should list all queue names', () => {
+      tq.addTask({ payload: 'a', queue: 'alpha' });
+      tq.addTask({ payload: 'b', queue: 'beta' });
+      const names = tq.getQueueNames();
+      expect(names).toContain('alpha');
+      expect(names).toContain('beta');
+    });
+
+    it('should implicitly create queues on first task', () => {
+      expect(tq.getQueueNames()).toEqual([]);
+      tq.addTask({ payload: 'x', queue: 'new-queue' });
+      expect(tq.getQueueNames()).toContain('new-queue');
+    });
+  });
+
+  // ─── Phase 3: Priority ───
+
+  describe('Phase 3: Priority', () => {
+    it('should default to priority 5', () => {
+      const task = tq.addTask({ payload: 'x' });
+      expect(task.priority).toBe(5);
+    });
+
+    it('should return higher priority tasks first (lower number)', () => {
+      tq.addTask({ payload: 'low', priority: 10 });
+      tq.addTask({ payload: 'high', priority: 1 });
+      tq.addTask({ payload: 'mid', priority: 5 });
+
+      expect(tq.getTask()!.payload).toBe('high');
+      expect(tq.getTask()!.payload).toBe('mid');
+      expect(tq.getTask()!.payload).toBe('low');
+    });
+
+    it('should maintain FIFO order within same priority', () => {
+      tq.addTask({ payload: 'first', priority: 3 });
+      tq.addTask({ payload: 'second', priority: 3 });
+      tq.addTask({ payload: 'third', priority: 3 });
+
+      expect(tq.getTask()!.payload).toBe('first');
+      expect(tq.getTask()!.payload).toBe('second');
+      expect(tq.getTask()!.payload).toBe('third');
+    });
+
+    it('should reject invalid priorities', () => {
+      expect(() => tq.addTask({ payload: 'x', priority: 0 })).toThrow();
+      expect(() => tq.addTask({ payload: 'x', priority: 11 })).toThrow();
+      expect(() => tq.addTask({ payload: 'x', priority: 3.5 })).toThrow();
+    });
+
+    it('should accept valid edge priorities', () => {
+      expect(() => tq.addTask({ payload: 'x', priority: 1 })).not.toThrow();
+      expect(() => tq.addTask({ payload: 'x', priority: 10 })).not.toThrow();
+    });
+
+    it('should maintain priority ordering per queue', () => {
+      tq.addTask({ payload: 'q1-low', queue: 'q1', priority: 8 });
+      tq.addTask({ payload: 'q1-high', queue: 'q1', priority: 2 });
+      tq.addTask({ payload: 'q2-low', queue: 'q2', priority: 9 });
+      tq.addTask({ payload: 'q2-high', queue: 'q2', priority: 1 });
+
+      expect(tq.getTask('q1')!.payload).toBe('q1-high');
+      expect(tq.getTask('q2')!.payload).toBe('q2-high');
+    });
+  });
+
+  // ─── Phase 4: Delayed Tasks ───
+
+  describe('Phase 4: Delayed Tasks', () => {
+    it('should not return a delayed task before its availability time', () => {
+      tq.addTask({ payload: 'delayed', delay: 60000 });
+      expect(tq.getTask()).toBeNull();
+    });
+
+    it('should return a delayed task after its time has passed', () => {
+      const pastTime = new Date(Date.now() - 1000);
+      tq.addTask({ payload: 'ready', processAt: pastTime });
+      const task = tq.getTask();
+      expect(task).not.toBeNull();
+      expect(task!.payload).toBe('ready');
+    });
+
+    it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {
+      tq.addTask({ payload: 'delayed', delay: 60000 });
+      tq.addTask({ payload: 'immediate' });
+      const task = tq.getTask();
+      expect(task!.payload).toBe('immediate');
+    });
+
+    it('should expose availableAt on the task object', () => {
+      const task = tq.addTask({ payload: 'x', delay: 5000 });
+      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);
+    });
+
+    it('should order delayed tasks by availability time, then priority, then FIFO', () => {
+      const t1 = new Date(Date.now() - 3000);
+      const t2 = new Date(Date.now() - 2000);
+      const t3 = new Date(Date.now() - 1000);
+
+      tq.addTask({ payload: 'later', processAt: t3 });
+      tq.addTask({ payload: 'earliest', processAt: t1 });
+      tq.addTask({ payload: 'middle', processAt: t2 });
+
+      expect(tq.getTask()!.payload).toBe('earliest');
+      expect(tq.getTask()!.payload).toBe('middle');
+      expect(tq.getTask()!.payload).toBe('later');
+    });
+
+    it('should work correctly with named queues', () => {
+      tq.addTask({ payload: 'q1-delayed', queue: 'q1', delay: 60000 });
+      tq.addTask({ payload: 'q1-ready', queue: 'q1' });
+
+      expect(tq.getTask('q1')!.payload).toBe('q1-ready');
+      expect(tq.getTask('q1')).toBeNull();
+    });
+  });
+
+  // ─── Phase 5: Retry with Backoff ───
+
+  describe('Phase 5: Retry with Backoff', () => {
+    it('should mark a task as completed', () => {
+      tq.addTask({ payload: 'test' });
+      const task = tq.getTask()!;
+      tq.completeTask(task.id);
+      expect(tq.getTaskById(task.id)!.status).toBe('completed');
+    });
+
+    it('should mark a task as failed and requeue with delay when retries remain', () => {
+      tq.addTask({ payload: 'retry-me', maxRetries: 3, backoffDelay: 100 });
+      const task = tq.getTask()!;
+      tq.failTask(task.id, 'oops');
+
+      const updated = tq.getTaskById(task.id)!;
+      expect(updated.status).toBe('pending');
+      expect(updated.lastError).toBe('oops');
+      expect(updated.failCount).toBe(1);
+      expect(updated.attempt).toBe(1);
+      // Should be delayed (backoff)
+      expect(updated.availableAt.getTime()).toBeGreaterThan(Date.now() - 50);
+    });
+
+    it('should use exponential backoff formula', () => {
+      tq.addTask({ payload: 'exp', maxRetries: 3, backoffDelay: 1000 });
+      const task = tq.getTask()!;
+
+      // First failure: delay = 1000 * 2^0 = 1000
+      tq.failTask(task.id, 'fail1');
+      const afterFirst = tq.getTaskById(task.id)!;
+      const expectedDelay1 = 1000;
+      expect(afterFirst.availableAt.getTime()).toBeGreaterThanOrEqual(Date.now() + expectedDelay1 - 100);
+    });
+
+    it('should track attempt count', () => {
+      tq.addTask({ payload: 'attempt', maxRetries: 5, backoffDelay: 0 });
