row new Error(`Dependency task \"${depId}\" does not exist.`);\n      }\n    }\n\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      this.checkCircularDependencies(dependencies);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n    if (options.processAt) {\n      availableAt = options.processAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload: options.payload,\n      status: 'pending',\n      createdAt: now,\n      queue: queueName,\n      priority,\n      availableAt,\n      attempt: 0,\n      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      failCount: 0,\n      dependencies,\n      progress: 0,\n    };\n\n    this.tasks.set(task.id, task as Task);\n    this.ensureQueue(queueName);\n\n    return task;\n  }\n\n  getTask(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueState = this.queues.get(name);\n\n    // Check concurrency limit (Phase 8)\n    if (queueState && queueState.concurrencyLimit > 0) {\n      const activeCount = this.getActiveCount(name);\n      if (activeCount >= queueState.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n    const candidates: Task[] = [];\n\n    for (const task of this.tasks.values()) {\n      if (\n        task.queue === name &&\n        task.status === 'pending' &&\n        task.availableAt <= now &&\n        this.areDependenciesMet(task)\n      ) {\n        candidates.push(task);\n      }\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Sort: priority asc, availableAt asc, createdAt asc (FIFO)\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n        return a.availableAt.getTime() - b.availableAt.getTime();\n      }\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.attempt += 1;\n    return task;\n  }\n\n  getTaskCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === name && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  getTaskById(id: string): Task | undefined {\n    return this.tasks.get(id);\n  }\n\n  // ─── Phase 2: Named queues ───\n\n  getQueueNames(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ─── Phase 5: Complete / Fail ───\n\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found.`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not in processing state (current: ${task.status}).`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Phase 7: check if any dependent tasks are now unblocked\n    // (no action needed since getTask checks dependencies dynamically)\n  }\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found.`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not in processing state (current: ${task.status}).`);\n    }\n\n    task.lastError = error ?? 'Unknown error';\n    task.failCount += 1;\n\n    if (task.attempt < task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'pending';\n      task.progress = 0;\n    } else {\n      // Exhausted retries\n      task.status = 'failed';\n\n      // Phase 6: Move to DLQ\n      this.addToDeadLetterQueue(task);\n    }\n  }\n\n  // ─── Phase 6: Dead Letter Queue ───\n\n  private addToDeadLetterQueue(task: Task): void {\n    const queueName = task.queue;\n    if (!this.deadLetterQueues.has(queueName)) {\n      this.deadLetterQueues.set(queueName, []);\n    }\n    this.deadLetterQueues.get(queueName)!.push({\n      task,\n      error: task.lastError ?? 'Unknown error',\n      failCount: task.failCount,\n      deadLetteredAt: new Date(),\n    });\n  }\n\n  getDeadLetterTasks(queueName?: string): DeadLetterEntry[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return this.deadLetterQueues.get(name) ?? [];\n  }\n\n  requeue(taskId: string): Task {\n    // Find in DLQ\n    for (const [queueName, entries] of this.deadLetterQueues) {\n      const index = entries.findIndex(e => e.task.id === taskId);\n      if (index !== -1) {\n        const entry = entries[index];\n        entries.splice(index, 1);\n\n        const task = entry.task;\n        task.status = 'pending';\n        task.attempt = 0;\n        task.failCount = 0;\n        task.progress = 0;\n        task.availableAt = new Date();\n        task.lastError = undefined;\n\n        // Ensure we have the queue\n        this.ensureQueue(queueName);\n\n        return task;\n      }\n    }\n    throw new Error(`Task \"${taskId}\" not found in any dead letter queue.`);\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    // Remove tasks from main map too\n    const entries = this.deadLetterQueues.get(name);\n    if (entries) {\n      for (const entry of entries) {\n        this.tasks.delete(entry.task.id);\n      }\n    }\n    this.deadLetterQueues.set(name, []);\n  }\n\n  // ─── Phase 7: Dependencies ───\n\n  private areDependenciesMet(task: Task): boolean {\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (!dep || dep.status !== 'completed') {\n        return false;\n      }\n    }\n    return true;\n  }\n\n  private checkCircularDependencies(newDeps: string[]): void {\n    // BFS from each dependency; if we can reach back to any task in newDeps chain, it's circular.\n    // Since the task doesn't exist yet, we just need to make sure none of the dependencies\n    // ultimately depend on each other in a cycle. We check if any dependency transitively\n    // depends on another dependency in the set.\n    // Actually the new task has no ID yet, so it can't be part of a cycle by itself.\n    // We need to check the deps don't form a cycle among themselves.\n    // But more importantly, we need to ensure no dep depends on another dep transitively.\n    // This is actually fine since the new task doesn't exist yet.\n    // The real check: the new task will depend on these IDs. Could adding a task that\n    // depends on these create a cycle? Only if one of these tasks (or their transitive deps)\n    // was already waiting on the new task -- but the new task doesn't exist yet.\n    // So no cycle is possible for a brand new task. The cycle detection is mainly for\n    // ensuring the dependency graph is a DAG.\n    // However, we should validate that the deps themselves don't form cycles through existing tasks.\n    // Actually, since we check at creation time and the new task has no ID, no existing task\n    // can depend on it. So cycles are impossible for new tasks.\n    // The main concern is: does specifying deps that transitively depend on each other cause issues?\n    // That's not a cycle. A->B->C is fine, even if you add D depending on both A and C.\n    // A cycle would be A depends on B, B depends on A. But since we validate at creation time,\n    // this can only happen if you try to create A depending on B, then B depending on A.\n    // The second creation would find that A depends on B, but B trying to depend on A\n    // would create A->B->A. We need to check: \"would this new task create a cycle?\"\n    // Since the new task doesn't exist yet, no one depends on it, so no cycle.\n    // BUT we should still validate. Let's be safe.\n\n    // Actually, let me reconsider. Suppose:\n    // 1. Create task A (no deps)\n    // 2. Create task B (depends on A)\n    // 3. Try to create task C (depends on B) -- fine\n    // 4. Try to make A depend on C? Can't modify deps after creation.\n    // So cycles are truly impossible with this model. But let's still do the check\n    // for correctness if the requirements demand it.\n\n    // The requirement says \"Circular dependencies (direct or indirect) must be detected\n    // and rejected at task-creation time.\" Since a new task can never be depended on by\n    // its own dependencies (it doesn't exist yet), there's no cycle possible.\n    // We'll still implement the check to be safe.\n\n    // No-op for now - cycles are structurally impossible in this design\n    // because a task must exist before it can be listed as a dependency,\n    // and dependencies are set at creation time and never modified.\n  }\n\n  getDependencyStatus(taskId: string): { dependency: string; status: TaskStatus | 'not_found' }[] {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found.`);\n\n    return task.dependencies.map(depId => {\n      const dep = this.tasks.get(depId);\n      return {\n        dependency: depId,\n        status: dep ? dep.status : 'not_found' as const,\n      };\n    });\n  }\n\n  // ─── Phase 8: Concurrency ───\n\n  setConcurrency(queueName: string, limit: number): void {\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return this.queues.get(name)?.concurrencyLimit ?? 0;\n  }\n\n  getActiveCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === name && task.status === 'processing') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ─── Phase 9: Progress & Cancellation ───\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found.`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not in processing state.`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Progress must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found.`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  cancelTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found.`);\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" cannot be cancelled (current status: ${task.status}).`);\n    }\n\n    task.status = 'cancelled';\n    task.progress = 0;\n  }\n\n  // ─── Phase 10: Recurring / Cron ───\n\n  addSchedule(cron: string, queue: string, payload: unknown): Schedule {\n    this.validateCron(cron);\n\n    const schedule: Schedule = {\n      id: randomUUID(),\n      cron,\n      queue,\n      payload,\n      lastRun: null,\n      createdAt: new Date(),\n    };\n\n    this.schedules.set(schedule.id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): void {\n    if (!this.schedules.has(scheduleId)) {\n      throw new Error(`Schedule \"${scheduleId}\" not found.`);\n    }\n    this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const createdTasks: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.shouldRun(schedule, currentTime)) {\n        const task = this.addTask({\n          payload: schedule.payload,\n          queue: schedule.queue,\n        });\n        createdTasks.push(task as Task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return createdTasks;\n  }\n\n  private validateCron(cron: string): void {\n    const parts = cron.split(' ');\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: \"${cron}\". Must have exactly 5 fields.`);\n    }\n\n    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n\n    // Supported patterns:\n    // */N * * * * - every N minutes\n    // 0 * * * * - every hour\n    // 0 0 * * * - every day at midnight\n    const isEveryNMinutes = /^\\*\\/\\d+$/.test(minute) && hour === '*' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';\n    const isEveryHour = /^\\d+$/.test(minute) && hour === '*' && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';\n    const isDaily = /^\\d+$/.test(minute) && /^\\d+$/.test(hour) && dayOfMonth === '*' && month === '*' && dayOfWeek === '*';\n\n    if (!isEveryNMinutes && !isEveryHour && !isDaily) {\n      throw new Error(`Unsupported cron expression: \"${cron}\".`);\n    }\n\n    if (isEveryNMinutes) {\n      const n = parseInt(minute.split('/')[1], 10);\n      if (n < 1 || n > 59) {\n        throw new Error(`Invalid interval in cron expression: \"${cron}\".`);\n      }\n    }\n  }\n\n  private shouldRun(schedule: Schedule, now: Date): boolean {\n    const parts = schedule.cron.split(' ');\n    const [minutePart, hourPart] = parts;\n\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n\n    // */N * * * * - every N minutes\n    if (minutePart.startsWith('*/')) {\n      const interval = parseInt(minutePart.split('/')[1], 10);\n      if (currentMinute % interval !== 0) return false;\n\n      // Check we haven't already run this minute\n      if (schedule.lastRun) {\n        const lastMinute = schedule.lastRun.getMinutes();\n        const lastHour = schedule.lastRun.getHours();\n        const lastDate = schedule.lastRun.toDateString();\n        const nowDate = now.toDateString();\n        if (lastDate === nowDate && lastHour === currentHour && lastMinute === currentMinute) {\n          return false;\n        }\n      }\n      return true;\n    }\n\n    const cronMinute = parseInt(minutePart, 10);\n\n    // 0 * * * * - every hour on the hour\n    if (hourPart === '*') {\n      if (currentMinute !== cronMinute) return false;\n\n      if (schedule.lastRun) {\n        const sameHour = schedule.lastRun.getHours() === currentHour &&\n          schedule.lastRun.toDateString() === now.toDateString();\n        if (sameHour) return false;\n      }\n      return true;\n    }\n\n    // 0 0 * * * - daily at specific time\n    const cronHour = parseInt(hourPart, 10);\n    if (currentMinute !== cronMinute || currentHour !== cronHour) return false;\n\n    if (schedule.lastRun) {\n      if (schedule.lastRun.toDateString() === now.toDateString()) {\n        return false;\n      }\n    }\n    return true;\n  }\n\n  // ─── Phase 11: Middleware ───\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.middlewares.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: HandlerFn): void {\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.handler = handler;\n  }\n\n  async processTask(queueName?: string): Promise<Task | null> {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const task = this.getTask(name);\n    if (!task) return null;\n\n    const queueState = this.queues.get(name);\n    const middlewares = queueState?.middlewares ?? [];\n    const handler = queueState?.handler ?? null;\n\n    try {\n      await this.runMiddlewarePipeline(task, middlewares, handler);\n      if (task.status === 'processing') {\n        this.completeTask(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.failTask(task.id, err instanceof Error ? err.message : String(err));\n      }\n    }\n\n    return task;\n  }\n\n  private async runMiddlewarePipeline(\n    task: Task,\n    middlewares: MiddlewareFn[],\n    handler: HandlerFn | null,\n  ): Promise<void> {\n    let index = 0;\n    const next = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const mw = middlewares[index++];\n        await mw(task, next);\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n    await next();\n  }\n\n  // ─── Phase 12: Graceful Shutdown ───\n\n  onShutdown(callback: ShutdownCallback): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShutdown = true;\n    this.shutdownPromise = this.performShutdown(options);\n    return this.shutdownPromise;\n  }\n\n  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    const startTime = Date.now();\n    const timeout = options?.timeout ?? 30000;\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Get currently processing tasks\n    const processingTasks: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        processingTasks.push(task);\n      }\n    }\n\n    let completed = 0;\n    let forceCancelled = 0;\n\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        forceCancelled: 0,\n        duration: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks to complete, up to timeout\n    const waitResult = await this.waitForProcessingTasks(processingTasks, timeout);\n    completed = waitResult.completed;\n\n    // Force-cancel remaining processing tasks\n    for (const task of processingTasks) {\n      if (task.status === 'processing') {\n        task.status = 'cancelled';\n        forceCancelled++;\n      }\n    }\n\n    return {\n      completed,\n      forceCancelled,\n      duration: Date.now() - startTime,\n    };\n  }\n\n  private waitForProcessingTasks(\n    tasks: Task[],\n    timeout: number,\n  ): Promise<{ completed: number }> {\n    return new Promise(resolve => {\n      const startTime = Date.now();\n      let completed = 0;\n\n      const check = () => {\n        completed = 0;\n        let stillProcessing = 0;\n        for (const task of tasks) {\n          if (task.status === 'completed' || task.status === 'failed') {\n            completed++;\n          } else if (task.status === 'processing') {\n            stillProcessing++;\n          }\n        }\n\n        if (stillProcessing === 0 || Date.now() - startTime >= timeout) {\n          resolve({ completed });\n          return;\n        }\n\n        setTimeout(check, 10);\n      };\n\n      check();\