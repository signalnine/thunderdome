+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JnqXUcqFpPs3Joumt4JMcH","type":"tool_result","content":"     1→CREATE TABLE IF NOT EXISTS documents (\n     2→  id TEXT PRIMARY KEY,\n     3→  title TEXT NOT NULL,\n     4→  content TEXT NOT NULL DEFAULT '',\n     5→  created_at TEXT NOT NULL DEFAULT (datetime('now')),\n     6→  updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n     7→);\n     8→\n     9→CREATE TABLE IF NOT EXISTS versions (\n    10→  id INTEGER PRIMARY KEY AUTOINCREMENT,\n    11→  document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,\n    12→  version INTEGER NOT NULL,\n    13→  content TEXT NOT NULL,\n    14→  operation TEXT, -- JSON of the operation that produced this version\n    15→  created_at TEXT NOT NULL DEFAULT (datetime('now')),\n    16→  UNIQUE(document_id, version)\n    17→);\n    18→\n    19→CREATE TABLE IF NOT EXISTS active_connections (\n    20→  id TEXT PRIMARY KEY,\n    21→  document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,\n    22→  connected_at TEXT NOT NULL DEFAULT (datetime('now'))\n    23→);\n    24→"}]},"parent_tool_use_id":"toolu_01V9wDDiV54Ew6ftGADTKNLK","session_id":"c5cd2e3b-afd8-4a2b-9b23-7c1c003eb530","uuid":"96f38fde-c437-495a-b008-a6220dd309ca"}
