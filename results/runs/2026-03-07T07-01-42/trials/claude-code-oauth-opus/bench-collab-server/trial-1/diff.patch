@@ -0,0 +1,68 @@
+import express from 'express';
+import { createServer, Server } from 'http';
+import { createDatabase, DocumentStore } from './database.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './websocket.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath || ':memory:');
+  const store = new DocumentStore(db);
+
+  const app = express();
+  app.use(express.json());
+
+  // REST API routes
+  const router = createRouter(store);
+  app.use('/api', router);
+  // Also mount at root for convenience
+  app.use(router);
+
+  let httpServer: Server | null = null;
+  let collaborationServer: CollaborationServer | null = null;
+
+  const start = async (port: number = 0): Promise<number> => {
+    return new Promise((resolve, reject) => {
+      httpServer = createServer(app);
+      collaborationServer = new CollaborationServer(httpServer, store);
+
+      httpServer.on('error', reject);
+
+      httpServer.listen(port, () => {
+        const addr = httpServer!.address();
+        if (typeof addr === 'object' && addr !== null) {
+          resolve(addr.port);
+        } else {
+          resolve(port);
+        }
+      });
+    });
+  };
+
+  const stop = async (): Promise<void> => {
+    return new Promise((resolve) => {
+      if (collaborationServer) {
+        collaborationServer.closeAll();
+      }
+
+      if (httpServer) {
+        httpServer.close(() => {
+          db.close();
+          resolve();
+        });
+      } else {
+        db.close();
+        resolve();
+      }
+    });
+  };
+
+  return { app, start, stop };
+}
+
+export default createApp;
