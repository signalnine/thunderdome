documents/${docId}`);\n      const messages: Record<string, unknown>[] = [];\n      const waiters: Array<(msg: Record<string, unknown>) => void> = [];\n\n      ws.on('message', (data) => {\n        const msg = JSON.parse(data.toString());\n        if (waiters.length > 0) {\n          const waiter = waiters.shift()!;\n          waiter(msg);\n        } else {\n          messages.push(msg);\n        }\n      });\n\n      const waitForMessage = (): Promise<Record<string, unknown>> => {\n        if (messages.length > 0) {\n          return Promise.resolve(messages.shift()!);\n        }\n        return new Promise((resolve) => {\n          waiters.push(resolve);\n        });\n      };\n\n      ws.on('open', () => resolve({ ws, messages, waitForMessage }));\n      ws.on('error', reject);\n    });\n  }\n\n  async function createDoc(title: string, content: string = ''): Promise<string> {\n    const res = await request(app.app)\n      .post('/documents')\n      .send({ title, content });\n    return res.body.id;\n  }\n\n  describe('Connection Lifecycle', () => {\n    it('should receive sync message on connect', async () => {\n      const docId = await createDoc('WS Test', 'Hello');\n      const ws = await connectToDoc(docId);\n      const msg = await waitForMessage(ws);\n\n      expect(msg.type).toBe('sync');\n      expect(msg.document).toBeDefined();\n      const doc = msg.document as Record<string, unknown>;\n      expect(doc.id).toBe(docId);\n      expect(doc.content).toBe('Hello');\n      expect(typeof doc.version).toBe('number');\n      expect(msg.clientId).toBeDefined();\n\n      ws.close();\n    });\n\n    it('should reject connection to non-existent document', async () => {\n      return new Promise<void>((resolve) => {\n        const ws = new WebSocket(`${baseUrl}/documents/fake-id`);\n        ws.on('message', (data) => {\n          const msg = JSON.parse(data.toString());\n          if (msg.type === 'error') {\n            ws.close();\n            resolve();\n          }\n        });\n        ws.on('close', () => resolve());\n      });\n    });\n\n    it('should reject connection to invalid URL', async () => {\n      return new Promise<void>((resolve) => {\n        const ws = new WebSocket(`${baseUrl}/invalid`);\n        ws.on('message', (data) => {\n          const msg = JSON.parse(data.toString());\n          if (msg.type === 'error') {\n            ws.close();\n            resolve();\n          }\n        });\n        ws.on('close', () => resolve());\n      });\n    });\n  });\n\n  describe('Single Client Editing', () => {\n    let docId: string;\n\n    beforeEach(async () => {\n      docId = await createDoc('Edit Test', 'Hello');\n    });\n\n    it('should apply an insert operation and receive ack', async () => {\n      const ws = await connectToDoc(docId);\n      const syncMsg = await waitForMessage(ws);\n      const version = (syncMsg.document as Record<string, unknown>).version as number;\n\n      const op: Operation = [{ retain: 5 }, { insert: ' World' }];\n      const ackPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({ type: 'operation', operation: op, version }));\n\n      const ack = await ackPromise;\n      expect(ack.type).toBe('ack');\n      expect(ack.version).toBe(version + 1);\n\n      // Verify via REST\n      const res = await request(app.app).get(`/documents/${docId}`);\n      expect(res.body.content).toBe('Hello World');\n\n      ws.close();\n    });\n\n    it('should apply a delete operation', async () => {\n      const ws = await connectToDoc(docId);\n      const syncMsg = await waitForMessage(ws);\n      const version = (syncMsg.document as Record<string, unknown>).version as number;\n\n      const op: Operation = [{ retain: 3 }, { delete: 2 }];\n      const ackPromise = waitForMessage(ws);\n      ws.send(JSON.stringify({ type: 'operation', operation: op, version }));\n\n      const ack = await ackPromise;\n      expect(ack.type).toBe('ack');\n\n      const res = await request(app.app).get(