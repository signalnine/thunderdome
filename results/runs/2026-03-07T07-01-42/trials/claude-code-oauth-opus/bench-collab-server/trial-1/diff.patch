+    });
+
+    it('should apply insert at beginning', () => {
+      const doc = 'world';
+      const op: Operation = [{ insert: 'hello ' }, { retain: 5 }];
+      expect(apply(doc, op)).toBe('hello world');
+    });
+
+    it('should apply a complex operation', () => {
+      const doc = 'abcdef';
+      const op: Operation = [
+        { retain: 2 },
+        { delete: 2 },
+        { insert: 'XY' },
+        { retain: 2 },
+      ];
+      expect(apply(doc, op)).toBe('abXYef');
+    });
+
+    it('should throw on length mismatch', () => {
+      const doc = 'hello';
+      const op: Operation = [{ retain: 10 }];
+      expect(() => apply(doc, op)).toThrow();
+    });
+
+    it('should apply empty operation to empty doc', () => {
+      expect(apply('', [])).toBe('');
+    });
+
+    it('should apply insert to empty doc', () => {
+      expect(apply('', [{ insert: 'hello' }])).toBe('hello');
+    });
+  });
+
+  describe('transform', () => {
+    it('should transform two inserts at the same position', () => {
+      // Both insert at position 0 of "abc"
+      const op1: Operation = [{ insert: 'X' }, { retain: 3 }];
+      const op2: Operation = [{ insert: 'Y' }, { retain: 3 }];
+      const [op1Prime, op2Prime] = transform(op1, op2);
+
+      // Apply A then B'
+      const result1 = apply(apply('abc', op1), op2Prime);
+      // Apply B then A'
+      const result2 = apply(apply('abc', op2), op1Prime);
+
+      expect(result1).toBe(result2);
+      // Both insertions should be preserved
+      expect(result1).toContain('X');
+      expect(result1).toContain('Y');
+    });
+
+    it('should transform insert and delete', () => {
+      const doc = 'abcde';
+      // op1 inserts 'X' at position 2
+      const op1: Operation = [{ retain: 2 }, { insert: 'X' }, { retain: 3 }];
+      // op2 deletes 'c' at position 2
+      const op2: Operation = [{ retain: 2 }, { delete: 1 }, { retain: 2 }];
+      const [op1Prime, op2Prime] = transform(op1, op2);
+
+      const result1 = apply(apply(doc, op1), op2Prime);
+      const result2 = apply(apply(doc, op2), op1Prime);
+
+      expect(result1).toBe(result2);
+    });
+
+    it('should transform two deletes at the same position', () => {
+      const doc = 'abcde';
+      // Both delete 'c' at position 2
+      const op1: Operation = [{ retain: 2 }, { delete: 1 }, { retain: 2 }];
+      const op2: Operation = [{ retain: 2 }, { delete: 1 }, { retain: 2 }];
+      const [op1Prime, op2Prime] = transform(op1, op2);
+
+      const result1 = apply(apply(doc, op1), op2Prime);
+      const result2 = apply(apply(doc, op2), op1Prime);
+
+      expect(result1).toBe(result2);
+      expect(result1).toBe('abde');
+    });
+
+    it('should handle identity transforms', () => {
+      const doc = 'hello';
+      const op1: Operation = [{ retain: 5 }];
+      const op2: Operation = [{ retain: 5 }];
+      const [op1Prime, op2Prime] = transform(op1, op2);
+
+      const result1 = apply(apply(doc, op1), op2Prime);
+      const result2 = apply(apply(doc, op2), op1Prime);
+
+      expect(result1).toBe(result2);
+      expect(result1).toBe('hello');
+    });
+
+    it('should transform inserts at different positions', () => {
+      const doc = 'abcde';
+      const op1: Operation = [{ retain: 1 }, { insert: 'X' }, { retain: 4 }];
+      const op2: Operation = [{ retain: 3 }, { insert: 'Y' }, { retain: 2 }];
+      const [op1Prime, op2Prime] = transform(op1, op2);
+
+      const result1 = apply(apply(doc, op1), op2Prime);
+      const result2 = apply(apply(doc, op2), op1Prime);
+
+      expect(result1).toBe(result2);
+      expect(result1).toBe('aXbcYde');
+    });
+  });
+
+  describe('compose', () => {
+    it('should compose two sequential operations', () => {
+      const doc = 'hello';
+      const op1: Operation = [{ retain: 5 }, { insert: ' world' }];
+      const op2: Operation = [{ retain: 11 }, { insert: '!' }];
+
+      const composed = compose(op1, op2);
+      const result1 = apply(apply(doc, op1), op2);
+      const result2 = apply(doc, composed);
+
+      expect(result1).toBe(result2);
+      expect(result1).toBe('hello world!');
+    });
+  });
+
+  describe('validateOperation', () => {
+    it('should accept valid operations', () => {
+      expect(validateOperation([{ retain: 5 }], 5)).toBeNull();
+      expect(validateOperation([{ insert: 'hello' }], 0)).toBeNull();
+      expect(validateOperation([{ delete: 3 }], 3)).toBeNull();
+    });
+
+    it('should reject non-array operations', () => {
+      expect(validateOperation('not an array' as unknown as Operation, 0)).not.toBeNull();
+    });
+
+    it('should reject wrong length', () => {
+      expect(validateOperation([{ retain: 10 }], 5)).not.toBeNull();
+    });
+
+    it('should reject invalid components', () => {
+      expect(validateOperation([{ retain: -1 }], 0)).not.toBeNull();
+      expect(validateOperation([{ delete: 0 }], 0)).not.toBeNull();
+    });
+  });
+
+  describe('helpers', () => {
+    it('makeInsert creates correct operation', () => {
+      const op = makeInsert(3, 'XYZ', 5);
+      expect(apply('abcde', op)).toBe('abcXYZde');
+    });
+
+    it('makeDelete creates correct operation', () => {
+      const op = makeDelete(2, 2, 5);
+      expect(apply('abcde', op)).toBe('abe');
+    });
+
+    it('inputLength calculates correctly', () => {
+      const op: Operation = [{ retain: 3 }, { insert: 'abc' }, { delete: 2 }];
+      expect(inputLength(op)).toBe(5);
+    });
+
+    it('outputLength calculates correctly', () => {
+      const op: Operation = [{ retain: 3 }, { insert: 'abc' }, { delete: 2 }];
+      expect(outputLength(op)).toBe(6);
+    });
+  });
+});
