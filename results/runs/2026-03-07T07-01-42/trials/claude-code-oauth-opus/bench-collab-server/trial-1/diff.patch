+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01BCxDevFZeqMz9tcaGYcNzR","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013nkJUaDWpRQAU213gnrntS","name":"Write","input":{"file_path":"/workspace/src/websocket.ts","content":"import { WebSocketServer, WebSocket } from 'ws';\nimport { IncomingMessage } from 'http';\nimport { Server } from 'http';\nimport { randomUUID } from 'crypto';\nimport { DocumentStore } from './database.js';\nimport {\n  Operation,\n  apply,\n  transform,\n  validateOperation,\n} from './ot.js';\n\ninterface ClientConnection {\n  id: string;\n  ws: WebSocket;\n  documentId: string;\n}\n\ninterface DocumentState {\n  content: string;\n  version: number;\n  clients: Map<string, ClientConnection>;\n}\n\ninterface OperationMessage {\n  type: 'operation';\n  operation: Operation;\n  version: number;\n}\n\ninterface CursorMessage {\n  type: 'cursor';\n  position: number;\n}\n\ntype ClientMessage = OperationMessage | CursorMessage;\n\nexport class CollaborationServer {\n  private wss: WebSocketServer;\n  private store: DocumentStore;\n  private documents: Map<string, DocumentState> = new Map();\n\n  constructor(server: Server, store: DocumentStore) {\n    this.store = store;\n    this.wss = new WebSocketServer({ server });\n\n    this.wss.on('connection', (ws: WebSocket, req: IncomingMessage) => {\n      this.handleConnection(ws, req);\n    });\n  }\n\n  private getDocumentState(documentId: string): DocumentState | null {\n    // Check in-memory cache first\n    let state = this.documents.get(documentId);\n    if (state) return state;\n\n    // Load from database\n    const doc = this.store.getDocument(documentId);\n    if (!doc) return null;\n\n    const version = this.store.getLatestVersion(documentId);\n\n    state = {\n      content: doc.content,\n      version,\n      clients: new Map(),\n    };\n    this.documents.set(documentId, state);\n    return state;\n  }\n\n  private handleConnection(ws: WebSocket, req: IncomingMessage): void {\n    // Extract document ID from URL path: /documents/:id or /ws/documents/:id\n    const url = req.url || '';\n    const match = url.match(/\\/(?:ws\\/)?documents\\/([^/?]+)/);\n\n    if (!match) {\n      ws.send(JSON.stringify({ type: 'error', message: 'Invalid URL. Connect to /documents/:id' }));\n      ws.close(1008, 'Invalid URL');\n      return;\n    }\n\n    const documentId = match[1];\n    const state = this.getDocumentState(documentId);\n\n    if (!state) {\n      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));\n      ws.close(1008, 'Document not found');\n      return;\n    }\n\n    const clientId = randomUUID();\n    const client: ClientConnection = { id: clientId, ws, documentId };\n\n    state.clients.set(clientId, client);\n\n    // Send sync message with current document state\n    ws.send(JSON.stringify({\n      type: 'sync',\n      document: {\n        id: documentId,\n        content: state.content,\n        version: state.version,\n      },\n      clientId,\n    }));\n\n    ws.on('message', (data) => {\n      try {\n        const raw = data.toString();\n        let message: ClientMessage;\n        try {\n          message = JSON.parse(raw);\n        } catch {\n          ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));\n          return;\n        }\n\n        this.handleMessage(client, state, message);\n      } catch (err) {\n        const errorMsg = err instanceof Error ? err.message : 'Unknown error';\n        ws.send(JSON.stringify({ type: 'error', message: errorMsg }));\n      }\n    });\n\n    ws.on('close', () => {\n      state.clients.delete(clientId);\n      // Clean up document state if no clients are connected\n      if (state.clients.size === 0) {\n        // Persist final content to DB before removing from memory\n        this.store.updateContent(documentId, state.content);\n        this.documents.delete(documentId);\n      }\n    });\n\n    ws.on('error', () => {\n      state.clients.delete(clientId);\n    });\n  }\n\n  private handleMessage(client: ClientConnection, state: DocumentState, message: ClientMessage): void {\n    if (message.type === 'operation') {\n      this.handleOperation(client, state, message);\n    }\n    // Silently ignore other message types (like cursor)\n  }\n\n  private handleOperation(client: ClientConnection, state: DocumentState, message: OperationMessage): void {\n    const { operation, version } = message;\n\n    // Validate the operation format\n    if (!Array.isArray(operation)) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: 'Operation must be an array',\n      }));\n      return;\n    }\n\n    if (typeof version !== 'number' || version < 0) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: 'Version must be a non-negative number',\n      }));\n      return;\n    }\n\n    if (version > state.version) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: `Client version ${version} is ahead of server version ${state.version}`,\n      }));\n      return;\n    }\n\n    // Get operations that happened since the client's version\n    let transformedOp = operation;\n\n    if (version < state.version) {\n      // Need to transform against operations that happened since client's version\n      const versions = this.store.getVersions(client.documentId);\n      const missedVersions = versions.filter(v => v.version > version && v.version <= state.version);\n\n      for (const v of missedVersions) {\n        if (v.operation) {\n          const serverOp: Operation = JSON.parse(v.operation);\n          const [transformedClient] = transform(transformedOp, serverOp);\n          transformedOp = transformedClient;\n        }\n      }\n    }\n\n    // Validate the transformed operation against the current document\n    const validationError = validateOperation(transformedOp, state.content.length);\n    if (validationError) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: validationError,\n      }));\n      return;\n    }\n\n    // Apply the operation\n    try {\n      const newContent = apply(state.content, transformedOp);\n      state.version++;\n      state.content = newContent;\n\n      // Persist to database\n      this.store.updateContent(client.documentId, newContent);\n      this.store.createVersion(\n        client.documentId,\n        state.version,\n        newContent,\n        JSON.stringify(transformedOp)\n      );\n\n      // Acknowledge to the sender\n      client.ws.send(JSON.stringify({\n        type: 'ack',\n        version: state.version,\n      }));\n\n      // Broadcast to other clients\n      for (const [id, otherClient] of state.clients) {\n        if (id !== client.id && otherClient.ws.readyState === WebSocket.OPEN) {\n          otherClient.ws.send(JSON.stringify({\n            type: 'operation',\n            operation: transformedOp,\n            version: state.version,\n            clientId: client.id,\n          }));\n        }\n      }\n    } catch (err) {\n      const errorMsg = err instanceof Error ? err.message : 'Failed to apply operation';\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: errorMsg,\n      }));\n    }\n  }\n\n  closeAll(): void {\n    // Close all WebSocket connections\n    for (const [, state] of this.documents) {\n      for (const [, client] of state.clients) {\n        client.ws.close(1001, 'Server shutting down');\n      }\n    }\n    this.wss.close();\n  }\n\n  getConnectedClients(documentId: string): number {\n    const state = this.documents.get(documentId);\n    return state ? state.clients.size : 0;\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":327,"cache_read_input_tokens":29565,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":32