+import { describe, it, expect, afterEach } from 'vitest';
+import { unlinkSync, existsSync } from 'fs';
+import request from 'supertest';
+import { createApp, AppInstance } from '../src/server.js';
+
+const TEST_DB = '/tmp/test-persistence.db';
+
+describe('Persistence', () => {
+  let app: AppInstance;
+
+  afterEach(async () => {
+    if (app) {
+      await app.stop();
+    }
+    // Clean up test database
+    try {
+      if (existsSync(TEST_DB)) unlinkSync(TEST_DB);
+      if (existsSync(TEST_DB + '-wal')) unlinkSync(TEST_DB + '-wal');
+      if (existsSync(TEST_DB + '-shm')) unlinkSync(TEST_DB + '-shm');
+    } catch {
+      // ignore
+    }
+  });
+
+  it('should persist documents across restarts', async () => {
+    // Create first server instance and add a document
+    app = createApp(TEST_DB);
+    await app.start(0);
+
+    const createRes = await request(app.app)
+      .post('/documents')
+      .send({ title: 'Persistent Doc', content: 'Persisted content' });
+    const docId = createRes.body.id;
+    expect(createRes.status).toBe(201);
+
+    // Stop the server
+    await app.stop();
+
+    // Create new server instance with same DB
+    app = createApp(TEST_DB);
+    await app.start(0);
+
+    // Document should still exist
+    const getRes = await request(app.app).get(`/documents/${docId}`);
+    expect(getRes.status).toBe(200);
+    expect(getRes.body.title).toBe('Persistent Doc');
+    expect(getRes.body.content).toBe('Persisted content');
+  });
+
+  it('should persist version history across restarts', async () => {
+    app = createApp(TEST_DB);
+    await app.start(0);
+
+    const createRes = await request(app.app)
+      .post('/documents')
+      .send({ title: 'Versioned', content: 'v0' });
+    const docId = createRes.body.id;
+
+    await app.stop();
+
+    app = createApp(TEST_DB);
+    await app.start(0);
+
+    const versionsRes = await request(app.app)
+      .get(`/documents/${docId}/versions`);
+    expect(versionsRes.status).toBe(200);
+    expect(versionsRes.body.length).toBeGreaterThanOrEqual(1);
+  });
+});
diff --git a/tests/websocket.test.ts b/tests/websocket.test.ts
new file mode 100644
index 0000000..0cf3286
--- /dev/null
+++ b/tests/websocket.test.ts
@@ -0,0 +1,410 @@
+import { describe, it, expect, beforeAll, afterAll, beforeEach } from 'vitest';
+import request from 'supertest';
+import WebSocket from 'ws';
+import { createApp, AppInstance } from '../src/server.js';
+import { Operation } from '../src/ot.js';
+
+interface ClientHelper {
+  ws: WebSocket;
+  waitForMessage: () => Promise<Record<string, unknown>>;
+}
+
+function createClientHelper(ws: WebSocket): ClientHelper {
+  const messages: Record<string, unknown>[] = [];
+  const waiters: Array<(msg: Record<string, unknown>) => void> = [];
+
+  ws.on('message', (data) => {
+    const msg = JSON.parse(data.toString());
+    if (waiters.length > 0) {
+      const waiter = waiters.shift()!;
+      waiter(msg);
+    } else {
+      messages.push(msg);
+    }
+  });
+
+  const waitForMessage = (): Promise<Record<string, unknown>> => {
+    if (messages.length > 0) {
+      return Promise.resolve(messages.shift()!);
+    }
+    return new Promise((resolve) => {
+      waiters.push(resolve);
+    });
+  };
+
+  return { ws, waitForMessage };
+}
+
+describe('WebSocket Collaboration', () => {
+  let app: AppInstance;
+  let port: number;
+  let baseUrl: string;
+
+  beforeAll(async () => {
+    app = createApp();
+    port = await app.start(0);
+    baseUrl = `ws://localhost:${port}`;
+  });
+
+  afterAll(async () => {
+    await app.stop();
+  });
+
+  function connectToDoc(docId: string): Promise<ClientHelper> {
+    return new Promise((resolve, reject) => {
+      const ws = new WebSocket(`${baseUrl}/documents/${docId}`);
+      const helper = createClientHelper(ws);
+      ws.on('open', () => resolve(helper));
+      ws.on('error', reject);
+    });
+  }
+
+  async function createDoc(title: string, content: string = ''): Promise<string> {
+    const res = await request(app.app)
+      .post('/documents')
+      .send({ title, content });
+    return res.body.id;
+  }
+
+  describe('Connection Lifecycle', () => {
+    it('should receive sync message on connect', async () => {
+      const docId = await createDoc('WS Test', 'Hello');
+      const client = await connectToDoc(docId);
+      const msg = await client.waitForMessage();
+
+      expect(msg.type).toBe('sync');
+      expect(msg.document).toBeDefined();
+      const doc = msg.document as Record<string, unknown>;
+      expect(doc.id).toBe(docId);
+      expect(doc.content).toBe('Hello');
+      expect(typeof doc.version).toBe('number');
+      expect(msg.clientId).toBeDefined();
+
+      client.ws.close();
+    });
+
+    it('should reject connection to non-existent document', async () => {
+      return new Promise<void>((resolve) => {
+        const ws = new WebSocket(`${baseUrl}/documents/fake-id`);
+        ws.on('message', (data) => {
+          const msg = JSON.parse(data.toString());
+          if (msg.type === 'error') {
+            ws.close();
+            resolve();
+          }
+        });
+        ws.on('close', () => resolve());
+      });
+    });
+
+    it('should reject connection to invalid URL', async () => {
+      return new Promise<void>((resolve) => {
+        const ws = new WebSocket(`${baseUrl}/invalid`);
+        ws.on('message', (data) => {
+          const msg = JSON.parse(data.toString());
+          if (msg.type === 'error') {
+            ws.close();
+            resolve();
+          }
+        });
+        ws.on('close', () => resolve());
+      });
+    });
+  });
+
+  describe('Single Client Editing', () => {
+    let docId: string;
+
+    beforeEach(async () => {
+      docId = await createDoc('Edit Test', 'Hello');
+    });
+
+    it('should apply an insert operation and receive ack', async () => {
+      const client = await connectToDoc(docId);
+      const syncMsg = await client.waitForMessage();
+      const version = (syncMsg.document as Record<string, unknown>).version as number;
+
+      const op: Operation = [{ retain: 5 }, { insert: ' World' }];
+      client.ws.send(JSON.stringify({ type: 'operation', operation: op, version }));
+
+      const ack = await client.waitForMessage();
+      expect(ack.type).toBe('ack');
+      expect(ack.version).toBe(version + 1);
+
+      // Verify via REST
+      const res = await request(app.app).get(`/documents/${docId}`);
+      expect(res.body.content).toBe('Hello World');
+
+      client.ws.close();
+    });
+
+    it('should apply a delete operation', async () => {
+      const client = await connectToDoc(docId);
+      const syncMsg = await client.waitForMessage();
+      const version = (syncMsg.document as Record<string, unknown>).version as number;
+
+      const op: Operation = [{ retain: 3 }, { delete: 2 }];
+      client.ws.send(JSON.stringify({ type: 'operation', operation: op, version }));
+
+      const ack = await client.waitForMessage();
+      expect(ack.type).toBe('ack');
+
+      const res = await request(app.app).get(`/documents/${docId}`);
+      expect(res.body.content).toBe('Hel');
+
+      client.ws.close();
+    });
+
+    it('should apply multiple sequential operations', async () => {
+      const client = await connectToDoc(docId);
+      const syncMsg = await client.waitForMessage();
+      let version = (syncMsg.document as Record<string, unknown>).version as number;
+
+      // Insert " World"
+      const op1: Operation = [{ retain: 5 }, { insert: ' World' }];
+      client.ws.send(JSON.stringify({ type: 'operation', operation: op1, version }));
+      const ack1 = await client.waitForMessage();
+      expect(ack1.type).toBe('ack');
+      version = ack1.version as number;
+
+      // Insert "!" at end (now doc is "Hello World", length 11)
+      const op2: Operation = [{ retain: 11 }, { insert: '!' }];
+      client.ws.send(JSON.stringify({ type: 'operation', operation: op2, version }));
+      const ack2 = await client.waitForMessage();
+      expect(ack2.type).toBe('ack');
+
+      const res = await request(app.app).get(`/documents/${docId}`);
+      expect(res.body.content).toBe('Hello World!');
+
+      client.ws.close();
+    });
+  });
+
+  describe('Multi-Client Broadcasting', () => {
+    it('should broadcast operations to other clients', async () => {
+      const docId = await createDoc('Broadcast Test', 'Hello');
+
+      const client1 = await connectToDoc(docId);
+      const sync1 = await client1.waitForMessage();
+      const version = (sync1.document as Record<string, unknown>).version as number;
+
+      const client2 = await connectToDoc(docId);
+      await client2.waitForMessage(); // sync message
+
+      // Client 1 sends an operation
+      const op: Operation = [{ retain: 5 }, { insert: ' World' }];
+      client1.ws.send(JSON.stringify({ type: 'operation', operation: op, version }));
+
+      // Client 1 should get ack
+      const ack = await client1.waitForMessage();
+      expect(ack.type).toBe('ack');
+
+      // Client 2 should get the operation
+      const broadcast = await client2.waitForMessage();
+      expect(broadcast.type).toBe('operation');
+      expect(broadcast.operation).toBeDefined();
+      expect(broadcast.version).toBeDefined();
+
+      client1.ws.close();
+      client2.ws.close();
+    });
+
+    it('should handle concurrent edits from two clients', async () => {
+      const docId = await createDoc('Concurrent Test', 'abcde');
+
+      const client1 = await connectToDoc(docId);
+      const sync1 = await client1.waitForMessage();
+      const version1 = (sync1.document as Record<string, unknown>).version as number;
+
+      const client2 = await connectToDoc(docId);
+      const sync2 = await client2.waitForMessage();
+      const version2 = (sync2.document as Record<string, unknown>).version as number;
+
+      expect(version1).toBe(version2);
+
+      // Client 1 inserts 'X' at position 1
+      const op1: Operation = [{ retain: 1 }, { insert: 'X' }, { retain: 4 }];
+      client1.ws.send(JSON.stringify({ type: 'operation', operation: op1, version: version1 }));
+
+      // Wait for ack and broadcast
+      const ack1 = await client1.waitForMessage();
+      expect(ack1.type).toBe('ack');
+
+      const broadcast1 = await client2.waitForMessage();
+      expect(broadcast1.type).toBe('operation');
+
+      // Client 2 inserts 'Y' at position 3 (using the version it synced with)
+      // Server has already applied op1, so this will be transformed
+      const op2: Operation = [{ retain: 3 }, { insert: 'Y' }, { retain: 2 }];
+      client2.ws.send(JSON.stringify({ type: 'operation', operation: op2, version: version2 }));
+
+      const ack2 = await client2.waitForMessage();
+      expect(ack2.type).toBe('ack');
+
+      // Verify final content via REST
+      const res = await request(app.app).get(`/documents/${docId}`);
+      expect(res.body.content).toContain('X');
+      expect(res.body.content).toContain('Y');
+
+      client1.ws.close();
+      client2.ws.close();
+    });
+  });
+
+  describe('Error Handling', () => {
+    it('should handle invalid JSON', async () => {
+      const docId = await createDoc('Error Test', 'Hello');
+      const client = await connectToDoc(docId);
+      await client.waitForMessage(); // sync
+
+      client.ws.send('not json');
+      const error = await client.waitForMessage();
+      expect(error.type).toBe('error');
+
+      client.ws.close();
+    });
+
+    it('should handle invalid operation', async () => {
+      const docId = await createDoc('Error Test 2', 'Hello');
+      const client = await connectToDoc(docId);
+      const syncMsg = await client.waitForMessage();
+      const version = (syncMsg.document as Record<string, unknown>).version as number;
+
+      // Operation with wrong length
+      client.ws.send(JSON.stringify({
+        type: 'operation',
+        operation: [{ retain: 100 }],
+        version,
+      }));
+
+      const error = await client.waitForMessage();
+      expect(error.type).toBe('error');
+
+      client.ws.close();
+    });
+
+    it('should handle future version number', async () => {
+      const docId = await createDoc('Error Test 3', 'Hello');
+      const client = await connectToDoc(docId);
+      await client.waitForMessage(); // sync
+
+      client.ws.send(JSON.stringify({
+        type: 'operation',
+        operation: [{ retain: 5 }],
+        version: 999,
+      }));
+
+      const error = await client.waitForMessage();
+      expect(error.type).toBe('error');
+
+      client.ws.close();
+    });
+  });
+
+  describe('Version History', () => {
+    it('should track versions as edits are made', async () => {
+      const docId = await createDoc('Version Test', 'Hello');
+      const client = await connectToDoc(docId);
+      const syncMsg = await client.waitForMessage();
+      let version = (syncMsg.document as Record<string, unknown>).version as number;
+
+      // Make some edits
+      const op1: Operation = [{ retain: 5 }, { insert: ' World' }];
+      client.ws.send(JSON.stringify({ type: 'operation', operation: op1, version }));
+      const ack1 = await client.waitForMessage();
+      version = ack1.version as number;
+
+      const op2: Operation = [{ retain: 11 }, { insert: '!' }];
+      client.ws.send(JSON.stringify({ type: 'operation', operation: op2, version }));
+      await client.waitForMessage();
+
+      client.ws.close();
+
+      // Check versions via REST
+      const res = await request(app.app).get(`/documents/${docId}/versions`);
+      expect(res.body.length).toBeGreaterThanOrEqual(3); // initial + 2 edits
+    });
+  });
+});
+
+describe('Stress Test', () => {
+  let app: AppInstance;
+  let port: number;
+
+  beforeAll(async () => {
+    app = createApp();
+    port = await app.start(0);
+  });
+
+  afterAll(async () => {
+    await app.stop();
+  });
+
+  it('should handle 10 concurrent clients without corruption', async () => {
+    // Create a document
+    const res = await request(app.app)
+      .post('/documents')
+      .send({ title: 'Stress Test', content: '' });
+    const docId = res.body.id;
+
+    const NUM_CLIENTS = 10;
+    const clients: ClientHelper[] = [];
+
+    // Connect all clients and get their sync messages
+    for (let i = 0; i < NUM_CLIENTS; i++) {
+      const client = await new Promise<ClientHelper>((resolve, reject) => {
+        const ws = new WebSocket(`ws://localhost:${port}/documents/${docId}`);
+        const helper = createClientHelper(ws);
+        ws.on('open', () => resolve(helper));
+        ws.on('error', reject);
+      });
+
+      const syncData = await client.waitForMessage();
+      const version = (syncData.document as Record<string, unknown>).version as number;
+      (client as ClientHelper & { version: number }).version = version;
+      clients.push(client);
+    }
+
+    // Each client sends one insert concurrently
+    const promises: Promise<void>[] = [];
+    for (let i = 0; i < NUM_CLIENTS; i++) {
+      const client = clients[i] as ClientHelper & { version: number };
+      promises.push((async () => {
+        const op: Operation = [{ insert: `${i}` }];
+        client.ws.send(JSON.stringify({
+          type: 'operation',
+          operation: op,
+          version: client.version,
+        }));
+
+        // Wait for ack (skip any broadcast messages)
+        let msg = await client.waitForMessage();
+        while (msg.type !== 'ack') {
+          msg = await client.waitForMessage();
+        }
+      })());
+    }
+
+    await Promise.all(promises);
+
+    // Wait for broadcasts to settle
+    await new Promise(r => setTimeout(r, 200));
+
+    // Verify document via REST
+    const docRes = await request(app.app).get(`/documents/${docId}`);
+    const content = docRes.body.content;
+
+    // All digits 0-9 should be present
+    for (let i = 0; i < NUM_CLIENTS; i++) {
+      expect(content).toContain(`${i}`);
+    }
+
+    // Content should have exactly NUM_CLIENTS characters
+    expect(content.length).toBe(NUM_CLIENTS);
+
+    // Close all clients
+    for (const client of clients) {
+      client.ws.close();
+    }
+  }, 15000);
+});
