@@ -0,0 +1,343 @@
+/**
+ * Operational Transform (OT) engine for collaborative text editing.
+ *
+ * Operations are represented as a sequence of components:
+ * - { retain: n } - skip n characters
+ * - { insert: "text" } - insert text at current position
+ * - { delete: n } - delete n characters from current position
+ *
+ * The key function is `transform(op1, op2)` which takes two concurrent
+ * operations and returns transformed versions that can be applied in
+ * either order to reach the same final state.
+ */
+
+export type OpComponent =
+  | { retain: number }
+  | { insert: string }
+  | { delete: number };
+
+export type Operation = OpComponent[];
+
+function isRetain(c: OpComponent): c is { retain: number } {
+  return 'retain' in c;
+}
+
+function isInsert(c: OpComponent): c is { insert: string } {
+  return 'insert' in c;
+}
+
+function isDelete(c: OpComponent): c is { delete: number } {
+  return 'delete' in c;
+}
+
+/** Calculate the length of the input document that an operation expects. */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (isRetain(c)) len += c.retain;
+    else if (isDelete(c)) len += c.delete;
+    // insert doesn't consume input
+  }
+  return len;
+}
+
+/** Calculate the length of the output document after applying an operation. */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (isRetain(c)) len += c.retain;
+    else if (isInsert(c)) len += c.insert.length;
+    // delete doesn't produce output
+  }
+  return len;
+}
+
+/** Apply an operation to a document string. */
+export function apply(doc: string, op: Operation): string {
+  const expectedLen = inputLength(op);
+  if (expectedLen !== doc.length) {
+    throw new Error(
+      `Operation input length (${expectedLen}) doesn't match document length (${doc.length})`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of op) {
+    if (isRetain(c)) {
+      result += doc.slice(pos, pos + c.retain);
+      pos += c.retain;
+    } else if (isInsert(c)) {
+      result += c.insert;
+    } else if (isDelete(c)) {
+      pos += c.delete;
+    }
+  }
+
+  return result;
+}
+
+/** Normalize an operation by merging adjacent same-type components and removing no-ops. */
+function normalize(op: Operation): Operation {
+  const result: Operation = [];
+
+  for (const c of op) {
+    if (isRetain(c) && c.retain === 0) continue;
+    if (isDelete(c) && c.delete === 0) continue;
+    if (isInsert(c) && c.insert === '') continue;
+
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+
+    const last = result[result.length - 1];
+    if (isRetain(c) && isRetain(last)) {
+      result[result.length - 1] = { retain: last.retain + c.retain };
+    } else if (isDelete(c) && isDelete(last)) {
+      result[result.length - 1] = { delete: last.delete + c.delete };
+    } else if (isInsert(c) && isInsert(last)) {
+      result[result.length - 1] = { insert: last.insert + c.insert };
+    } else {
+      result.push(c);
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Transform two concurrent operations so they can be applied in sequence.
+ *
+ * Given operations A and B that were both created against the same document state:
+ * - Returns [A', B'] such that apply(apply(doc, A), B') === apply(apply(doc, B), A')
+ *
+ * Convention: A has priority (its inserts come first positionally).
+ */
+export function transform(op1: Operation, op2: Operation): [Operation, Operation] {
+  const op1Prime: Operation = [];
+  const op2Prime: Operation = [];
+
+  let i1 = 0;
+  let i2 = 0;
+  let c1: OpComponent | null = op1[i1] || null;
+  let c2: OpComponent | null = op2[i2] || null;
+
+  // Track remaining amounts for partially consumed components
+  let r1 = componentLength(c1);
+  let r2 = componentLength(c2);
+
+  while (c1 !== null || c2 !== null) {
+    // Insert from op1 takes priority
+    if (c1 !== null && isInsert(c1)) {
+      const text = getInsertText(c1, r1);
+      op1Prime.push({ insert: text });
+      op2Prime.push({ retain: text.length });
+      // Advance op1
+      i1++;
+      c1 = op1[i1] || null;
+      r1 = componentLength(c1);
+      continue;
+    }
+
+    // Then insert from op2
+    if (c2 !== null && isInsert(c2)) {
+      const text = getInsertText(c2, r2);
+      op2Prime.push({ insert: text });
+      op1Prime.push({ retain: text.length });
+      // Advance op2
+      i2++;
+      c2 = op2[i2] || null;
+      r2 = componentLength(c2);
+      continue;
+    }
+
+    if (c1 === null || c2 === null) {
+      throw new Error('Operations have different base lengths');
+    }
+
+    const minLen = Math.min(r1, r2);
+
+    if (isRetain(c1) && isRetain(c2)) {
+      op1Prime.push({ retain: minLen });
+      op2Prime.push({ retain: minLen });
+    } else if (isDelete(c1) && isDelete(c2)) {
+      // Both delete the same region: nothing to emit
+    } else if (isDelete(c1) && isRetain(c2)) {
+      op1Prime.push({ delete: minLen });
+      // op2's retain is consumed by op1's delete
+    } else if (isRetain(c1) && isDelete(c2)) {
+      op2Prime.push({ delete: minLen });
+      // op1's retain is consumed by op2's delete
+    }
+
+    r1 -= minLen;
+    r2 -= minLen;
+
+    if (r1 === 0) {
+      i1++;
+      c1 = op1[i1] || null;
+      r1 = componentLength(c1);
+    }
+    if (r2 === 0) {
+      i2++;
+      c2 = op2[i2] || null;
+      r2 = componentLength(c2);
+    }
+  }
+
+  return [normalize(op1Prime), normalize(op2Prime)];
+}
+
+/**
+ * Compose two sequential operations into one.
+ * apply(apply(doc, op1), op2) === apply(doc, compose(op1, op2))
+ */
+export function compose(op1: Operation, op2: Operation): Operation {
+  const result: Operation = [];
+
+  let i1 = 0;
+  let i2 = 0;
+  let c1: OpComponent | null = op1[i1] || null;
+  let c2: OpComponent | null = op2[i2] || null;
+  let r1 = componentLength(c1);
+  let r2 = componentLength(c2);
+
+  while (c1 !== null || c2 !== null) {
+    // Delete from op1 passes through
+    if (c1 !== null && isDelete(c1)) {
+      result.push({ delete: r1 });
+      i1++;
+      c1 = op1[i1] || null;
+      r1 = componentLength(c1);
+      continue;
+    }
+
+    // Insert from op2 passes through
+    if (c2 !== null && isInsert(c2)) {
+      const text = getInsertText(c2, r2);
+      result.push({ insert: text });
+      i2++;
+      c2 = op2[i2] || null;
+      r2 = componentLength(c2);
+      continue;
+    }
+
+    if (c1 === null || c2 === null) {
+      throw new Error('Compose: operations have incompatible lengths');
+    }
+
+    const minLen = Math.min(r1, r2);
+
+    if (isRetain(c1) && isRetain(c2)) {
+      result.push({ retain: minLen });
+    } else if (isInsert(c1) && isRetain(c2)) {
+      const text = getInsertSlice(c1, r1, minLen);
+      result.push({ insert: text });
+    } else if (isInsert(c1) && isDelete(c2)) {
+      // Insert then delete cancels out
+    } else if (isRetain(c1) && isDelete(c2)) {
+      result.push({ delete: minLen });
+    }
+
+    r1 -= minLen;
+    r2 -= minLen;
+
+    if (r1 === 0) {
+      i1++;
+      c1 = op1[i1] || null;
+      r1 = componentLength(c1);
+    }
+    if (r2 === 0) {
+      i2++;
+      c2 = op2[i2] || null;
+      r2 = componentLength(c2);
+    }
+  }
+
+  return normalize(result);
+}
+
+function componentLength(c: OpComponent | null): number {
+  if (c === null) return 0;
+  if (isRetain(c)) return c.retain;
+  if (isDelete(c)) return c.delete;
+  if (isInsert(c)) return c.insert.length;
+  return 0;
+}
+
+function getInsertText(c: OpComponent, remaining: number): string {
+  if (!isInsert(c)) return '';
+  const full = c.insert;
+  // If we've partially consumed an insert, get the remaining portion
+  const start = full.length - remaining;
+  return full.slice(start);
+}
+
+function getInsertSlice(c: OpComponent, remaining: number, len: number): string {
+  if (!isInsert(c)) return '';
+  const full = c.insert;
+  const start = full.length - remaining;
+  return full.slice(start, start + len);
+}
+
+/** Validate an operation against a document length. */
+export function validateOperation(op: Operation, docLength: number): string | null {
+  if (!Array.isArray(op)) {
+    return 'Operation must be an array';
+  }
+
+  for (let i = 0; i < op.length; i++) {
+    const c = op[i];
+    if (typeof c !== 'object' || c === null) {
+      return `Component ${i} is not an object`;
+    }
+    const keys = Object.keys(c);
+    if (keys.length !== 1) {
+      return `Component ${i} must have exactly one key (retain, insert, or delete)`;
+    }
+    const key = keys[0];
+    if (key === 'retain') {
+      if (typeof (c as { retain: unknown }).retain !== 'number' || (c as { retain: number }).retain <= 0) {
+        return `Component ${i}: retain must be a positive number`;
+      }
+    } else if (key === 'insert') {
+      if (typeof (c as { insert: unknown }).insert !== 'string') {
+        return `Component ${i}: insert must be a string`;
+      }
+    } else if (key === 'delete') {
+      if (typeof (c as { delete: unknown }).delete !== 'number' || (c as { delete: number }).delete <= 0) {
+        return `Component ${i}: delete must be a positive number`;
+      }
+    } else {
+      return `Component ${i}: unknown key "${key}"`;
+    }
+  }
+
+  const inLen = inputLength(op);
+  if (inLen !== docLength) {
+    return `Operation input length (${inLen}) doesn't match document length (${docLength})`;
+  }
+
+  return null;
+}
+
+/** Create a simple insert operation at a given position in a document of given length. */
+export function makeInsert(pos: number, text: string, docLength: number): Operation {
+  const op: Operation = [];
+  if (pos > 0) op.push({ retain: pos });
+  op.push({ insert: text });
+  if (pos < docLength) op.push({ retain: docLength - pos });
+  return op;
+}
+
+/** Create a simple delete operation at a given position in a document of given length. */
+export function makeDelete(pos: number, count: number, docLength: number): Operation {
+  const op: Operation = [];
+  if (pos > 0) op.push({ retain: pos });
+  op.push({ delete: count });
+  const remaining = docLength - pos - count;
+  if (remaining > 0) op.push({ retain: remaining });
+  return op;
+}
