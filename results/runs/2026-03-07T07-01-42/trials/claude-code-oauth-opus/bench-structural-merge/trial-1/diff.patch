+++ b/src/index.test.ts
@@ -0,0 +1,397 @@
+import { describe, it, expect, beforeEach } from "vitest";
+import { DocumentStore } from "./index";
+
+describe("DocumentStore", () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  // ── CRUD ──────────────────────────────────────────────────────────
+
+  describe("CRUD operations", () => {
+    it("creates and retrieves a document", () => {
+      store.create("doc1", { name: "test" });
+      expect(store.get("doc1")).toEqual({ name: "test" });
+    });
+
+    it("throws when creating a duplicate document", () => {
+      store.create("doc1", { a: 1 });
+      expect(() => store.create("doc1", { a: 2 })).toThrow();
+    });
+
+    it("throws when getting a non-existent document", () => {
+      expect(() => store.get("nope")).toThrow();
+    });
+
+    it("updates a document", () => {
+      store.create("doc1", { v: 1 });
+      store.update("doc1", { v: 2 });
+      expect(store.get("doc1")).toEqual({ v: 2 });
+    });
+
+    it("throws when updating a non-existent document", () => {
+      expect(() => store.update("nope", { v: 1 })).toThrow();
+    });
+
+    it("deletes a document", () => {
+      store.create("doc1", { v: 1 });
+      store.delete("doc1");
+      expect(() => store.get("doc1")).toThrow();
+    });
+
+    it("throws when deleting a non-existent document", () => {
+      expect(() => store.delete("nope")).toThrow();
+    });
+
+    it("throws when deleting an already-deleted document", () => {
+      store.create("doc1", { v: 1 });
+      store.delete("doc1");
+      expect(() => store.delete("doc1")).toThrow();
+    });
+
+    it("deep clones on create so mutations don't affect store", () => {
+      const obj = { nested: { val: 1 } };
+      store.create("doc1", obj);
+      obj.nested.val = 999;
+      expect(store.get("doc1")).toEqual({ nested: { val: 1 } });
+    });
+
+    it("deep clones on get so mutations don't affect store", () => {
+      store.create("doc1", { nested: { val: 1 } });
+      const result = store.get("doc1") as { nested: { val: number } };
+      result.nested.val = 999;
+      expect(store.get("doc1")).toEqual({ nested: { val: 1 } });
+    });
+  });
+
+  // ── Version History ───────────────────────────────────────────────
+
+  describe("Version history", () => {
+    it("creates a version on create", () => {
+      store.create("doc1", { v: 1 });
+      const history = store.getHistory("doc1");
+      expect(history).toHaveLength(1);
+      expect(history[0].content).toEqual({ v: 1 });
+    });
+
+    it("creates a version on each update", () => {
+      store.create("doc1", { v: 1 });
+      store.update("doc1", { v: 2 });
+      store.update("doc1", { v: 3 });
+      const history = store.getHistory("doc1");
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ v: 1 });
+      expect(history[1].content).toEqual({ v: 2 });
+      expect(history[2].content).toEqual({ v: 3 });
+    });
+
+    it("each version has a unique id", () => {
+      store.create("doc1", { v: 1 });
+      store.update("doc1", { v: 2 });
+      const history = store.getHistory("doc1");
+      expect(history[0].id).not.toBe(history[1].id);
+    });
+
+    it("getVersion retrieves specific version content", () => {
+      store.create("doc1", { v: 1 });
+      store.update("doc1", { v: 2 });
+      const history = store.getHistory("doc1");
+      expect(store.getVersion("doc1", history[0].id)).toEqual({ v: 1 });
+      expect(store.getVersion("doc1", history[1].id)).toEqual({ v: 2 });
+    });
+
+    it("throws getHistory for non-existent document", () => {
+      expect(() => store.getHistory("nope")).toThrow();
+    });
+
+    it("throws getVersion for non-existent version", () => {
+      store.create("doc1", { v: 1 });
+      expect(() => store.getVersion("doc1", "bad_id")).toThrow();
+    });
+
+    it("versions are in chronological order", () => {
+      store.create("doc1", { v: 1 });
+      store.update("doc1", { v: 2 });
+      store.update("doc1", { v: 3 });
+      const history = store.getHistory("doc1");
+      for (let i = 1; i < history.length; i++) {
+        expect(history[i].timestamp).toBeGreaterThanOrEqual(
+          history[i - 1].timestamp,
+        );
+      }
+    });
+  });
+
+  // ── Branching ─────────────────────────────────────────────────────
+
+  describe("Branching", () => {
+    it("default branch is main", () => {
+      expect(store.getBranch()).toBe("main");
+    });
+
+    it("lists branches", () => {
+      expect(store.listBranches()).toEqual(["main"]);
+    });
+
+    it("creates and switches to a new branch", () => {
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      expect(store.getBranch()).toBe("feature");
+      expect(store.listBranches()).toContain("feature");
+    });
+
+    it("throws when creating a duplicate branch", () => {
+      store.createBranch("feature");
+      expect(() => store.createBranch("feature")).toThrow();
+    });
+
+    it("throws when switching to non-existent branch", () => {
+      expect(() => store.switchBranch("nope")).toThrow();
+    });
+
+    it("branches have independent document state", () => {
+      store.create("doc1", { v: 1 });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.update("doc1", { v: 2 });
+
+      expect(store.get("doc1")).toEqual({ v: 2 });
+      store.switchBranch("main");
+      expect(store.get("doc1")).toEqual({ v: 1 });
+    });
+
+    it("new documents on one branch are not visible on another", () => {
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.create("doc1", { v: 1 });
+
+      store.switchBranch("main");
+      expect(() => store.get("doc1")).toThrow();
+    });
+
+    it("creates a branch from a specific branch", () => {
+      store.create("doc1", { v: 1 });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.update("doc1", { v: 2 });
+
+      store.createBranch("feature2", "feature");
+      store.switchBranch("feature2");
+      expect(store.get("doc1")).toEqual({ v: 2 });
+    });
+  });
+
+  // ── Merging ───────────────────────────────────────────────────────
+
+  describe("Merging", () => {
+    it("merges changes from source into current branch (no conflict)", () => {
+      store.create("doc1", { a: 1, b: 2 });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.update("doc1", { a: 1, b: 3 });
+
+      store.switchBranch("main");
+      const result = store.merge("feature");
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged["doc1"]).toEqual({ a: 1, b: 3 });
+      expect(store.get("doc1")).toEqual({ a: 1, b: 3 });
+    });
+
+    it("merges changes on different fields cleanly", () => {
+      store.create("doc1", { a: 1, b: 2 });
+      store.createBranch("feature");
+
+      // Change 'a' on main
+      store.update("doc1", { a: 10, b: 2 });
+
+      // Change 'b' on feature
+      store.switchBranch("feature");
+      store.update("doc1", { a: 1, b: 20 });
+
+      store.switchBranch("main");
+      const result = store.merge("feature");
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged["doc1"]).toEqual({ a: 10, b: 20 });
+      expect(store.get("doc1")).toEqual({ a: 10, b: 20 });
+    });
+
+    it("detects conflicts when both sides change the same field differently", () => {
+      store.create("doc1", { a: 1 });
+      store.createBranch("feature");
+
+      store.update("doc1", { a: 2 });
+
+      store.switchBranch("feature");
+      store.update("doc1", { a: 3 });
+
+      store.switchBranch("main");
+      const result = store.merge("feature");
+
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0]).toEqual({
+        documentId: "doc1",
+        path: "a",
+        base: 1,
+        ours: 2,
+        theirs: 3,
+      });
+      // Current branch unchanged
+      expect(store.get("doc1")).toEqual({ a: 2 });
+    });
+
+    it("no conflict when both sides change same field to same value", () => {
+      store.create("doc1", { a: 1 });
+      store.createBranch("feature");
+
+      store.update("doc1", { a: 42 });
+
+      store.switchBranch("feature");
+      store.update("doc1", { a: 42 });
+
+      store.switchBranch("main");
+      const result = store.merge("feature");
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged["doc1"]).toEqual({ a: 42 });
+    });
+
+    it("merged field contains ours-favored result even with conflicts", () => {
+      store.create("doc1", { a: 1, b: 2 });
+      store.createBranch("feature");
+
+      store.update("doc1", { a: 10, b: 20 });
+
+      store.switchBranch("feature");
+      store.update("doc1", { a: 100, b: 200 });
+
+      store.switchBranch("main");
+      const result = store.merge("feature");
+
+      expect(result.applied).toBe(false);
+      // Merged favors ours
+      expect(result.merged["doc1"]).toEqual({ a: 10, b: 20 });
+    });
+
+    it("handles new documents on source branch", () => {
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.create("doc1", { v: 1 });
+
+      store.switchBranch("main");
+      const result = store.merge("feature");
+
+      expect(result.applied).toBe(true);
+      expect(result.merged["doc1"]).toEqual({ v: 1 });
+      expect(store.get("doc1")).toEqual({ v: 1 });
+    });
+
+    it("handles multiple documents independently", () => {
+      store.create("doc1", { a: 1 });
+      store.create("doc2", { x: 1 });
+      store.createBranch("feature");
+
+      // Change doc1 on main
+      store.update("doc1", { a: 2 });
+
+      // Change doc2 on feature
+      store.switchBranch("feature");
+      store.update("doc2", { x: 2 });
+
+      store.switchBranch("main");
+      const result = store.merge("feature");
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged["doc1"]).toEqual({ a: 2 });
+      expect(result.merged["doc2"]).toEqual({ x: 2 });
+    });
+
+    it("handles nested object merges", () => {
+      store.create("doc1", { nested: { a: 1, b: 2 } });
+      store.createBranch("feature");
+
+      store.update("doc1", { nested: { a: 10, b: 2 } });
+
+      store.switchBranch("feature");
+      store.update("doc1", { nested: { a: 1, b: 20 } });
+
+      store.switchBranch("main");
+      const result = store.merge("feature");
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged["doc1"]).toEqual({ nested: { a: 10, b: 20 } });
+    });
+
+    it("detects nested conflicts with correct path", () => {
+      store.create("doc1", { nested: { deep: { val: 1 } } });
+      store.createBranch("feature");
+
+      store.update("doc1", { nested: { deep: { val: 2 } } });
+
+      store.switchBranch("feature");
+      store.update("doc1", { nested: { deep: { val: 3 } } });
+
+      store.switchBranch("main");
+      const result = store.merge("feature");
+
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].path).toBe("nested.deep.val");
+      expect(result.conflicts[0].base).toBe(1);
+      expect(result.conflicts[0].ours).toBe(2);
+      expect(result.conflicts[0].theirs).toBe(3);
+    });
+
+    it("fast-forward merge when no changes on either side", () => {
+      store.create("doc1", { v: 1 });
+      store.createBranch("feature");
+
+      store.switchBranch("main");
+      const result = store.merge("feature");
+
+      expect(result.applied).toBe(false); // no-op
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it("throws when merging from a non-existent branch", () => {
+      expect(() => store.merge("nope")).toThrow();
+    });
+
+    it("handles adding new fields on one side", () => {
+      store.create("doc1", { a: 1 });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.update("doc1", { a: 1, b: 2 });
+
+      store.switchBranch("main");
+      const result = store.merge("feature");
+
+      expect(result.applied).toBe(true);
+      expect(result.merged["doc1"]).toEqual({ a: 1, b: 2 });
+    });
+
+    it("merge creates a new version on the target branch", () => {
+      store.create("doc1", { a: 1 });
+      store.createBranch("feature");
+      store.switchBranch("feature");
+      store.update("doc1", { a: 2 });
+
+      store.switchBranch("main");
+      const historyBefore = store.getHistory("doc1");
+      store.merge("feature");
+      const historyAfter = store.getHistory("doc1");
+
+      expect(historyAfter.length).toBe(historyBefore.length + 1);
+      expect(historyAfter[historyAfter.length - 1].content).toEqual({ a: 2 });
+    });
+  });
+});
