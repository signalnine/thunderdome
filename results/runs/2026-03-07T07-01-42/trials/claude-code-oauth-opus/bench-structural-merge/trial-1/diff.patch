+// ── Types ──────────────────────────────────────────────────────────────
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+// ── Helpers ─────────────────────────────────────────────────────────────
+
+function deepClone<T>(obj: T): T {
+  if (obj === null || typeof obj !== "object") return obj;
+  if (Array.isArray(obj)) return obj.map((item) => deepClone(item)) as T;
+  const clone: Record<string, unknown> = {};
+  for (const key of Object.keys(obj as Record<string, unknown>)) {
+    clone[key] = deepClone((obj as Record<string, unknown>)[key]);
+  }
+  return clone as T;
+}
+
+let versionCounter = 0;
+
+function generateVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+// ── Internal data structures ────────────────────────────────────────────
+
+interface DocumentEntry {
+  content: object;
+  deleted: boolean;
+  versions: Version[];
+}
+
+interface BranchData {
+  documents: Map<string, DocumentEntry>;
+  /** The snapshot id of the branch this was forked from, used for merge base. */
+  forkPoint: BranchSnapshot | null;
+  parent: string | null;
+}
+
+/** A frozen-in-time snapshot of all documents at a branch point. */
+interface BranchSnapshot {
+  documents: Map<string, { content: object; deleted: boolean }>;
+}
+
+function snapshotBranch(branch: BranchData): BranchSnapshot {
+  const docs = new Map<string, { content: object; deleted: boolean }>();
+  for (const [id, entry] of branch.documents) {
+    docs.set(id, { content: deepClone(entry.content), deleted: entry.deleted });
+  }
+  return { documents: docs };
+}
+
+function cloneBranchData(source: BranchData): BranchData {
+  const documents = new Map<string, DocumentEntry>();
+  for (const [id, entry] of source.documents) {
+    documents.set(id, {
+      content: deepClone(entry.content),
+      deleted: entry.deleted,
+      versions: entry.versions.map((v) => ({
+        id: v.id,
+        timestamp: v.timestamp,
+        content: deepClone(v.content),
+      })),
+    });
+  }
+  return {
+    documents,
+    forkPoint: source.forkPoint,
+    parent: source.parent,
+  };
+}
+
+// ── Three-way merge utilities ───────────────────────────────────────────
+
+function isPlainObject(v: unknown): v is Record<string, unknown> {
+  return v !== null && typeof v === "object" && !Array.isArray(v);
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return false;
+  if (typeof a !== typeof b) return false;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    return a.every((val, i) => deepEqual(val, b[i]));
+  }
+  if (isPlainObject(a) && isPlainObject(b)) {
+    const keysA = Object.keys(a);
+    const keysB = Object.keys(b);
+    if (keysA.length !== keysB.length) return false;
+    return keysA.every((k) => Object.prototype.hasOwnProperty.call(b, k) && deepEqual(a[k], b[k]));
+  }
+  return false;
+}
+
+/**
+ * Three-way merge of two objects against a common base.
+ * Returns the merged result and any conflicts found.
+ */
+function threeWayMerge(
+  base: Record<string, unknown>,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+  documentId: string,
+  pathPrefix: string,
+): { result: Record<string, unknown>; conflicts: Conflict[] } {
+  const result: Record<string, unknown> = {};
+  const conflicts: Conflict[] = [];
+  const allKeys = new Set([
+    ...Object.keys(base),
+    ...Object.keys(ours),
+    ...Object.keys(theirs),
+  ]);
+
+  for (const key of allKeys) {
+    const bVal = base[key];
+    const oVal = ours[key];
+    const tVal = theirs[key];
+    const currentPath = pathPrefix ? `${pathPrefix}.${key}` : key;
+
+    const oChanged = !deepEqual(bVal, oVal);
+    const tChanged = !deepEqual(bVal, tVal);
+
+    if (!oChanged && !tChanged) {
+      // Neither side changed — keep base value (if it exists)
+      if (Object.prototype.hasOwnProperty.call(base, key)) {
+        result[key] = deepClone(bVal);
+      } else if (Object.prototype.hasOwnProperty.call(ours, key)) {
+        result[key] = deepClone(oVal);
+      }
+    } else if (oChanged && !tChanged) {
+      // Only ours changed
+      if (Object.prototype.hasOwnProperty.call(ours, key)) {
+        result[key] = deepClone(oVal);
+      }
+      // else: ours deleted the key — omit from result
+    } else if (!oChanged && tChanged) {
+      // Only theirs changed
+      if (Object.prototype.hasOwnProperty.call(theirs, key)) {
+        result[key] = deepClone(tVal);
+      }
+      // else: theirs deleted the key — omit from result
+    } else {
+      // Both changed
+      if (deepEqual(oVal, tVal)) {
+        // Both changed to same value — no conflict
+        if (Object.prototype.hasOwnProperty.call(ours, key)) {
+          result[key] = deepClone(oVal);
+        }
+      } else if (
+        isPlainObject(bVal) &&
+        isPlainObject(oVal) &&
+        isPlainObject(tVal)
+      ) {
+        // Both are objects — recurse
+        const sub = threeWayMerge(bVal, oVal, tVal, documentId, currentPath);
+        result[key] = sub.result;
+        conflicts.push(...sub.conflicts);
+      } else {
+        // Conflict — favor "ours" in the merged result
+        conflicts.push({
+          documentId,
+          path: currentPath,
+          base: deepClone(bVal),
+          ours: deepClone(oVal),
+          theirs: deepClone(tVal),
+        });
+        result[key] = deepClone(oVal);
+      }
+    }
+  }
+
+  return { result, conflicts };
+}
+
+// ── DocumentStore ───────────────────────────────────────────────────────
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = "main";
+
+  constructor() {
+    this.branches.set("main", {
+      documents: new Map(),
+      forkPoint: null,
+      parent: null,
+    });
+  }
+
+  // ── helpers ──
+
+  private branch(): BranchData {
+    return this.branches.get(this.currentBranch)!;
+  }
+
+  private getEntry(id: string): DocumentEntry {
+    const entry = this.branch().documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return entry;
+  }
+
+  // ── CRUD ──
+
+  create(id: string, content: object): void {
+    const branch = this.branch();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const cloned = deepClone(content);
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(cloned),
+    };
+    branch.documents.set(id, {
+      content: cloned,
+      deleted: false,
+      versions: existing ? [...existing.versions, version] : [version],
+    });
+  }
+
+  get(id: string): object {
+    return deepClone(this.getEntry(id).content);
+  }
+
+  update(id: string, content: object): void {
+    const entry = this.getEntry(id);
+    const cloned = deepClone(content);
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(cloned),
+    };
+    entry.content = cloned;
+    entry.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const entry = this.getEntry(id); // throws if missing/deleted
+    entry.deleted = true;
+  }
+
+  // ── Version history ──
+
+  getHistory(id: string): Version[] {
+    const branch = this.branch();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return entry.versions.map((v) => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.branch();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version = entry.versions.find((v) => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // ── Branching ──
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch "${sourceName}" not found`);
+    }
+    const newBranch = cloneBranchData(source);
+    newBranch.forkPoint = snapshotBranch(source);
+    newBranch.parent = sourceName;
+    this.branches.set(name, newBranch);
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return [...this.branches.keys()];
+  }
+
+  // ── Merging ──
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceBranchData = this.branches.get(sourceBranch);
+    if (!sourceBranchData) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+    const targetBranchData = this.branch();
+
+    // Find the common ancestor (the fork point snapshot).
+    // The base is the state of the branch at the time sourceBranch was created
+    // from the target, or vice versa.
+    const base = this.findMergeBase(sourceBranch, this.currentBranch);
+
+    const allDocIds = new Set<string>();
+    for (const id of targetBranchData.documents.keys()) allDocIds.add(id);
+    for (const id of sourceBranchData.documents.keys()) allDocIds.add(id);
+    if (base) {
+      for (const id of base.documents.keys()) allDocIds.add(id);
+    }
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+    let hasChanges = false;
+
+    for (const docId of allDocIds) {
+      const baseEntry = base?.documents.get(docId);
+      const oursEntry = targetBranchData.documents.get(docId);
+      const theirsEntry = sourceBranchData.documents.get(docId);
+
+      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : undefined;
+      const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : undefined;
+      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : undefined;
+
+      const baseDeleted = baseEntry ? baseEntry.deleted : true;
+      const oursDeleted = oursEntry ? oursEntry.deleted : true;
+      const theirsDeleted = theirsEntry ? theirsEntry.deleted : true;
+
+      // Check if either side changed relative to base
+      const oursChanged = !deepEqual(baseContent, oursContent) || baseDeleted !== oursDeleted;
+      const theirsChanged = !deepEqual(baseContent, theirsContent) || baseDeleted !== theirsDeleted;
+
+      if (!oursChanged && !theirsChanged) {
+        // No changes on either side for this doc — keep as-is
+        if (oursContent !== undefined) {
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      hasChanges = true;
+
+      if (oursChanged && !theirsChanged) {
+        // Only our side changed
+        if (oursContent !== undefined) {
+          merged[docId] = deepClone(oursContent);
+        }
+        // else: we deleted it — omit from merged
+        continue;
+      }
+
+      if (!oursChanged && theirsChanged) {
+        // Only their side changed
+        if (theirsContent !== undefined) {
+          merged[docId] = deepClone(theirsContent);
+        }
+        // else: they deleted it — omit from merged
+        continue;
+      }
+
+      // Both sides changed
+      if (oursDeleted && theirsDeleted) {
+        // Both deleted — no conflict, just omit
+        continue;
+      }
+
+      if (deepEqual(oursContent, theirsContent)) {
+        // Both changed to the same thing
+        if (oursContent !== undefined) {
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      // If one side deleted and the other modified, treat as conflict
+      if (oursDeleted || theirsDeleted) {
+        conflicts.push({
+          documentId: docId,
+          path: "",
+          base: baseContent !== undefined ? deepClone(baseContent) : undefined,
+          ours: oursContent !== undefined ? deepClone(oursContent) : undefined,
+          theirs: theirsContent !== undefined ? deepClone(theirsContent) : undefined,
+        });
+        // Favor ours
+        if (oursContent !== undefined) {
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      // Both modified — do a structural three-way merge
+      const baseObj = (baseContent ?? {}) as Record<string, unknown>;
+      const oursObj = oursContent as Record<string, unknown>;
+      const theirsObj = theirsContent as Record<string, unknown>;
+      const mergeResult = threeWayMerge(baseObj, oursObj, theirsObj, docId, "");
+      merged[docId] = mergeResult.result as object;
+      conflicts.push(...mergeResult.conflicts);
+    }
+
+    const applied = conflicts.length === 0 && hasChanges;
+
+    if (applied) {
+      // Apply the merge: update the current branch's documents
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const existingEntry = targetBranchData.documents.get(docId);
+          const mergedContent = deepClone(merged[docId]);
+          const version: Version = {
+            id: generateVersionId(),
+            timestamp: Date.now(),
+            content: deepClone(mergedContent),
+          };
+          if (existingEntry) {
+            existingEntry.content = mergedContent;
+            existingEntry.deleted = false;
+            existingEntry.versions.push(version);
+          } else {
+            targetBranchData.documents.set(docId, {
+              content: mergedContent,
+              deleted: false,
+              versions: [version],
+            });
+          }
+        } else {
+          // Document was deleted in the merge
+          const existingEntry = targetBranchData.documents.get(docId);
+          if (existingEntry && !existingEntry.deleted) {
+            existingEntry.deleted = true;
+          }
+        }
+      }
+    }
+
+    // If no changes at all, it's a no-op (fast-forward) — applied stays false
+    // but there are no conflicts either
+    if (!hasChanges) {
+      // Return whatever is currently in target as merged
+      for (const [docId, entry] of targetBranchData.documents) {
+        if (!entry.deleted) {
+          merged[docId] = deepClone(entry.content);
+        }
+      }
+    }
+
+    return {
+      merged,
+      conflicts,
+      applied,
+    };
+  }
+
+  /**
+   * Find the merge base (common ancestor) between two branches.
+   * Walks up the parent chain to find where they diverge.
+   */
+  private findMergeBase(
+    branchA: string,
+    branchB: string,
+  ): BranchSnapshot | null {
+    const branchAData = this.branches.get(branchA)!;
+    const branchBData = this.branches.get(branchB)!;
+
+    // If A was forked from B, the fork point of A is the base
+    if (branchAData.parent === branchB) {
+      return branchAData.forkPoint;
+    }
+    // If B was forked from A, the fork point of B is the base
+    if (branchBData.parent === branchA) {
+      return branchBData.forkPoint;
+    }
+
+    // Walk up A's ancestry to see if it connects to B's ancestry
+    const aAncestors = new Map<string, BranchSnapshot | null>();
+    let current: string | null = branchA;
+    while (current !== null) {
+      const data = this.branches.get(current);
+      if (!data) break;
+      aAncestors.set(current, data.forkPoint);
+      current = data.parent;
+    }
+
+    current = branchB;
+    while (current !== null) {
+      if (aAncestors.has(current)) {
+        // Found common ancestor
+        return branchBData.forkPoint;
+      }
+      const data = this.branches.get(current);
+      if (!data) break;
+      current = data.parent;
+    }
+
+    // Fallback: empty base
+    return { documents: new Map() };
+  }
+}
