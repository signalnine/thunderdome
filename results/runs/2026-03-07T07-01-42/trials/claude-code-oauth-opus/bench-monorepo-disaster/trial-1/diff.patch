ace/.eslintrc.cjs`\n```javascript\nmodule.exports = {\n  parser: '@typescript-eslint/parser',\n  plugins: ['@typescript-eslint'],\n  extends: ['eslint:recommended', 'plugin:@typescript-eslint/recommended'],\n  parserOptions: {\n    ecmaVersion: 2022,\n    sourceType: 'module',\n  },\n  rules: {\n    '@typescript-eslint/no-unused-vars': ['error', { argsIgnorePattern: '^_' }],\n  },\n  env: {\n    node: true,\n    es2022: true,\n  },\n};\n```\n\n#### `/workspace/vitest.config.ts`\n```typescript\nimport { defineConfig } from 'vitest/config';\n\nexport default defineConfig({\n  test: {\n    globals: true,\n    testTimeout: 10000,\n  },\n});\n```\n\n---\n\n### PACKAGES CONFIGURATION\n\n### 1. packages/core (Shared Library)\n\n#### `packages/core/package.json`\n```json\n{\n  \"name\": \"@monorepo/core\",\n  \"version\": \"1.0.0\",\n  \"type\": \"module\",\n  \"main\": \"./dist/index.js\",\n  \"types\": \"./dist/index.d.ts\",\n  \"scripts\": {\n    \"build\": \"tsc\"\n  },\n  \"dependencies\": {\n    \"zod\": \"3.19.0\",\n    \"better-sqlite3\": \"^11.0.0\"\n  },\n  \"devDependencies\": {\n    \"@types/better-sqlite3\": \"^7.6.0\",\n    \"typescript\": \"^5.4.0\"\n  }\n}\n```\n\n#### `packages/core/tsconfig.json`\n```json\n{\n  \"compilerOptions\": {\n    \"target\": \"ES2022\",\n    \"module\": \"Node16\",\n    \"moduleResolution\": \"Node16\",\n    \"outDir\": \"./dist\",\n    \"rootDir\": \"./src\",\n    \"strict\": true,\n    \"composite\": true,\n    \"declaration\": true,\n    \"declarationMap\": true,\n    \"sourceMap\": true,\n    \"esModuleInterop\": true,\n    \"skipLibCheck\": true,\n    \"forceConsistentCasingInFileNames\": true\n  },\n  \"include\": [\"src/**/*.ts\"],\n  \"exclude\": [\"node_modules\", \"dist\", \"tests\"]\n}\n```\n\n#### `packages/core/src/index.ts`\n```typescript\n/**\n * @monorepo/core - Shared business logic\n */\n\n// Types\nexport type { User, CreateUserInput, UserFilters, Role, Permission } from './types.js';\n\n// User management\nexport {\n  registerUser,\n  validateUser,\n  getUserById,\n  getAllUsers,\n  canUserPerformAction,\n  getDefaultConnection,\n  resetDefaultConnection,\n} from './user.js';\n\n// Validation\nexport {\n  createUserSchema,\n  userIdSchema,\n  userFiltersSchema,\n  roleSchema,\n  validateCreateUser,\n  validateUserId,\n} from './validation.js';\n\n// Database\nexport {\n  createDatabase,\n  createTables,\n  insertUser,\n  findUserById,\n  findAllUsers,\n  type DatabaseConnection,\n} from './database.js';\n\n// Permissions\nexport {\n  hasPermission,\n  getAllPermissions,\n  canManageUsers,\n  canWrite,\n  canDelete,\n  requirePermission,\n} from './permissions.js';\n```\n\n#### `packages/core/src/types.ts`\n```typescript\n/**\n * Shared types for the monorepo.\n */\n\nimport { getUserById } from './user.js';\n\nexport type Role = 'admin' | 'user' | 'viewer';\n\nexport type Permission =\n  | 'read'\n  | 'write'\n  | 'delete'\n  | 'manage_users'\n  | 'view_reports';\n\nexport interface User {\n  id: number;\n  name: string;\n  email: string;\n  role: Role;\n  createdAt: string;\n  updatedAt: string;\n}\n\nexport interface CreateUserInput {\n  name: string;\n  email: string;\n  role: Role;\n}\n\nexport interface UserFilters {\n  role?: Role;\n  search?: string;\n  limit?: number;\n  offset?: number;\n}\n\n/** Utility to check if a user exists by ID */\nexport function userExists(id: number): boolean {\n  return getUserById(id) !== null;\n}\n```\n\n#### `packages/core/src/database.ts`\n```typescript\n/**\n * Database connection factory and table creation.\n * Uses better-sqlite3 for a simple embedded database.\n */\n\nimport Database from 'better-sqlite3';\nimport type { User } from './types.js';\n\nexport interface DatabaseConnection {\n  db: Database.Database;\n  close: () => void;\n}\n\nexport function createDatabase(path: string = ':memory:'): DatabaseConnection {\n  const db = new Database(path);\n\n  // Enable WAL mode for better concurrent read performance\n  db.pragma('journal_mode = WAL');\n  db.pragma('foreign_keys = ON');\n\n  return {\n    db,\n    close: () => db.close(),\n  };\n}\n\nexport function createTables(conn: DatabaseConnection): void {\n  conn.db.exec(`\n    CREATE TABLE IF NOT EXISTS users (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      name TEXT NOT NULL,\n      email TEXT NOT NULL UNIQUE,\n      role TEXT NOT NULL CHECK(role IN ('admin', 'user', 'viewer')),\n      created_at TEXT NOT NULL DEFAULT (datetime('now')),\n      updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n    );\n\n    CREATE INDEX IF NOT EXISTS idx_users_email ON users(email);\n    CREATE INDEX IF NOT EXISTS idx_users_role ON users(role);\n  `);\n}\n\nexport function insertUser(\n  conn: DatabaseConnection,\n  user: { name: string; email: string; role: string }\n): User {\n  const stmt = conn.db.prepare(\n    'INSERT INTO users (name, email, role) VALUES (?, ?, ?) RETURNING *'\n  );\n  const row = stmt.get(user.name, user.email, user.role) as {\n    id: number;\n    name: string;\n    email: string;\n    role: string;\n    created_at: string;\n    updated_at: string;\n  };\n  return {\n    id: row.id,\n    name: row.name,\n    email: row.email,\n    role: row.role as User['role'],\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nexport function findUserById(\n  conn: DatabaseConnection,\n  id: number\n): User | null {\n  const stmt = conn.db.prepare('SELECT * FROM users WHERE id = ?');\n  const row = stmt.get(id) as {\n    id: number;\n    name: string;\n    email: string;\n    role: string;\n    created_at: string;\n    updated_at: string;\n  } | undefined;\n  if (!row) return null;\n  return {\n    id: row.id,\n    name: row.name,\n    email: row.email,\n    role: row.role as User['role'],\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nexport function findAllUsers(conn: DatabaseConnection): User[] {\n  const stmt = conn.db.prepare('SELECT * FROM users ORDER BY id');\n  const rows = stmt.all() as Array<{\n    id: number;\n    name: string;\n    email: string;\n    role: string;\n    created_at: string;\n    updated_at: string;\n  }>;\n  return rows.map((row) => ({\n    id: row.id,\n    name: row.name,\n    email: row.email,\n    role: row.role as User['role'],\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  }));\n}\n```\n\n#### `packages/core/src/user.ts`\n```typescript\n/**\n * User management: creation, validation, and retrieval.\n */\n\nimport type { User, CreateUserInput } from './types.js';\nimport { validateCreateUser } from './validation.js';\nimport { hasPermission } from './permissions.js';\nimport {\n  createDatabase,\n  createTables,\n  insertUser,\n  findUserById,\n  findAllUsers,\n  type DatabaseConnection,\n} from './database.js';\n\nlet defaultConn: DatabaseConnection | null = null;\n\nexport function getDefaultConnection(): DatabaseConnection {\n  if (!defaultConn) {\n    defaultConn = createDatabase(':memory:');\n    createTables(defaultConn);\n  }\n  return defaultConn;\n}\n\nexport function resetDefaultConnection(): void {\n  if (defaultConn) {\n    defaultConn.close();\n    defaultConn = null;\n  }\n}\n\nexport function registerUser(input: CreateUserInput): User {\n  const validation = validateCreateUser(input);\n  if (!validation.success) {\n    throw new Error(`Invalid user data: ${validation.errors?.join(', ')}`);\n  }\n\n  const conn = getDefaultConnection();\n  return insertUser(conn, input);\n}\n\nexport function validateUser(input: unknown): {\n  valid: boolean;\n  errors?: string[];\n} {\n  const result = validateCreateUser(input);\n  return {\n    valid: result.success,\n    errors: result.errors,\n  };\n}\n\nexport function getUserById(id: number): User | null {\n  const conn = getDefaultConnection();\n  return findUserById(conn, id);\n}\n\nexport function getAllUsers(): User[] {\n  const conn = getDefaultConnection();\n  return findAllUsers(conn);\n}\n\nexport function canUserPerformAction(\n  userRole: User['role'],\n  action: 'read' | 'write' | 'delete'\n): boolean {\n  return hasPermission(userRole, action);\n}\n```\n\n**NOTE:** The user.ts file doesn't export `createUser()` function but the API package imports it. This is a **missing export bug**.\n\n#### `packages/core/src/permissions.ts`\n```typescript\n/**\n * Permission checking and role-based access control.\n */\n\nimport type { Role, Permission } from './types.js';\n\nconst ROLE_PERMISSIONS: Record<Role, Permission[]> = {\n  admin: ['read', 'write', 'delete', 'manage_users', 'view_reports'],\n  user: ['read', 'write', 'view_reports'],\n  viewer: ['read'],\n};\n\nexport function hasPermission(role: Role, permission: Permission): boolean {\n  const permissions = ROLE_PERMISSIONS[role];\n  return permissions.includes(permission);\n}\n\nexport function getAllPermissions(role: Role): Permission[] {\n  return [...ROLE_PERMISSIONS[role]];\n}\n\nexport function canManageUsers(role: Role): boolean {\n  return hasPermission(role, 'manage_users');\n}\n\nexport function canWrite(role: Role): boolean {\n  return hasPermission(role, 'write');\n}\n\nexport function canDelete(role: Role): boolean {\n  return hasPermission(role, 'delete');\n}\n\nexport function requirePermission(\n  role: Role,\n  permission: Permission\n): void {\n  if (!hasPermission(role, permission)) {\n    throw new Error(\n      `Role '${role}' does not have permission '${permission}'`\n    );\n  }\n}\n```\n\n#### `packages/core/src/validation.ts`\n```typescript\n/**\n * Schema validation using zod.\n * Uses z.pipe() for string-to-number coercion (requires zod >= 3.22).\n */\n\nimport { z } from 'zod';\nimport type { Role } from './types.js';\n\nexport const roleSchema = z.enum(['admin', 'user', 'viewer']);\n\nexport const createUserSchema = z.object({\n  name: z\n    .string()\n    .min(1, 'Name is required')\n    .max(100, 'Name must be 100 characters or less'),\n  email: z.string().email('Invalid email address'),\n  role: roleSchema,\n});\n\nexport const userIdSchema = z\n  .string()\n  .pipe(z.coerce.number().int().positive('User ID must be a positive integer'));\n\nexport const userFiltersSchema = z.object({\n  role: roleSchema.optional(),\n  search: z.string().optional(),\n  limit: z\n    .string()\n    .pipe(z.coerce.number().int().min(1).max(100))\n    .optional()\n    .default('20'),\n  offset: z\n    .string()\n    .pipe(z.coerce.number().int().min(0))\n    .optional()\n    .default('0'),\n});\n\nexport function validateCreateUser(data: unknown): {\n  success: boolean;\n  data?: { name: string; email: string; role: Role };\n  errors?: string[];\n} {\n  const result = createUserSchema.safeParse(data);\n  if (result.success) {\n    return { success: true, data: result.data };\n  }\n  return {\n    success: false,\n    errors: result.error.errors.map((e) => e.message),\n  };\n}\n\nexport function validateUserId(id: string): {\n  success: boolean;\n  data?: number;\n  errors?: string[];\n} {\n  const result = userIdSchema.safeParse(id);\n  if (result.success) {\n    return { success: true, data: result.data };\n  }\n  return {\n    success: false,\n    errors: result.error.errors.map((e) => e.message),\n  };\n}\n```\n\n#### `packages/core/tests/` (Test Files)\n\n**permissions.test.ts**\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport {\n  hasPermission,\n  getAllPermissions,\n  canManageUsers,\n  canWrite,\n  canDelete,\n  requirePermission,\n} from '../src/permissions.js';\n\ndescribe('Permissions', () => {\n  it('admin has all permissions', () => {\n    expect(hasPermission('admin', 'read')).toBe(true);\n    expect(hasPermission('admin', 'write')).toBe(true);\n    expect(hasPermission('admin', 'delete')).toBe(true);\n    expect(hasPermission('admin', 'manage_users')).toBe(true);\n    expect(hasPermission('admin', 'view_reports')).toBe(true);\n  });\n\n  it('viewer can only read', () => {\n    expect(hasPermission('viewer', 'read')).toBe(true);\n    expect(hasPermission('viewer', 'write')).toBe(false);\n    expect(hasPermission('viewer', 'delete')).toBe(false);\n  });\n\n  it('returns all permissions for a role', () => {\n    const perms = getAllPermissions('user');\n    expect(perms).toContain('read');\n    expect(perms).toContain('write');\n    expect(perms).not.toContain('delete');\n  });\n\n  it('canManageUsers is true only for admin', () => {\n    expect(canManageUsers('admin')).toBe(true);\n    expect(canManageUsers('user')).toBe(false);\n    expect(canManageUsers('viewer')).toBe(false);\n  });\n\n  it('canWrite is true for admin and user', () => {\n    expect(canWrite('admin')).toBe(true);\n    expect(canWrite('user')).toBe(true);\n    expect(canWrite('viewer')).toBe(false);\n  });\n\n  it('canDelete is true only for admin', () => {\n    expect(canDelete('admin')).toBe(true);\n    expect(canDelete('user')).toBe(false);\n  });\n\n  it('requirePermission throws when permission is missing', () => {\n    expect(() => requirePermission('viewer', 'write')).toThrow(\n      \"Role 'viewer' does not have permission 'write'\"\n    );\n  });\n});\n```\n\n**user.test.ts**\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport {\n  registerUser,\n  validateUser,\n  getUserById,\n  getAllUsers,\n  resetDefaultConnection,\n} from '../src/user.js';\n\ndescribe('User Management', () => {\n  beforeEach(() => {\n    resetDefaultConnection();\n  });\n\n  it('registers a new user with valid data', () => {\n    const user = registerUser({\n      name: 'Alice',\n      email: 'alice@example.com',\n      role: 'admin',\n    });\n    expect(user.id).toBe(1);\n    expect(user.name).toBe('Alice');\n    expect(user.email).toBe('alice@example.com');\n    expect(user.role).toBe('admin');\n  });\n\n  it('throws on invalid user data', () => {\n    expect(() =>\n      registerUser({ name: '', email: 'bad', role: 'admin' })\n    ).toThrow('Invalid user data');\n  });\n\n  it('retrieves a user by id', () => {\n    const created = registerUser({\n      name: 'Bob',\n      email: 'bob@example.com',\n      role: 'user',\n    });\n    const found = getUserById(created.id);\n    expect(found).not.toBeNull();\n    expect(found!.name).toBe('Bob');\n  });\n\n  it('returns null for nonexistent user', () => {\n    const found = getUserById(999);\n    expect(found).toBeNull();\n  });\n\n  it('lists all users', () => {\n    registerUser({ name: 'A', email: 'a@a.com', role: 'user' });\n    registerUser({ name: 'B', email: 'b@b.com', role: 'viewer' });\n    const all = getAllUsers();\n    expect(all).toHaveLength(2);\n  });\n\n  it('validates user input correctly', () => {\n    const valid = validateUser({\n      name: 'Test',\n      email: 'test@test.com',\n      role: 'user',\n    });\n    expect(valid.valid).toBe(true);\n\n    const invalid = validateUser({ name: '', email: 'not-an-email', role: 'hacker' });\n    expect(invalid.valid).toBe(false);\n    expect(invalid.errors).toBeDefined();\n  });\n});\n```\n\n**validation.test.ts**\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport {\n  validateCreateUser,\n  validateUserId,\n  userFiltersSchema,\n} from '../src/validation.js';\n\ndescribe('Validation', () => {\n  it('validates a correct user input', () => {\n    const result = validateCreateUser({\n      name: 'Alice',\n      email: 'alice@example.com',\n      role: 'admin',\n    });\n    expect(result.success).toBe(true);\n    expect(result.data).toEqual({\n      name: 'Alice',\n      email: 'alice@example.com',\n      role: 'admin',\n    });\n  });\n\n  it('rejects invalid email', () => {\n    const result = validateCreateUser({\n      name: 'Alice',\n      email: 'not-an-email',\n      role: 'admin',\n    });\n    expect(result.success).toBe(false);\n    expect(result.errors).toContain('Invalid email address');\n  });\n\n  it('uses z.pipe() to coerce string user ID to number', () => {\n    const result = validateUserId('42');\n    expect(result.success).toBe(true);\n    expect(result.data).toBe(42);\n  });\n\n  it('rejects non-numeric user ID via z.pipe()', () => {\n    const result = validateUserId('abc');\n    expect(result.success).toBe(false);\n  });\n\n  it('parses user filters with string-to-number coercion via z.pipe()', () => {\n    const result = userFiltersSchema.safeParse({\n      role: 'admin',\n      limit: '50',\n      offset: '10',\n    });\n    expect(result.success).toBe(true);\n    if (result.success) {\n      expect(result.data.limit).toBe(50);\n      expect(result.data.offset).toBe(10);\n    }\n  });\n});\n```\n\n---\n\n### 2. packages/api (Express API Server)\n\n#### `packages/api/package.json`\n```json\n{\n  \"name\": \"@monorepo/api\",\n  \"version\": \"1.0.0\",\n  \"type\": \"module\",\n  \"main\": \"./dist/index.js\",\n  \"scripts\": {\n    \"build\": \"tsc\",\n    \"start\": \"node dist/index.js\"\n  },\n  \"dependencies\": {\n    \"@monorepo/core\": \"*\",\n    \"express\": \"^4.21.0\"\n  },\n  \"devDependencies\": {\n    \"@types/express\": \"^4.17.0\",\n    \"supertest\": \"^7.0.0\",\n    \"@types/supertest\": \"^6.0.0\",\n    \"typescript\": \"^5.4.0\"\n  }\n}\n```\n\n#### `packages/api/tsconfig.json`\n```json\n{\n  \"compilerOptions\": {\n    \"target\": \"ES2022\",\n    \"module\": \"Node16\",\n    \"moduleResolution\": \"Node16\",\n    \"outDir\": \"./dist\",\n    \"rootDir\": \"./src\",\n    \"strict\": true,\n    \"composite\": true,\n    \"declaration\": true,\n    \"declarationMap\": true,\n    \"sourceMap\": true,\n    \"esModuleInterop\": true,\n    \"skipLibCheck\": true,\n    \"forceConsistentCasingInFileNames\": true\n  },\n  \"include\": [\"src/**/*.ts\"],\n  \"exclude\": [\"node_modules\", \"dist\", \"tests\"],\n  \"references\": [\n    { \"path\": \"../core\" }\n  ]\n}\n```\n\n#### `packages/api/src/index.ts`\n```typescript\n/**\n * Express API application setup.\n */\n\nimport express from 'express';\nimport { usersRouter } from './routes/users.js';\nimport { authRouter } from './routes/auth.js';\nimport { authMiddleware } from './middleware/auth.js';\n\nexport function createApp() {\n  const app = express();\n\n  app.use(express.json());\n\n  // Health check\n  app.get('/health', (_req, res) => {\n    res.json({ status: 'ok' });\n  });\n\n  // Public routes\n  app.use('/auth', authRouter);\n\n  // Protected routes\n  app.use('/users', authMiddleware, usersRouter);\n\n  // Error handler\n  app.use(\n    (\n      err: Error,\n      _req: express.Request,\n      res: express.Response,\n      _next: express.NextFunction\n    ) => {\n      console.error(err.message);\n      res.status(500).json({ error: 'Internal server error' });\n    }\n  );\n\n  return app;\n}\n\n// Start server if run directly\nconst isMainModule = process.argv[1]?.includes('api/dist/index.js');\nif (isMainModule) {\n  const port = process.env['PORT'] || 3000;\n  const app = createApp();\n  app.listen(port, () => {\n    console.log(`API server running on port ${port}`);\n  });\n}\n```\n\n#### `packages/api/src/middleware/auth.ts`\n```typescript\n/**\n * Authentication middleware using core permissions.\n */\n\nimport type { Request, Response, NextFunction } from 'express';\nimport { hasPermission, type Role, type Permission } from '@monorepo/core';\n\n/**\n * Basic auth middleware that checks for a token header.\n * In this benchmark, we use a simplified mock auth system.\n */\nexport function authMiddleware(\n  req: Request,\n  res: Response,\n  next: NextFunction\n): void {\n  const token = req.headers['authorization']?.replace('Bearer ', '');\n\n  // Allow requests with valid mock tokens or role headers\n  if (token?.startsWith('mock-token-') || req.headers['x-user-role']) {\n    next();\n    return;\n  }\n\n  res.status(401).json({ error: 'Authentication required' });\n}\n\n/**\n * Middleware factory to require a specific permission.\n */\nexport function requirePermissionMiddleware(permission: Permission) {\n  return (req: Request, res: Response, next: NextFunction): void => {\n    const role = (req.headers['x-user-role'] as Role) || 'viewer';\n\n    if (!hasPermission(role, permission)) {\n      res.status(403).json({\n        error: `Permission '${permission}' required`,\n      });\n      return;\n    }\n\n    next();\n  };\n}\n```\n\n#### `packages/api/src/routes/auth.ts`\n```typescript\n/**\n * Authentication routes.\n */\n\nimport { Router, type Request, type Response } from 'express';\nimport { validateCreateUser, registerUser, type Role } from '@monorepo/core';\n\nexport const authRouter = Router();\n\n// Simple registration (public)\nauthRouter.post('/register', (req: Request, res: Response) => {\n  try {\n    const validation = validateCreateUser({\n      ...req.body,\n      role: 'user', // Force 'user' role for self-registration\n    });\n\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = registerUser({\n      name: req.body.name,\n      email: req.body.email,\n      role: 'user' as Role,\n    });\n\n    res.status(201).json({\n      user,\n      token: `mock-token-${user.id}`, // Simplified for benchmark\n    });\n  } catch (err) {\n    if (err instanceof Error && err.message.includes('UNIQUE')) {\n      res.status(409).json({ error: 'Email already registered' });\n      return;\n    }\n    res.status(500).json({ error: 'Registration failed' });\n  }\n});\n\n// Simple login (mock)\nauthRouter.post('/login', (req: Request, res: Response) => {\n  try {\n    const { email } = req.body as { email?: string };\n    if (!email) {\n      res.status(400).json({ error: 'Email is required' });\n      return;\n    }\n\n    // In a real app, we'd verify credentials\n    res.json({\n      token: `mock-token-for-${email}`,\n      message: 'Login successful',\n    });\n  } catch (err) {\n    res.status(500).json({ error: 'Login failed' });\n  }\n});\n\n// Token validation (mock)\nauthRouter.get('/verify', (req: Request, res: Response) => {\n  const token = req.headers['authorization']?.replace('Bearer ', '');\n  if (!token) {\n    res.status(401).json({ error: 'No token provided' });\n    return;\n  }\n\n  // Simplified: any token with correct format is valid\n  if (token.startsWith('mock-token-')) {\n    res.json({ valid: true, token });\n  } else {\n    res.status(401).json({ valid: false, error: 'Invalid token' });\n  }\n});\n```\n\n#### `packages/api/src/routes/users.ts`\n```typescript\n/**\n * User CRUD routes.\n */\n\nimport { Router, type Request, type Response } from 'express';\nimport {\n  createUser,\n  getUserById,\n  getAllUsers,\n  validateCreateUser,\n  validateUserId,\n  canManageUsers,\n  type Role,\n} from '@monorepo/core';\n\nexport const usersRouter = Router();\n\n// List all users\nusersRouter.get('/', (_req: Request, res: Response) => {\n  try {\n    const users = getAllUsers();\n    res.json({ users });\n  } catch (err) {\n    res.status(500).json({ error: 'Failed to fetch users' });\n  }\n});\n\n// Get user by ID\nusersRouter.get('/:id', (req: Request, res: Response) => {\n  try {\n    const validation = validateUserId(req.params['id']!);\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = getUserById(validation.data!);\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    res.json({ user });\n  } catch (err) {\n    res.status(500).json({ error: 'Failed to fetch user' });\n  }\n});\n\n// Create a new user\nusersRouter.post('/', (req: Request, res: Response) => {\n  try {\n    const callerRole = (req.headers['x-user-role'] as Role) || 'viewer';\n    if (!canManageUsers(callerRole)) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const validation = validateCreateUser(req.body);\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = createUser(req.body