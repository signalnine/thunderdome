s,\n  canUserPerformAction,\n  getDefaultConnection,\n  resetDefaultConnection,\n} from './user.js';\n\n// Validation\nexport {\n  createUserSchema,\n  userIdSchema,\n  userFiltersSchema,\n  roleSchema,\n  validateCreateUser,\n  validateUserId,\n} from './validation.js';\n\n// Database\nexport {\n  createDatabase,\n  createTables,\n  insertUser,\n  findUserById,\n  findAllUsers,\n  type DatabaseConnection,\n} from './database.js';\n\n// Permissions\nexport {\n  hasPermission,\n  getAllPermissions,\n  canManageUsers,\n  canWrite,\n  canDelete,\n  requirePermission,\n} from './permissions.js';\n```\n\n#### `packages/core/src/types.ts`\n```typescript\n/**\n * Shared types for the monorepo.\n */\n\nimport { getUserById } from './user.js';\n\nexport type Role = 'admin' | 'user' | 'viewer';\n\nexport type Permission =\n  | 'read'\n  | 'write'\n  | 'delete'\n  | 'manage_users'\n  | 'view_reports';\n\nexport interface User {\n  id: number;\n  name: string;\n  email: string;\n  role: Role;\n  createdAt: string;\n  updatedAt: string;\n}\n\nexport interface CreateUserInput {\n  name: string;\n  email: string;\n  role: Role;\n}\n\nexport interface UserFilters {\n  role?: Role;\n  search?: string;\n  limit?: number;\n  offset?: number;\n}\n\n/** Utility to check if a user exists by ID */\nexport function userExists(id: number): boolean {\n  return getUserById(id) !== null;\n}\n```\n\n#### `packages/core/src/database.ts`\n```typescript\n/**\n * Database connection factory and table creation.\n * Uses better-sqlite3 for a simple embedded database.\n */\n\nimport Database from 'better-sqlite3';\nimport type { User } from './types.js';\n\nexport interface DatabaseConnection {\n  db: Database.Database;\n  close: () => void;\n}\n\nexport function createDatabase(path: string = ':memory:'): DatabaseConnection {\n  const db = new Database(path);\n\n  // Enable WAL mode for better concurrent read performance\n  db.pragma('journal_mode = WAL');\n  db.pragma('foreign_keys = ON');\n\n  return {\n    db,\n    close: () => db.close(),\n  };\n}\n\nexport function createTables(conn: DatabaseConnection): void {\n  conn.db.exec(`\n    CREATE TABLE IF NOT EXISTS users (\n      id INTEGER PRIMARY KEY AUTOINCREMENT,\n      name TEXT NOT NULL,\n      email TEXT NOT NULL UNIQUE,\n      role TEXT NOT NULL CHECK(role IN ('admin', 'user', 'viewer')),\n      created_at TEXT NOT NULL DEFAULT (datetime('now')),\n      updated_at TEXT NOT NULL DEFAULT (datetime('now'))\n    );\n\n    CREATE INDEX IF NOT EXISTS idx_users_email ON users(email);\n    CREATE INDEX IF NOT EXISTS idx_users_role ON users(role);\n  `);\n}\n\nexport function insertUser(\n  conn: DatabaseConnection,\n  user: { name: string; email: string; role: string }\n): User {\n  const stmt = conn.db.prepare(\n    'INSERT INTO users (name, email, role) VALUES (?, ?, ?) RETURNING *'\n  );\n  const row = stmt.get(user.name, user.email, user.role) as {\n    id: number;\n    name: string;\n    email: string;\n    role: string;\n    created_at: string;\n    updated_at: string;\n  };\n  return {\n    id: row.id,\n    name: row.name,\n    email: row.email,\n    role: row.role as User['role'],\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nexport function findUserById(\n  conn: DatabaseConnection,\n  id: number\n): User | null {\n  const stmt = conn.db.prepare('SELECT * FROM users WHERE id = ?');\n  const row = stmt.get(id) as {\n    id: number;\n    name: string;\n    email: string;\n    role: string;\n    created_at: string;\n    updated_at: string;\n  } | undefined;\n  if (!row) return null;\n  return {\n    id: row.id,\n    name: row.name,\n    email: row.email,\n    role: row.role as User['role'],\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nexport function findAllUsers(conn: DatabaseConnection): User[] {\n  const stmt = conn.db.prepare('SELECT * FROM users ORDER BY id');\n  const rows = stmt.all() as Array<{\n    id: number;\n    name: string;\n    email: string;\n    role: string;\n    created_at: string;\n    updated_at: string;\n  }>;\n  return rows.map((row) => ({\n    id: row.id,\n    name: row.name,\n    email: row.email,\n    role: row.role as User['role'],\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  }));\n}\n```\n\n#### `packages/core/src/user.ts`\n```typescript\n/**\n * User management: creation, validation, and retrieval.\n */\n\nimport type { User, CreateUserInput } from './types.js';\nimport { validateCreateUser } from './validation.js';\nimport { hasPermission } from './permissions.js';\nimport {\n  createDatabase,\n  createTables,\n  insertUser,\n  findUserById,\n  findAllUsers,\n  type DatabaseConnection,\n} from './database.js';\n\nlet defaultConn: DatabaseConnection | null = null;\n\nexport function getDefaultConnection(): DatabaseConnection {\n  if (!defaultConn) {\n    defaultConn = createDatabase(':memory:');\n    createTables(defaultConn);\n  }\n  return defaultConn;\n}\n\nexport function resetDefaultConnection(): void {\n  if (defaultConn) {\n    defaultConn.close();\n    defaultConn = null;\n  }\n}\n\nexport function registerUser(input: CreateUserInput): User {\n  const validation = validateCreateUser(input);\n  if (!validation.success) {\n    throw new Error(`Invalid user data: ${validation.errors?.join(', ')}`);\n  }\n\n  const conn = getDefaultConnection();\n  return insertUser(conn, input);\n}\n\nexport function validateUser(input: unknown): {\n  valid: boolean;\n  errors?: string[];\n} {\n  const result = validateCreateUser(input);\n  return {\n    valid: result.success,\n    errors: result.errors,\n  };\n}\n\nexport function getUserById(id: number): User | null {\n  const conn = getDefaultConnection();\n  return findUserById(conn, id);\n}\n\nexport function getAllUsers(): User[] {\n  const conn = getDefaultConnection();\n  return findAllUsers(conn);\n}\n\nexport function canUserPerformAction(\n  userRole: User['role'],\n  action: 'read' | 'write' | 'delete'\n): boolean {\n  return hasPermission(userRole, action);\n}\n```\n\n**NOTE:** The user.ts file doesn't export `createUser()` function but the API package imports it. This is a **missing export bug**.\n\n#### `packages/core/src/permissions.ts`\n```typescript\n/**\n * Permission checking and role-based access control.\n */\n\nimport type { Role, Permission } from './types.js';\n\nconst ROLE_PERMISSIONS: Record<Role, Permission[]> = {\n  admin: ['read', 'write', 'delete', 'manage_users', 'view_reports'],\n  user: ['read', 'write', 'view_reports'],\n  viewer: ['read'],\n};\n\nexport function hasPermission(role: Role, permission: Permission): boolean {\n  const permissions = ROLE_PERMISSIONS[role];\n  return permissions.includes(permission);\n}\n\nexport function getAllPermissions(role: Role): Permission[] {\n  return [...ROLE_PERMISSIONS[role]];\n}\n\nexport function canManageUsers(role: Role): boolean {\n  return hasPermission(role, 'manage_users');\n}\n\nexport function canWrite(role: Role): boolean {\n  return hasPermission(role, 'write');\n}\n\nexport function canDelete(role: Role): boolean {\n  return hasPermission(role, 'delete');\n}\n\nexport function requirePermission(\n  role: Role,\n  permission: Permission\n): void {\n  if (!hasPermission(role, permission)) {\n    throw new Error(\n      `Role '${role}' does not have permission '${permission}'`\n    );\n  }\n}\n```\n\n#### `packages/core/src/validation.ts`\n```typescript\n/**\n * Schema validation using zod.\n * Uses z.pipe() for string-to-number coercion (requires zod >= 3.22).\n */\n\nimport { z } from 'zod';\nimport type { Role } from './types.js';\n\nexport const roleSchema = z.enum(['admin', 'user', 'viewer']);\n\nexport const createUserSchema = z.object({\n  name: z\n    .string()\n    .min(1, 'Name is required')\n    .max(100, 'Name must be 100 characters or less'),\n  email: z.string().email('Invalid email address'),\n  role: roleSchema,\n});\n\nexport const userIdSchema = z\n  .string()\n  .pipe(z.coerce.number().int().positive('User ID must be a positive integer'));\n\nexport const userFiltersSchema = z.object({\n  role: roleSchema.optional(),\n  search: z.string().optional(),\n  limit: z\n    .string()\n    .pipe(z.coerce.number().int().min(1).max(100))\n    .optional()\n    .default('20'),\n  offset: z\n    .string()\n    .pipe(z.coerce.number().int().min(0))\n    .optional()\n    .default('0'),\n});\n\nexport function validateCreateUser(data: unknown): {\n  success: boolean;\n  data?: { name: string; email: string; role: Role };\n  errors?: string[];\n} {\n  const result = createUserSchema.safeParse(data);\n  if (result.success) {\n    return { success: true, data: result.data };\n  }\n  return {\n    success: false,\n    errors: result.error.errors.map((e) => e.message),\n  };\n}\n\nexport function validateUserId(id: string): {\n  success: boolean;\n  data?: number;\n  errors?: string[];\n} {\n  const result = userIdSchema.safeParse(id);\n  if (result.success) {\n    return { success: true, data: result.data };\n  }\n  return {\n    success: false,\n    errors: result.error.errors.map((e) => e.message),\n  };\n}\n```\n\n#### `packages/core/tests/` (Test Files)\n\n**permissions.test.ts**\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport {\n  hasPermission,\n  getAllPermissions,\n  canManageUsers,\n  canWrite,\n  canDelete,\n  requirePermission,\n} from '../src/permissions.js';\n\ndescribe('Permissions', () => {\n  it('admin has all permissions', () => {\n    expect(hasPermission('admin', 'read')).toBe(true);\n    expect(hasPermission('admin', 'write')).toBe(true);\n    expect(hasPermission('admin', 'delete')).toBe(true);\n    expect(hasPermission('admin', 'manage_users')).toBe(true);\n    expect(hasPermission('admin', 'view_reports')).toBe(true);\n  });\n\n  it('viewer can only read', () => {\n    expect(hasPermission('viewer', 'read')).toBe(true);\n    expect(hasPermission('viewer', 'write')).toBe(false);\n    expect(hasPermission('viewer', 'delete')).toBe(false);\n  });\n\n  it('returns all permissions for a role', () => {\n    const perms = getAllPermissions('user');\n    expect(perms).toContain('read');\n    expect(perms).toContain('write');\n    expect(perms).not.toContain('delete');\n  });\n\n  it('canManageUsers is true only for admin', () => {\n    expect(canManageUsers('admin')).toBe(true);\n    expect(canManageUsers('user')).toBe(false);\n    expect(canManageUsers('viewer')).toBe(false);\n  });\n\n  it('canWrite is true for admin and user', () => {\n    expect(canWrite('admin')).toBe(true);\n    expect(canWrite('user')).toBe(true);\n    expect(canWrite('viewer')).toBe(false);\n  });\n\n  it('canDelete is true only for admin', () => {\n    expect(canDelete('admin')).toBe(true);\n    expect(canDelete('user')).toBe(false);\n  });\n\n  it('requirePermission throws when permission is missing', () => {\n    expect(() => requirePermission('viewer', 'write')).toThrow(\n      \"Role 'viewer' does not have permission 'write'\"\n    );\n  });\n});\n```\n\n**user.test.ts**\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport {\n  registerUser,\n  validateUser,\n  getUserById,\n  getAllUsers,\n  resetDefaultConnection,\n} from '../src/user.js';\n\ndescribe('User Management', () => {\n  beforeEach(() => {\n    resetDefaultConnection();\n  });\n\n  it('registers a new user with valid data', () => {\n    const user = registerUser({\n      name: 'Alice',\n      email: 'alice@example.com',\n      role: 'admin',\n    });\n    expect(user.id).toBe(1);\n    expect(user.name).toBe('Alice');\n    expect(user.email).toBe('alice@example.com');\n    expect(user.role).toBe('admin');\n  });\n\n  it('throws on invalid user data', () => {\n    expect(() =>\n      registerUser({ name: '', email: 'bad', role: 'admin' })\n    ).toThrow('Invalid user data');\n  });\n\n  it('retrieves a user by id', () => {\n    const created = registerUser({\n      name: 'Bob',\n      email: 'bob@example.com',\n