function createApp() {\n  const app = express();\n\n  app.use(express.json());\n\n  // Health check\n  app.get('/health', (_req, res) => {\n    res.json({ status: 'ok' });\n  });\n\n  // Public routes\n  app.use('/auth', authRouter);\n\n  // Protected routes\n  app.use('/users', authMiddleware, usersRouter);\n\n  // Error handler\n  app.use(\n    (\n      err: Error,\n      _req: express.Request,\n      res: express.Response,\n      _next: express.NextFunction\n    ) => {\n      console.error(err.message);\n      res.status(500).json({ error: 'Internal server error' });\n    }\n  );\n\n  return app;\n}\n\n// Start server if run directly\nconst isMainModule = process.argv[1]?.includes('api/dist/index.js');\nif (isMainModule) {\n  const port = process.env['PORT'] || 3000;\n  const app = createApp();\n  app.listen(port, () => {\n    console.log(`API server running on port ${port}`);\n  });\n}\n```\n\n#### `packages/api/src/middleware/auth.ts`\n```typescript\n/**\n * Authentication middleware using core permissions.\n */\n\nimport type { Request, Response, NextFunction } from 'express';\nimport { hasPermission, type Role, type Permission } from '@monorepo/core';\n\n/**\n * Basic auth middleware that checks for a token header.\n * In this benchmark, we use a simplified mock auth system.\n */\nexport function authMiddleware(\n  req: Request,\n  res: Response,\n  next: NextFunction\n): void {\n  const token = req.headers['authorization']?.replace('Bearer ', '');\n\n  // Allow requests with valid mock tokens or role headers\n  if (token?.startsWith('mock-token-') || req.headers['x-user-role']) {\n    next();\n    return;\n  }\n\n  res.status(401).json({ error: 'Authentication required' });\n}\n\n/**\n * Middleware factory to require a specific permission.\n */\nexport function requirePermissionMiddleware(permission: Permission) {\n  return (req: Request, res: Response, next: NextFunction): void => {\n    const role = (req.headers['x-user-role'] as Role) || 'viewer';\n\n    if (!hasPermission(role, permission)) {\n      res.status(403).json({\n        error: `Permission '${permission}' required`,\n      });\n      return;\n    }\n\n    next();\n  };\n}\n```\n\n#### `packages/api/src/routes/auth.ts`\n```typescript\n/**\n * Authentication routes.\n */\n\nimport { Router, type Request, type Response } from 'express';\nimport { validateCreateUser, registerUser, type Role } from '@monorepo/core';\n\nexport const authRouter = Router();\n\n// Simple registration (public)\nauthRouter.post('/register', (req: Request, res: Response) => {\n  try {\n    const validation = validateCreateUser({\n      ...req.body,\n      role: 'user', // Force 'user' role for self-registration\n    });\n\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = registerUser({\n      name: req.body.name,\n      email: req.body.email,\n      role: 'user' as Role,\n    });\n\n    res.status(201).json({\n      user,\n      token: `mock-token-${user.id}`, // Simplified for benchmark\n    });\n  } catch (err) {\n    if (err instanceof Error && err.message.includes('UNIQUE')) {\n      res.status(409).json({ error: 'Email already registered' });\n      return;\n    }\n    res.status(500).json({ error: 'Registration failed' });\n  }\n});\n\n// Simple login (mock)\nauthRouter.post('/login', (req: Request, res: Response) => {\n  try {\n    const { email } = req.body as { email?: string };\n    if (!email) {\n      res.status(400).json({ error: 'Email is required' });\n      return;\n    }\n\n    // In a real app, we'd verify credentials\n    res.json({\n      token: `mock-token-for-${email}`,\n      message: 'Login successful',\n    });\n  } catch (err) {\n    res.status(500).json({ error: 'Login failed' });\n  }\n});\n\n// Token validation (mock)\nauthRouter.get('/verify', (req: Request, res: Response) => {\n  const token = req.headers['authorization']?.replace('Bearer ', '');\n  if (!token) {\n    res.status(401).json({ error: 'No token provided' });\n    return;\n  }\n\n  // Simplified: any token with correct format is valid\n  if (token.startsWith('mock-token-')) {\n    res.json({ valid: true, token });\n  } else {\n    res.status(401).json({ valid: false, error: 'Invalid token' });\n  }\n});\n```\n\n#### `packages/api/src/routes/users.ts`\n```typescript\n/**\n * User CRUD routes.\n */\n\nimport { Router, type Request, type Response } from 'express';\nimport {\n  createUser,\n  getUserById,\n  getAllUsers,\n  validateCreateUser,\n  validateUserId,\n  canManageUsers,\n  type Role,\n} from '@monorepo/core';\n\nexport const usersRouter = Router();\n\n// List all users\nusersRouter.get('/', (_req: Request, res: Response) => {\n  try {\n    const users = getAllUsers();\n    res.json({ users });\n  } catch (err) {\n    res.status(500).json({ error: 'Failed to fetch users' });\n  }\n});\n\n// Get user by ID\nusersRouter.get('/:id', (req: Request, res: Response) => {\n  try {\n    const validation = validateUserId(req.params['id']!);\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = getUserById(validation.data!);\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    res.json({ user });\n  } catch (err) {\n    res.status(500).json({ error: 'Failed to fetch user' });\n  }\n});\n\n// Create a new user\nusersRouter.post('/', (req: Request, res: Response) => {\n  try {\n    const callerRole = (req.headers['x-user-role'] as Role) || 'viewer';\n    if (!canManageUsers(callerRole)) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const validation = validateCreateUser(req.body);\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = createUser(req.body);\n    res.status(201).json({ user });\n  } catch (err) {\n    if (err instanceof Error && err.message.includes('UNIQUE')) {\n      res.status(409).json({ error: 'Email already exists' });\n      return;\n    }\n    res.status(500).json({ error: 'Failed to create user' });\n  }\n});\n\n// Delete user by ID\nusersRouter.delete('/:id', (req: Request, res: Response) => {\n  try {\n    const callerRole = (req.headers['x-user-role'] as Role) || 'viewer';\n    if (!canManageUsers(callerRole)) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const validation = validateUserId(req.params['id']!);\n    if (!validation.success) {\n      res.status(400).json({ errors: validation.errors });\n      return;\n    }\n\n    const user = getUserById(validation.data!);\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n\n    // In a real app, we'd delete here\n    res.status(200).json({ message: 'User deleted', user });\n  } catch (err) {\n    res.status(500).json({ error: 'Failed to delete user' });\n  }\n});\n```\n\n#### `packages/api/tests/auth.test.ts`\n```typescript\nimport { describe, it, expect, beforeEach } from 'vitest';\nimport request from 'supertest';\nimport { createApp } from '../src/index.js';\nimport { resetDefaultConnection } from '@monorepo/core';\n\ndescribe('Auth Routes', () => {\n  let app: ReturnType<typeof createApp>;\n\n  beforeEach(() => {\n    resetDefaultConnection();\n    app = createApp();\n  });\n\n  it('registers a new user', async () => {\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ name: 'New User', email: 'new@test.com' });\n    expect(res.status).toBe(201);\n    expect(res.body.token).toBeDefined();\n    expect(res.body.user.role).toBe('user');\n  });\n\n  it('rejects registration with invalid data', async () => {\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ name: '', email: 'bad' });\n    expect(res.status).toBe(400);\n  });\n\n  it('handles login