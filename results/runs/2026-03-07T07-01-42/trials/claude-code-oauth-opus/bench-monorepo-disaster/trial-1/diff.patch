  stdout = execSync(\n        'npx madge --circular --extensions ts packages/',\n        { cwd: ROOT_DIR, encoding: 'utf-8', timeout: 30000, stdio: ['pipe', 'pipe', 'pipe'] }\n      );\n    } catch (err) {\n      const error = err as { stdout?: string; stderr?: string; status?: number };\n      stdout = error.stdout || '';\n      exitCode = error.status || 1;\n    }\n\n    if (exitCode !== 0) {\n      throw new Error(`Circular dependencies found:\\n${stdout}`);\n    }\n  });\n\n  it('has no merge conflict markers in any TypeScript file', () => {\n    const tsFiles = getAllTsFiles(join(ROOT_DIR, 'packages'));\n    const filesWithMarkers: string[] = [];\n\n    for (const file of tsFiles) {\n      const content = readFileSync(file, 'utf-8');\n      if (\n        content.includes('<<<<<<<') ||\n        content.includes('>>>>>>>') ||\n        content.includes('=======\\n')\n      ) {\n        filesWithMarkers.push(file.replace(ROOT_DIR + '/', ''));\n      }\n    }\n\n    expect(filesWithMarkers).toEqual([]);\n  });\n\n  it('has no .env files with secrets', () => {\n    const allFiles = getAllFiles(ROOT_DIR);\n    const envFiles = allFiles.filter((f) => {\n      const name = f.split('/').pop() || '';\n      return name === '.env' || name.match(/^\\.env\\./);\n    });\n\n    const envFilesWithSecrets: string[] = [];\n    for (const envFile of envFiles) {\n      const content = readFileSync(envFile, 'utf-8');\n      if (\n        content.includes('PASSWORD') ||\n        content.includes('SECRET') ||\n        content.includes('TOKEN') ||\n        content.includes('API_KEY')\n      ) {\n        envFilesWithSecrets.push(envFile.replace(ROOT_DIR + '/', ''));\n      }\n    }\n\n    expect(envFilesWithSecrets).toEqual([]);\n  });\n\n  it('all packages build successfully', () => {\n    try {\n      execSync('npx tsc -b --force', {\n        cwd: ROOT_DIR,\n        encoding: 'utf-8',\n        timeout: 60000,\n      });\n    } catch (err) {\n      const error = err as { stdout?: string; stderr?: string };\n      throw new Error(\n        `Build failed:\\n${error.stdout || ''}${error.stderr || ''}`\n      );\n    }\n  });\n\n  it('TypeScript strict mode is enabled in all packages', () => {\n    const packages = ['core', 'api', 'worker'];\n\n    for (const pkg of packages) {\n      const tsconfigPath = join(ROOT_DIR, 'packages', pkg, 'tsconfig.json');\n      expect(existsSync(tsconfigPath), `${pkg}/tsconfig.json must exist`).toBe(\n        true\n      );\n\n      const tsconfig = JSON.parse(readFileSync(tsconfigPath, 'utf-8'));\n      expect(\n        tsconfig.compilerOptions?.strict,\n        `${pkg} must have strict: true`\n      ).toBe(true);\n    }\n  });\n});\n```\n\n---\n\n## KEY ISSUES IDENTIFIED\n\n### 1. **MERGE CONFLICT in `/workspace/packages/api/tests/users.test.ts`** (Lines 14-28)\n   - Git merge markers present: `<<<<<<<`, `=======`, `>>>>>>>`\n   - Conflicting test implementations for user creation route\n\n### 2. **Missing Export in `/workspace/packages/core/src/user.ts`**\n   - The file imports `createUser` in `packages/api/src/routes/users.ts` (line 7)\n   - But `createUser` is NOT exported from `packages/core/src/user.ts`\n   - This will cause a runtime/compilation error\n\n### 3. **Secrets in `.env` file** (Will fail structural test)\n   - Contains `DB_PASSWORD=super_secret_password_123`\n   - The structural test checks for PASSWORD, SECRET, TOKEN, API_KEY keywords\n   - This file should NOT be committed to version control\n\n### 4. **Package Dependencies**\n   - `/workspace/packages/api` imports `createUser` from `@monorepo/core` which doesn't exist\n   - `/workspace/packages/worker` also imports `createUser` which is missing\n\n---\n\n## DEPENDENCY GRAPH\n\n```\n@monorepo/core (standalone library)\n├── dependencies: zod, better-sqlite3\n├── exports: User types, validation, database, permissions, user management\n\n@monorepo/api (Express REST API)\n├── depends on: @monorepo/core\n├── adds: Express, Supertest (dev)\n├── expose