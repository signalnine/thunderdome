\n        let result: number;\n        switch (gate.op) {\n          case 'AND':\n            result = v1 & v2;\n            break;\n          case 'OR':\n            result = v1 | v2;\n            break;\n          case 'XOR':\n            result = v1 ^ v2;\n            break;\n        }\n        wires[gate.out] = result;\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Find the number of input bits\n  const xWires = new Set<string>();\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      if (w.startsWith('x')) xWires.add(w);\n    }\n  }\n  const numBits = xWires.size;\n\n  // Build lookup: find a gate by op and inputs (order-independent)\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string,\n  ): Gate | undefined {\n    for (const g of gates) {\n      if (\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1))\n      ) {\n        return g;\n      }\n    }\n    return undefined;\n  }\n\n  // Find gates using a particular wire as input, filtered by op\n  function findGatesUsing(wire: string, op: Gate['op']): Gate[] {\n    return gates.filter(\n      (g) => g.op === op && (g.in1 === wire || g.in2 === wire),\n    );\n  }\n\n  // Get the other input of a gate given one input\n  function otherInput(g: Gate, wire: string): string {\n    return g.in1 === wire ? g.in2 : g.in1;\n  }\n\n  const swapped = new Set<string>();\n\n  // Track carry wire name through each bit\n  let carry = '';\n\n  // Bit 0: z00 = x00 XOR y00, c00 = x00 AND y00\n  {\n    const xorGate = findGate('XOR', 'x00', 'y00')!;\n    const andGate = findGate('AND', 'x00', 'y00')!;\n\n    if (xorGate.out !== 'z00') {\n      swapped.add('z00');\n      swapped.add(xorGate.out);\n    }\n\n    carry = andGate.out;\n  }\n\n  for (let i = 1; i < numBits; i++) {\n    const xi = `x${String(i).padStart(2, '0')}`;\n    const yi = `y${String(i).padStart(2, '0')}`;\n    const zi = `z${String(i).padStart(2, '0')}`;\n\n    // xorXY: x_i XOR y_i -> partialSum\n    const xorXY = findGate('XOR', xi, yi)!;\n    let partialSum = xorXY.out;\n\n    // andXY: x_i AND y_i -> generate\n    const andXY = findGate('AND', xi, yi)!;\n    let generate = andXY.out;\n\n    // sumGate: partialSum XOR carry -> z_i\n    let sumGate = findGate('XOR', partialSum, carry);\n\n    if (!sumGate) {\n      // partialSum or carry is wrong. One of them was swapped with something.\n      // Strategy: Look for XOR gates that use carry as input (not the x_i XOR y_i gate).\n      // There should be exactly one such gate in a correct adder (the sum gate for bit i).\n      const xorWithCarry = findGatesUsing(carry, 'XOR').filter(\n        (g) => !((g.in1 === xi || g.in1 === yi) && (g.in2 === xi || g.in2 === yi)),\n      );\n\n      if (xorWithCarry.length === 1) {\n        // carry is correct; partialSum is wrong\n        const correctPartialSum = otherInput(xorWithCarry[0], carry);\n        swapped.add(partialSum);\n        swapped.add(correctPartialSum);\n        partialSum = correctPartialSum;\n        sumGate = xorWithCarry[0];\n      } else {\n        // carry is wrong. Look for XOR gates that use partialSum (not x_i XOR y_i).\n        const xorWithPartial = findGatesUsing(partialSum, 'XOR').filter(\n          (g) => !((g.in1 === xi || g.in1 === yi) && (g.in2 === xi || g.in2 === yi)),\n        );\n        if (xorWithPartial.length === 1) {\n          const correctCarry = otherInput(xorWithPartial[0], partialSum);\n          swapped.add(carry);\n          swapped.add(correctCarry);\n          carry = correctCarry;\n          sumGate = xorWithPartial[0];\n        }\n      }\n    }\n\n    if (sumGate) {\n      if (sumGate.out !== zi) {\n        swapped.add(sumGate.out);\n        swapped.add(zi);\n\n        // Fix up references: if generate or carry was named zi, update\n        if (generate === 