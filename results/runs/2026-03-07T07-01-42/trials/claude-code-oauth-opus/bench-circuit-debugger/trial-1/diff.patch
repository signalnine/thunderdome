op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 1, x03: 0,\n      y00: 1, y01: 1, y02: 1, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    // 7 + 7 = 14 = 01110\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function make4BitAdder(): Gate[] {\n    return [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n  }\n\n  function swapOutputs(gates: Gate[], w1: string, w2: string): void {\n    const g1 = gates.find((g) => g.out === w1)!;\n    const g2 = gates.find((g) => g.out === w2)!;\n    g1.out = w2;\n    g2.out = w1;\n  }\n\n  it('should find z-wire swaps', () => {\n    const gates = make4BitAdder();\n    // Swap z01 with a01, z02 with a02, z03 with a03, z04 with b03\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z02', 'a02');\n    swapOutputs(gates, 'z03', 'a03');\n    swapOutputs(gates, 'z04', 'b03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'a02', 'a03', 'b03', 'z01', 'z02', 'z03', 'z04'].sort(),\n    );\n  });\n\n  it('should detect swaps at bit 0', () => {\n    const gates = make4BitAdder();\n    swapOutputs(gates, 'z00', 'c00');\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z02', 'a02');\n    swapOutputs(gates, 'z03', 'a03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'a02', 'a03', 'c00', 'z00', 'z01', 'z02', 'z03'].sort(),\n    );\n  });\n\n  it('should detect generate swapped across bits', () => {\n    const gates = make4BitAdder();\n    // Swap generate from bit 1 with z02, and carry from bit 1 with z03\n    swapOutputs(gates, 'a01', 'z02');\n    swapOutputs(gates, 'c01', 'z03');\n    swapOutputs(gates, 'z00', 'c00');\n    swapOutputs(gates, 'z04', 'b03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'b03', 'c00', 'c01', 'z00', 'z02', 'z03', 'z04'].sort(),\n    );\n  });\n\n  it('should detect carry swapped with z wire', () => {\n    const gates = make4BitAdder();\n    // Swap carry with z wire, and generate with z wire\n    swapOutputs(gates, 'c00', 'z01');\n    swapOutputs(gates, 'c01', 'z02');\n    swapOutputs(gates, 'c02', 'z03');\n    swapOutputs(gates, 'z04', 'a03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a03', 'c00', 'c01', 'c02', 'z01', 'z02', 'z03', 'z04'].sort(),\n    );\n  });\n\n  it('should detect mixed swaps', () => {\n    const gates = make4BitAdder();\n    // z01 <-> a01: Gate(t01 XOR c00 -> z01) and Gate(x01 AND y01 -> a01)\n    // Neither gate uses the other's output as input. Safe.\n    swapOutputs(gates, 'z01', 'a01');\n    // z02 <-> c01: Gate(t02 XOR c01 -> z02) uses c01 as input!\n    // So we can't swap z02 with c01. Use z02 <-> a02 instead.\n    swapOutputs(gates, 'z02', 'a02');\n    // z03 <-> b02: Gate(t03 XOR c02 -> z03) doesn't use b02.\n    // Gate(t02 AND c01 -> b02) doesn't use z03. Safe.\n    swapOutputs(gates, 'z03', 'b02');\n    // z04 <-> c00: Gate(a03 OR b03 -> z04) doesn't use c00.\n    // Gate(x00 AND y00 -> c00) doesn't use z04. Safe.\n    swapOutputs(gates, 'z04', 'c00');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'a02', 'b02', 'c00', 'z01', 'z02', 'z03', 'z04'].sort(),\n    );\n  });\n\n  it('should work with larger adder (8-bit)', () => {\n    const gates: Gate[] = [];\n    // Build an 8-bit adder\n    // Bit 0\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n    // Bits 1-6\n    for (let i = 1; i < 7; i++) {\n      const xi = `x${String(i).padStart(2, '0')}`;\n      const yi = `y${String(i).padStart(2, '0')}`;\n      const zi = `z${String(i).padStart(2, '0')}`;\n      const ti = `t${String(i).padStart(2, '0')}`;\n      const ai = `a${String(i).padStart(2, '0')}`;\n      const bi = `b${String(i).padStart(2, '0')}`;\n      const ci = `c${String(i).padStart(2, '0')}`;\n      const cprev = `c${String(i - 1).padStart(2, '0')}`;\n\n      gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n      gates.push({ op: 'XOR', in1: ti, in2: cprev, out: zi });\n      gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n      gates.push({ op: 'AND', in1: ti, in2: cprev, out: bi });\n      gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n    }\n    // Bit 7 (last bit): carry out is z08\n    {\n      const i = 7;\n      const xi = `x${String(i).padStart(2, '0')}`;\n      const yi = `y${String(i).padStart(2, '0')}`;\n      const ti = `t${String(i).padStart(2, '0')}`;\n      const ai = `a${String(i).padStart(2, '0')}`;\n      const bi = `b${String(i).padStart(2, '0')}`;\n      const cprev = 