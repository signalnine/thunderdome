+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      const v1 = wires[gate.in1];
+      const v2 = wires[gate.in2];
+      if (v1 !== undefined && v2 !== undefined) {
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = v1 & v2;
+            break;
+          case 'OR':
+            result = v1 | v2;
+            break;
+          case 'XOR':
+            result = v1 ^ v2;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Find the number of input bits
+  const xWires = new Set<string>();
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      if (w.startsWith('x')) xWires.add(w);
+    }
+  }
+  const numBits = xWires.size;
+  const lastZ = `z${String(numBits).padStart(2, '0')}`;
+
+  function hasXYInputs(g: Gate): boolean {
+    return (
+      (g.in1.startsWith('x') || g.in1.startsWith('y')) &&
+      (g.in2.startsWith('x') || g.in2.startsWith('y'))
+    );
+  }
+
+  function isBit0XY(g: Gate): boolean {
+    return g.in1 === 'x00' || g.in2 === 'x00' || g.in1 === 'y00' || g.in2 === 'y00';
+  }
+
+  function feedsInto(wire: string, op: Gate['op']): boolean {
+    return gates.some(
+      (g) => g.op === op && (g.in1 === wire || g.in2 === wire),
+    );
+  }
+
+  function findGate(
+    op: Gate['op'],
+    in1: string,
+    in2: string,
+  ): Gate | undefined {
+    for (const g of gates) {
+      if (
+        g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) ||
+          (g.in1 === in2 && g.in2 === in1))
+      ) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  function findGatesUsingExcept(
+    wire: string,
+    op: Gate['op'],
+    exclude: Gate,
+  ): Gate[] {
+    return gates.filter(
+      (g) =>
+        g !== exclude && g.op === op && (g.in1 === wire || g.in2 === wire),
+    );
+  }
+
+  function otherInput(g: Gate, wire: string): string {
+    return g.in1 === wire ? g.in2 : g.in1;
+  }
+
+  // --- Rule-based detection ---
+  const swapped = new Set<string>();
+
+  for (const g of gates) {
+    const out = g.out;
+    const isZWire = out.startsWith('z');
+
+    if (g.op === 'XOR') {
+      if (hasXYInputs(g)) {
+        if (isBit0XY(g)) {
+          if (out !== 'z00') {
+            swapped.add(out);
+          }
+        } else {
+          if (isZWire) {
+            swapped.add(out);
+          } else if (!feedsInto(out, 'XOR') || !feedsInto(out, 'AND')) {
+            swapped.add(out);
+          }
+        }
+      } else {
+        if (!isZWire) {
+          swapped.add(out);
+        }
+      }
+    } else if (g.op === 'AND') {
+      if (isBit0XY(g)) {
+        if (isZWire) {
+          swapped.add(out);
+        }
+      } else {
+        if (!feedsInto(out, 'OR')) {
+          swapped.add(out);
+        }
+      }
+    } else {
+      // OR gate
+      if (isZWire && out !== lastZ) {
+        swapped.add(out);
+      }
+      if (!isZWire && out !== lastZ) {
+        if (!feedsInto(out, 'XOR') || !feedsInto(out, 'AND')) {
+          swapped.add(out);
+        }
+      }
+    }
+  }
+
+  // --- Carry chain tracing to find remaining swaps ---
+  // This catches cases where two OR gates (carry outputs) swapped with each other
+  // and one of them is lastZ. Rules can't catch this because both OR outputs
+  // look structurally correct.
+  if (swapped.size < 8) {
+    let carry = '';
+
+    // Bit 0
+    {
+      const andGate = findGate('AND', 'x00', 'y00')!;
+      carry = andGate.out;
+      // If carry was detected as swapped, we can't trace further reliably
+      // But we still try because the carry wire name is what the AND gate says
+    }
+
+    for (let i = 1; i < numBits; i++) {
+      const xi = `x${String(i).padStart(2, '0')}`;
+      const yi = `y${String(i).padStart(2, '0')}`;
+
+      const xorXY = findGate('XOR', xi, yi)!;
+      let partialSum = xorXY.out;
+
+      // If partialSum was already flagged as swapped, skip tracing this bit
+      if (swapped.has(partialSum)) {
+        // We can't determine carry for this bit; try to find carry by
+        // looking for the OR gate that feeds into the next bit
+        // Skip this bit's carry tracing
+        continue;
+      }
+
+      const andXY = findGate('AND', xi, yi)!;
+      let generate = andXY.out;
+
+      let sumGate = findGate('XOR', partialSum, carry);
+
+      if (!sumGate) {
+        // Try to find via carry
+        const xorWithCarry = findGatesUsingExcept(carry, 'XOR', xorXY);
+        if (xorWithCarry.length === 1) {
+          partialSum = otherInput(xorWithCarry[0], carry);
+          sumGate = xorWithCarry[0];
+        } else {
+          const xorWithPartial = findGatesUsingExcept(partialSum, 'XOR', xorXY);
+          if (xorWithPartial.length === 1) {
+            carry = otherInput(xorWithPartial[0], partialSum);
+            sumGate = xorWithPartial[0];
+          }
+        }
+      }
+
+      if (sumGate && sumGate.out !== `z${String(i).padStart(2, '0')}`) {
+        if (generate === `z${String(i).padStart(2, '0')}`) {
+          generate = sumGate.out;
+        }
+        if (carry === `z${String(i).padStart(2, '0')}`) {
+          carry = sumGate.out;
+        }
+      }
+
+      // Find carry out
+      const propGate = findGate('AND', partialSum, carry);
+      const propagate = propGate ? propGate.out : '';
+
+      let carryGate = findGate('OR', generate, propagate);
+
+      if (!carryGate) {
+        if (propagate) {
+          const orGates = gates.filter(
+            (g) =>
+              g.op === 'OR' &&
+              (g.in1 === propagate || g.in2 === propagate),
+          );
+          if (orGates.length === 1) {
+            generate = otherInput(orGates[0], propagate);
+            carryGate = orGates[0];
+          }
+        }
+        if (!carryGate) {
+          const orGates = gates.filter(
+            (g) =>
+              g.op === 'OR' &&
+              (g.in1 === generate || g.in2 === generate),
+          );
+          if (orGates.length === 1) {
+            carryGate = orGates[0];
+          }
+        }
+      }
+
+      carry = carryGate ? carryGate.out : carry;
+    }
+
+    // Check final carry
+    if (carry !== lastZ) {
+      swapped.add(carry);
+      swapped.add(lastZ);
+    }
+  }
+
+  return [...swapped].sort();
+}
