c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 0, x03: 0,\n      y00: 1, y01: 0, y02: 1, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(0);\n  });\n\n  it('should simulate 7 + 7 = 14', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 1, x03: 0,\n      y00: 1, y01: 1, y02: 1, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function make4BitAdder(): Gate[] {\n    return [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n  }\n\n  function swapOutputs(gates: Gate[], w1: string, w2: string): void {\n    const g1 = gates.find((g) => g.out === w1)!;\n    const g2 = gates.find((g) => g.out === w2)!;\n    g1.out = w2;\n    g2.out = w1;\n  }\n\n  it('should find z-wire swapped with generate', () => {\n    const gates = make4BitAdder();\n    // Valid swaps: z01<->a01, z02<->a02, z03<->a03, z04<->c02\n    // Verify no cycles:\n    // z01: gate(t01 XOR c00), a01: gate(x01 AND y01) - no cross input deps\n    // z02: gate(t02 XOR c01), a02: gate(x02 AND y02) - no cross input deps\n    // z03: gate(t03 XOR c02), a03: gate(x03 AND y03) - no cross input deps\n    // z04: gate(a03 OR b03), c02: gate(a02 OR b02) - z04 doesn't use c02, c02 doesn't use z04. Safe.\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z02', 'a02');\n    swapOutputs(gates, 'z03', 'a03');\n    swapOutputs(gates, 'z04', 'c02');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'a02', 'a03', 'c02', 'z01', 'z02', 'z03', 'z04'].sort(),\n    );\n  });\n\n  it('should detect swaps at bit 0', () => {\n    const gates = make4BitAdder();\n    // z00<->c00: gate(x00 XOR y00) and gate(x00 AND y00) - safe, no cross deps\n    // z01<->a01, z02<->a02, z03<->a03: all safe (different gate types, no cross deps)\n    swapOutputs(gates, 'z00', 'c00');\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z02', 'a02');\n    swapOutputs(gates, 'z03', 'a03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'a02', 'a03', 'c00', 'z00', 'z01', 'z02', 'z03'].sort(),\n    );\n  });\n\n  it('should detect carry swapped with z wire', () => {\n    const gates = make4BitAdder();\n    // c00<->z01: gate(x00 AND y00) doesn't use z01, gate(t01 XOR c00) uses c00. Safe?\n    // gate(t01 XOR c00 -> z01) becomes gate(t01 XOR c00 -> c00): c00 is input AND output. CYCLE!\n    // Instead use c00<->z02: gate(x00 AND y00) doesn't use z02, gate(t02 XOR c01 -> z02) doesn't use c00. Safe.\n    swapOutputs(gates, 'c00', 'z02');\n    // c01<->z03: gate(a01 OR b01 -> c01) doesn't use z03, gate(t03 XOR c02 -> z03) doesn't use c01. Safe.\n    swapOutputs(gates, 'c01', 'z03');\n    // z01<->a01: safe as before\n    swapOutputs(gates, 'z01', 'a01');\n    // z04<->b02: gate(a03 OR b03 -> z04) doesn't use b02, gate(t02 AND c01 -> b02) doesn't use z04. Safe.\n    swapOutputs(gates, 'z04', 'b02');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'b02', 'c00', 'c01', 'z01', 'z02', 'z03', 'z04'].sort(),\n    );\n  });\n\n  it('should detect mixed swaps across bits', () => {\n    const gates = make4BitAdder();\n    // z01<->a02: gate(t01 XOR c00 -> z01) doesn't use a02, gate(x02 AND y02 -> a02) doesn't use z01. Safe.\n    swapOutputs(gates, 'z01', 'a02');\n    // z02<->b01: gate(t02 XOR c01 -> z02) doesn't use b01, gate(t01 AND c00 -> b01) doesn't use z02. Safe.\n    swapOutputs(gates, 'z02', 'b01');\n    // z03<->b02: gate(t03 XOR c02 -> z03) doesn't use b02, gate(t02 AND c01 -> b02) doesn't use z03. Safe.\n    swapOutputs(gates, 'z03', 'b02');\n    // z04<->b03: gate(a03 OR b03 -> z04) uses b03! CYCLE!\n    // Use z04<->a02... already used. Use z04<->c01.\n    // z04<->c01: gate(a03 OR b03 -> z04) doesn't use c01, gate(a01 OR b01 -> c01) doesn't use z04. Safe.\n    swapOutputs(gates, 'z04', 'c01');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a02', 'b01', 'b02', 'c01', 'z01', 'z02', 'z03', 'z04'].sort(),\n    );\n  });\n\n  it('should work with larger adder (8-bit)', () => {\n    const gates: Gate[] = [];\n    // Bit 0\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n    // Bits 1-6\n    for (let i = 1; i < 7; i++) {\n      const xi = `x${String(i).padStart(2, '0')}`;\n      const yi = `y${String(i).padStart(2, '0')}`;\n      const zi = `z${String(i).padStart(2, '0')}`;\n      const ti = `t${String(i).padStart(2, '0')}`;\n      const ai = `a${String(i).padStart(2, '0')}`;\n      const bi = `b${String(i).padStart(2, '0')}`;\n      const ci = `c${String(i).padStart(2, '0')}`;\n      const cprev = `c${String(i - 1).padStart(2, '0')}`;\n\n      gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n      gates.push({ op: 'XOR', in1: ti, in2: cprev, out: zi });\n      gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n      gates.push({ op: 'AND', in1: ti, in2: cprev, out: bi });\n      gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n    }\n    // Bit 7 (last bit): carry out is z08\n    {\n      const i = 7;\n      const xi = `x${String(i).padStart(2, '0')}`;\n      const yi = `y${String(i).padStart(2, '0')}`;\n      const ti = `t${String(i).padStart(2, '0')}`;\n      const ai = `a${String(i).padStart(2, '0')}`;\n      const bi = `b${String(i).padStart(2, '0')}`;\n      const cprev = `c${String(i - 1).padStart(2, '0')}`;\n\n      gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n      gates.push({ op: 'XOR', in1: ti, in2: cprev, out: 'z07' });\n      gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n      gates.push({ op: 'AND', in1: ti, in2: cprev, out: bi });\n      gates.push({ op: 'OR', in1: ai, in2: bi, out: 'z08' });\n    }\n\n    // Valid swaps (verified no cycles):\n    // z01<->a01: safe\n    swapOutputs(gates, 'z01', 'a01');\n    // z04<->a04: safe\n    swapOutputs(gates, 'z04', 'a04');\n    // z06<->a06: safe\n    swapOutputs(gates, 'z06', 'a06');\n    // z08<->c05: gate(a07 OR b07 -> z08) doesn't use c05, gate(a05 OR b05 -> c05) doesn't use z08. Safe.\n    swapOutputs(gates, 'z08', 'c05');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'a04', 'a06', 'c05', 'z01', 'z04', 'z06', 'z08'].sort(),\n    );\n  });\n});\n","structuredPatch":[{"oldStart":198,"oldLines":20,"newStart":198,"newLines":19,"lines":[" ","   it('should detect mixed swaps across bits', () => {","     const gates = make4BitAdder();","-    // z01<->a02: gate(t01 XOR c00 -> z01) doesn't use a02, gate(x02 AND y02 -> a02) doesn't use z01. Safe.","+    // z01<->a02: safe","     swapOutputs(gates, 'z01', 'a02');","-    // z02<->b01: gate(t02 XOR c01 -> z02) doesn