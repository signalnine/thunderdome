+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from './index.js';
+
+describe('simulate', () => {
+  it('should simulate a simple AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 1 });
+    expect(result.c).toBe(1);
+    expect(result.a).toBe(1);
+    expect(result.b).toBe(1);
+  });
+
+  it('should simulate AND with 0 input', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const result = simulate(gates, { a: 1, b: 0 });
+    expect(result.c).toBe(0);
+  });
+
+  it('should simulate OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);
+    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);
+  });
+
+  it('should simulate XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);
+    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);
+  });
+
+  it('should simulate a chain of dependent gates', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    const result = simulate(gates, { a: 1, b: 1, d: 0 });
+    expect(result.c).toBe(1);
+    expect(result.e).toBe(1);
+  });
+
+  it('should handle gates in any order', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    const result = simulate(gates, { a: 1, b: 1, d: 0 });
+    expect(result.c).toBe(1);
+    expect(result.e).toBe(1);
+  });
+
+  it('should simulate a 4-bit adder: 3 + 5 = 8', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
