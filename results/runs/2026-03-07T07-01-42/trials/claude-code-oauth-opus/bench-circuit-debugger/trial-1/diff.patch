alSum XOR carry -> z_i\n    let sumGate = findGate('XOR', partialSum, carry);\n\n    if (!sumGate) {\n      // Either partialSum or carry has been swapped to a different name.\n      // Try to find which one by looking for XOR gates using one of them.\n\n      // Look for non-xorXY XOR gates that use carry\n      const xorWithCarry = findGatesUsingExcept(carry, 'XOR', xorXY);\n\n      if (xorWithCarry.length === 1) {\n        // Found a gate using carry; the other input is the correct partialSum\n        const correctPartialSum = otherInput(xorWithCarry[0], carry);\n        swapped.add(partialSum);\n        swapped.add(correctPartialSum);\n        partialSum = correctPartialSum;\n        sumGate = xorWithCarry[0];\n      } else {\n        // Look for non-xorXY XOR gates that use partialSum\n        const xorWithPartial = findGatesUsingExcept(partialSum, 'XOR', xorXY);\n        if (xorWithPartial.length === 1) {\n          const correctCarry = otherInput(xorWithPartial[0], partialSum);\n          swapped.add(carry);\n          swapped.add(correctCarry);\n          carry = correctCarry;\n          sumGate = xorWithPartial[0];\n        }\n      }\n    }\n\n    if (sumGate) {\n      if (sumGate.out !== zi) {\n        swapped.add(sumGate.out);\n        swapped.add(zi);\n\n        // Fix up: if generate or carry had the name zi, update the local var\n        if (generate === zi) {\n          generate = sumGate.out;\n        }\n        if (carry === zi) {\n          carry = sumGate.out;\n        }\n      }\n    }\n\n    // propGate: partialSum AND carry -> propagate\n    const propGate = findGate('AND', partialSum, carry);\n    let propagate = propGate ? propGate.out : '';\n\n    // carryGate: generate OR propagate -> carry_out\n    let carryGate = findGate('OR', generate, propagate);\n\n    if (!carryGate) {\n      // Either generate or propagate is swapped.\n      if (propagate) {\n        // Look for OR gates using propagate\n        const orGates = gates.filter(\n     