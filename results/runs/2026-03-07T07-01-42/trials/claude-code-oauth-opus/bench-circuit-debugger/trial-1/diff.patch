,"originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>,\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  let changed = true;\n  while (remaining.length > 0 && changed) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      const v1 = wires[gate.in1];\n      const v2 = wires[gate.in2];\n      if (v1 !== undefined && v2 !== undefined) {\n        let result: number;\n        switch (gate.op) {\n          case 'AND':\n            result = v1 & v2;\n            break;\n          case 'OR':\n            result = v1 | v2;\n            break;\n          case 'XOR':\n            result = v1 ^ v2;\n            break;\n        }\n        wires[gate.out] = result;\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Find the number of input bits\n  const xWires = new Set<string>();\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      if (w.startsWith('x')) xWires.add(w);\n    }\n  }\n  const numBits = xWires.size;\n\n  // Find a gate by op and inputs (order-independent)\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string,\n  ): Gate | undefined {\n    for (const g of gates) {\n      if (\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1))\n      ) {\n        return g;\n      }\n    }\n    return undefined;\n  }\n\n  // Find gates using a wire as input, with given op, excluding a specific gate\n  function findGatesUsingExcept(\n    wire: string,\n    op: Gate['op'],\n    exclude: Gate,\n  ): Gate[] {\n    return gates.filter(\n      (g) => g !== exclude && g.op === op && (g.in1 === wire || g.in2 === wire),\n    );\n  }\n\n  function otherInput(g: Gate, wire: string): string {\n    return g.in1 === wire ? g.in2 : g.in1;\n  }\n\n  const swapped = new Set<string>();\n\n  let carry = '';\n\n  // Bit 0\n  {\n    const xorGate = findGate('XOR', 'x00', 'y00')!;\n    const andGate = findGate('AND', 'x00', 'y00')!;\n\n    if (xorGate.out !== 'z00') {\n      swapped.add('z00');\n      swapped.add(xorGate.out);\n    }\n\n    carry = andGate.out;\n    // If carry was swapped to z00, and z00 swap was detected above,\n    // the carry wire name is now z00 but after the swap fix it should\n    // be whatever z00 was swapped with. Actually, the gate output names\n    // don't change - we just record them. So carry = andGate.out which\n    // is whatever the AND gate's output wire is named (possibly incorrectly).\n    // We handle this in the next iteration.\n  }\n\n  for (let i = 1; i < numBits; i++) {\n    const xi = `x${String(i).padStart(2, '0')}`;\n    const yi = `y${String(i).padStart(2, '0')}`;\n    const zi = `z${String(i).padStart(2, '0')}`;\n\n    const xorXY = findGate('XOR', xi, yi)!;\n    let partialSum = xorXY.out;\n\n    const andXY = findGate('AND', xi, yi)!;\n    let generate = andXY.out;\n\n    // Look for: partialSum XOR carry -> z_i\n    let sumGate = findGate('XOR', partialSum, carry);\n\n    if (!sumGate) {\n      // Either partialSum or carry has been swapped to a different name.\n      // Try to find which one by looking for XOR gates using one of them.\n\n      // Look for non-xorXY XOR gates that use carry\n      const xorWithCarry = findGatesUsingExcept(carry, 'XOR', xorXY);\n\n      if (xorWithCarry.length === 1) {\n        // Found a gate using carry; the other input is the correct partialSum\n        const correctPartialSum = otherInput(xorWithCarry[0], carry);\n        swapped.add(partialSum);\n        swapped.add(correctPartialSum);\n        partialSum = correctPartialSum;\n        sumGate = xorWithCarry[0];\n      } else