+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function advance(beam: Beam): Beam {
+  const row = beam.row + 1;
+  const col =
+    beam.dir === 'down' ? beam.col :
+    beam.dir === 'down-left' ? beam.col - 1 :
+    beam.col + 1;
+  return { row, col, dir: beam.dir };
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+function findSource(grid: string[][]): { row: number; col: number } | null {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') {
+      return { row: 0, col };
+    }
+  }
+  return null;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+  if (cols === 0) return 0;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<number>();
+  const encode = (r: number, c: number) => r * cols + c;
+
+  visited.add(encode(source.row, source.col));
+
+  const active: Beam[] = [{ row: source.row, col: source.col, dir: 'down' }];
+
+  while (active.length > 0) {
+    const next: Beam[] = [];
+
+    for (const beam of active) {
+      const cell = grid[beam.row][beam.col];
+
+      if (cell === '^') {
+        // Splitter: emit down-left and down-right
+        const left: Beam = { row: beam.row + 1, col: beam.col - 1, dir: 'down-left' };
+        const right: Beam = { row: beam.row + 1, col: beam.col + 1, dir: 'down-right' };
+        for (const b of [left, right]) {
+          if (inBounds(b.row, b.col, rows, cols)) {
+            visited.add(encode(b.row, b.col));
+            next.push(b);
+          }
+        }
+      } else {
+        // Continue in current direction
+        const moved = advance(beam);
+        if (inBounds(moved.row, moved.col, rows, cols)) {
+          visited.add(encode(moved.row, moved.col));
+          next.push(moved);
+        }
+      }
+    }
+
+    active.length = 0;
+    active.push(...next);
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+  if (cols === 0) return 0n;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // We track beams with their path counts.
+  // Each beam carries a count of how many paths are following that trajectory.
+  // When a beam hits a splitter, both children inherit the count.
+  // When a beam exits, we add its count to total paths.
+
+  interface CountedBeam {
+    row: number;
+    col: number;
+    dir: Direction;
+    paths: bigint;
+  }
+
+  let totalPaths = 0n;
+  const active: CountedBeam[] = [{ row: source.row, col: source.col, dir: 'down', paths: 1n }];
+
+  while (active.length > 0) {
+    const next: CountedBeam[] = [];
+
+    for (const beam of active) {
+      const cell = grid[beam.row][beam.col];
+
+      if (cell === '^') {
+        const left = { row: beam.row + 1, col: beam.col - 1 };
+        const right = { row: beam.row + 1, col: beam.col + 1 };
+
+        const leftIn = inBounds(left.row, left.col, rows, cols);
+        const rightIn = inBounds(right.row, right.col, rows, cols);
+
+        if (leftIn) {
+          next.push({ row: left.row, col: left.col, dir: 'down-left', paths: beam.paths });
+        } else {
+          totalPaths += beam.paths;
+        }
+
+        if (rightIn) {
+          next.push({ row: right.row, col: right.col, dir: 'down-right', paths: beam.paths });
+        } else {
+          totalPaths += beam.paths;
+        }
+      } else {
+        const moved = advance(beam);
+        if (inBounds(moved.row, moved.col, rows, cols)) {
+          next.push({ ...moved, paths: beam.paths });
+        } else {
+          totalPaths += beam.paths;
+        }
+      }
+    }
+
+    active.length = 0;
+    active.push(...next);
+  }
+
+  return totalPaths;
+}
