+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from '../src/index.js';
+
+function makeGrid(rows: string[]): string[][] {
+  return rows.map(r => r.split(''));
+}
+
+describe('countBeamCells', () => {
+  it('basic example: beam goes straight down', () => {
+    const grid = makeGrid([
+      '.S...',
+      '.....',
+      '.^...',
+      '.....',
+    ]);
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('two splitters example', () => {
+    const grid = makeGrid([
+      '.S...',
+      '.^...',
+      '^.^..',
+      '.....',
+    ]);
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('no splitters: beam goes straight down', () => {
+    const grid = makeGrid([
+      '.S.',
+      '...',
+      '...',
+    ]);
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('beam exits left boundary', () => {
+    const grid = makeGrid([
+      'S..',
+      '^..',
+      '...',
+    ]);
+    // S at (0,0), moves to (1,0) hits splitter
+    // down-left: (2,-1) absorbed, down-right: (2,1)
+    // visited: (0,0), (1,0), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('beam exits right boundary', () => {
+    const grid = makeGrid([
+      '..S',
+      '..^',
+      '...',
+    ]);
+    // S at (0,2), moves to (1,2) hits splitter
+    // down-left: (2,1), down-right: (2,3) absorbed
+    // visited: (0,2), (1,2), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('empty grid returns 0', () => {
+    expect(countBeamCells([])).toBe(0);
+  });
+
+  it('no source returns 0', () => {
+    const grid = makeGrid(['...', '...']);
+    expect(countBeamCells(grid)).toBe(0);
+  });
+
+  it('source on single row grid', () => {
+    const grid = makeGrid(['.S.']);
+    // source at (0,1), beam goes to (1,1) which is out of bounds
+    // visited: just (0,1) = 1
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('multiple beams converge on same cell', () => {
+    const grid = makeGrid([
+      '.S...',
+      '.^...',
+      '^.^..',
+      '.....',
+    ]);
+    // (3,1) is visited by two beams but counts once
+    expect(countBeamCells(grid)).toBe(6);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('basic example: one splitter gives 2 paths', () => {
+    const grid = makeGrid([
+      '.S...',
+      '.....',
+      '.^...',
+      '.....',
+    ]);
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('two splitters in series gives 4 paths', () => {
+    const grid = makeGrid([
+      '.S...',
+      '.^...',
+      '^.^..',
+      '.....',
+    ]);
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('no splitters gives 1 path', () => {
+    const grid = makeGrid([
+      '.S.',
+      '...',
+      '...',
+    ]);
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('empty grid returns 0n', () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it('source only row', () => {
+    const grid = makeGrid(['.S.']);
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('absorbed beam still counts as a path', () => {
+    const grid = makeGrid([
+      'S..',
+      '^..',
+      '...',
+    ]);
+    // Splitter at (1,0): down-left (2,-1) absorbed, down-right (2,1) exits at bottom
+    // Both are paths = 2
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('handles large number of splitters (exponential paths)', () => {
+    // Build a grid where a chain of splitters produces 2^n paths
+    // Each splitter's right child hits the next splitter
+    const rows = 10;
+    const cols = 20;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][10] = 'S';
+    // Place splitters in a chain going down-right
+    for (let i = 0; i < 5; i++) {
+      grid[1 + i * 1][10 + i] = '^';
+    }
+    // This won't form a perfect chain since down-right from (r,c) goes to (r+1,c+1)
+    // Splitters at (1,10), (2,11), (3,12), (4,13), (5,14)
+    // Beam: (0,10) -> (1,10) split -> dl(2,9) + dr(2,11) split
+    // dr: (2,11) split -> dl(3,10) + dr(3,12) split
+    // etc. Only the down-right child hits next splitter
+    // Paths: first split = 2, only right continues splitting
+    // After k splitters on the right chain: each adds one more path
+    // Actually: splitter 1 splits into L1, R1
+    // R1 hits splitter 2: L2, R2
+    // R2 hits splitter 3: L3, R3 ... etc
+    // Total paths = 1 (L1) + 1 (L2) + 1 (L3) + 1 (L4) + 2 (L5 + R5) = 6
+    // because last splitter's both children are terminal
+    const result = countBeamPaths(grid);
+    expect(result).toBe(6n);
+  });
+});
+
+describe('performance', () => {
+  it('handles 200x200 grid with 50 splitters under 5 seconds', () => {
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+
+    // Place 50 splitters in a binary tree pattern
+    // First splitter directly below source
+    const splitters: [number, number][] = [];
+    // Place splitters so they form a tree
+    let positions: [number, number][] = [[2, 100]];
+    let row = 2;
+    for (let i = 0; i < 50 && positions.length > 0; i++) {
+      const [r, c] = positions[0];
+      if (r < rows && c >= 0 && c < cols) {
+        grid[r][c] = '^';
+        splitters.push([r, c]);
+        // Only add right child to keep chain going
+        if (r + 2 < rows && c + 2 < cols) {
+          positions.push([r + 2, c + 2]);
+        }
+        if (r + 2 < rows && c - 2 >= 0) {
+          positions.push([r + 2, c - 2]);
+        }
+      }
+      positions.shift();
+    }
+
+    const start = performance.now();
+    const cells = countBeamCells(grid);
+    const paths = countBeamPaths(grid);
+    const elapsed = performance.now() - start;
+
+    expect(cells).toBeGreaterThan(0);
+    expect(paths).toBeGreaterThan(0n);
+    expect(elapsed).toBeLessThan(5000);
+  });
+});
