+++ b/src/tracker.ts
@@ -0,0 +1,90 @@
+import type { TimeEntry, TimeTrackerOptions, TimeSummary } from "./types.js";
+import { loadData, saveData } from "./storage.js";
+
+export class TimeTracker {
+  private readonly filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(options: TimeTrackerOptions) {
+    this.filePath = options.filePath;
+    this.entries = loadData(this.filePath).entries;
+  }
+
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name must not be empty");
+    }
+
+    // Stop any currently running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    };
+
+    this.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  getEntries(filter?: { from?: Date; to?: Date }): TimeEntry[] {
+    if (!filter) {
+      return [...this.entries];
+    }
+
+    return this.entries.filter((entry) => {
+      const start = new Date(entry.start);
+      if (filter.from && start < filter.from) {
+        return false;
+      }
+      if (filter.to && start > filter.to) {
+        return false;
+      }
+      return true;
+    });
+  }
+
+  getSummary(filter?: { from?: Date; to?: Date }): TimeSummary {
+    const entries = this.getEntries(filter);
+    const summary: TimeSummary = {};
+
+    for (const entry of entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  getRunningEntry(): TimeEntry | null {
+    return this.entries.find((e) => e.stop === null) ?? null;
+  }
+
+  private save(): void {
+    saveData(this.filePath, { entries: this.entries });
+  }
+}
