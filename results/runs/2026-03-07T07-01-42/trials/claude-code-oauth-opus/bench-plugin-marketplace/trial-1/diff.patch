rsion) as Record<string, unknown> | undefined;\n      if (!existing) {\n        throw new Error(`Plugin ${name}@${version} not found`);\n      }\n      const current = rowToManifest(existing);\n      const merged = { ...current, ...updates, name, version };\n      updateStmt.run(\n        merged.description,\n        merged.author,\n        JSON.stringify(merged.dependencies),\n        merged.entryPoint,\n        JSON.stringify(merged.permissions),\n        name,\n        version\n      );\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":374,"cache_read_input_tokens":22414,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":374},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"6c5e84c6-ba0c-4df5-8a29-fd49cd86e848","uuid":"435ad5c1-fd69-45ec-8b3a-b7b5adb48899"}
