+import { describe, it, expect, beforeEach } from "vitest";
+import { createRunner } from "./index.js";
+import type { RunnerService } from "../types.js";
+
+describe("RunnerService", () => {
+  let runner: RunnerService;
+
+  beforeEach(() => {
+    runner = createRunner();
+  });
+
+  it("should execute simple code and return output", async () => {
+    const result = await runner.execute("return 42;");
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(42);
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+    expect(result.memoryUsed).toBeDefined();
+  });
+
+  it("should execute code with context variables", async () => {
+    const result = await runner.execute("return x + y;", { x: 10, y: 20 });
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(30);
+  });
+
+  it("should handle code that returns strings", async () => {
+    const result = await runner.execute('return "hello world";');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe("hello world");
+  });
+
+  it("should handle code that returns objects", async () => {
+    const result = await runner.execute('return { key: "value" };');
+    expect(result.success).toBe(true);
+    expect(result.output).toEqual({ key: "value" });
+  });
+
+  it("should catch runtime errors", async () => {
+    const result = await runner.execute("throw new Error('boom');");
+    expect(result.success).toBe(false);
+    expect(result.error).toContain("boom");
+    expect(result.output).toBeNull();
+  });
+
+  it("should catch reference errors", async () => {
+    const result = await runner.execute("return undefinedVar.prop;");
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  });
+
+  it("should enforce timeout", async () => {
+    const result = await runner.executeWithTimeout("while(true) {}", 50);
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  });
+
+  it("should measure duration", async () => {
+    const result = await runner.execute(
+      "let sum = 0; for (let i = 0; i < 1000; i++) sum += i; return sum;"
+    );
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(499500);
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+  });
+
+  it("should isolate execution contexts", async () => {
+    await runner.execute("var leaked = 42;");
+    const result = await runner.execute(
+      "try { return leaked; } catch(e) { return 'isolated'; }"
+    );
+    expect(result.success).toBe(true);
+    expect(result.output).toBe("isolated");
+  });
+});
