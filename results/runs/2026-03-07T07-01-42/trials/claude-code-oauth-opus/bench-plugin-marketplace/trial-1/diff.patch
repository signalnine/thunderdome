+import { describe, it, expect, beforeEach } from "vitest";
+import { createReviewService } from "./index.js";
+import type { ReviewService } from "../types.js";
+
+describe("ReviewService", () => {
+  let reviews: ReviewService;
+
+  beforeEach(() => {
+    reviews = createReviewService();
+  });
+
+  it("should add and retrieve a review", () => {
+    const review = reviews.addReview({
+      pluginName: "test-plugin",
+      pluginVersion: "1.0.0",
+      userId: "user1",
+      rating: 5,
+      comment: "Great plugin!",
+    });
+    expect(review.id).toBeDefined();
+    expect(review.pluginName).toBe("test-plugin");
+    expect(review.rating).toBe(5);
+    expect(review.flagged).toBe(false);
+    expect(review.createdAt).toBeDefined();
+  });
+
+  it("should get reviews by plugin name", () => {
+    reviews.addReview({
+      pluginName: "plugin-a",
+      pluginVersion: "1.0.0",
+      userId: "user1",
+      rating: 4,
+      comment: "Good",
+    });
+    reviews.addReview({
+      pluginName: "plugin-b",
+      pluginVersion: "1.0.0",
+      userId: "user1",
+      rating: 3,
+      comment: "OK",
+    });
+    reviews.addReview({
+      pluginName: "plugin-a",
+      pluginVersion: "1.0.0",
+      userId: "user2",
+      rating: 5,
+      comment: "Excellent",
+    });
+    const pluginAReviews = reviews.getReviews("plugin-a");
+    expect(pluginAReviews).toHaveLength(2);
+  });
+
+  it("should compute average rating excluding flagged reviews", () => {
+    reviews.addReview({
+      pluginName: "plugin-a",
+      pluginVersion: "1.0.0",
+      userId: "user1",
+      rating: 4,
+      comment: "Good",
+    });
+    const bad = reviews.addReview({
+      pluginName: "plugin-a",
+      pluginVersion: "1.0.0",
+      userId: "troll",
+      rating: 1,
+      comment: "Spam",
+    });
+    reviews.addReview({
+      pluginName: "plugin-a",
+      pluginVersion: "1.0.0",
+      userId: "user2",
+      rating: 5,
+      comment: "Great",
+    });
+
+    // Average with all: (4+1+5)/3 = 3.33
+    // Flag the spam review
+    reviews.flagReview(bad.id);
+
+    // Average excluding flagged: (4+5)/2 = 4.5
+    const avg = reviews.getAverageRating("plugin-a");
+    expect(avg).toBe(4.5);
+  });
+
+  it("should return 0 average for plugin with no reviews", () => {
+    expect(reviews.getAverageRating("nonexistent")).toBe(0);
+  });
+
+  it("should flag and retrieve flagged reviews", () => {
+    const r = reviews.addReview({
+      pluginName: "plugin-a",
+      pluginVersion: "1.0.0",
+      userId: "user1",
+      rating: 1,
+      comment: "Spam",
+    });
+    reviews.flagReview(r.id);
+    const flagged = reviews.getFlaggedReviews();
+    expect(flagged).toHaveLength(1);
+    expect(flagged[0].flagged).toBe(true);
+  });
+
+  it("should remove a review", () => {
+    const r = reviews.addReview({
+      pluginName: "plugin-a",
+      pluginVersion: "1.0.0",
+      userId: "user1",
+      rating: 3,
+      comment: "Meh",
+    });
+    expect(reviews.removeReview(r.id)).toBe(true);
+    expect(reviews.getReviews("plugin-a")).toHaveLength(0);
+  });
+
+  it("should return false for removing non-existent review", () => {
+    expect(reviews.removeReview(9999)).toBe(false);
+  });
+
+  it("should get reviews by user", () => {
+    reviews.addReview({
+      pluginName: "plugin-a",
+      pluginVersion: "1.0.0",
+      userId: "user1",
+      rating: 4,
+      comment: "Nice",
+    });
+    reviews.addReview({
+      pluginName: "plugin-b",
+      pluginVersion: "1.0.0",
+      userId: "user1",
+      rating: 5,
+      comment: "Great",
+    });
+    reviews.addReview({
+      pluginName: "plugin-a",
+      pluginVersion: "1.0.0",
+      userId: "user2",
+      rating: 3,
+      comment: "OK",
+    });
+    const user1Reviews = reviews.getReviewsByUser("user1");
+    expect(user1Reviews).toHaveLength(2);
+  });
+
+  it("should count reviews for a plugin", () => {
+    reviews.addReview({
+      pluginName: "plugin-a",
+      pluginVersion: "1.0.0",
+      userId: "user1",
+      rating: 4,
+      comment: "Good",
+    });
+    reviews.addReview({
+      pluginName: "plugin-a",
+      pluginVersion: "2.0.0",
+      userId: "user2",
+      rating: 3,
+      comment: "OK",
+    });
+    expect(reviews.getReviewCount("plugin-a")).toBe(2);
+    expect(reviews.getReviewCount("plugin-b")).toBe(0);
+  });
+});
