d handle missing dependencies gracefully\", () => {\n      registry.register(makeManifest(\"app\", \"1.0.0\", { missing: \"^1.0.0\" }));\n\n      const tree = deps.buildTree(\"app\", registry);\n      expect(tree.dependencies).toHaveLength(1);\n      expect(tree.dependencies[0].name).toBe(\"missing\");\n      expect(tree.dependencies[0].version).toBe(\"unknown\");\n    });\n  });\n\n  describe(\"detectCycles\", () => {\n    it(\"should return null when no cycles exist\", () => {\n      registry.register(makeManifest(\"a\", \"1.0.0\", { b: \"^1.0.0\" }));\n      registry.register(makeManifest(\"b\", \"1.0.0\"));\n\n      expect(deps.detectCycles(\"a\", registry)).toBeNull();\n    });\n\n    it(\"should detect a direct cycle\", () => {\n      registry.register(makeManifest(\"a\", \"1.0.0\", { b: \"^1.0.0\" }));\n      registry.register(makeManifest(\"b\", \"1.0.0\", { a: \"^1.0.0\" }));\n\n      const cycles = deps.detectCycles(\"a\", registry);\n      expect(cycles).not.toBeNull();\n      expect(cycles!.length).toBeGreaterThan(0);\n    });\n\n    it(\"should detect an indirect cycle\", () => {\n      registry.register(makeManifest(\"a\", \"1.0.0\", { b: \"^1.0.0\" }));\n      registry.register(makeManifest(\"b\", \"1.0.0\", { c: \"^1.0.0\" }));\n      registry.register(makeManifest(\"c\", \"1.0.0\", { a: \"^1.0.0\" }));\n\n      const cycles = deps.detectCycles(\"a\", registry);\n      expect(cycles).not.toBeNull();\n      expect(cycles!.length).toBeGreaterThan(0);\n    });\n  });\n\n  describe(\"hasCircularDependency\", () => {\n    it(\"should return false for acyclic graph\", () => {\n      registry.register(makeManifest(\"a\", \"1.0.0\", { b: \"^1.0.0\" }));\n      registry.register(makeManifest(\"b\", \"1.0.0\"));\n\n      expect(deps.hasCircularDependency(\"a\", registry)).toBe(false);\n    });\n\n    it(\"should return true for cyclic graph\", () => {\n      registry.register(makeManifest(\"a\", \"1.0.0\", { b: \"^1.0.0\" }));\n      registry.register(makeManifest(\"b\", \"1.0.0\", { a: \"^1.0.0\" }));\n\n      expect(deps.hasCircularDependency(\"a\", registry)).toBe(true);\n    });\n  });\n\n  describe(\"topologicalSort\", () => {\n    it(\"should produce correct ordering\", () => {\n      registry.register(makeManifest(\"app\", \"1.0.0\", { lib: \"^1.0.0\", util: \"^1.0.0\" }));\n      registry.register(makeManifest(\"lib\", \"1.0.0\", { util: \"^1.0.0\" }));\n      registry.register(makeManifest(\"util\", \"1.0.0\"));\n\n      const order = deps.topologicalSort(\"app\", registry);\n      const utilIdx = order.indexOf(\"util\");\n      const libIdx = order.indexOf(\"lib\");\n      const appIdx = order.indexOf(\"app\");\n      expect(utilIdx).toBeLessThan(libIdx);\n      expect(libIdx).toBeLessThan(appIdx);\n    });\n\n    it(\"should handle plugin with no dependencies\", () => {\n      registry.register(makeManifest(\"solo\", \"1.0.0\"));\n      const order = deps.topologicalSort(\"solo\", registry);\n      expect(order).toEqual([\"solo\"]);\n    });\n  });\n\n  describe(\"flattenDependencies\", () => {\n    it(\"should flatten transitive dependencies\", () => {\n      registry.register(makeManifest(\"app\", \"1.0.0\", { lib: \"^1.0.0\" }));\n      registry.register(makeManifest(\"lib\", \"1.0.0\", { util: \"^1.0.0\" }));\n      registry.register(makeManifest(\"util\", \"1.0.0\"));\n\n      const flat = deps.flattenDependencies(\"app\", registry);\n      expect(flat).toContain(\"lib\");\n      expect(flat).toContain(\"util\");\n      expect(flat).not.toContain(\"app\"); // should not include itself\n    });\n\n    it(\"should return empty for plugin with no dependencies\", () => {\n      registry.register(makeManifest(\"solo\", \"1.0.0\"));\n      const flat = deps.flattenDependencies(\"solo\", registry);\n      expect(flat).toHaveLength(0);\n    });\n\n    it(\"should deduplicate shared dependencies\", () => {\n      registry.register(makeManifest(\"app\", \"1.0.0\", { a: \"^1.0.0\", b: \"^1.0.0\" }));\n      registry