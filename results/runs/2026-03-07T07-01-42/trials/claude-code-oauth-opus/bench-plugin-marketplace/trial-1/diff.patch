nst bad = reviews.addReview({\n      pluginName: \"plugin-a\",\n      pluginVersion: \"1.0.0\",\n      userId: \"troll\",\n      rating: 1,\n      comment: \"Spam\",\n    });\n    reviews.addReview({\n      pluginName: \"plugin-a\",\n      pluginVersion: \"1.0.0\",\n      userId: \"user2\",\n      rating: 5,\n      comment: \"Great\",\n    });\n\n    // Average with all: (4+1+5)/3 = 3.33\n    // Flag the spam review\n    reviews.flagReview(bad.id);\n\n    // Average excluding flagged: (4+5)/2 = 4.5\n    const avg = reviews.getAverageRating(\"plugin-a\");\n    expect(avg).toBe(4.5);\n  });\n\n  it(\"should return 0 average for plugin with no reviews\", () => {\n    expect(reviews.getAverageRating(\"nonexistent\")).toBe(0);\n  });\n\n  it(\"should flag and retrieve flagged reviews\", () => {\n    const r = reviews.addReview({\n      pluginName: \"plugin-a\",\n      pluginVersion: \"1.0.0\",\n      userId: \"user1\",\n      rating: 1,\n      comment: \"Spam\",\n    });\n    reviews.flagReview(r.id);\n    const flagged = reviews.getFlaggedReviews();\n    expect(flagged).toHaveLength(1);\n    expect(flagged[0].flagged).toBe(true);\n  });\n\n  it(\"should remove a review\", () => {\n    const r = reviews.addReview({\n      pluginName: \"plugin-a\",\n      pluginVersion: \"1.0.0\",\n      userId: \"user1\",\n      rating: 3,\n      comment: \"Meh\",\n    });\n    expect(reviews.removeReview(r.id)).toBe(true);\n    expect(reviews.getReviews(\"plugin-a\")).toHaveLength(0);\n  });\n\n  it(\"should return false for removing non-existent review\", () => {\n    expect(reviews.removeReview(9999)).toBe(false);\n  });\n\n  it(\"should get reviews by user\", () => {\n    reviews.addReview({\n      pluginName: \"plugin-a\",\n      pluginVersion: \"1.0.0\",\n      userId: \"user1\",\n      rating: 4,\n      comment: \"Nice\",\n    });\n    reviews.addReview({\n      pluginName: \"plugin-b\",\n      pluginVersion: \"1.0.0\",\n      userId: \"user1\",\n      rating: 5,\n      comment: \