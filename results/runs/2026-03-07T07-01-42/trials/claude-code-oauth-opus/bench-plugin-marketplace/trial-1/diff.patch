@@ -0,0 +1,63 @@
+import vm from "node:vm";
+import type { SandboxResult, RunnerService } from "../types.js";
+
+export function createRunner(): RunnerService {
+  function runInSandbox(
+    code: string,
+    timeoutMs: number,
+    context: Record<string, unknown> = {}
+  ): SandboxResult {
+    const sandbox: Record<string, unknown> = {
+      ...context,
+      __output: undefined,
+    };
+
+    vm.createContext(sandbox);
+
+    const wrappedCode = `__output = (function() { ${code} })();`;
+
+    const start = performance.now();
+    const memBefore = process.memoryUsage().heapUsed;
+
+    try {
+      vm.runInContext(wrappedCode, sandbox, { timeout: timeoutMs });
+      const duration = performance.now() - start;
+      const memAfter = process.memoryUsage().heapUsed;
+
+      return {
+        success: true,
+        output: sandbox.__output,
+        duration,
+        memoryUsed: Math.max(0, memAfter - memBefore),
+      };
+    } catch (err: unknown) {
+      const duration = performance.now() - start;
+      const memAfter = process.memoryUsage().heapUsed;
+
+      return {
+        success: false,
+        output: null,
+        duration,
+        memoryUsed: Math.max(0, memAfter - memBefore),
+        error: err instanceof Error ? err.message : String(err),
+      };
+    }
+  }
+
+  return {
+    async execute(
+      code: string,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return runInSandbox(code, 5000, context);
+    },
+
+    async executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return runInSandbox(code, timeoutMs, context);
+    },
+  };
+}
