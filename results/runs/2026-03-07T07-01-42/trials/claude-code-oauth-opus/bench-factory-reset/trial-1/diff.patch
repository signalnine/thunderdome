uce, then\n * enumerate assignments of free variables (each 0 or 1) to minimise\n * the number of 1s, breaking ties lexicographically.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const nLights = target.length;\n  const nButtons = buttons.length;\n\n  // Build augmented matrix rows[light][col], col 0..nButtons-1 = buttons, col nButtons = target\n  // We pack bits into numbers for speed (up to 41 bits fits in JS safe ints — 53 bit limit).\n  const rows: number[] = new Array(nLights);\n\n  for (let i = 0; i < nLights; i++) {\n    let row = 0;\n    if (target[i]) row |= (1 << nButtons); // augmented column\n    rows[i] = row;\n  }\n  for (let j = 0; j < nButtons; j++) {\n    for (const light of buttons[j]) {\n      if (light >= 0 && light < nLights) {\n        rows[light] |= (1 << j);\n      }\n    }\n  }\n\n  // Gaussian elimination (GF(2)) — partial pivoting\n  const pivotCol: number[] = []; // pivotCol[rank] = column index of pivot\n  let rank = 0;\n  for (let col = 0; col < nButtons && rank < nLights; col++) {\n    // find pivot row\n    let pivotRow = -1;\n    for (let r = rank; r < nLights; r++) {\n      if ((rows[r] >> col) & 1) { pivotRow = r; break; }\n    }\n    if (pivotRow === -1) continue; // free variable\n\n    // swap\n    [rows[rank], rows[pivotRow]] = [rows[pivotRow], rows[rank]];\n\n    // eliminate\n    for (let r = 0; r < nLights; r++) {\n      if (r !== rank && ((rows[r] >> col) & 1)) {\n        rows[r] ^= rows[rank];\n      }\n    }\n    pivotCol.push(col);\n    rank++;\n  }\n\n  // Check consistency: any row with all-zero coefficient part but nonzero target bit\n  for (let r = rank; r < nLights; r++) {\n    if ((rows[r] >> nButtons) & 1) return null; // inconsistent\n  }\n\n  // Identify free columns\n  const pivotSet = new Set(pivotCol);\n  const freeCols: number[] = [];\n  for (let c = 0; c < nButtons; c++) {\n    if (!pivotSet.has(c)) freeCols.push(c);\n  }\n\n  const nFree 