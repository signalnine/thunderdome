+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+// ── Helper: verify a toggle solution ────────────────────────────────────
+
+function verifyToggle(machine: Machine, pressed: number[]): boolean {
+  const state = new Array(machine.target.length).fill(false);
+  for (const b of pressed) {
+    for (const light of machine.buttons[b]) {
+      state[light] = !state[light];
+    }
+  }
+  return state.every((v, i) => v === machine.target[i]);
+}
+
+// ── Helper: verify a counter solution ───────────────────────────────────
+
+function verifyCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+  presses: number[],
+): boolean {
+  const counters = new Array(lights.length).fill(0);
+  for (let j = 0; j < buttons.length; j++) {
+    for (const idx of buttons[j]) {
+      counters[idx] = (counters[idx] + presses[j]) % modulus;
+    }
+  }
+  return counters.every((v, i) => v === lights[i]);
+}
+
+// ── Part 1: solveToggle ─────────────────────────────────────────────────
+
+describe('solveToggle', () => {
+  it('returns null for the impossible example from the spec', () => {
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('returns empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([]);
+  });
+
+  it('single button solves single light', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+  });
+
+  it('two buttons, need both', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 1]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('prefers fewer presses', () => {
+    // Button 0 toggles {0,1}, Button 1 toggles {0}, Button 2 toggles {1}
+    // Target: [true, true]
+    // Solution with 1 press: button 0
+    // Solution with 2 presses: buttons 1, 2
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+  });
+
+  it('lexicographic tie-breaking', () => {
+    // Two buttons that each toggle light 0 independently
+    // Button 0 toggles {0}, Button 1 toggles {0}
+    // Target: [true]
+    // Both {0} and {1} are solutions with 1 press. Lex smallest = {0}.
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+  });
+
+  it('handles larger puzzle', () => {
+    // 5 lights, 5 buttons
+    const machine: Machine = {
+      target: [true, false, true, false, true],
+      buttons: [
+        [0, 2, 4],  // button 0 toggles lights 0,2,4 — exactly the target
+        [1, 3],
+        [0, 1],
+        [2, 3],
+        [4],
+      ],
+    };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+    expect(verifyToggle(machine, result!)).toBe(true);
+    // Pressing button 0 alone gives exactly the target
+    expect(result).toEqual([0]);
+  });
+
+  it('handles no buttons', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('handles no buttons with all-off target', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+});
+
+// ── Part 2: solveCounter ────────────────────────────────────────────────
+
+describe('solveCounter', () => {
+  it('returns all zeros when target is all zero', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('single button single counter', () => {
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+    expect(verifyCounter([3], [[0]], 5, result!)).toBe(true);
+  });
+
+  it('returns null for impossible system', () => {
+    // 2 counters, 1 button affects both. Target [1, 2] mod 5.
+    // Pressing button x times gives [x, x]. Need x=1 and x=2 simultaneously — impossible.
+    const result = solveCounter([1, 2], [[0, 1]], 5);
+    expect(result).toBeNull();
+  });
+
+  it('two independent buttons', () => {
+    const result = solveCounter([3, 4], [[0], [1]], 5);
+    expect(result).toEqual([3, 4]);
+    expect(verifyCounter([3, 4], [[0], [1]], 5, result!)).toBe(true);
+  });
+
+  it('prefers minimum total presses', () => {
+    // Button 0 affects counter 0, Button 1 affects counter 0
+    // Target: [1] mod 5
+    // Solutions: [1,0] sum=1, [0,1] sum=1, [2,4] sum=6, etc.
+    // Both [1,0] and [0,1] have sum 1. Lex smallest = [0,1]? No — [0,1] vs [1,0]:
+    // [0,1] < [1,0] lex. So answer is [0,1].
+    // Wait: button 0 affects {0}, button 1 affects {0}.
+    // x0 + x1 ≡ 1 (mod 5). Free var: x1. x0 = (1 - x1) mod 5.
+    // sum = (1-x1)%5 + x1.
+    // x1=0: sum = 1+0 = 1, assign=[1,0]
+    // x1=1: sum = 0+1 = 1, assign=[0,1]
+    // Lex smallest with sum 1: [0,1]
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+    expect(verifyCounter([1], [[0], [0]], 5, result!)).toBe(true);
+  });
+
+  it('handles modular arithmetic wrapping', () => {
+    // Button 0 affects counter 0. Target: 0 mod 3.
+    // Press 0 times → counter = 0. Minimum = 0.
+    const result = solveCounter([0], [[0]], 3);
+    expect(result).toEqual([0]);
+  });
+
+  it('handles mod 2 (binary-like)', () => {
+    const result = solveCounter([1, 1], [[0, 1], [1]], 2);
+    // Button 0 affects {0,1}, Button 1 affects {1}
+    // x0 ≡ 1 (counter 0), x0 + x1 ≡ 1 (counter 1)
+    // x0 = 1, x1 = 0. Sum = 1.
+    expect(result).toEqual([1, 0]);
+    expect(verifyCounter([1, 1], [[0, 1], [1]], 2, result!)).toBe(true);
+  });
+
+  it('no buttons with nonzero target returns null', () => {
+    const result = solveCounter([1], [], 5);
+    expect(result).toBeNull();
+  });
+
+  it('no buttons with zero target returns empty', () => {
+    const result = solveCounter([0, 0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  it('larger modulus', () => {
+    // Button 0 affects counter 0. Target: 50 mod 97.
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+    expect(verifyCounter([50], [[0]], 97, result!)).toBe(true);
+  });
+});
+
+// ── Stress / edge-case tests ────────────────────────────────────────────
+
+describe('solveToggle - large inputs', () => {
+  it('handles 40 buttons and 40 lights (identity mapping)', () => {
+    const n = 40;
+    const target = new Array(n).fill(true);
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]); // button i toggles light i only
+    }
+    const result = solveToggle({ target, buttons });
+    expect(result).not.toBeNull();
+    expect(result!.length).toBe(40);
+    expect(verifyToggle({ target, buttons }, result!)).toBe(true);
+  });
+
+  it('handles 40 buttons with overlapping toggles', () => {
+    const n = 40;
+    const target: boolean[] = [];
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      target.push(i % 2 === 0);
+      buttons.push([i, (i + 1) % n]); // each button toggles two adjacent lights
+    }
+    const result = solveToggle({ target, buttons });
+    if (result !== null) {
+      expect(verifyToggle({ target, buttons }, result)).toBe(true);
+    }
+    // either null or correct — both valid outcomes
+  });
+});
+
+describe('solveCounter - large inputs', () => {
+  it('handles 40 buttons, 40 counters, mod 97 (identity)', () => {
+    const n = 40;
+    const p = 97;
+    const lights: number[] = [];
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      lights.push((i * 7 + 3) % p); // arbitrary targets
+      buttons.push([i]);
+    }
+    const result = solveCounter(lights, buttons, p);
+    expect(result).not.toBeNull();
+    expect(verifyCounter(lights, buttons, p, result!)).toBe(true);
+    // Each button only affects one counter, so result[i] = lights[i]
+    for (let i = 0; i < n; i++) {
+      expect(result![i]).toBe(lights[i]);
+    }
+  });
+});
