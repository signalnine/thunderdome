+/**
+ * Factory Reset — Toggle and Counter puzzle solvers.
+ *
+ * Both puzzles reduce to solving systems of linear equations over finite fields:
+ *   Part 1: GF(2)  (toggle = XOR)
+ *   Part 2: GF(p)  (counter increment mod prime)
+ *
+ * We use Gaussian elimination with free-variable enumeration to find
+ * the solution with minimum total presses, breaking ties lexicographically.
+ */
+
+// ── Part 1: Toggle Puzzle ──────────────────────────────────────────────
+
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve toggle puzzle over GF(2) using Gaussian elimination with BigInt
+ * bit-packed rows (supports up to 40+ columns).
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const nLights = target.length;
+  const nButtons = buttons.length;
+
+  // Build augmented matrix: rows[light] is a BigInt with bits 0..nButtons-1
+  // for button columns and bit nButtons for the target (augmented) column.
+  const rows: bigint[] = new Array(nLights);
+  const one = 1n;
+
+  for (let i = 0; i < nLights; i++) {
+    let row = 0n;
+    if (target[i]) row |= (one << BigInt(nButtons));
+    rows[i] = row;
+  }
+  for (let j = 0; j < nButtons; j++) {
+    const bit = one << BigInt(j);
+    for (const light of buttons[j]) {
+      if (light >= 0 && light < nLights) {
+        rows[light] |= bit;
+      }
+    }
+  }
+
+  // Gaussian elimination (GF(2)) — full reduction to RREF
+  const pivotCol: number[] = [];
+  let rank = 0;
+  for (let col = 0; col < nButtons && rank < nLights; col++) {
+    const colBit = one << BigInt(col);
+    let pivotRow = -1;
+    for (let r = rank; r < nLights; r++) {
+      if (rows[r] & colBit) { pivotRow = r; break; }
+    }
+    if (pivotRow === -1) continue;
+
+    [rows[rank], rows[pivotRow]] = [rows[pivotRow], rows[rank]];
+
+    for (let r = 0; r < nLights; r++) {
+      if (r !== rank && (rows[r] & colBit)) {
+        rows[r] ^= rows[rank];
+      }
+    }
+    pivotCol.push(col);
+    rank++;
+  }
+
+  // Consistency check
+  const targetBit = one << BigInt(nButtons);
+  for (let r = rank; r < nLights; r++) {
+    if (rows[r] & targetBit) return null;
+  }
+
+  // Free columns
+  const pivotSet = new Set(pivotCol);
+  const freeCols: number[] = [];
+  for (let c = 0; c < nButtons; c++) {
+    if (!pivotSet.has(c)) freeCols.push(c);
+  }
+  const nFree = freeCols.length;
+
+  if (nFree > 25) {
+    // Safety fallback — shouldn't happen with ≤40 buttons and ≤40 lights
+    return evalToggleAssignment(0, freeCols, pivotCol, rows, nButtons, rank);
+  }
+
+  let bestCount = nButtons + 1;
+  let bestAssign: number[] | null = null;
+  const totalCombinations = 1 << nFree;
+
+  // Precompute BigInt masks for free columns
+  const freeColBits: bigint[] = freeCols.map(c => one << BigInt(c));
+
+  for (let mask = 0; mask < totalCombinations; mask++) {
+    const assign = new Array<number>(nButtons).fill(0);
+
+    for (let f = 0; f < nFree; f++) {
+      if ((mask >> f) & 1) assign[freeCols[f]] = 1;
+    }
+
+    // Back-substitution for pivot variables
+    for (let r = rank - 1; r >= 0; r--) {
+      let val = (rows[r] & targetBit) ? 1 : 0;
+      for (let f = 0; f < nFree; f++) {
+        if (rows[r] & freeColBits[f]) {
+          val ^= assign[freeCols[f]];
+        }
+      }
+      assign[pivotCol[r]] = val;
+    }
+
+    const count = assign.reduce((a, b) => a + b, 0);
+    if (count < bestCount || (count === bestCount && indexSetLexSmaller(assign, bestAssign!))) {
+      bestCount = count;
+      bestAssign = assign.slice();
+    }
+  }
+
+  if (bestAssign === null) return null;
+
+  const result: number[] = [];
+  for (let i = 0; i < nButtons; i++) {
+    if (bestAssign[i]) result.push(i);
+  }
+  return result;
+}
+
+function evalToggleAssignment(
+  mask: number,
+  freeCols: number[],
+  pivotCol: number[],
+  rows: bigint[],
+  nButtons: number,
+  rank: number,
+): number[] {
+  const one = 1n;
+  const targetBit = one << BigInt(nButtons);
+  const nFree = freeCols.length;
+  const assign = new Array<number>(nButtons).fill(0);
+  for (let f = 0; f < nFree; f++) {
+    if ((mask >> f) & 1) assign[freeCols[f]] = 1;
+  }
+  for (let r = rank - 1; r >= 0; r--) {
+    let val = (rows[r] & targetBit) ? 1 : 0;
+    for (let f = 0; f < nFree; f++) {
+      if (rows[r] & (one << BigInt(freeCols[f]))) {
+        val ^= assign[freeCols[f]];
+      }
+    }
+    assign[pivotCol[r]] = val;
+  }
+  const result: number[] = [];
+  for (let i = 0; i < nButtons; i++) {
+    if (assign[i]) result.push(i);
+  }
+  return result;
+}
+
+/**
+ * Compare two 0/1 button-press vectors as sorted index sets.
+ * The set that includes a smaller index first is lexicographically smaller.
+ */
+function indexSetLexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] > b[i]) return true;
+    if (a[i] < b[i]) return false;
+  }
+  return false;
+}
+
+
+// ── Part 2: Counter Puzzle ─────────────────────────────────────────────
+
+/**
+ * Solve counter puzzle over GF(p) where p = modulus (prime).
+ *
+ * System  A·x = t (mod p).  Gaussian elimination to RREF, then enumerate
+ * free variable assignments to minimise total presses, ties broken
+ * lexicographically.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+): number[] | null {
+  const nCounters = lights.length;
+  const nButtons = buttons.length;
+  const p = modulus;
+
+  // Build augmented matrix over GF(p)
+  const mat: number[][] = [];
+  for (let i = 0; i < nCounters; i++) {
+    const row = new Array<number>(nButtons + 1).fill(0);
+    row[nButtons] = ((lights[i] % p) + p) % p;
+    mat.push(row);
+  }
+  for (let j = 0; j < nButtons; j++) {
+    for (const counter of buttons[j]) {
+      if (counter >= 0 && counter < nCounters) {
+        mat[counter][j] = (mat[counter][j] + 1) % p;
+      }
+    }
+  }
+
+  // Modular inverse table for GF(p) via Fermat's little theorem
+  const inv = new Array<number>(p);
+  inv[0] = 0;
+  for (let a = 1; a < p; a++) {
+    inv[a] = modPow(a, p - 2, p);
+  }
+
+  // Gaussian elimination over GF(p) to RREF
+  const pivotCol: number[] = [];
+  let rank = 0;
+  for (let col = 0; col < nButtons && rank < nCounters; col++) {
+    let pivotRow = -1;
+    for (let r = rank; r < nCounters; r++) {
+      if (mat[r][col] !== 0) { pivotRow = r; break; }
+    }
+    if (pivotRow === -1) continue;
+
+    [mat[rank], mat[pivotRow]] = [mat[pivotRow], mat[rank]];
+
+    // Scale pivot row so leading entry = 1
+    const scale = inv[mat[rank][col]];
+    for (let c = col; c <= nButtons; c++) {
+      mat[rank][c] = (mat[rank][c] * scale) % p;
+    }
+
+    // Eliminate this column in all other rows
+    for (let r = 0; r < nCounters; r++) {
+      if (r !== rank && mat[r][col] !== 0) {
+        const factor = mat[r][col];
+        for (let c = col; c <= nButtons; c++) {
+          mat[r][c] = ((mat[r][c] - factor * mat[rank][c]) % p + p) % p;
+        }
+      }
+    }
+    pivotCol.push(col);
+    rank++;
+  }
+
+  // Consistency check
+  for (let r = rank; r < nCounters; r++) {
+    if (mat[r][nButtons] !== 0) return null;
+  }
+
+  // Free columns
+  const pivotSet = new Set(pivotCol);
+  const freeCols: number[] = [];
+  for (let c = 0; c < nButtons; c++) {
+    if (!pivotSet.has(c)) freeCols.push(c);
+  }
+  const nFree = freeCols.length;
+
+  // Enumerate free variable assignments if feasible
+  const totalCombinations = Math.pow(p, nFree);
+
+  if (nFree === 0 || totalCombinations <= 5_000_000) {
+    return enumerateCounterSolutions(mat, pivotCol, freeCols, nButtons, rank, p);
+  }
+
+  // Fallback: set all free variables to 0
+  return evalCounterAssignment(new Array(nFree).fill(0), mat, pivotCol, freeCols, nButtons, rank, p);
+}
+
+function enumerateCounterSolutions(
+  mat: number[][],
+  pivotCol: number[],
+  freeCols: number[],
+  nButtons: number,
+  rank: number,
+  p: number,
+): number[] | null {
+  const nFree = freeCols.length;
+  const totalCombinations = Math.round(Math.pow(p, nFree));
+
+  let bestSum = Infinity;
+  let bestAssign: number[] | null = null;
+
+  const freeVals = new Array<number>(nFree).fill(0);
+
+  for (let iter = 0; iter < totalCombinations; iter++) {
+    const assign = new Array<number>(nButtons).fill(0);
+
+    for (let f = 0; f < nFree; f++) {
+      assign[freeCols[f]] = freeVals[f];
+    }
+
+    for (let r = rank - 1; r >= 0; r--) {
+      let val = mat[r][nButtons];
+      for (let f = 0; f < nFree; f++) {
+        val = ((val - mat[r][freeCols[f]] * freeVals[f]) % p + p) % p;
+      }
+      assign[pivotCol[r]] = val;
+    }
+
+    const sum = assign.reduce((a, b) => a + b, 0);
+    if (sum < bestSum || (sum === bestSum && lexSmallerArr(assign, bestAssign!))) {
+      bestSum = sum;
+      bestAssign = assign.slice();
+    }
+
+    incrementMixedRadix(freeVals, p);
+  }
+
+  return bestAssign;
+}
+
+function evalCounterAssignment(
+  freeVals: number[],
+  mat: number[][],
+  pivotCol: number[],
+  freeCols: number[],
+  nButtons: number,
+  rank: number,
+  p: number,
+): number[] {
+  const assign = new Array<number>(nButtons).fill(0);
+  for (let f = 0; f < freeCols.length; f++) {
+    assign[freeCols[f]] = freeVals[f];
+  }
+  for (let r = rank - 1; r >= 0; r--) {
+    let val = mat[r][nButtons];
+    for (let f = 0; f < freeCols.length; f++) {
+      val = ((val - mat[r][freeCols[f]] * freeVals[f]) % p + p) % p;
+    }
+    assign[pivotCol[r]] = val;
+  }
+  return assign;
+}
+
+function incrementMixedRadix(vals: number[], base: number): void {
+  for (let i = vals.length - 1; i >= 0; i--) {
+    vals[i]++;
+    if (vals[i] < base) return;
+    vals[i] = 0;
+  }
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function modPow(base: number, exp: number, m: number): number {
+  let result = 1;
+  base = base % m;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % m;
+    exp >>= 1;
+    base = (base * base) % m;
+  }
+  return result;
+}
