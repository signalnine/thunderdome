ch free var\n    return solveCounterGreedy(mat, pivotCol, freeCols, nButtons, rank, p, inv);\n  }\n\n  let bestSum = Infinity;\n  let bestAssign: number[] | null = null;\n\n  // Enumerate free variable assignments (each 0..p-1)\n  // Represent as a mixed-radix counter\n  const freeVals = new Array<number>(nFree).fill(0);\n\n  for (let iter = 0; iter < totalCombinations; iter++) {\n    const assign = new Array<number>(nButtons).fill(0);\n\n    // Set free variables\n    for (let f = 0; f < nFree; f++) {\n      assign[freeCols[f]] = freeVals[f];\n    }\n\n    // Back-substitute pivot variables\n    for (let r = rank - 1; r >= 0; r--) {\n      let val = mat[r][nButtons];\n      for (let f = 0; f < nFree; f++) {\n        val = (val - mat[r][freeCols[f]] * freeVals[f] % p + p * p) % p;\n      }\n      // Also subtract contributions from other pivot cols that appear after this one in the row\n      // Actually, since we did full elimination (RREF), other pivot columns are already 0 in this row.\n      assign[pivotCol[r]] = val % p;\n    }\n\n    const sum = assign.reduce((a, b) => a + b, 0);\n    if (sum < bestSum || (sum === bestSum && lexSmallerArr(assign, bestAssign!))) {\n      bestSum = sum;\n      bestAssign = assign.slice();\n    }\n\n    // Increment mixed-radix counter\n    incrementMixedRadix(freeVals, p);\n  }\n\n  return bestAssign;\n}\n\nfunction solveCounterGreedy(\n  mat: number[][],\n  pivotCol: number[],\n  freeCols: number[],\n  nButtons: number,\n  rank: number,\n  p: number,\n  _inv: number[],\n): number[] | null {\n  // With many free variables, try all free vars = 0, which gives a valid solution\n  // but might not be optimal. For correctness we return it anyway.\n  const assign = new Array<number>(nButtons).fill(0);\n\n  for (let r = rank - 1; r >= 0; r--) {\n    const val = mat[r][nButtons];\n    assign[pivotCol[r]] = val % p;\n  }\n\n  return assign;\n}\n\nfunction incrementMixedRadix(vals: number[], base: number): void {\n  for (let i = vals.leng