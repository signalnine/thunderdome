+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<string>();
+  const processed = new Set<string>();
+  const beams: Beam[] = [{ row: source[0], col: source[1], dir: 'down' }];
+
+  visited.add(`${source[0]},${source[1]}`);
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const { row, col, dir } = beam;
+
+    const beamKey = `${row},${col},${dir}`;
+    if (processed.has(beamKey)) continue;
+    processed.add(beamKey);
+
+    if (grid[row][col] === '^') {
+      const [nlr, nlc] = advance(row, col, 'down-left');
+      const [nrr, nrc] = advance(row, col, 'down-right');
+
+      if (inBounds(nlr, nlc, rows, cols)) {
+        visited.add(`${nlr},${nlc}`);
+        beams.push({ row: nlr, col: nlc, dir: 'down-left' });
+      }
+      if (inBounds(nrr, nrc, rows, cols)) {
+        visited.add(`${nrr},${nrc}`);
+        beams.push({ row: nrr, col: nrc, dir: 'down-right' });
+      }
+    } else {
+      const [nr, nc] = advance(row, col, dir);
+      if (inBounds(nr, nc, rows, cols)) {
+        visited.add(`${nr},${nc}`);
+        beams.push({ row: nr, col: nc, dir: dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // Memoize: from a given splitter, how many paths exit the grid?
+  const memo = new Map<string, bigint>();
+
+  function countFromSplitter(row: number, col: number): bigint {
+    const key = `${row},${col}`;
+    if (memo.has(key)) return memo.get(key)!;
+
+    let total = 0n;
+
+    // Left beam: down-left
+    const [lr, lc] = advance(row, col, 'down-left');
+    if (inBounds(lr, lc, rows, cols)) {
+      total += countFromPosition(lr, lc, 'down-left');
+    } else {
+      total += 1n; // beam exits immediately = 1 path
+    }
+
+    // Right beam: down-right
+    const [rr, rc] = advance(row, col, 'down-right');
+    if (inBounds(rr, rc, rows, cols)) {
+      total += countFromPosition(rr, rc, 'down-right');
+    } else {
+      total += 1n; // beam exits immediately = 1 path
+    }
+
+    memo.set(key, total);
+    return total;
+  }
+
+  function countFromPosition(row: number, col: number, dir: Direction): bigint {
+    // Trace beam until it hits a splitter or exits
+    let r = row;
+    let c = col;
+
+    while (inBounds(r, c, rows, cols)) {
+      if (grid[r][c] === '^') {
+        return countFromSplitter(r, c);
+      }
+      [r, c] = advance(r, c, dir);
+    }
+
+    // Beam exited the grid = 1 path
+    return 1n;
+  }
+
+  // Start from source, beam goes down
+  // The source itself is at (source[0], source[1]), beam direction is down
+  // Move to the next cell after source
+  const [startR, startC] = advance(source[0], source[1], 'down');
+  if (!inBounds(startR, startC, rows, cols)) {
+    return 1n; // beam exits immediately = 1 path
+  }
+
+  return countFromPosition(startR, startC, 'down');
+}
