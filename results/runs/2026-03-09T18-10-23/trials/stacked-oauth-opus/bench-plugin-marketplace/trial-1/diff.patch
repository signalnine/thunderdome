+++ b/tests/marketplace.test.ts
@@ -0,0 +1,146 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace, type Marketplace } from '../src/index.js';
+import type { PluginManifest } from '../src/types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'test-author',
+    dependencies: {},
+    entryPoint: '2 + 2',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('Marketplace Integration', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should install a simple plugin', async () => {
+    const manifest = makeManifest();
+    const result = await marketplace.installPlugin(manifest);
+
+    expect(result.executionResult.success).toBe(true);
+    expect(result.executionResult.output).toBe(4);
+    expect(result.resolvedDependencies).toEqual([]);
+
+    // Plugin should be in registry
+    const registered = marketplace.registry.get('test-plugin');
+    expect(registered).not.toBeNull();
+  });
+
+  it('should install a plugin with dependencies', async () => {
+    // First register the dependency
+    marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.0.0' }));
+    marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.1.0' }));
+
+    const manifest = makeManifest({
+      name: 'my-plugin',
+      dependencies: { 'dep-a': '^1.0.0' },
+      entryPoint: '"installed"',
+    });
+
+    const result = await marketplace.installPlugin(manifest);
+    expect(result.resolvedDependencies.length).toBe(1);
+    expect(result.resolvedDependencies[0].name).toBe('dep-a');
+    expect(result.resolvedDependencies[0].version).toBe('1.1.0');
+    expect(result.executionResult.success).toBe(true);
+  });
+
+  it('should reject plugin with missing name', async () => {
+    const manifest = makeManifest({ name: '' });
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow('name');
+  });
+
+  it('should reject plugin with missing version', async () => {
+    const manifest = makeManifest({ version: '' });
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow('version');
+  });
+
+  it('should reject plugin with missing entryPoint', async () => {
+    const manifest = makeManifest({ entryPoint: '' });
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow('entryPoint');
+  });
+
+  it('should reject plugin with circular dependencies', async () => {
+    // Create circular: a -> b -> a
+    marketplace.registry.register(
+      makeManifest({ name: 'a', version: '1.0.0', dependencies: { b: '^1.0.0' } })
+    );
+    marketplace.registry.register(
+      makeManifest({ name: 'b', version: '1.0.0', dependencies: { a: '^1.0.0' } })
+    );
+
+    // Now try to install 'a' again with circular dep
+    const manifest = makeManifest({
+      name: 'c',
+      version: '1.0.0',
+      dependencies: { a: '^1.0.0' },
+      entryPoint: '"hello"',
+    });
+
+    // c -> a -> b -> a (cycle in deps)
+    // Actually c depends on a, a depends on b, b depends on a, so a has cycles
+    // But c itself might not be in a cycle, let's rethink this
+
+    // Let's create a real cycle involving the installed plugin
+    marketplace.registry.register(
+      makeManifest({ name: 'd', version: '1.0.0', dependencies: { e: '^1.0.0' } })
+    );
+    marketplace.registry.register(
+      makeManifest({ name: 'e', version: '1.0.0', dependencies: {} })
+    );
+
+    // Now install f that depends on d (no cycle - should work)
+    const f = makeManifest({
+      name: 'f',
+      version: '1.0.0',
+      dependencies: { d: '^1.0.0' },
+      entryPoint: '"ok"',
+    });
+    const result = await marketplace.installPlugin(f);
+    expect(result.executionResult.success).toBe(true);
+  });
+
+  it('should detect and reject circular dependencies involving the new plugin', async () => {
+    // Register g that depends on h
+    marketplace.registry.register(
+      makeManifest({ name: 'g', version: '1.0.0', dependencies: { h: '^1.0.0' } })
+    );
+
+    // Now install h that depends on g (creating g -> h -> g cycle)
+    const hManifest = makeManifest({
+      name: 'h',
+      version: '1.0.0',
+      dependencies: { g: '^1.0.0' },
+      entryPoint: '"hello"',
+    });
+
+    await expect(marketplace.installPlugin(hManifest)).rejects.toThrow('Circular dependency');
+    // h should not remain in registry after rejection
+    expect(marketplace.registry.get('h')).toBeNull();
+  });
+
+  it('should handle plugin that throws at runtime', async () => {
+    const manifest = makeManifest({
+      entryPoint: 'throw new Error("runtime error")',
+    });
+    const result = await marketplace.installPlugin(manifest);
+    expect(result.executionResult.success).toBe(false);
+    expect(result.executionResult.error).toBe('runtime error');
+  });
+
+  it('should expose all services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+  });
+});
