@@ -0,0 +1,78 @@
+import vm from 'node:vm';
+import type { SandboxResult, RunnerService } from '../types.js';
+
+export function createRunner(): RunnerService {
+  async function run(
+    code: string,
+    timeoutMs: number,
+    context: Record<string, unknown> = {}
+  ): Promise<SandboxResult> {
+    const startMem = process.memoryUsage().heapUsed;
+    const startTime = performance.now();
+
+    try {
+      const outputs: string[] = [];
+      const sandbox: Record<string, unknown> = {
+        ...context,
+        console: {
+          log: (...args: unknown[]) => {
+            outputs.push(args.map(String).join(' '));
+          },
+          error: (...args: unknown[]) => {
+            outputs.push(args.map(String).join(' '));
+          },
+          warn: (...args: unknown[]) => {
+            outputs.push(args.map(String).join(' '));
+          },
+        },
+      };
+
+      const vmContext = vm.createContext(sandbox);
+      const script = new vm.Script(code);
+      const output = script.runInContext(vmContext, { timeout: timeoutMs });
+
+      const duration = performance.now() - startTime;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - startMem);
+
+      return {
+        success: true,
+        output: output !== undefined ? output : (outputs.length > 0 ? outputs.join('\n') : undefined),
+        duration,
+        memoryUsed,
+      };
+    } catch (err: unknown) {
+      const duration = performance.now() - startTime;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - startMem);
+      // Errors thrown inside vm may not be instanceof Error from host context
+      const errorMessage =
+        err && typeof err === 'object' && 'message' in err
+          ? String((err as { message: unknown }).message)
+          : String(err);
+
+      return {
+        success: false,
+        output: undefined,
+        duration,
+        memoryUsed,
+        error: errorMessage,
+      };
+    }
+  }
+
+  return {
+    async execute(
+      code: string,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return run(code, 5000, context);
+    },
+
+    async executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return run(code, timeoutMs, context);
+    },
+  };
+}
