+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+describe('solveToggle', () => {
+  it('returns empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('returns null for the example from TASK.md', () => {
+    // target [true, true, false, true] with buttons [0,1], [1,2,3], [0,3]
+    // The system has no solution (verified in the task description)
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('solves a simple single-button case', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('solves a two-button case', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('finds minimum buttons when multiple solutions exist', () => {
+    // 2 lights, 3 buttons
+    // Button 0: toggle light 0
+    // Button 1: toggle light 1
+    // Button 2: toggle lights 0 and 1
+    // Target: [true, true]
+    // Solutions: {0,1} (2 presses) or {2} (1 press)
+    // Minimum is {2}
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0, 1]],
+    };
+    expect(solveToggle(machine)).toEqual([2]);
+  });
+
+  it('returns lexicographically smallest when tied on count', () => {
+    // 2 lights, 3 buttons
+    // Button 0: toggle lights 0, 1
+    // Button 1: toggle lights 0, 1
+    // Button 2: toggle light 0
+    // Target: [true, true]
+    // Both {0} and {1} work with 1 press each.
+    // Lex smallest: {0}
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0, 1], [0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('handles case where no buttons needed', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [[0, 1], [0]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('returns null when target is unreachable', () => {
+    // Light 0 needs to be on but no button affects it
+    const machine: Machine = {
+      target: [true, false],
+      buttons: [[1]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('handles overlapping buttons correctly', () => {
+    // 3 lights, target all on
+    // Button 0: [0, 1, 2] - toggles all
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0, 1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('handles XOR cancellation', () => {
+    // Pressing same button twice cancels out.
+    // But each button can only be pressed once.
+    // 2 lights, 2 buttons that both toggle the same lights
+    // Target: [false, false]
+    // Press neither: solution is []
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [[0, 1], [0, 1]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('handles larger puzzle', () => {
+    // 5 lights, 5 buttons (identity-like)
+    const machine: Machine = {
+      target: [true, false, true, false, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 2, 4]);
+  });
+
+  it('verifies solution correctness for complex case', () => {
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    };
+    // All three buttons pressed:
+    // Light 0: buttons 0 and 2 toggle it -> 2 toggles -> off
+    // Light 1: buttons 0 and 1 toggle it -> 2 toggles -> off
+    // Light 2: buttons 1 and 2 toggle it -> 2 toggles -> off
+    // Not all-on. Let's figure out:
+    // b0 + b2 = 1 (mod 2), b0 + b1 = 1, b1 + b2 = 1
+    // From 1st & 2nd: b1 = b2. From 2nd & 3rd: b0 = b2. So b0=b1=b2.
+    // From 1st: b0+b2 = 2b0 = 0 ≠ 1. No solution!
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('handles empty buttons list', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('handles empty buttons with non-zero target', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns all zeros when target is all zero', () => {
+    expect(solveCounter([0, 0], [[0], [1]], 5)).toEqual([0, 0]);
+  });
+
+  it('solves simple single-button case', () => {
+    expect(solveCounter([3], [[0]], 5)).toEqual([3]);
+  });
+
+  it('solves two-button independent case', () => {
+    expect(solveCounter([2, 3], [[0], [1]], 5)).toEqual([2, 3]);
+  });
+
+  it('returns null for impossible case', () => {
+    // Counter 0 needs value 1 but no button affects it
+    expect(solveCounter([1, 0], [[1]], 5)).toBeNull();
+  });
+
+  it('handles modular arithmetic', () => {
+    // Need counter 0 = 4, button 0 affects counter 0
+    // Press button 0 four times
+    expect(solveCounter([4], [[0]], 5)).toEqual([4]);
+  });
+
+  it('finds minimum total presses', () => {
+    // 1 counter, 2 buttons, both affect counter 0, mod 5
+    // Target: counter 0 = 1
+    // Options: (1,0) total=1, (0,1) total=1
+    // Lex smallest: [0,1] -- wait, the result array has entry per button
+    // result[0]=1, result[1]=0 gives total 1 and is lex smaller than result[0]=0, result[1]=1
+    expect(solveCounter([1], [[0], [0]], 5)).toEqual([0, 1]);
+  });
+
+  it('finds minimum over modular alternatives', () => {
+    // 1 counter, 1 button, mod 5
+    // Target: counter 0 = 4
+    // Only option: press button 0 four times -> result [4]
+    // Since each button can be pressed 0..p-1 times and there's only one variable
+    expect(solveCounter([4], [[0]], 5)).toEqual([4]);
+  });
+
+  it('handles overlapping buttons with modular arithmetic', () => {
+    // 2 counters, 2 buttons, mod 3
+    // Button 0 affects counter 0 and 1
+    // Button 1 affects counter 1
+    // Target: [1, 2]
+    // b0 = 1 (from counter 0)
+    // b0 + b1 = 2 mod 3 -> b1 = 2 - 1 = 1
+    // Result: [1, 1], total = 2
+    expect(solveCounter([1, 2], [[0, 1], [1]], 3)).toEqual([1, 1]);
+  });
+
+  it('handles larger modulus', () => {
+    // mod 7, simple case
+    expect(solveCounter([6], [[0]], 7)).toEqual([6]);
+  });
+
+  it('returns lexicographically smallest for tied total', () => {
+    // 1 counter, 2 buttons both affecting counter 0, mod 3
+    // Target: 2
+    // Options: (0,2)=2, (1,1)=2, (2,0)=2
+    // All have total 2
+    // Lex smallest: [0, 2]
+    expect(solveCounter([2], [[0], [0]], 3)).toEqual([0, 2]);
+  });
+
+  it('handles system with free variables', () => {
+    // 1 counter, 3 buttons all affecting counter 0, mod 5
+    // Target: 1
+    // b0 + b1 + b2 = 1 mod 5
+    // Minimum total: 1 (e.g., [1,0,0])
+    // Lex smallest with total 1: [0,0,1]? No - [1,0,0] is lex smaller.
+    expect(solveCounter([1], [[0], [0], [0]], 5)).toEqual([0, 0, 1]);
+  });
+
+  it('handles zero target with all zeros solution', () => {
+    expect(solveCounter([0, 0, 0], [[0, 1], [1, 2], [0, 2]], 7)).toEqual([0, 0, 0]);
+  });
+});
+
+// Verification helpers
+function verifyToggleSolution(machine: Machine, solution: number[] | null): boolean {
+  if (solution === null) return true; // Can't verify null
+  const lights = new Array(machine.target.length).fill(false);
+  for (const btnIdx of solution) {
+    for (const lightIdx of machine.buttons[btnIdx]) {
+      lights[lightIdx] = !lights[lightIdx];
+    }
+  }
+  return lights.every((l, i) => l === machine.target[i]);
+}
+
+function verifyCounterSolution(
+  target: number[], buttons: number[][], modulus: number, solution: number[] | null,
+): boolean {
+  if (solution === null) return true;
+  const counters = new Array(target.length).fill(0);
+  for (let b = 0; b < buttons.length; b++) {
+    for (const idx of buttons[b]) {
+      counters[idx] = (counters[idx] + solution[b]) % modulus;
+    }
+  }
+  return counters.every((c, i) => c === target[i]);
+}
+
+describe('solution verification', () => {
+  it('verifies toggle solutions are correct', () => {
+    const cases: Machine[] = [
+      { target: [true, true], buttons: [[0], [1], [0, 1]] },
+      { target: [true, false, true, false, true], buttons: [[0], [1], [2], [3], [4]] },
+      { target: [true, true], buttons: [[0, 1], [0, 1], [0]] },
+    ];
+    for (const machine of cases) {
+      const result = solveToggle(machine);
+      expect(verifyToggleSolution(machine, result)).toBe(true);
+    }
+  });
+
+  it('verifies counter solutions are correct', () => {
+    const cases: { lights: number[]; buttons: number[][]; mod: number }[] = [
+      { lights: [3], buttons: [[0]], mod: 5 },
+      { lights: [2, 3], buttons: [[0], [1]], mod: 5 },
+      { lights: [1, 2], buttons: [[0, 1], [1]], mod: 3 },
+      { lights: [2], buttons: [[0], [0]], mod: 3 },
+      { lights: [1], buttons: [[0], [0], [0]], mod: 5 },
+    ];
+    for (const { lights, buttons, mod } of cases) {
+      const result = solveCounter(lights, buttons, mod);
+      expect(verifyCounterSolution(lights, buttons, mod, result)).toBe(true);
+    }
+  });
+});
+
+describe('edge cases', () => {
+  it('toggle: single light single button', () => {
+    expect(solveToggle({ target: [true], buttons: [[0]] })).toEqual([0]);
+    expect(solveToggle({ target: [false], buttons: [[0]] })).toEqual([]);
+  });
+
+  it('counter: modulus 2 behaves like toggle', () => {
+    // mod 2: pressing once = toggle
+    expect(solveCounter([1, 1, 0], [[0], [1], [2]], 2)).toEqual([1, 1, 0]);
+  });
+
+  it('counter: large modulus', () => {
+    // mod 97, simple case
+    expect(solveCounter([50], [[0]], 97)).toEqual([50]);
+  });
+
+  it('toggle: many buttons few lights (underdetermined)', () => {
+    // 2 lights, 5 buttons
+    // Button 0: [0], Button 1: [1], Button 2: [0,1], Button 3: [0], Button 4: [1]
+    // Target: [true, true]
+    // Min press 1: button 2 alone → [0,1] toggled → [on, on] ✓
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1], [0, 1], [0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([2]);
+  });
+});
+
+describe('performance tests', () => {
+  it('handles 20 lights and 20 buttons (toggle) quickly', () => {
+    const n = 20;
+    const buttons: number[][] = [];
+    const target: boolean[] = [];
+    for (let i = 0; i < n; i++) {
+      // Each button affects itself and the next light (cyclic)
+      buttons.push([i, (i + 1) % n]);
+      target.push(i % 2 === 0);
+    }
+    const machine: Machine = { target, buttons };
+    const start = Date.now();
+    const result = solveToggle(machine);
+    const elapsed = Date.now() - start;
+    expect(elapsed).toBeLessThan(5000);
+    if (result !== null) {
+      expect(verifyToggleSolution(machine, result)).toBe(true);
+    }
+  });
+
+  it('handles 40 lights and 40 buttons (toggle) with full rank', () => {
+    // Identity-like: each button toggles exactly one light
+    const n = 40;
+    const buttons: number[][] = [];
+    const target: boolean[] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+      target.push(i % 3 === 0);
+    }
+    const machine: Machine = { target, buttons };
+    const start = Date.now();
+    const result = solveToggle(machine);
+    const elapsed = Date.now() - start;
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).not.toBeNull();
+    expect(verifyToggleSolution(machine, result)).toBe(true);
+  });
+
+  it('handles 20 counters and 20 buttons (counter, mod 7) quickly', () => {
+    const n = 20;
+    const buttons: number[][] = [];
+    const lights: number[] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i, (i + 1) % n]);
+      lights.push((i * 3) % 7);
+    }
+    const start = Date.now();
+    const result = solveCounter(lights, buttons, 7);
+    const elapsed = Date.now() - start;
+    expect(elapsed).toBeLessThan(5000);
+    if (result !== null) {
+      expect(verifyCounterSolution(lights, buttons, 7, result)).toBe(true);
+    }
+  });
+});
