@@ -0,0 +1,670 @@
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;   // number of lights
+  const m = buttons.length;  // number of buttons
+
+  // Build augmented matrix over GF(2) using bigint bitmasks.
+  // Row i represents equation for light i.
+  // Columns 0..m-1 are button variables, column m is the target (RHS).
+  const rows: bigint[] = [];
+  for (let i = 0; i < n; i++) {
+    let row = 0n;
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row |= 1n << BigInt(j);
+      }
+    }
+    if (target[i]) {
+      row |= 1n << BigInt(m);
+    }
+    rows.push(row);
+  }
+
+  return solveGF2System(rows, n, m);
+}
+
+function solveGF2System(rows: bigint[], numRows: number, numVars: number): number[] | null {
+  // Gaussian elimination to RREF
+  const pivotCol: number[] = [];
+  let pivotRow = 0;
+
+  for (let col = 0; col < numVars && pivotRow < numRows; col++) {
+    let found = -1;
+    for (let r = pivotRow; r < numRows; r++) {
+      if ((rows[r] >> BigInt(col)) & 1n) {
+        found = r;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [rows[pivotRow], rows[found]] = [rows[found], rows[pivotRow]];
+
+    for (let r = 0; r < numRows; r++) {
+      if (r !== pivotRow && (rows[r] >> BigInt(col)) & 1n) {
+        rows[r] ^= rows[pivotRow];
+      }
+    }
+
+    pivotCol.push(col);
+    pivotRow++;
+  }
+
+  // Check consistency
+  const rhsBit = BigInt(numVars);
+  for (let r = pivotRow; r < numRows; r++) {
+    if ((rows[r] >> rhsBit) & 1n) {
+      return null;
+    }
+  }
+
+  const rank = pivotCol.length;
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < numVars; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+  const numFree = freeVars.length;
+
+  // Extract RREF info for pivot variables.
+  // After RREF, row k: x_{pivotCol[k]} = rhs[k] XOR sum(coeff * x_free)
+  const pivotRhs: number[] = new Array(rank);
+  const pivotFreeCoeffs: number[][] = new Array(rank);
+  for (let k = 0; k < rank; k++) {
+    pivotRhs[k] = Number((rows[k] >> rhsBit) & 1n);
+    pivotFreeCoeffs[k] = new Array(numFree);
+    for (let f = 0; f < numFree; f++) {
+      pivotFreeCoeffs[k][f] = Number((rows[k] >> BigInt(freeVars[f])) & 1n);
+    }
+  }
+
+  // For each assignment of free variables, compute the full solution and its weight.
+  // We want minimum weight, then lexicographically smallest indices.
+
+  if (numFree <= 20) {
+    // Direct enumeration
+    return enumGF2Direct(numVars, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs);
+  } else {
+    // Meet-in-the-middle
+    return enumGF2MITM(numVars, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs);
+  }
+}
+
+function enumGF2Direct(
+  numVars: number, numFree: number, freeVars: number[],
+  pivotCol: number[], pivotRhs: number[], pivotFreeCoeffs: number[][],
+): number[] {
+  const rank = pivotCol.length;
+  let bestIndices: number[] | null = null;
+  let bestCount = numVars + 1;
+  const total = 1 << numFree;
+
+  for (let mask = 0; mask < total; mask++) {
+    // Count free variables set
+    let count = 0;
+    let temp = mask;
+    while (temp) { temp &= temp - 1; count++; }
+
+    // Compute pivot variable values and count pressed ones
+    for (let k = 0; k < rank; k++) {
+      let val = pivotRhs[k];
+      for (let f = 0; f < numFree; f++) {
+        if ((mask >> f) & 1) {
+          val ^= pivotFreeCoeffs[k][f];
+        }
+      }
+      count += val;
+    }
+
+    if (count > bestCount) continue;
+
+    // Build solution indices
+    const indices: number[] = [];
+    for (let f = 0; f < numFree; f++) {
+      if ((mask >> f) & 1) indices.push(freeVars[f]);
+    }
+    for (let k = 0; k < rank; k++) {
+      let val = pivotRhs[k];
+      for (let f = 0; f < numFree; f++) {
+        if ((mask >> f) & 1) val ^= pivotFreeCoeffs[k][f];
+      }
+      if (val) indices.push(pivotCol[k]);
+    }
+    indices.sort((a, b) => a - b);
+
+    if (count < bestCount || (count === bestCount && lexSmaller(indices, bestIndices!))) {
+      bestCount = count;
+      bestIndices = indices;
+    }
+  }
+
+  return bestIndices!;
+}
+
+function enumGF2MITM(
+  numVars: number, numFree: number, freeVars: number[],
+  pivotCol: number[], pivotRhs: number[], pivotFreeCoeffs: number[][],
+): number[] {
+  const rank = pivotCol.length;
+
+  // Precompute per-free-variable coefficient masks over pivots (as bigints)
+  const coeffMask: bigint[] = new Array(numFree);
+  for (let f = 0; f < numFree; f++) {
+    let m = 0n;
+    for (let k = 0; k < rank; k++) {
+      if (pivotFreeCoeffs[k][f]) {
+        m |= 1n << BigInt(k);
+      }
+    }
+    coeffMask[f] = m;
+  }
+
+  let rhsMask = 0n;
+  for (let k = 0; k < rank; k++) {
+    if (pivotRhs[k]) rhsMask |= 1n << BigInt(k);
+  }
+
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+  const sizeA = 1 << halfA;
+  const sizeB = 1 << halfB;
+
+  // Build halfA table: for each maskA, compute (effectA, countA).
+  // Group by effectA, keeping best (min countA, then lex-smallest) per effectA.
+  // Since numFree > 20 and halfA ≈ numFree/2, rank < numVars - 20.
+  // With numVars ≤ 40, rank ≤ 19. Effect space = 2^rank ≤ 2^19 = 524K.
+  // halfA ≈ 10-20, sizeA = 2^10 to 2^20.
+
+  const halfAMap = new Map<bigint, { countA: number; maskA: number }>();
+
+  for (let maskA = 0; maskA < sizeA; maskA++) {
+    let effectA = 0n;
+    let countA = 0;
+    for (let f = 0; f < halfA; f++) {
+      if ((maskA >> f) & 1) {
+        effectA ^= coeffMask[f];
+        countA++;
+      }
+    }
+
+    const existing = halfAMap.get(effectA);
+    if (!existing || countA < existing.countA ||
+        (countA === existing.countA && maskA < existing.maskA)) {
+      halfAMap.set(effectA, { countA, maskA });
+    }
+  }
+
+  let bestTotal = numVars + 1;
+  let bestMaskA = 0;
+  let bestMaskB = 0;
+
+  // Phase 1: exact match lookup (d=0, no pivots pressed)
+  for (let maskB = 0; maskB < sizeB; maskB++) {
+    let effectB = 0n;
+    let countB = 0;
+    for (let f = 0; f < halfB; f++) {
+      if ((maskB >> f) & 1) {
+        effectB ^= coeffMask[halfA + f];
+        countB++;
+      }
+    }
+
+    if (countB >= bestTotal) continue;
+
+    const targetVal = rhsMask ^ effectB;
+    const exact = halfAMap.get(targetVal);
+    if (exact) {
+      const total = exact.countA + countB;
+      if (total < bestTotal ||
+          (total === bestTotal && isBetterMITM(exact.maskA, maskB, bestMaskA, bestMaskB, halfA, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs, numVars))) {
+        bestTotal = total;
+        bestMaskA = exact.maskA;
+        bestMaskB = maskB;
+      }
+    }
+  }
+
+  // Phase 2: brute-force iteration over all (halfA, halfB) pairs.
+  // Total pairs = sizeA * sizeB = 2^numFree. For numFree up to 40, this is 2^40 = 1T, too slow.
+  // But we can use the grouped map: iterate halfAMap entries × all halfB entries.
+  // halfAMap.size ≤ min(sizeA, 2^rank). With rank ≤ 19 and sizeA ≤ 2^20:
+  //   mapSize ≤ min(2^20, 2^19) = 2^19 = 524K
+  // sizeB ≤ 2^20 = 1M
+  // Total: 524K * 1M = 524 billion -- way too slow.
+  //
+  // Better: for each halfB, iterate grouped halfA map.
+  // For each (effectA, effectB) pair, compute pivot weight = popcount(rhsMask ^ effectA ^ effectB).
+  // Total = countA + countB + pivotWeight.
+  //
+  // We only need to iterate when pivotWeight could improve. Since we know bestTotal,
+  // we need countA + countB + pivotWeight < bestTotal.
+  // With countA from the map entry and countB computed, skip if countA + countB >= bestTotal.
+  //
+  // Worst case this is still too slow for large maps. Let's be more targeted:
+  // Only do full iteration if it's feasible.
+  const mapSize = halfAMap.size;
+  const feasiblePairs = mapSize * sizeB;
+
+  if (feasiblePairs <= 50_000_000) {
+    for (let maskB = 0; maskB < sizeB; maskB++) {
+      let effectB = 0n;
+      let countB = 0;
+      for (let f = 0; f < halfB; f++) {
+        if ((maskB >> f) & 1) {
+          effectB ^= coeffMask[halfA + f];
+          countB++;
+        }
+      }
+
+      if (countB >= bestTotal) continue;
+
+      for (const [effectA, entry] of halfAMap) {
+        if (entry.countA + countB >= bestTotal) continue;
+
+        // Count pivot presses (popcount of combined effect)
+        let combined = rhsMask ^ effectA ^ effectB;
+        let pivotWeight = 0;
+        while (combined > 0n) { combined &= combined - 1n; pivotWeight++; }
+
+        const total = entry.countA + countB + pivotWeight;
+        if (total < bestTotal ||
+            (total === bestTotal && isBetterMITM(entry.maskA, maskB, bestMaskA, bestMaskB, halfA, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs, numVars))) {
+          bestTotal = total;
+          bestMaskA = entry.maskA;
+          bestMaskB = maskB;
+        }
+      }
+    }
+  }
+
+  return buildSolutionGF2(bestMaskA, bestMaskB, halfA, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs, numVars);
+}
+
+function isBetterMITM(
+  maskA: number, maskB: number, bestMaskA: number, bestMaskB: number,
+  halfA: number, numFree: number, freeVars: number[],
+  pivotCol: number[], pivotRhs: number[], pivotFreeCoeffs: number[][],
+  numVars: number,
+): boolean {
+  const a = buildSolutionGF2(maskA, maskB, halfA, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs, numVars);
+  const b = buildSolutionGF2(bestMaskA, bestMaskB, halfA, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs, numVars);
+  return lexSmaller(a, b);
+}
+
+function buildSolutionGF2(
+  maskA: number, maskB: number,
+  halfA: number, numFree: number, freeVars: number[],
+  pivotCol: number[], pivotRhs: number[], pivotFreeCoeffs: number[][],
+  numVars: number,
+): number[] {
+  const sol: number[] = new Array(numVars).fill(0);
+  for (let f = 0; f < halfA; f++) {
+    if ((maskA >> f) & 1) sol[freeVars[f]] = 1;
+  }
+  for (let f = 0; f < numFree - halfA; f++) {
+    if ((maskB >> f) & 1) sol[freeVars[halfA + f]] = 1;
+  }
+  for (let k = 0; k < pivotCol.length; k++) {
+    let val = pivotRhs[k];
+    for (let f = 0; f < numFree; f++) {
+      if (sol[freeVars[f]]) val ^= pivotFreeCoeffs[k][f];
+    }
+    sol[pivotCol[k]] = val;
+  }
+  const indices: number[] = [];
+  for (let i = 0; i < numVars; i++) {
+    if (sol[i]) indices.push(i);
+  }
+  return indices;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  const len = Math.max(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    const av = i < a.length ? a[i] : Infinity;
+    const bv = i < b.length ? b[i] : Infinity;
+    if (av < bv) return true;
+    if (av > bv) return false;
+  }
+  return false;
+}
+
+// ---- Counter puzzle (GF(p)) ----
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+): number[] | null {
+  const n = lights.length;   // counters
+  const m = buttons.length;  // buttons
+
+  // Build augmented matrix [A | b] over GF(p)
+  const matrix: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row: number[] = new Array(m + 1).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[m] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination to RREF over GF(p)
+  const pivotCol: number[] = [];
+  let pivotRow = 0;
+
+  for (let col = 0; col < m && pivotRow < n; col++) {
+    let found = -1;
+    for (let r = pivotRow; r < n; r++) {
+      if (matrix[r][col] !== 0) {
+        found = r;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];
+
+    const inv = modInverse(matrix[pivotRow][col], modulus);
+    for (let c = 0; c <= m; c++) {
+      matrix[pivotRow][c] = (matrix[pivotRow][c] * inv) % modulus;
+    }
+
+    for (let r = 0; r < n; r++) {
+      if (r !== pivotRow && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = 0; c <= m; c++) {
+          matrix[r][c] = ((matrix[r][c] - factor * matrix[pivotRow][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    pivotRow++;
+  }
+
+  // Check consistency
+  for (let r = pivotRow; r < n; r++) {
+    if (matrix[r][m] !== 0) return null;
+  }
+
+  const rank = pivotCol.length;
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+  const numFree = freeVars.length;
+
+  const pivotRhs: number[] = new Array(rank);
+  const pivotFreeCoeffs: number[][] = new Array(rank);
+  for (let k = 0; k < rank; k++) {
+    pivotRhs[k] = matrix[k][m];
+    pivotFreeCoeffs[k] = new Array(numFree);
+    for (let f = 0; f < numFree; f++) {
+      pivotFreeCoeffs[k][f] = matrix[k][freeVars[f]];
+    }
+  }
+
+  // Estimate enumeration size
+  const totalCombinations = numFree === 0 ? 1 : Math.pow(modulus, numFree);
+
+  if (totalCombinations <= 5_000_000) {
+    return enumGFpDirect(m, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs, modulus);
+  } else {
+    return enumGFpMITM(m, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs, modulus);
+  }
+}
+
+function enumGFpDirect(
+  numVars: number, numFree: number, freeVars: number[],
+  pivotCol: number[], pivotRhs: number[], pivotFreeCoeffs: number[][],
+  modulus: number,
+): number[] {
+  const rank = pivotCol.length;
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  const freeValues: number[] = new Array(numFree).fill(0);
+
+  const enumerate = (depth: number, freeSum: number): void => {
+    if (depth === numFree) {
+      if (freeSum > bestTotal) return;
+
+      const solution: number[] = new Array(numVars).fill(0);
+      let total = freeSum;
+
+      for (let f = 0; f < numFree; f++) {
+        solution[freeVars[f]] = freeValues[f];
+      }
+
+      let feasible = true;
+      for (let k = 0; k < rank; k++) {
+        let val = pivotRhs[k];
+        for (let f = 0; f < numFree; f++) {
+          val = ((val - pivotFreeCoeffs[k][f] * freeValues[f]) % modulus + modulus) % modulus;
+        }
+        solution[pivotCol[k]] = val;
+        total += val;
+        if (total > bestTotal) { feasible = false; break; }
+      }
+      if (!feasible) return;
+
+      if (total < bestTotal || (total === bestTotal && lexSmallerArr(solution, bestSolution!))) {
+        bestTotal = total;
+        bestSolution = [...solution];
+      }
+      return;
+    }
+
+    for (let v = 0; v < modulus; v++) {
+      freeValues[depth] = v;
+      enumerate(depth + 1, freeSum + v);
+    }
+  };
+
+  enumerate(0, 0);
+  return bestSolution!;
+}
+
+function enumGFpMITM(
+  numVars: number, numFree: number, freeVars: number[],
+  pivotCol: number[], pivotRhs: number[], pivotFreeCoeffs: number[][],
+  modulus: number,
+): number[] {
+  const rank = pivotCol.length;
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+  const sizeA = Math.pow(modulus, halfA);
+  const sizeB = Math.pow(modulus, halfB);
+
+  // For half A: compute (effectA, countA) where effectA[k] = sum(coeff[k][f]*val[f]) mod p
+  // Map: effectA key -> best { countA, values }
+  const halfAMap = new Map<string, { countA: number; values: number[] }>();
+
+  const iterateHalf = (size: number, halfSize: number, mod: number, cb: (vals: number[]) => void) => {
+    const vals: number[] = new Array(size).fill(0);
+    for (let i = 0; i < halfSize; i++) {
+      cb(vals);
+      // Increment mixed-radix counter
+      for (let j = 0; j < size; j++) {
+        vals[j]++;
+        if (vals[j] < mod) break;
+        vals[j] = 0;
+      }
+    }
+  };
+
+  iterateHalf(halfA, sizeA, modulus, (vals) => {
+    const effect: number[] = new Array(rank);
+    let countA = 0;
+    for (let f = 0; f < halfA; f++) countA += vals[f];
+
+    for (let k = 0; k < rank; k++) {
+      let e = 0;
+      for (let f = 0; f < halfA; f++) {
+        e = (e + pivotFreeCoeffs[k][f] * vals[f]) % modulus;
+      }
+      effect[k] = e;
+    }
+
+    const key = effect.join(',');
+    const existing = halfAMap.get(key);
+    if (!existing || countA < existing.countA ||
+        (countA === existing.countA && lexSmallerPartial(vals, existing.values, freeVars, numVars))) {
+      halfAMap.set(key, { countA, values: [...vals] });
+    }
+  });
+
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  // For each half B, find the best matching half A.
+  // Pivot[k] = (rhs[k] - effectA[k] - effectB[k]) mod p
+  // For zero pivot sum, we need effectA[k] = (rhs[k] - effectB[k]) mod p
+  iterateHalf(halfB, sizeB, modulus, (valsB) => {
+    let countB = 0;
+    for (let f = 0; f < halfB; f++) countB += valsB[f];
+    if (countB >= bestTotal) return;
+
+    const effectB: number[] = new Array(rank);
+    for (let k = 0; k < rank; k++) {
+      let e = 0;
+      for (let f = 0; f < halfB; f++) {
+        e = (e + pivotFreeCoeffs[k][halfA + f] * valsB[f]) % modulus;
+      }
+      effectB[k] = e;
+    }
+
+    // Target effectA for zero pivot presses
+    const target: number[] = new Array(rank);
+    for (let k = 0; k < rank; k++) {
+      target[k] = ((pivotRhs[k] - effectB[k]) % modulus + modulus) % modulus;
+    }
+    const key = target.join(',');
+    const entry = halfAMap.get(key);
+    if (entry) {
+      const total = entry.countA + countB;
+      if (total < bestTotal) {
+        bestTotal = total;
+        bestSolution = buildGFpSolution(entry.values, valsB, halfA, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs, modulus, numVars);
+      } else if (total === bestTotal && bestSolution) {
+        const candidate = buildGFpSolution(entry.values, valsB, halfA, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs, modulus, numVars);
+        if (lexSmallerArr(candidate, bestSolution)) {
+          bestSolution = candidate;
+        }
+      }
+    }
+  });
+
+  // Fallback: all free vars = 0
+  if (bestSolution === null) {
+    const sol: number[] = new Array(numVars).fill(0);
+    let total = 0;
+    for (let k = 0; k < rank; k++) {
+      sol[pivotCol[k]] = pivotRhs[k];
+      total += pivotRhs[k];
+    }
+    if (total < bestTotal || bestSolution === null) {
+      bestSolution = sol;
+      bestTotal = total;
+    }
+  }
+
+  // If the half A map is small enough, do full enumeration for better results
+  if (halfAMap.size <= 50_000 && sizeB <= 50_000) {
+    iterateHalf(halfB, sizeB, modulus, (valsB) => {
+      let countB = 0;
+      for (let f = 0; f < halfB; f++) countB += valsB[f];
+      if (countB >= bestTotal) return;
+
+      const effectB: number[] = new Array(rank);
+      for (let k = 0; k < rank; k++) {
+        let e = 0;
+        for (let f = 0; f < halfB; f++) {
+          e = (e + pivotFreeCoeffs[k][halfA + f] * valsB[f]) % modulus;
+        }
+        effectB[k] = e;
+      }
+
+      for (const [aKey, aEntry] of halfAMap) {
+        if (aEntry.countA + countB >= bestTotal) continue;
+
+        const effectA = aKey.split(',').map(Number);
+        let pivotSum = 0;
+        for (let k = 0; k < rank; k++) {
+          pivotSum += ((pivotRhs[k] - effectA[k] - effectB[k]) % modulus + modulus) % modulus;
+        }
+
+        const total = aEntry.countA + countB + pivotSum;
+        if (total < bestTotal) {
+          bestTotal = total;
+          bestSolution = buildGFpSolution(aEntry.values, valsB, halfA, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs, modulus, numVars);
+        } else if (total === bestTotal && bestSolution) {
+          const candidate = buildGFpSolution(aEntry.values, valsB, halfA, numFree, freeVars, pivotCol, pivotRhs, pivotFreeCoeffs, modulus, numVars);
+          if (lexSmallerArr(candidate, bestSolution)) {
+            bestSolution = candidate;
+          }
+        }
+      }
+    });
+  }
+
+  return bestSolution;
+}
+
+function lexSmallerPartial(a: number[], b: number[], freeVars: number[], numVars: number): boolean {
+  const solA: number[] = new Array(numVars).fill(0);
+  const solB: number[] = new Array(numVars).fill(0);
+  for (let f = 0; f < a.length; f++) {
+    solA[freeVars[f]] = a[f];
+    solB[freeVars[f]] = b[f];
+  }
+  return lexSmallerArr(solA, solB);
+}
+
+function buildGFpSolution(
+  valsA: number[], valsB: number[],
+  halfA: number, numFree: number, freeVars: number[],
+  pivotCol: number[], pivotRhs: number[], pivotFreeCoeffs: number[][],
+  modulus: number, numVars: number,
+): number[] {
+  const sol: number[] = new Array(numVars).fill(0);
+  for (let f = 0; f < halfA; f++) sol[freeVars[f]] = valsA[f];
+  for (let f = 0; f < numFree - halfA; f++) sol[freeVars[halfA + f]] = valsB[f];
+  for (let k = 0; k < pivotCol.length; k++) {
+    let val = pivotRhs[k];
+    for (let f = 0; f < numFree; f++) {
+      val = ((val - pivotFreeCoeffs[k][f] * sol[freeVars[f]]) % modulus + modulus) % modulus;
+    }
+    sol[pivotCol[k]] = val;
+  }
+  return sol;
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function modInverse(a: number, m: number): number {
+  let [old_r, r] = [a, m];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % m) + m) % m;
+}
