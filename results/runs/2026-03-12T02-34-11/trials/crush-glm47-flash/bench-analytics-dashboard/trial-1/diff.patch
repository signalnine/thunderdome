+
+const router = Router();
+
+router.get('/events/:format', isAuthenticated, (req: AuthenticatedRequest, res: ApiResponse) => {
+  if (!req.user) {
+    res.status(401).json({ success: false, error: 'Unauthorized' });
+    return;
+  }
+
+  const { format } = req.params;
+
+  if (format !== 'csv' && format !== 'json') {
+    res.status(400).json({ success: false, error: 'Format must be csv or json' });
+    return;
+  }
+
+  const db = getDB('./analytics.db');
+  const events = db.getEventsByTenant(req.user.tenantId, 1000);
+
+  if (format === 'json') {
+    const data = events.map((event: any) => ({
+      id: event.id,
+      name: event.name,
+      properties: JSON.parse(event.properties),
+      timestamp: event.timestamp,
+      user_id: event.user_id
+    }));
+
+    res.setHeader('Content-Type', 'application/json');
+    res.send(JSON.stringify(data, null, 2));
+  } else if (format === 'csv') {
+    const headers = ['id', 'name', 'timestamp', 'user_id'];
+    const rows = events.map((event: any) => [
+      event.id,
+      event.name,
+      event.timestamp,
+      event.user_id || ''
+    ]);
+
+    const csvContent = [headers.join(','), ...rows.map((r: string[]) => r.join(','))].join('\n');
+
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename=events.csv');
+    res.send(csvContent);
+  }
+});
+
