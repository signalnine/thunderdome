+import bcrypt from 'bcrypt';
+import { getDB } from './db';
+import { type ApiResponse, type RegisterRequest, type LoginRequest } from './types';
+import { generateToken, verifyToken, JWTPayload, AuthenticatedRequest, hasRole } from './utils';
