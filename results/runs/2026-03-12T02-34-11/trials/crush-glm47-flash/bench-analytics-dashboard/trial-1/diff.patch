+import { Router, Request, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDB } from './db';
+import { type ApiResponse } from './types';
+import { isAuthenticated, AuthenticatedRequest, requireTenantIsolation } from './utils';
+
+const router = Router();
+
+router.post('/dashboard/:dashboardId', isAuthenticated, (req: AuthenticatedRequest, res: ApiResponse) => {
+  if (!req.user) {
+    res.status(401).json({ success: false, error: 'Unauthorized' });
+    return;
+  }
+
+  const { dashboardId } = req.params;
+  const { type, config, position_x, position_y, width, height } = req.body;
+
+  if (!type || !['counter', 'timeseries', 'breakdown', 'funnel'].includes(type)) {
+    res.status(400).json({ success: false, error: 'Widget type is required' });
+    return;
+  }
+
+  const db = getDB('./analytics.db');
+  const dashboard = db.getDashboardById(dashboardId);
+
+  if (!dashboard) {
+    res.status(404).json({ success: false, error: 'Dashboard not found' });
+    return;
+  }
+
+  if (dashboard.tenant_id !== req.user.tenantId) {
+    res.status(403).json({ success: false, error: 'Access denied to different tenant' });
+    return;
+  }
+
+  const widgetId = uuidv4();
+
+  db.createWidget(widgetId, dashboardId, type, config || {}, position_x || 0, position_y || 0, width || 1, height || 1);
+
+  res.status(201).json({
+    success: true,
+    data: {
+      id: widgetId,
+      dashboardId,
+      type,
+      config: config || {},
+      position_x: position_x || 0,
+      position_y: position_y || 0,
+      width: width || 1,
+      height: height || 1
+    }
+  });
+});
+
+router.get('/dashboard/:dashboardId', isAuthenticated, (req: AuthenticatedRequest, res: ApiResponse) => {
+  if (!req.user) {
+    res.status(401).json({ success: false, error: 'Unauthorized' });
+    return;
+  }
+
+  const { dashboardId } = req.params;
+
+  const db = getDB('./analytics.db');
+  const widgets = db.getWidgetsByDashboard(dashboardId);
+
+  if (!widgets) {
+    res.status(200).json({
+      success: true,
+      data: []
+    });
+    return;
+  }
+
+  res.json({
+    success: true,
+    data: widgets.map((w: any) => ({
+      id: w.id,
+      dashboard_id: w.dashboard_id,
+      type: w.type,
+      config: JSON.parse(w.config),
+      position_x: w.position_x,
+      position_y: w.position_y,
+      width: w.width,
+      height: w.height
+    }))
+  });
+});
+
+router.delete('/dashboard/:dashboardId/:widgetId', isAuthenticated, (req: AuthenticatedRequest, res: ApiResponse) => {
+  if (!req.user) {
+    res.status(401).json({ success: false, error: 'Unauthorized' });
+    return;
+  }
+
+  const { dashboardId, widgetId } = req.params;
+
+  const db = getDB('./analytics.db');
+  const widget = db.getWidgetById(widgetId);
+
+  if (!widget) {
+    res.status(404).json({ success: false, error: 'Widget not found' });
+    return;
+  }
+
+  if (widget.dashboard_id !== dashboardId) {
+    res.status(400).json({ success: false, error: 'Widget belongs to different dashboard' });
+    return;
+  }
+
+  const dashboard = db.getDashboardById(dashboardId);
+
+  if (!dashboard) {
+    res.status(404).json({ success: false, error: 'Dashboard not found' });
+    return;
+  }
+
+  if (dashboard.tenant_id !== req.user.tenantId) {
+    res.status(403).json({ success: false, error: 'Access denied to different tenant' });
+    return;
+  }
+
+  db.deleteWidget(widgetId);
+
+  res.json({
+    success: true,
+    data: { deleted: widgetId }
+  });
+});
+
+export { createWidget, deleteWidget };
+export default router;
