@@ -0,0 +1,240 @@
+import Database from 'better-sqlite3';
+import { join } from 'path';
+
+export class DatabaseManager {
+  private db: Database.Database;
+
+  constructor(dbPath: string) {
+    this.db = new Database(dbPath);
+    this.db.pragma('foreign_keys = ON');
+  }
+
+  public isOpen(): boolean {
+    return this.db.inTransaction;
+  }
+
+  public initialize() {
+    const fs = require('fs');
+    const schemaPath = join(__dirname, '../../schema.sql');
+
+    const schema = fs.readFileSync(schemaPath, 'utf-8');
+    const statements = schema.split(';').filter(s => s.trim());
+
+    for (const stmt of statements) {
+      if (stmt.trim()) {
+        this.db.exec(stmt);
+      }
+    }
+  }
+
+  public close() {
+    this.db.close();
+  }
+
+  public getUserById(userId: string) {
+    const stmt = this.db.prepare('SELECT * FROM users WHERE id = ?');
+    return stmt.get(userId) as { id: string; email: string; password_hash: string; tenant_id: string; role: string; created_at: string } | undefined;
+  }
+
+  public getUserByEmail(email: string) {
+    const stmt = this.db.prepare('SELECT * FROM users WHERE email = ?');
+    return stmt.get(email) as { id: string; email: string; password_hash: string; tenant_id: string; role: string; created_at: string } | undefined;
+  }
+
+  public createUser(userId: string, email: string, passwordHash: string, tenantId: string, role: string) {
+    const stmt = this.db.prepare('INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)');
+    return stmt.run(userId, email, passwordHash, tenantId, role);
+  }
+
+  public updateUserRole(userId: string, role: string) {
+    const stmt = this.db.prepare('UPDATE users SET role = ? WHERE id = ?');
+    return stmt.run(role, userId);
+  }
+
+  public getUsersByTenant(tenantId: string) {
+    const stmt = this.db.prepare('SELECT id, email, role, created_at FROM users WHERE tenant_id = ?');
+    return stmt.all(tenantId);
+  }
+
+  public getEventById(eventId: string) {
+    const stmt = this.db.prepare('SELECT * FROM events WHERE id = ?');
+    return stmt.get(eventId);
+  }
+
+  public createEvent(eventId: string, tenantId: string, name: string, properties: object, timestamp: string, userId?: string, sessionId?: string) {
+    const stmt = this.db.prepare('INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)');
+    return stmt.run(eventId, tenantId, name, JSON.stringify(properties), timestamp, userId, sessionId);
+  }
+
+  public getEventsByTenant(tenantId: string, limit: number = 100) {
+    const stmt = this.db.prepare('SELECT * FROM events WHERE tenant_id = ? ORDER BY timestamp DESC LIMIT ?');
+    return stmt.all(tenantId, limit);
+  }
+
+  public getFilteredEvents(tenantId: string, filter: any) {
+    let query = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: any[] = [tenantId];
+
+    if (filter.eventName) {
+      query += ' AND name = ?';
+      params.push(filter.eventName);
+    }
+
+    if (filter.propertyKey) {
+      const jsonExpr = `${filter.propertyKey} LIKE ?`;
+      query += ` AND ${jsonExpr}`;
+      params.push(`%${filter.propertyValue}%`);
+    }
+
+    if (filter.timestampStart) {
+      query += ' AND timestamp >= ?';
+      params.push(filter.timestampStart);
+    }
+
+    if (filter.timestampEnd) {
+      query += ' AND timestamp <= ?';
+      params.push(filter.timestampEnd);
+    }
+
+    const stmt = this.db.prepare(query);
+    return stmt.all(...params);
+  }
+
+  public getEventsForTimeseries(tenantId: string, eventName?: string, propertyWhitelist?: string[]) {
+    let query = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: any[] = [tenantId];
+
+    if (eventName) {
+      query += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (!propertyWhitelist || propertyWhitelist.length === 0) {
+      propertyWhitelist = ['*'];
+    }
+
+    if (propertyWhitelist.some(p => p === '*')) {
+      query += ' AND properties != "{}"';
+    } else {
+      query += ' AND json_type(properties, ?) = "text"';
+    }
+
+    const stmt = this.db.prepare(query);
+    return stmt.all(...params);
+  }
+
+  public getEventsForBreakdown(tenantId: string, eventName?: string, propertyKey: string) {
+    let query = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: any[] = [tenantId];
+
+    if (eventName) {
+      query += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    query += ' AND json_extract(properties, ?) IS NOT NULL';
+    params.push(`$${propertyKey}`);
+
+    const stmt = this.db.prepare(query);
+    return stmt.all(...params);
+  }
+
+  public getEventCount(tenantId: string) {
+    const stmt = this.db.prepare('SELECT COUNT(*) as count FROM events WHERE tenant_id = ?');
+    const result = stmt.get(tenantId) as { count: number };
+    return result.count;
+  }
+
+  public getDashboardById(dashboardId: string) {
+    const stmt = this.db.prepare('SELECT * FROM dashboards WHERE id = ?');
+    return stmt.get(dashboardId) as { id: string; tenant_id: string; name: string; owner_id: string; config: string } | undefined;
+  }
+
+  public getDashboardsByTenant(tenantId: string) {
+    const stmt = this.db.prepare('SELECT id, name, owner_id, created_at, updated_at FROM dashboards WHERE tenant_id = ?');
+    return stmt.all(tenantId);
+  }
+
+  public createDashboard(dashboardId: string, tenantId: string, name: string, ownerId: string, config: object) {
+    const stmt = this.db.prepare('INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)');
+    return stmt.run(dashboardId, tenantId, name, ownerId, JSON.stringify(config));
+  }
+
+  public getWidgetById(widgetId: string) {
+    const stmt = this.db.prepare('SELECT * FROM widgets WHERE id = ?');
+    return stmt.get(widgetId) as { id: string; dashboard_id: string; type: string; config: string; position_x: number; position_y: number; width: number; height: number } | undefined;
+  }
+
+  public getWidgetsByDashboard(dashboardId: string) {
+    const stmt = this.db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?');
+    return stmt.all(dashboardId);
+  }
+
+  public createWidget(widgetId: string, dashboardId: string, type: string, config: object, position_x: number, position_y: number, width: number, height: number) {
+    const stmt = this.db.prepare('INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)');
+    return stmt.run(widgetId, dashboardId, type, JSON.stringify(config), position_x, position_y, width, height);
+  }
+
+  public deleteWidget(widgetId: string) {
+    const stmt = this.db.prepare('DELETE FROM widgets WHERE id = ?');
+    return stmt.run(widgetId);
+  }
+
+  public updateDashboard(dashboardId: string, name?: string, config?: object) {
+    const stmt = this.db.prepare('UPDATE dashboards SET name = ?, config = ?, updated_at = datetime("now") WHERE id = ?');
+    return stmt.run(name || '', JSON.stringify(config), dashboardId);
+  }
+
+  public deleteDashboard(dashboardId: string) {
+    const stmt = this.db.prepare('DELETE FROM dashboards WHERE id = ?');
+    return stmt.run(dashboardId);
+  }
+
+  public getAllEvents(): Database.Statement {
+    return this.db.prepare('SELECT * FROM events ORDER BY timestamp DESC');
+  }
+
+  public getEventCountByTenant(tenantId: string, eventName?: string) {
+    let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+    const params: any[] = [tenantId];
+
+    if (eventName) {
+      query += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    const stmt = this.db.prepare(query);
+    const result = stmt.get(...params) as { count: number };
+    return result.count;
+  }
+
+  public getEventsByDashboard(dashboardId: string) {
+    const stmt = this.db.prepare(`
+      WITH widget_ids AS (
+        SELECT id FROM widgets WHERE dashboard_id = ?
+      )
+      SELECT e.*
+      FROM events e
+      WHERE e.id IN (SELECT event_id FROM widgets_event WHERE dashboard_id = ?)
+      OR 1=0
+    `);
+    return stmt.all(dashboardId, dashboardId);
+  }
+}
+
+let db: DatabaseManager | null = null;
+
+export function getDB(dbPath: string): DatabaseManager {
+  if (!db) {
+    db = new DatabaseManager(dbPath);
+    db.initialize();
+  }
+  return db;
+}
+
+export function closeDB() {
+  if (db) {
+    db.close();
+    db = null;
+  }
+}
