+import { isAuthenticated, AuthenticatedRequest } from './utils';
+
+const router = Router();
+
+router.get('/count', isAuthenticated, (req: AuthenticatedRequest, res: ApiResponse) => {
+  if (!req.user) {
+    res.status(401).json({ success: false, error: 'Unauthorized' });
+    return;
+  }
+
+  const db = getDB('./analytics.db');
+  const eventName = req.query.eventName as string | undefined;
+
+  const count = db.getEventCountByTenant(req.user.tenantId, eventName);
+
+  res.json({
+    success: true,
+    data: { count, eventName }
+  });
+});
+
+router.post('/timeseries', isAuthenticated, (req: AuthenticatedRequest, res: ApiResponse) => {
+  if (!req.user) {
+    res.status(401).json({ success: false, error: 'Unauthorized' });
+    return;
+  }
+
+  const { filter, bucketSize }: TimeseriesQuery = req.body;
+
+  if (!filter || !bucketSize) {
+    res.status(400).json({ success: false, error: 'Filter and bucketSize are required' });
+    return;
+  }
+
+  if (!['hour', 'day', 'week', 'month'].includes(bucketSize)) {
+    res.status(400).json({ success: false, error: 'bucketSize must be hour, day, week, or month' });
+    return;
+  }
+
+  const db = getDB('./analytics.db');
+  const eventName = filter.eventName;
+  const propertyWhitelist = filter.propertyWhitelist;
+
+  // Get all events for the tenant
+  let events: any[];
+  if (eventName) {
+    events = db.getEventsForTimeseries(req.user.tenantId, eventName, propertyWhitelist);
+  } else {
+    events = db.getEventsForTimeseries(req.user.tenantId, undefined, propertyWhitelist);
+  }
+
+  const buckets: { [key: string]: number } = {};
+
+  for (const event of events) {
+    const properties = event.properties ? JSON.parse(event.properties) : {};
+    const timestamp = event.timestamp;
+
+    if (!timestamp) continue;
+    const date = new Date(timestamp);
+    let bucketKey: string;
+
+    switch (bucketSize) {
+      case 'hour':
+        bucketKey = date.toISOString().slice(0, 10) + 'T' + date.toISOString().slice(11, 13) + ':00:00';
+        break;
+      case 'day':
+        bucketKey = date.toISOString().slice(0, 10);
+        break;
+      case 'week':
+        bucketKey = 'W' + getWeekNumber(date);
+        break;
+      case 'month':
+        bucketKey = date.toISOString().slice(0, 7);
+        break;
+      default:
+        break;
+    }
+
+    if (bucketKey && !buckets[bucketKey]) {
+      buckets[bucketKey] = 0;
+    }
+    if (bucketKey) {
+      buckets[bucketKey] = (buckets[bucketKey] || 0) + 1;
+    }
+  }
+
+  const sortedBuckets = Object.entries(buckets)
+    .sort(([a], [b]) => a.localeCompare(b));
+
+  const result = sortedBuckets.map(([key, value]) => ({ key, value }));
+
+  res.json({
+    success: true,
+    data: { bucketSize, buckets: result }
+  });
+});
+
+router.post('/breakdown', isAuthenticated, (req: AuthenticatedRequest, res: ApiResponse) => {
+  if (!req.user) {
+    res.status(401).json({ success: false, error: 'Unauthorized' });
+    return;
+  }
+
+  const { filter, propertyKey }: BreakdownQuery = req.body;
+
+  if (!filter || !propertyKey) {
+    res.status(400).json({ success: false, error: 'Filter and propertyKey are required' });
+    return;
+  }
+
+  const db = getDB('./analytics.db');
+  const eventName = filter.eventName;
+
+  const events = db.getEventsForBreakdown(req.user.tenantId, eventName, propertyKey);
+
+  const breakdown: { [key: string]: number } = {};
+
+  const valueFromProperties = propsObj['value'];
+
+  for (const event of events) {
+    const props = JSON.parse(event.properties);
+    let value: string | undefined = props[propertyKey];
+
+    if (value === undefined && valueFromProperties) {
+      value = valueFromProperties.toString();
+    }
+
+    if (value) {
+      breakdown[value] = (breakdown[value] || 0) + 1;
+    }
+  }
+
+  const sortedBreakdown = Object.entries(breakdown)
+    .sort(([, countA], [, countB]) => countB - countA);
+
+  res.json({
+    success: true,
+    data: {
+      propertyKey,
+      breakdown: sortedBreakdown.map(([key, value]) => ({ key, value }))
+    }
+  });
+});
+
+function getWeekNumber(date: Date): string {
+  const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
+  const dayNum = d.getUTCDay() || 7;
+  d.setUTCDate(d.getUTCDate() + 4 - dayNum);
+  const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
+  const weekNo = Math.ceil((((+d - +yearStart) / 86400000) + 1) / 7);
+  return `${d.getUTCFullYear()}-W${weekNo.toString().padStart(2, '0')}`;
+}
