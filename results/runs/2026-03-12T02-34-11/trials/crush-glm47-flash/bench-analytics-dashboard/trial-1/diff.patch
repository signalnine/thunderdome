+import { Router, Request, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDB } from './db';
+import { type ApiResponse, type CreateEventRequest, type CreateEventsBatchRequest } from './types';
+import { isAuthenticated, AuthenticatedRequest } from './utils';
+import { v4 as uuidv4 } from 'uuid';
+import { getDB } from './db';
+import { type ApiResponse, type CreateEventRequest, type CreateEventsBatchRequest } from './types';
+import { isAuthenticated, AuthenticatedRequest } from './utils';
+
+const router = Router();
+
+router.post('/', isAuthenticated, (req: AuthenticatedRequest, res: ApiResponse) => {
+  if (!req.user) {
+    res.status(401).json({ success: false, error: 'Unauthorized' });
+    return;
+  }
+
+  const { name, properties, timestamp } = req.body;
+
+  if (!name) {
+    res.status(400).json({ success: false, error: 'Event name is required' });
+    return;
+  }
+
+  const eventId = uuidv4();
+  const eventTimestamp = timestamp || new Date().toISOString();
+
+  const db = getDB('./analytics.db');
+
+  try {
+    db.createEvent(
+      eventId,
+      req.user.tenantId,
+      name,
+      properties || {},
+      eventTimestamp,
+      req.user.userId
+    );
+
+    res.status(201).json({
+      success: true,
+      data: { id: eventId, name, properties, timestamp: eventTimestamp }
+    });
+  } catch (err) {
+    res.status(500).json({ success: false, error: 'Failed to create event' });
+  }
+});
+
+router.post('/batch', isAuthenticated, (req: CreateEventsBatchRequest, res: ApiResponse) => {
+  if (!req.user) {
+    res.status(401).json({ success: false, error: 'Unauthorized' });
+    return;
+  }
+
+  const { events } = req.body;
+
+  if (!events || !Array.isArray(events) || events.length === 0) {
+    res.status(400).json({ success: false, error: 'Events array is required' });
+    return;
+  }
+
+  if (events.length > 1000) {
+    res.status(400).json({ success: false, error: 'Maximum 1000 events per batch' });
+    return;
+  }
+
+  const db = getDB('./analytics.db');
+  const createdEvents: any[] = [];
+
+  try {
+    const insertStmt = db.db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)'
+    );
+
+    const transaction = db.db.transaction((eventsToInsert: any[]) => {
+      const results: any[] = [];
+      for (const event of eventsToInsert) {
+        if (!event.name) {
+          continue;
+        }
+
+        const eventId = event.id || uuidv4();
+        const eventTimestamp = event.timestamp || new Date().toISOString();
+
+        insertStmt.run(
+          eventId,
+          req.user.tenantId,
+          event.name,
+          JSON.stringify(event.properties || {}),
+          eventTimestamp,
+          req.user.userId
+        );
+
+        results.push({ id: eventId, name: event.name, timestamp: eventTimestamp });
+      }
+      return results;
+    });
+
+    createdEvents.push(...transaction(events));
+
+    res.status(201).json({
+      success: true,
+      data: {
+        count: createdEvents.length,
+        events: createdEvents
+      }
+    });
+  } catch (err) {
+    res.status(500).json({ success: false, error: 'Failed to create batch events' });
+  }
+});
+
+router.get('/', isAuthenticated, (req: AuthenticatedRequest, res: ApiResponse) => {
+  if (!req.user) {
+    res.status(401).json({ success: false, error: 'Unauthorized' });
+    return;
+  }
+
+  const db = getDB('./analytics.db');
+  const limit = parseInt(req.query.limit as string) || 100;
+
+  const events = db.getEventsByTenant(req.user.tenantId, limit);
+
+  res.json({
+    success: true,
+    data: events.map((event: any) => ({
+      id: event.id,
+      name: event.name,
+      properties: JSON.parse(event.properties),
+      timestamp: event.timestamp,
+      user_id: event.user_id
+    }))
+  });
+});
+
+export default router;
