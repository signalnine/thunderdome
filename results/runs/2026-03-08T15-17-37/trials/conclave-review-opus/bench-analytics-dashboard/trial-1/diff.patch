+import { Router, Response } from "express";
+import { v4 as uuidv4 } from "uuid";
+import { getDb } from "../db.js";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+const router = Router();
+
+router.use(authMiddleware);
+
+// Ingest single event
+router.post("/", (req: AuthRequest, res: Response) => {
+  const { name, properties, timestamp, sessionId } = req.body;
+
+  if (!name) {
+    res.status(400).json({ error: "Event name is required" });
+    return;
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const eventTimestamp = timestamp || new Date().toISOString();
+  const eventProperties = properties ? JSON.stringify(properties) : "{}";
+
+  db.prepare(
+    "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+  ).run(id, req.user!.tenantId, name, eventProperties, eventTimestamp, req.user!.userId, sessionId || null);
+
+  res.status(201).json({ id, name, tenantId: req.user!.tenantId, timestamp: eventTimestamp });
+});
+
+// Ingest batch events
+router.post("/batch", (req: AuthRequest, res: Response) => {
+  const { events } = req.body;
+
+  if (!Array.isArray(events) || events.length === 0) {
+    res.status(400).json({ error: "events array is required" });
+    return;
+  }
+
+  const db = getDb();
+  const insert = db.prepare(
+    "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+  );
+
+  const insertMany = db.transaction((evts: Array<{ name: string; properties?: Record<string, unknown>; timestamp?: string; sessionId?: string }>) => {
+    const results: Array<{ id: string; name: string }> = [];
+    for (const evt of evts) {
+      if (!evt.name) continue;
+      const id = uuidv4();
+      const ts = evt.timestamp || new Date().toISOString();
+      const props = evt.properties ? JSON.stringify(evt.properties) : "{}";
+      insert.run(id, req.user!.tenantId, evt.name, props, ts, req.user!.userId, evt.sessionId || null);
+      results.push({ id, name: evt.name });
+    }
+    return results;
+  });
+
+  const results = insertMany(events);
+  res.status(201).json({ inserted: results.length, events: results });
+});
+
+export default router;
