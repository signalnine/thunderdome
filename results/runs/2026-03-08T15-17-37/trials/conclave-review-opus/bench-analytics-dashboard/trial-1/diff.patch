+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QtpfPcgQEcszjRo6Nnn7je","type":"tool_result","content":"     1→import { Request, Response, NextFunction } from \"express\";\n     2→import jwt from \"jsonwebtoken\";\n     3→\n     4→const JWT_SECRET = process.env.JWT_SECRET || \"analytics-dashboard-secret\";\n     5→\n     6→export interface AuthPayload {\n     7→  userId: string;\n     8→  tenantId: string;\n     9→  role: string;\n    10→  email: string;\n    11→}\n    12→\n    13→export interface AuthRequest extends Request {\n    14→  user?: AuthPayload;\n    15→}\n    16→\n    17→export function signToken(payload: AuthPayload): string {\n    18→  return jwt.sign(payload, JWT_SECRET, { expiresIn: \"24h\" });\n    19→}\n    20→\n    21→export function verifyToken(token: string): AuthPayload {\n    22→  return jwt.verify(token, JWT_SECRET) as AuthPayload;\n    23→}\n    24→\n    25→export function authMiddleware(\n    26→  req: AuthRequest,\n    27→  res: Response,\n    28→  next: NextFunction\n    29→): void {\n    30→  const header = req.headers.authorization;\n    31→  if (!header || !header.startsWith(\"Bearer \")) {\n    32→    res.status(401).json({ error: \"Authentication required\" });\n    33→    return;\n    34→  }\n    35→\n    36→  const token = header.slice(7);\n    37→  try {\n    38→    req.user = verifyToken(token);\n    39→    next();\n    40→  } catch {\n    41→    res.status(401).json({ error: \"Invalid or expired token\" });\n    42→  }\n    43→}\n    44→"}]},"parent_tool_use_id":"toolu_01LVCfbWhqqYh2TzUVvTNTr5","session_id":"5e4cf42f-969d-4e71-a19c-7c0602a95f19","uuid":"73b64597-45e4-45bf-b6ad-b124fbd33c53"}
