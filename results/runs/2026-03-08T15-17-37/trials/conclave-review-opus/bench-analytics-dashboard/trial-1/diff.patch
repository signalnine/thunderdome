+
+function escapeCsvField(field: string): string {
+  if (field.includes(",") || field.includes('"') || field.includes("\n")) {
+    return `"${field.replace(/"/g, '""')}"`;
+  }
+  return field;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = "id,tenant_id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map(
+    (e) =>
+      [
+        escapeCsvField(e.id),
+        escapeCsvField(e.tenant_id),
+        escapeCsvField(e.name),
+        escapeCsvField(e.properties),
+        escapeCsvField(e.timestamp),
+        escapeCsvField(e.user_id || ""),
+        escapeCsvField(e.session_id || ""),
+      ].join(",")
+  );
+  return [header, ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const header = "id,tenant_id,name,owner_id,config,created_at,updated_at";
+  const rows = dashboards.map(
+    (d) =>
+      [
+        escapeCsvField(d.id),
+        escapeCsvField(d.tenant_id),
+        escapeCsvField(d.name),
+        escapeCsvField(d.owner_id),
+        escapeCsvField(d.config),
+        escapeCsvField(d.created_at),
+        escapeCsvField(d.updated_at),
+      ].join(",")
+  );
+  return [header, ...rows].join("\n");
+}
+
+// Export events
+router.get("/events", (req: AuthRequest, res: Response) => {
+  const format = (req.query.format as string) || "json";
+  const db = getDb();
+
+  let sql = "SELECT * FROM events WHERE tenant_id = ?";
+  const params: unknown[] = [req.user!.tenantId];
+
+  if (req.query.eventName) {
+    sql += " AND name = ?";
+    params.push(req.query.eventName);
+  }
+
+  if (req.query.startDate) {
+    sql += " AND timestamp >= ?";
+    params.push(req.query.startDate);
+  }
+
+  if (req.query.endDate) {
+    sql += " AND timestamp <= ?";
+    params.push(req.query.endDate);
+  }
+
+  sql += " ORDER BY timestamp DESC";
+
+  const events = db.prepare(sql).all(...params) as EventRow[];
+
+  if (format === "csv") {
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCsv(events));
+  } else {
+    res.json({
+      events: events.map((e) => ({
+        id: e.id,
+        tenantId: e.tenant_id,
+        name: e.name,
+        properties: JSON.parse(e.properties),
+        timestamp: e.timestamp,
+        userId: e.user_id,
+        sessionId: e.session_id,
+      })),
+    });
+  }
+});
+
+// Export dashboards
+router.get("/dashboards", (req: AuthRequest, res: Response) => {
+  const format = (req.query.format as string) || "json";
+  const db = getDb();
+
+  const dashboards = db
+    .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+    .all(req.user!.tenantId) as DashboardRow[];
+
+  if (format === "csv") {
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+    res.send(dashboardsToCsv(dashboards));
+  } else {
+    res.json({
+      dashboards: dashboards.map((d) => ({
+        id: d.id,
+        tenantId: d.tenant_id,
+        name: d.name,
+        ownerId: d.owner_id,
+        config: JSON.parse(d.config),
+        createdAt: d.created_at,
+        updatedAt: d.updated_at,
+      })),
+    });
+  }
+});
+
+export default router;
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..bf46ec6
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,123 @@
+import { Router, Response } from "express";
+import { getDb } from "../db.js";
+import { AuthRequest, authMiddleware } from "../auth.js";
+
+const router = Router();
+
+router.use(authMiddleware);
+
+const TIMESERIES_BUCKETS: Record<string, string> = {
+  hour: "%Y-%m-%dT%H:00:00",
+  day: "%Y-%m-%d",
+  month: "%Y-%m",
+};
+
+// Count query
+router.post("/count", (req: AuthRequest, res: Response) => {
+  const { eventName, startDate, endDate, filters } = req.body;
+
+  const db = getDb();
+  let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+  const params: unknown[] = [req.user!.tenantId];
+
+  if (eventName) {
+    sql += " AND name = ?";
+    params.push(eventName);
+  }
+
+  if (startDate) {
+    sql += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+
+  if (endDate) {
+    sql += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  if (filters && typeof filters === "object") {
+    for (const [key, value] of Object.entries(filters)) {
+      sql += " AND json_extract(properties, ?) = ?";
+      params.push(`$.${key}`, value as string);
+    }
+  }
+
+  const result = db.prepare(sql).get(...params) as { count: number };
+  res.json({ count: result.count });
+});
+
+// Timeseries query
+router.post("/timeseries", (req: AuthRequest, res: Response) => {
+  const { eventName, startDate, endDate, interval, filters } = req.body;
+
+  if (!eventName) {
+    res.status(400).json({ error: "eventName is required" });
+    return;
+  }
+
+  const db = getDb();
+  const bucket = TIMESERIES_BUCKETS[interval as string] || TIMESERIES_BUCKETS.day;
+
+  let sql = `SELECT strftime('${bucket}', timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+  const params: unknown[] = [req.user!.tenantId, eventName];
+
+  if (startDate) {
+    sql += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+
+  if (endDate) {
+    sql += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  if (filters && typeof filters === "object") {
+    for (const [key, value] of Object.entries(filters)) {
+      sql += " AND json_extract(properties, ?) = ?";
+      params.push(`$.${key}`, value as string);
+    }
+  }
+
+  sql += " GROUP BY period ORDER BY period";
+
+  const results = db.prepare(sql).all(...params) as Array<{ period: string; count: number }>;
+  res.json({ data: results });
+});
+
+// Breakdown query
+router.post("/breakdown", (req: AuthRequest, res: Response) => {
+  const { eventName, property, startDate, endDate, filters } = req.body;
+
+  if (!eventName || !property) {
+    res.status(400).json({ error: "eventName and property are required" });
+    return;
+  }
+
+  const db = getDb();
+  let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ?`;
+  const params: unknown[] = [`$.${property}`, req.user!.tenantId, eventName];
+
+  if (startDate) {
+    sql += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+
+  if (endDate) {
+    sql += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  if (filters && typeof filters === "object") {
+    for (const [key, value] of Object.entries(filters)) {
+      sql += " AND json_extract(properties, ?) = ?";
+      params.push(`$.${key}`, value as string);
+    }
+  }
+
+  sql += " GROUP BY value ORDER BY count DESC";
+
+  const results = db.prepare(sql).all(...params) as Array<{ value: string; count: number }>;
+  res.json({ data: results });
+});
+
+export default router;
