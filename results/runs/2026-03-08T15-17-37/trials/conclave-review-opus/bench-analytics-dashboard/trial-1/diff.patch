CsvField(d.updated_at),\n      ].join(\",\")\n  );\n  return [header, ...rows].join(\"\\n\");\n}\n\n// Export events\nrouter.get(\"/events\", (req: AuthRequest, res: Response) => {\n  const format = (req.query.format as string) || \"json\";\n  const db = getDb();\n\n  let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n  const params: unknown[] = [req.user!.tenantId];\n\n  if (req.query.eventName) {\n    sql += \" AND name = ?\";\n    params.push(req.query.eventName);\n  }\n\n  if (req.query.startDate) {\n    sql += \" AND timestamp >= ?\";\n    params.push(req.query.startDate);\n  }\n\n  if (req.query.endDate) {\n    sql += \" AND timestamp <= ?\";\n    params.push(req.query.endDate);\n  }\n\n  sql += \" ORDER BY timestamp DESC\";\n\n  const events = db.prepare(sql).all(...params) as EventRow[];\n\n  if (format === \"csv\") {\n    res.setHeader(\"Content-Type\", \"text/csv\");\n    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n    res.send(eventsToCsv(events));\n  } else {\n    res.json({\n      events: events.map((e) => ({\n        id: e.id,\n        tenantId: e.tenant_id,\n        name: e.name,\n        properties: JSON.parse(e.properties),\n        timestamp: e.timestamp,\n        userId: e.user_id,\n        sessionId: e.session_id,\n      })),\n    });\n  }\n});\n\n// Export dashboards\nrouter.get(\"/dashboards\", (req: AuthRequest, res: Response) => {\n  const format = (req.query.format as string) || \"json\";\n  const db = getDb();\n\n  const dashboards = db\n    .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n    .all(req.user!.tenantId) as DashboardRow[];\n\n  if (format === \"csv\") {\n    res.setHeader(\"Content-Type\", \"text/csv\");\n    res.setHeader(\"Content-Disposition\", \"attachment; filename=dashboards.csv\");\n    res.send(dashboardsToCsv(dashboards));\n  } else {\n    res.json({\n      dashboards: dashboards.map((d) => ({\n        id: d.id,\n        tenantId: d.tenant_id,\n        name: d.name,\n        ownerId: d.owner_id,\n        config: JSON.parse(d.config),\n        createdAt: d.created_at,\n        updatedAt: d.updated_at,\n      })),\n    });\n  }\n});\n\nexport default router;\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1371,"cache_read_input_tokens":25226,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1371},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5e4cf42f-969d-4e71-a19c-7c0602a95f19","uuid":"a336446b-0a26-4ccd-ab3f-3b5aa292d6d4"}
