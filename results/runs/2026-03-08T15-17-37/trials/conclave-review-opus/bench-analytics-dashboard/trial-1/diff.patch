+  createDb();
+
+  const app = express();
+  app.use(express.json());
+
+  app.get("/health", (_req, res) => {
+    res.json({ status: "ok" });
+  });
+
+  // User management (register, login, profile)
+  app.use("/auth", userRoutes);
