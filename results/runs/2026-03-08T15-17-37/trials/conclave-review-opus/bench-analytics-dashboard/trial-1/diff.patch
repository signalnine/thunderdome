+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M5h3t3J6hfPe2JovwTgV5F","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import { v4 as uuidv4 } from \"uuid\";\n     3→import { getDb } from \"../db.js\";\n     4→import { AuthRequest, authMiddleware } from \"../auth.js\";\n     5→\n     6→const router = Router();\n     7→\n     8→router.use(authMiddleware);\n     9→\n    10→interface DashboardRow {\n    11→  id: string;\n    12→  tenant_id: string;\n    13→  name: string;\n    14→  owner_id: string;\n    15→  config: string;\n    16→  created_at: string;\n    17→  updated_at: string;\n    18→}\n    19→\n    20→// Create dashboard\n    21→router.post(\"/\", (req: AuthRequest, res: Response) => {\n    22→  const { name, config } = req.body;\n    23→\n    24→  if (!name) {\n    25→    res.status(400).json({ error: \"Dashboard name is required\" });\n    26→    return;\n    27→  }\n    28→\n    29→  const db = getDb();\n    30→  const id = uuidv4();\n    31→  const dashConfig = config ? JSON.stringify(config) : \"{}\";\n    32→  const now = new Date().toISOString();\n    33→\n    34→  db.prepare(\n    35→    \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    36→  ).run(id, req.user!.tenantId, name, req.user!.userId, dashConfig, now, now);\n    37→\n    38→  res.status(201).json({ id, name, tenantId: req.user!.tenantId, ownerId: req.user!.userId, config: config || {}, createdAt: now, updatedAt: now });\n    39→});\n    40→\n    41→// List dashboards for tenant\n    42→router.get(\"/\", (req: AuthRequest, res: Response) => {\n    43→  const db = getDb();\n    44→  const dashboards = db\n    45→    .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n    46→    .all(req.user!.tenantId) as DashboardRow[];\n    47→\n    48→  res.json({\n    49→    dashboards: dashboards.map((d) => ({\n    50→      id: d.id,\n    51→      name: d.name,\n    52→      tenantId: d.tenant_id,\n    53→      ownerId: d.owner_id,\n    54→      config: JSON.parse(d.config),\n    55→      createdAt: d.created_at,\n    56→      updatedAt: d.updated_at,\n    57→    })),\n    58→  });\n    59→});\n    60→\n    61→// Get single dashboard\n    62→router.get(\"/:id\", (req: AuthRequest, res: Response) => {\n    63→  const db = getDb();\n    64→  const dashboard = db\n    65→    .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    66→    .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n    67→\n    68→  if (!dashboard) {\n    69→    res.status(404).json({ error: \"Dashboard not found\" });\n    70→    return;\n    71→  }\n    72→\n    73→  res.json({\n    74→    id: dashboard.id,\n    75→    name: dashboard.name,\n    76→    tenantId: dashboard.tenant_id,\n    77→    ownerId: dashboard.owner_id,\n    78→    config: JSON.parse(dashboard.config),\n    79→    createdAt: dashboard.created_at,\n    80→    updatedAt: dashboard.updated_at,\n    81→  });\n    82→});\n    83→\n    84→// Update dashboard\n    85→router.put(\"/:id\", (req: AuthRequest, res: Response) => {\n    86→  const { name, config } = req.body;\n    87→\n    88→  const db = getDb();\n    89→  const existing = db\n    90→    .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    91→    .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n    92→\n    93→  if (!existing) {\n    94→    res.status(404).json({ error: \"Dashboard not found\" });\n    95→    return;\n    96→  }\n    97→\n    98→  const updatedName = name || existing.name;\n    99→  const updatedConfig = config ? JSON.stringify(config) : existing.config;\n   100→  const now = new Date().toISOString();\n   101→\n   102→  db.prepare(\"UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?\").run(\n   103→    updatedName,\n   104→    updatedConfig,\n   105→    now,\n   106→    req.params.id\n   107→  );\n   108→\n   109→  res.json({\n   110→    id: req.params.id,\n   111→    name: updatedName,\n   112→    tenantId: req.user!.tenantId,\n   113→    ownerId: existing.owner_id,\n   114→    config: JSON.parse(updatedConfig),\n   115→    createdAt: existing.created_at,\n   116→    updatedAt: now,\n   117→  });\n   118→});\n   119→\n   120→// Delete dashboard\n   121→router.delete(\"/:id\", (req: AuthRequest, res: Response) => {\n   122→  const db = getDb();\n   123→  const existing = db\n   124→    .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n   125→    .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n   126→\n   127→  if (!existing) {\n   128→    res.status(404).json({ error: \"Dashboard not found\" });\n   129→    return;\n   130→  }\n   131→\n   132→  db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(req.params.id);\n   133→  res.status(204).send();\n   134→});\n   135→\n   136→export default router;\n   137→"}]},"parent_tool_use_id":"toolu_01LVCfbWhqqYh2TzUVvTNTr5","session_id":"5e4cf42f-969d-4e71-a19c-7c0602a95f19","uuid":"69527290-c177-439c-9ca5-6cd044714a61"}
