+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GSJ9FhujnTDjUwJe3XDrFF","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import { v4 as uuidv4 } from \"uuid\";\n     3→import { createHash } from \"crypto\";\n     4→import { getDb } from \"../db.js\";\n     5→import { AuthRequest, authMiddleware, signToken } from \"../auth.js\";\n     6→\n     7→const router = Router();\n     8→\n     9→function hashPassword(password: string): string {\n    10→  return createHash(\"sha256\").update(password).digest(\"hex\");\n    11→}\n    12→\n    13→// Register\n    14→router.post(\"/register\", (req: AuthRequest, res: Response) => {\n    15→  const { email, password, tenantId, role } = req.body;\n    16→\n    17→  if (!email || !password || !tenantId) {\n    18→    res.status(400).json({ error: \"email, password, and tenantId are required\" });\n    19→    return;\n    20→  }\n    21→\n    22→  const db = getDb();\n    23→  const userRole = role && [\"admin\", \"viewer\", \"editor\"].includes(role) ? role : \"viewer\";\n    24→  const id = uuidv4();\n    25→  const passwordHash = hashPassword(password);\n    26→\n    27→  try {\n    28→    db.prepare(\n    29→      \"INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)\"\n    30→    ).run(id, email, passwordHash, tenantId, userRole);\n    31→\n    32→    const token = signToken({ userId: id, tenantId, role: userRole, email });\n    33→    res.status(201).json({ id, email, tenantId, role: userRole, token });\n    34→  } catch (err: unknown) {\n    35→    const message = err instanceof Error ? err.message : \"Unknown error\";\n    36→    if (message.includes(\"UNIQUE constraint\")) {\n    37→      res.status(409).json({ error: \"Email already exists\" });\n    38→      return;\n    39→    }\n    40→    res.status(500).json({ error: message });\n    41→  }\n    42→});\n    43→\n    44→// Login\n    45→router.post(\"/login\", (req: AuthRequest, res: Response) => {\n    46→  const { email, password } = req.body;\n    47→\n    48→  if (!email || !password) {\n    49→    res.status(400).json({ error: \"email and password are required\" });\n    50→    return;\n    51→  }\n    52→\n    53→  const db = getDb();\n    54→  const user = db\n    55→    .prepare(\"SELECT * FROM users WHERE email = ?\")\n    56→    .get(email) as { id: string; email: string; password_hash: string; tenant_id: string; role: string } | undefined;\n    57→\n    58→  if (!user || user.password_hash !== hashPassword(password)) {\n    59→    res.status(401).json({ error: \"Invalid email or password\" });\n    60→    return;\n    61→  }\n    62→\n    63→  const token = signToken({\n    64→    userId: user.id,\n    65→    tenantId: user.tenant_id,\n    66→    role: user.role,\n    67→    email: user.email,\n    68→  });\n    69→  res.json({ token, user: { id: user.id, email: user.email, tenantId: user.tenant_id, role: user.role } });\n    70→});\n    71→\n    72→// Get profile\n    73→router.get(\"/me\", authMiddleware, (req: AuthRequest, res: Response) => {\n    74→  const db = getDb();\n    75→  const user = db\n    76→    .prepare(\"SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?\")\n    77→    .get(req.user!.userId) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;\n    78→\n    79→  if (!user) {\n    80→    res.status(404).json({ error: \"User not found\" });\n    81→    return;\n    82→  }\n    83→\n    84→  res.json({\n    85→    id: user.id,\n    86→    email: user.email,\n    87→    tenantId: user.tenant_id,\n    88→    role: user.role,\n    89→    createdAt: user.created_at,\n    90→  });\n    91→});\n    92→\n    93→// Admin: change user role\n    94→router.put(\"/users/:userId/role\", authMiddleware, (req: AuthRequest, res: Response) => {\n    95→  if (req.user!.role !== \"admin\") {\n    96→    res.status(403).json({ error: \"Admin access required\" });\n    97→    return;\n    98→  }\n    99→\n   100→  const { role } = req.body;\n   101→  if (!role || ![\"admin\", \"viewer\", \"editor\"].includes(role)) {\n   102→    res.status(400).json({ error: \"Valid role required: admin, viewer, editor\" });\n   103→    return;\n   104→  }\n   105→\n   106→  const db = getDb();\n   107→  const targetUser = db\n   108→    .prepare(\"SELECT id, tenant_id FROM users WHERE id = ?\")\n   109→    .get(req.params.userId) as { id: string; tenant_id: string } | undefined;\n   110→\n   111→  if (!targetUser) {\n   112→    res.status(404).json({ error: \"User not found\" });\n   113→    return;\n   114→  }\n   115→\n   116→  if (targetUser.tenant_id !== req.user!.tenantId) {\n   117→    res.status(403).json({ error: \"Cannot modify users in other tenants\" });\n   118→    return;\n   119→  }\n   120→\n   121→  db.prepare(\"UPDATE users SET role = ? WHERE id = ?\").run(role, req.params.userId);\n   122→  res.json({ id: req.params.userId, role });\n   123→});\n   124→\n   125→export default router;\n   126→"}]},"parent_tool_use_id":"toolu_01LVCfbWhqqYh2TzUVvTNTr5","session_id":"5e4cf42f-969d-4e71-a19c-7c0602a95f19","uuid":"826d9021-2e48-4c6b-8cbc-653b9e63bd90"}
