+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PErAsMQU77hCrMooruP4ho","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import { getDb } from \"../db.js\";\n     3→import { AuthRequest, authMiddleware } from \"../auth.js\";\n     4→\n     5→const router = Router();\n     6→\n     7→router.use(authMiddleware);\n     8→\n     9→interface EventRow {\n    10→  id: string;\n    11→  tenant_id: string;\n    12→  name: string;\n    13→  properties: string;\n    14→  timestamp: string;\n    15→  user_id: string | null;\n    16→  session_id: string | null;\n    17→}\n    18→\n    19→interface DashboardRow {\n    20→  id: string;\n    21→  tenant_id: string;\n    22→  name: string;\n    23→  owner_id: string;\n    24→  config: string;\n    25→  created_at: string;\n    26→  updated_at: string;\n    27→}\n    28→\n    29→function escapeCsvField(field: string): string {\n    30→  if (field.includes(\",\") || field.includes('\"') || field.includes(\"\\n\")) {\n    31→    return `\"${field.replace(/\"/g, '\"\"')}\"`;\n    32→  }\n    33→  return field;\n    34→}\n    35→\n    36→function eventsToCsv(events: EventRow[]): string {\n    37→  const header = \"id,tenant_id,name,properties,timestamp,user_id,session_id\";\n    38→  const rows = events.map(\n    39→    (e) =>\n    40→      [\n    41→        escapeCsvField(e.id),\n    42→        escapeCsvField(e.tenant_id),\n    43→        escapeCsvField(e.name),\n    44→        escapeCsvField(e.properties),\n    45→        escapeCsvField(e.timestamp),\n    46→        escapeCsvField(e.user_id || \"\"),\n    47→        escapeCsvField(e.session_id || \"\"),\n    48→      ].join(\",\")\n    49→  );\n    50→  return [header, ...rows].join(\"\\n\");\n    51→}\n    52→\n    53→function dashboardsToCsv(dashboards: DashboardRow[]): string {\n    54→  const header = \"id,tenant_id,name,owner_id,config,created_at,updated_at\";\n    55→  const rows = dashboards.map(\n    56→    (d) =>\n    57→      [\n    58→        escapeCsvField(d.id),\n    59→        escapeCsvField(d.tenant_id),\n    60→        escapeCsvField(d.name),\n    61→        escapeCsvField(d.owner_id),\n    62→        escapeCsvField(d.config),\n    63→        escapeCsvField(d.created_at),\n    64→        escapeCsvField(d.updated_at),\n    65→      ].join(\",\")\n    66→  );\n    67→  return [header, ...rows].join(\"\\n\");\n    68→}\n    69→\n    70→// Export events\n    71→router.get(\"/events\", (req: AuthRequest, res: Response) => {\n    72→  const format = (req.query.format as string) || \"json\";\n    73→  const db = getDb();\n    74→\n    75→  let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n    76→  const params: unknown[] = [req.user!.tenantId];\n    77→\n    78→  if (req.query.eventName) {\n    79→    sql += \" AND name = ?\";\n    80→    params.push(req.query.eventName);\n    81→  }\n    82→\n    83→  if (req.query.startDate) {\n    84→    sql += \" AND timestamp >= ?\";\n    85→    params.push(req.query.startDate);\n    86→  }\n    87→\n    88→  if (req.query.endDate) {\n    89→    sql += \" AND timestamp <= ?\";\n    90→    params.push(req.query.endDate);\n    91→  }\n    92→\n    93→  sql += \" ORDER BY timestamp DESC\";\n    94→\n    95→  const events = db.prepare(sql).all(...params) as EventRow[];\n    96→\n    97→  if (format === \"csv\") {\n    98→    res.setHeader(\"Content-Type\", \"text/csv\");\n    99→    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n   100→    res.send(eventsToCsv(events));\n   101→  } else {\n   102→    res.json({\n   103→      events: events.map((e) => ({\n   104→        id: e.id,\n   105→        tenantId: e.tenant_id,\n   106→        name: e.name,\n   107→        properties: JSON.parse(e.properties),\n   108→        timestamp: e.timestamp,\n   109→        userId: e.user_id,\n   110→        sessionId: e.session_id,\n   111→      })),\n   112→    });\n   113→  }\n   114→});\n   115→\n   116→// Export dashboards\n   117→router.get(\"/dashboards\", (req: AuthRequest, res: Response) => {\n   118→  const format = (req.query.format as string) || \"json\";\n   119→  const db = getDb();\n   120→\n   121→  const dashboards = db\n   122→    .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n   123→    .all(req.user!.tenantId) as DashboardRow[];\n   124→\n   125→  if (format === \"csv\") {\n   126→    res.setHeader(\"Content-Type\", \"text/csv\");\n   127→    res.setHeader(\"Content-Disposition\", \"attachment; filename=dashboards.csv\");\n   128→    res.send(dashboardsToCsv(dashboards));\n   129→  } else {\n   130→    res.json({\n   131→      dashboards: dashboards.map((d) => ({\n   132→        id: d.id,\n   133→        tenantId: d.tenant_id,\n   134→        name: d.name,\n   135→        ownerId: d.owner_id,\n   136→        config: JSON.parse(d.config),\n   137→        createdAt: d.created_at,\n   138→        updatedAt: d.updated_at,\n   139→      })),\n   140→    });\n   141→  }\n   142→});\n   143→\n   144→export default router;\n   145→"}]},"parent_tool_use_id":"toolu_01LVCfbWhqqYh2TzUVvTNTr5","session_id":"5e4cf42f-969d-4e71-a19c-7c0602a95f19","uuid":"d420fd01-6abd-4c0f-ace3-a964f55be62f"}
