--- /dev/null
+++ b/src/app.test.ts
@@ -0,0 +1,338 @@
+import { describe, it, expect, beforeEach } from "vitest";
+import request from "supertest";
+import { createApp } from "./app.js";
+import { closeDb } from "./db.js";
+import type { Express } from "express";
+
+let app: Express;
+
+beforeEach(() => {
+  closeDb();
+  app = createApp();
+});
+
+async function registerUser(overrides: Record<string, string> = {}) {
+  const data = {
+    email: `user${Math.random().toString(36).slice(2)}@test.com`,
+    password: "password123",
+    tenantId: "tenant-1",
+    role: "admin",
+    ...overrides,
+  };
+  const res = await request(app).post("/auth/register").send(data);
+  return { res, data };
+}
+
+async function getToken(overrides: Record<string, string> = {}): Promise<string> {
+  const { res } = await registerUser(overrides);
+  return res.body.token;
+}
+
+describe("Health", () => {
+  it("returns ok", async () => {
+    const res = await request(app).get("/health");
+    expect(res.status).toBe(200);
+    expect(res.body.status).toBe("ok");
+  });
+});
+
+describe("User Management", () => {
+  it("registers a user", async () => {
+    const { res } = await registerUser();
+    expect(res.status).toBe(201);
+    expect(res.body.token).toBeDefined();
+    expect(res.body.email).toBeDefined();
+    expect(res.body.tenantId).toBe("tenant-1");
+  });
+
+  it("rejects duplicate emails", async () => {
+    const email = "dup@test.com";
+    await registerUser({ email });
+    const { res } = await registerUser({ email });
+    expect(res.status).toBe(409);
