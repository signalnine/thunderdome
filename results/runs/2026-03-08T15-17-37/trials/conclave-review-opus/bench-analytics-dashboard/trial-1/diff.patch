vt of evts) {\n      if (!evt.name) continue;\n      const id = uuidv4();\n      const ts = evt.timestamp || new Date().toISOString();\n      const props = evt.properties ? JSON.stringify(evt.properties) : \"{}\";\n      insert.run(id, req.user!.tenantId, evt.name, props, ts, req.user!.userId, evt.sessionId || null);\n      results.push({ id, name: evt.name });\n    }\n    return results;\n  });\n\n  const results = insertMany(events);\n  res.status(201).json({ inserted: results.length, events: results });\n});\n\nexport default router;\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1344,"cache_read_input_tokens":21921,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1344},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"5e4cf42f-969d-4e71-a19c-7c0602a95f19","uuid":"06dd79e9-d12e-4c5b-b475-202ad50d4f97"}
