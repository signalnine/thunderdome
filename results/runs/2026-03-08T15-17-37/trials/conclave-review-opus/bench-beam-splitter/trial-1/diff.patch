+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from '../src/index.js';
+
+describe('countBeamCells', () => {
+  it('basic example: beam goes straight down', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(4);
+  });
+
+  it('example with one splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('example with two splitters', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('empty grid', () => {
+    expect(countBeamCells([])).toBe(0);
+  });
+
+  it('source only', () => {
+    const grid = [['S']];
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('beam absorbed at left edge', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Source at (0,0), down to (1,0) splitter
+    // down-left goes to (2,-1) absorbed, down-right to (2,1)
+    expect(countBeamCells(grid)).toBe(3); // (0,0), (1,0), (2,1)
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('no splitters: one path', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('one splitter: two paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('two splitters in sequence: four paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('empty grid returns 0', () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it('source only: one path (exits immediately)', () => {
+    const grid = [['S']];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('handles large grid with reconverging splitters', () => {
+    // 200x200 grid with diamond pattern of splitters that cause beams to reconverge.
+    // Row k (1-indexed from source): splitters at cols (center-k) to (center+k) step 2.
+    // This creates exponential path counts but DP merges them efficiently.
+    const rows = 200;
+    const cols = 200;
+    const center = 100;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][center] = 'S';
+
+    // Place 50 rows of splitters in a diamond pattern
+    // After splitting at row r, beams land on row r+1.
+    // Place splitters every 2 rows so beams land on splitter rows.
+    const numLevels = 50;
+    for (let level = 0; level < numLevels; level++) {
+      const row = 1 + level * 2;
+      if (row >= rows) break;
+      for (let offset = -level; offset <= level; offset++) {
+        const col = center + offset;
+        if (col >= 0 && col < cols) {
+          grid[row][col] = '^';
+        }
+      }
+    }
+
+    const start = performance.now();
+    const pathResult = countBeamPaths(grid);
+    const cellResult = countBeamCells(grid);
+    const elapsed = performance.now() - start;
+
+    expect(pathResult).toBeGreaterThan(0n);
+    expect(cellResult).toBeGreaterThan(0);
+    expect(elapsed).toBeLessThan(5000);
+  });
+});
