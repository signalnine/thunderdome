+const DIR_DOWN = 0;
+const DIR_DOWN_LEFT = 1;
+const DIR_DOWN_RIGHT = 2;
+
+type DirIndex = 0 | 1 | 2;
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  return null;
+}
+
+function advanceCol(col: number, dir: DirIndex): number {
+  if (dir === DIR_DOWN) return col;
+  if (dir === DIR_DOWN_LEFT) return col - 1;
+  return col + 1; // DIR_DOWN_RIGHT
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+function beamKey(col: number, dir: DirIndex): number {
+  return col * 3 + dir;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const visited = new Set<number>();
+  visited.add(source[0] * cols + source[1]);
+
+  // Track unique (col, dir) per row to avoid exponential blowup
+  let currentBeams = new Map<number, DirIndex>();
+  currentBeams.set(beamKey(source[1], DIR_DOWN), DIR_DOWN);
+
+  for (let row = source[0]; row < rows && currentBeams.size > 0; row++) {
+    const nextBeams = new Map<number, DirIndex>();
+
+    for (const [key] of currentBeams) {
+      const dir = (key % 3) as DirIndex;
+      const col = (key - dir) / 3;
+      const nr = row + 1;
+      const nc = advanceCol(col, dir);
+
+      if (!inBounds(nr, nc, rows, cols)) continue;
+
+      visited.add(nr * cols + nc);
+
+      if (grid[nr][nc] === '^') {
+        nextBeams.set(beamKey(nc, DIR_DOWN_LEFT), DIR_DOWN_LEFT);
+        nextBeams.set(beamKey(nc, DIR_DOWN_RIGHT), DIR_DOWN_RIGHT);
+      } else {
+        nextBeams.set(beamKey(nc, dir), dir);
+      }
+    }
+
+    currentBeams = nextBeams;
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  // Process row by row, merging beams with the same (col, dir) by summing path counts.
+  // Key: col * 3 + dirIndex, Value: path count (bigint)
+  let currentBeams = new Map<number, bigint>();
+  currentBeams.set(beamKey(source[1], DIR_DOWN), 1n);
+  let totalPaths = 0n;
+
+  for (let row = source[0]; row < rows && currentBeams.size > 0; row++) {
+    const nextBeams = new Map<number, bigint>();
+
+    for (const [key, paths] of currentBeams) {
+      const dir = (key % 3) as DirIndex;
+      const col = (key - dir) / 3;
+      const nr = row + 1;
+      const nc = advanceCol(col, dir);
+
+      if (!inBounds(nr, nc, rows, cols)) {
+        totalPaths += paths;
+        continue;
+      }
+
+      if (grid[nr][nc] === '^') {
+        const keyL = beamKey(nc, DIR_DOWN_LEFT);
+        const keyR = beamKey(nc, DIR_DOWN_RIGHT);
+        nextBeams.set(keyL, (nextBeams.get(keyL) ?? 0n) + paths);
+        nextBeams.set(keyR, (nextBeams.get(keyR) ?? 0n) + paths);
+      } else {
+        const nk = beamKey(nc, dir);
+        nextBeams.set(nk, (nextBeams.get(nk) ?? 0n) + paths);
+      }
+    }
+
+    currentBeams = nextBeams;
+  }
+
+  // Beams remaining after last row exit the grid
+  for (const [, paths] of currentBeams) {
+    totalPaths += paths;
+  }
+
+  return totalPaths;
+}
