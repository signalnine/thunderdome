+import { describe, it, expect } from 'vitest';
+import { schedule } from '../src/index.js';
+import type { Event, Room, ScheduleOptions } from '../src/index.js';
+
+describe('schedule', () => {
+  const defaultOptions: ScheduleOptions = {
+    startTime: 540, // 9:00 AM
+    endTime: 1020,  // 5:00 PM
+    gap: 15,
+  };
+
+  const rooms: Room[] = [
+    { id: 'r1', name: 'Room A', capacity: 10 },
+    { id: 'r2', name: 'Room B', capacity: 20 },
+  ];
+
+  describe('basic scheduling', () => {
+    it('should schedule a single event', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting', duration: 60 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+      expect(result.assignments[0].eventId).toBe('e1');
+      expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(540);
+      expect(result.assignments[0].endTime).toBeLessThanOrEqual(1020);
+      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);
+    });
+
+    it('should schedule multiple events', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting 1', duration: 60 },
+        { id: 'e2', name: 'Meeting 2', duration: 60 },
+        { id: 'e3', name: 'Meeting 3', duration: 60 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(3);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should handle empty events', () => {
+      const result = schedule([], rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should handle empty rooms', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting', duration: 60 },
+      ];
+      const result = schedule(events, [], defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['e1']);
+    });
+  });
+
+  describe('room capacity', () => {
+    it('should respect room capacity', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Big Meeting', duration: 60, attendees: 15 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      // Should be in room B (capacity 20), not room A (capacity 10)
+      expect(result.assignments[0].roomId).toBe('r2');
+    });
+
+    it('should not schedule event if no room has sufficient capacity', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Huge Meeting', duration: 60, attendees: 50 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['e1']);
+    });
+
+    it('should default attendees to 1', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Solo Meeting', duration: 60 },
+      ];
+      const smallRooms: Room[] = [
+        { id: 'r1', name: 'Tiny Room', capacity: 1 },
+      ];
+      const result = schedule(events, smallRooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+    });
+  });
+
+  describe('time window', () => {
+    it('should respect time window', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting', duration: 60 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      const a = result.assignments[0];
+      expect(a.startTime).toBeGreaterThanOrEqual(540);
+      expect(a.endTime).toBeLessThanOrEqual(1020);
+    });
+
+    it('should not schedule event that exceeds time window', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'All-day event', duration: 600 },
+      ];
+      const shortWindow: ScheduleOptions = {
+        startTime: 540,
+        endTime: 600, // only 60 min window
+      };
+      const result = schedule(events, rooms, shortWindow);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['e1']);
+    });
+  });
+
+  describe('room gaps', () => {
+    it('should enforce gaps between events in the same room', () => {
+      const singleRoom: Room[] = [
+        { id: 'r1', name: 'Room A', capacity: 10 },
+      ];
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting 1', duration: 60 },
+        { id: 'e2', name: 'Meeting 2', duration: 60 },
+      ];
+      const result = schedule(events, singleRoom, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);
+      // Gap between events should be at least 15
+      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);
+    });
+
+    it('should use default gap of 15 minutes', () => {
+      const singleRoom: Room[] = [
+        { id: 'r1', name: 'Room A', capacity: 10 },
+      ];
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting 1', duration: 60 },
+        { id: 'e2', name: 'Meeting 2', duration: 60 },
+      ];
+      const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };
+      const result = schedule(events, singleRoom, opts);
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);
+    });
+
+    it('should use custom gap', () => {
+      const singleRoom: Room[] = [
+        { id: 'r1', name: 'Room A', capacity: 10 },
+      ];
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting 1', duration: 60 },
+        { id: 'e2', name: 'Meeting 2', duration: 60 },
+      ];
+      const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };
+      const result = schedule(events, singleRoom, opts);
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);
+    });
+
+    it('should allow zero gap', () => {
+      const singleRoom: Room[] = [
+        { id: 'r1', name: 'Room A', capacity: 10 },
+      ];
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting 1', duration: 60 },
+        { id: 'e2', name: 'Meeting 2', duration: 60 },
+      ];
+      const opts: ScheduleOptions = { startTime: 540, endTime: 660, gap: 0 };
+      const result = schedule(events, singleRoom, opts);
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[0].endTime).toBeLessThanOrEqual(sorted[1].startTime);
+    });
+  });
+
+  describe('prerequisites', () => {
+    it('should respect prerequisite ordering', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'First', duration: 60 },
+        { id: 'e2', name: 'Second', duration: 60, prerequisites: ['e1'] },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+      expect(a1.endTime + 15).toBeLessThanOrEqual(a2.startTime);
+    });
+
+    it('should apply gap between prerequisite events', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'First', duration: 60 },
+        { id: 'e2', name: 'Second', duration: 60, prerequisites: ['e1'] },
+      ];
+      const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };
+      const result = schedule(events, rooms, opts);
+      expect(result.assignments).toHaveLength(2);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 30);
+    });
+
+    it('should handle chain of prerequisites', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'First', duration: 30 },
+        { id: 'e2', name: 'Second', duration: 30, prerequisites: ['e1'] },
+        { id: 'e3', name: 'Third', duration: 30, prerequisites: ['e2'] },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(3);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+      const a3 = result.assignments.find(a => a.eventId === 'e3')!;
+      expect(a1.endTime + 15).toBeLessThanOrEqual(a2.startTime);
+      expect(a2.endTime + 15).toBeLessThanOrEqual(a3.startTime);
+    });
+
+    it('should handle multiple prerequisites', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Prereq 1', duration: 30 },
+        { id: 'e2', name: 'Prereq 2', duration: 30 },
+        { id: 'e3', name: 'Dependent', duration: 30, prerequisites: ['e1', 'e2'] },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(3);
+
+      const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+      const a3 = result.assignments.find(a => a.eventId === 'e3')!;
+      const latestPrereqEnd = Math.max(a1.endTime, a2.endTime);
