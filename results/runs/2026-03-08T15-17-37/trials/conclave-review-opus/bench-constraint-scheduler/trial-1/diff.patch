+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bx4UQno4nwmHhrRc6Ph9ci","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { schedule } from '../src/index.js';\n     3→import type { Event, Room, ScheduleOptions } from '../src/index.js';\n     4→\n     5→describe('schedule', () => {\n     6→  const defaultOptions: ScheduleOptions = {\n     7→    startTime: 540, // 9:00 AM\n     8→    endTime: 1020,  // 5:00 PM\n     9→    gap: 15,\n    10→  };\n    11→\n    12→  const rooms: Room[] = [\n    13→    { id: 'r1', name: 'Room A', capacity: 10 },\n    14→    { id: 'r2', name: 'Room B', capacity: 20 },\n    15→  ];\n    16→\n    17→  describe('basic scheduling', () => {\n    18→    it('should schedule a single event', () => {\n    19→      const events: Event[] = [\n    20→        { id: 'e1', name: 'Meeting', duration: 60 },\n    21→      ];\n    22→      const result = schedule(events, rooms, defaultOptions);\n    23→      expect(result.assignments).toHaveLength(1);\n    24→      expect(result.unscheduled).toHaveLength(0);\n    25→      expect(result.assignments[0].eventId).toBe('e1');\n    26→      expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(540);\n    27→      expect(result.assignments[0].endTime).toBeLessThanOrEqual(1020);\n    28→      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);\n    29→    });\n    30→\n    31→    it('should schedule multiple events', () => {\n    32→      const events: Event[] = [\n    33→        { id: 'e1', name: 'Meeting 1', duration: 60 },\n    34→        { id: 'e2', name: 'Meeting 2', duration: 60 },\n    35→        { id: 'e3', name: 'Meeting 3', duration: 60 },\n    36→      ];\n    37→      const result = schedule(events, rooms, defaultOptions);\n    38→      expect(result.assignments).toHaveLength(3);\n    39→      expect(result.unscheduled).toHaveLength(0);\n    40→    });\n    41→\n    42→    it('should handle empty events', () => {\n    43→      const result = schedule([], rooms, defaultOptions);\n    44→      expect(result.assignments).toHaveLength(0);\n    45→      expect(result.unscheduled).toHaveLength(0);\n    46→    });\n    47→\n    48→    it('should handle empty rooms', () => {\n    49→      const events: Event[] = [\n    50→        { id: 'e1', name: 'Meeting', duration: 60 },\n    51→      ];\n    52→      const result = schedule(events, [], defaultOptions);\n    53→      expect(result.assignments).toHaveLength(0);\n    54→      expect(result.unscheduled).toEqual(['e1']);\n    55→    });\n    56→  });\n    57→\n    58→  describe('room capacity', () => {\n    59→    it('should respect room capacity', () => {\n    60→      const events: Event[] = [\n    61→        { id: 'e1', name: 'Big Meeting', duration: 60, attendees: 15 },\n    62→      ];\n    63→      const result = schedule(events, rooms, defaultOptions);\n    64→      expect(result.assignments).toHaveLength(1);\n    65→      // Should be in room B (capacity 20), not room A (capacity 10)\n    66→      expect(result.assignments[0].roomId).toBe('r2');\n    67→    });\n    68→\n    69→    it('should not schedule event if no room has sufficient capacity', () => {\n    70→      const events: Event[] = [\n    71→        { id: 'e1', name: 'Huge Meeting', duration: 60, attendees: 50 },\n    72→      ];\n    73→      const result = schedule(events, rooms, defaultOptions);\n    74→      expect(result.assignments).toHaveLength(0);\n    75→      expect(result.unscheduled).toEqual(['e1']);\n    76→    });\n    77→\n    78→    it('should default attendees to 1', () => {\n    79→      const events: Event[] = [\n    80→        { id: 'e1', name: 'Solo Meeting', duration: 60 },\n    81→      ];\n    82→      const smallRooms: Room[] = [\n    83→        { id: 'r1', name: 'Tiny Room', capacity: 1 },\n    84→      ];\n    85→      const result = schedule(events, smallRooms, defaultOptions);\n    86→      expect(result.assignments).toHaveLength(1);\n    87→    });\n    88→  });\n    89→\n    90→  describe('time window', () => {\n    91→    it('should respect time window', () => {\n    92→      const events: Event[] = [\n    93→        { id: 'e1', name: 'Meeting', duration: 60 },\n    94→      ];\n    95→      const result = schedule(events, rooms, defaultOptions);\n    96→      const a = result.assignments[0];\n    97→      expect(a.startTime).toBeGreaterThanOrEqual(540);\n    98→      expect(a.endTime).toBeLessThanOrEqual(1020);\n    99→    });\n   100→\n   101→    it('should not schedule event that exceeds time window', () => {\n   102→      const events: Event[] = [\n   103→        { id: 'e1', name: 'All-day event', duration: 600 },\n   104→      ];\n   105→      const shortWindow: ScheduleOptions = {\n   106→        startTime: 540,\n   107→        endTime: 600, // only 60 min window\n   108→      };\n   109→      const result = schedule(events, rooms, shortWindow);\n   110→      expect(result.assignments).toHaveLength(0);\n   111→      expect(result.unscheduled).toEqual(['e1']);\n   112→    });\n   113→  });\n   114→\n   115→  describe('room gaps', () => {\n   116→    it('should enforce gaps between events in the same room', () => {\n   117→      const singleRoom: Room[] = [\n   118→        { id: 'r1', name: 'Room A', capacity: 10 },\n   119→      ];\n   120→      const events: Event[] = [\n   121→        { id: 'e1', name: 'Meeting 1', duration: 60 },\n   122→        { id: 'e2', name: 'Meeting 2', duration: 60 },\n   123→      ];\n   124→      const result = schedule(events, singleRoom, defaultOptions);\n   125→      expect(result.assignments).toHaveLength(2);\n   126→\n   127→      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n   128→      // Gap between events should be at least 15\n   129→      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);\n   130→    });\n   131→\n   132→    it('should use default gap of 15 minutes', () => {\n   133→      const singleRoom: Room[] = [\n   134→        { id: 'r1', name: 'Room A', capacity: 10 },\n   135→      ];\n   136→      const events: Event[] = [\n   137→        { id: 'e1', name: 'Meeting 1', duration: 60 },\n   138→        { id: 'e2', name: 'Meeting 2', duration: 60 },\n   139→      ];\n   140→      const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };\n   141→      const result = schedule(events, singleRoom, opts);\n   142→      expect(result.assignments).toHaveLength(2);\n   143→\n   144→      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n   145→      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);\n   146→    });\n   147→\n   148→    it('should use custom gap', () => {\n   149→      const singleRoom: Room[] = [\n   150→        { id: 'r1', name: 'Room A', capacity: 10 },\n   151→      ];\n   152→      const events: Event[] = [\n   153→        { id: 'e1', name: 'Meeting 1', duration: 60 },\n   154→        { id: 'e2', name: 'Meeting 2', duration: 60 },\n   155→      ];\n   156→      const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };\n   157→      const result = schedule(events, singleRoom, opts);\n   158→      expect(result.assignments).toHaveLength(2);\n   159→\n   160→      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n   161→      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);\n   162→    });\n   163→\n   164→    it('should allow zero gap', () => {\n   165→      const singleRoom: Room[] = [\n   166→        { id: 'r1', name: 'Room A', capacity: 10 },\n   167→      ];\n   168→      const events: Event[] = [\n   169→        { id: 'e1', name: 'Meeting 1', duration: 60 },\n   170→        { id: 'e2', name: 'Meeting 2', duration: 60 },\n   171→      ];\n   172→      const opts: ScheduleOptions = { startTime: 540, endTime: 660, gap: 0 };\n   173→      const result = schedule(events, singleRoom, opts);\n   174→      expect(result.assignments).toHaveLength(2);\n   175→\n   176→      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n   177→      expect(sorted[0].endTime).toBeLessThanOrEqual(sorted[1].startTime);\n   178→    });\n   179→  });\n   180→\n   181→  describe('prerequisites', () => {\n   182→    it('should respect prerequisite ordering', () => {\n   183→      const events: Event[] = [\n   184→        { id: 'e1', name: 'First', duration: 60 },\n   185→        { id: 'e2', name: 'Second', duration: 60, prerequisites: ['e1'] },\n   186→      ];\n   187→      const result = schedule(events, rooms, defaultOptions);\n   188→      expect(result.assignments).toHaveLength(2);\n   189→\n   190→      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n   191→      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n   192→      expect(a1.endTime + 15).toBeLessThanOrEqual(a2.startTime);\n   193→    });\n   194→\n   195→    it('should apply gap between prerequisite events', () => {\n   196→      const events: Event[] = [\n   197→        { id: 'e1', name: 'First', duration: 60 },\n   198→        { id: 'e2', name: 'Second', duration: 60, prerequisites: ['e1'] },\n   199→      ];\n   200→      const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };\n   201→      const result = schedule(events, rooms, opts);\n   202→      expect(result.assignments).toHaveLength(2);\n   203→\n   204→      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n   205→      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n   206→      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 30);\n   207→    });\n   208→\n   209→    it('should handle chain of prerequisites', () => {\n   210→      const events: Event[] = [\n   211→        { id: 'e1', name: 'First', duration: 30 },\n   212→        { id: 'e2', name: 'Second', duration: 30, prerequisites: ['e1'] },\n   213→        { id: 'e3', name: 'Third', duration: 30, prerequisites: ['e2'] },\n   214→      ];\n   215→      const result = schedule(events, rooms, defaultOptions);\n   216→      expect(result.assignments).toHaveLength(3);\n   217→\n   218→      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n   219→      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n   220→      const a3 = result.assignments.find(a => a.eventId === 'e3')!;\n   221→      expect(a1.endTime + 15).toBeLessThanOrEqual(a2.startTime);\n   222→      expect(a2.endTime + 15).toBeLessThanOrEqual(a3.startTime);\n   223→    });\n   224→\n   225→    it('should handle multiple prerequisites', () => {\n   226→      const events: Event[] = [\n   227→        { id: 'e1', name: 'Prereq 1', duration: 30 },\n   228→        { id: 'e2', name: 'Prereq 2', duration: 30 },\n   229→        { id: 'e3', name: 'Dependent', duration: 30, prerequisites: ['e1', 'e2'] },\n   230→      ];\n   231→      const result = schedule(events, rooms, defaultOptions);\n   232→      expect(result.assignments).toHaveLength(3);\n   233→\n   234→      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n   235→      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n   236→      const a3 = result.assignments.find(a => a.eventId === 'e3')!;\n   237→      const latestPrereqEnd = Math.max(a1.endTime, a2.endTime);\n   238→      expect(latestPrereqEnd + 15).toBeLessThanOrEqual(a3.startTime);\n   239→    });\n   240→  });\n   241→\n   242→  describe('prerequisite cycles', () => {\n   243→    it('should throw on self-referencing prerequisite', () => {\n   244→      const events: Event[] = [\n   245→        { id: 'e1', name: 'Self-ref', duration: 60, prerequisites: ['e1'] },\n   246→      ];\n   247→      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n   248→    });\n   249→\n   250→    it('should throw on direct cycle', () => {\n   251→      const events: Event[] = [\n   252→        { id: 'e1', name: 'A', duration: 60, prerequisites: ['e2'] },\n   253→        { id: 'e2', name: 'B', duration: 60, prerequisites: ['e1'] },\n   254→      ];\n   255→      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n   256→    });\n   257→\n   258→    it('should throw on indirect cycle', () => {\n   259→      const events: Event[] = [\n   260→        { id: 'e1', name: 'A', duration: 60, prerequisites: ['e3'] },\n   261→        { id: 'e2', name: 'B', duration: 60, prerequisites: ['e1'] },\n   262→        { id: 'e3', name: 'C', duration: 60, prerequisites: ['e2'] },\n   263→      ];\n   264→      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n   265→    });\n   266→  });\n   267→\n   268→  describe('preferred room', () => {\n   269→    it('should honor preferred room when possible', () => {\n   270→      const events: Event[] = [\n   271→        { id: 'e1', name: 'Meeting', duration: 60, preferredRoom: 'r2' },\n   272→      ];\n   273→      const result = schedule(events, rooms, defaultOptions);\n   274→      expect(result.assignments).toHaveLength(1);\n   275→      expect(result.assignments[0].roomId).toBe('r2');\n   276→    });\n   277→\n   278→    it('should use another room if preferred room has insufficient capacity', () => {\n   279→      const events: Event[] = [\n   280→        { id: 'e1', name: 'Meeting', duration: 60, attendees: 15, preferredRoom: 'r1' },\n   281→      ];\n   282→      // r1 capacity is 10, r2 capacity is 20\n   283→      const result = schedule(events, rooms, defaultOptions);\n   284→      expect(result.assignments).toHaveLength(1);\n   285→      expect(result.assignments[0].roomId).toBe('r2');\n   286→    });\n   287→\n   288→    it('should use another room if preferred room is fully booked', () => {\n   289→      // Fill up r1 completely\n   290→      const manyEvents: Event[] = [];\n   291→      // 480 minutes window, 60 min events + 15 gap = 75 per event, ~6 events\n   292→      for (let i = 0; i < 7; i++) {\n   293→        manyEvents.push({ id: `fill${i}`, name: `Fill ${i}`, duration: 60, preferredRoom: 'r1' });\n   294→      }\n   295→      manyEvents.push({ id: 'target', name: 'Target', duration: 60, preferredRoom: 'r1' });\n   296→\n   297→      const result = schedule(manyEvents, rooms, defaultOptions);\n   298→      const target = result.assignments.find(a => a.eventId === 'target');\n   299→      if (target) {\n   300→        // It should be scheduled somewhere, possibly not in r1\n   301→        expect(result.unscheduled).not.toContain('target');\n   302→      }\n   303→    });\n   304→  });\n   305→\n   306→  describe('unscheduled events', () => {\n   307→    it('should list events that cannot be scheduled', () => {\n   308→      const tinyRoom: Room[] = [{ id: 'r1', name: 'Tiny', capacity: 5 }];\n   309→      const events: Event[] = [\n   310→        { id: 'e1', name: 'Meeting', duration: 60, attendees: 10 },\n   311→      ];\n   312→      const result = schedule(events, tinyRoom, defaultOptions);\n   313→      expect(result.assignments).toHaveLength(0);\n   314→      expect(result.unscheduled).toEqual(['e1']);\n   315→    });\n   316→\n   317→    it('should handle time overflow gracefully', () => {\n   318→      const singleRoom: Room[] = [{ id: 'r1', name: 'Room', capacity: 50 }];\n   319→      // Create many events that can't all fit\n   320→      const events: Event[] = [];\n   321→      for (let i = 0; i < 20; i++) {\n   322→        events.push({ id: `e${i}`, name: `Event ${i}`, duration: 60 });\n   323→      }\n   324→      // 480 min window, 60+15=75 per event = 6 events max (last one no gap needed = 7)\n   325→      const result = schedule(events, singleRoom, defaultOptions);\n   326→      expect(result.assignments.length + result.unscheduled.length).toBe(20);\n   327→      expect(result.unscheduled.length).toBeGreaterThan(0);\n   328→    });\n   329→  });\n   330→\n   331→  describe('batch optimization', () => {\n   332→    it('should maximize the number of scheduled events