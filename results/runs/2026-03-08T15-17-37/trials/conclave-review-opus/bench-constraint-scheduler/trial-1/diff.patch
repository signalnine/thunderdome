name: 'A', duration: 30 },\n        { id: 'e2', name: 'B', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'C', duration: 30 }\n      ],\n      [{ id: 'r1', name: 'R', capacity: 10 }],\n      { startTime: 0, endTime: 480, gap: 15 }\n    );\n    expect(result.assignments).toHaveLength(3);\n  });\n\n  it('preferred room should be used even if it means later start time', () => {\n    // Two rooms, preferred room has an earlier event\n    // The event should still go to preferred room even if other room has earlier slot\n    const result = schedule(\n      [\n        { id: 'blocker', name: 'Blocker', duration: 60, preferredRoom: 'r1' },\n        { id: 'target', name: 'Target', duration: 60, preferredRoom: 'r1' }\n      ],\n      [\n        { id: 'r1', name: 'R1', capacity: 10 },\n        { id: 'r2', name: 'R2', capacity: 10 }\n      ],\n      { startTime: 0, endTime: 480, gap: 15 }\n    );\n    const target = result.assignments.find(a => a.eventId === 'target')!;\n    console.log('Preferred room priority:', JSON.stringify(result.assignments));\n    expect(target.roomId).toBe('r1');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":99,"cache_read_input_tokens":34600,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":99},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01EWvmxD8QjCviu8rFo19cPS","session_id":"eef121b2-49f8-4d60-9240-61d4eab8b10d","uuid":"a1b22ad6-dcaf-47b7-b6ea-ed5de669516d"}
