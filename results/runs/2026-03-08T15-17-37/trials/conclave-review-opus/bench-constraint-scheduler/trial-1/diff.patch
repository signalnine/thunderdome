(const r of roomList) {\n        tempRoomSchedules.set(r.id, []);\n      }\n      const tempUnscheduled: string[] = [];\n\n      // Save/restore room schedules for tryScheduleEvent\n      const origAssignments = assignments;\n      const origRoomSchedules = roomSchedules;\n\n      // Temporarily swap\n      // We need to use the temp structures in tryScheduleEvent\n      // So we'll inline the logic here\n      let success = true;\n      for (const eventId of ordering) {\n        const event = eventMap.get(eventId);\n        if (!event) continue;\n\n        const attendees = event.attendees ?? 1;\n        const duration = event.duration;\n\n        if (duration > endTime - startTime) {\n          tempUnscheduled.push(eventId);\n          continue;\n        }\n\n        let earliestFromPrereqs = startTime;\n        if (event.prerequisites) {\n          let prereqMissing = false;\n          for (const preId of event.prerequisites) {\n            const preAssignment = tempAssignments.get(preId);\n            if (!preAssignment) {\n              prereqMissing = true;\n              break;\n            }\n            earliestFromPrereqs = Math.max(earliestFromPrereqs, preAssignment.endTime + gap);\n          }\n          if (prereqMissing) {\n            tempUnscheduled.push(eventId);\n            continue;\n          }\n        }\n\n        const eligibleRooms = roomList.filter(r => r.capacity >= attendees);\n        if (eligibleRooms.length === 0) {\n          tempUnscheduled.push(eventId);\n          continue;\n        }\n\n        const sortedRooms = [...eligibleRooms].sort((a, b) => {\n          if (event.preferredRoom) {\n            if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n            if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n          }\n          return a.capacity - b.capacity;\n        });\n\n        let bestA: Assignment | null = null;\n        for (const room of sortedRooms) {\n          const slotStart = findEarliestSlot(\n            room.id, duration, earliestFromPrereqs, endTime, gap, tempRoomSchedules\n          );\n          if (slotStart !== null) {\n            const candidate: Assignment = {\n              eventId,\n              roomId: room.id,\n              startTime: slotStart,\n              endTime: slotStart + duration,\n            };\n            if (event.preferredRoom && room.id === event.preferredRoom) {\n              bestA = candidate;\n              break;\n            }\n            if (!bestA || slotStart < bestA.startTime) {\n              bestA = candidate;\n            }\n          }\n        }\n\n        if (bestA) {\n          tempAssignments.set(eventId, bestA);\n          const roomSched = tempRoomSchedules.get(bestA.roomId)!;\n          roomSched.push(bestA);\n        } else {\n          tempUnscheduled.push(eventId);\n        }\n      }\n\n      if (tempUnscheduled.length < bestResult.unscheduled.length) {\n        bestResult.assignments = tempAssignments;\n        bestResult.roomSchedules = tempRoomSchedules;\n        bestResult.unscheduled = tempUnscheduled;\n      }\n\n      if (bestResult.unscheduled.length === 0) break;\n    }\n\n    // Use best result\n    return {\n      assignments: Array.from(bestResult.assignments.values()),\n      unscheduled: bestResult.unscheduled,\n    };\n  }\n\n  return {\n    assignments: Array.from(assignments.values()),\n    unscheduled,\n  };\n}\n\nfunction computeTopoLevels(events: Event[], eventMap: Map<string, Event>): string[][] {\n  const inDegree = new Map<string, number>();\n  const adj = new Map<string, string[]>();\n\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n    if (!adj.has(e.id)) adj.set(e.id, []);\n  }\n\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const preId of e.prerequisites) {\n        if (!adj.has(preId)) adj.set(preId, []);\n        adj.get(preId)!.push(e.id);\n        inDegree.set(e.id, (inDegree.get(e.id) || 0) + 1);\