+      for (let i = 0; i < 7; i++) {
+        manyEvents.push({ id: `fill${i}`, name: `Fill ${i}`, duration: 60, preferredRoom: 'r1' });
+      }
+      manyEvents.push({ id: 'target', name: 'Target', duration: 60, preferredRoom: 'r1' });
+
+      const result = schedule(manyEvents, rooms, defaultOptions);
+      const target = result.assignments.find(a => a.eventId === 'target');
