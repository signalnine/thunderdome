+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CEMQYwo6KF7Sq8zcXuKBgn","type":"tool_result","content":"     1→import type { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';\n     2→\n     3→function detectCycle(events: Event[]): void {\n     4→  const eventMap = new Map<string, Event>();\n     5→  for (const e of events) {\n     6→    eventMap.set(e.id, e);\n     7→  }\n     8→\n     9→  const WHITE = 0, GRAY = 1, BLACK = 2;\n    10→  const color = new Map<string, number>();\n    11→  for (const e of events) {\n    12→    color.set(e.id, WHITE);\n    13→  }\n    14→\n    15→  function dfs(id: string): void {\n    16→    color.set(id, GRAY);\n    17→    const event = eventMap.get(id);\n    18→    if (event?.prerequisites) {\n    19→      for (const preId of event.prerequisites) {\n    20→        const c = color.get(preId);\n    21→        if (c === GRAY) {\n    22→          throw new Error(`Cycle detected in prerequisites involving event \"${preId}\"`);\n    23→        }\n    24→        if (c === WHITE) {\n    25→          dfs(preId);\n    26→        }\n    27→      }\n    28→    }\n    29→    color.set(id, BLACK);\n    30→  }\n    31→\n    32→  for (const e of events) {\n    33→    if (color.get(e.id) === WHITE) {\n    34→      dfs(e.id);\n    35→    }\n    36→  }\n    37→}\n    38→\n    39→function topologicalSort(events: Event[]): string[] {\n    40→  const eventMap = new Map<string, Event>();\n    41→  for (const e of events) {\n    42→    eventMap.set(e.id, e);\n    43→  }\n    44→\n    45→  const inDegree = new Map<string, number>();\n    46→  for (const e of events) {\n    47→    if (!inDegree.has(e.id)) inDegree.set(e.id, 0);\n    48→    if (e.prerequisites) {\n    49→      for (const preId of e.prerequisites) {\n    50→        if (!inDegree.has(preId)) inDegree.set(preId, 0);\n    51→      }\n    52→    }\n    53→  }\n    54→\n    55→  // Build adjacency: prereq -> dependents\n    56→  const adj = new Map<string, string[]>();\n    57→  for (const e of events) {\n    58→    if (e.prerequisites) {\n    59→      for (const preId of e.prerequisites) {\n    60→        if (!adj.has(preId)) adj.set(preId, []);\n    61→        adj.get(preId)!.push(e.id);\n    62→        inDegree.set(e.id, (inDegree.get(e.id) || 0) + 1);\n    63→      }\n    64→    }\n    65→  }\n    66→\n    67→  const queue: string[] = [];\n    68→  for (const e of events) {\n    69→    if ((inDegree.get(e.id) || 0) === 0) {\n    70→      queue.push(e.id);\n    71→    }\n    72→  }\n    73→\n    74→  const result: string[] = [];\n    75→  while (queue.length > 0) {\n    76→    const id = queue.shift()!;\n    77→    result.push(id);\n    78→    for (const dep of adj.get(id) || []) {\n    79→      const newDeg = (inDegree.get(dep) || 1) - 1;\n    80→      inDegree.set(dep, newDeg);\n    81→      if (newDeg === 0) {\n    82→        queue.push(dep);\n    83→      }\n    84→    }\n    85→  }\n    86→\n    87→  return result;\n    88→}\n    89→\n    90→function getEarliestStartAfterPrereqs(\n    91→  eventId: string,\n    92→  eventMap: Map<string, Event>,\n    93→  assignments: Map<string, Assignment>,\n    94→  gap: number,\n    95→  windowStart: number\n    96→): number {\n    97→  const event = eventMap.get(eventId)!;\n    98→  let earliest = windowStart;\n    99→  if (event.prerequisites) {\n   100→    for (const preId of event.prerequisites) {\n   101→      const preAssignment = assignments.get(preId);\n   102→      if (!preAssignment) {\n   103→        return Infinity; // prerequisite not scheduled\n   104→      }\n   105→      earliest = Math.max(earliest, preAssignment.endTime + gap);\n   106→    }\n   107→  }\n   108→  return earliest;\n   109→}\n   110→\n   111→function findEarliestSlot(\n   112→  roomId: string,\n   113→  duration: number,\n   114→  earliestStart: number,\n   115→  endTime: number,\n   116→  gap: number,\n   117→  roomSchedules: Map<string, Assignment[]>\n   118→): number | null {\n   119→  const schedule = roomSchedules.get(roomId) || [];\n   120→\n   121→  // Try to fit before the first event, between events, or after the last event\n   122→  // All slots must respect earliestStart and endTime constraints\n   123→  if (schedule.length === 0) {\n   124→    if (earliestStart + duration <= endTime) {\n   125→      return earliestStart;\n   126→    }\n   127→    return null;\n   128→  }\n   129→\n   130→  // Sort by start time\n   131→  const sorted = [...schedule].sort((a, b) => a.startTime - b.startTime);\n   132→\n   133→  // Try before first event\n   134→  const firstStart = sorted[0].startTime;\n   135→  const beforeEnd = firstStart - gap;\n   136→  if (earliestStart + duration <= beforeEnd) {\n   137→    return earliestStart;\n   138→  }\n   139→\n   140→  // Try between events\n   141→  for (let i = 0; i < sorted.length - 1; i++) {\n   142→    const gapStart = sorted[i].endTime + gap;\n   143→    const gapEnd = sorted[i + 1].startTime - gap;\n   144→    const candidateStart = Math.max(earliestStart, gapStart);\n   145→    if (candidateStart + duration <= gapEnd) {\n   146→      return candidateStart;\n   147→    }\n   148→  }\n   149→\n   150→  // Try after last event\n   151→  const afterStart = Math.max(earliestStart, sorted[sorted.length - 1].endTime + gap);\n   152→  if (afterStart + duration <= endTime) {\n   153→    return afterStart;\n   154→  }\n   155→\n   156→  return null;\n   157→}\n   158→\n   159→export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n   160→  const gap = options.gap ?? 15;\n   161→  const { startTime, endTime } = options;\n   162→\n   163→  // Check for self-references explicitly (also caught by cycle detection, but be thorough)\n   164→  for (const e of events) {\n   165→    if (e.prerequisites?.includes(e.id)) {\n   166→      throw new Error(`Cycle detected in prerequisites involving event \"${e.id}\"`);\n   167→    }\n   168→  }\n   169→\n   170→  // Detect cycles\n   171→  detectCycle(events);\n   172→\n   173→  const eventMap = new Map<string, Event>();\n   174→  for (const e of events) {\n   175→    eventMap.set(e.id, e);\n   176→  }\n   177→\n   178→  // Get topological order\n   179→  const topoOrder = topologicalSort(events);\n   180→\n   181→  // Filter rooms that exist and build capacity index\n   182→  const roomList = [...rooms];\n   183→\n   184→  // Build room schedules tracker\n   185→  const roomSchedules = new Map<string, Assignment[]>();\n   186→  for (const r of roomList) {\n   187→    roomSchedules.set(r.id, []);\n   188→  }\n   189→\n   190→  const assignments = new Map<string, Assignment>();\n   191→  const unscheduled: string[] = [];\n   192→\n   193→  // We'll use a backtracking approach for better optimization.\n   194→  // For large inputs, we limit backtracking depth.\n   195→  //\n   196→  // Strategy: Process events in topological order. For each event,\n   197→  // try to assign it to rooms (preferred first), picking the earliest slot.\n   198→  // If we can't schedule it, mark as unscheduled.\n   199→  //\n   200→  // For better optimization, we use a two-pass approach:\n   201→  // Pass 1: Greedily assign events, preferring rooms that best fit capacity.\n   202→  // Pass 2: Try to reschedule unscheduled events by considering alternative placements.\n   203→\n   204→  function tryScheduleEvent(eventId: string): Assignment | null {\n   205→    const event = eventMap.get(eventId);\n   206→    if (!event) return null;\n   207→\n   208→    const attendees = event.attendees ?? 1;\n   209→    const duration = event.duration;\n   210→\n   211→    if (duration > endTime - startTime) return null;\n   212→\n   213→    const earliestFromPrereqs = getEarliestStartAfterPrereqs(\n   214→      eventId, eventMap, assignments, gap, startTime\n   215→    );\n   216→    if (earliestFromPrereqs === Infinity) return null;\n   217→\n   218→    // Get eligible rooms (capacity sufficient)\n   219→    const eligibleRooms = roomList.filter(r => r.capacity >= attendees);\n   220→    if (eligibleRooms.length === 0) return null;\n   221→\n   222→    // Sort rooms: preferred room first, then by capacity (smallest sufficient first)\n   223→    const sortedRooms = [...eligibleRooms].sort((a, b) => {\n   224→      // Preferred room gets top priority\n   225→      if (event.preferredRoom) {\n   226→        if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n   227→        if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n   228→      }\n   229→      // Then sort by capacity (smallest first for best fit)\n   230→      return a.capacity - b.capacity;\n   231→    });\n   232→\n   233→    let bestAssignment: Assignment | null = null;\n   234→\n   235→    for (const room of sortedRooms) {\n   236→      const slotStart = findEarliestSlot(\n   237→        room.id, duration, earliestFromPrereqs, endTime, gap, roomSchedules\n   238→      );\n   239→      if (slotStart !== null) {\n   240→        const candidate: Assignment = {\n   241→          eventId,\n   242→          roomId: room.id,\n   243→          startTime: slotStart,\n   244→          endTime: slotStart + duration,\n   245→        };\n   246→        // If preferred room and it works, use it immediately\n   247→        if (event.preferredRoom && room.id === event.preferredRoom) {\n   248→          return candidate;\n   249→        }\n   250→        // Otherwise take earliest start across all rooms\n   251→        if (!bestAssignment || slotStart < bestAssignment.startTime) {\n   252→          bestAssignment = candidate;\n   253→        }\n   254→      }\n   255→    }\n   256→\n   257→    return bestAssignment;\n   258→  }\n   259→\n   260→  // Pass 1: Greedy scheduling in topological order\n   261→  for (const eventId of topoOrder) {\n   262→    const assignment = tryScheduleEvent(eventId);\n   263→    if (assignment) {\n   264→      assignments.set(eventId, assignment);\n   265→      const roomSched = roomSchedules.get(assignment.roomId)!;\n   266→      roomSched.push(assignment);\n   267→    } else {\n   268→      unscheduled.push(eventId);\n   269→    }\n   270→  }\n   271→\n   272→  // Pass 2: Try to reschedule unscheduled events\n   273→  // Clear and retry: for each unscheduled event, see if rearranging\n   274→  // could help. Simple approach: retry unscheduled events.\n   275→  if (unscheduled.length > 0) {\n   276→    // Try a smarter approach: clear all assignments and reschedule\n   277→    // with different priority (shorter events first within each topo level)\n   278→    const bestResult = {\n   279→      assignments: new Map(assignments),\n   280→      roomSchedules: new Map<string, Assignment[]>(),\n   281→      unscheduled: [...unscheduled],\n   282→    };\n   283→    for (const [roomId, sched] of roomSchedules) {\n   284→      bestResult.roomSchedules.set(roomId, [...sched]);\n   285→    }\n   286→\n   287→    // Try different orderings within topological levels\n   288→    const levels = computeTopoLevels(events, eventMap);\n   289→    const orderings = generateOrderings(levels, eventMap);\n   290→\n   291→    for (const ordering of orderings) {\n   292→      // Reset state\n   293→      const tempAssignments = new Map<string, Assignment>();\n   294→      const tempRoomSchedules = new Map<string, Assignment[]>();\n   295→      for (const r of roomList) {\n   296→        tempRoomSchedules.set(r.id, []);\n   297→      }\n   298→      const tempUnscheduled: string[] = [];\n   299→\n   300→      // Inline scheduling logic using temp structures\n   301→      for (const eventId of ordering) {\n   302→        const event = eventMap.get(eventId);\n   303→        if (!event) continue;\n   304→\n   305→        const attendees = event.attendees ?? 1;\n   306→        const duration = event.duration;\n   307→\n   308→        if (duration > endTime - startTime) {\n   309→          tempUnscheduled.push(eventId);\n   310→          continue;\n   311→        }\n   312→\n   313→        let earliestFromPrereqs = startTime;\n   314→        if (event.prerequisites) {\n   315→          let prereqMissing = false;\n   316→          for (const preId of event.prerequisites) {\n   317→            const preAssignment = tempAssignments.get(preId);\n   318→            if (!preAssignment) {\n   319→              prereqMissing = true;\n   320→              break;\n   321→            }\n   322→            earliestFromPrereqs = Math.max(earliestFromPrereqs, preAssignment.endTime + gap);\n   323→          }\n   324→          if (prereqMissing) {\n   325→            tempUnscheduled.push(eventId);\n   326→            continue;\n   327→          }\n   328→        }\n   329→\n   330→        const eligibleRooms = roomList.filter(r => r.capacity >= attendees);\n   331→        if (eligibleRooms.length === 0) {\n   332→          tempUnscheduled.push(eventId);\n   333→          continue;\n   334→        }\n   335→\n   336→        const sortedRooms = [...eligibleRooms].sort((a, b) => {\n   337→          if (event.preferredRoom) {\n   338→            if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n   339→            if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n   340→          }\n   341→          return a.capacity - b.capacity;\n   342→        });\n   343→\n   344→        let bestA: Assignment | null = null;\n   345→        for (const room of sortedRooms) {\n   346→          const slotStart = findEarliestSlot(\n   347→            room.id, duration, earliestFromPrereqs, endTime, gap, tempRoomSchedules\n   348→          );\n   349→          if (slotStart !== null) {\n   350→            const candidate: Assignment = {\n   351→              eventId,\n   352→              roomId: room.id,\n   353→              startTime: slotStart,\n   354→              endTime: slotStart + duration,\n   355→            };\n   356→            if (event.preferredRoom && room.id === event.preferredRoom) {\n   357→              bestA = candidate;\n   358→              break;\n   359→            }\n   360→            if (!bestA || slotStart < bestA.startTime) {\n   361→              bestA = candidate;\n   362→            }\n   363→          }\n   364→        }\n   365→\n   366→        if (bestA) {\n   367→          tempAssignments.set(eventId, bestA);\n   368→          const roomSched = tempRoomSchedules.get(bestA.roomId)!;\n   369→          roomSched.push(bestA);\n   370→        } else {\n   371→          tempUnscheduled.push(eventId);\n   372→        }\n   373→      }\n   374→\n   375→      if (tempUnscheduled.length < bestResult.unscheduled.length) {\n   376→        bestResult.assignments = tempAssignments;\n   377→        bestResult.roomSchedules = tempRoomSchedules;\n   378→        bestResult.unscheduled = tempUnscheduled;\n   379→      }\n   380→\n   381→      if (bestResult.unscheduled.length === 0) break;\n   382→    }\n   383→\n   384→    // Use best result\n   385→    return {\n   386→      assignments: Array.from(bestResult.assignments.values()),\n   387→      unscheduled: bestResult.unscheduled,\n   388→    };\n   389→  }\n   390→\n   391→  return {\n   392→    assignments: Array.from(assignments.values()),\n   393→    unscheduled,\n   394→  };\n   395→}\n   396→\n   397→function computeTopoLevels(events: Event[], _eventMap: Map<string, Event>): string[][] {\n   398→  const inDegree = new Map<string, number>();\n   399→  const adj = new Map<string, string[]>();\n   400→\n   401→  for (const e of events) {\n   402→    inDegree.set(e.id, 0);\n   403→    if (!adj.has(e.id)) adj.set(e.id, []);\n   404→  }\n   405→\n   406→  for (const e of events) {\n   407→    if (e.prerequisites) {\n   408→      for (const preId of e.prerequisites) {\n   409→        if (!adj.has(preId)) adj.set(preId, []);\n   410→        adj.get(preId)!.push(e.id);\n   411→        inDegree.set(e.id, (inDegree.get(e.id) || 0) + 1);\n   412→      }\n   413→    }\n   414→  }\n   415→\n   416→  const levels: string[][] = [];\n   417→  let queue = events.filter(e => (inDegree.get(e.id) || 0) === 0).map(e => e.id);\n   418→\n   419→  while (queue.length > 0) {\n   420→    levels.push([...queue]);\n   421→    const nextQueue: string[] = [];\n   422→    for (const id of queue) {\n   423→      for (const dep of adj.get(id) || []) {\n   424→        const newDeg = (inDegree.get(dep) || 1) - 1;\n   425→        inDegree.set(dep, newDeg);\n   426→        if (newDeg === 0) {\n   427→          nextQueue.push(dep);\n   428→        }\n   429→      }\n   430→    }\n   431→    queue = nextQueue;\n   432→  }\n   433→\n   434→  return levels;\n   435→}\n   436→\n   437→function generateOrderings(levels: string[][], eventMap: Map<string, Event>): string[][] {\n   438→  // Generate a few different orderings by sorting within levels differently\n   439→  const orderings: string[][] = [];\n   440→\n   441→  // Ordering 1: shortest duration first within levels\n   442→  {\n   443→    const order: string[] = [];\n   444→    for (const level of levels) {\n   445→      const sorted = [...level].sort((a, b) => {\n   446→        const ea = eventMap.get(a)!;\n   447→        const eb = eventMap.get(b)!;\n   448→        return ea.duration - eb.duration;\n   449→      });\n   450→      order.push(...sorted);\n   451→    }\n   452→    orderings.push(order);\n   453→  }\n   454→\n   455→  // Ordering 2: longest duration first within levels\n   456→  {\n   457→    const order: string[] = [];\n   458→    for (const level of levels) {\n   459→      const sorted = [...level].sort((a, b) => {\n   460→        const ea = eventMap.get(a)!;\n   461→        const eb = eventMap.get(b)!;\n   462→        return eb.duration - ea.duration;\n   463→      });\n   464→      order.push(...sorted);\n   465→    }\n   466→    orderings.push(order);\n   467→  }\n   468→\n   469→  // Ordering 3: most attendees first (hardest to place)\n   470→  {\n   471→    const order: string[] = [];\n   472→    for (const level of levels) {\n   473→      const sorted = [...level].sort((a, b) => {\n   474→        const ea = eventMap.get(a)!;\n   475→        const eb = eventMap.get(b)!;\n   476→        return (eb.attendees ?? 1) - (ea.attendees ?? 1);\n   477→      });\n   478→      order.push(...sorted);\n   479→    }\n   480→    orderings.push(order);\n   481→  }\n   482→\n   483→  // Ordering 4: fewest eligible rooms first (most constrained)\n   484→  {\n   485→    const order: string[] = [];\n   486→    for (const level of levels) {\n   487→      const sorted = [...level].sort((a, b) => {\n   488→        const ea = eventMap.get(a)!;\n   489→        const eb = eventMap.get(b)!;\n   490→        return (ea.attendees ?? 1) - (eb.attendees ?? 1);\n   491→      });\n   492→      order.push(...sorted);\n   493→    }\n   494→    orderings.push(order);\n   495→  }\n   496→\n   497→  return orderings;\n   498→}\n   499→"}]},"parent_tool_use_id":"toolu_01EWvmxD8QjCviu8rFo19cPS","session_id":"eef121b2-49f8-4d60-9240-61d4eab8b10d","uuid":"2c9aba0f-ed2f-4fcd-acc3-70f214493d3f"}
