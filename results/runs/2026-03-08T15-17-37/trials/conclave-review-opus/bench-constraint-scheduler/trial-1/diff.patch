+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Pqbd9zF49mBF4SKw2AZ2DN","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01VwNBAeJTMHWapiHdAwEcen","name":"Write","input":{"file_path":"/workspace/tests/edge-cases.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { schedule } from '../src/scheduler.js';\nimport type { Event, Room, ScheduleOptions } from '../src/types.js';\n\ndescribe('edge case analysis', () => {\n  it('non-existent prerequisite should result in unscheduled', () => {\n    const result = schedule(\n      [{ id: 'e1', name: 'A', duration: 30, prerequisites: ['nonexistent'] }],\n      [{ id: 'r1', name: 'R', capacity: 10 }],\n      { startTime: 0, endTime: 480, gap: 15 }\n    );\n    console.log('Non-existent prereq:', JSON.stringify(result));\n    // e1 depends on 'nonexistent' which is not in the events list\n    // topologicalSort may or may not include e1\n    // getEarliestStartAfterPrereqs returns Infinity if prereq not assigned\n    expect(result.assignments.length + result.unscheduled.length).toBeLessThanOrEqual(1);\n  });\n\n  it('zero-duration event', () => {\n    const result = schedule(\n      [{ id: 'e1', name: 'A', duration: 0 }],\n      [{ id: 'r1', name: 'R', capacity: 10 }],\n      { startTime: 0, endTime: 480, gap: 15 }\n    );\n    console.log('Zero duration:', JSON.stringify(result));\n  });\n\n  it('negative duration event', () => {\n    const result = schedule(\n      [{ id: 'e1', name: 'A', duration: -10 }],\n      [{ id: 'r1', name: 'R', capacity: 10 }],\n      { startTime: 0, endTime: 480, gap: 15 }\n    );\n    console.log('Negative duration:', JSON.stringify(result));\n  });\n\n  it('duplicate event IDs', () => {\n    const result = schedule(\n      [\n        { id: 'e1', name: 'A', duration: 30 },\n        { id: 'e1', name: 'B', duration: 60 }\n      ],\n      [{ id: 'r1', name: 'R', capacity: 10 }],\n      { startTime: 0, endTime: 480, gap: 15 }\n    );\n    console.log('Duplicate IDs:', JSON.stringify(result));\n  });\n\n  it('startTime equals endTime', () => {\n    const result = schedule(\n      [{ id: 'e1', name: 'A', duration: 30 }],\n      [{ id: 'r1', name: 'R', capacity: 10 }],\n      { startTime: 500, endTime: 500, gap: 15 }\n    );\n    console.log('startTime=endTime:', JSON.stringify(result));\n    expect(result.unscheduled).toContain('e1');\n  });\n\n  it('optimization: should prefer 2 short events over 1 long event', () => {\n    // Room: 100 min window, gap=0\n    // A=90min, B=50min, C=50min\n    // Greedy first pass with default topo: picks A first (90min) -> only fits 1\n    // Optimal: B+C -> 2 events\n    const result = schedule(\n      [\n        { id: 'A', name: 'A', duration: 90 },\n        { id: 'B', name: 'B', duration: 50 },\n        { id: 'C', name: 'C', duration: 50 }\n      ],\n      [{ id: 'r1', name: 'R', capacity: 10 }],\n      { startTime: 0, endTime: 100, gap: 0 }\n    );\n    console.log('Optimization test:', result.assignments.map(a => a.eventId), 'Unscheduled:', result.unscheduled);\n    expect(result.assignments.length).toBe(2);\n  });\n\n  it('non-existent preferred room falls back gracefully', () => {\n    const result = schedule(\n      [{ id: 'e1', name: 'A', duration: 30, preferredRoom: 'nonexistent' }],\n      [{ id: 'r1', name: 'R', capacity: 10 }],\n      { startTime: 0, endTime: 480, gap: 15 }\n    );\n    console.log('Non-existent preferred room:', JSON.stringify(result));\n    expect(result.assignments).toHaveLength(1);\n    expect(result.assignments[0].roomId).toBe('r1');\n  });\n\n  it('cascading unschedule when prerequisite cannot be scheduled', () => {\n    const result = schedule(\n      [\n        { id: 'e1', name: 'Too big', duration: 30, attendees: 100 },\n        { id: 'e2', name: 'Depends on e1', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Depends on e2', duration: 30, prerequisites: ['e2'] }\n      ],\n      [{ id: 'r1', name: 'R',