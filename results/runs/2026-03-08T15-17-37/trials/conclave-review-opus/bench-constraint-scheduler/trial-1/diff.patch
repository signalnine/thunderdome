+import type { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+
+function detectCycle(events: Event[]): void {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const e of events) {
+    color.set(e.id, WHITE);
+  }
+
+  function dfs(id: string): void {
+    color.set(id, GRAY);
+    const event = eventMap.get(id);
+    if (event?.prerequisites) {
+      for (const preId of event.prerequisites) {
+        const c = color.get(preId);
+        if (c === GRAY) {
+          throw new Error(`Cycle detected in prerequisites involving event "${preId}"`);
+        }
+        if (c === WHITE) {
+          dfs(preId);
+        }
+      }
+    }
+    color.set(id, BLACK);
+  }
+
+  for (const e of events) {
+    if (color.get(e.id) === WHITE) {
+      dfs(e.id);
+    }
+  }
+}
+
+function topologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map(e => e.id));
+
+  const inDegree = new Map<string, number>();
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+  }
+
+  // Build adjacency: prereq -> dependents (only for known event IDs)
+  const adj = new Map<string, string[]>();
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const preId of e.prerequisites) {
+        if (!eventIds.has(preId)) continue;
+        if (!adj.has(preId)) adj.set(preId, []);
+        adj.get(preId)!.push(e.id);
+        inDegree.set(e.id, (inDegree.get(e.id) || 0) + 1);
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const e of events) {
+    if ((inDegree.get(e.id) || 0) === 0) {
+      queue.push(e.id);
+    }
+  }
+
+  const result: string[] = [];
+  while (queue.length > 0) {
+    const id = queue.shift()!;
+    if (eventIds.has(id)) {
+      result.push(id);
+    }
+    for (const dep of adj.get(id) || []) {
+      const newDeg = (inDegree.get(dep) || 1) - 1;
+      inDegree.set(dep, newDeg);
+      if (newDeg === 0) {
+        queue.push(dep);
+      }
+    }
+  }
+
+  return result;
+}
+
+function findEarliestSlot(
+  roomId: string,
+  duration: number,
+  earliestStart: number,
+  endTime: number,
+  gap: number,
+  roomSchedules: Map<string, Assignment[]>
+): number | null {
+  const existing = roomSchedules.get(roomId) || [];
+
+  if (existing.length === 0) {
+    if (earliestStart + duration <= endTime) {
+      return earliestStart;
+    }
+    return null;
+  }
+
+  // Sort by start time
+  const sorted = [...existing].sort((a, b) => a.startTime - b.startTime);
+
+  // Try before first event
+  const firstStart = sorted[0].startTime;
+  const beforeEnd = firstStart - gap;
+  if (earliestStart + duration <= beforeEnd) {
+    return earliestStart;
+  }
+
+  // Try between events
+  for (let i = 0; i < sorted.length - 1; i++) {
+    const gapStart = sorted[i].endTime + gap;
+    const gapEnd = sorted[i + 1].startTime - gap;
+    const candidateStart = Math.max(earliestStart, gapStart);
+    if (candidateStart + duration <= gapEnd) {
+      return candidateStart;
+    }
+  }
+
+  // Try after last event
+  const afterStart = Math.max(earliestStart, sorted[sorted.length - 1].endTime + gap);
+  if (afterStart + duration <= endTime) {
+    return afterStart;
+  }
+
+  return null;
+}
+
+function scheduleWithOrdering(
+  ordering: string[],
+  eventMap: Map<string, Event>,
+  roomList: Room[],
+  startTime: number,
+  endTime: number,
+  gap: number
+): { assignments: Map<string, Assignment>; roomSchedules: Map<string, Assignment[]>; unscheduled: string[] } {
+  const assignments = new Map<string, Assignment>();
+  const roomSchedules = new Map<string, Assignment[]>();
+  for (const r of roomList) {
+    roomSchedules.set(r.id, []);
+  }
+  const unscheduled: string[] = [];
+
+  for (const eventId of ordering) {
+    const event = eventMap.get(eventId);
+    if (!event) continue;
+
+    const attendees = event.attendees ?? 1;
+    const duration = event.duration;
+
+    if (duration > endTime - startTime) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    let earliestFromPrereqs = startTime;
+    if (event.prerequisites) {
+      let prereqMissing = false;
+      for (const preId of event.prerequisites) {
+        const preAssignment = assignments.get(preId);
+        if (!preAssignment) {
+          prereqMissing = true;
+          break;
+        }
+        earliestFromPrereqs = Math.max(earliestFromPrereqs, preAssignment.endTime + gap);
+      }
+      if (prereqMissing) {
+        unscheduled.push(eventId);
+        continue;
+      }
+    }
+
+    const eligibleRooms = roomList.filter(r => r.capacity >= attendees);
+    if (eligibleRooms.length === 0) {
+      unscheduled.push(eventId);
+      continue;
+    }
+
+    const sortedRooms = [...eligibleRooms].sort((a, b) => {
+      if (event.preferredRoom) {
+        if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;
+        if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;
+      }
+      return a.capacity - b.capacity;
+    });
+
+    let bestA: Assignment | null = null;
+    for (const room of sortedRooms) {
+      const slotStart = findEarliestSlot(
+        room.id, duration, earliestFromPrereqs, endTime, gap, roomSchedules
+      );
+      if (slotStart !== null) {
+        const candidate: Assignment = {
+          eventId,
+          roomId: room.id,
+          startTime: slotStart,
+          endTime: slotStart + duration,
+        };
+        if (event.preferredRoom && room.id === event.preferredRoom) {
+          bestA = candidate;
+          break;
+        }
+        if (!bestA || slotStart < bestA.startTime) {
+          bestA = candidate;
+        }
+      }
+    }
+
+    if (bestA) {
+      assignments.set(eventId, bestA);
+      const roomSched = roomSchedules.get(bestA.roomId)!;
+      roomSched.push(bestA);
+    } else {
+      unscheduled.push(eventId);
+    }
+  }
+
+  return { assignments, roomSchedules, unscheduled };
+}
+
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  const gap = options.gap ?? 15;
+  const { startTime, endTime } = options;
+
+  // Check for self-references explicitly
+  for (const e of events) {
+    if (e.prerequisites?.includes(e.id)) {
+      throw new Error(`Cycle detected in prerequisites involving event "${e.id}"`);
+    }
+  }
+
+  // Detect cycles
+  detectCycle(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Get topological order
+  const topoOrder = topologicalSort(events);
+
+  const roomList = [...rooms];
+
+  // Pass 1: Greedy scheduling in topological order
+  const pass1 = scheduleWithOrdering(topoOrder, eventMap, roomList, startTime, endTime, gap);
+
+  // If all events scheduled, return immediately
+  if (pass1.unscheduled.length === 0) {
+    return {
+      assignments: Array.from(pass1.assignments.values()),
+      unscheduled: [],
+    };
+  }
+
+  // Pass 2: Try different orderings within topological levels to maximize scheduled events
+  let bestResult = pass1;
+
+  const levels = computeTopoLevels(events);
+  const orderings = generateOrderings(levels, eventMap);
+
+  for (const ordering of orderings) {
+    const result = scheduleWithOrdering(ordering, eventMap, roomList, startTime, endTime, gap);
+
+    if (result.unscheduled.length < bestResult.unscheduled.length) {
+      bestResult = result;
+    }
+
+    if (bestResult.unscheduled.length === 0) break;
+  }
+
+  return {
+    assignments: Array.from(bestResult.assignments.values()),
+    unscheduled: bestResult.unscheduled,
+  };
+}
+
+function computeTopoLevels(events: Event[]): string[][] {
+  const eventIds = new Set(events.map(e => e.id));
+  const inDegree = new Map<string, number>();
+  const adj = new Map<string, string[]>();
+
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    if (!adj.has(e.id)) adj.set(e.id, []);
+  }
+
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const preId of e.prerequisites) {
+        if (!eventIds.has(preId)) continue;
+        if (!adj.has(preId)) adj.set(preId, []);
+        adj.get(preId)!.push(e.id);
+        inDegree.set(e.id, (inDegree.get(e.id) || 0) + 1);
+      }
+    }
+  }
+
+  const levels: string[][] = [];
+  let queue = events.filter(e => (inDegree.get(e.id) || 0) === 0).map(e => e.id);
+
+  while (queue.length > 0) {
+    levels.push([...queue]);
+    const nextQueue: string[] = [];
+    for (const id of queue) {
+      for (const dep of adj.get(id) || []) {
+        const newDeg = (inDegree.get(dep) || 1) - 1;
+        inDegree.set(dep, newDeg);
+        if (newDeg === 0) {
+          nextQueue.push(dep);
+        }
+      }
+    }
+    queue = nextQueue;
+  }
+
+  return levels;
+}
+
+function generateOrderings(levels: string[][], eventMap: Map<string, Event>): string[][] {
+  const orderings: string[][] = [];
+
+  // Ordering 1: shortest duration first within levels
+  {
+    const order: string[] = [];
+    for (const level of levels) {
+      const sorted = [...level].sort((a, b) => {
+        const ea = eventMap.get(a)!;
+        const eb = eventMap.get(b)!;
+        return ea.duration - eb.duration;
+      });
+      order.push(...sorted);
+    }
+    orderings.push(order);
+  }
+
+  // Ordering 2: longest duration first within levels
+  {
+    const order: string[] = [];
+    for (const level of levels) {
+      const sorted = [...level].sort((a, b) => {
+        const ea = eventMap.get(a)!;
+        const eb = eventMap.get(b)!;
+        return eb.duration - ea.duration;
+      });
+      order.push(...sorted);
+    }
+    orderings.push(order);
+  }
+
+  // Ordering 3: most attendees first (most constrained by room capacity)
+  {
+    const order: string[] = [];
+    for (const level of levels) {
+      const sorted = [...level].sort((a, b) => {
+        const ea = eventMap.get(a)!;
+        const eb = eventMap.get(b)!;
+        return (eb.attendees ?? 1) - (ea.attendees ?? 1);
+      });
+      order.push(...sorted);
+    }
+    orderings.push(order);
+  }
+
+  // Ordering 4: fewest attendees first (least constrained first)
+  {
+    const order: string[] = [];
+    for (const level of levels) {
+      const sorted = [...level].sort((a, b) => {
+        const ea = eventMap.get(a)!;
+        const eb = eventMap.get(b)!;
+        return (ea.attendees ?? 1) - (eb.attendees ?? 1);
+      });
+      order.push(...sorted);
+    }
+    orderings.push(order);
+  }
+
+  return orderings;
+}
