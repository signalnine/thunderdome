    expect(latestPrereqEnd + 15).toBeLessThanOrEqual(a3.startTime);\n    });\n  });\n\n  describe('prerequisite cycles', () => {\n    it('should throw on self-referencing prerequisite', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Self-ref', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw on direct cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'A', duration: 60, prerequisites: ['e2'] },\n        { id: 'e2', name: 'B', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw on indirect cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'A', duration: 60, prerequisites: ['e3'] },\n        { id: 'e2', name: 'B', duration: 60, prerequisites: ['e1'] },\n        { id: 'e3', name: 'C', duration: 60, prerequisites: ['e2'] },\n      ];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n  });\n\n  describe('preferred room', () => {\n    it('should honor preferred room when possible', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Meeting', duration: 60, preferredRoom: 'r2' },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('r2');\n    });\n\n    it('should use another room if preferred room has insufficient capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Meeting', duration: 60, attendees: 15, preferredRoom: 'r1' },\n      ];\n      // r1 capacity is 10, r2 capacity is 20\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('r2');\n    });\n\n    it('should use another room if preferred room is fully booked', () => {\n      // Fill up r1 completely\n      const manyEvents: Event[] = [];\n      // 480 minutes window, 60 min events + 15 gap = 75 per event, ~6 events\n      for (let i = 0; i < 7; i++) {\n        manyEvents.push({ id: `fill${i}`, name: `Fill ${i}`, duration: 60, preferredRoom: 'r1' });\n      }\n      manyEvents.push({ id: 'target', name: 'Target', duration: 60, preferredRoom: 'r1' });\n\n      const result = schedule(manyEvents, rooms, defaultOptions);\n      const target = result.assignments.find(a => a.eventId === 'target');\n      if (target) {\n        // It should be scheduled somewhere, possibly not in r1\n        expect(result.unscheduled).not.toContain('target');\n      }\n    });\n  });\n\n  describe('unscheduled events', () => {\n    it('should list events that cannot be scheduled', () => {\n      const tinyRoom: Room[] = [{ id: 'r1', name: 'Tiny', capacity: 5 }];\n      const events: Event[] = [\n        { id: 'e1', name: 'Meeting', duration: 60, attendees: 10 },\n      ];\n      const result = schedule(events, tinyRoom, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual(['e1']);\n    });\n\n    it('should handle time overflow gracefully', () => {\n      const singleRoom: Room[] = [{ id: 'r1', name: 'Room', capacity: 50 }];\n      // Create many events that can't all fit\n      const events: Event[] = [];\n      for (let i = 0; i < 20; i++) {\n        events.push({ id: `e${i}`, name: `Event ${i}`, duration: 60 });\n      }\n      // 480 min window, 60+15=75 per event = 6 events max (last one no gap needed = 7)\n      const result = schedule(events, singleRoom, defaultOptions);\n      expect(result.assignments.length + result.unscheduled.length).toBe(20);\n      expect(result.unscheduled.length).toBeGreaterThan(0);\n    });\n  });\n\n  describe('batch optimization', () => {\n    it('should maximize the number of scheduled events', () => {\n      // One room, tight 