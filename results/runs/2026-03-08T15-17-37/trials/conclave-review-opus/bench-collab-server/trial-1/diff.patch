+describe('OT - compose', () => {
+  it('composes two inserts', () => {
+    const a: Operation = ['hello'];       // '' -> 'hello'
+    const b: Operation = [5, ' world'];   // 'hello' -> 'hello world'
+
+    const ab = compose(a, b);
+    expect(apply('', ab)).toBe('hello world');
+  });
+
+  it('composes insert then delete', () => {
+    const a: Operation = ['hello'];
+    const b: Operation = [-3, 2]; // 'hello' -> 'lo'
+
+    const ab = compose(a, b);
+    expect(apply('', ab)).toBe('lo');
+  });
+
+  it('composes retain with insert', () => {
+    const a: Operation = [3]; // 'abc' -> 'abc'
+    const b: Operation = [1, 'x', 2]; // 'abc' -> 'axbc'
+
+    const ab = compose(a, b);
+    expect(apply('abc', ab)).toBe('axbc');
+  });
