212→      }\n   213→      continue;\n   214→    }\n   215→\n   216→    // B inserts\n   217→    if (peekB !== null && typeof peekB === 'string') {\n   218→      result.push(iterB.next() as string);\n   219→      continue;\n   220→    }\n   221→\n   222→    // B retains\n   223→    if (peekB !== null && typeof peekB === 'number' && peekB > 0) {\n   224→      let remaining = iterB.next() as number;\n   225→      while (remaining > 0) {\n   226→        const peekA2 = iterA.peek();\n   227→        if (peekA2 === null) throw new Error('Compose: A ran out of output');\n   228→        if (typeof peekA2 === 'string') {\n   229→          const ins = iterA.next() as string;\n   230→          if (ins.length <= remaining) {\n   231→            result.push(ins);\n   232→            remaining -= ins.length;\n   233→          } else {\n   234→            result.push(ins.slice(0, remaining));\n   235→            iterA.putBack(ins.slice(remaining));\n   236→            remaining = 0;\n   237→          }\n   238→        } else if ((peekA2 as number) > 0) {\n   239→          const ret = peekA2 as number;\n   240→          const min = Math.min(ret, remaining);\n   241→          iterA.take(min);\n   242→          result.push(min);\n   243→          remaining -= min;\n   244→        } else {\n   245→          // A deletes — pass through\n   246→          result.push(iterA.next() as number);\n   247→        }\n   248→      }\n   249→      continue;\n   250→    }\n   251→\n   252→    // B is done, drain A\n   253→    if (!iterB.hasNext()) {\n   254→      while (iterA.hasNext()) {\n   255→        result.push(iterA.next()!);\n   256→      }\n   257→      break;\n   258→    }\n   259→  }\n   260→\n   261→  return normalize(result);\n   262→}\n   263→\n   264→/**\n   265→ * Validate that an operation is well-formed and compatible with a document of the given length.\n   266→ */\n   267→export function validate(op: Operation, docLength: number): string | null {\n   268→  if (!Array.isArray(op))