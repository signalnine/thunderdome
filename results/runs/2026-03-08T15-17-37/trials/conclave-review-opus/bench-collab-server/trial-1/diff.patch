put\n  }\n  return len;\n}\n\n/** Compute the output length an operation produces. */\nexport function outputLength(op: Operation): number {\n  let len = 0;\n  for (const c of op) {\n    if (typeof c === 'number') {\n      if (c > 0) len += c;       // retain\n      // delete produces nothing\n    } else {\n      len += c.length;           // insert\n    }\n  }\n  return len;\n}\n\n/** Apply an operation to a document string. */\nexport function apply(doc: string, op: Operation): string {\n  const expected = inputLength(op);\n  if (expected !== doc.length) {\n    throw new Error(`Operation input length ${expected} does not match document length ${doc.length}`);\n  }\n  let result = '';\n  let pos = 0;\n  for (const c of op) {\n    if (typeof c === 'string') {\n      result += c;\n    } else if (c > 0) {\n      result += doc.slice(pos, pos + c);\n      pos += c;\n    } else if (c < 0) {\n      pos += -c;\n    }\n  }\n  return result;\n}\n\n/** Normalize an operation by merging adjacent same-type components. */\nexport function normalize(op: Operation): Operation {\n  const result: Operation = [];\n  for (const c of op) {\n    if (typeof c === 'number' && c === 0) continue;\n    if (typeof c === 'string' && c === '') continue;\n\n    if (result.length === 0) {\n      result.push(c);\n      continue;\n    }\n    const last = result[result.length - 1];\n    if (typeof c === 'string' && typeof last === 'string') {\n      result[result.length - 1] = last + c;\n    } else if (typeof c === 'number' && typeof last === 'number') {\n      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {\n        result[result.length - 1] = last + c;\n      } else {\n        result.push(c);\n      }\n    } else {\n      result.push(c);\n    }\n  }\n  return result;\n}\n\n/**\n * Transform two concurrent operations so they can be applied in sequence.\n * Given operations A and B that both apply to the same document,\n * returns [A', B'] such that apply(apply(doc, A), B') === apply(apply(doc, B), A').\n */\nexport function transform(opA: Operation, opB: Operation): [Operation, Operation] {\n  const iterA = new OpIterator(opA);\n  const iterB = new OpIterator(opB);\n  const aPrime: Operation = [];\n  const bPrime: Operation = [];\n\n  while (iterA.hasNext() || iterB.hasNext()) {\n    const peekA = iterA.peek();\n    const peekB = iterB.peek();\n\n    // If A inserts, include it in A' and retain in B'\n    if (peekA !== null && typeof peekA === 'string') {\n      const ins = iterA.next() as string;\n      aPrime.push(ins);\n      bPrime.push(ins.length);\n      continue;\n    }\n\n    // If B inserts, include it in B' and retain in A'\n    if (peekB !== null && typeof peekB === 'string') {\n      const ins = iterB.next() as string;\n      bPrime.push(ins);\n      aPrime.push(ins.length);\n      continue;\n    }\n\n    // Both done\n    if (peekA === null && peekB === null) break;\n\n    // Both must be numbers at this point (retain or delete)\n    if (peekA === null || peekB === null) {\n      throw new Error('Operations have different base lengths');\n    }\n\n    const aVal = peekA as number;\n    const bVal = peekB as number;\n\n    // Both retain\n    if (aVal > 0 && bVal > 0) {\n      const min = Math.min(aVal, bVal);\n      iterA.take(min);\n      iterB.take(min);\n      aPrime.push(min);\n      bPrime.push(min);\n    }\n    // A deletes, B retains\n    else if (aVal < 0 && bVal > 0) {\n      const min = Math.min(-aVal, bVal);\n      iterA.take(min);\n      iterB.take(min);\n      aPrime.push(-min);\n      // B' doesn't need to do anything for deleted chars\n    }\n    // A retains, B deletes\n    else if (aVal > 0 && bVal < 0) {\n      const min = Math.min(aVal, -bVal);\n      iterA.take(min);\n      iterB.take(min);\n      bPrime.push(-min);\n      // A' doesn't need to do anything for deleted chars\n    }\n    // Both delete\n    else if (aVal < 0 && bVal < 0) {\n      const min = Math.min(-aVal, -bVal);\n      iterA.take(min);\n      iterB.take(min);\n      // Both deleted the same text; neither prime needs to delete\n    }\n    else {\n      throw new Error('Unexpected OT state');\n    }\n  }\n\n  return [normalize(aPrime), normalize(bPrime)];\n}\n\n/** Compose two sequential operations into one. */\nexport function compose(opA: Operation, opB: Operation): Operation {\n  const iterA = new OpIterator(opA);\n  const iterB = new OpIterator(opB);\n  const result: Operation = [];\n\n  while (iterA.hasNext() || iterB.hasNext()) {\n    const peekB = iterB.peek();\n\n    // B deletes: consume from A's output\n    if (peekB !== null && typeof peekB === 'number' && peekB < 0) {\n      const delCount = -(iterB.next() as number);\n      let remaining = delCount;\n      while (remaining > 0) {\n        const peekA2 = iterA.peek();\n        if (peekA2 === null) throw new Error('Compose: A ran out of output');\n        if (typeof peekA2 === 'string') {\n          const ins = iterA.next() as string;\n          if (ins.length <= remaining) {\n            remaining -= ins.length;\n          } else {\n            iterA.putBack(ins.slice(remaining));\n            remaining = 0;\n          }\n        } else if ((peekA2 as number) > 0) {\n          const ret = peekA2 as number;\n          const min = Math.min(ret, remaining);\n          iterA.take(min);\n          result.push(-min);\n          remaining -= min;\n        } else {\n          // A deletes — pass through\n          result.push(iterA.next() as number);\n        }\n      }\n      continue;\n    }\n\n    // B inserts\n    if (peekB !== null && typeof peekB === 'string') {\n      result.push(iterB.next() as string);\n      continue;\n    }\n\n    // B retains\n    if (peekB !== null && typeof peekB === 'number' && peekB > 0) {\n      let remaining = iterB.next() as number;\n      while (remaining > 0) {\n        const peekA2 = iterA.peek();\n        if (peekA2 === null) throw new Error('Compose: A ran out of output');\n        if (typeof peekA2 === 'string') {\n         