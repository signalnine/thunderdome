+import { describe, it, expect } from 'vitest';
+import { apply, transform, compose, normalize, validate, inputLength, outputLength, Operation } from '../src/ot.js';
+
+describe('OT - basic operations', () => {
+  it('should apply retain', () => {
+    expect(apply('hello', [5])).toBe('hello');
+  });
+
+  it('should apply insert at beginning', () => {
+    expect(apply('world', ['hello ', 5])).toBe('hello world');
+  });
+
+  it('should apply insert at end', () => {
+    expect(apply('hello', [5, ' world'])).toBe('hello world');
+  });
+
+  it('should apply delete', () => {
+    expect(apply('hello world', [5, -6])).toBe('hello');
+  });
+
+  it('should apply insert in middle', () => {
+    expect(apply('hllo', [1, 'e', 3])).toBe('hello');
+  });
+
+  it('should apply delete in middle', () => {
+    expect(apply('hxello', [1, -1, 4])).toBe('hello');
+  });
+
+  it('should handle empty document insert', () => {
+    expect(apply('', ['hello'])).toBe('hello');
+  });
+
+  it('should handle full delete', () => {
+    expect(apply('hello', [-5])).toBe('');
+  });
+
+  it('should throw on mismatched length', () => {
+    expect(() => apply('hi', [5])).toThrow();
+  });
+});
+
+describe('OT - inputLength / outputLength', () => {
+  it('computes input length', () => {
+    expect(inputLength([3, 'abc', -2])).toBe(5);
+  });
+
+  it('computes output length', () => {
+    expect(outputLength([3, 'abc', -2])).toBe(6);
+  });
+});
+
+describe('OT - normalize', () => {
+  it('merges adjacent retains', () => {
+    expect(normalize([2, 3])).toEqual([5]);
+  });
+
+  it('merges adjacent inserts', () => {
+    expect(normalize(['ab', 'cd'])).toEqual(['abcd']);
+  });
+
+  it('merges adjacent deletes', () => {
+    expect(normalize([-2, -3])).toEqual([-5]);
+  });
+
+  it('removes zeros', () => {
+    expect(normalize([0, 3, 0])).toEqual([3]);
+  });
+
+  it('removes empty strings', () => {
+    expect(normalize(['', 'hi', ''])).toEqual(['hi']);
+  });
+});
+
+describe('OT - validate', () => {
+  it('returns null for valid operation', () => {
+    expect(validate([3, 'x', -2], 5)).toBeNull();
+  });
+
+  it('rejects non-array', () => {
+    expect(validate('bad' as unknown as Operation, 0)).toBe('Operation must be an array');
+  });
+
+  it('rejects non-integer', () => {
+    expect(validate([1.5], 2)).toBe('Operation components must be integers');
+  });
+
+  it('rejects zero', () => {
+    expect(validate([0], 0)).toBe('Operation must not contain zero');
+  });
+
+  it('rejects bad types', () => {
+    expect(validate([true] as unknown as Operation, 0)).toBe('Operation components must be numbers or strings');
+  });
+
+  it('rejects wrong length', () => {
+    expect(validate([3], 5)).toContain('does not match');
+  });
