+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DuWdaZAjjziHLTgDgdkZeZ","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n     2→import request from 'supertest';\n     3→import WebSocket from 'ws';\n     4→import { createApp, AppInstance } from '../src/server.js';\n     5→\n     6→/** A WebSocket wrapper that buffers messages so none are missed. */\n     7→class BufferedWs {\n     8→  readonly ws: WebSocket;\n     9→  private messageQueue: Record<string, unknown>[] = [];\n    10→  private waiters: Array<(msg: Record<string, unknown>) => void> = [];\n    11→  private _open: Promise<void>;\n    12→\n    13→  constructor(url: string) {\n    14→    this.ws = new WebSocket(url);\n    15→    this._open = new Promise((resolve, reject) => {\n    16→      this.ws.on('open', resolve);\n    17→      this.ws.on('error', reject);\n    18→    });\n    19→    this.ws.on('message', (data) => {\n    20→      const msg = JSON.parse(data.toString());\n    21→      if (this.waiters.length > 0) {\n    22→        const waiter = this.waiters.shift()!;\n    23→        waiter(msg);\n    24→      } else {\n    25→        this.messageQueue.push(msg);\n    26→      }\n    27→    });\n    28→  }\n    29→\n    30→  async open(): Promise<void> {\n    31→    await this._open;\n    32→  }\n    33→\n    34→  nextMessage(timeout = 3000): Promise<Record<string, unknown>> {\n    35→    if (this.messageQueue.length > 0) {\n    36→      return Promise.resolve(this.messageQueue.shift()!);\n    37→    }\n    38→    return new Promise((resolve, reject) => {\n    39→      const timer = setTimeout(() => {\n    40→        const idx = this.waiters.indexOf(handler);\n    41→        if (idx >= 0) this.waiters.splice(idx, 1);\n    42→        reject(new Error('Timeout waiting for message'));\n    43→      }, timeout);\n    44→      const handler = (msg: Record<string, unknown>) => {\n    45→        clearTimeout(timer);\n    46→        resolve(msg);\n    47→      };\n    48→      this.waiters.push(handler);\n    49→    });\n    50→  }\n    51→\n    52→  send(data: unknown): void {\n    53→    this.ws.send(JSON.stringify(data));\n    54→  }\n    55→\n    56→  sendOp(version: number, operation: unknown[]): void {\n    57→    this.send({ type: 'operation', version, operation });\n    58→  }\n    59→\n    60→  close(): void {\n    61→    if (this.ws.readyState === WebSocket.OPEN || this.ws.readyState === WebSocket.CONNECTING) {\n    62→      this.ws.close();\n    63→    }\n    64→  }\n    65→}\n    66→\n    67→describe('WebSocket Collaboration', () => {\n    68→  let app: AppInstance;\n    69→  let port: number;\n    70→  const clients: BufferedWs[] = [];\n    71→\n    72→  beforeEach(async () => {\n    73→    app = createApp(':memory:');\n    74→    port = await app.start(0);\n    75→  });\n    76→\n    77→  afterEach(async () => {\n    78→    for (const c of clients) {\n    79→      c.close();\n    80→    }\n    81→    clients.length = 0;\n    82→    await app.stop();\n    83→  });\n    84→\n    85→  async function createDoc(title: string, content: string = ''): Promise<string> {\n    86→    const res = await request(app.app)\n    87→      .post('/api/documents')\n    88→      .send({ title, content });\n    89→    return res.body.id;\n    90→  }\n    91→\n    92→  async function connect(docId: string): Promise<BufferedWs> {\n    93→    const bws = new BufferedWs(`ws://127.0.0.1:${port}/documents/${docId}/ws`);\n    94→    clients.push(bws);\n    95→    await bws.open();\n    96→    return bws;\n    97→  }\n    98→\n    99→  it('sends sync on connect', async () => {\n   100→    const docId = await createDoc('Test', 'hello');\n   101→    const c = await connect(docId);\n   102→    const msg = await c.nextMessage();\n   103→\n   104→    expect(msg.type).toBe('sync');\n   105→    expect(msg.content).toBe('hello');\n   106→    expect(msg.version).toBe(0);\n   107→    expect(msg.clientId).toBeDefined();\n   108→  });\n   109→\n   110→  it('applies an operation and sends ack', async () => {\n   111→    const docId = await createDoc('Test', 'hello');\n   112→    const c = await connect(docId);\n   113→    await c.nextMessage(); // sync\n   114→\n   115→    c.sendOp(0, [5, ' world']);\n   116→    const ack = await c.nextMessage();\n   117→\n   118→    expect(ack.type).toBe('ack');\n   119→    expect(ack.version).toBe(1);\n   120→\n   121→    const res = await request(app.app).get(`/api/documents/${docId}`);\n   122→    expect(res.body.content).toBe('hello world');\n   123→  });\n   124→\n   125→  it('broadcasts operation to other clients', async () => {\n   126→    const docId = await createDoc('Test', 'abc');\n   127→    const c1 = await connect(docId);\n   128→    const c2 = await connect(docId);\n   129→\n   130→    await c1.nextMessage(); // sync\n   131→    await c2.nextMessage(); // sync\n   132→\n   133→    c1.sendOp(0, ['x', 3]);\n   134→\n   135→    const ack = await c1.nextMessage();\n   136→    expect(ack.type).toBe('ack');\n   137→\n   138→    const broadcast = await c2.nextMessage();\n   139→    expect(broadcast.type).toBe('operation');\n   140→    expect(broadcast.operation).toEqual(['x', 3]);\n   141→    expect(broadcast.version).toBe(1);\n   142→  });\n   143→\n   144→  it('transforms concurrent operations', async () => {\n   145→    const docId = await createDoc('Test', 'abc');\n   146→    const c1 = await connect(docId);\n   147→    const c2 = await connect(docId);\n   148→\n   149→    await c1.nextMessage(); // sync\n   150→    await c2.nextMessage(); // sync\n   151→\n   152→    // Both clients send ops based on version 0\n   153→    c1.sendOp(0, ['x', 3]); // insert 'x' at start\n   154→    c2.sendOp(0, [3, 'y']); // insert 'y' at end\n   155→\n   156→    // Client 1: ack, then broadcast of client 2's transformed op\n   157→    const c1Msg1 = await c1.nextMessage();\n   158→    expect(c1Msg1.type).toBe('ack');\n   159→    expect(c1Msg1.version).toBe(1);\n   160→\n   161→    // Client 2: broadcast of client 1's op, then ack\n   162→    const c2Msg1 = await c2.nextMessage();\n   163→    expect(c2Msg1.type).toBe('operation');\n   164→\n   165→    const c2Msg2 = await c2.nextMessage();\n   166→    expect(c2Msg2.type).toBe('ack');\n   167→    expect(c2Msg2.version).toBe(2);\n   168→\n   169→    const c1Msg2 = await c1.nextMessage();\n   170→    expect(c1Msg2.type).toBe('operation');\n   171→\n   172→    // Both clients should converge\n   173→    const res = await request(app.app).get(`/api/documents/${docId}`);\n   174→    expect(res.body.content).toBe('xabcy');\n   175→  });\n   176→\n   177→  it('handles multiple sequential operations', async () => {\n   178→    const docId = await createDoc('Test', '');\n   179→    const c = await connect(docId);\n   180→    await c.nextMessage(); // sync\n   181→\n   182→    c.sendOp(0, ['h']);\n   183→    const ack1 = await c.nextMessage();\n   184→    expect(ack1.type).toBe('ack');\n   185→\n   186→    c.sendOp(1, [1, 'i']);\n   187→    const ack2 = await c.nextMessage();\n   188→    expect(ack2.type).toBe('ack');\n   189→\n   190→    const res = await request(app.app).get(`/api/documents/${docId}`);\n   191→    expect(res.body.content).toBe('hi');\n   192→  });\n   193→\n   194→  it('rejects invalid operation', async () => {\n   195→    const docId = await createDoc('Test', 'abc');\n   196→    const c = await connect(docId);\n   197→    await c.nextMessage(); // sync\n   198→\n   199→    c.sendOp(0, [10]); // wrong base length\n   200→    const err = await c.nextMessage();\n   201→    expect(err.type).toBe('error');\n   202→  });\n   203→\n   204→  it('rejects malformed messages', async () => {\n   205→    const docId = await createDoc('Test', 'abc');\n   206→    const c = await connect(docId);\n   207→    await c.nextMessage(); // sync\n   208→\n   209→    c.ws.send('not json at all {{{');\n   210→    const err = await c.nextMessage();\n   211→    expect(err.type)