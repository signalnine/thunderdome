t pathname = parse(request.url || '', true).pathname || '';\n      const match = pathname.match(/^\\/documents\\/([^/]+)\\/ws$/);\n\n      if (!match) {\n        socket.destroy();\n        return;\n      }\n\n      const documentId = match[1];\n      const doc = this.store.getDocument(documentId);\n      if (!doc) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.wss.emit('connection', ws, request, documentId);\n      });\n    });\n\n    this.wss.on('connection', (ws: WebSocket, _request: IncomingMessage, documentId: string) => {\n      this.handleConnection(ws, documentId);\n    });\n  }\n\n  private getOrCreateSession(documentId: string): DocumentSession {\n    let session = this.sessions.get(documentId);\n    if (!session) {\n      const doc = this.store.getDocument(documentId);\n      if (!doc) throw new Error('Document not found');\n      const version = this.store.getLatestVersion(documentId);\n      session = {\n        documentId,\n        clients: new Map(),\n        version,\n        content: doc.content,\n      };\n      this.sessions.set(documentId, session);\n    }\n    return session;\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string): void {\n    const session = this.getOrCreateSession(documentId);\n    const clientId = randomUUID();\n    const client: Client = { id: clientId, ws, documentId };\n    session.clients.set(clientId, client);\n\n    // Send sync message with current state\n    this.send(ws, {\n      type: 'sync',\n      documentId,\n      content: session.content,\n      version: session.version,\n      clientId,\n    });\n\n    ws.on('message', (data) => {\n      try {\n        const msg = JSON.parse(data.toString()) as WsMessage;\n        this.handleMessage(client, session, msg);\n      } catch (err) {\n        this.send(ws, {\n          type: 'error',\n          message: err instanceof Error ? err.message : 'Invalid message',\n        });\n      }\n    });\n\n    ws.on('close', () => {\n      session.clients.delete(clientId);\n      if (session.clients.size === 0) {\n        this.sessions.delete(documentId);\n      }\n    });\n\n    ws.on('error', () => {\n      session.clients.delete(clientId);\n    });\n  }\n\n  private handleMessage(client: Client, session: DocumentSession, msg: WsMessage): void {\n    if (msg.type !== 'operation') {\n      this.send(client.ws, { type: 'error', message: `Unknown message type: ${msg.type}` });\n      return;\n    }\n\n    const op = msg.operation as Operation | undefined;\n    const clientVersion = msg.version as number | undefined;\n\n    if (!op || !Array.isArray(op)) {\n      this.send(client.ws, { type: 'error', message: 'Missing or invalid operation' });\n      return;\n    }\n\n    if (typeof clientVersion !== 'number' || !Number.isInteger(clientVersion)) {\n      this.send(client.ws, { type: 'error', message: 'Missing or invalid version' });\n      return;\n    }\n\n    if (clientVersion < 0 || clientVersion > session.version) {\n      this.send(client.ws, {\n        type: 'error',\n        message: `Version ${clientVersion} is out of range (current: ${session.version})`,\n      });\n      return;\n    }\n\n    // Validate the operation structure\n    const validationError = validate(op, -1); // skip length check, we'll do it after transform\n    if (validationError && !validationError.includes('input length')) {\n      this.send(client.ws, { type: 'error', message: validationError });\n      return;\n    }\n\n    try {\n      // Transform against all operations that have happened since clientVersion\n      let transformedOp = op;\n      const versions = this.store.getVersions(session.documentId);\n\n      for (const ver of versions) {\n        if (ver.version <= clientVersion) continue;\n        if (ver.version > session.version) break;\n        if (!ver.operation) continue;\n\n        const serverOp = JSON.parse(ver.operation) as Operation;\n        const [, clientPrime] = transform(serverOp, transformedOp);\n        transformedOp = clientPrime;\n      }\n\n      // Validate the transformed operation against current document\n      const lengthError = validate(transformedOp, session.content.length);\n      if (lengthError) {\n        this.send(client.ws, { type: 'error', message: lengthError });\n        return;\n      }\n\n      // Apply the operation\n      const newContent = apply(session.content, transformedOp);\n      session.version++;\n      session.content = newContent;\n\n      // Persist to database\n      this.store.addVersion(\n        session.documentId,\n        session.version,\n        newContent,\n        JSON.stringify(transformedOp)\n      );\n      this.store.updateContent(session.documentId, newContent);\n\n      // ACK to sender\n      this.send(client.ws, {\n        type: 'ack',\n        version: session.version,\n      });\n\n      // Broadcast to other clients\n      for (const [id, c] of session.clients) {\n        if (id === client.id) continue;\n        if (c.ws.readyState === WebSocket.OPEN) {\n          this.send(c.ws, {\n            type: 'operation',\n            operation: transformedOp,\n            version: session.version,\n            clientId: client.id,\n          });\n        }\n      }\n    } catch (err) {\n      this.send(client.ws, {\n        type: 'error',\n        message: err instanceof Error ? err.message : 'Failed to apply operation',\n      });\n    }\n  }\n\n  private send(ws: WebSocket, msg: WsMessage): void {\n    if (ws.readyState === WebSocket.OPEN) {\n      ws.send(JSON.stringify(msg));\n    }\n  }\n\n  closeAll(): void {\n    for (const session of this.sessions.values()) {\n      for (const client of session.clients.values()) {\n        client.ws.close();\n      }\n    }\n    this.sessions.clear();\n    this.wss.close();\n  }\n}\n","numLines":231,"startLine":1,"totalLines":231}}}
