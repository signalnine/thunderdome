);\n      };\n      this.waiters.push(handler);\n    });\n  }\n\n  send(data: unknown): void {\n    this.ws.send(JSON.stringify(data));\n  }\n\n  sendOp(version: number, operation: unknown[]): void {\n    this.send({ type: 'operation', version, operation });\n  }\n\n  close(): void {\n    if (this.ws.readyState === WebSocket.OPEN || this.ws.readyState === WebSocket.CONNECTING) {\n      this.ws.close();\n    }\n  }\n}\n\ndescribe('WebSocket Collaboration', () => {\n  let app: AppInstance;\n  let port: number;\n  const clients: BufferedWs[] = [];\n\n  beforeEach(async () => {\n    app = createApp(':memory:');\n    port = await app.start(0);\n  });\n\n  afterEach(async () => {\n    for (const c of clients) {\n      c.close();\n    }\n    clients.length = 0;\n    await app.stop();\n  });\n\n  async function createDoc(title: string, content: string = ''): Promise<string> {\n    const res = await request(app.app)\n      .post('/api/documents')\n      .send({ title, content });\n    return res.body.id;\n  }\n\n  async function connect(docId: string): Promise<BufferedWs> {\n    const bws = new BufferedWs(`ws://127.0.0.1:${port}/documents/${docId}/ws`);\n    clients.push(bws);\n    await bws.open();\n    return bws;\n  }\n\n  it('sends sync on connect', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const c = await connect(docId);\n    const msg = await c.nextMessage();\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('hello');\n    expect(msg.version).toBe(0);\n    expect(msg.clientId).toBeDefined();\n  });\n\n  it('applies an operation and sends ack', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const c = await connect(docId);\n    await c.nextMessage(); // sync\n\n    c.sendOp(0, [5, ' world']);\n    const ack = await c.nextMessage();\n\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(1);\n\n    const res = await request(app.app).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('hello world');\n  });\n\n  it('broadcasts operation to other clients', async () => {\n    const docId = await createDoc('Test', 'abc');\n    const c1 = await connect(docId);\n    const c2 = await connect(docId);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    c1.sendOp(0, ['x', 3]);\n\n    const ack = await c1.nextMessage();\n    expect(ack.type).toBe('ack');\n\n    const broadcast = await c2.nextMessage();\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.operation).toEqual(['x', 3]);\n    expect(broadcast.version).toBe(1);\n  });\n\n  it('transforms concurrent operations', async () => {\n    const docId = await createDoc('Test', 'abc');\n    const c1 = await connect(docId);\n    const c2 = await connect(docId);\n\n    await c1.nextMessage(); // sync\n    await c2.nextMessage(); // sync\n\n    // Both clients send ops based on version 0\n    c1.sendOp(0, ['x', 3]); // insert 'x' at start\n    c2.sendOp(0, [3, 'y']); // insert 'y' at end\n\n    // Client 1: ack, then broadcast of client 2's transformed op\n    const c1Msg1 = await c1.nextMessage();\n    expect(c1Msg1.type).toBe('ack');\n    expect(c1Msg1.version).toBe(1);\n\n    // Client 2: broadcast of client 1's op, then ack\n    const c2Msg1 = await c2.nextMessage();\n    expect(c2Msg1.type).toBe('operation');\n\n    const c2Msg2 = await c2.nextMessage();\n    expect(c2Msg2.type).toBe('ack');\n    expect(c2Msg2.version).toBe(2);\n\n    const c1Msg2 = await c1.nextMessage();\n    expect(c1Msg2.type).toBe('operation');\n\n    // Both clients should converge\n    const res = await request(app.app).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('xabcy');\n  });\n\n  it('handles multiple sequential operations', async () => {\n    const docId = await createDoc('Test', '');\n    const c = await connect(docId);\n    await c.nextMessage(); // sync\n\n    c.sendOp(0, ['h']);\n    const ack1 = await c.nextMessage();\n    expect(ack1.type).toBe('ack');\n\n    c.sendOp(1, [1, 'i']);\n    const ack2 = await c.nextMessage();\n    expect(ack2.type).toBe('ack');\n\n    const res = await request(app.app).get(`/api/documents/${docId}`);\n    expect(res.body.content).toBe('hi');\n  });\n\n  it('rejects invalid operation', async () => {\n    const docId = await createDoc('Test', 'abc');\n    const c = await connect(docId);\n    await c.nextMessage(); // sync\n\n    c.sendOp(0, [10]); // wrong base length\n    const err = await c.nextMessage();\n    expect(err.type).toBe('error');\n  });\n\n  it('rejects malformed messages', async () => {\n    const docId = await createDoc('Test', 'abc');\n    const c = await connect(docId);\n    await c.nextMessage(); // sync\n\n    c.ws.send('not json at all {{{');\n    const err = await c.nextMessage();\n    expect(err.type).toBe('error');\n  });\n\n  it('rejects unknown message types', async () => {\n    const docId = await createDoc('Test', 'abc');\n    const c = await connect(docId);\n    await c.nextMessage(); // sync\n\n    c.send({ type: 'invalid_type' });\n    const err = await c.nextMessage();\n    expect(err.type).toBe('error');\n  });\n\n  it('persists operations in version history', async () => {\n    const docId = await createDoc('Test', 'hello');\n    const c = await connect(docId);\n    await c.nextMessage(); // sync\n\n    c.sendOp(0, [5, ' world']);\n    await c.nextMessage(); // ack\n\n    const res = await request(app.app).get(`/api/documents/${docId}/versions`);\n    expect(res.body.length).toBe(2);\n    expect(res.body[0].version).toBe(0);\n    expect(res.body[0].content).toBe('hello');\n    expect(res.body[1].version).toBe(1);\n    expect(res.body[1].content).toBe('hello world');\n  });\n\n  it('handles 10 concurrent clients', async () => {\n    const docId = await createDoc('Test', '');\n    const conns: BufferedWs[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const c = await connect(docId);\n      await c.nextMessage(); // sync\n      conns.push(c);\n    }\n\n    // Each client inserts its digit, all at version 0\n    const promises: Promise<void>[] = [];\n    for (let i = 0; i < 10; i++) {\n      const c = conns[i];\n      const char = String(i);\n      promises.push((async () => {\n        c.sendOp(0, [char]);\n        // Drain messages until we get our ack\n        let gotAck = false;\n        while (!gotAck) {\n          const msg = await c.nextMessage(5000);\n          if (msg.type === 'ack') gotAck = true;\n        }\n      })());\n    }\n\n    await Promise.all(promises);\n\n    // Wait for broadcasts to settle\n    await new Promise((resolve) => setTimeout(resolve, 200));\n\n    const res = await request(app.app).get(`/api/documents/${docId}`);\n    const content = res.body.content as string;\n    expect(content.length).toBe(10);\n\n    for (let i = 0; i < 10; i++) {\n      expect(content).toContain(String(i));\n    }\n  });\n\n  it('document survives server restart', async () => {\n    const fs = await import('fs');\n    const os = await import('os');\n    const path = await import('path');\n    const dbPath = path.join(os.tmpdir(), `collab-test-${Date.now()}.db`);\n\n    try {\n      const app1 = createApp(dbPath);\n      const port1 = await app1.start(0);\n\n      const createRes = await request(app1.app)\n        .post('/api/documents')\n        .send({ title: 'Persistent', content: 'initial' });\n      const docId = createRes.body.id;\n\n      const c = new BufferedWs(`ws://127.0.0.1:${port1}/documents/${docId}/ws`);\n      await c.open();\n      await c.nextMessage(); // sync\n\n      c.sendOp(0, [7, ' content']);\n      await c.nextMessage(); // ack\n\n      c.close();\n      await app1.stop();\n\n      // Restart with same DB\n      const app2 = createApp(dbPath);\n      await app2.start(0);\n\n      const res = await request(app2.app).get(`/api/documents/${docId}`);\n      expect(res.body.content).toBe('initial content');\n      expect(res.body.title).toBe('Persistent');\n\n      await app2.stop();\n    } finally {\n      try { fs.unlinkSync(dbPath); } catch { /* ignore */ }\n    }\n  });\n});\n","structuredPatch":[{"oldStart":3,"oldLines":32,"newStart":3,"newLines":71,"lines":[" import WebSocket from 'ws';"," import { createApp, AppInstance } from '../src/server.js';"," ","-function connectWs(port: number, docId: string): Promise<WebSocket> {","-  return new Promise((resolve, reject) => {","-    const ws = new WebSocket(`ws://127.0.0.1:${port}/documents/${docId}/ws`);","-    ws.on('open', () => resolve(ws));","-    ws.on('error', reject);","-  });","-}","+/** A WebSocket wrapper that buffers messages so none are missed. */","+class BufferedWs {","+  readonly ws: WebSocket;","+  private messageQueue: Record<string, unknown>[] = [];","+  private waiters: Array<(msg: Record<string, unknown>) => void> = [];","+  private _open: Promise<void>;"," ","-function waitForMessage(ws: WebSocket, timeout = 3000): Promise<Record<string, unknown>> {","-  return new Promise((resolve, reject) => {","-    const timer = setTimeout(() => reject(new Error('Timeout waiting for message')), timeout);","-    ws.once('message', (data) => {","-      clearTimeout(timer);","-      resolve(JSON.parse(data.toString()));","+  constructor(url: string) {","+    this.ws = new WebSocket(url);","+    this._open = new Promise((resolve, reject) => {","+      this.ws.on('open', resolve);","+      this.ws.on('error', reject);","     });","-  });","-}","+    this.ws.on('message', (data) => {","+      const msg = JSON.parse(data.toString());","+      if (this.waiters.length > 0) {","+        const waiter = this.waiters.shift()!;","+        waiter(msg);","+      } else {","+        this.messageQueue.push(msg);","+      }","+    });","+  }"," ","-function sendOp(ws: WebSocket, version: number, operation: unknown[]): void {","-  ws.send(JSON.stringify({ type: 'operation', version, operation }));","+  async open(): Promise<void> {","+    await this._open;","+  }","+","+