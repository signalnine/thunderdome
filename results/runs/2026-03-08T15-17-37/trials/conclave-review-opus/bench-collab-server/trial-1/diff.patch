handleUpgrade(request, socket, head, (ws) => {\n    54→        this.wss.emit('connection', ws, request, documentId);\n    55→      });\n    56→    });\n    57→\n    58→    this.wss.on('connection', (ws: WebSocket, _request: IncomingMessage, documentId: string) => {\n    59→      this.handleConnection(ws, documentId);\n    60→    });\n    61→  }\n    62→\n    63→  private getOrCreateSession(documentId: string): DocumentSession {\n    64→    let session = this.sessions.get(documentId);\n    65→    if (!session) {\n    66→      const doc = this.store.getDocument(documentId);\n    67→      if (!doc) throw new Error('Document not found');\n    68→      const version = this.store.getLatestVersion(documentId);\n    69→      session = {\n    70→        documentId,\n    71→        clients: new Map(),\n    72→        version,\n    73→        content: doc.content,\n    74→      };\n    75→      this.sessions.set(documentId, session);\n    76→    }\n    77→    return session;\n    78→  }\n    79→\n    80→  private handleConnection(ws: WebSocket, documentId: string): void {\n    81→    const session = this.getOrCreateSession(documentId);\n    82→    const clientId = randomUUID();\n    83→    const client: Client = { id: clientId, ws, documentId };\n    84→    session.clients.set(clientId, client);\n    85→\n    86→    // Send sync message with current state\n    87→    this.send(ws, {\n    88→      type: 'sync',\n    89→      documentId,\n    90→      content: session.content,\n    91→      version: session.version,\n    92→      clientId,\n    93→    });\n    94→\n    95→    ws.on('message', (data) => {\n    96→      try {\n    97→        const msg = JSON.parse(data.toString()) as WsMessage;\n    98→        this.handleMessage(client, session, msg);\n    99→      } catch (err) {\n   100→        this.send(ws, {\n   101→          type: 'error',\n   102→          message: err instanceof Error ? err.message : 'Invalid message',\n   103→        });\n   104→      }\n   105→    });\n  