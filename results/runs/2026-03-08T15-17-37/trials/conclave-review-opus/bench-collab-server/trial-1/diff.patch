ng them as needed. */\nclass OpIterator {\n  private components: OpComponent[];\n  private index: number;\n\n  constructor(op: Operation) {\n    this.components = [...op];\n    this.index = 0;\n  }\n\n  hasNext(): boolean {\n    return this.index < this.components.length;\n  }\n\n  peek(): OpComponent | null {\n    if (this.index >= this.components.length) return null;\n    return this.components[this.index];\n  }\n\n  next(): OpComponent | null {\n    if (this.index >= this.components.length) return null;\n    return this.components[this.index++];\n  }\n\n  /** Consume `n` characters from the current numeric component. */\n  take(n: number): void {\n    const c = this.components[this.index];\n    if (typeof c === 'string') throw new Error('Cannot take from string component');\n    const abs = Math.abs(c);\n    if (n > abs) throw new Error('Taking more than available');\n    if (n === abs) {\n      this.index++;\n    } else {\n      this.components[this.index] = c > 0 ? c - n : c + n;\n    }\n  }\n\n  putBack(component: OpComponent): void {\n    this.components.splice(this.index, 0, component);\n  }\n}\n","structuredPatch":[{"oldStart":98,"oldLines":6,"newStart":98,"newLines":10,"lines":["  * Transform two concurrent operations so they can be applied in sequence.","  * Given operations A and B that both apply to the same document,","  * returns [A', B'] such that apply(apply(doc, A), B') === apply(apply(doc, B), A').","+ *","+ * Tie-breaking: when both operations insert at the same position, opA's insert","+ * is placed first. Callers should pass the server/authoritative operation as opA","+ * and the client operation as opB.","  */"," export function transform(opA: Operation, opB: Operation): [Operation, Operation] {","   const iterA = new OpIterator(opA);"]}],"userModified":false,"replaceAll":false}}
