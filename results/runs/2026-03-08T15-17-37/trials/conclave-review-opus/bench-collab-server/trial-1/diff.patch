@@ -0,0 +1,337 @@
+/**
+ * Operational Transform (OT) implementation for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert the string at current position
+ * - number < 0: delete |N| characters
+ *
+ * The document cursor advances by retain and delete amounts,
+ * and insert adds text without advancing the input cursor.
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface VersionedOperation {
+  version: number;
+  operation: Operation;
+  clientId?: string;
+}
+
+/** Compute the input length an operation expects. */
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;       // retain
+      else if (c < 0) len += -c; // delete
+    }
+    // insert doesn't consume input
+  }
+  return len;
+}
+
+/** Compute the output length an operation produces. */
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;       // retain
+      // delete produces nothing
+    } else {
+      len += c.length;           // insert
+    }
+  }
+  return len;
+}
+
+/** Apply an operation to a document string. */
+export function apply(doc: string, op: Operation): string {
+  const expected = inputLength(op);
+  if (expected !== doc.length) {
+    throw new Error(`Operation input length ${expected} does not match document length ${doc.length}`);
+  }
+  let result = '';
+  let pos = 0;
+  for (const c of op) {
+    if (typeof c === 'string') {
+      result += c;
+    } else if (c > 0) {
+      result += doc.slice(pos, pos + c);
+      pos += c;
+    } else if (c < 0) {
+      pos += -c;
+    }
+  }
+  return result;
+}
+
+/** Normalize an operation by merging adjacent same-type components. */
+export function normalize(op: Operation): Operation {
+  const result: Operation = [];
+  for (const c of op) {
+    if (typeof c === 'number' && c === 0) continue;
+    if (typeof c === 'string' && c === '') continue;
+
+    if (result.length === 0) {
+      result.push(c);
+      continue;
+    }
+    const last = result[result.length - 1];
+    if (typeof c === 'string' && typeof last === 'string') {
+      result[result.length - 1] = last + c;
+    } else if (typeof c === 'number' && typeof last === 'number') {
+      if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+        result[result.length - 1] = last + c;
+      } else {
+        result.push(c);
+      }
+    } else {
+      result.push(c);
+    }
+  }
+  return result;
+}
+
+/**
+ * Transform two concurrent operations so they can be applied in sequence.
+ * Given operations A and B that both apply to the same document,
+ * returns [A', B'] such that apply(apply(doc, A), B') === apply(apply(doc, B), A').
+ *
+ * Tie-breaking: when both operations insert at the same position, opA's insert
+ * is placed first. Callers should pass the server/authoritative operation as opA
+ * and the client operation as opB.
+ */
+export function transform(opA: Operation, opB: Operation): [Operation, Operation] {
+  const iterA = new OpIterator(opA);
+  const iterB = new OpIterator(opB);
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+
+  while (iterA.hasNext() || iterB.hasNext()) {
+    const peekA = iterA.peek();
+    const peekB = iterB.peek();
+
+    // If A inserts, include it in A' and retain in B'
+    if (peekA !== null && typeof peekA === 'string') {
+      const ins = iterA.next() as string;
+      aPrime.push(ins);
+      bPrime.push(ins.length);
+      continue;
+    }
+
+    // If B inserts, include it in B' and retain in A'
+    if (peekB !== null && typeof peekB === 'string') {
+      const ins = iterB.next() as string;
+      bPrime.push(ins);
+      aPrime.push(ins.length);
+      continue;
+    }
+
+    // Both done
+    if (peekA === null && peekB === null) break;
+
+    // Both must be numbers at this point (retain or delete)
+    if (peekA === null || peekB === null) {
+      throw new Error('Operations have different base lengths');
+    }
+
+    const aVal = peekA as number;
+    const bVal = peekB as number;
+
+    // Both retain
+    if (aVal > 0 && bVal > 0) {
+      const min = Math.min(aVal, bVal);
+      iterA.take(min);
+      iterB.take(min);
+      aPrime.push(min);
+      bPrime.push(min);
+    }
+    // A deletes, B retains
+    else if (aVal < 0 && bVal > 0) {
+      const min = Math.min(-aVal, bVal);
+      iterA.take(min);
+      iterB.take(min);
+      aPrime.push(-min);
+      // B' doesn't need to do anything for deleted chars
+    }
+    // A retains, B deletes
+    else if (aVal > 0 && bVal < 0) {
+      const min = Math.min(aVal, -bVal);
+      iterA.take(min);
+      iterB.take(min);
+      bPrime.push(-min);
+      // A' doesn't need to do anything for deleted chars
+    }
+    // Both delete
+    else if (aVal < 0 && bVal < 0) {
+      const min = Math.min(-aVal, -bVal);
+      iterA.take(min);
+      iterB.take(min);
+      // Both deleted the same text; neither prime needs to delete
+    }
+    else {
+      throw new Error('Unexpected OT state');
+    }
+  }
+
+  return [normalize(aPrime), normalize(bPrime)];
+}
+
+/** Compose two sequential operations into one. */
+export function compose(opA: Operation, opB: Operation): Operation {
+  const iterA = new OpIterator(opA);
+  const iterB = new OpIterator(opB);
+  const result: Operation = [];
+
+  while (iterA.hasNext() || iterB.hasNext()) {
+    const peekB = iterB.peek();
+
+    // B deletes: consume from A's output
+    if (peekB !== null && typeof peekB === 'number' && peekB < 0) {
+      const delCount = -(iterB.next() as number);
+      let remaining = delCount;
+      while (remaining > 0) {
+        const peekA2 = iterA.peek();
+        if (peekA2 === null) throw new Error('Compose: A ran out of output');
+        if (typeof peekA2 === 'string') {
+          const ins = iterA.next() as string;
+          if (ins.length <= remaining) {
+            remaining -= ins.length;
+          } else {
+            iterA.putBack(ins.slice(remaining));
+            remaining = 0;
+          }
+        } else if ((peekA2 as number) > 0) {
+          const ret = peekA2 as number;
+          const min = Math.min(ret, remaining);
+          iterA.take(min);
+          result.push(-min);
+          remaining -= min;
+        } else {
+          // A deletes — pass through
+          result.push(iterA.next() as number);
+        }
+      }
+      continue;
+    }
+
+    // B inserts
+    if (peekB !== null && typeof peekB === 'string') {
+      result.push(iterB.next() as string);
+      continue;
+    }
+
+    // B retains
+    if (peekB !== null && typeof peekB === 'number' && peekB > 0) {
+      let remaining = iterB.next() as number;
+      while (remaining > 0) {
+        const peekA2 = iterA.peek();
+        if (peekA2 === null) throw new Error('Compose: A ran out of output');
+        if (typeof peekA2 === 'string') {
+          const ins = iterA.next() as string;
+          if (ins.length <= remaining) {
+            result.push(ins);
+            remaining -= ins.length;
+          } else {
+            result.push(ins.slice(0, remaining));
+            iterA.putBack(ins.slice(remaining));
+            remaining = 0;
+          }
+        } else if ((peekA2 as number) > 0) {
+          const ret = peekA2 as number;
+          const min = Math.min(ret, remaining);
+          iterA.take(min);
+          result.push(min);
+          remaining -= min;
+        } else {
+          // A deletes — pass through
+          result.push(iterA.next() as number);
+        }
+      }
+      continue;
+    }
+
+    // B is done, drain A
+    if (!iterB.hasNext()) {
+      while (iterA.hasNext()) {
+        result.push(iterA.next()!);
+      }
+      break;
+    }
+  }
+
+  return normalize(result);
+}
+
+/** Validate that an operation is structurally well-formed (without checking document length). */
+export function validateStructure(op: Operation): string | null {
+  if (!Array.isArray(op)) return 'Operation must be an array';
+  for (const c of op) {
+    if (typeof c === 'string') {
+      // insert is always valid
+    } else if (typeof c === 'number') {
+      if (!Number.isInteger(c)) return 'Operation components must be integers';
+      if (c === 0) return 'Operation must not contain zero';
+    } else {
+      return 'Operation components must be numbers or strings';
+    }
+  }
+  return null;
+}
+
+/**
+ * Validate that an operation is well-formed and compatible with a document of the given length.
+ */
+export function validate(op: Operation, docLength: number): string | null {
+  const structErr = validateStructure(op);
+  if (structErr) return structErr;
+  const inLen = inputLength(op);
+  if (inLen !== docLength) {
+    return `Operation input length ${inLen} does not match document length ${docLength}`;
+  }
+  return null;
+}
+
+/** Helper: iterates over operation components, splitting them as needed. */
+class OpIterator {
+  private components: OpComponent[];
+  private index: number;
+
+  constructor(op: Operation) {
+    this.components = [...op];
+    this.index = 0;
+  }
+
+  hasNext(): boolean {
+    return this.index < this.components.length;
+  }
+
+  peek(): OpComponent | null {
+    if (this.index >= this.components.length) return null;
+    return this.components[this.index];
+  }
+
+  next(): OpComponent | null {
+    if (this.index >= this.components.length) return null;
+    return this.components[this.index++];
+  }
+
+  /** Consume `n` characters from the current numeric component. */
+  take(n: number): void {
+    const c = this.components[this.index];
+    if (typeof c === 'string') throw new Error('Cannot take from string component');
+    const abs = Math.abs(c);
+    if (n > abs) throw new Error('Taking more than available');
+    if (n === abs) {
+      this.index++;
+    } else {
+      this.components[this.index] = c > 0 ? c - n : c + n;
+    }
+  }
+
+  putBack(component: OpComponent): void {
+    this.components.splice(this.index, 0, component);
+  }
+}
