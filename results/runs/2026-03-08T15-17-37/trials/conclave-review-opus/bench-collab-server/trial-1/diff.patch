+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import request from 'supertest';
+import { createApp, AppInstance } from '../src/server.js';
+
+describe('REST API', () => {
+  let app: AppInstance;
+
+  beforeEach(async () => {
+    app = createApp(':memory:');
+    await app.start(0);
+  });
+
+  afterEach(async () => {
+    await app.stop();
+  });
+
+  describe('POST /api/documents', () => {
+    it('creates a document', async () => {
+      const res = await request(app.app)
+        .post('/api/documents')
+        .send({ title: 'Test Doc', content: 'Hello' })
+        .expect(201);
+
+      expect(res.body.id).toBeDefined();
+      expect(res.body.title).toBe('Test Doc');
+      expect(res.body.content).toBe('Hello');
+    });
+
+    it('creates a document with empty content', async () => {
+      const res = await request(app.app)
+        .post('/api/documents')
+        .send({ title: 'Empty Doc' })
+        .expect(201);
+
+      expect(res.body.content).toBe('');
+    });
+
+    it('rejects missing title', async () => {
+      await request(app.app)
+        .post('/api/documents')
+        .send({ content: 'No title' })
+        .expect(400);
+    });
+  });
+
+  describe('GET /api/documents', () => {
+    it('lists documents', async () => {
+      await request(app.app).post('/api/documents').send({ title: 'Doc 1' });
+      await request(app.app).post('/api/documents').send({ title: 'Doc 2' });
+
+      const res = await request(app.app).get('/api/documents').expect(200);
+      expect(res.body.length).toBe(2);
+    });
+
+    it('returns empty array when no documents', async () => {
+      const res = await request(app.app).get('/api/documents').expect(200);
+      expect(res.body).toEqual([]);
+    });
+  });
+
+  describe('GET /api/documents/:id', () => {
+    it('gets a document by id', async () => {
+      const created = await request(app.app)
+        .post('/api/documents')
+        .send({ title: 'Test', content: 'Content' });
+
+      const res = await request(app.app)
+        .get(`/api/documents/${created.body.id}`)
+        .expect(200);
+
+      expect(res.body.title).toBe('Test');
+      expect(res.body.content).toBe('Content');
+    });
+
+    it('returns 404 for missing document', async () => {
+      await request(app.app)
+        .get('/api/documents/nonexistent')
+        .expect(404);
+    });
+  });
+
+  describe('PUT /api/documents/:id', () => {
+    it('updates title', async () => {
+      const created = await request(app.app)
+        .post('/api/documents')
+        .send({ title: 'Old Title' });
+
+      const res = await request(app.app)
+        .put(`/api/documents/${created.body.id}`)
+        .send({ title: 'New Title' })
+        .expect(200);
+
+      expect(res.body.title).toBe('New Title');
+    });
+
+    it('updates content', async () => {
+      const created = await request(app.app)
+        .post('/api/documents')
+        .send({ title: 'Doc', content: 'old' });
+
+      const res = await request(app.app)
+        .put(`/api/documents/${created.body.id}`)
+        .send({ content: 'new' })
+        .expect(200);
+
+      expect(res.body.content).toBe('new');
+    });
+
+    it('returns 404 for missing document', async () => {
+      await request(app.app)
+        .put('/api/documents/nonexistent')
+        .send({ title: 'test' })
+        .expect(404);
+    });
+  });
+
+  describe('DELETE /api/documents/:id', () => {
+    it('deletes a document', async () => {
+      const created = await request(app.app)
+        .post('/api/documents')
+        .send({ title: 'To Delete' });
+
+      await request(app.app)
+        .delete(`/api/documents/${created.body.id}`)
+        .expect(204);
+
+      await request(app.app)
+        .get(`/api/documents/${created.body.id}`)
+        .expect(404);
+    });
+
+    it('returns 404 for missing document', async () => {
+      await request(app.app)
+        .delete('/api/documents/nonexistent')
+        .expect(404);
+    });
+  });
+
+  describe('GET /api/documents/:id/versions', () => {
+    it('returns version history', async () => {
+      const created = await request(app.app)
+        .post('/api/documents')
+        .send({ title: 'Versioned', content: 'initial' });
+
+      const res = await request(app.app)
+        .get(`/api/documents/${created.body.id}/versions`)
+        .expect(200);
+
+      expect(res.body.length).toBe(1);
+      expect(res.body[0].version).toBe(0);
+      expect(res.body[0].content).toBe('initial');
+    });
+
+    it('returns 404 for missing document', async () => {
+      await request(app.app)
+        .get('/api/documents/nonexistent/versions')
+        .expect(404);
+    });
+  });
+});
