+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pp3toq9yrjCSJNhz4yQtRi","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n     2→import request from 'supertest';\n     3→import { createApp, AppInstance } from '../src/server.js';\n     4→\n     5→describe('REST API', () => {\n     6→  let app: AppInstance;\n     7→\n     8→  beforeEach(async () => {\n     9→    app = createApp(':memory:');\n    10→    await app.start(0);\n    11→  });\n    12→\n    13→  afterEach(async () => {\n    14→    await app.stop();\n    15→  });\n    16→\n    17→  describe('POST /api/documents', () => {\n    18→    it('creates a document', async () => {\n    19→      const res = await request(app.app)\n    20→        .post('/api/documents')\n    21→        .send({ title: 'Test Doc', content: 'Hello' })\n    22→        .expect(201);\n    23→\n    24→      expect(res.body.id).toBeDefined();\n    25→      expect(res.body.title).toBe('Test Doc');\n    26→      expect(res.body.content).toBe('Hello');\n    27→    });\n    28→\n    29→    it('creates a document with empty content', async () => {\n    30→      const res = await request(app.app)\n    31→        .post('/api/documents')\n    32→        .send({ title: 'Empty Doc' })\n    33→        .expect(201);\n    34→\n    35→      expect(res.body.content).toBe('');\n    36→    });\n    37→\n    38→    it('rejects missing title', async () => {\n    39→      await request(app.app)\n    40→        .post('/api/documents')\n    41→        .send({ content: 'No title' })\n    42→        .expect(400);\n    43→    });\n    44→  });\n    45→\n    46→  describe('GET /api/documents', () => {\n    47→    it('lists documents', async () => {\n    48→      await request(app.app).post('/api/documents').send({ title: 'Doc 1' });\n    49→      await request(app.app).post('/api/documents').send({ title: 'Doc 2' });\n    50→\n    51→      const res = await request(app.app).get('/api/documents').expect(200);\n    52→      expect(res.body.length).toBe(2);\n    53→    });\n    54→\n    55→    it('returns empty array when no documents', async () => {\n    56→      const res = await request(app.app).get('/api/documents').expect(200);\n    57→      expect(res.body).toEqual([]);\n    58→    });\n    59→  });\n    60→\n    61→  describe('GET /api/documents/:id', () => {\n    62→    it('gets a document by id', async () => {\n    63→      const created = await request(app.app)\n    64→        .post('/api/documents')\n    65→        .send({ title: 'Test', content: 'Content' });\n    66→\n    67→      const res = await request(app.app)\n    68→        .get(`/api/documents/${created.body.id}`)\n    69→        .expect(200);\n    70→\n    71→      expect(res.body.title).toBe('Test');\n    72→      expect(res.body.content).toBe('Content');\n    73→    });\n    74→\n    75→    it('returns 404 for missing document', async () => {\n    76→      await request(app.app)\n    77→        .get('/api/documents/nonexistent')\n    78→        .expect(404);\n    79→    });\n    80→  });\n    81→\n    82→  describe('PUT /api/documents/:id', () => {\n    83→    it('updates title', async () => {\n    84→      const created = await request(app.app)\n    85→        .post('/api/documents')\n    86→        .send({ title: 'Old Title' });\n    87→\n    88→      const res = await request(app.app)\n    89→        .put(`/api/documents/${created.body.id}`)\n    90→        .send({ title: 'New Title' })\n    91→        .expect(200);\n    92→\n    93→      expect(res.body.title).toBe('New Title');\n    94→    });\n    95→\n    96→    it('updates content', async () => {\n    97→      const created = await request(app.app)\n    98→        .post('/api/documents')\n    99→        .send({ title: 'Doc', content: 'old' });\n   100→\n   101→      const res = await request(app.app)\n   102→        .put(`/api/documents/${created.body.id}`)\n   103→        .send({ content: 'new' })\n   104→        .expect(200);\n   105→\n   106→      expect(res.body.content).toBe('new');\n   107→    });\n   108→\n   109→    it('returns 404 for missing document', async () => {\n   110→      await request(app.app)\n   111→        .put('/api/documents/nonexistent')\n   112→        .send({ title: 'test' })\n   113→        .expect(404);\n   114→    });\n   115→  });\n   116→\n   117→  describe('DELETE /api/documents/:id', () => {\n   118→    it('deletes a document', async () => {\n   119→      const created = await request(app.app)\n   120→        .post('/api/documents')\n   121→        .send({ title: 'To Delete' });\n   122→\n   123→      await request(app.app)\n   124→        .delete(`/api/documents/${created.body.id}`)\n   125→        .expect(204);\n   126→\n   127→      await request(app.app)\n   128→        .get(`/api/documents/${created.body.id}`)\n   129→        .expect(404);\n   130→    });\n   131→\n   132→    it('returns 404 for missing document', async () => {\n   133→      await request(app.app)\n   134→        .delete('/api/documents/nonexistent')\n   135→        .expect(404);\n   136→    });\n   137→  });\n   138→\n   139→  describe('GET /api/documents/:id/versions', () => {\n   140→    it('returns version history', async () => {\n   141→      const created = await request(app.app)\n   142→        .post('/api/documents')\n   143→        .send({ title: 'Versioned', content: 'initial' });\n   144→\n   145→      const res = await request(app.app)\n   146→        .get(`/api/documents/${created.body.id}/versions`)\n   147→        .expect(200);\n   148→\n   149→      expect(res.body.length).toBe(1);\n   150→      expect(res.body[0].version).toBe(0);\n   151→      expect(res.body[0].content).toBe('initial');\n   152→    });\n   153→\n   154→    it('returns 404 for missing document', async () => {\n   155→      await request(app.app)\n   156→        .get('/api/documents/nonexistent/versions')\n   157→        .expect(404);\n   158→    });\n   159→  });\n   160→});\n   161→"}]},"