212→      }\n   213→      continue;\n   214→    }\n   215→\n   216→    // B inserts\n   217→    if (peekB !== null && typeof peekB === 'string') {\n   218→      result.push(iterB.next() as string);\n   219→      continue;\n   220→    }\n   221→\n   222→    // B retains\n   223→    if (peekB !== null && typeof peekB === 'number' && peekB > 0) {\n   224→      let remaining = iterB.next() as number;\n   225→      while (remaining > 0) {\n   226→        const peekA2 = iterA.peek();\n   227→        if (peekA2 === null) throw new Error('Compose: A ran out of output');\n   228→        if (typeof peekA2 === 'string') {\n   229→          const ins = iterA.next() as string;\n   230→          if (ins.length <= remaining) {\n   231→            result.push(ins);\n   232→            remaining -= ins.length;\n   233→          } else {\n   234→            result.push(ins.slice(0, remaining));\n   235→            iterA.putBack(ins.slice(remaining));\n   236→            remaining = 0;\n   237→          }\n   238→        } else if ((peekA2 as number) > 0) {\n   239→          const ret = peekA2 as number;\n   240→          const min = Math.min(ret, remaining);\n   241→          iterA.take(min);\n   242→          result.push(min);\n   243→          remaining -= min;\n   244→        } else {\n   245→          // A deletes — pass through\n   246→          result.push(iterA.next() as number);\n   247→        }\n   248→      }\n   249→      continue;\n   250→    }\n   251→\n   252→    // B is done, drain A\n   253→    if (!iterB.hasNext()) {\n   254→      while (iterA.hasNext()) {\n   255→        result.push(iterA.next()!);\n   256→      }\n   257→      break;\n   258→    }\n   259→  }\n   260→\n   261→  return normalize(result);\n   262→}\n   263→\n   264→/**\n   265→ * Validate that an operation is well-formed and compatible with a document of the given length.\n   266→ */\n   267→export function validate(op: Operation, docLength: number): string | null {\n   268→  if (!Array.isArray(op)) return 'Operation must be an array';\n   269→  for (const c of op) {\n   270→    if (typeof c === 'string') {\n   271→      // insert is always valid\n   272→    } else if (typeof c === 'number') {\n   273→      if (!Number.isInteger(c)) return 'Operation components must be integers';\n   274→      if (c === 0) return 'Operation must not contain zero';\n   275→    } else {\n   276→      return 'Operation components must be numbers or strings';\n   277→    }\n   278→  }\n   279→  const inLen = inputLength(op);\n   280→  if (inLen !== docLength) {\n   281→    return `Operation input length ${inLen} does not match document length ${docLength}`;\n   282→  }\n   283→  return null;\n   284→}\n   285→\n   286→/** Helper: iterates over operation components, splitting them as needed. */\n   287→class OpIterator {\n   288→  private components: OpComponent[];\n   289→  private index: number;\n   290→\n   291→  constructor(op: Operation) {\n   292→    this.components = [...op];\n   293→    this.index = 0;\n   294→  }\n   295→\n   296→  hasNext(): boolean {\n   297→    return this.index < this.components.length;\n   298→  }\n   299→\n   300→  peek(): OpComponent | null {\n   301→    if (this.index >= this.components.length) return null;\n   302→    return this.components[this.index];\n   303→  }\n   304→\n   305→  next(): OpComponent | null {\n   306→    if (this.index >= this.components.length) return null;\n   307→    return this.components[this.index++];\n   308→  }\n   309→\n   310→  /** Consume `n` characters from the current numeric component. */\n   311→  take(n: number): void {\n   312→    const c = this.components[this.index];\n   313→    if (typeof c === 'string') throw new Error('Cannot take from string component');\n   314→    const abs = Math.abs(c);\n   315→    if (n > abs) throw new Error('Taking more than available');\n   316→    if (n === abs) {\n   317→      this.index++;\n   318→    } else {\n   319→      this.components[this.index] = c > 0 ? c - n : c + n;\n   320→    }\n   321→  }\n   322→\n   323→  putBack(component: OpComponent): void {\n   324→    this.components.splice(this.index, 0, component);\n   325→  }\n   326→}\n   327→"}]},"parent_tool_use_id":"toolu_01SM8JZ8tyr14cGVxeC9Cu35","session_id":"693a0101-0822-43c8-9992-946eaa32531d","uuid":"a59c297d-8b74-4584-bd01-0ecdf45fb433"}
