end();\n  });\n\n  // Get version history\n  router.get('/documents/:id/versions', (req, res) => {\n    const doc = store.getDocument(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versions = store.getVersions(req.params.id);\n    res.json(versions);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":303,"cache_read_input_tokens":26228,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":303},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"693a0101-0822-43c8-9992-946eaa32531d","uuid":"58785fe6-000a-452b-9a9f-81280239b0e1"}
