+
+describe('OT - transform', () => {
+  it('transforms two inserts at same position', () => {
+    // Both insert at the beginning of "abc"
+    const a: Operation = ['x', 3]; // insert 'x' then retain 3
+    const b: Operation = ['y', 3]; // insert 'y' then retain 3
+
+    const [aPrime, bPrime] = transform(a, b);
+
+    const doc = 'abc';
+    const afterA = apply(doc, a);     // 'xabc'
+    const afterB = apply(doc, b);     // 'yabc'
+
+    const result1 = apply(afterA, bPrime); // 'xabc' -> should insert 'y'
+    const result2 = apply(afterB, aPrime); // 'yabc' -> should insert 'x'
+
+    expect(result1).toBe(result2); // convergence
+  });
+
+  it('transforms insert vs delete', () => {
+    const a: Operation = ['x', 3]; // insert 'x' at start of 'abc'
+    const b: Operation = [-1, 2];  // delete 'a' from 'abc'
+
+    const [aPrime, bPrime] = transform(a, b);
+
+    const doc = 'abc';
+    const afterA = apply(doc, a);
+    const afterB = apply(doc, b);
+
+    const result1 = apply(afterA, bPrime);
+    const result2 = apply(afterB, aPrime);
+
+    expect(result1).toBe(result2);
+  });
+
+  it('transforms two deletes at same position', () => {
+    const a: Operation = [-1, 2]; // delete first char of 'abc'
+    const b: Operation = [-1, 2]; // delete first char of 'abc'
+
+    const [aPrime, bPrime] = transform(a, b);
+
+    const doc = 'abc';
+    const afterA = apply(doc, a);
+    const afterB = apply(doc, b);
+
+    const result1 = apply(afterA, bPrime);
+    const result2 = apply(afterB, aPrime);
+
+    expect(result1).toBe(result2);
+    expect(result1).toBe('bc'); // only one 'a' is deleted
+  });
+
+  it('transforms inserts at different positions', () => {
+    const a: Operation = [1, 'x', 2]; // insert 'x' after pos 1 in 'abc'
+    const b: Operation = [2, 'y', 1]; // insert 'y' after pos 2 in 'abc'
+
+    const [aPrime, bPrime] = transform(a, b);
+
+    const doc = 'abc';
+    const result1 = apply(apply(doc, a), bPrime);
+    const result2 = apply(apply(doc, b), aPrime);
+
+    expect(result1).toBe(result2);
+    expect(result1).toBe('axbyc');
+  });
+
+  it('handles identity transforms', () => {
+    const a: Operation = [5]; // retain all
+    const b: Operation = [5]; // retain all
+
+    const [aPrime, bPrime] = transform(a, b);
+    const doc = 'hello';
+
+    expect(apply(apply(doc, a), bPrime)).toBe('hello');
+    expect(apply(apply(doc, b), aPrime)).toBe('hello');
+  });
+
+  it('handles empty document', () => {
+    const a: Operation = ['x'];
+    const b: Operation = ['y'];
+
+    const [aPrime, bPrime] = transform(a, b);
+
+    const doc = '';
+    const result1 = apply(apply(doc, a), bPrime);
+    const result2 = apply(apply(doc, b), aPrime);
+
+    expect(result1).toBe(result2);
+  });
+});
