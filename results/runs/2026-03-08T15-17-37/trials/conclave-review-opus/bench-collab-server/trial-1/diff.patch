+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JVPgG74xh2bxhDnHCAiVs5","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { readFileSync } from 'fs';\n     3→import { join, dirname } from 'path';\n     4→import { fileURLToPath } from 'url';\n     5→import { randomUUID } from 'crypto';\n     6→\n     7→const __dirname = dirname(fileURLToPath(import.meta.url));\n     8→\n     9→export interface DocumentRow {\n    10→  id: string;\n    11→  title: string;\n    12→  content: string;\n    13→  created_at: string;\n    14→  updated_at: string;\n    15→}\n    16→\n    17→export interface VersionRow {\n    18→  id: number;\n    19→  document_id: string;\n    20→  version: number;\n    21→  content: string;\n    22→  operation: string | null;\n    23→  created_at: string;\n    24→}\n    25→\n    26→export function createDatabase(dbPath?: string): Database.Database {\n    27→  const db = new Database(dbPath || ':memory:');\n    28→  db.pragma('journal_mode = WAL');\n    29→  db.pragma('foreign_keys = ON');\n    30→\n    31→  const schemaPath = join(__dirname, '..', 'schema.sql');\n    32→  const schema = readFileSync(schemaPath, 'utf-8');\n    33→  db.exec(schema);\n    34→\n    35→  return db;\n    36→}\n    37→\n    38→export class DocumentStore {\n    39→  private db: Database.Database;\n    40→\n    41→  constructor(db: Database.Database) {\n    42→    this.db = db;\n    43→  }\n    44→\n    45→  createDocument(title: string, content: string = ''): DocumentRow {\n    46→    const id = randomUUID();\n    47→    const stmt = this.db.prepare(\n    48→      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'\n    49→    );\n    50→    stmt.run(id, title, content);\n    51→\n    52→    // Create initial version\n    53→    this.db.prepare(\n    54→      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, 0, ?, NULL)'\n    55→    ).run(id, content);\n    56→\n    57→    return this.getDocument(id)!;\n    58→  }\n    59→\n    60→  getDocument(id: string): DocumentRow | null {\n    61→    const row = this.db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as DocumentRow | undefined;\n    62→    return row || null;\n    63→  }\n    64→\n    65→  listDocuments(): DocumentRow[] {\n    66→    return this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC').all() as DocumentRow[];\n    67→  }\n    68→\n    69→  updateDocument(id: string, updates: { title?: string; content?: string }): DocumentRow | null {\n    70→    const doc = this.getDocument(id);\n    71→    if (!doc) return null;\n    72→\n    73→    const title = updates.title ?? doc.title;\n    74→    const content = updates.content ?? doc.content;\n    75→\n    76→    this.db.prepare(\n    77→      \"UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?\"\n    78→    ).run(title, content, id);\n    79→\n    80→    return this.getDocument(id)!;\n    81→  }\n    82→\n    83→  deleteDocument(id: string): boolean {\n    84→    const result = this.db.prepare('DELETE FROM documents WHERE id = ?').run(id);\n    85→    return result.changes > 0;\n    86→  }\n    87→\n    88→  getVersions(documentId: string): VersionRow[] {\n    89→    return this.db.prepare(\n    90→      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'\n    91→    ).all(documentId) as VersionRow[];\n    92→  }\n    93→\n    94→  getLatestVersion(documentId: string): number {\n    95→    const row = this.db.prepare(\n    96→      'SELECT COALESCE(MAX(version), 0) as version FROM versions WHERE document_id = ?'\n    97→    ).get(documentId) as { version: number } | undefined;\n    98→    return row?.version ?? 0;\n    99→  }\n   100→\n   101→  addVersion(documentId: string, version: number, content: string, operation: string | null): void {\n   102→    this.db.prepare(\n   103→      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'\n   104→    ).run(documentId, version, content, operation);\n   105→  }\n   106→\n   107→  updateContent(id: string, content: string): void {\n   108→    this.db.prepare(\n   109→      \"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"\n   110→    ).run(content, id);\n   111→  }\n   112→}\n   113→"}]},"parent_tool_use_id":"toolu_01SM8JZ8tyr14cGVxeC9Cu35","session_id":"693a0101-0822-43c8-9992-946eaa32531d","uuid":"e4800d28-8e5d-4dd1-82f2-58773610a952"}
