+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xu4ZoQRijBt71iReWJNn5K","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from 'ws';\n     2→import { IncomingMessage, Server as HttpServer } from 'http';\n     3→import { DocumentStore } from './db.js';\n     4→import { Operation, apply, transform, validate } from './ot.js';\n     5→import { randomUUID } from 'crypto';\n     6→import { parse } from 'url';\n     7→\n     8→interface Client {\n     9→  id: string;\n    10→  ws: WebSocket;\n    11→  documentId: string;\n    12→}\n    13→\n    14→interface DocumentSession {\n    15→  documentId: string;\n    16→  clients: Map<string, Client>;\n    17→  version: number;\n    18→  content: string;\n    19→}\n    20→\n    21→export interface WsMessage {\n    22→  type: string;\n    23→  [key: string]: unknown;\n    24→}\n    25→\n    26→export class CollaborationServer {\n    27→  private wss: WebSocketServer;\n    28→  private sessions: Map<string, DocumentSession> = new Map();\n    29→  private store: DocumentStore;\n    30→\n    31→  constructor(server: HttpServer, store: DocumentStore) {\n    32→    this.store = store;\n    33→    this.wss = new WebSocketServer({ noServer: true });\n    34→\n    35→    server.on('upgrade', (request: IncomingMessage, socket, head) => {\n    36→      const pathname = parse(request.url || '', true).pathname || '';\n    37→      const match = pathname.match(/^\\/documents\\/([^/]+)\\/ws$/);\n    38→\n    39→      if (!match) {\n    40→        socket.destroy();\n    41→        return;\n    42→      }\n    43→\n    44→      const documentId = match[1];\n    45→      const doc = this.store.getDocument(documentId);\n    46→      if (!doc) {\n    47→        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n    48→        socket.destroy();\n    49→        return;\n    50→      }\n    51→\n    52→      this.wss.handleUpgrade(request, socket, head, (ws) => {\n    53→        this.handleConnection(ws, documentId);\n    54→      });\n    55→    });\n    56→  }\n    57→\n    58→  private getOrCreateSession(documentId: string): DocumentSession {\n    59→    let session = this.sessions.get(documentId);\n    60→    if (!session) {\n    61→      const doc = this.store.getDocument(documentId);\n    62→      if (!doc) throw new Error('Document not found');\n    63→      const version = this.store.getLatestVersion(documentId);\n    64→      session = {\n    65→        documentId,\n    66→        clients: new Map(),\n    67→        version,\n    68→        content: doc.content,\n    69→      };\n    70→      this.sessions.set(documentId, session);\n    71→    }\n    72→    return session;\n    73→  }\n    74→\n    75→  private handleConnection(ws: WebSocket, documentId: string): void {\n    76→    const session = this.getOrCreateSession(documentId);\n    77→    const clientId = randomUUID();\n    78→    const client: Client = { id: clientId, ws, documentId };\n    79→    session.clients.set(clientId, client);\n    80→\n    81→    // Send sync message with current state\n    82→    this.send(ws, {\n    83→      type: 'sync',\n    84→      documentId,\n    85→      content: session.content,\n    86→      version: session.version,\n    87→      clientId,\n    88→    });\n    89→\n    90→    ws.on('message', (data) => {\n    91→      try {\n    92→        const msg = JSON.parse(data.toString()) as WsMessage;\n    93→        this.handleMessage(client, session, msg);\n    94→      } catch (err) {\n    95→        this.send(ws, {\n    96→          type: 'error',\n    97→          message: err instanceof Error ? err.message : 'Invalid message',\n    98→        });\n    99→      }\n   100→    });\n   101→\n   102→    ws.on('close', () => {\n   103→      session.clients.delete(clientId);\n   104→      if (session.clients.size === 0) {\n   105→        this.sessions.delete(documentId);\n   106→      }\n   107→    });\n   108→\n   109→    ws.on('error', () => {\n   110→      session.clients.delete(clientId);\n   111→    });\n   112→  }\n   113→\n   114→  private handleMessage(client: Client, session: DocumentSession, msg: WsMessage): void {\n   115→    if (msg.type !== 'operation') {\n   116→      this.send(client.ws, { type: 'error', message: `Unknown message type: ${msg.type}` });\n   117→      return;\n   118→    }\n   119→\n   120→    const op = msg.operation as Operation | undefined;\n   121→    const clientVersion = msg.version as number | undefined;\n   122→\n   123→    if (!op || !Array.isArray(op)) {\n   124→      this.send(client.ws, { type: 'error', message: 'Missing or invalid operation' });\n   125→      return;\n   126→    }\n   127→\n   128→    if (typeof clientVersion !== 'number' || !Number.isInteger(clientVersion)) {\n   129→      this.send(client.ws, { type: 'error', message: 'Missing or invalid version' });\n   130→      return;\n   131→    }\n   132→\n   133→    if (clientVersion < 0 || clientVersion > session.version) {\n   134→      this.send(client.ws, {\n   135→        type: 'error',\n   136→        message: `Version ${clientVersion} is out of range (current: ${session.version})`,\n   137→      });\n   138→      return;\n   139→    }\n   140→\n   141→    // Validate the operation structure\n   142→    const validationError = validate(op, -1); // skip length check, we'll do it after transform\n   143→    if (validationError && !validationError.includes('input length')) {\n   144→      this.send(client.ws, { type: 'error', message: validationError });\n   145→      return;\n   146→    }\n   147→\n   148→    try {\n   149→      // Transform against all operations that have happened since clientVersion\n   150→      let transformedOp = op;\n   151→      const versions = this.store.getVersions(session.documentId);\n   152→\n   153→      for (const ver of versions) {\n   154→        if (ver.version <= clientVersion) continue;\n   155→        if (ver.version > session.version) break;\n   156→        if (!ver.operation) continue;\n   157→\n   158→        const serverOp = JSON.parse(ver.operation) as Operation;\n   159→        const [, clientPrime] = transform(serverOp, transformedOp);\n   160→        transformedOp = clientPrime;\n   161→      }\n   162→\n   163→      // Validate the transformed operation against current document\n   164→      const lengthError = validate(transformedOp, session.content.length);\n   165→      if (lengthError) {\n   166→        this.send(client.ws, { type: 'error', message: lengthError });\n   167→        return;\n   168→      }\n   169→\n   170→      // Apply the operation\n   171→      const newContent = apply(session.content, transformedOp);\n   172→      session.version++;\n   173→      session.content = newContent;\n   174→\n   175→      // Persist to database\n   176→      this.store.addVersion(\n   177→        session.documentId,\n   178→        session.version,\n   179→        newContent,\n   180→        JSON.stringify(transformedOp)\n   181→      );\n   182→      this.store.updateContent(session.documentId, newContent);\n   183→\n   184→      // ACK to sender\n   185→      this.send(client.ws, {\n   186→        type: 'ack',\n   187→        version: session.version,\n   188→      });\n   189→\n   190→      // Broadcast to other clients\n   191→      for (const [id, c] of session.clients) {\n   192→        if (id === client.id) continue;\n   193→        if (c.ws.readyState === WebSocket.OPEN) {\n   194→          this.send(c.ws, {\n   195→            type: 'operation',\n   196→            operation: transformedOp,\n   197→            version: session.version,\n   198→            clientId: client.id,\n   199→          });\n   200→        }\n   201→      }\n   202→    } catch (err) {\n   203→      this.send(client.ws, {\n   204→        type: 'error',\n   205→        message: err instanceof Error ? err.message : 'Failed to apply operation',\n   206→      });\n   207→    }\n   208→  }\n   209→\n   210→  private send(ws: WebSocket, msg: WsMessage): void {\n   211→    if (ws.readyState === WebSocket.OPEN) {\n   212→      ws.send(JSON.stringify(msg));\n   213→    }\n   214→  }\n   215→\n   216→  closeAll(): void {\n   217→    for (const session of this.sessions.values()) {\n   218→      for (const client of session.clients.values()) {\n   219→        client.ws.close();\n   220→      }\n   221→    }\n   222→    this.sessions.clear();\n   223→    this.wss.close();\n   224→  }\n   225→}\n   226→"}]},"parent_tool_use_id":"toolu_01SM8JZ8tyr14cGVxeC9Cu35","session_id":"693a0101-0822-43c8-9992-946eaa32531d","uuid":"f1bab840-99a9-4727-ae2c-2f008d95d83a"}
