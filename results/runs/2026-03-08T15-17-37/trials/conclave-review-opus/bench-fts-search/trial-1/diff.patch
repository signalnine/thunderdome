      SELECT notes.id, notes.title\n        FROM notes_fts\n        JOIN notes ON notes.id = notes_fts.rowid\n        WHERE notes_fts MATCH ?\n        ORDER BY rank\n        LIMIT 5\n      `);\n      const results = stmt.all(ftsQuery) as SuggestResult[];\n\n      res.json({ results });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes/search?q=query&page=N - Full-text search\n  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const q = req.query.q as string | undefined;\n      if (!q || q.trim() === '') {\n        throw new ValidationError('Query parameter q is required');\n      }\n\n      const page = Math.max(1, parseInt(req.query.page as string) || 1);\n      const perPage = 20;\n      const offset = (page - 1) * perPage;\n\n      const sanitized = sanitizeFtsQuery(q.trim());\n      if (!sanitized) {\n        res.json({ results: [], total: 0, page, perPage });\n        return;\n      }\n\n      // Build FTS query - preserve quoted phrases, add prefix matching for unquoted terms\n      let ftsQuery: string;\n      // Check if the query contains quoted phrases\n      const hasQuotes = sanitized.includes('\"');\n      if (hasQuotes) {\n        ftsQuery = sanitized;\n      } else {\n        // Wrap each word in quotes to handle special chars safely\n        ftsQuery = sanitized.split(/\\s+/).filter(Boolean).map(t => `\"${t}\"`).join(' ');\n      }\n\n      // Count total results\n      const countStmt = db.prepare(`\n        SELECT COUNT(*) as total\n        FROM notes_fts\n        WHERE notes_fts MATCH ?\n      `);\n      const { total } = countStmt.get(ftsQuery) as { total: number };\n\n      // Get paginated results with snippets and BM25 ranking\n      const searchStmt = db.prepare(`\n        SELECT\n          notes.id,\n          notes.title,\n          snippet(notes_fts, 1, '<mark>', '</mark>', '...', 32) as snippet,\n          bm25(notes_fts) as rank\n        FROM notes_fts\n        JOIN notes ON notes.id = notes_fts.rowid\n        WHERE notes_fts MATCH ?\n        ORDER BY rank\n        LIMIT ? OFFSET ?\n      `);\n      const results = searchStmt.all(ftsQuery, perPage, offset) as SearchResult[];\n\n      res.json({ results, total, page, perPage });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes - List all notes (with optional tag filter)\n  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":246,"cache_read_input_tokens":35267,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":246},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4a04920e-671d-4890-9a70-f8a5a0e4e6c3","uuid":"19272f9f-54b4-4314-8de7-85d380a6f232"}
