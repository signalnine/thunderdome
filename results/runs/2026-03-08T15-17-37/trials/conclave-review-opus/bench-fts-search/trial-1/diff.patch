p).get('/notes/search/suggest?q=');\\n   147→    expect(res.status).toBe(400);\\n   148→  });\\n   149→\\n   150→  // 16. FTS syncs on create - new note appears in search\\n   151→  it('FTS syncs on create - new note appears in search', async () => {\\n   152→    // Create a note with a unique term\\n   153→    await request(appCtx.app)\\n   154→      .post('/notes')\\n   155→      .send({ title: 'Zylophone Dynamics', body: 'The zylophone produces unique harmonics and overtones.' });\\n   156→\\n   157→    const res = await request(appCtx.app).get('/notes/search?q=zylophone');\\n   158→    expect(res.status).toBe(200);\\n   159→    expect(res.body.results.length).toBe(1);\\n   160→    expect(res.body.results[0].title).toBe('Zylophone Dynamics');\\n   161→  });\\n   162→\\n   163→  // 17. FTS syncs on update - updated content appears in search\\n   164→  it('FTS syncs on update - updated content appears in search', async () => {\\n   165→    // Create a note\\n   166→    const createRes = await request(appCtx.app)\\n   167→      .post('/notes')\\n   168→      .send({ title: 'Original Title', body: 'Original content about elephants.' });\\n   169→    const noteId = createRes.body.note.id;\\n   170→\\n   171→    // Update it with unique content\\n   172→    await request(appCtx.app)\\n   173→      .put(`/notes/${noteId}`)\\n   174→      .send({ title: 'Updated Title', body: 'Updated content about xylographics.' });\\n   175→\\n   176→    // Search for the new content\\n   177→    const searchNew = await request(appCtx.app).get('/notes/search?q=xylographics');\\n   178→    expect(searchNew.body.results.length).toBe(1);\\n   179→\\n   180→    // Search for the old content - should not find it\\n   181→    const searchOld = await request(appCtx.app).get('/notes/search?q=elephants');\\n   182→    expect(searchOld.body.results.length).toBe(0);\\n   183→  });\\n   184→\\n   185→  // 18. FTS syncs on delete - deleted note disappears from search\\n   186→  it('FTS syncs on delete - deleted note disappears from search', async () => {\\n   187→    // Create a note with unique content\\n   188→    const createRes = await request(appCtx.app)\\n   189→      .post('/notes')\\n   190→      .send({ title: 'Temporary Note', body: 'Quizzaciously unique content for deletion test.' });\\n   191→    const noteId = createRes.body.note.id;\\n   192→\\n   193→    // Verify it appears in search\\n   194→    let searchRes = await request(appCtx.app).get('/notes/search?q=quizzaciously');\\n   195→    expect(searchRes.body.results.length).toBe(1);\\n   196→\\n   197→    // Delete it\\n   198→    await request(appCtx.app).delete(`/notes/${noteId}`);\\n   199→\\n   200→    // Verify it no longer appears in search\\n   201→    searchRes = await request(appCtx.app).get('/notes/search?q=quizzaciously');\\n   202→    expect(searchRes.body.results.length).toBe(0);\\n   203→  });\\n   204→\\n   205→  // 19. Special characters in query don't crash\\n   206→  it(\\\"Special characters in query don't crash\\\", async () => {\\n   207→    const specialQueries = [\\n   208→      '/notes/search?q=hello%20world',\\n   209→      '/notes/search?q=test%26test',\\n   210→      '/notes/search?q=it%27s',\\n   211→      '/notes/search?q=%3Cscript%3E',\\n   212→      '/notes/search?q=foo%2Bbar',\\n   213→      '/notes/search?q=a%2Fb',\\n   214→    ];\\n   215→\\n   216→    for (const url of specialQueries) {\\n   217→      const res = await request(appCtx.app).get(url);\\n   218→      // Should return 200 (search endpoint exists and handles special chars gracefully)\\n   219→      expect(res.status).toBe(200);\\n   220→      expect(Array.isArray(res.body.results)).toBe(true);\\n   221→    }\\n   222→  });\\n   223→\\n   224→  // 20. Search response time under 100ms for seeded dataset\\n   225→  it('Search response time under 100ms for seeded dataset', async () => {\\n   226→    const start = performance.now();\\n   227→    const res = await request(appCtx.app).get('/notes/search?