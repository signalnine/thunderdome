--- /dev/null
+++ b/src/plugins/asset-pipeline.ts
@@ -0,0 +1,38 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function transformContent(file: ContentFile, ctx: BuildContext): ContentFile {
+  let content = file.content;
+  const discoveredAssets: string[] = [];
+
+  // Rewrite relative src="./..." URLs
+  content = content.replace(/src="\.\/([^"]+)"/g, (_match, filename: string) => {
+    discoveredAssets.push(filename);
+    return `src="/assets/${filename}"`;
+  });
+
+  // Rewrite relative href="./..." URLs
+  content = content.replace(/href="\.\/([^"]+)"/g, (_match, filename: string) => {
+    discoveredAssets.push(filename);
+    return `href="/assets/${filename}"`;
+  });
+
+  // Update asset manifest
+  if (discoveredAssets.length > 0) {
+    const existing = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+    const assets = existing ? [...existing.assets, ...discoveredAssets] : [...discoveredAssets];
+    ctx.data.set('asset-manifest', { assets });
+  }
+
+  return { ...file, content };
+}
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent,
+    },
+  };
+}
