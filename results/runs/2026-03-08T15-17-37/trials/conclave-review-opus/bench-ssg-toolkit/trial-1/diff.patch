 slug: 'post-1', title: 'Post 1', tags: ['javascript'] }),\n    52→    ];\n    53→    const ctx = makeCtx(files);\n    54→    await plugin.hooks.beforeBuild!(ctx);\n    55→    await plugin.hooks.afterBuild!(ctx);\n    56→    expect(ctx.output.has('tags/javascript.html')).toBe(true);\n    57→    expect(ctx.output.get('tags/javascript.html')).toContain('Post 1');\n    58→  });\n    59→\n    60→  it('handles files with no tags', async () => {\n    61→    const files = [\n    62→      makeFile({ slug: 'post-1', title: 'Post 1' }),\n    63→    ];\n    64→    const ctx = makeCtx(files);\n    65→    await plugin.hooks.beforeBuild!(ctx);\n    66→    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    67→    expect(tagMap.size).toBe(0);\n    68→  });\n    69→\n    70→  it('handles files with multiple tags', async () => {\n    71→    const files = [\n    72→      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['js', 'node', 'web'] }),\n    73→    ];\n    74→    const ctx = makeCtx(files);\n    75→    await plugin.hooks.beforeBuild!(ctx);\n    76→    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    77→    expect(tagMap.size).toBe(3);\n    78→    expect(tagMap.has('js')).toBe(true);\n    79→    expect(tagMap.has('node')).toBe(true);\n    80→    expect(tagMap.has('web')).toBe(true);\n    81→  });\n    82→\n    83→  it('tag pages list all files with that tag', async () => {\n    84→    const files = [\n    85→      makeFile({ slug: 'post-1', title: 'First Post', tags: ['tech'] }),\n    86→      makeFile({ slug: 'post-2', title: 'Second Post', tags: ['tech'] }),\n    87→    ];\n    88→    const ctx = makeCtx(files);\n    89→    await plugin.hooks.beforeBuild!(ctx);\n    90→    await plugin.hooks.afterBuild!(ctx);\n    91→    const tagPage = ctx.output.get('tags/tech.html')!;\n    92→    expect(tagPage).toContain('First Post');\n    93→    expect(tagPage).toContain('Second Post');\n    94→  });\n    95→\n    96→  it('stores tag map in ctx.data', async () => {\n    97→    const files = [\n    98→      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['alpha'] }),\n    99→    ];\n   100→    const ctx = makeCtx(files);\n   101→    await plugin.hooks.beforeBuild!(ctx);\n   102→    expect(ctx.data.has('taxonomy-tags')).toBe(true);\n   103→  });\n   104→\n   105→  it('handles empty file list', async () => {\n   106→    const ctx = makeCtx([]);\n   107→    await plugin.hooks.beforeBuild!(ctx);\n   108→    await plugin.hooks.afterBuild!(ctx);\n   109→    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n   110→    expect(tagMap.size).toBe(0);\n   111→  });\n   112→\n   113→  it('tags are case-normalized to lowercase', async () => {\n   114→    const files = [\n   115→      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['JavaScript'] }),\n   116→      makeFile({ slug: 'post-2', title: 'Post 2', tags: ['JAVASCRIPT'] }),\n   117→    ];\n   118→    const ctx = makeCtx(files);\n   119→    await plugin.hooks.beforeBuild!(ctx);\n   120→    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n   121→    expect(tagMap.has('javascript')).toBe(true);\n   122→    expect(tagMap.get('javascript')).toHaveLength(2);\n   123→    expect(tagMap.has('JavaScript')).toBe(false);\n   124→    expect(tagMap.has('JAVASCRIPT')).toBe(false);\n   125→  });\n   126→});\n   127→"}]},"parent_tool_use_id":"toolu_01N8a5rs3rDb61meKNgmWNfx","session_id":"564c26e2-ad17-491e-9d10-f6e4f67df875","uuid":"d821f2d4-385a-4b05-ba95-55db6ae4917e"}
