, async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<title>Test Site</title>');\n  });\n\n  it('feed items sorted by date newest first', async () => {\n    const files = [\n      makeFile({ slug: 'old', title: 'Old Post', date: '2023-01-01' }),\n      makeFile({ slug: 'new', title: 'New Post', date: '2024-06-15' }),\n      makeFile({ slug: 'mid', title: 'Mid Post', date: '2024-01-01' }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    const newIdx = feed.indexOf('New Post');\n    const midIdx = feed.indexOf('Mid Post');\n    const oldIdx = feed.indexOf('Old Post');\n    expect(newIdx).toBeLessThan(midIdx);\n    expect(midIdx).toBeLessThan(oldIdx);\n  });\n\n  it('handles files without dates', async () => {\n    const files = [\n      makeFile({ slug: 'no-date', title: 'No Date Post', content: '<p>No date</p>' }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('No Date Post');\n    expect(feed).not.toContain('<pubDate>undefined</pubDate>');\n  });\n\n  it('feed link uses baseUrl from config', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<link>https://example.com</link>');\n    expect(feed).toContain('<link>https://example.com/post-1.html</link>');\n  });\n});\n","numLines":121,"startLine":1,"totalLines":121}}}
