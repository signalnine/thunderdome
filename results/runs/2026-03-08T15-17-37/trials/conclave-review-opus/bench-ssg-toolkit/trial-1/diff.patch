+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015r9YAgYV9bd35kriHDsFPS","type":"tool_result","content":"     1→import { Plugin, BuildContext } from '../core/types.js';\n     2→\n     3→function escapeXml(str: string): string {\n     4→  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\"/g, '&quot;');\n     5→}\n     6→\n     7→function afterBuild(ctx: BuildContext): void {\n     8→  const { config, files } = ctx;\n     9→\n    10→  // Sort files by date, newest first. Files without dates go last.\n    11→  const sorted = [...files].sort((a, b) => {\n    12→    if (!a.date && !b.date) return 0;\n    13→    if (!a.date) return 1;\n    14→    if (!b.date) return -1;\n    15→    return new Date(b.date).getTime() - new Date(a.date).getTime();\n    16→  });\n    17→\n    18→  const items = sorted.map(file => {\n    19→    const categories = file.tags\n    20→      ? file.tags.map(tag => `      <category>${escapeXml(tag)}</category>`).join('\\n')\n    21→      : '';\n    22→\n    23→    const pubDate = file.date ? `      <pubDate>${file.date}</pubDate>\\n` : '';\n    24→\n    25→    return `    <item>\n    26→      <title>${escapeXml(file.title)}</title>\n    27→      <link>${config.baseUrl}/${file.slug}.html</link>\n    28→${pubDate}      <description><![CDATA[${file.content}]]></description>\n    29→${categories}\n    30→    </item>`;\n    31→  }).join('\\n');\n    32→\n    33→  const feed = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n    34→<rss version=\"2.0\">\n    35→  <channel>\n    36→    <title>${escapeXml(config.title)}</title>\n    37→    <link>${config.baseUrl}</link>\n    38→    <description>${escapeXml(config.title)} RSS Feed</description>\n    39→${items}\n    40→  </channel>\n    41→</rss>`;\n    42→\n    43→  ctx.output.set('feed.xml', feed);\n    44→}\n    45→\n    46→export function createRssFeedPlugin(): Plugin {\n    47→  return {\n    48→    name: 'rss-feed',\n    49→    version: '1.0.0',\n    50→    dependencies: ['markdown-ext', 'taxonomy'],\n    51→    hooks: {\n    52→      afterBuild,\n    53→    },\n    54→  };\n    55→}\n    56→"}]},"parent_tool_use_id":"toolu_01Xqem93UCdtBP56VBP7gnzp","session_id":"564c26e2-ad17-491e-9d10-f6e4f67df875","uuid":"0a9466f0-813c-46e8-ab93-ec08dcdef9d5"}
