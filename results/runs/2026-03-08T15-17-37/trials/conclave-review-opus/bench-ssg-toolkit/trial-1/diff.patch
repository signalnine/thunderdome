ets/doc.pdf\"');\n    49→    expect(result.content).not.toContain('href=\"./doc.pdf\"');\n    50→  });\n    51→\n    52→  it('leaves absolute URLs unchanged', async () => {\n    53→    const file = makeFile({ content: '<img src=\"https://cdn.example.com/image.png\">' });\n    54→    const ctx = makeCtx();\n    55→    const result = await plugin.hooks.transformContent!(file, ctx);\n    56→    expect(result.content).toContain('src=\"https://cdn.example.com/image.png\"');\n    57→  });\n    58→\n    59→  it('generates asset manifest in ctx.data', async () => {\n    60→    const file = makeFile({ content: '<img src=\"./photo.jpg\">' });\n    61→    const ctx = makeCtx();\n    62→    await plugin.hooks.transformContent!(file, ctx);\n    63→    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    64→    expect(manifest).toBeDefined();\n    65→    expect(manifest.assets).toContain('photo.jpg');\n    66→  });\n    67→\n    68→  it('handles files with no asset references', async () => {\n    69→    const file = makeFile({ content: '<p>No assets here</p>' });\n    70→    const ctx = makeCtx();\n    71→    const result = await plugin.hooks.transformContent!(file, ctx);\n    72→    expect(result.content).toBe('<p>No assets here</p>');\n    73→  });\n    74→\n    75→  it('handles multiple assets in one file', async () => {\n    76→    const file = makeFile({\n    77→      content: '<img src=\"./a.png\"><img src=\"./b.jpg\"><a href=\"./c.pdf\">link</a>',\n    78→    });\n    79→    const ctx = makeCtx();\n    80→    await plugin.hooks.transformContent!(file, ctx);\n    81→    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    82→    expect(manifest.assets).toContain('a.png');\n    83→    expect(manifest.assets).toContain('b.jpg');\n    84→    expect(manifest.assets).toContain('c.pdf');\n    85→  });\n    86→\n    87→  it('asset manifest includes all discovered assets', async () => {\n    88→    const ctx = makeCtx();\n    89→    const file1 = makeFile({ content: '<img src=\"./one.png\">' });\n    90→    const file2 = makeFile({ content: '<img src=\"./two.png\">' });\n    91→    await plugin.hooks.transformContent!(file1, ctx);\n    92→    await plugin.hooks.transformContent!(file2, ctx);\n    93→    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    94→    expect(manifest.assets).toHaveLength(2);\n    95→    expect(manifest.assets).toContain('one.png');\n    96→    expect(manifest.assets).toContain('two.png');\n    97→  });\n    98→\n    99→  it('does not double-process already-rewritten URLs', async () => {\n   100→    const file = makeFile({ content: '<img src=\"/assets/image.png\">' });\n   101→    const ctx = makeCtx();\n   102→    const result = await plugin.hooks.transformContent!(file, ctx);\n   103→    expect(result.content).toBe('<img src=\"/assets/image.png\">');\n   104→    const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;\n   105→    expect(!manifest || manifest.assets.length === 0).toBe(true);\n   106→  });\n   107→});\n   108→"}]},"parent_tool_use_id":null,"session_id":"564c26e2-ad17-491e-9d10-f6e4f67df875","uuid":"4fcb0ad4-5b2b-4401-9500-1b8e2d7aab1d","tool_use_result":{"type":"text","file":{"filePath":"/workspace/tests/plugins/asset-pipeline.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { createAssetPipelinePlugin } from '../../src/plugins/asset-pipeline.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: new Map(),\n    assets: new Map(),\n    data: new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('asset-pipeline plugin', () => {\n  const plugin = createAssetPipelinePlugin();\n\n  it('rewrites relative image URLs to /assets/ path', async () => {\n    const file = makeFile({ content: '<img src=\"./image.png\" alt=\"test\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('src=\"/assets/image.png\"');\n    expect(result.content).not.toContain('src=\"./image.png\"');\n  });\n\n  it('rewrites relative link URLs to /assets/ path', async () => {\n    const file = makeFile({ content: '<a href=\"./doc.pdf\">Download</a>' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('href=\"/assets/doc.pdf\"');\n    expect(result.content).not.toContain('href=\"./doc.pdf\"');\n  });\n\n  it('leaves absolute URLs unchanged', async () => {\n    const file = makeFile({ content: '<img src=\"https://cdn.example.com/image.png\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('src=\"https://cdn.example.com/image.png\"');\n  });\n\n  it('generates asset manifest in ctx.data', async () => {\n    const file = makeFile({ content: '<img src=\"./photo.jpg\">' });\n    const ctx = makeCtx();\n    await plugin.hooks.transformContent!(file, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest).toBeDefined();\n    expect(manifest.assets).toContain('photo.jpg');\n  });\n\n  it('handles files with no asset references', async () => {\n    const file = makeFile({ content: '<p>No assets here</p>' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toBe('<p>No assets here</p>');\n  });\n\n  it('handles multiple assets in one file', async () => {\n    const file = makeFile({\n      content: '<img src=\"./a.png\"><img src=\"./b.jpg\"><a href=\"./c.pdf\">link</a>',\n    });\n    const ctx = makeCtx();\n    await plugin.hooks.transformContent!(file, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest.assets).toContain('a.png');\n    expect(manifest.assets).toContain('b.jpg');\n    expect(manifest.assets).toContain('c.pdf');\n  });\n\n  it('asset manifest includes all discovered assets', async () => {\n    const ctx = makeCtx();\n    const file1 = makeFile({ content: '<img src=\"./one.png\">' });\n    const file2 = makeFile({ content: '<img src=\"./two.png\">' });\n    await plugin.hooks.transformContent!(file1, ctx);\n    await plugin.hooks.transformContent!(file2, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest.assets).toHaveLength(2);\n    expect(manifest.assets).toContain('one.png');\n    expect(manifest.assets).toContain('two.png');\n  });\n\n  it('does not double-process already-rewritten URLs', async () => {\n    const file = makeFile({ content: '<img src=\"/assets/image.png\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toBe('<img src=\"/assets/image.png\">');\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;\n    expect(!manifest || manifest.assets.length === 0).toBe(true);\n  });\n});\n","numLines":108,"startLine":1,"totalLines":108}}}
