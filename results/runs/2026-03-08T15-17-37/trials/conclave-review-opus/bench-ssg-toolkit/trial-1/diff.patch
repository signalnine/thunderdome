+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0161VeZihnMWmgpRJ58rpkWy","type":"tool_result","content":"     1→import { Plugin, BuildContext } from '../core/types.js';\n     2→\n     3→function afterBuild(ctx: BuildContext): void {\n     4→  const { config, output } = ctx;\n     5→\n     6→  const urls: string[] = [];\n     7→\n     8→  // Collect all output pages (including tag pages and feed.xml)\n     9→  for (const path of output.keys()) {\n    10→    if (path === 'sitemap.xml') continue; // don't include itself\n    11→    urls.push(`${config.baseUrl}/${path}`);\n    12→  }\n    13→\n    14→  const urlEntries = urls\n    15→    .map(url => `  <url>\\n    <loc>${url}</loc>\\n  </url>`)\n    16→    .join('\\n');\n    17→\n    18→  const sitemap = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n    19→<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n    20→${urlEntries}\n    21→</urlset>`;\n    22→\n    23→  ctx.output.set('sitemap.xml', sitemap);\n    24→}\n    25→\n    26→export function createSitemapPlugin(): Plugin {\n    27→  return {\n    28→    name: 'sitemap',\n    29→    version: '1.0.0',\n    30→    dependencies: ['taxonomy', 'rss-feed'],\n    31→    hooks: {\n    32→      afterBuild,\n    33→    },\n    34→  };\n    35→}\n    36→"}]},"parent_tool_use_id":"toolu_01Xqem93UCdtBP56VBP7gnzp","session_id":"564c26e2-ad17-491e-9d10-f6e4f67df875","uuid":"ef359f18-8073-4ed7-b757-e819daeaf970"}
