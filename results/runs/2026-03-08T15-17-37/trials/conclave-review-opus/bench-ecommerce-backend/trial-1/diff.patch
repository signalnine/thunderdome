, currentQuantity: current, threshold };\n        void bus.emit(Events.LOW_STOCK_ALERT, alert);\n      }\n    }\n  }\n\n  function emitUpdated(productId: string): void {\n    const quantity = stock.get(productId) ?? 0;\n    const event: InventoryUpdatedEvent = { productId, quantity };\n    void bus.emit(Events.INVENTORY_UPDATED, event);\n  }\n\n  return {\n    setStock(productId: string, quantity: number): void {\n      stock.set(productId, quantity);\n      emitUpdated(productId);\n      checkLowStock(productId);\n    },\n\n    getStock(productId: string): number {\n      return getAvailable(productId);\n    },\n\n    reserve(productId: string, quantity: number): boolean {\n      const available = getAvailable(productId);\n      if (available < quantity) return false;\n      reserved.set(productId, (reserved.get(productId) ?? 0) + quantity);\n      return true;\n    },\n\n    release(productId: string, quantity: number): void {\n      const current = reserved.get(productId) ?? 0;\n      reserved.set(productId, Math.max(0, current - quantity));\n    },\n\n    setLowStockThreshold(productId: string, threshold: number): void {\n      thresholds.set(productId, threshold);\n      checkLowStock(productId);\n    },\n  };\n}\n","structuredPatch":[{"oldStart":13,"oldLines":7,"newStart":13,"newLines":7,"lines":["   function checkLowStock(productId: string): void {","     const threshold = thresholds.get(productId);","     if (threshold !== undefined) {","-      const current = stock.get(productId) ?? 0;","+      const current = getAvailable(productId);","       if (current <= threshold) {","         const alert: LowStockAlertEvent = { productId, currentQuantity: current, threshold };","         void bus.emit(Events.LOW_STOCK_ALERT, alert);"]}],"userModified":false,"replaceAll":false}}
