rvice(bus);\n    const id = catalog.createProduct('Old', 5, 'cat');\n    catalog.updateProduct(id, { name: 'New', price: 10 });\n    const p = catalog.getProduct(id);\n    expect(p?.name).toBe('New');\n    expect(p?.price).toBe(10);\n    expect(p?.category).toBe('cat');\n  });\n\n  it('should remove a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('X', 5, 'cat');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct(id)).toBe(false);\n  });\n\n  it('should emit product:created event', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Test', 5, 'cat');\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PRODUCT_CREATED)).toBe(true);\n  });\n});\n\ndescribe('InventoryService', () => {\n  it('should set and get stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 100);\n    expect(inv.getStock('p1')).toBe(100);\n  });\n\n  it('should reserve and release stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 10);\n    expect(inv.reserve('p1', 5)).toBe(true);\n    expect(inv.getStock('p1')).toBe(5);\n    expect(inv.reserve('p1', 6)).toBe(false);\n    inv.release('p1', 3);\n    expect(inv.getStock('p1')).toBe(8);\n  });\n\n  it('should detect low stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 100);\n    inv.setLowStockThreshold('p1', 5);\n    inv.setStock('p1', 3);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.LOW_STOCK_ALERT)).toBe(true);\n  });\n\n  it('should emit low stock alert when threshold set on already low stock', () => {\n    const inv = createInventoryService(bus);\n    inv.setStock('p1', 2);\n    inv.setLowStockThreshold('p1', 5);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.LOW_STOCK_ALERT)).toBe(true);\n  });\n});\n\ndescribe('CartService', () => {\n  it('should create and get cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    const c = cart.getCart(id);\n    expect(c).toEqual({ id, userId: 'user1', items: [] });\n  });\n\n  it('should add items and consolidate duplicates', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c?.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n  });\n\n  it('should remove items', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    expect(cart.getCart(id)?.items).toEqual([{ productId: 'p2', quantity: 1 }]);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    expect(cart.getCart(id)?.items).toEqual([{ productId: 'p1', quantity: 10 }]);\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    expect(cart.getCart(id)?.items).toEqual([]);\n  });\n\n  it('should return null for unknown cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nope')).toBeNull();\n  });\n});\n\ndescribe('PricingService', () => {\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10',\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // 10% of 90\n    expect(result.total).toBe(99);\n  });\n\n  it('should track prices from product:created events', () => {\n    const pricing = createPricingService(bus);\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Test', 42, 'cat');\n    expect(pricing.getPrice(id)).toBe(42);\n  });\n\n  it('should ignore unknown discount codes', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'UNKNOWN',\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n});\n\ndescribe('OrderService', () => {\n  it('should create an order in pending state', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    const order = orders.getOrder(id);\n    expect(order?.status).toBe(OrderStatus.PENDING);\n    expect(order?.total).toBe(50);\n  });\n\n  it('should update order status with previous status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CONFIRMED);\n\n    const log = bus.getLog();\n    const statusEvent = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(statusEvent).toBeDefined();\n    const payload = statusEvent?.payload as { previousStatus: string; status: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n    expect(payload.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should list orders by user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'c1', 10);\n    orders.createOrder('user2', 'c2', 20);\n    orders.createOrder('user1', 'c3', 30);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for unknown order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nope')).toBeNull();\n  });\n\n  it('should emit order:created event', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 50);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.ORDER_CREATED)).toBe(true);\n  });\n\n  it('should cancel an order', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CANCELLED);\n  });\n});\n\ndescribe('PaymentService', () => {\n  it('should process successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(await payment.refund(result.transactionId!)).toBe(true);\n  });\n\n  it('should not refund unknown transaction', async () => {\n    const payment = createPaymentService(bus);\n    expect(await payment.refund('unknown')).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('NotificationService', () => {\n  it('should record notifications for subscribed users on order creation', () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    notifications.subscribe('user1');\n    orders.createOrder('user1', 'cart1', 50);\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n    expect(notifs[0].type).toBe('order_created');\n  });\n\n  it('should not notify unsubscribed users', () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 50);\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n\n  it('should notify on order status change', () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    notifications.subscribe('user1');\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should notify on payment processed', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    await payment.processPayment(orderId, 50);\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  it('should count events by type', () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat');\n    catalog.createProduct('B', 2, 'cat');\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not count failed payments as revenue', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n    const cartId1 = cart.createCart('user1');\n    cart.addItem(cartId1, 'p1', 1);\n    const cartId2 = cart.createCart('user2');\n    cart.addItem(cartId2, 'p2', 1);\n    orders.createOrder('user1', cartId1, 10);\n    // 1 order / 2 unique carts = 0.5\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should rank top products', () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 5);\n    cart.addItem(cartId, 'p2', 3);\n    orders.createOrder('user1', cartId, 80);\n\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(3);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n});\n\ndescribe('Integration: full order flow', () => {\n  it('should handle a complete purchase flow', async () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n\n    // Subscribe user\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29, 'accessories');\n\n    // Set inventory\n    inventory.setStock(p1, 10);\n    inventory.setStock(p2, 50);\n\n    // Set low stock threshold\n    inventory.setLowStockThreshold(p1, 2);\n\n    // Create cart\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, p1, 1);\n    cartService.addItem(cartId, p2, 2);\n\n    // Calculate price\n    pricing.addDiscountCode('SAVE20', 20);\n    const cartData = cartService.getCart(cartId)!;\n    const items = cartData.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const priceResult = pricing.calculateTotal(items, 'SAVE20');\n\n    // Reserve stock\n    expect(inventory.reserve(p1, 1)).toBe(true);\n    expect(inventory.reserve(p2, 2)).toBe(true);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, priceResult.total);\n    expect(orders.getOrder(orderId)?.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const payResult = await payment.processPayment(orderId, priceResult.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Confirm order\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(orderId)?.status).toBe(OrderStatus.CONFIRMED);\n\n    // Ship order\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n\n    // Deliver order\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n    expect(orders.getOrder(orderId)?.status).toBe(OrderStatus.DELIVERED);\n\n    // Check notifications\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(4); // order_created + payment + 3 status changes\n\n    // Check analytics\n    expect(analytics.getRevenue()).toBe(priceResult.total);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getConversionRate()).toBe(1); // 1 order / 1 cart\n\n    const topProducts = analytics.getTopProducts(5);\n    expect(topProducts.length).toBeGreaterThan(0);\n  });\n});\n"}}
