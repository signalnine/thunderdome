@@ -0,0 +1,106 @@
+import * as fs from "node:fs";
+import * as path from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  startTime: string;
+  endTime: string | null;
+}
+
+interface StorageData {
+  entries: TimeEntry[];
+}
+
+export interface TimeTrackerOptions {
+  filePath: string;
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(options: TimeTrackerOptions) {
+    this.filePath = path.resolve(options.filePath);
+    this.entries = [];
+    this.load();
+  }
+
+  private load(): void {
+    try {
+      const raw = fs.readFileSync(this.filePath, "utf-8");
+      const data: StorageData = JSON.parse(raw);
+      this.entries = data.entries;
+    } catch {
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    const data: StorageData = { entries: this.entries };
+    fs.writeFileSync(this.filePath, JSON.stringify(data, null, 2), "utf-8");
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    const running = this.getRunningEntry();
+    if (running) {
+      running.endTime = new Date().toISOString();
+    }
+
+    this.entries.push({
+      task,
+      startTime: new Date().toISOString(),
+      endTime: null,
+    });
+    this.save();
+  }
+
+  stop(): void {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+    running.endTime = new Date().toISOString();
+    this.save();
+  }
+
+  getEntries(filter?: { from?: Date; to?: Date }): TimeEntry[] {
+    if (!filter) {
+      return [...this.entries];
+    }
+
+    return this.entries.filter((entry) => {
+      const start = new Date(entry.startTime);
+      if (filter.from && start < filter.from) {
+        return false;
+      }
+      if (filter.to && start > filter.to) {
+        return false;
+      }
+      return true;
+    });
+  }
+
+  getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+    const now = Date.now();
+
+    for (const entry of this.entries) {
+      const start = new Date(entry.startTime).getTime();
+      const end = entry.endTime ? new Date(entry.endTime).getTime() : now;
+      const duration = end - start;
+      summary[entry.task] = (summary[entry.task] ?? 0) + duration;
+    }
+
+    return summary;
+  }
+
+  private getRunningEntry(): TimeEntry | undefined {
+    return this.entries.find((e) => e.endTime === null);
+  }
+}
