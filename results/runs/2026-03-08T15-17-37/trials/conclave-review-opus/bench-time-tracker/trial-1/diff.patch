@@ -0,0 +1,184 @@
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import * as fs from "node:fs";
+import * as path from "node:path";
+import * as os from "node:os";
+import { TimeTracker } from "./tracker.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "tracker-test-"));
+  return path.join(dir, "data.json");
+}
+
+function cleanup(filePath: string): void {
+  try {
+    fs.rmSync(path.dirname(filePath), { recursive: true, force: true });
+  } catch {
+    // ignore
+  }
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    cleanup(filePath);
+  });
+
+  describe("start and stop", () => {
+    it("should start a timer and stop it", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("coding");
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+      expect(entries[0].endTime).toBeNull();
+
+      tracker.stop();
+      const after = tracker.getEntries();
+      expect(after[0].endTime).not.toBeNull();
+    });
+
+    it("should auto-stop previous timer when starting a new one", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].endTime).not.toBeNull();
+      expect(entries[1].endTime).toBeNull();
+    });
+
+    it("should throw when starting with empty name", () => {
+      const tracker = new TimeTracker({ filePath });
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw when stopping with nothing running", () => {
+      const tracker = new TimeTracker({ filePath });
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to file and reload", () => {
+      const tracker1 = new TimeTracker({ filePath });
+      tracker1.start("reading");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker({ filePath });
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("reading");
+    });
+
+    it("should create parent directories if they don't exist", () => {
+      const deepPath = path.join(
+        os.tmpdir(),
+        `tracker-test-${Date.now()}`,
+        "a",
+        "b",
+        "data.json"
+      );
+      const tracker = new TimeTracker({ filePath: deepPath });
+      tracker.start("nested");
+      tracker.stop();
+
+      expect(fs.existsSync(deepPath)).toBe(true);
+      fs.rmSync(path.join(os.tmpdir(), `tracker-test-${Date.now()}`), {
+        recursive: true,
+        force: true,
+      });
+    });
+  });
+
+  describe("querying entries", () => {
+    it("should return all entries without filter", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("a");
+      tracker.start("b");
+      tracker.stop();
+
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter by date range", () => {
+      const tracker = new TimeTracker({ filePath });
+
+      const now = new Date();
+      tracker.start("before");
+      tracker.stop();
+
+      const entries = tracker.getEntries({
+        from: new Date(now.getTime() - 1000),
+        to: new Date(now.getTime() + 60000),
+      });
+      expect(entries).toHaveLength(1);
+
+      const noEntries = tracker.getEntries({
+        from: new Date(now.getTime() + 60000),
+      });
+      expect(noEntries).toHaveLength(0);
+    });
+  });
+
+  describe("summary", () => {
+    it("should summarize time per task", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("review");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(summary["review"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should use current time for running tasks", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("running");
+      const summary = tracker.getSummary();
+      expect(summary["running"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("日本語タスク");
+      tracker.stop();
+      tracker.start("🚀 deployment");
+      tracker.stop();
+      tracker.start("café break ☕");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(3);
+      expect(entries[0].task).toBe("日本語タスク");
+      expect(entries[1].task).toBe("🚀 deployment");
+      expect(entries[2].task).toBe("café break ☕");
+
+      const summary = tracker.getSummary();
+      expect("日本語タスク" in summary).toBe(true);
+      expect("🚀 deployment" in summary).toBe(true);
+      expect("café break ☕" in summary).toBe(true);
+    });
+
+    it("should persist and reload unicode names", () => {
+      const tracker1 = new TimeTracker({ filePath });
+      tracker1.start("🎯 目標");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker({ filePath });
+      expect(tracker2.getEntries()[0].task).toBe("🎯 目標");
+    });
+  });
+});
