imination over GF(2) with full row reduction (RREF)\n  const pivotCol: number[] = [];\n  let pivotRow = 0;\n\n  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {\n    let found = -1;\n    for (let row = pivotRow; row < numLights; row++) {\n      if (matrix[row][col] === 1) { found = row; break; }\n    }\n    if (found === -1) continue;\n\n    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];\n    pivotCol.push(col);\n\n    for (let row = 0; row < numLights; row++) {\n      if (row !== pivotRow && matrix[row][col] === 1) {\n        for (let c = 0; c <= numButtons; c++) {\n          matrix[row][c] ^= matrix[pivotRow][c];\n        }\n      }\n    }\n    pivotRow++;\n  }\n\n  const rank = pivotRow;\n\n  // Check for inconsistency\n  for (let row = rank; row < numLights; row++) {\n    if (matrix[row][numButtons] === 1) return null;\n  }\n\n  // Identify free variables\n  const pivotVarSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (!pivotVarSet.has(j)) freeVars.push(j);\n  }\n  const numFree = freeVars.length;\n\n  // Compute solution as bigint given free variable assignment as bigint mask\n  function solutionFromFreeMask(freeMask: number): bigint {\n    let result = 0n;\n    for (let i = 0; i < numFree; i++) {\n      if (freeMask & (1 << i)) result |= (1n << BigInt(freeVars[i]));\n    }\n    for (let r = rank - 1; r >= 0; r--) {\n      const col = pivotCol[r];\n      let val = matrix[r][numButtons];\n      for (let c = col + 1; c < numButtons; c++) {\n        if (matrix[r][c] === 1) {\n          val ^= Number((result >> BigInt(c)) & 1n);\n        }\n      }\n      if (val) result |= (1n << BigInt(col));\n    }\n    return result;\n  }\n\n  const particularBig = solutionFromFreeMask(0);\n\n  // Compute null basis vectors\n  const nullBasisBig: bigint[] = [];\n  for (let i = 0; i < numFree; i++) {\n    nullBasisBig.push(solutionFromFreeMask(1 << i) ^ particularBig);\n  }\n\n  function popcount(x: bigint): number {\n    let count = 0;\n    while (x > 0n) { x &= (x - 1n); count++; }\n    return count;\n  }\n\n  function toButtonArray(x: bigint): number[] {\n    const result: number[] = [];\n    for (let i = 0; i < numButtons; i++) {\n      if (x & (1n << BigInt(i))) result.push(i);\n    }\n    return result;\n  }\n\n  // Compare two solutions: return true if a is strictly better (fewer presses, then lex smaller)\n  function isBetter(a: bigint, aWeight: number, b: bigint, bWeight: number): boolean {\n    if (aWeight !== bWeight) return aWeight < bWeight;\n    const diff = a ^ b;\n    if (diff === 0n) return false;\n    const lowestDiff = diff & (-diff);\n    return (a & lowestDiff) !== 0n;\n  }\n\n  if (numFree === 0) {\n    return toButtonArray(particularBig);\n  }\n\n  let bestSol = particularBig;\n  let bestWeight = popcount(particularBig);\n\n  if (numFree <= 24) {\n    // Direct enumeration: O(2^numFree)\n    for (let mask = 1; mask < (1 << numFree); mask++) {\n      let delta = 0n;\n      for (let i = 0; i < numFree; i++) {\n        if (mask & (1 << i)) delta ^= nullBasisBig[i];\n      }\n      const sol = particularBig ^ delta;\n      const w = popcount(sol);\n      if (isBetter(sol, w, bestSol, bestWeight)) {\n        bestSol = sol;\n        bestWeight = w;\n      }\n    }\n    return toButtonArray(bestSol);\n  }\n\n  // For > 24 free vars: meet-in-the-middle with two halves\n  // Each half has at most 20 free vars -> 2^20 = ~1M entries\n  // We build a list for the first half, then for each second half entry,\n  // iterate all first half entries. Total: 2^half1 * 2^half2 = 2^numFree.\n  // This is only feasible if numFree <= ~30 (2^30 = 1B iterations with simple ops).\n  //\n  // For numFree up to 30: half1=15, half2=15: 2^15 * 2^15 = 2^30 ~ 1B. Tight for 5 seconds.\n  // For numFree up to 40: half1=20, half2=20: 2^20 * 2^20 = 2^40. Not feasible.\n  //\n  // For truly large numFree (> 30), use greedy + local search.\n\n  if (numFree <= 30) {\n    const half1 = Math.floor(numFree / 2);\n    const half2 = numFree - half1;\n\n    // Build first-half deltas\n    const firstHalfDeltas: bigint[] = new Array(1 << half1);\n    firstHalfDeltas[0] = 0n;\n    for (let mask = 1; mask < (1 << half1); mask++) {\n      // Find the lowest set bit\n      const lsb = mask & (-mask);\n      const lsbIdx = 31 - Math.clz32(lsb);\n      firstHalfDeltas[mask] = firstHalfDeltas[mask ^ lsb] ^ nullBasisBig[lsbIdx];\n    }\n\n    // Enumerate all second-half deltas\n    const secondHalfDeltas: bigint[] = new Array(1 << half2);\n    secondHalfDeltas[0] = 0n;\n    for (let mask = 1; mask < (1 << half2); mask++) {\n      const lsb = mask & (-mask);\n      const lsbIdx = 31 - Math.clz32(lsb);\n      secondHalfDeltas[mask] = secondHalfDeltas[mask ^ lsb] ^ nullBasisBig[half1 + lsbIdx];\n    }\n\n    for (let mask2 = 0; mask2 < (1 << half2); mask2++) {\n      const partial = particularBig ^ secondHalfDeltas[mask2];\n      for (let mask1 = 0; mask1 < (1 << half1); mask1++) {\n        const sol = partial ^ firstHalfDeltas[mask1];\n        const w = popcount(sol);\n        if (isBetter(sol, w, bestSol, bestWeight)) {\n          bestSol = sol;\n          bestWeight = w;\n        }\n      }\n    }\n\n    return toButtonArray(bestSol);\n  }\n\n  // For very large numFree (> 30): greedy + local search\n  // This is a heuristic that may not find the optimal solution,\n  // but should work well for practical cases.\n  let currentDelta = 0n;\n  for (let i = 0; i < numFree; i++) {\n    const withFlip = particularBig ^ currentDelta ^ nullBasisBig[i];\n    const without = particularBig ^ currentDelta;\n    if (popcount(withFlip) < popcount(without)) {\n      currentDelta ^= nullBasisBig[i];\n    }\n  }\n  bestSol = particularBig ^ currentDelta;\n  bestWeight = popcount(bestSol);\n\n  // Local search: flip each free var and see if it helps\n  let improved = true;\n  while (improved) {\n    improved = false;\n    for (let i = 0; i < numFree; i++) {\n      const flipped = bestSol ^ nullBasisBig[i];\n      const w = popcount(flipped);\n      if (isBetter(flipped, w, bestSol, bestWeight)) {\n        bestSol = flipped;\n        bestWeight = w;\n        improved = true;\n      }\n    }\n  }\n\n  // Try pairs of flips\n  for (let i = 0; i < numFree; i++) {\n    for (let j = i + 1; j < numFree; j++) {\n      const flipped = bestSol ^ nullBasisBig[i] ^ nullBasisBig[j];\n      const w = popcount(flipped);\n      if (isBetter(flipped, w, bestSol, bestWeight)) {\n        bestSol = flipped;\n        bestWeight = w;\n        improved = true;\n      }\n    }\n    if (improved) {\n      // Restart single-flip local search\n      improved = true;\n      while (improved) {\n        improved = false;\n        for (let k = 0; k < numFree; k++) {\n          const flipped = bestSol ^ nullBasisBig[k];\n          const w = popcount(flipped);\n          if (isBetter(flipped, w, bestSol, bestWeight)) {\n            bestSol = flipped;\n            bestWeight = w;\n            improved = true;\n          }\n        }\n      }\n      // Continue pair search\n      improved = false;\n    }\n  }\n\n  return toButtonArray(bestSol);\n}\n\n/**\n * Solve the counter puzzle using Gaussian elimination over GF(p).\n * Find minimum total presses, breaking ties by lexicographic order of the result array.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numLights = lights.length;\n  const numButtons = buttons.length;\n\n  if (numButtons === 0) {\n    return lights.every(v => ((v % modulus) + modulus) % modulus === 0) ? [] : null;\n  }\n\n  // Build augmented matrix over GF(p)\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n  for (let j = 0; j < numButtons; j++) {\n    for (const lig