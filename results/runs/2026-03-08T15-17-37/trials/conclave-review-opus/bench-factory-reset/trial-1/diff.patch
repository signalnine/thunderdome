, pivotCol, freeVars, numButtons, numFree, modulus);\n  }\n}\n\nfunction enumSolveGFp(\n  computeSolution: (freeAssignment: number[]) => number[],\n  numButtons: number,\n  numFree: number,\n  modulus: number,\n  _freeVars: number[]\n): number[] | null {\n  let bestSolution: number[] | null = null;\n  let bestSum = Infinity;\n\n  const freeAssignment = new Array(numFree).fill(0);\n\n  function enumerate(idx: number): void {\n    if (idx === numFree) {\n      const sol = computeSolution(freeAssignment);\n      const sum = sol.reduce((a, b) => a + b, 0);\n      if (sum < bestSum || (sum === bestSum && lexSmallerArr(sol, bestSolution!))) {\n        bestSum = sum;\n        bestSolution = [...sol];\n      }\n      return;\n    }\n    for (let v = 0; v < modulus; v++) {\n      freeAssignment[idx] = v;\n      enumerate(idx + 1);\n    }\n  }\n\n  enumerate(0);\n  return bestSolution;\n}\n\nfunction meetInMiddleSolveGFp(\n  matrix: number[][],\n  rank: number,\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  numFree: number,\n  modulus: number\n): number[] | null {\n  // Compute particular solution and null basis\n  function computeSolution(freeAssignment: number[]): number[] {\n    const solution = new Array(numButtons).fill(0);\n    for (let i = 0; i < numFree; i++) {\n      solution[freeVars[i]] = freeAssignment[i];\n    }\n    for (let r = rank - 1; r >= 0; r--) {\n      const col = pivotCol[r];\n      let val = matrix[r][numButtons];\n      for (let c = col + 1; c < numButtons; c++) {\n        if (matrix[r][c] !== 0) {\n          val = ((val - matrix[r][c] * solution[c]) % modulus + modulus) % modulus;\n        }\n      }\n      solution[col] = val;\n    }\n    return solution;\n  }\n\n  // Compute null basis vectors\n  const nullBasis: number[][] = [];\n  const zeroAssign = new Array(numFree).fill(0);\n  const particular = computeSolution(zeroAssign);\n\n  for (let i = 0; i < numFree; i++) {\n    const assignment = new Array(numFree).fill(0);\n    assignment[i] = 1;\n    const withFree = computeSolution(assignment);\n    const diff = new Array(numButtons).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      diff[j] = ((withFree[j] - particular[j]) % modulus + modulus) % modulus;\n    }\n    nullBasis.push(diff);\n  }\n\n  // Split free vars into two halves for meet-in-the-middle\n  const half1 = Math.min(numFree, Math.floor(numFree / 2));\n  const half2 = numFree - half1;\n\n  // Enumerate first half\n  type Entry = { coeffs: number[]; sum: number; solution: number[] };\n\n  function enumHalf(start: number, count: number): Entry[] {\n    const entries: Entry[] = [];\n    const coeffs = new Array(count).fill(0);\n\n    function rec(idx: number, partialSol: number[]): void {\n      if (idx === count) {\n        const sum = partialSol.reduce((a, b) => a + b, 0);\n        entries.push({ coeffs: [...coeffs], sum, solution: [...partialSol] });\n        return;\n      }\n      for (let v = 0; v < modulus; v++) {\n        coeffs[idx] = v;\n        const newSol = new Array(numButtons).fill(0);\n        for (let j = 0; j < numButtons; j++) {\n          newSol[j] = (partialSol[j] + v * nullBasis[start + idx][j]) % modulus;\n        }\n        rec(idx + 1, newSol);\n      }\n    }\n\n    rec(0, new Array(numButtons).fill(0));\n    return entries;\n  }\n\n  const firstEntries = enumHalf(0, half1);\n\n  // Group first half entries by their solution vector (as a key)\n  // For each unique \"effect on solution\", keep only the one with min sum, then lex smallest\n  // Actually, for meet-in-the-middle, the full solution is:\n  // particular + firstDelta + secondDelta (mod p)\n  // We want to minimize sum(particular + firstDelta + secondDelta mod p)\n\n  // This is more complex than the GF(2) case because values aren't just 0/1.\n  // The sum depends on the actual values mod p.\n\n  // For modulus up to 97 and ~3-4 free vars per half, this is manageable.\n  // half1 entries: p^half1, half2 entries: p^half2.\n  // For each pair, compute solution and check sum. Total: p^numFree which we're trying to avoid.\n\n  // Alternative: group first half by the \"delta pattern\" and for each second half,\n  // find the best first half. But since we need to compute the full solution values\n  // to determine the sum (because adding mod p can change things), this requires\n  // looking at all combinations.\n\n  // Let's try a different approach: enumerate second half, and for each,\n  // find the best first half entry. We can pre-sort first half entries.\n\n  // Actually, we can precompute: for each first half entry, the partial solution\n  // (particular + firstDelta mod p), and store sum of that.\n  // For second half, compute the delta pattern. The full solution at position j is\n  // (particular[j] + firstDelta[j] + secondDelta[j]) % p.\n  // sum = sum_j (particular[j] + firstDelta[j] + secondDelta[j]) % p\n  // This depends on both deltas in a non-linear way (because of mod).\n\n  // With p^half1 * p^half2 = p^numFree total, this is what we're trying to avoid.\n  // But if half1 or half2 is small enough, we can enumerate one half and iterate.\n\n  // For p=97 and numFree=4: half1=2, half2=2. 97^2 = 9409 each. 9409 * 9409 = 88M.\n  // That's marginal but might work in 5 seconds.\n  // For numFree=5: 97^3 * 97^2 ~= 860M. Too slow.\n\n  // For larger cases, use greedy + local search (similar to toggle)\n  if (firstEntries.length * Math.pow(modulus, half2) > 50_000_000) {\n    return greedySolveGFp(particular, nullBasis, numButtons, numFree, modulus);\n  }\n\n  let bestSolution: number[] | null = null;\n  let bestSum = Infinity;\n\n  const secondCoeffs = new Array(half2).fill(0);\n\n  function enumSecond(idx: number, secondDelta: number[]): void {\n    if (idx === half2) {\n      // Try all first half entries\n      for (const entry of firstEntries) {\n        const sol = new Array(numButtons).fill(0);\n        let sum = 0;\n        for (let j = 0; j < numButtons; j++) {\n          sol[j] = (