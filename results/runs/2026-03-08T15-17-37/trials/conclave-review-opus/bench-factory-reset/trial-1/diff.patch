\n   206→    const baseAssignment = new Array(numFree).fill(0);\n   207→    const base = computeSolution(baseAssignment);\n   208→\n   209→    const diff = new Array(numButtons).fill(0);\n   210→    for (let j = 0; j < numButtons; j++) {\n   211→      diff[j] = withFree[j] ^ base[j];\n   212→    }\n   213→    nullBasis.push(diff);\n   214→  }\n   215→\n   216→  const particular = computeSolution(new Array(numFree).fill(0));\n   217→\n   218→  // For meet-in-the-middle: enumerate first half combinations, store by their\n   219→  // effect on the solution (as XOR with particular). Then enumerate second half\n   220→  // and find best combination.\n   221→\n   222→  // Actually, let's think differently. The full solution is:\n   223→  // solution = particular XOR (sum of selected null basis vectors)\n   224→  // We want to minimize the Hamming weight.\n   225→\n   226→  // First half: enumerate all 2^half1 XOR combinations of nullBasis[0..half1-1]\n   227→  // For each, compute the partial XOR pattern applied to `particular`\n   228→  // Store: for each pattern, the minimum weight contribution and the assignment\n   229→\n   230→  // This is the \"closest vector\" problem. Let me use a simpler approach:\n   231→  // We compute the XOR of the null space vectors with particular for all first-half combos,\n   232→  // then for each second-half combo, find the best first-half combo.\n   233→\n   234→  // Key insight: solution = particular XOR delta, where delta = XOR of selected null basis vectors\n   235→  // weight(solution) = popcount(particular XOR delta)\n   236→  // We want to minimize this.\n   237→\n   238→  // Represent particular and null basis as bigints for efficient XOR\n   239→  function toBigInt(arr: number[]): bigint {\n   240→    let result = 0n;\n   241→    for (let i = 0; i < arr.length; i++) {\n   242→      if (arr[i]) result |= (1n << BigInt(i));\n   243→    }\n   244→    return result;\n   245→  }\n   246→\n   247→  function popcount(x: bigint): numbe