t(result).toEqual([0, 0]);","+  });","+","+  it('should handle empty target with no buttons', () => {","+    const result = solveCounter([], [], 5);","+    expect(result).toEqual([]);","+  });","+","+  it('should find minimum sum with multiple free variables', () => {","+    // target: [1, 0], buttons: [[0], [0], [1]], modulus 3","+    // x0 + x1 ≡ 1 (mod 3), x2 ≡ 0 (mod 3)","+    // Minimize x0 + x1 + x2","+    // x2 = 0, and (x0+x1) mod 3 = 1","+    // Min sum of x0+x1 = 1 (e.g., x0=0,x1=1 or x0=1,x1=0)","+    // Lex smallest: [0, 1, 0]","+    const result = solveCounter([1, 0], [[0], [0], [1]], 3);","+    expect(result).toEqual([0, 1, 0]);","+    expect(verifyCounter([1, 0], [[0], [0], [1]], 3, result!)).toBe(true);","+  });"," });"]}],"originalFile":"import { describe, it, expect } from 'vitest';\nimport { solveToggle, solveCounter, Machine } from './index.js';\n\ndescribe('solveToggle', () => {\n  it('should return empty array when target is all off', () => {\n    const machine: Machine = {\n      target: [false, false, false],\n      buttons: [[0, 1], [1, 2]],\n    };\n    expect(solveToggle(machine)).toEqual([]);\n  });\n\n  it('should return null for the example in the spec', () => {\n    const machine: Machine = {\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]],\n    };\n    // From the spec: b1=0, b0=1, b2=0, but light 3: b1 XOR b2 = 0 != 1. No solution.\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('should solve a simple single button case', () => {\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0, 1]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('should find minimum presses', () => {\n    // Target: [true, false]. Buttons: [0] (toggles light 0), [0,1] (toggles both), [1] (toggles light 1)\n    // Press button 0 only -> [true, false] = target. 1 press.\n    // Press buttons 1,2 -> [true, true] XOR [false, true] = [true, false]. 2 presses.\n    // Minimum is 1 press: [0]\n    const machine: Machine = {\n      target: [true, false],\n      buttons: [[0], [0, 1], [1]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('should return lex smallest among ties', () => {\n    // Target: [true]. Two buttons both toggle light 0.\n    // Button 0 alone: [true]. Button 1 alone: [true]. Both: [false].\n    // Two solutions with 1 press: [0] and [1]. Lex smallest is [0].\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0], [0]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('should handle no buttons case', () => {\n    const machine: Machine = {\n      target: [true],\n      buttons: [],\n    };\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('should handle all-on target', () => {\n    const machine: Machine = {\n      target: [true, true, true],\n      buttons: [[0], [1], [2]],\n    };\n    expect(solveToggle(machine)).toEqual([0, 1, 2]);\n  });\n\n  it('should handle overlapping buttons', () => {\n    // target: [true, true]\n    // button 0: [0, 1] -> toggles both\n    // button 1: [0] -> toggles 0 only\n    // button 2: [1] -> toggles 1 only\n    // Solutions: {0} = [true, true] ✓ (1 press), {1,2} = [true, true] ✓ (2 presses)\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0, 1], [0], [1]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('should handle larger puzzle', () => {\n    // 5 lights, 5 buttons, identity-like setup\n    const machine: Machine = {\n      target: [true, false, true, false, true],\n      buttons: [[0], [1], [2], [3], [4]],\n    };\n    expect(solveToggle(machine)).toEqual([0, 2, 4]);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('should return all zeros when target is all zeros', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('should solve a simple single button case', () => {\n    // target: [3], button 0: [0], modulus 5\n    // Press button 0 three times -> counter 0 = 3\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('should return null when no solution exists', () => {\n    // target: [1], no buttons, modulus 5\n    const result = solveCounter([1], [], 5);\n    expect(result).toBeNull();\n  });\n\n  it('should handle wrapping', () => {\n    // target: [0], button 0: [0], modulus 5\n    // 0 presses gives 0. That's the minimum.\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('should find minimum total presses', () => {\n    // target: [4], button 0: [0], modulus 5\n    // Press 4 times: sum = 4\n    // Or press 0 times: counter = 0 != 4. No, must be 4.\n    // Since modulus=5, pressing 4 times gives 4. That's the only option.\n    const result = solveCounter([4], [[0]], 5);\n    expect(result).toEqual([4]);\n  });\n\n  it('should handle two buttons affecting same counter', () => {\n    // target: [2], buttons: [[0], [0]], modulus 5\n    // x0 + x1 ≡ 2 (mod 5)\n    // Minimize x0 + x1 with 0 ≤ x0, x1 ≤ 4\n    // Options: (0,2)=2, (1,1)=2, (2,0)=2, (3,4)=7, (4,3)=7\n    // Min sum = 2. Lex smallest among {(0,2), (1,1), (2,0)} is [0, 2]\n    const result = solveCounter([2], [[0], [0]], 5);\n    expect(result).toEqual([0, 2]);\n  });\n\n  it('should handle larger modulus', () => {\n    // target: [1], button 0: [0], modulus 97\n    const result = solveCounter([1], [[0]], 97);\n    expect(result).toEqual([1]);\n  });\n\n  it('should return null for impossible case', () => {\n    // target: [1, 0], buttons: [[0, 1]], modulus 3\n    // Pressing button 0 x times: counter 0 = x, counter 1 = x\n    // Need x ≡ 1 (mod 3) and x ≡ 0 (mod 3). Impossible.\n    const result = solveCounter([1, 0], [[0, 1]], 3);\n    expect(result).toBeNull();\n  });\n\n  it('should handle multi-button multi-counter case', () => {\n    // target: [1, 1], buttons: [[0], [1]], modulus 3\n    // x0 = 1, x1 = 1. Sum = 2.\n    const result = solveCounter([1, 1], [[0], [1]], 3);\n    expect(result).toEqual([1, 1]);\n  });\n});\n"}}
