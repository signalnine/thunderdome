@@ -0,0 +1,572 @@
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+// Use two 32-bit numbers to represent a bitmask of up to 64 bits
+// This avoids BigInt overhead for popcount and XOR operations
+type BitPair = [number, number]; // [low 32 bits, high 32 bits]
+
+function bpZero(): BitPair { return [0, 0]; }
+function bpXor(a: BitPair, b: BitPair): BitPair { return [a[0] ^ b[0], a[1] ^ b[1]]; }
+function bpSetBit(bp: BitPair, bit: number): BitPair {
+  if (bit < 32) return [bp[0] | (1 << bit), bp[1]];
+  return [bp[0], bp[1] | (1 << (bit - 32))];
+}
+function bpGetBit(bp: BitPair, bit: number): number {
+  if (bit < 32) return (bp[0] >>> bit) & 1;
+  return (bp[1] >>> (bit - 32)) & 1;
+}
+
+function popcount32(n: number): number {
+  n = n - ((n >>> 1) & 0x55555555);
+  n = (n & 0x33333333) + ((n >>> 2) & 0x33333333);
+  n = (n + (n >>> 4)) & 0x0f0f0f0f;
+  return (n * 0x01010101) >>> 24;
+}
+
+function bpPopcount(bp: BitPair): number {
+  return popcount32(bp[0]) + popcount32(bp[1]);
+}
+
+// Lex comparison: for same-weight bitpairs representing sorted button arrays,
+// find the lowest bit where they differ. If a has it set, a is lex smaller.
+function bpLexSmaller(a: BitPair, b: BitPair): boolean {
+  // Check low bits first (smaller indices)
+  const diffLow = a[0] ^ b[0];
+  if (diffLow !== 0) {
+    const lowestDiff = diffLow & (-diffLow);
+    return (a[0] & lowestDiff) !== 0;
+  }
+  const diffHigh = a[1] ^ b[1];
+  if (diffHigh !== 0) {
+    const lowestDiff = diffHigh & (-diffHigh);
+    return (a[1] & lowestDiff) !== 0;
+  }
+  return false;
+}
+
+function bpIsBetter(a: BitPair, aw: number, b: BitPair, bw: number): boolean {
+  if (aw !== bw) return aw < bw;
+  return bpLexSmaller(a, b);
+}
+
+function bpToArray(bp: BitPair, maxBits: number): number[] {
+  const result: number[] = [];
+  for (let i = 0; i < maxBits; i++) {
+    if (bpGetBit(bp, i)) result.push(i);
+  }
+  return result;
+}
+
+/**
+ * Solve the toggle puzzle using Gaussian elimination over GF(2).
+ * Find minimum button presses, breaking ties by lexicographic order.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return target.some(t => t) ? null : [];
+  }
+
+  // Build augmented matrix over GF(2)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const lightIdx of buttons[j]) {
+      if (lightIdx >= 0 && lightIdx < numLights) {
+        matrix[lightIdx][j] ^= 1;
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(2) to RREF
+  const pivotCol: number[] = [];
+  let pivotRow = 0;
+
+  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {
+    let found = -1;
+    for (let row = pivotRow; row < numLights; row++) {
+      if (matrix[row][col] === 1) { found = row; break; }
+    }
+    if (found === -1) continue;
+
+    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];
+    pivotCol.push(col);
+
+    for (let row = 0; row < numLights; row++) {
+      if (row !== pivotRow && matrix[row][col] === 1) {
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[row][c] ^= matrix[pivotRow][c];
+        }
+      }
+    }
+    pivotRow++;
+  }
+
+  const rank = pivotRow;
+
+  // Check for inconsistency
+  for (let row = rank; row < numLights; row++) {
+    if (matrix[row][numButtons] === 1) return null;
+  }
+
+  // Identify free variables
+  const pivotVarSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < numButtons; j++) {
+    if (!pivotVarSet.has(j)) freeVars.push(j);
+  }
+  const numFree = freeVars.length;
+
+  // Compute solution as BitPair given free variable assignment as BitPair
+  function solutionFromFree(freeBits: BitPair): BitPair {
+    let result = bpZero();
+    for (let i = 0; i < numFree; i++) {
+      if (bpGetBit(freeBits, i)) {
+        result = bpSetBit(result, freeVars[i]);
+      }
+    }
+    for (let r = rank - 1; r >= 0; r--) {
+      const col = pivotCol[r];
+      let val = matrix[r][numButtons];
+      for (let c = col + 1; c < numButtons; c++) {
+        if (matrix[r][c] === 1) {
+          val ^= bpGetBit(result, c);
+        }
+      }
+      if (val) result = bpSetBit(result, col);
+    }
+    return result;
+  }
+
+  const particularBP = solutionFromFree(bpZero());
+
+  // Compute null basis vectors as BitPairs
+  const nullBasis: BitPair[] = [];
+  for (let i = 0; i < numFree; i++) {
+    const freeBits = bpSetBit(bpZero(), i);
+    nullBasis.push(bpXor(solutionFromFree(freeBits), particularBP));
+  }
+
+  if (numFree === 0) {
+    return bpToArray(particularBP, numButtons);
+  }
+
+  let bestSol = particularBP;
+  let bestWeight = bpPopcount(particularBP);
+
+  if (numFree <= 25) {
+    // Direct enumeration with incremental XOR via lowest-set-bit trick
+    const deltas: BitPair[] = new Array(1 << numFree);
+    deltas[0] = bpZero();
+    for (let mask = 1; mask < (1 << numFree); mask++) {
+      const lsb = mask & (-mask);
+      const lsbIdx = 31 - Math.clz32(lsb);
+      deltas[mask] = bpXor(deltas[mask ^ lsb], nullBasis[lsbIdx]);
+    }
+
+    for (let mask = 1; mask < (1 << numFree); mask++) {
+      const sol = bpXor(particularBP, deltas[mask]);
+      const w = bpPopcount(sol);
+      if (bpIsBetter(sol, w, bestSol, bestWeight)) {
+        bestSol = sol;
+        bestWeight = w;
+      }
+    }
+    return bpToArray(bestSol, numButtons);
+  }
+
+  // Meet-in-the-middle for numFree > 25
+  const half1 = Math.floor(numFree / 2);
+  const half2 = numFree - half1;
+
+  // Build first-half deltas with incremental XOR
+  const firstDeltas: BitPair[] = new Array(1 << half1);
+  firstDeltas[0] = bpZero();
+  for (let mask = 1; mask < (1 << half1); mask++) {
+    const lsb = mask & (-mask);
+    const lsbIdx = 31 - Math.clz32(lsb);
+    firstDeltas[mask] = bpXor(firstDeltas[mask ^ lsb], nullBasis[lsbIdx]);
+  }
+
+  // Build second-half deltas
+  const secondDeltas: BitPair[] = new Array(1 << half2);
+  secondDeltas[0] = bpZero();
+  for (let mask = 1; mask < (1 << half2); mask++) {
+    const lsb = mask & (-mask);
+    const lsbIdx = 31 - Math.clz32(lsb);
+    secondDeltas[mask] = bpXor(secondDeltas[mask ^ lsb], nullBasis[half1 + lsbIdx]);
+  }
+
+  // Check if full enumeration is feasible (2^half1 * 2^half2 iterations)
+  // With BitPair (native 32-bit ops), this is much faster than BigInt.
+  // 2^20 * 2^20 = 2^40 ~ 1T iterations is still too many.
+  // 2^15 * 2^15 = 2^30 ~ 1B iterations: ~2-3 seconds with native ops.
+  const totalIter = (1 << half1) * (1 << half2);
+  if (totalIter <= 2_000_000_000) {
+    for (let mask2 = 0; mask2 < (1 << half2); mask2++) {
+      const partial = bpXor(particularBP, secondDeltas[mask2]);
+      for (let mask1 = 0; mask1 < (1 << half1); mask1++) {
+        const sol = bpXor(partial, firstDeltas[mask1]);
+        const w = bpPopcount(sol);
+        if (bpIsBetter(sol, w, bestSol, bestWeight)) {
+          bestSol = sol;
+          bestWeight = w;
+        }
+      }
+    }
+    return bpToArray(bestSol, numButtons);
+  }
+
+  // For very large numFree (> 30): greedy + local search
+  let currentDelta = bpZero();
+  for (let i = 0; i < numFree; i++) {
+    const withFlip = bpXor(bpXor(particularBP, currentDelta), nullBasis[i]);
+    const without = bpXor(particularBP, currentDelta);
+    if (bpPopcount(withFlip) < bpPopcount(without)) {
+      currentDelta = bpXor(currentDelta, nullBasis[i]);
+    }
+  }
+  bestSol = bpXor(particularBP, currentDelta);
+  bestWeight = bpPopcount(bestSol);
+
+  // Local search: single flips
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (let i = 0; i < numFree; i++) {
+      const flipped = bpXor(bestSol, nullBasis[i]);
+      const w = bpPopcount(flipped);
+      if (bpIsBetter(flipped, w, bestSol, bestWeight)) {
+        bestSol = flipped;
+        bestWeight = w;
+        improved = true;
+      }
+    }
+  }
+
+  // Try pairs of flips
+  let foundPairImprovement = true;
+  while (foundPairImprovement) {
+    foundPairImprovement = false;
+    for (let i = 0; i < numFree && !foundPairImprovement; i++) {
+      for (let j = i + 1; j < numFree; j++) {
+        const flipped = bpXor(bpXor(bestSol, nullBasis[i]), nullBasis[j]);
+        const w = bpPopcount(flipped);
+        if (bpIsBetter(flipped, w, bestSol, bestWeight)) {
+          bestSol = flipped;
+          bestWeight = w;
+          foundPairImprovement = true;
+          // Run single-flip local search to convergence
+          let singleImproved = true;
+          while (singleImproved) {
+            singleImproved = false;
+            for (let k = 0; k < numFree; k++) {
+              const f2 = bpXor(bestSol, nullBasis[k]);
+              const w2 = bpPopcount(f2);
+              if (bpIsBetter(f2, w2, bestSol, bestWeight)) {
+                bestSol = f2;
+                bestWeight = w2;
+                singleImproved = true;
+              }
+            }
+          }
+          break;
+        }
+      }
+    }
+  }
+
+  return bpToArray(bestSol, numButtons);
+}
+
+/**
+ * Solve the counter puzzle using Gaussian elimination over GF(p).
+ * Find minimum total presses, breaking ties by lexicographic order of the result array.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return lights.every(v => ((v % modulus) + modulus) % modulus === 0) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(p)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const lightIdx of buttons[j]) {
+      if (lightIdx >= 0 && lightIdx < numLights) {
+        matrix[lightIdx][j] = (matrix[lightIdx][j] + 1) % modulus;
+      }
+    }
+  }
+
+  function modPow(base: number, exp: number, mod: number): number {
+    let result = 1;
+    base = ((base % mod) + mod) % mod;
+    while (exp > 0) {
+      if (exp & 1) result = (result * base) % mod;
+      exp >>= 1;
+      base = (base * base) % mod;
+    }
+    return result;
+  }
+
+  function modInverse(a: number, p: number): number {
+    return modPow(a, p - 2, p);
+  }
+
+  // Gaussian elimination over GF(p) to RREF
+  const pivotCol: number[] = [];
+  let pivotRow = 0;
+
+  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {
+    let found = -1;
+    for (let row = pivotRow; row < numLights; row++) {
+      if (matrix[row][col] !== 0) { found = row; break; }
+    }
+    if (found === -1) continue;
+
+    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];
+    pivotCol.push(col);
+
+    const inv = modInverse(matrix[pivotRow][col], modulus);
+    for (let c = 0; c <= numButtons; c++) {
+      matrix[pivotRow][c] = (matrix[pivotRow][c] * inv) % modulus;
+    }
+
+    for (let row = 0; row < numLights; row++) {
+      if (row !== pivotRow && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[row][c] = ((matrix[row][c] - factor * matrix[pivotRow][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+    pivotRow++;
+  }
+
+  const rank = pivotRow;
+
+  // Check for inconsistency
+  for (let row = rank; row < numLights; row++) {
+    if (matrix[row][numButtons] !== 0) return null;
+  }
+
+  // Identify free variables
+  const pivotVarSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < numButtons; j++) {
+    if (!pivotVarSet.has(j)) freeVars.push(j);
+  }
+  const numFree = freeVars.length;
+
+  // Compute solution given free variable values
+  function computeSolution(freeValues: number[]): number[] {
+    const solution = new Array(numButtons).fill(0);
+    for (let i = 0; i < numFree; i++) {
+      solution[freeVars[i]] = freeValues[i];
+    }
+    for (let r = rank - 1; r >= 0; r--) {
+      const col = pivotCol[r];
+      let val = matrix[r][numButtons];
+      for (let c = col + 1; c < numButtons; c++) {
+        if (matrix[r][c] !== 0) {
+          val = ((val - matrix[r][c] * solution[c]) % modulus + modulus) % modulus;
+        }
+      }
+      solution[col] = val;
+    }
+    return solution;
+  }
+
+  // Compute null space basis vectors
+  const particular = computeSolution(new Array(numFree).fill(0));
+  const nullBasis: number[][] = [];
+  for (let i = 0; i < numFree; i++) {
+    const assignment = new Array(numFree).fill(0);
+    assignment[i] = 1;
+    const withFree = computeSolution(assignment);
+    const diff = new Array(numButtons).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      diff[j] = ((withFree[j] - particular[j]) % modulus + modulus) % modulus;
+    }
+    nullBasis.push(diff);
+  }
+
+  function solutionSum(sol: number[]): number {
+    let s = 0;
+    for (let j = 0; j < numButtons; j++) s += sol[j];
+    return s;
+  }
+
+  function isBetterSol(a: number[], aSum: number, b: number[], bSum: number): boolean {
+    if (aSum !== bSum) return aSum < bSum;
+    for (let i = 0; i < a.length; i++) {
+      if (a[i] < b[i]) return true;
+      if (a[i] > b[i]) return false;
+    }
+    return false;
+  }
+
+  if (numFree === 0) {
+    return particular;
+  }
+
+  // Determine enumeration strategy
+  let totalCombinations = 1;
+  let canEnum = true;
+  const ENUM_LIMIT = 5_000_000;
+  for (let i = 0; i < numFree; i++) {
+    totalCombinations *= modulus;
+    if (totalCombinations > ENUM_LIMIT) { canEnum = false; break; }
+  }
+
+  if (canEnum) {
+    let bestSol = [...particular];
+    let bestSum = solutionSum(particular);
+
+    const freeValues = new Array(numFree).fill(0);
+
+    const enumerate = (idx: number): void => {
+      if (idx === numFree) {
+        const sol = computeSolution(freeValues);
+        const s = solutionSum(sol);
+        if (isBetterSol(sol, s, bestSol, bestSum)) {
+          bestSol = [...sol];
+          bestSum = s;
+        }
+        return;
+      }
+      for (let v = 0; v < modulus; v++) {
+        freeValues[idx] = v;
+        enumerate(idx + 1);
+      }
+    };
+
+    enumerate(0);
+    return bestSol;
+  }
+
+  // Meet-in-the-middle for moderate cases
+  const half1 = Math.floor(numFree / 2);
+  const half2 = numFree - half1;
+  const half1Size = Math.pow(modulus, half1);
+  const half2Size = Math.pow(modulus, half2);
+
+  if (half1Size <= 100000 && half2Size <= 100000 && half1Size * half2Size <= 100_000_000) {
+    const firstDeltas: number[][] = [];
+
+    const enumFirst = (idx: number, delta: number[]): void => {
+      if (idx === half1) {
+        firstDeltas.push([...delta]);
+        return;
+      }
+      for (let v = 0; v < modulus; v++) {
+        const newDelta = new Array(numButtons).fill(0);
+        for (let j = 0; j < numButtons; j++) {
+          newDelta[j] = (delta[j] + v * nullBasis[idx][j]) % modulus;
+        }
+        enumFirst(idx + 1, newDelta);
+      }
+    };
+    enumFirst(0, new Array(numButtons).fill(0));
+
+    let bestSol = [...particular];
+    let bestSum = solutionSum(particular);
+
+    const enumSecond = (idx: number, delta: number[]): void => {
+      if (idx === half2) {
+        for (const fd of firstDeltas) {
+          const sol = new Array(numButtons).fill(0);
+          let s = 0;
+          for (let j = 0; j < numButtons; j++) {
+            sol[j] = (particular[j] + fd[j] + delta[j]) % modulus;
+            s += sol[j];
+          }
+          if (isBetterSol(sol, s, bestSol, bestSum)) {
+            bestSol = sol;
+            bestSum = s;
+          }
+        }
+        return;
+      }
+      for (let v = 0; v < modulus; v++) {
+        const newDelta = new Array(numButtons).fill(0);
+        for (let j = 0; j < numButtons; j++) {
+          newDelta[j] = (delta[j] + v * nullBasis[half1 + idx][j]) % modulus;
+        }
+        enumSecond(idx + 1, newDelta);
+      }
+    };
+    enumSecond(0, new Array(numButtons).fill(0));
+    return bestSol;
+  }
+
+  // Greedy + local search for very large search spaces
+  let bestSol = [...particular];
+  let bestSum = solutionSum(particular);
+
+  function addNull(sol: number[], basisIdx: number, coeff: number): number[] {
+    const result = new Array(numButtons).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      result[j] = (sol[j] + coeff * nullBasis[basisIdx][j]) % modulus;
+    }
+    return result;
+  }
+
+  // Greedy: for each free variable, find best coefficient
+  for (let i = 0; i < numFree; i++) {
+    let localBest = bestSol;
+    let localBestSum = bestSum;
+    for (let v = 1; v < modulus; v++) {
+      const sol = addNull(bestSol, i, v);
+      const s = solutionSum(sol);
+      if (isBetterSol(sol, s, localBest, localBestSum)) {
+        localBest = sol;
+        localBestSum = s;
+      }
+    }
+    bestSol = localBest;
+    bestSum = localBestSum;
+  }
+
+  // Local search
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (let i = 0; i < numFree; i++) {
+      for (let v = 1; v < modulus; v++) {
+        const sol = addNull(bestSol, i, v);
+        const s = solutionSum(sol);
+        if (isBetterSol(sol, s, bestSol, bestSum)) {
+          bestSol = sol;
+          bestSum = s;
+          improved = true;
+          break;
+        }
+      }
+      if (improved) break;
+    }
+  }
+
+  return bestSol;
+}
