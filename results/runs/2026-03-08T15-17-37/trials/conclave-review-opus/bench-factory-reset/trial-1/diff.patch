\n}\n\n/**\n * Solve the toggle puzzle using Gaussian elimination over GF(2).\n *\n * We model this as a system of linear equations over GF(2):\n * For each light i: sum of b_j for all buttons j that affect light i ≡ target[i] (mod 2)\n *\n * We find the solution with minimum button presses, breaking ties lexicographically.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build the augmented matrix over GF(2).\n  // Each row represents a light equation. Columns are buttons + 1 (augmented with target).\n  // matrix[light][button] = 1 if that button toggles that light\n  // matrix[light][numButtons] = target value\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    row[numButtons] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n  for (let j = 0; j < numButtons; j++) {\n    for (const lightIdx of buttons[j]) {\n      if (lightIdx < numLights) {\n        matrix[lightIdx][j] = 1;\n      }\n    }\n  }\n\n  // Gaussian elimination over GF(2)\n  // Track which column is the pivot for each row\n  const pivotCol: number[] = new Array(numLights).fill(-1);\n  let pivotRow = 0;\n\n  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {\n    // Find a row with a 1 in this column\n    let found = -1;\n    for (let row = pivotRow; row < numLights; row++) {\n      if (matrix[row][col] === 1) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];\n    pivotCol[pivotRow] = col;\n\n    // Eliminate this column from all other rows\n    for (let row = 0; row < numLights; row++) {\n      if (row !== pivotRow && matrix[row][col] === 1) {\n        for (let c = 0; c <= numButtons; c++) {\n          matrix[row][c] ^= matrix[pivo