solveToggle(machine)).toBeNull();\n  });\n\n  it('should handle no buttons with all-off target', () => {\n    const machine: Machine = {\n      target: [false, false],\n      buttons: [],\n    };\n    expect(solveToggle(machine)).toEqual([]);\n  });\n\n  it('should handle all-on target', () => {\n    const machine: Machine = {\n      target: [true, true, true],\n      buttons: [[0], [1], [2]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0, 1, 2]);\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should handle overlapping buttons', () => {\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0, 1], [0], [1]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]);\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should handle larger puzzle', () => {\n    const machine: Machine = {\n      target: [true, false, true, false, true],\n      buttons: [[0], [1], [2], [3], [4]],\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0, 2, 4]);\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should handle medium-size puzzle with free variables', () => {\n    // 3 lights, 10 buttons - many free variables\n    const machine: Machine = {\n      target: [true, true, true],\n      buttons: [\n        [0], [1], [2], [0, 1], [1, 2],\n        [0, 2], [0, 1, 2], [0], [1], [2],\n      ],\n    };\n    const result = solveToggle(machine);\n    expect(result).not.toBeNull();\n    expect(verifyToggle(machine, result!)).toBe(true);\n    // Verify minimum: pressing just button 6 toggles all 3 lights\n    expect(result!.length).toBeLessThanOrEqual(1);\n  });\n\n  it('should handle 20 buttons performance test', () => {\n    // 10 lights, 20 buttons\n    const buttons: number[][] = [];\n    for (let i = 0; i < 20; i++) {\n      const affected: number[] = [];\n      for (let j = 0; j < 10; j++) {\n        if ((i * 7 + j * 3) % 5 < 2) affected.push(j);\n      }\n      if (affected.length === 0) affected.push(i % 10);\n      buttons.push(affected);\n    }\n    const target = new Array(10).fill(true);\n    const machine: Machine = { target, buttons };\n    const result = solveToggle(machine);\n    if (result !== null) {\n      expect(verifyToggle(machine, result)).toBe(true);\n    }\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('should return all zeros when target is all zeros', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('should solve a simple single button case', () => {\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n    expect(verifyCounter([3], [[0]], 5, result!)).toBe(true);\n  });\n\n  it('should return null when no solution exists', () => {\n    const result = solveCounter([1], [], 5);\n    expect(result).toBeNull();\n  });\n\n  it('should handle wrapping', () => {\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('should find minimum total presses', () => {\n    const result = solveCounter([4], [[0]], 5);\n    expect(result).toEqual([4]);\n    expect(verifyCounter([4], [[0]], 5, result!)).toBe(true);\n  });\n\n  it('should handle two buttons affecting same counter', () => {\n    const result = solveCounter([2], [[0], [0]], 5);\n    expect(result).toEqual([0, 2]);\n    expect(verifyCounter([2], [[0], [0]], 5, result!)).toBe(true);\n  });\n\n  it('should handle larger modulus', () => {\n    const result = solveCounter([1], [[0]], 97);\n    expect(result).toEqual([1]);\n  });\n\n  it('should return null for impossible case', () => {\n    const result = solveCounter([1, 0], [[0, 1]], 3);\n    expect(result).toBeNull();\n  });\n\n  it('should handle multi-button multi-counter case', () => {\n    const result = solveCounter([1, 1], [[0], [1]], 3);\n    expect(result).toEqual([1, 1]);\n    expect(verifyCounter([1, 1], [[0], [1]], 3, result!)).toBe(true);\n  });\n\n  it('should handle 0 target with buttons', () => {\n    const result = solveCounter([0, 0], [[0], [1]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('should handle empty target with no buttons', () => {\n    const result = solveCounter([], [], 5);\n    expect(result).toEqual([]);\n  });\n\n  it('should find minimum sum with multiple free variables', () => {\n    // target: [1, 0], buttons: [[0], [0], [1]], modulus 3\n    // x0 + x1 ≡ 1 (mod 3), x2 ≡ 0 (mod 3)\n    // Minimize x0 + x1 + x2\n    // x2 = 0, and (x0+x1) mod 3 = 1\n    // Min sum of x0+x1 = 1 (e.g., x0=0,x1=1 or x0=1,x1=0)\n    // Lex smallest: [0, 1, 0]\n    const result = solveCounter([1, 0], [[0], [0], [1]], 3);\n    expect(result).toEqual([0, 1, 0]);\n    expect(verifyCounter([1, 0], [[0], [0], [1]], 3, result!)).toBe(true);\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":6,"newStart":1,"newLines":30,"lines":[" import { describe, it, expect } from 'vitest';"," import { solveToggle, solveCounter, Machine } from './index.js';"," ","+// Helper to verify a toggle solution is correct","+function verifyToggle(machine: Machine, buttons: number[]): boolean {","+  const state = new Array(machine.target.length).fill(false);","+  for (const b of buttons) {","+    for (const lightIdx of machine.buttons[b]) {","+      state[lightIdx] = !state[lightIdx];","+    }","+  }","+  return state.every((v, i) => v === machine.target[i]);","+}","+","+// Helper to verify a counter solution is correct","+function verifyCounter(lights: number[], buttons: number[][], modulus: number, solution: number[]): boolean {","+  const state = new Array(lights.length).fill(0);","+  for (let j = 0; j < solution.length; j++) {","+    for (let press = 0; press < solution[j]; press++) {","+      for (const idx of buttons[j]) {","+        state[idx] = (state[idx] + 1) % modulus;","+      }","+    }","+  }","+  return state.every((v, i) => v === lights[i] % modulu