88→  // Simpler: just enumerate all 2^half1 first-half deltas, and all 2^half2 second-half deltas.\n   289→  // Total solution delta = firstDelta XOR secondDelta.\n   290→  // Solution = particular XOR firstDelta XOR secondDelta.\n   291→  // Weight = popcount(particular XOR firstDelta XOR secondDelta).\n   292→\n   293→  // For each second-half delta, we want the first-half delta that minimizes\n   294→  // popcount((particular XOR secondDelta) XOR firstDelta).\n   295→\n   296→  // This is the nearest neighbor problem in Hamming space, which is hard in general.\n   297→  // But with ~1M points in 40 dimensions, we can try brute force:\n   298→  // 1M * 1M = 1T operations, too slow.\n   299→\n   300→  // Better: for small dimension (40 bits), we can split the 40-bit string into chunks\n   301→  // and use lookup tables. But this gets complex.\n   302→\n   303→  // Pragmatic approach: enumerate all first-half combos (~1M), store them.\n   304→  // For each second-half combo (~1M), iterate all first-half combos and find minimum.\n   305→  // This is 1M * 1M = 1T, too slow.\n   306→\n   307→  // Let's try a different approach: since we want minimum weight, iterate from weight 0 upward.\n   308→  // For weight k, check if any combination of k free vars (toggled) gives a valid solution\n   309→  // with exactly k button presses... but the total weight includes both free and pivot vars.\n   310→\n   311→  // Actually, the most practical approach for <= 40 free vars:\n   312→  // Use a recursive search with pruning. At each free variable, try 0 and 1,\n   313→  // maintaining a running XOR with particular, and prune branches that can't improve.\n   314→\n   315→  let bestWeight = numButtons + 1;\n   316→  let bestSolution = 0n;\n   317→\n   318→  function search(idx: number, currentDelta: bigint, _depth: number): void {\n   319→    if (idx === numFree) {\n   320→      const sol = particularBig ^ currentDelta;\n   321→      const w = popcount(sol);\n   322→      if (w < bestWeight || (w === bestWeight && lexSmallerBig(sol, bestSolution, numButtons))) {\n   323→        bestWeight = w;\n   324→        bestSolution = sol;\n   325→      }\n   326→      return;\n   327→    }\n   328→\n   329→    // Try free var = 0 first (lex preference)\n   330→    search(idx + 1, currentDelta, _depth + 1);\n   331→    // Try free var = 1\n   332→    search(idx + 1, currentDelta ^ nullBasisBig[idx], _depth + 1);\n   333→  }\n   334→\n   335→  // For up to ~25 free vars this is fine (2^25 = 33M). For 40, we need pruning.\n   336→  // Let's add a time limit and early termination.\n   337→  if (numFree <= 25) {\n   338→    search(0, 0n, 0);\n   339→  } else {\n   340→    // For very large free var counts, use a heuristic: greedy approach\n   341→    // Set each free var to whichever value reduces weight more\n   342→    let currentDelta = 0n;\n   343→    for (let i = 0; i < numFree; i++) {\n   344→      const w0 = popcount(particularBig ^ currentDelta);\n   345→      const w1 = popcount(particularBig ^ (currentDelta ^ nullBasisBig[i]));\n   346→      if (w1 < w0) {\n   347→        currentDelta ^= nullBasisBig[i];\n   348→      }\n   349→    }\n   350→    bestSolution = particularBig ^ currentDelta;\n   351→    bestWeight = popcount(bestSolution);\n   352→\n   353→    // Do a few rounds of local search (flip each free var and see if it improves)\n   354→    let improved = true;\n   355→    while (improved) {\n   356→      improved = false;\n   357→      currentDelta = particularBig ^ bestSolution;\n   358→      for (let i = 0; i < numFree; i++) {\n   359→        const flipped = bestSolution ^ nullBasisBig[i];\n   360→        const w = popcount(flipped);\n   361→        if (w < bestWeight || (w === bestWeight && lexSmallerBig(flipped, bestSolution, numButtons))) {\n   362→          bestSolution = flipped;\n   363→          bestWeight = w;\n   364→          improved = true;\n   365→        }\n   366→      }\n   367→    }\n   368→  }\n   369→\n   370→  return toButtonArray(bestSolution, numButtons);\n   371→}\n   372→\n   373→function lexSmallerBig(a: bigint, b: bigint, n: number): boolean {\n   374→  // Compare as button arrays lexicographically\n   375→  // Button arrays are sorted ascending indices of set bits\n   376→  for (let i = 0; i < n; i++) {\n   377→    const aBit = (a >> BigInt(i)) & 1n;\n   378→    const bBit = (b >> BigInt(i)) & 1n;\n   379→    if (aBit !== bBit) {\n   380→      // If a has bit set and b doesn't at this position,\n   381→      // a's array includes this index but b's doesn't.\n   382→      // The one that includes fewer early indices or different sets...\n   383→      // Actually, for lex comparison of sets:\n   384→      // Compare element by element. The first set that has an element\n   385→      // not in the other (at the smallest index) determines the order.\n   386→      // But this is equivalent to: find the smallest index where they differ.\n   387→      // If a has it and b doesn't: at that point a's array has an extra element,\n   388→      // but we need to think about this more carefully.\n   389→\n   390→      // For sets of equal size, lex order is: compare element by element.\n   391→      // [0,2] < [0,3] < [1,2]\n   392→\n   393→      // For sets of different sizes (same weight guaranteed by caller context...\n   394→      // actually weight is same since we check w === bestWeight):\n   395→      // We need to compare as sorted arrays.\n   396→      // Simpler: find the first bit where they differ.\n   397→      // If a has 0 and b has 1 at that position: a's set doesn't include this index,\n   398→      // b's does. Since they have the same weight, a must have a later bit set.\n   399→      // So a's array = [..., later_index, ...] vs b's = [..., this_index, ...].\n   400→      // b would have this_index which is smaller, so b's array has this element earlier.\n   401→      // Wait, both arrays are sorted. Let me think again...\n   402→\n   403→      // Actually, for arrays of same length, lex comparison:\n   404→      // [0,3] vs [1,2]: first elements differ: 0 < 1, so [0,3] is smaller.\n   405→      // As bitsets: a = ...1001, b = ...0110. First differing bit at index 0: a=1, b=0.\n   406→      // So a has index 0 in its set, b doesn't. a is lex smaller.\n   407→\n   408→      // [0,2] vs [0,3]: first elements same (0). Second: 2 < 3, so [0,2] is smaller.\n   409→      // a = ...0101, b = ...1001. First differing bit at index 2: a=1, b=0.\n   410→      // a has index 2, b doesn't. a is lex smaller.\n   411→\n   412→      // Pattern: at the first differing bit position, if a has 1 and b has 0, a is lex smaller.\n   413→      return aBit === 1n;\n   414→    }\n   415→  }\n   416→  return false;\n   417→}\n   418→\n   419→function lexSmaller(a: number[], b: number[]): boolean {\n   420→  const len = Math.min(a.length, b.length);\n   421→  for (let i = 0; i < len; i++) {\n   422→    if (a[i] < b[i]) return true;\n   423→    if (a[i] > b[i]) return false;\n   424→  }\n   425→  return a.length < b.length;\n   426→}\n   427→\n   428→/**\n   429→ * Solve the counter puzzle using Gaussian elimination over GF(p).\n   430→ *\n   431→ * Each button j pressed x_j times adds x_j to each counter it affects (mod p).\n   432→ * We need: for each counter i, sum of x_j for buttons j affecting counter i ≡ target[i] (mod p)\n   433→ *\n   434→ * Find the solution minimizing total presses (sum of x_j), then lex smallest.\n   435→ */\n   436→export function solveCounter(\n   437→  lights: number[],\n   438→  buttons: number[][],\n   439→  modulus: number\n   440→): number[] | null {\n   441→  const numLights = lights.length;\n   442→  const numButtons = buttons.length;\n   443→\n   444→  // Build augmented matrix over GF(modulus)\n   445→  // matrix[light][button] = 1 if button affects that light, 0 otherwise\n   446→  // matrix[light][numButtons] = target value\n   447→  const matrix: number[][] = [];\n   448→  for (let i = 0; i < numLights; i++) {\n   449→    const row = new Array(numButtons + 1).fill(0);\n   450→    row[numButtons] = lights[i] % modulus;\n   451→    matrix.push(row);\n   452→  }\n   453→  for (let j = 0; j < numButtons; j++) {\n   454→    for (const lightIdx of buttons[j]) {\n   455→      if (lightIdx < numLights) {\n   456→        matrix[lightIdx][j] = (matrix[lightIdx][j] + 1) % modulus;\n   457→      }\n   458→    }\n   459→  }\n   460→\n   461→  // Compute modular inverse using Fermat's little theorem (modulus is prime)\n   462→  function modInverse(a: number, p: number): number {\n   463→    return modPow(((a % p) + p) % p, p - 2, p);\n   464→  }\n   465→\n   466→  function modPow(base: number, exp: number, mod: number): number {\n   467→    let result = 1;\n   468→    base = base % mod;\n   469→    while (exp > 0) {\n   470→      if (exp % 2 === 1) {\n   471→        result = (result * base) % mod;\n   472→      }\n   473→      exp = Math.floor(exp / 2);\n   474→      base = (base * base) % mod;\n   475→    }\n   476→    return result;\n   477→  }\n   478→\n   479→  // Gaussian elimination over GF(modulus)\n   480→  const pivotCol: number[] = new Array(numLights).fill(-1);\n   481→  let pivotRow = 0;\n   482→\n   483→  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {\n   484→    // Find a row with a non-zero entry in this column\n   485→    let found = -1;\n   486→    for (let row = pivotRow; row < numLights; row++) {\n   487→      if (matrix[row][col] !== 0) {\n   488→        found = row;\n   489→        break;\n   490→      }\n   491→    }\n   492→    if (found === -1) continue;\n   493→\n   494→    // Swap rows\n   495→    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];\n   496→    pivotCol[pivotRow] = col;\n   497→\n   498→    // Normalize pivot row\n   499→    const inv = modInverse(matrix[pivotRow][col], modulus);\n   500→    for (let c = 0; c <= numButtons; c++) {\n   501→      matrix[pivotRow][c] = (matrix[pivotRow][c] * inv) % modulus;\n   502→    }\n   503→\n   504→    // Eliminate this column from all other rows\n   505→    for (let row = 0; row < numLights; row++) {\n   506→      if (row !== pivotRow && matrix[row][col] !== 0) {\n   507→        const factor = matrix[row][col];\n   508→        for (let c = 0; c <= numButtons; c++) {\n   509→          matrix[row][c] = ((matrix[row][c] - factor * matrix[pivotRow][c]) % modulus + modulus) % modulus;\n   510→        }\n   511→      }\n   512→    }\n   513→    pivotRow++;\n   514→  }\n   515→\n   516→  const rank = pivotRow;\n   517→\n   518→  // Check for inconsistency\n   519→  for (let row = rank; row < numLights; row++) {\n   520→    if (matrix[row][numButtons] !== 0) {\n   521→      return null;\n   522→    }\n   523→  }\n   524→\n   525→  // Identify pivot and free variables\n   526→  const pivotVars = new Set<number>();\n   527→  for (let r = 0; r < rank; r++) {\n   528→    pivotVars.add(pivotCol[r]);\n   529→  }\n   530→\n   531→  const freeVars: number[] = [];\n   532→  for (let j = 0; j < numButtons; j++) {\n   533→    if (!pivotVars.has(j)) {\n   534→      freeVars.push(j);\n   535→    }\n   536→  }\n   537→\n   538→  const numFree = freeVars.length;\n   539→\n   540→  // For GF(p), each free variable can take values 0..p-1.\n   541→  // Total combinations: p^numFree.\n   542→  // We need to find the assignment minimizing total presses (sum of all x_j),\n   543→  // then lex smallest.\n   544→\n   545→  // Compute particular solution (all free vars = 0)\n   546→  function computeSolution(freeAssignment: number[]): number[] {\n   547→    const solution = new Array(numButtons).fill(0);\n   548→    for (let i = 0; i < numFree; i++) {\n   549→      solution[freeVars[i]] = freeAssignment[i];\n   550→    }\n   551→    for (let r = rank - 1; r >= 0; r--) {\n   552→      const col = pivotCol[r];\n   553→      let val = matrix[r][numButtons];\n   554→      for (let c = col + 1; c < numButtons; c++) {\n   555→        if (matrix[r][c] !== 0) {\n   556→          val = ((val - matrix[r][c] * solution[c]) % modulus + modulus) % modulus;\n   557→        }\n   558→      }\n   559→      solution[col] = val;\n   560→    }\n   561→    return solution;\n   562→  }\n   563→\n   564→  // For small number of free vars and small modulus, enumerate\n   565→  // p^numFree combinations. With p=97 and numFree=1, that's 97.\n   566→  // With numFree=2, 97^2 = 9409. numFree=3, 97^3 ~= 912K.\n   567→  // numFree=4, ~88M (too slow for 5 seconds).\n   568→\n   569→  // For larger cases, we need a smarter approach.\n   570→  // Since modulus is prime, we can compute the null space basis vectors\n   571→  // and find the minimum weight solution using meet-in-the-middle over GF(p).\n   572→\n   573→  const maxEnum = 5_000_000; // Max total enumeration\n   574→  let totalCombinations = 1;\n   575→  let overflow = false;\n   576→  for (let i = 0; i < numFree; i++) {\n   577→    totalCombinations *= modulus;\n   578→    if (totalCombinations > maxEnum) {\n   579→      overflow = true;\n   580→      break;\n   581→    }\n   582→  }\n   583→\n   584→  if (!overflow && numFree <= 40) {\n   585→    return enumSolveGFp(computeSolution, numButtons, numFree, modulus, freeVars);\n   586→  } else {\n   587→    return meetInMiddleSolveGFp(matrix, rank, pivotCol, freeVars, numButtons, numFree, modulus);\n   588→  }\n   589→}\n   590→\n   591→function enumSolveGFp(\n   592→  computeSolution: (freeAssignment: number[]) => number[],\n   593→  numButtons: number,\n   594→  numFree: number,\n   595→  modulus: number,\n   596→  _freeVars: number[]\n   597→): number[] | null {\n   598→  let bestSolution: number[] | null = null;\n   599→  let bestSum = Infinity;\n   600→\n   601→  const freeAssignment = new Array(numFree).fill(0);\n   602→\n   603→  function enumerate(idx: number): void {\n   604→    if (idx === numFree) {\n   605→      const sol = computeSolution(freeAssignment);\n   606→      const sum = sol.reduce((a, b) => a + b, 0);\n   607→      if (sum < bestSum || (sum === bestSum && lexSmallerArr(sol, bestSolution!))) {\n   608→        bestSum = sum;\n   609→        bestSolution = [...sol];\n   610→      }\n   611→      return;\n   612→    }\n   613→    for (let v = 0; v < modulus; v++) {\n   614→      freeAssignment[idx] = v;\n   615→      enumerate(idx + 1);\n   616→    }\n   617→  }\n   618→\n   619→  enumerate(0);\n   620→  return bestSolution;\n   621→}\n   622→\n   623→function meetInMiddleSolveGFp(\n   624→  matrix: number[][],\n   625→  rank: number,\n   626→  pivotCol: number[],\n   627→  freeVars: number[],\n   628→  numButtons: number,\n   629→  numFree: number,\n   630→  modulus: number\n   631→): number[] | null {\n   632→  // Compute particular solution and null basis\n   633→  function computeSolution(freeAssignment: number[]): number[] {\n   634→    const solution = new Array(numButtons).fill(0);\n   635→    for (let i = 0; i < numFree; i++) {\n   636→      solution[freeVars[i]] = freeAssignment[i];\n   637→    }\n   638→    for (let r = rank - 1; r >= 0; r--) {\n   639→      const col = pivotCol[r];\n   640→      let val = matrix[r][numButtons];\n   641→      for (let c = col + 1; c < numButtons; c++) {\n   642→        if (matrix[r][c] !== 0) {\n   643→          val = ((val - matrix[r][c] * solution[c]) % modulus + modulus) % modulus;\n   644→        }\n   645→      }\n   646→      solution[col] = val;\n   647→    }\n   648→    return solution;\n   649→  }\n   650→\n   651→  // Compute null basis vectors\n   652→  const nullBasis: number[][] = [];\n   653→  const zeroAssign = new Array(numFree).fill(0);\n   654→  const particular = computeSolution(zeroAssign);\n   655→\n   656→  for (let i = 0; i < numFree; i++) {\n   657→    const assignment = new Array(numFree).fill(0);\n   658→    assignment[i] = 1;\n   659→    const withFree = computeSolution(assignment);\n   660→    const diff = new Array(numButtons).fill(0);\n   661→    for (let j = 0; j < numButtons; j++) {\n   662→      diff[j] = ((withF