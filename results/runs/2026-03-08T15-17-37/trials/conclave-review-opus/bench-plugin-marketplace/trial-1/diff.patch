tAverageRating('nonexistent')).toBe(0);\n  });\n\n  it('should flag and retrieve flagged reviews', () => {\n    const r = reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'bad' });\n    reviews.flagReview(r.id);\n\n    const flagged = reviews.getFlaggedReviews();\n    expect(flagged.length).toBe(1);\n    expect(flagged[0].flagged).toBe(true);\n  });\n\n  it('should remove reviews', () => {\n    const r = reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    expect(reviews.removeReview(r.id)).toBe(true);\n    expect(reviews.getReviews('foo').length).toBe(0);\n    expect(reviews.removeReview(r.id)).toBe(false);\n  });\n\n  it('should get reviews by user', () => {\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'alice', rating: 5, comment: '' });\n    reviews.addReview({ pluginName: 'bar', pluginVersion: '1.0.0', userId: 'alice', rating: 4, comment: '' });\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'bob', rating: 3, comment: '' });\n\n    const aliceReviews = reviews.getReviewsByUser('alice');\n    expect(aliceReviews.length).toBe(2);\n  });\n\n  it('should count reviews', () => {\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: '' });\n\n    expect(reviews.getReviewCount('foo')).toBe(2);\n    expect(reviews.getReviewCount('bar')).toBe(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":681,"cache_read_input_tokens":31772,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":681},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"204fc9b7-8dd9-