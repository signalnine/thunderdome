nown }).message)\n    46→          : String(err);\n    47→\n    48→      return {\n    49→        success: false,\n    50→        output: null,\n    51→        duration,\n    52→        memoryUsed,\n    53→        error: errorMessage,\n    54→      };\n    55→    }\n    56→  }\n    57→\n    58→  return {\n    59→    async execute(\n    60→      code: string,\n    61→      context?: Record<string, unknown>\n    62→    ): Promise<SandboxResult> {\n    63→      return run(code, 5000, context);\n    64→    },\n    65→\n    66→    async executeWithTimeout(\n    67→      code: string,\n    68→      timeoutMs: number,\n    69→      context?: Record<string, unknown>\n    70→    ): Promise<SandboxResult> {\n    71→      return run(code, timeoutMs, context);\n    72→    },\n    73→  };\n    74→}\n    75→"}]},"parent_tool_use_id":"toolu_018ptV8c4jZvrMgL63L3LJRA","session_id":"204fc9b7-8dd9-4cc6-926f-837ce50d007b","uuid":"7c9b245d-ab95-42be-8f3e-185bcbd85eac"}
