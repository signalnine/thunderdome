+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011WSuG7TTNFawkQQYpr98iQ","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { createResolver } from './index.js';\n     3→\n     4→describe('Resolver', () => {\n     5→  const resolver = createResolver();\n     6→\n     7→  describe('satisfies', () => {\n     8→    it('should check if version satisfies range', () => {\n     9→      expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);\n    10→      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n    11→      expect(resolver.satisfies('1.5.0', '>=1.0.0 <2.0.0')).toBe(true);\n    12→    });\n    13→  });\n    14→\n    15→  describe('maxSatisfying', () => {\n    16→    it('should find max version satisfying range', () => {\n    17→      expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0')).toBe('1.5.0');\n    18→      expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^2.0.0')).toBe('2.0.0');\n    19→    });\n    20→\n    21→    it('should return null when no version satisfies', () => {\n    22→      expect(resolver.maxSatisfying(['1.0.0'], '^2.0.0')).toBeNull();\n    23→    });\n    24→  });\n    25→\n    26→  describe('validRange', () => {\n    27→    it('should validate semver ranges', () => {\n    28→      expect(resolver.validRange('^1.0.0')).toBe(true);\n    29→      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);\n    30→      expect(resolver.validRange('not-a-range')).toBe(false);\n    31→    });\n    32→  });\n    33→\n    34→  describe('resolve', () => {\n    35→    it('should resolve version constraints', () => {\n    36→      const constraints = [\n    37→        { name: 'foo', range: '^1.0.0' },\n    38→        { name: 'bar', range: '~2.1.0' },\n    39→      ];\n    40→      const available = {\n    41→        foo: ['1.0.0', '1.2.0', '1.5.0', '2.0.0'],\n    42→        bar: ['2.0.0', '2.1.0', '2.1.5', '2.2.0'],\n    43→      };\n    44→\n    45→      const resolved = resolver.resolve(constraints, available);\n    46→      expect(resolved.length).toBe(2);\n    47→\n    48→      const foo = resolved.find(r => r.name === 'foo');\n    49→      expect(foo?.version).toBe('1.5.0');\n    50→      expect(foo?.satisfies).toBe('^1.0.0');\n    51→\n    52→      const bar = resolved.find(r => r.name === 'bar');\n    53→      expect(bar?.version).toBe('2.1.5');\n    54→    });\n    55→\n    56→    it('should throw when no versions available', () => {\n    57→      expect(() => resolver.resolve([{ name: 'x', range: '^1.0.0' }], {})).toThrow();\n    58→    });\n    59→\n    60→    it('should throw when no version satisfies range', () => {\n    61→      expect(() =>\n    62→        resolver.resolve(\n    63→          [{ name: 'x', range: '^3.0.0' }],\n    64→          { x: ['1.0.0', '2.0.0'] }\n    65→        )\n    66→      ).toThrow();\n    67→    });\n    68→  });\n    69→});\n    70→"}]},"parent_tool_use_id":"toolu_018ptV8c4jZvrMgL63L3LJRA","session_id":"204fc9b7-8dd9-4cc6-926f-837ce50d007b","uuid":"39277164-ebfb-41e1-859b-5f652efc629a"}
