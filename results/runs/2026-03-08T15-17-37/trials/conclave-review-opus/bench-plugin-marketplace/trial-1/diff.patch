e('1.0.0');\n\n    const v2 = registry.getVersion('test-plugin', '2.0.0');\n    expect(v2?.version).toBe('2.0.0');\n\n    expect(registry.getVersion('test-plugin', '3.0.0')).toBeNull();\n  });\n\n  it('should list all plugins', () => {\n    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));\n\n    const all = registry.list();\n    expect(all.length).toBe(2);\n  });\n\n  it('should search by name, description, and author', () => {\n    registry.register(makeManifest({ name: 'auth-plugin', description: 'Authentication', author: 'alice' }));\n    registry.register(makeManifest({ name: 'db-plugin', description: 'Database connector', author: 'bob' }));\n\n    expect(registry.search('auth').length).toBe(1);\n    expect(registry.search('Database').length).toBe(1);\n    expect(registry.search('bob').length).toBe(1);\n    expect(registry.search('xyz').length).toBe(0);\n  });\n\n  it('should remove a specific version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n\n    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);\n    expect(registry.listVersions('test-plugin')).toEqual(['2.0.0']);\n    expect(registry.remove('test-plugin', '1.0.0')).toBe(false);\n  });\n\n  it('should remove the plugin entirely when last version is removed', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.remove('test-plugin', '1.0.0');\n    expect(registry.get('test-plugin')).toBeNull();\n    expect(registry.listVersions('test-plugin')).toEqual([]);\n  });\n\n  it('should update a plugin manifest', () => {\n    registry.register(makeManifest());\n    registry.update('test-plugin', '1.0.0', { description: 'Updated description' });\n    const updated = registry.getVersion('test-plugin', '1.0.0');\n    expect(updated?.description).toBe('Updated description');\n  });\n\n  it('should throw when updating non-existent plugin', () => {\n    expect(() => registry.update('nonexistent', '1.0.0', {})).toThrow();\n  });\n\n  it('should return copies to prevent mutation', () => {\n    registry.register(makeManifest());\n    const a = registry.get('test-plugin');\n    const b = registry.get('test-plugin');\n    expect(a).toEqual(b);\n    if (a) a.description = 'mutated';\n    const c = registry.get('test-plugin');\n    expect(c?.description).toBe('A test plugin');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":123,"cache_read_input_tokens":29225,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":123},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"204fc9b7-8dd9-4cc6-926f-837ce50d007b","uuid":"22ff780c-a6ce-437d-8c8d-7486c109df0d"}
