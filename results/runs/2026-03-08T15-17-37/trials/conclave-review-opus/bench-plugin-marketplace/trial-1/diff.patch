+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K6GsaSckB7Nj5zGQAPfmoW","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { createRegistry } from './index.js';\n     3→import type { PluginManifest, RegistryService } from '../types.js';\n     4→\n     5→function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {\n     6→  return {\n     7→    name: 'test-plugin',\n     8→    version: '1.0.0',\n     9→    description: 'A test plugin',\n    10→    author: 'tester',\n    11→    dependencies: {},\n    12→    entryPoint: 'console.log(\"hello\")',\n    13→    permissions: [],\n    14→    ...overrides,\n    15→  };\n    16→}\n    17→\n    18→describe('Registry', () => {\n    19→  let registry: RegistryService;\n    20→\n    21→  beforeEach(() => {\n    22→    registry = createRegistry();\n    23→  });\n    24→\n    25→  it('should register and retrieve a plugin', () => {\n    26→    const manifest = makeManifest();\n    27→    registry.register(manifest);\n    28→    const retrieved = registry.get('test-plugin');\n    29→    expect(retrieved).not.toBeNull();\n    30→    expect(retrieved?.name).toBe('test-plugin');\n    31→    expect(retrieved?.version).toBe('1.0.0');\n    32→  });\n    33→\n    34→  it('should return null for non-existent plugin', () => {\n    35→    expect(registry.get('nonexistent')).toBeNull();\n    36→  });\n    37→\n    38→  it('should support multiple versions of the same plugin', () => {\n    39→    registry.register(makeManifest({ version: '1.0.0' }));\n    40→    registry.register(makeManifest({ version: '2.0.0' }));\n    41→\n    42→    const versions = registry.listVersions('test-plugin');\n    43→    expect(versions).toContain('1.0.0');\n    44→    expect(versions).toContain('2.0.0');\n    45→    expect(versions.length).toBe(2);\n    46→  });\n    47→\n    48→  it('should get a specific version', () => {\n    49→    registry.register(makeManifest({ version: '1.0.0' }));\n    50→    registry.register(makeManifest({ version: '2.0.0' }));\n    51→\n    52→    const v1 = registry.getVersion('test-plugin', '1.0.0');\n    53→    expect(v1?.version).toBe('1.0.0');\n    54→\n    55→    const v2 = registry.getVersion('test-plugin', '2.0.0');\n    56→    expect(v2?.version).toBe('2.0.0');\n    57→\n    58→    expect(registry.getVersion('test-plugin', '3.0.0')).toBeNull();\n    59→  });\n    60→\n    61→  it('should list all plugins', () => {\n    62→    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));\n    63→    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));\n    64→\n    65→    const all = registry.list();\n    66→    expect(all.length).toBe(2);\n    67→  });\n    68→\n    69→  it('should search by name, description, and author', () => {\n    70→    registry.register(makeManifest({ name: 'auth-plugin', description: 'Authentication', author: 'alice' }));\n    71→    registry.register(makeManifest({ name: 'db-plugin', description: 'Database connector', author: 'bob' }));\n    72→\n    73→    expect(registry.search('auth').length).toBe(1);\n    74→    expect(registry.search('Database').length).toBe(1);\n    75→    expect(registry.search('bob').length).toBe(1);\n    76→    expect(registry.search('xyz').length).toBe(0);\n    77→  });\n    78→\n    79→  it('should remove a specific version', () => {\n    80→    registry.register(makeManifest({ version: '1.0.0' }));\n    81→    registry.register(makeManifest({ version: '2.0.0' }));\n    82→\n    83→    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);\n    84→    expect(registry.listVersions('test-plugin')).toEqual(['2.0.0']);\n    85→    expect(registry.remove('test-plugin', '1.0.0')).toBe(false);\n    86→  });\n    87→\n    88→  it('should remove the plugin entirely when last version is removed', () => {\n    89→    registry.register(makeManifest({ version: '1.0.0' }));\n    90→    registry.remove('test-plugin', '