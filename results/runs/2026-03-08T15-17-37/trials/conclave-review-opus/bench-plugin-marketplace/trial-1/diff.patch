+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { Marketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '2 + 2',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should create a marketplace with all services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+    expect(marketplace.installPlugin).toBeInstanceOf(Function);
+  });
+
+  describe('installPlugin', () => {
+    it('should install a simple plugin', async () => {
+      const result = await marketplace.installPlugin(makeManifest());
+      expect(result.executionResult.success).toBe(true);
+      expect(result.executionResult.output).toBe(4);
+      expect(result.resolvedDependencies).toEqual([]);
+
+      // Should be registered
+      const plugin = marketplace.registry.get('test-plugin');
+      expect(plugin).not.toBeNull();
+    });
+
+    it('should resolve dependencies during install', async () => {
+      // Pre-register a dependency
+      marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.0.0' }));
+      marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.2.0' }));
+
+      const result = await marketplace.installPlugin(
+        makeManifest({
+          name: 'my-plugin',
+          dependencies: { 'dep-a': '^1.0.0' },
+        })
+      );
+
+      expect(result.resolvedDependencies.length).toBe(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-a');
+      expect(result.resolvedDependencies[0].version).toBe('1.2.0');
+    });
+
+    it('should reject plugin with missing name', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ name: '' }))
+      ).rejects.toThrow('name');
+    });
+
+    it('should reject plugin with missing version', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ version: '' }))
+      ).rejects.toThrow('version');
+    });
+
+    it('should reject plugin with missing entryPoint', async () => {
+      await expect(
+        marketplace.installPlugin(makeManifest({ entryPoint: '' }))
+      ).rejects.toThrow('entryPoint');
+    });
+
+    it('should reject plugin with circular dependencies', async () => {
+      // Register plugin A depending on B
+      marketplace.registry.register(
+        makeManifest({ name: 'plugin-a', dependencies: { 'plugin-b': '^1.0.0' } })
+      );
+      // Register plugin B depending on A
+      marketplace.registry.register(
+        makeManifest({ name: 'plugin-b', dependencies: { 'plugin-a': '^1.0.0' } })
+      );
+
+      // Now try installing C which depends on A (which circularly depends on B)
+      await expect(
+        marketplace.installPlugin(
+          makeManifest({
+            name: 'plugin-c',
+            dependencies: { 'plugin-a': '^1.0.0' },
+            entryPoint: '1 + 1',
+          })
+        )
+      ).rejects.toThrow('Circular');
+    });
+
+    it('should throw when dependency is not in registry', async () => {
+      await expect(
+        marketplace.installPlugin(
+          makeManifest({
+            name: 'my-plugin',
+            dependencies: { 'unknown-dep': '^1.0.0' },
+          })
+        )
+      ).rejects.toThrow('not found');
+    });
+
+    it('should handle plugin execution failure', async () => {
+      const result = await marketplace.installPlugin(
+        makeManifest({ entryPoint: 'throw new Error("init failed")' })
+      );
+      expect(result.executionResult.success).toBe(false);
+      expect(result.executionResult.error).toBe('init failed');
+    });
+  });
+});
