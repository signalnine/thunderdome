+import { describe, it, expect } from 'vitest';
+import { createResolver } from './index.js';
+
+describe('Resolver', () => {
+  const resolver = createResolver();
+
+  describe('satisfies', () => {
+    it('should check if version satisfies range', () => {
+      expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);
+      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+      expect(resolver.satisfies('1.5.0', '>=1.0.0 <2.0.0')).toBe(true);
+    });
+  });
+
+  describe('maxSatisfying', () => {
+    it('should find max version satisfying range', () => {
+      expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0')).toBe('1.5.0');
+      expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^2.0.0')).toBe('2.0.0');
+    });
+
+    it('should return null when no version satisfies', () => {
+      expect(resolver.maxSatisfying(['1.0.0'], '^2.0.0')).toBeNull();
+    });
+  });
+
+  describe('validRange', () => {
+    it('should validate semver ranges', () => {
+      expect(resolver.validRange('^1.0.0')).toBe(true);
+      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);
+      expect(resolver.validRange('not-a-range')).toBe(false);
+    });
+  });
+
+  describe('resolve', () => {
+    it('should resolve version constraints', () => {
+      const constraints = [
+        { name: 'foo', range: '^1.0.0' },
+        { name: 'bar', range: '~2.1.0' },
+      ];
+      const available = {
+        foo: ['1.0.0', '1.2.0', '1.5.0', '2.0.0'],
+        bar: ['2.0.0', '2.1.0', '2.1.5', '2.2.0'],
+      };
+
+      const resolved = resolver.resolve(constraints, available);
+      expect(resolved.length).toBe(2);
+
+      const foo = resolved.find(r => r.name === 'foo');
+      expect(foo?.version).toBe('1.5.0');
+      expect(foo?.satisfies).toBe('^1.0.0');
+
+      const bar = resolved.find(r => r.name === 'bar');
+      expect(bar?.version).toBe('2.1.5');
+    });
+
+    it('should throw when no versions available', () => {
+      expect(() => resolver.resolve([{ name: 'x', range: '^1.0.0' }], {})).toThrow();
+    });
+
+    it('should throw when no version satisfies range', () => {
+      expect(() =>
+        resolver.resolve(
+          [{ name: 'x', range: '^3.0.0' }],
+          { x: ['1.0.0', '2.0.0'] }
+        )
+      ).toThrow();
+    });
+  });
+});
