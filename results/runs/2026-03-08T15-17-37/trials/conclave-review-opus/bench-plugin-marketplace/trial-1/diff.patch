tAverageRating('foo')).toBe(5); // only unflagged review is 5\n    45→  });\n    46→\n    47→  it('should return 0 for plugins with no reviews', () => {\n    48→    expect(reviews.getAverageRating('nonexistent')).toBe(0);\n    49→  });\n    50→\n    51→  it('should flag and retrieve flagged reviews', () => {\n    52→    const r = reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 1, comment: 'bad' });\n    53→    reviews.flagReview(r.id);\n    54→\n    55→    const flagged = reviews.getFlaggedReviews();\n    56→    expect(flagged.length).toBe(1);\n    57→    expect(flagged[0].flagged).toBe(true);\n    58→  });\n    59→\n    60→  it('should remove reviews', () => {\n    61→    const r = reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    62→    expect(reviews.removeReview(r.id)).toBe(true);\n    63→    expect(reviews.getReviews('foo').length).toBe(0);\n    64→    expect(reviews.removeReview(r.id)).toBe(false);\n    65→  });\n    66→\n    67→  it('should get reviews by user', () => {\n    68→    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'alice', rating: 5, comment: '' });\n    69→    reviews.addReview({ pluginName: 'bar', pluginVersion: '1.0.0', userId: 'alice', rating: 4, comment: '' });\n    70→    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'bob', rating: 3, comment: '' });\n    71→\n    72→    const aliceReviews = reviews.getReviewsByUser('alice');\n    73→    expect(aliceReviews.length).toBe(2);\n    74→  });\n    75→\n    76→  it('should count reviews', () => {\n    77→    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    78→    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: '' });\n    79→\n    80→    expect(reviews.getReviewCount('foo')).toBe(2);\n    81→    expect(reviews.getReviewCount('bar')).toBe(0);\n   