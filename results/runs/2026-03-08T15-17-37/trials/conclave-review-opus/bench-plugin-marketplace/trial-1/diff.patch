new file mode 100644
index 0000000..c916163
--- /dev/null
+++ b/src/runner/index.ts
@@ -0,0 +1,74 @@
+import vm from 'node:vm';
+import type { SandboxResult, RunnerService } from '../types.js';
+
+export function createRunner(): RunnerService {
+  async function run(
+    code: string,
+    timeoutMs: number,
+    context: Record<string, unknown> = {}
+  ): Promise<SandboxResult> {
+    const startMem = process.memoryUsage().heapUsed;
+    const start = performance.now();
+
+    try {
+      const sandbox: Record<string, unknown> = {
+        ...context,
+        console: {
+          log: (...args: unknown[]) => {
+            sandbox.__output = args.length === 1 ? args[0] : args;
+          },
+        },
+        __output: undefined,
+      };
+
+      const vmContext = vm.createContext(sandbox);
+      const script = new vm.Script(code);
+      const result = script.runInContext(vmContext, { timeout: timeoutMs });
+
+      const duration = performance.now() - start;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - startMem);
+
+      // If the script used console.log, prefer that output; otherwise use the return value
+      const output = sandbox.__output !== undefined ? sandbox.__output : result;
+
+      return {
+        success: true,
+        output,
+        duration,
+        memoryUsed,
+      };
+    } catch (err: unknown) {
+      const duration = performance.now() - start;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - startMem);
+      const errorMessage =
+        err !== null && typeof err === 'object' && 'message' in err
+          ? String((err as { message: unknown }).message)
+          : String(err);
+
+      return {
+        success: false,
+        output: null,
+        duration,
+        memoryUsed,
+        error: errorMessage,
+      };
+    }
+  }
+
+  return {
+    async execute(
+      code: string,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return run(code, 5000, context);
+    },
+
+    async executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return run(code, timeoutMs, context);
+    },
+  };
+}
