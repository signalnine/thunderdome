hrow new Error(`Document \"${id}\" does not exist`);\n    }\n    entry.deleted = true;\n  }\n\n  // ---- Version History ----\n\n  getHistory(id: string): Version[] {\n    const state = this.getBranchState();\n    const entry = state.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    return entry.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const state = this.getBranchState();\n    const entry = state.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    const version = entry.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" does not exist for document \"${id}\"`);\n    }\n    return deepClone(version.content);\n  }\n\n  // ---- Branching ----\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n\n    const sourceBranchName = fromBranch ?? this.currentBranch;\n    const sourceState = this.getBranchState(sourceBranchName);\n    const snapshot = cloneDocuments(sourceState.documents);\n\n    this.branches.set(name, {\n      documents: cloneDocuments(sourceState.documents),\n      forkPoints: new Map(),\n    });\n\n    // Record the fork point: store the snapshot of the source branch at fork time\n    this.branchOrigins.set(name, {\n      parentBranch: sourceBranchName,\n      snapshot,\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" does not exist`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // ---- Merging ----\