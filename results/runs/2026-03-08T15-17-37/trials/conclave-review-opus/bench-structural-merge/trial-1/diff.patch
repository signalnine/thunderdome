oString(36);\n}\n\nfunction cloneDocuments(docs: Map<string, DocumentEntry>): Map<string, DocumentEntry> {\n  const cloned = new Map<string, DocumentEntry>();\n  for (const [id, entry] of docs) {\n    cloned.set(id, {\n      content: deepClone(entry.content),\n      versions: entry.versions.map(v => ({\n        id: v.id,\n        timestamp: v.timestamp,\n        content: deepClone(v.content),\n      })),\n      deleted: entry.deleted,\n    });\n  }\n  return cloned;\n}\n\n/**\n * Get all leaf paths and their values from an object.\n * Returns dot-separated paths.\n */\nfunction getLeafPaths(obj: unknown, prefix: string = ''): Map<string, unknown> {\n  const result = new Map<string, unknown>();\n\n  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {\n    result.set(prefix, obj);\n    return result;\n  }\n\n  const keys = Object.keys(obj as Record<string, unknown>);\n  if (keys.length === 0) {\n    // Empty object is a leaf\n    result.set(prefix, obj);\n    return result;\n  }\n\n  for (const key of keys) {\n    const newPrefix = prefix ? `${prefix}.${key}` : key;\n    const value = (obj as Record<string, unknown>)[key];\n\n    if (value !== null && value !== undefined && typeof value === 'object' && !Array.isArray(value) && Object.keys(value).length > 0) {\n      for (const [path, val] of getLeafPaths(value, newPrefix)) {\n        result.set(path, val);\n      }\n    } else {\n      result.set(newPrefix, value);\n    }\n  }\n\n  return result;\n}\n\n/**\n * Set a value at a dot-separated path in an object.\n */\nfunction setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (!(parts[i] in current) || typeof current[parts[i]] !== 'object' || current[parts[i]] === null || Array.isArray(current[parts[i]])) {\n      current[parts[i]] = {};\n    }\n    current = current[parts[i]] as Record<string, unknown>;\n  }\n  current[parts[parts.length - 1]] = value;\n}\n\n/**\n * Delete a value at a dot-separated path in an object, cleaning up empty parent objects.\n */\nfunction deleteAtPath(obj: Record<string, unknown>, path: string): void {\n  const parts = path.split('.');\n  if (parts.length === 1) {\n    delete obj[parts[0]];\n    return;\n  }\n\n  const stack: Record<string, unknown>[] = [obj];\n  let current: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (!(parts[i] in current) || typeof current[parts[i]] !== 'object' || current[parts[i]] === null) {\n      return;\n    }\n    current = current[parts[i]] as Record<string, unknown>;\n    stack.push(current);\n  }\n  delete current[parts[parts.length - 1]];\n}\n\nconst DELETED_SENTINEL = Symbol('deleted');\n\nfunction valuesEqual(a: unknown, b: unknown): boolean {\n  if (a === b) return true;\n  if (a === DELETED_SENTINEL || b === DELETED_SENTINEL) return a === b;\n  return JSON.stringify(a) === JSON.stringify(b);\n}\n\n/**\n * Three-way merge of two objects against a common base.\n * Returns the merged object and any conflicts.\n */\nfunction threeWayMerge(\n  base: object | null,\n  ours: object | null,\n  theirs: object | null,\n  documentId: string\n): { merged: object; conflicts: Conflict[] } {\n  const basePaths = base ? getLeafPaths(base) : new Map<string, unknown>();\n  const ourPaths = ours ? getLeafPaths(ours) : new Map<string, unknown>();\n  const theirPaths = theirs ? getLeafPaths(theirs) : new Map<string, unknown>();\n\n  // Collect all unique paths\n  const allPaths = new Set<string>();\n  for (const p of basePaths.keys()) allPaths.add(p);\n  for (const p of ourPaths.keys()) allPaths.add(p);\n  for (const p of theirPaths.keys()) allPaths.add(p);\n\n  const conflicts: Conflict[] = [];\n  const merged: Record<string, unknown> = {};\n\n  for (const path of allPaths) {\n    const baseVal = basePaths.has(path) ? basePaths.get(path) : DELETED_SENTINEL;\n    const ourVal = ourPaths.has(path) ? ourPaths.get(path) : DELETED_SENTINEL;\n    const theirVal = theirPaths.has(path) ? theirPaths.get(path) : DELETED_SENTINEL;\n\n    const ourChanged = !valuesEqual(baseVal, ourVal);\n    const theirChanged = !valuesEqual(baseVal, theirVal);\n\n    if (!ourChanged && !theirChanged) {\n      // Neither side changed\n      if (ourVal !== DELETED_SENTINEL) {\n        setAtPath(merged, path, deepClone(ourVal));\n      }\n    } else if (ourChanged && !theirChanged) {\n      // Only we changed\n      if (ourVal !== DELETED_SENTINEL) {\n        setAtPath(merged, path, deepClone(ourVal));\n      }\n      // If ourVal is DELETED_SENTINEL, we deleted it - don't include\n    } else if (!ourChanged && theirChanged) {\n      // Only they changed\n      if (theirVal !== DELETED_SENTINEL) {\n        setAtPath(merged, path, deepClone(theirVal));\n      }\n      // If theirVal is DELETED_SENTINEL, they deleted it - don't include\n    } else {\n      // Both changed\n      if (valuesEqual(ourVal, theirVal)) {\n        // Both changed to the same value\n        if (ourVal !== DELETED_SENTINEL) {\n          setAtPath(merged, path, deepClone(ourVal));\n        }\n      } else {\n        // Conflict! Resolve in favor of \"ours\" for merged output\n        if (ourVal !== DELETED_SENTINEL) {\n          setAtPath(merged, path, deepClone(ourVal));\n        }\n        conflicts.push({\n          documentId,\n          path,\n          base: baseVal === DELETED_SENTINEL ? undefined : deepClone(baseVal),\n          ours: ourVal === DELETED_SENTINEL ? undefined : deepClone(ourVal),\n          theirs: theirVal === DELETED_SENTINEL ? undefined : deepClone(theirVal),\n        });\n      }\n    }\n  }\n\n  return { merged, conflicts };\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchState> = new Map();\n  private currentBranch: string = 'main';\n  /** Records from which branch (and its snapshot) each branch was forked */\n