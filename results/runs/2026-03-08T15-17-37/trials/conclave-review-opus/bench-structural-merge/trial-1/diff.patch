ursEntry.deleted ? oursEntry.content : null;\n   409→      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : null;\n   410→\n   411→      // Check if anything changed\n   412→      const oursChanged = !valuesEqual(baseContent, oursContent);\n   413→      const theirsChanged = !valuesEqual(baseContent, theirsContent);\n   414→\n   415→      if (!oursChanged && !theirsChanged) {\n   416→        // No changes on either side for this document - keep as-is\n   417→        if (oursContent !== null) {\n   418→          merged[docId] = deepClone(oursContent);\n   419→        }\n   420→        continue;\n   421→      }\n   422→\n   423→      if (!oursChanged && theirsChanged) {\n   424→        // Only source changed - take theirs\n   425→        if (theirsContent !== null) {\n   426→          merged[docId] = deepClone(theirsContent);\n   427→        }\n   428→        // If theirsContent is null (deleted), don't include in merged\n   429→        continue;\n   430→      }\n   431→\n   432→      if (oursChanged && !theirsChanged) {\n   433→        // Only target changed - keep ours\n   434→        if (oursContent !== null) {\n   435→          merged[docId] = deepClone(oursContent);\n   436→        }\n   437→        continue;\n   438→      }\n   439→\n   440→      // Both changed - do three-way merge\n   441→      if (oursContent === null && theirsContent === null) {\n   442→        // Both deleted - no conflict\n   443→        continue;\n   444→      }\n   445→\n   446→      if (oursContent === null || theirsContent === null) {\n   447→        // One deleted, one modified - conflict at document level\n   448→        // For merged, use ours (which might be null/deleted)\n   449→        if (oursContent !== null) {\n   450→          merged[docId] = deepClone(oursContent);\n   451→        }\n   452→        allConflicts.push({\n   453→          documentId: docId,\n   454→          path: '',\n   455→          base: baseContent !== null ? deepClone(base