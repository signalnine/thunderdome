 T): T {\n  return JSON.parse(JSON.stringify(obj));\n}\n\nfunction generateId(): string {\n  return Math.random().toString(36).substring(2) + Date.now().toString(36);\n}\n\nfunction cloneDocuments(docs: Map<string, DocumentEntry>): Map<string, DocumentEntry> {\n  const cloned = new Map<string, DocumentEntry>();\n  for (const [id, entry] of docs) {\n    cloned.set(id, {\n      content: deepClone(entry.content),\n      versions: entry.versions.map(v => ({\n        id: v.id,\n        timestamp: v.timestamp,\n        content: deepClone(v.content),\n      })),\n      deleted: entry.deleted,\n    });\n  }\n  return cloned;\n}\n\n/**\n * Get all leaf paths and their values from an object.\n * Returns dot-separated paths.\n */\nfunction getLeafPaths(obj: unknown, prefix: string = ''): Map<string, unknown> {\n  const result = new Map<string, unknown>();\n\n  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {\n    result.set(prefix, obj);\n    return result;\n  }\n\n  const keys = Object.keys(obj as Record<string, unknown>);\n  if (keys.length === 0) {\n    // Empty object is a leaf\n    result.set(prefix, obj);\n    return result;\n  }\n\n  for (const key of keys) {\n    const newPrefix = prefix ? `${prefix}.${key}` : key;\n    const value = (obj as Record<string, unknown>)[key];\n\n    if (value !== null && value !== undefined && typeof value === 'object' && !Array.isArray(value) && Object.keys(value).length > 0) {\n      for (const [path, val] of getLeafPaths(value, newPrefix)) {\n        result.set(path, val);\n      }\n    } else {\n      result.set(newPrefix, value);\n    }\n  }\n\n  return result;\n}\n\n/**\n * Set a value at a dot-separated path in an object.\n */\nfunction setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (!(parts[i] in current) || typeof current[parts[i]] !== 'object' || current[parts[i]] === null || Array.isArray(current[parts[i]])) {\n      current[parts[i]] = {};\n    }\n    current = current[parts[i]] as Record<string, unknown>;\n  }\n  current[parts[parts.length - 1]] = value;\n}\n\nconst DELETED_SENTINEL = Symbol('deleted');\n\nfunction valuesEqual(a: unknown, b: unknown): boolean {\n  if (a === b) return true;\n  if (a === DELETED_SENTINEL || b === DELETED_SENTINEL) return a === b;\n  return JSON.stringify(a) === JSON.stringify(b);\n}\n\n/**\n * Three-way merge of two objects against a common base.\n * Returns the merged object and any conflicts.\n */\nfunction threeWayMerge(\n  base: object | null,\n  ours: object | null,\n  theirs: object | null,\n  documentId: string\n): { merged: object; conflicts: Conflict[] } {\n  const basePaths = base ? getLeafPaths(base) : new Map<string, unknown>();\n  const ourPaths = ours ? getLeafPaths(ours) : new Map<string, unknown>();\n  const theirPaths = theirs ? getLeafPaths(theirs) : new Map<string, unknown>();\n\n  // Collect all unique paths\n  const allPaths = new Set<string>();\n  for (const p of basePaths.keys()) allPaths.add(p);\n  for (const p of ourPaths.keys()) allPaths.add(p);\n  for (const p of theirPaths.keys()) allPaths.add(p);\n\n  const conflicts: Conflict[] = [];\n  const merged: Record<string, unknown> = {};\n\n  for (const path of allPaths) {\n    const baseVal = basePaths.has(path) ? basePaths.get(path) : DELETED_SENTINEL;\n    const ourVal = ourPaths.has(path) ? ourPaths.get(path) : DELETED_SENTINEL;\n    const theirVal = theirPaths.has(path) ? theirPaths.get(path) : DELETED_SENTINEL;\n\n    const ourChanged = !valuesEqual(baseVal, ourVal);\n    const theirChanged = !valuesEqual(baseVal, theirVal);\n\n    if (!ourChanged && !theirChanged) {\n      // Neither side changed\n      if (ourVal !== DELETED_SENTINEL) {\n        setAtPath(merged, path, deepClone(ourVal));\n      }\n    } else if (ourChanged && !theirChanged) {\n      // Only we changed\n      if (ourVal !== DELETED_SENTINEL) {\n        setAtPath(merged, path, deepClone(ourVal));\n      }\n      // If ourVal is DELETED_SENTINEL, we deleted it - don't include\n    } else if (!ourChanged && theirChanged) {\n      // Only they changed\n      if (theirVal !== DELETED_SENTINEL) {\n        setAtPath(merged, path, deepClone(theirVal));\n      }\n      // If theirVal is DELETED_SENTINEL, they deleted it - don't include\n    } else {\n      // Both changed\n      if (valuesEqual(ourVal, theirVal)) {\n        // Both changed to the same value\n        if (ourVal !== DELETED_SENTINEL) {\n          setAtPath(merged, path, deepClone(ourVal));\n        }\n      } else {\n        // Conflict! Resolve in favor of \"ours\" for merged output\n        if (ourVal !== DELETED_SENTINEL) {\n          setAtPath(merged, path, deepClone(ourVal));\n        }\n        conflicts.push({\n          documentId,\n          path,\n          base: baseVal === DELETED_SENTINEL ? undefined : deepClone(baseVal),\n          ours: ourVal === DELETED_SENTINEL ? undefined : deepClone(ourVal),\n          theirs: theirVal === DELETED_SENTINEL ? undefined : deepClone(theirVal),\n        });\n      }\n    }\n  }\n\n  return { merged, conflicts };\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchState> = new Map();\n  private currentBranch: string = 'main';\n  /** Records from which branch (and its snapshot) each branch was forked */\n  private branchOrigins: Map<string, { parentBranch: string; snapshot: Map<string, DocumentEntry> }> = new Map();\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n    });\n  }\n\n  private getBranchState(name?: string): BranchState {\n    const branchName = name ?? this.currentBranch;\n    const state = this.branches.get(branchName);\n    if (!state) {\n      throw new Error(`Branch \"${branchName}\" does not exist`);\n    }\n    return state;\n  }\n\n  // ---- Document CRUD ----\n\n  create(id: string, content: object): void {\n    const state = this.getBranchState();\n    const existing = state.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n\n    const version: Version = {\n      id: generateId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n\n    state.documents.set(id, {\n      content: deepClone(content),\n      versions: existing?.deleted ? [...existing.versions, version] : [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const state = this.getBranchState();\n    const entry = state.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    return deepClone(entry.content);\n  }\n\n  update(id: string, content: object): void {\n    const state = this.getBranchState();\n    const entry = state.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n\n    const version: Version = {\n      id: generateId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n\n    entry.content = deepClone(content);\n    entry.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const state = this.getBranchState();\n    const entry = state.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    entry.deleted = true;\n  }\n\n  // ---- Version History ----\n\n  getHistory(id: string): Version[] {\n    const state = this.getBranchState();\n    const entry = state.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    return entry.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const state = this.getBranchState();\n    const entry = state.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    const version = entry.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" does not exist for document \"${id}\"`);\n    }\n    return deepClone(version.content);\n  }\n\n  // ---- Branching ----\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n\n    const sourceBranchName = fromBranch ?? this.currentBranch;\n    const sourceState = this.getBranchState(sourceBranchName);\n    const snapshot = cloneDocuments(sourceState.documents);\n\n    this.branches.set(name, {\n      documents: cloneDocuments(sourceState.documents),\n    });\n\n    // Record the fork point: store the snapshot of the source branch at fork time\n    this.branchOrigins.set(name, {\n      parentBranch: sourceBranchName,\n      snapshot,\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" does not exist`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // ---- Merging ----\n\n  /**\n   * Find the common ancestor state between two branches by tracing branch origins.\n   */\n  private findCommonAncestor(\n    targetBranch: string,\n    sourceBranch: string\n  ): Map<string, DocumentEntry> {\n    // If sourceBranch was forked from targetBranch, the ancestor is the fork point snapshot\n    const sourceOrigin = this.branchOrigins.get(sourceBranch);\n    if (sourceOrigin && sourceOrigin.parentBranch === targetBranch) {\n      return sourceOrigin.snapshot;\n    }\n\n    // If targetBranch was forked from sourceBranch, the ancestor is the fork point snapshot\n    const targetOrigin = this.branchOrigins.get(targetBranch);\n    if (targetOrigin && targetOrigin.parentBranch === sourceBranch) {\n      return targetOrigin.snapshot;\n    }\n\n    // Both branches forked from a common parent - trace up\n    // For simplicity: find shared ancestor by tracing origins\n    const sourceAncestors = this.getAncestorChain(sourceBranch);\n    const targetAncestors = this.getAncestorChain(targetBranch);\n\n    // Find the most recent common ancestor\n    for (const [sBranch, sSnapshot] of sourceAncestors) {\n      for (const [tBranch] of targetAncestors) {\n        if (sBranch === tBranch) {\n          return sSnapshot;\n        }\n      }\n    }\n\n    // No common ancestor found, use empty state\n    return new Map();\n  }\n\n  private getAncestorChain(branchName: string): Array<[string, Map<string, DocumentEntry>]> {\n    const chain: Array<[string, Map<string, DocumentEntry>]> = [];\n    let current = branchName;\n    while (this.branchOrigins.has(current)) {\n      const origin = this.branchOrigins.get(current)!;\n      chain.push([origin.parentBranch, origin.snapshot]);\n      current = origin.parentBranch;\n    }\n    return chain;\n  }\n\n  merge(sourceBranch: string): MergeResult {\n    if (!this.branches.has(sourceBranch)) {\n      throw new Error(`Branch \"${sourceBranch}\" does not exist`);\n    }\n\n    const targetState = this.getBranchState();\n    const sourceState = this.getBranchState(sourceBranch);\n    const ancestorDocs = this.findCommonAncestor(this.currentBranch, sourceBranch);\n\n    // Collect all document IDs across all three states\n    const allDocIds = new Set<string>();\n    for (const id of ancestorDocs.keys()) allDocIds.add(id);\n    for (const id of targetState.documents.keys()) allDocIds.add(id);\n    for (const id of sourceState.documents.keys()) allDocIds.add(id);\n\n    const merged: Record<string, object> = {};\n    const allConflicts: Conflict[] = [];\n\n    for (const docId of allDocIds) {\n      const baseEntry = ancestorDocs.get(docId);\n      const oursEntry = targetState.documents.get(docId);\n      const theirsEntry = sourceState.documents.get(docId);\n\n      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;\n      const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : null;\n      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : null;\n\n      // Check if anything changed\n      const oursChanged = !valuesEqual(baseContent, oursContent);\n      const theirsChanged = !valuesEqual(baseContent, theirsContent);\n\n      if (!oursChanged && !theirsChanged) {\n        // No changes on either side for this document - keep as-is\n        if (oursContent !== null) {\n          merged[docId] = deepClone(oursContent);\n        }\n        continue;\n      }\n\n      if (!oursChanged && theirsChanged) {\n        // Only source changed - take theirs\n        if (theirsContent !== null) {\n          merged[docId] = deepClone(theirsContent);\n        }\n        // If theirsContent is null (deleted), don't include in merged\n        continue;\n      }\n\n      if (oursChanged && !theirsChanged) {\n        // Only target changed - keep ours\n        if (oursContent !== null) {\n          merged[docId] = deepClone(oursContent);\n        }\n        continue;\n      }\n\n      // Both changed - do three-way merge\n      if (oursContent === null && theirsContent === null) {\n        // Both deleted - no conflict\n        continue;\n      }\n\n      if (oursContent === null || theirsContent === null) {\n        // One deleted, one modified - conflict at document level\n        // For merged, use ours (which might be null/deleted)\n        if (oursContent !== null) {\n          merged[docId] = deepClone(oursContent);\n        }\n        allConflicts.push({\n          documentId: docId,\n          path: '',\n          base: baseContent !== null ? deepClone(baseContent) : undefined,\n          ours: oursContent !== null ? deepClone(oursContent) : undefined,\n          theirs: theirsContent !== null ? deepClone(theirsContent) : undefined,\n        });\n        continue;\n      }\n\n      // Both modified - structural merge\n      const { merged: mergedContent, conflicts } = threeWayMerge(\n        baseContent,\n        oursContent,\n        theirsContent,\n        docId\n      );\n      merged[docId] = mergedContent;\n      allConflicts.push(...conflicts);\n    }\n\n    const applied = allConflicts.length === 0;\n\n    if (applied) {\n      // Apply the merge to the current branch\n      for (const docId of allDocIds) {\n        if (docId in merged) {\n          const existingEntry = targetState.documents.get(docId);\n          const version: Version = {\n            id: generateId(),\n            timestamp: Date.now(),\n            content: deepClone(merged[docId]),\n          };\n\n          if (existingEntry) {\n            // Check if content actually changed\n            if (!valuesEqual(existingEntry.content, merged[docId]) || existingEntry.deleted) {\n              existingEntry.content = deepClone(merged[docId]);\n              existingEntry.deleted = false;\n              existingEntry.versions.push(version);\n            }\n          } else {\n            targetState.documents.set(docId, {\n              content: deepClone(merged[docId]),\n              versions: [version],\n              deleted: false,\n            });\n          }\n        } else {\n          // Document was deleted in the merge\n          const existingEntry = targetState.documents.get(docId);\n          if (existingEntry && !existingEntry.deleted) {\n            existingEntry.deleted = true;\n          }\n        }\n      }\n\n      // Update the fork point so subsequent merges use the current state as base\n      this.branchOrigins.set(sourceBranch, {\n        parentBranch: this.currentBranch,\n        snapshot: cloneDocuments(targetState.documents),\n      });\n    }\n\n    return { merged, conflicts: allConflicts, applied };\n  }\n}\n","structuredPatch":[{"oldStart":107,"oldLines":7,"newStart":107,"newLines":22,"lines":[" function valuesEqual(a: unknown, b: unknown): boolean {","   if (a === b) return true;","   if (a === DELETED_SENTINEL || b === DELETED_SENTINEL) return a === b;","-  return JSON.stringify(a) === JSON.stringify(b);","+  if (a === null || b === null) return a === b;","+  if (typeof a !== typeof b) return false;","+  if (typeof a !== 'object') return a === b;","+","+  if (Array.isArray(a) !== Array.isArray(b)) return false;","+  if (Array.isArray(a) && Array.isArray(b)) {","+    if (a.length !== b.length) return false;","+    return a.every((val, i) => valuesEqual(val, (b as unknown[])[i]));","+  }","+","+  const aObj = a as Record<string, unknown>;","+  const bObj = b as Record<string, unknown>;","+  const aKeys = Object.keys(aObj);","+  const bKeys = Object.keys(bObj);","+  if (aKeys.length !== bKeys.length) return false;","+  return aKeys.every(key => key in bObj && valuesEqual(aObj[key], bObj[key]));"," }"," "," /**"]}],"userModified":false,"replaceAll":false}}
