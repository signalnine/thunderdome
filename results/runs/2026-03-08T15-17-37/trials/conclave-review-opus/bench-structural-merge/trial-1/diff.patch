+    }
+    return deepClone(entry.content);
+  }
+
+  update(id: string, content: object): void {
+    const state = this.getBranchState();
+    const entry = state.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    entry.content = deepClone(content);
+    entry.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const state = this.getBranchState();
+    const entry = state.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    entry.deleted = true;
+  }
+
