+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016P5F8PZyimkMk6woWCEYNG","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→import type {\n     3→  Task,\n     4→  AddTaskOptions,\n     5→  ScheduleOptions,\n     6→  Schedule,\n     7→  MiddlewareFn,\n     8→  HandlerFn,\n     9→  ProgressListener,\n    10→  ShutdownOptions,\n    11→  ShutdownSummary,\n    12→  QueueConfig,\n    13→} from './types.js';\n    14→\n    15→const DEFAULT_QUEUE = 'default';\n    16→const DEFAULT_PRIORITY = 5;\n    17→const DEFAULT_MAX_RETRIES = 3;\n    18→const DEFAULT_BACKOFF_DELAY = 1000;\n    19→\n    20→export class TaskQueue {\n    21→  private tasks: Map<string, Task> = new Map();\n    22→  private queues: Map<string, Task[]> = new Map();\n    23→  private dlqs: Map<string, Task[]> = new Map();\n    24→  private queueConfigs: Map<string, QueueConfig> = new Map();\n    25→  private activeCount: Map<string, number> = new Map();\n    26→  private schedules: Map<string, Schedule> = new Map();\n    27→  private middleware: Map<string, MiddlewareFn[]> = new Map();\n    28→  private handlers: Map<string, HandlerFn> = new Map();\n    29→  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n    30→  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n    31→  private isShuttingDown = false;\n    32→  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n    33→\n    34→  // Phase 1: Add a task\n    35→  add<T = unknown>(options: AddTaskOptions<T>): Task<T> {\n    36→    if (this.isShuttingDown) {\n    37→      throw new Error('Queue system is shutting down; cannot add new tasks');\n    38→    }\n    39→\n    40→    const queueName = options.queue ?? DEFAULT_QUEUE;\n    41→    const priority = options.priority ?? DEFAULT_PRIORITY;\n    42→\n    43→    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n    44→      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    45→    }\n    46→\n    47→    // Phase 7: Validate dependencies\n    48→    const dependencies = options.dependencies ?? [];\n    49→    for (const depId of dependencies) {\n    50→      if (!this.tasks.has(depId)) {\n    51→        throw new Error(`Dependency task '${depId}' does not exist`);\n    52→      }\n    53→    }\n    54→\n    55→    const now = new Date();\n    56→    let availableAt = now;\n    57→    if (options.availableAt) {\n    58→      availableAt = options.availableAt;\n    59→    } else if (options.delay != null && options.delay > 0) {\n    60→      availableAt = new Date(now.getTime() + options.delay);\n    61→    }\n    62→\n    63→    // Determine initial status\n    64→    const hasUnresolvedDeps = dependencies.length > 0 && dependencies.some(depId => {\n    65→      const depTask = this.tasks.get(depId);\n    66→      return depTask?.status !== 'completed';\n    67→    });\n    68→\n    69→    const task: Task<T> = {\n    70→      id: randomUUID(),\n    71→      payload: options.payload,\n    72→      status: hasUnresolvedDeps ? 'blocked' : 'pending',\n    73→      queue: queueName,\n    74→      priority,\n    75→      createdAt: now,\n    76→      updatedAt: now,\n    77→      availableAt,\n    78→      attempts: 0,\n    79→      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,\n    80→      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n    81→      dependencies: [...dependencies],\n    82→      resolvedDependencies: new Set(\n    83→        dependencies.filter(depId => {\n    84→          const depTask = this.tasks.get(depId);\n    85→          return depTask?.status === 'completed';\n    86→        })\n    87→      ),\n    88→      progress: 0,\n    89→      metadata: {},\n    90→    };\n    91→\n    92→    this.tasks.set(task.id, task as Task);\n    93→\n    94→    // Add to queue list\n    95→    if (!this.queues.has(queueName)) {\n    96→      this.queues.set(queueName, []);\n    97→    }\n    98→    this.queues.get(queueName)!.push(task as Task);\n    99→\n   100→    return task;\n   101→  }\n   102→\n   103→  // Phase 1: Get the next task\n   104→  next(queueName?: string): Task | null {\n   105→    const name = queueName ?? DEFAULT_QUEUE;\n   106→    const queue = this.queues.get(name);\n   107→    if (!queue) return null;\n   108→\n   109→    // Phase 8: Check concurrency limit\n   110→    const config = this.queueConfigs.get(name);\n   111→    if (config?.concurrency != null) {\n   112→      const active = this.activeCount.get(name) ?? 0;\n   113→      if (active >= config.concurrency) {\n   114→        return null;\n   115→      }\n   116→    }\n   117→\n   118→    const now = new Date();\n   119→\n   120→    // Find the best candidate: pending, available, unblocked, ordered by priority then FIFO\n   121→    let bestIdx = -1;\n   122→    let bestTask: Task | null = null;\n   123→\n   124→    for (let i = 0; i < queue.length; i++) {\n   125→      const t = queue[i];\n   126→      if (t.status !== 'pending') continue;\n   127→      if (t.availableAt > now) continue;\n   128→\n   129→      if (bestTask === null ||\n   130→          t.priority < bestTask.priority ||\n   131→          (t.priority === bestTask.priority && t.availableAt < bestTask.availableAt) ||\n   132→          (t.priority === bestTask.priority && t.availableAt.getTime() === bestTask.availableAt.getTime() && t.createdAt < bestTask.createdAt)) {\n   133→        bestIdx = i;\n   134→        bestTask = t;\n   135→      }\n   136→    }\n   137→\n   138→    if (bestTask === null) return null;\n   139→\n   140→    bestTask.status = 'processing';\n   141→    bestTask.updatedAt = new Date();\n   142→    bestTask.attempts++;\n   143→\n   144→    // Update active count\n   145→    this.activeCount.set(name, (this.activeCount.get(name) ?? 0) + 1);\n   146→\n   147→    // Remove from queue array\n   148→    queue.splice(bestIdx, 1);\n   149→\n   150→    return bestTask;\n   151→  }\n   152→\n   153→  // Phase 1: Count pending tasks\n   154→  pending(queueName?: string): number {\n   155→    const name = queueName ?? DEFAULT_QUEUE;\n   156→    const queue = this.queues.get(name);\n   157→    if (!queue) return 0;\n   158→    return queue.filter(t => t.status === 'pending').length;\n   159→  }\n   160→\n   161→  // Phase 5: Complete a task\n   162→  complete(taskId: string): Task {\n   163→    const task = this.tasks.get(taskId);\n   164→    if (!task) throw new Error(`Task '${taskId}' not found`);\n   165→    if (task.status !== 'processing') {\n   166→      throw new Error(`Task '${taskId}' is not in processing state (current: ${task.status})`);\n   167→    }\n   168→\n   169→    task.status = 'completed';\n   170→    task.progress = 100;\n   171→    task.updatedAt = new Date();\n   172→\n   173→    // Decrement active count\n   174→    const active = this.activeCount.get(task.queue) ?? 0;\n   175→    if (active > 0) this.activeCount.set(task.queue, active - 1);\n   176→\n   177→    // Phase 7: Check if any blocked tasks can now be unblocked\n   178→    this.checkDependents(taskId);\n   179→\n   180→    return task;\n   181→  }\n   182→\n   183→  // Phase 5: Fail a task\n   184→  fail(taskId: string, error?: string): Task {\n   185→    const task = this.tasks.get(taskId);\n   186→    if (!task) throw new Error(`Task '${taskId}' not found`);\n   187→    if (task.status !== 'processing') {\n   188→      throw new Error(`Task '${taskId}' is not in processing state (current: ${task.status})`);\n   189→    }\n   190→\n   191→    task.lastError = error;\n   192→    task.updatedAt = new Date();\n   193→\n   194→    // Decrement active count\n   195→    const active = this.activeCount.get(task.queue) ?? 0;\n   196→    if (active > 0) this.activeCount.set(task.queue, active - 1);\n   197→\n   198→    // Check if retries remaining\n   199→    if (task.attempts < task.maxRetries) {\n   200→      // Re-add with exponential backoff delay\n   201→      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n   202→      task.status = 'pending';\n   203→      task.availableAt = new Date(Date.now() + delay);\n   204→\n   205→      // Re-add to queue\n   206→      const queue = this.queues.get(task.queue);\n   207→      if (queue) {\n   208→        queue.push(task);\n   209→      }\n   210→    } else {\n   211→      // Phase 6: Move to DLQ\n   212→      task.status = 'failed';\n   213→      this.addToDLQ(task);\n   214→    }\n   215→\n   216→    return task;\n   217→  }\n   218→\n   219→  // Phase 6: Dead Letter Queue operations\n   220→  private addToDLQ(task: Task): void {\n   221→    if (!this.dlqs.has(task.queue)) {\n   222→      this.dlqs.set(task.queue, []);\n   223→    }\n   224→    this.dlqs.get(task.queue)!.push(task);\n   225→  }\n   226→\n   227→  deadLetterQueue(queueName?: string): Task[] {\n   228→    const name = queueName ?? DEFAULT_QUEUE;\n   229→    return [...(this.dlqs.get(name) ?? [])];\n   230→  }\n   231→\n   232→  redrive(taskId: string): Task {\n   233→    const task = this.tasks.get(taskId);\n   234→    if (!task) throw new Error(`Task '${taskId}' not found`);\n   235→    if (task.status !== 'failed') {\n   236→      throw new Error(`Task '${taskId}' is not in failed state`);\n   237→    }\n   238→\n   239→    // Remove from DLQ\n   240→    const dlq = this.dlqs.get(task.queue);\n   241→    if (dlq) {\n   242→      const idx = dlq.findIndex(t => t.id === taskId);\n   243→      if (idx !== -1) dlq.splice(idx, 1);\n   244→    }\n   245→\n   246→    // Reset for fresh round\n   247→    task.status = 'pending';\n   248→    task.attempts = 0;\n   249→    task.progress = 0;\n   250→    task.lastError = undefined;\n   251→    task.availableAt = new Date();\n   252→    task.updatedAt = new Date();\n   253→\n   254→    // Add back to queue\n   255→    const queue = this.queues.get(task.queue);\n   256→    if (queue) {\n   257→      queue.push(task);\n   258→    }\n   259→\n   260→    return task;\n   261→  }\n   262→\n   263→  clearDLQ(queueName?: string): number {\n   264→    const name = queueName ?? DEFAULT_QUEUE;\n   265→    const dlq = this.dlqs.get(name);\n   266→    if (!dlq) return 0;\n   267→    const count = dlq.length;\n   268→    // Remove the tasks from the task map as well\n   269→    for (const t of dlq) {\n   270→      this.tasks.delete(t.id);\n   271→    }\n   272→    this.dlqs.set(name, []);\n   273→    return count;\n   274→  }\n   275→\n   276→  // Phase 7: Check dependents when a task completes\n   277→  private checkDependents(completedTaskId: string): void {\n   278→    for (const [, task] of this.tasks) {\n   279→      if (task.status !== 'blocked') continue;\n   280→      if (!task.dependencies.includes(completedTaskId)) continue;\n   281→\n   282→      task.resolvedDependencies.add(completedTaskId);\n   283→\n   284→      // Check if all dependencies are now resolved\n   285→      const allResolved = task.dependencies.every(depId => task.resolvedDependencies.has(depId));\n   286→      if (allResolved) {\n   287→        task.status = 'pending';\n   288→        task.updatedAt = new Date();\n   289→      }\n   290→    }\n   291→  }\n   292→\n   293→  // Phase 7: Get dependency status\n   294→  getDependencyStatus(taskId: string): { total: number; resolved: number; pending: string[] } {\n   295→    const task = this.tasks.get(taskId);\n   296→    if (!task) throw new Error(`Task '${taskId}' not found`);\n   297→\n   298→    const pending = task.dependencies.filter(d => !task.resolvedDependencies.has(d));\n   299→    return {\n   300→      total: task.dependencies.length,\n   301→      resolved: task.resolvedDependencies.size,\n   302→      pending,\n   303→    };\n   304→  }\n   305→\n   306→  // Phase 2: List queue names\n   307→  listQueues(): string[] {\n   308→    return [...this.queues.keys()];\n   309→  }\n   310→\n   311→  // Phase 1: Get a task by ID\n   312→  getTask(taskId: string): Task | null {\n   313→    re