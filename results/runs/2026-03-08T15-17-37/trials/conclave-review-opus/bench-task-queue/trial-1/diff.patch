+    // */N pattern
+    const stepMatch = field.match(/^\*\/(\d+)$/);
+    if (stepMatch) {
+      const step = parseInt(stepMatch[1], 10);
+      return value % step === 0;
+    }
+
+    // Exact number
+    const num = parseInt(field, 10);
+    if (!isNaN(num)) {
+      return value === num;
+    }
+
+    throw new Error(`Unsupported cron field: '${field}'`);
+  }
+
+  // Phase 11: Register middleware
+  use(queueName: string, fn: MiddlewareFn): void {
+    if (!this.middleware.has(queueName)) {
