resolve immediately if no more processing\n        if (processingTasks.every(t => t.status !== 'processing')) {\n          clearInterval(checkInterval);\n          resolve();\n        }\n      });\n\n      // Count completed and force-cancel remaining\n      for (const task of processingTasks) {\n        if (task.status === 'completed') {\n          completed++;\n        } else if (task.status === 'processing') {\n          task.status = 'cancelled';\n          task.updatedAt = new Date();\n          const active = this.activeCount.get(task.queue) ?? 0;\n          if (active > 0) this.activeCount.set(task.queue, active - 1);\n          forceCancelled++;\n        }\n      }\n    }\n\n    const duration = Date.now() - startTime;\n\n    return {\n      completed,\n      forceCancelled,\n      duration,\n    };\n  }\n\n  // Utility: check if system is shutting down\n  get shuttingDown(): boolean {\n    return this.isShuttingDown;\n  }\n}\n","structuredPatch":[{"oldStart":588,"oldLines":9,"newStart":588,"newLines":22,"lines":[" ","       await executeNext();"," ","-      // Only auto-complete if the pipeline fully executed (all middleware called next)","-      if (task.status === 'processing' && reachedEnd) {","-        this.complete(task.id);","+      if (task.status === 'processing') {","+        if (reachedEnd) {","+          // Pipeline fully executed - auto-complete","+          this.complete(task.id);","+        } else {","+          // Middleware skipped processing (didn't call next) - revert task to pending","+          task.status = 'pending';","+          task.attempts--;","+          task.updatedAt = new Date();","+          const active = this.activeCount.get(name) ?? 0;","+          if (active > 0) this.activeCount.set(name, active - 1);","+          const queue = this.queues.get(name);","+          if (queue) {","+            queue.push(task);","+          }","+        }","       }","     } catch (err) {","       const errorMsg = err instanceof Error ? err.