for (const depId of dependencies) {\n      if (!this.tasks.has(depId)) {\n        throw new Error(`Dependency task '${depId}' does not exist`);\n      }\n    }\n\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      // We'll create a temporary task id to check for cycles\n      const tempId = '__temp__';\n      // Build adjacency: for each task, what tasks depend on it\n      // We need to check: can any of our dependencies eventually lead back to us?\n      // Since we haven't added the task yet, we check if any dependency depends on any of the other deps transitively\n      // Actually, since this task doesn't exist yet, there can't be a cycle involving it unless\n      // two tasks in `dependencies` form a cycle with each other (which would have been caught earlier)\n      // The real cycle concern is if we add dep A -> B -> C -> A. But each step is checked at add time.\n      // So cycles through the new task are impossible since it doesn't exist yet.\n      // However, if a dependency is blocked on some task that will later depend on this one -\n      // we can't know that yet. The spec says to detect circular deps at creation time.\n      // We need to check if adding this task would create a cycle where:\n      // this task depends on X, and X (transitively) depends on this task.\n      // But this task hasn't been created, so nothing can depend on it yet. No cycle possible.\n      // The only scenario: if dependencies themselves form a cycle - but that's already prevented.\n      void tempId;\n    }\n\n    const now = new Date();\n    let availableAt = now;\n    if (options.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    // Determine initial status\n    const hasUnresolvedDeps = dependencies.length > 0 && dependencies.some(depId => {\n      const depTask = this.tasks.get(depId);\n      return depTask?.status !== 'completed';\n    });\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload: options.payload,\n      status: hasUnresolvedDeps ? 'blocked' : 'pending',\n      queue: queueName,\n      priority,\n      createdAt: now,\n      updatedAt: now,\n      availableAt,\n      attempts: 0,\n      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      dependencies: [...dependencies],\n      resolvedDependencies: new Set(\n        dependencies.filter(depId => {\n          const depTask = this.tasks.get(depId);\n          return depTask?.status === 'completed';\n        })\n      ),\n      progress: 0,\n      metadata: {},\n    };\n\n    this.tasks.set(task.id, task as Task);\n\n    // Add to queue list\n    if (!this.queues.has(queueName)) {\n      this.queues.set(queueName, []);\n    }\n    this.queues.get(queueName)!.push(task as Task);\n\n    return task;\n  }\n\n  // Phase 1: Get the next task\n  next(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    if (!queue) return null;\n\n    // Phase 8: Check concurrency limit\n    const config = this.queueConfigs.get(name);\n    if (config?.concurrency != null) {\n      const active = this.activeCount.get(name) ?? 0;\n      if (active >= config.concurrency) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n\n    // Find the best candidate: pending, available, unblocked, ordered by priority then FIFO\n    let bestIdx = -1;\n    let bestTask: Task | null = null;\n\n    for (let i = 0; i < queue.length; i++) {\n      const t = queue[i];\n      if (t.status !== 'pending') continue;\n      if (t.availableAt > now) continue;\n\n      if (bestTask === null || t.priority < bestTask.priority ||\n          (t.priority === bestTask.priority && t.createdAt < bestTask.createdAt)) {\n        bestIdx = i;\n        bestTask = t;\n      }\n    }\n\n    if (bestTask === null) return null;\n\n    bestTask.status = 'processing';\n    bestTask.updatedAt = new Date();\n    bestTask.attempts++;\n\n    // Update active count\n    this.activeCount.set(name, (this.activeCount.get(name) ?? 0) + 1);\n\n    // Remove from queue array\n    queue.splice(bestIdx, 1);\n\n    return bestTask;\n  }\n\n  // Phase 1: Count pending tasks\n  pending(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queue = this.queues.get(name);\n    if (!queue) return 0;\n    return queue.filter(t => t.status === 'pending').length;\n  }\n\n  // Phase 5: Complete a task\n  complete(taskId: string): Task {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task '${taskId}' is not in processing state (current: ${task.status})`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n    task.updatedAt = new Date();\n\n    // Decrement active count\n    const active = this.activeCount.get(task.queue) ?? 0;\n    if (active > 0) this.activeCount.set(task.queue, active - 1);\n\n    // Phase 7: Check if any blocked tasks can now be unblocked\n    this.checkDependents(taskId);\n\n    return task;\n  }\n\n  // Phase 5: Fail a task\n  fail(taskId: string, error?: string): Task {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task '${taskId}' is not in processing state (current: ${task.status})`);\n    }\n\n    task.lastError = error;\n    task.updatedAt = new Date();\n\n    // Decrement active count\n    const active = this.activeCount.get(task.queue) ?? 0;\n    if (active > 0) this.activeCount.set(task.queue, active - 1);\n\n    // Check if retries remaining\n    if (task.attempts < task.maxRetries) {\n      // Re-add with exponential backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n\n      // Re-add to queue\n      const queue = this.queues.get(task.queue);\n      if (queue) {\n        queue.push(task);\n      }\n    } else {\n      // Phase 6: Move to DLQ\n      task.status = 'failed';\n      this.addToDLQ(task);\n    }\n\n    return task;\n  }\n\n  // Phase 6: Dead Letter Queue operations\n  private addToDLQ(task: Task): void {\n    if (!this.dlqs.has(task.queue)) {\n      this.dlqs.set(task.queue, []);\n    }\n    this.dlqs.get(task.queue)!.push(task);\n  }\n\n  deadLetterQueue(queueName?: string): Task[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return [...(this.dlqs.get(name) ?? [])];\n  }\n\n  redrive(taskId: string): Task {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n    if (task.status !== 'failed') {\n      throw new Error(`Task '${taskId}' is not in failed state`);\n    }\n\n    // Remove from DLQ\n    const dlq = this.dlqs.get(task.queue);\n    if (dlq) {\n      const idx = dlq.findIndex(t => t.id === taskId);\n      if (idx !== -1) dlq.splice(idx, 1);\n    }\n\n    // Reset for fresh round\n    task.status = 'pending';\n    task.attempts = 0;\n    task.progress = 0;\n    task.lastError = undefined;\n    task.availableAt = new Date();\n    task.updatedAt = new Date();\n\n    // Add back to queue\n    const queue = this.queues.get(task.queue);\n    if (queue) {\n      queue.push(task);\n    }\n\n    return task;\n  }\n\n  clearDLQ(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const dlq = this.dlqs.get(name);\n    if (!dlq) return 0;\n    const count = dlq.length;\n    // Remove the tasks from the task map as well\n    for (const t of dlq) {\n      this.tasks.delete(t.id);\n    }\n    this.dlqs.set(name, []);\n    return count;\n  }\n\n  // Phase 7: Check dependents when a task completes\n  private checkDependents(completedTaskId: string): void {\n    for (const [, task] of this.tasks) {\n      if (task.status !== 'blocked') continue;\n      if (!task.dependencies.includes(completedTaskId)) continue;\n\n      task.resolvedDependencies.add(completedTaskId);\n\n      // Check if all dependencies are now resolved\n      const allResolved = task.dependencies.every(depId => task.resolvedDependencies.has(depId));\n      if (allResolved) {\n        task.status = 'pending';\n        task.updatedAt = new Date();\n      }\n    }\n  }\n\n  // Phase 7: Get dependency status\n  getDependencyStatus(taskId: string): { total: number; resolved: number; pending: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n\n    const pending = task.dependencies.filter(d => !task.resolvedDependencies.has(d));\n    return {\n      total: task.dependencies.length,\n      resolved: task.resolvedDependencies.size,\n      pending,\n    };\n  }\n\n  // Phase 2: List queue names\n  listQueues(): string[] {\n    return [...this.queues.keys()];\n  }\n\n  // Phase 1: Get a task by ID\n  getTask(taskId: string): Task | null {\n    return this.tasks.get(taskId) ?? null;\n  }\n\n  // Phase 8: Set concurrency limit\n  setConcurrency(queueName: string, limit: number): void {\n    if (!this.queueConfigs.has(queueName)) {\n      this.queueConfigs.set(queueName, {});\n    }\n    this.queueConfigs.get(queueName)!.concurrency = limit;\n  }\n\n  getConcurrency(queueName: string): number | undefined {\n    return this.queueConfigs.get(queueName)?.concurrency;\n  }\n\n  getActiveCount(queueName: string): number {\n    return this.activeCount.get(queueName) ?? 0;\n  }\n\n  // Phase 9: Report progress\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task '${taskId}' is not in processing state`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Progress must be between 0 and 100`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n    task.updatedAt = new Date();\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  // Phase 9: Subscribe to progress\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  // Phase 9: Cancel a task\n  cancel(taskId: string): Task {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n\n    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {\n      throw new Error(`Task '${taskId}' cannot be cancelled (current: ${task.status})`);\n    }\n\n    const wasPending = task.status === 'pending' || task.status === 'blocked';\n    task.status = 'cancelled';\n    task.updatedAt = new Date();\n\n    if (wasPending) {\n      // Remove from queue\n      const queue = this.queues.get(task.queue);\n      if (queue) {\n        const idx = queue.findIndex(t => t.id === taskId);\n        if (idx !== -1) queue.splice(idx, 1);\n      }\n    } else {\n      // Was processing - decrement active count\n      const active = this.activeCount.get(task.queue) ?? 0;\n      if (active > 0) this.activeCount.set(