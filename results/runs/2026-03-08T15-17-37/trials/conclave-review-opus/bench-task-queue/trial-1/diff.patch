+  backoffDelay?: number;
+}
+
+export interface Schedule<T = unknown> {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: T;
+  priority: number;
+  maxRetries: number;
+  backoffDelay: number;
+  lastRun?: Date;
+  active: boolean;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void> | void;
+export type HandlerFn = (task: Task) => Promise<void> | void;
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownSummary {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+export interface QueueConfig {
+  concurrency?: number;
+}
