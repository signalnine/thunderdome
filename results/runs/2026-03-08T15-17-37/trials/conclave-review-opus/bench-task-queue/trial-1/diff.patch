69→      month: parts[3],\n   470→      dayOfWeek: parts[4],\n   471→    };\n   472→  }\n   473→\n   474→  private shouldRunAt(schedule: Schedule, now: Date): boolean {\n   475→    const cron = this.parseCron(schedule.cron);\n   476→    const minute = now.getMinutes();\n   477→    const hour = now.getHours();\n   478→\n   479→    // Check minute field\n   480→    if (!this.cronFieldMatches(cron.minute, minute)) return false;\n   481→    // Check hour field\n   482→    if (!this.cronFieldMatches(cron.hour, hour)) return false;\n   483→\n   484→    // Prevent duplicate runs: if lastRun exists and is within the same minute, skip\n   485→    if (schedule.lastRun) {\n   486→      const lastMinute = schedule.lastRun.getMinutes();\n   487→      const lastHour = schedule.lastRun.getHours();\n   488→      const lastDate = schedule.lastRun.toDateString();\n   489→      if (lastMinute === minute && lastHour === hour && lastDate === now.toDateString()) {\n   490→        return false;\n   491→      }\n   492→    }\n   493→\n   494→    return true;\n   495→  }\n   496→\n   497→  private cronFieldMatches(field: string, value: number): boolean {\n   498→    if (field === '*') return true;\n   499→\n   500→    // */N pattern\n   501→    const stepMatch = field.match(/^\\*\\/(\\d+)$/);\n   502→    if (stepMatch) {\n   503→      const step = parseInt(stepMatch[1], 10);\n   504→      return value % step === 0;\n   505→    }\n   506→\n   507→    // Exact number\n   508→    const num = parseInt(field, 10);\n   509→    if (!isNaN(num)) {\n   510→      return value === num;\n   511→    }\n   512→\n   513→    throw new Error(`Unsupported cron field: '${field}'`);\n   514→  }\n   515→\n   516→  // Phase 11: Register middleware\n   517→  use(queueName: string, fn: MiddlewareFn): void {\n   518→    if (!this.middleware.has(queueName)) {\n   519→      this.middleware.set(queueName, []);\n   520→    }\n   521→    this.middleware.get(queueName)!.push(fn);\n   522→  }\n   523→\n   524→  // Phase 1