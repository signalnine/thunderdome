+      throw new Error(`Invalid cron expression: '${expression}'`);
+    }
+    return {
+      minute: parts[0],
+      hour: parts[1],
+      dayOfMonth: parts[2],
+      month: parts[3],
+      dayOfWeek: parts[4],
+    };
+  }
+
+  private shouldRunAt(schedule: Schedule, now: Date): boolean {
+    const cron = this.parseCron(schedule.cron);
+    const minute = now.getMinutes();
+    const hour = now.getHours();
+
+    // Check minute field
+    if (!this.cronFieldMatches(cron.minute, minute)) return false;
+    // Check hour field
+    if (!this.cronFieldMatches(cron.hour, hour)) return false;
