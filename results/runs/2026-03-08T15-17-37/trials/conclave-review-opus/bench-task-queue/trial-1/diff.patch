romise;\n   578→    }\n   579→\n   580→    this.isShuttingDown = true;\n   581→    this.shutdownPromise = this.performShutdown(options);\n   582→    return this.shutdownPromise;\n   583→  }\n   584→\n   585→  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownSummary> {\n   586→    const startTime = Date.now();\n   587→    const timeout = options?.timeout ?? 30000;\n   588→\n   589→    // Run shutdown callbacks\n   590→    for (const cb of this.shutdownCallbacks) {\n   591→      await cb();\n   592→    }\n   593→\n   594→    // Stop all schedules\n   595→    for (const [, schedule] of this.schedules) {\n   596→      schedule.active = false;\n   597→    }\n   598→    this.schedules.clear();\n   599→\n   600→    // Find all currently processing tasks\n   601→    const processingTasks: Task[] = [];\n   602→    for (const [, task] of this.tasks) {\n   603→      if (task.status === 'processing') {\n   604→        processingTasks.push(task);\n   605→      }\n   606→    }\n   607→\n   608→    let completed = 0;\n   609→    let forceCancelled = 0;\n   610→\n   611→    if (processingTasks.length > 0) {\n   612→      // Wait up to timeout for processing tasks to complete\n   613→      const deadline = startTime + timeout;\n   614→\n   615→      await new Promise<void>(resolve => {\n   616→        const checkInterval = setInterval(() => {\n   617→          const stillProcessing = processingTasks.filter(t => t.status === 'processing');\n   618→          if (stillProcessing.length === 0 || Date.now() >= deadline) {\n   619→            clearInterval(checkInterval);\n   620→            resolve();\n   621→          }\n   622→        }, 10);\n   623→\n   624→        // Also resolve immediately if no more processing\n   625→        if (processingTasks.every(t => t.status !== 'processing')) {\n   626→          clearInterval(checkInterval);\n   627→          resolve();\n   628→        }\n   629→      });\n   630→\n   631→      // Count completed and force-cancel 