d = tq.cancel(task.id);\n      expect(cancelled.status).toBe('cancelled');\n    });\n\n    it('should handle process with no handler and no middleware', async () => {\n      tq.add({ payload: 'test' });\n      const task = await tq.process();\n      expect(task?.status).toBe('completed');\n    });\n\n    it('should handle recurring tasks with queue options', () => {\n      tq.addSchedule({\n        cron: '*/5 * * * *',\n        payload: 'test',\n        queue: 'scheduled',\n        priority: 2,\n      });\n\n      const now = new Date('2024-01-01T00:00:00');\n      const tasks = tq.tick(now);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].queue).toBe('scheduled');\n      expect(tasks[0].priority).toBe(2);\n    });\n\n    it('should handle multiple schedules ticking at different times', () => {\n      tq.addSchedule({ cron: '*/5 * * * *', payload: 'every5' });\n      tq.addSchedule({ cron: '*/10 * * * *', payload: 'every10' });\n\n      // At minute 5: both */5 and not */10 match\n      const t1 = tq.tick(new Date('2024-01-01T00:05:00'));\n      expect(t1).toHaveLength(1);\n      expect(t1[0].payload).toBe('every5');\n\n      // At minute 10: both match\n      const t2 = tq.tick(new Date('2024-01-01T00:10:00'));\n      expect(t2).toHaveLength(2);\n    });\n\n    it('should process middleware that throws and retry', async () => {\n      let callCount = 0;\n      tq.use('default', async (_task, next) => {\n        callCount++;\n        if (callCount === 1) {\n          throw new Error('first attempt error');\n        }\n        await next();\n      });\n\n      tq.handle('default', async () => {\n        // handler\n      });\n\n      const task = tq.add({ payload: 'test', maxRetries: 3, backoffDelay: 1 });\n\n      // First process: middleware throws\n      await tq.process();\n      expect(task.status).toBe('pending'); // retried\n      expect(task.lastError).toBe('first attempt error');\n\n      // Make available for retry\n      task.availableAt = new