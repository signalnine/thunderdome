  503→    if (schedule.lastRun) {\n   504→      const lastMinute = schedule.lastRun.getMinutes();\n   505→      const lastHour = schedule.lastRun.getHours();\n   506→      const lastDate = schedule.lastRun.toDateString();\n   507→      if (lastMinute === minute && lastHour === hour && lastDate === now.toDateString()) {\n   508→        return false;\n   509→      }\n   510→    }\n   511→\n   512→    return true;\n   513→  }\n   514→\n   515→  private cronFieldMatches(field: string, value: number): boolean {\n   516→    if (field === '*') return true;\n   517→\n   518→    // */N pattern\n   519→    const stepMatch = field.match(/^\\*\\/(\\d+)$/);\n   520→    if (stepMatch) {\n   521→      const step = parseInt(stepMatch[1], 10);\n   522→      return value % step === 0;\n   523→    }\n   524→\n   525→    // Exact number\n   526→    const num = parseInt(field, 10);\n   527→    if (!isNaN(num)) {\n   528→      return value === num;\n   529→    }\n   530→\n   531→    throw new Error(`Unsupported cron field: '${field}'`);\n   532→  }\n   533→\n   534→  // Phase 11: Register middleware\n   535→  use(queueName: string, fn: MiddlewareFn): void {\n   536→    if (!this.middleware.has(queueName)) {\n   537→      this.middleware.set(queueName, []);\n   538→    }\n   539→    this.middleware.get(queueName)!.push(fn);\n   540→  }\n   541→\n   542→  // Phase 11: Register handler\n   543→  handle(queueName: string, fn: HandlerFn): void {\n   544→    this.handlers.set(queueName, fn);\n   545→  }\n   546→\n   547→  // Phase 11: Process a task through middleware pipeline + handler\n   548→  async process(queueName?: string): Promise<Task | null> {\n   549→    const name = queueName ?? DEFAULT_QUEUE;\n   550→    const task = this.next(name);\n   551→    if (!task) return null;\n   552→\n   553→    const middlewareStack = this.middleware.get(name) ?? [];\n   554→    const handler = this.handlers.get(name);\n   555→\n   556→    try {\n   557→      let index = 0;\n   558→      let reachedEnd