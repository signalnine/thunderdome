ng - decrement active count\n      const active = this.activeCount.get(task.queue) ?? 0;\n      if (active > 0) this.activeCount.set(task.queue, active - 1);\n    }\n\n    return task;\n  }\n\n  // Phase 10: Create a recurring schedule\n  addSchedule<T = unknown>(options: ScheduleOptions<T>): Schedule<T> {\n    const schedule: Schedule<T> = {\n      id: options.id ?? randomUUID(),\n      cron: options.cron,\n      queue: options.queue ?? DEFAULT_QUEUE,\n      payload: options.payload,\n      priority: options.priority ?? DEFAULT_PRIORITY,\n      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      active: true,\n    };\n\n    // Validate cron expression\n    this.parseCron(schedule.cron);\n\n    this.schedules.set(schedule.id, schedule as Schedule);\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): boolean {\n    const schedule = this.schedules.get(scheduleId);\n    if (!schedule) return false;\n    schedule.active = false;\n    this.schedules.delete(scheduleId);\n    return true;\n  }\n\n  listSchedules(): Schedule[] {\n    return [...this.schedules.values()];\n  }\n\n  // Phase 10: Tick - check schedules and enqueue due tasks\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const created: Task[] = [];\n\n    for (const [, schedule] of this.schedules) {\n      if (!schedule.active) continue;\n\n      if (this.shouldRunAt(schedule, currentTime)) {\n        const task = this.add({\n          payload: schedule.payload,\n          queue: schedule.queue,\n          priority: schedule.priority,\n          maxRetries: schedule.maxRetries,\n          backoffDelay: schedule.backoffDelay,\n        });\n        schedule.lastRun = currentTime;\n        created.push(task as Task);\n      }\n    }\n\n    return created;\n  }\n\n  private parseCron(expression: string): { minute: string; hour: string; dayOfMonth: string; month: string; dayOfWeek: string } {\