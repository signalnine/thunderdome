+    }
+    this.middleware.get(queueName)!.push(fn);
+  }
+
+  // Phase 11: Register handler
+  handle(queueName: string, fn: HandlerFn): void {
+    this.handlers.set(queueName, fn);
+  }
+
+  // Phase 11: Process a task through middleware pipeline + handler
+  async process(queueName?: string): Promise<Task | null> {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const task = this.next(name);
+    if (!task) return null;
+
+    const middlewareStack = this.middleware.get(name) ?? [];
+    const handler = this.handlers.get(name);
+
+    try {
+      let index = 0;
+      let reachedEnd = false;
+      const executeNext = async (): Promise<void> => {
+        if (index < middlewareStack.length) {
+          const mw = middlewareStack[index++];
+          await mw(task, executeNext);
+        } else {
+          reachedEnd = true;
+          if (handler) {
+            await handler(task);
+          }
+        }
+      };
