+    if (processingTasks.length > 0) {
+      // Wait up to timeout for processing tasks to complete
+      const deadline = startTime + timeout;
+
+      await new Promise<void>(resolve => {
+        const checkInterval = setInterval(() => {
+          const stillProcessing = processingTasks.filter(t => t.status === 'processing');
+          if (stillProcessing.length === 0 || Date.now() >= deadline) {
+            clearInterval(checkInterval);
+            resolve();
+          }
+        }, 10);
+
+        // Also resolve immediately if no more processing
+        if (processingTasks.every(t => t.status !== 'processing')) {
+          clearInterval(checkInterval);
+          resolve();
+        }
+      });
+
+      // Count completed and force-cancel remaining
+      for (const task of processingTasks) {
+        if (task.status === 'completed') {
+          completed++;
+        } else if (task.status === 'processing') {
+          task.status = 'cancelled';
+          task.updatedAt = new Date();
+          const active = this.activeCount.get(task.queue) ?? 0;
+          if (active > 0) this.activeCount.set(task.queue, active - 1);
+          forceCancelled++;
+        }
+      }
+    }
+
+    const duration = Date.now() - startTime;
+
+    return {
+      completed,
+      forceCancelled,
+      duration,
+    };
+  }
+
+  // Utility: check if system is shutting down
+  get shuttingDown(): boolean {
+    return this.isShuttingDown;
+  }
+}
