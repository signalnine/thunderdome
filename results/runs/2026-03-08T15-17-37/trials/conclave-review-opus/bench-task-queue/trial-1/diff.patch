+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01TFk7a2G3R1DnHDbiXsE43b","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017hJB4CCgRkJDkmbXcZ9mPp","name":"Write","input":{"file_path":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from './task-queue.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ==================== Phase 1: Basic FIFO Queue ====================\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object with id, status, and createdAt', () => {\n      const task = tq.add({ payload: { message: 'hello' } });\n      expect(task.id).toBeDefined();\n      expect(typeof task.id).toBe('string');\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n      expect(task.payload).toEqual({ message: 'hello' });\n    });\n\n    it('should assign unique IDs to each task', () => {\n      const t1 = tq.add({ payload: 'a' });\n      const t2 = tq.add({ payload: 'b' });\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should return tasks in FIFO order', () => {\n      tq.add({ payload: 'first' });\n      tq.add({ payload: 'second' });\n      tq.add({ payload: 'third' });\n\n      expect(tq.next()?.payload).toBe('first');\n      expect(tq.next()?.payload).toBe('second');\n      expect(tq.next()?.payload).toBe('third');\n    });\n\n    it('should transition task to processing state on retrieval', () => {\n      const task = tq.add({ payload: 'data' });\n      const retrieved = tq.next();\n      expect(retrieved?.id).toBe(task.id);\n      expect(retrieved?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should count pending tasks', () => {\n      expect(tq.pending()).toBe(0);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      expect(tq.pending()).toBe(2);\n      tq.next();\n      expect(tq.pending()).toBe(1);\n    });\n\n    it('should retrieve a task by ID', () => {\n      const task = tq.add({ payload: 'test' });\n      const found = tq.getTask(task.id);\n      expect(found).toBeDefined();\n      expect(found?.id).toBe(task.id);\n    });\n\n    it('should return null for non-existent task ID', () => {\n      expect(tq.getTask('non-existent')).toBeNull();\n    });\n  });\n\n  // ==================== Phase 2: Named Queues ====================\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name given', () => {\n      tq.add({ payload: 'default' });\n      expect(tq.pending()).toBe(1);\n      expect(tq.pending('default')).toBe(1);\n    });\n\n    it('should support multiple independent queues', () => {\n      tq.add({ payload: 'email', queue: 'emails' });\n      tq.add({ payload: 'sms', queue: 'sms' });\n\n      expect(tq.pending('emails')).toBe(1);\n      expect(tq.pending('sms')).toBe(1);\n      expect(tq.pending()).toBe(0); // default queue is empty\n    });\n\n    it('should retrieve from specific queue only', () => {\n      tq.add({ payload: 'email', queue: 'emails' });\n      tq.add({ payload: 'sms', queue: 'sms' });\n\n      const task = tq.next('emails');\n      expect(task?.payload).toBe('email');\n      expect(tq.pending('sms')).toBe(1);\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.next('nonexistent')).toBeNull();\n    });\n\n    it('should list all queue names', () => {\n      tq.add({ payload: 'a', queue: 'q1' });\n      tq.add({ payload: 'b', queue: 'q2' });\n      const names = tq.listQueues();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n    });\n\n    it('should create queues implicitly', () => {\n      expect(tq.listQueues()).toHaveLength(0);\n      tq.add({ payload: 'data', queue: 'new-queue' });\n      expect(tq.listQueues()).toContain('new-queue');\n    });\n  });\n\n  // ==================== Phase 3: Priority ====================\n  describe('Phase 3: Priority', () => {\n    it('should default to priority 5', () => {\n      const task = tq.add({ payload: 'test' });\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher-priority tasks first', () => {\n      tq.add({ payload: 'low', priority: 8 });\n      tq.add({ payload: 'high', priority: 2 });\n      tq.add({ payload: 'medium', priority: 5 });\n\n      expect(tq.next()?.payload).toBe('high');\n      expect(tq.next()?.payload).toBe('medium');\n      expect(tq.next()?.payload).toBe('low');\n    });\n\n    it('should use FIFO for same priority', () => {\n      tq.add({ payload: 'first', priority: 3 });\n      tq.add({ payload: 'second', priority: 3 });\n      tq.add({ payload: 'third', priority: 3 });\n\n      expect(tq.next()?.payload).toBe('first');\n      expect(tq.next()?.payload).toBe('second');\n      expect(tq.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => tq.add({ payload: 'test', priority: 0 })).toThrow();\n      expect(() => tq.add({ payload: 'test', priority: 11 })).toThrow();\n      expect(() => tq.add({ payload: 'test', priority: 5.5 })).toThrow();\n    });\n\n    it('should maintain priority per queue', () => {\n      tq.add({ payload: 'q1-low', priority: 8, queue: 'q1' });\n      tq.add({ payload: 'q1-high', priority: 2, queue: 'q1' });\n      tq.add({ payload: 'q2-low', priority: 9, queue: 'q2' });\n\n      expect(tq.next('q1')?.payload).toBe('q1-high');\n      expect(tq.next('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ==================== Phase 4: Delayed Tasks ====================\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their available time', () => {\n      tq.add({ payload: 'delayed', delay: 60000 });\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should return delayed tasks after their available time', () => {\n      const pastTime = new Date(Date.now() - 1000);\n      tq.add({ payload: 'available', availableAt: pastTime });\n      const task = tq.next();\n      expect(task?.payload).toBe('available');\n    });\n\n    it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {\n      tq.add({ payload: 'delayed', delay: 60000, priority: 1 });\n      tq.add({ payload: 'immediate', priority: 10 });\n\n      expect(tq.next()?.payload).toBe('immediate');\n    });\n\n    it('should expose availability time on task', () => {\n      const task = tq.add({ payload: 'test', delay: 5000 });\n      expect(task.availableAt).toBeInstanceOf(Date);\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should work with named queues', () => {\n      tq.add({ payload: 'delayed', delay: 60000, queue: 'q1' });\n      tq.add({ payload: 'immediate', queue: 'q1' });\n\n      expect(tq.next('q1')?.payload).toBe('immediate');\n    });\n\n    it('should accept a specific availableAt Date', () => {\n      const future = new Date(Date.now() + 60000);\n      const task = tq.add({ payload: 'scheduled', availableAt: future });\n      expect(task.availableAt.getTime()).toBe(future.getTime());\n      expect(tq.next()).toBeNull();\n    });\n  });\n\n  // ==================== Phase 5: Retry with Backoff ====================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      const completed = tq.complete(task.id);\n      expect(completed.status).toBe('completed');\n    });\n\n    it('should fail a task and retry with backoff', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 3, backoffDelay: 100 });\n      tq.next();\n      const failed = tq.fail(task.id, 'error');\n\n      expect(failed.status).toBe('pending');\n      expect(failed.attempts).toBe(1);\n      expect(failed.lastError).toBe('error');\n      // Backoff: 100 * 2^0 = 100ms\n      expect(failed.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should use exponential backoff', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 5, backoffDelay: 1000 });\n\n      // First attempt\n      tq.next();\n      tq.fail(task.id, 'err1');\n      // Backoff: 1000 * 2^0 = 1000ms\n      const delay1 = task.availableAt.getTime() - Date.now();\n      expect(delay1).toBeGreaterThan(800);\n      expect(delay1).toBeLessThan(1200);\n\n      // Need to make the task available for the next attempt\n      task.availableAt = new Date(Date.now() - 1);\n      tq.next();\n      tq.fail(task.id, 'err2');\n      // Backoff: 1000 * 2^1 = 2000ms\n      const delay2 = task.availableAt.getTime() - Date.now();\n      expect(delay2).toBeGreaterThan(1800);\n      expect(delay2).toBeLessThan(2200);\n    });\n\n    it('should default to 3 retries', () => {\n      const task = tq.add({ payload: 'test' });\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 2, backoffDelay: 1 });\n\n      tq.next();\n      expect(task.attempts).toBe(1);\n      tq.fail(task.id);\n      task.availableAt = new Date(Date.now() - 1);\n\n      tq.next();\n      expect(task.attempts).toBe(2);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = tq.add({ payload: 'test', queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 1 });\n      tq.next('myq');\n      tq.fail(task.id, 'err');\n\n      expect(task.queue).toBe('myq');\n      expect(task.priority).toBe(2);\n    });\n\n    it('should mark as failed when retries exhausted', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, 'final error');\n\n      expect(task.status).toBe('failed');\n    });\n\n    it('should throw when completing a non-processing task', () => {\n      const task = tq.add({ payload: 'test' });\n      expect(() => tq.complete(task.id)).toThrow();\n    });\n\n    it('should throw when failing a non-processing task', () => {\n      const task = tq.add({ payload: 'test' });\n      expect(() => tq.fail(task.id)).toThrow();\n    });\n  });\n\n  // ==================== Phase 6: Dead Letter Queue ====================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move task to DLQ when retries exhausted', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, 'error');\n\n      const dlq = tq.deadLetterQueue();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].lastError).toBe('error');\n    });\n\n    it('should have per-queue DLQs', () => {\n      const t1 = tq.add({ payload: 'a', queue: 'q1', maxRetries: 1 });\n      const t2 = tq.add({ payload: 'b', queue: 'q2', maxRetries: 1 });\n\n      tq.next('q1');\n      tq.fail(t1.id, 'err');\n      tq.next('q2');\n      tq.fail(t2.id, 'err');\n\n      expect(tq.deadLetterQueue('q1')).toHaveLength(1);\n      expect(tq.deadLetterQueue('q2')).toHaveLength(1);\n    });\n\n    it('should redrive a dead-lettered task', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, 'error');\n\n      expect(tq.deadLetterQueue()).toHaveLength(1);\n      const redriven = tq.redrive(task.id);\n      expect(redriven.status).toBe('pending');\n      expect(redriven.attempts).toBe(0);\n      expect(tq.deadLetterQueue()).toHaveLength(0);\n      expect(tq.pending()).toBe(1);\n    });\n\n    it('should clear DLQ for a queue', () => {\n      const t1 = tq.add({ payload: 'a', maxRetries: 1 });\n      const t2 = tq.add({ payload: 'b', maxRetries: 1 });\n\n      tq.next();\n      tq.fail(t1.id, 'err');\n      tq.next();\n      tq.fail(t2.id, 'err');\n\n      expect(tq.deadLetterQueue()).toHaveLength(2);\n      const count = tq.clearDLQ();\n      expect(count).toBe(2);\n      expect(tq.deadLetterQueue()).toHaveLength(0);\n    });\n\n    it('should return empty array for queue with no DLQ', () => {\n      expect(tq.deadLetterQueue('nonexistent')).toEqual([]);\n    });\n  });\n\n  // ==================== Phase 7: Task Dependencies ====================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.add({ payload: 'dep' });\n      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n\n      expect(task.status).toBe('blocked');\n      expect(tq.next()).not.toBeNull(); // gets dep\n      expect(tq.next()).toBeNull(); // task is blocked\n    });\n\n    it('should unblock task when dependency completes', () => {\n      const dep = tq.add({ payload: 'dep' });\n      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n\n      const depTask = tq.next()!;\n      tq.complete(depTask.id);\n\n      expect(task.status).toBe('pending');\n      const mainTask = tq.next();\n      expect(mainTask?.id).toBe(task.id);\n    });\n\n    it('should handle multiple dependencies', () => {\n      const dep1 = tq.add({ payload: 'dep1' });\n      const dep2 = tq.add({ payload: 'dep2' });\n      const task = tq.add({ payload: 'main', dependencies: [dep1.id, dep2.id] });\n\n      expect(task.status).toBe('blocked');\n\n      const d1 = tq.next()!;\n      tq.complete(d1.id);\n      expect(task.status).toBe('blocked'); // still waiting for dep2\n\n      const d2 = tq.next()!;\n      tq.complete(d2.id);\n      expect(task.status).toBe('pending'); // now unblocked\n    });\n\n    it('should reject non-existent dependency', () => {\n      expect(() => tq.add({ payload: 'test', dependencies: ['fake-id'] })).toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = tq.add({ payload: 'dep', maxRetries: 1 });\n      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n\n      tq.next();\n      tq.fail(dep.id, 'error');\n\n      expect(task.status).toBe('blocked');\n    });\n\n    it('should report dependency status', () => {\n      const dep1 = tq.add({ payload: 'dep1' });\n      const dep2 = tq.add({ payload: 'dep2' });\n      const task = tq.add({ payload: 'main', dependencies: [dep1.id, dep2.id] });\n\n      const status = tq.getDependencyStatus(task.id);\n      expect(status.total).toBe(2);\n      expect(status.resolved).toBe(0);\n      expect(status.pending).toHaveLength(2);\n\n      const d1 = tq.next()!;\n      tq.complete(d1.id);\n\n      const status2 = tq.getDependencyStatus(task.id);\n      expect(status2.resolved).toBe(1);\n      expect(status2.pending).toHaveLength(1);\n    });\n\n    it('should unblock task when dependency is already completed', () => {\n      const dep = tq.add({ payload: 'dep' });\n      const d = tq.next()!;\n      tq.complete(d.id);\n\n      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n      expect(task.status).toBe('pending'); // already resolved\n    });\n  });\n\n  // ==================== Phase 8: Concurrency Control ====================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      tq.setConcurrency('default', 2);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      tq.add({ payload: 'c' });\n\n      expect(tq.next()).not.toBeNull();\n      expect(tq.next()).not.toBeNull();\n      expect(tq.next()).toBeNull(); // concurrency limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      tq.setConcurrency('default', 1);\n      const t1 = tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n\n      tq.next();\n      expect(tq.next()).toBeNull();\n\n      tq.complete(t1.id);\n      expect(tq.next()).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      tq.setConcurrency('default', 1);\n      const t1 = tq.add({ payload: 'a', maxRetries: 1 });\n      tq.add({ payload: 'b' });\n\n      tq.next();\n      expect(tq.next()).toBeNull();\n\n      tq.fail(t1.id, 'err');\n      expect(tq.next()).not.toBeNull();\n    });\n\n    it('should have no limit by default', () => {\n      expect(tq.getConcurrency('default')).toBeUndefined();\n    });\n\n    it('should report active count', () => {\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n\n      expect(tq.getActiveCount('default')).toBe(0);\n      tq.next();\n      expect(tq.getActiveCount('default')).toBe(1);\n      tq.next();\n      expect(tq.getActiveCount('default')).toBe(2);\n    });\n\n    it('should respect priority under concurrency limits', () => {\n      tq.setConcurrency('default', 1);\n      tq.add({ payload: 'low', priority: 8 });\n      tq.add({ payload: 'high', priority: 2 });\n\n      expect(tq.next()?.payload).toBe('high');\n    });\n  });\n\n  // ==================== Phase 9: Progress and Cancellation ====================\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report progress on a processing task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      tq.reportProgress(task.id, 50, 'halfway');\n      const found = tq.getTask(task.id)!;\n      expect(found.progress).toBe(50);\n      expect(found.progressMessage).toBe('halfway');\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('should notify progress listeners', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      tq.reportProgress(task.id, 25, 'quarter');\n      tq.reportProgress(task.id, 75, 'three quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n      expect(updates[1]).toEqual({ progress: 75, message: 'three quarters' });\n    });\n\n    it('should support unsubscribing from progress updates', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 25);\n      unsub();\n      tq.reportProgress(task.id, 75);\n\n      expect(updates).toHaveLength(1);\n      expect(updates[0]).toBe(25);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = tq.add({ payload: 'test' });\n      const cancelled = tq.cancel(task.id);\n\n      expect(cancelled.status).toBe('cancelled');\n      expect(tq.pending()).toBe(0);\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      const cancelled = tq.cancel(task.id);\n      expect(cancelled.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 5 });\n      tq.next();\n\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      // Task should not be requeued\n      expect(tq.pending()).toBe(0);\n    });\n\n    it('should throw when cancelling a completed task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      tq.complete(task.id);\n\n      expect(() => tq.cancel(task.id)).toThrow();\n    });\n  });\n\n  // ==================== Phase 10: Recurring Tasks ====================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule({\n        cron: '*/5 * * * *',\n        payload: { type: 'cleanup' },\n      });\n\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cron).toBe('*/5 * * * *');\n      expect(schedule.active).toBe(true);\n    });\n\n    it('should enqueue tasks on tick', () => {\n      tq.addSchedule({\n        cron: '*/5 * * * *',\n        payload: { type: 'cleanup' },\n      });\n\n      // Tick at minute 0 (should match */5)\n      const now = new Date('2024-01-01T00:00:00');\n      const created = tq.tick(now);\n      expect(created).toHaveLength(1);\n      expect(created[0].payload).toEqual({ type: 'cleanup' });\n    });\n\n    it('should not enqueue when cron does not match', () => {\n      tq.addSchedule({\n        cron: '0 * * * *', // every hour on the hour\n        payload: 'hourly',\n      });\n\n      // Tick at minute 30 - should not match\n      const now = new Date('2024-01-01T00:30:00');\n      const created = tq.tick(now);\n      expect(created).toHaveLength(0);\n    });\n\n    it('should support every day at midnight', () => {\n      tq.addSchedule({\n        cron: '0 0 * * *',\n        payload: 'daily',\n      });\n\n      // Tick at midnight\n      const midnight = new Date('2024-01-01T00:00:00');\n      expect(tq.tick(midnight)).toHaveLength(1);\n\n      // Tick at noon\n      const noon = new Date('2024-01-01T12:00:00');\n      expect(tq.tick(noon)).toHaveLength(0);\n    });\n\n    it('should prevent duplicate runs in the same minute', () => {\n      tq.addSchedule({\n        cron: '*/1 * * * *',\n        payload: 'every-min',\n      });\n\n      const now = new Date('2024-01-01T00:00:00');\n      expect(tq.tick(now)).toHaveLength(1);\n      expect(tq.tick(now)).toHaveLength(0); // same minute\n    });\n\n    it('should remove a schedule', () => {\n      const schedule = tq.addSchedule({ cron: '*/5 * * * *', payload: 'test' });\n      expect(tq.removeSchedule(schedule.id)).toBe(true);\n      expect(tq.listSchedules()).toHaveLength(0);\n\n      const now = new Date('2024-01-01T00:00:00');\n      expect(tq.tick(now)).toHaveLength(0);\n    });\n\n    it('should list active schedules', () => {\n      tq.addSchedule({ cron: '*/5 * * * *', payload: 'a' });\n      tq.addSchedule({ cron: '0 * * * *', payload: 'b' });\n\n      expect(tq.listSchedules()).toHaveLength(2);\n    });\n\n    it('should reject invalid cron expression', () => {\n      expect(() => tq.addSchedule({ cron: 'invalid', payload: 'test' })).toThrow();\n    });\n  });\n\n  // ==================== Phase 11: Middleware Pipeline ====================\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware before handler', async () => {\n      const order: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push('middleware');\n        await next();\n      });\n\n      tq.handle('default', async () => {\n        order.push('handler');\n      });\n\n      tq.add({ payload: 'test' });\n      await tq.process();\n\n      expect(order).toEqual(['middleware', 'handler']);\n    });\n\n    it('should run middleware in order', async () => {\n      const order: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push('first');\n        await next();\n      });\n\n      tq.use('default', async (_task, next) => {\n        order.push('second');\n        await next();\n      });\n\n      tq.handle('default', async () => {\n        order.push('handler');\n      });\n\n      tq.add({ payload: 'test' });\n      await tq.process();\n\n      expect(order).toEqual(['first', 'second', 'handler']);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      const handlerCalled = vi.fn();\n\n      tq.use('default', async () => {\n        // deliberately not calling next\n      });\n\n      tq.handle('default', handlerCalled);\n\n      tq.add({ payload: 'test' });\n      const task = await tq.process();\n\n      expect(handlerCalled).not.toHaveBeenCalled();\n      // Task should still be processing (not auto-completed since middleware didn't pass through)\n      expect(task?.status).not.toBe('completed');\n    });\n\n    it('should modify task in middleware', async () => {\n      tq.use('default', async (task, next) => {\n        task.metadata['enriched'] = true;\n        await next();\n      });\n\n      let enriched = false;\n      tq.handle('default', async (task) => {\n        enriched = task.metadata['enriched'] as boolean;\n      });\n\n      tq.add({ payload: 'test' });\n      await tq.process();\n\n      expect(enriched).toBe(true);\n    });\n\n    it('should fail task if middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = tq.add({ payload: 'test', maxRetries: 1 });\n      await tq.process();\n\n      expect(task.lastError).toBe('middleware error');\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const q1Calls: string[] = [];\n      const q2Calls: string[] = [];\n\n      tq.use('q1', async (_task, next) => {\n        q1Calls.push('q1-mw');\n        await next();\n      });\n\n      tq.use('q2', async (_task, next) => {\n        q2Calls.push('q2-mw');\n        await next();\n      });\n\n      tq.add({ payload: 'a', queue: 'q1' });\n      tq.add({ payload: 'b', queue: 'q2' });\n\n      await tq.process('q1');\n      await tq.process('q2');\n\n      expect(q1Calls).toEqual(['q1-mw']);\n      expect(q2Calls).toEqual(['q2-mw']);\n    });\n\n    it('should return null from process when queue is empty', async () => {\n      const result = await tq.process();\n      expect(result).toBeNull();\n    });\n\n    it('should auto-complete task after successful processing', async () => {\n      tq.handle('default', async () => {\n        // handler succeeds\n      });\n\n      const task = tq.add({ payload: 'test' });\n      await tq.process();\n\n      expect(task.status).toBe('completed');\n    });\n  });\n\n  // ==================== Phase 12: Graceful Shutdown ====================\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should stop accepting new tasks after shutdown', async () => {\n      await tq.shutdown();\n\n      expect(() => tq.add({ payload: 'test' })).toThrow(/shutting down/);\n    });\n\n    it('should complete immediately with no processing tasks', async () => {\n      const summary = await tq.shutdown();\n\n      expect(summary.completed).toBe(0);\n      expect(summary.forceCancelled).toBe(0);\n      expect(summary.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks to complete', async () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      // Start shutdown but complete task during the wait\n      const shutdownPromise = tq.shutdown({ timeout: 5000 });\n\n      // Complete the task after a small delay\n      setTimeout(() => tq.complete(task.id), 50);\n\n      const summary = await shutdownPromise;\n      expect(summary.completed).toBe(1);\n      expect(summary.forceCancelled).toBe(0);\n    });\n\n    it('should force-cancel tasks after timeout', async () => {\n      tq.add({ payload: 'test' });\n      tq.next();\n\n      const summary = await tq.shutdown({ timeout: 50 });\n\n      expect(summary.forceCancelled).toBe(1);\n    });\n\n    it('should be idempotent', async () => {\n      const s1 = tq.shutdown();\n      const s2 = tq.shutdown();\n\n      const r1 = await s1;\n      const r2 = await s2;\n      expect(r1).toBe(r2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      const called = vi.fn();\n      tq.onShutdown(called);\n\n      await tq.shutdown();\n      expect(called).toHaveBeenCalled();\n    });\n\n    it('should report shutdown duration', async () => {\n      const summary = await tq.shutdown();\n      expect(typeof summary.duration).toBe('number');\n      expect(summary.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should expose shuttingDown property', async () => {\n      expect(tq.shuttingDown).toBe(false);\n      const promise = tq.shutdown();\n      expect(tq.shuttingDown).toBe(true);\n      await promise;\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":377,"cache_read_input_tokens":32900,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":377},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d55f7efa-1a7c-4c18-baa6-46556b297090","uuid":"da09ff40-9605-4e88-8639-ba48280bd351"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017hJB4CCgRkJDkmbXcZ9mPp","type":"tool_result","content":"File created successfully at: /workspace/src/task-queue.test.ts"}]},"parent_tool_use_id":null,"session_id":"d55f7efa-1a7c-4c18-baa6-46556b297090","uuid":"7ebe9ec9-d316-487f-98f5-50946fca363d","tool_use_result":{"type":"create","filePath":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from './task-queue.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ==================== Phase 1: Basic FIFO Queue ====================\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object with id, status, and createdAt', () => {\n      const task = tq.add({ payload: { message: 'hello' } });\n      expect(task.id).toBeDefined();\n      expect(typeof task.id).toBe('string');\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n      expect(task.payload).toEqual({ message: 'hello' });\n    });\n\n    it('should assign unique IDs to each task', () => {\n      const t1 = tq.add({ payload: 'a' });\n      const t2 = tq.add({ payload: 'b' });\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should return tasks in FIFO order', () => {\n      tq.add({ payload: 'first' });\n      tq.add({ payload: 'second' });\n      tq.add({ payload: 'third' });\n\n      expect(tq.next()?.payload).toBe('first');\n      expect(tq.next()?.payload).toBe('second');\n      expect(tq.next()?.payload).toBe('third');\n    });\n\n    it('should transition task to processing state on retrieval', () => {\n      const task = tq.add({ payload: 'data' });\n      const retrieved = tq.next();\n      expect(retrieved?.id).toBe(task.id);\n      expect(retrieved?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should count pending tasks', () => {\n      expect(tq.pending()).toBe(0);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      expect(tq.pending()).toBe(2);\n      tq.next();\n      expect(tq.pending()).toBe(1);\n    });\n\n    it('should retrieve a task by ID', () => {\n      const task = tq.add({ payload: 'test' });\n      const found = tq.getTask(task.id);\n      expect(found).toBeDefined();\n      expect(found?.id).toBe(task.id);\n    });\n\n    it('should return null for non-existent task ID', () => {\n      expect(tq.getTask('non-existent')).toBeNull();\n    });\n  });\n\n  // ==================== Phase 2: Named Queues ====================\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name given', () => {\n      tq.add({ payload: 'default' });\n      expect(tq.pending()).toBe(1);\n      expect(tq.pending('default')).toBe(1);\n    });\n\n    it('should support multiple independent queues', () => {\n      tq.add({ payload: 'email', queue: 'emails' });\n      tq.add({ payload: 'sms', queue: 'sms' });\n\n      expect(tq.pending('emails')).toBe(1);\n      expect(tq.pending('sms')).toBe(1);\n      expect(tq.pending()).toBe(0); // default queue is empty\n    });\n\n    it('should retrieve from specific queue only', () => {\n      tq.add({ payload: 'email', queue: 'emails' });\n      tq.add({ payload: 'sms', queue: 'sms' });\n\n      const task = tq.next('emails');\n      expect(task?.payload).toBe('email');\n      expect(tq.pending('sms')).toBe(1);\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.next('nonexistent')).toBeNull();\n    });\n\n    it('should list all queue names', () => {\n      tq.add({ payload: 'a', queue: 'q1' });\n      tq.add({ payload: 'b', queue: 'q2' });\n      const names = tq.listQueues();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n    });\n\n    it('should create queues implicitly', () => {\n      expect(tq.listQueues()).toHaveLength(0);\n      tq.add({ payload: 'data', queue: 'new-queue' });\n      expect(tq.listQueues()).toContain('new-queue');\n    });\n  });\n\n  // ==================== Phase 3: Priority ====================\n  describe('Phase 3: Priority', () => {\n    it('should default to priority 5', () => {\n      const task = tq.add({ payload: 'test' });\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher-priority tasks first', () => {\n      tq.add({ payload: 'low', priority: 8 });\n      tq.add({ payload: 'high', priority: 2 });\n      tq.add({ payload: 'medium', priority: 5 });\n\n      expect(tq.next()?.payload).toBe('high');\n      expect(tq.next()?.payload).toBe('medium');\n      expect(tq.next()?.payload).toBe('low');\n    });\n\n    it('should use FIFO for same priority', () => {\n      tq.add({ payload: 'first', priority: 3 });\n      tq.add({ payload: 'second', priority: 3 });\n      tq.add({ payload: 'third', priority: 3 });\n\n      expect(tq.next()?.payload).toBe('first');\n      expect(tq.next()?.payload).toBe('second');\n      expect(tq.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => tq.add({ payload: 'test', priority: 0 })).toThrow();\n      expect(() => tq.add({ payload: 'test', priority: 11 })).toThrow();\n      expect(() => tq.add({ payload: 'test', priority: 5.5 })).toThrow();\n    });\n\n    it('should maintain priority per queue', () => {\n      tq.add({ payload: 'q1-low', priority: 8, queue: 'q1' });\n      tq.add({ payload: 'q1-high', priority: 2, queue: 'q1' });\n      tq.add({ payload: 'q2-low', priority: 9, queue: 'q2' });\n\n      expect(tq.next('q1')?.payload).toBe('q1-high');\n      expect(tq.next('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ==================== Phase 4: Delayed Tasks ====================\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their available time', () => {\n      tq.add({ payload: 'delayed', delay: 60000 });\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should return delayed tasks after their available time', () => {\n      const pastTime = new Date(Date.now() - 1000);\n      tq.add({ payload: 'available', availableAt: pastTime });\n      const task = tq.next();\n      expect(task?.payload).toBe('available');\n    });\n\n    it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {\n      tq.add({ payload: 'delayed', delay: 60000, priority: 1 });\n      tq.add({ payload: 'immediate', priority: 10 });\n\n      expect(tq.next()?.payload).toBe('immediate');\n    });\n\n    it('should expose availability time on task', () => {\n      const task = tq.add({ payload: 'test', delay: 5000 });\n      expect(task.availableAt).toBeInstanceOf(Date);\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should work with named queues', () => {\n      tq.add({ payload: 'delayed', delay: 60000, queue: 'q1' });\n      tq.add({ payload: 'immediate', queue: 'q1' });\n\n      expect(tq.next('q1')?.payload).toBe('immediate');\n    });\n\n    it('should accept a specific availableAt Date', () => {\n      const future = new Date(Date.now() + 60000);\n      const task = tq.add({ payload: 'scheduled', availableAt: future });\n      expect(task.availableAt.getTime()).toBe(future.getTime());\n      expect(tq.next()).toBeNull();\n    });\n  });\n\n  // ==================== Phase 5: Retry with Backoff ====================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      const completed = tq.complete(task.id);\n      expect(completed.status).toBe('completed');\n    });\n\n    it('should fail a task and retry with backoff', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 3, backoffDelay: 100 });\n      tq.next();\n      const failed = tq.fail(task.id, 'error');\n\n      expect(failed.status).toBe('pending');\n      expect(failed.attempts).toBe(1);\n      expect(failed.lastError).toBe('error');\n      // Backoff: 100 * 2^0 = 100ms\n      expect(failed.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should use exponential backoff', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 5, backoffDelay: 1000 });\n\n      // First attempt\n      tq.next();\n      tq.fail(task.id, 'err1');\n      // Backoff: 1000 * 2^0 = 1000ms\n      const delay1 = task.availableAt.getTime() - Date.now();\n      expect(delay1).toBeGreaterThan(800);\n      expect(delay1).toBeLessThan(1200);\n\n      // Need to make the task available for the next attempt\n      task.availableAt = new Date(Date.now() - 1);\n      tq.next();\n      tq.fail(task.id, 'err2');\n      // Backoff: 1000 * 2^1 = 2000ms\n      const delay2 = task.availableAt.getTime() - Date.now();\n      expect(delay2).toBeGreaterThan(1800);\n      expect(delay2).toBeLessThan(2200);\n    });\n\n    it('should default to 3 retries', () => {\n      const task = tq.add({ payload: 'test' });\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 2, backoffDelay: 1 });\n\n      tq.next();\n      expect(task.attempts).toBe(1);\n      tq.fail(task.id);\n      task.availableAt = new Date(Date.now() - 1);\n\n      tq.next();\n      expect(task.attempts).toBe(2);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = tq.add({ payload: 'test', queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 1 });\n      tq.next('myq');\n      tq.fail(task.id, 'err');\n\n      expect(task.queue).toBe('myq');\n      expect(task.priority).toBe(2);\n    });\n\n    it('should mark as failed when retries exhausted', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, 'final error');\n\n      expect(task.status).toBe('failed');\n    });\n\n    it('should throw when completing a non-processing task', () => {\n      const task = tq.add({ payload: 'test' });\n      expect(() => tq.complete(task.id)).toThrow();\n    });\n\n    it('should throw when failing a non-processing task', () => {\n      const task = tq.add({ payload: 'test' });\n      expect(() => tq.fail(task.id)).toThrow();\n    });\n  });\n\n  // ==================== Phase 6: Dead Letter Queue ====================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move task to DLQ when retries exhausted', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, 'error');\n\n      const dlq = tq.deadLetterQueue();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].lastError).toBe('error');\n    });\n\n    it('should have per-queue DLQs', () => {\n      const t1 = tq.add({ payload: 'a', queue: 'q1', maxRetries: 1 });\n      const t2 = tq.add({ payload: 'b', queue: 'q2', maxRetries: 1 });\n\n      tq.next('q1');\n      tq.fail(t1.id, 'err');\n      tq.next('q2');\n      tq.fail(t2.id, 'err');\n\n      expect(tq.deadLetterQueue('q1')).toHaveLength(1);\n      expect(tq.deadLetterQueue('q2')).toHaveLength(1);\n    });\n\n    it('should redrive a dead-lettered task', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1, backoffDelay: 1 });\n      tq.next();\n      tq.fail(task.id, 'error');\n\n      expect(tq.deadLetterQueue()).toHaveLength(1);\n      const redriven = tq.redrive(task.id);\n      expect(redriven.status).toBe('pending');\n      expect(redriven.attempts).toBe(0);\n      expect(tq.deadLetterQueue()).toHaveLength(0);\n      expect(tq.pending()).toBe(1);\n    });\n\n    it('should clear DLQ for a queue', () => {\n      const t1 = tq.add({ payload: 'a', maxRetries: 1 });\n      const t2 = tq.add({ payload: 'b', maxRetries: 1 });\n\n      tq.next();\n      tq.fail(t1.id, 'err');\n      tq.next();\n      tq.fail(t2.id, 'err');\n\n      expect(tq.deadLetterQueue()).toHaveLength(2);\n      const count = tq.clearDLQ();\n      expect(count).toBe(2);\n      expect(tq.deadLetterQueue()).toHaveLength(0);\n    });\n\n    it('should return empty array for queue with no DLQ', () => {\n      expect(tq.deadLetterQueue('nonexistent')).toEqual([]);\n    });\n  });\n\n  // ==================== Phase 7: Task Dependencies ====================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.add({ payload: 'dep' });\n      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n\n      expect(task.status).toBe('blocked');\n      expect(tq.next()).not.toBeNull(); // gets dep\n      expect(tq.next()).toBeNull(); // task is blocked\n    });\n\n    it('should unblock task when dependency completes', () => {\n      const dep = tq.add({ payload: 'dep' });\n      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n\n      const depTask = tq.next()!;\n      tq.complete(depTask.id);\n\n      expect(task.status).toBe('pending');\n      const mainTask = tq.next();\n      expect(mainTask?.id).toBe(task.id);\n    });\n\n    it('should handle multiple dependencies', () => {\n      const dep1 = tq.add({ payload: 'dep1' });\n      const dep2 = tq.add({ payload: 'dep2' });\n      const task = tq.add({ payload: 'main', dependencies: [dep1.id, dep2.id] });\n\n      expect(task.status).toBe('blocked');\n\n      const d1 = tq.next()!;\n      tq.complete(d1.id);\n      expect(task.status).toBe('blocked'); // still waiting for dep2\n\n      const d2 = tq.next()!;\n      tq.complete(d2.id);\n      expect(task.status).toBe('pending'); // now unblocked\n    });\n\n    it('should reject non-existent dependency', () => {\n      expect(() => tq.add({ payload: 'test', dependencies: ['fake-id'] })).toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = tq.add({ payload: 'dep', maxRetries: 1 });\n      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n\n      tq.next();\n      tq.fail(dep.id, 'error');\n\n      expect(task.status).toBe('blocked');\n    });\n\n    it('should report dependency status', () => {\n      const dep1 = tq.add({ payload: 'dep1' });\n      const dep2 = tq.add({ payload: 'dep2' });\n      const task = tq.add({ payload: 'main', dependencies: [dep1.id, dep2.id] });\n\n      const status = tq.getDependencyStatus(task.id);\n      expect(status.total).toBe(2);\n      expect(status.resolved).toBe(0);\n      expect(status.pending).toHaveLength(2);\n\n      const d1 = tq.next()!;\n      tq.complete(d1.id);\n\n      const status2 = tq.getDependencyStatus(task.id);\n      expect(status2.resolved).toBe(1);\n      expect(status2.pending).toHaveLength(1);\n    });\n\n    it('should unblock task when dependency is already completed', () => {\n      const dep = tq.add({ payload: 'dep' });\n      const d = tq.next()!;\n      tq.complete(d.id);\n\n      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n      expect(task.status).toBe('pending'); // already resolved\n    });\n  });\n\n  // ==================== Phase 8: Concurrency Control ====================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      tq.setConcurrency('default', 2);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      tq.add({ payload: 'c' });\n\n      expect(tq.next()).not.toBeNull();\n      expect(tq.next()).not.toBeNull();\n      expect(tq.next()).toBeNull(); // concurrency limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      tq.setConcurrency('default', 1);\n      const t1 = tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n\n      tq.next();\n      expect(tq.next()).toBeNull();\n\n      tq.complete(t1.id);\n      expect(tq.next()).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      tq.setConcurrency('default', 1);\n      const t1 = tq.add({ payload: 'a', maxRetries: 1 });\n      tq.add({ payload: 'b' });\n\n      tq.next();\n      expect(tq.next()).toBeNull();\n\n      tq.fail(t1.id, 'err');\n      expect(tq.next()).not.toBeNull();\n    });\n\n    it('should have no limit by default', () => {\n      expect(tq.getConcurrency('default')).toBeUndefined();\n    });\n\n    it('should report active count', () => {\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n\n      expect(tq.getActiveCount('default')).toBe(0);\n      tq.next();\n      expect(tq.getActiveCount('default')).toBe(1);\n      tq.next();\n      expect(tq.getActiveCount('default')).toBe(2);\n    });\n\n    it('should respect priority under concurrency limits', () => {\n      tq.setConcurrency('default', 1);\n      tq.add({ payload: 'low', priority: 8 });\n      tq.add({ payload: 'high', priority: 2 });\n\n      expect(tq.next()?.payload).toBe('high');\n    });\n  });\n\n  // ==================== Phase 9: Progress and Cancellation ====================\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report progress on a processing task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      tq.reportProgress(task.id, 50, 'halfway');\n      const found = tq.getTask(task.id)!;\n      expect(found.progress).toBe(50);\n      expect(found.progressMessage).toBe('halfway');\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('should notify progress listeners', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      tq.reportProgress(task.id, 25, 'quarter');\n      tq.reportProgress(task.id, 75, 'three quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n      expect(updates[1]).toEqual({ progress: 75, message: 'three quarters' });\n    });\n\n    it('should support unsubscribing from progress updates', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 25);\n      unsub();\n      tq.reportProgress(task.id, 75);\n\n      expect(updates).toHaveLength(1);\n      expect(updates[0]).toBe(25);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = tq.add({ payload: 'test' });\n      const cancelled = tq.cancel(task.id);\n\n      expect(cancelled.status).toBe('cancelled');\n      expect(tq.pending()).toBe(0);\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      const cancelled = tq.cancel(task.id);\n      expect(cancelled.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 5 });\n      tq.next();\n\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      // Task should not be requeued\n      expect(tq.pending()).toBe(0);\n    });\n\n    it('should throw when cancelling a completed task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      tq.complete(task.id);\n\n      expect(() => tq.cancel(task.id)).toThrow();\n    });\n  });\n\n  // ==================== Phase 10: Recurring Tasks ====================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule({\n        cron: '*/5 * * * *',\n        payload: { type: 'cleanup' },\n      });\n\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cron).toBe('*/5 * * * *');\n      expect(schedule.active).toBe(true);\n    });\n\n    it('should enqueue tasks on tick', () => {\n      tq.addSchedule({\n        cron: '*/5 * * * *',\n        payload: { type: 'cleanup' },\n      });\n\n      // Tick at minute 0 (should match */5)\n      const now = new Date('2024-01-01T00:00:00');\n      const created = tq.tick(now);\n      expect(created).toHaveLength(1);\n      expect(created[0].payload).toEqual({ type: 'cleanup' });\n    });\n\n    it('should not enqueue when cron does not match', () => {\n      tq.addSchedule({\n        cron: '0 * * * *', // every hour on the hour\n        payload: 'hourly',\n      });\n\n      // Tick at minute 30 - should not match\n      const now = new Date('2024-01-01T00:30:00');\n      const created = tq.tick(now);\n      expect(created).toHaveLength(0);\n    });\n\n    it('should support every day at midnight', () => {\n      tq.addSchedule({\n        cron: '0 0 * * *',\n        payload: 'daily',\n      });\n\n      // Tick at midnight\n      const midnight = new Date('2024-01-01T00:00:00');\n      expect(tq.tick(midnight)).toHaveLength(1);\n\n      // Tick at noon\n      const noon = new Date('2024-01-01T12:00:00');\n      expect(tq.tick(noon)).toHaveLength(0);\n    });\n\n    it('should prevent duplicate runs in the same minute', () => {\n      tq.addSchedule({\n        cron: '*/1 * * * *',\n        payload: 'every-min',\n      });\n\n      const now = new Date('2024-01-01T00:00:00');\n      expect(tq.tick(now)).toHaveLength(1);\n      expect(tq.tick(now)).toHaveLength(0); // same minute\n    });\n\n    it('should remove a schedule', () => {\n      const schedule = tq.addSchedule({ cron: '*/5 * * * *', payload: 'test' });\n      expect(tq.removeSchedule(schedule.id)).toBe(true);\n      expect(tq.listSchedules()).toHaveLength(0);\n\n      const now = new Date('2024-01-01T00:00:00');\n      expect(tq.tick(now)).toHaveLength(0);\n    });\n\n    it('should list active schedules', () => {\n      tq.addSchedule({ cron: '*/5 * * * *', payload: 'a' });\n      tq.addSchedule({ cron: '0 * * * *', payload: 'b' });\n\n      expect(tq.listSchedules()).toHaveLength(2);\n    });\n\n    it('should reject invalid cron expression', () => {\n      expect(() => tq.addSchedule({ cron: 'invalid', payload: 'test' })).toThrow();\n    });\n  });\n\n  // ==================== Phase 11: Middleware Pipeline ====================\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware before handler', async () => {\n      const order: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push('middleware');\n        await next();\n      });\n\n      tq.handle('default', async () => {\n        order.push('handler');\n      });\n\n      tq.add({ payload: 'test' });\n      await tq.process();\n\n      expect(order).toEqual(['middleware', 'handler']);\n    });\n\n    it('should run middleware in order', async () => {\n      const order: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push('first');\n        await next();\n      });\n\n      tq.use('default', async (_task, next) => {\n        order.push('second');\n        await next();\n      });\n\n      tq.handle('default', async () => {\n        order.push('handler');\n      });\n\n      tq.add({ payload: 'test' });\n      await tq.process();\n\n      expect(order).toEqual(['first', 'second', 'handler']);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      const handlerCalled = vi.fn();\n\n      tq.use('default', async () => {\n        // deliberately not calling next\n      });\n\n      tq.handle('default', handlerCalled);\n\n      tq.add({ payload: 'test' });\n      const task = await tq.process();\n\n      expect(handlerCalled).not.toHaveBeenCalled();\n      // Task should still be processing (not auto-completed since middleware didn't pass through)\n      expect(task?.status).not.toBe('completed');\n    });\n\n    it('should modify task in middleware', async () => {\n      tq.use('default', async (task, next) => {\n        task.metadata['enriched'] = true;\n        await next();\n      });\n\n      let enriched = false;\n      tq.handle('default', async (task) => {\n        enriched = task.metadata['enriched'] as boolean;\n      });\n\n      tq.add({ payload: 'test' });\n      await tq.process();\n\n      expect(enriched).toBe(true);\n    });\n\n    it('should fail task if middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = tq.add({ payload: 'test', maxRetries: 1 });\n      await tq.process();\n\n      expect(task.lastError).toBe('middleware error');\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const q1Calls: string[] = [];\n      const q2Calls: string[] = [];\n\n      tq.use('q1', async (_task, next) => {\n        q1Calls.push('q1-mw');\n        await next();\n      });\n\n      tq.use('q2', async (_task, next) => {\n        q2Calls.push('q2-mw');\n        await next();\n      });\n\n      tq.add({ payload: 'a', queue: 'q1' });\n      tq.add({ payload: 'b', queue: 'q2' });\n\n      await tq.process('q1');\n      await tq.process('q2');\n\n      expect(q1Calls).toEqual(['q1-mw']);\n      expect(q2Calls).toEqual(['q2-mw']);\n    });\n\n    it('should return null from process when queue is empty', async () => {\n      const result = await tq.process();\n      expect(result).toBeNull();\n    });\n\n    it('should auto-complete task after successful processing', async () => {\n      tq.handle('default', async () => {\n        // handler succeeds\n      });\n\n      const task = tq.add({ payload: 'test' });\n      await tq.process();\n\n      expect(task.status).toBe('completed');\n    });\n  });\n\n  // ==================== Phase 12: Graceful Shutdown ====================\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should stop accepting new tasks after shutdown', async () => {\n      await tq.shutdown();\n\n      expect(() => tq.add({ payload: 'test' })).toThrow(/shutting down/);\n    });\n\n    it('should complete immediately with no processing tasks', async () => {\n      const summary = await tq.shutdown();\n\n      expect(summary.completed).toBe(0);\n      expect(summary.forceCancelled).toBe(0);\n      expect(summary.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks to complete', async () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      // Start shutdown but complete task during the wait\n      const shutdownPromise = tq.shutdown({ timeout: 5000 });\n\n      // Complete the task after a small delay\n      setTimeout(() => tq.complete(task.id), 50);\n\n      const summary = await shutdownPromise;\n      expect(summary.completed).toBe(1);\n      expect(summary.forceCancelled).toBe(0);\n    });\n\n    it('should force-cancel tasks after timeout', async () => {\n      tq.add({ payload: 'test' });\n      tq.next();\n\n      const summary = await tq.shutdown({ timeout: 50 });\n\n      expect(summary.forceCancelled).toBe(1);\n    });\n\n    it('should be idempotent', async () => {\n      const s1 = tq.shutdown();\n      const s2 = tq.shutdown();\n\n      const r1 = await s1;\n      const r2 = await s2;\n      expect(r1).toBe(r2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      const called = vi.fn();\n      tq.onShutdown(called);\n\n      await tq.shutdown();\n      expect(called).toHaveBeenCal