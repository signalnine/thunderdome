+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016ALLcPGVjLecgf4mSxNG8Q","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, vi } from 'vitest';\n     2→import { TaskQueue } from './task-queue.js';\n     3→\n     4→describe('TaskQueue', () => {\n     5→  let tq: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    tq = new TaskQueue();\n     9→  });\n    10→\n    11→  // ==================== Phase 1: Basic FIFO Queue ====================\n    12→  describe('Phase 1: Basic FIFO Queue', () => {\n    13→    it('should add a task and return a task object with id, status, and createdAt', () => {\n    14→      const task = tq.add({ payload: { message: 'hello' } });\n    15→      expect(task.id).toBeDefined();\n    16→      expect(typeof task.id).toBe('string');\n    17→      expect(task.status).toBe('pending');\n    18→      expect(task.createdAt).toBeInstanceOf(Date);\n    19→      expect(task.payload).toEqual({ message: 'hello' });\n    20→    });\n    21→\n    22→    it('should assign unique IDs to each task', () => {\n    23→      const t1 = tq.add({ payload: 'a' });\n    24→      const t2 = tq.add({ payload: 'b' });\n    25→      expect(t1.id).not.toBe(t2.id);\n    26→    });\n    27→\n    28→    it('should return tasks in FIFO order', () => {\n    29→      tq.add({ payload: 'first' });\n    30→      tq.add({ payload: 'second' });\n    31→      tq.add({ payload: 'third' });\n    32→\n    33→      expect(tq.next()?.payload).toBe('first');\n    34→      expect(tq.next()?.payload).toBe('second');\n    35→      expect(tq.next()?.payload).toBe('third');\n    36→    });\n    37→\n    38→    it('should transition task to processing state on retrieval', () => {\n    39→      const task = tq.add({ payload: 'data' });\n    40→      const retrieved = tq.next();\n    41→      expect(retrieved?.id).toBe(task.id);\n    42→      expect(retrieved?.status).toBe('processing');\n    43→    });\n    44→\n    45→    it('should return null when no tasks available', () => {\n    46→      expect(tq.next()).toBeNull();\n    47→    });\n    48→\n    49→    it('should count pending tasks', () => {\n    50→      expect(tq.pending()).toBe(0);\n    51→      tq.add({ payload: 'a' });\n    52→      tq.add({ payload: 'b' });\n    53→      expect(tq.pending()).toBe(2);\n    54→      tq.next();\n    55→      expect(tq.pending()).toBe(1);\n    56→    });\n    57→\n    58→    it('should retrieve a task by ID', () => {\n    59→      const task = tq.add({ payload: 'test' });\n    60→      const found = tq.getTask(task.id);\n    61→      expect(found).toBeDefined();\n    62→      expect(found?.id).toBe(task.id);\n    63→    });\n    64→\n    65→    it('should return null for non-existent task ID', () => {\n    66→      expect(tq.getTask('non-existent')).toBeNull();\n    67→    });\n    68→  });\n    69→\n    70→  // ==================== Phase 2: Named Queues ====================\n    71→  describe('Phase 2: Named Queues', () => {\n    72→    it('should use default queue when no name given', () => {\n    73→      tq.add({ payload: 'default' });\n    74→      expect(tq.pending()).toBe(1);\n    75→      expect(tq.pending('default')).toBe(1);\n    76→    });\n    77→\n    78→    it('should support multiple independent queues', () => {\n    79→      tq.add({ payload: 'email', queue: 'emails' });\n    80→      tq.add({ payload: 'sms', queue: 'sms' });\n    81→\n    82→      expect(tq.pending('emails')).toBe(1);\n    83→      expect(tq.pending('sms')).toBe(1);\n    84→      expect(tq.pending()).toBe(0); // default queue is empty\n    85→    });\n    86→\n    87→    it('should retrieve from specific queue only', () => {\n    88→      tq.add({ payload: 'email', queue: 'emails' });\n    89→      tq.add({ payload: 'sms', queue: 'sms' });\n    90→\n    91→      const task = tq.next('emails');\n    92→      expect(task?.payload).toBe('email');\n    93→      expect(tq.pending('sms')).toBe(1);\n    94→    });\n    95→\n    96→    it('should return null for non-existent queue', () => {\n    97→      expect(tq.next('nonexistent')).toBeNull();\n    98→    });\n    99→\n   100→    it('should list all queue names', () => {\n   101→      tq.add({ payload: 'a', queue: 'q1' });\n   102→      tq.add({ payload: 'b', queue: 'q2' });\n   103→      const names = tq.listQueues();\n   104→      expect(names).toContain('q1');\n   105→      expect(names).toContain('q2');\n   106→    });\n   107→\n   108→    it('should create queues implicitly', () => {\n   109→      expect(tq.listQueues()).toHaveLength(0);\n   110→      tq.add({ payload: 'data', queue: 'new-queue' });\n   111→      expect(tq.listQueues()).toContain('new-queue');\n   112→    });\n   113→  });\n   114→\n   115→  // ==================== Phase 3: Priority ====================\n   116→  describe('Phase 3: Priority', () => {\n   117→    it('should default to priority 5', () => {\n   118→      const task = tq.add({ payload: 'test' });\n   119→      expect(task.priority).toBe(5);\n   120→    });\n   121→\n   122→    it('should return higher-priority tasks first', () => {\n   123→      tq.add({ payload: 'low', priority: 8 });\n   124→      tq.add({ payload: 'high', priority: 2 });\n   125→      tq.add({ payload: 'medium', priority: 5 });\n   126→\n   127→      expect(tq.next()?.payload).toBe('high');\n   128→      expect(tq.next()?.payload).toBe('medium');\n   129→      expect(tq.next()?.payload).toBe('low');\n   130→    });\n   131→\n   132→    it('should use FIFO for same priority', () => {\n   133→      tq.add({ payload: 'first', priority: 3 });\n   134→      tq.add({ payload: 'second', priority: 3 });\n   135→      tq.add({ payload: 'third', priority: 3 });\n   136→\n   137→      expect(tq.next()?.payload).toBe('first');\n   138→      expect(tq.next()?.payload).toBe('second');\n   139→      expect(tq.next()?.payload).toBe('third');\n   140→    });\n   141→\n   142→    it('should reject invalid priority values', () => {\n   143→      expect(() => tq.add({ payload: 'test', priority: 0 })).toThrow();\n   144→      expect(() => tq.add({ payload: 'test', priority: 11 })).toThrow();\n   145→      expect(() => tq.add({ payload: 'test', priority: 5.5 })).toThrow();\n   146→    });\n   147→\n   148→    it('should maintain priority per queue', () => {\n   149→      tq.add({ payload: 'q1-low', priority: 8, queue: 'q1' });\n   150→      tq.add({ payload: 'q1-high', priority: 2, queue: 'q1' });\n   151→      tq.add({ payload: 'q2-low', priority: 9, queue: 'q2' });\n   152→\n   153→      expect(tq.next('q1')?.payload).toBe('q1-high');\n   154→      expect(tq.next('q2')?.payload).toBe('q2-low');\n   155→    });\n   156→  });\n   157→\n   158→  // ==================== Phase 4: Delayed Tasks ====================\n   159→  describe('Phase 4: Delayed Tasks', () => {\n   160→    it('should not return delayed tasks before their available time', () => {\n   161→      tq.add({ payload: 'delayed', delay: 60000 });\n   162→      expect(tq.next()).toBeNull();\n   163→    });\n   164→\n   165→    it('should return delayed tasks after their available time', () => {\n   166→      const pastTime = new Date(Date.now() - 1000);\n   167→      tq.add({ payload: 'available', availableAt: pastTime });\n   168→      const task = tq.next();\n   169→      expect(task?.payload).toBe('available');\n   170→    });\n   171→\n   172→    it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {\n   173→      tq.add({ payload: 'delayed', delay: 60000, priority: 1 });\n   174→      tq.add({ payload: 'immediate', priority: 10 });\n   175→\n   176→      expect(tq.next()?.payload).toBe('immediate');\n   177→    });\n   178→\n   179→    it('should expose availability time on task', () => {\n   180→      const task = tq.add({ payload: 'test', delay: 5000 });\n   181→      expect(task.availableAt).toBeInstanceOf(Date);\n   182→      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n   183→    });\n   184→\n   185→    it('should work with named queues', () => {\n   186→      tq.add({ payload: 'delayed', delay: 60000, queue: 'q1' });\n   187→      tq.add({ payload: 'immediate', queue: 'q1' });\n   188→\n   189→      expect(tq.next('q1')?.payload).toBe('immediate');\n   190→    });\n   191→\n   192→    it('should accept a specific availableAt Date', () => {\n   193→      const future = new Date(Date.now() + 60000);\n   194→      const task = tq.add({ payload: 'scheduled', availableAt: future });\n   195→      expect(task.availableAt.getTime()).toBe(future.getTime());\n   196→      expect(tq.next()).toBeNull();\n   197→    });\n   198→  });\n   199→\n   200→  // ==================== Phase 5: Retry with Backoff ====================\n   201→  describe('Phase 5: Retry with Backoff', () => {\n   202→    it('should complete a task', () => {\n   203→      const task = tq.add({ payload: 'test' });\n   204→      tq.next();\n   205→      const completed = tq.complete(task.id);\n   206→      expect(completed.status).toBe('completed');\n   207→    });\n   208→\n   209→    it('should fail a task and retry with backoff', () => {\n   210→      const task = tq.add({ payload: 'test', maxRetries: 3, backoffDelay: 100 });\n   211→      tq.next();\n   212→      const failed = tq.fail(task.id, 'error');\n   213→\n   214→      expect(failed.status).toBe('pending');\n   215→      expect(failed.attempts).toBe(1);\n   216→      expect(failed.lastError).toBe('error');\n   217→      // Backoff: 100 * 2^0 = 100ms\n   218→      expect(failed.availableAt.getTime()).toBeGreaterThan(Date.now());\n   219→    });\n   220→\n   221→    it('should use exponential backoff', () => {\n   222→      const task = tq.add({ payload: 'test', maxRetries: 5, backoffDelay: 1000 });\n   223→\n   224→      // First attempt\n   225→      tq.next();\n   226→      tq.fail(task.id, 'err1');\n   227→      // Backoff: 1000 * 2^0 = 1000ms\n   228→      const delay1 = task.availableAt.getTime() - Date.now();\n   229→      expect(delay1).toBeGreaterThan(800);\n   230→      expect(delay1).toBeLessThan(1200);\n   231→\n   232→      // Need to make the task available for the next attempt\n   233→      task.availableAt = new Date(Date.now() - 1);\n   234→      tq.next();\n   235→      tq.fail(task.id, 'err2');\n   236→      // Backoff: 1000 * 2^1 = 2000ms\n   237→      const delay2 = task.availableAt.getTime() - Date.now();\n   238→      expect(delay2).toBeGreaterThan(1800);\n   239→      expect(delay2).toBeLessThan(2200);\n   240→    });\n   241→\n   242→    it('should default to 3 retries', () => {\n   243→      const task = tq.add({ payload: 'test' });\n   244→      expect(task.maxRetries).toBe(3);\n   245→    });\n   246→\n   247→    it('should track attempt count', () => {\n   248→      const task = tq.add({ payload: 'test', maxRetries: 2, backoffDelay: 1 });\n   249→\n   250→      tq.next();\n   251→      expect(task.attempts).toBe(1);\n   252→      tq.fail(task.id);\n   253→      task.availableAt = new Date(Date.now() - 1);\n   254→\n   255→      tq.next();\n   256→      expect(task.attempts).toBe(2);\n   257→    });\n   258→\n   259→    it('should keep original queue and priority on retry', () => {\n   260→      const task = tq.add({ payload: 'test', queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 1 });\n   261→      tq.next('myq');\n   262→      tq.fail(task.id, 'err');\n   263→\n   264→      expect(task.queue).toBe('myq');\n   265→      expect(task.priority).toBe(2);\n   266→    });\n   267→\n   268→    it('should mark as failed when retries exhausted', () => {\n   269→      const task = tq.add({ payload: 'test', maxRetries: 1, backoffDelay: 1 });\n   270→      tq.next();\n   271→      tq.fail(task.id, 'final error');\n   272→\n   273→      expect(task.status).toBe('failed');\n   274→    });\n   275→\n   276→    it('should throw when completing a non-processing task', () => {\n   277→      const task = tq.add({ payload: 'test' });\n   278→      expect(() => tq.complete(task.id)).toThrow();\n   279→    });\n   280→\n   281→    it('should throw when failing a non-processing task', () => {\n   282→      const task = tq.add({ payload: 'test' });\n   283→      expect(() => tq.fail(task.id)).toThrow();\n   284→    });\n   285→  });\n   286→\n   287→  // ==================== Phase 6: Dead Letter Queue ====================\n   288→  describe('Phase 6: Dead Letter Queue', () => {\n   289→    it('should move task to DLQ when retries exhausted', () => {\n   290→      const task = tq.add({ payload: 'test', maxRetries: 1, backoffDelay: 1 });\n   291→      tq.next();\n   292→      tq.fail(task.id, 'error');\n   293→\n   294→      const dlq = tq.deadLetterQueue();\n   295→      expect(dlq).toHaveLength(1);\n   296→      expect(dlq[0].id).toBe(task.id);\n   297→      expect(dlq[0].lastError).toBe('error');\n   298→    });\n   299→\n   300→    it('should have per-queue DLQs', () => {\n   301→      const t1 = tq.add({ payload: 'a', queue: 'q1', maxRetries: 1 });\n   302→      const t2 = tq.add({ payload: 'b', queue: 'q2', maxRetries: 1 });\n   303→\n   304→      tq.next('q1');\n   305→      tq.fail(t1.id, 'err');\n   306→      tq.next('q2');\n   307→      tq.fail(t2.id, 'err');\n   308→\n   309→      expect(tq.deadLetterQueue('q1')).toHaveLength(1);\n   310→      expect(tq.deadLetterQueue('q2')).toHaveLength(1);\n   311→    });\n   312→\n   313→    it('should redrive a dead-lettered task', () => {\n   314→      const task = tq.add({ payload: 'test', maxRetries: 1, backoffDelay: 1 });\n   315→      tq.next();\n   316→      tq.fail(task.id, 'error');\n   317→\n   318→      expect(tq.deadLetterQueue()).toHaveLength(1);\n   319→      const redriven = tq.redrive(task.id);\n   320→      expect(redriven.status).toBe('pending');\n   321→      expect(redriven.attempts).toBe(0);\n   322→      expect(tq.deadLetterQueue()).toHaveLength(0);\n   323→      expect(tq.pending()).toBe(1);\n   324→    });\n   325→\n   326→    it('should clear DLQ for a queue', () => {\n   327→      const t1 = tq.add({ payload: 'a', maxRetries: 1 });\n   328→      const t2 = tq.add({ payload: 'b', maxRetries: 1 });\n   329→\n   330→      tq.next();\n   331→      tq.fail(t1.id, 'err');\n   332→      tq.next();\n   333→      tq.fail(t2.id, 'err');\n   334→\n   335→      expect(tq.deadLetterQueue()).toHaveLength(2);\n   336→      const count = tq.clearDLQ();\n   337→      expect(count).toBe(2);\n   338→      expect(tq.deadLetterQueue()).toHaveLength(0);\n   339→    });\n   340→\n   341→    it('should return empty array for queue with no DLQ', () => {\n   342→      expect(tq.deadLetterQueue('nonexistent')).toEqual([]);\n   343→    });\n   344→  });\n   345→\n   346→  // ==================== Phase 7: Task Dependencies ====================\n   347→  describe('Phase 7: Task Dependencies', () => {\n   348→    it('should block tasks with unresolved dependencies', () => {\n   349→      const dep = tq.add({ payload: 'dep' });\n   350→      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n   351→\n   352→      expect(task.status).toBe('blocked');\n   353→      expect(tq.next()).not.toBeNull(); // gets dep\n   354→      expect(tq.next()).toBeNull(); // task is blocked\n   355→    });\n   356→\n   357→    it('should unblock task when dependency completes', () => {\n   358→      const dep = tq.add({ payload: 'dep' });\n   359→      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n   360→\n   361→      const depTask = tq.next()!;\n   362→      tq.complete(depTask.id);\n   363→\n   364→      expect(task.status).toBe('pending');\n   365→      const mainTask = tq.next();\n   366→      expect(mainTask?.id).toBe(task.id);\n   367→    });\n   368→\n   369→    it('should handle multiple dependencies', () => {\n   370→      const dep1 = tq.add({ payload: 'dep1' });\n   371→      const dep2 = tq.add({ payload: 'dep2' });\n   372→      const task = tq.add({ payload: 'main', dependencies: [dep1.id, dep2.id] });\n   373→\n   374→      expect(task.status).toBe('blocked');\n   375→\n   376→      const d1 = tq.next()!;\n   377→      tq.complete(d1.id);\n   378→      expect(task.status).toBe('blocked'); // still waiting for dep2\n   379→\n   380→      const d2 = tq.next()!;\n   381→      tq.complete(d2.id);\n   382→      expect(task.status).toBe('pending'); // now unblocked\n   383→    });\n   384→\n   385→    it('should reject non-existent dependency', () => {\n   386→      expect(() => tq.add({ payload: 'test', dependencies: ['fake-id'] })).toThrow();\n   387→    });\n   388→\n   389→    it('should keep dependents blocked when dependency fails', () => {\n   390→      const dep = tq.add({ payload: 'dep', maxRetries: 1 });\n   391→      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n   392→\n   393→      tq.next();\n   394→      tq.fail(dep.id, 'error');\n   395→\n   396→      expect(task.status).toBe('blocked');\n   397→    });\n   398→\n   399→    it('should report dependency status', () => {\n   400→      const dep1 = tq.add({ payload: 'dep1' });\n   401→      const dep2 = tq.add({ payload: 'dep2' });\n   402→      const task = tq.add({ payload: 'main', dependencies: [dep1.id, dep2.id] });\n   403→\n   404→      const status = tq.getDependencyStatus(task.id);\n   405→      expect(status.total).toBe(2);\n   406→      expect(status.resolved).toBe(0);\n   407→      expect(status.pending).toHaveLength(2);\n   408→\n   409→      const d1 = tq.next()!;\n   410→      tq.complete(d1.id);\n   411→\n   412→      const status2 = tq.getDependencyStatus(task.id);\n   413→      expect(status2.resolved).toBe(1);\n   414→      expect(status2.pending).toHaveLength(1);\n   415→    });\n   416→\n   417→    it('should unblock task when dependency is already completed', () => {\n   418→      const dep = tq.add({ payload: 'dep' });\n   419→      const d = tq.next()!;\n   420→      tq.complete(d.id);\n   421→\n   422→      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n   423→      expect(task.status).toBe('pending'); // already resolved\n   424→    });\n   425→  });\n   426→\n   427→  // ==================== Phase 8: Concurrency Control ====================\n   428→  describe('Phase 8: Concurrency Control', () => {\n   429→    it('should limit concurrent processing', () => {\n   430→      tq.setConcurrency('default', 2);\n   431→      tq.add({ payload: 'a' });\n   432→      tq.add({ payload: 'b' });\n   433→      tq.add({ payload: 'c' });\n   434→\n   435→      expect(tq.next()).not.toBeNull();\n   436→      expect(tq.next()).not.toBeNull();\n   437→      expect(tq.next()).toBeNull(); // concurrency limit reached\n   438→    });\n   439→\n   440→    it('should free slot when task completes', () => {\n   441→      tq.setConcurrency('default', 1);\n   442→      const t1 = tq.add({ payload: 'a' });\n   443→      tq.add({ payload: 'b' });\n   444→\n   445→      tq.next();\n   446→      expect(tq.next()).toBeNull();\n   447→\n   448→      tq.complete(t1.id);\n   449→      expect(tq.next()).not.toBeNull();\n   450→    });\n   451→\n   452→    it('should free slot when task fails', () => {\n   453→      tq.setConcurrency('default', 1);\n   454→      const t1 = tq.add({ payload: 'a', maxRetries: 1 });\n   455→      tq.add({ payload: 'b' });\n   456→\n   457→      tq.next();\n   458→      expect(tq.next()).toBeNull();\n   459→\n   460→      tq.fail(t1.id, 'err');\n   461→      expect(tq.next()).not.toBeNull();\n   462→    });\n   463→\n   464→    it('should have no limit by default', () => {\n   465→      expect(tq.getConcurrency('default')).toBeUndefined();\n   466→    });\n   467→\n   468→    it('should report active count', () => {\n   469→      tq.add({ payload: 'a' });\n   470→      tq.add({ payload: 'b' });\n   471→\n   472→      expect(tq.getActiveCount('default')).toBe(0);\n   473→      tq.next();\n   474→      expect(tq.getActiveCount('default')).toBe(1);\n   475→      tq.next();\n   476→      expect(tq.getActiveCount('default')).toBe(2);\n   477→    });\n   478→\n   479→    it('should respect priority under concurrency limits', () => {\n   480→      tq.setConcurrency('default', 1);\n   481→      tq.add({ payload: 'low', priority: 8 });\n   482→      tq.add({ payload: 'high', priority: 2 });\n   483→\n   484→      expect(tq.next()?.payload).toBe('high');\n   485→    });\n   486→  });\n   487→\n   488→  // ==================== Phase 9: Progress and Cancellation ====================\n   489→  describe('Phase 9: Progress and Cancellation', () => {\n   490→    it('should report progress on a processing task', () => {\n   491→      const task = tq.add({ payload: 'test' });\n   492→      tq.next();\n   493→\n   494→      tq.reportProgress(task.id, 50, 'halfway');\n   495→      const found = tq.getTask(task.id)!;\n   496→      expect(found.progress).toBe(50);\n   497→      expect(found.progressMessage).toBe('halfway');\n   498→    });\n   499→\n   500→    it('should reject invalid progress values', () => {\n   501→      const task = tq.add({ payload: 'test' });\n   502→      tq.next();\n   503→\n   504→      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n   505→      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n   506→    });\n   507→\n   508→    it('should notify progress listeners', () => {\n   509→      const task = tq.add({ payload: 'test' });\n   510→      tq.next();\n   511→\n   512→      const updates: Array<{ progress: number; message?: string }> = [];\n   513→      tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n   514→\n   515→      tq.reportProgress(task.id, 25, 'quarter');\n   516→      tq.reportProgress(task.id, 75, 'three quarters');\n   517→\n   518→      expect(updates).toHaveLength(2);\n   519→      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n   520→      expect(updates[1]).toEqual({ progress: 75, message: 'three quarters' });\n   521→    });\n   522→\n   523→    it('should support unsubscribing from progress updates', () => {\n   524→      const task = tq.add({ payload: 'test' });\n   525→      tq.next();\n   526→\n   527→      const updates: number[] = [];\n   528→      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n   529→\n   530→      tq.reportProgress(task.id, 25);\n   531→      unsub();\n   532→      tq.reportProgress(task.id, 75);\n   533→\n   534→      expect(updates).toHaveLength(1);\n   535→      expect(updates[0]).toBe(25);\n   536→    });\n   537→\n   538→    it('should cancel a pending task', () => {\n   539→      const task = tq.add({ payload: 'test' });\n   540→      const cancelled = tq.cancel(task.id);\n   541→\n   542→      expect(cancelled.status).toBe('cancelled');\n   543→      expect(tq.pending()).toBe(0);\n   544→      expect(tq.next()).toBeNull();\n   545→    });\n   546→\n   547→    it('should cancel a processing task', () => {\n   548→      const task = tq.add({ payload: 'test' });\n   549→      tq.next();\n   550→\n   551→      const cancelled = tq.cancel(task.id);\n   552→      expect(cancelled.status).toBe('cancelled');\n   553→    });\n   554→\n   555→    it('should not retry cancelled tasks', () => {\n   556→      const task = tq.add({ payload: 'test', maxRetries: 5 });\n   557→      tq.next();\n   558→\n   559→      tq.cancel(task.id);\n   560→      expect(task.status).toBe('cancelled');\n   561→      // Task should not be requeued\n   562→      expect(tq.pending()).toBe(0);\n   563→    });\n   564→\n   565→    it('should throw when cancelling a completed task', () => {\n   566→      const task = tq.add({ payload: 'test' });\n   567→      tq.next();\n   568→      tq.complete(task.id);\n   569→\n   570→      expect(() => tq.cancel(task.id)).toThrow();\n   571→    });\n   572→  });\n   573→\n   574→  // ==================== Phase 10: Recurring Tasks ====================\n   575→  describe('Phase 10: Recurring Tasks', () => {\n   576→    it('should create a schedule', () => {\n   577→      const schedule = tq.addSchedule({\n   578→        cron: '*/5 * * * *',\n   579→        payload: { type: 'cleanup' },\n   580→      });\n   581→\n   582→      expect(schedule.id).toBeDefined();\n   583→      expect(schedule.cron).toBe('*/5 * * * *');\n   584→      expect(schedule.active).toBe(true);\n   585→    });\n   586→\n   587→    it('should enqueue tasks on tick', () => {\n   588→      tq.addSchedule({\n   589→        cron: '*/5 * * * *',\n   590→        payload: { type: 'cleanup' },\n   591→      });\n   592→\n   593→      // Tick at minute 0 (should match */5)\n   594→      const now = new Date('2024-01-01T00:00:00');\n   595→      const created = tq.tick(now);\n   596→      expect(created).toHaveLength(1);\n   597→      expect(created[0].payload).toEqual({ type: 'cleanup' });\n   598→    });\n   599→\n   600→    it('should not enqueue when cron does not match', () => {\n   601→      tq.addSchedule({\n   602→        cron: '0 * * * *', // every hour on the hour\n   603→        payload: 'hourly',\n   604→      });\n   605→\n   606→      // Tick at minute 30 - should not match\n   607→      const now = new Date('2024-01-01T00:30:00');\n   608→      const created = tq.tick(now);\n   609→      expect(created).toHaveLength(0);\n   610→    });\n   611→\n   612→    it('should support every day at midnight', () => {\n   613→      tq.addSchedule({\n   614→        cron: '0 0 * * *',\n   615→        payload: 'daily',\n   616→      });\n   617→\n   618→      // Tick at midnight\n   619→      const midnight = new Date('2024-01-01T00:00:00');\n   620→      expect(tq.tick(midnight)).toHaveLength(1);\n   621→\n   622→      // Tick at noon\n   623→      const noon = new Date('2024-01-01T12:00:00');\n   624→      expect(tq.tick(noon)).toHaveLength(0);\n   625→    });\n   626→\n   627→    it('should prevent duplicate runs in the same minute', () => {\n   628→      tq.addSchedule({\n   629→        cron: '*/1 * * * *',\n   630→        payload: 'every-min',\n   631→      });\n   632→\n   633→      const now = new Date('2024-01-01T00:00:00');\n   634→      expect(tq.tick(now)).toHaveLength(1);\n   635→      expect(tq.tick(now)).toHaveLength(0); // same minute\n   636→    });\n   637→\n   638→    it('should remove a schedule', () => {\n   639→      const schedule = tq.addSchedule({ cron: '*/5 * * * *', payload: 'test' });\n   640→      expect(tq.removeSchedule(schedule.id)).toBe(true);\n   641→      expect(tq.listSchedules()).toHaveLength(0);\n   642→\n   643→      const now = new Date('2024-01-01T00:00:00');\n   644→      expect(tq.tick(now)).toHaveLength(0);\n   645→    });\n   646→\n   647→    it('should list active schedules', () => {\n   648→      tq.addSchedule({ cron: '*/5 * * * *', payload: 'a' });\n   649→      tq.addSchedule({ cron: '0 * * * *', payload: 'b' });\n   650→\n   651→      expect(tq.listSchedules()).toHaveLength(2);\n   652→    });\n   653→\n   654→    it('should reject invalid cron expression', () => {\n   655→      expect(() => tq.addSchedule({ cron: 'invalid', payload: 'test' })).toThrow();\n   656→    });\n   657→  });\n   658→\n   659→  // ==================== Phase 11: Middleware Pipeline ====================\n   660→  describe('Phase 11: Middleware Pipeline', () => {\n   661→    it('should run middleware before handler', async () => {\n   662→      const order: string[] = [];\n   663→\n   664→      tq.use('default', async (_task, next) => {\n   665→        order.push('middleware');\n   666→        await next();\n   667→      });\n   668→\n   669→      tq.handle('default', async () => {\n   670→        order.push('handler');\n   671→      });\n   672→\n   673→      tq.add({ payload: 'test' });\n   674→      await tq.process();\n   675→\n   676→      expect(order).toEqual(['middleware', 'handler']);\n   677→    });\n   678→\n   679→    it('should run middleware in order', async () => {\n   680→      const order: string[] = [];\n   681→\n   682→      tq.use('default', async (_task, next) => {\n   683→        order.push('first');\n   684→        await next();\n   685→      });\n   686→\n   687→      tq.use('default', async (_task, next) => {\n   688→        order.push('second');\n   689→        await next();\n   690→      });\n   691→\n   692→      tq.handle('default', async () => {\n   693→        order.push('handler');\n   694→      });\n   695→\n   696→      tq.add({ payload: 'test' });\n   697→      await tq.process();\n   698→\n   699→      expect(order).toEqual(['first', 'second', 'handler']);\n   700→    });\n   701→\n   702→    it('should skip processing if middleware does not call next', async () => {\n   703→      const handlerCalled = vi.fn();\n   704→\n   705→      tq.use('default', async () => {\n   706→        // deliberately not calling next\n   707→      });\n   708→\n   709→      tq.handle('default', handlerCalled);\n   710→\n   711→      tq.add({ payload: 'test' });\n   712→      const task = await tq.process();\n   713→\n   714→      expect(handlerCalled).not.toHaveBeenCalled();\n   715→      // Task should still be processing (not auto-completed since middleware didn't pass through)\n   716→      expect(task?.status).not.toBe('completed');\n   717→    });\n   718→\n   719→    it('should modify task in middleware', async () => {\n   720→      tq.use('default', async (task, next) => {\n   721→        task.metadata['enriched'] = true;\n   722→        await next();\n   723→      });\n   724→\n   725→      let enriched = false;\n   726→      tq.handle('default', async (task) => {\n   727→        enriched = task.metadata['enriched'] as boolean;\n   728→      });\n   729→\n   730→      tq.add({ payload: 'test' });\n   731→      await tq.process();\n   732→\n   733→      expect(enriched).toBe(true);\n   734→    });\n   735→\n   736→    it('should fail task if middleware throws', async () => {\n   737→      tq.use('default', async () => {\n   738→        throw new Error('middleware error');\n   739→      });\n   740→\n   741→      const task = tq.add({ payload: 'test', maxRetries: 1 });\n   742→      await tq.process();\n   743→\n   744→      expect(task.lastError).toBe('middleware error');\n   745→    });\n   746→\n   747→    it('should have independent middleware per queue', async () => {\n   748→      const q1Calls: string[] = [];\n   749→      const q2Calls: string[] = [];\n   750→\n   751→      tq.use('q1', async (_task, next) => {\n   752→        q1Calls.push('q1-mw');\n   753→        await next();\n   754→      });\n   755→\n   756→      tq.use('q2', async (_task, next) => {\n   757→        q2Calls.push('q2-mw');\n   758→        await next();\n   759→      });\n   760→\n   761→      tq.add({ payload: 'a', queue: 'q1' });\n   762→      tq.add({ payload: 'b', queue: 'q2' });\n   763→\n   764→      await tq.process('q1');\n   765→      await tq.process('q2');\n   766→\n   767→      expect(q1Calls).toEqual(['q1-mw']);\n   768→      expect(q2Calls).toEqual(['q2-mw']);\n   769→    });\n   770→\n   771→    it('should return null from process when queue is empty', async () => {\n   772→      const result = await tq.process();\n   773→      expect(result).toBeNull();\n   774→    });\n   775→\n   776→    it('should auto-complete task after successful processing', async () => {\n   777→      tq.handle('default', async () => {\n   778→        // handler succeeds\n   779→      });\n   780→\n   781→      const task = tq.add({ payload: 'test' });\n   782→      await tq.process();\n   783→\n   784→      expect(task.status).toBe('completed');\n   785→    });\n   786→  });\n   787→\n   788→  // ==================== Phase 12: Graceful Shutdown ====================\n   789→  describe('Phase 12: Graceful Shutdown', () => {\n   790→    it('should stop accepting new tasks after shutdown', async () => {\n   791→      await tq.shutdown();\n   792→\n   793→      expect(() => tq.add({ payload: 'test' })).toThrow(/shutting down/);\n   794→    });\n   795→\n   796→    it('should complete immediately with no processing tasks', async () => {\n   797→      const summary = await tq.shutdown();\n   798→\n   799→      expect(summary.completed).toBe(0);\n   800→      expect(summary.forceCancelled).toBe(0);\n   801→      expect(summary.duration).toBeGreaterThanOrEqual(0);\n   802→    });\n   803→\n   804→    it('should wait for processing tasks to complete', async () => {\n   805→      const task = tq.add({ payload: 'test' });\n   806→      tq.next();\n   807→\n   808→      // Start shutdown but complete task during the wait\n   809→      const shutdownPromise = tq.shutdown({ timeout: 5000 });\n   810→\n   811→      // Complete the task after a small delay\n   812→      setTimeout(() => tq.complete(task.id), 50);\n   813→\n   814→      const summary = await shutdownPromise;\n   815→      expect(summary.completed).toBe(1);\n   816→      expect(summary.forceCancelled).toBe(0);\n   817→    });\n   818→\n   819→    it('should force-cancel tasks after timeout', async () => {\n   820→      tq.add({ payload: 'test' });\n   821→      tq.next();\n   822→\n   823→      const summary = await tq.shutdown({ timeout: 50 });\n   824→\n   825→      expect(summary.forceCancelled).toBe(1);\n   826→    });\n   827→\n   828→    it('should be idempotent', async () => {\n   829→      const s1 = tq.shutdown();\n   830→      const s2 = tq.shutdown();\n   831→\n   832→      const r1 = await s1;\n   833→      const r2 = await s2;\n   834→      expect(r1).toBe(r2);\n   835→    });\n   836→\n   837→    it('should run shutdown callbacks', async () => {\n   838→      const called = vi.fn();\n   839→      tq.onShutdown(called);\n   840→\n   841→      await tq.shutdown();\n   842→      expect(called).toHaveBeenCalled();\n   843→    });\n   844→\n   845→    it('should report shutdown duration', async () => {\n   846→      const summary = await tq.shutdown();\n   847→      expect(typeof summary.duration).toBe('number');\n   848→      expect(summary.duration).toBeGreaterThanOrEqual(0);\n   849→    });\n   850→\n   851→    it('should expose shuttingDown property', async () => {\n   852→      expect(tq.shuttingDown).toBe(false);\n   853→      const promise = tq.shutdown();\n   854→      expect(tq.shuttingDown).toBe(true);\n   855→      await promise;\n   856→    });\n   857→  });\n   858→\n   859→  // ==================== Integration / Edge Case Tests ====================\n   860→  describe('Integration and Edge Cases', () => {\n   861→    it('should handle delayed tasks with priorities across queues', () => {\n   862→      const past = new Date(Date.now() - 1000);\n   863→      tq.add({ payload: 'low-avail', priority: 8, availableAt: past, queue: 'q' });\n   864→      tq.add({ payload: 'high-avail', priority: 2, availableAt: past, queue: 'q' });\n   865→      tq.add({ payload: 'high-delayed', priority: 1, delay: 60000, queue: 'q' });\n   866→\n   867→      // Should get high-avail first (available, highest priority among available)\n   868→      expect(tq.next('q')?.payload).toBe('high-avail');\n   869→      expect(tq.next('q')?.payload).toBe('low-avail');\n   870→      expect(tq.next('q')).toBeNull(); // delayed task not available\n   871→    });\n   872→\n   873→    it('should handle retry then complete successfully', () => {\n   874→      const task = tq.add({ payload: 'test', maxRetries: 3, backoffDelay: 1 });\n   875→\n   876→      // First attempt: fail\n   877→      tq.next();\n   878→      tq.fail(task.id, 'first error');\n   879→      expect(task.attempts).toBe(1);\n   880→\n   881→      // Second attempt: succeed\n   882→      task.availableAt = new Date(Date.now() - 1);\n   883→      tq.next();\n   884→      tq.complete(task.id);\n   885→      expect(task.status).toBe('completed');\n   886→      expect(task.attempts).toBe(2);\n   887→    });\n   888→\n   889→    it('should handle concurrency with delayed tasks', () => {\n   890→      tq.setConcurrency('default', 1);\n   891→      const t1 = tq.add({ payload: 'a' });\n   892→      tq.add({ payload: 'b', delay: 60000 });\n   893→\n   894→      tq.next(); // get task a\n   895→      expect(tq.next()).toBeNull(); // concurrency limit\n   896→      tq.complete(t1.id);\n   897→      expect(tq.next()).toBeNull(); // b is delayed\n   898→    });\n   899→\n   900→    it('should handle dependencies with different queues', () => {\n   901→      const dep = tq.add({ payload: 'dep', queue: 'q1' });\n   902→      const task = tq.add({ payload: 'main', queue: 'q2', dependencies: [dep.id] });\n   903→\n   904→      expect(task.status).toBe('blocked');\n   905→      expect(tq.next('q2')).toBeNull();\n   906→\n   907→      const d = tq.next('q1')!;\n   908→      tq.complete(d.id);\n   909→\n   910→      expect(task.status).toBe('pending');\n   911→      const main = tq.next('q2');\n   912→      expect(main?.payload).toBe('main');\n   913→    });\n   914→\n   915→    it('should cancel a blocked task', () => {\n   916→      const dep = tq.add({ payload: 'dep' });\n   917→      const task = tq.add({ payload: 'main', dependencies: [dep.id] });\n   918→\n   919→      expect(task.status).toBe('blocked');\n   920→      const cancelled = tq.cancel(task.id);\n   921→      expect(cancelled.status).toBe('cancelled');\n   922→    });\n   923→\n   924→    it('should handle process with no handler and no middleware', async () => {\n   925→      tq.add({ payload: 'test' });\n   926→      const task = await tq.process();\n   927→      expect(task?.status).toBe('completed');\n   928→    });\n   929→\n   930→    it('should handle recurring tasks with queue options', () => {\n   931→      tq.addSchedule({\n   932→        cron: '*/5 * * * *',\n   933→        payload: 'test',\n   934→        queue: 'scheduled',\n   935→        priority: 2,\n   936→      });\n   937→\n   938→      const now = new Date('2024-01-01T00:00:00');\n   939→      const tasks = tq.tick(now);\n   940→      expect(tasks).toHaveLength(1);\n   941→      expect(tasks[0].queue).toBe('scheduled');\n   942→      expect(tasks[0].priority).toBe(2);\n   943→    });\n   944→\n   945→    it('should handle multiple schedules ticking at different times', () => {\n   946→      tq.addSchedule({ cron: '*/5 * * * *', payload: 'every5' });\n   947→      tq.addSchedule({ cron: '*/10 * * * *', payload: 'every10' });\n   948→\n   949→      // At minute 5: both */5 and not */10 match\n   950→      const t1 = tq.tick(new Date('2024-01-01T00:05:00'));\n   951→      expect(t1).toHaveLength(1);\n   952→      expect(t1[0].payload).toBe('every5');\n   953→\n   954→      // At minute 10: both match\n   955→      const t2 = tq.tick(new Date('2024-01-01T00:10:00'));\n   956→      expect(t2).toHaveLength(2);\n   957→    });\n   958→\n   959→    it('should process middleware that throws and retry', async () => {\n   960→      let callCount = 0;\n   961→      tq.use('default', async (_task, next) => {\n   962→        callCount++;\n   963→        if (callCount === 1) {\n   964→          throw new Error('first attempt error');\n   965→        }\n   966→        await next();\n   967→      });\n   968→\n   969→      tq.handle('default', async () => {\n   970→        // handler\n   971→      });\n   972→\n   973→      const task = tq.add({ payload: 'test', maxRetries: 3, backoffDelay: 1 });\n   974→\n   975→      // First process: middleware throws\n   976→      await tq.process();\n   977→      expect(task.status).toBe('pending'); // retried\n   978→      expect(task.lastError).toBe('first attempt error');\n   979→\n   980→      // Make available for retry\n   981→      task.availableAt = new Date(Date.now() - 1);\n   982→\n   983→      // Second process: middleware succeeds\n   984→      await tq.process();\n   985→      expect(task.status).toBe('completed');\n   986→    });\n   987→\n   988→    it('should decrement active count when cancelling processing task under concurrency', () => {\n   989→      tq.setConcurrency('default', 2);\n   990→      tq.add({ payload: 'a' });\n   991→      tq.add({ payload: 'b' });\n   992→      tq.add({ payload: 'c' });\n   993→\n   994→      const t1 = tq.next()!;\n   995→      tq.next()!;\n   996→      expect(tq.getActiveCount('default')).toBe(2);\n   997→      expect(tq.next()).toBeNull(); // at limit\n   998→\n   999→      tq.cancel(t1.id);\n  1000→      expect(tq.getActiveCount('default')).toBe(1);\n  1001→      expect(tq.next()).not.toBeNull(); // freed up a slot\n  1002→    });\n  1003→  });\n  1004→});\n  1005→"}]},"parent_tool_use_id":"toolu_018AXXupVqJ6TjwZQRkyLuon","session_id":"d55f7efa-1a7c-4c18-baa6-46556b297090","uuid":"f0feb53b-9f9c-431f-a6ce-80aeb647f899"}
