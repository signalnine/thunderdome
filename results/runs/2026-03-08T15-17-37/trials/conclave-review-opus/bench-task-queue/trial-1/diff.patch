+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Tczhj11QxFLRrX4PkycJQf","type":"tool_result","content":"     1→export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled' | 'blocked';\n     2→\n     3→export interface Task<T = unknown> {\n     4→  id: string;\n     5→  payload: T;\n     6→  status: TaskStatus;\n     7→  queue: string;\n     8→  priority: number;\n     9→  createdAt: Date;\n    10→  updatedAt: Date;\n    11→  availableAt: Date;\n    12→  attempts: number;\n    13→  maxRetries: number;\n    14→  backoffDelay: number;\n    15→  lastError?: string;\n    16→  dependencies: string[];\n    17→  resolvedDependencies: Set<string>;\n    18→  progress: number;\n    19→  progressMessage?: string;\n    20→  metadata: Record<string, unknown>;\n    21→}\n    22→\n    23→export interface AddTaskOptions<T = unknown> {\n    24→  payload: T;\n    25→  queue?: string;\n    26→  priority?: number;\n    27→  delay?: number;\n    28→  availableAt?: Date;\n    29→  maxRetries?: number;\n    30→  backoffDelay?: number;\n    31→  dependencies?: string[];\n    32→}\n    33→\n    34→export interface ScheduleOptions<T = unknown> {\n    35→  id?: string;\n    36→  cron: string;\n    37→  queue?: string;\n    38→  payload: T;\n    39→  priority?: number;\n    40→  maxRetries?: number;\n    41→  backoffDelay?: number;\n    42→}\n    43→\n    44→export interface Schedule<T = unknown> {\n    45→  id: string;\n    46→  cron: string;\n    47→  queue: string;\n    48→  payload: T;\n    49→  priority: number;\n    50→  maxRetries: number;\n    51→  backoffDelay: number;\n    52→  lastRun?: Date;\n    53→  active: boolean;\n    54→}\n    55→\n    56→export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void> | void;\n    57→export type HandlerFn = (task: Task) => Promise<void> | void;\n    58→export type ProgressListener = (progress: number, message?: string) => void;\n    59→\n    60→export interface ShutdownOptions {\n    61→  timeout?: number;\n    62→}\n    63→\n    64→export interface ShutdownSummary {\n    65→  completed: number;\n    66→  forceCancelled: number;\n    67→  duration: number;\n    68→}\n    69→\n    70→export interface QueueConfig {\n    71→  concurrency?: number;\n    72→}\n    73→"}]},"parent_tool_use_id":"toolu_018AXXupVqJ6TjwZQRkyLuon","session_id":"d55f7efa-1a7c-4c18-baa6-46556b297090","uuid":"b49b2cbe-b995-4b72-8b97-ed54d9d24c70"}
