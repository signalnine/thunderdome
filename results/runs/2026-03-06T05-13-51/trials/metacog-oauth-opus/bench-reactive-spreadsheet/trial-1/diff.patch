+// ─── Cell Reference Utilities ───────────────────────────────────────────────
+
+function columnToNumber(col: string): number {
+  let n = 0;
+  for (let i = 0; i < col.length; i++) {
+    n = n * 26 + (col.charCodeAt(i) - 64);
+  }
+  return n;
+}
+
+function numberToColumn(n: number): string {
+  let s = '';
+  while (n > 0) {
+    n--;
+    s = String.fromCharCode(65 + (n % 26)) + s;
+    n = Math.floor(n / 26);
+  }
+  return s;
+}
+
+function parseRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: columnToNumber(match[1]), row: parseInt(match[2], 10) };
+}
+
+function formatRef(col: number, row: number): string {
+  return numberToColumn(col) + row;
+}
+
+function expandRange(start: string, end: string): string[] {
+  const s = parseRef(start);
+  const e = parseRef(end);
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+  const cells: string[] = [];
+  for (let r = minRow; r <= maxRow; r++) {
+    for (let c = minCol; c <= maxCol; c++) {
+      cells.push(formatRef(c, r));
+    }
+  }
+  return cells;
+}
+
+// ─── Tokenizer ──────────────────────────────────────────────────────────────
+
+type TokenType =
+  | 'NUMBER'
+  | 'STRING'
+  | 'BOOLEAN'
+  | 'CELL'
+  | 'RANGE'
+  | 'FUNC'
+  | 'OP'
+  | 'COMP'
+  | 'LPAREN'
+  | 'RPAREN'
+  | 'COMMA';
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+function tokenize(formula: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < formula.length) {
+    const ch = formula[i];
+
+    if (ch === ' ') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (ch === '"') {
+      let str = '';
+      i++;
+      while (i < formula.length && formula[i] !== '"') {
+        str += formula[i];
+        i++;
+      }
+      i++; // closing quote
+      tokens.push({ type: 'STRING', value: str });
+      continue;
+    }
+
+    // Comparison operators (must check before single-char ops)
+    if (ch === '<' && formula[i + 1] === '>') {
+      tokens.push({ type: 'COMP', value: '<>' });
+      i += 2;
+      continue;
+    }
+    if (ch === '>' && formula[i + 1] === '=') {
+      tokens.push({ type: 'COMP', value: '>=' });
+      i += 2;
+      continue;
+    }
+    if (ch === '<' && formula[i + 1] === '=') {
+      tokens.push({ type: 'COMP', value: '<=' });
+      i += 2;
+      continue;
+    }
+    if (ch === '>' || ch === '<') {
+      tokens.push({ type: 'COMP', value: ch });
+      i++;
+      continue;
+    }
+
+    // Arithmetic operators & equality
+    if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {
+      tokens.push({ type: 'OP', value: ch });
+      i++;
+      continue;
+    }
+
+    if (ch === '(') {
+      tokens.push({ type: 'LPAREN', value: '(' });
+      i++;
+      continue;
+    }
+
+    if (ch === ')') {
+      tokens.push({ type: 'RPAREN', value: ')' });
+      i++;
+      continue;
+    }
+
+    if (ch === ',') {
+      tokens.push({ type: 'COMMA', value: ',' });
+      i++;
+      continue;
+    }
+
+    // Number
+    if (ch >= '0' && ch <= '9') {
+      let num = '';
+      while (i < formula.length && ((formula[i] >= '0' && formula[i] <= '9') || formula[i] === '.')) {
+        num += formula[i];
+        i++;
+      }
+      tokens.push({ type: 'NUMBER', value: num });
+      continue;
+    }
+
+    // Identifier: cell ref, range, function name, or boolean
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+      let ident = '';
+      while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+        ident += formula[i];
+        i++;
+      }
+
+      const upper = ident.toUpperCase();
+
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: 'BOOLEAN', value: upper });
+        continue;
+      }
+
+      // Check if it's a function (next non-space char is '(')
+      let peek = i;
+      while (peek < formula.length && formula[peek] === ' ') peek++;
+      if (peek < formula.length && formula[peek] === '(') {
+        tokens.push({ type: 'FUNC', value: upper });
+        continue;
+      }
+
+      // Check for range (CELL:CELL)
+      if (i < formula.length && formula[i] === ':') {
+        const colonPos = i;
+        i++; // skip ':'
+        let ident2 = '';
+        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+          ident2 += formula[i];
+          i++;
+        }
+        if (ident2.length > 0) {
+          tokens.push({ type: 'RANGE', value: upper + ':' + ident2.toUpperCase() });
+        } else {
+          // Not a range, backtrack
+          i = colonPos;
+          tokens.push({ type: 'CELL', value: upper });
+        }
+        continue;
+      }
+
+      tokens.push({ type: 'CELL', value: upper });
+      continue;
+    }
+
+    // '=' as comparison (in formula context, after the leading '=' is stripped)
+    if (ch === '=') {
+      tokens.push({ type: 'COMP', value: '=' });
+      i++;
+      continue;
+    }
+
+    throw new Error(`Unexpected character in formula: ${ch}`);
+  }
+
+  return tokens;
+}
+
+// ─── AST ────────────────────────────────────────────────────────────────────
+
+type ASTNode =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'cell'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'binop'; op: string; left: ASTNode; right: ASTNode }
+  | { type: 'unary'; op: string; operand: ASTNode }
+  | { type: 'func'; name: string; args: ASTNode[] };
+
+// ─── Parser (recursive descent) ────────────────────────────────────────────
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token | undefined {
+    return this.tokens[this.pos];
+  }
+
+  private consume(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  private expect(type: TokenType): Token {
+    const t = this.consume();
+    if (!t || t.type !== type) {
+      throw new Error(`Expected ${type} but got ${t?.type ?? 'EOF'}`);
+    }
+    return t;
+  }
+
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    if (this.pos < this.tokens.length) {
+      throw new Error(`Unexpected token: ${this.tokens[this.pos].value}`);
+    }
+    return node;
+  }
+
+  private parseComparison(): ASTNode {
+    let left = this.parseAddSub();
+    while (this.peek()?.type === 'COMP') {
+      const op = this.consume().value;
+      const right = this.parseAddSub();
+      left = { type: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  private parseAddSub(): ASTNode {
+    let left = this.parseMulDiv();
+    while (this.peek()?.type === 'OP' && (this.peek()!.value === '+' || this.peek()!.value === '-')) {
+      const op = this.consume().value;
+      const right = this.parseMulDiv();
+      left = { type: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  private parseMulDiv(): ASTNode {
+    let left = this.parseUnary();
+    while (this.peek()?.type === 'OP' && (this.peek()!.value === '*' || this.peek()!.value === '/')) {
+      const op = this.consume().value;
+      const right = this.parseUnary();
+      left = { type: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    if (this.peek()?.type === 'OP' && (this.peek()!.value === '-' || this.peek()!.value === '+')) {
+      const op = this.consume().value;
+      const operand = this.parseUnary();
+      return { type: 'unary', op, operand };
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const t = this.peek();
+    if (!t) throw new Error('Unexpected end of formula');
+
+    if (t.type === 'NUMBER') {
+      this.consume();
+      return { type: 'number', value: parseFloat(t.value) };
+    }
+
+    if (t.type === 'STRING') {
+      this.consume();
+      return { type: 'string', value: t.value };
+    }
+
+    if (t.type === 'BOOLEAN') {
+      this.consume();
+      return { type: 'boolean', value: t.value === 'TRUE' };
+    }
+
+    if (t.type === 'CELL') {
+      this.consume();
+      return { type: 'cell', ref: t.value };
+    }
+
+    if (t.type === 'RANGE') {
+      this.consume();
+      const [start, end] = t.value.split(':');
+      return { type: 'range', start, end };
+    }
+
+    if (t.type === 'FUNC') {
+      const name = this.consume().value;
+      this.expect('LPAREN');
+      const args: ASTNode[] = [];
+      if (this.peek()?.type !== 'RPAREN') {
+        args.push(this.parseComparison());
+        while (this.peek()?.type === 'COMMA') {
+          this.consume();
+          args.push(this.parseComparison());
+        }
+      }
+      this.expect('RPAREN');
+      return { type: 'func', name, args };
+    }
+
+    if (t.type === 'LPAREN') {
+      this.consume();
+      const node = this.parseComparison();
+      this.expect('RPAREN');
+      return node;
+    }
+
+    throw new Error(`Unexpected token: ${t.value}`);
+  }
+}
+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  return new Parser(tokens).parse();
+}
+
+// ─── Dependency extraction ──────────────────────────────────────────────────
+
+function extractDeps(node: ASTNode): Set<string> {
+  const deps = new Set<string>();
+  const visit = (n: ASTNode) => {
+    switch (n.type) {
+      case 'cell':
+        deps.add(n.ref);
+        break;
+      case 'range':
+        for (const cell of expandRange(n.start, n.end)) {
+          deps.add(cell);
+        }
+        break;
+      case 'binop':
+        visit(n.left);
+        visit(n.right);
+        break;
+      case 'unary':
+        visit(n.operand);
+        break;
+      case 'func':
+        for (const arg of n.args) {
+          visit(arg);
+        }
+        break;
+    }
+  };
+  visit(node);
+  return deps;
+}
+
+// ─── Cell storage ───────────────────────────────────────────────────────────
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  value: string | number | boolean | null;
+  deps: Set<string>;
+}
+
+// ─── Spreadsheet ────────────────────────────────────────────────────────────
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // reverse dependency map: cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+    let formula: ASTNode | null = null;
+    let deps = new Set<string>();
+    let computedValue: string | number | boolean | null = null;
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaStr = value.slice(1);
+      formula = parseFormula(formulaStr);
+      deps = extractDeps(formula);
+    }
+
+    // Check for circular references before committing
+    if (deps.size > 0) {
+      this.checkCircular(ref, deps);
+    }
+
+    // Remove old reverse dependencies
+    const existing = this.cells.get(ref);
+    if (existing) {
+      for (const dep of existing.deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    // Store the cell
+    const cellData: CellData = { raw: value, formula, value: null, deps };
+    this.cells.set(ref, cellData);
+
+    // Add new reverse dependencies
+    for (const dep of deps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    // Evaluate this cell
+    if (formula) {
+      cellData.value = this.evaluate(formula);
+    } else {
+      computedValue = value as string | number | boolean;
+      cellData.value = computedValue;
+    }
+
+    // Propagate to dependents (topological order)
+    this.propagate(ref);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    const ref = cell.toUpperCase();
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.value;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, string | number | boolean | null> {
+    const result = new Map<string, string | number | boolean | null>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  private checkCircular(target: string, deps: Set<string>): void {
+    // BFS from deps through the dependency graph to see if we reach target
+    const visited = new Set<string>();
+    const queue = [...deps];
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      if (current === target) {
+        throw new Error(`Circular reference detected`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+      const cellData = this.cells.get(current);
+      if (cellData) {
+        for (const dep of cellData.deps) {
+          if (!visited.has(dep)) {
+            queue.push(dep);
+          }
+        }
+      }
+    }
+  }
+
+  private propagate(changedCell: string): void {
+    // BFS to collect dependents level by level (topological order)
+    const visited = new Set<string>();
+    const queue: string[] = [];
+
+    // Seed with direct dependents
+    const directDeps = this.dependents.get(changedCell);
+    if (directDeps) {
+      for (const dep of directDeps) {
+        if (!visited.has(dep)) {
+          visited.add(dep);
+          queue.push(dep);
+        }
+      }
+    }
+
+    let idx = 0;
+    while (idx < queue.length) {
+      const cell = queue[idx++];
+      const data = this.cells.get(cell);
+      if (data?.formula) {
+        data.value = this.evaluate(data.formula);
+      }
+      const nextDeps = this.dependents.get(cell);
+      if (nextDeps) {
+        for (const dep of nextDeps) {
+          if (!visited.has(dep)) {
+            visited.add(dep);
+            queue.push(dep);
+          }
+        }
+      }
+    }
+  }
+
+  private evaluate(node: ASTNode): string | number | boolean {
+    switch (node.type) {
+      case 'number':
+        return node.value;
+      case 'string':
+        return node.value;
+      case 'boolean':
+        return node.value;
+      case 'cell': {
+        const val = this.get(node.ref);
+        return val ?? 0;
+      }
+      case 'unary': {
+        const operand = this.evaluate(node.operand);
+        if (node.op === '-') return -(operand as number);
+        return operand as number;
+      }
+      case 'binop': {
+        const left = this.evaluate(node.left);
+        const right = this.evaluate(node.right);
+        switch (node.op) {
+          case '+': return (left as number) + (right as number);
+          case '-': return (left as number) - (right as number);
+          case '*': return (left as number) * (right as number);
+          case '/': return (left as number) / (right as number);
+          case '>': return (left as number) > (right as number);
+          case '<': return (left as number) < (right as number);
+          case '>=': return (left as number) >= (right as number);
+          case '<=': return (left as number) <= (right as number);
+          case '=': return left === right;
+          case '<>': return left !== right;
+          default: throw new Error(`Unknown operator: ${node.op}`);
+        }
+      }
+      case 'func':
+        return this.evaluateFunc(node.name, node.args);
+      case 'range':
+        throw new Error('Range cannot be evaluated as a standalone value');
+    }
+  }
+
+  private resolveValues(args: ASTNode[]): (string | number | boolean)[] {
+    const values: (string | number | boolean)[] = [];
+    for (const arg of args) {
+      if (arg.type === 'range') {
+        const cells = expandRange(arg.start, arg.end);
+        for (const ref of cells) {
+          const val = this.get(ref);
+          if (val !== null) {
+            values.push(val);
+          }
+        }
+      } else {
+        values.push(this.evaluate(arg));
+      }
+    }
+    return values;
+  }
+
+  private evaluateFunc(name: string, args: ASTNode[]): string | number | boolean {
+    switch (name) {
+      case 'SUM': {
+        const values = this.resolveValues(args);
+        let sum = 0;
+        for (const v of values) {
+          if (typeof v === 'number') sum += v;
+        }
+        return sum;
+      }
+      case 'AVERAGE': {
+        const values = this.resolveValues(args);
+        let sum = 0;
+        let count = 0;
+        for (const v of values) {
+          if (typeof v === 'number') { sum += v; count++; }
+        }
+        return count === 0 ? 0 : sum / count;
+      }
+      case 'MIN': {
+        const values = this.resolveValues(args);
+        const nums = values.filter((v): v is number => typeof v === 'number');
+        return nums.length === 0 ? 0 : Math.min(...nums);
+      }
+      case 'MAX': {
+        const values = this.resolveValues(args);
+        const nums = values.filter((v): v is number => typeof v === 'number');
+        return nums.length === 0 ? 0 : Math.max(...nums);
+      }
+      case 'COUNT': {
+        const values = this.resolveValues(args);
+        return values.filter(v => typeof v === 'number').length;
+      }
+      case 'IF': {
+        if (args.length < 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evaluate(args[0]);
+        return condition ? this.evaluate(args[1]) : this.evaluate(args[2]);
+      }
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+}
