valuate greater than or equal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 10);\n      sheet.set('B1', '=A1>=A2');\n      expect(sheet.get('B1')).toBe(true);\n    });\n\n    it('should evaluate less than or equal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('A2', 10);\n      sheet.set('B1', '=A1<=A2');\n      expect(sheet.get('B1')).toBe(true);\n    });\n  });\n\n  describe('SUM function', () => {\n    it('should sum a column range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('A4', 4);\n      sheet.set('A5', 5);\n      sheet.set('B1', '=SUM(A1:A5)');\n      expect(sheet.get('B1')).toBe(15);\n    });\n\n    it('should sum a row range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', 20);\n      sheet.set('C1', 30);\n      sheet.set('D1', '=SUM(A1:C1)');\n      expect(sheet.get('D1')).toBe(60);\n    });\n\n    it('should sum a block range', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('B1', 3);\n      sheet.set('B2', 4);\n      sheet.set('C1', '=SUM(A1:B2)');\n      expect(sheet.get('C1')).toBe(10);\n    });\n\n    it('should skip non-numeric values', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 'hello');\n      sheet.set('A3', 20);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(30);\n    });\n  });\n\n  describe('AVERAGE function', () => {\n    it('should compute average', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=AVERAGE(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n  });\n\n  describe('MIN function', () => {\n    it('should find minimum', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 5);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MIN(A1:A3)');\n      expect(sheet.get('B1')).toBe(5);\n    });\n  });\n\n  describe('MAX function', () => {\n    it('should find maximum', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 5);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MAX(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n  });\n\n  describe('COUNT function', () => {\n    it('should count numeric values', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 'hello');\n      sheet.set('A3', 20);\n      sheet.set('A4', true);\n      sheet.set('B1', '=COUNT(A1:A4)');\n      expect(sheet.get('B1')).toBe(2);\n    });\n  });\n\n  describe('IF function', () => {\n    it('should return true value when condition is true', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 50);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('big');\n    });\n\n    it('should return false value when condition is false', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('small');\n    });\n\n    it('should work with numeric results', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=IF(A1>3, A1*2, 0)');\n      expect(sheet.get('B1')).toBe(10);\n    });\n  });\n\n  describe('reactive updates', () => {\n    it('should update direct dependents', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n    });\n\n    it('should update transitive dependents', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=A1+1');\n      sheet.set('C1', '=B1*2');\n      expect(sheet.get('C1')).toBe(12);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe(11);\n      expect(sheet.get('C1')).toBe(22);\n    });\n\n    it('should update SUM when a cell in the range changes', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(6);\n\n      sheet.set('A2', 10);\n      expect(sheet.get('B1')).toBe(14);\n    });\n\n    it('should handle multiple dependents of the same cell', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1*2');\n      sheet.set('C1', '=A1+5');\n      expect(sheet.get('B1')).toBe(20);\n      expect(sheet.get('C1')).toBe(15);\n\n      sheet.set('A1', 20);\n      expect(sheet.get('B1')).toBe(40);\n      expect(sheet.get('C1')).toBe(25);\n    });\n\n    it('should handle diamond dependencies correctly', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('B1', '=A1+1');\n      sheet.set('C1', '=A1+2');\n      sheet.set('D1', '=B1+C1');\n      expect(sheet.get('D1')).toBe(5); // (1+1) + (1+2) = 5\n\n      sheet.set('A1', 10);\n      expect(sheet.get('D1')).toBe(23); // (10+1) + (10+2) = 23\n    });\n\n    it('should update IF formula reactively', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 50);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('big');\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe('small');\n    });\n\n    it('should handle overwriting a formula with a value', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1*2');\n      expect(sheet.get('B1')).toBe(20);\n\n      sheet.set('B1', 99);\n      expect(sheet.get('B1')).toBe(99);\n\n      // Changing A1 should no longer affect B1\n      sheet.set('A1', 100);\n      expect(sheet.get('B1')).toBe(99);\n    });\n  });\n\n  describe('circular reference detection', () => {\n    it('should detect direct circular reference', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1');\n      expect(() => sheet.set('B1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should detect self-reference', () => {\n      const sheet = new Spreadsheet();\n      expect(() => sheet.set('A1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should detect indirect circular reference', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1');\n      sheet.set('B1', '=C1');\n      expect(() => sheet.set('C1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should allow non-circular dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1');\n      sheet.set('C1', '=B1');\n      expect(sheet.get('C1')).toBe(10);\n    });\n  });\n\n  describe('multi-column cell references', () => {\n    it('should handle AA column', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('AA1', 100);\n      expect(sheet.get('AA1')).toBe(100);\n    });\n\n    it('should handle formulas referencing multi-letter columns', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('AA1', 10);\n      sheet.set('AB1', 20);\n      sheet.set('AC1', '=AA1+AB1');\n      expect(sheet.get('AC1')).toBe(30);\n    });\n  });\n\n  describe('example from spec', () => {\n    it('should match the example usage', () => {\n      const sheet = new Spreadsheet();\n\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n      expect(sheet.getDisplay('A3')).toBe('30');\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3'