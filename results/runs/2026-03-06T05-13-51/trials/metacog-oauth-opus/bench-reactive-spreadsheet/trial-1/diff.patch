+import { describe, it, expect } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+describe('Spreadsheet', () => {
+  describe('basic values', () => {
+    it('should store and retrieve numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should store and retrieve strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should store and retrieve booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.get('A1')).toBeNull();
+    });
+
+    it('should handle case-insensitive cell references', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('a1', 10);
+      expect(sheet.get('A1')).toBe(10);
+      expect(sheet.get('a1')).toBe(10);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('should display numbers as strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should display strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should display booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should display empty string for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('should display computed formula result', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('getCells', () => {
+    it('should return all non-empty cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(2);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+    });
+  });
+
+  describe('simple formulas', () => {
+    it('should evaluate addition', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate subtraction', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 30);
+      sheet.set('A2', 10);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(20);
+    });
+
+    it('should evaluate multiplication', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate division', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 100);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(25);
+    });
+
+    it('should respect operator precedence', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('B1', '=A1+A2*A3');
+      expect(sheet.get('B1')).toBe(14); // 2 + 3*4 = 14
+    });
+
+    it('should handle parentheses', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('B1', '=(A1+A2)*A3');
+      expect(sheet.get('B1')).toBe(20); // (2+3)*4 = 20
+    });
+
+    it('should handle numeric literals in formulas', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', '=A1+5');
+      expect(sheet.get('B1')).toBe(15);
+    });
+
+    it('should handle unary minus', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', '=-A1');
+      expect(sheet.get('B1')).toBe(-10);
+    });
+
+    it('should treat empty cell references as 0 in arithmetic', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=B1+5');
+      expect(sheet.get('A1')).toBe(5);
+    });
+  });
+
+  describe('comparison operators', () => {
+    it('should evaluate greater than', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('B1', '=A1>A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate less than', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 3);
+      sheet.set('A2', 5);
+      sheet.set('B1', '=A1<A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate equality', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 10);
+      sheet.set('B1', '=A1=A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate not equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('B1', '=A1<>A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate greater than or equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 10);
+      sheet.set('B1', '=A1>=A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+
+    it('should evaluate less than or equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 10);
+      sheet.set('B1', '=A1<=A2');
+      expect(sheet.get('B1')).toBe(true);
+    });
+  });
+
+  describe('SUM function', () => {
+    it('should sum a column range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('A3', 3);
+      sheet.set('A4', 4);
+      sheet.set('A5', 5);
+      sheet.set('B1', '=SUM(A1:A5)');
+      expect(sheet.get('B1')).toBe(15);
+    });
+
+    it('should sum a row range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', 30);
+      sheet.set('D1', '=SUM(A1:C1)');
+      expect(sheet.get('D1')).toBe(60);
+    });
+
+    it('should sum a block range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('A2', 2);
+      sheet.set('B1', 3);
+      sheet.set('B2', 4);
+      sheet.set('C1', '=SUM(A1:B2)');
+      expect(sheet.get('C1')).toBe(10);
+    });
+
+    it('should skip non-numeric values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 'hello');
+      sheet.set('A3', 20);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(30);
+    });
+  });
+
+  describe('AVERAGE function', () => {
+    it('should compute average', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=AVERAGE(A1:A3)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+  });
+
+  describe('MIN function', () => {
+    it('should find minimum', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('A3', 20);
+      sheet.set('B1', '=MIN(A1:A3)');
+      expect(sheet.get('B1')).toBe(5);
+    });
+  });
+
+  describe('MAX function', () => {
+    it('should find maximum', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('A3', 20);
+      sheet.set('B1', '=MAX(A1:A3)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+  });
+
+  describe('COUNT function', () => {
+    it('should count numeric values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 'hello');
+      sheet.set('A3', 20);
+      sheet.set('A4', true);
+      sheet.set('B1', '=COUNT(A1:A4)');
+      expect(sheet.get('B1')).toBe(2);
+    });
+  });
+
+  describe('IF function', () => {
+    it('should return true value when condition is true', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 50);
+      sheet.set('B1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('B1')).toBe('big');
+    });
+
+    it('should return false value when condition is false', () => {
+      const sheet = new Spreadsheet();
