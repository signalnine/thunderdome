+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    const clients: {
+      ws: WebSocket;
+      sync: Record<string, unknown>;
+    }[] = [];
+    for (let i = 0; i < 10; i++) {
+      clients.push(await connectWs(baseUrl, doc.id as string));
+    }
+
+    let version = clients[0].sync.version as number;
+
+    // First 5 clients send operations
+    for (let i = 0; i < 5; i++) {
+      const ack = await sendOp(
+        clients[i].ws,
+        {
+          type: "insert",
+          position: 5 + i,
+          text: String(i),
+        },
+        version
+      );
+      version = ack.version as number;
+    }
+
+    // Disconnect last 5 clients
+    for (let i = 5; i < 10; i++) {
+      clients[i].ws.close();
+    }
+
+    await new Promise((r) => setTimeout(r, 200));
+
+    // Document should be intact
+    const getRes = await request(baseUrl, "GET", `/documents/${doc.id}`);
+    const content = (getRes.body as Record<string, unknown>).content as string;
+    expect(content).toContain("Start");
+    expect(content.length).toBe(10); // "Start" + 5 digits
+
+    for (let i = 0; i < 5; i++) {
+      clients[i].ws.close();
+    }
+  });
+});
+
+// ============================================================
+// Error Handling Tests
+// ============================================================
+describe("Error Handling", () => {
+  let app: AppInstance;
+  let baseUrl: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    const port = await app.start(0);
+    baseUrl = `http://localhost:${port}`;
+  });
+
+  afterEach(async () => {
+    await app.stop();
+  });
+
+  it("should reject invalid JSON over WebSocket", async () => {
+    const createRes = await request(baseUrl, "POST", "/documents", {
+      title: "Bad JSON",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    const { ws } = await connectWs(baseUrl, doc.id as string);
+    const errorPromise = waitForMessage(ws, "error");
+    ws.send("not json at all");
+    const error = await errorPromise;
+    expect(error.type).toBe("error");
+    ws.close();
+  });
+
+  it("should reject unknown message type", async () => {
+    const createRes = await request(baseUrl, "POST", "/documents", {
+      title: "Unknown Type",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    const { ws } = await connectWs(baseUrl, doc.id as string);
+    const errorPromise = waitForMessage(ws, "error");
+    ws.send(JSON.stringify({ type: "unknown_type" }));
+    const error = await errorPromise;
+    expect(error.type).toBe("error");
+    ws.close();
+  });
+
+  it("should reject operation with missing fields", async () => {
+    const createRes = await request(baseUrl, "POST", "/documents", {
+      title: "Missing Fields",
+      content: "Test",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    const { ws, sync } = await connectWs(baseUrl, doc.id as string);
+    const errorPromise = waitForMessage(ws, "error");
+    ws.send(
+      JSON.stringify({
+        type: "operation",
+        operation: { type: "insert" },
+        version: sync.version,
+      })
+    );
+    const error = await errorPromise;
+    expect(error.type).toBe("error");
+    ws.close();
+  });
+
+  it("should return 400 for creating document without title", async () => {
+    const res = await request(baseUrl, "POST", "/documents", {});
+    expect(res.status).toBe(400);
+  });
+
+  it("should reject delete operation out of bounds", async () => {
+    const createRes = await request(baseUrl, "POST", "/documents", {
+      title: "OOB Delete",
+      content: "Hi",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    const { ws, sync } = await connectWs(baseUrl, doc.id as string);
+    const errorPromise = waitForMessage(ws, "error");
+    ws.send(
+      JSON.stringify({
+        type: "operation",
+        operation: { type: "delete", position: 0, count: 100 },
+        version: sync.version,
+      })
+    );
+    const error = await errorPromise;
+    expect(error.type).toBe("error");
+    ws.close();
+  });
+});
+
+// ============================================================
+// Persistence Tests
+// ============================================================
+describe("Persistence", () => {
+  let tmpDir: string;
+  let dbPath: string;
+
+  beforeAll(() => {
+    tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), "collab-test-"));
+    dbPath = path.join(tmpDir, "test.db");
+  });
+
+  afterAll(() => {
+    try {
+      fs.rmSync(tmpDir, { recursive: true });
+    } catch {
+      // ignore
+    }
+  });
+
+  it("should persist documents across server restarts", async () => {
+    // Create document on first server instance
+    const app1 = createApp(dbPath);
+    const port1 = await app1.start(0);
+    const baseUrl1 = `http://localhost:${port1}`;
+
+    const createRes = await request(baseUrl1, "POST", "/documents", {
+      title: "Persistent Doc",
+      content: "Persisted content",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+    await app1.stop();
+
+    // Read document on second server instance
+    const app2 = createApp(dbPath);
+    const port2 = await app2.start(0);
+    const baseUrl2 = `http://localhost:${port2}`;
+
+    const getRes = await request(baseUrl2, "GET", `/documents/${doc.id}`);
+    expect(getRes.status).toBe(200);
+    expect((getRes.body as Record<string, unknown>).title).toBe(
+      "Persistent Doc"
+    );
+    expect((getRes.body as Record<string, unknown>).content).toBe(
+      "Persisted content"
+    );
+    await app2.stop();
+  });
+
+  it("should persist WebSocket edits across restarts", async () => {
+    const dbPath2 = path.join(tmpDir, "test2.db");
+
+    const app1 = createApp(dbPath2);
+    const port1 = await app1.start(0);
+    const baseUrl1 = `http://localhost:${port1}`;
+
+    const createRes = await request(baseUrl1, "POST", "/documents", {
+      title: "WS Persist",
+      content: "Hello",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    const { ws, sync } = await connectWs(baseUrl1, doc.id as string);
+    await sendOp(
+      ws,
+      { type: "insert", position: 5, text: " World" },
+      sync.version as number
+    );
+    ws.close();
+    await new Promise((r) => setTimeout(r, 100));
+    await app1.stop();
+
+    const app2 = createApp(dbPath2);
+    const port2 = await app2.start(0);
+    const baseUrl2 = `http://localhost:${port2}`;
+
+    const getRes = await request(baseUrl2, "GET", `/documents/${doc.id}`);
+    expect((getRes.body as Record<string, unknown>).content).toBe(
+      "Hello World"
+    );
+    await app2.stop();
+  });
+
+  it("should persist version history across restarts", async () => {
+    const dbPath3 = path.join(tmpDir, "test3.db");
+
+    const app1 = createApp(dbPath3);
+    const port1 = await app1.start(0);
+    const baseUrl1 = `http://localhost:${port1}`;
+
+    const createRes = await request(baseUrl1, "POST", "/documents", {
+      title: "Version Persist",
+      content: "V1",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    await request(baseUrl1, "PUT", `/documents/${doc.id}`, {
+      content: "V2",
+    });
+    await app1.stop();
+
+    const app2 = createApp(dbPath3);
+    const port2 = await app2.start(0);
+    const baseUrl2 = `http://localhost:${port2}`;
+
+    const versionsRes = await request(
+      baseUrl2,
+      "GET",
+      `/documents/${doc.id}/versions`
+    );
+    const versions = versionsRes.body as unknown[];
+    expect(versions.length).toBe(2);
+    await app2.stop();
+  });
+});
