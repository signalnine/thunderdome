+import { describe, it, expect, beforeEach, afterEach, beforeAll, afterAll } from "vitest";
+import { createApp } from "../server.js";
+import type { AppInstance } from "../server.js";
+import WebSocket from "ws";
+import fs from "node:fs";
+import path from "node:path";
+import os from "node:os";
+
+// Helper to make HTTP requests
+async function request(
+  baseUrl: string,
+  method: string,
+  path: string,
+  body?: unknown
+): Promise<{ status: number; body: unknown }> {
+  const res = await fetch(`${baseUrl}${path}`, {
+    method,
+    headers: body ? { "Content-Type": "application/json" } : {},
+    body: body ? JSON.stringify(body) : undefined,
+  });
+  const status = res.status;
+  let responseBody: unknown;
+  const text = await res.text();
+  try {
+    responseBody = JSON.parse(text);
+  } catch {
+    responseBody = text;
+  }
+  return { status, body: responseBody };
+}
+
+// Helper to connect a WebSocket client and wait for sync
+function connectWs(
+  baseUrl: string,
+  docId: string
+): Promise<{ ws: WebSocket; sync: Record<string, unknown>; clientId: string }> {
+  return new Promise((resolve, reject) => {
+    const wsUrl = baseUrl.replace("http://", "ws://");
+    const ws = new WebSocket(`${wsUrl}/ws/${docId}`);
+    ws.on("message", (data) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === "sync") {
+        resolve({ ws, sync: msg, clientId: msg.clientId });
+      } else if (msg.type === "error") {
+        reject(new Error(msg.message));
+      }
+    });
+    ws.on("error", reject);
+  });
+}
+
+// Helper to wait for a specific message type
+function waitForMessage(
+  ws: WebSocket,
+  type: string,
+  timeout: number = 5000
+): Promise<Record<string, unknown>> {
+  return new Promise((resolve, reject) => {
+    const timer = setTimeout(
+      () => reject(new Error(`Timeout waiting for ${type} message`)),
+      timeout
+    );
+    const handler = (data: WebSocket.Data) => {
+      const msg = JSON.parse(data.toString());
+      if (msg.type === type) {
+        clearTimeout(timer);
+        ws.off("message", handler);
+        resolve(msg);
+      }
+    };
+    ws.on("message", handler);
+  });
+}
+
+// Helper to send an operation and wait for ack
+function sendOp(
+  ws: WebSocket,
+  operation: Record<string, unknown>,
+  version: number
+): Promise<Record<string, unknown>> {
+  const ackPromise = waitForMessage(ws, "ack");
+  ws.send(JSON.stringify({ type: "operation", operation, version }));
+  return ackPromise;
+}
+
+// ============================================================
+// REST CRUD Tests
+// ============================================================
+describe("REST CRUD", () => {
+  let app: AppInstance;
+  let baseUrl: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    const port = await app.start(0);
+    baseUrl = `http://localhost:${port}`;
+  });
+
+  afterEach(async () => {
+    await app.stop();
+  });
+
+  it("should create a document", async () => {
+    const res = await request(baseUrl, "POST", "/documents", {
+      title: "Test Doc",
+      content: "Hello",
+    });
+    expect(res.status).toBe(201);
+    const doc = res.body as Record<string, unknown>;
+    expect(doc.title).toBe("Test Doc");
+    expect(doc.content).toBe("Hello");
+    expect(doc.id).toBeDefined();
+  });
+
+  it("should create a document with empty content", async () => {
+    const res = await request(baseUrl, "POST", "/documents", {
+      title: "Empty Doc",
+    });
+    expect(res.status).toBe(201);
+    const doc = res.body as Record<string, unknown>;
+    expect(doc.content).toBe("");
+  });
+
+  it("should get a document by id", async () => {
+    const createRes = await request(baseUrl, "POST", "/documents", {
+      title: "Get Test",
+      content: "Content",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    const getRes = await request(baseUrl, "GET", `/documents/${doc.id}`);
+    expect(getRes.status).toBe(200);
+    expect((getRes.body as Record<string, unknown>).title).toBe("Get Test");
+  });
+
+  it("should return 404 for non-existent document", async () => {
+    const res = await request(baseUrl, "GET", "/documents/nonexistent");
+    expect(res.status).toBe(404);
+  });
+
+  it("should list documents", async () => {
+    await request(baseUrl, "POST", "/documents", { title: "Doc 1" });
+    await request(baseUrl, "POST", "/documents", { title: "Doc 2" });
+
+    const res = await request(baseUrl, "GET", "/documents");
+    expect(res.status).toBe(200);
+    const docs = res.body as unknown[];
+    expect(docs.length).toBe(2);
+  });
+
+  it("should update a document", async () => {
+    const createRes = await request(baseUrl, "POST", "/documents", {
+      title: "Original",
+      content: "Old",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    const updateRes = await request(baseUrl, "PUT", `/documents/${doc.id}`, {
+      title: "Updated",
+      content: "New",
+    });
+    expect(updateRes.status).toBe(200);
+    const updated = updateRes.body as Record<string, unknown>;
+    expect(updated.title).toBe("Updated");
+    expect(updated.content).toBe("New");
+  });
+
+  it("should partially update a document with PATCH", async () => {
+    const createRes = await request(baseUrl, "POST", "/documents", {
+      title: "Original",
+      content: "Content",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    const patchRes = await request(
+      baseUrl,
+      "PATCH",
+      `/documents/${doc.id}`,
+      { title: "Patched" }
+    );
+    expect(patchRes.status).toBe(200);
+    const patched = patchRes.body as Record<string, unknown>;
+    expect(patched.title).toBe("Patched");
+    expect(patched.content).toBe("Content");
+  });
+
+  it("should delete a document", async () => {
+    const createRes = await request(baseUrl, "POST", "/documents", {
+      title: "Delete Me",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    const deleteRes = await request(
+      baseUrl,
+      "DELETE",
+      `/documents/${doc.id}`
+    );
+    expect(deleteRes.status).toBe(204);
+
+    const getRes = await request(baseUrl, "GET", `/documents/${doc.id}`);
+    expect(getRes.status).toBe(404);
+  });
+
+  it("should return 404 when deleting non-existent document", async () => {
+    const res = await request(baseUrl, "DELETE", "/documents/nonexistent");
+    expect(res.status).toBe(404);
+  });
+
+  it("should get version history", async () => {
+    const createRes = await request(baseUrl, "POST", "/documents", {
+      title: "Versioned",
+      content: "V1",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    await request(baseUrl, "PUT", `/documents/${doc.id}`, {
+      title: "Versioned",
+      content: "V2",
+    });
+
+    const versionsRes = await request(
+      baseUrl,
+      "GET",
+      `/documents/${doc.id}/versions`
+    );
+    expect(versionsRes.status).toBe(200);
+    const versions = versionsRes.body as unknown[];
+    expect(versions.length).toBe(2);
+  });
+});
+
+// ============================================================
+// WebSocket Lifecycle Tests
+// ============================================================
+describe("WebSocket Lifecycle", () => {
+  let app: AppInstance;
+  let baseUrl: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    const port = await app.start(0);
+    baseUrl = `http://localhost:${port}`;
+  });
+
+  afterEach(async () => {
+    await app.stop();
+  });
+
+  it("should receive sync message on connect", async () => {
+    const createRes = await request(baseUrl, "POST", "/documents", {
+      title: "WS Test",
+      content: "Hello WS",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    const { ws, sync } = await connectWs(baseUrl, doc.id as string);
+    expect(sync.type).toBe("sync");
+    expect(sync.content).toBe("Hello WS");
+    expect(sync.version).toBeDefined();
+    ws.close();
+  });
+
+  it("should assign a clientId on connect", async () => {
+    const createRes = await request(baseUrl, "POST", "/documents", {
+      title: "Client ID Test",
+    });
+    const doc = createRes.body as Record<string, unknown>;
+
+    const { ws, clientId } = await connectWs(baseUrl, doc.id as string);
+    expect(clientId).toBeDefined();
+    expect(typeof clientId).toBe("string");
+    ws.close();
+  });
+
+  it("should error on invalid document id", async () => {
+    const wsUrl = baseUrl.replace("http://", "ws://");
+    const ws = new WebSocket(`${wsUrl}/ws/nonexistent-doc`);
+
+    const msg = await new Promise<Record<string, unknown>>(
+      (resolve, reject) => {
+        ws.on("message", (data) => {
+          resolve(JSON.parse(data.toString()));
+        });
+        ws.on("error", reject);
+        setTimeout(() => reject(new Error("Timeout")), 5000);
