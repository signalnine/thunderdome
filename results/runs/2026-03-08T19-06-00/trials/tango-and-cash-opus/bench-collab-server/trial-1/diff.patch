@@ -0,0 +1,344 @@
+import { WebSocketServer, WebSocket } from "ws";
+import type { Server as HttpServer } from "node:http";
+import type { Database as DatabaseType } from "better-sqlite3";
+import crypto from "node:crypto";
+import {
+  getDocument,
+  updateDocumentContent,
+  createVersion,
+} from "./db.js";
+import {
+  applyOperation,
+  transformOpAgainstOps,
+  validateOperation,
+} from "./ot.js";
+import type { Operation } from "./ot.js";
+
+interface VersionedOp {
+  version: number;
+  operation: Operation;
+  clientId: string;
+}
+
+interface DocumentState {
+  version: number;
+  content: string;
+  history: VersionedOp[]; // All ops applied, indexed by version
+  clients: Map<string, WebSocket>;
+}
+
+export class CollaborationManager {
+  private documents: Map<string, DocumentState> = new Map();
+  private wss: WebSocketServer;
+  private db: DatabaseType;
+
+  constructor(server: HttpServer, db: DatabaseType) {
+    this.db = db;
+    this.wss = new WebSocketServer({ server });
+
+    this.wss.on("connection", (ws, req) => {
+      const url = req.url || "";
+      // Extract document ID from /ws/:docId
+      const match = url.match(/^\/ws\/([^/?]+)/);
+      if (!match) {
+        ws.send(JSON.stringify({ type: "error", message: "Invalid URL. Use /ws/:docId" }));
+        ws.close(1008, "Invalid URL");
+        return;
+      }
+
+      const docId = decodeURIComponent(match[1]);
+      this.handleConnection(ws, docId);
+    });
+  }
+
+  private getOrLoadDocument(docId: string): DocumentState | null {
+    let state = this.documents.get(docId);
+    if (state) return state;
+
+    const doc = getDocument(this.db, docId);
+    if (!doc) return null;
+
+    // Determine current version from DB
+    const maxVerStmt = this.db.prepare(
+      `SELECT COALESCE(MAX(version), 0) as maxVer FROM versions WHERE document_id = ?`
+    );
+    const row = maxVerStmt.get(docId) as { maxVer: number };
+
+    state = {
+      version: row.maxVer,
+      content: doc.content,
+      history: [],
+      clients: new Map(),
+    };
+    this.documents.set(docId, state);
+    return state;
+  }
+
+  private handleConnection(ws: WebSocket, docId: string): void {
+    const state = this.getOrLoadDocument(docId);
+    if (!state) {
+      ws.send(
+        JSON.stringify({ type: "error", message: "Document not found" })
+      );
+      ws.close(1008, "Document not found");
+      return;
+    }
+
+    const clientId = crypto.randomUUID();
+    state.clients.set(clientId, ws);
+
+    // Send sync message with current state
+    ws.send(
+      JSON.stringify({
+        type: "sync",
+        content: state.content,
+        version: state.version,
+        clientId,
+      })
+    );
+
+    ws.on("message", (data) => {
+      try {
+        const msg = JSON.parse(data.toString());
+        this.handleMessage(ws, docId, clientId, msg);
+      } catch {
+        ws.send(
+          JSON.stringify({ type: "error", message: "Invalid JSON" })
+        );
+      }
+    });
+
+    ws.on("close", () => {
+      const docState = this.documents.get(docId);
+      if (docState) {
+        docState.clients.delete(clientId);
+        // Clean up document state if no clients
+        if (docState.clients.size === 0) {
+          this.documents.delete(docId);
+        }
+      }
+    });
+
+    ws.on("error", () => {
+      const docState = this.documents.get(docId);
+      if (docState) {
+        docState.clients.delete(clientId);
+      }
+    });
+  }
+
+  private handleMessage(
+    ws: WebSocket,
+    docId: string,
+    clientId: string,
+    msg: Record<string, unknown>
+  ): void {
+    const state = this.documents.get(docId);
+    if (!state) {
+      ws.send(
+        JSON.stringify({ type: "error", message: "Document not found" })
+      );
+      return;
+    }
+
+    if (msg.type === "operation") {
+      this.handleOperation(ws, state, docId, clientId, msg);
+    } else {
+      ws.send(
+        JSON.stringify({
+          type: "error",
+          message: `Unknown message type: ${String(msg.type)}`,
+        })
+      );
+    }
+  }
+
+  private handleOperation(
+    ws: WebSocket,
+    state: DocumentState,
+    docId: string,
+    clientId: string,
+    msg: Record<string, unknown>
+  ): void {
+    const clientVersion =
+      typeof msg.version === "number" ? msg.version : -1;
+
+    if (clientVersion < 0 || clientVersion > state.version) {
+      ws.send(
+        JSON.stringify({
+          type: "error",
+          message: `Invalid version: ${clientVersion}. Current: ${state.version}`,
+        })
+      );
+      return;
+    }
+
+    // Validate the raw operation against current content
+    const rawOp = msg.operation;
+    if (!rawOp || typeof rawOp !== "object") {
+      ws.send(
+        JSON.stringify({ type: "error", message: "Missing operation" })
+      );
+      return;
+    }
+
+    // Get ops that happened since client's version
+    const concurrentOps = state.history
+      .filter((h) => h.version > clientVersion)
+      .map((h) => h.operation);
+
+    // Transform the incoming op against concurrent ops
+    let transformedOp: Operation;
+
+    // First validate the op structure loosely (before transform)
+    const opObj = rawOp as Record<string, unknown>;
+    if (opObj.type !== "insert" && opObj.type !== "delete") {
+      ws.send(
+        JSON.stringify({
+          type: "error",
+          message: `Unknown operation type: ${String(opObj.type)}`,
+        })
+      );
+      return;
+    }
+
+    // Build operation for transform
+    let incomingOp: Operation;
+    if (opObj.type === "insert") {
+      if (
+        typeof opObj.position !== "number" ||
+        !Number.isInteger(opObj.position)
+      ) {
+        ws.send(
+          JSON.stringify({
+            type: "error",
+            message: "Insert position must be an integer",
+          })
+        );
+        return;
+      }
+      if (typeof opObj.text !== "string" || opObj.text.length === 0) {
+        ws.send(
+          JSON.stringify({
+            type: "error",
+            message: "Insert text must be a non-empty string",
+          })
+        );
+        return;
+      }
+      incomingOp = {
+        type: "insert",
+        position: opObj.position,
+        text: opObj.text,
+      };
+    } else {
+      if (
+        typeof opObj.position !== "number" ||
+        !Number.isInteger(opObj.position)
+      ) {
+        ws.send(
+          JSON.stringify({
+            type: "error",
+            message: "Delete position must be an integer",
+          })
+        );
+        return;
+      }
+      if (
+        typeof opObj.count !== "number" ||
+        !Number.isInteger(opObj.count) ||
+        opObj.count < 1
+      ) {
+        ws.send(
+          JSON.stringify({
+            type: "error",
+            message: "Delete count must be a positive integer",
+          })
+        );
+        return;
+      }
+      incomingOp = {
+        type: "delete",
+        position: opObj.position,
+        count: opObj.count,
+      };
+    }
+
+    // Transform against concurrent ops
+    if (concurrentOps.length > 0) {
+      transformedOp = transformOpAgainstOps(incomingOp, concurrentOps);
+    } else {
+      transformedOp = incomingOp;
+    }
+
+    // Validate transformed op against current content
+    const validation = validateOperation(transformedOp, state.content.length);
+    if (!validation.valid) {
+      ws.send(
+        JSON.stringify({
+          type: "error",
+          message: validation.error,
+        })
+      );
+      return;
+    }
+
+    // Apply operation
+    const newContent = applyOperation(state.content, validation.operation);
+    const newVersion = state.version + 1;
+
+    state.content = newContent;
+    state.version = newVersion;
+    state.history.push({
+      version: newVersion,
+      operation: validation.operation,
+      clientId,
+    });
+
+    // Persist to database
+    try {
+      updateDocumentContent(this.db, docId, newContent);
+      createVersion(
+        this.db,
+        docId,
+        newVersion,
+        newContent,
+        JSON.stringify(validation.operation)
+      );
+    } catch {
+      // Log but don't fail the operation
+    }
+
+    // Send ack to sender
+    ws.send(
+      JSON.stringify({
+        type: "ack",
+        version: newVersion,
+      })
+    );
+
+    // Broadcast to other clients
+    for (const [cId, clientWs] of state.clients) {
+      if (cId !== clientId && clientWs.readyState === WebSocket.OPEN) {
+        clientWs.send(
+          JSON.stringify({
+            type: "operation",
+            operation: validation.operation,
+            version: newVersion,
+            clientId,
+          })
+        );
+      }
+    }
+  }
+
+  close(): void {
+    for (const [, state] of this.documents) {
+      for (const [, ws] of state.clients) {
+        ws.close(1001, "Server shutting down");
+      }
+    }
+    this.documents.clear();
+    this.wss.close();
+  }
+}
