--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,196 @@
+export interface InsertOp {
+  type: "insert";
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: "delete";
+  position: number;
+  count: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === "insert") {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    return content.slice(0, pos) + op.text + content.slice(pos);
+  } else {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    const count = Math.min(op.count, content.length - pos);
+    return content.slice(0, pos) + content.slice(pos + count);
+  }
+}
+
+/**
+ * Transform op1 against op2 (both applied to the same document state).
+ * Returns the transformed op1' such that applying op2 then op1' yields
+ * the same result as applying op1 then op2'.
+ */
+export function transformOp(
+  op1: Operation,
+  op2: Operation
+): Operation {
+  if (op1.type === "insert" && op2.type === "insert") {
+    // Both inserts: if op1 is at a position <= op2, op1 goes first
+    if (op1.position < op2.position) {
+      return { ...op1 };
+    } else if (op1.position > op2.position) {
+      return { ...op1, position: op1.position + op2.text.length };
+    } else {
+      // Tie-break: op1 goes after op2 (arbitrary but consistent)
+      return { ...op1, position: op1.position + op2.text.length };
+    }
+  }
+
+  if (op1.type === "insert" && op2.type === "delete") {
+    if (op1.position <= op2.position) {
+      return { ...op1 };
+    } else if (op1.position >= op2.position + op2.count) {
+      return { ...op1, position: op1.position - op2.count };
+    } else {
+      // Insert is within the deleted range - place at delete position
+      return { ...op1, position: op2.position };
+    }
+  }
+
+  if (op1.type === "delete" && op2.type === "insert") {
+    if (op2.position <= op1.position) {
+      return { ...op1, position: op1.position + op2.text.length };
+    } else if (op2.position >= op1.position + op1.count) {
+      return { ...op1 };
+    } else {
+      // Insert is within the delete range - expand delete to account for inserted text
+      return {
+        ...op1,
+        count: op1.count + op2.text.length,
+      };
+    }
+  }
+
+  // Both deletes
+  if (op1.type === "delete" && op2.type === "delete") {
+    if (op1.position >= op2.position + op2.count) {
+      // op1 is entirely after op2
+      return { ...op1, position: op1.position - op2.count };
+    } else if (op2.position >= op1.position + op1.count) {
+      // op1 is entirely before op2
+      return { ...op1 };
+    } else {
+      // Overlapping deletes
+      const overlapStart = Math.max(op1.position, op2.position);
+      const overlapEnd = Math.min(
+        op1.position + op1.count,
+        op2.position + op2.count
+      );
+      const overlap = Math.max(0, overlapEnd - overlapStart);
+      const newPosition = Math.min(op1.position, op2.position);
+      const newCount = op1.count - overlap;
+
+      if (newCount <= 0) {
+        return { type: "delete", position: newPosition, count: 0 };
+      }
+
+      // Adjust position if op2 starts before op1
+      if (op2.position < op1.position) {
+        return {
+          type: "delete",
+          position: op1.position - (overlapStart - op2.position),
+          count: newCount,
+        };
+      } else {
+        return {
+          type: "delete",
+          position: op1.position,
+          count: newCount,
+        };
+      }
+    }
+  }
+
+  // Fallback (should not reach here)
+  return { ...op1 };
+}
+
+/**
+ * Transform op against a series of concurrent operations.
+ */
+export function transformOpAgainstOps(
+  op: Operation,
+  ops: Operation[]
+): Operation {
+  let result = op;
+  for (const other of ops) {
+    result = transformOp(result, other);
+  }
+  return result;
+}
+
+export function validateOperation(
+  op: unknown,
+  contentLength: number
+): { valid: true; operation: Operation } | { valid: false; error: string } {
+  if (typeof op !== "object" || op === null) {
+    return { valid: false, error: "Operation must be an object" };
+  }
+
+  const obj = op as Record<string, unknown>;
+
+  if (obj.type === "insert") {
+    if (typeof obj.position !== "number" || !Number.isInteger(obj.position)) {
+      return { valid: false, error: "Insert position must be an integer" };
+    }
+    if (typeof obj.text !== "string" || obj.text.length === 0) {
+      return { valid: false, error: "Insert text must be a non-empty string" };
+    }
+    if (obj.position < 0 || obj.position > contentLength) {
+      return {
+        valid: false,
+        error: `Insert position ${obj.position} out of range [0, ${contentLength}]`,
+      };
+    }
+    return {
+      valid: true,
+      operation: {
+        type: "insert",
+        position: obj.position,
+        text: obj.text,
+      },
+    };
+  }
+
+  if (obj.type === "delete") {
+    if (typeof obj.position !== "number" || !Number.isInteger(obj.position)) {
+      return { valid: false, error: "Delete position must be an integer" };
+    }
+    if (typeof obj.count !== "number" || !Number.isInteger(obj.count) || obj.count < 1) {
+      return {
+        valid: false,
+        error: "Delete count must be a positive integer",
+      };
+    }
+    if (obj.position < 0 || obj.position >= contentLength) {
+      return {
+        valid: false,
+        error: `Delete position ${obj.position} out of range [0, ${contentLength - 1}]`,
+      };
+    }
+    if (obj.position + obj.count > contentLength) {
+      return {
+        valid: false,
+        error: `Delete range exceeds document length`,
+      };
+    }
+    return {
+      valid: true,
+      operation: {
+        type: "delete",
+        position: obj.position,
+        count: obj.count,
+      },
+    };
+  }
+
+  return { valid: false, error: `Unknown operation type: ${String(obj.type)}` };
+}
