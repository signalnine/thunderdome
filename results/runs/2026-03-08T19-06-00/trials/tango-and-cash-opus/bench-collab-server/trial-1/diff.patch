@@ -0,0 +1,172 @@
+import fs from "node:fs";
+import path from "node:path";
+import { fileURLToPath } from "node:url";
+import crypto from "node:crypto";
+import DatabaseConstructor from "better-sqlite3";
+import type { Database as DatabaseType } from "better-sqlite3";
+
+const DbConstructor =
+  typeof DatabaseConstructor === "function"
+    ? DatabaseConstructor
+    : (DatabaseConstructor as unknown as { default: typeof DatabaseConstructor }).default;
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function initDb(dbPath: string = ":memory:"): DatabaseType {
+  const db = new DbConstructor(dbPath);
+  db.pragma("journal_mode = WAL");
+  db.pragma("foreign_keys = ON");
+
+  const __filename = fileURLToPath(import.meta.url);
+  const __dirname = path.dirname(__filename);
+  const schemaPath = path.join(__dirname, "..", "schema.sql");
+  const schemaSql = fs.readFileSync(schemaPath, "utf-8");
+
+  db.exec(schemaSql);
+
+  return db;
+}
+
+export function createDocument(
+  db: DatabaseType,
+  title: string,
+  content: string = ""
+): DocumentRow {
+  const id = crypto.randomUUID();
+
+  const insertDoc = db.prepare(
+    `INSERT INTO documents (id, title, content) VALUES (?, ?, ?)`
+  );
+  const getDoc = db.prepare(`SELECT * FROM documents WHERE id = ?`);
+  const insertVersion = db.prepare(
+    `INSERT INTO versions (document_id, version, content) VALUES (?, ?, ?)`
+  );
+
+  const transaction = db.transaction(() => {
+    insertDoc.run(id, title, content);
+    insertVersion.run(id, 1, content);
+    return getDoc.get(id) as DocumentRow;
+  });
+
+  return transaction();
+}
+
+export function getDocument(
+  db: DatabaseType,
+  id: string
+): DocumentRow | undefined {
+  const stmt = db.prepare(`SELECT * FROM documents WHERE id = ?`);
+  return stmt.get(id) as DocumentRow | undefined;
+}
+
+export function listDocuments(db: DatabaseType): DocumentRow[] {
+  const stmt = db.prepare(
+    `SELECT * FROM documents ORDER BY updated_at DESC`
+  );
+  return stmt.all() as DocumentRow[];
+}
+
+export function updateDocument(
+  db: DatabaseType,
+  id: string,
+  updates: { title?: string; content?: string }
+): DocumentRow | undefined {
+  const doc = getDocument(db, id);
+  if (!doc) return undefined;
+
+  const newTitle = updates.title !== undefined ? updates.title : doc.title;
+  const newContent =
+    updates.content !== undefined ? updates.content : doc.content;
+  const contentChanged =
+    updates.content !== undefined && updates.content !== doc.content;
+
+  const transaction = db.transaction(() => {
+    const updateStmt = db.prepare(
+      `UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?`
+    );
+    updateStmt.run(newTitle, newContent, id);
+
+    if (contentChanged) {
+      const maxVersionStmt = db.prepare(
+        `SELECT COALESCE(MAX(version), 0) as maxVer FROM versions WHERE document_id = ?`
+      );
+      const row = maxVersionStmt.get(id) as { maxVer: number };
+      const nextVersion = row.maxVer + 1;
+
+      const insertVersion = db.prepare(
+        `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`
+      );
+      insertVersion.run(id, nextVersion, newContent, null);
+    }
+
+    return getDocument(db, id);
+  });
+
+  return transaction();
+}
+
+export function deleteDocument(db: DatabaseType, id: string): boolean {
+  const stmt = db.prepare(`DELETE FROM documents WHERE id = ?`);
+  const result = stmt.run(id);
+  return result.changes > 0;
+}
+
+export function getVersions(
+  db: DatabaseType,
+  documentId: string
+): VersionRow[] {
+  const stmt = db.prepare(
+    `SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC`
+  );
+  return stmt.all(documentId) as VersionRow[];
+}
+
+export function getVersion(
+  db: DatabaseType,
+  documentId: string,
+  version: number
+): VersionRow | undefined {
+  const stmt = db.prepare(
+    `SELECT * FROM versions WHERE document_id = ? AND version = ?`
+  );
+  return stmt.get(documentId, version) as VersionRow | undefined;
+}
+
+export function createVersion(
+  db: DatabaseType,
+  documentId: string,
+  version: number,
+  content: string,
+  operation?: string
+): void {
+  const stmt = db.prepare(
+    `INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)`
+  );
+  stmt.run(documentId, version, content, operation ?? null);
+}
+
+export function updateDocumentContent(
+  db: DatabaseType,
+  id: string,
+  content: string
+): void {
+  const stmt = db.prepare(
+    `UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?`
+  );
+  stmt.run(content, id);
+}
