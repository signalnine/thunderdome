+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01PCxnkpyr59VAakRBFtD7Li","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01UCercShiwDZcejNDXrvYNq","name":"Write","input":{"file_path":"/workspace/src/__tests__/server.test.ts","content":"import { describe, it, expect, beforeEach, afterEach, beforeAll, afterAll } from \"vitest\";\nimport { createApp } from \"../server.js\";\nimport type { AppInstance } from \"../server.js\";\nimport WebSocket from \"ws\";\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport os from \"node:os\";\n\n// Helper to make HTTP requests\nasync function request(\n  baseUrl: string,\n  method: string,\n  path: string,\n  body?: unknown\n): Promise<{ status: number; body: unknown }> {\n  const res = await fetch(`${baseUrl}${path}`, {\n    method,\n    headers: body ? { \"Content-Type\": \"application/json\" } : {},\n    body: body ? JSON.stringify(body) : undefined,\n  });\n  const status = res.status;\n  let responseBody: unknown;\n  const text = await res.text();\n  try {\n    responseBody = JSON.parse(text);\n  } catch {\n    responseBody = text;\n  }\n  return { status, body: responseBody };\n}\n\n// Helper to connect a WebSocket client and wait for sync\nfunction connectWs(\n  baseUrl: string,\n  docId: string\n): Promise<{ ws: WebSocket; sync: Record<string, unknown>; clientId: string }> {\n  return new Promise((resolve, reject) => {\n    const wsUrl = baseUrl.replace(\"http://\", \"ws://\");\n    const ws = new WebSocket(`${wsUrl}/ws/${docId}`);\n    ws.on(\"message\", (data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === \"sync\") {\n        resolve({ ws, sync: msg, clientId: msg.clientId });\n      } else if (msg.type === \"error\") {\n        reject(new Error(msg.message));\n      }\n    });\n    ws.on(\"error\", reject);\n  });\n}\n\n// Helper to wait for a specific message type\nfunction waitForMessage(\n  ws: WebSocket,\n  type: string,\n  timeout: number = 5000\n): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(\n      () => reject(new Error(`Timeout waiting for ${type} message`)),\n      timeout\n    );\n    const handler = (data: WebSocket.Data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === type) {\n        clearTimeout(timer);\n        ws.off(\"message\", handler);\n        resolve(msg);\n      }\n    };\n    ws.on(\"message\", handler);\n  });\n}\n\n// Helper to send an operation and wait for ack\nfunction sendOp(\n  ws: WebSocket,\n  operation: Record<string, unknown>,\n  version: number\n): Promise<Record<string, unknown>> {\n  const ackPromise = waitForMessage(ws, \"ack\");\n  ws.send(JSON.stringify({ type: \"operation\", operation, version }));\n  return ackPromise;\n}\n\n// ============================================================\n// REST CRUD Tests\n// ============================================================\ndescribe(\"REST CRUD\", () => {\n  let app: AppInstance;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should create a document\", async () => {\n    const res = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Test Doc\",\n      content: \"Hello\",\n    });\n    expect(res.status).toBe(201);\n    const doc = res.body as Record<string, unknown>;\n    expect(doc.title).toBe(\"Test Doc\");\n    expect(doc.content).toBe(\"Hello\");\n    expect(doc.id).toBeDefined();\n  });\n\n  it(\"should create a document with empty content\", async () => {\n    const res = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Empty Doc\",\n    });\n    expect(res.status).toBe(201);\n    const doc = res.body as Record<string, unknown>;\n    expect(doc.content).toBe(\"\");\n  });\n\n  it(\"should get a document by id\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Get Test\",\n      content: \"Content\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect(getRes.status).toBe(200);\n    expect((getRes.body as Record<string, unknown>).title).toBe(\"Get Test\");\n  });\n\n  it(\"should return 404 for non-existent document\", async () => {\n    const res = await request(baseUrl, \"GET\", \"/documents/nonexistent\");\n    expect(res.status).toBe(404);\n  });\n\n  it(\"should list documents\", async () => {\n    await request(baseUrl, \"POST\", \"/documents\", { title: \"Doc 1\" });\n    await request(baseUrl, \"POST\", \"/documents\", { title: \"Doc 2\" });\n\n    const res = await request(baseUrl, \"GET\", \"/documents\");\n    expect(res.status).toBe(200);\n    const docs = res.body as unknown[];\n    expect(docs.length).toBe(2);\n  });\n\n  it(\"should update a document\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Original\",\n      content: \"Old\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const updateRes = await request(baseUrl, \"PUT\", `/documents/${doc.id}`, {\n      title: \"Updated\",\n      content: \"New\",\n    });\n    expect(updateRes.status).toBe(200);\n    const updated = updateRes.body as Record<string, unknown>;\n    expect(updated.title).toBe(\"Updated\");\n    expect(updated.content).toBe(\"New\");\n  });\n\n  it(\"should partially update a document with PATCH\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Original\",\n      content: \"Content\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const patchRes = await request(\n      baseUrl,\n      \"PATCH\",\n      `/documents/${doc.id}`,\n      { title: \"Patched\" }\n    );\n    expect(patchRes.status).toBe(200);\n    const patched = patchRes.body as Record<string, unknown>;\n    expect(patched.title).toBe(\"Patched\");\n    expect(patched.content).toBe(\"Content\");\n  });\n\n  it(\"should delete a document\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Delete Me\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const deleteRes = await request(\n      baseUrl,\n      \"DELETE\",\n      `/documents/${doc.id}`\n    );\n    expect(deleteRes.status).toBe(204);\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it(\"should return 404 when deleting non-existent document\", async () => {\n    const res = await request(baseUrl, \"DELETE\", \"/documents/nonexistent\");\n    expect(res.status).toBe(404);\n  });\n\n  it(\"should get version history\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Versioned\",\n      content: \"V1\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    await request(baseUrl, \"PUT\", `/documents/${doc.id}`, {\n      title: \"Versioned\",\n      content: \"V2\",\n    });\n\n    const versionsRes = await request(\n      baseUrl,\n      \"GET\",\n      `/documents/${doc.id}/versions`\n    );\n    expect(versionsRes.status).toBe(200);\n    const versions = versionsRes.body as unknown[];\n    expect(versions.length).toBe(2);\n  });\n});\n\n// ============================================================\n// WebSocket Lifecycle Tests\n// ============================================================\ndescribe(\"WebSocket Lifecycle\", () => {\n  let app: AppInstance;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should receive sync message on connect\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"WS Test\",\n      content: \"Hello WS\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    expect(sync.type).toBe(\"sync\");\n    expect(sync.content).toBe(\"Hello WS\");\n    expect(sync.version).toBeDefined();\n    ws.close();\n  });\n\n  it(\"should assign a clientId on connect\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Client ID Test\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, clientId } = await connectWs(baseUrl, doc.id as string);\n    expect(clientId).toBeDefined();\n    expect(typeof clientId).toBe(\"string\");\n    ws.close();\n  });\n\n  it(\"should error on invalid document id\", async () => {\n    const wsUrl = baseUrl.replace(\"http://\", \"ws://\");\n    const ws = new WebSocket(`${wsUrl}/ws/nonexistent-doc`);\n\n    const msg = await new Promise<Record<string, unknown>>(\n      (resolve, reject) => {\n        ws.on(\"message\", (data) => {\n          resolve(JSON.parse(data.toString()));\n        });\n        ws.on(\"error\", reject);\n        setTimeout(() => reject(new Error(\"Timeout\")), 5000);\n      }\n    );\n    expect(msg.type).toBe(\"error\");\n    ws.close();\n  });\n\n  it(\"should handle multiple clients connecting to same document\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Multi Client\",\n      content: \"Shared\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2, sync: sync2 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n\n    expect(sync1.content).toBe(\"Shared\");\n    expect(sync2.content).toBe(\"Shared\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle client disconnect gracefully\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Disconnect Test\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws } = await connectWs(baseUrl, doc.id as string);\n    ws.close();\n\n    // Should be able to reconnect\n    await new Promise((r) => setTimeout(r, 100));\n    const { ws: ws2, sync: sync2 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    expect(sync2.type).toBe(\"sync\");\n    ws2.close();\n  });\n\n  it(\"should close connection with error for invalid URL path\", async () => {\n    const wsUrl = baseUrl.replace(\"http://\", \"ws://\");\n    const ws = new WebSocket(`${wsUrl}/invalid-path`);\n\n    const msg = await new Promise<Record<string, unknown>>(\n      (resolve, reject) => {\n        ws.on(\"message\", (data) => {\n          resolve(JSON.parse(data.toString()));\n        });\n        ws.on(\"error\", reject);\n        setTimeout(() => reject(new Error(\"Timeout\")), 5000);\n      }\n    );\n    expect(msg.type).toBe(\"error\");\n    ws.close();\n  });\n\n  it(\"should provide correct version in sync message\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Version Sync\",\n      content: \"Initial\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    expect(sync.version).toBe(1); // version 1 from creation\n    ws.close();\n  });\n\n  it(\"should handle rapid connect/disconnect cycles\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Rapid Test\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    for (let i = 0; i < 5; i++) {\n      const { ws } = await connectWs(baseUrl, doc.id as string);\n      ws.close();\n      await new Promise((r) => setTimeout(r, 50));\n    }\n\n    // Final connection should still work\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    expect(sync.type).toBe(\"sync\");\n    ws.close();\n  });\n});\n\n// ============================================================\n// Single Client Editing Tests\n// ============================================================\ndescribe(\"Single Client Editing\", () => {\n  let app: AppInstance;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should apply an insert operation\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Insert Test\",\n      content: \"Hello\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    const version = sync.version as number;\n\n    const ack = await sendOp(\n      ws,\n      { type: \"insert\", position: 5, text: \" World\" },\n      version\n    );\n    expect(ack.version).toBe(version + 1);\n\n    // Verify via REST\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect((getRes.body as Record<string, unknown>).content).toBe(\n      \"Hello World\"\n    );\n    ws.close();\n  });\n\n  it(\"should apply a delete operation\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Delete Test\",\n      content: \"Hello World\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    const version = sync.version as number;\n\n    const ack = await sendOp(\n      ws,\n      { type: \"delete\", position: 5, count: 6 },\n      version\n    );\n    expect(ack.version).toBe(version + 1);\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect((getRes.body as Record<string, unknown>).content).toBe(\"Hello\");\n    ws.close();\n  });\n\n  it(\"should apply multiple sequential operations\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Sequential\",\n      content: \"\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    let version = sync.version as number;\n\n    let ack = await sendOp(\n      ws,\n      { type: \"insert\", position: 0, text: \"Hello\" },\n      version\n    );\n    version = ack.version as number;\n\n    ack = await sendOp(\n      ws,\n      { type: \"insert\", position: 5, text: \" World\" },\n      version\n    );\n    version = ack.version as number;\n\n    ack = await sendOp(\n      ws,\n      { type: \"insert\", position: 11, text: \"!\" },\n      version\n    );\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect((getRes.body as Record<string, unknown>).content).toBe(\n      \"Hello World!\"\n    );\n    ws.close();\n  });\n\n  it(\"should insert at position 0\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Prepend\",\n      content: \"World\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    await sendOp(\n      ws,\n      { type: \"insert\", position: 0, text: \"Hello \" },\n      sync.version as number\n    );\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect((getRes.body as Record<string, unknown>).content).toBe(\n      \"Hello World\"\n    );\n    ws.close();\n  });\n\n  it(\"should create version entries for operations\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Version Track\",\n      content: \"A\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    await sendOp(\n      ws,\n      { type: \"insert\", position: 1, text: \"B\" },\n      sync.version as number\n    );\n\n    const versionsRes = await request(\n      baseUrl,\n      \"GET\",\n      `/documents/${doc.id}/versions`\n    );\n    const versions = versionsRes.body as Record<string, unknown>[];\n    expect(versions.length).toBeGreaterThanOrEqual(2);\n    ws.close();\n  });\n\n  it(\"should handle insert at end of document\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Append\",\n      content: \"Hello\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    await sendOp(\n      ws,\n      { type: \"insert\", position: 5, text: \"!\" },\n      sync.version as number\n    );\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect((getRes.body as Record<string, unknown>).content).toBe(\"Hello!\");\n    ws.close();\n  });\n});\n\n// ============================================================\n// Two-Client Convergence Tests\n// ============================================================\ndescribe(\"Two-Client Convergence\", () => {\n  let app: AppInstance;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should broadcast operation to other client\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Broadcast\",\n      content: \"Hello\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    const opPromise = waitForMessage(ws2, \"operation\");\n    await sendOp(\n      ws1,\n      { type: \"insert\", position: 5, text: \" World\" },\n      sync1.version as number\n    );\n\n    const broadcastedOp = await opPromise;\n    expect(broadcastedOp.type).toBe(\"operation\");\n    expect(broadcastedOp.operation).toBeDefined();\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge with two simultaneous inserts at different positions\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Converge\",\n      content: \"AC\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2, sync: sync2 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n\n    const version = sync1.version as number;\n    expect(sync2.version).toBe(version);\n\n    // Client 1 inserts \"B\" at position 1 (between A and C)\n    // Client 2 inserts \"D\" at position 2 (after C)\n    // Both send at the same base version\n    const ack1Promise = sendOp(\n      ws1,\n      { type: \"insert\", position: 1, text: \"B\" },\n      version\n    );\n    // Wait for ack1 first so version ordering is deterministic\n    await ack1Promise;\n\n    const ack2Promise = sendOp(\n      ws2,\n      { type: \"insert\", position: 2, text: \"D\" },\n      version\n    );\n    await ack2Promise;\n\n    // Give time for operations to propagate\n    await new Promise((r) => setTimeout(r, 200));\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    // Both B and D should be present\n    expect(content).toContain(\"A\");\n    expect(content).toContain(\"B\");\n    expect(content).toContain(\"C\");\n    expect(content).toContain(\"D\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge with two inserts at the same position\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Same Pos\",\n      content: \"X\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    const version = sync1.version as number;\n\n    // Both insert at position 0\n    await sendOp(ws1, { type: \"insert\", position: 0, text: \"A\" }, version);\n    await sendOp(ws2, { type: \"insert\", position: 0, text: \"B\" }, version);\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    expect(content).toContain(\"A\");\n    expect(content).toContain(\"B\");\n    expect(content).toContain(\"X\");\n    expect(content.length).toBe(3);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge with insert and delete\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Insert+Delete\",\n      content: \"Hello World\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    const version = sync1.version as number;\n\n    // Client 1 inserts \"!\" at end\n    await sendOp(\n      ws1,\n      { type: \"insert\", position: 11, text: \"!\" },\n      version\n    );\n    // Client 2 deletes \" World\" (position 5, count 6) - based on same version\n    await sendOp(\n      ws2,\n      { type: \"delete\", position: 5, count: 6 },\n      version\n    );\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    // \"Hello\" should remain, \"!\" should be present (possibly repositioned)\n    expect(content).toContain(\"Hello\");\n    expect(content).toContain(\"!\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle rapid alternating edits\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Rapid\",\n      content: \"\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    let version = sync1.version as number;\n\n    // Alternating inserts\n    let ack = await sendOp(\n      ws1,\n      { type: \"insert\", position: 0, text: \"A\" },\n      version\n    );\n    version = ack.version as number;\n\n    ack = await sendOp(\n      ws2,\n      { type: \"insert\", position: 1, text: \"B\" },\n      version\n    );\n    version = ack.version as number;\n\n    ack = await sendOp(\n      ws1,\n      { type: \"insert\", position: 2, text: \"C\" },\n      version\n    );\n    version = ack.version as number;\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    expect(content).toBe(\"ABC\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should preserve both insertions in concurrent edits\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Preserve Both\",\n      content: \"Hello\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    const version = sync1.version as number;\n\n    // Both insert at same base version\n    await sendOp(\n      ws1,\n      { type: \"insert\", position: 0, text: \"Start: \" },\n      version\n    );\n    await sendOp(\n      ws2,\n      { type: \"insert\", position: 5, text: \" End\" },\n      version\n    );\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    expect(content).toContain(\"Start: \");\n    expect(content).toContain(\"Hello\");\n    expect(content).toContain(\" End\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should increment version correctly with concurrent ops\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Version Inc\",\n      content: \"AB\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    const version = sync1.version as number;\n\n    const ack1 = await sendOp(\n      ws1,\n      { type: \"insert\", position: 1, text: \"X\" },\n      version\n    );\n    const ack2 = await sendOp(\n      ws2,\n      { type: \"insert\", position: 1, text: \"Y\" },\n      version\n    );\n\n    expect(ack1.version).toBe(version + 1);\n    expect(ack2.version).toBe(version + 2);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle three sequential operations from different clients\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Three Ops\",\n      content: \"start\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    let version = sync1.version as number;\n\n    let ack = await sendOp(\n      ws1,\n      { type: \"insert\", position: 5, text: \"1\" },\n      version\n    );\n    version = ack.version as number;\n\n    ack = await sendOp(\n      ws2,\n      { type: \"insert\", position: 6, text: \"2\" },\n      version\n    );\n    version = ack.version as number;\n\n    ack = await sendOp(\n      ws1,\n      { type: \"insert\", position: 7, text: \"3\" },\n      version\n    );\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    expect(content).toBe(\"start123\");\n\n    ws1.close();\n    ws2.close();\n  });\n});\n\n// ============================================================\n// Stress Test\n// ============================================================\ndescribe(\"Stress Test\", () => {\n  let app: AppInstance;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should handle 10 concurrent clients connecting\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Stress Connect\",\n      content: \"Base\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const clients: { ws: WebSocket; sync: Record<string, unknown> }[] = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(baseUrl, doc.id as string);\n      clients.push(client);\n    }\n\n    expect(clients.length).toBe(10);\n    for (const { sync } of clients) {\n      expect(sync.content).toBe(\"Base\");\n    }\n\n    for (const { ws } of clients) {\n      ws.close();\n    }\n  });\n\n  it(\"should handle 10 clients each sending an insert\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Stress Edit\",\n      content: \"\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const clients: {\n      ws: WebSocket;\n      sync: Record<string, unknown>;\n    }[] = [];\n    for (let i = 0; i < 10; i++) {\n      clients.push(await connectWs(baseUrl, doc.id as string));\n    }\n\n    // Each client inserts sequentially with correct versions\n    let version = clients[0].sync.version as number;\n    for (let i = 0; i < 10; i++) {\n      const ack = await sendOp(\n        clients[i].ws,\n        { type: \"insert\", position: i, text: String(i) },\n        version\n      );\n      version = ack.version as number;\n    }\n\n    await new Promise((r) => setTimeout(r, 300));\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    expect(content.length).toBe(10);\n    // All digits 0-9 should be present\n    for (let i = 0; i < 10; i++) {\n      expect(content).toContain(String(i));\n    }\n\n    for (const { ws } of clients) {\n      ws.close();\n    }\n  });\n\n  it(\"should not corrupt document with concurrent operations from many clients\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"No Corruption\",\n      content: \"BASE\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const clients: {\n      ws: WebSocket;\n      sync: Record<string, unknown>;\n    }[] = [];\n    for (let i = 0; i < 10; i++) {\n      clients.push(await connectWs(baseUrl, doc.id as string));\n    }\n\n    const baseVersion = clients[0].sync.version as number;\n\n    // All clients insert at position 0 at the same base version\n    const ackPromises = clients.map((c, i) =>\n      sendOp(\n        c.ws,\n        { type: \"insert\", position: 0, text: String.fromCharCode(65 + i) },\n        baseVersion\n      )\n    );\n\n    await Promise.all(ackPromises);\n    await new Promise((r) => setTimeout(r, 300));\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    // All 10 letters plus \"BASE\" should be present\n    expect(content).toContain(\"BASE\");\n    expect(content.length).toBe(14); // 4 (BASE) + 10 letters\n\n    for (const { ws } of clients) {\n      ws.close();\n    }\n  });\n\n  it(\"should maintain consistency across all clients\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Consistency\",\n      content: \"\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const clients: {\n      ws: WebSocket;\n      sync: Record<string, unknown>;\n    }[] = [];\n    for (let i = 0; i < 5; i++) {\n      clients.push(await connectWs(baseUrl, doc.id as string));\n    }\n\n    let version = clients[0].sync.version as number;\n\n    // Sequential operations to build predictable content\n    for (let i = 0; i < 5; i++) {\n      const ack = await sendOp(\n        clients[i].ws,\n        { type: \"insert\", position: i, text: String(i) },\n        version\n      );\n      version = ack.version as number;\n    }\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    // All should see the same content via REST\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    expect(content).toBe(\"01234\");\n\n    for (const { ws } of clients) {\n      ws.close();\n    }\n  });\n\n  it(\"should handle clients disconnecting during editing\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Disconnect Stress\",\n      content: \"Start\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const clients: {\n      ws: WebSocket;\n      sync: Record<string, unknown>;\n    }[] = [];\n    for (let i = 0; i < 10; i++) {\n      clients.push(await connectWs(baseUrl, doc.id as string));\n    }\n\n    let version = clients[0].sync.version as number;\n\n    // First 5 clients send operations\n    for (let i = 0; i < 5; i++) {\n      const ack = await sendOp(\n        clients[i].ws,\n        {\n          type: \"insert\",\n          position: 5 + i,\n          text: String(i),\n        },\n        version\n      );\n      version = ack.version as number;\n    }\n\n    // Disconnect last 5 clients\n    for (let i = 5; i < 10; i++) {\n      clients[i].ws.close();\n    }\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    // Document should be intact\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    expect(content).toContain(\"Start\");\n    expect(content.length).toBe(10); // \"Start\" + 5 digits\n\n    for (let i = 0; i < 5; i++) {\n      clients[i].ws.close();\n    }\n  });\n});\n\n// ============================================================\n// Error Handling Tests\n// ============================================================\ndescribe(\"Error Handling\", () => {\n  let app: AppInstance;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should reject invalid JSON over WebSocket\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Bad JSON\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws } = await connectWs(baseUrl, doc.id as string);\n    const errorPromise = waitForMessage(ws, \"error\");\n    ws.send(\"not json at all\");\n    const error = await errorPromise;\n    expect(error.type).toBe(\"error\");\n    ws.close();\n  });\n\n  it(\"should reject unknown message type\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Unknown Type\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws } = await connectWs(baseUrl, doc.id as string);\n    const errorPromise = waitForMessage(ws, \"error\");\n    ws.send(JSON.stringify({ type: \"unknown_type\" }));\n    const error = await errorPromise;\n    expect(error.type).toBe(\"error\");\n    ws.close();\n  });\n\n  it(\"should reject operation with missing fields\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Missing Fields\",\n      content: \"Test\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    const errorPromise = waitForMessage(ws, \"error\");\n    ws.send(\n      JSON.stringify({\n        type: \"operation\",\n        operation: { type: \"insert\" },\n        version: sync.version,\n      })\n    );\n    const error = await errorPromise;\n    expect(error.type).toBe(\"error\");\n    ws.close();\n  });\n\n  it(\"should return 400 for creating document without title\", async () => {\n    const res = await request(baseUrl, \"POST\", \"/documents\", {});\n    expect(res.status).toBe(400);\n  });\n\n  it(\"should reject delete operation out of bounds\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"OOB Delete\",\n      content: \"Hi\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    const errorPromise = waitForMessage(ws, \"error\");\n    ws.send(\n      JSON.stringify({\n        type: \"operation\",\n        operation: { type: \"delete\", position: 0, count: 100 },\n        version: sync.version,\n      })\n    );\n    const error = await errorPromise;\n    expect(error.type).toBe(\"error\");\n    ws.close();\n  });\n});\n\n// ============================================================\n// Persistence Tests\n// ============================================================\ndescribe(\"Persistence\", () => {\n  let tmpDir: string;\n  let dbPath: string;\n\n  beforeAll(() => {\n    tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), \"collab-test-\"));\n    dbPath = path.join(tmpDir, \"test.db\");\n  });\n\n  afterAll(() => {\n    try {\n      fs.rmSync(tmpDir, { recursive: true });\n    } catch {\n      // ignore\n    }\n  });\n\n  it(\"should persist documents across server restarts\", async () => {\n    // Create document on first server instance\n    const app1 = createApp(dbPath);\n    const port1 = await app1.start(0);\n    const baseUrl1 = `http://localhost:${port1}`;\n\n    const createRes = await request(baseUrl1, \"POST\", \"/documents\", {\n      title: \"Persistent Doc\",\n      content: \"Persisted content\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n    await app1.stop();\n\n    // Read document on second server instance\n    const app2 = createApp(dbPath);\n    const port2 = await app2.start(0);\n    const baseUrl2 = `http://localhost:${port2}`;\n\n    const getRes = await request(baseUrl2, \"GET\", `/documents/${doc.id}`);\n    expect(getRes.status).toBe(200);\n    expect((getRes.body as Record<string, unknown>).title).toBe(\n      \"Persistent Doc\"\n    );\n    expect((getRes.body as Record<string, unknown>).content).toBe(\n      \"Persisted content\"\n    );\n    await app2.stop();\n  });\n\n  it(\"should persist WebSocket edits across restarts\", async () => {\n    const dbPath2 = path.join(tmpDir, \"test2.db\");\n\n    const app1 = createApp(dbPath2);\n    const port1 = await app1.start(0);\n    const baseUrl1 = `http://localhost:${port1}`;\n\n    const createRes = await request(baseUrl1, \"POST\", \"/documents\", {\n      title: \"WS Persist\",\n      content: \"Hello\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl1, doc.id as string);\n    await sendOp(\n      ws,\n      { type: \"insert\", position: 5, text: \" World\" },\n      sync.version as number\n    );\n    ws.close();\n    await new Promise((r) => setTimeout(r, 100));\n    await app1.stop();\n\n    const app2 = createApp(dbPath2);\n    const port2 = await app2.start(0);\n    const baseUrl2 = `http://localhost:${port2}`;\n\n    const getRes = await request(baseUrl2, \"GET\", `/documents/${doc.id}`);\n    expect((getRes.body as Record<string, unknown>).content).toBe(\n      \"Hello World\"\n    );\n    await app2.stop();\n  });\n\n  it(\"should persist version history across restarts\", async () => {\n    const dbPath3 = path.join(tmpDir, \"test3.db\");\n\n    const app1 = createApp(dbPath3);\n    const port1 = await app1.start(0);\n    const baseUrl1 = `http://localhost:${port1}`;\n\n    const createRes = await request(baseUrl1, \"POST\", \"/documents\", {\n      title: \"Version Persist\",\n      content: \"V1\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    await request(baseUrl1, \"PUT\", `/documents/${doc.id}`, {\n      content: \"V2\",\n    });\n    await app1.stop();\n\n    const app2 = createApp(dbPath3);\n    const port2 = await app2.start(0);\n    const baseUrl2 = `http://localhost:${port2}`;\n\n    const versionsRes = await request(\n      baseUrl2,\n      \"GET\",\n      `/documents/${doc.id}/versions`\n    );\n    const versions = versionsRes.body as unknown[];\n    expect(versions.length).toBe(2);\n    await app2.stop();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":122,"cache_read_input_tokens":37368,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":122},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"86e173e1-38a5-4c3c-9b95-74f5ae49777b","uuid":"ac65e9d2-d911-439f-ba40-f1098d042791"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UCercShiwDZcejNDXrvYNq","type":"tool_result","content":"File created successfully at: /workspace/src/__tests__/server.test.ts"}]},"parent_tool_use_id":null,"session_id":"86e173e1-38a5-4c3c-9b95-74f5ae49777b","uuid":"d7916e4a-6c68-4cf8-8d87-453968f7c848","tool_use_result":{"type":"create","filePath":"/workspace/src/__tests__/server.test.ts","content":"import { describe, it, expect, beforeEach, afterEach, beforeAll, afterAll } from \"vitest\";\nimport { createApp } from \"../server.js\";\nimport type { AppInstance } from \"../server.js\";\nimport WebSocket from \"ws\";\nimport fs from \"node:fs\";\nimport path from \"node:path\";\nimport os from \"node:os\";\n\n// Helper to make HTTP requests\nasync function request(\n  baseUrl: string,\n  method: string,\n  path: string,\n  body?: unknown\n): Promise<{ status: number; body: unknown }> {\n  const res = await fetch(`${baseUrl}${path}`, {\n    method,\n    headers: body ? { \"Content-Type\": \"application/json\" } : {},\n    body: body ? JSON.stringify(body) : undefined,\n  });\n  const status = res.status;\n  let responseBody: unknown;\n  const text = await res.text();\n  try {\n    responseBody = JSON.parse(text);\n  } catch {\n    responseBody = text;\n  }\n  return { status, body: responseBody };\n}\n\n// Helper to connect a WebSocket client and wait for sync\nfunction connectWs(\n  baseUrl: string,\n  docId: string\n): Promise<{ ws: WebSocket; sync: Record<string, unknown>; clientId: string }> {\n  return new Promise((resolve, reject) => {\n    const wsUrl = baseUrl.replace(\"http://\", \"ws://\");\n    const ws = new WebSocket(`${wsUrl}/ws/${docId}`);\n    ws.on(\"message\", (data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === \"sync\") {\n        resolve({ ws, sync: msg, clientId: msg.clientId });\n      } else if (msg.type === \"error\") {\n        reject(new Error(msg.message));\n      }\n    });\n    ws.on(\"error\", reject);\n  });\n}\n\n// Helper to wait for a specific message type\nfunction waitForMessage(\n  ws: WebSocket,\n  type: string,\n  timeout: number = 5000\n): Promise<Record<string, unknown>> {\n  return new Promise((resolve, reject) => {\n    const timer = setTimeout(\n      () => reject(new Error(`Timeout waiting for ${type} message`)),\n      timeout\n    );\n    const handler = (data: WebSocket.Data) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === type) {\n        clearTimeout(timer);\n        ws.off(\"message\", handler);\n        resolve(msg);\n      }\n    };\n    ws.on(\"message\", handler);\n  });\n}\n\n// Helper to send an operation and wait for ack\nfunction sendOp(\n  ws: WebSocket,\n  operation: Record<string, unknown>,\n  version: number\n): Promise<Record<string, unknown>> {\n  const ackPromise = waitForMessage(ws, \"ack\");\n  ws.send(JSON.stringify({ type: \"operation\", operation, version }));\n  return ackPromise;\n}\n\n// ============================================================\n// REST CRUD Tests\n// ============================================================\ndescribe(\"REST CRUD\", () => {\n  let app: AppInstance;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should create a document\", async () => {\n    const res = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Test Doc\",\n      content: \"Hello\",\n    });\n    expect(res.status).toBe(201);\n    const doc = res.body as Record<string, unknown>;\n    expect(doc.title).toBe(\"Test Doc\");\n    expect(doc.content).toBe(\"Hello\");\n    expect(doc.id).toBeDefined();\n  });\n\n  it(\"should create a document with empty content\", async () => {\n    const res = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Empty Doc\",\n    });\n    expect(res.status).toBe(201);\n    const doc = res.body as Record<string, unknown>;\n    expect(doc.content).toBe(\"\");\n  });\n\n  it(\"should get a document by id\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Get Test\",\n      content: \"Content\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect(getRes.status).toBe(200);\n    expect((getRes.body as Record<string, unknown>).title).toBe(\"Get Test\");\n  });\n\n  it(\"should return 404 for non-existent document\", async () => {\n    const res = await request(baseUrl, \"GET\", \"/documents/nonexistent\");\n    expect(res.status).toBe(404);\n  });\n\n  it(\"should list documents\", async () => {\n    await request(baseUrl, \"POST\", \"/documents\", { title: \"Doc 1\" });\n    await request(baseUrl, \"POST\", \"/documents\", { title: \"Doc 2\" });\n\n    const res = await request(baseUrl, \"GET\", \"/documents\");\n    expect(res.status).toBe(200);\n    const docs = res.body as unknown[];\n    expect(docs.length).toBe(2);\n  });\n\n  it(\"should update a document\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Original\",\n      content: \"Old\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const updateRes = await request(baseUrl, \"PUT\", `/documents/${doc.id}`, {\n      title: \"Updated\",\n      content: \"New\",\n    });\n    expect(updateRes.status).toBe(200);\n    const updated = updateRes.body as Record<string, unknown>;\n    expect(updated.title).toBe(\"Updated\");\n    expect(updated.content).toBe(\"New\");\n  });\n\n  it(\"should partially update a document with PATCH\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Original\",\n      content: \"Content\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const patchRes = await request(\n      baseUrl,\n      \"PATCH\",\n      `/documents/${doc.id}`,\n      { title: \"Patched\" }\n    );\n    expect(patchRes.status).toBe(200);\n    const patched = patchRes.body as Record<string, unknown>;\n    expect(patched.title).toBe(\"Patched\");\n    expect(patched.content).toBe(\"Content\");\n  });\n\n  it(\"should delete a document\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Delete Me\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const deleteRes = await request(\n      baseUrl,\n      \"DELETE\",\n      `/documents/${doc.id}`\n    );\n    expect(deleteRes.status).toBe(204);\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it(\"should return 404 when deleting non-existent document\", async () => {\n    const res = await request(baseUrl, \"DELETE\", \"/documents/nonexistent\");\n    expect(res.status).toBe(404);\n  });\n\n  it(\"should get version history\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Versioned\",\n      content: \"V1\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    await request(baseUrl, \"PUT\", `/documents/${doc.id}`, {\n      title: \"Versioned\",\n      content: \"V2\",\n    });\n\n    const versionsRes = await request(\n      baseUrl,\n      \"GET\",\n      `/documents/${doc.id}/versions`\n    );\n    expect(versionsRes.status).toBe(200);\n    const versions = versionsRes.body as unknown[];\n    expect(versions.length).toBe(2);\n  });\n});\n\n// ============================================================\n// WebSocket Lifecycle Tests\n// ============================================================\ndescribe(\"WebSocket Lifecycle\", () => {\n  let app: AppInstance;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should receive sync message on connect\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"WS Test\",\n      content: \"Hello WS\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    expect(sync.type).toBe(\"sync\");\n    expect(sync.content).toBe(\"Hello WS\");\n    expect(sync.version).toBeDefined();\n    ws.close();\n  });\n\n  it(\"should assign a clientId on connect\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Client ID Test\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, clientId } = await connectWs(baseUrl, doc.id as string);\n    expect(clientId).toBeDefined();\n    expect(typeof clientId).toBe(\"string\");\n    ws.close();\n  });\n\n  it(\"should error on invalid document id\", async () => {\n    const wsUrl = baseUrl.replace(\"http://\", \"ws://\");\n    const ws = new WebSocket(`${wsUrl}/ws/nonexistent-doc`);\n\n    const msg = await new Promise<Record<string, unknown>>(\n      (resolve, reject) => {\n        ws.on(\"message\", (data) => {\n          resolve(JSON.parse(data.toString()));\n        });\n        ws.on(\"error\", reject);\n        setTimeout(() => reject(new Error(\"Timeout\")), 5000);\n      }\n    );\n    expect(msg.type).toBe(\"error\");\n    ws.close();\n  });\n\n  it(\"should handle multiple clients connecting to same document\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Multi Client\",\n      content: \"Shared\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2, sync: sync2 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n\n    expect(sync1.content).toBe(\"Shared\");\n    expect(sync2.content).toBe(\"Shared\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle client disconnect gracefully\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Disconnect Test\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws } = await connectWs(baseUrl, doc.id as string);\n    ws.close();\n\n    // Should be able to reconnect\n    await new Promise((r) => setTimeout(r, 100));\n    const { ws: ws2, sync: sync2 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    expect(sync2.type).toBe(\"sync\");\n    ws2.close();\n  });\n\n  it(\"should close connection with error for invalid URL path\", async () => {\n    const wsUrl = baseUrl.replace(\"http://\", \"ws://\");\n    const ws = new WebSocket(`${wsUrl}/invalid-path`);\n\n    const msg = await new Promise<Record<string, unknown>>(\n      (resolve, reject) => {\n        ws.on(\"message\", (data) => {\n          resolve(JSON.parse(data.toString()));\n        });\n        ws.on(\"error\", reject);\n        setTimeout(() => reject(new Error(\"Timeout\")), 5000);\n      }\n    );\n    expect(msg.type).toBe(\"error\");\n    ws.close();\n  });\n\n  it(\"should provide correct version in sync message\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Version Sync\",\n      content: \"Initial\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    expect(sync.version).toBe(1); // version 1 from creation\n    ws.close();\n  });\n\n  it(\"should handle rapid connect/disconnect cycles\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Rapid Test\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    for (let i = 0; i < 5; i++) {\n      const { ws } = await connectWs(baseUrl, doc.id as string);\n      ws.close();\n      await new Promise((r) => setTimeout(r, 50));\n    }\n\n    // Final connection should still work\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    expect(sync.type).toBe(\"sync\");\n    ws.close();\n  });\n});\n\n// ============================================================\n// Single Client Editing Tests\n// ============================================================\ndescribe(\"Single Client Editing\", () => {\n  let app: AppInstance;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should apply an insert operation\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Insert Test\",\n      content: \"Hello\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    const version = sync.version as number;\n\n    const ack = await sendOp(\n      ws,\n      { type: \"insert\", position: 5, text: \" World\" },\n      version\n    );\n    expect(ack.version).toBe(version + 1);\n\n    // Verify via REST\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect((getRes.body as Record<string, unknown>).content).toBe(\n      \"Hello World\"\n    );\n    ws.close();\n  });\n\n  it(\"should apply a delete operation\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Delete Test\",\n      content: \"Hello World\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    const version = sync.version as number;\n\n    const ack = await sendOp(\n      ws,\n      { type: \"delete\", position: 5, count: 6 },\n      version\n    );\n    expect(ack.version).toBe(version + 1);\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect((getRes.body as Record<string, unknown>).content).toBe(\"Hello\");\n    ws.close();\n  });\n\n  it(\"should apply multiple sequential operations\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Sequential\",\n      content: \"\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    let version = sync.version as number;\n\n    let ack = await sendOp(\n      ws,\n      { type: \"insert\", position: 0, text: \"Hello\" },\n      version\n    );\n    version = ack.version as number;\n\n    ack = await sendOp(\n      ws,\n      { type: \"insert\", position: 5, text: \" World\" },\n      version\n    );\n    version = ack.version as number;\n\n    ack = await sendOp(\n      ws,\n      { type: \"insert\", position: 11, text: \"!\" },\n      version\n    );\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect((getRes.body as Record<string, unknown>).content).toBe(\n      \"Hello World!\"\n    );\n    ws.close();\n  });\n\n  it(\"should insert at position 0\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Prepend\",\n      content: \"World\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    await sendOp(\n      ws,\n      { type: \"insert\", position: 0, text: \"Hello \" },\n      sync.version as number\n    );\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect((getRes.body as Record<string, unknown>).content).toBe(\n      \"Hello World\"\n    );\n    ws.close();\n  });\n\n  it(\"should create version entries for operations\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Version Track\",\n      content: \"A\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    await sendOp(\n      ws,\n      { type: \"insert\", position: 1, text: \"B\" },\n      sync.version as number\n    );\n\n    const versionsRes = await request(\n      baseUrl,\n      \"GET\",\n      `/documents/${doc.id}/versions`\n    );\n    const versions = versionsRes.body as Record<string, unknown>[];\n    expect(versions.length).toBeGreaterThanOrEqual(2);\n    ws.close();\n  });\n\n  it(\"should handle insert at end of document\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Append\",\n      content: \"Hello\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws, sync } = await connectWs(baseUrl, doc.id as string);\n    await sendOp(\n      ws,\n      { type: \"insert\", position: 5, text: \"!\" },\n      sync.version as number\n    );\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    expect((getRes.body as Record<string, unknown>).content).toBe(\"Hello!\");\n    ws.close();\n  });\n});\n\n// ============================================================\n// Two-Client Convergence Tests\n// ============================================================\ndescribe(\"Two-Client Convergence\", () => {\n  let app: AppInstance;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should broadcast operation to other client\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Broadcast\",\n      content: \"Hello\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    const opPromise = waitForMessage(ws2, \"operation\");\n    await sendOp(\n      ws1,\n      { type: \"insert\", position: 5, text: \" World\" },\n      sync1.version as number\n    );\n\n    const broadcastedOp = await opPromise;\n    expect(broadcastedOp.type).toBe(\"operation\");\n    expect(broadcastedOp.operation).toBeDefined();\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge with two simultaneous inserts at different positions\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Converge\",\n      content: \"AC\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2, sync: sync2 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n\n    const version = sync1.version as number;\n    expect(sync2.version).toBe(version);\n\n    // Client 1 inserts \"B\" at position 1 (between A and C)\n    // Client 2 inserts \"D\" at position 2 (after C)\n    // Both send at the same base version\n    const ack1Promise = sendOp(\n      ws1,\n      { type: \"insert\", position: 1, text: \"B\" },\n      version\n    );\n    // Wait for ack1 first so version ordering is deterministic\n    await ack1Promise;\n\n    const ack2Promise = sendOp(\n      ws2,\n      { type: \"insert\", position: 2, text: \"D\" },\n      version\n    );\n    await ack2Promise;\n\n    // Give time for operations to propagate\n    await new Promise((r) => setTimeout(r, 200));\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    // Both B and D should be present\n    expect(content).toContain(\"A\");\n    expect(content).toContain(\"B\");\n    expect(content).toContain(\"C\");\n    expect(content).toContain(\"D\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge with two inserts at the same position\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Same Pos\",\n      content: \"X\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    const version = sync1.version as number;\n\n    // Both insert at position 0\n    await sendOp(ws1, { type: \"insert\", position: 0, text: \"A\" }, version);\n    await sendOp(ws2, { type: \"insert\", position: 0, text: \"B\" }, version);\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    expect(content).toContain(\"A\");\n    expect(content).toContain(\"B\");\n    expect(content).toContain(\"X\");\n    expect(content.length).toBe(3);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should converge with insert and delete\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Insert+Delete\",\n      content: \"Hello World\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    const version = sync1.version as number;\n\n    // Client 1 inserts \"!\" at end\n    await sendOp(\n      ws1,\n      { type: \"insert\", position: 11, text: \"!\" },\n      version\n    );\n    // Client 2 deletes \" World\" (position 5, count 6) - based on same version\n    await sendOp(\n      ws2,\n      { type: \"delete\", position: 5, count: 6 },\n      version\n    );\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    // \"Hello\" should remain, \"!\" should be present (possibly repositioned)\n    expect(content).toContain(\"Hello\");\n    expect(content).toContain(\"!\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle rapid alternating edits\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Rapid\",\n      content: \"\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    let version = sync1.version as number;\n\n    // Alternating inserts\n    let ack = await sendOp(\n      ws1,\n      { type: \"insert\", position: 0, text: \"A\" },\n      version\n    );\n    version = ack.version as number;\n\n    ack = await sendOp(\n      ws2,\n      { type: \"insert\", position: 1, text: \"B\" },\n      version\n    );\n    version = ack.version as number;\n\n    ack = await sendOp(\n      ws1,\n      { type: \"insert\", position: 2, text: \"C\" },\n      version\n    );\n    version = ack.version as number;\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    expect(content).toBe(\"ABC\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should preserve both insertions in concurrent edits\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Preserve Both\",\n      content: \"Hello\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    const version = sync1.version as number;\n\n    // Both insert at same base version\n    await sendOp(\n      ws1,\n      { type: \"insert\", position: 0, text: \"Start: \" },\n      version\n    );\n    await sendOp(\n      ws2,\n      { type: \"insert\", position: 5, text: \" End\" },\n      version\n    );\n\n    await new Promise((r) => setTimeout(r, 200));\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    expect(content).toContain(\"Start: \");\n    expect(content).toContain(\"Hello\");\n    expect(content).toContain(\" End\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should increment version correctly with concurrent ops\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Version Inc\",\n      content: \"AB\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    const version = sync1.version as number;\n\n    const ack1 = await sendOp(\n      ws1,\n      { type: \"insert\", position: 1, text: \"X\" },\n      version\n    );\n    const ack2 = await sendOp(\n      ws2,\n      { type: \"insert\", position: 1, text: \"Y\" },\n      version\n    );\n\n    expect(ack1.version).toBe(version + 1);\n    expect(ack2.version).toBe(version + 2);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle three sequential operations from different clients\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Three Ops\",\n      content: \"start\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const { ws: ws1, sync: sync1 } = await connectWs(\n      baseUrl,\n      doc.id as string\n    );\n    const { ws: ws2 } = await connectWs(baseUrl, doc.id as string);\n\n    let version = sync1.version as number;\n\n    let ack = await sendOp(\n      ws1,\n      { type: \"insert\", position: 5, text: \"1\" },\n      version\n    );\n    version = ack.version as number;\n\n    ack = await sendOp(\n      ws2,\n      { type: \"insert\", position: 6, text: \"2\" },\n      version\n    );\n    version = ack.version as number;\n\n    ack = await sendOp(\n      ws1,\n      { type: \"insert\", position: 7, text: \"3\" },\n      version\n    );\n\n    const getRes = await request(baseUrl, \"GET\", `/documents/${doc.id}`);\n    const content = (getRes.body as Record<string, unknown>).content as string;\n    expect(content).toBe(\"start123\");\n\n    ws1.close();\n    ws2.close();\n  });\n});\n\n// ============================================================\n// Stress Test\n// ============================================================\ndescribe(\"Stress Test\", () => {\n  let app: AppInstance;\n  let baseUrl: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    const port = await app.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it(\"should handle 10 concurrent clients connecting\", async () => {\n    const createRes = await request(baseUrl, \"POST\", \"/documents\", {\n      title: \"Stress Connect\",\n      content: \"Base\",\n    });\n    const doc = createRes.body as Record<string, unknown>;\n\n    const clients: { ws: WebSocket; sync: