: \"yza\", in2: \"vwx\", out: \"dzf\" },\n      { op: \"OR\", in1: \"bzc\", in2: \"dzf\", out: \"fzg\" },\n      // Bit 4\n      { op: \"XOR\", in1: \"x04\", in2: \"y04\", out: \"hzk\" },\n      { op: \"XOR\", in1: \"hzk\", in2: \"fzg\", out: \"z04\" },\n      { op: \"AND\", in1: \"x04\", in2: \"y04\", out: \"kzl\" },\n      { op: \"AND\", in1: \"hzk\", in2: \"fzg\", out: \"mzn\" },\n      { op: \"OR\", in1: \"kzl\", in2: \"mzn\", out: \"nzo\" },\n      // Bit 5\n      { op: \"XOR\", in1: \"x05\", in2: \"y05\", out: \"pzq\" },\n      { op: \"XOR\", in1: \"pzq\", in2: \"nzo\", out: \"z05\" },\n      { op: \"AND\", in1: \"x05\", in2: \"y05\", out: \"qzr\" },\n      { op: \"AND\", in1: \"pzq\", in2: \"nzo\", out: \"szx\" },\n      { op: \"OR\", in1: \"qzr\", in2: \"szx\", out: \"tzy\" },\n      // Bit 6\n      { op: \"XOR\", in1: \"x06\", in2: \"y06\", out: \"uuu\" },\n      { op: \"XOR\", in1: \"uuu\", in2: \"tzy\", out: \"z06\" },\n      { op: \"AND\", in1: \"x06\", in2: \"y06\", out: \"vvv\" },\n      { op: \"AND\", in1: \"uuu\", in2: \"tzy\", out: \"www\" },\n      { op: \"OR\", in1: \"vvv\", in2: \"www\", out: \"xxx\" },\n      // Bit 7\n      { op: \"XOR\", in1: \"x07\", in2: \"y07\", out: \"yyy\" },\n      { op: \"XOR\", in1: \"yyy\", in2: \"xxx\", out: \"z07\" },\n      { op: \"AND\", in1: \"x07\", in2: \"y07\", out: \"zzz\" },\n      { op: \"AND\", in1: \"yyy\", in2: \"xxx\", out: \"aab\" },\n      { op: \"OR\", in1: \"zzz\", in2: \"aab\", out: \"z08\" },\n    ];\n\n    // Swap 1: z01 <-> pqr (bit 1: sum and partial sum)\n    swapOutputs(gates, \"z01\", \"pqr\");\n    // Swap 2: z03 <-> yza (bit 3: sum and partial sum)\n    swapOutputs(gates, \"z03\", \"yza\");\n    // Swap 3: z05 <-> qzr (bit 5: sum and generate)\n    swapOutputs(gates, \"z05\", \"qzr\");\n    // Swap 4: z07 <-> xxx (bit 7: sum and bit 6 carry)\n    swapOutputs(gates, \"z07\", \"xxx\");\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      [\"pqr\", \"qzr\", \"xxx\", \"yza\", \"z01\", \"z03\", \"z05\", \"z07\"].sort(),\n    );\n  });\n\n  it(\"should verify finding exactly 8 wires for 4 swaps\", () => {\n    const gates = make4BitAdder();\n    // Swap z01 <-> t01\n    swapOutputs(gates, \"z01\", \"t01\");\n    // Swap z02 <-> a02\n    swapOutputs(gates, \"z02\", \"a02\");\n    // Swap z03 <-> b03\n    swapOutputs(gates, \"z03\", \"b03\");\n    // Swap z04 <-> c01\n    swapOutputs(gates, \"z04\", \"c01\");\n\n    const swappedWires = findSwappedWires(JSON.parse(JSON.stringify(gates)));\n    expect(swappedWires.length).toBe(8);\n  });\n});","originalFile":"import { describe, it, expect } from \"vitest\";\nimport { simulate, findSwappedWires, Gate } from \"../src/index.js\";\n\ndescribe(\"simulate\", () => {\n  it(\"should simulate basic AND gate\", () => {\n    const gates: Gate[] = [{ op: \"AND\", in1: \"a\", in2: \"b\", out: \"c\" }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it(\"should simulate basic OR gate\", () => {\n    const gates: Gate[] = [{ op: \"OR\", in1: \"a\", in2: \"b\", out: \"c\" }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n  });\n\n  it(\"should simulate basic XOR gate\", () => {\n    const gates: Gate[] = [{ op: \"XOR\", in1: \"a\", in2: \"b\", out: \"c\" }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n  });\n\n  it(\"should handle chained gates in dependency order\", () => {\n    const gates: Gate[] = [\n      { op: \"AND\", in1: \"a\", in2: \"b\", out: \"c\" },\n      { op: \"OR\", in1: \"c\", in2: \"d\", out: \"e\" },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1,\n      b: 1,\n      c: 1,\n      d: 0,\n      e: 1,\n    });\n  });\n\n  it(\"should simulate a 2-bit adder\", () => {\n    // 2-bit adder: x + y = z\n    const gates: Gate[] = [\n      // Bit 0\n      { op: \"XOR\", in1: \"x00\", in2: \"y00\", out: \"z00\" },\n      { op: \"AND\", in1: \"x00\", in2: \"y00\", out: \"c00\" },\n      // Bit 1\n      { op: \"XOR\", in1: \"x01\", in2: \"y01\", out: \"t01\" },\n      { op: \"XOR\", in1: \"t01\", in2: \"c00\", out: \"z01\" },\n      { op: \"AND\", in1: \"x01\", in2: \"y01\", out: \"a01\" },\n      { op: \"AND\", in1: \"t01\", in2: \"c00\", out: \"b01\" },\n      { op: \"OR\", in1: \"a01\", in2: \"b01\", out: \"z02\" },\n    ];\n\n    // 1 + 1 = 2 (binary: 01 + 01 = 10)\n    const result1 = simulate(gates, { x00: 1, x01: 0, y00: 1, y01: 0 });\n    expect(result1.z00).toBe(0);\n    expect(result1.z01).toBe(1);\n    expect(result1.z02).toBe(0);\n\n    // 3 + 1 = 4 (binary: 11 + 01 = 100)\n    const result2 = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 0 });\n    expect(result2.z00).toBe(0);\n    expect(result2.z01).toBe(0);\n    expect(result2.z02).toBe(1);\n\n    // 3 + 3 = 6 (binary: 11 + 11 = 110)\n    const result3 = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n    expect(result3.z00).toBe(0);\n    expect(result3.z01).toBe(1);\n    expect(result3.z02).toBe(1);\n  });\n});\n\ndescribe(\"findSwappedWires\", () => {\n  function make4BitAdder(): Gate[] {\n    return [\n      // Bit 0\n      { op: \"XOR\", in1: \"x00\", in2: \"y00\", out: \"z00\" },\n      { op: \"AND\", in1: \"x00\", in2: \"y00\", out: \"c00\" },\n      // Bit 1\n      { op: \"XOR\", in1: \"x01\", in2: \"y01\", out: \"t01\" },\n      { op: \"XOR\", in1: \"t01\", in2: \"c00\", out: \"z01\" },\n      { op: \"AND\", in1: \"x01\", in2: \"y01\", out: \"a01\" },\n      { op: \"AND\", in1: \"t01\", in2: \"c00\", out: \"b01\" },\n      { op: \"OR\", in1: \"a01\", in2: \"b01\", out: \"c01\" },\n      // Bit 2\n      { op: \"XOR\", in1: \"x02\", in2: \"y02\", out: \"t02\" },\n      { op: \"XOR\", in1: \"t02\", in2: \"c01\", out: \"z02\" },\n      { op: \"AND\", in1: \"x02\", in2: \"y02\", out: \"a02\" },\n      { op: \"AND\", in1: \"t02\", in2: \"c01\", out: \"b02\" },\n      { op: \"OR\", in1: \"a02\", in2: \"b02\", out: \"c02\" },\n      // Bit 3\n      { op: \"XOR\", in1: \"x03\", in2: \"y03\", out: \"t03\" },\n      { op: \"XOR\", in1: \"t03\", in2: \"c02\", out: \"z03\" },\n      { op: \"AND\", in1: \"x03\", in2: \"y03\", out: \"a03\" },\n      { op: \"AND\", in1: \"t03\", in2: \"c02\", out: \"b03\" },\n      { op: \"OR\", in1: \"a03\", in2: \"b03\", out: \"z04\" },\n    ];\n  }\n\n  function swapOutputs(gates: Gate[], out1: string, out2: string): void {\n    const g1 = gates.find((g) => g.out === out1)!;\n    const g2 = gates.find((g) => g.out === out2)!;\n    g1.out = out2;\n    g2.out = out1;\n  }\n\n  it(\"should find swapped z and intermediate wires\", () => {\n    const gates = make4BitAdder();\n    // Swap 1: z01 <-> a01\n    swapOutputs(gates, \"z01\", \"a01\");\n    // Swap 2: z02 <-> t02\n    swapOutputs(gates, \"z02\", \"t02\");\n    // Swap 3: b03 <-> c02\n    swapOutputs(gates, \"b03\", \"c02\");\n    // Swap 4: z04 <-> c00\n    swapOutputs(gates, \"z04\", \"c00\");\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      [\"a01\", \"b03\", \"c00\", \"c02\", \"t02\", \"z01\", \"z02\", \"z04\"].sort(),\n    );\n  });\n\n  it(\"should find swapped carry and z wires\", () => {\n    const gates = make4BitAdder();\n    // Swap 1: z01 <-> t01\n    swapOutputs(gates, \"z01\", \"t01\");\n    // Swap 2: c01 <-> a02\n    swapOutputs(gates, \"c01\", \"a02\");\n    // Swap 3: z03 <-> b03\n    swapOutputs(gates, \"z03\", \"b03\");\n    // Swap 4: z04 <-> c02\n    swapOutputs(gates, \"z04\", \"c02\");\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      [\"a02\", \"b03\", \"c01\", \"c02\", \"t01\", \"z01\", \"z03\", \"z04\"].sort(),\n    );\n  });\n\n  it(\"should handle swaps at bit 0 and across bits\", () => {\n    const gates = make4BitAdder();\n    // Swap 1: z00 <-> c00  (bit 0 half-adder outputs swapped)\n    swapOutputs(gates, \"z00\", \"c00\");\n    // Swap 2: z01 <-> t01  (bit 1 XOR outputs swapped)\n    swapOutputs(gates, \"z01\", \"t01\");\n    // Swap 3: z02 <-> a02  (bit 2 sum and generate swapped)\n    swapOutputs(gates, \"z02\", \"a02\");\n    // Swap 4: z03 <-> c01  (bit 3 sum and bit 1 carry swapped)\n    swapOutputs(gates, \"z03\", \"c01\");\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      [\"a02\", \"c00\", \"c01\", \"t01\", \"z00\", \"z01\", \"z02\", \"z03\"].sort(),\n    );\n  });\n});\n","structuredPatch":[{"oldStart":154,"oldLines":4,"newStart":154,"newLines":84,"lines":["       [\"a02\", \"c00\", \"c01\", \"t01\", \"z00\", \"z01\", \"z02\", \"z03\"].sort(),","     );","   });","+","+  it(\"should handle a larger adder with random wire names\", () => {","+    // 8-bit adder with random wire names","+    const gates: Gate[] = [","+      // Bit 0","+      { op: \"XOR\", in1: \"x00\", in2: \"y00\", out: \"z00\" },","+      { op: \"AND\", in1: \"x00\", in2: \"y00\", out: \"rvw\" },","+      // Bit 1","+      { op: \"XOR\", in1: \"x01\", in2: \"y01\", out: \"pqr\" },","+      { op: \"XOR\", in1: \"pqr\", in2: \"rvw\", out: \"z01\" },","+      { op: \"AND\", in1: \"x01\", in2: \"y01\", out: \"abc\" },","+      { op: \"AND\", in1: \"pqr\", in2: \"rvw\", out: \"def\" },","+      { op: \"OR\", in1: \"abc\", in2: \"def\", out: \"ghi\" },","+      // Bit 2","+      { op: \"XOR\", in1: \"x02\", in2: \"y02\", out: \"jkl\" },","+      { op: \"XOR\", in1: \"jkl\", in2: \"ghi\", out: \"z02\" },","+      { op: \"AND\", in1: \"x02\", in2: \"y02\", out: \"mno\" },","+      { op: \"AND\", in1: \"jkl\", in2: \"ghi\", out: \"stu\" },","+      { op: \"OR\", in1: \"mno\", in2: \"stu\", out: \"vwx\" },","+      // Bit 3","+      { op: \"XOR\", in1: \"x03\", in2: \"y03\", out: \"yza\" },","+      { op: \"XOR\", in1: \"yza\", in2: \"vwx\", out: \"z03\" },","+      { op: \"AND\", in1: \"x03\", in2: \"y03\", out: \"bzc\" },","+      { op: \"AND\", in1: \"yza\", in2: \"vwx\", out: \"dzf\" },","+      { op: \"OR\", in1: \"bzc\", in2: \"dzf\", out: \"fzg\" },","+      // Bit 4","+      { op: \"XOR\", in1: \"x04\", in2: \"y04\", out: \"hzk\" },","+      { op: \"XOR\", in1: \"hzk\", in2: \"fzg\", out: \"z04\" },","+      { op: \"AND\", in1: \"x04\", in2: \"y04\", out: \"kzl\" },","+      { op: \"AND\", in1: \"hzk\", in2: \"fzg\", out: \"mzn\" },","+      { op: \"OR\", in1: \"kzl\", in2: \"mzn\", out: \"nzo\" },","+      // Bit 5","+      { op: \"XOR\", in1: \"x05\", in2: \"y05\", out: \"pzq\" },","+      { op: \"XOR\", in1: \"pzq\", in2: \"nzo\", out: \"z05\" },","+      { op: \"AND\", in1: \"x05\", in2: \"y05\", out: \"qzr\" },","+      { op: \"AND\", in1: \"pzq\", in2: \"nzo\", out: \"szx\" },","+      { op: \"OR\", in1: \"qzr\", in2: \"szx\", out: \"tzy\" },","+      // Bit 6","+      { op: \"XOR\", in1: \"x06\", in2: \"y06\", out: \"uuu\" },","+      { op: \"XOR\", in1: \"uuu\", in2: \"tzy\", out: \"z06\" },","+      { op: \"AND\", in1: \"x06\", in2: \"y06\", out: \"vvv\" },","+      { op: \"AND\", in1: \"uuu\", in2: \"tzy\", out: \"www\" },","+      { op: \"OR\", in1: \"vvv\", in2: \"www\", out: \"xxx\" },","+      // Bit 7","+      { op: \"XOR\", in1: \"x07\", in2: \"y07\", out: \"yyy\" },","+      { op: \"XOR\", in1: \"yyy\", in2: \"xxx\", out: \"z07\" },","+      { op: \"AND\", in1: \"x07\", in2: \"y07\", out: \"zzz\" },","+      { op: \"AND\", in1: \"yyy\", in2: \"xxx\", out: \"aab\" },","+      { op: \"OR\", in1: \"zzz\", in2: \"aab\", out: \"z08\" },","+    ];","+","+    // Swap 1: z01 <-> pqr (bit 1: sum and partial sum)","+    swapOutputs(gates, \"z01\", \"pqr\");","+    // Swap 2: z03 <-> yza (bit 3: sum and partial sum)","+    swapOutputs(gates, \"z03\", \"yza\