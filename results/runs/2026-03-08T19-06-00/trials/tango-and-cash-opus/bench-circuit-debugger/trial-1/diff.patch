\n}\n\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>,\n): Record<string, number> {\n  const values: Record<string, number> = { ...inputs };\n  const remaining = new Set<number>(gates.map((_, i) => i));\n\n  let progress = true;\n  while (progress) {\n    progress = false;\n    for (const i of remaining) {\n      const gate = gates[i];\n      if (values[gate.in1] !== undefined && values[gate.in2] !== undefined) {\n        const v1 = values[gate.in1];\n        const v2 = values[gate.in2];\n        switch (gate.op) {\n          case \"AND\":\n            values[gate.out] = v1 & v2;\n            break;\n          case \"OR\":\n            values[gate.out] = v1 | v2;\n            break;\n          case \"XOR\":\n            values[gate.out] = v1 ^ v2;\n            break;\n        }\n        remaining.delete(i);\n        progress = true;\n      }\n    }\n  }\n\n  return values;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped: string[] = [];\n\n  // Find the number of output bits\n  let maxZ = 0;\n  for (const g of gates) {\n    if (g.out.startsWith(\"z\")) {\n      const num = parseInt(g.out.slice(1), 10);\n      if (num > maxZ) maxZ = num;\n    }\n  }\n\n  const pad = (n: number): string => n.toString().padStart(2, \"0\");\n  const lastZ = `z${pad(maxZ)}`;\n\n  // Swap two gate outputs and record them\n  const doSwap = (a: string, b: string): void => {\n    swapped.push(a, b);\n    const ga = gates.find((g) => g.out === a);\n    const gb = gates.find((g) => g.out === b);\n    if (ga && gb) {\n      ga.out = b;\n      gb.out = a;\n    }\n  };\n\n  // Find a gate by its operation and inputs (order-independent)\n  const findGate = (\n    op: string,\n    in1: string,\n    in2: string,\n  ): Gate | undefined => {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1)),\n    );\n  };\n\n  // Find a gate that uses a specific wire as one of its inputs\n  const findGateWithInput = (op: string, wire: string): Gate | undefined => {\n    return gates.find(\n      (g) => g.op === op && (g.in1 === wire || g.in2 === wire),\n    );\n  };\n\n  const otherInput = (g: Gate, wire: string): string => {\n    return g.in1 === wire ? g.in2 : g.in1;\n  };\n\n  let carry = \"\";\n\n  for (let i = 0; i < maxZ; i++) {\n    const x = `x${pad(i)}`;\n    const y = `y${pad(i)}`;\n    const z = `z${pad(i)}`;\n\n    if (i === 0) {\n      // Bit 0: half adder\n      const xorGate = findGate(\"XOR\", x, y);\n      const andGate = findGate(\"AND\", x, y);\n      if (!xorGate || !andGate) continue;\n\n      if (xorGate.out !== z) {\n        doSwap(xorGate.out, z);\n      }\n      carry = andGate.out;\n    } else {\n      // Bit N: full adder\n      const xor1 = findGate(\"XOR\", x, y);\n      const and1 = findGate(\"AND\", x, y);\n      if (!xor1 || !and1) continue;\n\n      let w = xor1.out; // partial sum wire\n      let generate = and1.out; // generate carry wire\n\n      // Rule: partial sum (XOR of xN, yN) should NOT output directly to z\n      // (only the second XOR should output to z)\n      if (w.startsWith(\"z\") && w !== lastZ) {\n        // w is incorrectly going to a z wire. Find what should be w by\n        // looking for the XOR gate that uses carry as input - its other\n        // input should be w.\n        const carryXor = findGateWithInput(\"XOR\", carry);\n        if (carryXor) {\n          const correctW = otherInput(carryXor, carry);\n          doSwap(w, correctW);\n          w = correctW;\n        }\n      }\n\n      // Find second XOR: partial_sum XOR carry -> zN\n      let xor2 = findGate(\"XOR\", w, carry);\n\n      if (!xor2) {\n        // Maybe generate and w got swapped\n        const altXor2 = findGate(\"XOR\", generate, carry);\n        if (altXor2) {\n          doSwap(w, generate);\n          const tmp = w;\n          w = generate;\n          generate = tmp;\n          xor2 =