+export interface Gate {
+  op: "AND" | "OR" | "XOR";
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const values: Record<string, number> = { ...inputs };
+  const remaining = new Set<number>(gates.map((_, i) => i));
+
+  let progress = true;
+  while (progress) {
+    progress = false;
+    for (const i of remaining) {
+      const gate = gates[i];
+      if (values[gate.in1] !== undefined && values[gate.in2] !== undefined) {
+        const v1 = values[gate.in1];
+        const v2 = values[gate.in2];
+        switch (gate.op) {
+          case "AND":
+            values[gate.out] = v1 & v2;
+            break;
+          case "OR":
+            values[gate.out] = v1 | v2;
+            break;
+          case "XOR":
+            values[gate.out] = v1 ^ v2;
+            break;
+        }
+        remaining.delete(i);
+        progress = true;
+      }
+    }
+  }
+
+  return values;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const swapped: string[] = [];
+
+  // Find the number of output bits
+  let maxZ = 0;
+  for (const g of gates) {
+    if (g.out.startsWith("z")) {
+      const num = parseInt(g.out.slice(1), 10);
+      if (num > maxZ) maxZ = num;
+    }
+  }
+
+  const pad = (n: number): string => n.toString().padStart(2, "0");
+  const lastZ = `z${pad(maxZ)}`;
+
+  // Swap two gate outputs and record them
+  const doSwap = (a: string, b: string): void => {
+    swapped.push(a, b);
+    const ga = gates.find((g) => g.out === a);
+    const gb = gates.find((g) => g.out === b);
+    if (ga && gb) {
+      ga.out = b;
+      gb.out = a;
+    }
+  };
+
+  // Find a gate by its operation and inputs (order-independent)
+  const findGate = (
+    op: string,
+    in1: string,
+    in2: string,
+  ): Gate | undefined => {
+    return gates.find(
+      (g) =>
+        g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) ||
+          (g.in1 === in2 && g.in2 === in1)),
+    );
+  };
+
+  // Find a gate that uses a specific wire as one of its inputs
+  const findGateWithInput = (op: string, wire: string): Gate | undefined => {
+    return gates.find(
+      (g) => g.op === op && (g.in1 === wire || g.in2 === wire),
+    );
+  };
+
+  const otherInput = (g: Gate, wire: string): string => {
+    return g.in1 === wire ? g.in2 : g.in1;
+  };
+
+  let carry = "";
+
+  for (let i = 0; i < maxZ; i++) {
+    const x = `x${pad(i)}`;
+    const y = `y${pad(i)}`;
+    const z = `z${pad(i)}`;
+
+    if (i === 0) {
+      // Bit 0: half adder
+      const xorGate = findGate("XOR", x, y);
+      const andGate = findGate("AND", x, y);
+      if (!xorGate || !andGate) continue;
+
+      if (xorGate.out !== z) {
+        doSwap(xorGate.out, z);
+      }
+      carry = andGate.out;
+    } else {
+      // Bit N: full adder
+      const xor1 = findGate("XOR", x, y);
+      const and1 = findGate("AND", x, y);
+      if (!xor1 || !and1) continue;
+
+      let w = xor1.out; // partial sum wire
+      let generate = and1.out; // generate carry wire
+
+      // Rule: partial sum (XOR of xN, yN) should NOT output directly to z
+      // (only the second XOR should output to z)
+      if (w.startsWith("z") && w !== lastZ) {
+        // w is incorrectly going to a z wire. Find what should be w by
+        // looking for the XOR gate that uses carry as input - its other
+        // input should be w.
+        const carryXor = findGateWithInput("XOR", carry);
+        if (carryXor) {
+          const correctW = otherInput(carryXor, carry);
+          doSwap(w, correctW);
+          w = correctW;
+        }
+      }
+
+      // Find second XOR: partial_sum XOR carry -> zN
+      let xor2 = findGate("XOR", w, carry);
+
+      if (!xor2) {
+        // Maybe generate and w got swapped
+        const altXor2 = findGate("XOR", generate, carry);
+        if (altXor2) {
+          doSwap(w, generate);
+          const tmp = w;
+          w = generate;
+          generate = tmp;
+          xor2 = altXor2;
+        } else {
+          // Try finding any XOR that uses w
+          const wxor = findGateWithInput("XOR", w);
+          if (wxor) {
+            const expectedCarry = otherInput(wxor, w);
+            if (carry !== expectedCarry) {
+              doSwap(carry, expectedCarry);
+              carry = expectedCarry;
+            }
+            xor2 = wxor;
+          }
+        }
+      }
+
+      if (xor2 && xor2.out !== z) {
+        doSwap(xor2.out, z);
+      }
+
+      // Refresh generate after potential swaps
+      generate = and1.out;
+
+      // Find propagate gate: partial_sum AND carry -> propagate
+      const propGate = findGate("AND", w, carry);
+      let propagate = propGate ? propGate.out : "";
+
+      // Find OR gate: generate OR propagate -> carry_out
+      let orGate: Gate | undefined;
+      if (propagate) {
+        orGate = findGate("OR", generate, propagate);
+      }
+
+      if (!orGate) {
+        // Try to find the OR gate via one known input
+        if (propagate) {
+          orGate = findGateWithInput("OR", propagate);
+          if (orGate) {
+            const expectedGen = otherInput(orGate, propagate);
+            if (generate !== expectedGen) {
+              doSwap(generate, expectedGen);
+              generate = expectedGen;
+            }
+          }
+        }
+        if (!orGate && generate) {
+          orGate = findGateWithInput("OR", generate);
+          if (orGate) {
+            const expectedProp = otherInput(orGate, generate);
+            if (propagate !== expectedProp) {
+              doSwap(propagate, expectedProp);
+              propagate = expectedProp;
+            }
+          }
+        }
+      }
+
+      if (orGate) {
+        carry = orGate.out;
+      }
+    }
+  }
+
+  // Final carry should be the last z bit
+  if (carry !== lastZ) {
+    doSwap(carry, lastZ);
+  }
+
+  return [...new Set(swapped)].sort();
+}
