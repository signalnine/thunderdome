@@ -0,0 +1,481 @@
+import { describe, it, expect } from 'vitest';
+import { schedule, Event, Room, ScheduleOptions } from './scheduler.js';
+
+const defaultOptions: ScheduleOptions = {
+  startTime: 540, // 9:00 AM
+  endTime: 1020,  // 5:00 PM
+};
+
+const rooms: Room[] = [
+  { id: 'room-a', name: 'Room A', capacity: 10 },
+  { id: 'room-b', name: 'Room B', capacity: 20 },
+  { id: 'room-c', name: 'Room C', capacity: 50 },
+];
+
+describe('schedule', () => {
+  describe('basic scheduling', () => {
+    it('should schedule a single event', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting', duration: 60 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+      expect(result.assignments[0].eventId).toBe('e1');
+      expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(540);
+      expect(result.assignments[0].endTime).toBeLessThanOrEqual(1020);
+      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);
+    });
+
+    it('should schedule multiple events', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting 1', duration: 60 },
+        { id: 'e2', name: 'Meeting 2', duration: 90 },
+        { id: 'e3', name: 'Meeting 3', duration: 30 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(3);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should handle empty events list', () => {
+      const result = schedule([], rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('should default attendees to 1', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Solo Meeting', duration: 60 },
+      ];
+      const smallRooms: Room[] = [
+        { id: 'r1', name: 'Phone Booth', capacity: 1 },
+      ];
+      const result = schedule(events, smallRooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].roomId).toBe('r1');
+    });
+  });
+
+  describe('room capacity', () => {
+    it('should not assign event to room with insufficient capacity', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Big Meeting', duration: 60, attendees: 25 },
+      ];
+      const smallRooms: Room[] = [
+        { id: 'r1', name: 'Small Room', capacity: 10 },
+      ];
+      const result = schedule(events, smallRooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['e1']);
+    });
+
+    it('should assign event to room with exact capacity', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting', duration: 60, attendees: 10 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(1);
+      // Should fit in room-a (capacity 10) since attendees = 10
+      expect(result.assignments[0].roomId).toBe('room-a');
+    });
+
+    it('should assign large events to rooms with sufficient capacity', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Conference', duration: 60, attendees: 45 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].roomId).toBe('room-c'); // Only room-c fits 45
+    });
+  });
+
+  describe('time window constraints', () => {
+    it('should respect start and end time', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting', duration: 60 },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+
+      const assignment = result.assignments[0];
+      expect(assignment.startTime).toBeGreaterThanOrEqual(540);
+      expect(assignment.endTime).toBeLessThanOrEqual(1020);
+    });
+
+    it('should mark events as unscheduled if they dont fit in the window', () => {
+      const tightOptions: ScheduleOptions = {
+        startTime: 540,
+        endTime: 570, // Only 30 minutes
+      };
+      const events: Event[] = [
+        { id: 'e1', name: 'Long Meeting', duration: 60 },
+      ];
+      const result = schedule(events, rooms, tightOptions);
+
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['e1']);
+    });
+
+    it('should fit events exactly within the window', () => {
+      const tightOptions: ScheduleOptions = {
+        startTime: 540,
+        endTime: 600, // Exactly 60 minutes
+        gap: 0,
+      };
+      const events: Event[] = [
+        { id: 'e1', name: 'Exact Fit', duration: 60 },
+      ];
+      const result = schedule(events, rooms, tightOptions);
+
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].startTime).toBe(540);
+      expect(result.assignments[0].endTime).toBe(600);
+    });
+  });
+
+  describe('room gaps', () => {
+    it('should enforce default 15-minute gap between events in same room', () => {
+      const singleRoom: Room[] = [
+        { id: 'r1', name: 'Room 1', capacity: 100 },
+      ];
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting 1', duration: 60 },
+        { id: 'e2', name: 'Meeting 2', duration: 60 },
+      ];
+      const result = schedule(events, singleRoom, defaultOptions);
+
+      expect(result.assignments).toHaveLength(2);
+      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime + 15);
+    });
+
+    it('should use custom gap when specified', () => {
+      const singleRoom: Room[] = [
+        { id: 'r1', name: 'Room 1', capacity: 100 },
+      ];
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting 1', duration: 60 },
+        { id: 'e2', name: 'Meeting 2', duration: 60 },
+      ];
+      const opts: ScheduleOptions = { ...defaultOptions, gap: 30 };
+      const result = schedule(events, singleRoom, opts);
+
+      expect(result.assignments).toHaveLength(2);
+      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime + 30);
+    });
+
+    it('should allow zero gap', () => {
+      const singleRoom: Room[] = [
+        { id: 'r1', name: 'Room 1', capacity: 100 },
+      ];
+      const events: Event[] = [
+        { id: 'e1', name: 'Meeting 1', duration: 60 },
+        { id: 'e2', name: 'Meeting 2', duration: 60 },
+      ];
+      const opts: ScheduleOptions = { ...defaultOptions, gap: 0 };
+      const result = schedule(events, singleRoom, opts);
+
+      expect(result.assignments).toHaveLength(2);
+      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);
+      // With zero gap, second can start immediately after first
+      expect(sorted[1].startTime).toBeGreaterThanOrEqual(sorted[0].endTime);
+    });
+  });
+
+  describe('prerequisites', () => {
+    it('should schedule prerequisite before dependent event', () => {
+      const events: Event[] = [
+        { id: 'e1', name: 'Setup', duration: 30 },
+        { id: 'e2', name: 'Main Event', duration: 60, prerequisites: ['e1'] },
+      ];
+      const result = schedule(events, rooms, defaultOptions);
+
+      expect(result.assignments).toHaveLength(2);
+      const e1 = result.assignments.find(a => a.eventId === 'e1')!;
+      const e2 = result.assignments.find(a => a.eventId === 'e2')!;
+      expect(e2.startTime).toBeGreaterThanOrEqual(e1.endTime + 15); // default gap
