@@ -0,0 +1,379 @@
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+/**
+ * Detect cycles in the prerequisite graph using DFS.
+ * Returns the topological order if no cycles exist.
+ * Throws if a cycle (including self-references) is detected.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map(e => e.id));
+  const adjacency = new Map<string, string[]>();
+  const inDegree = new Map<string, number>();
+
+  for (const ev of events) {
+    adjacency.set(ev.id, []);
+    inDegree.set(ev.id, 0);
+  }
+
+  for (const ev of events) {
+    if (!ev.prerequisites) continue;
+    for (const prereq of ev.prerequisites) {
+      if (!eventIds.has(prereq)) continue;
+      // prereq -> ev.id (prereq must come before ev)
+      adjacency.get(prereq)!.push(ev.id);
+      inDegree.set(ev.id, inDegree.get(ev.id)! + 1);
+
+      // Self-reference check
+      if (prereq === ev.id) {
+        throw new Error('Prerequisite cycle detected');
+      }
+    }
+  }
+
+  // Kahn's algorithm
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const order: string[] = [];
+  while (queue.length > 0) {
+    const curr = queue.shift()!;
+    order.push(curr);
+    for (const neighbor of adjacency.get(curr) || []) {
+      const newDeg = inDegree.get(neighbor)! - 1;
+      inDegree.set(neighbor, newDeg);
+      if (newDeg === 0) queue.push(neighbor);
+    }
+  }
+
+  if (order.length !== events.length) {
+    throw new Error('Prerequisite cycle detected');
+  }
+
+  return order;
+}
+
+/**
+ * Find the earliest valid start time for an event in a room,
+ * given existing assignments and constraints.
+ */
+function findEarliestStart(
+  duration: number,
+  roomId: string,
+  earliestPossible: number,
+  endTime: number,
+  gap: number,
+  roomAssignments: Assignment[]
+): number | null {
+  const relevantAssignments = roomAssignments
+    .filter(a => a.roomId === roomId)
+    .sort((a, b) => a.startTime - b.startTime);
+
+  // Try starting at the earliest possible time
+  let candidate = earliestPossible;
+
+  if (candidate + duration > endTime) return null;
+
+  for (const existing of relevantAssignments) {
+    // Check if we can fit before this existing assignment
+    if (candidate + duration + gap <= existing.startTime) {
+      // Fits before this assignment
+      return candidate;
+    }
+    // Move candidate to after this assignment
+    candidate = Math.max(candidate, existing.endTime + gap);
+    if (candidate + duration > endTime) return null;
+  }
+
+  // Check if we can fit after all existing assignments
+  if (candidate + duration <= endTime) {
+    return candidate;
+  }
+
+  return null;
+}
+
+/**
+ * Get all possible start times for an event in a room.
+ */
+function getAllPossibleStarts(
+  duration: number,
+  roomId: string,
+  earliestPossible: number,
+  endTime: number,
+  gap: number,
+  roomAssignments: Assignment[]
+): number[] {
+  const relevantAssignments = roomAssignments
+    .filter(a => a.roomId === roomId)
+    .sort((a, b) => a.startTime - b.startTime);
+
+  const starts: number[] = [];
+
+  // Candidate slots: before each existing assignment, and after the last one
+  let slotStart = earliestPossible;
+
+  for (const existing of relevantAssignments) {
+    // Try fitting in the gap before this assignment
+    if (slotStart + duration + gap <= existing.startTime) {
+      starts.push(slotStart);
+    }
+    slotStart = Math.max(slotStart, existing.endTime + gap);
+  }
+
+  // After all assignments
+  if (slotStart + duration <= endTime) {
+    starts.push(slotStart);
+  }
+
+  return starts;
+}
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  // Detect cycles and get topological order
+  const topoOrder = topologicalSort(events);
+
+  const eventMap = new Map(events.map(e => [e.id, e]));
+
+  // Sort rooms by capacity ascending (fit tighter first)
+  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);
+
+  // Build a priority ordering: topological order first, then most constrained
+  // (fewest valid rooms, then longest duration)
+  const topoIndex = new Map(topoOrder.map((id, i) => [id, i]));
+
+  const orderedEvents = [...events].sort((a, b) => {
+    const ai = topoIndex.get(a.id) ?? 0;
+    const bi = topoIndex.get(b.id) ?? 0;
+
+    // Respect topological ordering first
+    if (ai !== bi) return ai - bi;
+
+    // Then most constrained (fewer room options) first
+    const aRooms = sortedRooms.filter(r => r.capacity >= (a.attendees ?? 1)).length;
+    const bRooms = sortedRooms.filter(r => r.capacity >= (b.attendees ?? 1)).length;
+    if (aRooms !== bRooms) return aRooms - bRooms;
+
+    // Longer events first (harder to place)
+    return b.duration - a.duration;
+  });
+
+  // Use backtracking with pruning to maximize scheduled events
+  let bestAssignments: Assignment[] = [];
+  let bestCount = 0;
+  let iterations = 0;
+  const MAX_ITERATIONS = 200000;
+
+  function backtrack(
+    eventIndex: number,
+    currentAssignments: Assignment[],
+    assignmentMap: Map<string, Assignment>
+  ): void {
+    if (iterations++ > MAX_ITERATIONS) return;
+
+    // Update best if current is better
+    if (currentAssignments.length > bestCount) {
+      bestCount = currentAssignments.length;
+      bestAssignments = currentAssignments.map(a => ({ ...a }));
+    }
+
+    // If we've scheduled everything, we're done
+    if (bestCount === events.length) return;
+
+    // If we've processed all events, return
+    if (eventIndex >= orderedEvents.length) return;
+
+    // Pruning: even if we schedule everything remaining, can we beat best?
+    const remaining = orderedEvents.length - eventIndex;
+    if (currentAssignments.length + remaining <= bestCount) return;
+
+    const ev = orderedEvents[eventIndex];
+    const attendees = ev.attendees ?? 1;
+
+    // Check prerequisites are met
+    let earliestStart = options.startTime;
+    let prereqsMet = true;
+
+    if (ev.prerequisites) {
+      for (const prereqId of ev.prerequisites) {
+        if (!eventMap.has(prereqId)) continue; // Prerequisite not in event list
+        const prereqAssignment = assignmentMap.get(prereqId);
+        if (!prereqAssignment) {
+          prereqsMet = false;
+          break;
+        }
+        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);
+      }
+    }
+
+    if (prereqsMet && earliestStart + ev.duration <= options.endTime) {
+      // Get candidate rooms, putting preferred room first
+      const candidateRooms = sortedRooms.filter(r => r.capacity >= attendees);
+
+      // Sort: preferred room first, then by capacity ascending
+      if (ev.preferredRoom) {
+        candidateRooms.sort((a, b) => {
+          if (a.id === ev.preferredRoom && b.id !== ev.preferredRoom) return -1;
+          if (b.id === ev.preferredRoom && a.id !== ev.preferredRoom) return 1;
+          return a.capacity - b.capacity;
+        });
+      }
+
+      for (const room of candidateRooms) {
+        // Find all possible start times for this event in this room
+        const possibleStarts = getAllPossibleStarts(
+          ev.duration,
+          room.id,
+          earliestStart,
+          options.endTime,
+          gap,
+          currentAssignments
+        );
+
+        for (const startTime of possibleStarts) {
+          const assignment: Assignment = {
+            eventId: ev.id,
+            roomId: room.id,
+            startTime,
+            endTime: startTime + ev.duration,
+          };
+
+          currentAssignments.push(assignment);
+          assignmentMap.set(ev.id, assignment);
+
+          backtrack(eventIndex + 1, currentAssignments, assignmentMap);
+
+          // If we've found a perfect solution, stop
+          if (bestCount === events.length) return;
+
+          currentAssignments.pop();
+          assignmentMap.delete(ev.id);
+
+          // Only try the earliest start per room to limit branching
+          break;
+        }
+      }
+    }
+
+    // Try skipping this event (it goes to unscheduled)
+    backtrack(eventIndex + 1, currentAssignments, assignmentMap);
+  }
+
+  // First, try a greedy pass to get a good initial solution
+  const greedyAssignments: Assignment[] = [];
+  const greedyMap = new Map<string, Assignment>();
+
+  for (const ev of orderedEvents) {
+    const attendees = ev.attendees ?? 1;
+    let earliestStart = options.startTime;
+    let prereqsMet = true;
+
+    if (ev.prerequisites) {
+      for (const prereqId of ev.prerequisites) {
+        if (!eventMap.has(prereqId)) continue;
+        const prereqAssignment = greedyMap.get(prereqId);
+        if (!prereqAssignment) {
+          prereqsMet = false;
+          break;
+        }
+        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);
+      }
+    }
+
+    if (!prereqsMet || earliestStart + ev.duration > options.endTime) continue;
+
+    const candidateRooms = sortedRooms.filter(r => r.capacity >= attendees);
+    if (ev.preferredRoom) {
+      candidateRooms.sort((a, b) => {
+        if (a.id === ev.preferredRoom && b.id !== ev.preferredRoom) return -1;
+        if (b.id === ev.preferredRoom && a.id !== ev.preferredRoom) return 1;
+        return a.capacity - b.capacity;
+      });
+    }
+
+    for (const room of candidateRooms) {
+      const startTime = findEarliestStart(
+        ev.duration,
+        room.id,
+        earliestStart,
+        options.endTime,
+        gap,
+        greedyAssignments
+      );
+
+      if (startTime !== null) {
+        const assignment: Assignment = {
+          eventId: ev.id,
+          roomId: room.id,
+          startTime,
+          endTime: startTime + ev.duration,
+        };
+        greedyAssignments.push(assignment);
+        greedyMap.set(ev.id, assignment);
+        break;
+      }
+    }
+  }
+
+  // Start with greedy solution as the baseline
+  bestAssignments = [...greedyAssignments];
+  bestCount = greedyAssignments.length;
+
+  // If greedy scheduled everything, we're done
+  if (bestCount < events.length) {
+    // Run backtracking to try to improve
+    backtrack(0, [], new Map());
+  }
+
+  const scheduledIds = new Set(bestAssignments.map(a => a.eventId));
+  const unscheduled = events
+    .filter(e => !scheduledIds.has(e.id))
+    .map(e => e.id);
+
+  return {
+    assignments: bestAssignments,
+    unscheduled,
+  };
+}
