ime + 15); // default gap\n    });\n\n    it('should handle chain of prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Step 1', duration: 30 },\n        { id: 'e2', name: 'Step 2', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Step 3', duration: 30, prerequisites: ['e2'] },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      const e1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const e3 = result.assignments.find(a => a.eventId === 'e3')!;\n\n      expect(e2.startTime).toBeGreaterThanOrEqual(e1.endTime + 15);\n      expect(e3.startTime).toBeGreaterThanOrEqual(e2.endTime + 15);\n    });\n\n    it('should handle multiple prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Prereq 1', duration: 30 },\n        { id: 'e2', name: 'Prereq 2', duration: 30 },\n        { id: 'e3', name: 'Dependent', duration: 30, prerequisites: ['e1', 'e2'] },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(3);\n      const e1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const e3 = result.assignments.find(a => a.eventId === 'e3')!;\n\n      expect(e3.startTime).toBeGreaterThanOrEqual(e1.endTime + 15);\n      expect(e3.startTime).toBeGreaterThanOrEqual(e2.endTime + 15);\n    });\n\n    it('should not schedule dependent event if prerequisite cannot be scheduled', () => {\n      const tinyRoom: Room[] = [\n        { id: 'r1', name: 'Tiny', capacity: 5 },\n      ];\n      const events: Event[] = [\n        { id: 'e1', name: 'Big Event', duration: 30, attendees: 100 }, // Can't fit\n        { id: 'e2', name: 'Dependent', duration: 30, prerequisites: ['e1'] },\n      ];\n      const result = schedule(events, tinyRoom, defaultOptions);\n\n      expect(result.unscheduled).toContain('e1');\n      expect(result.unscheduled).toContain('e2');\n    });\n  });\n\n  describe('prerequisite cycles', () => {\n    it('should throw on self-reference', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Self Ref', duration: 30, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow(/cycle/i);\n    });\n\n    it('should throw on direct cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 30, prerequisites: ['e2'] },\n        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow(/cycle/i);\n    });\n\n    it('should throw on indirect cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 30, prerequisites: ['e3'] },\n        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },\n      ];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow(/cycle/i);\n    });\n  });\n\n  describe('preferred room', () => {\n    it('should honor preferred room when possible', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Meeting', duration: 60, attendees: 5, preferredRoom: 'room-b' },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n\n    it('should ignore preferred room when capacity is insufficient', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Big Meeting', duration: 60, attendees: 15, preferredRoom: 'room-a' },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      // room-a 