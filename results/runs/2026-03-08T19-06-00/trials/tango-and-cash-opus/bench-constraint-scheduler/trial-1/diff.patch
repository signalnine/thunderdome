rtedRooms.filter(r => r.capacity >= attendees);\n    if (ev.preferredRoom) {\n      candidateRooms.sort((a, b) => {\n        if (a.id === ev.preferredRoom && b.id !== ev.preferredRoom) return -1;\n        if (b.id === ev.preferredRoom && a.id !== ev.preferredRoom) return 1;\n        return a.capacity - b.capacity;\n      });\n    }\n\n    for (const room of candidateRooms) {\n      const startTime = findEarliestStart(\n        ev.duration,\n        room.id,\n        earliestStart,\n        options.endTime,\n        gap,\n        greedyAssignments\n      );\n\n      if (startTime !== null) {\n        const assignment: Assignment = {\n          eventId: ev.id,\n          roomId: room.id,\n          startTime,\n          endTime: startTime + ev.duration,\n        };\n        greedyAssignments.push(assignment);\n        greedyMap.set(ev.id, assignment);\n        break;\n      }\n    }\n  }\n\n  // Start with greedy solution as the baseline\n  bestAssignments = [...greedyAssignments];\n  bestCount = greedyAssignments.length;\n\n  // If greedy scheduled everything, we're done\n  if (bestCount < events.length) {\n    // Run backtracking to try to improve\n    backtrack(0, [], new Map());\n  }\n\n  const scheduledIds = new Set(bestAssignments.map(a => a.eventId));\n  const unscheduled = events\n    .filter(e => !scheduledIds.has(e.id))\n    .map(e => e.id);\n\n  return {\n    assignments: bestAssignments,\n    unscheduled,\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":300,"cache_read_input_tokens":26180,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":300},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"187e2434-2e99-4eea-8f02-6ef295cddc77","uuid":"386ac6d5-2a9c-4629-8bcc-5ffa90619b78"}
