+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function mod(a: number, m: number): number {
+  return ((a % m) + m) % m;
+}
+
+function modInverse(a: number, m: number): number {
+  a = mod(a, m);
+  // Extended Euclidean algorithm
+  let old_r = a, r = m;
+  let old_s = 1, s = 0;
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return mod(old_s, m);
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const numLights = machine.target.length;
+  const numButtons = machine.buttons.length;
+
+  if (numButtons === 0) {
+    // Check if target is all false
+    for (let i = 0; i < numLights; i++) {
+      if (machine.target[i]) return null;
+    }
+    return [];
+  }
+
+  // Build augmented matrix over GF(2): numLights x (numButtons + 1)
+  const matrix: number[][] = Array.from({ length: numLights }, () =>
+    new Array(numButtons + 1).fill(0)
+  );
+
+  for (let j = 0; j < numButtons; j++) {
+    for (const lightIdx of machine.buttons[j]) {
+      if (lightIdx >= 0 && lightIdx < numLights) {
+        matrix[lightIdx][j] ^= 1;
+      }
+    }
+  }
+  for (let i = 0; i < numLights; i++) {
+    matrix[i][numButtons] = machine.target[i] ? 1 : 0;
+  }
+
+  // Gaussian elimination over GF(2) — reduced row echelon form
+  const pivotRow: number[] = []; // pivotRow[r] = column of pivot in row r
+  let row = 0;
+
+  for (let col = 0; col < numButtons && row < numLights; col++) {
+    // Find pivot row
+    let pr = -1;
+    for (let i = row; i < numLights; i++) {
+      if (matrix[i][col] === 1) {
+        pr = i;
+        break;
+      }
+    }
+    if (pr === -1) continue;
+
+    // Swap
+    [matrix[row], matrix[pr]] = [matrix[pr], matrix[row]];
+    pivotRow.push(col);
+
+    // Eliminate all other rows
+    for (let i = 0; i < numLights; i++) {
+      if (i !== row && matrix[i][col] === 1) {
+        for (let k = col; k <= numButtons; k++) {
+          matrix[i][k] ^= matrix[row][k];
+        }
+      }
+    }
+    row++;
+  }
+
+  // Check for inconsistency
+  for (let i = row; i < numLights; i++) {
+    if (matrix[i][numButtons] === 1) return null;
+  }
+
+  const rank = row;
+  const pivotColSet = new Set(pivotRow);
+  const freeCols: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotColSet.has(col)) {
+      freeCols.push(col);
+    }
+  }
+
+  const numFree = freeCols.length;
+
+  // If too many free variables, just use free vars = 0
+  if (numFree > 20) {
+    const solution: number[] = new Array(numButtons).fill(0);
+    for (let r = 0; r < rank; r++) {
+      solution[pivotRow[r]] = matrix[r][numButtons];
+    }
+    const result: number[] = [];
+    for (let i = 0; i < numButtons; i++) {
+      if (solution[i] === 1) result.push(i);
+    }
+    return result;
+  }
+
+  // Enumerate all 2^numFree combinations
+  let bestResult: number[] | null = null;
+  let bestCount = Infinity;
+
+  const numCombos = 1 << numFree;
+  for (let mask = 0; mask < numCombos; mask++) {
+    const solution: number[] = new Array(numButtons).fill(0);
+
+    // Set free variables
+    for (let f = 0; f < numFree; f++) {
+      if ((mask >> f) & 1) {
+        solution[freeCols[f]] = 1;
+      }
+    }
+
+    // Back-substitute pivot variables
+    for (let r = 0; r < rank; r++) {
+      let val = matrix[r][numButtons];
+      for (let f = 0; f < numFree; f++) {
+        if (solution[freeCols[f]] === 1 && matrix[r][freeCols[f]] === 1) {
+          val ^= 1;
+        }
+      }
+      solution[pivotRow[r]] = val;
+    }
+
+    // Count pressed buttons
+    let count = 0;
+    for (let i = 0; i < numButtons; i++) {
+      if (solution[i] === 1) count++;
+    }
+
+    if (count < bestCount) {
+      bestCount = count;
+      bestResult = solution;
+    } else if (count === bestCount && bestResult !== null) {
+      // Compare lexicographic order of index sets
+      // Scan from index 0: first difference decides
+      // solution[i]=0,best[i]=1 => solution set is lex smaller (skips this index)
+      // solution[i]=1,best[i]=0 => solution set is lex larger (includes this index)
+      for (let i = 0; i < numButtons; i++) {
+        if (solution[i] !== bestResult[i]) {
+          if (solution[i] < bestResult[i]) {
+            // solution is lex smaller
+            bestResult = solution;
+          }
+          break;
+        }
+      }
+    }
+  }
+
+  if (bestResult === null) return null;
+
+  const result: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (bestResult[i] === 1) result.push(i);
+  }
+  return result;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numLights = lights.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    for (let i = 0; i < numLights; i++) {
+      if (mod(lights[i], modulus) !== 0) return null;
+    }
+    return [];
+  }
+
+  // Build augmented matrix over GF(modulus): numLights x (numButtons + 1)
+  const matrix: number[][] = Array.from({ length: numLights }, () =>
+    new Array(numButtons + 1).fill(0)
+  );
+
+  for (let j = 0; j < numButtons; j++) {
+    for (const lightIdx of buttons[j]) {
+      if (lightIdx >= 0 && lightIdx < numLights) {
+        matrix[lightIdx][j] = mod(matrix[lightIdx][j] + 1, modulus);
+      }
+    }
+  }
+  for (let i = 0; i < numLights; i++) {
+    matrix[i][numButtons] = mod(lights[i], modulus);
+  }
+
+  // Gaussian elimination over GF(p) — reduced row echelon form
+  const pivotRow: number[] = [];
+  let row = 0;
+
+  for (let col = 0; col < numButtons && row < numLights; col++) {
+    let pr = -1;
+    for (let i = row; i < numLights; i++) {
+      if (matrix[i][col] !== 0) {
+        pr = i;
+        break;
+      }
+    }
+    if (pr === -1) continue;
+
+    [matrix[row], matrix[pr]] = [matrix[pr], matrix[row]];
+    pivotRow.push(col);
+
+    // Scale pivot row so pivot = 1
+    const inv = modInverse(matrix[row][col], modulus);
+    for (let k = col; k <= numButtons; k++) {
+      matrix[row][k] = mod(matrix[row][k] * inv, modulus);
+    }
+
+    // Eliminate all other rows
+    for (let i = 0; i < numLights; i++) {
+      if (i !== row && matrix[i][col] !== 0) {
+        const factor = matrix[i][col];
+        for (let k = col; k <= numButtons; k++) {
+          matrix[i][k] = mod(matrix[i][k] - factor * matrix[row][k], modulus);
+        }
+      }
+    }
+    row++;
+  }
+
+  // Check inconsistency
+  for (let i = row; i < numLights; i++) {
+    if (matrix[i][numButtons] !== 0) return null;
+  }
+
+  const rank = row;
+  const pivotColSet = new Set(pivotRow);
+  const freeCols: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotColSet.has(col)) {
+      freeCols.push(col);
+    }
+  }
+
+  const numFree = freeCols.length;
+
+  // Check if enumeration is feasible
+  let totalCombos = 1;
+  let feasible = true;
+  const MAX_COMBOS = 10_000_000;
+  for (let f = 0; f < numFree; f++) {
+    totalCombos *= modulus;
+    if (totalCombos > MAX_COMBOS) {
+      feasible = false;
+      break;
+    }
+  }
+
+  if (!feasible) {
+    // Fallback: set free vars to 0
+    const solution: number[] = new Array(numButtons).fill(0);
+    for (let r = 0; r < rank; r++) {
+      solution[pivotRow[r]] = matrix[r][numButtons];
+    }
+    return solution;
+  }
+
+  // Enumerate all modulus^numFree combinations
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+
+  const freeVals: number[] = new Array(numFree).fill(0);
+
+  const enumerate = (): void => {
+    // eslint-disable-next-line no-constant-condition
+    while (true) {
+      const solution: number[] = new Array(numButtons).fill(0);
+
+      // Set free variables
+      for (let f = 0; f < numFree; f++) {
+        solution[freeCols[f]] = freeVals[f];
+      }
+
+      // Back-substitute pivot variables
+      for (let r = 0; r < rank; r++) {
+        let val = matrix[r][numButtons];
+        for (let f = 0; f < numFree; f++) {
+          if (freeVals[f] !== 0 && matrix[r][freeCols[f]] !== 0) {
+            val = mod(val - matrix[r][freeCols[f]] * freeVals[f], modulus);
+          }
+        }
+        solution[pivotRow[r]] = val;
+      }
+
+      // Compute sum
+      let sum = 0;
+      for (let i = 0; i < numButtons; i++) {
+        sum += solution[i];
+      }
+
+      if (sum < bestSum) {
+        bestSum = sum;
+        bestSolution = solution;
+      } else if (sum === bestSum && bestSolution !== null) {
+        // Lexicographic comparison
+        for (let i = 0; i < numButtons; i++) {
+          if (solution[i] !== bestSolution[i]) {
+            if (solution[i] < bestSolution[i]) {
+              bestSolution = solution;
+            }
+            break;
+          }
+        }
+      }
+
+      // Increment freeVals (odometer-style)
+      let carry = true;
+      for (let f = 0; f < numFree; f++) {
+        freeVals[f]++;
+        if (freeVals[f] >= modulus) {
+          freeVals[f] = 0;
+        } else {
+          carry = false;
+          break;
+        }
+      }
+      if (carry) break;
+    }
+  };
+
+  enumerate();
+
+  return bestSolution;
+}
