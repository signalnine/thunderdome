: 1, backoffDelay: 0 });\n    const t2 = queue.addTask('b', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n\n    queue.getNextTask('q1');\n    queue.fail(t1.id, 'err');\n    queue.getNextTask('q2');\n    queue.fail(t2.id, 'err');\n\n    expect(queue.getDeadLetterTasks('q1').length).toBe(1);\n    expect(queue.getDeadLetterTasks('q2').length).toBe(1);\n  });\n});\n\n// ─── Phase 7: Task Dependencies ─────────────────────────────────────────────\n\ndescribe('Phase 7: Task Dependencies', () => {\n  it('should block tasks with unresolved dependencies', () => {\n    const t1 = queue.addTask('dep');\n    queue.addTask('dependent', { dependencies: [t1.id] });\n\n    // Should get t1 (no deps), not t2\n    const next = queue.getNextTask();\n    expect(next?.id).toBe(t1.id);\n\n    // t2 is blocked\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should unblock when dependency completes', () => {\n    const t1 = queue.addTask('dep');\n    const t2 = queue.addTask('dependent', { dependencies: [t1.id] });\n\n    queue.getNextTask(); // t1\n    queue.complete(t1.id);\n\n    const next = queue.getNextTask();\n    expect(next?.id).toBe(t2.id);\n  });\n\n  it('should reject non-existent dependency', () => {\n    expect(() => queue.addTask('data', { dependencies: ['nonexistent'] })).toThrow();\n  });\n\n  it('should keep blocked if dependency fails', () => {\n    const t1 = queue.addTask('dep', { maxRetries: 1, backoffDelay: 0 });\n    queue.addTask('dependent', { dependencies: [t1.id] });\n\n    queue.getNextTask(); // t1\n    queue.fail(t1.id, 'err');\n\n    // t2 remains blocked because t1 is not completed\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should expose dependency status', () => {\n    const t1 = queue.addTask('dep');\n    const t2 = queue.addTask('dependent', { dependencies: [t1.id] });\n\n    const status = queue.getDependencyStatus(t2.id);\n    expect(status[t1.id]).toBe(false);\n\n    queue.getNextTask();\n    queue.complete(t1.id);\