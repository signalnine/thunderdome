hrow new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    50→    }\n    51→\n    52→    // Validate dependencies exist\n    53→    if (options?.dependencies) {\n    54→      for (const depId of options.dependencies) {\n    55→        if (!this.tasks.has(depId)) {\n    56→          throw new Error(`Dependency task '${depId}' does not exist.`);\n    57→        }\n    58→      }\n    59→      // Check for circular dependencies\n    60→      this.detectCircularDependencies(options.dependencies);\n    61→    }\n    62→\n    63→    const now = new Date();\n    64→    let availableAt = now;\n    65→\n    66→    if (options?.runAt) {\n    67→      availableAt = options.runAt;\n    68→    } else if (options?.delay != null && options.delay > 0) {\n    69→      availableAt = new Date(now.getTime() + options.delay);\n    70→    }\n    71→\n    72→    const dependencies = options?.dependencies ?? [];\n    73→    const dependencyStatus: Record<string, boolean> = {};\n    74→    for (const depId of dependencies) {\n    75→      const depTask = this.tasks.get(depId);\n    76→      dependencyStatus[depId] = depTask?.status === 'completed';\n    77→    }\n    78→\n    79→    const task: Task = {\n    80→      id: randomUUID(),\n    81→      payload,\n    82→      status: 'pending',\n    83→      queue: queueName,\n    84→      priority,\n    85→      createdAt: now,\n    86→      availableAt,\n    87→      attempt: 0,\n    88→      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n    89→      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n    90→      progress: 0,\n    91→      failureCount: 0,\n    92→      dependencies,\n    93→      dependencyStatus,\n    94→    };\n    95→\n    96→    this.tasks.set(task.id, task);\n    97→    this.taskSeq.set(task.id, this.seqCounter++);\n    98→    this.ensureQueue(queueName);\n    99→\n   100→    return task;\n   101→  }\n   102→\n   103→  // Alias for backward compatibility\n   104→  a