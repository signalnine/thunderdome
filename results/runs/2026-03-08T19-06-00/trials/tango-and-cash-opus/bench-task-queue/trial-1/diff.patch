    if (subs.size === 0) {\n   323→          this.progressSubscribers.delete(taskId);\n   324→        }\n   325→      }\n   326→    };\n   327→  }\n   328→\n   329→  cancel(taskId: string): void {\n   330→    const task = this.tasks.get(taskId);\n   331→    if (!task) {\n   332→      throw new Error(`Task '${taskId}' not found.`);\n   333→    }\n   334→    if (task.status !== 'pending' && task.status !== 'processing') {\n   335→      throw new Error(`Task '${taskId}' cannot be cancelled (status: ${task.status}).`);\n   336→    }\n   337→\n   338→    task.status = 'cancelled';\n   339→  }\n   340→\n   341→  // ─── Phase 10: Recurring Tasks ───────────────────────────────────\n   342→\n   343→  addSchedule(cron: string, queueName: string, payload: unknown): Schedule {\n   344→    this.validateCron(cron);\n   345→\n   346→    const schedule: Schedule = {\n   347→      id: randomUUID(),\n   348→      cron,\n   349→      queue: queueName,\n   350→      payload,\n   351→      lastRun: null,\n   352→      createdAt: new Date(),\n   353→    };\n   354→\n   355→    this.schedules.set(schedule.id, schedule);\n   356→    this.ensureQueue(queueName);\n   357→\n   358→    return schedule;\n   359→  }\n   360→\n   361→  removeSchedule(scheduleId: string): void {\n   362→    if (!this.schedules.has(scheduleId)) {\n   363→      throw new Error(`Schedule '${scheduleId}' not found.`);\n   364→    }\n   365→    this.schedules.delete(scheduleId);\n   366→  }\n   367→\n   368→  getSchedules(): Schedule[] {\n   369→    return Array.from(this.schedules.values());\n   370→  }\n   371→\n   372→  tick(now?: Date): Task[] {\n   373→    const currentTime = now ?? new Date();\n   374→    const createdTasks: Task[] = [];\n   375→\n   376→    for (const schedule of this.schedules.values()) {\n   377→      if (this.shouldRunSchedule(schedule, currentTime)) {\n   378→        const task = this.enqueue(\n   379→          typeof schedule.payload === 'object' && schedule.payload !== null\n   380→      