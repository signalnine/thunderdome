ield, currentHour)) return false;\n    // Check day of month\n    if (!this.matchCronField(dayOfMonthField, currentDayOfMonth)) return false;\n    // Check month\n    if (!this.matchCronField(monthField, currentMonth)) return false;\n    // Check day of week\n    if (!this.matchCronField(dayOfWeekField, currentDayOfWeek)) return false;\n\n    // Avoid duplicate runs in the same minute window\n    if (schedule.lastRun) {\n      const lastRunMinute = new Date(\n        schedule.lastRun.getFullYear(),\n        schedule.lastRun.getMonth(),\n        schedule.lastRun.getDate(),\n        schedule.lastRun.getHours(),\n        schedule.lastRun.getMinutes()\n      );\n      const currentMinuteStart = new Date(\n        now.getFullYear(),\n        now.getMonth(),\n        now.getDate(),\n        now.getHours(),\n        now.getMinutes()\n      );\n      if (lastRunMinute.getTime() >= currentMinuteStart.getTime()) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  private matchCronField(field: string, value: number): boolean {\n    if (field === '*') return true;\n\n    // */N pattern\n    const stepMatch = field.match(/^\\*\\/(\\d+)$/);\n    if (stepMatch) {\n      const step = parseInt(stepMatch[1], 10);\n      return value % step === 0;\n    }\n\n    // Exact number\n    const num = parseInt(field, 10);\n    return value === num;\n  }\n\n  private async runMiddlewarePipeline(\n    task: Task,\n    middlewares: Middleware[],\n    handler: TaskHandler | null\n  ): Promise<void> {\n    let index = 0;\n\n    const next = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const middleware = middlewares[index++];\n        await middleware(task, next);\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    await next();\n  }\n\n  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    const startTime = Date.now();\n    const timeout = options?.timeout ?? 30000;\n\n    // Run