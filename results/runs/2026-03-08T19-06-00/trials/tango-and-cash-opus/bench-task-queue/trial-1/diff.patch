+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DXMmVXM8xWhCrEWGtoZJWW","type":"tool_result","content":"     1→import { randomUUID } from 'node:crypto';\n     2→import type {\n     3→  Task,\n     4→  TaskOptions,\n     5→  ProgressUpdate,\n     6→  ProgressCallback,\n     7→  Middleware,\n     8→  TaskHandler,\n     9→  Schedule,\n    10→  ShutdownOptions,\n    11→  ShutdownResult,\n    12→} from './types.js';\n    13→\n    14→const DEFAULT_QUEUE = 'default';\n    15→const DEFAULT_PRIORITY = 5;\n    16→const DEFAULT_MAX_RETRIES = 3;\n    17→const DEFAULT_BACKOFF_DELAY = 1000;\n    18→\n    19→interface QueueState {\n    20→  name: string;\n    21→  concurrencyLimit: number | null;\n    22→  middlewares: Middleware[];\n    23→  handler: TaskHandler | null;\n    24→}\n    25→\n    26→export class TaskQueue {\n    27→  private tasks: Map<string, Task> = new Map();\n    28→  private queues: Map<string, QueueState> = new Map();\n    29→  private deadLetterQueues: Map<string, Task[]> = new Map();\n    30→  private progressSubscribers: Map<string, Set<ProgressCallback>> = new Map();\n    31→  private schedules: Map<string, Schedule> = new Map();\n    32→  private isShutdown = false;\n    33→  private shutdownPromise: Promise<ShutdownResult> | null = null;\n    34→  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n    35→\n    36→  // ─── Phase 1 & 2: Basic FIFO Queue + Named Queues ──────────────\n    37→\n    38→  enqueue(payload: unknown, options?: TaskOptions): Task {\n    39→    if (this.isShutdown) {\n    40→      throw new Error('Queue is shut down. Cannot add new tasks.');\n    41→    }\n    42→\n    43→    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    44→    const priority = options?.priority ?? DEFAULT_PRIORITY;\n    45→\n    46→    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n    47→      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    48→    }\n    49→\n    50→    // Validate dependencies exist\n    51→    if (options?.dependencies) {\n    52→      for (const depId of options.dependencies) {\n    53→        if (!this.tasks.has(depId)) {\n    54→          throw new Error(`Dependency task '${depId}' does not exist.`);\n    55→        }\n    56→      }\n    57→      // Check for circular dependencies\n    58→      this.detectCircularDependencies(options.dependencies);\n    59→    }\n    60→\n    61→    const now = new Date();\n    62→    let availableAt = now;\n    63→\n    64→    if (options?.runAt) {\n    65→      availableAt = options.runAt;\n    66→    } else if (options?.delay != null && options.delay > 0) {\n    67→      availableAt = new Date(now.getTime() + options.delay);\n    68→    }\n    69→\n    70→    const dependencies = options?.dependencies ?? [];\n    71→    const dependencyStatus: Record<string, boolean> = {};\n    72→    for (const depId of dependencies) {\n    73→      const depTask = this.tasks.get(depId);\n    74→      dependencyStatus[depId] = depTask?.status === 'completed';\n    75→    }\n    76→\n    77→    const task: Task = {\n    78→      id: randomUUID(),\n    79→      payload,\n    80→      status: 'pending',\n    81→      queue: queueName,\n    82→      priority,\n    83→      createdAt: now,\n    84→      availableAt,\n    85→      attempt: 0,\n    86→      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n    87→      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n    88→      progress: 0,\n    89→      failureCount: 0,\n    90→      dependencies,\n    91→      dependencyStatus,\n    92→    };\n    93→\n    94→    this.tasks.set(task.id, task);\n    95→    this.ensureQueue(queueName);\n    96→\n    97→    return task;\n    98→  }\n    99→\n   100→  // Alias for backward compatibility\n   101→  addTask(payload: unknown, options?: TaskOptions): Task {\n   102→    return this.enqueue(payload, options);\n   103→  }\n   104→\n   105→  dequeue(queueName?: string): Task | null {\n   106→    const name = queueName ?? DEFAULT_QUEUE;\n   107→    const queueState = this.queues.get(name);\n   108→\n   109→    // Check concurrency limit\n   110→    if (queueState?.concurrencyLimit != null) {\n   111→      const activeCount = this.getActiveCount(name);\n   112→      if (activeCount >= queueState.concurrencyLimit) {\n   113→        return null;\n   114→      }\n   115→    }\n   116→\n   117→    const now = new Date();\n   118→    const pendingTasks = this.getPendingTasks(name, now);\n   119→\n   120→    if (pendingTasks.length === 0) {\n   121→      return null;\n   122→    }\n   123→\n   124→    // Sort: priority ASC, then availableAt ASC, then createdAt ASC\n   125→    pendingTasks.sort((a, b) => {\n   126→      if (a.priority !== b.priority) return a.priority - b.priority;\n   127→      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n   128→        return a.availableAt.getTime() - b.availableAt.getTime();\n   129→      }\n   130→      return a.createdAt.getTime() - b.createdAt.getTime();\n   131→    });\n   132→\n   133→    const task = pendingTasks[0];\n   134→    task.status = 'processing';\n   135→    task.attempt += 1;\n   136→\n   137→    return task;\n   138→  }\n   139→\n   140→  // Alias for backward compatibility\n   141→  getNextTask(queueName?: string): Task | null {\n   142→    return this.dequeue(queueName);\n   143→  }\n   144→\n   145→  getTask(taskId: string): Task | null {\n   146→    return this.tasks.get(taskId) ?? null;\n   147→  }\n   148→\n   149→  size(queueName?: string): number {\n   150→    const name = queueName ?? DEFAULT_QUEUE;\n   151→    let count = 0;\n   152→    for (const task of this.tasks.values()) {\n   153→      if (task.queue === name && task.status === 'pending') {\n   154→        count++;\n   155→      }\n   156→    }\n   157→    return count;\n   158→  }\n   159→\n   160→  getQueues(): string[] {\n   161→    return Array.from(this.queues.keys());\n   162→  }\n   163→\n   164→  // ─── Phase 5: Retry with Backoff ─────────────────────────────────\n   165→\n   166→  complete(taskId: string): void {\n   167→    const task = this.tasks.get(taskId);\n   168→    if (!task) {\n   169→      throw new Error(`Task '${taskId}' not found.`);\n   170→    }\n   171→    if (task.status !== 'processing') {\n   172→      throw new Error(`Task '${taskId}' is not in processing state.`);\n   173→    }\n   174→\n   175→    task.status = 'completed';\n   176→    task.progress = 100;\n   177→\n   178→    // Check if any blocked tasks can be unblocked\n   179→    this.updateDependents(taskId);\n   180→  }\n   181→\n   182→  fail(taskId: string, error?: string): void {\n   183→    const task = this.tasks.get(taskId);\n   184→    if (!task) {\n   185→      throw new Error(`Task '${taskId}' not found.`);\n   186→    }\n   187→    if (task.status !== 'processing') {\n   188→      throw new Error(`Task '${taskId}' is not in processing state.`);\n   189→    }\n   190→\n   191→    task.error = error;\n   192→    task.failureCount += 1;\n   193→\n   194→    if (task.attempt <= task.maxRetries) {\n   195→      // Retry with exponential backoff\n   196→      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n   197→      task.status = 'pending';\n   198→      task.availableAt = new Date(Date.now() + delay);\n   199→      task.progress = 0;\n   200→      task.progressMessage = undefined;\n   201→    } else {\n   202→      // Exhausted retries\n   203→      task.status = 'failed';\n   204→\n   205→      // Move to DLQ\n   206→      this.addToDeadLetterQueue(task);\n   207→    }\n   208→  }\n   209→\n   210→  // ─── Phase 6: Dead Letter Queue ──────────────────────────────────\n   211→\n   212→  getDeadLetterTasks(queueName?: string): Task[] {\n   213→    const name = queueName ?? DEFAULT_QUEUE;\n   214→    return [...(this.deadLetterQueues.get(name) ?? [])];\n   215→  }\n   216→\n   217→  retryDeadLetterTask(taskId: string): Task {\n   218→    for (const [queueName, dlqTasks] of this.deadLetterQueues.entries()) {\n   219→      const index = dlqTasks.findIndex(t => t.id === taskId);\n   220→      if (index !== -1) {\n   221→        const task = dlqTasks[index];\n   222→        dlqTasks.splice(index, 1);\n   223→\n   224→        // Reset for fresh retry round\n   225→        task.status = 'pending';\n   226→        task.attempt = 0;\n   227→        task.availableAt = new Date();\n   228→        task.progress = 0;\n   229→        task.progressMessage = undefined;\n   230→        task.error = undefined;\n   231→\n   232→        this.tasks.set(task.id, task);\n   233→        this.ensureQueue(queueName);\n   234→\n   235→        return task;\n   236→      }\n   237→    }\n   238→    throw new Error(`Task '${taskId}' not found in any dead letter queue.`);\n   239→  }\n   240→\n   241→  clearDeadLetterQueue(queueName?: string): void {\n   242→    const name = queueName ?? DEFAULT_QUEUE;\n   243→    this.deadLetterQueues.set(name, []);\n   244→  }\n   245→\n   246→  // ─── Phase 7: Task Dependencies ──────────────────────────────────\n   247→\n   248→  getDependencyStatus(taskId: string): Record<string, boolean> {\n   249→    const task = this.tasks.get(taskId);\n   250→    if (!task) {\n   251→      throw new Error(`Task '${taskId}' not found.`);\n   252→    }\n   253→\n   254→    // Refresh dependency status\n   255→    for (const depId of task.dependencies) {\n   256→      const depTask = this.tasks.get(depId);\n   257→      task.dependencyStatus[depId] = depTask?.status === 'completed';\n   258→    }\n   259→\n   260→    return { ...task.dependencyStatus };\n   261→  }\n   262→\n   263→  // ─── Phase 8: Concurrency Control ────────────────────────────────\n   264→\n   265→  setConcurrency(queueName: string, limit: number | null): void {\n   266→    const queue = this.ensureQueue(queueName);\n   267→    queue.concurrencyLimit = limit;\n   268→  }\n   269→\n   270→  getConcurrency(queueName?: string): number | nul