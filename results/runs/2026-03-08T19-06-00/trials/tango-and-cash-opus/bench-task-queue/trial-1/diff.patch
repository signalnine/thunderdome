d: unknown, options?: TaskOptions): Task {\n    if (this.isShutdown) {\n      throw new Error('Queue is shut down. Cannot add new tasks.');\n    }\n\n    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? DEFAULT_PRIORITY;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Validate dependencies exist\n    if (options?.dependencies) {\n      for (const depId of options.dependencies) {\n        if (!this.tasks.has(depId)) {\n          throw new Error(`Dependency task '${depId}' does not exist.`);\n        }\n      }\n      // Check for circular dependencies\n      this.detectCircularDependencies(options.dependencies);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n\n    if (options?.runAt) {\n      availableAt = options.runAt;\n    } else if (options?.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    const dependencies = options?.dependencies ?? [];\n    const dependencyStatus: Record<string, boolean> = {};\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      dependencyStatus[depId] = depTask?.status === 'completed';\n    }\n\n    const task: Task = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      queue: queueName,\n      priority,\n      createdAt: now,\n      availableAt,\n      attempt: 0,\n      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      progress: 0,\n      failureCount: 0,\n      dependencies,\n      dependencyStatus,\n    };\n\n    this.tasks.set(task.id, task);\n    this.taskSeq.set(task.id, this.seqCounter++);\n    this.ensureQueue(queueName);\n\n    return task;\n  }\n\n  // Alias for backward compatibility\n  addTask(payload: unknown, options?: TaskOptions): Task {\n    return this.enqueue(payload, options);\n  }\n\n  dequeue(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueState = this.queues.get(name);\n\n    // Check concurrency limit\n    if (queueState?.concurrencyLimit != null) {\n      const activeCount = this.getActiveCount(name);\n      if (activeCount >= queueState.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n    const pendingTasks = this.getPendingTasks(name, now);\n\n    if (pendingTasks.length === 0) {\n      return null;\n    }\n\n    // Sort: priority ASC, then availableAt ASC, then FIFO (sequence number)\n    pendingTasks.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n        return a.availableAt.getTime() - b.availableAt.getTime();\n      }\n      return (this.taskSeq.get(a.id) ?? 0) - (this.taskSeq.get(b.id) ?? 0);\n    });\n\n    const task = pendingTasks[0];\n    task.status = 'processing';\n    task.attempt += 1;\n\n    return task;\n  }\n\n  // Alias for backward compatibility\n  getNextTask(queueName?: string): Task | null {\n    return this.dequeue(queueName);\n  }\n\n  getTask(taskId: string): Task | null {\n    return this.tasks.get(taskId) ?? null;\n  }\n\n  size(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === name && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ─── Phase 5: Retry with Backoff ─────────────────────────────────\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task '${taskId}' not found.`);\n    }\n    if (task.status !== 'processing') {\n      throw new