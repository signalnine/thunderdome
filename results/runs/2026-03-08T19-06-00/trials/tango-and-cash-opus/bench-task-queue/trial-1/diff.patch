 48→    }\n    49→\n    50→    // Validate dependencies exist\n    51→    if (options?.dependencies) {\n    52→      for (const depId of options.dependencies) {\n    53→        if (!this.tasks.has(depId)) {\n    54→          throw new Error(`Dependency task '${depId}' does not exist.`);\n    55→        }\n    56→      }\n    57→      // Check for circular dependencies\n    58→      this.detectCircularDependencies(options.dependencies);\n    59→    }\n    60→\n    61→    const now = new Date();\n    62→    let availableAt = now;\n    63→\n    64→    if (options?.runAt) {\n    65→      availableAt = options.runAt;\n    66→    } else if (options?.delay != null && options.delay > 0) {\n    67→      availableAt = new Date(now.getTime() + options.delay);\n    68→    }\n    69→\n    70→    const dependencies = options?.dependencies ?? [];\n    71→    const dependencyStatus: Record<string, boolean> = {};\n    72→    for (const depId of dependencies) {\n    73→      const depTask = this.tasks.get(depId);\n    74→      dependencyStatus[depId] = depTask?.status === 'completed';\n    75→    }\n    76→\n    77→    const task: Task = {\n    78→      id: randomUUID(),\n    79→      payload,\n    80→      status: 'pending',\n    81→      queue: queueName,\n    82→      priority,\n    83→      createdAt: now,\n    84→      availableAt,\n    85→      attempt: 0,\n    86→      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n    87→      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n    88→      progress: 0,\n    89→      failureCount: 0,\n    90→      dependencies,\n    91→      dependencyStatus,\n    92→    };\n    93→\n    94→    this.tasks.set(task.id, task);\n    95→    this.ensureQueue(queueName);\n    96→\n    97→    return task;\n    98→  }\n    99→\n   100→  getTask(taskId: string): Task | null {\n   101→    return this.tasks.get(taskId) ?? null;\n   102→  }\n   103→\n   104→  getNextTask(queueName?: string): Task | null {\n   105→    const name = queueName ?? DEFAULT_QUEUE;\n   106→    const queueState = this.queues.get(name);\n   107→\n   108→    // Check concurrency limit\n   109→    if (queueState?.concurrencyLimit != null) {\n   110→      const activeCount = this.getActiveCount(name);\n   111→      if (activeCount >= queueState.concurrencyLimit) {\n   112→        return null;\n   113→      }\n   114→    }\n   115→\n   116→    const now = new Date();\n   117→    const pendingTasks = this.getPendingTasks(name, now);\n   118→\n   119→    if (pendingTasks.length === 0) {\n   120→      return null;\n   121→    }\n   122→\n   123→    // Sort: priority ASC, then availableAt ASC, then createdAt ASC\n   124→    pendingTasks.sort((a, b) => {\n   125→      if (a.priority !== b.priority) return a.priority - b.priority;\n   126→      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n   127→        return a.availableAt.getTime() - b.availableAt.getTime();\n   128→      }\n   129→      return a.createdAt.getTime() - b.createdAt.getTime();\n   130→    });\n   131→\n   132→    const task = pendingTasks[0];\n   133→    task.status = 'processing';\n   134→    task.attempt += 1;\n   135→\n   136→    return task;\n   137→  }\n   138→\n   139→  size(queueName?: string): number {\n   140→    const name = queueName ?? DEFAULT_QUEUE;\n   141→    let count = 0;\n   142→    for (const task of this.tasks.values()) {\n   143→      if (task.queue === name && task.status === 'pending') {\n   144→        count++;\n   145→      }\n   146→    }\n   147→    return count;\n   148→  }\n   149→\n   150→  // ─── Phase 2: Named Queues ────────────────────────────────────────\n   151→\n   152→  getQueues(): string[] {\n   153→    return Array.from(this.queues.keys());\n   154→  }\n   155→\n   156→  // ─── Phase 5: Retry with Backoff ─────────────────────────────────\n   157→\n   158→  complete(taskId: string): void {\n   159→    const task = this.tasks.get(taskId);\n   160→    if (!task) {\n   161→      throw new Error(`Task '${taskId}' not found.`);\n   162→    }\n   163→    if (task.status !== 'processing') {\n   164→      throw new Error(`Task '${taskId}' is not in processing state.`);\n   165→    }\n   166→\n   167→    task.status = 'completed';\n   168→    task.progress = 100;\n   169→\n   170→    // Check if any blocked tasks can be unblocked\n   171→    this.updateDependents(taskId);\n   172→  }\n   173→\n   174→  fail(taskId: string, error?: string): void {\n   175→    const task = this.tasks.get(taskId);\n   176→    if (!task) {\n   177→      throw new Error(`Task '${taskId}' not found.`);\n   178→    }\n   179→    if (task.status !== 'processing') {\n   180→      throw new Error(`Task '${taskId}' is not in processing state.`);\n   181→    }\n   182→\n   183→    task.error = error;\n   184→    task.failureCount += 1;\n   185→\n   186→    if (task.attempt < task.maxRetries) {\n   187→      // Retry with exponential backoff\n   188→      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n   189→      task.status = 'pending';\n   190→      task.availableAt = new Date(Date.now() + delay);\n   191→      task.progress = 0;\n   192→      task.progressMessage = undefined;\n   193→    } else {\n   194→      // Exhausted retries\n   195→      task.status = 'failed';\n   196→\n   197→      // Move to DLQ\n   198→      this.addToDeadLetterQueue(task);\n   199→    }\n   200→  }\n   201→\n   202→  // ─── Phase 6: Dead Letter Queue ──────────────────────────────────\n   203→\n   204→  getDeadLetterTasks(queueName?: string): Task[] {\n   205→    const name = queueName ?? DEFAULT_QUEUE;\n   206→    return [...(this.deadLetterQueues.get(name) ?? [])];\n   207→  }\n   208→\n   209→  retryDeadLetterTask(taskId: string): Task {\n   210→    // Find the task in any DLQ\n   211→    for (const [queueName, dlqTasks] of this.deadLetterQueues.entries()) {\n   212→      const index = dlqTasks.findIndex(t => t.id === taskId);\n   213→      if (index !== -1) {\n   214→        const task = dlqTasks[index];\n   215→        dlqTasks.splice(index, 1);\n   216→\n   217→        // Reset for fresh retry round\n   218→        task.status = 'pending';\n   219→        task.attempt = 0;\n   220→        task.availableAt = new Date();\n   221→        task.progress = 0;\n   222→        task.progressMessage = undefined;\n   223→        task.error = undefined;\n   224→\n   225→        // Make sure it's in the tasks map\n   226→        this.tasks.set(task.id, task);\n   227→        this.ensureQueue(queueName);\n   228→\n   229→        return task;\n   230→      }\n   231→    }\n   232→    throw new Error(`Task '${taskId}' not found in any dead letter queue.`);\n   233→  }\n   234→\n   235→  clearDeadLetterQueue(queueName?: string): void {\n   236→    const name = queueName ?? DEFAULT_QUEUE;\n   237→    this.deadLetterQueues.set(name, []);\n   238→  }\n   239→\n   240→  // ─── Phase 7: Task Dependencies ──────────────────────────────────\n   241→\n   242→  getDependencyStatus(taskId: string): Record<string, boolean> {\n   243→    const task = this.tasks.get(taskId);\n   244→    if (!task) {\n   245→      throw new Error(`Task '${taskId}' not found.`);\n   246→    }\n   247→\n   248→    // Refresh dependency status\n   249→    for (const depId of task.dependencies) {\n   250→      const depTask = this.tasks.get(depId);\n   251→      task.dependencyStatus[depId] = depTask?.status === 'completed';\n   252→    }\n   253→\n   254→    return { ...task.dependencyStatus };\n   255→  }\n   256→\n   257→  // ─── Phase 8: Concurrency Control ────────────────────────────────\n   258→\n   259→  setConcurrency(queueName: string, limit: number | null): void {\n   260→    const queue = this.ensureQueue(queueName);\n   261→    queue.concurrencyLimit = limit;\n   262→  }\n   263→\n   264→  getConcurrency(queueName?: string): number | null {\n   265→    const name = queueName ?? DEFAULT_QUEUE;\n   266→    return this.queues.get(name)?.concurrencyLimit ?? null;\n   267→  }\n   268→\n   269→  getActiveCount(queueName?: string): number {\n   270→    const name = queueName ?? DEFAULT_QUEUE;\n   271→    let count = 0;\n   272→    for (const task of this.tasks.values()) {\n   273→      if (task.queue === name && task.status === 'processing') {\n   274→        count++;\n   275→      }\n   276→    }\n   277→    return count;\n   278→  }\n   279→\n   280→  // ─── Phase 9: Progress and Cancellation ──────────────────────────\n   281→\n   282→  updateProgress(taskId: string, progress: number, message?: string): void {\n   283→    const task = this.tasks.get(taskId);\n   284→    if (!task) {\n   285→      throw new Error(`Task '${taskId}' not found.`);\n   286→    }\n   287→    if (task.status !== 'processing') {\n   288→      throw new Error(`Task '${taskId}' is not in processing state.`);\n   289→    }\n   290→    if (progress < 0 || progress > 100) {\n   291→      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n   292→    }\n   293→\n   294→    task.progress = progress;\n   295→    task.progressMessage = message;\n   296→\n   297→    // Notify subscribers\n   298→    const subscribers = this.progressSubscribers.get(taskId);\n   299→    if (subscribers) {\n   300→      const update: ProgressUpdate = { taskId, progress, message };\n   301→      for (const callback of subscribers) {\n   302→        callback(update);\n   303→      }\n   304→    }\n   305→  }\n   306→\n   307→  onProgress(taskId: string, callback: ProgressCallback): () => void {\n   308→    if (!this.progressSubscribers.has(taskId)) {\n   309→      this.progressSubscribers.set(taskId, new Set());\n   310→    }\n   311→    this.progressSubscribers.get(taskId)!.add(callback);\n   312→\n   313→    // Return unsubscribe function\n   314→    return () => {\n   315→      const subs = this.progressSubscribers.get(taskId);\n   316→      if (subs) {\n   317→        subs.delete(callback);\n   318→        if (subs.size === 0) {\n   319→          this.progressSubscribers.delete(taskId);\n   320→        }\n   321→      }\n   322→    };\n   323→  }\n   324→\n   325→  cancel(taskId: string): void {\n   326→    const task = this.tasks.get(taskId);\n   327→    if (!task) {\n   328→      throw new Error(`Task '${taskId}' not found.`);\n   329→    }\n   330→    if (task.status !== 'pending' && task.status !== 'processing') {\n   331→      throw new Error(`Task '${taskId}' cannot be cancelled (status: ${task.status}).`);\n   332→    }\n   333→\n   334→    task.status = 'cancelled';\n   335→  }\n   336→\n   337→  // ─── Phase 10: Recurring Tasks ───────────────────────────────────\n   338→\n   339→  addSchedule(cron: string, queueName: string, payload: unknown): Schedule {\n   340→    this.validateCron(cron);\n   341→\n   342→    const schedule: Schedule = {\n   343→      id: randomUUID(),\n   344→      cron,\n   345→      queue: queueName,\n   346→      payload,\n   347→      lastRun: null,\n   348→      createdAt: new Date(),\n   349→    };\n   350→\n   351→    this.schedules.set(schedule.id, schedule);\n   352→    this.ensureQueue(queueName);\n   353→\n   354→    return schedule;\n   355→  }\n   356→\n   357→  removeSchedule(scheduleId: string): void {\n   358→    if (!this.schedules.has(scheduleId)) {\n   359→      throw new Error(`Schedule '${scheduleId}' not found.`);\n   360→    }\n   361→    this.schedules.delete(scheduleId);\n   362→  }\n   363→\n   364→  getSchedules(): Schedule[] {\n   365→    return Array.from(this.schedules.values());\n   366→  }\n   367→\n   368→  tick(now?: Date): Task[] {\n   369→    const currentTime = now ?? new Date();\n   370→    const createdTasks: Task[] = [];\n   371→\n   372→    for (const schedule of this.schedules.values()) {\n   373→      if (this.shouldRunSchedule(schedule, currentTime)) {\n   374→        const task = this.addTask(\n   375→          typeof schedule.payload === 'object' && schedule.payload !== null\n   376→            ? JSON.parse(JSON.stringify(schedule.payload))\n   377→            : schedule.payload,\n   378→          { queue: schedule.queue }\n   379→        );\n   380→        createdTasks.push(task);\n   381→        schedule.lastRun = currentTime;\n   382→      }\n   383→    }\n   384→\n   385→    return createdTasks;\n   386→  }\n   387→\n   388→  // ─── Phase 11: Middleware Pipeline ────────────────────────────────\n   389→\n   390→  use(queueName: string, middleware: Middleware): void {\n   391→    const queue = this.ensureQueue(queueName);\n   392→    queue.middlewares.push(middleware);\n   393→  }\n   394→\n   395→  setHandler(queueName: string, handler: TaskHandler): void {\n   396→    const queue = this.ensureQueue(queueName);\n   397→    queue.handler = handler;\n   398→  }\n   399→\n   400→  async process(queueName?: string): Promise<Task | null> {\n   401→    const name = queueName ?? DEFAULT_QUEUE;\n   402→    const task = this.getNextTask(name);\n   403→\n   404→    if (!task) {\n   405→      return null;\n   406→    }\n   407→\n   408→    const queueState = this.queues.get(name);\n   409→    const middlewares = queueState?.middlewares ?? [];\n   410→    const handler = queueState?.handler ?? null;\n   411→\n   412→    try {\n   413→      await this.runMiddlewarePipeline(task, middlewares, handler);\n   414→      // If still in processing state after pipeline (not completed/failed by handler),\n   415→      // don't auto-complete - let the caller manage the lifecycle\n   416→    } catch (err) {\n   417→      if (task.status === 'processing') {\n   418→        this.fail(task.id, err instanceof Error ? err.message : String(err));\n   419→      }\n   420→    }\n   421→\n   422→    return task;\n   423→  }\n   424→\n   425→  // ─── Phase 12: Graceful Shutdown ─────────────────────────────────\n   426→\n   427→  onShutdown(callback: () => void | Promise<void>): void {\n   428→    this.shutdownCallbacks.push(callback);\n   429→  }\n   430→\n   431→  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n   432→    if (this.shutdownPromise) {\n   433→      return this.shutdownPromise;\n   434→    }\n   435→\n   436→    this.isShutdown = true;\n   437→    this.shutdownPromise = this.performShutdown(options);\n   438→    return this.shutdownPromise;\n   439→  }\n   440→\n   441→  // ─── Internal Helpers ─────────────────────────────────────────────\n   442→\n   443→  private ensureQueue(name: string): QueueState {\n   444→    if (!this.queues.has(name)) {\n   445→      this.queues.set(name, {\n   446→        name,\n   447→        concurrencyLimit: null,\n   448→        middlewares: [],\n   449→        handler: null,\n   450→      });\n   451→    }\n   452→    return this.queues.get(name)!;\n   453→  }\n   454→\n   455→  private getPendingTasks(queueName: string, now: Date): Task[] {\n   456→    const result: Task[] = [];\n   457→    for (const task of this.tasks.values()) {\n   458→      if (task.queue !== queueName || task.status !== 'pending') continue;\n   459→\n   460→      // Check availability time\n   461→      if (task.availableAt > now) continue;\n   462→\n   463→      // Check dependencies\n   464→      if (task.dependencies.length > 0) {\n   465→        let allResolved = true;\n   466→        for (const depId of task.dependencies) {\n   467→          const dep = this.tasks.get(depId);\n   468→          if (!dep || dep.status !== 'completed') {\n   469→            allResolved = false;\n   470→            break;\n   471→          }\n   472→        }\n   473→        if (!allResolved) continue;\n   474→      }\n   475→\n   476→      result.push(task);\n   477→    }\n   478→    return result;\n   479→  }\n   480→\n   481→  private updateDependents(completedTaskId: string): void {\n   482→    for (const task of this.tasks.values()) {\n   483→      if (task.dependencies.includes(completedTaskId)) {\n   484→        task.dependencyStatus[completedTaskId] = true;\n   485→      }\n   486→    }\n   487→  }\n   488→\n   489→  private addToDeadLetterQueue(task: Task): void {\n   490→    if (!this.deadLetterQueues.has(task.queue)) {\n   491→      this.deadLetterQueues.set(task.queue, []);\n   492→    }\n   493→    this.deadLetterQueues.get(task.queue)!.push(task);\n   494→  }\n   495→\n   496→  private detectCircularDependencies(newDeps: string[]): void {\n   497→    // We need to check if adding these dependencies would create a cycle\n   498→    // The \"current task\" doesn't have an ID yet, so we check if any\n   499→    // dependency transitively depends on any other dependency in the new set\n   500→    // Actually, since the task doesn't exist yet, we just need to verify\n   501→    // that the dependency chain doesn't eventually contain a cycle.\n   502→    // The only way a cycle can happen is if we're creating a task that depends\n   503→    // on tasks that depend on each other in a way that forms a cycle.\n   504→    // Since the new task doesn't exist in the graph yet, we just need to\n   505→    // ensure all dependency IDs lead to valid, non-circular chains.\n   506→\n   507→    // Check each dependency for existing cycles in the dep graph\n   508→    const visited = new Set<string>();\n   509→    const visiting = new Set<string>();\n   510→\n   511→    const hasCycle = (taskId: string): boolean => {\n   512→      if (visiting.has(taskId)) return true;\n   513→      if (visited.has(taskId)) return false;\n   514→\n   515→      visiting.add(taskId);\n   516→      const task = this.tasks.get(taskId);\n   517→      if (task) {\n   518→        for (const depId of task.dependencies) {\n   519→          if (hasCycle(depId)) return true;\n   520→        }\n   521→      }\n   522→      visiting.delete(taskId);\n   523→      visited.add(taskId);\n   524→      return false;\n   525→    };\n   526→\n   527→    for (const depId of newDeps) {\n   528→      if (hasCycle(depId)) {\n   529→        throw new Error('Circular dependency detected.');\n   530→      }\n   531→    }\n   532→  }\n   533→\n   534→  private validateCron(cron: string): void {\n   535→    const parts = cron.trim().split(/\\s+/);\n   536→    if (parts.length !== 5) {\n   537→      throw new Error(`Invalid cron expression: '${cron}'. Expected 5 fields.`);\n   538→    }\n   539→\n   540→    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n   541→\n   542→    // Validate minute field\n   543→    if (minute !== '*' && !minute.match(/^\\*\\/\\d+$/) && !minute.match(/^\\d+$/)) {\n   544→      throw new Error(`Invalid cron minute field: '${minute}'.`);\n   545→    }\n   546→\n   547→    // Validate hour field\n   548→    if (hour !== '*' && !hour.match(/^\\d+$/)) {\n   549→      throw new Error(`Invalid cron hour field: '${hour}'.`);\n   550→    }\n   551→\n   552→    // Validate remaining fields (just allow * and digits)\n   553→    for (const field of [dayOfMonth, month, dayOfWeek]) {\n   554→      if (field !== '*' && !field.match(/^\\d+$/)) {\n   555→        throw new Error(`Invalid cron field: '${field}'.`);\n   556→      }\n   557→    }\n   558→  }\n   559→\n   560→  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n   561→    const parts = schedule.cron.trim().split(/\\s+/);\n   562→    const [minuteField, hourField, dayOfMonthField, monthField, dayOfWeekField] = parts;\n   563→\n   564→    const currentMinute = now.getMinutes();\n   565→    const currentHour = now.getHours();\n   566→    const currentDayOfMonth = now.getDate();\n   567→    const currentMonth = now.getMonth() + 1; // 0-indexed to 1-indexed\n   568→    const currentDayOfWeek = now.getDay(); // 0 = Sunday\n   569→\n   570→    // Check minute\n   571→    if (!this.matchCronField(minuteField, currentMinute)) return false;\n   572→    // Check hour\n   573→    if (!this.matchCronField(hourField, currentHour)) return false;\n   574→    // Check day of month\n   575→    if (!this.matchCronField(dayOfMonthField, currentDayOfMonth)) return false;\n   576→    // Check month\n   577→    if (!this.matchCronField(monthField, currentMonth)) return false;\n   578→    // Che