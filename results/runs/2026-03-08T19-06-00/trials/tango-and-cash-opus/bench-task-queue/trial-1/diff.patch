queue: 'q1' });\n    queue.addTask('b', { queue: 'q2' });\n\n    expect(queue.size('q1')).toBe(1);\n    expect(queue.size('q2')).toBe(1);\n\n    queue.getNextTask('q1');\n    expect(queue.size('q1')).toBe(0);\n    expect(queue.size('q2')).toBe(1);\n  });\n\n  it('should return null for empty or non-existent queue', () => {\n    expect(queue.getNextTask('nonexistent')).toBeNull();\n  });\n\n  it('should list queue names', () => {\n    queue.addTask('a', { queue: 'alpha' });\n    queue.addTask('b', { queue: 'beta' });\n\n    const names = queue.getQueues();\n    expect(names).toContain('alpha');\n    expect(names).toContain('beta');\n  });\n\n  it('should create queue implicitly', () => {\n    queue.addTask('data', { queue: 'new-queue' });\n    expect(queue.getQueues()).toContain('new-queue');\n  });\n});\n\n// ─── Phase 3: Priority ──────────────────────────────────────────────────────\n\ndescribe('Phase 3: Priority', () => {\n  it('should default to priority 5', () => {\n    const task = queue.addTask('data');\n    expect(task.priority).toBe(5);\n  });\n\n  it('should respect custom priority', () => {\n    const task = queue.addTask('data', { priority: 1 });\n    expect(task.priority).toBe(1);\n  });\n\n  it('should return higher priority tasks first', () => {\n    queue.addTask('low', { priority: 10 });\n    queue.addTask('high', { priority: 1 });\n    queue.addTask('medium', { priority: 5 });\n\n    expect(queue.getNextTask()?.payload).toBe('high');\n    expect(queue.getNextTask()?.payload).toBe('medium');\n    expect(queue.getNextTask()?.payload).toBe('low');\n  });\n\n  it('should use FIFO for same priority', () => {\n    queue.addTask('first', { priority: 5 });\n    queue.addTask('second', { priority: 5 });\n\n    expect(queue.getNextTask()?.payload).toBe('first');\n    expect(queue.getNextTask()?.payload).toBe('second');\n  });\n\n  it('should reject invalid priority', () => {\n    expect(() => queue.addTask('data', { priority: 0 })).toThrow();\n    expect(() => queue.addTask('data', { priority: 11 })).toThrow();\n    expect(() => queue.addTask('data', { priority: 3.5 })).toThrow();\n  });\n\n  it('should work per queue', () => {\n    queue.addTask('low', { queue: 'q1', priority: 10 });\n    queue.addTask('high', { queue: 'q1', priority: 1 });\n    queue.addTask('only', { queue: 'q2', priority: 5 });\n\n    expect(queue.getNextTask('q1')?.payload).toBe('high');\n    expect(queue.getNextTask('q2')?.payload).toBe('only');\n  });\n});\n\n// ─── Phase 4: Delayed Tasks ────────────────────────────────────────────────\n\ndescribe('Phase 4: Delayed Tasks', () => {\n  it('should not return delayed tasks before their time', () => {\n    queue.addTask('delayed', { delay: 100000 });\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should return non-delayed tasks over not-yet-available delayed tasks', () => {\n    queue.addTask('delayed', { delay: 100000 });\n    queue.addTask('immediate');\n\n    const task = queue.getNextTask();\n    expect(task?.payload).toBe('immediate');\n  });\n\n  it('should support runAt for scheduling', () => {\n    const futureDate = new Date(Date.now() + 100000);\n    const task = queue.addTask('scheduled', { runAt: futureDate });\n    expect(task.availableAt.getTime()).toBe(futureDate.getTime());\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should return delayed tasks once available', () => {\n    const pastDate = new Date(Date.now() - 1000);\n    queue.addTask('ready', { runAt: pastDate });\n\n    const task = queue.getNextTask();\n    expect(task?.payload).toBe('ready');\n  });\n\n  it('should set availableAt for delayed tasks', () => {\n    const before = Date.now();\n    const task = queue.addTask('data', { delay: 5000 });\n    expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(before + 5000);\n  });\n});\n\n// ─── Phase 5: Retry with Backoff ────────────────────────────────────────────\n\ndescribe('Phase 5: Retry with Backoff', () => {\n  it('should complete a processing task', () => {\n    const task = queue.addTask('data');\n    queue.getNextTask();\n    queue.complete(task.id);\n    expect(task.status).toBe('completed');\n  });\n\n  it('should fail and retry with backoff', () => {\n    const task = queue.addTask('data', { maxRetries: 3, backoffDelay: 100 });\n    queue.getNextTask();\n    queue.fail(task.id, 'error');\n\n    // Task should be pending again\n    expect(task.status).toBe('pending');\n    expect(task.failureCount).toBe(1);\n    // Should have delay (100ms * 2^0 = 100ms)\n    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 10);\n  });\n\n  it('should use exponential backoff', () => {\n    const task = queue.addTask('data', { maxRetries: 3, backoffDelay: 1000 });\n\n    // First attempt\n    queue.getNextTask();\n    const beforeFail1 = Date.now();\n    queue.fail(task.id, 'err');\n    // Backoff: 1000 * 2^0 = 1000ms\n    expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail1 + 1000 - 10);\n  });\n\n  it('should track attempt count', () => {\n    const task = queue.addTask('data', { maxRetries: 3, backoffDelay: 0 });\n    queue.getNextTask();\n    expect(task.attempt).toBe(1);\n  });\n\n  it('should exhaust retries and fail permanently', () => {\n    // maxRetries=1: initial attempt + 1 retry = 2 total\n    const task = queue.addTask('data', { maxRetries: 1, backoffDelay: 0 });\n\n    // First attempt: attempt=1\n    queue.getNextTask();\n    queue.fail(task.id, 'err');\n    // attempt(1) <= maxRetries(1) → retry\n    expect(task.status).toBe('pending');\n\n    // Second attempt: attempt=2\n    // Need to make task available immediately for test\n    task.availableAt = new Date(Date.now() - 1000);\n    queue.getNextTask();\n    queue.fail(task.id, 'err2');\n    // attempt(2) <= maxRetries(1) → false → permanent fail\n    expect(task.status).toBe('failed');\n  });\n\n  it('should default maxRetries to 3', () => {\n    const task = queue.addTask('data');\n    expect(task.maxRetries).toBe(3);\n  });\n\n  it('should default backoffDelay to 1000', () => {\n    const task = queue.addTask('data');\n    expect(task.backoffDelay).toBe(1000);\n  });\n});\n\n// ─── Phase 6: Dead Letter Queue ─────────────────────────────────────────────\n\ndescribe('Phase 6: Dead Letter Queue', () => {\n  it('should move exhausted tasks to DLQ', () => {\n    const task = queue.addTask('data', { maxRetries: 0, backoffDelay: 0 });\n    queue.getNextTask();\n    queue.fail(task.id, 'permanent error');\n\n    const dlq = queue.getDeadLetterTasks();\n    expect(dlq.length).toBe(1);\n    expect(dlq[0].id).toBe(task.id);\n  });\n\n  it('should retain error info', () => {\n    const task = queue.addTask('data', { maxRetries: 0, backoffDelay: 0 });\n    queue.getNextTask();\n    queue.fail(task.id, 'some error');\n\n    const dlq = queue.getDeadLetterTasks();\n    expect(dlq[0].error).toBe('some error');\n    expect(dlq[0].failureCount).toBe(1);\n  });\n\n  it('should retry dead-lettered tasks', () => {\n    const task = queue.addTask('data', { maxRetries: 0, backoffDelay: 0 });\n    queue.getNextTask();\n    queue.fail(task.id, 'err');\n\n    const retried = queue.retryDeadLetterTask(task.id);\n    expect(retried.status).toBe('pending');\n    expect(retried.attempt).toBe(0);\n\n    expect(queue.getDeadLetterTasks().length).toBe(0);\n  });\n\n  it('should clear DLQ', () => {\n    const task = queue.addTask('data', { maxRetries: 0, backoffDelay: 0 });\n    queue.getNextTask();\n    queue.fail(task.id, 'err');\n\n    queue.clearDeadLetterQueue();\n    expect(queue.getDeadLetterTasks().length).toBe(0);\n  });\n\n  it('should have independent DLQs per queue', () => {\n    const t1 = queue.addTask('a', { queue: 'q1', maxRetries: 0, backoffDelay: 0 });\n    const t2 = queue.addTask('b', { queue: 'q2', maxRetries: 0, backoffDelay: 0 });\n\n    queue.getNextTask('q1');\n    queue.fail(t1.id, 'err');\n    queue.getNextTask('q2');\n    queue.fail(t2.id, 'err');\n\n    expect(queue.getDeadLetterTasks('q1').length).toBe(1);\n    expect(queue.getDeadLetterTasks('q2').length).toBe(1);\n  });\n});\n\n// ─── Phase 7: Task Dependencies ─────────────────────────────────────────────\n\ndescribe('Phase 7: Task Dependencies', () => {\n  it('should block tasks with unresolved dependencies', () => {\n    const t1 = queue.addTask('dep');\n    queue.addTask('dependent', { dependencies: [t1.id] });\n\n    // Should get t1 (no deps), not t2\n    const next = queue.getNextTask();\n    expect(next?.id).toBe(t1.id);\n\n    // t2 is blocked\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should unblock when dependency completes', () => {\n    const t1 = queue.addTask('dep');\n    const t2 = queue.addTask('dependent', { dependencies: [t1.id] });\n\n    queue.getNextTask(); // t1\n    queue.complete(t1.id);\n\n    const next = queue.getNextTask();\n    expect(next?.id).toBe(t2.id);\n  });\n\n  it('should reject non-existent dependency', () => {\n    expect(() => queue.addTask('data', { dependencies: ['nonexistent'] })).toThrow();\n  });\n\n  it('should keep blocked if dependency fails', () => {\n    const t1 = queue.addTask('dep', { maxRetries: 0, backoffDelay: 0 });\n    queue.addTask('dependent', { dependencies: [t1.id] });\n\n    queue.getNextTask(); // t1\n    queue.fail(t1.id, 'err');\n\n    // t2 remains blocked because t1 is not completed\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should expose dependency status', () => {\n    const t1 = queue.addTask('dep');\n    const t2 = queue.addTask('dependent', { dependencies: [t1.id] });\n\n    const status = queue.getDependencyStatus(t2.id);\n    expect(status[t1.id]).toBe(false);\n\n    queue.getNextTask();\n    queue.complete(t1.id);\n\n    const updated = queue.getDependencyStatus(t2.id);\n    expect(updated[t1.id]).toBe(true);\n  });\n});\n\n// ─── Phase 8: Concurrency Control ──────────────────────────────────────────\n\ndescribe('Phase 8: Concurrency Control', () => {\n  it('should default to no limit', () => {\n    expect(queue.getConcurrency()).toBeNull();\n  });\n\n  it('should set concurrency limit', () => {\n    queue.setConcurrency('default', 2);\n    expect(queue.getConcurrency('default')).toBe(2);\n  });\n\n  it('should block retrieval at concurrency limit', () => {\n    queue.setConcurrency('default', 1);\n    queue.addTask('a');\n    queue.addTask('b');\n\n    const t1 = queue.getNextTask();\n    expect(t1).not.toBeNull();\n\n    // Limit reached\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should free slot on completion', () => {\n    queue.setConcurrency('default', 1);\n    queue.addTask('a');\n    queue.addTask('b');\n\n    const t1 = queue.getNextTask()!;\n    queue.complete(t1.id);\n\n    expect(queue.getNextTask()).not.toBeNull();\n  });\n\n  it('should track active count', () => {\n    queue.addTask('a');\n    queue.addTask('b');\n\n    expect(queue.getActiveCount()).toBe(0);\n    queue.getNextTask();\n    expect(queue.getActiveCount()).toBe(1);\n  });\n});\n\n// ─── Phase 9: Progress and Cancellation ─────────────────────────────────────\n\ndescribe('Phase 9: Progress and Cancellation', () => {\n  it('should update and query progress', () => {\n    const task = queue.addTask('data');\n    queue.getNextTask();\n\n    queue.updateProgress(task.id, 50, 'halfway');\n    const updated = queue.getTask(task.id)!;\n    expect(updated.progress).toBe(50);\n    expect(updated.progressMessage).toBe('halfway');\n  });\n\n  it('should notify progress subscribers', () => {\n    const task = queue.addTask('data');\n    queue.getNextTask();\n\n    const updates: number[] = [];\n    queue.onProgress(task.id, (u) => updates.push(u.progress));\n\n    queue.updateProgress(task.id, 25);\n    queue.updateProgress(task.id, 75);\n\n    expect(updates).toEqual([25, 75]);\n  });\n\n  it('should support unsubscribe', () => {\n    const task = queue.addTask('data');\n    queue.getNextTask();\n\n    const updates: number[] = [];\n    const unsub = queue.onProgress(task.id, (u) => updates.push(u.progress));\n\n    queue.updateProgress(task.id, 25);\n    unsub();\n    queue.updateProgress(task.id, 75);\n\n    expect(updates).toEqual([25]);\n  });\n\n  it('should cancel pending task', () => {\n    const task = queue.addTask('data');\n    queue.cancel(task.id);\n\n    expect(task.status).toBe('cancelled');\n    expect(queue.getNextTask()).toBeNull();\n  });\n\n  it('should cancel processing task', () => {\n    const task = queue.addTask('data');\n    queue.getNextTask();\n    queue.cancel(task.id);\n\n    expect(task.status).toBe('cancelled');\n  });\n\n  it('should not retry cancelled tasks', () => {\n    const task = queue.addTask('data', { maxRetries: 3 });\n    queue.getNextTask();\n    queue.cancel(task.id);\n\n    // Cannot fail a cancelled task\n    expect(task.status).toBe('cancelled');\n  });\n});\n\n// ─── Phase 10: Recurring Tasks ──────────────────────────────────────────────\n\ndescribe('Phase 10: Recurring Tasks', () => {\n  it('should create a schedule', () => {\n    const sched = queue.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n    expect(sched.id).toBeDefined();\n    expect(sched.cron).toBe('*/5 * * * *');\n    expect(sched.queue).toBe('default');\n  });\n\n  it('should list active schedules', () => {\n    queue.addSchedule('*/5 * * * *', 'default', 'task1');\n    queue.addSchedule('0 * * * *', 'default', 'task2');\n\n    expect(queue.getSchedules().length).toBe(2);\n  });\n\n  it('should remove a schedule', () => {\n    const sched = queue.addSchedule('*/5 * * * *', 'default', 'task1');\n    queue.removeSchedule(sched.id);\n\n    expect(queue.getSchedules().length).toBe(0);\n  });\n\n  it('should enqueue tasks on tick when due', () => {\n    queue.addSchedule('*/5 * * * *', 'default', { type: 'recurring' });\n\n    // Tick at a time that matches */5 (minute divisible by 5)\n    const matchingTime = new Date(2024, 0, 1, 12, 10, 0);\n    const tasks = queue.tick(matchingTime);\n\n    expect(tasks.length).toBe(1);\n    expect(tasks[0].payload).toEqual({ type: 'recurring' });\n  });\n\n  it('should not duplicate on same minute tick', () => {\n    queue.addSchedule('*/5 * * * *', 'default', 'data');\n\n    const time = new Date(2024, 0, 1, 12, 10, 0);\n    queue.tick(time);\n    const second = queue.tick(time);\n\n    expect(second.length).toBe(0);\n  });\n});\n\n// ─── Phase 11: Middleware Pipeline ──────────────────────────────────────────\n\ndescribe('Phase 11: Middleware Pipeline', () => {\n  it('should run middleware in order', async () => {\n    const order: string[] = [];\n\n    queue.use('default', async (_task, next) => {\n      order.push('mw1');\n      await next();\n    });\n    queue.use('default', async (_task, next) => {\n      order.push('mw2');\n      await next();\n    });\n    queue.setHandler('default', () => {\n      order.push('handler');\n    });\n\n    queue.addTask('data');\n    await queue.process();\n\n    expect(order).toEqual(['mw1', 'mw2', 'handler']);\n  });\n\n  it('should skip processing if middleware does not call next', async () => {\n    const order: string[] = [];\n\n    queue.use('default', async () => {\n      order.push('mw1');\n      // Not calling next\n    });\n    queue.setHandler('default', () => {\n      order.push('handler');\n    });\n\n    queue.addTask('data');\n    await queue.process();\n\n    expect(order).toEqual(['mw1']);\n  });\n\n  it('should mark task as failed on middleware error', async () => {\n    queue.use('default', async () => {\n      throw new Error('middleware error');\n    });\n\n    const task = queue.addTask('data', { maxRetries: 1, backoffDelay: 0 });\n    await queue.process();\n\n    // After first fail with maxRetries=1, task should be failed/in DLQ\n    expect(task.status).toBe('failed');\n  });\n\n  it('should allow middleware to modify task', async () => {\n    queue.use('default', async (task, next) => {\n      (task.payload as Record<string, unknown>).modified = true;\n      await next();\n    });\n\n    let receivedPayload: unknown;\n    queue.setHandler('default', (task) => {\n      receivedPayload = task.payload;\n    });\n\n    queue.addTask({ original: true });\n    await queue.process();\n\n    expect((receivedPayload as Record<string, unknown>).modified).toBe(true);\n  });\n});\n\n// ─── Phase 12: Graceful Shutdown ────────────────────────────────────────────\n\ndescribe('Phase 12: Graceful Shutdown', () => {\n  it('should reject new tasks after shutdown', async () => {\n    await queue.shutdown();\n    expect(() => queue.addTask('data')).toThrow();\n  });\n\n  it('should complete immediately with no processing tasks', async () => {\n    const result = await queue.shutdown();\n    expect(result.completed).toBe(0);\n    expect(result.forceCancelled).toBe(0);\n    expect(result.elapsed).toBeGreaterThanOrEqual(0);\n  });\n\n  it('should return same result on multiple shutdown calls', async () => {\n    const result1 = await queue.shutdown();\n    const result2 = await queue.shutdown();\n    expect(result1).toBe(result2);\n  });\n\n  it('should force-cancel tasks exceeding timeout', async () => {\n    queue.addTask('slow');\n    queue.getNextTask(); // Now processing\n\n    const result = await queue.shutdown({ timeout: 50 });\n    expect(result.forceCancelled).toBe(1);\n  });\n\n  it('should run shutdown callbacks', async () => {\n    let called = false;\n    queue.onShutdown(() => { called = true; });\n\n    await queue.shutdown();\n    expect(called).toBe(true);\n  });\n});\n","structuredPatch":[{"oldStart":591,"oldLines":10,"newStart":591,"newLines":10,"lines":["       throw new Error('middleware error');","     });"," ","-    const task = queue.addTask('data', { maxRetries: 1, backoffDelay: 0 });","+    const task = queue.addTask('data', { maxRetries: 0, backoffDelay: 0 });","     await queue.process();"," ","-    // After first fail with maxRetries=1, task should be failed/in DLQ","+    // After first fail with