ap();\n  private queues: Map<string, QueueState> = new Map();\n  private deadLetterQueues: Map<string, Task[]> = new Map();\n  private progressSubscribers: Map<string, Set<ProgressCallback>> = new Map();\n  private schedules: Map<string, Schedule> = new Map();\n  private isShutdown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  // ─── Phase 1 & 2: Basic FIFO Queue + Named Queues ──────────────\n\n  enqueue(payload: unknown, options?: TaskOptions): Task {\n    if (this.isShutdown) {\n      throw new Error('Queue is shut down. Cannot add new tasks.');\n    }\n\n    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? DEFAULT_PRIORITY;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Validate dependencies exist\n    if (options?.dependencies) {\n      for (const depId of options.dependencies) {\n        if (!this.tasks.has(depId)) {\n          throw new Error(`Dependency task '${depId}' does not exist.`);\n        }\n      }\n      // Check for circular dependencies\n      this.detectCircularDependencies(options.dependencies);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n\n    if (options?.runAt) {\n      availableAt = options.runAt;\n    } else if (options?.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    const dependencies = options?.dependencies ?? [];\n    const dependencyStatus: Record<string, boolean> = {};\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      dependencyStatus[depId] = depTask?.status === 'completed';\n    }\n\n    const task: Task = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      queue: queueName,\n      priority,\n      createdAt: now,\n      availableAt,\n      attempt: 0,\n      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      progress: 0,\n      failureCount: 0,\n      dependencies,\n      dependencyStatus,\n    };\n\n    this.tasks.set(task.id, task);\n    this.ensureQueue(queueName);\n\n    return task;\n  }\n\n  // Alias for backward compatibility\n  addTask(payload: unknown, options?: TaskOptions): Task {\n    return this.enqueue(payload, options);\n  }\n\n  dequeue(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueState = this.queues.get(name);\n\n    // Check concurrency limit\n    if (queueState?.concurrencyLimit != null) {\n      const activeCount = this.getActiveCount(name);\n      if (activeCount >= queueState.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n    const pendingTasks = this.getPendingTasks(name, now);\n\n    if (pendingTasks.length === 0) {\n      return null;\n    }\n\n    // Sort: priority ASC, then availableAt ASC, then createdAt ASC\n    pendingTasks.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n        return a.availableAt.getTime() - b.availableAt.getTime();\n      }\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = pendingTasks[0];\n    task.status = 'processing';\n    task.attempt += 1;\n\n    return task;\n  }\n\n  // Alias for backward compatibility\n  getNextTask(queueName?: string): Task | null {\n    return this.dequeue(queueName);\n  }\n\n  getTask(taskId: string): Task | null {\n    return this.tasks.get(taskId) ?? null;\n  }\n\n  size(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === name && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ─── Phase 5: Retry with Backoff ─────────────────────────────────\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task '${taskId}' not found.`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task '${taskId}' is not in processing state.`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Check if any blocked tasks can be unblocked\n    this.updateDependents(taskId);\n  }\n\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task '${taskId}' not found.`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task '${taskId}' is not in processing state.`);\n    }\n\n    task.error = error;\n    task.failureCount += 1;\n\n    if (task.attempt <= task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n      task.progressMessage = undefined;\n    } else {\n      // Exhausted retries\n      task.status = 'failed';\n\n      // Move to DLQ\n      this.addToDeadLetterQueue(task);\n    }\n  }\n\n  // ─── Phase 6: Dead Letter Queue ──────────────────────────────────\n\n  getDeadLetterTasks(queueName?: string): Task[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return [...(this.deadLetterQueues.get(name) ?? [])];\n  }\n\n  retryDeadLetterTask(taskId: string): Task {\n    for (const [queueName, dlqTasks] of this.deadLetterQueues.entries()) {\n      const index = dlqTasks.findIndex(t => t.id === taskId);\n      if (index !== -1) {\n        const task = dlqTasks[index];\n        dlqTasks.splice(index, 1);\n\n        // Reset for fresh retry round\n        task.status = 'pending';\n        task.attempt = 0;\n        task.availableAt = new Date();\n        task.progress = 0;\n        task.progressMessage = undefined;\n        task.error = undefined;\n\n        this.tasks.set(task.id, task);\n        this.ensureQueue(queueName);\n\n        return task;\n      }\n    }\n    throw new Error(`Task '${taskId}' not found in any dead letter queue.`);\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    this.deadLetterQueues.set(name, []);\n  }\n\n  // ─── Phase 7: Task Dependencies ──────────────────────────────────\n\n  getDependencyStatus(taskId: string): Record<string, boolean> {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task '${taskId}' not found.`);\n    }\n\n    // Refresh dependency status\n    for (const depId of task.dependencies) {\n      const depTask = this.tasks.get(depId);\n      task.dependencyStatus[depId] = depTask?.status === 'completed';\n    }\n\n    return { ...task.dependencyStatus };\n  }\n\n  // ─── Phase 8: Concurrency Control ────────────────────────────────\n\n  setConcurrency(queueName: string, limit: number | null): void {\n    const queue = this.ensureQueue(queueName);\n    queue.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName?: string): number | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return this.queues.get(name)?.concurrencyLimit ?? null;\n  }\n\n  getActiveCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === name && task.status === 'processing') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ─── Phase 9: Progress and Cancellation ──────────────────────────\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task '${taskId}' not found.`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task '${taskId}' is not in processing state.`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    const subscribers = this.progressSubscribers.get(taskId);\n    if (subscribers) {\n      const update: ProgressUpdate = { taskId, progress, message };\n      for (const callback of subscribers) {\n        callback(update);\n      }\n    }\n  }\n\n  onProgress(taskId: string, callback: ProgressCallback): () => void {\n    if (!this.progressSubscribers.has(taskId)) {\n      this.progressSubscribers.set(taskId, new Set());\n    }\n    this.progressSubscribers.get(taskId)!.add(callback);\n\n    return () => {\n      const subs = this.progressSubscribers.get(taskId);\n      if (subs) {\n        subs.delete(callback);\n        if (subs.size === 0) {\n          this.progressSubscribers.delete(taskId);\n        }\n      }\n    };\n  }\n\n  cancel(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task '${taskId}' not found.`);\n    }\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Task '${taskId}' cannot be cancelled (status: ${task.status}).`);\n    }\n\n    task.status = 'cancelled';\n  }\n\n  // ─── Phase 10: Recurring Tasks ───────────────────────────────────\n\n  addSchedule(cron: string, queueName: string, payload: unknown): Schedule {\n    this.validateCron(cron);\n\n    const schedule: Schedule = {\n      id: randomUUID(),\n      cron,\n      queue: queueName,\n      payload,\n      lastRun: null,\n      createdAt: new Date(),\n    };\n\n    this.schedules.set(schedule.id, schedule);\n    this.ensureQueue(queueName);\n\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): void {\n    if (!this.schedules.has(scheduleId)) {\n      throw new Error(`Schedule '${scheduleId}' not found.`);\n    }\n    this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const createdTasks: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.shouldRunSchedule(schedule, currentTime)) {\n        const task = this.enqueue(\n          typeof schedule.payload === 'object' && schedule.payload !== null\n            ? JSON.parse(JSON.stringify(schedule.payload))\n            : schedule.payload,\n          { queue: schedule.queue }\n        );\n        createdTasks.push(task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return createdTasks;\n  }\n\n  // ─── Phase 11: Middleware Pipeline ────────────────────────────────\n\n  use(queueName: string, middleware: Middleware): void {\n    const queue = this.ensureQueue(queueName);\n    queue.middlewares.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: TaskHandler): void {\n    const queue = this.ensureQueue(queueName);\n    queue.handler = handler;\n  }\n\n  async process(queueName?: string): Promise<Task | null> {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const task = this.dequeue(name);\n\n    if (!task) {\n      return null;\n    }\n\n    const queueState = this.queues.get(name);\n    const middlewares = queueState?.middlewares ?? [];\n    const handler = queueState?.handler ?? null;\n\n    try {\n      await this.runMiddlewarePipeline(task, middlewares, handler);\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.fail(task.id, err instanceof Error ? err.message : String(err));\n      }\n    }\n\n    return task;\n  }\n\n  // ─── Phase 12: Graceful Shutdown ─────────────────────────────────\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    if (this.shutdownPromise) {\n      return this.shutdownPromise;\n    }\n\n    this.isShutdown = true;\n    this.shutdownPromise = this.performShutdown(options);\n    return this.shutdownPromise;\n  }\n\n  // ─── Internal Helpers ─────────────────────────────────────────────\n\n  private ensureQueue(name: string): QueueState {\n    if (!this.queues.has(name)) {\n      this.queues.set(name, {\n        name,\n        concurrencyLimit: null,\n        middlewares: [],\n        handler: null,\n      });\n    }\n    return this.queues.get(name)!;\n  }\n\n  private getPendingTasks(queueName: string, now: Date): Task[] {\n    const result: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.queue !== queueName || task.status !== 'pending') continue;\n\n      // Check availability time\n      if (task.availableAt > now) continue;\n\n      // Check dependencies\n      if (task.dependencies.length > 0) {\n        let allResolved = true;\n        for (const depId of task.dependencies) {\n          const dep = this.tasks.get(depId);\n          if (!dep || dep.status !== 'completed') {\n            allResolved = false;\n            break;\n          }\n        }\n        if (!allResolved) continue;\n      }\n\n      result.push(task);\n    }\n    return result;\n  }\n\n  private updateDependents(completedTaskId: string): void {\n    for (const task of this.tasks.values()) {\n      if (task.dependencies.includes(completedTaskId)) {\n        task.dependencyStatus[completedTaskId] = true;\n      }\n    }\n  }\n\n  private addToDeadLetterQueue(task: Task): void {\n    if (!this.deadLetterQueues.has(task.queue)) {\n      this.deadLetterQueues.set(task.queue, []);\n    }\n    this.deadLetterQueues.get(task.queue)!.push(task);\n  }\n\n  private detectCircularDependencies(newDeps: string[]): void {\n    const visited = new Set<string>();\n    const visiting = new Set<string>();\n\n    const hasCycle = (taskId: string): boolean => {\n      if (visiting.has(taskId)) return true;\n      if (visited.has(taskId)) return false;\n\n      visiting.add(taskId);\n      const task = this.tasks.get(taskId);\n      if (task) {\n        for (const depId of task.dependencies) {\n          if (hasCycle(depId)) return true;\n        }\n      }\n      visiting.delete(taskId);\n      visited.add(taskId);\n      return false;\n    };\n\n    for (const depId of newDeps) {\n      if (hasCycle(depId)) {\n        throw new Error('Circular dependency detected.');\n      }\n    }\n  }\n\n  private validateCron(cron: string): void {\n    const parts = cron.trim().split(/\\s+/);\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: '${cron}'. Expected 5 fields.`);\n    }\n\n    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n\n    if (minute !== '*' && !minute.match(/^\\*\\/\\d+$/) && !minute.match(/^\\d+$/)) {\n      throw new Error(`Invalid cron minute field: '${minute}'.`);\n    }\n\n    if (hour !== '*' && !hour.match(/^\\d+$/)) {\n      throw new Error(`Invalid cron hour field: '${hour}'.`);\n    }\n\n    for (const field of [dayOfMonth, month, dayOfWeek]) {\n      if (field !== '*' && !field.match(/^\\d+$/)) {\n        throw new Error(`Invalid cron field: '${field}'.`);\n      }\n    }\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const parts = schedule.cron.trim().split(/\\s+/);\n    const [minuteField, hourField, dayOfMonthField, monthField, dayOfWeekField] = parts;\n\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n    const currentDayOfMonth = now.getDate();\n    const currentMonth = now.getMonth() + 1;\n    const currentDayOfWeek = now.getDay();\n\n    if (!this.matchCronField(minuteField, currentMinute)) return false;\n    if (!this.matchCronField(hourField, currentHour)) return false;\n    if (!this.matchCronField(dayOfMonthField, currentDayOfMonth)) return false;\n    if (!this.matchCronField(monthField, currentMonth)) return false;\n    if (!this.matchCronField(dayOfWeekField, currentDayOfWeek)) return false;\n\n    // Avoid duplicate runs in the same minute window\n    if (schedule.lastRun) {\n      const lastRunMinute = new Date(\n        schedule.lastRun.getFullYear(),\n        schedule.lastRun.getMonth(),\n        schedule.lastRun.getDate(),\n        schedule.lastRun.getHours(),\n        schedule.lastRun.getMinutes()\n      );\n      const currentMinuteStart = new Date(\n        now.getFullYear(),\n        now.getMonth(),\n        now.getDate(),\n        now.getHours(),\n        now.getMinutes()\n      );\n      if (lastRunMinute.getTime() >= currentMinuteStart.getTime()) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  private matchCronField(field: string, value: number): boolean {\n    if (field === '*') return true;\n\n    const stepMatch = field.match(/^\\*\\/(\\d+)$/);\n    if (stepMatch) {\n      const step = parseInt(stepMatch[1], 10);\n      return value % step === 0;\n    }\n\n    const num = parseInt(field, 10);\n    return value === num;\n  }\n\n  private async runMiddlewarePipeline(\n    task: Task,\n    middlewares: Middleware[],\n    handler: TaskHandler | null\n  ): Promise<void> {\n    let index = 0;\n\n    const next = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const middleware = middlewares[index++];\n        await middleware(task, next);\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    await next();\n  }\n\n  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    const startTime = Date.now();\n    const timeout = options?.timeout ?? 30000;\n\n    // Run shutdown callbacks\n    for (const callback of this.shutdownCallbacks) {\n      try {\n        await callback();\n      } catch {\n        // Igno