─────────\n   435→\n   436→  onShutdown(callback: () => void | Promise<void>): void {\n   437→    this.shutdownCallbacks.push(callback);\n   438→  }\n   439→\n   440→  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n   441→    if (this.shutdownPromise) {\n   442→      return this.shutdownPromise;\n   443→    }\n   444→\n   445→    this.isShutdown = true;\n   446→    this.shutdownPromise = this.performShutdown(options);\n   447→    return this.shutdownPromise;\n   448→  }\n   449→\n   450→  // ─── Internal Helpers ─────────────────────────────────────────────\n   451→\n   452→  private ensureQueue(name: string): QueueState {\n   453→    if (!this.queues.has(name)) {\n   454→      this.queues.set(name, {\n   455→        name,\n   456→        concurrencyLimit: null,\n   457→        middlewares: [],\n   458→        handler: null,\n   459→      });\n   460→    }\n   461→    return this.queues.get(name)!;\n   462→  }\n   463→\n   464→  private getPendingTasks(queueName: string, now: Date): Task[] {\n   465→    const result: Task[] = [];\n   466→    for (const task of this.tasks.values()) {\n   467→      if (task.queue !== queueName || task.status !== 'pending') continue;\n   468→\n   469→      // Check availability time\n   470→      if (task.availableAt > now) continue;\n   471→\n   472→      // Check dependencies\n   473→      if (task.dependencies.length > 0) {\n   474→        let allResolved = true;\n   475→        for (const depId of task.dependencies) {\n   476→          const dep = this.tasks.get(depId);\n   477→          if (!dep || dep.status !== 'completed') {\n   478→            allResolved = false;\n   479→            break;\n   480→          }\n   481→        }\n   482→        if (!allResolved) continue;\n   483→      }\n   484→\n   485→      result.push(task);\n   486→    }\n   487→    return result;\n   488→  }\n   489→\n   490→  private updateDependents(completedTaskId: string): void {\n   491→    for (const task of this.tasks.values()) {\n   492→      if (task.dependencies.includes(completedTaskId)) {\n   493→        task.dependencyStatus[completedTaskId] = true;\n   494→      }\n   495→    }\n   496→  }\n   497→\n   498→  private addToDeadLetterQueue(task: Task): void {\n   499→    if (!this.deadLetterQueues.has(task.queue)) {\n   500→      this.deadLetterQueues.set(task.queue, []);\n   501→    }\n   502→    this.deadLetterQueues.get(task.queue)!.push(task);\n   503→  }\n   504→\n   505→  private detectCircularDependencies(newDeps: string[]): void {\n   506→    const visited = new Set<string>();\n   507→    const visiting = new Set<string>();\n   508→\n   509→    const hasCycle = (taskId: string): boolean => {\n   510→      if (visiting.has(taskId)) return true;\n   511→      if (visited.has(taskId)) return false;\n   512→\n   513→      visiting.add(taskId);\n   514→      const task = this.tasks.get(taskId);\n   515→      if (task) {\n   516→        for (const depId of task.dependencies) {\n   517→          if (hasCycle(depId)) return true;\n   518→        }\n   519→      }\n   520→      visiting.delete(taskId);\n   521→      visited.add(taskId);\n   522→      return false;\n   523→    };\n   524→\n   525→    for (const depId of newDeps) {\n   526→      if (hasCycle(depId)) {\n   527→        throw new Error('Circular dependency detected.');\n   528→      }\n   529→    }\n   530→  }\n   531→\n   532→  private validateCron(cron: string): void {\n   533→    const parts = cron.trim().split(/\\s+/);\n   534→    if (parts.length !== 5) {\n   535→      throw new Error(`Invalid cron expression: '${cron}'. Expected 5 fields.`);\n   536→    }\n   537→\n   538→    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n   539→\n   540→    if (minute !== '*' && !minute.match(/^\\*\\/\\d+$/) && !minute.match(/^\\d+$/)) {\n   541→      throw new Error(`Invalid cron minute field: '${minute}'.`);\n   542→    }\n   543→\n   544→    if (hour !== '*' && !hour.match(/^\\d+$/)) {\n   545→      throw new Error(`Invalid cron hour field: '${hour}'.`);\n   546→    }\n   547→\n   548→    for (const field of [dayOfMonth, month, dayOfWeek]) {\n   549→      if (field !== '*' && !field.match(/^\\d+$/)) {\n   550→        throw new Error(`Invalid cron field: '${field}'.`);\n   551→      }\n   552→    }\n   553→  }\n   554→\n   555→  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n   556→    const parts = schedule.cron.trim().split(/\\s+/);\n   557→    const [minuteField, hourField, dayOfMonthField, monthField, dayOfWeekField] = parts;\n   558→\n   559→    const currentMinute = now.getMinutes();\n   560→    const currentHour = now.getHours();\n   561→    const currentDayOfMonth = now.getDate();\n   562→    const currentMonth = now.getMonth() + 1;\n   563→    const currentDayOfWeek = now.getDay();\n   564→\n   565→    if (!this.matchCronField(minuteField, currentMinute)) return false;\n   566→    if (!this.matchCronField(hourField, currentHour)) return false;\n   567→    if (!this.matchCronField(dayOfMonthField, currentDayOfMonth)) return false;\n   568→    if (!this.matchCronField(monthField, currentMonth)) return false;\n   569→    if (!this.matchCronField(dayOfWeekField, currentDayOfWeek)) return false;\n   570→\n   571→    // Avoid duplicate runs in the same minute window\n   572→    if (schedule.lastRun) {\n   573→      const lastRunMinute = new Date(\n   574→        schedule.lastRun.getFullYear(),\n   575→        schedule.lastRun.getMonth(),\n   576→        schedule.lastRun.getDate(),\n   577→        schedule.lastRun.getHours(),\n   578→        schedule.lastRun.getMinutes()\n   579→      );\n   580→      const currentMinuteStart = new Date(\n   581→        now.getFullYear(),\n   582→        now.getMonth(),\n   583→        now.getDate(),\n   584→        now.getHours(),\n   585→        now.getMinutes()\n   586→      );\n   587→      if (lastRunMinute.getTime() >= currentMinuteStart.getTime()) {\n   588→        return false;\n   589→      }\n   590→    }\n   591→\n   592→    return true;\n   593→  }\n   594→\n   595→  private matchCronField(field: string, value: number): boolean {\n   596→    if (field === '*') return true;\n   597→\n   598→    const stepMatch = field.match(/^\\*\\/(\\d+)$/);\n   599→    if (stepMatch) {\n   600→      const step = parseInt(stepMatch[1], 10);\n   601→      return value % step === 0;\n   602→    }\n   603→\n   604→    const num = parseInt(field, 10);\n   605→    return value === num;\n   606→  }\n   607→\n   608→  private async runMiddlewarePipeline(\n   609→    task: Task,\n   610→    middlewares: Middleware[],\n   611→    handler: TaskHandler | null\n   612→  ): Promise<void> {\n   613→    let index = 0;\n   614→\n   615→    const next = async (): Promise<void> => {\n   616→      if (index < middlewares.length) {\n   617→        const middleware = middlewares[index++];\n   618→        await middleware(task, next);\n   619→      } else if (handler) {\n   620→        await handler(task);\n   621→      }\n   622→    };\n   623→\n   624→    await next();\n   625→  }\n   626→\n   627→  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n   628→    const startTime = Date.now();\n   629→    const timeout = options?.timeout ?? 30000;\n   630→\n   631→    // Run shutdown callbacks\n   632→    for (const callback of this.shutdownCallbacks) {\n   633→      try {\n   634→        await callback();\n   635→      } catch {\n   636→        // Ignore callback errors during shutdown\n   637→      }\n   638→    }\n   639→\n   640→    // Get all currently processing tasks\n   641→    const processingTasks: Task[] = [];\n   642→    for (const task of this.tasks.values()) {\n   643→      if (task.status === 'processing') {\n   644→        processingTasks.push(task);\n   645→      }\n   646→    }\n   647→\n   648→    if (processingTasks.length === 0) {\n   649→      return {\n   650→        completed: 0,\n   651→        forceCancelled: 0,\n   652→        elapsed: Date.now() - startTime,\n   653→      };\n   654→    }\n   655→\n   656→    // Wait for processing tasks to finish, up to timeout\n   657→    let completed = 0;\n   658→    let forceCancelled = 0;\n   659→\n   660→    const waitForCompletion = new Promise<void>((resolve) => {\n   661→      const check = () => {\n   662→        let allDone = true;\n   663→        for (const task of processingTasks) {\n   664→          if (task.status === 'processing') {\n   665→            allDone = false;\n   666→            break;\n   667→          }\n   668→        }\n   669→        if (allDone) {\n   670→          resolve();\n   671→        } else {\n   672→          setTimeout(check, 10);\n   673→        }\n   674→      };\n   675→      check();\n   676→    });\n   677→\n   678→    const timeoutPromise = new Promise<void>((resolve) => {\n   679→      setTimeout(resolve, timeout);\n   680→    });\n   681→\n   682→    await Promise.race([waitForCompletion, timeoutPromise]);\n   683→\n   684→    // Count results\n   685→    for (const task of processingTasks) {\n   686→      if (task.status === 'processing') {\n   687→        task.status = 'cancelled';\n   688→        forceCancelled++;\n   689→      } else {\n   690→        completed++;\n   691→      }\n   692→    }\n   693→\n   694→    return {\n   695→      completed,\n   696→      forceCancelled,\n   697→      elapsed: Date.now() - startTime,\n   698→    };\n   699→  }\n   700→}\n   701→"}]},"parent_tool_use_id":null,"session_id":"8d05ce79-98b1-4890-9460-df7d22557abf","uuid":"7b055fe6-710a-432f-b907-04f1ba773526","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/task-queue.ts","content":"import { randomUUID } from 'node:crypto';\nimport type {\n  Task,\n  TaskOptions,\n  ProgressUpdate,\n  ProgressCallback,\n  Middleware,\n  TaskHandler,\n  Schedule,\n  ShutdownOptions,\n  ShutdownResult,\n} from './types.js';\n\nconst DEFAULT_QUEUE = 'default';\nconst DEFAULT_PRIORITY = 5;\nconst DEFAULT_MAX_RETRIES = 3;\nconst DEFAULT_BACKOFF_DELAY = 1000;\n\ninterface QueueState {\n  name: string;\n  concurrencyLimit: number | null;\n  middlewares: Middleware[];\n  handler: TaskHandler | null;\n}\n\nexport class TaskQueue {\n  private tasks: Map<string, Task> = new Map();\n  private taskSeq: Map<string, number> = new Map();\n  private seqCounter = 0;\n  private queues: Map<string, QueueState> = new Map();\n  private deadLetterQueues: Map<string, Task[]> = new Map();\n  private progressSubscribers: Map<string, Set<ProgressCallback>> = new Map();\n  private schedules: Map<string, Schedule> = new Map();\n  private isShutdown = false;\n  private shutdownPromise: Promise<ShutdownResult> | null = null;\n  private shutdownCallbacks: Array<() => void | Promise<void>> = [];\n\n  // ─── Phase 1 & 2: Basic FIFO Queue + Named Queues ──────────────\n\n  enqueue(payload: unknown, options?: TaskOptions): Task {\n    if (this.isShutdown) {\n      throw new Error('Queue is shut down. Cannot add new tasks.');\n    }\n\n    const queueName = options?.queue ?? DEFAULT_QUEUE;\n    const priority = options?.priority ?? DEFAULT_PRIORITY;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Validate dependencies exist\n    if (options?.dependencies) {\n      for (const depId of options.dependencies) {\n        if (!this.tasks.has(depId)) {\n          throw new Error(`Dependency task '${depId}' does not exist.`);\n        }\n      }\n      // Check for circular dependencies\n      this.detectCircularDependencies(options.dependencies);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n\n    if (options?.runAt) {\n      availableAt = options.runAt;\n    } else if (options?.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    const dependencies = options?.dependencies ?? [];\n    const dependencyStatus: Record<string, boolean> = {};\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      dependencyStatus[depId] = depTask?.status === 'completed';\n    }\n\n    const task: Task = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      queue: queueName,\n      priority,\n      createdAt: now,\n      availableAt,\n      attempt: 0,\n      maxRetries: options?.maxRetries ?? DEFAULT_MAX_RETRIES,\n      backoffDelay: options?.backoffDelay ?? DEFAULT_BACKOFF_DELAY,\n      progress: 0,\n      failureCount: 0,\n      dependencies,\n      dependencyStatus,\n    };\n\n    this.tasks.set(task.id, task);\n    this.taskSeq.set(task.id, this.seqCounter++);\n    this.ensureQueue(queueName);\n\n    return task;\n  }\n\n  // Alias for backward compatibility\n  addTask(payload: unknown, options?: TaskOptions): Task {\n    return this.enqueue(payload, options);\n  }\n\n  dequeue(queueName?: string): Task | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const queueState = this.queues.get(name);\n\n    // Check concurrency limit\n    if (queueState?.concurrencyLimit != null) {\n      const activeCount = this.getActiveCount(name);\n      if (activeCount >= queueState.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n    const pendingTasks = this.getPendingTasks(name, now);\n\n    if (pendingTasks.length === 0) {\n      return null;\n    }\n\n    // Sort: priority ASC, then availableAt ASC, then FIFO (sequence number)\n    pendingTasks.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n        return a.availableAt.getTime() - b.availableAt.getTime();\n      }\n      return (this.taskSeq.get(a.id) ?? 0) - (this.taskSeq.get(b.id) ?? 0);\n    });\n\n    const task = pendingTasks[0];\n    task.status = 'processing';\n    task.attempt += 1;\n\n    return task;\n  }\n\n  // Alias for backward compatibility\n  getNextTask(queueName?: string): Task | null {\n    return this.dequeue(queueName);\n  }\n\n  getTask(taskId: string): Task | null {\n    return this.tasks.get(taskId) ?? null;\n  }\n\n  size(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === name && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  getQueues(): string[] {\n    return Array.from(this.queues.keys());\n  }\n\n  // ─── Phase 5: Retry with Backoff ─────────────────────────────────\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task '${taskId}' not found.`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task '${taskId}' is not in processing state.`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Check if any blocked tasks can be unblocked\n    this.updateDependents(taskId);\n  }\n\n  fail(taskId: string, error?: string | Error): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task '${taskId}' not found.`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task '${taskId}' is not in processing state.`);\n    }\n\n    task.error = error instanceof Error ? error.message : error;\n    task.failureCount += 1;\n\n    if (task.attempt <= task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n      task.progressMessage = undefined;\n    } else {\n      // Exhausted retries\n      task.status = 'failed';\n\n      // Move to DLQ\n      this.addToDeadLetterQueue(task);\n    }\n  }\n\n  // ─── Phase 6: Dead Letter Queue ──────────────────────────────────\n\n  getDeadLetterTasks(queueName?: string): Task[] {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return [...(this.deadLetterQueues.get(name) ?? [])];\n  }\n\n  retryDeadLetterTask(taskId: string): Task {\n    for (const [queueName, dlqTasks] of this.deadLetterQueues.entries()) {\n      const index = dlqTasks.findIndex(t => t.id === taskId);\n      if (index !== -1) {\n        const task = dlqTasks[index];\n        dlqTasks.splice(index, 1);\n\n        // Reset for fresh retry round\n        task.status = 'pending';\n        task.attempt = 0;\n        task.availableAt = new Date();\n        task.progress = 0;\n        task.progressMessage = undefined;\n        task.error = undefined;\n\n        this.tasks.set(task.id, task);\n        this.ensureQueue(queueName);\n\n        return task;\n      }\n    }\n    throw new Error(`Task '${taskId}' not found in any dead letter queue.`);\n  }\n\n  requeueDeadLetterTask(taskId: string): Task {\n    return this.retryDeadLetterTask(taskId);\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const name = queueName ?? DEFAULT_QUEUE;\n    this.deadLetterQueues.set(name, []);\n  }\n\n  // ─── Phase 7: Task Dependencies ──────────────────────────────────\n\n  getDependencyStatus(taskId: string): Record<string, boolean> {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task '${taskId}' not found.`);\n    }\n\n    // Refresh dependency status\n    for (const depId of task.dependencies) {\n      const depTask = this.tasks.get(depId);\n      task.dependencyStatus[depId] = depTask?.status === 'completed';\n    }\n\n    return { ...task.dependencyStatus };\n  }\n\n  // ─── Phase 8: Concurrency Control ────────────────────────────────\n\n  setConcurrency(queueName: string, limit: number | null): void {\n    const queue = this.ensureQueue(queueName);\n    queue.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName?: string): number | null {\n    const name = queueName ?? DEFAULT_QUEUE;\n    return this.queues.get(name)?.concurrencyLimit ?? null;\n  }\n\n  getActiveCount(queueName?: string): number {\n    const name = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === name && task.status === 'processing') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ─── Phase 9: Progress and Cancellation ──────────────────────────\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task '${taskId}' not found.`);\n    }\n    if (task.status !== 'processing') {\n      throw new Error(`Task '${taskId}' is not in processing state.`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    const subscribers = this.progressSubscribers.get(taskId);\n    if (subscribers) {\n      const update: ProgressUpdate = { taskId, progress, message };\n      for (const callback of subscribers) {\n        callback(update);\n      }\n    }\n  }\n\n  onProgress(taskId: string, callback: ProgressCallback): () => void {\n    if (!this.progressSubscribers.has(taskId)) {\n      this.progressSubscribers.set(taskId, new Set());\n    }\n    this.progressSubscribers.get(taskId)!.add(callback);\n\n    return () => {\n      const subs = this.progressSubscribers.get(taskId);\n      if (subs) {\n        subs.delete(callback);\n        if (subs.size === 0) {\n          this.progressSubscribers.delete(taskId);\n        }\n      }\n    };\n  }\n\n  cancel(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) {\n      throw new Error(`Task '${taskId}' not found.`);\n    }\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Task '${taskId}' cannot be cancelled (status: ${task.stat