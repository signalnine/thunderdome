his.isShutdown = true;\n   439→    this.shutdownPromise = this.performShutdown(options);\n   440→    return this.shutdownPromise;\n   441→  }\n   442→\n   443→  // ─── Internal Helpers ─────────────────────────────────────────────\n   444→\n   445→  private ensureQueue(name: string): QueueState {\n   446→    if (!this.queues.has(name)) {\n   447→      this.queues.set(name, {\n   448→        name,\n   449→        concurrencyLimit: null,\n   450→        middlewares: [],\n   451→        handler: null,\n   452→      });\n   453→    }\n   454→    return this.queues.get(name)!;\n   455→  }\n   456→\n   457→  private getPendingTasks(queueName: string, now: Date): Task[] {\n   458→    const result: Task[] = [];\n   459→    for (const task of this.tasks.values()) {\n   460→      if (task.queue !== queueName || task.status !== 'pending') continue;\n   461→\n   462→      // Check availability time\n   463→      if (task.availableAt > now) continue;\n   464→\n   465→      // Check dependencies\n   466→      if (task.dependencies.length > 0) {\n   467→        let allResolved = true;\n   468→        for (const depId of task.dependencies) {\n   469→          const dep = this.tasks.get(depId);\n   470→          if (!dep || dep.status !== 'completed') {\n   471→            allResolved = false;\n   472→            break;\n   473→          }\n   474→        }\n   475→        if (!allResolved) continue;\n   476→      }\n   477→\n   478→      result.push(task);\n   479→    }\n   480→    return result;\n   481→  }\n   482→\n   483→  private updateDependents(completedTaskId: string): void {\n   484→    for (const task of this.tasks.values()) {\n   485→      if (task.dependencies.includes(completedTaskId)) {\n   486→        task.dependencyStatus[completedTaskId] = true;\n   487→      }\n   488→    }\n   489→  }\n   490→\n   491→  private addToDeadLetterQueue(task: Task): void {\n   492→    if (!this.deadLetterQueues.has(task.queue)) {\n   493→      this.deadLetterQueues.set(task.queue, []);\n   494→    }\n   495→    this.deadLetterQueues.get(task.queue)!.push(task);\n   496→  }\n   497→\n   498→  private detectCircularDependencies(newDeps: string[]): void {\n   499→    const visited = new Set<string>();\n   500→    const visiting = new Set<string>();\n   501→\n   502→    const hasCycle = (taskId: string): boolean => {\n   503→      if (visiting.has(taskId)) return true;\n   504→      if (visited.has(taskId)) return false;\n   505→\n   506→      visiting.add(taskId);\n   507→      const task = this.tasks.get(taskId);\n   508→      if (task) {\n   509→        for (const depId of task.dependencies) {\n   510→          if (hasCycle(depId)) return true;\n   511→        }\n   512→      }\n   513→      visiting.delete(taskId);\n   514→      visited.add(taskId);\n   515→      return false;\n   516→    };\n   517→\n   518→    for (const depId of newDeps) {\n   519→      if (hasCycle(depId)) {\n   520→        throw new Error('Circular dependency detected.');\n   521→      }\n   522→    }\n   523→  }\n   524→\n   525→  private validateCron(cron: string): void {\n   526→    const parts = cron.trim().split(/\\s+/);\n   527→    if (parts.length !== 5) {\n   528→      throw new Error(`Invalid cron expression: '${cron}'. Expected 5 fields.`);\n   529→    }\n   530→\n   531→    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;\n   532→\n   533→    if (minute !== '*' && !minute.match(/^\\*\\/\\d+$/) && !minute.match(/^\\d+$/)) {\n   534→      throw new Error(`Invalid cron minute field: '${minute}'.`);\n   535→    }\n   536→\n   537→    if (hour !== '*' && !hour.match(/^\\d+$/)) {\n   538→      throw new Error(`Invalid cron hour field: '${hour}'.`);\n   539→    }\n   540→\n   541→    for (const field of [dayOfMonth, month, dayOfWeek]) {\n   542→      if (field !== '*' && !field.match(/^\\d+$/)) {\n   543→        throw new Error(`Invalid cron field: '${field}'.`);\n   544→      }\n   545→    }\n   546→  }\n   547→\n   548→  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n   549→    const parts = schedule.cron.trim().split(/\\s+/);\n   550→    const [minuteField, hourField, dayOfMonthField, monthField, dayOfWeekField] = parts;\n   551→\n   552→    const currentMinute = now.getMinutes();\n   553→    const currentHour = now.getHours();\n   554→    const currentDayOfMonth = now.getDate();\n   555→    const currentMonth = now.getMonth() + 1;\n   556→    const currentDayOfWeek = now.getDay();\n   557→\n   558→    if (!this.matchCronField(minuteField, currentMinute)) return false;\n   559→    if (!this.matchCronField(hourField, currentHour)) return false;\n   560→    if (!this.matchCronField(dayOfMonthField, currentDayOfMonth)) return false;\n   561→    if (!this.matchCronField(monthField, currentMonth)) return false;\n   562→    if (!this.matchCronField(dayOfWeekField, currentDayOfWeek)) return false;\n   563→\n   564→    // Avoid duplicate runs in the same minute window\n   565→    if (schedule.lastRun) {\n   566→      const lastRunMinute = new Date(\n   567→        schedule.lastRun.getFullYear(),\n   568→        schedule.lastRun.getMonth(),\n   569→        schedule.lastRun.getDate(),\n   570→        schedule.lastRun.getHours(),\n   571→        schedule.lastRun.getMinutes()\n   572→      );\n   573→      const currentMinuteStart = new Date(\n   574→        now.getFullYear(),\n   575→        now.getMonth(),\n   576→        now.getDate(),\n   577→        now.getHours(),\n   578→        now.getMinutes()\n   579→      );\n   580→      if (lastRunMinute.getTime() >= currentMinuteStart.getTime()) {\n   581→        return false;\n   582→      }\n   583→    }\n   584→\n   585→    return true;\n   586→  }\n   587→\n   588→  private matchCronField(field: string, value: number): boolean {\n   589→    if (field === '*') return true;\n   590→\n   591→    const stepMatch = field.match(/^\\*\\/(\\d+)$/);\n   592→    if (stepMatch) {\n   593→      const step = parseInt(stepMatch[1], 10);\n   594→      return value % step