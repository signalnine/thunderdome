urn false;\n    // Check month\n    if (!this.matchCronField(monthField, currentMonth)) return false;\n    // Check day of week\n    if (!this.matchCronField(dayOfWeekField, currentDayOfWeek)) return false;\n\n    // Avoid duplicate runs in the same minute window\n    if (schedule.lastRun) {\n      const lastRunMinute = new Date(\n        schedule.lastRun.getFullYear(),\n        schedule.lastRun.getMonth(),\n        schedule.lastRun.getDate(),\n        schedule.lastRun.getHours(),\n        schedule.lastRun.getMinutes()\n      );\n      const currentMinuteStart = new Date(\n        now.getFullYear(),\n        now.getMonth(),\n        now.getDate(),\n        now.getHours(),\n        now.getMinutes()\n      );\n      if (lastRunMinute.getTime() >= currentMinuteStart.getTime()) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  private matchCronField(field: string, value: number): boolean {\n    if (field === '*') return true;\n\n    // */N pattern\n    const stepMatch = field.match(/^\\*\\/(\\d+)$/);\n    if (stepMatch) {\n      const step = parseInt(stepMatch[1], 10);\n      return value % step === 0;\n    }\n\n    // Exact number\n    const num = parseInt(field, 10);\n    return value === num;\n  }\n\n  private async runMiddlewarePipeline(\n    task: Task,\n    middlewares: Middleware[],\n    handler: TaskHandler | null\n  ): Promise<void> {\n    let index = 0;\n\n    const next = async (): Promise<void> => {\n      if (index < middlewares.length) {\n        const middleware = middlewares[index++];\n        await middleware(task, next);\n      } else if (handler) {\n        await handler(task);\n      }\n    };\n\n    await next();\n  }\n\n  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    const startTime = Date.now();\n    const timeout = options?.timeout ?? 30000;\n\n    // Run shutdown callbacks\n    for (const callback of this.shutdownCallbacks) {\n      try {\n        await callback();\n      } catch {\n        // Ignore callback errors during shutdown\n      }\n    }\n\n    // Get all currently processing tasks\n    const processingTasks: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        processingTasks.push(task);\n      }\n    }\n\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        forceCancelled: 0,\n        elapsed: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks to finish, up to timeout\n    let completed = 0;\n    let forceCancelled = 0;\n\n    const waitForCompletion = new Promise<void>((resolve) => {\n      const check = () => {\n        let allDone = true;\n        for (const task of processingTasks) {\n          if (task.status === 'processing') {\n            allDone = false;\n            break;\n          }\n        }\n        if (allDone) {\n          resolve();\n        } else {\n          setTimeout(check, 10);\n        }\n      };\n      check();\n    });\n\n    const timeoutPromise = new Promise<void>((resolve) => {\n      setTimeout(resolve, timeout);\n    });\n\n    await Promise.race([waitForCompletion, timeoutPromise]);\n\n    // Count results\n    for (const task of processingTasks) {\n      if (task.status === 'processing') {\n        task.status = 'cancelled';\n        forceCancelled++;\n      } else {\n        completed++;\n      }\n    }\n\n    return {\n      completed,\n      forceCancelled,\n      elapsed: Date.now() - startTime,\n    };\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":537,"cache_read_input_tokens":31215,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":537},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8d05ce79-98b1-4890-9460-df7d22557abf","uuid":"56a93c23-f994-43a9-85f5-7b7b047cd3c4