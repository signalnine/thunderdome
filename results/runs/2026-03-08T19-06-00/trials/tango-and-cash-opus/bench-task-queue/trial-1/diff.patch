+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  runAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Task {
+  id: string;
+  payload: unknown;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempt: number;
+  maxRetries: number;
+  backoffDelay: number;
+  progress: number;
+  progressMessage?: string;
+  error?: string;
+  failureCount: number;
+  dependencies: string[];
+  dependencyStatus: Record<string, boolean>;
+}
+
+export interface ProgressUpdate {
+  taskId: string;
+  progress: number;
+  message?: string;
+}
+
+export type ProgressCallback = (update: ProgressUpdate) => void;
+
+export type Middleware = (task: Task, next: () => Promise<void> | void) => Promise<void> | void;
+
+export type TaskHandler = (task: Task) => Promise<void> | void;
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  lastRun: Date | null;
+  createdAt: Date;
+}
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  elapsed: number;
+}
