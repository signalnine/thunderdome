→  private async performShutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n   640→    const startTime = Date.now();\n   641→    const timeout = options?.timeout ?? 30000;\n   642→\n   643→    // Run shutdown callbacks\n   644→    for (const callback of this.shutdownCallbacks) {\n   645→      try {\n   646→        await callback();\n   647→      } catch {\n   648→        // Ignore callback errors during shutdown\n   649→      }\n   650→    }\n   651→\n   652→    // Get all currently processing tasks\n   653→    const processingTasks: Task[] = [];\n   654→    for (const task of this.tasks.values()) {\n   655→      if (task.status === 'processing') {\n   656→        processingTasks.push(task);\n   657→      }\n   658→    }\n   659→\n   660→    if (processingTasks.length === 0) {\n   661→      return {\n   662→        completed: 0,\n   663→        forceCancelled: 0,\n   664→        elapsed: Date.now() - startTime,\n   665→      };\n   666→    }\n   667→\n   668→    // Wait for processing tasks to finish, up to timeout\n   669→    let completed = 0;\n   670→    let forceCancelled = 0;\n   671→\n   672→    const waitForCompletion = new Promise<void>((resolve) => {\n   673→      const check = () => {\n   674→        let allDone = true;\n   675→        for (const task of processingTasks) {\n   676→          if (task.status === 'processing') {\n   677→            allDone = false;\n   678→            break;\n   679→          }\n   680→        }\n   681→        if (allDone) {\n   682→          resolve();\n   683→        } else {\n   684→          setTimeout(check, 10);\n   685→        }\n   686→      };\n   687→      check();\n   688→    });\n   689→\n   690→    const timeoutPromise = new Promise<void>((resolve) => {\n   691→      setTimeout(resolve, timeout);\n   692→    });\n   693→\n   694→    await Promise.race([waitForCompletion, timeoutPromise]);\n   695→\n   696→    // Count results\n   697→    for (const task of processingTasks) {\n   698→      if (task.st