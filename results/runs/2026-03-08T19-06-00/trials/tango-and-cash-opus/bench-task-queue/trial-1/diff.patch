this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const createdTasks: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.shouldRunSchedule(schedule, currentTime)) {\n        const task = this.enqueue(\n          typeof schedule.payload === 'object' && schedule.payload !== null\n            ? JSON.parse(JSON.stringify(schedule.payload))\n            : schedule.payload,\n          { queue: schedule.queue }\n        );\n        createdTasks.push(task);\n        schedule.lastRun = currentTime;\n      }\n    }\n\n    return createdTasks;\n  }\n\n  // ─── Phase 11: Middleware Pipeline ────────────────────────────────\n\n  use(queueName: string, middleware: Middleware): void {\n    const queue = this.ensureQueue(queueName);\n    queue.middlewares.push(middleware);\n  }\n\n  setHandler(queueName: string, handler: TaskHandler): void {\n    const queue = this.ensureQueue(queueName);\n    queue.handler = handler;\n  }\n\n  async process(queueName?: string): Promise<Task | null> {\n    const name = queueName ?? DEFAULT_QUEUE;\n    const task = this.dequeue(name);\n\n    if (!task) {\n      return null;\n    }\n\n    const queueState = this.queues.get(name);\n    const middlewares = queueState?.middlewares ?? [];\n    const handler = queueState?.handler ?? null;\n\n    try {\n      await this.runMiddlewarePipeline(task, middlewares, handler);\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.fail(task.id, err instanceof Error ? err.message : String(err));\n      }\n    }\n\n    return task;\n  }\n\n  // ─── Phase 12: Graceful Shutdown ─────────────────────────────────\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {\n    if (th