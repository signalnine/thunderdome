@@ -0,0 +1,115 @@
+import fs from "node:fs";
+import path from "node:path";
+import { TimeEntry } from "./types.js";
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private currentTask: string | null = null;
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.load();
+  }
+
+  public start(task: string): void {
+    if (task.trim() === "") {
+      throw new Error("Task name cannot be empty or whitespace-only");
+    }
+
+    if (this.currentTask !== null) {
+      this.stop();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      startTime: new Date().toISOString(),
+      endTime: null,
+    };
+
+    this.entries.push(entry);
+    this.currentTask = task;
+    this.save();
+  }
+
+  public stop(): TimeEntry {
+    if (this.currentTask === null) {
+      throw new Error("No timer is currently running");
+    }
+
+    const lastEntryIndex = this.entries.length - 1;
+    if (lastEntryIndex >= 0 && this.entries[lastEntryIndex].endTime === null) {
+      this.entries[lastEntryIndex].endTime = new Date().toISOString();
+      this.currentTask = null;
+      this.save();
+      return this.entries[lastEntryIndex];
+    }
+
+    throw new Error("No timer is currently running");
+  }
+
+  public getEntries(from?: Date, to?: Date): TimeEntry[] {
+    return this.entries.filter((entry) => {
+      const start = new Date(entry.startTime).getTime();
+      let include = true;
+      if (from) {
+        include = include && start >= from.getTime();
+      }
+      if (to) {
+        include = include && start <= to.getTime();
+      }
+      return include;
+    });
+  }
+
+  public getSummary(): Record<string, number> {
+    const summary: Record<string, number> = {};
+    const now = Date.now();
+
+    for (const entry of this.entries) {
+      const start = new Date(entry.startTime).getTime();
+      const end = entry.endTime ? new Date(entry.endTime).getTime() : now;
+      const duration = end - start;
+
+      if (!summary[entry.task]) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  private load(): void {
+    try {
+      if (fs.existsSync(this.filePath)) {
+        const data = fs.readFileSync(this.filePath, "utf-8");
+        this.entries = JSON.parse(data) as TimeEntry[];
+        if (this.entries.length > 0) {
+          const lastEntry = this.entries[this.entries.length - 1];
+          if (lastEntry.endTime === null) {
+            this.currentTask = lastEntry.task;
+          }
+        }
+      } else {
+        this.entries = [];
+        this.currentTask = null;
+      }
+    } catch {
+      this.entries = [];
+      this.currentTask = null;
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    if (!fs.existsSync(dir)) {
+      fs.mkdirSync(dir, { recursive: true });
+    }
+    fs.writeFileSync(
+      this.filePath,
+      JSON.stringify(this.entries, null, 2),
+      "utf-8"
+    );
+  }
+}
