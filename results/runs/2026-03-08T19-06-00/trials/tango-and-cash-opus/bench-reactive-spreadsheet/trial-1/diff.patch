+// Token types for the formula lexer
+type Token =
+  | { type: 'NUMBER'; value: number }
+  | { type: 'STRING'; value: string }
+  | { type: 'BOOLEAN'; value: boolean }
+  | { type: 'CELL'; value: string }
+  | { type: 'FUNCTION'; value: string }
+  | { type: 'OP'; value: string }
+  | { type: 'LPAREN' }
+  | { type: 'RPAREN' }
+  | { type: 'COMMA' }
+  | { type: 'COLON' }
+  | { type: 'EOF' };
+
+// AST node types
+type ASTNode =
+  | { type: 'literal'; value: string | number | boolean }
+  | { type: 'cell'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'unary'; op: string; expr: ASTNode }
+  | { type: 'binary'; op: string; left: ASTNode; right: ASTNode }
+  | { type: 'function'; name: string; args: ASTNode[] };
+
+// Tokenize a formula expression (without the leading '=')
+function tokenize(expr: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < expr.length) {
+    const ch = expr[i];
+
+    // Skip whitespace
+    if (/\s/.test(ch)) {
+      i++;
+      continue;
+    }
+
+    // String literals
+    if (ch === '"') {
+      let str = '';
+      i++;
+      while (i < expr.length && expr[i] !== '"') {
+        str += expr[i];
+        i++;
+      }
+      if (i < expr.length) i++; // skip closing quote
+      tokens.push({ type: 'STRING', value: str });
+      continue;
+    }
+
+    // Numbers
+    if (/[0-9]/.test(ch) || (ch === '.' && i + 1 < expr.length && /[0-9]/.test(expr[i + 1]))) {
+      let numStr = '';
+      while (i < expr.length && /[0-9.]/.test(expr[i])) {
+        numStr += expr[i];
+        i++;
+      }
+      tokens.push({ type: 'NUMBER', value: parseFloat(numStr) });
+      continue;
+    }
+
+    // Identifiers: cell refs, function names, booleans
+    if (/[A-Za-z]/.test(ch)) {
+      let id = '';
+      while (i < expr.length && /[A-Za-z0-9]/.test(expr[i])) {
+        id += expr[i];
+        i++;
+      }
+      const upper = id.toUpperCase();
+      if (upper === 'TRUE') {
+        tokens.push({ type: 'BOOLEAN', value: true });
+      } else if (upper === 'FALSE') {
+        tokens.push({ type: 'BOOLEAN', value: false });
+      } else if (/^[A-Z]+[0-9]+$/.test(upper) && /[1-9]/.test(upper.replace(/^[A-Z]+/, '')[0])) {
+        tokens.push({ type: 'CELL', value: upper });
+      } else {
+        tokens.push({ type: 'FUNCTION', value: upper });
+      }
+      continue;
+    }
+
+    // Two-character operators
+    if (i + 1 < expr.length) {
+      const two = expr.substring(i, i + 2);
+      if (two === '<>' || two === '<=' || two === '>=') {
+        tokens.push({ type: 'OP', value: two });
+        i += 2;
+        continue;
+      }
+    }
+
+    // Single-character operators and punctuation
+    if ('+-*/'.includes(ch) || ch === '<' || ch === '>' || ch === '=') {
+      tokens.push({ type: 'OP', value: ch });
+      i++;
+      continue;
+    }
+    if (ch === '(') { tokens.push({ type: 'LPAREN' }); i++; continue; }
+    if (ch === ')') { tokens.push({ type: 'RPAREN' }); i++; continue; }
+    if (ch === ',') { tokens.push({ type: 'COMMA' }); i++; continue; }
+    if (ch === ':') { tokens.push({ type: 'COLON' }); i++; continue; }
+
+    throw new Error(`Unexpected character: ${ch}`);
+  }
+
+  tokens.push({ type: 'EOF' });
+  return tokens;
+}
+
+// Recursive descent parser
+class FormulaParser {
+  private tokens: Token[];
+  private pos = 0;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+  }
+
+  private peek(): Token {
+    return this.tokens[this.pos];
+  }
+
+  private consume(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    if (this.peek().type !== 'EOF') {
+      throw new Error('Unexpected trailing tokens');
+    }
+    return node;
+  }
+
+  private isComparisonOp(tok: Token): boolean {
+    return tok.type === 'OP' && ['=', '<>', '<', '<=', '>', '>='].includes(tok.value);
+  }
+
+  // Lowest precedence: comparison operators
+  private parseComparison(): ASTNode {
+    let left = this.parseAddSub();
+    let tok = this.peek();
+    while (this.isComparisonOp(tok)) {
+      this.consume();
+      const right = this.parseAddSub();
+      left = { type: 'binary', op: (tok as { type: 'OP'; value: string }).value, left, right };
+      tok = this.peek();
+    }
+    return left;
+  }
+
+  private isAddSubOp(tok: Token): boolean {
+    return tok.type === 'OP' && (tok.value === '+' || tok.value === '-');
+  }
+
+  // Addition and subtraction
+  private parseAddSub(): ASTNode {
+    let left = this.parseMulDiv();
+    let tok = this.peek();
+    while (this.isAddSubOp(tok)) {
+      this.consume();
+      const right = this.parseMulDiv();
+      left = { type: 'binary', op: (tok as { type: 'OP'; value: string }).value, left, right };
+      tok = this.peek();
+    }
+    return left;
+  }
+
+  private isMulDivOp(tok: Token): boolean {
+    return tok.type === 'OP' && (tok.value === '*' || tok.value === '/');
+  }
+
+  // Multiplication and division
+  private parseMulDiv(): ASTNode {
+    let left = this.parseUnary();
+    let tok = this.peek();
+    while (this.isMulDivOp(tok)) {
+      this.consume();
+      const right = this.parseUnary();
+      left = { type: 'binary', op: (tok as { type: 'OP'; value: string }).value, left, right };
+      tok = this.peek();
+    }
+    return left;
+  }
+
+  // Unary plus/minus
+  private parseUnary(): ASTNode {
+    const tok = this.peek();
+    if (tok.type === 'OP' && tok.value === '-') {
+      this.consume();
+      const expr = this.parseUnary();
+      return { type: 'unary', op: '-', expr };
+    }
+    if (tok.type === 'OP' && tok.value === '+') {
+      this.consume();
+      return this.parseUnary();
+    }
+    return this.parsePrimary();
+  }
+
+  // Primary: literals, cell refs, ranges, function calls, parenthesized exprs
+  private parsePrimary(): ASTNode {
+    const tok = this.consume();
+
+    if (tok.type === 'NUMBER') {
+      return { type: 'literal', value: tok.value };
+    }
+    if (tok.type === 'STRING') {
+      return { type: 'literal', value: tok.value };
+    }
+    if (tok.type === 'BOOLEAN') {
+      return { type: 'literal', value: tok.value };
+    }
+
+    if (tok.type === 'LPAREN') {
+      const expr = this.parseComparison();
+      const closing = this.consume();
+      if (closing.type !== 'RPAREN') throw new Error("Expected ')'");
+      return expr;
+    }
+
+    if (tok.type === 'CELL') {
+      // Check for range (CELL:CELL)
+      if (this.peek().type === 'COLON') {
+        this.consume(); // consume ':'
+        const endTok = this.consume();
+        if (endTok.type !== 'CELL') throw new Error("Expected cell reference after ':'");
+        return { type: 'range', start: tok.value, end: endTok.value };
+      }
+      return { type: 'cell', ref: tok.value };
+    }
+
+    if (tok.type === 'FUNCTION') {
+      const lp = this.consume();
+      if (lp.type !== 'LPAREN') throw new Error("Expected '(' after function name");
+      const args: ASTNode[] = [];
+      if (this.peek().type !== 'RPAREN') {
+        args.push(this.parseComparison());
+        while (this.peek().type === 'COMMA') {
+          this.consume(); // skip comma
+          args.push(this.parseComparison());
+        }
+      }
+      const rp = this.consume();
+      if (rp.type !== 'RPAREN') throw new Error("Expected ')'");
+      return { type: 'function', name: tok.value, args };
+    }
+
+    throw new Error(`Unexpected token: ${JSON.stringify(tok)}`);
+  }
+}
+
+// Parse cell reference string to col/row indices
+function parseCellRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)([1-9][0-9]*)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  let col = 0;
+  for (let i = 0; i < match[1].length; i++) {
+    col = col * 26 + (match[1].charCodeAt(i) - 64);
+  }
+  return { col: col - 1, row: parseInt(match[2], 10) };
+}
+
+// Convert 0-based column index to letter(s)
+function colToLetters(col: number): string {
+  let result = '';
+  let n = col + 1;
+  while (n > 0) {
+    const rem = (n - 1) % 26;
+    result = String.fromCharCode(65 + rem) + result;
+    n = Math.floor((n - 1) / 26);
+  }
+  return result;
+}
+
+// Expand a range into individual cell references
+function expandRange(start: string, end: string): string[] {
+  const s = parseCellRef(start);
+  const e = parseCellRef(end);
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+
+  const cells: string[] = [];
+  for (let r = minRow; r <= maxRow; r++) {
+    for (let c = minCol; c <= maxCol; c++) {
+      cells.push(`${colToLetters(c)}${r}`);
+    }
+  }
+  return cells;
+}
+
+// Extract all cell dependencies from an AST
+function extractDependencies(node: ASTNode): Set<string> {
+  const deps = new Set<string>();
+
+  function walk(n: ASTNode): void {
+    switch (n.type) {
+      case 'cell':
+        deps.add(n.ref);
+        break;
+      case 'range':
+        for (const c of expandRange(n.start, n.end)) {
+          deps.add(c);
+        }
+        break;
+      case 'unary':
+        walk(n.expr);
+        break;
+      case 'binary':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'function':
+        for (const arg of n.args) {
+          walk(arg);
+        }
+        break;
+      // literal: no deps
+    }
+  }
+
+  walk(node);
+  return deps;
+}
+
+// Convert a value to a number for arithmetic
+function toNumber(val: string | number | boolean | null): number {
+  if (val === null) return 0;
+  if (typeof val === 'number') return val;
+  if (typeof val === 'boolean') return val ? 1 : 0;
+  const n = Number(val);
+  return isNaN(n) ? 0 : n;
+}
+
+export class Spreadsheet {
+  // Raw values as set by the user
+  private rawValues = new Map<string, string | number | boolean>();
+  // Computed (evaluated) values
+  private computedValues = new Map<string, string | number | boolean | null>();
+  // Parsed ASTs for formula cells
+  private formulaASTs = new Map<string, ASTNode>();
+  // Forward dependents: cell -> set of cells that depend on it
+  private dependents = new Map<string, Set<string>>();
+  // Reverse dependencies: cell -> set of cells it depends on
+  private dependencies = new Map<string, Set<string>>();
+
+  set(cell: string, value: string | number | boolean): void {
+    cell = cell.toUpperCase();
+
+    const isFormula = typeof value === 'string' && value.startsWith('=');
+    let ast: ASTNode | null = null;
+    let newDeps = new Set<string>();
+
+    if (isFormula) {
+      const expr = (value as string).substring(1);
+      const tokens = tokenize(expr);
+      const parser = new FormulaParser(tokens);
+      ast = parser.parse();
+      newDeps = extractDependencies(ast);
+    }
+
+    // Check for circular references before making any changes
+    // A cycle exists if any of the new dependencies transitively depend on this cell
+    // i.e., if we can reach any newDep from cell by following the dependents graph
+    if (newDeps.has(cell)) {
+      throw new Error('Circular reference detected');
+    }
+    for (const dep of newDeps) {
+      if (this.wouldCreateCycle(cell, dep)) {
+        throw new Error('Circular reference detected');
+      }
+    }
+
+    // Remove old dependency edges
+    const oldDeps = this.dependencies.get(cell);
+    if (oldDeps) {
+      for (const oldDep of oldDeps) {
+        this.dependents.get(oldDep)?.delete(cell);
+      }
+    }
+
+    // Set new dependency edges
+    this.dependencies.set(cell, newDeps);
+    for (const dep of newDeps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(cell);
+    }
+
+    // Store raw value and AST
+    this.rawValues.set(cell, value);
+    if (ast) {
+      this.formulaASTs.set(cell, ast);
+    } else {
+      this.formulaASTs.delete(cell);
+    }
+
+    // Recompute this cell and all transitive dependents in topological order
+    this.recompute(cell);
+  }
+
+  get(cell: string): string | number | boolean | null {
+    cell = cell.toUpperCase();
+    if (this.computedValues.has(cell)) {
+      return this.computedValues.get(cell)!;
+    }
+    return null;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, string | number | boolean | null> {
+    const result = new Map<string, string | number | boolean | null>();
+    for (const [cell, val] of this.computedValues) {
+      if (val !== null) {
+        result.set(cell, val);
+      }
+    }
+    return result;
+  }
+
+  // Check if adding "cell depends on dep" would create a cycle.
+  // A cycle exists if cell is already a transitive dependent of dep
+  // (i.e., dep already transitively depends on cell through the dependents graph).
+  // Equivalently: can we reach dep from cell by following the dependents map?
+  private wouldCreateCycle(cell: string, dep: string): boolean {
+    // BFS from cell through the dependents graph to see if we reach dep
+    const visited = new Set<string>();
+    const queue: string[] = [cell];
+    visited.add(cell);
+
+    while (queue.length > 0) {
+      const curr = queue.shift()!;
+      const fwd = this.dependents.get(curr);
+      if (fwd) {
+        for (const d of fwd) {
+          if (d === dep) return true;
+          if (!visited.has(d)) {
+            visited.add(d);
+            queue.push(d);
+          }
+        }
+      }
+    }
+    return false;
+  }
+
+  // Collect all transitive dependents of a cell (not including the cell itself)
+  private getTransitiveDependents(cell: string): Set<string> {
+    const result = new Set<string>();
+    const queue: string[] = [cell];
+
+    while (queue.length > 0) {
+      const curr = queue.shift()!;
+      const fwd = this.dependents.get(curr);
+      if (fwd) {
+        for (const d of fwd) {
+          if (!result.has(d)) {
+            result.add(d);
+            queue.push(d);
+          }
+        }
+      }
+    }
+    return result;
+  }
+
+  // Recompute a cell and all its transitive dependents in topological order
+  private recompute(cell: string): void {
+    const affected = this.getTransitiveDependents(cell);
+    affected.add(cell);
+
+    // Topological sort using Kahn's algorithm
+    const inDegree = new Map<string, number>();
+    for (const c of affected) {
+      inDegree.set(c, 0);
+    }
+
+    for (const c of affected) {
+      const fwd = this.dependents.get(c);
+      if (fwd) {
+        for (const d of fwd) {
+          if (affected.has(d)) {
+            inDegree.set(d, (inDegree.get(d) || 0) + 1);
+          }
+        }
+      }
+    }
+
+    const queue: string[] = [];
+    for (const [c, deg] of inDegree) {
+      if (deg === 0) queue.push(c);
+    }
+
+    const order: string[] = [];
+    while (queue.length > 0) {
+      const curr = queue.shift()!;
+      order.push(curr);
+      const fwd = this.dependents.get(curr);
+      if (fwd) {
+        for (const d of fwd) {
+          if (affected.has(d)) {
+            const newDeg = inDegree.get(d)! - 1;
+            inDegree.set(d, newDeg);
+            if (newDeg === 0) queue.push(d);
+          }
+        }
+      }
+    }
+
+    // Evaluate each cell in topological order
+    for (const c of order) {
+      this.evaluateCell(c);
+    }
+  }
+
+  // Evaluate a single cell and store its computed value
+  private evaluateCell(cell: string): void {
+    const raw = this.rawValues.get(cell);
+    if (raw === undefined) {
+      this.computedValues.delete(cell);
+      return;
+    }
+
+    const ast = this.formulaASTs.get(cell);
+    if (ast) {
+      const result = this.evaluate(ast);
+      this.computedValues.set(cell, result);
+    } else {
+      // Raw value (not a formula)
+      this.computedValues.set(cell, raw);
+    }
+  }
+
+  // Evaluate an AST node
+  private evaluate(node: ASTNode): string | number | boolean | null {
+    switch (node.type) {
+      case 'literal':
+        return node.value;
+
+      case 'cell':
+        return this.get(node.ref);
+
+      case 'range':
+        // Ranges are only valid inside aggregate functions; shouldn't be evaluated directly
+        throw new Error('Range cannot be used outside of a function');
+
+      case 'unary':
+        if (node.op === '-') {
+          return -toNumber(this.evaluate(node.expr));
+        }
+        return this.evaluate(node.expr);
+
+      case 'binary':
+        return this.evaluateBinary(node.op, node.left, node.right);
+
+      case 'function':
+        return this.evaluateFunction(node.name, node.args);
+    }
+  }
+
+  private evaluateBinary(
+    op: string,
+    leftNode: ASTNode,
+    rightNode: ASTNode
+  ): string | number | boolean | null {
+    const left = this.evaluate(leftNode);
+    const right = this.evaluate(rightNode);
+
+    switch (op) {
+      case '+':
+        return toNumber(left) + toNumber(right);
+      case '-':
+        return toNumber(left) - toNumber(right);
+      case '*':
+        return toNumber(left) * toNumber(right);
+      case '/': {
+        const divisor = toNumber(right);
+        if (divisor === 0) throw new Error('Division by zero');
+        return toNumber(left) / divisor;
+      }
+      case '=':
+        return left === right;
+      case '<>':
+        return left !== right;
+      case '<':
+        return toNumber(left) < toNumber(right);
+      case '<=':
+        return toNumber(left) <= toNumber(right);
+      case '>':
+        return toNumber(left) > toNumber(right);
+      case '>=':
+        return toNumber(left) >= toNumber(right);
+      default:
+        throw new Error(`Unknown operator: ${op}`);
+    }
+  }
+
+  // Flatten function arguments, expanding ranges into individual cell values
+  private flattenArgs(args: ASTNode[]): (string | number | boolean | null)[] {
+    const result: (string | number | boolean | null)[] = [];
+    for (const arg of args) {
+      if (arg.type === 'range') {
+        const cells = expandRange(arg.start, arg.end);
+        for (const c of cells) {
+          result.push(this.get(c));
+        }
+      } else {
+        result.push(this.evaluate(arg));
+      }
+    }
+    return result;
+  }
+
+  private evaluateFunction(
+    name: string,
+    args: ASTNode[]
+  ): string | number | boolean | null {
+    if (name === 'IF') {
+      if (args.length !== 3) throw new Error('IF requires 3 arguments');
+      const condition = this.evaluate(args[0]);
+      return condition ? this.evaluate(args[1]) : this.evaluate(args[2]);
+    }
+
+    const values = this.flattenArgs(args);
+    const nums = values.filter((v): v is number => typeof v === 'number');
+
+    switch (name) {
+      case 'SUM':
+        return nums.reduce((a, b) => a + b, 0);
+      case 'AVERAGE':
+        return nums.length > 0 ? nums.reduce((a, b) => a + b, 0) / nums.length : 0;
+      case 'MIN':
+        return nums.length > 0 ? Math.min(...nums) : 0;
+      case 'MAX':
+        return nums.length > 0 ? Math.max(...nums) : 0;
+      case 'COUNT':
+        return nums.length;
+      default:
+        throw new Error(`Unknown function: ${name}`);
+    }
+  }
+}
