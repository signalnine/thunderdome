);\n      sheet.set('B2', 4);\n      sheet.set('C1', '=SUM(A1:B2)');\n      expect(sheet.get('C1')).toBe(10);\n    });\n\n    it('SUM should ignore non-numeric values', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 'hello');\n      sheet.set('A3', 20);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(30);\n    });\n\n    it('AVERAGE should compute mean', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=AVERAGE(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n\n    it('MIN should find minimum', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 5);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MIN(A1:A3)');\n      expect(sheet.get('B1')).toBe(5);\n    });\n\n    it('MAX should find maximum', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 5);\n      sheet.set('A3', 20);\n      sheet.set('B1', '=MAX(A1:A3)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n\n    it('COUNT should count numeric values', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 'text');\n      sheet.set('A3', 20);\n      sheet.set('A4', true);\n      sheet.set('B1', '=COUNT(A1:A4)');\n      expect(sheet.get('B1')).toBe(2);\n    });\n\n    it('IF should return trueValue when condition is true', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 50);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('big');\n    });\n\n    it('IF should return falseValue when condition is false', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('small');\n    });\n\n    it('IF should work with numeric results', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=IF(A1>5, A1*2, 0)');\n      expect(sheet.get('B1')).toBe(20);\n    });\n  });\n\n  describe('reactive updates', () => {\n    it('should update dependents when a cell changes', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n\n      sheet.set('A1', 50);\n      expect(sheet.get('A3')).toBe(70);\n    });\n\n    it('should update transitive dependents', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', '=A1+1');\n      sheet.set('A3', '=A2+1');\n      sheet.set('A4', '=A3+1');\n      expect(sheet.get('A4')).toBe(4);\n\n      sheet.set('A1', 10);\n      expect(sheet.get('A2')).toBe(11);\n      expect(sheet.get('A3')).toBe(12);\n      expect(sheet.get('A4')).toBe(13);\n    });\n\n    it('should update multiple dependents', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1*2');\n      sheet.set('C1', '=A1*3');\n      sheet.set('D1', '=B1+C1');\n\n      sheet.set('A1', 5);\n      expect(sheet.get('B1')).toBe(10);\n      expect(sheet.get('C1')).toBe(15);\n      expect(sheet.get('D1')).toBe(25);\n    });\n\n    it('should handle changing a formula', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', '=A1+A2');\n      expect(sheet.get('A3')).toBe(30);\n\n      sheet.set('A3', '=A1*A2');\n      expect(sheet.get('A3')).toBe(200);\n    });\n\n    it('should handle replacing a formula with a value', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', '=A1*2');\n      expect(sheet.get('A2')).toBe(20);\n\n      sheet.set('A2', 99);\n      expect(sheet.get('A2')).toBe(99);\n\n      // Changing A1 should no longer affect A2\n      sheet.set('A1', 999);\n      expect(sheet.get('A2')).toBe(99);\n    });\n\n    it('should reactively update SUM when range values change', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('A2', 2);\n      sheet.set('A3', 3);\n      sheet.set('B1', '=SUM(A1:A3)');\n      expect(sheet.get('B1')).toBe(6);\n\n      sheet.set('A2', 10);\n      expect(sheet.get('B1')).toBe(14);\n    });\n\n    it('should reactively update IF', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 50);\n      sheet.set('B1', '=IF(A1>30, \"big\", \"small\")');\n      expect(sheet.get('B1')).toBe('big');\n\n      sheet.set('A1', 10);\n      expect(sheet.get('B1')).toBe('small');\n    });\n  });\n\n  describe('circular reference detection', () => {\n    it('should detect direct self-reference', () => {\n      const sheet = new Spreadsheet();\n      expect(() => sheet.set('A1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should detect simple cycle', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1');\n      expect(() => sheet.set('B1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should detect indirect cycle', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1');\n      sheet.set('B1', '=C1');\n      expect(() => sheet.set('C1', '=A1')).toThrow(/[Cc]ircular/);\n    });\n\n    it('should not modify cell on circular reference error', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1');\n      expect(sheet.get('B1')).toBe(10);\n\n      expect(() => sheet.set('A1', '=B1')).toThrow(/[Cc]ircular/);\n      // A1 should still be 10\n      expect(sheet.get('A1')).toBe(10);\n      expect(sheet.get('B1')).toBe(10);\n    });\n\n    it('should allow non-circular dependencies', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 1);\n      sheet.set('B1', '=A1');\n      sheet.set('C1', '=B1');\n      // No cycle - A1 -> B1 -> C1 is fine\n      expect(sheet.get('C1')).toBe(1);\n    });\n  });\n\n  describe('cell references - multi-letter columns', () => {\n    it('should handle AA column', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('AA1', 42);\n      expect(sheet.get('AA1')).toBe(42);\n    });\n\n    it('should handle formulas referencing multi-letter columns', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('AA1', 10);\n      sheet.set('AB1', 20);\n      sheet.set('AC1', '=AA1+AB1');\n      expect(sheet.get('AC1')).toBe(30);\n    });\n\n    it('should handle ranges with multi-letter columns', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('AA1', 1);\n      sheet.set('AB1', 2);\n      sheet.set('AC1', 3);\n      sheet.set('A1', '=SUM(AA1:AC1)');\n      expect(sheet.get('A1')).toBe(6);\n    });\n  });\n\n  describe('edge cases', () => {\n    it('should handle formula referencing empty cell', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=B1');\n      expect(sheet.get('A1')).toBeNull();\n    });\n\n    it('should handle complex nested formulas', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('A2', 20);\n      sheet.set('A3', 30);\n      sheet.set('B1', '=IF(SUM(A1:A3)>50, MAX(A1:A3), MIN(A1:A3))');\n      expect(sheet.get('B1')).toBe(30); // SUM=60>50, so MAX=30\n    });\n\n    it('should handle formula with boolean literals', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=IF(true, 1, 0)');\n      expect(sheet.get('A1')).toBe(1);\n    });\n\n    it('should handle string literals in formulas', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', '=IF(true, \"yes\", \"no\")');\n      expect(sheet.get('A1')).toBe('yes');\n    });\n\n    it('should handle diamond dependency pattern', () => {\n      const sheet = new Spreadsheet();\n      // A1 -> B1 -> D1\n      // A1 -> C1 -> D1\n  