@@ -0,0 +1,551 @@
+import { describe, it, expect } from 'vitest';
+import { Spreadsheet } from './index';
+
+describe('Spreadsheet', () => {
+  describe('basic values', () => {
+    it('should store and retrieve numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should store and retrieve floats', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 3.14);
+      expect(sheet.get('A1')).toBe(3.14);
+    });
+
+    it('should store and retrieve strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should store and retrieve booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      sheet.set('A2', false);
+      expect(sheet.get('A1')).toBe(true);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.get('A1')).toBeNull();
+    });
+
+    it('should handle case-insensitive cell references', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('a1', 10);
+      expect(sheet.get('A1')).toBe(10);
+      expect(sheet.get('a1')).toBe(10);
+    });
+
+    it('should overwrite existing values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A1', 20);
+      expect(sheet.get('A1')).toBe(20);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('should display numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should display strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should display booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should display empty string for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('should display formula results', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('getCells', () => {
+    it('should return all non-empty cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(3);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+    });
+
+    it('should not include empty cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      const cells = sheet.getCells();
+      expect(cells.has('B1')).toBe(false);
+    });
+  });
+
+  describe('formulas - arithmetic', () => {
+    it('should add two cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should subtract', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 30);
+      sheet.set('A2', 10);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(20);
+    });
+
+    it('should multiply', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should divide', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 20);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(5);
+    });
+
+    it('should respect operator precedence', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=A1+A2*A3');
+      expect(sheet.get('A4')).toBe(14); // 2 + (3*4) = 14
+    });
+
+    it('should handle parentheses', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=(A1+A2)*A3');
+      expect(sheet.get('A4')).toBe(20); // (2+3)*4 = 20
+    });
+
+    it('should handle unary minus', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', '=-A1');
+      expect(sheet.get('A2')).toBe(-5);
+    });
+
+    it('should handle number literals in formulas', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+5');
+      expect(sheet.get('A2')).toBe(15);
