r (let c = minCol; c <= maxCol; c++) {\n      cells.push(`${colToLetters(c)}${r}`);\n    }\n  }\n  return cells;\n}\n\n// Extract all cell dependencies from an AST\nfunction extractDependencies(node: ASTNode): Set<string> {\n  const deps = new Set<string>();\n\n  function walk(n: ASTNode): void {\n    switch (n.type) {\n      case 'cell':\n        deps.add(n.ref);\n        break;\n      case 'range':\n        for (const c of expandRange(n.start, n.end)) {\n          deps.add(c);\n        }\n        break;\n      case 'unary':\n        walk(n.expr);\n        break;\n      case 'binary':\n        walk(n.left);\n        walk(n.right);\n        break;\n      case 'function':\n        for (const arg of n.args) {\n          walk(arg);\n        }\n        break;\n      // literal: no deps\n    }\n  }\n\n  walk(node);\n  return deps;\n}\n\n// Convert a value to a number for arithmetic\nfunction toNumber(val: string | number | boolean | null): number {\n  if (val === null) return 0;\n  if (typeof val === 'number') return val;\n  if (typeof val === 'boolean') return val ? 1 : 0;\n  const n = Number(val);\n  return isNaN(n) ? 0 : n;\n}\n\nexport class Spreadsheet {\n  // Raw values as set by the user\n  private rawValues = new Map<string, string | number | boolean>();\n  // Computed (evaluated) values\n  private computedValues = new Map<string, string | number | boolean | null>();\n  // Parsed ASTs for formula cells\n  private formulaASTs = new Map<string, ASTNode>();\n  // Forward dependents: cell -> set of cells that depend on it\n  private dependents = new Map<string, Set<string>>();\n  // Reverse dependencies: cell -> set of cells it depends on\n  private dependencies = new Map<string, Set<string>>();\n\n  set(cell: string, value: string | number | boolean): void {\n    cell = cell.toUpperCase();\n\n    const isFormula = typeof value === 'string' && value.startsWith('=');\n    let ast: ASTNode | null = null;\n    let newDeps = new Set<string>();\n\n    if (isFormula) {\n  