ring; end: string }\n  | { type: 'unary'; op: string; expr: ASTNode }\n  | { type: 'binary'; op: string; left: ASTNode; right: ASTNode }\n  | { type: 'function'; name: string; args: ASTNode[] };\n\n// Tokenize a formula expression (without the leading '=')\nfunction tokenize(expr: string): Token[] {\n  const tokens: Token[] = [];\n  let i = 0;\n\n  while (i < expr.length) {\n    const ch = expr[i];\n\n    // Skip whitespace\n    if (/\\s/.test(ch)) {\n      i++;\n      continue;\n    }\n\n    // String literals\n    if (ch === '\"') {\n      let str = '';\n      i++;\n      while (i < expr.length && expr[i] !== '\"') {\n        str += expr[i];\n        i++;\n      }\n      if (i < expr.length) i++; // skip closing quote\n      tokens.push({ type: 'STRING', value: str });\n      continue;\n    }\n\n    // Numbers\n    if (/[0-9]/.test(ch) || (ch === '.' && i + 1 < expr.length && /[0-9]/.test(expr[i + 1]))) {\n      let numStr = '';\n      while (i < expr.length && /[0-9.]/.test(expr[i])) {\n        numStr += expr[i];\n        i++;\n      }\n      tokens.push({ type: 'NUMBER', value: parseFloat(numStr) });\n      continue;\n    }\n\n    // Identifiers: cell refs, function names, booleans\n    if (/[A-Za-z]/.test(ch)) {\n      let id = '';\n      while (i < expr.length && /[A-Za-z0-9]/.test(expr[i])) {\n        id += expr[i];\n        i++;\n      }\n      const upper = id.toUpperCase();\n      if (upper === 'TRUE') {\n        tokens.push({ type: 'BOOLEAN', value: true });\n      } else if (upper === 'FALSE') {\n        tokens.push({ type: 'BOOLEAN', value: false });\n      } else if (/^[A-Z]+[0-9]+$/.test(upper) && /[1-9]/.test(upper.replace(/^[A-Z]+/, '')[0])) {\n        tokens.push({ type: 'CELL', value: upper });\n      } else {\n        tokens.push({ type: 'FUNCTION', value: upper });\n      }\n      continue;\n    }\n\n    // Two-character operators\n    if (i + 1 < expr.length) {\n      const two = expr.substring(i, i + 2);\n      if (two === '<>' || two === '<=' || two === '>=') {\n        tokens.push({ type: 'OP', value: two });\n        i += 2;\n        continue;\n      }\n    }\n\n    // Single-character operators and punctuation\n    if ('+-*/'.includes(ch) || ch === '<' || ch === '>' || ch === '=') {\n      tokens.push({ type: 'OP', value: ch });\n      i++;\n      continue;\n    }\n    if (ch === '(') { tokens.push({ type: 'LPAREN' }); i++; continue; }\n    if (ch === ')') { tokens.push({ type: 'RPAREN' }); i++; continue; }\n    if (ch === ',') { tokens.push({ type: 'COMMA' }); i++; continue; }\n    if (ch === ':') { tokens.push({ type: 'COLON' }); i++; continue; }\n\n    throw new Error(`Unexpected character: ${ch}`);\n  }\n\n  tokens.push({ type: 'EOF' });\n  return tokens;\n}\n\n// Recursive descent parser\nclass FormulaParser {\n  private tokens: Token[];\n  private pos = 0;\n\n  constructor(tokens: Token[]) {\n    this.tokens = tokens;\n  }\n\n  private peek(): Token {\n    return this.tokens[this.pos];\n  }\n\n  private consume(): Token {\n    return this.tokens[this.pos++];\n  }\n\n  parse(): ASTNode {\n    const node = this.parseComparison();\n    if (this.peek().type !== 'EOF') {\n      throw new Error('Unexpected trailing tokens');\n    }\n    return node;\n  }\n\n  // Lowest precedence: comparison operators\n  private parseComparison(): ASTNode {\n    let left = this.parseAddSub();\n    while (true) {\n      const tok = this.peek();\n      if (tok.type === 'OP' && ['=', '<>', '<', '<=', '>', '>='].includes(tok.value)) {\n        this.consume();\n        const right = this.parseAddSub();\n        left = { type: 'binary', op: tok.value, left, right };\n      } else {\n        break;\n      }\n    }\n    return left;\n  }\n\n  // Addition and subtraction\n  private parseAddSub(): ASTNode {\n    let left = this.parseMulDiv();\n    while (true) {\n      const tok = this.peek();\n      if (tok.type === 'OP' && (tok.value === '+' || tok.value === '-')) {\n        this.consume();\n        const right = this.parseMulDiv();\n        left = { type: 'binary', op: tok.value, left, right };\n      } else {\n        break;\n      }\n    }\n    return left;\n  }\n\n  // Multiplication and division\n  private parseMulDiv(): ASTNode {\n    let left = this.parseUnary();\n    while (true) {\n      const tok = this.peek();\n      if (tok.type === 'OP' && (tok.value === '*' || tok.value === '/')) {\n        this.consume();\n        const right = this.parseUnary();\n        left = { type: 'binary', op: tok.value, left, right };\n      } else {\n        break;\n      }\n    }\n    return left;\n  }\n\n  // Unary plus/minus\n  private parseUnary(): ASTNode {\n    const tok = this.peek();\n    if (tok.type === 'OP' && tok.value === '-') {\n      this.consume();\n      const expr = this.parseUnary();\n      return { type: 'unary', op: '-', expr };\n    }\n    if (tok.type === 'OP' && tok.value === '+') {\n      this.consume();\n      return this.parseUnary();\n    }\n    return this.parsePrimary();\n  }\n\n  // Primary: literals, cell refs, ranges, function calls, parenthesized exprs\n  private parsePrimary(): ASTNode {\n    const tok = this.consume();\n\n    if (tok.type === 'NUMBER') {\n      return { type: 'literal', value: tok.value };\n    }\n    if (tok.type === 'STRING') {\n      return { type: 'literal', value: tok.value };\n    }\n    if (tok.type === 'BOOLEAN') {\n      return { type: 'literal', value: tok.value };\n    }\n\n    if (tok.type === 'LPAREN') {\n      const expr = this.parseComparison();\n      const closing = this.consume();\n      if (closing.type !== 'RPAREN') throw new Error(\"Expected ')'\");\n      return expr;\n    }\n\n    if (tok.type === 'CELL') {\n      // Check for range (CELL:CELL)\n      if (this.peek().type === 'COLON') {\n        this.consume(); // consume ':'\n        const endTok = this.consume();\n        if (endTok.type !== 'CELL') throw new Error(\"Expected cell reference after ':'\");\n        return { type: 'range', start: tok.value, end: endTok.va