+import { marked } from 'marked';
+import { Plugin, ContentFile } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      async transformContent(file: ContentFile): Promise<ContentFile> {
+        let content = file.content || '';
+
+        // Pre-process admonition containers before marked
+        content = content.replace(
+          /^:::([a-zA-Z0-9_-]+)\n([\s\S]*?)\n:::/gm,
+          '<div class="admonition admonition-$1">\n$2\n</div>'
+        );
+
+        // Collect and remove footnote definitions
+        const footnotes: { id: string; text: string }[] = [];
+        const definitionRegex = /^\[\^([^\]]+)\]:\s*([^\r\n]*)/gm;
+
+        content = content.replace(definitionRegex, (_match, id: string, text: string) => {
+          footnotes.push({ id, text: text.trim() });
+          return '';
+        });
+
+        // Replace footnote references in body text
+        const referenceRegex = /\[\^([^\]]+)\]/g;
+        content = content.replace(
+          referenceRegex,
+          '<sup><a href="#fn-$1">$1</a></sup>'
+        );
+
+        // Convert markdown to HTML
+        let processedHtml = await Promise.resolve(marked.parse(content));
+
+        // Append footnotes section if any
+        if (footnotes.length > 0) {
+          let footnotesHtml = '<section class="footnotes"><ol>';
+          for (const fn of footnotes) {
+            footnotesHtml += `<li id="fn-${fn.id}">${fn.text}</li>`;
+          }
+          footnotesHtml += '</ol></section>';
+          processedHtml += footnotesHtml;
+        }
+
+        return {
+          ...file,
+          content: processedHtml as string,
+        };
+      },
+    },
+  };
+}
