+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, ctx: BuildContext): ContentFile {
+        const regex = /(src|href)="\.\/([^"]+)"/g;
+        const newAssets: string[] = [];
+
+        const newContent = file.content.replace(regex, (_match, attr: string, filename: string) => {
+          newAssets.push(filename);
+          return `${attr}="/assets/${filename}"`;
+        });
+
+        if (newAssets.length > 0) {
+          let manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+          if (!manifest) {
+            manifest = { assets: [] };
+            ctx.data.set('asset-manifest', manifest);
+          }
+          manifest.assets.push(...newAssets);
+          return { ...file, content: newContent };
+        }
+
+        return file;
+      },
+    },
+  };
+}
