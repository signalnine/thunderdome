\n    <title>${escapeXml(config.title)}</title>\n    <link>${config.baseUrl}</link>\n    <description>${escapeXml(config.title)} RSS Feed</description>\n${items}  </channel>\n</rss>`;\n\n        ctx.output.set('feed.xml', feed);\n      },\n    },\n  };\n}\n\nfunction escapeXml(str: string): string {\n  return str\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;')\n    .replace(/'/g, '&apos;');\n}\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":4,"lines":["-import { Plugin, BuildContext, ContentFile } from '../core/types.js';","+import { Plugin, BuildContext } from '../core/types.js';"," "," export function createRssFeedPlugin(): Plugin {","   return {"]}],"userModified":false,"replaceAll":false}}
