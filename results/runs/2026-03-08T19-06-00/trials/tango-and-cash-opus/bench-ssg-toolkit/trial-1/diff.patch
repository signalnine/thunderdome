+import { Plugin, ContentFile } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile): ContentFile {
+        const newContent = file.content.replace(
+          /<pre><code class="language-([^"]+)">([\s\S]*?)<\/code><\/pre>/g,
+          (_match, lang: string, code: string) =>
+            `<pre data-language="${lang}"><code class="language-${lang} highlighted">${code}</code></pre>`
+        );
+        return { ...file, content: newContent };
+      },
+    },
+  };
+}
