,\n    output: new Map(),\n    assets: new Map(),\n    data: data || new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '<p>HTML content</p>',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('rss-feed plugin', () => {\n  const plugin = createRssFeedPlugin();\n\n  it('generates valid RSS 2.0 XML', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1', date: '2024-01-01' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<?xml version=\"1.0\"');\n    expect(feed).toContain('<rss version=\"2.0\">');\n    expect(feed).toContain('<channel>');\n    expect(feed).toContain('<item>');\n    expect(feed).toContain('</rss>');\n  });\n\n  it('feed items contain HTML content not raw markdown', async () => {\n    const files = [\n      makeFile({\n        slug: 'post-1',\n        title: 'Post 1',\n        content: '<p>This is <strong>HTML</strong> content</p>',\n        date: '2024-01-01',\n      }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<![CDATA[<p>This is <strong>HTML</strong> content</p>]]>');\n  });\n\n  it('feed items include category tags from taxonomy', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['javascript'], date: '2024-01-01' }),\n    ];\n    const tagMap = new Map<string, ContentFile[]>();\n    tagMap.set('javascript', [files[0]]);\n    const data = new Map<string, unknown>();\n    data.set('taxonomy-tags', tagMap);\n    const ctx = makeCtx(files, data);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<category>javascript</category>');\n  });\n\n  it('feed includes channel title from config'