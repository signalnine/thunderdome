+import { EventBus } from '../bus.js';
+import { InventoryService, Events, InventoryUpdatedEvent, LowStockAlertEvent } from '../types.js';
+
+export function createInventoryService(bus: EventBus): InventoryService {
+  const stock = new Map<string, number>();
+  const reserved = new Map<string, number>();
+  const thresholds = new Map<string, number>();
+
+  return {
+    setStock(productId: string, quantity: number): void {
+      stock.set(productId, quantity);
+
+      const updateEvent: InventoryUpdatedEvent = { productId, quantity };
+      void bus.emit(Events.INVENTORY_UPDATED, updateEvent);
+
+      const threshold = thresholds.get(productId);
+      if (threshold !== undefined && quantity < threshold) {
+        const alertEvent: LowStockAlertEvent = { productId, currentQuantity: quantity, threshold };
+        void bus.emit(Events.LOW_STOCK_ALERT, alertEvent);
+      }
+    },
+
+    getStock(productId: string): number {
+      const currentStock = stock.get(productId) ?? 0;
+      const currentReserved = reserved.get(productId) ?? 0;
+      return currentStock - currentReserved;
+    },
+
+    reserve(productId: string, quantity: number): boolean {
+      const currentStock = stock.get(productId) ?? 0;
+      const currentReserved = reserved.get(productId) ?? 0;
+      const available = currentStock - currentReserved;
+
+      if (available >= quantity) {
+        reserved.set(productId, currentReserved + quantity);
+        return true;
+      }
+      return false;
+    },
+
+    release(productId: string, quantity: number): void {
+      const currentReserved = reserved.get(productId) ?? 0;
+      reserved.set(productId, Math.max(0, currentReserved - quantity));
+    },
+
+    setLowStockThreshold(productId: string, threshold: number): void {
+      thresholds.set(productId, threshold);
+    },
+  };
+}
