index 0000000..dfce3a5
--- /dev/null
+++ b/src/cart/index.ts
@@ -0,0 +1,79 @@
+import { EventBus } from '../bus.js';
+import { CartService, Events, CartUpdatedEvent } from '../types.js';
+
+export function createCartService(bus: EventBus): CartService {
+  const carts = new Map<string, { id: string; userId: string; items: Array<{ productId: string; quantity: number }> }>();
+  let cartCounter = 1;
+
+  return {
+    createCart(userId: string): string {
+      const id = `cart_${cartCounter++}`;
+      carts.set(id, { id, userId, items: [] });
+      return id;
+    },
+
+    addItem(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+
+      const existingItem = cart.items.find(item => item.productId === productId);
+      if (existingItem) {
+        existingItem.quantity += quantity;
+      } else {
+        cart.items.push({ productId, quantity });
+      }
+
+      void bus.emit(Events.CART_UPDATED, {
+        cartId: cart.id,
+        userId: cart.userId,
+        items: cart.items,
+      } as CartUpdatedEvent);
+    },
+
+    removeItem(cartId: string, productId: string): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+
+      cart.items = cart.items.filter(item => item.productId !== productId);
+
+      void bus.emit(Events.CART_UPDATED, {
+        cartId: cart.id,
+        userId: cart.userId,
+        items: cart.items,
+      } as CartUpdatedEvent);
+    },
+
+    getCart(cartId: string) {
+      return carts.get(cartId) ?? null;
+    },
+
+    clearCart(cartId: string): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+
+      cart.items = [];
+
+      void bus.emit(Events.CART_UPDATED, {
+        cartId: cart.id,
+        userId: cart.userId,
+        items: [],
+      } as CartUpdatedEvent);
+    },
+
+    updateQuantity(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+
+      const existingItem = cart.items.find(item => item.productId === productId);
+      if (existingItem) {
+        existingItem.quantity = quantity;
+      }
+
+      void bus.emit(Events.CART_UPDATED, {
+        cartId: cart.id,
+        userId: cart.userId,
+        items: cart.items,
+      } as CartUpdatedEvent);
+    },
+  };
+}
