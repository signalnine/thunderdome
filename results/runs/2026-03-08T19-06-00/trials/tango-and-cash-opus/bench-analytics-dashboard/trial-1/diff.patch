@@ -0,0 +1,72 @@
+import { Router, Response } from "express";
+import { v4 as uuidv4 } from "uuid";
+import { getDb } from "../db.js";
+import { AuthRequest, authenticate } from "../auth.js";
+
+const router = Router();
+
+router.use(authenticate);
+
+router.post("/", (req: AuthRequest, res: Response) => {
+  const { name, properties, timestamp, sessionId } = req.body;
+
+  if (!name) {
+    res.status(400).json({ error: "Event name is required" });
+    return;
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const eventTimestamp = timestamp || new Date().toISOString();
+  const eventProps = properties ? JSON.stringify(properties) : "{}";
+
+  db.prepare(
+    "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+  ).run(id, req.user!.tenantId, name, eventProps, eventTimestamp, req.user!.userId, sessionId || null);
+
+  res.status(201).json({
+    id,
+    tenantId: req.user!.tenantId,
+    name,
+    properties: properties || {},
+    timestamp: eventTimestamp,
+    userId: req.user!.userId,
+    sessionId: sessionId || null,
+  });
+});
+
+router.post("/batch", (req: AuthRequest, res: Response) => {
+  const { events } = req.body;
+
+  if (!Array.isArray(events) || events.length === 0) {
+    res.status(400).json({ error: "events array is required and must not be empty" });
+    return;
+  }
+
+  const db = getDb();
+  const insert = db.prepare(
+    "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+  );
+
+  const results: Array<{ id: string; name: string }> = [];
+
+  const insertMany = db.transaction((evts: Array<{ name: string; properties?: Record<string, unknown>; timestamp?: string; sessionId?: string }>) => {
+    for (const evt of evts) {
+      if (!evt.name) continue;
+      const id = uuidv4();
+      const eventTimestamp = evt.timestamp || new Date().toISOString();
+      const eventProps = evt.properties ? JSON.stringify(evt.properties) : "{}";
+      insert.run(id, req.user!.tenantId, evt.name, eventProps, eventTimestamp, req.user!.userId, evt.sessionId || null);
+      results.push({ id, name: evt.name });
+    }
+  });
+
+  insertMany(events);
+
+  res.status(201).json({
+    inserted: results.length,
+    events: results,
+  });
+});
+
+export default router;
diff --git a/src/routes/export.ts b/src/routes/export.ts
