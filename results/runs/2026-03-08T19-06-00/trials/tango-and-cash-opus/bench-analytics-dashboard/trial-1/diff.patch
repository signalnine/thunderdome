undefined;\n\n  if (!dashboard) {\n    res.status(404).json({ error: \"Dashboard not found\" });\n    return;\n  }\n\n  const newName = name || dashboard.name;\n  const newConfig = config ? JSON.stringify(config) : dashboard.config;\n\n  db.prepare(\n    \"UPDATE dashboards SET name = ?, config = ?, updated_at = datetime('now') WHERE id = ?\"\n  ).run(newName, newConfig, dashboard.id);\n\n  res.json({\n    id: dashboard.id,\n    tenantId: dashboard.tenant_id,\n    name: newName,\n    ownerId: dashboard.owner_id,\n    config: config || JSON.parse(dashboard.config),\n    updatedAt: new Date().toISOString(),\n  });\n});\n\nrouter.delete(\"/:id\", (req: AuthRequest, res: Response) => {\n  const db = getDb();\n\n  const dashboard = db.prepare(\n    \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n  ).get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n\n  if (!dashboard) {\n    res.status(404).json({ error: \"Dashboard not found\" });\n    return;\n  }\n\n  db.prepare(\"DELETE FROM widgets WHERE dashboard_id = ?\").run(dashboard.id);\n  db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(dashboard.id);\n\n  res.json({ deleted: true, id: dashboard.id });\n});\n\nexport default router;\n","structuredPatch":[],"originalFile":null}}
