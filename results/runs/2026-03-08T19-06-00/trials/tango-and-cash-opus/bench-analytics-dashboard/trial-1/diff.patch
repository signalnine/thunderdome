d<string, unknown>; timestamp?: string; sessionId?: string }>) => {\n    for (const evt of evts) {\n      if (!evt.name) continue;\n      const id = uuidv4();\n      const eventTimestamp = evt.timestamp || new Date().toISOString();\n      const eventProps = evt.properties ? JSON.stringify(evt.properties) : \"{}\";\n      insert.run(id, req.user!.tenantId, evt.name, eventProps, eventTimestamp, req.user!.userId, evt.sessionId || null);\n      results.push({ id, name: evt.name });\n    }\n  });\n\n  insertMany(events);\n\n  res.status(201).json({\n    inserted: results.length,\n    events: results,\n  });\n});\n\nexport default router;\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":414,"cache_read_input_tokens":27317,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":414},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d9ccb131-93dc-418a-806a-a62752ac5915","uuid":"77d1d32f-5fa4-4bbb-bda1-be3b8f151fcf"}
