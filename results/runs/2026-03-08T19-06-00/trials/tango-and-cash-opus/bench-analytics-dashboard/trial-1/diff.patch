+import { describe, it, expect, beforeAll } from "vitest";
+import request from "supertest";
+import { createApp } from "../src/app.js";
+import type { Application } from "express";
+
+let app: Application;
+let adminToken: string;
+let viewerToken: string;
+let tenantId: string;
+let adminUserId: string;
+let viewerUserId: string;
+
+beforeAll(() => {
+  app = createApp();
+  tenantId = "test-tenant-1";
+});
+
+describe("User Management", () => {
+  it("should register a new admin user", async () => {
+    const res = await request(app)
+      .post("/api/users/register")
+      .send({ email: "admin@test.com", password: "password123", tenantId, role: "admin" });
+
+    expect(res.status).toBe(201);
+    expect(res.body.email).toBe("admin@test.com");
+    expect(res.body.role).toBe("admin");
+    expect(res.body.token).toBeDefined();
+    adminToken = res.body.token;
+    adminUserId = res.body.id;
+  });
+
+  it("should register a viewer user", async () => {
+    const res = await request(app)
+      .post("/api/users/register")
+      .send({ email: "viewer@test.com", password: "password123", tenantId });
+
+    expect(res.status).toBe(201);
+    expect(res.body.role).toBe("viewer");
+    viewerToken = res.body.token;
+    viewerUserId = res.body.id;
+  });
+
+  it("should reject duplicate email", async () => {
+    const res = await request(app)
+      .post("/api/users/register")
+      .send({ email: "admin@test.com", password: "password123", tenantId });
+
+    expect(res.status).toBe(409);
+  });
+
+  it("should login", async () => {
+    const res = await request(app)
+      .post("/api/users/login")
+      .send({ email: "admin@test.com", password: "password123" });
+
+    expect(res.status).toBe(200);
+    expect(res.body.token).toBeDefined();
+  });
+
+  it("should reject bad credentials", async () => {
+    const res = await request(app)
+      .post("/api/users/login")
+      .send({ email: "admin@test.com", password: "wrong" });
+
+    expect(res.status).toBe(401);
+  });
+
+  it("should get own profile", async () => {
+    const res = await request(app)
+      .get("/api/users/me")
+      .set("Authorization", `Bearer ${adminToken}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body.email).toBe("admin@test.com");
+  });
+
+  it("should return 401 without token", async () => {
+    const res = await request(app).get("/api/users/me");
+    expect(res.status).toBe(401);
+  });
+
+  it("should allow admin to change role", async () => {
+    const res = await request(app)
+      .put("/api/users/role")
+      .set("Authorization", `Bearer ${adminToken}`)
+      .send({ userId: viewerUserId, role: "editor" });
+
+    expect(res.status).toBe(200);
+    expect(res.body.role).toBe("editor");
+  });
+
+  it("should reject non-admin role change", async () => {
+    const res = await request(app)
+      .put("/api/users/role")
+      .set("Authorization", `Bearer ${viewerToken}`)
+      .send({ userId: adminUserId, role: "viewer" });
+
+    expect(res.status).toBe(403);
+  });
+});
+
+describe("Event Ingestion", () => {
+  it("should ingest a single event", async () => {
+    const res = await request(app)
+      .post("/api/events")
+      .set("Authorization", `Bearer ${adminToken}`)
+      .send({
+        name: "page_view",
+        properties: { url: "/home", browser: "Chrome" },
+        timestamp: "2024-01-15T10:00:00Z",
+      });
+
+    expect(res.status).toBe(201);
+    expect(res.body.name).toBe("page_view");
+  });
+
+  it("should ingest batch events", async () => {
+    const events = [
+      { name: "page_view", properties: { url: "/about" }, timestamp: "2024-01-15T11:00:00Z" },
+      { name: "page_view", properties: { url: "/home" }, timestamp: "2024-01-16T10:00:00Z" },
+      { name: "click", properties: { button: "signup" }, timestamp: "2024-01-16T11:00:00Z" },
+    ];
+
+    const res = await request(app)
+      .post("/api/events/batch")
+      .set("Authorization", `Bearer ${adminToken}`)
+      .send({ events });
+
+    expect(res.status).toBe(201);
+    expect(res.body.inserted).toBe(3);
+  });
+
+  it("should reject unauthenticated event", async () => {
+    const res = await request(app)
+      .post("/api/events")
+      .send({ name: "test" });
+
+    expect(res.status).toBe(401);
+  });
+});
+
+describe("Query Engine", () => {
+  it("should count events", async () => {
+    const res = await request(app)
+      .post("/api/queries/count")
+      .set("Authorization", `Bearer ${adminToken}`)
