@@ -0,0 +1,177 @@
+import { Router, Response } from "express";
+import { v4 as uuidv4 } from "uuid";
+import { getDb } from "../db.js";
+import { AuthRequest, authenticate } from "../auth.js";
+
+const router = Router();
+
+router.use(authenticate);
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+router.post("/", (req: AuthRequest, res: Response) => {
+  const { name, config, widgets } = req.body;
+
+  if (!name) {
+    res.status(400).json({ error: "Dashboard name is required" });
+    return;
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const dashConfig = config ? JSON.stringify(config) : "{}";
+
+  db.prepare(
+    "INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)"
+  ).run(id, req.user!.tenantId, name, req.user!.userId, dashConfig);
+
+  if (Array.isArray(widgets)) {
+    const insertWidget = db.prepare(
+      "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+    );
+    for (const w of widgets) {
+      insertWidget.run(
+        uuidv4(),
+        id,
+        w.type || "counter",
+        w.config ? JSON.stringify(w.config) : "{}",
+        w.positionX ?? 0,
+        w.positionY ?? 0,
+        w.width ?? 1,
+        w.height ?? 1
+      );
+    }
+  }
+
+  res.status(201).json({
+    id,
+    tenantId: req.user!.tenantId,
+    name,
+    ownerId: req.user!.userId,
+    config: config || {},
+  });
+});
+
+router.get("/", (req: AuthRequest, res: Response) => {
+  const db = getDb();
+  const dashboards = db.prepare(
+    "SELECT * FROM dashboards WHERE tenant_id = ?"
+  ).all(req.user!.tenantId) as DashboardRow[];
+
+  res.json({
+    dashboards: dashboards.map((d) => ({
+      id: d.id,
+      tenantId: d.tenant_id,
+      name: d.name,
+      ownerId: d.owner_id,
+      config: JSON.parse(d.config),
+      createdAt: d.created_at,
+      updatedAt: d.updated_at,
+    })),
+  });
+});
+
+router.get("/:id", (req: AuthRequest, res: Response) => {
+  const db = getDb();
+  const dashboard = db.prepare(
+    "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+  ).get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: "Dashboard not found" });
+    return;
+  }
+
+  const widgets = db.prepare(
+    "SELECT * FROM widgets WHERE dashboard_id = ?"
+  ).all(dashboard.id) as WidgetRow[];
+
+  res.json({
+    id: dashboard.id,
+    tenantId: dashboard.tenant_id,
+    name: dashboard.name,
+    ownerId: dashboard.owner_id,
+    config: JSON.parse(dashboard.config),
+    createdAt: dashboard.created_at,
+    updatedAt: dashboard.updated_at,
+    widgets: widgets.map((w) => ({
+      id: w.id,
+      dashboardId: w.dashboard_id,
+      type: w.type,
+      config: JSON.parse(w.config),
+      positionX: w.position_x,
+      positionY: w.position_y,
+      width: w.width,
+      height: w.height,
+    })),
+  });
+});
+
+router.put("/:id", (req: AuthRequest, res: Response) => {
+  const { name, config } = req.body;
+  const db = getDb();
+
+  const dashboard = db.prepare(
+    "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+  ).get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: "Dashboard not found" });
+    return;
+  }
+
+  const newName = name || dashboard.name;
+  const newConfig = config ? JSON.stringify(config) : dashboard.config;
+
+  db.prepare(
+    "UPDATE dashboards SET name = ?, config = ?, updated_at = datetime('now') WHERE id = ?"
+  ).run(newName, newConfig, dashboard.id);
+
+  res.json({
+    id: dashboard.id,
+    tenantId: dashboard.tenant_id,
+    name: newName,
+    ownerId: dashboard.owner_id,
+    config: config || JSON.parse(dashboard.config),
+    updatedAt: new Date().toISOString(),
+  });
+});
+
+router.delete("/:id", (req: AuthRequest, res: Response) => {
+  const db = getDb();
+
+  const dashboard = db.prepare(
+    "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+  ).get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: "Dashboard not found" });
+    return;
+  }
+
+  db.prepare("DELETE FROM widgets WHERE dashboard_id = ?").run(dashboard.id);
+  db.prepare("DELETE FROM dashboards WHERE id = ?").run(dashboard.id);
+
+  res.json({ deleted: true, id: dashboard.id });
+});
+
+export default router;
