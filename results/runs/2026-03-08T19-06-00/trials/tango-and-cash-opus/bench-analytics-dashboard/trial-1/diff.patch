+import { Router, Response } from "express";
+import { getDb } from "../db.js";
+import { AuthRequest, authenticate } from "../auth.js";
+
+const router = Router();
+
+router.use(authenticate);
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = "id,tenant_id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map((e) => {
+    const props = e.properties.replace(/"/g, '""');
+    const userId = e.user_id || "";
+    const sessionId = e.session_id || "";
+    return `${e.id},${e.tenant_id},${e.name},"${props}",${e.timestamp},${userId},${sessionId}`;
+  });
+  return [header, ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const header = "id,tenant_id,name,owner_id,config,created_at,updated_at";
+  const rows = dashboards.map((d) => {
+    const config = d.config.replace(/"/g, '""');
+    return `${d.id},${d.tenant_id},${d.name},${d.owner_id},"${config}",${d.created_at},${d.updated_at}`;
+  });
+  return [header, ...rows].join("\n");
+}
+
+router.get("/events", (req: AuthRequest, res: Response) => {
+  const format = (req.query.format as string) || "json";
+  const eventName = req.query.eventName as string | undefined;
+  const startDate = req.query.startDate as string | undefined;
+  const endDate = req.query.endDate as string | undefined;
+
+  const db = getDb();
+  let sql = "SELECT * FROM events WHERE tenant_id = ?";
+  const params: unknown[] = [req.user!.tenantId];
+
+  if (eventName) {
+    sql += " AND name = ?";
+    params.push(eventName);
+  }
+
+  if (startDate) {
+    sql += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+
+  if (endDate) {
+    sql += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  sql += " ORDER BY timestamp DESC";
+
+  const events = db.prepare(sql).all(...params) as EventRow[];
+
+  if (format === "csv") {
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send(eventsToCsv(events));
+  } else {
+    res.json({
+      events: events.map((e) => ({
+        id: e.id,
+        tenantId: e.tenant_id,
+        name: e.name,
+        properties: JSON.parse(e.properties),
+        timestamp: e.timestamp,
+        userId: e.user_id,
+        sessionId: e.session_id,
+      })),
+    });
+  }
+});
+
+router.get("/dashboards", (req: AuthRequest, res: Response) => {
+  const format = (req.query.format as string) || "json";
+
+  const db = getDb();
+  const dashboards = db.prepare(
+    "SELECT * FROM dashboards WHERE tenant_id = ?"
+  ).all(req.user!.tenantId) as DashboardRow[];
+
+  if (format === "csv") {
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+    res.send(dashboardsToCsv(dashboards));
+  } else {
+    res.json({
+      dashboards: dashboards.map((d) => ({
+        id: d.id,
+        tenantId: d.tenant_id,
+        name: d.name,
+        ownerId: d.owner_id,
+        config: JSON.parse(d.config),
+        createdAt: d.created_at,
+        updatedAt: d.updated_at,
+      })),
+    });
+  }
+});
+
+router.get("/dashboards/:id", (req: AuthRequest, res: Response) => {
+  const format = (req.query.format as string) || "json";
+
+  const db = getDb();
+  const dashboard = db.prepare(
+    "SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?"
+  ).get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: "Dashboard not found" });
+    return;
+  }
+
+  if (format === "csv") {
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", `attachment; filename=dashboard-${dashboard.id}.csv`);
+    res.send(dashboardsToCsv([dashboard]));
+  } else {
+    res.json({
+      id: dashboard.id,
+      tenantId: dashboard.tenant_id,
+      name: dashboard.name,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+    });
+  }
+});
+
+export default router;
