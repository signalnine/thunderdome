req.user!.userId,\n    config: config || {},\n  });\n});\n\nrouter.get(\"/\", (req: AuthRequest, res: Response) => {\n  const db = getDb();\n  const dashboards = db.prepare(\n    \"SELECT * FROM dashboards WHERE tenant_id = ?\"\n  ).all(req.user!.tenantId) as DashboardRow[];\n\n  res.json({\n    dashboards: dashboards.map((d) => ({\n      id: d.id,\n      tenantId: d.tenant_id,\n      name: d.name,\n      ownerId: d.owner_id,\n      config: JSON.parse(d.config),\n      createdAt: d.created_at,\n      updatedAt: d.updated_at,\n    })),\n  });\n});\n\nrouter.get(\"/:id\", (req: AuthRequest, res: Response) => {\n  const db = getDb();\n  const dashboard = db.prepare(\n    \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n  ).get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n\n  if (!dashboard) {\n    res.status(404).json({ error: \"Dashboard not found\" });\n    return;\n  }\n\n  const widgets = db.prepare(\n    \"SELECT * FROM widgets WHERE dashboard_id = ?\"\n  ).all(dashboard.id) as WidgetRow[];\n\n  res.json({\n    id: dashboard.id,\n    tenantId: dashboard.tenant_id,\n    name: dashboard.name,\n    ownerId: dashboard.owner_id,\n    config: JSON.parse(dashboard.config),\n    createdAt: dashboard.created_at,\n    updatedAt: dashboard.updated_at,\n    widgets: widgets.map((w) => ({\n      id: w.id,\n      dashboardId: w.dashboard_id,\n      type: w.type,\n      config: JSON.parse(w.config),\n      positionX: w.position_x,\n      positionY: w.position_y,\n      width: w.width,\n      height: w.height,\n    })),\n  });\n});\n\nrouter.put(\"/:id\", (req: AuthRequest, res: Response) => {\n  const { name, config } = req.body;\n  const db = getDb();\n\n  const dashboard = db.prepare(\n    \"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\"\n  ).get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;\n\n  if (!dashboard) {\n    res.status(404).json({ error: \"Dashboard not found\" });\n    return;\n  }\n\n  const newName = na