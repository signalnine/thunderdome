+++ b/src/routes/queries.ts
@@ -0,0 +1,139 @@
+import { Router, Response } from "express";
+import { getDb } from "../db.js";
+import { AuthRequest, authenticate } from "../auth.js";
+
+const router = Router();
+
+router.use(authenticate);
+
+router.post("/count", (req: AuthRequest, res: Response) => {
+  const { eventName, startDate, endDate, filters } = req.body;
+
+  const db = getDb();
+  let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+  const params: unknown[] = [req.user!.tenantId];
+
+  if (eventName) {
+    sql += " AND name = ?";
+    params.push(eventName);
+  }
+
+  if (startDate) {
+    sql += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+
+  if (endDate) {
+    sql += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  if (filters && typeof filters === "object") {
+    for (const [key, value] of Object.entries(filters)) {
+      sql += " AND json_extract(properties, ?) = ?";
+      params.push(`$.${key}`, value);
+    }
+  }
+
+  const result = db.prepare(sql).get(...params) as { count: number };
+
+  res.json({ count: result.count });
+});
+
+router.post("/timeseries", (req: AuthRequest, res: Response) => {
+  const { eventName, startDate, endDate, interval, filters } = req.body;
+
+  if (!startDate || !endDate) {
+    res.status(400).json({ error: "startDate and endDate are required" });
+    return;
+  }
+
+  const db = getDb();
+  const granularity = interval || "day";
+
+  let dateFormat: string;
+  switch (granularity) {
+    case "hour":
+      dateFormat = "%Y-%m-%dT%H:00:00";
+      break;
+    case "day":
+      dateFormat = "%Y-%m-%d";
+      break;
+    case "week":
+      dateFormat = "%Y-W%W";
+      break;
+    case "month":
+      dateFormat = "%Y-%m";
+      break;
+    default:
+      dateFormat = "%Y-%m-%d";
+  }
+
+  let sql = `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+  const params: unknown[] = [req.user!.tenantId];
+
+  if (eventName) {
+    sql += " AND name = ?";
+    params.push(eventName);
+  }
+
+  sql += " AND timestamp >= ? AND timestamp <= ?";
+  params.push(startDate, endDate);
+
+  if (filters && typeof filters === "object") {
+    for (const [key, value] of Object.entries(filters)) {
+      sql += " AND json_extract(properties, ?) = ?";
+      params.push(`$.${key}`, value);
+    }
+  }
+
+  sql += " GROUP BY bucket ORDER BY bucket ASC";
+
+  const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+
+  res.json({ timeseries: results });
+});
+
+router.post("/breakdown", (req: AuthRequest, res: Response) => {
+  const { eventName, property, startDate, endDate, filters } = req.body;
+
+  if (!property) {
+    res.status(400).json({ error: "property is required for breakdown queries" });
+    return;
+  }
+
+  const db = getDb();
+
+  let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+  const params: unknown[] = [`$.${property}`, req.user!.tenantId];
+
+  if (eventName) {
+    sql += " AND name = ?";
+    params.push(eventName);
+  }
+
+  if (startDate) {
+    sql += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+
+  if (endDate) {
+    sql += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  if (filters && typeof filters === "object") {
+    for (const [key, value] of Object.entries(filters)) {
+      sql += " AND json_extract(properties, ?) = ?";
+      params.push(`$.${key}`, value);
+    }
+  }
+
+  sql += " GROUP BY value ORDER BY count DESC";
+
+  const results = db.prepare(sql).all(...params) as Array<{ value: string | null; count: number }>;
+
+  res.json({ breakdown: results });
+});
+
+export default router;
