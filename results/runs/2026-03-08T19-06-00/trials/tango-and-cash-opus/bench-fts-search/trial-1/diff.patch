press';\nimport Database from 'better-sqlite3';\nimport { Note, NoteInput } from './models.js';\nimport { NotFoundError, ValidationError } from './errors.js';\n\nfunction sanitizeFtsQuery(query: string): string {\n  // If the query contains quoted phrases, preserve them\n  // Otherwise, strip FTS5 special characters and treat each word as a term\n  const trimmed = query.trim();\n\n  // Check for quoted phrase queries like \"exact phrase\"\n  if (/^\".*\"$/.test(trimmed)) {\n    return trimmed;\n  }\n\n  // For non-quoted queries, escape special FTS5 characters\n  // Remove characters that have special meaning in FTS5: *, ^, :, (, ), {, }, +, -, ~\n  // Keep alphanumeric, spaces, and basic punctuation\n  const cleaned = trimmed.replace(/[*^:(){}+\\-~\"<>/\\\\&|!]/g, ' ');\n  // Collapse multiple spaces\n  const words = cleaned.split(/\\s+/).filter(w => w.length > 0);\n  if (words.length === 0) return '';\n  // Quote each individual word to avoid FTS5 syntax issues with apostrophes etc.\n  return words.map(w => `\"${w}\"`).join(' ');\n}\n\nexport function createRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // GET /notes/search - Full-text search (MUST come before /notes/:id)\n  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const q = req.query.q as string | undefined;\n      if (!q || q.trim() === '') {\n        throw new ValidationError('Search query is required');\n      }\n\n      const page = Math.max(1, parseInt(req.query.page as string) || 1);\n      const perPage = 20;\n      const offset = (page - 1) * perPage;\n\n      const sanitized = sanitizeFtsQuery(q);\n      if (sanitized === '') {\n        res.json({ results: [], total: 0, page, perPage });\n        return;\n      }\n\n      // Count total matches\n      const countStmt = db.prepare(`\n        SELECT COUNT(*) as total FROM notes_fts WHERE notes_fts MATCH ?\n      `);\n      const { total } = countStmt.get(sanitized) as { total: number };\n\n      // Get paginated results with BM25 ranking and snippet highlighting\n      const searchStmt = db.prepare(`\n        SELECT\n          notes_fts.rowid as id,\n          notes.title,\n          snippet(notes_fts, 0, '<mark>', '</mark>', '...', 32) as title_snippet,\n          snippet(notes_fts, 1, '<mark>', '</mark>', '...', 32) as body_snippet,\n          bm25(notes_fts) as rank\n        FROM notes_fts\n        JOIN notes ON notes.id = notes_fts.rowid\n        WHERE notes_fts MATCH ?\n        ORDER BY bm25(notes_fts)\n        LIMIT ? OFFSET ?\n      `);\n\n      const rows = searchStmt.all(sanitized, perPage, offset) as Array<{\n        id: number;\n        title: string;\n        title_snippet: string;\n        body_snippet: string;\n        rank: number;\n      }>;\n\n      const results = rows.map(row => ({\n        id: row.id,\n        title: row.title,\n        snippet: row.body_snippet || row.title_snippet,\n        rank: row.rank,\n      }));\n\n      res.json({ results, total, page, perPage });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes/search/suggest - Autocomplete suggestions\n  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const q = req.query.q as string | undefined;\n      if (!q || q.trim() === '') {\n        throw new ValidationError('Search query is required');\n      }\n\n      const sanitized = sanitizeFtsQuery(q);\n      if (sanitized === '') {\n        res.json({ results: [] });\n        return;\n      }\n\n      // Use prefix query for autocomplete: append * for prefix matching\n      const prefixQuery = sanitized + '*';\n\n      const suggestStmt = db.prepare(`\n        SELECT\n          notes_fts.rowid as id,\n          notes.title\n        FROM notes_fts\n        JOIN notes ON notes.id = notes_fts.rowid\n        WHERE notes_fts MATCH ?\n        ORDER BY bm25(notes_fts)\n        LIMIT 5\n      `);\n\n      const results = suggestStmt.all(prefixQuery) as Array<{ id: number; title: string }>;\n\n      res.json({ results });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes - List all notes (with optional tag filter)\n  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const tag = req.query.tag as string | undefined;\n\n      let notes: Note[];\n      if (tag) {\n        // Use a join with json_each for tag filtering\n        const tagStmt = db.prepare(`\n          SELECT DISTINCT notes.* FROM notes, json_each(notes.tags)\n          WHERE json_each.value = ?\n          ORDER BY created_at DESC\n        `);\n        notes = tagStmt.all(tag) as Note[];\n      } else {\n        const stmt = db.prepare('SELECT * FROM notes ORDER BY created_at DESC');\n        notes = stmt.all() as Note[];\n      }\n\n      res.json({ notes });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes/:id - Get single note\n  router.get('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const stmt = db.prepare('SELECT * FROM notes WHERE id = ?');\n      const note = stmt.get(id) as Note | undefined;\n\n      if (!note) {\n        throw new NotFoundError('Note not found');\n      }\n\n      res.json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // POST /notes - Create note\n  router.post('/notes', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const input = req.body as NoteInput;\n\n      if (!input.title || input.title.trim() === '') {\n        throw new ValidationError('Title is required');\n      }\n      if (!input.body || input.body.trim() === '') {\n        throw new ValidationError('Body is required');\n      }\n\n      const tags = input.tags ? JSON.stringify(input.tags) : '[]';\n      const stmt = db.prepare(`\n        INSERT INTO notes (title, body, tags) VALUES (?, ?, ?)\n      `);\n      const result = stmt.run(input.title, input.body, tags);\n\n      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(result.lastInsertRowid) as Note;\n      res.status(201).json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // PUT /notes/:id - Update note\n  router.put('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n\n      if (!existing) {\n        throw new NotFoundError('Note not found');\n      }\n\n      const input = req.body as Partial<NoteInput>;\n      const title = input.title ?? existing.title;\n      const body = input.body ?? existing.body;\n      const tags = input.tags ? JSON.stringify(input.tags) : existing.tags;\n\n      const stmt = db.prepare(`\n        UPDATE notes SET title = ?, body = ?, tags = ?, updated_at = datetime('now')\n        WHERE id = ?\n      `);\n      stmt.run(title, body, tags, id);\n\n      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note;\n      res.json({ note });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // DELETE /notes/:id - Delete note\n  router.delete('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n    try {\n      const id = parseInt(req.params.id);\n      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n\n      if (!existing) {\n        throw new NotFoundError('Note not found');\n      }\n\n      db.prepare('DELETE FROM notes WHERE id = ?').run(id);\n      res.status(204).send();\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  return router;\n}\n","structuredPatch":[{"oldStart":3,"oldLines":9,"newStart":3,"newLines":126,"lines":[" import { Note, NoteInput } from './models.js';"," import { NotFoundError, ValidationError } from './errors.js';"," ","+function sanitizeFtsQuery(query: string): string {","+  // If