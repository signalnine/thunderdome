+import * as crypto from 'node:crypto';
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  base: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  ours: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  theirs: any;
+}
+
+interface DocState {
+  deleted: boolean;
+  history: Version[];
+  content: object | null;
+}
+
+type BranchData = Map<string, DocState>;
+type Snapshot = Map<string, object | null>;
+type Obj = Record<string, unknown>;
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch = 'main';
+  private ancestorSnapshots: Map<string, Snapshot> = new Map();
+
+  constructor() {
+    this.branches.set('main', new Map());
+  }
+
+  // ── Document CRUD ──
+
+  create(id: string, content: object): void {
+    const branchDocs = this.branches.get(this.currentBranch)!;
+    const existing = branchDocs.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const cloned = structuredClone(content);
+    const version: Version = {
+      id: crypto.randomUUID(),
+      timestamp: Date.now(),
+      content: structuredClone(cloned),
+    };
+    if (existing && existing.deleted) {
+      existing.deleted = false;
+      existing.history.push(version);
+      existing.content = cloned;
+    } else {
+      branchDocs.set(id, {
+        deleted: false,
+        history: [version],
+        content: cloned,
+      });
+    }
+  }
+
+  get(id: string): object {
+    const doc = this.requireDoc(id);
+    if (doc.deleted) {
+      throw new Error(`Document "${id}" has been deleted`);
+    }
+    return structuredClone(doc.content!);
+  }
+
+  update(id: string, content: object): void {
+    const doc = this.requireDoc(id);
+    if (doc.deleted) {
+      throw new Error(`Document "${id}" has been deleted`);
+    }
+    const cloned = structuredClone(content);
+    const version: Version = {
+      id: crypto.randomUUID(),
+      timestamp: Date.now(),
+      content: structuredClone(cloned),
+    };
+    doc.history.push(version);
+    doc.content = cloned;
+  }
+
+  delete(id: string): void {
+    const doc = this.requireDoc(id);
+    if (doc.deleted) {
+      throw new Error(`Document "${id}" has been deleted`);
+    }
+    doc.deleted = true;
+    doc.content = null;
+  }
+
+  // ── Version History ──
+
+  getHistory(id: string): Version[] {
+    const doc = this.requireDoc(id);
+    return structuredClone(doc.history);
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const doc = this.requireDoc(id);
+    const version = doc.history.find((v) => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return structuredClone(version.content);
+  }
+
+  // ── Branching ──
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const sourceDocs = this.branches.get(sourceName);
+    if (!sourceDocs) {
+      throw new Error(`Branch "${sourceName}" does not exist`);
+    }
+
+    const newDocs: BranchData = new Map();
+    const snapshot: Snapshot = new Map();
+
+    for (const [id, doc] of sourceDocs) {
+      newDocs.set(id, {
+        deleted: doc.deleted,
+        history: structuredClone(doc.history),
+        content: doc.content !== null ? structuredClone(doc.content) : null,
+      });
+      snapshot.set(id, doc.content !== null ? structuredClone(doc.content) : null);
+    }
+
+    this.branches.set(name, newDocs);
+
+    const key1 = this.snapshotKey(sourceName, name);
+    const key2 = this.snapshotKey(name, sourceName);
+    this.ancestorSnapshots.set(key1, snapshot);
+    this.ancestorSnapshots.set(key2, structuredClone(snapshot));
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // ── Merging ──
+
+  merge(sourceBranch: string): MergeResult {
+    if (!this.branches.has(sourceBranch)) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+    if (sourceBranch === this.currentBranch) {
+      throw new Error('Cannot merge a branch into itself');
+    }
+
+    const targetName = this.currentBranch;
+    const key = this.snapshotKey(sourceBranch, targetName);
+    const baseSnapshot: Snapshot =
+      this.ancestorSnapshots.get(key) ?? new Map();
+
+    const targetDocs = this.branches.get(targetName)!;
+    const sourceDocs = this.branches.get(sourceBranch)!;
+
+    const allIds = new Set<string>();
+    for (const id of baseSnapshot.keys()) allIds.add(id);
+    for (const id of targetDocs.keys()) allIds.add(id);
+    for (const id of sourceDocs.keys()) allIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+    const toApply = new Map<string, object | null>();
+    let hasChanges = false;
+
+    for (const id of allIds) {
+      const inBase = baseSnapshot.has(id);
+      const baseContent = inBase ? baseSnapshot.get(id) : undefined;
+
+      const oursDoc = targetDocs.get(id);
+      const theirsDoc = sourceDocs.get(id);
+
+      const oursAlive = oursDoc !== undefined && !oursDoc.deleted;
+      const theirsAlive = theirsDoc !== undefined && !theirsDoc.deleted;
+
+      const oursContent: object | undefined = oursAlive ? oursDoc!.content! : undefined;
+      const theirsContent: object | undefined = theirsAlive ? theirsDoc!.content! : undefined;
+
+      const baseExists = inBase && baseContent !== null && baseContent !== undefined;
+      const baseObj: object | undefined = baseExists ? baseContent! : undefined;
+
+      if (!baseExists) {
+        if (oursContent !== undefined && theirsContent === undefined) {
+          merged[id] = structuredClone(oursContent);
+        } else if (oursContent === undefined && theirsContent !== undefined) {
+          merged[id] = structuredClone(theirsContent);
+          toApply.set(id, theirsContent);
+          hasChanges = true;
+        } else if (oursContent !== undefined && theirsContent !== undefined) {
+          if (this.deepEqual(oursContent, theirsContent)) {
+            merged[id] = structuredClone(oursContent);
+          } else {
+            const result = this.mergeObjects(id, {}, oursContent as Obj, theirsContent as Obj, conflicts);
+            merged[id] = result;
+            if (!this.deepEqual(oursContent, result)) {
+              toApply.set(id, result);
+              hasChanges = true;
+            }
+          }
+        }
+        continue;
+      }
+
+      const oursChanged = !this.deepEqual(baseObj, oursContent);
+      const theirsChanged = !this.deepEqual(baseObj, theirsContent);
+
+      if (oursContent === undefined && theirsContent === undefined) {
+        continue;
+      }
+
+      if (oursContent !== undefined && theirsContent !== undefined) {
+        if (!oursChanged && !theirsChanged) {
+          merged[id] = structuredClone(oursContent);
+          continue;
+        }
+        if (!oursChanged && theirsChanged) {
+          merged[id] = structuredClone(theirsContent);
+          toApply.set(id, theirsContent);
+          hasChanges = true;
+          continue;
+        }
+        if (oursChanged && !theirsChanged) {
+          merged[id] = structuredClone(oursContent);
+          continue;
+        }
+        if (this.deepEqual(oursContent, theirsContent)) {
+          merged[id] = structuredClone(oursContent);
+          continue;
+        }
+        if (this.isPlainObject(baseObj) && this.isPlainObject(oursContent) && this.isPlainObject(theirsContent)) {
+          const result = this.mergeObjects(id, baseObj, oursContent, theirsContent, conflicts);
+          merged[id] = result;
+          if (!this.deepEqual(oursContent, result)) {
+            toApply.set(id, result);
+            hasChanges = true;
+          }
+        } else {
+          conflicts.push({
+            documentId: id,
+            path: '',
+            base: structuredClone(baseObj),
+            ours: structuredClone(oursContent),
+            theirs: structuredClone(theirsContent),
+          });
+          merged[id] = structuredClone(oursContent);
+        }
+        continue;
+      }
+
+      if (oursContent === undefined && theirsContent !== undefined) {
+        if (!theirsChanged) {
+          continue;
+        } else {
+          conflicts.push({
+            documentId: id,
+            path: '',
+            base: structuredClone(baseObj),
+            ours: undefined,
+            theirs: structuredClone(theirsContent),
+          });
+          continue;
+        }
+      }
+
+      if (oursContent !== undefined && theirsContent === undefined) {
+        if (!oursChanged) {
+          toApply.set(id, null);
+          hasChanges = true;
+          continue;
+        } else {
+          conflicts.push({
+            documentId: id,
+            path: '',
+            base: structuredClone(baseObj),
+            ours: structuredClone(oursContent),
+            theirs: undefined,
+          });
+          merged[id] = structuredClone(oursContent);
+          continue;
+        }
+      }
+    }
+
+    if (conflicts.length > 0) {
+      return { merged, conflicts, applied: false };
+    }
+
+    if (!hasChanges) {
+      return { merged, conflicts: [], applied: true };
+    }
+
+    const savedBranch = this.currentBranch;
+    for (const [id, content] of toApply) {
+      if (content === null) {
+        const doc = targetDocs.get(id);
+        if (doc && !doc.deleted) {
+          doc.deleted = true;
+          doc.content = null;
+        }
+      } else {
+        const doc = targetDocs.get(id);
+        if (!doc || doc.deleted) {
+          this.currentBranch = targetName;
+          this.create(id, content);
+        } else {
+          this.currentBranch = targetName;
+          this.update(id, content);
+        }
+      }
+    }
+    this.currentBranch = savedBranch;
+
+    return { merged, conflicts: [], applied: true };
+  }
+
+  // ── Private Helpers ──
+
+  private requireDoc(id: string): DocState {
+    const branchDocs = this.branches.get(this.currentBranch)!;
+    const doc = branchDocs.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return doc;
+  }
+
+  private snapshotKey(branchA: string, branchB: string): string {
+    return `${branchA}:${branchB}`;
+  }
+
+  private isPlainObject(val: unknown): val is Obj {
+    return val !== null && val !== undefined && typeof val === 'object' && !Array.isArray(val);
+  }
+
+  private deepEqual(a: unknown, b: unknown): boolean {
+    if (a === b) return true;
+    if (a === null || b === null) return a === b;
+    if (a === undefined || b === undefined) return a === b;
+    if (typeof a !== typeof b) return false;
+    if (typeof a !== 'object') return false;
+
+    const aObj = a as Record<string, unknown>;
+    const bObj = b as Record<string, unknown>;
+
+    if (Array.isArray(a) !== Array.isArray(b)) return false;
+    if (Array.isArray(a)) {
+      const bArr = b as unknown[];
+      if (a.length !== bArr.length) return false;
+      for (let i = 0; i < a.length; i++) {
+        if (!this.deepEqual(a[i], bArr[i])) return false;
+      }
+      return true;
+    }
+
+    const keysA = Object.keys(aObj);
+    const keysB = Object.keys(bObj);
+    if (keysA.length !== keysB.length) return false;
+    for (const key of keysA) {
+      if (!Object.prototype.hasOwnProperty.call(bObj, key)) return false;
+      if (!this.deepEqual(aObj[key], bObj[key])) return false;
+    }
+    return true;
+  }
+
+  private mergeObjects(
+    docId: string,
+    base: Obj,
+    ours: Obj,
+    theirs: Obj,
+    conflicts: Conflict[],
+    pathPrefix = ''
+  ): Obj {
+    const result: Obj = {};
+    const allKeys = new Set<string>();
+    for (const k of Object.keys(base)) allKeys.add(k);
+    for (const k of Object.keys(ours)) allKeys.add(k);
+    for (const k of Object.keys(theirs)) allKeys.add(k);
+
+    for (const key of allKeys) {
+      const currentPath = pathPrefix ? `${pathPrefix}.${key}` : key;
+      const bVal = Object.prototype.hasOwnProperty.call(base, key) ? base[key] : undefined;
+      const oVal = Object.prototype.hasOwnProperty.call(ours, key) ? ours[key] : undefined;
+      const tVal = Object.prototype.hasOwnProperty.call(theirs, key) ? theirs[key] : undefined;
+
+      const oChanged = !this.deepEqual(bVal, oVal);
+      const tChanged = !this.deepEqual(bVal, tVal);
+
+      if (!oChanged && !tChanged) {
+        if (bVal !== undefined) {
+          result[key] = structuredClone(bVal);
+        }
+        continue;
+      }
+
+      if (oChanged && !tChanged) {
+        if (oVal !== undefined) {
+          result[key] = structuredClone(oVal);
+        }
+        continue;
+      }
+
+      if (!oChanged && tChanged) {
+        if (tVal !== undefined) {
+          result[key] = structuredClone(tVal);
+        }
+        continue;
+      }
+
+      // Both changed
+      if (this.deepEqual(oVal, tVal)) {
+        if (oVal !== undefined) {
+          result[key] = structuredClone(oVal);
+        }
+        continue;
+      }
+
+      // Both changed to different values - recurse if all plain objects
+      if (this.isPlainObject(bVal) && this.isPlainObject(oVal) && this.isPlainObject(tVal)) {
+        result[key] = this.mergeObjects(docId, bVal, oVal, tVal, conflicts, currentPath);
+        continue;
+      }
+
+      // Conflict
+      conflicts.push({
+        documentId: docId,
+        path: currentPath,
+        base: bVal !== undefined ? structuredClone(bVal) : undefined,
+        ours: oVal !== undefined ? structuredClone(oVal) : undefined,
+        theirs: tVal !== undefined ? structuredClone(tVal) : undefined,
+      });
+      // Resolve in favor of ours
+      if (oVal !== undefined) {
+        result[key] = structuredClone(oVal);
+      }
+    }
+
+    return result;
+  }
+}
