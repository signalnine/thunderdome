+import { describe, it, expect, beforeEach } from "vitest";
+import { createReviewService } from "./index.js";
+import type { ReviewService } from "../types.js";
+
+describe("ReviewService", () => {
+  let reviews: ReviewService;
+
+  beforeEach(() => {
+    reviews = createReviewService();
+  });
+
+  describe("addReview", () => {
+    it("should add a review and return it with id and createdAt", () => {
+      const review = reviews.addReview({
+        pluginName: "test-plugin",
+        pluginVersion: "1.0.0",
+        userId: "user1",
+        rating: 5,
+        comment: "Great plugin!",
+      });
+      expect(review.id).toBe(1);
+      expect(review.pluginName).toBe("test-plugin");
+      expect(review.rating).toBe(5);
+      expect(review.flagged).toBe(false);
+      expect(review.createdAt).toBeDefined();
+    });
+
+    it("should auto-increment ids", () => {
+      const r1 = reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u1",
+        rating: 3,
+        comment: "ok",
+      });
+      const r2 = reviews.addReview({
+        pluginName: "b",
+        pluginVersion: "1.0.0",
+        userId: "u1",
+        rating: 4,
+        comment: "good",
+      });
+      expect(r2.id).toBe(r1.id + 1);
+    });
+  });
+
+  describe("getReviews", () => {
+    it("should get reviews for a specific plugin", () => {
+      reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u1",
+        rating: 5,
+        comment: "nice",
+      });
+      reviews.addReview({
+        pluginName: "b",
+        pluginVersion: "1.0.0",
+        userId: "u1",
+        rating: 4,
+        comment: "ok",
+      });
+      reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u2",
+        rating: 3,
+        comment: "meh",
+      });
+
+      const pluginAReviews = reviews.getReviews("a");
+      expect(pluginAReviews).toHaveLength(2);
+      expect(pluginAReviews.every((r) => r.pluginName === "a")).toBe(true);
+    });
+
+    it("should return empty array for plugin with no reviews", () => {
+      expect(reviews.getReviews("nonexistent")).toEqual([]);
+    });
+  });
+
+  describe("getAverageRating", () => {
+    it("should compute average of non-flagged reviews", () => {
+      reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u1",
+        rating: 4,
+        comment: "good",
+      });
+      reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u2",
+        rating: 2,
+        comment: "ok",
+      });
+      expect(reviews.getAverageRating("a")).toBe(3);
+    });
+
+    it("should exclude flagged reviews from average", () => {
+      const r1 = reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u1",
+        rating: 1,
+        comment: "spam",
+      });
+      reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u2",
+        rating: 5,
+        comment: "great",
+      });
+      reviews.flagReview(r1.id);
+      expect(reviews.getAverageRating("a")).toBe(5);
+    });
+
+    it("should return 0 for plugin with no reviews", () => {
+      expect(reviews.getAverageRating("nonexistent")).toBe(0);
+    });
+  });
+
+  describe("flagReview", () => {
+    it("should flag a review", () => {
+      const review = reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u1",
+        rating: 1,
+        comment: "spam",
+      });
+      reviews.flagReview(review.id);
+      const flagged = reviews.getFlaggedReviews();
+      expect(flagged).toHaveLength(1);
+      expect(flagged[0].id).toBe(review.id);
+      expect(flagged[0].flagged).toBe(true);
+    });
+  });
+
+  describe("getFlaggedReviews", () => {
+    it("should return only flagged reviews", () => {
+      reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u1",
+        rating: 5,
+        comment: "good",
+      });
+      const spam = reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u2",
+        rating: 1,
+        comment: "spam",
+      });
+      reviews.flagReview(spam.id);
+      expect(reviews.getFlaggedReviews()).toHaveLength(1);
+    });
+  });
+
+  describe("removeReview", () => {
+    it("should remove a review and return true", () => {
+      const review = reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u1",
+        rating: 5,
+        comment: "great",
+      });
+      expect(reviews.removeReview(review.id)).toBe(true);
+      expect(reviews.getReviews("a")).toHaveLength(0);
+    });
+
+    it("should return false for non-existent review", () => {
+      expect(reviews.removeReview(999)).toBe(false);
+    });
+  });
+
+  describe("getReviewsByUser", () => {
+    it("should return reviews by a specific user", () => {
+      reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "user1",
+        rating: 5,
+        comment: "nice",
+      });
+      reviews.addReview({
+        pluginName: "b",
+        pluginVersion: "1.0.0",
+        userId: "user2",
+        rating: 4,
+        comment: "ok",
+      });
+      reviews.addReview({
+        pluginName: "c",
+        pluginVersion: "1.0.0",
+        userId: "user1",
+        rating: 3,
+        comment: "eh",
+      });
+
+      const user1Reviews = reviews.getReviewsByUser("user1");
+      expect(user1Reviews).toHaveLength(2);
+      expect(user1Reviews.every((r) => r.userId === "user1")).toBe(true);
+    });
+  });
+
+  describe("getReviewCount", () => {
+    it("should return count of reviews for a plugin", () => {
+      reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u1",
+        rating: 5,
+        comment: "great",
+      });
+      reviews.addReview({
+        pluginName: "a",
+        pluginVersion: "1.0.0",
+        userId: "u2",
+        rating: 4,
+        comment: "good",
+      });
+      expect(reviews.getReviewCount("a")).toBe(2);
+    });
+
+    it("should return 0 for no reviews", () => {
+      expect(reviews.getReviewCount("nonexistent")).toBe(0);
+    });
+  });
+});
