@@ -0,0 +1,93 @@
+import semver from "semver";
+import type { PluginManifest, RegistryService } from "../types.js";
+
+export function createRegistry(): RegistryService {
+  const store = new Map<string, Map<string, PluginManifest>>();
+
+  return {
+    register(manifest: PluginManifest): void {
+      if (!store.has(manifest.name)) {
+        store.set(manifest.name, new Map());
+      }
+      const versions = store.get(manifest.name)!;
+      if (versions.has(manifest.version)) {
+        throw new Error(
+          `Plugin ${manifest.name}@${manifest.version} already exists`
+        );
+      }
+      versions.set(manifest.version, { ...manifest });
+    },
+
+    get(name: string): PluginManifest | null {
+      const versions = store.get(name);
+      if (!versions || versions.size === 0) return null;
+
+      const sortedVersions = Array.from(versions.keys()).sort((a, b) =>
+        semver.rcompare(a, b)
+      );
+      return versions.get(sortedVersions[0]) ?? null;
+    },
+
+    getVersion(name: string, version: string): PluginManifest | null {
+      const versions = store.get(name);
+      if (!versions) return null;
+      return versions.get(version) ?? null;
+    },
+
+    list(): PluginManifest[] {
+      const all: PluginManifest[] = [];
+      for (const versions of store.values()) {
+        all.push(...versions.values());
+      }
+      return all;
+    },
+
+    search(query: string): PluginManifest[] {
+      const q = query.toLowerCase();
+      const results: PluginManifest[] = [];
+      for (const versions of store.values()) {
+        for (const manifest of versions.values()) {
+          if (
+            manifest.name.toLowerCase().includes(q) ||
+            manifest.description.toLowerCase().includes(q) ||
+            manifest.author.toLowerCase().includes(q)
+          ) {
+            results.push(manifest);
+          }
+        }
+      }
+      return results;
+    },
+
+    remove(name: string, version: string): boolean {
+      const versions = store.get(name);
+      if (!versions) return false;
+      const deleted = versions.delete(version);
+      if (versions.size === 0) {
+        store.delete(name);
+      }
+      return deleted;
+    },
+
+    listVersions(name: string): string[] {
+      const versions = store.get(name);
+      if (!versions) return [];
+      return Array.from(versions.keys()).sort((a, b) =>
+        semver.rcompare(a, b)
+      );
+    },
+
+    update(
+      name: string,
+      version: string,
+      updates: Partial<PluginManifest>
+    ): void {
+      const versions = store.get(name);
+      if (!versions || !versions.has(version)) {
+        throw new Error(`Plugin ${name}@${version} not found`);
+      }
+      const existing = versions.get(version)!;
+      versions.set(version, { ...existing, ...updates });
+    },
+  };
+}
