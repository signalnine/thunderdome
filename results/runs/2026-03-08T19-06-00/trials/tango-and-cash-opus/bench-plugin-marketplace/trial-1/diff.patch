\" }));\n      registry.register(makeManifest({ version: \"2.0.0\" }));\n      registry.register(makeManifest({ version: \"1.5.0\" }));\n      expect(registry.get(\"test-plugin\")?.version).toBe(\"2.0.0\");\n    });\n  });\n\n  describe(\"getVersion\", () => {\n    it(\"should return exact version\", () => {\n      registry.register(makeManifest({ version: \"1.0.0\" }));\n      registry.register(makeManifest({ version: \"2.0.0\" }));\n      expect(registry.getVersion(\"test-plugin\", \"1.0.0\")?.version).toBe(\n        \"1.0.0\"\n      );\n    });\n\n    it(\"should return null for non-existent version\", () => {\n      registry.register(makeManifest());\n      expect(registry.getVersion(\"test-plugin\", \"9.9.9\")).toBeNull();\n    });\n\n    it(\"should return null for non-existent plugin\", () => {\n      expect(registry.getVersion(\"nope\", \"1.0.0\")).toBeNull();\n    });\n  });\n\n  describe(\"list\", () => {\n    it(\"should return all manifests\", () => {\n      registry.register(makeManifest({ name: \"a\", version: \"1.0.0\" }));\n      registry.register(makeManifest({ name: \"b\", version: \"1.0.0\" }));\n      registry.register(makeManifest({ name: \"a\", version: \"2.0.0\" }));\n      expect(registry.list()).toHaveLength(3);\n    });\n\n    it(\"should return empty array when no plugins\", () => {\n      expect(registry.list()).toEqual([]);\n    });\n  });\n\n  describe(\"search\", () => {\n    it(\"should find plugins by name\", () => {\n      registry.register(makeManifest({ name: \"foo-bar\" }));\n      registry.register(makeManifest({ name: \"baz-qux\" }));\n      expect(registry.search(\"foo\")).toHaveLength(1);\n      expect(registry.search(\"foo\")[0].name).toBe(\"foo-bar\");\n    });\n\n    it(\"should find plugins by description\", () => {\n      registry.register(\n        makeManifest({ name: \"plug\", description: \"A logging utility\" })\n      );\n      expect(registry.search(\"logging\")).toHaveLength(1);\n    });\n\n    it(\"should find plugins by author\", () => {\n      registry.register(makeManifest({ name: \"plug\", author: \"JohnDoe\" }));\n      expect(registry.search(\"johndoe\")).toHaveLength(1);\n    });\n\n    it(\"should be case-insensitive\", () => {\n      registry.register(makeManifest({ name: \"FooBar\" }));\n      expect(registry.search(\"foobar\")).toHaveLength(1);\n      expect(registry.search(\"FOOBAR\")).toHaveLength(1);\n    });\n  });\n\n  describe(\"remove\", () => {\n    it(\"should remove a specific version\", () => {\n      registry.register(makeManifest({ version: \"1.0.0\" }));\n      registry.register(makeManifest({ version: \"2.0.0\" }));\n      expect(registry.remove(\"test-plugin\", \"1.0.0\")).toBe(true);\n      expect(registry.getVersion(\"test-plugin\", \"1.0.0\")).toBeNull();\n      expect(registry.getVersion(\"test-plugin\", \"2.0.0\")).not.toBeNull();\n    });\n\n    it(\"should return false for non-existent plugin\", () => {\n      expect(registry.remove(\"nonexistent\", \"1.0.0\")).toBe(false);\n    });\n\n    it(\"should return false for non-existent version\", () => {\n      registry.register(makeManifest());\n      expect(registry.remove(\"test-plugin\", \"9.9.9\")).toBe(false);\n    });\n  });\n\n  describe(\"listVersions\", () => {\n    it(\"should return versions sorted by semver descending\", () => {\n      registry.register(makeManifest({ version: \"1.0.0\" }));\n      registry.register(makeManifest({ version: \"3.0.0\" }));\n      registry.register(makeManifest({ version: \"2.0.0\" }));\n      expect(registry.listVersions(\"test-plugin\")).toEqual([\n        \"3.0.0\",\n        \"2.0.0\",\n        \"1.0.0\",\n      ]);\n    });\n\n    it(\"should return empty array for non-existent plugin\", () => {\n      expect(registry.listVersions(\"nope\")).toEqual([]);\n    });\n  });\n\n  describe(\"update\", () => {\n    it(\"should update manifest fields\", () => {\n      registry.register(makeManifest());\n      registry.update(\"test-plugin\", \"1.0.0\", {\