+export function countBeamCells(grid: string[][]): number {
+  if (!grid || grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  let startRow = -1;
+  let startCol = -1;
+
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      startRow = 0;
+      startCol = c;
+      break;
+    }
+  }
+
+  if (startRow === -1) return 0;
+
+  const visited = new Set<string>();
+  const visitedStates = new Set<string>();
+
+  visited.add(`${startRow},${startCol}`);
+  visitedStates.add(`${startRow},${startCol},0`);
+
+  const queue: [number, number, number][] = [[startRow, startCol, 0]];
+
+  while (queue.length > 0) {
+    const [r, c, dir] = queue.shift()!;
+
+    const nr = r + 1;
+    const nc = c + dir;
+
+    if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
+      visited.add(`${nr},${nc}`);
+
+      if (grid[nr][nc] === '^') {
+        const state1 = `${nr},${nc},-1`;
+        if (!visitedStates.has(state1)) {
+          visitedStates.add(state1);
+          queue.push([nr, nc, -1]);
+        }
+
+        const state2 = `${nr},${nc},1`;
+        if (!visitedStates.has(state2)) {
+          visitedStates.add(state2);
+          queue.push([nr, nc, 1]);
+        }
+      } else {
+        const state = `${nr},${nc},${dir}`;
+        if (!visitedStates.has(state)) {
+          visitedStates.add(state);
+          queue.push([nr, nc, dir]);
+        }
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (!grid || grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  let startRow = -1;
+  let startCol = -1;
+
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      startRow = 0;
+      startCol = c;
+      break;
+    }
+  }
+
+  if (startRow === -1) return 0n;
+
+  const memo = new Map<string, bigint>();
+
+  function getPathsFromSplitter(r: number, c: number): bigint {
+    const key = `${r},${c}`;
+    if (memo.has(key)) return memo.get(key)!;
+
+    const paths = traceBeam(r + 1, c - 1, -1) + traceBeam(r + 1, c + 1, 1);
+    memo.set(key, paths);
+    return paths;
+  }
+
+  function traceBeam(r: number, c: number, dir: number): bigint {
+    let currR = r;
+    let currC = c;
+
+    while (currR >= 0 && currR < rows && currC >= 0 && currC < cols) {
+      if (grid[currR][currC] === '^') {
+        return getPathsFromSplitter(currR, currC);
+      }
+      currR++;
+      currC += dir;
+    }
+
+    return 1n;
+  }
+
+  return traceBeam(startRow + 1, startCol, 0);
+}
