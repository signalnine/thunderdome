nction validateUser(input: unknown): {\n  valid: boolean;\n  errors?: string[];\n} {\n  const result = validateCreateUser(input);\n  return {\n    valid: result.success,\n    errors: result.errors,\n  };\n}\n\nexport function getUserById(id: number): User | null {\n  const conn = getDefaultConnection();\n  return findUserById(conn, id);\n}\n\nexport function getAllUsers(): User[] {\n  const conn = getDefaultConnection();\n  return findAllUsers(conn);\n}\n\nexport function canUserPerformAction(\n  userRole: User['role'],\n  action: 'read' | 'write' | 'delete'\n): boolean {\n  return hasPermission(userRole, action);\n}\n","structuredPatch":[{"oldStart":68,"oldLines":3,"newStart":68,"newLines":8,"lines":[" ): boolean {","   return hasPermission(userRole, action);"," }","+","+/** Utility to check if a user exists by ID */","+export function userExists(id: number): boolean {","+  return getUserById(id) !== null;","+}"]}],"userModified":false,"replaceAll":false}}
