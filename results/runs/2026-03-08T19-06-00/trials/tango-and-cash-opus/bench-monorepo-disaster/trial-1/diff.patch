er input correctly', () => {\n    57→    const valid = validateUser({\n    58→      name: 'Test',\n    59→      email: 'test@test.com',\n    60→      role: 'user',\n    61→    });\n    62→    expect(valid.valid).toBe(true);\n    63→\n    64→    const invalid = validateUser({ name: '', email: 'not-an-email', role: 'hacker' });\n    65→    expect(invalid.valid).toBe(false);\n    66→    expect(invalid.errors).toBeDefined();\n    67→  });\n    68→});\n    69→"}]},"parent_tool_use_id":"toolu_01FmsGLmVu7AirWkxd4gaRwP","session_id":"ce3b1dec-8d36-4754-bf31-ffcb32ea075e","uuid":"2ac26354-361c-4077-9e8d-265410193aad"}
