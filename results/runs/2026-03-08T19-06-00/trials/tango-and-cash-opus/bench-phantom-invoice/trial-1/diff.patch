rice: 50 },\n   207→        { description: 'Product B', quantity: 5, unit_price: 100 },\n   208→      ],\n   209→    });\n   210→    const invoice = getInvoiceById(db, id);\n   211→    // subtotal = 500 + 500 = 1000\n   212→    // discounted = 1000 * 0.85 = 850\n   213→    // total = 850 * 1.0 = 850\n   214→    expect(invoice!.total).toBe(850);\n   215→  });\n   216→});\n   217→\n   218→// ─── Date Range Queries (7 tests) ──────────────────────────────────\n   219→\n   220→describe('Date Range Queries', () => {\n   221→  beforeEach(() => {\n   222→    // Seed some invoices across different dates\n   223→    const dates = [\n   224→      '2024-01-15', '2024-01-31', '2024-02-01',\n   225→      '2024-02-28', '2024-03-01', '2024-03-31',\n   226→      '2024-06-30',\n   227→    ];\n   228→    dates.forEach((date, i) => {\n   229→      createInvoice(db, {\n   230→        customer_id: `cust-${i}`,\n   231→        date,\n   232→        subtotal: (i + 1) * 100,\n   233→        discount_rate: 0,\n   234→        tax_rate: 0,\n   235→        total: (i + 1) * 100,\n   236→        status: 'paid',\n   237→      });\n   238→    });\n   239→  });\n   240→\n   241→  it('returns invoices within a date range', () => {\n   242→    const invoices = getInvoicesByDateRange(db, '2024-02-01', '2024-03-15');\n   243→    expect(invoices).toHaveLength(3);\n   244→  });\n   245→\n   246→  it('returns empty array when no invoices match', () => {\n   247→    const invoices = getInvoicesByDateRange(db, '2025-01-01', '2025-12-31');\n   248→    expect(invoices).toHaveLength(0);\n   249→  });\n   250→\n   251→  it('includes invoices on start date boundary', () => {\n   252→    const invoices = getInvoicesByDateRange(db, '2024-01-15', '2024-01-20');\n   253→    expect(invoices).toHaveLength(1);\n   254→    expect(invoices[0].date).toBe('2024-01-15');\n   255→  });\n   256→\n   257→  it('includes invoices on end date boundary', () => {\n   258→    // Should include the invoice on 2024-03-31\n   259→    c