   485→      sheet.set('A1', 10);\n   486→      sheet.set('A2', 20);\n   487→      sheet.set('A3', '=A1+A2');\n   488→      expect(sheet.get('A3')).toBe(30);\n   489→      expect(sheet.getDisplay('A3')).toBe('30');\n   490→\n   491→      sheet.set('A1', 50);\n   492→      expect(sheet.get('A3')).toBe(70);\n   493→\n   494→      sheet.set('B1', '=SUM(A1:A2)');\n   495→      expect(sheet.get('B1')).toBe(70);\n   496→\n   497→      sheet.set('C1', '=IF(A1>30, \"big\", \"small\")');\n   498→      expect(sheet.get('C1')).toBe('big');\n   499→    });\n   500→  });\n   501→\n   502→  describe('edge cases', () => {\n   503→    it('should handle division by zero', () => {\n   504→      const sheet = new Spreadsheet();\n   505→      sheet.set('A1', 10);\n   506→      sheet.set('A2', 0);\n   507→      expect(() => sheet.set('A3', '=A1/A2')).toThrow(/[Dd]ivision/);\n   508→    });\n   509→\n   510→    it('should handle overwriting a cell value', () => {\n   511→      const sheet = new Spreadsheet();\n   512→      sheet.set('A1', 10);\n   513→      expect(sheet.get('A1')).toBe(10);\n   514→      sheet.set('A1', 20);\n   515→      expect(sheet.get('A1')).toBe(20);\n   516→    });\n   517→\n   518→    it('should handle string values in formulas', () => {\n   519→      const sheet = new Spreadsheet();\n   520→      sheet.set('A1', '=IF(1>0, \"yes\", \"no\")');\n   521→      expect(sheet.get('A1')).toBe('yes');\n   522→    });\n   523→\n   524→    it('should handle boolean literals in formulas', () => {\n   525→      const sheet = new Spreadsheet();\n   526→      sheet.set('A1', '=IF(true, 1, 0)');\n   527→      expect(sheet.get('A1')).toBe(1);\n   528→    });\n   529→\n   530→    it('should handle nested functions', () => {\n   531→      const sheet = new Spreadsheet();\n   532→      sheet.set('A1', 5);\n   533→      sheet.set('A2', 10);\n   534→      sheet.set('A3', 15);\n   535→      sheet.set('A4', '=IF(SUM(A1:A3)>20, MAX(A1:A3), MIN(A1:A3))');\n   536→      expect(sheet.get('A4