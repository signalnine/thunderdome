+      }
+      case 'STRING': {
+        this.consume();
+        return { type: 'string', value: token.value };
+      }
+      case 'BOOLEAN': {
+        this.consume();
+        return { type: 'boolean', value: token.value === 'TRUE' };
+      }
+      case 'CELL_REF': {
+        this.consume();
+        return { type: 'cell_ref', ref: token.value };
+      }
+      case 'RANGE': {
+        this.consume();
+        const [start, end] = token.value.split(':');
+        return { type: 'range', start, end };
+      }
+      case 'FUNCTION': {
+        const name = this.consume().value;
+        this.expect('LPAREN');
+        const args: ASTNode[] = [];
+        if (this.peek()?.type !== 'RPAREN') {
+          args.push(this.parseComparison());
+          while (this.peek()?.type === 'COMMA') {
+            this.consume();
+            args.push(this.parseComparison());
+          }
+        }
+        this.expect('RPAREN');
+        return { type: 'function', name, args };
+      }
+      case 'LPAREN': {
+        this.consume();
+        const node = this.parseComparison();
+        this.expect('RPAREN');
+        return node;
+      }
+      default:
+        throw new Error(`Unexpected token: ${token.value}`);
+    }
+  }
+}
+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+// --- Dependency Extraction ---
+
+function extractDependencies(ast: ASTNode): Set<string> {
+  const deps = new Set<string>();
+  function walk(node: ASTNode): void {
+    switch (node.type) {
+      case 'cell_ref':
+        deps.add(node.ref);
+        break;
+      case 'range':
+        for (const cell of expandRange(node.start, node.end)) {
+          deps.add(cell);
+        }
+        break;
+      case 'binary':
+        walk(node.left);
+        walk(node.right);
+        break;
+      case 'unary':
+        walk(node.operand);
+        break;
+      case 'function':
+        for (const arg of node.args) {
+          walk(arg);
+        }
+        break;
+    }
+  }
+  walk(ast);
+  return deps;
+}
+
+// --- Evaluator ---
+
+type CellValue = string | number | boolean | null;
+
+function evaluate(ast: ASTNode, getCellValue: (ref: string) => CellValue): CellValue {
+  switch (ast.type) {
+    case 'number':
+      return ast.value;
+    case 'string':
+      return ast.value;
+    case 'boolean':
+      return ast.value;
+    case 'cell_ref':
+      return getCellValue(ast.ref);
+    case 'range':
+      throw new Error('Range can only be used inside functions');
+    case 'unary': {
+      const operand = evaluate(ast.operand, getCellValue);
+      if (typeof operand !== 'number') return operand;
+      return ast.op === '-' ? -operand : operand;
+    }
+    case 'binary':
+      return evaluateBinary(ast.op, ast.left, ast.right, getCellValue);
+    case 'function':
+      return evaluateFunction(ast.name, ast.args, getCellValue);
+  }
+}
+
+function evaluateBinary(op: string, left: ASTNode, right: ASTNode, getCellValue: (ref: string) => CellValue): CellValue {
+  const lv = evaluate(left, getCellValue);
+  const rv = evaluate(right, getCellValue);
+
+  // Comparison operators
+  switch (op) {
+    case '=':
+      return lv === rv;
+    case '<>':
+      return lv !== rv;
+    case '<':
+      return (lv as number) < (rv as number);
+    case '>':
+      return (lv as number) > (rv as number);
+    case '<=':
+      return (lv as number) <= (rv as number);
+    case '>=':
+      return (lv as number) >= (rv as number);
+  }
+
+  // Arithmetic operators — treat null as 0
+  const ln = typeof lv === 'number' ? lv : 0;
+  const rn = typeof rv === 'number' ? rv : 0;
+
+  switch (op) {
+    case '+':
+      return ln + rn;
+    case '-':
+      return ln - rn;
+    case '*':
+      return ln * rn;
+    case '/':
+      if (rn === 0) throw new Error('Division by zero');
+      return ln / rn;
+    default:
+      throw new Error(`Unknown operator: ${op}`);
+  }
+}
+
+function resolveRangeValues(node: ASTNode, getCellValue: (ref: string) => CellValue): CellValue[] {
+  if (node.type === 'range') {
+    return expandRange(node.start, node.end).map(ref => getCellValue(ref));
+  }
+  return [evaluate(node, getCellValue)];
+}
+
+function evaluateFunction(name: string, args: ASTNode[], getCellValue: (ref: string) => CellValue): CellValue {
+  switch (name) {
+    case 'SUM': {
+      let sum = 0;
+      for (const arg of args) {
+        for (const v of resolveRangeValues(arg, getCellValue)) {
+          if (typeof v === 'number') sum += v;
+        }
+      }
+      return sum;
+    }
+    case 'AVERAGE': {
+      let sum = 0;
+      let count = 0;
+      for (const arg of args) {
+        for (const v of resolveRangeValues(arg, getCellValue)) {
+          if (typeof v === 'number') {
+            sum += v;
+            count++;
+          }
+        }
+      }
+      return count === 0 ? 0 : sum / count;
+    }
+    case 'MIN': {
+      let min = Infinity;
+      for (const arg of args) {
+        for (const v of resolveRangeValues(arg, getCellValue)) {
+          if (typeof v === 'number' && v < min) min = v;
+        }
+      }
+      return min === Infinity ? 0 : min;
+    }
+    case 'MAX': {
+      let max = -Infinity;
+      for (const arg of args) {
+        for (const v of resolveRangeValues(arg, getCellValue)) {
+          if (typeof v === 'number' && v > max) max = v;
+        }
+      }
+      return max === -Infinity ? 0 : max;
+    }
+    case 'COUNT': {
+      let count = 0;
+      for (const arg of args) {
+        for (const v of resolveRangeValues(arg, getCellValue)) {
+          if (typeof v === 'number') count++;
+        }
+      }
+      return count;
+    }
+    case 'IF': {
+      if (args.length < 3) throw new Error('IF requires 3 arguments');
+      const condition = evaluate(args[0], getCellValue);
+      // Falsy: false, 0, null, ""
+      const isTruthy = condition !== false && condition !== 0 && condition !== null && condition !== '';
+      return evaluate(isTruthy ? args[1] : args[2], getCellValue);
+    }
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
+
+// --- Spreadsheet Class ---
+
+interface CellData {
+  raw: string | number | boolean;
+  ast?: ASTNode;
+  value: CellValue;
+  deps: Set<string>;
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Map from cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+
+    // Parse if formula
+    let ast: ASTNode | undefined;
+    let deps = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaStr = value.slice(1);
+      ast = parseFormula(formulaStr);
+      deps = extractDependencies(ast);
+    }
+
+    // Check for circular references before committing
+    if (deps.size > 0) {
+      this.checkCircular(ref, deps);
+    }
+
+    // Compute value BEFORE modifying any state, so errors don't corrupt the graph
+    const computedValue = ast ? this.evaluate(ast) : value;
+
+    // Remove old reverse dependencies
+    const oldCell = this.cells.get(ref);
+    if (oldCell) {
+      for (const dep of oldCell.deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    // Register new reverse dependencies
+    for (const dep of deps) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    const cellData: CellData = { raw: value, ast, value: computedValue, deps };
+    this.cells.set(ref, cellData);
+
+    // Propagate updates to dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = cell.toUpperCase();
+    const cellData = this.cells.get(ref);
+    return cellData ? cellData.value : null;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, cellData] of this.cells) {
+      result.set(ref, cellData.value);
+    }
+    return result;
+  }
+
+  private evaluate(ast: ASTNode): CellValue {
+    return evaluate(ast, (ref: string) => this.get(ref));
+  }
+
+  private checkCircular(target: string, deps: Set<string>): void {
+    // BFS from deps to see if we reach target
+    const visited = new Set<string>();
+    const queue = [...deps];
+
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      if (current === target) {
+        throw new Error(`Circular reference detected: ${target}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      // Follow the dependencies of current cell
+      const currentCell = this.cells.get(current);
+      if (currentCell) {
+        for (const dep of currentCell.deps) {
+          if (!visited.has(dep)) {
+            queue.push(dep);
+          }
+        }
+      }
+    }
+  }
+
+  private propagate(changed: string): void {
+    // Topological sort of all transitive dependents, then recompute in order
+    const order: string[] = [];
+    const visited = new Set<string>();
+
+    const visit = (ref: string): void => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+      order.push(ref);
+    };
+
+    // Start from the changed cell's dependents
+    const directDeps = this.dependents.get(changed);
+    if (directDeps) {
+      for (const dep of directDeps) {
+        visit(dep);
+      }
+    }
+
+    // Recompute in reverse topological order
+    order.reverse();
+    for (const ref of order) {
+      const cellData = this.cells.get(ref);
+      if (cellData?.ast) {
+        try {
+          cellData.value = this.evaluate(cellData.ast);
+        } catch {
+          cellData.value = null;
+        }
+      }
+    }
+  }
+}
