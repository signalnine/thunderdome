st maxCol = Math.max(s.col, e.col);\n  const minRow = Math.min(s.row, e.row);\n  const maxRow = Math.max(s.row, e.row);\n  const cells: string[] = [];\n  for (let r = minRow; r <= maxRow; r++) {\n    for (let c = minCol; c <= maxCol; c++) {\n      cells.push(refToString(c, r));\n    }\n  }\n  return cells;\n}\n\n// --- Tokenizer ---\n\ntype TokenType =\n  | 'NUMBER'\n  | 'STRING'\n  | 'BOOLEAN'\n  | 'CELL_REF'\n  | 'RANGE'\n  | 'FUNCTION'\n  | 'OP'\n  | 'COMPARE'\n  | 'LPAREN'\n  | 'RPAREN'\n  | 'COMMA';\n\ninterface Token {\n  type: TokenType;\n  value: string;\n}\n\nfunction tokenize(formula: string): Token[] {\n  const tokens: Token[] = [];\n  let i = 0;\n\n  while (i < formula.length) {\n    // Skip whitespace\n    if (formula[i] === ' ' || formula[i] === '\\t') {\n      i++;\n      continue;\n    }\n\n    // String literal\n    if (formula[i] === '\"') {\n      let str = '';\n      i++; // skip opening quote\n      while (i < formula.length && formula[i] !== '\"') {\n        str += formula[i];\n        i++;\n      }\n      if (i < formula.length) i++; // skip closing quote\n      tokens.push({ type: 'STRING', value: str });\n      continue;\n    }\n\n    // Number\n    if (/\\d/.test(formula[i]) || (formula[i] === '.' && i + 1 < formula.length && /\\d/.test(formula[i + 1]))) {\n      let num = '';\n      while (i < formula.length && (/\\d/.test(formula[i]) || formula[i] === '.')) {\n        num += formula[i];\n        i++;\n      }\n      tokens.push({ type: 'NUMBER', value: num });\n      continue;\n    }\n\n    // Cell reference, range, function, or boolean\n    if (/[A-Za-z]/.test(formula[i])) {\n      let ident = '';\n      while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {\n        ident += formula[i];\n        i++;\n      }\n\n      const upper = ident.toUpperCase();\n\n      // Check for boolean\n      if (upper === 'TRUE' || upper === 'FALSE') {\n        tokens.push({ type: 'BOOLEAN', value: upper });\n        continue;\n      }\n\n      // Check if it's a range (CELL:CELL)\n      if (/^[A-Z]+\\d+$/i.test(ident) && i < formula.length && formula[i] === ':') {\n        i++; // skip colon\n        let end = '';\n        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {\n          end += formula[i];\n          i++;\n        }\n        tokens.push({ type: 'RANGE', value: upper + ':' + end.toUpperCase() });\n        continue;\n      }\n\n      // Check if it's a function call (followed by '(')\n      if (i < formula.length && formula[i] === '(') {\n        tokens.push({ type: 'FUNCTION', value: upper });\n        continue;\n      }\n\n      // Check if it's a cell reference\n      if (/^[A-Z]+\\d+$/.test(upper)) {\n        tokens.push({ type: 'CELL_REF', value: upper });\n        continue;\n      }\n\n      throw new Error(`Unknown identifier: ${ident}`);\n    }\n\n    // Comparison operators\n    if (formula[i] === '<') {\n      if (i + 1 < formula.length && formula[i + 1] === '=') {\n        tokens.push({ type: 'COMPARE', value: '<=' });\n        i += 2;\n        continue;\n      }\n      if (i + 1 < formula.length && formula[i + 1] === '>') {\n        tokens.push({ type: 'COMPARE', value: '<>' });\n        i += 2;\n        continue;\n      }\n      tokens.push({ type: 'COMPARE', value: '<' });\n      i++;\n      continue;\n    }\n    if (formula[i] === '>') {\n      if (i + 1 < formula.length && formula[i + 1] === '=') {\n        tokens.push({ type: 'COMPARE', value: '>=' });\n        i += 2;\n        continue;\n      }\n      tokens.push({ type: 'COMPARE', value: '>' });\n      i++;\n      continue;\n    }\n    if (formula[i] === '=') {\n      tokens.push({ type: 'COMPARE', value: '=' });\n      i++;\n      continue;\n    }\n\n    // Arithmetic operators\n    if ('+-*/'.includes(formula[i])) {\n      tokens.push({ type: 'OP', value: formula[i] });\n      i++;\n      continue;\n    }\n\n    // Parens and comma\n    if (formula[i] === '(') {\n      tokens.push({ type: 'LPAREN', value: '(' });\n      i++;\n      continue;\n    }\n    if (formula[i] === ')') {\n      tokens.push({ type: 'RPAREN', value: ')' });\n      i++;\n      continue;\n    }\n    if (formula[i] === ',') {\n      tokens.push({ type: 'COMMA', value: ',' });\n      i++;\n      continue;\n    }\n\n    throw new Error(`Unexpected character: ${formula[i]}`);\n  }\n\n  return tokens;\n}\n\n// --- AST ---\n\ntype ASTNode =\n  | { type: 'number'; value: number }\n  | { type: 'string'; value: string }\n  | { type: 'boolean'; value: boolean }\n  | { type: 'cell_ref'; ref: string }\n  | { type: 'range'; start: string; end: string }\n  | { type: 'binary'; op: string; left: ASTNode; right: ASTNode }\n  | { type: 'unary'; op: string; operand: ASTNode }\n  | { type: 'function'; name: string; args: ASTNode[] };\n\n// --- Parser (recursive descent) ---\n\nclass Parser {\n  private tokens: Token[];\n  private pos: number;\n\n  constructor(tokens: Token[]) {\n    this.tokens = tokens;\n    this.pos = 0;\n  }\n\n  parse(): ASTNode {\n    const node = this.parseComparison();\n    if (this.pos < this.tokens.length) {\n      throw new Error(`Unexpected token: ${this.tokens[this.pos].value}`);\n    }\n    return node;\n  }\n\n  private peek(): Token | undefined {\n    return this.tokens[this.pos];\n  }\n\n  private consume(): Token {\n    return this.tokens[this.pos++];\n  }\n\n  private expect(type: TokenType): Token {\n    const token = this.consume();\n    if (!token || token.type !== type) {\n      throw new Error(`Expected ${type}, got ${token?.type ?? 'EOF'}`);\n    }\n    return token;\n  }\n\n  private parseComparison(): ASTNode {\n    let left = this.parseAddSub();\n    while (this.peek()?.type === 'COMPARE') {\n      const op = this.consume().value;\n      const right = this.parseAddSub();\n      left = { type: 'binary', op, left, right };\n    }\n    return left;\n  }\n\n  private parseAddSub(): ASTNode {\n    let left = this.parseMulDiv();\n    while (this.peek()?.type === 'OP' && (this.peek()!.value === '+' || this.peek()!.value === '-')) {\n      const op = this.consume().value;\n      const right = this.parseMulDiv();\n      left = { type: 'binary', op, left, right };\n    }\n    return left;\n  }\n\n  private parseMulDiv(): ASTNode {\n    let left = this.parseUnary();\n    while (this.peek()?.type === 'OP' && (this.peek()!.value === '*' || this.peek()!.value === '/')) {\n      const op = this.consume().value;\n      const right = this.parseUnary();\n      left = { type: 'binary', op, left, right };\n    }\n    return left;\n  }\n\n  private parseUnary(): ASTNode {\n    if (this.peek()?.type === 'OP' && (this.peek()!.value === '-' || this.peek()!.value === '+')) {\n      const op = this.consume().value;\n      const operand = this.parseUnary();\n      return { type: 'unary', op, operand };\n    }\n    return this.parsePrimary();\n  }\n\n  private parsePrimary(): ASTNode {\n    const token = this.peek();\n    if (!token) throw new Error('Unexpected end of expression');\n\n    switch (token.type) {\n      case 'NUMBER': {\n        this.consume();\n        return { type: 'number', value: parseFloat(token.value) };\n      }\n      case 'STRING': {\n        this.consume();\n        return { type: 'string', value: token.value };\n      }\n      case 'BOOLEAN': {\n        this.consume();\n        return { type: 'boolean', value: token.value === 'TRUE' };\n      }\n      case 'CELL_REF': {\n        this.consume();\n        return { type: 'cell_ref', ref: token.value };\n      }\n      case 'RANGE': {\n        this.consume();\n        const [start, end] = token.value.split(':');\n        return { type: 'range', start, end };\n      }\n      case 'FUNCTION': {\n        const name = this.consume().value;\n        this.expect('LPAREN');\n        const args: ASTNode[] = [];\n        if (this.peek()?.type !== 'RPAREN') {\n          args.push(this.parseComparison());\n          while (this.peek()?.type === 'COMMA') {\n            this.consume();\n            args.push(this.parseComparison());\n          }\n        }\n        this.expect('RPAREN');\n        return { type: 'function', name, args };\n      }\n      case 'LPAREN': {\n        this.consume();\n        const node = this.parseComparison();\n        this.expect('RPAREN');\n        return node;\n      }\n      default:\n        throw new Error(`Unexpected token: ${token.value}`);\n    }\n  }\n}\n\nfunction parseFormula(formula: string): ASTNode {\n  const tokens = tokenize(formula);\n  const parser = new Parser(tokens);\n  return parser.parse();\n}\n\n// --- Dependency Extraction ---\n\nfunction extractDependencies(ast: ASTNode): Set<string> {\n  const deps = new Set<string>();\n  function walk(node: ASTNode): void {\n    switch (node.type) {\n      case 'cell_ref':\n        deps.add(node.ref);\n        break;\n      case 'range':\n        for (const cell of expandRange(node.start, node.end)) {\n          deps.add(cell);\n        }\n        break;\n      case 'binary':\n        walk(node.left);\n        walk(node.right);\n        break;\n      case 'unary':\n        walk(node.operand);\n        break;\n      case 'function':\n        for (const arg of node.args) {\n          walk(arg);\n        }\n        break;\n    }\n  }\n  walk(ast);\n  return deps;\n}\n\n// --- Evaluator ---\n\ntype CellValue = string | number | boolean | null;\n\nfunction evaluate(ast: ASTNode, getCellValue: (ref: string) => CellValue): CellValue {\n  switch (ast.type) {\n    case 'number':\n      return ast.value;\n    case 'string':\n      return ast.value;\n    case 'boolean':\n      return ast.value;\n    case 'cell_ref':\n      return getCellValue(ast.ref);\n    case 'range':\n      throw new Error('Range can only be used inside functions');\n    case 'unary': {\n      const operand = evaluate(ast.operand, getCellValue);\n      if (typeof operand !== 'number') return operand;\n      return ast.op === '-' ? -operand : operand;\n    }\n    case 'binary':\n      return evaluateBinary(ast.op, ast.left, ast.right, getCellValue);\n    case 'function':\n      return evaluateFunction(ast.name, ast.args, getCellValue);\n  }\n}\n\nfunction evaluateBinary(op: string, left: ASTNode, right: ASTNode, getCellValue: (ref: string) => CellValue): CellValue {\n  const lv = evaluate(left, getCellValue);\n  const rv = evaluate(right, getCellValue);\n\n  // Comparison operators\n  switch (op) {\n    case '=':\n      return lv === rv;\n    case '<>':\n      return lv !== rv;\n    case '<':\n      return (lv as number) < (rv as number);\n    case '>':\n      return (lv as number) > (rv as number);\n    case '<=':\n      return (lv as number) <= (rv as number);\n    case '>=':\n      return (lv as number) >= (rv as number);\n  }\n\n  // Arithmetic operators — treat null as 0\n  const ln = typeof lv === 'number' ? lv : 0;\n  const rn = typeof rv === 'number' ? rv : 0;\n\n  switch (op) {\n    case '+':\n      return ln + rn;\n    case '-':\n      return ln - rn;\n    case '*':\n      return ln * rn;\n    case '/':\n      if (rn === 0) throw new Error('Division by zero');\n      return ln / rn;\n    default:\n      throw new Error(`Unknown operator: ${op}`);\n  }\n}\n\nfunction resolveRangeValues(node: ASTNode, getCellValue: (ref: string) => CellValue): CellValue[] {\n  if (node.type === 'range') {\n    return expandRange(node.start, node.end).map(ref => getCellValue(ref));\n  }\n  return [evaluate(node, getCellValue)];\n}\n\nfunction evaluateFunction(name: string, args: ASTNode[], getCellValue: (ref: string) => CellValue): CellValue {\n  switch (name) {\n    case 'SUM': {\n      let sum = 0;\n      for (const arg of args) {\n        for (const v of resolveRangeValues(arg, getCellValue)) {\n          if (typeof v === 'number') sum += v;\n        }\n      }\n      return sum;\n    }\n    case 'AVERAGE': {\n      let sum = 0;\n      let count = 0;\n      for (const arg of args) {\n        for (const v of resolveRangeValues(arg, getCellValue)) {\n          if (typeof v === 'number') {\n            sum += v;\n            count++;\n          }\n        }\n      }\n      return count === 0 ? 0 : sum / count;\n    }\n    case 'MIN': {\n      let min = Infinity;\n      for (const arg of args) {\n        for (const v of resolveRangeValues(arg, getCellValue)) {\n          if (typeof v === 'number' && v < min) min = v;\n        }\n      }\n      return min === Infinity ? 0 : min;\n    }\n    case 'MAX': {\n      let max = -Infinity;\n      for (const arg of args) {\n        for (const v of resolveRangeValues(arg, getCellValue)) {\n          if (typeof v === 'number' && v > max) max = v;\n        }\n      }\n      return max === -Infinity ? 0 : max;\n    }\n    case 'COUNT': {\n      let count = 0;\n      for (const arg of args) {\n        for (const v of resolveRangeValues(arg, getCellValue)) {\n          if (typeof v === 'number') count++;\n        }\n      }\n      return count;\n    }\n    case 'IF': {\n      if (args.length < 3) throw new Error('IF requires 3 arguments');\n      const condition = evaluate(args[0], getCellValue);\n      // Falsy: false, 0, null, \"\"\n      const isTruthy = condition !== false && condition !== 0 && condition !== null && condition !== '';\n      return evaluate(isTruthy ? args[1] : args[2], getCellValue);\n    }\n    default:\n      throw new Error(`Unknown function: ${name}`);\n  }\n}\n\n// --- Spreadsheet Class ---\n\ninterface CellData {\n  raw: string | number | boolean;\n  ast?: ASTNode;\n  value: CellValue;\n  deps: Set<string>;\n}\n\nexport class Spreadsheet {\n  private cells: Map<string, CellData> = new Map();\n  // Map from cell -> set of cells that depend on it\n  private dependents: Map<string, Set<string>> = new Map();\n\n  set(cell: string, value: string | number | boolean): void {\n    const ref = cell.toUpperCase();\n\n    // Parse if formula\n    let ast: ASTNode | undefined;\n    let deps = new Set<string>();\n\n    if (typeof value === 'string' && value.startsWith('=')) {\n      const formulaStr = valu