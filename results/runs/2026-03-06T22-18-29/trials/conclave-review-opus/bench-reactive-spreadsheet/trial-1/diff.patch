eturn cells;\n}\n\n// --- Tokenizer ---\n\ntype TokenType =\n  | 'NUMBER'\n  | 'STRING'\n  | 'BOOLEAN'\n  | 'CELL_REF'\n  | 'RANGE'\n  | 'FUNCTION'\n  | 'OP'\n  | 'COMPARE'\n  | 'LPAREN'\n  | 'RPAREN'\n  | 'COMMA';\n\ninterface Token {\n  type: TokenType;\n  value: string;\n}\n\nfunction tokenize(formula: string): Token[] {\n  const tokens: Token[] = [];\n  let i = 0;\n\n  while (i < formula.length) {\n    // Skip whitespace\n    if (formula[i] === ' ' || formula[i] === '\\t') {\n      i++;\n      continue;\n    }\n\n    // String literal\n    if (formula[i] === '\"') {\n      let str = '';\n      i++; // skip opening quote\n      while (i < formula.length && formula[i] !== '\"') {\n        str += formula[i];\n        i++;\n      }\n      if (i < formula.length) i++; // skip closing quote\n      tokens.push({ type: 'STRING', value: str });\n      continue;\n    }\n\n    // Number\n    if (/\\d/.test(formula[i]) || (formula[i] === '.' && i + 1 < formula.length && /\\d/.test(formula[i + 1]))) {\n      let num = '';\n      while (i < formula.length && (/\\d/.test(formula[i]) || formula[i] === '.')) {\n        num += formula[i];\n        i++;\n      }\n      tokens.push({ type: 'NUMBER', value: num });\n      continue;\n    }\n\n    // Cell reference, range, function, or boolean\n    if (/[A-Za-z]/.test(formula[i])) {\n      let ident = '';\n      while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {\n        ident += formula[i];\n        i++;\n      }\n\n      const upper = ident.toUpperCase();\n\n      // Check for boolean\n      if (upper === 'TRUE' || upper === 'FALSE') {\n        tokens.push({ type: 'BOOLEAN', value: upper });\n        continue;\n      }\n\n      // Check if it's a range (CELL:CELL)\n      if (/^[A-Z]+\\d+$/i.test(ident) && i < formula.length && formula[i] === ':') {\n        i++; // skip colon\n        let end = '';\n        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {\n          end += formula[i];\n          i++;\n        }\n        tokens.push({ type: 'RANGE', value: upper + ':' + end.toUpperCase() });\n        continue;\n      }\n\n      // Check if it's a function call (followed by '(')\n      if (i < formula.length && formula[i] === '(') {\n        tokens.push({ type: 'FUNCTION', value: upper });\n        continue;\n      }\n\n      // Check if it's a cell reference\n      if (/^[A-Z]+\\d+$/.test(upper)) {\n        tokens.push({ type: 'CELL_REF', value: upper });\n        continue;\n      }\n\n      throw new Error(`Unknown identifier: ${ident}`);\n    }\n\n    // Comparison operators\n    if (formula[i] === '<') {\n      if (i + 1 < formula.length && formula[i + 1] === '=') {\n        tokens.push({ type: 'COMPARE', value: '<=' });\n        i += 2;\n        continue;\n      }\n      if (i + 1 < formula.length && formula[i + 1] === '>') {\n        tokens.push({ type: 'COMPARE', value: '<>' });\n        i += 2;\n        continue;\n      }\n      tokens.push({ type: 'COMPARE', value: '<' });\n      i++;\n      continue;\n    }\n    if (formula[i] === '>') {\n      if (i + 1 < formula.length && formula[i + 1] === '=') {\n        tokens.push({ type: 'COMPARE', value: '>=' });\n        i += 2;\n        continue;\n      }\n      tokens.push({ type: 'COMPARE', value: '>' });\n      i++;\n      continue;\n    }\n    if (formula[i] === '=') {\n      tokens.push({ type: 'COMPARE', value: '=' });\n      i++;\n      continue;\n    }\n\n    // Arithmetic operators\n    if ('+-*/'.includes(formula[i])) {\n      tokens.push({ type: 'OP', value: formula[i] });\n      i++;\n      continue;\n    }\n\n    // Parens and comma\n    if (formula[i] === '(') {\n      tokens.push({ type: 'LPAREN', value: '(' });\n      i++;\n      continue;\n    }\n    if (formula[i] === ')') {\n      tokens.push({ type: 'RPAREN', value: ')' });\n      i++;\n      continue;\n    }\n    if (formula[i] === ',') {\n      tokens.push({ type: 'COMMA', value: ',' });\n      i++;\n      continue;\n    }\n\n    throw new Error