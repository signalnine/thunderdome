+import { describe, it, expect } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+describe('Spreadsheet', () => {
+  describe('basic values', () => {
+    it('should store and retrieve numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should store and retrieve strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should store and retrieve booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.get('A1')).toBe(null);
+    });
+
+    it('should store floating point numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 3.14);
+      expect(sheet.get('A1')).toBeCloseTo(3.14);
+    });
+
+    it('should handle case-insensitive cell references', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('a1', 10);
+      expect(sheet.get('A1')).toBe(10);
+      expect(sheet.get('a1')).toBe(10);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('should display numbers as strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should display strings as strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should display booleans as strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should display empty cells as empty string', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('should display formula results', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('getCells', () => {
+    it('should return all non-empty cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(3);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+    });
+
+    it('should return empty map for empty spreadsheet', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getCells().size).toBe(0);
+    });
+  });
+
+  describe('simple formulas', () => {
+    it('should evaluate addition', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate subtraction', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 30);
+      sheet.set('A2', 10);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(20);
+    });
+
+    it('should evaluate multiplication', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate division', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 20);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(5);
+    });
+
+    it('should respect operator precedence', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('A4', '=A1+A2*A3');
+      expect(sheet.get('A4')).toBe(14); // 2 + 3*4 = 14
+    });
+
+    it('should handle parentheses', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', '=((A1+A2)*2)');
+      expect(sheet.get('A3')).toBe(10);
+    });
+
+    it('should handle unary minus', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', '=-A1');
+      expect(sheet.get('A2')).toBe(-5);
+    });
+
+    it('should handle numeric literals in formulas', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+5');
+      expect(sheet.get('A2')).toBe(15);
+    });
+
+    it('should reference empty cells as null (treated as 0 in arithmetic)', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+B1');
+      expect(sheet.get('A2')).toBe(10);
+    });
+  });
+
+  describe('comparison operators', () => {
+    it('should evaluate greater than', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1>5');
+      expect(sheet.get('A2')).toBe(true);
+    });
+
+    it('should evaluate less than', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 3);
+      sheet.set('A2', '=A1<5');
+      expect(sheet.get('A2')).toBe(true);
+    });
+
+    it('should evaluate equality', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', '=A1=5');
+      expect(sheet.get('A2')).toBe(true);
+    });
+
+    it('should evaluate not equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', '=A1<>3');
+      expect(sheet.get('A2')).toBe(true);
+    });
+
+    it('should evaluate greater than or equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', '=A1>=5');
+      expect(sheet.get('A2')).toBe(true);
+    });
+
+    it('should evaluate less than or equal', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', '=A1<=5');
+      expect(sheet.get('A2')).toBe(true);
+    });
+  });
+
+  describe('SUM function', () => {
+    it('should sum a column range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('A4', '=SUM(A1:A3)');
+      expect(sheet.get('A4')).toBe(60);
+    });
+
+    it('should sum a row range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('B1', 2);
+      sheet.set('C1', 3);
+      sheet.set('D1', '=SUM(A1:C1)');
+      expect(sheet.get('D1')).toBe(6);
+    });
+
+    it('should sum a block range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('B1', 2);
+      sheet.set('A2', 3);
+      sheet.set('B2', 4);
+      sheet.set('C1', '=SUM(A1:B2)');
+      expect(sheet.get('C1')).toBe(10);
+    });
+
+    it('should skip non-numeric values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 'hello');
+      sheet.set('A3', 20);
+      sheet.set('A4', '=SUM(A1:A3)');
+      expect(sheet.get('A4')).toBe(30);
+    });
+  });
+
+  describe('AVERAGE function', () => {
+    it('should compute average', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('A4', '=AVERAGE(A1:A3)');
+      expect(sheet.get('A4')).toBe(20);
+    });
+
+    it('should skip non-numeric values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 'hello');
+      sheet.set('A3', 30);
+      sheet.set('A4', '=AVERAGE(A1:A3)');
+      expect(sheet.get('A4')).toBe(20); // (10+30)/2
+    });
+  });
+
+  describe('MIN function', () => {
