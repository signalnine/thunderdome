lue, deps };\n    this.cells.set(ref, cellData);","originalFile":"// --- Cell Reference Utilities ---\n\nfunction columnToIndex(col: string): number {\n  let index = 0;\n  for (let i = 0; i < col.length; i++) {\n    index = index * 26 + (col.charCodeAt(i) - 64);\n  }\n  return index - 1; // 0-based\n}\n\nfunction indexToColumn(index: number): string {\n  let col = '';\n  let n = index + 1; // 1-based\n  while (n > 0) {\n    n--;\n    col = String.fromCharCode(65 + (n % 26)) + col;\n    n = Math.floor(n / 26);\n  }\n  return col;\n}\n\nfunction parseRef(ref: string): { col: number; row: number } {\n  const match = ref.match(/^([A-Z]+)(\\d+)$/);\n  if (!match) throw new Error(`Invalid cell reference: ${ref}`);\n  return { col: columnToIndex(match[1]), row: parseInt(match[2], 10) - 1 };\n}\n\nfunction refToString(col: number, row: number): string {\n  return indexToColumn(col) + (row + 1);\n}\n\nfunction expandRange(start: string, end: string): string[] {\n  const s = parseRef(start);\n  const e = parseRef(end);\n  const minCol = Math.min(s.col, e.col);\n  const maxCol = Math.max(s.col, e.col);\n  const minRow = Math.min(s.row, e.row);\n  const maxRow = Math.max(s.row, e.row);\n  const cells: string[] = [];\n  for (let r = minRow; r <= maxRow; r++) {\n    for (let c = minCol; c <= maxCol; c++) {\n      cells.push(refToString(c, r));\n    }\n  }\n  return cells;\n}\n\n// --- Tokenizer ---\n\ntype TokenType =\n  | 'NUMBER'\n  | 'STRING'\n  | 'BOOLEAN'\n  | 'CELL_REF'\n  | 'RANGE'\n  | 'FUNCTION'\n  | 'OP'\n  | 'COMPARE'\n  | 'LPAREN'\n  | 'RPAREN'\n  | 'COMMA';\n\ninterface Token {\n  type: TokenType;\n  value: string;\n}\n\nfunction tokenize(formula: string): Token[] {\n  const tokens: Token[] = [];\n  let i = 0;\n\n  while (i < formula.length) {\n    // Skip whitespace\n    if (formula[i] === ' ' || formula[i] === '\\t') {\n      i++;\n      continue;\n    }\n\n    // String literal\n    if (formula[i] === '\"') {\n      let str = '';\n      i++; // skip opening quote\n      while (i < formula.length && formula[i] !== '\"') {\n        str += formula[i];\n        i++;\n      }\n      if (i < formula.length) i++; // skip closing quote\n      tokens.push({ type: 'STRING', value: str });\n      continue;\n    }\n\n    // Number\n    if (/\\d/.test(formula[i]) || (formula[i] === '.' && i + 1 < formula.length && /\\d/.test(formula[i + 1]))) {\n      let num = '';\n      while (i < formula.length && (/\\d/.test(formula[i]) || formula[i] === '.')) {\n        num += formula[i];\n        i++;\n      }\n      tokens.push({ type: 'NUMBER', value: num });\n      continue;\n    }\n\n    // Cell reference, range, function, or boolean\n    if (/[A-Za-z]/.test(formula[i])) {\n      let ident = '';\n      while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {\n        ident += formula[i];\n        i++;\n      }\n\n      const upper = ident.toUpperCase();\n\n      // Check for boolean\n      if (upper === 'TRUE' || upper === 'FALSE') {\n        tokens.push({ type: 'BOOLEAN', value: upper });\n        continue;\n      }\n\n      // Check if it's a range (CELL:CELL)\n      if (/^[A-Z]+\\d+$/i.test(ident) && i < formula.length && formula[i] === ':') {\n        i++; // skip colon\n        let end = '';\n        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {\n          end += formula[i];\n          i++;\n        }\n        tokens.push({ type: 'RANGE', value: upper + ':' + end.toUpperCase() });\n        continue;\n      }\n\n      // Check if it's a function call (followed by '(')\n      if (i < formula.length && formula[i] === '(') {\n        tokens.push({ type: 'FUNCTION', value: upper });\n        continue;\n      }\n\n      // Check if it's a cell reference\n      if (/^[A-Z]+\\d+$/.test(upper)) {\n        tokens.push({ type: 'CELL_REF', value: upper });\n        continue;\n      }\n\n      throw new Error(`Unknown identifier: ${ident}`);\n    }\n\n    // Comparison operators\n    if (formula[i] === '<') {\n      if (i + 1 < f