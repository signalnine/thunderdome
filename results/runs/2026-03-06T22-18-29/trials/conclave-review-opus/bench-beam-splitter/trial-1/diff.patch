+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  if (grid.length === 0) return null;
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') return [0, col];
+  }
+  return null;
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const visited = new Set<string>();
+  const seenStates = new Set<string>();
+
+  const beams: Beam[] = [{ row: source[0], col: source[1], dir: 'down' }];
+  visited.add(`${source[0]},${source[1]}`);
+  seenStates.add(`${source[0]},${source[1]},down`);
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const [nr, nc] = advance(beam.row, beam.col, beam.dir);
+
+    if (!inBounds(nr, nc, rows, cols)) continue;
+
+    visited.add(`${nr},${nc}`);
+
+    if (grid[nr][nc] === '^') {
+      const k1 = `${nr},${nc},down-left`;
+      const k2 = `${nr},${nc},down-right`;
+      if (!seenStates.has(k1)) {
+        seenStates.add(k1);
+        beams.push({ row: nr, col: nc, dir: 'down-left' });
+      }
+      if (!seenStates.has(k2)) {
+        seenStates.add(k2);
+        beams.push({ row: nr, col: nc, dir: 'down-right' });
+      }
+    } else {
+      const k = `${nr},${nc},${beam.dir}`;
+      if (!seenStates.has(k)) {
+        seenStates.add(k);
+        beams.push({ row: nr, col: nc, dir: beam.dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+
+  // We use a DP approach: track beams as (row, col, direction) with a count of paths.
+  // At each step, we process all beams at the current state and advance them.
+  // We use a map from (row, col, dir) -> number of paths (as bigint).
+
+  type StateKey = string;
+  function key(row: number, col: number, dir: Direction): StateKey {
+    return `${row},${col},${dir}`;
+  }
+
+  let current = new Map<StateKey, bigint>();
+  current.set(key(source[0], source[1], 'down'), 1n);
+
+  let totalPaths = 0n;
+
+  while (current.size > 0) {
+    const next = new Map<StateKey, bigint>();
+
+    for (const [stateKey, count] of current) {
+      const parts = stateKey.split(',');
+      const row = parseInt(parts[0]);
+      const col = parseInt(parts[1]);
+      const dir = parts[2] as Direction;
+
+      const [nr, nc] = advance(row, col, dir);
+
+      if (!inBounds(nr, nc, rows, cols)) {
+        // Beam exits grid - this is a complete path
+        totalPaths += count;
+        continue;
+      }
+
+      if (grid[nr][nc] === '^') {
+        // Split into two beams
+        const k1 = key(nr, nc, 'down-left');
+        const k2 = key(nr, nc, 'down-right');
+        next.set(k1, (next.get(k1) ?? 0n) + count);
+        next.set(k2, (next.get(k2) ?? 0n) + count);
+      } else {
+        const k = key(nr, nc, dir);
+        next.set(k, (next.get(k) ?? 0n) + count);
+      }
+    }
+
+    current = next;
+  }
+
+  return totalPaths;
+}
