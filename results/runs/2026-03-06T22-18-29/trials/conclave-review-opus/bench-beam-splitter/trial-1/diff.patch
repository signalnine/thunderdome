+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  it('basic example: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('two splitters example', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('no splitters - beam goes straight down', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('single row with source only', () => {
+    const grid = [['S']];
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('beam absorbed at boundary after split', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // S at (0,0), moves down to (1,0) hits splitter
+    // Split: down-left (2,-1) absorbed, down-right (2,1)
+    // Visited: (0,0), (1,0), (2,1)
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('empty grid', () => {
+    expect(countBeamCells([])).toBe(0);
+  });
+
+  it('no source in grid', () => {
+    const grid = [
+      ['.', '.', '.'],
+      ['.', '^', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(0);
+  });
+
+  it('source at edge, beam exits immediately after one step', () => {
+    const grid = [
+      ['S'],
+      ['.'],
+    ];
+    expect(countBeamCells(grid)).toBe(2);
+  });
+
+  it('performance: large grid with many splitters', () => {
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+
+    for (let i = 0; i < 50; i++) {
+      const row = 2 + i * 3;
+      const col = 100 - i + Math.floor(i / 2);
+      if (row < rows && col >= 0 && col < cols) {
+        grid[row][col] = '^';
+      }
+    }
+
+    const start = performance.now();
+    const result = countBeamCells(grid);
+    const elapsed = performance.now() - start;
+
+    expect(result).toBeGreaterThan(0);
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+  it('multiple beams converge on same cell', () => {
+    const grid = [
+      ['.', '.', 'S', '.', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '^', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // S at (0,2), down to (1,2) splitter
+    // Split: DL to (2,1), DR to (2,3)
+    // (2,1) goes DL to (3,0) - no splitter, continues DL to (4,-1) absorbed
+    // (2,3) goes DR to (3,4) - no splitter, continues DR to (4,5) absorbed
+    // Wait, let me recalculate. (3,1) and (3,3) are splitters.
+    // (2,1) dir=down-left -> (3,0) which is '.', continues DL -> (4,-1) absorbed
+    // (2,3) dir=down-right -> (3,4) which is '.', continues DR -> (4,5) absorbed
+    // Hmm, the splitters at (3,1) and (3,3) are never hit.
+    // Visited: (0,2), (1,2), (2,1), (2,3), (3,0), (3,4)
+    expect(countBeamCells(grid)).toBe(6);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('basic example: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('two splitters example', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('no splitters - single path', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('single row with source only', () => {
+    const grid = [['S']];
+    // Beam starts at (0,0), next step goes to (1,0) which is out of bounds
+    // That's 1 path
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('empty grid', () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it('chain of splitters doubles each time', () => {
+    // 3 splitters in a chain along the diagonal
+    const grid = [
+      ['.', '.', '.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '^', '.', '.', '.'],
+      ['.', '.', '^', '.', '^', '.', '.'],
+      ['.', '^', '.', '.', '.', '^', '.'],
+      ['.', '.', '.', '.', '.', '.', '.'],
+    ];
+    // S at (0,3), down to (1,3) splitter -> 2 beams
+    // DL to (2,2) splitter -> 2 beams (4 total from this branch)
+    // DR to (2,4) splitter -> 2 beams (4 total from this branch)
+    // From (2,2) DL: (3,1) splitter -> 2 beams
+    // From (2,2) DR: (3,3) no splitter -> continues
+    // From (2,4) DL: (3,3) no splitter -> continues
+    // From (2,4) DR: (3,5) splitter -> 2 beams
+    // From (3,1) DL: (4,0) exit
+    // From (3,1) DR: (4,2) exit
+    // From (3,3) dir=DR from (2,2): (4,4) exit
+    // From (3,3) dir=DL from (2,4): (4,2) exit
+    // From (3,5) DL: (4,4) exit
+    // From (3,5) DR: (4,6) exit
+    // Total: 6 paths? No wait, let me recount.
+    // After (1,3) split: 2 beams
+    // After (2,2) and (2,4) splits: 4 beams
+    // After (3,1) and (3,5) splits: 4 become 6 (2 split, 2 don't)
+    // Actually: from the 4 beams:
+    //   (2,2) DL -> (3,1) splits -> 2
+    //   (2,2) DR -> (3,3) continues -> 1
+    //   (2,4) DL -> (3,3) continues -> 1
+    //   (2,4) DR -> (3,5) splits -> 2
+    // Total = 2+1+1+2 = 6
+    expect(countBeamPaths(grid)).toBe(6n);
+  });
+
+  it('performance: large grid with many splitters', () => {
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+
+    // Place splitters in a pattern
+    for (let i = 0; i < 50; i++) {
+      const row = 2 + i * 3;
+      const col = 100 - i + Math.floor(i / 2);
+      if (row < rows && col >= 0 && col < cols) {
+        grid[row][col] = '^';
+      }
+    }
+
+    const start = performance.now();
+    const result = countBeamPaths(grid);
+    const elapsed = performance.now() - start;
+
+    expect(result).toBeGreaterThan(0n);
+    expect(elapsed).toBeLessThan(5000);
+  });
+});
