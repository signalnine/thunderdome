+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = a & b;
+            break;
+          case 'OR':
+            result = a | b;
+            break;
+          case 'XOR':
+            result = a ^ b;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(inputGates: Gate[]): string[] {
+  // Strategy: walk the adder bit-by-bit, identify each expected wire,
+  // and when a mismatch is found, correct it (swap outputs back) and record.
+  //
+  // We work on a deep copy to avoid mutating the input.
+  const gates = inputGates.map((g) => ({ ...g }));
+
+  const swapped = new Set<string>();
+
+  // Build lookup structures
+  const gateByOutput = new Map<string, Gate>();
+  for (const g of gates) {
+    gateByOutput.set(g.out, g);
+  }
+
+  // Find the number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^x(\d+)$/);
+      if (m) {
+        maxBit = Math.max(maxBit, parseInt(m[1], 10));
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+
+  // Helper: find gate by op and input wires (order-independent)
+  function findGate(op: string, w1: string, w2: string): Gate | undefined {
+    return gates.find(
+      (g) =>
+        g.op === op &&
+        ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))
+    );
+  }
+
+  // Helper to swap two gate outputs and record the swap
+  function doSwap(w1: string, w2: string): void {
+    swapped.add(w1);
+    swapped.add(w2);
+    const g1 = gateByOutput.get(w1)!;
+    const g2 = gateByOutput.get(w2)!;
+    g1.out = w2;
+    g2.out = w1;
+    gateByOutput.set(w1, g2);
+    gateByOutput.set(w2, g1);
+  }
+
+  // Process bit by bit and check structural invariants
+  let carry = '';
+
+  for (let i = 0; i < numBits; i++) {
+    const xi = `x${String(i).padStart(2, '0')}`;
+    const yi = `y${String(i).padStart(2, '0')}`;
+    const zi = `z${String(i).padStart(2, '0')}`;
+
+    if (i === 0) {
+      // Bit 0: XOR(x00, y00) -> z00, AND(x00, y00) -> c00
+      const xorGate = findGate('XOR', xi, yi);
+      if (xorGate) {
+        if (xorGate.out !== zi) {
+          doSwap(xorGate.out, zi);
+        }
+      }
+      const andGate = findGate('AND', xi, yi);
+      if (andGate) {
+        carry = andGate.out;
+      }
+    } else {
+      // Bit i > 0:
+      // Step 1: find XOR(xi, yi) -> t_i (partial sum)
+      const xorXY = findGate('XOR', xi, yi);
+      if (!xorXY) continue;
+      let ti = xorXY.out;
+
+      // Check: ti should NOT be a z-wire (except in specific swap cases).
+      // If XOR(xi, yi) outputs zi, that means zi was swapped with the actual ti.
+      // The actual sum gate XOR(actual_ti, carry) now outputs actual_ti.
+      if (ti === zi) {
+        // XOR(xi,yi) -> zi is wrong. The zi wire should come from
+        // XOR(partial_sum, carry). Find the XOR gate that uses carry as input
+        // and is not xorXY.
+        const sumCandidates = gates.filter(
+          (g) =>
+            g.op === 'XOR' &&
+            (g.in1 === carry || g.in2 === carry) &&
+            g !== xorXY
+        );
+        if (sumCandidates.length === 1) {
+          // The other input to this XOR should be ti, but because of the swap,
+          // its output is the real ti name
+          const realTi = sumCandidates[0].out;
+          doSwap(ti, realTi);
+          ti = realTi;
+        }
+      }
+
+      // Step 2: find XOR(t_i, carry) -> z_i
+      let xorTC = findGate('XOR', ti, carry);
+
+      if (!xorTC) {
+        // ti or carry may have been swapped with something.
+        // Strategy: look for an XOR gate that uses carry as one input.
+        const carryXors = gates.filter(
+          (g) =>
+            g.op === 'XOR' &&
+            (g.in1 === carry || g.in2 === carry) &&
+            g !== xorXY
+        );
+        if (carryXors.length === 1) {
+          const cand = carryXors[0];
+          const otherInput = cand.in1 === carry ? cand.in2 : cand.in1;
+          // ti was swapped with otherInput
+          doSwap(ti, otherInput);
+          ti = otherInput;
+          xorTC = cand;
+        } else {
+          // Try: look for an XOR gate that uses ti as one input (not xorXY)
+          const tiXors = gates.filter(
+            (g) =>
+              g.op === 'XOR' &&
+              (g.in1 === ti || g.in2 === ti) &&
+              g !== xorXY
+          );
+          if (tiXors.length === 1) {
+            const cand = tiXors[0];
+            const otherInput = cand.in1 === ti ? cand.in2 : cand.in1;
+            // carry was swapped with otherInput
+            doSwap(carry, otherInput);
+            carry = otherInput;
+            xorTC = cand;
+          }
+        }
+      }
+
+      if (!xorTC) continue;
+
+      // Check that XOR(ti, carry) outputs zi
+      if (xorTC.out !== zi) {
+        doSwap(xorTC.out, zi);
+      }
+
+      // Step 3: AND(xi, yi) -> a_i (generate)
+      const andXY = findGate('AND', xi, yi);
+      if (!andXY) continue;
+      const ai = andXY.out;
+
+      // Step 4: AND(ti, carry) -> b_i (propagate carry)
+      const andTC = findGate('AND', ti, carry);
+      if (!andTC) continue;
+      const bi = andTC.out;
+
+      // Step 5: OR(ai, bi) -> c_i
+      let orGate = findGate('OR', ai, bi);
+      if (!orGate) {
+        // Maybe ai or bi is swapped; try to find an OR involving one of them
+        const orWithAi = gates.find(
+          (g) => g.op === 'OR' && (g.in1 === ai || g.in2 === ai)
+        );
+        if (orWithAi) {
+          const otherInput =
+            orWithAi.in1 === ai ? orWithAi.in2 : orWithAi.in1;
+          doSwap(bi, otherInput);
+          orGate = orWithAi;
+        } else {
+          const orWithBi = gates.find(
+            (g) => g.op === 'OR' && (g.in1 === bi || g.in2 === bi)
+          );
+          if (orWithBi) {
+            const otherInput =
+              orWithBi.in1 === bi ? orWithBi.in2 : orWithBi.in1;
+            doSwap(ai, otherInput);
+            orGate = orWithBi;
+          }
+        }
+      }
+
+      if (orGate) {
+        carry = orGate.out;
+        // The last carry should be z{numBits} if this is the last bit
+        if (i === numBits - 1) {
+          const zLast = `z${String(numBits).padStart(2, '0')}`;
+          if (carry !== zLast) {
+            doSwap(carry, zLast);
+            carry = zLast;
+          }
+        }
+      }
+    }
+  }
+
+  return Array.from(swapped).sort();
+}
