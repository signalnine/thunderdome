// Note: in buildCorrectAdder, the last carry is z04 (not c03)\n   181→    // Available wires: z00, c00, t01, z01, a01, b01, c01,\n   182→    //   t02, z02, a02, b02, c02, t03, z03, a03, b03, z04\n   183→\n   184→    // Swap 1: z01 and a01\n   185→    swapOutputs(gates, 'z01', 'a01');\n   186→    // Swap 2: z03 and b02\n   187→    swapOutputs(gates, 'z03', 'b02');\n   188→    // Swap 3: t02 and c01\n   189→    swapOutputs(gates, 't02', 'c01');\n   190→    // Swap 4: z04 and b03\n   191→    swapOutputs(gates, 'z04', 'b03');\n   192→\n   193→    const result = findSwappedWires(gates);\n   194→    expect(result).toEqual(\n   195→      ['a01', 'b02', 'b03', 'c01', 't02', 'z01', 'z03', 'z04'].sort()\n   196→    );\n   197→  });\n   198→\n   199→  it('finds swapped wires where z-output is swapped with internal wire', () => {\n   200→    const gates = buildCorrectAdder(8);\n   201→    expect(verifyAdder(gates, 8)).toBe(true);\n   202→\n   203→    // Note: last carry is z08, not c07. Available: c00..c06, z08\n   204→    // Create 4 swaps\n   205→    swapOutputs(gates, 'z02', 't03');\n   206→    swapOutputs(gates, 'z05', 'a05');\n   207→    swapOutputs(gates, 'z07', 'b06');\n   208→    swapOutputs(gates, 'z08', 'c06');\n   209→\n   210→    const result = findSwappedWires(gates);\n   211→    expect(result).toEqual(\n   212→      ['a05', 'b06', 'c06', 't03', 'z02', 'z05', 'z07', 'z08'].sort()\n   213→    );\n   214→  });\n   215→\n   216→  it('returns a sorted array of 8 wire names', () => {\n   217→    const gates = buildCorrectAdder(8);\n   218→    swapOutputs(gates, 'z01', 'a01');\n   219→    swapOutputs(gates, 'z03', 'b03');\n   220→    swapOutputs(gates, 'z05', 'c04');\n   221→    swapOutputs(gates, 'z07', 'a07');\n   222→\n   223→    const result = findSwappedWires(gates);\n   224→    expect(result.length).toBe(8);\n   225→    // Verify sorted\n   226→    for (let i = 1; i < result.length; i++) {\n   227→      expect(result[i] >= result[i - 1]).toBe(true);\n   228→    }\