+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PkK8QuW8VNG66KwPL9wC7u","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { simulate, findSwappedWires, Gate } from './index.js';\n     3→\n     4→describe('simulate', () => {\n     5→  it('evaluates a simple AND gate', () => {\n     6→    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n     7→    const result = simulate(gates, { a: 1, b: 1 });\n     8→    expect(result.c).toBe(1);\n     9→  });\n    10→\n    11→  it('evaluates a simple AND gate with 0', () => {\n    12→    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    13→    const result = simulate(gates, { a: 1, b: 0 });\n    14→    expect(result.c).toBe(0);\n    15→  });\n    16→\n    17→  it('evaluates a simple OR gate', () => {\n    18→    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    19→    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);\n    20→    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n    21→  });\n    22→\n    23→  it('evaluates a simple XOR gate', () => {\n    24→    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    25→    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);\n    26→    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);\n    27→  });\n    28→\n    29→  it('evaluates chained gates in dependency order', () => {\n    30→    const gates: Gate[] = [\n    31→      { op: 'AND', in1: 'a', in2: 'b', out: 'ab' },\n    32→      { op: 'OR', in1: 'ab', in2: 'c', out: 'result' },\n    33→    ];\n    34→    const result = simulate(gates, { a: 1, b: 1, c: 0 });\n    35→    expect(result.ab).toBe(1);\n    36→    expect(result.result).toBe(1);\n    37→  });\n    38→\n    39→  it('handles gates listed before their dependencies', () => {\n    40→    const gates: Gate[] = [\n    41→      { op: 'OR', in1: 'ab', in2: 'c', out: 'result' },\n    42→      { op: 'AND', in1: 'a', in2: 'b', out: 'ab' },\n    43→    ];\n    44→    const result = simulate(gates, { a: 1, b: 0, c: 0 });\n    45→    expect(result.ab).toBe(0);\n    46→    expect(result.result).toBe(0);\n    47→  });\n    48→\n    49→  it('simulates a correct 2-bit adder: 3 + 3 = 6', () => {\n    50→    // 2-bit adder: x=11 (3), y=11 (3), z=110 (6)\n    51→    const gates: Gate[] = [\n    52→      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n    53→      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    54→      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n    55→      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n    56→      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n    57→      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n    58→      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    59→    ];\n    60→    const inputs: Record<string, number> = {\n    61→      x00: 1, x01: 1,\n    62→      y00: 1, y01: 1,\n    63→    };\n    64→    const result = simulate(gates, inputs);\n    65→    // 3 + 3 = 6 = 110\n    66→    expect(result.z00).toBe(0);\n    67→    expect(result.z01).toBe(1);\n    68→    expect(result.z02).toBe(1);\n    69→  });\n    70→\n    71→  it('simulates a correct 2-bit adder: 2 + 1 = 3', () => {\n    72→    const gates: Gate[] = [\n    73→      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n    74→      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    75→      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n    76→      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n    77→      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n    78→      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n    79→      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    80→    ];\n    81→    const inputs: Record<string, number> = {\n    82→      x00: 0, x01: 1,  // x = 2\n    83→      y00: 1, y01: 0,  // y = 1\n    84→    };\n    85→    const result = simulate(gates, inputs);\n    86→    // 2 + 1 = 3 = 011\n    87→    expect(result.z00).toBe(1);\n    88→    expect(result.z01).toBe(1);\n    89→    expect(result.z02).toBe(0);\n    90→  });\n    91→\n    92→  it('returns all wire values including inputs', () => {\n    93→    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    94→    const result = simulate(gates, { a: 1, b: 0 });\n    95→    expect(result.a).toBe(1);\n    96→    expect(result.b).toBe(0);\n    97→    expect(result.c).toBe(0);\n    98→  });\n    99→});\n   100→\n   101→describe('findSwappedWires', () => {\n   102→  // Helper: build a correct N-bit adder\n   103→  function buildCorrectAdder(numBits: number): Gate[] {\n   104→    const gates: Gate[] = [];\n   105→    // Bit 0\n   106→    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n   107→    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n   108→\n   109→    for (let i = 1; i < numBits; i++) {\n   110→      const ii = String(i).padStart(2, '0');\n   111→      const pi = String(i - 1).padStart(2, '0');\n   112→      const xi = `x${ii}`;\n   113→      const yi = `y${ii}`;\n   114→      const ti = `t${ii}`;\n   115→      const ai = `a${ii}`;\n   116→      const bi = `b${ii}`;\n   117→      const ci = `c${ii}`;\n   118→      const zi = `z${ii}`;\n   119→      const cPrev = `c${pi}`;\n   120→\n   121→      gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n   122→      gates.push({ op: 'XOR', in1: ti, in2: cPrev, out: zi });\n   123→      gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n   124→      gates.push({ op: 'AND', in1: ti, in2: cPrev, out: bi });\n   125→      gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n   126→    }\n   127→\n   128→    // Final carry -> z_numBits\n   129→    const lastCarry = `c${String(numBits - 1).padStart(2, '0')}`;\n   130→    const zFinal = `z${String(numBits).padStart(2, '0')}`;\n   131→    // We represent this as an OR gate with carry OR'd with a 0 input\n   132→    // Actually, let's just use an identity-like gate. In real circuits the final carry\n   133→    // directly becomes the output. Let's use XOR with a dummy zero wire.\n   134→    // Better: replace the last carry gate to output directly to zFinal\n   135→    // Find the last OR gate and change its output\n   136→    const lastGate = gates[gates.length - 1];\n   137→    if (lastGate.op === 'OR') {\n   138→      lastGate.out = zFinal;\n   139→    }\n   140→\n   141→    return gates;\n   142→  }\n   143→\n   144→  // Helper: swap two gate outputs\n   145→  function swapOutputs(gates: Gate[], w1: string, w2: string): void {\n   146→    const g1 = gates.find((g) => g.out === w1)!;\n   147→    const g2 = gates.find((g) => g.out === w2)!;\n   148→    g1.out = w2;\n   149→    g2.out = w1;\n   150→  }\n   151→\n   152→  // Helper: verify adder works with simulation\n   153→  function verifyAdder(gates: Gate[], numBits: number): boolean {\n   154→    for (let trial = 0; trial < 10; trial++) {\n   155→      const x = Math.floor(Math.random() * (1 << numBits));\n   156→      const y = Math.floor(Math.random() * (1 << numBits));\n   157→      const expected = x + y;\n   158→      const inputs: Record<string, number> = {};\n   159→      for (let i = 0; i < numBits; i++) {\n   160→        const ii = String(i).padStart(2, '0');\n   161→        inputs[`x${ii}`] = (x >> i) & 1;\n   162→        inputs[`y${ii}`] = (y >> i) & 1;\n   163→      }\n   164→      const result = simulate(gates, inputs);\n   165→      let z = 0;\n   166→      for (let i = 0; i <= numBits; i++) {\n   167→        const ii = String(i).padStart(2, '0');\n   168→        z += (result[`z${ii}`] ?? 0) << i;\n   169→      }\n   170→      if (z !== expected) return false;\n   171→    }\n   172→    return true;\n   173→  }\n   174→\n   175→  it('finds swapped wires in a small 4-bit adder', () => {\n   176→    const gates = buildCorrectAdder(4);\n   177→    // Verify correct adder works\n   178→    expect(verifyAdder(gates, 4)).toBe(true);\n   179→\n   180→    // Note: in buildCorrectAdder, the last carry is z04 (not c03)\n   181→    // Available wires: z00, c00, t01, z01, a01, b01, c01,\n   182→    //   t02, z02, a02, b02, c02, t03, z03, a03, b03, z04\n   183→\n   184→    // Swap 1: z01 and a01\n   185→    swapOutputs(gates, 'z01', 'a01');\n   186→    // Swap 2: z03 and b02\n   187→    swapOutputs(gates, 'z03', 'b02');\n   188→    // Swap 3: t02 and c01\n   189→    swapOutputs(gates, 't02', 'c01');\n   190→    // Swap 4: z04 and b03\n   191→    swapOutputs(gates, 'z04', 'b03');\n   192→\n   193→    const result = findSwappedWires(gates);\n   194→    expect(result).toEqual(\n   195→      ['a01', 'b02', 'b03', 'c01', 't02', 'z01', 'z03', 'z04'].sort()\n   196→    );\n   197→  });\n   198→\n   199→  it('finds swapped wires where z-output is swapped with internal wire', () => {\n   200→    const gates = buildCorrectAdder(8);\n   201→    expect(verifyAdder(gates, 8)).toBe(true);\n   202→\n   203→    // Note: last carry is z08, not c07. Available: c00..c06, z08\n   204→    // Create 4 swaps\n   205→    swapOutputs(gates, 'z02', 't03');\n   206→    swapOutputs(gates, 'z05', 'a05');\n   207→    swapOutputs(gates, 'z07', 'b06');\n   208→    swapOutputs(gates, 'z08', 'c06');\n   209→\n   210→    const result = findSwappedWires(gates);\n   211→    expect(result).toEqual(\n   212→      ['a05', 'b06', 'c06', 't03', 'z02', 'z05', 'z07', 'z08'].sort()\n   213→    );\n   214→  });\n   215→\n   216→  it('returns a sorted array of 8 wire names', () => {\n   217→    const gates = buildCorrectAdder(8);\n   218→    swapOutputs(gates, 'z01', 'a01');\n   219→    swapOutputs(gates, 'z03', 'b03');\n   220→    swapOutputs(gates, 'z05', 'c04');\n   221→    swapOutputs(gates, 'z07', 'a07');\n   222→\n   223→    const result = findSwappedWires(gates);\n   224→    expect(result.length).toBe(8);\n   225→    // Verify sorted\n   226→    for (let i = 1; i < result.length; i++) {\n   227→      expect(result[i] >= result[i - 1]).toBe(true);\n   228→    }\n   229→  });\n   230→\n   231→  it('handles swaps that affect carry chain', () => {\n   232→    const gates = buildCorrectAdder(6);\n   233→    expect(verifyAdder(gates, 6)).toBe(true);\n   234→\n   235→    // Note: last carry is z06, not c05. Available: c00..c04, z06\n   236→    // Swap carry wires\n   237→    swapOutputs(gates, 'c01', 'a02');\n   238→    swapOutputs(gates, 'c03', 'b04');\n   239→    swapOutputs(gates, 'z02', 't02');\n   240→    swapOutputs(gates, 'z06', 'c04');\n   241→\n   242→    const result = findSwappedWires(gates);\n   243→    expect(result).toEqual(\n   244→      ['a02', 'b04', 'c01', 'c03', 'c04', 't02', 'z02', 'z06'].sort()\n   245→    );\n   246→  });\n   247→\n   248→  it('works with larger circuits (20-bit)', () => {\n   249→    const gates = buildCorrectAdder(20);\n   250→    expect(verifyAdder(gates, 20)).toBe(true);\n   251→\n   252→    // Note: last carry is z20, not c19. Available: c00..c18, z20\n   253→    swapOutputs(gates, 'z05', 't10');\n   254→    swapOutputs(gates, 'z10', 'a15');\n   255→    swapOutputs(gates, 'z15', 'c18');\n   256→    swapOutputs(gates, 'z20', 'b03');\n   257→\n   258→    const result = findSwappedWires(gates);\n   259→    expect(result).toEqual(\n   260→      ['a15', 'b03', 'c18', 't10', 'z05', 'z10', 'z15', 'z20'].sort()\n   261→    );\n   262→  });\n   263→});\n   264→"}]},"parent_tool_use_id":"toolu_01AoFiuX3Y9Kk3YJn9gtCjpu","session_id":"3f5d13e5-35da-470e-9db0-5db08f41ada9","uuid":"e6b6ca71-fce7-4f7a-8286-a70e9926f263"}
