03', 'b04');","-    swapOutputs(gates, 'z02', 't02');","+    // Swap carry with non-adjacent wire, z-outputs with internal wires","+    swapOutputs(gates, 'c01', 'z03');","+    swapOutputs(gates, 'c03', 'z05');","+    swapOutputs(gates, 'z02', 'a02');","     swapOutputs(gates, 'z06', 'c04');"," ","     const result = findSwappedWires(gates);","     expect(result).toEqual(","-      ['a02', 'b04', 'c01', 'c03', 'c04', 't02', 'z02', 'z06'].sort()","+      ['a02', 'c01', 'c03', 'c04', 'z02', 'z03', 'z05', 'z06'].sort()","     );","   });"," "]},{"oldStart":249,"oldLines":7,"newStart":232,"newLines":6,"lines":["     const gates = buildCorrectAdder(20);","     expect(verifyAdder(gates, 20)).toBe(true);"," ","-    // Note: last carry is z20, not c19. Available: c00..c18, z20","     swapOutputs(gates, 'z05', 't10');","     swapOutputs(gates, 'z10', 'a15');","     swapOutputs(gates, 'z15', 'c18');"]}],"originalFile":"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from './index.js';\n\ndescribe('simulate', () => {\n  it('evaluates a simple AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 1 });\n    expect(result.c).toBe(1);\n  });\n\n  it('evaluates a simple AND gate with 0', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result.c).toBe(0);\n  });\n\n  it('evaluates a simple OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);\n    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n  });\n\n  it('evaluates a simple XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);\n    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);\n  });\n\n  it('evaluates chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'ab' },\n      { op: 'OR', in1: 'ab', in2: 'c', out: 'result' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, c: 0 });\n    expect(result.ab).toBe(1);\n    expect(result.result).toBe(1);\n  });\n\n  it('handles gates listed before their dependencies', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'ab', in2: 'c', out: 'result' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'ab' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0, c: 0 });\n    expect(result.ab).toBe(0);\n    expect(result.result).toBe(0);\n  });\n\n  it('simulates a correct 2-bit adder: 3 + 3 = 6', () => {\n    // 2-bit adder: x=11 (3), y=11 (3), z=110 (6)\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1,\n      y00: 1, y01: 1,\n    };\n    const result = simulate(gates, inputs);\n    // 3 + 3 = 6 = 110\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n  });\n\n  it('simulates a correct 2-bit adder: 2 + 1 = 3', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 0, x01: 1,  // x = 2\n      y00: 1, y01: 0,  // y = 1\n    };\n    const result = simulate(gates, inputs);\n    // 2 + 1 = 3 = 011\n    expect(result.z00).toBe(1);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(0);\n  });\n\n  it('returns all wire values including inputs', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result.a).toBe(1);\n    expect(result.b).toBe(0);\n    expect(result.c).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  // Helper: build a correct N-bit adder\n  function buildCorrectAdder(numBits: number): Gate[] {\n    const gates: Gate[] = [];\n    // Bit 0\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n    for (let i = 1; i < numBits; i++) {\n      const ii = String(i).padStart(2, '0');\n      const pi = String(i - 1).padStart(2, '0');\n      const xi = `x${ii}`;\n      const yi = `y${ii}`;\n      const ti = `t${ii}`;\n      const ai = `a${ii}`;\n      const bi = `b${ii}`;\n      const ci = `c${ii}`;\n      const zi = `z${ii}`;\n      const cPrev = `c${pi}`;\n\n      gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });\n      gates.push({ op: 'XOR', in1: ti, in2: cPrev, out: zi });\n      gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });\n      gates.push({ op: 'AND', in1: ti, in2: cPrev, out: bi });\n      gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });\n    }\n\n    // Final carry -> z_numBits\n    const lastCarry = `c${String(numBits - 1).padStart(2, '0')}`;\n    const zFinal = `z${String(numBits).padStart(2, '0')}`;\n    // We represent this as an OR gate with carry OR'd with a 0 input\n    // Actually, let's just use an identity-like gate. In real circuits the final carry\n    // directly becomes the output. Let's use XOR with a dummy zero wire.\n    // Better: replace the last carry gate to output directly to zFinal\n    // Find the last OR gate and change its output\n    const lastGate = gates[gates.length - 1];\n    if (lastGate.op === 'OR') {\n      lastGate.out = zFinal;\n    }\n\n    return gates;\n  }\n\n  // Helper: swap two gate outputs\n  function swapOutputs(gates: Gate[], w1: string, w2: string): void {\n    const g1 = gates.find((g) => g.out === w1)!;\n    const g2 = gates.find((g) => g.out === w2)!;\n    g1.out = w2;\n    g2.out = w1;\n  }\n\n  // Helper: verify adder works with simulation\n  function verifyAdder(gates: Gate[], numBits: number): boolean {\n    for (let trial = 0; trial < 10; trial++) {\n      const x = Math.floor(Math.random() * (1 << numBits));\n      const y = Math.floor(Math.random() * (1 << numBits));\n      const expected = x + y;\n      const inputs: Record<string, number> = {};\n      for (let i = 0; i < numBits; i++) {\n        const ii = String(i).padStart(2, '0');\n        inputs[`x${ii}`] = (x >> i) & 1;\n        inputs[`y${ii}`] = (y >> i) & 1;\n      }\n      const result = simulate(gates, inputs);\n      let z = 0;\n      for (let i = 0; i <= numBits; i++) {\n        const ii = String(i).padStart(2, '0');\n        z += (result[`z${ii}`] ?? 0) << i;\n      }\n      if (z !== expected) return false;\n    }\n    return true;\n  }\n\n  it('finds swapped wires in a small 4-bit adder', () => {\n    const gates = buildCorrectAdder(4);\n    // Verify correct adder works\n    expect(verifyAdder(gates, 4)).toBe(true);\n\n    // Note: in buildCorrectAdder, the last carry is z04 (not c03)\n    // Available wires: z00, c00, t01, z01, a01, b01, c01,\n    //   t02, z02, a02, b02, c02, t03, z03, a03, b03, z04\n\n    // Swap 1: z01 and a01\n    swapOutputs(gates, 'z01', 'a01');\n    // Swap 2: z03 and b02\n    swapOutputs(gates, 'z03', 'b02');\n    // Swap 3: t02 and c01\n    swapOutputs(gates, 't02', 'c01');\n    // Swap 4: z04 and b03\n    swapOutputs(gates, 'z04', 'b03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'b02', 'b03', 'c01', 't02', 'z01', 'z03', 'z04'].sort()\n    );\n  });\n\n  it('finds swapped wires where z-output is swapped with internal wire', () => {\n    const gates = buildCorrectAdder(8);\n    expect(verifyAdder(gates, 8)).toBe(true);\n\n    // Note: last carry is z08, not c07. Available: c00..c06, z08\n    // Create 4 swaps\n    swapOutputs(gates, 'z02', 't03');\n    swapOutputs(gates, 'z05', 'a05');\n    swapOutputs(gates, 'z07', 'b06');\n    swapOutputs(gates, 'z08', 'c06');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a05', 'b06', 'c06', 't03', 'z02', 'z05', 'z07', 'z08'].sort()\n    );\n  });\n\n  it('returns a sorted array of 8 wire names', () => {\n    const gates = buildCorrectAdder(8);\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 'b03');\n    swapOutputs(gates, 'z05', 'c04');\n    swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result.length).toBe(8);\n    // Verify sorted\n    for (let i = 1; i < result.length; i++) {\n      expect(result[i] >= result[i - 1]).toBe(true);\n    }\n  });\n\n  it('handles swaps that affect carry chain', () => {\n    const gates = buildCorrectAdder(6);\n    expect(verifyAdder(gates, 6)).toBe(true);\n\n    // Note: last carry is z06, not c05. Available: c00..c04, z06\n    // Swap carry wires\n    swapOutputs(gates, 'c01', 'a02');\n    swapOutputs(gates, 'c03', 'b04');\n    swapOutputs(gates, 'z02', 't02');\n    swapOutputs(gates, 'z06', 'c04');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a02', 'b04', 'c01', 'c03', 'c04', 't02', 'z02', 'z06'].sort()\n    );\n  });\n\n  it('works with larger circuits (20-bit)', () => {\n    const gates = buildCorrectAdder(20);\n    expect(verifyAdder(gates, 20)).toBe(true);\n\n    // Note: last carry is z20, not c19. Available: c00..c18, z20\n    swapOutputs(gates, 'z05