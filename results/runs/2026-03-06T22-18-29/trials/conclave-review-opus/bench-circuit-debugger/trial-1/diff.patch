_i\n      let xorTC = findGate('XOR', ti, carry);\n\n      if (!xorTC) {\n        // Maybe ti or carry is swapped. Let's check if there's an XOR that\n        // outputs zi - if so, one of its inputs should be carry or ti.\n        const zGate = gateByOutput.get(zi);\n        if (zGate && zGate.op === 'XOR') {\n          // One of zGate's inputs should be carry, the other should be ti\n          // If carry is one input, the other should be ti but isn't\n          if (zGate.in1 === carry || zGate.in2 === carry) {\n            const otherInput =\n              zGate.in1 === carry ? zGate.in2 : zGate.in1;\n            // ti should be otherInput, so swap ti and otherInput\n            doSwap(ti, otherInput);\n            ti = otherInput;\n            xorTC = zGate;\n          } else if (zGate.in1 === ti || zGate.in2 === ti) {\n            const otherInput =\n              zGate.in1 === ti ? zGate.in2 : zGate.in1;\n            // carry should be otherInput, so swap carry and otherInput\n            doSwap(carry, otherInput);\n            carry = otherInput;\n            xorTC = zGate;\n          }\n        } else {\n          // No XOR gate has both ti and carry as inputs.\n          // Try: maybe ti got swapped with something.\n          // Look for any XOR gate that uses carry as input and isn't xorXY.\n          const candidates = gates.filter(\n            (g) =>\n              g.op === 'XOR' &&\n              (g.in1 === carry || g.in2 === carry) &&\n              g !== xorXY\n          );\n          if (candidates.length === 1) {\n            const cand = candidates[0];\n            const otherInput =\n              cand.in1 === carry ? cand.in2 : cand.in1;\n            doSwap(ti, otherInput);\n            ti = otherInput;\n            xorTC = cand;\n          }\n        }\n      }\n\n      if (!xorTC) continue;\n\n      // Check that XOR(ti, carry) outputs zi\n      if (xorTC.out !== zi) {\n        doSwap(xorTC.out, zi);\n      }\n\n      // Step 3: AND(xi, yi) ->