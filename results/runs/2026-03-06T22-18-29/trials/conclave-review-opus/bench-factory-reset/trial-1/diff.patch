n            }\n            const pivotVal = pivotTarget[r] !== parity;\n            if (pivotVal) {\n              pivotCount++;\n              result.push(pivotCol[r]);\n            }\n          }\n\n          const total = w + pivotCount;\n          if (total < bestCount) {\n            result.sort((a, b) => a - b);\n            bestCount = total;\n            bestResult = result;\n          } else if (total === bestCount) {\n            result.sort((a, b) => a - b);\n            if (lexSmaller(result, bestResult!)) {\n              bestResult = result;\n            }\n          }\n          return;\n        }\n\n        for (let i = start; i < numFree; i++) {\n          indices[pos] = i;\n          enumerate(pos + 1, i + 1, mask | (1 << i));\n        }\n      };\n\n      enumerate(0, 0, 0);\n    }\n  }\n\n  return bestResult ?? [];\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  // Compare two sorted arrays lexicographically\n  // But we're comparing SETS of button indices.\n  // The \"lexicographically smallest set\" means: compare as sorted arrays.\n  // First compare lengths (fewer is better - but that's handled by count).\n  // For same length, compare element by element.\n  if (a.length !== b.length) return a.length < b.length;\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) return a[i] < b[i];\n  }\n  return false;\n}\n\n/**\n * Solve a counter puzzle over GF(p) using Gaussian elimination.\n * Find the minimum total presses solution, breaking ties lexicographically.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const n = lights.length; // number of counters\n  const m = buttons.length; // number of buttons\n\n  // Build augmented matrix over GF(modulus).\n  // Each row represents a counter equation.\n  // matrix[i][j] = how many times button j affects counter i (0 or 1)\n  // matrix[i][m] = target value for counter i\n\n  const matrix: number[][