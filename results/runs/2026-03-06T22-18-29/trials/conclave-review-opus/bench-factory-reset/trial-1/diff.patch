+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve a toggle puzzle over GF(2) using Gaussian elimination.
+ * Find the minimum set of buttons, breaking ties lexicographically.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  // Build augmented matrix over GF(2) using BigInt bitmasks.
+  // Bit j (0..m-1) = coefficient of button j; bit m = target value.
+  const rows: bigint[] = [];
+  for (let i = 0; i < n; i++) {
+    let row = 0n;
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row |= 1n << BigInt(j);
+      }
+    }
+    if (target[i]) {
+      row |= 1n << BigInt(m);
+    }
+    rows.push(row);
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotCol: number[] = new Array(n).fill(-1);
+  const pivotRowForCol: number[] = new Array(m).fill(-1);
+  let rank = 0;
+
+  for (let col = 0; col < m; col++) {
+    let found = -1;
+    for (let row = rank; row < n; row++) {
+      if ((rows[row] >> BigInt(col)) & 1n) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [rows[rank], rows[found]] = [rows[found], rows[rank]];
+    pivotCol[rank] = col;
+    pivotRowForCol[col] = rank;
+
+    for (let row = 0; row < n; row++) {
+      if (row !== rank && (rows[row] >> BigInt(col)) & 1n) {
+        rows[row] ^= rows[rank];
+      }
+    }
+    rank++;
+  }
+
+  // Check consistency
+  for (let row = rank; row < n; row++) {
+    if ((rows[row] >> BigInt(m)) & 1n) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < m; col++) {
+    if (pivotRowForCol[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  if (freeVars.length === 0) {
+    const result: number[] = [];
+    for (let r = 0; r < rank; r++) {
+      if ((rows[r] >> BigInt(m)) & 1n) {
+        result.push(pivotCol[r]);
+      }
+    }
+    result.sort((a, b) => a - b);
+    return result;
+  }
+
+  const numFree = freeVars.length;
+
+  // Precompute for each pivot row: which free vars affect it, and its target bit
+  const pivotFreeDepMask: bigint[] = new Array(rank).fill(0n);
+  const pivotTarget: boolean[] = new Array(rank).fill(false);
+  for (let r = 0; r < rank; r++) {
+    pivotTarget[r] = !!((rows[r] >> BigInt(m)) & 1n);
+    for (let k = 0; k < numFree; k++) {
+      if ((rows[r] >> BigInt(freeVars[k])) & 1n) {
+        pivotFreeDepMask[r] |= 1n << BigInt(k);
+      }
+    }
+  }
+
+  let bestResult: number[] | null = null;
+  let bestCount = m + 1;
+
+  const computeAndUpdate = (bigMask: bigint, freeCount: number): void => {
+    let pivotCount = 0;
+    const result: number[] = [];
+
+    for (let k = 0; k < numFree; k++) {
+      if ((bigMask >> BigInt(k)) & 1n) {
+        result.push(freeVars[k]);
+      }
+    }
+
+    for (let r = 0; r < rank; r++) {
+      let overlap = pivotFreeDepMask[r] & bigMask;
+      let parity = false;
+      while (overlap) {
+        parity = !parity;
+        overlap &= overlap - 1n;
+      }
+      if (pivotTarget[r] !== parity) {
+        pivotCount++;
+        result.push(pivotCol[r]);
+      }
+    }
+
+    const total = freeCount + pivotCount;
+    if (total < bestCount) {
+      result.sort((a, b) => a - b);
+      bestCount = total;
+      bestResult = result;
+    } else if (total === bestCount) {
+      result.sort((a, b) => a - b);
+      if (lexSmaller(result, bestResult!)) {
+        bestResult = result;
+      }
+    }
+  };
+
+  if (numFree <= 25) {
+    const totalCombinations = 1 << numFree;
+    for (let mask = 0; mask < totalCombinations; mask++) {
+      const freeCount = popcount32(mask);
+      if (freeCount >= bestCount) continue;
+      computeAndUpdate(BigInt(mask), freeCount);
+    }
+  } else {
+    // Enumerate by increasing Hamming weight with early termination
+    for (let w = 0; w <= numFree && w < bestCount; w++) {
+      const enumByWeight = (pos: number, start: number, mask: bigint): void => {
+        if (pos === w) {
+          computeAndUpdate(mask, w);
+          return;
+        }
+        for (let i = start; i < numFree; i++) {
+          enumByWeight(pos + 1, i + 1, mask | (1n << BigInt(i)));
+        }
+      };
+      enumByWeight(0, 0, 0n);
+    }
+  }
+
+  return bestResult ?? [];
+}
+
+function popcount32(x: number): number {
+  x = x - ((x >> 1) & 0x55555555);
+  x = (x & 0x33333333) + ((x >> 2) & 0x33333333);
+  return (((x + (x >> 4)) & 0x0f0f0f0f) * 0x01010101) >> 24;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  if (a.length !== b.length) return a.length < b.length;
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] < b[i];
+  }
+  return false;
+}
+
+/**
+ * Solve a counter puzzle over GF(p) using Gaussian elimination.
+ * Find the minimum total presses solution, breaking ties lexicographically.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+
+  // Build augmented matrix over GF(modulus)
+  const matrix: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[m] = lights[i] % modulus;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(modulus)
+  const pivotCol: number[] = new Array(n).fill(-1);
+  const pivotRowForCol: number[] = new Array(m).fill(-1);
+  let rank = 0;
+
+  for (let col = 0; col < m; col++) {
+    let found = -1;
+    for (let row = rank; row < n; row++) {
+      if (matrix[row][col] !== 0) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];
+    pivotCol[rank] = col;
+    pivotRowForCol[col] = rank;
+
+    const inv = modInverse(matrix[rank][col], modulus);
+    for (let j = 0; j <= m; j++) {
+      matrix[rank][j] = (matrix[rank][j] * inv) % modulus;
+    }
+
+    for (let row = 0; row < n; row++) {
+      if (row !== rank && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let j = 0; j <= m; j++) {
+          matrix[row][j] = ((matrix[row][j] - factor * matrix[rank][j]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Check consistency
+  for (let row = rank; row < n; row++) {
+    if (matrix[row][m] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < m; col++) {
+    if (pivotRowForCol[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const result = new Array(m).fill(0);
+    for (let r = 0; r < rank; r++) {
+      result[pivotCol[r]] = matrix[r][m];
+    }
+    return result;
+  }
+
+  // Precompute coefficients: pivotVal[r] = constant[r] - sum(coeff[r][k] * free[k]) mod p
+  const pivotConstant: number[] = new Array(rank).fill(0);
+  const pivotCoeff: number[][] = [];
+  for (let r = 0; r < rank; r++) {
+    pivotConstant[r] = matrix[r][m];
+    pivotCoeff.push(new Array(numFree).fill(0));
+    for (let k = 0; k < numFree; k++) {
+      pivotCoeff[r][k] = matrix[r][freeVars[k]];
+    }
+  }
+
+  let bestResult: number[] | null = null;
+  let bestTotal = Infinity;
+
+  const freeVals = new Array(numFree).fill(0);
+
+  // Incremental pivot tracking for branch and bound
+  // pivotAccum[r] = sum(coeff[r][k] * freeVals[k]) mod p for k < current depth
+  const pivotAccum: number[] = new Array(rank).fill(0);
+
+  const branchAndBound = (idx: number, partialFreeSum: number): void => {
+    if (partialFreeSum > bestTotal) return;
+
+    if (idx === numFree) {
+      const result = new Array(m).fill(0);
+      let total = partialFreeSum;
+
+      for (let k = 0; k < numFree; k++) {
+        result[freeVars[k]] = freeVals[k];
+      }
+
+      for (let r = 0; r < rank; r++) {
+        const val = ((pivotConstant[r] - pivotAccum[r]) % modulus + modulus) % modulus;
+        result[pivotCol[r]] = val;
+        total += val;
+      }
+
+      if (total < bestTotal || (total === bestTotal && lexSmallerArr(result, bestResult!))) {
+        bestTotal = total;
+        bestResult = result;
+      }
+      return;
+    }
+
+    // Save pivot accumulators
+    const savedAccum = pivotAccum.slice();
+
+    for (let v = 0; v < modulus; v++) {
+      if (partialFreeSum + v > bestTotal) break; // pruning: remaining free vars add ≥ 0
+
+      freeVals[idx] = v;
+
+      // Update pivot accumulators
+      if (v === 0 && idx === 0) {
+        // Already zeroed
+      } else if (v === 0) {
+        // Restore from saved
+        for (let r = 0; r < rank; r++) {
+          pivotAccum[r] = savedAccum[r];
+        }
+      } else {
+        for (let r = 0; r < rank; r++) {
+          pivotAccum[r] = (savedAccum[r] + pivotCoeff[r][idx] * v) % modulus;
+        }
+      }
+
+      branchAndBound(idx + 1, partialFreeSum + v);
+    }
+
+    // Restore pivot accumulators
+    for (let r = 0; r < rank; r++) {
+      pivotAccum[r] = savedAccum[r];
+    }
+  };
+
+  // First, compute the zero-free-vars solution as an initial bound
+  {
+    const result = new Array(m).fill(0);
+    let total = 0;
+    for (let r = 0; r < rank; r++) {
+      result[pivotCol[r]] = pivotConstant[r];
+      total += pivotConstant[r];
+    }
+    bestTotal = total;
+    bestResult = result;
+  }
+
+  branchAndBound(0, 0);
+
+  return bestResult ?? new Array(m).fill(0);
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] < b[i];
+  }
+  return false;
+}
+
+function modInverse(a: number, mod: number): number {
+  let [old_r, r] = [((a % mod) + mod) % mod, mod];
+  let [old_s, s] = [1, 0];
+
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+
+  return ((old_s % mod) + mod) % mod;
+}
