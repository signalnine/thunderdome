{\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [rows[rank], rows[found]] = [rows[found], rows[rank]];\n    pivotCol[rank] = col;\n    pivotRow[col] = rank;\n\n    // Eliminate this column from all other rows\n    for (let row = 0; row < n; row++) {\n      if (row !== rank && (rows[row] >> BigInt(col)) & 1n) {\n        rows[row] ^= rows[rank];\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency: any row with all-zero coefficients but non-zero target\n  for (let row = rank; row < n; row++) {\n    if ((rows[row] >> BigInt(m)) & 1n) {\n      return null; // inconsistent system\n    }\n  }\n\n  // Identify free variables (columns without pivots)\n  const freeVars: number[] = [];\n  for (let col = 0; col < m; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  // If no free variables, there's exactly one solution\n  if (freeVars.length === 0) {\n    const result: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if ((rows[r] >> BigInt(m)) & 1n) {\n        result.push(pivotCol[r]);\n      }\n    }\n    result.sort((a, b) => a - b);\n    return result;\n  }\n\n  // Enumerate all 2^|freeVars| combinations to find minimum weight solution,\n  // breaking ties lexicographically.\n  // With up to 40 buttons, free vars could be up to 40, but in practice\n  // the number of free vars is bounded by m - rank.\n  // With n,m <= 40, rank <= min(n,m) <= 40, so free vars <= 40.\n  // But 2^40 is too many. We need a smarter approach for many free vars.\n\n  // For the toggle problem with up to 40 buttons and 40 lights,\n  // rank can be at most 40, and free vars = m - rank.\n  // If m=40 and rank=0, we'd have 40 free vars which is too many.\n  // But rank=0 means no button affects any light, so if target is all false,\n  // answer is [], otherwise null. That's already handled.\n  // In practice, with 40 lights, rank <= 40, free vars = m - rank.\n  // Worst case: 40 butto