\n    // Eliminate this column from all other rows\n    for (let row = 0; row < n; row++) {\n      if (row !== rank && (rows[row] >> BigInt(col)) & 1n) {\n        rows[row] ^= rows[rank];\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency: any row with all-zero coefficients but non-zero target\n  for (let row = rank; row < n; row++) {\n    if ((rows[row] >> BigInt(m)) & 1n) {\n      return null; // inconsistent system\n    }\n  }\n\n  // Identify free variables (columns without pivots)\n  const freeVars: number[] = [];\n  for (let col = 0; col < m; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  // If no free variables, there's exactly one solution\n  if (freeVars.length === 0) {\n    const result: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if ((rows[r] >> BigInt(m)) & 1n) {\n        result.push(pivotCol[r]);\n      }\n    }\n    result.sort((a, b) => a - b);\n    return result;\n  }\n\n  // Enumerate all 2^|freeVars| combinations to find minimum weight solution,\n  // breaking ties lexicographically.\n  // With up to 40 buttons, free vars could be up to 40, but in practice\n  // the number of free vars is bounded by m - rank.\n  // With n,m <= 40, rank <= min(n,m) <= 40, so free vars <= 40.\n  // But 2^40 is too many. We need a smarter approach for many free vars.\n\n  // For the toggle problem with up to 40 buttons and 40 lights,\n  // rank can be at most 40, and free vars = m - rank.\n  // If m=40 and rank=0, we'd have 40 free vars which is too many.\n  // But rank=0 means no button affects any light, so if target is all false,\n  // answer is [], otherwise null. That's already handled.\n  // In practice, with 40 lights, rank <= 40, free vars = m - rank.\n  // Worst case: 40 buttons, rank=20, free=20 → 2^20 = ~1M, feasible.\n  // Actually worst case is m=40, rank=0 with target all false → just press nothing.\n  // More realistically, if n=40 and m=40, rank is at most 40, free=0.\n  // The concern is when m > n. But m <= 40 and n <= 40.\n  // Let's handle up to ~25 free vars directly, and for more, use a meet-in-the-middle approach.\n\n  const numFree = freeVars.length;\n\n  // For each free variable assignment, compute the full solution\n  // and track the best (minimum presses, then lex smallest).\n  let bestResult: number[] | null = null;\n  let bestCount = m + 1;\n\n  // Precompute: for each pivot row r, which free variables appear?\n  // The solution for pivot variable pivotCol[r] = rows[r][m] XOR sum of rows[r][freeVars[k]] * freeVal[k]\n  // We store as a bitmask of free var indices that appear in each pivot row.\n  const pivotFreeDepMask: bigint[] = new Array(rank).fill(0n);\n  const pivotTarget: boolean[] = new Array(rank).fill(false);\n  for (let r = 0; r < rank; r++) {\n    pivotTarget[r] = !!((rows[r] >> BigInt(m)) & 1n);\n    for (let k = 0; k < numFree; k++) {\n      if ((rows[r] >> BigInt(freeVars[k])) & 1n) {\n        pivotFreeDepMask[r] |= 1n << BigInt(k);\n      }\n    }\n  }\n\n  if (numFree <= 25) {\n    // Direct enumeration\n    const totalCombinations = 1 << numFree;\n    for (let mask = 0; mask < totalCombinations; mask++) {\n      let count = 0;\n      const result: number[] = [];\n\n      // Count free variables set\n      const bigMask = BigInt(mask);\n      for (let k = 0; k < numFree; k++) {\n        if ((mask >> k) & 1) {\n          count++;\n          result.push(freeVars[k]);\n        }\n      }\n\n      // Count pivot variables set\n      for (let r = 0; r < rank; r++) {\n        // Compute value: target XOR (parity of free vars that appear in this row and are set)\n        let val = pivotTarget[r];\n        // Count bits in pivotFreeDepMask[r] & bigMask\n        let overlap = pivotFreeDepMask[r] & bigMask;\n        // Parity of overlap\n        let parity = false;\n        while (overlap) {\n          parity = !parity;\n          overlap &= overlap - 1n;\n        }\n        if (val !== parity) {\n          // This is XOR, so val