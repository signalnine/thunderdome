 {\n      buttons.push([i, (i + 1) % n]);\n    }\n    const lights = new Array(n).fill(0);\n    for (let i = 0; i < n; i++) lights[i] = (i * 7 + 3) % modulus;\n\n    const start = performance.now();\n    const result = solveCounter(lights, buttons, modulus);\n    const elapsed = performance.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    // Verify solution if it exists\n    if (result !== null) {\n      const state = new Array(n).fill(0);\n      for (let j = 0; j < n; j++) {\n        for (const counter of buttons[j]) {\n          state[counter] = (state[counter] + result[j]) % modulus;\n        }\n      }\n      expect(state).toEqual(lights);\n    }\n  });\n});","originalFile":"import { describe, it, expect } from 'vitest';\nimport { solveToggle, solveCounter, Machine } from './index.js';\n\ndescribe('solveToggle', () => {\n  it('should return empty array when target is all off', () => {\n    const machine: Machine = {\n      target: [false, false, false],\n      buttons: [[0, 1], [1, 2]],\n    };\n    expect(solveToggle(machine)).toEqual([]);\n  });\n\n  it('should return null when no solution exists', () => {\n    // From the example in the spec\n    const machine: Machine = {\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]],\n    };\n    // Light 0: b0 XOR b2 = 1\n    // Light 1: b0 XOR b1 = 1\n    // Light 2: b1 = 0\n    // Light 3: b1 XOR b2 = 1\n    // From light 2: b1=0. From light 1: b0=1. From light 0: b2=0.\n    // Check light 3: b1 XOR b2 = 0 XOR 0 = 0 ≠ 1. No solution.\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('should solve a simple single button case', () => {\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0, 1]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('should find minimum button presses', () => {\n    // Button 0: toggles [0]\n    // Button 1: toggles [0, 1]\n    // Button 2: toggles [1]\n    // Target: [true, true]\n    // Solution: press button 1 (1 press) instead of buttons 0 and 2 (2 presses)\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0], [0, 1], [1]],\n    };\n    expect(solveToggle(machine)).toEqual([1]);\n  });\n\n  it('should return lexicographically smallest when tied on count', () => {\n    // Button 0: toggles [0]\n    // Button 1: toggles [0]\n    // Target: [true]\n    // Both solutions {0} and {1} have 1 press. Lex smallest is {0}.\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0], [0]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('should handle multiple buttons needed', () => {\n    // Button 0: toggles [0]\n    // Button 1: toggles [1]\n    // Button 2: toggles [2]\n    // Target: [true, true, true]\n    const machine: Machine = {\n      target: [true, true, true],\n      buttons: [[0], [1], [2]],\n    };\n    expect(solveToggle(machine)).toEqual([0, 1, 2]);\n  });\n\n  it('should handle overlapping buttons', () => {\n    // Button 0: toggles [0, 1]\n    // Button 1: toggles [1, 2]\n    // Target: [true, false, true]\n    // Press both: light 0 toggled by b0 only = on, light 1 toggled by both = off, light 2 toggled by b1 only = on\n    const machine: Machine = {\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2]],\n    };\n    expect(solveToggle(machine)).toEqual([0, 1]);\n  });\n\n  it('should handle empty buttons list', () => {\n    const machine: Machine = {\n      target: [false, false],\n      buttons: [],\n    };\n    expect(solveToggle(machine)).toEqual([]);\n  });\n\n  it('should return null with empty buttons and non-zero target', () => {\n    const machine: Machine = {\n      target: [true, false],\n      buttons: [],\n    };\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('should handle single light single button', () => {\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('should handle larger system', () => {\n    // 5 lights, 5 buttons, each button toggles exactly one light\n    const machine: Machine = {\n      target: [true, false, true, false, true],\n      buttons: [[0], [1], [2], [3], [4]],\n    };\n    expect(solveToggle(machine)).toEqual([0, 2, 4]);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('should return all zeros when target is all zero', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('should solve simple single button case', () => {\n    // Button 0 affects counter 0. Target: counter 0 = 3. Modulus 5.\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('should return null when no solution exists', () => {\n    // Counter 0, no buttons affect it, target is 1\n    const result = solveCounter([1], [], 5);\n    expect(result).toBeNull();\n  });\n\n  it('should handle modular arithmetic', () => {\n    // Button 0 affects counter 0. Target: counter 0 = 0. Modulus 5.\n    // Press 0 times (or 5, but 0 is minimum).\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('should find minimum total presses', () => {\n    // Button 0 affects [0], Button 1 affects [0]\n    // Target: counter 0 = 1. Modulus 5.\n    // Solutions: (1,0), (0,1), (2,4), (3,3), (4,2) etc.\n    // Minimum total: (1,0) or (0,1), both total 1.\n    // Lex smallest: (0,1)\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('should solve with prime modulus', () => {\n    // Button 0 affects [0, 1], Button 1 affects [1, 2]\n    // Target: [1, 2, 1]. Modulus 3.\n    // b0 = 1 (from counter 0)\n    // b0 + b1 = 2 mod 3, so 1 + b1 = 2, b1 = 1\n    // b1 = 1 (from counter 2). Consistent!\n    const result = solveCounter([1, 2, 1], [[0, 1], [1, 2]], 3);\n    expect(result).toEqual([1, 1]);\n  });\n\n  it('should handle no solution with conflicting constraints', () => {\n    // Button 0 affects [0, 1]. Target: [1, 2]. Modulus 3.\n    // b0 = 1 (from counter 0), but b0 should also = 2 (from counter 1). Conflict.\n    const result = solveCounter([1, 2], [[0, 1]], 3);\n    expect(result).toBeNull();\n  });\n\n  it('should handle multiple buttons with free variables', () => {\n    // Button 0: [0], Button 1: [0], Button 2: [1]\n    // Target: [2, 3]. Modulus 5.\n    // b0 + b1 = 2 mod 5 (counter 0)\n    // b2 = 3 mod 5 (counter 1)\n    // b1 is free. b0 = 2 - b1 mod 5.\n    // We want min(b0 + b1 + b2) = min((2-b1) + b1 + 3) when 2-b1 ≥ 0\n    // but modular: if b1=0, b0=2, total=5; if b1=1, b0=1, total=5; if b1=2, b0=0, total=5\n    // if b1=3, b0=4, total=10; if b1=4, b0=3, total=10.\n    // Min total is 5 with b1=0,1,2. Lex smallest: b0=0,b1=2,b2=3 → [0,2,3]\n    const result = solveCounter([2, 3], [[0], [0], [1]], 5);\n    expect(result).toEqual([0, 2, 3]);\n  });\n\n  it('should handle larger modulus', () => {\n    // Button 0: [0]. Target: [50]. Modulus 97.\n    const result = solveCounter([50], [[0]], 97);\n    expect(result).toEqual([50]);\n  });\n\n  it('should return lex smallest for tied total', () => {\n    // Button 0: [0], Button 1: [0]\n    // Target: [0]. Modulus 3.\n    // Solutions: (0,0), (1,2), (2,1). Total: 0, 3, 3.\n    // Minimum is 0 with (0,0).\n    const result = solveCounter([0], [[0], [0]], 3);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('should handle identity-like system', () => {\n    // Each button affects exactly one counter\n    const result = solveCounter([1, 2, 3], [[0], [1], [2]], 5);\n    expect(result).toEqual([1, 2, 3]);\n  });\n});\n","structuredPatch":[{"oldStart":203,"oldLines":3,"newStart":203,"newLines":60,"lines":["     expect(result).toEqual([1, 2, 3]);","   });"," });","+","+describe('performance', () => {","+  it('solveToggle should handle 40 lights and 40 buttons quickly', () => {","+    // Create a system where ea