+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017kVmCtiveH9EfKgNdvLe1V","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import { Store, generateId, canShare, canManageRoles, addActivity, getEffectiveRole } from '../store.js';\n     3→import { AuthRequest, authMiddleware } from '../middleware.js';\n     4→import { Role } from '../types.js';\n     5→\n     6→export function shareRouter(store: Store): Router {\n     7→  const router = Router();\n     8→  router.use(authMiddleware(store));\n     9→\n    10→  // Share a resource\n    11→  router.post('/', (req: AuthRequest, res: Response): void => {\n    12→    const userId = req.userId!;\n    13→    const { resourceType, resourceId, targetUserId, role } = req.body;\n    14→\n    15→    if (!resourceType || !resourceId || !targetUserId || !role) {\n    16→      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });\n    17→      return;\n    18→    }\n    19→\n    20→    if (resourceType !== 'folder' && resourceType !== 'document') {\n    21→      res.status(400).json({ error: 'resourceType must be \"folder\" or \"document\"' });\n    22→      return;\n    23→    }\n    24→\n    25→    const validRoles: Role[] = ['viewer', 'editor', 'owner'];\n    26→    if (!validRoles.includes(role)) {\n    27→      res.status(400).json({ error: 'Role must be \"viewer\", \"editor\", or \"owner\"' });\n    28→      return;\n    29→    }\n    30→\n    31→    // Check resource exists\n    32→    if (resourceType === 'folder') {\n    33→      if (!store.folders.has(String(resourceId))) {\n    34→        res.status(404).json({ error: 'Folder not found' });\n    35→        return;\n    36→      }\n    37→    } else {\n    38→      if (!store.documents.has(String(resourceId))) {\n    39→        res.status(404).json({ error: 'Document not found' });\n    40→        return;\n    41→      }\n    42→    }\n    43→\n    44→    // Check target user exists\n    45→    if (!store.users.has(String(targetUserId))) {\n    46→      res.status(404).json({ error: 'Target user not found' });\n    47→      return;\n    48→    }\n    49→\n    50→    // Check permission: editors can share (viewer/editor), owners can assign any role\n    51→    if (role === 'owner') {\n    52→      if (!canManageRoles(store, userId, resourceType, String(resourceId))) {\n    53→        res.status(403).json({ error: 'Only owners can assign the owner role' });\n    54→        return;\n    55→      }\n    56→    } else {\n    57→      if (!canShare(store, userId, resourceType, String(resourceId))) {\n    58→        res.status(403).json({ error: 'Insufficient permissions to share' });\n    59→        return;\n    60→      }\n    61→    }\n    62→\n    63→    // Remove existing permission for this user+resource if any\n    64→    store.permissions = store.permissions.filter(\n    65→      p => !(p.resourceType === resourceType && p.resourceId === String(resourceId) && p.userId === String(targetUserId))\n    66→    );\n    67→\n    68→    // Add new permission\n    69→    const permission = {\n    70→      id: generateId(store),\n    71→      resourceType: resourceType as 'folder' | 'document',\n    72→      resourceId: String(resourceId),\n    73→      userId: String(targetUserId),\n    74→      role: role as Role,\n    75→    };\n    76→    store.permissions.push(permission);\n    77→\n    78→    addActivity(store, 'shared', userId, resourceType as 'folder' | 'document', String(resourceId),\n    79→      `Shared with user ${targetUserId} as ${role}`);\n    80→\n    81→    res.status(201).json(permission);\n    82→  });\n    83→\n    84→  // Get permissions for a resource\n    85→  router.get('/:resourceType/:resourceId', (req: AuthRequest, res: Response): void => {\n    86→    const userId = req.userId!;\n    87→    const { resourceType, resourceId } = req.params;\n    88→\n    89→    if (resourceType !== 'folder' && resourceType !== 'document') {\n    90→      res.status(400).json({ error: 'resourceType must be \"folder\" or \"document\"' });\n    91→      return;\n    92→    }\n    93→\n    94→    // Check resource exists\n    95→    if (resourceType === 'folder') {\n    96→      if (!store.folders.has(resourceId)) {\n    97→        res.status(404).json({ error: 'Folder not found' });\n    98→        return;\n    99→      }\n   100→    } else {\n   101→      if (!store.documents.has(resourceId)) {\n   102→        res.status(404).json({ error: 'Document not found' });\n   103→        return;\n   104→      }\n   105→    }\n   106→\n   107→    const userRole = getEffectiveRole(store, userId, resourceType as 'folder' | 'document', resourceId);\n   108→    if (!userRole) {\n   109→      res.status(403).json({ error: 'Access denied' });\n   110→      return;\n   111→    }\n   112→\n   113→    const permissions = store.permissions.filter(\n   114→      p => p.resourceType === resourceType && p.resourceId === resourceId\n   115→    );\n   116→\n   117→    res.json(permissions);\n   118→  });\n   119→\n   120→  return router;\n   121→}\n   122→"}]},"parent_tool_use_id":"toolu_017ivmXdFBNCuC9YvgG435ci","session_id":"a5d90211-2d06-449a-ade0-a88c412f1b18","uuid":"6464f326-91a6-49c3-9058-b281805d228f"}
