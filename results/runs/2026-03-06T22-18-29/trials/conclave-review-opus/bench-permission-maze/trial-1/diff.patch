@@ -0,0 +1,42 @@
+import { Router, Response } from 'express';
+import { Store, canRead } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+
+export function activityRouter(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Get activity log
+  router.get('/', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const { resourceType, resourceId } = req.query;
+
+    let entries = store.activity;
+
+    // Filter by resource if specified
+    if (resourceType && resourceId) {
+      entries = entries.filter(
+        e => e.resourceType === resourceType && e.resourceId === String(resourceId)
+      );
+    } else if (resourceType) {
+      entries = entries.filter(e => e.resourceType === resourceType);
+    }
+
+    // Only return activity for resources the user has access to, or their own actions
+    entries = entries.filter(e => {
+      if (e.userId === userId) return true;
+      if (e.resourceType === 'folder' && store.folders.has(e.resourceId)) {
+        return canRead(store, userId, e.resourceType, e.resourceId);
+      }
+      if (e.resourceType === 'document' && store.documents.has(e.resourceId)) {
+        return canRead(store, userId, e.resourceType, e.resourceId);
+      }
+      return false;
+    });
+
+    // Return newest first
+    res.json(entries.slice().reverse());
+  });
+
+  return router;
+}
