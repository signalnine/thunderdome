@@ -0,0 +1,56 @@
+import { Router, Response } from 'express';
+import { Store, generateId, generateToken, findUserByUsername } from '../store.js';
+import { AuthRequest } from '../middleware.js';
+
+export function authRouter(store: Store): Router {
+  const router = Router();
+
+  // Register
+  router.post('/register', (req: AuthRequest, res: Response): void => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    if (typeof username !== 'string' || typeof password !== 'string') {
+      res.status(400).json({ error: 'Username and password must be strings' });
+      return;
+    }
+
+    if (findUserByUsername(store, username)) {
+      res.status(409).json({ error: 'Username already exists' });
+      return;
+    }
+
+    const id = generateId(store);
+    const user = { id, username, password, token: null };
+    store.users.set(id, user);
+
+    res.status(201).json({ id, username });
+  });
+
+  // Login
+  router.post('/login', (req: AuthRequest, res: Response): void => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    const user = findUserByUsername(store, username);
+    if (!user || user.password !== password) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    const token = generateToken();
+    user.token = token;
+
+    res.status(200).json({ token, userId: user.id });
+  });
+
+  return router;
+}
diff --git a/src/routes/documents.ts b/src/routes/documents.ts
new file mode 100644
index 0000000..3152ebf
--- /dev/null
+++ b/src/routes/documents.ts
@@ -0,0 +1,139 @@
+import { Router, Response } from 'express';
+import { Store, generateId, canRead, canEdit, canDelete, addActivity, getEffectiveRole } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+
+export function documentsRouter(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Create document
+  router.post('/', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const { title, content, folderId } = req.body;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Title is required' });
+      return;
+    }
+
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Content is required' });
+      return;
+    }
+
+    if (!folderId) {
+      res.status(400).json({ error: 'Folder ID is required' });
+      return;
+    }
+
+    const folder = store.folders.get(String(folderId));
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    // Need at least editor on the folder to create a document
+    if (!canEdit(store, userId, 'folder', String(folderId))) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content: String(content),
+      folderId: String(folderId),
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    // Add owner permission
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    addActivity(store, 'document_created', userId, 'document', id);
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const docId = req.params.id;
+
+    const doc = store.documents.get(docId);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!canRead(store, userId, 'document', docId)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, userId, 'document', docId);
+    res.json({ ...doc, role });
+  });
+
+  // Update document
+  router.put('/:id', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const docId = req.params.id;
+
+    const doc = store.documents.get(docId);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!canEdit(store, userId, 'document', docId)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const { title, content } = req.body;
+    if (title !== undefined) doc.title = title;
+    if (content !== undefined) doc.content = String(content);
+    doc.updatedAt = new Date().toISOString();
+
+    addActivity(store, 'document_updated', userId, 'document', docId);
+
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const docId = req.params.id;
+
+    const doc = store.documents.get(docId);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!canDelete(store, userId, 'document', docId)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    store.documents.delete(docId);
+    store.permissions = store.permissions.filter(p => !(p.resourceType === 'document' && p.resourceId === docId));
+
+    addActivity(store, 'document_deleted', userId, 'document', docId);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/routes/folders.ts b/src/routes/folders.ts
new file mode 100644
index 0000000..bde6bf8
--- /dev/null
+++ b/src/routes/folders.ts
@@ -0,0 +1,173 @@
+import { Router, Response } from 'express';
+import { Store, generateId, canRead, canEdit, canDelete, addActivity, getEffectiveRole } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+
+export function foldersRouter(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Create folder
+  router.post('/', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const { name, parentId } = req.body;
+
+    if (!name || typeof name !== 'string') {
+      res.status(400).json({ error: 'Name is required' });
+      return;
+    }
+
+    if (parentId !== undefined && parentId !== null) {
+      const parentFolder = store.folders.get(String(parentId));
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      // Need at least editor on parent to create subfolder
+      if (!canEdit(store, userId, 'folder', String(parentId))) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const folder = {
+      id,
+      name,
+      parentId: parentId ? String(parentId) : null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    // Add owner permission
+    store.permissions.push({
+      id: generateId(store),
+      resourceType: 'folder',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    addActivity(store, 'folder_created', userId, 'folder', id);
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const folderId = req.params.id;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!canRead(store, userId, 'folder', folderId)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    // Get subfolders and documents
+    const subfolders = Array.from(store.folders.values()).filter(f => f.parentId === folderId);
+    const documents = Array.from(store.documents.values()).filter(d => d.folderId === folderId);
+    const role = getEffectiveRole(store, userId, 'folder', folderId);
+
+    res.json({ ...folder, subfolders, documents, role });
+  });
+
+  // Update folder
+  router.put('/:id', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const folderId = req.params.id;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!canEdit(store, userId, 'folder', folderId)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const { name, parentId } = req.body;
+    if (name !== undefined) folder.name = name;
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const newParentId = String(parentId);
+        const parentFolder = store.folders.get(newParentId);
+        if (!parentFolder) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Check permission on destination folder
+        if (!canEdit(store, userId, 'folder', newParentId)) {
+          res.status(403).json({ error: 'Insufficient permissions on destination folder' });
+          return;
+        }
+        // Prevent circular references by walking up the ancestor chain
+        let checkId: string | null = newParentId;
+        while (checkId) {
+          if (checkId === folderId) {
+            res.status(400).json({ error: 'Circular folder reference detected' });
+            return;
+          }
+          const ancestor = store.folders.get(checkId);
+          checkId = ancestor?.parentId ?? null;
+        }
+      }
+      folder.parentId = parentId ? String(parentId) : null;
+    }
+
+    addActivity(store, 'folder_updated', userId, 'folder', folderId);
+
+    res.json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const folderId = req.params.id;
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!canDelete(store, userId, 'folder', folderId)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    // Delete folder and all contents recursively
+    deleteFolderRecursive(store, folderId);
+    addActivity(store, 'folder_deleted', userId, 'folder', folderId);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
+
+function deleteFolderRecursive(store: Store, folderId: string): void {
+  // Delete subfolders
+  const subfolders = Array.from(store.folders.values()).filter(f => f.parentId === folderId);
+  for (const sub of subfolders) {
+    deleteFolderRecursive(store, sub.id);
+  }
+
+  // Delete documents in this folder
+  const docs = Array.from(store.documents.values()).filter(d => d.folderId === folderId);
+  for (const doc of docs) {
+    store.documents.delete(doc.id);
+    store.permissions = store.permissions.filter(p => !(p.resourceType === 'document' && p.resourceId === doc.id));
+  }
+
+  // Delete the folder
+  store.folders.delete(folderId);
+  store.permissions = store.permissions.filter(p => !(p.resourceType === 'folder' && p.resourceId === folderId));
+}
diff --git a/src/routes/share.ts b/src/routes/share.ts
new file mode 100644
index 0000000..ad8d171
--- /dev/null
+++ b/src/routes/share.ts
@@ -0,0 +1,134 @@
+import { Router, Response } from 'express';
+import { Store, generateId, canShare, canManageRoles, addActivity, getEffectiveRole } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { Role } from '../types.js';
+
+export function shareRouter(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Share a resource
+  router.post('/', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const { resourceType, resourceId, targetUserId, role } = req.body;
+
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });
+      return;
+    }
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be "folder" or "document"' });
+      return;
+    }
+
+    const validRoles: Role[] = ['viewer', 'editor', 'owner'];
+    if (!validRoles.includes(role)) {
+      res.status(400).json({ error: 'Role must be "viewer", "editor", or "owner"' });
+      return;
+    }
+
+    // Check resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(String(resourceId))) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(String(resourceId))) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check target user exists
+    if (!store.users.has(String(targetUserId))) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Check permission: editors can share (viewer/editor), owners can assign any role
+    if (role === 'owner') {
+      if (!canManageRoles(store, userId, resourceType, String(resourceId))) {
+        res.status(403).json({ error: 'Only owners can assign the owner role' });
+        return;
+      }
+    } else {
+      if (!canShare(store, userId, resourceType, String(resourceId))) {
+        res.status(403).json({ error: 'Insufficient permissions to share' });
+        return;
+      }
+    }
+
+    // Prevent non-owners from modifying permissions of users with equal or higher roles
+    const callerRole = getEffectiveRole(store, userId, resourceType as 'folder' | 'document', String(resourceId));
+    const targetCurrentRole = getEffectiveRole(store, String(targetUserId), resourceType as 'folder' | 'document', String(resourceId));
+    const rolePriority: Record<string, number> = { owner: 3, editor: 2, viewer: 1 };
+    if (targetCurrentRole && callerRole !== 'owner') {
+      const targetPriority = rolePriority[targetCurrentRole] || 0;
+      const callerPriority = rolePriority[callerRole!] || 0;
+      if (targetPriority >= callerPriority) {
+        res.status(403).json({ error: 'Cannot modify permissions of a user with equal or higher role' });
+        return;
+      }
+    }
+
+    // Remove existing direct permission for this user+resource if any
+    store.permissions = store.permissions.filter(
+      p => !(p.resourceType === resourceType && p.resourceId === String(resourceId) && p.userId === String(targetUserId))
+    );
+
+    // Add new permission
+    const permission = {
+      id: generateId(store),
+      resourceType: resourceType as 'folder' | 'document',
+      resourceId: String(resourceId),
+      userId: String(targetUserId),
+      role: role as Role,
+    };
+    store.permissions.push(permission);
+
+    addActivity(store, 'shared', userId, resourceType as 'folder' | 'document', String(resourceId),
+      `Shared with user ${targetUserId} as ${role}`);
+
+    res.status(201).json(permission);
+  });
+
+  // Get permissions for a resource
+  router.get('/:resourceType/:resourceId', (req: AuthRequest, res: Response): void => {
+    const userId = req.userId!;
+    const { resourceType, resourceId } = req.params;
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be "folder" or "document"' });
+      return;
+    }
+
+    // Check resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    const userRole = getEffectiveRole(store, userId, resourceType as 'folder' | 'document', resourceId);
+    if (!userRole) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const permissions = store.permissions.filter(
+      p => p.resourceType === resourceType && p.resourceId === resourceId
+    );
+
+    res.json(permissions);
+  });
+
+  return router;
+}
diff --git a/src/store.ts b/src/store.ts
new file mode 100644
index 0000000..efd3174
--- /dev/null
+++ b/src/store.ts
@@ -0,0 +1,196 @@
+import { randomBytes } from 'crypto';
+import { User, Folder, Document, Permission, ActivityEntry } from './types.js';
+
+export interface Store {
+  users: Map<string, User>;
+  folders: Map<string, Folder>;
+  documents: Map<string, Document>;
+  permissions: Permission[];
+  activity: ActivityEntry[];
+  nextId: number;
+}
+
+export function createStore(): Store {
+  return {
+    users: new Map(),
+    folders: new Map(),
+    documents: new Map(),
+    permissions: [],
+    activity: [],
+    nextId: 1,
+  };
+}
+
+export function generateId(store: Store): string {
+  return String(store.nextId++);
+}
+
+export function generateToken(): string {
+  return randomBytes(32).toString('hex');
+}
+
+export function findUserByUsername(store: Store, username: string): User | undefined {
+  for (const user of store.users.values()) {
+    if (user.username === username) return user;
+  }
+  return undefined;
+}
+
+export function findUserByToken(store: Store, token: string): User | undefined {
+  for (const user of store.users.values()) {
+    if (user.token === token) return user;
+  }
+  return undefined;
+}
+
+const ROLE_PRIORITY: Record<string, number> = { owner: 3, editor: 2, viewer: 1 };
+
+export function addActivity(
+  store: Store,
+  action: string,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  details?: string
+): void {
+  store.activity.push({
+    id: generateId(store),
+    action,
+    userId,
+    resourceType,
+    resourceId,
+    timestamp: new Date().toISOString(),
+    details,
+  });
+}
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): string | null {
+  const rolePriority = ROLE_PRIORITY;
+  let bestRole: string | null = null;
+  let bestPriority = 0;
+
+  // Check direct permissions on the resource
+  for (const perm of store.permissions) {
+    if (perm.resourceType === resourceType && perm.resourceId === resourceId && perm.userId === userId) {
+      const p = rolePriority[perm.role] || 0;
+      if (p > bestPriority) {
+        bestPriority = p;
+        bestRole = perm.role;
+      }
+    }
+  }
+
+  // If the resource is a document, also check folder permissions
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getFolderRole(store, userId, doc.folderId);
+      if (folderRole) {
+        const p = rolePriority[folderRole] || 0;
+        if (p > bestPriority) {
+          bestPriority = p;
+          bestRole = folderRole;
+        }
+      }
+    }
+  }
+
+  // If the resource is a folder, check parent folder permissions
+  if (resourceType === 'folder') {
+    const folderRole = getAncestorFolderRole(store, userId, resourceId);
+    if (folderRole) {
+      const p = rolePriority[folderRole] || 0;
+      if (p > bestPriority) {
+        bestPriority = p;
+        bestRole = folderRole;
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+function getFolderRole(store: Store, userId: string, folderId: string): string | null {
+  const rolePriority = ROLE_PRIORITY;
+  let bestRole: string | null = null;
+  let bestPriority = 0;
+
+  // Direct folder permissions
+  for (const perm of store.permissions) {
+    if (perm.resourceType === 'folder' && perm.resourceId === folderId && perm.userId === userId) {
+      const p = rolePriority[perm.role] || 0;
+      if (p > bestPriority) {
+        bestPriority = p;
+        bestRole = perm.role;
+      }
+    }
+  }
+
+  // Ancestor folder permissions
+  const ancestorRole = getAncestorFolderRole(store, userId, folderId);
+  if (ancestorRole) {
+    const p = rolePriority[ancestorRole] || 0;
+    if (p > bestPriority) {
+      bestPriority = p;
+      bestRole = ancestorRole;
+    }
+  }
+
+  return bestRole;
+}
+
+function getAncestorFolderRole(store: Store, userId: string, folderId: string): string | null {
+  const rolePriority = ROLE_PRIORITY;
+  let bestRole: string | null = null;
+  let bestPriority = 0;
+
+  const folder = store.folders.get(folderId);
+  if (!folder || !folder.parentId) return null;
+
+  let currentId: string | null = folder.parentId;
+  while (currentId) {
+    for (const perm of store.permissions) {
+      if (perm.resourceType === 'folder' && perm.resourceId === currentId && perm.userId === userId) {
+        const p = rolePriority[perm.role] || 0;
+        if (p > bestPriority) {
+          bestPriority = p;
+          bestRole = perm.role;
+        }
+      }
+    }
+    const parentFolder = store.folders.get(currentId);
+    currentId = parentFolder?.parentId ?? null;
+  }
+
+  return bestRole;
+}
+
+export function canRead(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role !== null;
+}
+
+export function canEdit(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role === 'editor' || role === 'owner';
+}
+
+export function canDelete(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role === 'owner';
+}
+
+export function canShare(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role === 'editor' || role === 'owner';
+}
+
+export function canManageRoles(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(store, userId, resourceType, resourceId);
+  return role === 'owner';
+}
