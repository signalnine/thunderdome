+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DzyFnuHtHC4GjZ4gMkHSXA","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import { Store } from '../store.js';\n     3→import { AuthRequest, authMiddleware } from '../middleware.js';\n     4→\n     5→export function activityRouter(store: Store): Router {\n     6→  const router = Router();\n     7→  router.use(authMiddleware(store));\n     8→\n     9→  // Get activity log\n    10→  router.get('/', (req: AuthRequest, res: Response): void => {\n    11→    const userId = req.userId!;\n    12→    const { resourceType, resourceId } = req.query;\n    13→\n    14→    let entries = store.activity;\n    15→\n    16→    // Filter by resource if specified\n    17→    if (resourceType && resourceId) {\n    18→      entries = entries.filter(\n    19→        e => e.resourceType === resourceType && e.resourceId === String(resourceId)\n    20→      );\n    21→    } else if (resourceType) {\n    22→      entries = entries.filter(e => e.resourceType === resourceType);\n    23→    }\n    24→\n    25→    // Only return activity for resources the user has access to, or their own actions\n    26→    entries = entries.filter(e => {\n    27→      if (e.userId === userId) return true;\n    28→      if (e.resourceType === 'folder' && store.folders.has(e.resourceId)) {\n    29→        return hasAnyPermission(store, userId, e.resourceType, e.resourceId);\n    30→      }\n    31→      if (e.resourceType === 'document' && store.documents.has(e.resourceId)) {\n    32→        return hasAnyPermission(store, userId, e.resourceType, e.resourceId);\n    33→      }\n    34→      return false;\n    35→    });\n    36→\n    37→    // Return newest first\n    38→    res.json(entries.slice().reverse());\n    39→  });\n    40→\n    41→  return router;\n    42→}\n    43→\n    44→function hasAnyPermission(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n    45→  // Check direct permissions\n    46→  for (const perm of store.permissions) {\n    47→    if (perm.resourceType === resourceType && perm.resourceId === resourceId && perm.userId === userId) {\n    48→      return true;\n    49→    }\n    50→  }\n    51→\n    52→  // For documents, also check folder permissions\n    53→  if (resourceType === 'document') {\n    54→    const doc = store.documents.get(resourceId);\n    55→    if (doc) {\n    56→      return hasAnyPermission(store, userId, 'folder', doc.folderId);\n    57→    }\n    58→  }\n    59→\n    60→  // For folders, check parent folder permissions\n    61→  if (resourceType === 'folder') {\n    62→    const folder = store.folders.get(resourceId);\n    63→    if (folder && folder.parentId) {\n    64→      return hasAnyPermission(store, userId, 'folder', folder.parentId);\n    65→    }\n    66→  }\n    67→\n    68→  return false;\n    69→}\n    70→"}]},"parent_tool_use_id":"toolu_017ivmXdFBNCuC9YvgG435ci","session_id":"a5d90211-2d06-449a-ade0-a88c412f1b18","uuid":"02a32b8d-1c37-4eb7-98ae-355ec63ce1ae"}
