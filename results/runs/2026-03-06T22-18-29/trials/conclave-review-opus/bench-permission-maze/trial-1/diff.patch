ces the user has access to, or their own actions\n    entries = entries.filter(e => {\n      if (e.userId === userId) return true;\n      if (e.resourceType === 'folder' && store.folders.has(e.resourceId)) {\n        return hasAnyPermission(store, userId, e.resourceType, e.resourceId);\n      }\n      if (e.resourceType === 'document' && store.documents.has(e.resourceId)) {\n        return hasAnyPermission(store, userId, e.resourceType, e.resourceId);\n      }\n      return false;\n    });\n\n    // Return newest first\n    res.json(entries.slice().reverse());\n  });\n\n  return router;\n}\n\nfunction hasAnyPermission(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n  // Check direct permissions\n  for (const perm of store.permissions) {\n    if (perm.resourceType === resourceType && perm.resourceId === resourceId && perm.userId === userId) {\n      return true;\n    }\n  }\n\n  // For documents, also check folder permissions\n  if (resourceType === 'document') {\n    const doc = store.documents.get(resourceId);\n    if (doc) {\n      return hasAnyPermission(store, userId, 'folder', doc.folderId);\n    }\n  }\n\n  // For folders, check parent folder permissions\n  if (resourceType === 'folder') {\n    const folder = store.folders.get(resourceId);\n    if (folder && folder.parentId) {\n      return hasAnyPermission(store, userId, 'folder', folder.parentId);\n    }\n  }\n\n  return false;\n}\n","numLines":70,"startLine":1,"totalLines":70}}}
