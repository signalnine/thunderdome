+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XW4gaaJGBW4jjzwrhrchEM","type":"tool_result","content":"     1→import { User, Folder, Document, Permission, ActivityEntry } from './types.js';\n     2→\n     3→export interface Store {\n     4→  users: Map<string, User>;\n     5→  folders: Map<string, Folder>;\n     6→  documents: Map<string, Document>;\n     7→  permissions: Permission[];\n     8→  activity: ActivityEntry[];\n     9→  nextId: number;\n    10→}\n    11→\n    12→export function createStore(): Store {\n    13→  return {\n    14→    users: new Map(),\n    15→    folders: new Map(),\n    16→    documents: new Map(),\n    17→    permissions: [],\n    18→    activity: [],\n    19→    nextId: 1,\n    20→  };\n    21→}\n    22→\n    23→export function generateId(store: Store): string {\n    24→  return String(store.nextId++);\n    25→}\n    26→\n    27→export function generateToken(): string {\n    28→  return Math.random().toString(36).substring(2) + Date.now().toString(36);\n    29→}\n    30→\n    31→export function findUserByUsername(store: Store, username: string): User | undefined {\n    32→  for (const user of store.users.values()) {\n    33→    if (user.username === username) return user;\n    34→  }\n    35→  return undefined;\n    36→}\n    37→\n    38→export function findUserByToken(store: Store, token: string): User | undefined {\n    39→  for (const user of store.users.values()) {\n    40→    if (user.token === token) return user;\n    41→  }\n    42→  return undefined;\n    43→}\n    44→\n    45→export function addActivity(\n    46→  store: Store,\n    47→  action: string,\n    48→  userId: string,\n    49→  resourceType: 'folder' | 'document',\n    50→  resourceId: string,\n    51→  details?: string\n    52→): void {\n    53→  store.activity.push({\n    54→    id: generateId(store),\n    55→    action,\n    56→    userId,\n    57→    resourceType,\n    58→    resourceId,\n    59→    timestamp: new Date().toISOString(),\n    60→    details,\n    61→  });\n    62→}\n    63→\n    64→export function getEffectiveRole(\n    65→  store: Store,\n    66→  userId: string,\n    67→  resourceType: 'folder' | 'document',\n    68→  resourceId: string\n    69→): string | null {\n    70→  const rolePriority: Record<string, number> = { owner: 3, editor: 2, viewer: 1 };\n    71→  let bestRole: string | null = null;\n    72→  let bestPriority = 0;\n    73→\n    74→  // Check direct permissions on the resource\n    75→  for (const perm of store.permissions) {\n    76→    if (perm.resourceType === resourceType && perm.resourceId === resourceId && perm.userId === userId) {\n    77→      const p = rolePriority[perm.role] || 0;\n    78→      if (p > bestPriority) {\n    79→        bestPriority = p;\n    80→        bestRole = perm.role;\n    81→      }\n    82→    }\n    83→  }\n    84→\n    85→  // If the resource is a document, also check folder permissions\n    86→  if (resourceType === 'document') {\n    87→    const doc = store.documents.get(resourceId);\n    88→    if (doc) {\n    89→      const folderRole = getFolderRole(store, userId, doc.folderId);\n    90→      if (folderRole) {\n    91→        const p = rolePriority[folderRole] || 0;\n    92→        if (p > bestPriority) {\n    93→          bestPriority = p;\n    94→          bestRole = folderRole;\n    95→        }\n    96→      }\n    97→    }\n    98→  }\n    99→\n   100→  // If the resource is a folder, check parent folder permissions\n   101→  if (resourceType === 'folder') {\n   102→    const folderRole = getAncestorFolderRole(store, userId, resourceId);\n   103→    if (folderRole) {\n   104→      const p = rolePriority[folderRole] || 0;\n   105→      if (p > bestPriority) {\n   106→        bestPriority = p;\n   107→        bestRole = folderRole;\n   108→      }\n   109→    }\n   110→  }\n   111→\n   112→  return bestRole;\n   113→}\n   114→\n   115→function getFolderRole(store: Store, userId: string, folderId: string): string | null {\n   116→  const rolePriority: Record<string, number> = { owner: 3, editor: 2, viewer: 1 };\n   117→  let bestRole: string | null = null;\n   118→  let bestPriority = 0;\n   119→\n   120→  // Direct folder permissions\n   121→  for (const perm of store.permissions) {\n   122→    if (perm.resourceType === 'folder' && perm.resourceId === folderId && perm.userId === userId) {\n   123→      const p = rolePriority[perm.role] || 0;\n   124→      if (p > bestPriority) {\n   125→        bestPriority = p;\n   126→        bestRole = perm.role;\n   127→      }\n   128→    }\n   129→  }\n   130→\n   131→  // Ancestor folder permissions\n   132→  const ancestorRole = getAncestorFolderRole(store, userId, folderId);\n   133→  if (ancestorRole) {\n   134→    const p = rolePriority[ancestorRole] || 0;\n   135→    if (p > bestPriority) {\n   136→      bestPriority = p;\n   137→      bestRole = ancestorRole;\n   138→    }\n   139→  }\n   140→\n   141→  return bestRole;\n   142→}\n   143→\n   144→function getAncestorFolderRole(store: Store, userId: string, folderId: string): string | null {\n   145→  const rolePriority: Record<string, number> = { owner: 3, editor: 2, viewer: 1 };\n   146→  let bestRole: string | null = null;\n   147→  let bestPriority = 0;\n   148→\n   149→  const folder = store.folders.get(folderId);\n   150→  if (!folder || !folder.parentId) return null;\n   151→\n   152→  let currentId: string | null = folder.parentId;\n   153→  while (currentId) {\n   154→    for (const perm of store.permissions) {\n   155→      if (perm.resourceType === 'folder' && perm.resourceId === currentId && perm.userId === userId) {\n   156→        const p = rolePriority[perm.role] || 0;\n   157→        if (p > bestPriority) {\n   158→          bestPriority = p;\n   159→          bestRole = perm.role;\n   160→        }\n   161→      }\n   162→    }\n   163→    const parentFolder = store.folders.get(currentId);\n   164→    currentId = parentFolder?.parentId ?? null;\n   165→  }\n   166→\n   167→  return bestRole;\n   168→}\n   169→\n   170→export function canRead(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n   171→  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n   172→  return role !== null;\n   173→}\n   174→\n   175→export function canEdit(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n   176→  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n   177→  return role === 'editor' || role === 'owner';\n   178→}\n   179→\n   180→export function canDelete(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n   181→  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n   182→  return role === 'owner';\n   183→}\n   184→\n   185→export function canShare(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n   186→  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n   187→  return role === 'editor' || role === 'owner';\n   188→}\n   189→\n   190→export function canManageRoles(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n   191→  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n   192→  return role === 'owner';\n   193→}\n   194→"}]},"parent_tool_use_id":"toolu_017ivmXdFBNCuC9YvgG435ci","session_id":"a5d90211-2d06-449a-ade0-a88c412f1b18","uuid":"beb94391-f031-4ec3-910c-170d2c49dcc9"}
