+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EbSNhPTL59oCKDjvuhF6xu","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import { Store, generateId, canRead, canEdit, canDelete, addActivity, getEffectiveRole } from '../store.js';\n     3→import { AuthRequest, authMiddleware } from '../middleware.js';\n     4→\n     5→export function documentsRouter(store: Store): Router {\n     6→  const router = Router();\n     7→  router.use(authMiddleware(store));\n     8→\n     9→  // Create document\n    10→  router.post('/', (req: AuthRequest, res: Response): void => {\n    11→    const userId = req.userId!;\n    12→    const { title, content, folderId } = req.body;\n    13→\n    14→    if (!title || typeof title !== 'string') {\n    15→      res.status(400).json({ error: 'Title is required' });\n    16→      return;\n    17→    }\n    18→\n    19→    if (content === undefined || content === null) {\n    20→      res.status(400).json({ error: 'Content is required' });\n    21→      return;\n    22→    }\n    23→\n    24→    if (!folderId) {\n    25→      res.status(400).json({ error: 'Folder ID is required' });\n    26→      return;\n    27→    }\n    28→\n    29→    const folder = store.folders.get(String(folderId));\n    30→    if (!folder) {\n    31→      res.status(404).json({ error: 'Folder not found' });\n    32→      return;\n    33→    }\n    34→\n    35→    // Need at least editor on the folder to create a document\n    36→    if (!canEdit(store, userId, 'folder', String(folderId))) {\n    37→      res.status(403).json({ error: 'Insufficient permissions on folder' });\n    38→      return;\n    39→    }\n    40→\n    41→    const id = generateId(store);\n    42→    const now = new Date().toISOString();\n    43→    const doc = {\n    44→      id,\n    45→      title,\n    46→      content: String(content),\n    47→      folderId: String(folderId),\n    48→      ownerId: userId,\n    49→      createdAt: now,\n    50→      updatedAt: now,\n    51→    };\n    52→    store.documents.set(id, doc);\n    53→\n    54→    // Add owner permission\n    55→    store.permissions.push({\n    56→      id: generateId(store),\n    57→      resourceType: 'document',\n    58→      resourceId: id,\n    59→      userId,\n    60→      role: 'owner',\n    61→    });\n    62→\n    63→    addActivity(store, 'document_created', userId, 'document', id);\n    64→\n    65→    res.status(201).json(doc);\n    66→  });\n    67→\n    68→  // Get document\n    69→  router.get('/:id', (req: AuthRequest, res: Response): void => {\n    70→    const userId = req.userId!;\n    71→    const docId = req.params.id;\n    72→\n    73→    const doc = store.documents.get(docId);\n    74→    if (!doc) {\n    75→      res.status(404).json({ error: 'Document not found' });\n    76→      return;\n    77→    }\n    78→\n    79→    if (!canRead(store, userId, 'document', docId)) {\n    80→      res.status(403).json({ error: 'Access denied' });\n    81→      return;\n    82→    }\n    83→\n    84→    const role = getEffectiveRole(store, userId, 'document', docId);\n    85→    res.json({ ...doc, role });\n    86→  });\n    87→\n    88→  // Update document\n    89→  router.put('/:id', (req: AuthRequest, res: Response): void => {\n    90→    const userId = req.userId!;\n    91→    const docId = req.params.id;\n    92→\n    93→    const doc = store.documents.get(docId);\n    94→    if (!doc) {\n    95→      res.status(404).json({ error: 'Document not found' });\n    96→      return;\n    97→    }\n    98→\n    99→    if (!canEdit(store, userId, 'document', docId)) {\n   100→      res.status(403).json({ error: 'Access denied' });\n   101→      return;\n   102→    }\n   103→\n   104→    const { title, content } = req.body;\n   105→    if (title !== undefined) doc.title = title;\n   106→    if (content !== undefined) doc.content = String(content);\n   107→    doc.updatedAt = new Date().toISOString();\n   108→\n   109→    addActivity(store, 'document_updated', userId, 'document', docId);\n   110→\n   111→    res.json(doc);\n   112→  });\n   113→\n   114→  // Delete document\n   115→  router.delete('/:id', (req: AuthRequest, res: Response): void => {\n   116→    const userId = req.userId!;\n   117→    const docId = req.params.id;\n   118→\n   119→    const doc = store.documents.get(docId);\n   120→    if (!doc) {\n   121→      res.status(404).json({ error: 'Document not found' });\n   122→      return;\n   123→    }\n   124→\n   125→    if (!canDelete(store, userId, 'document', docId)) {\n   126→      res.status(403).json({ error: 'Access denied' });\n   127→      return;\n   128→    }\n   129→\n   130→    store.documents.delete(docId);\n   131→    store.permissions = store.permissions.filter(p => !(p.resourceType === 'document' && p.resourceId === docId));\n   132→\n   133→    addActivity(store, 'document_deleted', userId, 'document', docId);\n   134→\n   135→    res.status(204).send();\n   136→  });\n   137→\n   138→  return router;\n   139→}\n   140→"}]},"parent_tool_use_id":"toolu_017ivmXdFBNCuC9YvgG435ci","session_id":"a5d90211-2d06-449a-ade0-a88c412f1b18","uuid":"d4b5ba7a-f818-4669-a851-069fe577ec19"}
