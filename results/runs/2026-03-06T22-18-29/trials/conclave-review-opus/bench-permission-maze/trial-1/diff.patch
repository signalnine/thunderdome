+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Srxx715F3x3tbrtU2ZbqY4","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import { Store, generateId, canRead, canEdit, canDelete, addActivity, getEffectiveRole } from '../store.js';\n     3→import { AuthRequest, authMiddleware } from '../middleware.js';\n     4→\n     5→export function foldersRouter(store: Store): Router {\n     6→  const router = Router();\n     7→  router.use(authMiddleware(store));\n     8→\n     9→  // Create folder\n    10→  router.post('/', (req: AuthRequest, res: Response): void => {\n    11→    const userId = req.userId!;\n    12→    const { name, parentId } = req.body;\n    13→\n    14→    if (!name || typeof name !== 'string') {\n    15→      res.status(400).json({ error: 'Name is required' });\n    16→      return;\n    17→    }\n    18→\n    19→    if (parentId !== undefined && parentId !== null) {\n    20→      const parentFolder = store.folders.get(String(parentId));\n    21→      if (!parentFolder) {\n    22→        res.status(404).json({ error: 'Parent folder not found' });\n    23→        return;\n    24→      }\n    25→      // Need at least editor on parent to create subfolder\n    26→      if (!canEdit(store, userId, 'folder', String(parentId))) {\n    27→        res.status(403).json({ error: 'Insufficient permissions on parent folder' });\n    28→        return;\n    29→      }\n    30→    }\n    31→\n    32→    const id = generateId(store);\n    33→    const folder = {\n    34→      id,\n    35→      name,\n    36→      parentId: parentId ? String(parentId) : null,\n    37→      ownerId: userId,\n    38→      createdAt: new Date().toISOString(),\n    39→    };\n    40→    store.folders.set(id, folder);\n    41→\n    42→    // Add owner permission\n    43→    store.permissions.push({\n    44→      id: generateId(store),\n    45→      resourceType: 'folder',\n    46→      resourceId: id,\n    47→      userId,\n    48→      role: 'owner',\n    49→    });\n    50→\n    51→    addActivity(store, 'folder_created', userId, 'folder', id);\n    52→\n    53→    res.status(201).json(folder);\n    54→  });\n    55→\n    56→  // Get folder\n    57→  router.get('/:id', (req: AuthRequest, res: Response): void => {\n    58→    const userId = req.userId!;\n    59→    const folderId = req.params.id;\n    60→\n    61→    const folder = store.folders.get(folderId);\n    62→    if (!folder) {\n    63→      res.status(404).json({ error: 'Folder not found' });\n    64→      return;\n    65→    }\n    66→\n    67→    if (!canRead(store, userId, 'folder', folderId)) {\n    68→      res.status(403).json({ error: 'Access denied' });\n    69→      return;\n    70→    }\n    71→\n    72→    // Get subfolders and documents\n    73→    const subfolders = Array.from(store.folders.values()).filter(f => f.parentId === folderId);\n    74→    const documents = Array.from(store.documents.values()).filter(d => d.folderId === folderId);\n    75→    const role = getEffectiveRole(store, userId, 'folder', folderId);\n    76→\n    77→    res.json({ ...folder, subfolders, documents, role });\n    78→  });\n    79→\n    80→  // Update folder\n    81→  router.put('/:id', (req: AuthRequest, res: Response): void => {\n    82→    const userId = req.userId!;\n    83→    const folderId = req.params.id;\n    84→\n    85→    const folder = store.folders.get(folderId);\n    86→    if (!folder) {\n    87→      res.status(404).json({ error: 'Folder not found' });\n    88→      return;\n    89→    }\n    90→\n    91→    if (!canEdit(store, userId, 'folder', folderId)) {\n    92→      res.status(403).json({ error: 'Access denied' });\n    93→      return;\n    94→    }\n    95→\n    96→    const { name, parentId } = req.body;\n    97→    if (name !== undefined) folder.name = name;\n    98→    if (parentId !== undefined) {\n    99→      if (parentId !== null) {\n   100→        const parentFolder = store.folders.get(String(parentId));\n   101→        if (!parentFolder) {\n   102→          res.status(404).json({ error: 'Parent folder not found' });\n   103→          return;\n   104→        }\n   105→        // Prevent circular references\n   106→        if (String(parentId) === folderId) {\n   107→          res.status(400).json({ error: 'A folder cannot be its own parent' });\n   108→          return;\n   109→        }\n   110→      }\n   111→      folder.parentId = parentId ? String(parentId) : null;\n   112→    }\n   113→\n   114→    addActivity(store, 'folder_updated', userId, 'folder', folderId);\n   115→\n   116→    res.json(folder);\n   117→  });\n   118→\n   119→  // Delete folder\n   120→  router.delete('/:id', (req: AuthRequest, res: Response): void => {\n   121→    const userId = req.userId!;\n   122→    const folderId = req.params.id;\n   123→\n   124→    const folder = store.folders.get(folderId);\n   125→    if (!folder) {\n   126→      res.status(404).json({ error: 'Folder not found' });\n   127→      return;\n   128→    }\n   129→\n   130→    if (!canDelete(store, userId, 'folder', folderId)) {\n   131→      res.status(403).json({ error: 'Access denied' });\n   132→      return;\n   133→    }\n   134→\n   135→    // Delete folder and all contents recursively\n   136→    deleteFolderRecursive(store, folderId);\n   137→    addActivity(store, 'folder_deleted', userId, 'folder', folderId);\n   138→\n   139→    res.status(204).send();\n   140→  });\n   141→\n   142→  return router;\n   143→}\n   144→\n   145→function deleteFolderRecursive(store: Store, folderId: string): void {\n   146→  // Delete subfolders\n   147→  const subfolders = Array.from(store.folders.values()).filter(f => f.parentId === folderId);\n   148→  for (const sub of subfolders) {\n   149→    deleteFolderRecursive(store, sub.id);\n   150→  }\n   151→\n   152→  // Delete documents in this folder\n   153→  const docs = Array.from(store.documents.values()).filter(d => d.folderId === folderId);\n   154→  for (const doc of docs) {\n   155→    store.documents.delete(doc.id);\n   156→    store.permissions = store.permissions.filter(p => !(p.resourceType === 'document' && p.resourceId === doc.id));\n   157→  }\n   158→\n   159→  // Delete the folder\n   160→  store.folders.delete(folderId);\n   161→  store.permissions = store.permissions.filter(p => !(p.resourceType === 'folder' && p.resourceId === folderId));\n   162→}\n   163→"}]},"parent_tool_use_id":"toolu_017ivmXdFBNCuC9YvgG435ci","session_id":"a5d90211-2d06-449a-ade0-a88c412f1b18","uuid":"a2b11ac1-687f-470d-9313-c5ee81c3363b"}
