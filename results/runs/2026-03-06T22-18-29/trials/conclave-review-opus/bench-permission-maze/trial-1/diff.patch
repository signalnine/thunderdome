+    const bobId = bobReg.body.id;
+    const bobLogin = await loginUser('bob', 'pass');
+    const bobToken = bobLogin.body.token;
+
+    const folder = await createFolder(aliceToken, 'Folder');
+
+    // Share with bob as editor
+    await shareResource(aliceToken, 'folder', folder.body.id, bobId, 'editor');
+
+    // Bob (editor) tries to demote Alice (owner) to viewer
+    const demoteRes = await shareResource(bobToken, 'folder', folder.body.id, aliceId, 'viewer');
+    expect(demoteRes.status).toBe(403);
+  });
+
+  it('should handle moving folder to new parent with permissions check', async () => {
+    const aliceToken = await createUserAndLogin('alice');
+    const bobReg = await registerUser('bob', 'pass');
+    const bobId = bobReg.body.id;
+    const bobLogin = await loginUser('bob', 'pass');
+    const bobToken = bobLogin.body.token;
+
+    const folderA = await createFolder(aliceToken, 'A');
+    const folderB = await createFolder(aliceToken, 'B');
+    const child = await createFolder(aliceToken, 'Child', folderA.body.id);
+
+    // Give bob editor on folderA and child, but NOT on folderB
+    await shareResource(aliceToken, 'folder', folderA.body.id, bobId, 'editor');
+
+    // Bob tries to move child to folderB (should fail, no edit perm on B)
+    const res = await request(app)
+      .put(`/folders/${child.body.id}`)
+      .set('Authorization', `Bearer ${bobToken}`)
+      .send({ parentId: folderB.body.id });
+    expect(res.status).toBe(403);
+  });
+});
