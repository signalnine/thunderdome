diff --git a/src/app.test.ts b/src/app.test.ts
new file mode 100644
index 0000000..be1c868
--- /dev/null
+++ b/src/app.test.ts
@@ -0,0 +1,778 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from './app.js';
+import type { Express } from 'express';
+
+let app: Express;
+
+beforeEach(() => {
+  app = createApp();
+});
+
+// Helper functions
+async function registerUser(username: string, password: string) {
+  return request(app).post('/auth/register').send({ username, password });
+}
+
+async function loginUser(username: string, password: string) {
+  return request(app).post('/auth/login').send({ username, password });
+}
+
+async function createUserAndLogin(username: string, password = 'pass123') {
+  await registerUser(username, password);
+  const res = await loginUser(username, password);
+  return res.body.token as string;
+}
+
+async function createFolder(token: string, name: string, parentId?: string) {
+  return request(app)
+    .post('/folders')
+    .set('Authorization', `Bearer ${token}`)
+    .send({ name, parentId });
+}
+
+async function createDocument(token: string, title: string, content: string, folderId: string) {
+  return request(app)
+    .post('/documents')
+    .set('Authorization', `Bearer ${token}`)
+    .send({ title, content, folderId });
+}
+
+async function shareResource(
+  token: string,
+  resourceType: string,
+  resourceId: string,
+  targetUserId: string,
+  role: string
+) {
+  return request(app)
+    .post('/share')
+    .set('Authorization', `Bearer ${token}`)
+    .send({ resourceType, resourceId, targetUserId, role });
+}
+
+// ===== AUTH TESTS =====
+describe('Auth', () => {
+  it('should register a new user', async () => {
+    const res = await registerUser('alice', 'password123');
+    expect(res.status).toBe(201);
+    expect(res.body).toHaveProperty('id');
+    expect(res.body.username).toBe('alice');
+  });
+
+  it('should reject duplicate username', async () => {
+    await registerUser('alice', 'password123');
+    const res = await registerUser('alice', 'otherpass');
+    expect(res.status).toBe(409);
+  });
+
+  it('should reject registration without username or password', async () => {
+    const res1 = await request(app).post('/auth/register').send({ username: 'bob' });
+    expect(res1.status).toBe(400);
+
+    const res2 = await request(app).post('/auth/register').send({ password: 'pass' });
+    expect(res2.status).toBe(400);
+  });
+
+  it('should login and return a token', async () => {
+    await registerUser('alice', 'password123');
+    const res = await loginUser('alice', 'password123');
+    expect(res.status).toBe(200);
+    expect(res.body).toHaveProperty('token');
+    expect(res.body.token).toBeTruthy();
+  });
+
+  it('should reject invalid credentials', async () => {
+    await registerUser('alice', 'password123');
+    const res = await loginUser('alice', 'wrong');
+    expect(res.status).toBe(401);
+  });
+
+  it('should reject login for non-existent user', async () => {
+    const res = await loginUser('ghost', 'pass');
+    expect(res.status).toBe(401);
+  });
+});
+
+// ===== FOLDER TESTS =====
+describe('Folders', () => {
+  let token: string;
+
+  beforeEach(async () => {
+    token = await createUserAndLogin('alice');
+  });
+
+  it('should create a folder', async () => {
+    const res = await createFolder(token, 'My Folder');
+    expect(res.status).toBe(201);
+    expect(res.body.name).toBe('My Folder');
+    expect(res.body.parentId).toBeNull();
+  });
+
+  it('should create a nested folder', async () => {
+    const parent = await createFolder(token, 'Parent');
+    const child = await createFolder(token, 'Child', parent.body.id);
+    expect(child.status).toBe(201);
+    expect(child.body.parentId).toBe(parent.body.id);
+  });
+
+  it('should reject folder creation in non-existent parent', async () => {
+    const res = await createFolder(token, 'Orphan', '9999');
+    expect(res.status).toBe(404);
+  });
+
+  it('should get a folder with subfolders and documents', async () => {
+    const parent = await createFolder(token, 'Parent');
+    await createFolder(token, 'Child', parent.body.id);
+    await createDocument(token, 'Doc', 'content', parent.body.id);
+
+    const res = await request(app)
+      .get(`/folders/${parent.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body.name).toBe('Parent');
