 167→\n   168→  return bestRole;\n   169→}\n   170→\n   171→export function canRead(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n   172→  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n   173→  return role !== null;\n   174→}\n   175→\n   176→export function canEdit(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n   177→  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n   178→  return role === 'editor' || role === 'owner';\n   179→}\n   180→\n   181→export function canDelete(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n   182→  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n   183→  return role === 'owner';\n   184→}\n   185→\n   186→export function canShare(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n   187→  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n   188→  return role === 'editor' || role === 'owner';\n   189→}\n   190→\n   191→export function canManageRoles(store: Store, userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {\n   192→  const role = getEffectiveRole(store, userId, resourceType, resourceId);\n   193→  return role === 'owner';\n   194→}\n   195→"}]},"parent_tool_use_id":null,"session_id":"a5d90211-2d06-449a-ade0-a88c412f1b18","uuid":"e716048b-29b6-4e17-b3c5-9b34653810d8","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/store.ts","content":"import { randomBytes } from 'crypto';\nimport { User, Folder, Document, Permission, ActivityEntry } from './types.js';\n\nexport interface Store {\n  users: Map<string, User>;\n  folders: Map<string, Folder>;\n  documents: Map<string, Document>;\n  permissions: Permission[];\n  activity: ActivityEntry[];\n  nextId: number;\n}\n\nexport function createStore(): Store {\n  return {\n    users: new Map(),\n    folders: new Map(),\n    documents: new Map(),\n    permissions: [],\n    activity: [],\n    nextId: 1,\n  };\n}\n\nexport function generateId(store: Store): string {\n  return String(store.nextId++);\n}\n\nexport function generateToken(): string {\n  return randomBytes(32).toString('hex');\n}\n\nexport function findUserByUsername(store: Store, username: string): User | undefined {\n  for (const user of store.users.values()) {\n    if (user.username === username) return user;\n  }\n  return undefined;\n}\n\nexport function findUserByToken(store: Store, token: string): User | undefined {\n  for (const user of store.users.values()) {\n    if (user.token === token) return user;\n  }\n  return undefined;\n}\n\nexport function addActivity(\n  store: Store,\n  action: string,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string,\n  details?: string\n): void {\n  store.activity.push({\n    id: generateId(store),\n    action,\n    userId,\n    resourceType,\n    resourceId,\n    timestamp: new Date().toISOString(),\n    details,\n  });\n}\n\nexport function getEffectiveRole(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string\n): string | null {\n  const rolePriority: Record<string, number> = { owner: 3, editor: 2, viewer: 1 };\n  let bestRole: string | null = null;\n  let bestPriority = 0;\n\n  // Check direct permissions on the resource\n  for (const perm of store.permissions) {\n    if (perm.resourceType === resourceType && perm.resourceId === resourceId && perm.userId === userId) {\n      const p = rolePriority[perm.role] || 0;\n      if (p > bestPriority) {\n        bestPriority = p;\n        bestRole = perm.role;\n      }\n    }\n  }\n\n  // If the resource is a document, also check folder permissions\n  if (resourceType === 'document') {\n    const doc = store.documents.get(resourceId);\n    if (doc) {\n      const folderRole = getFolder