xcept maybe maxZ, but that comes from OR)\n      if (isZ(out)) {\n        swapped.add(out);\n      }\n      if (xyInputs) {\n        const bit = parseInt(in1.slice(1));\n        if (bit === 0) {\n          // AND(x00, y00) -> carry for bit 0\n          // Should be consumed by one XOR and one AND (used in bit 1's full adder)\n          if (!isZ(out) && consumerOps.join(',') !== 'AND,XOR') {\n            swapped.add(out);\n          }\n        } else {\n          // AND(xNN, yNN) -> generate carry, should be consumed by one OR\n          if (!isZ(out) && consumerOps.join(',') !== 'OR') {\n            swapped.add(out);\n          }\n        }\n      } else {\n        // AND(partial, carry) -> propagate carry, should be consumed by one OR\n        if (!isZ(out) && consumerOps.join(',') !== 'OR') {\n          swapped.add(out);\n        }\n      }\n    } else if (op === 'OR') {\n      // OR gate output -> carry out\n      if (out === maxZ) {\n        // Final carry becomes the highest z bit - this is OK\n      } else if (isZ(out)) {\n        // OR should not output z (except maxZ)\n        swapped.add(out);\n      } else {\n        // Should be consumed by one XOR and one AND (feeds into next bit)\n        if (consumerOps.join(',') !== 'AND,XOR') {\n          swapped.add(out);\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}","originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\nexport function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n\n  while (remaining.length > 0) {\n    let progress = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {\n        const a = wires[gate.in1];\n        const b = wires[gate.in2];\n        if (gate.op === 'AND') {\n          wires[gate.out] = a & b;\n        } else if (gate.op === 'OR') {\n          wires[gate.out] = a | b;\n        } else if (gate.op === 'XOR') {\n          wires[gate.out] = a ^ b;\n        }\n        remaining.splice(i, 1);\n        progress = true;\n      }\n    }\n    if (!progress) break;\n  }\n\n  return wires;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped = new Set<string>();\n\n  // Build lookup maps\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  function isXY(wire: string): boolean {\n    return /^[xy]\\d+$/.test(wire);\n  }\n\n  function isZ(wire: string): boolean {\n    return /^z\\d+$/.test(wire);\n  }\n\n  function hasInputs(g: Gate, w1: string, w2: string): boolean {\n    return (g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1);\n  }\n\n  function findGate(op: Gate['op'], in1: string, in2: string): Gate | undefined {\n    return gates.find(g => g.op === op && hasInputs(g, in1, in2));\n  }\n\n  // Find the number of input bits\n  const numBits = new Set(\n    gates.flatMap(g => [g.in1, g.in2]).filter(w => w.startsWith('x'))\n  ).size;\n  const maxZ = `z${String(numBits).padStart(2, '0')}`;\n\n  // pad helper\n  const pad = (n: number) => String(n).padStart(2, '0');\n\n  // Strategy: Trace the ripple-carry adder bit by bit.\n  // For each bit, verify the expected structure. When something doesn't match,\n  // figure out which output wire was swapped and with what.\n  //\n  // Key insight: inputs (x/y wires) to gates are NEVER swapped — only output\n  // wires get swapped. So we can always find gates by their op + inputs.\n  // But a gate's output wire name might be wrong (swapped with another gate's output).\n  //\n  // When we find a structural violation, we can often deduce the swap partner by:\n  // 1. Knowing what the wire SHOULD be named\n  // 2. Finding the gate that currently has that name as its output\n\n  let carry = '';\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const x = `x${pad(bit)}`;\n    const y = `y${pad(bit)}`;\n    const z = `z${pad(bit)}`;\n\n    const xorXY = findGate('XOR', x, y);\n    const andXY = findGate('AND', x, y);\n    if (!xorXY || !andXY) continue;\n\n    if (bit === 0) {\n      // Half adder: z00 = XOR(x00, y00), carry = AND(x00, y00)\n      if (xorXY.out !== z) {\n        swapped.add(xorXY.out);\n        swapped.add(z);\n      }\n      carry = andXY.out;\n      if (isZ(carry) && carry !== maxZ) {\n        // carry should not be z-wire; find partner\n        swapped.add(carry);\n        // The partner: if z00 was correct, then this AND should output\n        // whatever wire the z-gate currently has\n        const partnerGate = gateByOutput.get(z);\n        if (partnerGate) swapped.add(z);\n      }\n    } else {\n      // Full adder:\n      // partialSum = XOR(xNN, yNN)\n      // sum = XOR(partialSum, carry_in) -> zNN\n      // genCarry = AND(xNN, yNN)\n      // propCarry = AND(partialSum, carry_in)\n      // carryOut = OR(genCarry, propCarry)\n\n      let partialSum = xorXY.out;\n      let genCarry = andXY.out;\n\n      // Validate partialSum: should not be z-wire (it's an intermediate)\n      if (isZ(partialSum)) {\n        swapped.add(partialSum);\n        // The gate that should produce z for this bit is XOR(?, carry)\n        // Find the gate currently outputting z for this bit\n        const currentZGate = gateByOutput.get(z);\n        if (currentZGate) {\n          swapped.add(z);\n          // The partial sum should actually be whatever z's gate currently outputs\n          // Swap them conceptually for further tracing\n          partialSum = z;\n        }\n      }\n\n      // Find sum gate: XOR(partialSum, carry)\n      let sumGate = findGate('XOR', partialSum, carry);\n\n      if (!sumGate && carry) {\n        // Can't find XOR(partialSum, carry).\n        // Possibilities:\n        // 1. carry wire name is wrong (carry was swapped)\n        // 2. partialSum wire name is wrong (but we checked that above)\n        // Look for any XOR gate that takes partialSum\n        const xorWithPartial = gates.find(\n          g => g.op === 'XOR' && (g.in1 === partialSum || g.in2 === partialSum)\n        );\n        if (xorWithPartial) {\n          const otherInput = xorWithPartial.in1 === partialSum\n            ? xorWithPartial.in2 : xorWithPartial.in1;\n          // otherInput should be carry but isn't\n          if (otherInput !== carry) {\n            swapped.add(carry);\n            swapped.add(otherInput);\n            carry = otherInput;\n            sumGate = xorWithPartial;\n          }\n        } else {\n          // Look for any XOR gate that takes carry\n          const xorWithCarry = gates.find(\n            g => g.op === 'XOR' && (g.in1 === carry || g.in2 === carry) && !isXY(g.in1) && !isXY(g.in2)\n          );\n          if (xorWithCarry) {\n            const otherInput = xorWithCarry.in1 === carry\n              ? xorWithCarry.in2 : xorWithCarry.in1;\n            swapped.add(partialSum);\n            swapped.add(otherInput);\n            partialSum = otherInput;\n            sumGate = xorWithCarry;\n          }\n        }\n      }\n\n      if (sumGate) {\n        // Sum gate output should be zNN\n        if (sumGate.out !== z) {\n          swapped.add(sumGate.out);\n          swapped.add(z);\n        }\n      }\n\n      // Now determine carry for next bit\n      // genCarry = AND(xNN, yNN) - already have as andXY.out\n      // propCarry = AND(partialSum, carry)\n      // carryOut = OR(genCarry, propCarry)\n\n      // Validate genCarry\n      if (isZ(genCarry) && genCarry !== maxZ) {\n        swapped.add(genCarry);\n        const partnerGate = gateByOutput.get(z);\n        if (partnerGate) swapped.add(z);\n      }\n\n      const propCarryGate = findGate('AND', partialSum, carry);\n      if (propCarryGate) {\n        const carryGate = findGate('OR', genCarry, propCarryGate.out);\n       