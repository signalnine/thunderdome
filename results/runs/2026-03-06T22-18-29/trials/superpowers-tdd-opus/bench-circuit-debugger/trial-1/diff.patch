wapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n  return gates.map(g => {\n    if (g.out === wire1) return { ...g, out: wire2 };\n    if (g.out === wire2) return { ...g, out: wire1 };\n    return g;\n  });\n}\n\ndescribe('findSwappedWires', () => {\n  it('finds 4 pairs of swapped wires in a 4-bit adder', () => {\n    let gates = make4BitAdder();\n    // Swap 4 pairs of output wires\n    gates = swapOutputs(gates, 'z00', 'c00');   // swap pair 1\n    gates = swapOutputs(gates, 'z01', 'a01');   // swap pair 2\n    gates = swapOutputs(gates, 't02', 'b02');   // swap pair 3\n    gates = swapOutputs(gates, 'z03', 'c03');   // swap pair 4\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'b02', 'c00', 'c03', 't02', 'z00', 'z01', 'z03']);\n  });\n});\n","numLines":51,"startLine":1,"totalLines":51}}}
