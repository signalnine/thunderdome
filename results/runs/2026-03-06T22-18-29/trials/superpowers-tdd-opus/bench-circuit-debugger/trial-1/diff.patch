+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  while (remaining.length > 0) {
+    let progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        if (gate.op === 'AND') {
+          wires[gate.out] = a & b;
+        } else if (gate.op === 'OR') {
+          wires[gate.out] = a | b;
+        } else if (gate.op === 'XOR') {
+          wires[gate.out] = a ^ b;
+        }
+        remaining.splice(i, 1);
+        progress = true;
+      }
+    }
+    if (!progress) break;
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
