e partial sums that need to be XOR'd with carry\n  // 2. XOR gates that output to z should have one non-x/y input (the carry)\n  //    - Exception: z00 = x00 XOR y00\n  // 3. AND gates should never output to z\n  // 4. OR gates should never output to z (except the final z bit)\n  // 5. The last z bit (zNN) should come from an OR gate (carry out) or direct wire\n\n  // Rule-based approach to detect swaps:\n  // Check structural rules that must hold in a correct adder\n\n  for (const gate of gates) {\n    const { op, in1, in2, out } = gate;\n    const bothInputsAreXY = isInputWire(in1) && isInputWire(in2);\n\n    // Rule 1: XOR gates with x/y inputs should not output z (except z00)\n    if (op === 'XOR' && bothInputsAreXY && isOutputWire(out) && out !== 'z00') {\n      // This XOR(xNN, yNN) should produce a partial sum, not a z output\n      // The z output should come from XOR(partial_sum, carry_in)\n      swapped.add(out);\n    }\n\n    // Rule 2: XOR gates NOT taking x/y inputs should output z\n    if (op === 'XOR' && !bothInputsAreXY && !isOutputWire(out)) {\n      // This is XOR(partial_sum, carry_in) which should output zNN\n      swapped.add(out);\n    }\n\n    // Rule 3: AND gates should never output z (except possibly z highest, but that comes from OR)\n    if (op === 'AND' && isOutputWire(out)) {\n      swapped.add(out);\n    }\n\n    // Rule 4: OR gates should never output z, except the highest z bit\n    if (op === 'OR' && isOutputWire(out) && out !== `z${String(maxZBit).padStart(2, '0')}`) {\n      swapped.add(out);\n    }\n  }\n\n  // Now we need to find the swap partners. Each swapped wire was swapped with exactly\n  // one other wire. We need to identify the pairs.\n  //\n  // For each swapped wire, find which wire it should have been, and that wire is also\n  // in the swapped set (or should be added).\n  //\n  // Additional cross-validation: check that outputs of certain gates feed into expected consumers\n\n  // For XOR(xNN, yNN) -> wrong_output (Ru