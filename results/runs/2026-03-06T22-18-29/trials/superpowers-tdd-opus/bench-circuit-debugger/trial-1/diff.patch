   gates = swapOutputs(gates, 't02', 'b02');\n    gates = swapOutputs(gates, 'z03', 'c03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'b02', 'c00', 'c03', 't02', 'z00', 'z01', 'z03']);\n  });\n\n  it('finds 4 pairs of swapped wires in an 8-bit adder', () => {\n    let gates = makeNBitAdder(8);\n    // Swap patterns: z with intermediate, two intermediates, carry with output\n    gates = swapOutputs(gates, 'z02', 'a02');   // z output with generate carry\n    gates = swapOutputs(gates, 't04', 'c04');   // partial sum with carry out\n    gates = swapOutputs(gates, 'b05', 'a05');   // propagate carry with generate carry\n    gates = swapOutputs(gates, 'z07', 'c07');   // z output with carry out\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a02', 'a05', 'b05', 'c04', 'c07', 't04', 'z02', 'z07']);\n  });\n\n  it('handles 45-bit adder within 5 seconds', () => {\n    let gates = makeNBitAdder(45);\n    gates = swapOutputs(gates, 'z10', 'a10');\n    gates = swapOutputs(gates, 't20', 'b20');\n    gates = swapOutputs(gates, 'c30', 'z30');\n    gates = swapOutputs(gates, 'z44', 'c44');\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(['a10', 'b20', 'c30', 'c44', 't20', 'z10', 'z30', 'z44']);\n  });\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1220,"cache_read_input_tokens":60887,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1220},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"700fa9f6-ba9e-4543-924a-5e964926a8c2","uuid":"09a9dbd6-92e2-42ba-b07c-50461ac636d4"}
