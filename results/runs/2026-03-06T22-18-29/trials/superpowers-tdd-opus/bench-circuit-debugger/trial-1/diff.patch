+        }
+      } else {
+        const partialSum = xorXY.out;
+        const genCarry = andXY.out;
+
+        // Check: partialSum should NOT be z
+        if (isZ(partialSum)) {
+          if (partialSum === z) {
+            // XOR(xNN,yNN) outputs zNN — the partial sum was swapped WITH zNN
+            // The gate that should output zNN (XOR sum gate) now outputs the old partial sum wire
+            // Find which gate references the old partial sum wire as input
+            // In the original circuit: XOR(tNN, carry) → zNN
+            // After swap: XOR(tNN, carry) → tNN (the old name, now swapped to be the sum gate output)
+            // We need to find the gate that outputs z for this bit — but zNN is taken by xorXY
+            // Instead look for an XOR gate that takes carry as input (non-xy)
+            const sumXorGate = workingGates.find(
+              g => g.op === 'XOR' && !isXY(g.in1) && !isXY(g.in2) &&
+                   (g.in1 === carry || g.in2 === carry)
+            );
+            if (sumXorGate) {
+              // sumXorGate.out is the wire that was swapped with zNN
+              allSwapped.add(z);
+              allSwapped.add(sumXorGate.out);
+              workingGates = applySwap(workingGates, z, sumXorGate.out);
+              foundSwap = true;
+              break;
+            }
+          } else {
+            // partialSum is a different z wire (e.g., XOR(x02,y02) → z05)
+            allSwapped.add(partialSum);
+            allSwapped.add(z);
+            workingGates = applySwap(workingGates, partialSum, z);
+            foundSwap = true;
+            break;
+          }
+        }
+
+        // Find sum gate: XOR(partialSum, carry)
+        const sumGate = findGate('XOR', partialSum, carry);
+
+        if (!sumGate) {
+          // Can't find XOR(partialSum, carry)
+          // Strategy: look at the gate that currently outputs z for this bit.
+          // In a correct adder, zNN = XOR(partialSum, carry).
+          // If the z gate exists and is XOR, check what inputs it has.
+          const zGate = gateByOutput.get(z);
+          if (zGate && zGate.op === 'XOR') {
+            // zGate inputs should be partialSum and carry
+            // Find which input is wrong
+            const inputs = [zGate.in1, zGate.in2];
+            if (inputs.includes(carry) && !inputs.includes(partialSum)) {
+              // carry is correct, but partialSum name is wrong
+              // The gate references some other wire instead of partialSum
+              const wrongWire = inputs[0] === carry ? inputs[1] : inputs[0];
+              // wrongWire and partialSum are swapped
+              allSwapped.add(partialSum);
+              allSwapped.add(wrongWire);
+              workingGates = applySwap(workingGates, partialSum, wrongWire);
+              foundSwap = true;
+              break;
+            } else if (inputs.includes(partialSum) && !inputs.includes(carry)) {
+              // partialSum is correct, but carry name is wrong
+              const wrongWire = inputs[0] === partialSum ? inputs[1] : inputs[0];
+              allSwapped.add(carry);
+              allSwapped.add(wrongWire);
+              workingGates = applySwap(workingGates, carry, wrongWire);
+              foundSwap = true;
+              break;
+            } else {
+              // Neither input matches — both are wrong
+              // This shouldn't happen with only 4 swaps total
+            }
+          } else {
+            // z gate is not XOR — z was swapped with something else
+            // Look for XOR consuming partialSum
+            const xorWithPartial = workingGates.find(
+              g => g.op === 'XOR' && (g.in1 === partialSum || g.in2 === partialSum)
+            );
+            if (xorWithPartial) {
+              const otherInput = xorWithPartial.in1 === partialSum
+                ? xorWithPartial.in2 : xorWithPartial.in1;
+              if (otherInput !== carry) {
+                allSwapped.add(carry);
+                allSwapped.add(otherInput);
+                workingGates = applySwap(workingGates, carry, otherInput);
+                foundSwap = true;
+                break;
+              }
+            } else {
+              // Look for XOR consuming carry (non-xy)
+              const xorWithCarry = workingGates.find(
+                g => g.op === 'XOR' && !isXY(g.in1) && !isXY(g.in2) &&
+                     (g.in1 === carry || g.in2 === carry)
+              );
+              if (xorWithCarry) {
+                const otherInput = xorWithCarry.in1 === carry
+                  ? xorWithCarry.in2 : xorWithCarry.in1;
+                allSwapped.add(partialSum);
+                allSwapped.add(otherInput);
+                workingGates = applySwap(workingGates, partialSum, otherInput);
+                foundSwap = true;
+                break;
+              }
+            }
+          }
+        } else {
+          // sumGate found, check its output
+          if (sumGate.out !== z) {
+            allSwapped.add(sumGate.out);
+            allSwapped.add(z);
+            workingGates = applySwap(workingGates, sumGate.out, z);
+            foundSwap = true;
+            break;
+          }
+        }
+
+        // Validate genCarry
+        if (isZ(genCarry) && genCarry !== maxZ) {
+          allSwapped.add(genCarry);
+          allSwapped.add(z);
+          workingGates = applySwap(workingGates, genCarry, z);
+          foundSwap = true;
+          break;
+        }
+
+        // Find propCarry and carry out
+        const propCarryGate = findGate('AND', partialSum, carry);
+        if (propCarryGate) {
+          const carryGate = findGate('OR', genCarry, propCarryGate.out);
+          if (carryGate) {
+            carry = carryGate.out;
+          } else {
+            // OR gate not found — genCarry or propCarry output may be swapped
+            const orWithGen = workingGates.find(
+              g => g.op === 'OR' && (g.in1 === genCarry || g.in2 === genCarry)
+            );
+            if (orWithGen) {
+              const otherInput = orWithGen.in1 === genCarry ? orWithGen.in2 : orWithGen.in1;
+              if (otherInput !== propCarryGate.out) {
+                allSwapped.add(propCarryGate.out);
+                allSwapped.add(otherInput);
+                workingGates = applySwap(workingGates, propCarryGate.out, otherInput);
+                foundSwap = true;
+                break;
+              }
+              carry = orWithGen.out;
+            } else {
+              const orWithProp = workingGates.find(
+                g => g.op === 'OR' && (g.in1 === propCarryGate.out || g.in2 === propCarryGate.out)
+              );
+              if (orWithProp) {
+                const otherInput = orWithProp.in1 === propCarryGate.out ? orWithProp.in2 : orWithProp.in1;
+                if (otherInput !== genCarry) {
+                  allSwapped.add(genCarry);
+                  allSwapped.add(otherInput);
+                  workingGates = applySwap(workingGates, genCarry, otherInput);
+                  foundSwap = true;
+                  break;
+                }
+                carry = orWithProp.out;
+              }
+            }
+          }
+        } else {
+          // AND(partialSum, carry) not found
+          // Try to find carry through OR gate that uses genCarry
+          const orWithGen = workingGates.find(
+            g => g.op === 'OR' && (g.in1 === genCarry || g.in2 === genCarry)
+          );
+          if (orWithGen) {
+            carry = orWithGen.out;
+          }
+        }
+
+        // Validate carry
+        if (carry && isZ(carry) && carry !== maxZ) {
+          // carry is wrongly a z-wire
+          // Find the partner by looking at what z-wire should have been
+          const zGate = gateByOutput.get(carry);
+          if (zGate) {
+            // We need to find what carry should actually be
+            // The OR gate for this bit should produce the carry
+            const orGate = workingGates.find(
+              g => g.op === 'OR' && (g.in1 === genCarry || g.in2 === genCarry)
+            );
+            if (orGate && orGate.out !== carry) {
+              allSwapped.add(carry);
+              allSwapped.add(orGate.out);
+              workingGates = applySwap(workingGates, carry, orGate.out);
+              foundSwap = true;
+              break;
+            }
+          }
+          allSwapped.add(carry);
+        }
+      }
+    }
+
+    if (!foundSwap) break;
+  }
+
+  return [...allSwapped].sort();
+}
diff --git a/tests/findSwappedWires.test.ts b/tests/findSwappedWires.test.ts
new file mode 100644
index 0000000..6a95292
--- /dev/null
+++ b/tests/findSwappedWires.test.ts
@@ -0,0 +1,122 @@
+import { describe, it, expect } from 'vitest';
+import { findSwappedWires, Gate } from '../src/index.js';
+
+function make4BitAdder(): Gate[] {
+  return [
+    // Bit 0: half adder
+    { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+    { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+    // Bit 1: full adder
+    { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+    { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+    { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+    { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+    { op: 'OR',  in1: 'a01', in2: 'b01', out: 'c01' },
+    // Bit 2: full adder
+    { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },
+    { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },
+    { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },
+    { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },
+    { op: 'OR',  in1: 'a02', in2: 'b02', out: 'c02' },
+    // Bit 3: full adder
+    { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },
+    { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },
+    { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },
+    { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },
+    { op: 'OR',  in1: 'a03', in2: 'b03', out: 'c03' },
+  ];
+}
+
+function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {
+  return gates.map(g => {
+    if (g.out === wire1) return { ...g, out: wire2 };
+    if (g.out === wire2) return { ...g, out: wire1 };
+    return g;
+  });
+}
+
+function makeNBitAdder(n: number): Gate[] {
+  const gates: Gate[] = [];
+  const pad = (i: number) => String(i).padStart(2, '0');
+
+  // Bit 0: half adder
+  gates.push({ op: 'XOR', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `z${pad(0)}` });
+  gates.push({ op: 'AND', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `c${pad(0)}` });
+
+  for (let i = 1; i < n; i++) {
+    const x = `x${pad(i)}`, y = `y${pad(i)}`, z = `z${pad(i)}`;
+    const t = `t${pad(i)}`, a = `a${pad(i)}`, b = `b${pad(i)}`, c = `c${pad(i)}`;
+    const prevC = `c${pad(i - 1)}`;
+    gates.push({ op: 'XOR', in1: x, in2: y, out: t });
+    gates.push({ op: 'XOR', in1: t, in2: prevC, out: z });
+    gates.push({ op: 'AND', in1: x, in2: y, out: a });
+    gates.push({ op: 'AND', in1: t, in2: prevC, out: b });
+    gates.push({ op: 'OR',  in1: a, in2: b, out: c });
+  }
+  return gates;
+}
+
+describe('findSwappedWires', () => {
+  it('finds 4 pairs of swapped wires in a 4-bit adder', () => {
+    let gates = make4BitAdder();
+    gates = swapOutputs(gates, 'z00', 'c00');
+    gates = swapOutputs(gates, 'z01', 'a01');
+    gates = swapOutputs(gates, 't02', 'b02');
+    gates = swapOutputs(gates, 'z03', 'c03');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'b02', 'c00', 'c03', 't02', 'z00', 'z01', 'z03']);
+  });
+
+  it('finds 4 pairs of swapped wires in an 8-bit adder', () => {
+    let gates = makeNBitAdder(8);
+    // Swap patterns that cause detectable structural violations
+    gates = swapOutputs(gates, 'z02', 'a02');   // z output with generate carry
+    gates = swapOutputs(gates, 't04', 'c04');   // partial sum with carry out
+    gates = swapOutputs(gates, 'z06', 'b06');   // z output with propagate carry
+    gates = swapOutputs(gates, 'z07', 'c07');   // z output with carry out
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a02', 'b06', 'c04', 'c07', 't04', 'z02', 'z06', 'z07']);
+  });
+
+  it('detects swap of genCarry with carry-out of different bit', () => {
+    let gates = makeNBitAdder(8);
+    // Swap a03 (genCarry for bit 3) with c05 (carry out of bit 5)
+    gates = swapOutputs(gates, 'a03', 'c05');
+    // Need 3 more swaps for exactly 4 pairs
+    gates = swapOutputs(gates, 'z01', 't01');
+    gates = swapOutputs(gates, 'z04', 'b04');
+    gates = swapOutputs(gates, 'z07', 'c07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a03', 'b04', 'c05', 'c07', 't01', 'z01', 'z04', 'z07']);
+  });
+
+  it('detects swap where AND(xNN,yNN) outputs z', () => {
+    let gates = makeNBitAdder(8);
+    // AND(x03,y03) → z03 (was a03), XOR sum gate → a03 (was z03)
+    gates = swapOutputs(gates, 'a03', 'z03');
+    gates = swapOutputs(gates, 'z01', 'c01');
+    gates = swapOutputs(gates, 't05', 'z05');
+    gates = swapOutputs(gates, 'c06', 'z06');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a03', 'c01', 'c06', 't05', 'z01', 'z03', 'z05', 'z06']);
+  });
+
+  it('handles 45-bit adder within 5 seconds', () => {
+    let gates = makeNBitAdder(45);
+    gates = swapOutputs(gates, 'z10', 'a10');
+    gates = swapOutputs(gates, 't20', 'b20');
+    gates = swapOutputs(gates, 'c30', 'z30');
+    gates = swapOutputs(gates, 'z44', 'c44');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).toEqual(['a10', 'b20', 'c30', 'c44', 't20', 'z10', 'z30', 'z44']);
+  });
+});
