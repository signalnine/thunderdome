body;\n    if (!userId || !role || !['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'userId and valid role are required' });\n      return;\n    }\n\n    if (!users.has(userId)) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n\n    // Update existing share or create new one\n    const existing = shares.find(s => s.resourceType === 'folder' && s.resourceId === folder.id && s.userId === userId);\n    if (existing) {\n      existing.role = role;\n    } else {\n      shares.push({ resourceType: 'folder', resourceId: folder.id, userId, role });\n    }\n\n    logActivity('share', req.userId!, 'folder', folder.id);\n    res.json({ message: 'Shared successfully' });\n  });\n\n  // Document routes\n  app.post('/documents', authenticate, (req: AuthRequest, res) => {\n    const { title, content, folderId } = req.body;\n    if (!title || content === undefined || !folderId) {\n      res.status(400).json({ error: 'Title, content, and folderId are required' });\n      return;\n    }\n\n    if (!folders.has(folderId)) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    const id = crypto.randomUUID();\n    const doc: Doc = { id, title, content, folderId, ownerId: req.userId! };\n    documents.set(id, doc);\n\n    logActivity('create', req.userId!, 'document', id);\n    res.status(201).json(doc);\n  });\n\n  app.get('/documents/:id', authenticate, (req: AuthRequest, res) => {\n    const doc = documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!requireRole(req.userId!, 'document', doc.id, 'viewer')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    res.json(doc);\n  });\n\n  app.put('/documents/:id', authenticate, (req: AuthRequest, res) => {\n    const doc = documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!requireRole(req.userId!, 'document', doc.id, 'editor')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    if (req.body.title !== undefined) doc.title = req.body.title;\n    if (req.body.content !== undefined) doc.content = req.body.content;\n\n    logActivity('update', req.userId!, 'document', doc.id);\n    res.json(doc);\n  });\n\n  app.delete('/documents/:id', authenticate, (req: AuthRequest, res) => {\n    const doc = documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!requireRole(req.userId!, 'document', doc.id, 'owner')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    documents.delete(req.params.id);\n    logActivity('delete', req.userId!, 'document', req.params.id);\n    res.status(204).send();\n  });\n\n  app.post('/documents/:id/share', authenticate, (req: AuthRequest, res) => {\n    const doc = documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    if (!requireRole(req.userId!, 'document', doc.id, 'editor')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    const { userId, role } = req.body;\n    if (!userId || !role || !['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'userId and valid role are required' });\n      return;\n    }\n\n    if (!users.has(userId)) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n\n    const existing = shares.find(s => s.resourceType === 'document' && s.resourceId === doc.id && s.userId === userId);\n    if (existing) {\n      existing.role = role;\n    } else {\n      shares.push({ resourceType: 'document', resourceId: doc.id, userId, role });\n    }\n\n    logActivity('share', req.userId!, 'document', doc.id);\n    res.js