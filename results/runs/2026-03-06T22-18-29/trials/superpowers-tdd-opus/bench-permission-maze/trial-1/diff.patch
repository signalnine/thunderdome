p();\n    const res = await request(app)\n      .post('/auth/login')\n      .send({ username: 'unknown', password: 'pw' });\n\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe('Folders', () => {\n  let app: Express;\n  let token: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    token = await registerAndLogin(app);\n  });\n\n  it('should require auth to create a folder', async () => {\n    const res = await request(app)\n      .post('/folders')\n      .send({ name: 'My Folder' });\n\n    expect(res.status).toBe(401);\n  });\n\n  it('should create a folder', async () => {\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'My Folder' });\n\n    expect(res.status).toBe(201);\n    expect(res.body).toHaveProperty('id');\n    expect(res.body.name).toBe('My Folder');\n  });\n\n  it('should create a nested folder', async () => {\n    const parent = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Parent' });\n\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: parent.body.id });\n\n    expect(child.status).toBe(201);\n    expect(child.body.parentId).toBe(parent.body.id);\n  });\n\n  it('should get a folder by id', async () => {\n    const created = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Test Folder' });\n\n    const res = await request(app)\n      .get(`/folders/${created.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Test Folder');\n  });\n\n  it('should update a folder', async () => {\n    const created = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Old Name' });\n\n    const res = await request(app)\n      .put(`/folders/${created.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'New Name' });\n\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('New Name');\n  });\n\n  it('should delete a folder', async () => {\n    const created = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'To Delete' });\n\n    const del = await request(app)\n      .delete(`/folders/${created.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(del.status).toBe(204);\n\n    const get = await request(app)\n      .get(`/folders/${created.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(get.status).toBe(404);\n  });\n\n  it('should return 404 for non-existent folder', async () => {\n    const res = await request(app)\n      .get('/folders/nonexistent')\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(res.status).toBe(404);\n  });\n});\n","numLines":189,"startLine":1,"totalLines":189}}}
