ments.get(resourceId);\n      if (doc && doc.ownerId === userId) return 'owner';\n    } else {\n      const folder = folders.get(resourceId);\n      if (folder && folder.ownerId === userId) return 'owner';\n    }\n\n    let bestRole: Role | null = null;\n\n    // Check direct shares on this resource\n    for (const share of shares) {\n      if (share.userId === userId && share.resourceType === resourceType && share.resourceId === resourceId) {\n        if (!bestRole || ROLE_LEVEL[share.role] > ROLE_LEVEL[bestRole]) {\n          bestRole = share.role;\n        }\n      }\n    }\n\n    // If resource is a document, also check folder shares (inherited permissions)\n    if (resourceType === 'document') {\n      const doc = documents.get(resourceId);\n      if (doc) {\n        const folderRole = getEffectiveRole(userId, 'folder', doc.folderId);\n        if (folderRole && (!bestRole || ROLE_LEVEL[folderRole] > ROLE_LEVEL[bestRole])) {\n          bestRole = folderRole;\n        }\n      }\n    }\n\n    // If resource is a folder, check parent folder shares (inherited)\n    if (resourceType === 'folder') {\n      const folder = folders.get(resourceId);\n      if (folder && folder.parentId) {\n        const parentRole = getEffectiveRole(userId, 'folder', folder.parentId);\n        if (parentRole && (!bestRole || ROLE_LEVEL[parentRole] > ROLE_LEVEL[bestRole])) {\n          bestRole = parentRole;\n        }\n      }\n    }\n\n    return bestRole;\n  }\n\n  function requireRole(userId: string, resourceType: 'folder' | 'document', resourceId: string, minRole: Role): Role | null {\n    const role = getEffectiveRole(userId, resourceType, resourceId);\n    if (!role || ROLE_LEVEL[role] < ROLE_LEVEL[minRole]) return null;\n    return role;\n  }\n\n  function authenticate(req: AuthRequest, res: Response, next: NextFunction) {\n    const authHeader = req.headers.authorization;\n    if (!authHeader || !authHeader.startsWith('Bearer ')) {\n      res.status(401).json({ error: 'Authentication required' });\n      return;\n    }\n    const token = authHeader.slice(7);\n    const userId = tokens.get(token);\n    if (!userId) {\n      res.status(401).json({ error: 'Invalid token' });\n      return;\n    }\n    req.userId = userId;\n    next();\n  }\n\n  // Auth routes\n  app.post('/auth/register', (req, res) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'Username and password are required' });\n      return;\n    }\n\n    const existing = Array.from(users.values()).find(u => u.username === username);\n    if (existing) {\n      res.status(409).json({ error: 'Username already exists' });\n      return;\n    }\n\n    const id = crypto.randomUUID();\n    const user: User = { id, username, password };\n    users.set(id, user);\n\n    res.status(201).json({ id, username });\n  });\n\n  app.post('/auth/login', (req, res) => {\n    const { username, password } = req.body;\n    const user = Array.from(users.values()).find(u => u.username === username);\n    if (!user || user.password !== password) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n\n    const token = crypto.randomUUID();\n    tokens.set(token, user.id);\n    res.json({ token });\n  });\n\n  app.get('/auth/me', authenticate, (req: AuthRequest, res) => {\n    const user = users.get(req.userId!);\n    if (!user) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    res.json({ id: user.id, username: user.username });\n  });\n\n  // Folder routes\n  app.post('/folders', authenticate, (req: AuthRequest, res) => {\n    const { name, parentId } = req.body;\n    if (!name) {\n      res.status(400).json({ error: 'Name is required' });\n      return;\n    }\n\n    if (parentId && !folders.has(parentId)) {\n      res.status(404).json({ error: 'Parent folder not found' });\n      return;\n    }\n\n    const id = crypto.randomUUID();\n    const folder: Folder = {