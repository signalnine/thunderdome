+import express, { Request, Response, NextFunction } from 'express';
+import crypto from 'crypto';
+
+interface User {
+  id: string;
+  username: string;
+  password: string;
+}
+
+interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+}
+
+interface Doc {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+}
+
+type Role = 'viewer' | 'editor' | 'owner';
+
+interface Share {
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+  userId: string;
+  role: Role;
+}
+
+interface ActivityEntry {
+  id: string;
+  action: string;
+  userId: string;
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+  timestamp: string;
+}
+
+interface AuthRequest extends Request {
+  userId?: string;
+}
+
+const ROLE_LEVEL: Record<Role, number> = { viewer: 1, editor: 2, owner: 3 };
+
+export function createApp() {
+  const app = express();
+  app.use(express.json());
+
+  const users = new Map<string, User>();
+  const tokens = new Map<string, string>();
+  const folders = new Map<string, Folder>();
+  const documents = new Map<string, Doc>();
+  const shares: Share[] = [];
+  const activityLog: ActivityEntry[] = [];
+
+  function logActivity(action: string, userId: string, resourceType: 'folder' | 'document', resourceId: string) {
+    activityLog.push({
+      id: crypto.randomUUID(),
+      action,
+      userId,
+      resourceType,
+      resourceId,
+      timestamp: new Date().toISOString(),
+    });
+  }
+
+  function getEffectiveRole(userId: string, resourceType: 'folder' | 'document', resourceId: string): Role | null {
+    // Check ownership
+    if (resourceType === 'document') {
+      const doc = documents.get(resourceId);
+      if (doc && doc.ownerId === userId) return 'owner';
+    } else {
+      const folder = folders.get(resourceId);
+      if (folder && folder.ownerId === userId) return 'owner';
+    }
+
+    let bestRole: Role | null = null;
+
+    // Check direct shares on this resource
+    for (const share of shares) {
+      if (share.userId === userId && share.resourceType === resourceType && share.resourceId === resourceId) {
+        if (!bestRole || ROLE_LEVEL[share.role] > ROLE_LEVEL[bestRole]) {
+          bestRole = share.role;
+        }
+      }
+    }
+
+    // If resource is a document, also check folder shares (inherited permissions)
+    if (resourceType === 'document') {
+      const doc = documents.get(resourceId);
+      if (doc) {
+        const folderRole = getEffectiveRole(userId, 'folder', doc.folderId);
+        if (folderRole && (!bestRole || ROLE_LEVEL[folderRole] > ROLE_LEVEL[bestRole])) {
+          bestRole = folderRole;
+        }
+      }
+    }
+
+    // If resource is a folder, check parent folder shares (inherited)
+    if (resourceType === 'folder') {
+      const folder = folders.get(resourceId);
+      if (folder && folder.parentId) {
+        const parentRole = getEffectiveRole(userId, 'folder', folder.parentId);
+        if (parentRole && (!bestRole || ROLE_LEVEL[parentRole] > ROLE_LEVEL[bestRole])) {
+          bestRole = parentRole;
+        }
+      }
+    }
+
+    return bestRole;
+  }
+
+  function requireRole(userId: string, resourceType: 'folder' | 'document', resourceId: string, minRole: Role): Role | null {
+    const role = getEffectiveRole(userId, resourceType, resourceId);
+    if (!role || ROLE_LEVEL[role] < ROLE_LEVEL[minRole]) return null;
+    return role;
+  }
+
+  function authenticate(req: AuthRequest, res: Response, next: NextFunction) {
+    const authHeader = req.headers.authorization;
+    if (!authHeader || !authHeader.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+    const token = authHeader.slice(7);
+    const userId = tokens.get(token);
+    if (!userId) {
+      res.status(401).json({ error: 'Invalid token' });
+      return;
+    }
+    req.userId = userId;
+    next();
+  }
+
+  // Auth routes
+  app.post('/auth/register', (req, res) => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    const existing = Array.from(users.values()).find(u => u.username === username);
+    if (existing) {
+      res.status(409).json({ error: 'Username already exists' });
+      return;
+    }
+
+    const id = crypto.randomUUID();
+    const user: User = { id, username, password };
+    users.set(id, user);
+
+    res.status(201).json({ id, username });
+  });
+
+  app.post('/auth/login', (req, res) => {
+    const { username, password } = req.body;
+    const user = Array.from(users.values()).find(u => u.username === username);
+    if (!user || user.password !== password) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    const token = crypto.randomUUID();
+    tokens.set(token, user.id);
+    res.json({ token });
+  });
+
+  app.get('/auth/me', authenticate, (req: AuthRequest, res) => {
+    const user = users.get(req.userId!);
+    if (!user) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+    res.json({ id: user.id, username: user.username });
+  });
+
+  // Folder routes
+  app.post('/folders', authenticate, (req: AuthRequest, res) => {
+    const { name, parentId } = req.body;
+    if (!name) {
+      res.status(400).json({ error: 'Name is required' });
+      return;
+    }
+
+    if (parentId && !folders.has(parentId)) {
+      res.status(404).json({ error: 'Parent folder not found' });
+      return;
+    }
+
+    const id = crypto.randomUUID();
+    const folder: Folder = { id, name, parentId: parentId || null, ownerId: req.userId! };
+    folders.set(id, folder);
+
+    res.status(201).json({ id, name, parentId: folder.parentId, ownerId: folder.ownerId });
+  });
+
+  app.get('/folders/:id', authenticate, (req: AuthRequest, res) => {
+    const folder = folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!requireRole(req.userId!, 'folder', folder.id, 'viewer')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    res.json(folder);
+  });
+
+  app.put('/folders/:id', authenticate, (req: AuthRequest, res) => {
+    const folder = folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!requireRole(req.userId!, 'folder', folder.id, 'editor')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    if (req.body.name) folder.name = req.body.name;
+    if (req.body.parentId !== undefined) folder.parentId = req.body.parentId;
+
+    res.json(folder);
+  });
+
+  app.delete('/folders/:id', authenticate, (req: AuthRequest, res) => {
+    const folder = folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!requireRole(req.userId!, 'folder', folder.id, 'owner')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    folders.delete(req.params.id);
+    res.status(204).send();
+  });
+
+  app.post('/folders/:id/share', authenticate, (req: AuthRequest, res) => {
+    const folder = folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!requireRole(req.userId!, 'folder', folder.id, 'editor')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const { userId, role } = req.body;
+    if (!userId || !role || !['viewer', 'editor', 'owner'].includes(role)) {
+      res.status(400).json({ error: 'userId and valid role are required' });
+      return;
+    }
+
+    if (!users.has(userId)) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+
+    // Update existing share or create new one
+    const existing = shares.find(s => s.resourceType === 'folder' && s.resourceId === folder.id && s.userId === userId);
+    if (existing) {
+      existing.role = role;
+    } else {
+      shares.push({ resourceType: 'folder', resourceId: folder.id, userId, role });
+    }
+
+    logActivity('share', req.userId!, 'folder', folder.id);
+    res.json({ message: 'Shared successfully' });
+  });
+
+  // Document routes
+  app.post('/documents', authenticate, (req: AuthRequest, res) => {
+    const { title, content, folderId } = req.body;
+    if (!title || content === undefined || !folderId) {
+      res.status(400).json({ error: 'Title, content, and folderId are required' });
+      return;
+    }
+
+    if (!folders.has(folderId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const id = crypto.randomUUID();
+    const doc: Doc = { id, title, content, folderId, ownerId: req.userId! };
+    documents.set(id, doc);
+
+    logActivity('create', req.userId!, 'document', id);
+    res.status(201).json(doc);
+  });
+
+  app.get('/documents/:id', authenticate, (req: AuthRequest, res) => {
+    const doc = documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!requireRole(req.userId!, 'document', doc.id, 'viewer')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  app.put('/documents/:id', authenticate, (req: AuthRequest, res) => {
+    const doc = documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!requireRole(req.userId!, 'document', doc.id, 'editor')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    if (req.body.title !== undefined) doc.title = req.body.title;
+    if (req.body.content !== undefined) doc.content = req.body.content;
+
+    logActivity('update', req.userId!, 'document', doc.id);
+    res.json(doc);
+  });
+
+  app.delete('/documents/:id', authenticate, (req: AuthRequest, res) => {
+    const doc = documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!requireRole(req.userId!, 'document', doc.id, 'owner')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    documents.delete(req.params.id);
+    logActivity('delete', req.userId!, 'document', req.params.id);
+    res.status(204).send();
+  });
+
+  app.post('/documents/:id/share', authenticate, (req: AuthRequest, res) => {
+    const doc = documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!requireRole(req.userId!, 'document', doc.id, 'editor')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const { userId, role } = req.body;
+    if (!userId || !role || !['viewer', 'editor', 'owner'].includes(role)) {
+      res.status(400).json({ error: 'userId and valid role are required' });
+      return;
+    }
+
+    if (!users.has(userId)) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+
+    const existing = shares.find(s => s.resourceType === 'document' && s.resourceId === doc.id && s.userId === userId);
+    if (existing) {
+      existing.role = role;
+    } else {
+      shares.push({ resourceType: 'document', resourceId: doc.id, userId, role });
+    }
+
+    logActivity('share', req.userId!, 'document', doc.id);
+    res.json({ message: 'Shared successfully' });
+  });
+
+  // Activity log
+  app.get('/activity', authenticate, (req: AuthRequest, res) => {
+    res.json(activityLog);
+  });
+
+  return app;
+}
