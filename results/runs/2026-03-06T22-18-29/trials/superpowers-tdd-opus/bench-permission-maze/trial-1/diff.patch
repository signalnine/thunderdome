ogin').send({ username, password });\n  return loginRes.body.token as string;\n}\n\ndescribe('User Registration', () => {\n  it('should register a new user and return 201', async () => {\n    const app = createApp();\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'password123' });\n\n    expect(res.status).toBe(201);\n    expect(res.body).toHaveProperty('id');\n    expect(res.body.username).toBe('alice');\n  });\n\n  it('should reject duplicate username with 409', async () => {\n    const app = createApp();\n    await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'password123' });\n\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'other' });\n\n    expect(res.status).toBe(409);\n  });\n\n  it('should return 400 if username or password missing', async () => {\n    const app = createApp();\n    const res1 = await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice' });\n    expect(res1.status).toBe(400);\n\n    const res2 = await request(app)\n      .post('/auth/register')\n      .send({ password: 'pw' });\n    expect(res2.status).toBe(400);\n  });\n});\n\ndescribe('User Login', () => {\n  it('should login with valid credentials and return a token', async () => {\n    const app = createApp();\n    await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'password123' });\n\n    const res = await request(app)\n      .post('/auth/login')\n      .send({ username: 'alice', password: 'password123' });\n\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveProperty('token');\n    expect(typeof res.body.token).toBe('string');\n  });\n\n  it('should reject invalid password with 401', async () => {\n    const app = createApp();\n    await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'password123' });\n\n    const res = await request(app)\n      .post('/auth/login')\n      .send({ username: 'alice', password: 'wrong' });\n\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject unknown username with 401', async () => {\n    const app = createApp();\n    const res = await request(app)\n      .post('/auth/login')\n      .send({ username: 'unknown', password: 'pw' });\n\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe('Folders', () => {\n  let app: Express;\n  let token: string;\n\n  beforeEach(async () => {\n    app = createApp();\n    token = await registerAndLogin(app);\n  });\n\n  it('should require auth to create a folder', async () => {\n    const res = await request(app)\n      .post('/folders')\n      .send({ name: 'My Folder' });\n\n    expect(res.status).toBe(401);\n  });\n\n  it('should create a folder', async () => {\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'My Folder' });\n\n    expect(res.status).toBe(201);\n    expect(res.body).toHaveProperty('id');\n    expect(res.body.name).toBe('My Folder');\n  });\n\n  it('should create a nested folder', async () => {\n    const parent = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Parent' });\n\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Child', parentId: parent.body.id });\n\n    expect(child.status).toBe(201);\n    expect(child.body.parentId).toBe(parent.body.id);\n  });\n\n  it('should get a folder by id', async () => {\n    const created = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Test Folder' });\n\n    const res = await request(app)\n      .get(`/folders/${created.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(res.status).toBe(200);\n    expect(re