d password are required' });\n    59→      return;\n    60→    }\n    61→\n    62→    const existing = Array.from(users.values()).find(u => u.username === username);\n    63→    if (existing) {\n    64→      res.status(409).json({ error: 'Username already exists' });\n    65→      return;\n    66→    }\n    67→\n    68→    const id = crypto.randomUUID();\n    69→    const user: User = { id, username, password };\n    70→    users.set(id, user);\n    71→\n    72→    res.status(201).json({ id, username });\n    73→  });\n    74→\n    75→  app.post('/auth/login', (req, res) => {\n    76→    const { username, password } = req.body;\n    77→    const user = Array.from(users.values()).find(u => u.username === username);\n    78→    if (!user || user.password !== password) {\n    79→      res.status(401).json({ error: 'Invalid credentials' });\n    80→      return;\n    81→    }\n    82→\n    83→    const token = crypto.randomUUID();\n    84→    tokens.set(token, user.id);\n    85→    res.json({ token });\n    86→  });\n    87→\n    88→  // Folder routes\n    89→  app.post('/folders', authenticate, (req: AuthRequest, res) => {\n    90→    const { name, parentId } = req.body;\n    91→    if (!name) {\n    92→      res.status(400).json({ error: 'Name is required' });\n    93→      return;\n    94→    }\n    95→\n    96→    if (parentId && !folders.has(parentId)) {\n    97→      res.status(404).json({ error: 'Parent folder not found' });\n    98→      return;\n    99→    }\n   100→\n   101→    const id = crypto.randomUUID();\n   102→    const folder: Folder = { id, name, parentId: parentId || null, ownerId: req.userId! };\n   103→    folders.set(id, folder);\n   104→\n   105→    res.status(201).json({ id, name, parentId: folder.parentId, ownerId: folder.ownerId });\n   106→  });\n   107→\n   108→  app.get('/folders/:id', authenticate, (req: AuthRequest, res) => {\n   109→    const folder = folders.get(req.params.id);\n   110→    if (!folder) {\n   111→      res.status(404).js