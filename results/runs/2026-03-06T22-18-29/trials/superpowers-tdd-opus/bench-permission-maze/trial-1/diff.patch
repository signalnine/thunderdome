+
+  it('editor should not be able to delete document', async () => {
+    await shareDoc(app, aliceToken, docId, bobToken, 'editor');
+
+    const res = await request(app)
+      .delete(`/documents/${docId}`)
+      .set('Authorization', `Bearer ${bobToken}`);
+
+    expect(res.status).toBe(403);
+  });
+
+  it('owner should be able to delete document', async () => {
+    const res = await request(app)
+      .delete(`/documents/${docId}`)
+      .set('Authorization', `Bearer ${aliceToken}`);
+
+    expect(res.status).toBe(204);
+  });
+
+  it('should share a folder and inherit access for documents in it', async () => {
+    await shareFolder(app, aliceToken, folderId, bobToken, 'viewer');
+
+    const readRes = await request(app)
+      .get(`/documents/${docId}`)
+      .set('Authorization', `Bearer ${bobToken}`);
+
+    expect(readRes.status).toBe(200);
+  });
+
+  it('should not allow bob to read alice folder without sharing', async () => {
+    const res = await request(app)
+      .get(`/folders/${folderId}`)
+      .set('Authorization', `Bearer ${bobToken}`);
+
+    expect(res.status).toBe(403);
+  });
+
+  it('editor should be able to share with others', async () => {
+    const charlieToken = await registerAndLogin(app, 'charlie', 'pw3');
+    await shareDoc(app, aliceToken, docId, bobToken, 'editor');
+
+    const charlieUser = await getUser(app, charlieToken);
+    const shareRes = await request(app)
+      .post(`/documents/${docId}/share`)
+      .set('Authorization', `Bearer ${bobToken}`)
+      .send({ userId: charlieUser.id, role: 'viewer' });
+
+    expect(shareRes.status).toBe(200);
+
+    const readRes = await request(app)
+      .get(`/documents/${docId}`)
+      .set('Authorization', `Bearer ${charlieToken}`);
+
+    expect(readRes.status).toBe(200);
+  });
+
+  it('viewer should not be able to share', async () => {
+    const charlieToken = await registerAndLogin(app, 'charlie', 'pw3');
+    await shareDoc(app, aliceToken, docId, bobToken, 'viewer');
+
+    const charlieUser = await getUser(app, charlieToken);
+    const shareRes = await request(app)
+      .post(`/documents/${docId}/share`)
+      .set('Authorization', `Bearer ${bobToken}`)
+      .send({ userId: charlieUser.id, role: 'viewer' });
+
+    expect(shareRes.status).toBe(403);
+  });
+
+  it('most permissive role wins when multiple paths grant access', async () => {
+    // Share folder with viewer, document with editor - editor should win
+    await shareFolder(app, aliceToken, folderId, bobToken, 'viewer');
+    await shareDoc(app, aliceToken, docId, bobToken, 'editor');
+
+    const res = await request(app)
+      .put(`/documents/${docId}`)
+      .set('Authorization', `Bearer ${bobToken}`)
+      .send({ title: 'Edited' });
+
+    expect(res.status).toBe(200);
+  });
+});
+
+describe('Activity Log', () => {
+  let app: Express;
+  let token: string;
+  let folderId: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    token = await registerAndLogin(app);
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Log Folder' });
+    folderId = folderRes.body.id;
+  });
+
+  it('should log document creation', async () => {
+    await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Doc', content: 'text', folderId });
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body.length).toBeGreaterThanOrEqual(1);
+    const createEntry = res.body.find((e: { action: string }) => e.action === 'create');
+    expect(createEntry).toBeDefined();
+    expect(createEntry.resourceType).toBe('document');
+    expect(createEntry).toHaveProperty('timestamp');
+    expect(createEntry).toHaveProperty('userId');
+  });
+
+  it('should log document updates', async () => {
+    const docRes = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Doc', content: 'text', folderId });
+
+    await request(app)
+      .put(`/documents/${docRes.body.id}`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Updated' });
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    const updateEntry = res.body.find((e: { action: string }) => e.action === 'update');
+    expect(updateEntry).toBeDefined();
+    expect(updateEntry.resourceType).toBe('document');
+  });
+
+  it('should log document deletion', async () => {
+    const docRes = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Doc', content: 'text', folderId });
+
+    await request(app)
+      .delete(`/documents/${docRes.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    const deleteEntry = res.body.find((e: { action: string }) => e.action === 'delete');
+    expect(deleteEntry).toBeDefined();
+  });
+
+  it('should log sharing events', async () => {
+    const bobToken = await registerAndLogin(app, 'bob', 'pw2');
+    const docRes = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Doc', content: 'text', folderId });
+
+    await shareDoc(app, token, docRes.body.id, bobToken, 'viewer');
+
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    const shareEntry = res.body.find((e: { action: string }) => e.action === 'share');
+    expect(shareEntry).toBeDefined();
+    expect(shareEntry.resourceType).toBe('document');
+  });
+});
+
+async function getUser(app: Express, token: string) {
+  const res = await request(app)
+    .get('/auth/me')
+    .set('Authorization', `Bearer ${token}`);
+  return res.body;
+}
+
+async function shareDoc(app: Express, ownerToken: string, docId: string, targetToken: string, role: string) {
+  const target = await getUser(app, targetToken);
+  return request(app)
+    .post(`/documents/${docId}/share`)
+    .set('Authorization', `Bearer ${ownerToken}`)
+    .send({ userId: target.id, role });
+}
+
+async function shareFolder(app: Express, ownerToken: string, folderId: string, targetToken: string, role: string) {
+  const target = await getUser(app, targetToken);
+  return request(app)
+    .post(`/folders/${folderId}/share`)
+    .set('Authorization', `Bearer ${ownerToken}`)
+    .send({ userId: target.id, role });
+}
