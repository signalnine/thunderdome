+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import type { Express } from 'express';
+import { createApp } from './app.js';
+
+async function registerAndLogin(app: Express, username = 'alice', password = 'password123') {
+  await request(app).post('/auth/register').send({ username, password });
+  const loginRes = await request(app).post('/auth/login').send({ username, password });
+  return loginRes.body.token as string;
+}
+
+describe('User Registration', () => {
+  it('should register a new user and return 201', async () => {
+    const app = createApp();
+    const res = await request(app)
+      .post('/auth/register')
+      .send({ username: 'alice', password: 'password123' });
+
+    expect(res.status).toBe(201);
+    expect(res.body).toHaveProperty('id');
+    expect(res.body.username).toBe('alice');
+  });
+
+  it('should reject duplicate username with 409', async () => {
+    const app = createApp();
+    await request(app)
+      .post('/auth/register')
+      .send({ username: 'alice', password: 'password123' });
+
+    const res = await request(app)
+      .post('/auth/register')
+      .send({ username: 'alice', password: 'other' });
+
+    expect(res.status).toBe(409);
+  });
+
+  it('should return 400 if username or password missing', async () => {
+    const app = createApp();
+    const res1 = await request(app)
+      .post('/auth/register')
+      .send({ username: 'alice' });
+    expect(res1.status).toBe(400);
+
+    const res2 = await request(app)
+      .post('/auth/register')
+      .send({ password: 'pw' });
+    expect(res2.status).toBe(400);
+  });
+});
+
+describe('User Login', () => {
+  it('should login with valid credentials and return a token', async () => {
+    const app = createApp();
+    await request(app)
+      .post('/auth/register')
+      .send({ username: 'alice', password: 'password123' });
+
+    const res = await request(app)
+      .post('/auth/login')
+      .send({ username: 'alice', password: 'password123' });
+
+    expect(res.status).toBe(200);
+    expect(res.body).toHaveProperty('token');
+    expect(typeof res.body.token).toBe('string');
+  });
+
+  it('should reject invalid password with 401', async () => {
+    const app = createApp();
+    await request(app)
+      .post('/auth/register')
+      .send({ username: 'alice', password: 'password123' });
+
+    const res = await request(app)
+      .post('/auth/login')
+      .send({ username: 'alice', password: 'wrong' });
+
+    expect(res.status).toBe(401);
+  });
+
+  it('should reject unknown username with 401', async () => {
+    const app = createApp();
+    const res = await request(app)
+      .post('/auth/login')
+      .send({ username: 'unknown', password: 'pw' });
+
+    expect(res.status).toBe(401);
+  });
+});
+
+describe('Folders', () => {
+  let app: Express;
+  let token: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    token = await registerAndLogin(app);
+  });
+
+  it('should require auth to create a folder', async () => {
+    const res = await request(app)
+      .post('/folders')
+      .send({ name: 'My Folder' });
+
+    expect(res.status).toBe(401);
+  });
+
+  it('should create a folder', async () => {
+    const res = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'My Folder' });
+
+    expect(res.status).toBe(201);
+    expect(res.body).toHaveProperty('id');
+    expect(res.body.name).toBe('My Folder');
+  });
+
+  it('should create a nested folder', async () => {
+    const parent = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Parent' });
+
+    const child = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Child', parentId: parent.body.id });
+
+    expect(child.status).toBe(201);
+    expect(child.body.parentId).toBe(parent.body.id);
+  });
+
+  it('should get a folder by id', async () => {
+    const created = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Test Folder' });
+
+    const res = await request(app)
+      .get(`/folders/${created.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body.name).toBe('Test Folder');
+  });
+
+  it('should update a folder', async () => {
+    const created = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Old Name' });
+
+    const res = await request(app)
+      .put(`/folders/${created.body.id}`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'New Name' });
+
+    expect(res.status).toBe(200);
+    expect(res.body.name).toBe('New Name');
+  });
+
+  it('should delete a folder', async () => {
+    const created = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'To Delete' });
+
+    const del = await request(app)
+      .delete(`/folders/${created.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(del.status).toBe(204);
+
+    const get = await request(app)
+      .get(`/folders/${created.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(get.status).toBe(404);
+  });
+
+  it('should return 404 for non-existent folder', async () => {
+    const res = await request(app)
+      .get('/folders/nonexistent')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(404);
+  });
+});
+
+describe('Documents', () => {
+  let app: Express;
+  let token: string;
+  let folderId: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    token = await registerAndLogin(app);
+    const folderRes = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Docs Folder' });
+    folderId = folderRes.body.id;
+  });
+
+  it('should create a document in a folder', async () => {
+    const res = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'My Doc', content: 'Hello world', folderId });
+
+    expect(res.status).toBe(201);
+    expect(res.body).toHaveProperty('id');
+    expect(res.body.title).toBe('My Doc');
+    expect(res.body.content).toBe('Hello world');
+    expect(res.body.folderId).toBe(folderId);
+  });
+
+  it('should get a document by id', async () => {
+    const created = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'My Doc', content: 'Hello', folderId });
+
+    const res = await request(app)
+      .get(`/documents/${created.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body.title).toBe('My Doc');
+    expect(res.body.content).toBe('Hello');
+  });
+
+  it('should update a document', async () => {
+    const created = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Old Title', content: 'Old', folderId });
+
+    const res = await request(app)
+      .put(`/documents/${created.body.id}`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'New Title', content: 'Updated' });
+
+    expect(res.status).toBe(200);
+    expect(res.body.title).toBe('New Title');
+    expect(res.body.content).toBe('Updated');
+  });
+
+  it('should delete a document', async () => {
+    const created = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Delete Me', content: 'bye', folderId });
+
+    const del = await request(app)
+      .delete(`/documents/${created.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(del.status).toBe(204);
+
+    const get = await request(app)
+      .get(`/documents/${created.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(get.status).toBe(404);
+  });
+
+  it('should return 404 for non-existent document', async () => {
+    const res = await request(app)
+      .get('/documents/nonexistent')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(404);
+  });
+
+  it('should reject document creation without folderId', async () => {
+    const res = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'No Folder', content: 'oops' });
+
+    expect(res.status).toBe(400);
+  });
+});
+
+describe('Sharing & Permissions', () => {
