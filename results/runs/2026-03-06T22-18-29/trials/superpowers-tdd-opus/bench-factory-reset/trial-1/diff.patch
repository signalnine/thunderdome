+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+// Represent bitmasks as [lo, hi] pairs for up to 41 bits (40 buttons + augment)
+type Pair = [number, number]; // [lo: bits 0-31, hi: bits 32+]
+
+function pairNew(): Pair { return [0, 0]; }
+function pairSetBit(p: Pair, bit: number): void {
+  if (bit < 32) p[0] |= (1 << bit) >>> 0;
+  else p[1] |= (1 << (bit - 32)) >>> 0;
+}
+function pairGetBit(p: Pair, bit: number): number {
+  if (bit < 32) return (p[0] >>> bit) & 1;
+  return (p[1] >>> (bit - 32)) & 1;
+}
+function pairXorMut(a: Pair, b: Pair): void {
+  a[0] = (a[0] ^ b[0]) >>> 0;
+  a[1] = (a[1] ^ b[1]) >>> 0;
+}
+function pairClone(p: Pair): Pair { return [p[0], p[1]]; }
+
+function popcount32(x: number): number {
+  x = x - ((x >> 1) & 0x55555555);
+  x = (x & 0x33333333) + ((x >> 2) & 0x33333333);
+  x = (x + (x >> 4)) & 0x0f0f0f0f;
+  return (x * 0x01010101) >> 24;
+}
+
+function pairPopcount(p: Pair): number {
+  return popcount32(p[0]) + popcount32(p[1]);
+}
+
+function pairToSortedArray(p: Pair, maxBits: number): number[] {
+  const result: number[] = [];
+  for (let i = 0; i < maxBits; i++) {
+    if (pairGetBit(p, i)) result.push(i);
+  }
+  return result;
