resentation.\n    48→  // We combine lo and hi into a unified scan using bit position tracking.\n    49→  let aLo = a[0] >>> 0, aHi = a[1] >>> 0;\n    50→  let bLo = b[0] >>> 0, bHi = b[1] >>> 0;\n    51→\n    52→  // Process lo bits (0-31) first\n    53→  while (aLo !== 0 || bLo !== 0 || aHi !== 0 || bHi !== 0) {\n    54→    // Find next set bit in a\n    55→    let posA: number;\n    56→    if (aLo !== 0) {\n    57→      posA = 31 - Math.clz32(aLo & (-aLo));\n    58→      aLo ^= (1 << posA) >>> 0;\n    59→    } else if (aHi !== 0) {\n    60→      posA = 32 + (31 - Math.clz32(aHi & (-aHi)));\n    61→      aHi ^= (1 << (posA - 32)) >>> 0;\n    62→    } else {\n    63→      // a exhausted, b has more -> a is shorter -> a < b\n    64→      return true;\n    65→    }\n    66→\n    67→    // Find next set bit in b\n    68→    let posB: number;\n    69→    if (bLo !== 0) {\n    70→      posB = 31 - Math.clz32(bLo & (-bLo));\n    71→      bLo ^= (1 << posB) >>> 0;\n    72→    } else if (bHi !== 0) {\n    73→      posB = 32 + (31 - Math.clz32(bHi & (-bHi)));\n    74→      bHi ^= (1 << (posB - 32)) >>> 0;\n    75→    } else {\n    76→      // b exhausted, a has more -> b is shorter -> a > b\n    77→      return false;\n    78→    }\n    79→\n    80→    if (posA < posB) return true;\n    81→    if (posA > posB) return false;\n    82→  }\n    83→  return false; // equal\n    84→}\n    85→\n    86→export function solveToggle(machine: Machine): number[] | null {\n    87→  const numLights = machine.target.length;\n    88→  const numButtons = machine.buttons.length;\n    89→\n    90→  // Build augmented matrix over GF(2).\n    91→  // Row i: bit j set if button j affects light i. Bit numButtons = target[i].\n    92→  const rows: Pair[] = [];\n    93→  for (let i = 0; i < numLights; i++) {\n    94→    const row = pairNew();\n    95→    for (let j = 0; j < numButtons; j++) {\n    96→      if (machine.buttons[j].includes(i)) {\n    97→        pairSetBit(row, j);\n    98→      }\n   