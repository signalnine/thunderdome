  });\n    expect(result).toEqual([0]);\n  });\n\n  it('handles overlapping toggles with XOR behavior', () => {\n    const result = solveToggle({\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('handles larger instance with identity buttons', () => {\n    // 10 lights, 10 buttons, each button toggles one light (identity matrix)\n    const buttons = Array.from({ length: 10 }, (_, i) => [i]);\n    const target = Array.from({ length: 10 }, (_, i) => i % 2 === 0);\n    // Need to press buttons 0, 2, 4, 6, 8\n    const result = solveToggle({ target, buttons });\n    expect(result).toEqual([0, 2, 4, 6, 8]);\n  });\n\n  it('lex tie-breaking: prefers earlier indices when same count', () => {\n    // 2 lights, 3 buttons\n    // Button 0: toggles [0, 1]\n    // Button 1: toggles [0]\n    // Button 2: toggles [1]\n    // Target: [true, true]\n    // Solutions: {0} (1 press) or {1,2} (2 presses)\n    // Minimum is {0}\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0, 1], [0], [1]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('handles case with many free variables efficiently', () => {\n    // 5 lights, 40 buttons - many redundant buttons creating 35 free vars\n    const buttons: number[][] = [];\n    for (let i = 0; i < 40; i++) {\n      buttons.push([i % 5]); // button i toggles light (i%5)\n    }\n    const target = [true, true, true, true, true];\n    const result = solveToggle({ target, buttons });\n    expect(result).not.toBeNull();\n    expect(result!.length).toBe(5);\n    // Verify correctness\n    const state = new Array(5).fill(false);\n    for (const btnIdx of result!) {\n      for (const lightIdx of buttons[btnIdx]) {\n        state[lightIdx] = !state[lightIdx];\n      }\n    }\n    expect(state).toEqual(target);\n    // Verify lex smallest: should prefer earliest button indices\n    expect(result).toEqual([0, 1, 2, 3, 4]);\n  });\n\n  it