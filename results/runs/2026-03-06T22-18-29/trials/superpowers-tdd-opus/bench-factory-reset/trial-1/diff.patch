+      const d_i = temp % p;
+      temp = Math.floor(temp / p);
+      const pd_i = ((d_i - effectMatrix[i][f] * v) % p + p) % p;
+      prevState += pd_i * powers[i];
+    }
+    state = prevState;
+  }
+
+  const solution = new Array(numButtons).fill(0);
+  for (let f = 0; f < numFree; f++) {
+    solution[freeVars[f]] = freeVals[f];
+  }
+  for (let i = 0; i < rank; i++) {
+    let val = matrix[i][numButtons];
+    for (let f = 0; f < numFree; f++) {
+      val = ((val - effectMatrix[i][f] * freeVals[f]) % modulus + modulus) % modulus;
+    }
+    solution[pivotCol[i]] = val;
+  }
+  return solution;
+}
+
+function greedyOptimize(
+  freeVars: number[], pivotCol: number[],
+  effectMatrix: number[][], matrix: number[][],
+  numButtons: number, numFree: number, rank: number, modulus: number
+): number[] {
+  // Try each free variable independently, greedily setting to minimize cost
+  const freeVals = new Array(numFree).fill(0);
+
+  for (let f = 0; f < numFree; f++) {
+    let bestVal = 0;
+    let bestCost = Infinity;
+    for (let v = 0; v < modulus; v++) {
+      freeVals[f] = v;
+      // Compute total cost with current assignment
+      let cost = 0;
+      for (let ff = 0; ff < numFree; ff++) cost += freeVals[ff];
+      for (let i = 0; i < rank; i++) {
+        let val = matrix[i][numButtons];
+        for (let ff = 0; ff < numFree; ff++) {
+          val = ((val - effectMatrix[i][ff] * freeVals[ff]) % modulus + modulus) % modulus;
+        }
+        cost += val;
+      }
+      if (cost < bestCost) {
+        bestCost = cost;
+        bestVal = v;
+      }
+    }
+    freeVals[f] = bestVal;
+  }
+
+  const solution = new Array(numButtons).fill(0);
+  for (let f = 0; f < numFree; f++) {
+    solution[freeVars[f]] = freeVals[f];
+  }
+  for (let i = 0; i < rank; i++) {
+    let val = matrix[i][numButtons];
+    for (let f = 0; f < numFree; f++) {
+      val = ((val - effectMatrix[i][f] * freeVals[f]) % modulus + modulus) % modulus;
+    }
+    solution[pivotCol[i]] = val;
+  }
+  return solution;
+}
