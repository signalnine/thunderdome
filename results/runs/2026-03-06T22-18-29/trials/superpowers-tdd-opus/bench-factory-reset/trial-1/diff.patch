air { return [0, 0]; }\nfunction pairSetBit(p: Pair, bit: number): void {\n  if (bit < 32) p[0] |= (1 << bit) >>> 0;\n  else p[1] |= (1 << (bit - 32)) >>> 0;\n}\nfunction pairGetBit(p: Pair, bit: number): number {\n  if (bit < 32) return (p[0] >>> bit) & 1;\n  return (p[1] >>> (bit - 32)) & 1;\n}\nfunction pairXorMut(a: Pair, b: Pair): void {\n  a[0] = (a[0] ^ b[0]) >>> 0;\n  a[1] = (a[1] ^ b[1]) >>> 0;\n}\nfunction pairXor(a: Pair, b: Pair): Pair {\n  return [(a[0] ^ b[0]) >>> 0, (a[1] ^ b[1]) >>> 0];\n}\nfunction pairClone(p: Pair): Pair { return [p[0], p[1]]; }\nfunction pairIsZero(p: Pair): boolean { return p[0] === 0 && p[1] === 0; }\n\nfunction popcount32(x: number): number {\n  x = x - ((x >> 1) & 0x55555555);\n  x = (x & 0x33333333) + ((x >> 2) & 0x33333333);\n  x = (x + (x >> 4)) & 0x0f0f0f0f;\n  return (x * 0x01010101) >> 24;\n}\n\nfunction pairPopcount(p: Pair): number {\n  return popcount32(p[0]) + popcount32(p[1]);\n}\n\nfunction pairToSortedArray(p: Pair, maxBits: number): number[] {\n  const result: number[] = [];\n  for (let i = 0; i < maxBits; i++) {\n    if (pairGetBit(p, i)) result.push(i);\n  }\n  return result;\n}\n\n// Lex comparison of sorted bit sets: returns true if a < b lex.\n// Compares the sorted arrays of set bit positions element by element.\nfunction pairLexSmaller(a: Pair, b: Pair): boolean {\n  // We scan both bitmasks together from lowest bit upward, comparing\n  // corresponding elements in the sorted set representation.\n  // We combine lo and hi into a unified scan using bit position tracking.\n  let aLo = a[0] >>> 0, aHi = a[1] >>> 0;\n  let bLo = b[0] >>> 0, bHi = b[1] >>> 0;\n\n  // Process lo bits (0-31) first\n  while (aLo !== 0 || bLo !== 0 || aHi !== 0 || bHi !== 0) {\n    // Find next set bit in a\n    let posA: number;\n    if (aLo !== 0) {\n      posA = 31 - Math.clz32(aLo & (-aLo));\n      aLo ^= (1 << posA) >>> 0;\n    } else if (aHi !== 0) {\n      posA = 32 + (31 - Math.clz32(aHi & (-aHi)));\n      aHi ^= (1 << (posA - 32)) >>> 0;\n    } else {\n      // a exhausted, b has more -> a is shorter -> a < b\n      return true;\n    }\n\n    // Find next set bit in b\n    let posB: number;\n    if (bLo !== 0) {\n      posB = 31 - Math.clz32(bLo & (-bLo));\n      bLo ^= (1 << posB) >>> 0;\n    } else if (bHi !== 0) {\n      posB = 32 + (31 - Math.clz32(bHi & (-bHi)));\n      bHi ^= (1 << (posB - 32)) >>> 0;\n    } else {\n      // b exhausted, a has more -> b is shorter -> a > b\n      return false;\n    }\n\n    if (posA < posB) return true;\n    if (posA > posB) return false;\n  }\n  return false; // equal\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const numLights = machine.target.length;\n  const numButtons = machine.buttons.length;\n\n  // Build augmented matrix over GF(2).\n  // Row i: bit j set if button j affects light i. Bit numButtons = target[i].\n  const rows: Pair[] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = pairNew();\n    for (let j = 0; j < numButtons; j++) {\n      if (machine.buttons[j].includes(i)) {\n        pairSetBit(row, j);\n      }\n    }\n    if (machine.target[i]) {\n      pairSetBit(row, numButtons);\n    }\n    rows.push(row);\n  }\n\n  // Gaussian elimination over GF(2) - RREF\n  const pivotCol: number[] = [];\n  let curRow = 0;\n  for (let col = 0; col < numButtons; col++) {\n    let pivotRow = -1;\n    for (let r = curRow; r < numLights; r++) {\n      if (pairGetBit(rows[r], col)) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    [rows[curRow], rows[pivotRow]] = [rows[pivotRow], rows[curRow]];\n    pivotCol.push(col);\n\n    for (let r = 0; r < numLights; r++) {\n      if (r !== curRow && pairGetBit(rows[r], col)) {\n        pairXorMut(rows[r], rows[curRow]);\n      }\n    }\n    curRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < numLights; r++) {\n    if (pairGetBit(rows[r], numButtons)) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (!pivotSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Base solution (all free vars = 0)\n  const baseSol = pairNew();\n  for (let i = 0; i < rank; i++) {\n    if (pairGetBit(rows[i], numButtons)) {\n      pairSetBit(baseSol, pivotCol[i]);\n    }\n  }\n\n  // Effect vectors: toggling free var f changes these bits\n  const effectVec: Pair[] = [];\n  for (let f = 0; f < numFree; f++) {\n    const effect = pairNew();\n    pairSetBit(effect, freeVars[f]); // the free var itself\n    for (let i = 0; i < rank; i++) {\n      if (pairGetBit(rows[i], freeVars[f])) {\n        pairSetBit(effect, pivotCol[i]);\n      }\n    }\n    effectVec.push(effect);\n  }\n\n  // Find minimum weight solution\n  const searchDim = Math.min(numFree, rank);\n\n  if (searchDim <= 25) {\n    if (numFree <= 25) {\n      return searchByFreeVars(baseSol, effectVec, numFree, numButtons);\n    } else {\n      return searchByPivotTargets(baseSol, effectVec, freeVars, pivotCol, rows, rank, numFree, numButtons);\n    }\n  }\n\n  // Both rank and numFree > 25: shouldn't happen since rank + numFree <= 40\n  return pairToSortedArray(baseSol, numButtons);\n}\n\nfunction searchByFreeVars(\n  baseSol: Pair,\n  effectVec: Pair[],\n  numFree: number,\n  numButtons: number\n): number[] {\n  let bestSol = pairClone(baseSol);\n  let bestWeight = pairPopcount(baseSol);\n\n  const total = 1 << numFree;\n  const sol = pairClone(baseSol);\n  let prevGray = 0;\n  for (let i = 1; i < total; i++) {\n    const gray = i ^ (i >> 1);\n    const diff = gray ^ prevGray;\n    const f = 31 - Math.clz32(diff);\n    pairXorMut(sol, effectVec[f]);\n    prevGray = gray;\n    const w = pairPopcount(sol);\n    if (w < bestWeight || (w === bestWeight && pairLexSmaller(sol, bestSol))) {\n      bestWeight = w;\n      bestSol[0] = sol[0];\n      bestSol[1] = sol[1];\n    }\n  }\n  return pairToSortedArray(bestSol, numButtons);\n}\n\nfunction searchByPivotTargets(\n  baseSol: Pair,\n  effectVec: Pair[],\n  freeVars: number[],\n  pivotCol: number[],\n  rows: Pair[],\n  rank: number,\n  numFree: number,\n  numButtons: number\n): number[] {\n  // When rank is small but numFree is large, enumerate over pivot target values.\n  // For each of the 2^rank pivot value assignments, determine the minimum-weight\n  // free variable assignment that achieves it.\n  //\n  // Each pivot equation i: pivot_i = b_i XOR sum_f(a_{if} * x_f)\n  // For target pivot_i = v_i: sum_f(a_{if} * x_f) = v_i XOR b_i = d_i\n  //\n  // Build the \"pivot effect\" matrix: for each free var f, which pivots does it affect?\n  // This is a rank-bit pattern per free variable.\n  const freeEffectOnPivots: number[] = []; // freeEffectOnPivots[f] = bitmask of which pivots are affected\n  for (let f = 0; f < numFree; f++) {\n    let pattern = 0;\n    for (let i = 0; i < rank; i++) {\n      if (pairGetBit(rows[i], freeVars[f])) {\n        pattern |= (1 << i);\n      }\n    }\n    freeEffectOnPivots.push(pattern);\n  }\n\n  // Base pivot values (when all free vars = 0)\n  let basePivotPattern = 0;\n  for (let i = 0; i < rank; i++) {\n    if (pairGetBit(baseSol, pivotCol[i])) {\n      basePivotPattern |= (1 << i);\n    }\n  }\n\n  // Group free variables by their pivot effect pattern.\n  // Free vars with the same pattern are interchangeable for pivot effects.\n  // To minimize weight, we want the fewest free vars set to 1.\n  // Among vars with the same pattern, prefer the lex-smallest indices.\n  const patternToFreeVars = new Map<number, number[]>();\n  for (let f = 0; f < numFree; f++) {\n    const p = freeEffectOnPivots[f];\n    if (!patternToFreeVars.has(p)) {\n      patternToFreeVars.set(p, []);\n    }\n    patternToFreeVars.get(p)!.push(f);\n  }\n\n  // Free vars with pattern 0 don't affect any pivot -> always set to 0\n  // Free vars with non-zero pattern: we need to select a subset that XORs to the desired delta.\n\n  // Get unique non-zero patterns and their associated free vars\n  const uniquePatterns: number[] = [];\n  const patternFreeVarsList: number[][] = [];\n  for (const [pat, fvs] of patternToFreeVars) {\n    if (pat !== 0) {\n      uniquePatterns.push(pat);\n      patternFreeVarsList.push(fvs);\n    }\n  }\n\n  // For each target pivot pattern (2^rank combinations):\n  // We need: XOR of selected free var effects = target XOR basePivotPattern\n  // And we want to minimize: count of selected free vars + popcount(target)\n  // (popcount(target) = number of pivots that are 1)\n\n  let bestSol: Pair | null = null;\n  let bestWeight = numButtons + 1;\n\n  const totalPivotCombos = 1 << rank;\n  for (let target = 0; target < totalPivotCombos; target++) {\n    const pivotWeight = popcount32(target);\n    if (pivotWeight >= bestWeight) continue; // Can't improve even with 0 free vars\n\n    const delta = target ^ basePivotPattern; // What free vars must produce on pivots\n\n    // Find minimum number of free vars needed to produce delta, preferring lex-smallest.\n    // This is itself a small optimization problem over the unique patterns.\n    // Use BFS/dynamic programming over the pattern space (2^rank states).\n    // dp[state] = minimum free vars to reach this state, with lex-smallest selection\n\n    // Since rank ≤ 20 (actually ≤ 15 in this branch), 2^rank ≤ 32768\n    // But we may have many unique patterns. Use BFS approach.\n\n    // Actually, let's use a simpler approach: since we need to find which patterns\n    // to select (each at most once, but we have multiple free vars per pattern),\n    // and each pattern can be toggled 0 or more times (even times cancel out),\n    // effectively each unique pattern contributes 0 or 1 to the XOR.\n    // An even number of free vars with the same pattern = net 0 effect.\n    // An odd number = net 1 effect.\n    // To minimize total count: use 1 var if we need odd, 0 if even.\n    // So effectively each unique non-zero pattern is either \"used\" (1 var, +1 weight) or \"not used\" (0 vars, +0 weight).\n    // We need the XOR of selected patterns to equal delta.\n\n    // This is again a minimum weight XOR problem but over at most ~min(numFree, 2^rank) patterns.\n    // With rank ≤ 15, there are at most 2^15 - 1 = 32767 possible non-zero patterns,\n    // but the number of unique patterns with available free vars is at most numFree ≤ 40.\n    // So we have at most 40 items.\n\n    // With ≤ 40 items and ≤ 15 bit state, use DP:\n    // dp[state] = {minCost, lexBest free var selection}\n    // Actually simpler: since each pattern either contributes or doesn't (0 or 1 weight each),\n    // and there are at most 40 unique patterns with ≤ 15 bits each,\n    // we can use Gaussian elimination on the patterns to find the minimum weight solution.\n    // But that's complex. Since there are ≤ 40 patterns, just use DP over the 2^rank states.\n\n    const numPat = uniquePatterns.length;\n    // dp[state] = minimum number of patterns to XOR to reach state\n    // We also need to track which patterns were used for lex ordering.\n    // Use BFS approach.\n    const INF = numPat + 1;\n    const dpCost = new Int32Array(1 << rank).fill(INF);\n    // Track parent for reconstruction\n    const dpFrom = new Int32Array(1 << rank).fill(-1); // which pattern was added\n    const dpPrev = new Int32Array(1 << rank).fill(-1); // previous state\n\n    dpCost[0] = 0;\n\n    // Process patterns in order (lex-smallest free var first)\n    for (let p = 0; p < numPat; p++) {\n      const pat = uniquePatterns[p];\n      // Process in reverse to avoid using same pattern twice\n      for (let s = (1 << rank) - 1; s >= 0; s--) {\n        if (dpCost[s] < INF) {\n          const ns = s ^ pat;\n          const nc = dpCost[s] + 1;\n          if (nc < dpCost[ns]) {\n            dpCost[ns] = nc;\n            dpFrom[ns] = p;\n            dpPrev[ns] = s;\n          }\n        }\n      }\n    }\n\n    if (dpCost[delta] >= INF) continue; // Can't achieve this pivot target\n\n    const freeVarWeight = dpCost[delta];\n    const totalWeight = pivotWeight + freeVarWeight;\n\n    if (totalWeight > bestWeight) continue;\n\n    // Reconstruct which patterns were used\n    const usedPatterns: number[] = [];\n    let state = delta;\n    while (state !== 0) {\n      const p = dpFrom[state];\n      usedPatterns.push(p);\n      state = dpPrev[state];\n    }\n\n    // Build the solution\n    const sol = pairNew();\n\n    // Set pivot bits according to target\n    for (let i = 0; i < rank; i++) {\n      if ((target >> i) & 1) {\n        pairSetBit(sol, pivotCol[i]);\n      }\n    }\n\n    // For each used pattern, pick the lex-smallest free var\n    const usedFreeVarIndices: number[] = [];\n    for (const p of usedPatterns) {\n      // Pick the lex-smallest free var with this pattern\n      const fv = patternFreeVarsList[p][0]; // already sorted (freeVars are in order)\n      usedFreeVarIndices.push(freeVars[fv]);\n    }\n\n    for (const fvIdx of usedFreeVarIndices) {\n      pairSetBit(sol, fvIdx);\n    }\n\n    const w = pairPopcount(sol);\n    if (bestSol === null || w < bestWeight || (w === bestWeight && pairLexSmaller(sol, bestSol))) {\n      bestWeight = w;\n      bestSol = sol;\n    }\n  }\n\n  if (bestSol === null) {\n    return pairToSortedArray(baseSol, numButtons);\n  }\n  return pairToSortedArray(bestSol, numButtons);\n}\n\nexport function solveCounter(\n  _lights: number[],\n  _buttons: number[][],\n  _modulus: number\n): number[] | null {\n  throw new Error('Not implemented');\n}\n","structuredPatch":[{"oldStart":217,"oldLines":7,"newStart":217,"newLines":7,"lines":[" "," function searchByPivotTargets(","   baseSol: Pair,","-  effectVec: Pair[],","+  _effectVec: Pair[],","   freeVars: number[],","   pivotCol: number[],","   rows: Pair[],"]},{"oldStart":225,"oldLines":16,"newStart":225,"new