t(effect, freeVars[f]); // the free var itself\n   163→    for (let i = 0; i < rank; i++) {\n   164→      if (pairGetBit(rows[i], freeVars[f])) {\n   165→        pairSetBit(effect, pivotCol[i]);\n   166→      }\n   167→    }\n   168→    effectVec.push(effect);\n   169→  }\n   170→\n   171→  // Find minimum weight solution\n   172→  const searchDim = Math.min(numFree, rank);\n   173→\n   174→  if (searchDim <= 25) {\n   175→    if (numFree <= 25) {\n   176→      return searchByFreeVars(baseSol, effectVec, numFree, numButtons);\n   177→    } else {\n   178→      return searchByPivotTargets(baseSol, effectVec, freeVars, pivotCol, rows, rank, numFree, numButtons);\n   179→    }\n   180→  }\n   181→\n   182→  // Both rank and numFree > 25: shouldn't happen since rank + numFree <= 40\n   183→  return pairToSortedArray(baseSol, numButtons);\n   184→}\n   185→\n   186→function searchByFreeVars(\n   187→  baseSol: Pair,\n   188→  effectVec: Pair[],\n   189→  numFree: number,\n   190→  numButtons: number\n   191→): number[] {\n   192→  const bestSol = pairClone(baseSol);\n   193→  let bestWeight = pairPopcount(baseSol);\n   194→\n   195→  const total = 1 << numFree;\n   196→  const sol = pairClone(baseSol);\n   197→  let prevGray = 0;\n   198→  for (let i = 1; i < total; i++) {\n   199→    const gray = i ^ (i >> 1);\n   200→    const diff = gray ^ prevGray;\n   201→    const f = 31 - Math.clz32(diff);\n   202→    pairXorMut(sol, effectVec[f]);\n   203→    prevGray = gray;\n   204→    const w = pairPopcount(sol);\n   205→    if (w < bestWeight || (w === bestWeight && pairLexSmaller(sol, bestSol))) {\n   206→      bestWeight = w;\n   207→      bestSol[0] = sol[0];\n   208→      bestSol[1] = sol[1];\n   209→    }\n   210→  }\n   211→  return pairToSortedArray(bestSol, numButtons);\n   212→}\n   213→\n   214→function searchByPivotTargets(\n   215→  baseSol: Pair,\n   216→  _effectVec: Pair[],\n   217→  freeVars: number[],\n   218→  pivotCol: number[],\n   219→  rows: Pair[],\n   220→  rank: number,\n   221→  numFree: number,\n   222→  numButtons: number\n   223→): number[] {\n   224→  // When rank is small (≤ 20) but numFree is large, enumerate efficiently.\n   225→  // Each free var has a \"pivot effect pattern\" (rank-bit number).\n   226→  // Group free vars by pattern, then use DP over 2^rank states to find\n   227→  // minimum cost selections.\n   228→\n   229→  const freeEffectOnPivots: number[] = [];\n   230→  for (let f = 0; f < numFree; f++) {\n   231→    let pattern = 0;\n   232→    for (let i = 0; i < rank; i++) {\n   233→      if (pairGetBit(rows[i], freeVars[f])) {\n   234→        pattern |= (1 << i);\n   235→      }\n   236→    }\n   237→    freeEffectOnPivots.push(pattern);\n   238→  }\n   239→\n   240→  let basePivotPattern = 0;\n   241→  for (let i = 0; i < rank; i++) {\n   242→    if (pairGetBit(baseSol, pivotCol[i])) {\n   243→      basePivotPattern |= (1 << i);\n   244→    }\n   245→  }\n   246→\n   247→  // Group free vars by pivot effect pattern\n   248→  const patternToFreeVars = new Map<number, number[]>();\n   249→  for (let f = 0; f < numFree; f++) {\n   250→    const p = freeEffectOnPivots[f];\n   251→    if (!patternToFreeVars.has(p)) {\n   252→      patternToFreeVars.set(p, []);\n   253→    }\n   254→    patternToFreeVars.get(p)!.push(f);\n   255→  }\n   256→\n   257→  // Get unique non-zero patterns\n   258→  const uniquePatterns: number[] = [];\n   259→  const patternFreeVarsList: number[][] = [];\n   260→  for (const [pat, fvs] of patternToFreeVars) {\n   261→    if (pat !== 0) {\n   262→      uniquePatterns.push(pat);\n   263→      patternFreeVarsList.push(fvs);\n   264→    }\n   265→  }\n   266→\n   267→  const numPat = uniquePatterns.length;\n   268→  const stateSize = 1 << rank;\n   269→\n   270→  // DP: compute minimum number of patterns to XOR to reach each state.\n   271→  // 0-1 knapsack style: each pattern used at most once.\n   272→  const INF = numPat + 1;\n   273→  const dpCost = new Int32Array(stateSize).fill(INF);\n   274→  const dpFrom = new Int32Array(stateSize).fill(-1);\n   275→  const dpPrev = new Int32Array(stateSize).fill(-1);\n   276→  dpCost[0] = 0;\n   277→\n   278→  // Process patterns in lex order of their smallest free var (already ordered)\n   279→  for (let p = 0; p < numPat; p++) {\n   280→    const pat = uniquePatterns[p];\n   281→    // Reverse iterate to ensure each pattern used at most once\n   282→    for (let s = stateSize - 1; s >= 0; s--) {\n   283→      if (dpCost[s] < INF) {\n   284→        const ns = s ^ pat;\n   285→        const nc = dpCost[s] + 1;\n   286→        if (nc < dpCost[ns]) {\n   287→          dpCost[ns] = nc;\n   288→          dpFrom[ns] = p;\n   289→          dpPrev[ns] = s;\n   290→        }\n   291→      }\n   292→    }\n   293→  }\n   294→\n   295→  // Now find best pivot target: minimize popcount(target) + dpCost[target XOR basePivotPattern]\n   296→  let bestSol: Pair | null = null;\n   297→  let bestWeight = numButtons + 1;\n   298→\n   299→  for (let target = 0; target < stateSize; target++) {\n   300→    const delta = target ^ basePivotPattern;\n   301→    if (dpCost[delta] >= INF) continue;\n   302→\n   303→    const pivotWeight = popcount32(target);\n   304→    const freeVarWeight = dpCost[delta];\n   305→    const totalWeight = pivotWeight + freeVarWeight;\n   306→\n   307→    if (totalWeight > bestWeight) continue;\n   308→\n   309→    // Reconstruct which patterns were used\n   310→    const usedPatternIndices: number[] = [];\n   311→    let state = delta;\n   312→    while (state !== 0) {\n   313→      usedPatternIndices.push(dpFrom[state]);\n   314→      state = dpPrev[state];\n   315→    }\n   316→\n   317→    // Build the solution\n   318→    const sol = pairNew();\n   319→\n   320→    // Set pivot bits\n   321→    for (let i = 0; i < rank; i++) {\n   322→      if ((target >> i) & 1) {\n   323→        pairSetBit(sol, pivotCol[i]);\n   324→      }\n   325→    }\n   326→\n   327→    // For each used pattern, pick the lex-smallest free var (freeVars[0] of that pattern)\n   328→    for (const p of usedPatternIndices) {\n   329→      const fv = patternFreeVarsList[p][0];\n   330→      pairSetBit(sol, freeVars[fv]);\n   331→    }\n   332→\n   333→    const w = pairPopcount(sol);\n   334→    if (bestSol === null || w < bestWeight || (w === bestWeight && pairLexSmaller(sol, bestSol))) {\n   335→      bestWeight = w;\n   336→      bestSol = pairClone(sol);\n   337→    }\n   338→  }\n   339→\n   340→  if (bestSol === null) {\n   341→    return pairToSortedArray(baseSol, numButtons);\n   342→  }\n   343→  return pairToSortedArray(bestSol, numButtons);\n   344→}\n   345→\n   346→function modInverse(a: number, m: number): number {\n   347→  a = ((a % m) + m) % m;\n   348→  let [old_r, r] = [a, m];\n   349→  let [old_s, s] = [1, 0];\n   350→  while (r !== 0) {\n   351→    const q = Math.floor(old_r / r);\n   352→    [old_r, r] = [r, old_r - q * r];\n   353→    [old_s, s] = [s, old_s - q * s];\n   354→  }\n   355→  return ((old_s % m) + m) % m;\n   356→}\n   357→\n   358→function lexSmallerArrayNum(a: number[], b: number[]): boolean {\n   359→  for (let i = 0; i < a.length; i++) {\n   360→    if (a[i] < b[i]) return true;\n   361→    if (a[i] > b[i]) return false;\n   362→  }\n   363→  return false;\n   364→}\n   365→\n   366→export function solveCounter(\n   367→  lights: number[],\n   368→  buttons: number[][],\n   369→  modulus: number\n   370→): number[] | null {\n   371→  const numCounters = lights.length;\n   372→  const numButtons = buttons.length;\n   373→\n   374→  // Build augmented matrix: rows = counters, columns = buttons + augment\n   375→  const matrix: number[][] = [];\n   376→  for (let i = 0; i < numCounters; i++) {\n   377→    const row = new Array(numButtons + 1).fill(0);\n   378→    for (let j = 0; j < numButtons; j++) {\n   379→      if (buttons[j].includes(i)) {\n   380→        row[j] = 1;\n   381→      }\n   382→    }\n   383→    row[numButtons] = lights[i];\n   384→    matrix.push(row);\n   385→  }\n   386→\n   387→  // Gaussian elimination over GF(modulus)\n   388→  const pivotCol: number[] = [];\n   389→  let curRow = 0;\n   390→  for (let col = 0; col < numButtons; col++) {\n   391→    let pivotRow = -1;\n   392→    for (let r = curRow; r < numCounters; r++) {\n   393→      if (matrix[r][col] !== 0) {\n   394→        pivotRow = r;\n   395→        break;\n   396→      }\n   397→    }\n   398→    if (pivotRow === -1) continue;\n   399→\n   400→    [matrix[curRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[curRow]];\n   401→    pivotCol.push(col);\n   402→\n   403→    const inv = modInverse(matrix[curRow][col], modulus);\n   404→    for (let j = 0; j <= numButtons; j++) {\n   405→      matrix[curRow][j] = (matrix[curRow][j] * inv) % modulus;\n   406→    }\n   407→\n   408→    for (let r = 0; r < numCounters; r++) {\n   409→      if (r !== curRow && matrix[r][col] !== 0) {\n   410→        const factor = matrix[r][col];\n   411→        for (let j = 0; j <= numButtons; j++) {\n   412→          matrix[r][j] = ((matrix[r][j] - factor * matrix[curRow][j]) % modulus + modulus) % modulus;\n   413→        }\n   414→      }\n   415→    }\n   416→    curRow++;\n   417→  }\n   418→\n   419→  const rank = pivotCol.length;\n   420→\n   421→  // Check for inconsistency\n   422→  for (let r = rank; r < numCounters; r++) {\n   423→    if (matrix[r][numButtons] !== 0) {\n   424→      return null;\n   425→    }\n   426→  }\n   427→\n   428→  // Identify free variables\n   429→  const pivotSet = new Set(pivotCol);\n   430→  const freeVars: number[] = [];\n   431→  for (let j = 0; j < numButtons; j++) {\n   432→    if (!pivotSet.has(j)) {\n   433→      freeVars.push(j);\n   434→    }\n   435→  }\n   436→\n   437→  const numFree = freeVars.length;\n   438→\n   439→  // Precompute effect matrix: effectMatrix[i][f] = coefficient of free var f in pivot eq i\n   440→  const effectMatrix: number[][] = [];\n   441→  for (let i = 0; i < rank; i++) {\n   442→    const effects: number[] = [];\n   443→    for (let f = 0; f < numFree; f++) {\n   444→      effects.push(matrix[i][freeVars[f]]);\n   445→    }\n   446→    effectMatrix.push(effects);\n   447→  }\n   448→\n   449→  // Compute solution for given free variable assignments\n   450→  function computeSolution(freeVals: number[]): number[] {\n   451→    const solution = new Array(numButtons).fill(0);\n   452→    for (let f = 0; f < numFree; f++) {\n   453→      solution[freeVars[f]] = freeVals[f];\n   454→    }\n   455→    for (let i = 0; i < rank; i++) {\n   456→      let val = matrix[i][numButtons];\n   457→      for (let f = 0; f < numFree; f++) {\n   458→        val = ((val - effectMatrix[i][f] * freeVals[f]) % modulus + modulus) % modulus;\n   459→      }\n   460→      solution[pivotCol[i]] = val;\n   461→    }\n   462→    return solution;\n   463→  }\n   464→\n   465→  if (numFree === 0) {\n   466→    // Unique solution\n   467→    return computeSolution([]);\n   468→  }\n   469→\n   470→  // Estimate search space for direct enumeration\n   471→  let searchSpace = 1;\n   472→  let feasible = true;\n   473→  for (let f = 0; f < numFree; f++) {\n   474→    searchSpace *= modulus;\n   475→    if (searchSpace > 5_000_000) { feasible = false; break; }\n   476→  }\n   477→\n   478→  if (feasible) {\n   479→    return enumerateFreeVars(\n   480→      freeVars, pivotCol, effectMatrix, matrix,\n   481→      numButtons, numFree, rank, modulus\n   482→    );\n   483→  }\n   484→\n   485→  // For larger cases, use DP over pivot residue states if rank is small\n   486→  // State: accumulated effect on each pivot (mod p), encoded as a single number\n   487→  // state = sum_i(effect_i * p^i), giving p^rank states\n   488→  let dpStateSize = 1;\n   489→  let dpFeasible = true;\n   490→  for (let i = 0; i < rank; i++) {\n   491→    dpStateSize *= modulus;\n   492→    if (dpStateSize > 5_000_000) { dpFeasible = false; break; }\n   493→  }\n   494→\n   495→  if (dpFeasible) {\n   496→    return dpOverPivotStates(\n   497→      freeVars, pivotCol, effectMatrix, matrix,\n   498→      numButtons, numFree, rank, modulus, dpStateSize\n   499→    );\n   500→  }\n   501→\n   502→  // Fallback: use base solution (all free vars = 0)\n   503→  // Then try each free var independently to see if setting it improves things\n   504→  return greedyOptimize(\n   505→    freeVars, pivotCol, effectMatrix, matrix,\n   506→    numButtons, numFree, rank, modulus\n   507→  );\n   508→}\n   509→\n   510→function enumerateFreeVars(\n   511→  freeVars: number[], pivotCol: number[],\n   512→  effectMatrix: number[][], matrix: number[][],\n   513→  numButtons: number, numFree: number, rank: number, modulus: number\n   514→): number[] {\n   515→  let bestSolution: number[] | null = null;\n   516→  let bestTotal = Infinity;\n   517→\n   518→  function enumerate(freeIdx: number, freeVals: number[], freeTotal: number): void {\n   519→    if (freeTotal > bestTotal) return;\n   520→\n   521→    if (freeIdx === numFree) {\n   522→      const solution = new Array(numButtons).fill(0);\n   523→      for (let f = 0; f < numFree; f++) {\n   524→        solution[freeVars[f]] = freeVals[f];\n   525→      }\n   526→      let pivotTotal = 0;\n   527→      for (let i = 0; i < rank; i++) {\n   528→        let val = matrix[i][numButtons];\n   529→        for (let f = 0; f < numFree; f++) {\n   530→          val = ((val - effectMatrix[i][f] * freeVals[f]) % modulus + modulus) % modulus;\n   531→        }\n   532→        solution[pivotCol[i]] = val;\n   533→        pivotTotal += val;\n   534→      }\n   535→      const total = freeTotal + pivotTotal;\n   536→      if (total < bestTotal || (total === bestTotal && lexSmallerArrayNum(solution, bestSolution!))) {\n   537→        bestTotal = total;\n   538→        bestSolution = [...solution];\n   539→      }\n   540→      return;\n   541→    }\n   542→\n   543→    for (let v = 0; v < modulus; v++) {\n   544→      freeVals[freeIdx] = v;\n   545→      enumerate(freeIdx + 1, freeVals, freeTotal + v);\n   546→    }\n   547→  }\n   548→\n   549→  enumerate(0, new Array(numFree).fill(0), 0);\n   550→  return bestSolution!;\n   551→}\n   552→\n   553→function dpOverPivotStates(\n   554→  freeVars: number[], pivotCol: number[],\n   555→  effectMatrix: number[][], matrix: number[][],\n   556→  numButtons: number, numFree: number, rank: number, modulus: number,\n   557→  stateSize: number\n   558→): number[] {\n   559→  // State encodes accumulated contribution to each pivot: sum_f(eff_{i,f} * x_f) mod p for each pivot i\n   560→  // Encoded as: state = d_0 + d_1*p + d_2*p^2 + ...\n   561→  // where d_i is the accumulated effect on pivot i\n   562→\n   563→  const p = modulus;\n   564→  const INF = numButtons * (p - 1) + 1;\n   565→\n   566→  // dpCost[state] = min cost (sum of free var values) to reach this state\n   567→  // dpChoice[state][f] = value chosen for free var f when transitioning to this state\n   568→  // (for reconstruction)\n   569→\n   570→  // We'll track: dpCost and dpParent for reconstruction\n   571→  let dpCost = new Float64Array(stateSize).fill(INF);\n   572→  dpCost[0] = 0;\n   573→\n   574→  // For each free variable, extend the DP\n   575→  // Also track the choices for reconstruction\n   576→  const choices: number[][] = []; // choices[f] = best value per state\n   577→\n   578→  for (let f = 0; f < numFree; f++) {\n   579→    // Effect of free var f on each pivot: effectMatrix[i][f]\n   580→    const effects: number[] = [];\n   581→    for (let i = 0; i < rank; i++) {\n   582→      effects.push(effectMatrix[i][f]);\n   583→    }\n   584→\n   585→    const newDpCost = new Float64Array(stateSize).fill(INF);\n   586→    const choice = new Array(stateSize).fill(0);\n   587→\n   588→    // Precompute power of p for state encoding\n   589→    const powers: number[] = [];\n   590→    let pw = 1;\n   591→    for (let i = 0; i < rank; i++) {\n   592→      powers.push(pw);\n   593→      pw *= p;\n   594→    }\n   595→\n   596→    for (let s = 0; s < stateSize; s++) {\n   597→      if (dpCost[s] >= INF) continue;\n   598→\n   599→      for (let v = 0; v < p; v++) {\n   600→        let temp = s;\n   601→        let ns = 0;\n   602→        for (let i = 0; i < rank; i++) {\n   603→          const d_i = temp % p;\n   604→          temp = Math.floor(temp / p);\n   605→          const nd_i = (d_i + effects[i] * v) % p;\n   606→          ns += nd_i * powers[i];\n   607→        }\n   608→\n   609→        const nc = dpCost[s] + v;\n   610→        if (nc < newDpCost[ns] || (nc === newDpCost[ns] && v < choice[ns])) {\n   611→          newDpCost[ns] = nc;\n   612→          choice[ns] = v;\n   613→        }\n   614→      }\n   615→    }\n   616→\n   617→    choices.push(choice);\n   618→    dpCost = newDpCost;\n   619→  }\n   620→\n   621→  // Find the target state: the state that, when subtracted from base pivots, gives minimum total\n   622→  // The target state encodes (sum_f(eff_{i,f} * x_f)) mod p for each pivot\n   623→  // Pivot value i = (base_i - state_d_i) mod p\n   624→  // Pivot cost = sum_i((base_i - state_d_i) mod p)\n   625→  // Total cost = dpCost[state] + pivot cost\n   626→  // We want to minimize total cost with lex tie-breaking\n   627→\n   628→  const powers: number[] = [];\n   629→  let pw = 1;\n   630→  for (let i = 0; i < rank; i++) {\n   631→    powers.push(pw);\n   632→    pw *= p;\n   633→  }\n   634→\n   635→  let bestState = -1;\n   636→  let bestTotal = INF;\n   637→\n   638→  for (let s = 0; s < stateSize; s++) {\n   639→    if (dpCost[s] >= INF) continue;\n   640→\n   641→    let pivotCost = 0;\n   642→    let temp = s;\n   643→    for (let i = 0; i < rank; i++) {\n   644→      const d_i = temp % p;\n   645→      temp = Math.floor(temp / p);\n   646→      const base_i = matrix[i][numButtons];\n   647→      pivotCost += (base_i - d_i + p) % p;\n   648→    }\n   649→\n   650→    const total = dpCost[s] + pivotCost;\n   651→    if (total < bestTotal) {\n   652→      bestTotal = total;\n   653→      bestState = s;\n   654→    }\n   655→  }\n   656→\n   657→  if (bestState === -1) {\n   658→    // Fallback to base solution\n   659→    const solution = new Array(numButtons).fill(0);\n   660→    for (let i = 0; i < rank; i++) {\n   661→      solution[pivotCol[i]] = matrix[i][numButtons];\n   662→    }\n   663→    return solution;\n   664→  }\n   665→\n   666→  // Find all states with the same minimum total and pick lex smallest\n   667→  const candidates: number[][] = [];\n   668→  for (let s = 0; s < stateSize; s++) {\n   669→    if (dpCost[s] >= INF) continue;\n   670→    let pivotCost = 0;\n   671→    let temp = s;\n   672→    for (let i = 0; i < rank; i++) {\n   673→      const d_i = temp % p;\n   674→      temp = Math.floor(temp / p);\n   675→      pivotCost += (matrix[i][numButtons] - d_i + p) % p;\n   676→    }\n   677→    const total = dpCost[s] + pivotCost;\n   678→    if (total === bestTotal) {\n   679→      candidates.push(reconstructSolutionFromState(s, freeVars, pivotCol, effectMatrix, matrix, numButtons, numFree, rank, modulus, choices, powers));\n   680→    }\n   681→  }\n   682→\n   683→  // Find lex smallest among candidates\n   684→  let result = candidates[0];\n   685→  for (let c = 1; c < candidates.length; c++) {\n   686→    if (lexSmallerArrayNum(candidates[c], result)) {\n   687→      result = candidates[c];\n   688→    }\n   689→  }\n   690→  return result;\n   691→}\n   692→\n   693→function reconstructSolutionFromState(\n   694→  targetState: number,\n   695→  freeVars: number[], pivotCol: number[],\n   696→  effectMatrix: number[][], matrix: number[][],\n   697→  numButtons: number, numFree: number, rank: number, modulus: number,\n   698→  choices: number[][], powers: number[]\n   699→): number[] {\n   700→  const p = modulus;\n   701→  const freeVals = new Array(numFree).fill(0);\n   702→  let state = targetState;\n   703→\n   704→  for (let f = numFree -