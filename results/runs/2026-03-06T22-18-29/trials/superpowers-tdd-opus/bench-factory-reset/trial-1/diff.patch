pattern, pick the lex-smallest free var (freeVars[0] of that pattern)\n   328→    for (const p of usedPatternIndices) {\n   329→      const fv = patternFreeVarsList[p][0];\n   330→      pairSetBit(sol, freeVars[fv]);\n   331→    }\n   332→\n   333→    const w = pairPopcount(sol);\n   334→    if (bestSol === null || w < bestWeight || (w === bestWeight && pairLexSmaller(sol, bestSol))) {\n   335→      bestWeight = w;\n   336→      bestSol = pairClone(sol);\n   337→    }\n   338→  }\n   339→\n   340→  if (bestSol === null) {\n   341→    return pairToSortedArray(baseSol, numButtons);\n   342→  }\n   343→  return pairToSortedArray(bestSol, numButtons);\n   344→}\n   345→\n   346→function modInverse(a: number, m: number): number {\n   347→  a = ((a % m) + m) % m;\n   348→  let [old_r, r] = [a, m];\n   349→  let [old_s, s] = [1, 0];\n   350→  while (r !== 0) {\n   351→    const q = Math.floor(old_r / r);\n   352→    [old_r, r] = [r, old_r - q * r];\n   353→    [old_s, s] = [s, old_s - q * s];\n   354→  }\n   355→  return ((old_s % m) + m) % m;\n   356→}\n   357→\n   358→function lexSmallerArrayNum(a: number[], b: number[]): boolean {\n   359→  for (let i = 0; i < a.length; i++) {\n   360→    if (a[i] < b[i]) return true;\n   361→    if (a[i] > b[i]) return false;\n   362→  }\n   363→  return false;\n   364→}\n   365→\n   366→export function solveCounter(\n   367→  lights: number[],\n   368→  buttons: number[][],\n   369→  modulus: number\n   370→): number[] | null {\n   371→  const numCounters = lights.length;\n   372→  const numButtons = buttons.length;\n   373→\n   374→  // Build augmented matrix: rows = counters, columns = buttons + augment\n   375→  const matrix: number[][] = [];\n   376→  for (let i = 0; i < numCounters; i++) {\n   377→    const row = new Array(numButtons + 1).fill(0);\n   378→    for (let j = 0; j < numButtons; j++) {\n   379→      if (buttons[j].includes(i)) {\n   380→        row[j] = 1;\n   381→      }\n   382→    }\n   383→    row[numButtons] = li