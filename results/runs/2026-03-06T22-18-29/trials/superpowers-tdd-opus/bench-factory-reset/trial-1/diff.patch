 return solution;\n  }\n\n  // Reconstruct the free variable values\n  const freeVals = new Array(numFree).fill(0);\n  let state = bestState;\n  for (let f = numFree - 1; f >= 0; f--) {\n    const v = choices[f][state];\n    freeVals[f] = v;\n\n    // Compute previous state\n    const effects: number[] = [];\n    for (let i = 0; i < rank; i++) {\n      effects.push(effectMatrix[i][f]);\n    }\n\n    let prevState = 0;\n    let temp = state;\n    for (let i = 0; i < rank; i++) {\n      const d_i = temp % p;\n      temp = Math.floor(temp / p);\n      const pd_i = ((d_i - effects[i] * v) % p + p) % p;\n      prevState += pd_i * powers[i];\n    }\n    state = prevState;\n  }\n\n  // Build solution\n  const solution = new Array(numButtons).fill(0);\n  for (let f = 0; f < numFree; f++) {\n    solution[freeVars[f]] = freeVals[f];\n  }\n  for (let i = 0; i < rank; i++) {\n    let val = matrix[i][numButtons];\n    for (let f = 0; f < numFree; f++) {\n      val = ((val - effectMatrix[i][f] * freeVals[f]) % modulus + modulus) % modulus;\n    }\n    solution[pivotCol[i]] = val;\n  }\n\n  // But we need to check lex ordering among all solutions with the same total.\n  // For now, let's also check all states with the same total.\n  // This is O(stateSize) which is manageable.\n  const candidates: number[][] = [];\n  for (let s = 0; s < stateSize; s++) {\n    if (dpCost[s] >= INF) continue;\n    let pivotCost = 0;\n    let temp = s;\n    for (let i = 0; i < rank; i++) {\n      const d_i = temp % p;\n      temp = Math.floor(temp / p);\n      pivotCost += (matrix[i][numButtons] - d_i + p) % p;\n    }\n    const total = dpCost[s] + pivotCost;\n    if (total === bestTotal) {\n      candidates.push(reconstructSolutionFromState(s, freeVars, pivotCol, effectMatrix, matrix, numButtons, numFree, rank, modulus, choices, powers));\n    }\n  }\n\n  // Find lex smallest among candidates\n  let result = candidates[0];\n  for (let c = 1; c < candidates.length; c++) {\n    if (lexSmallerArrayNum(