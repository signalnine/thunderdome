rue, false],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('returns two buttons when both are needed', () => {\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0], [1]],\n    });\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('returns null when no solution exists (task example)', () => {\n    // From the task description example\n    const result = solveToggle({\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('prefers minimum number of button presses', () => {\n    // Button 0 toggles [0,1], button 1 toggles [0], button 2 toggles [1]\n    // Target [true, true]: can do button 0 alone (1 press) or buttons 1+2 (2 presses)\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0, 1], [0], [1]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('returns lexicographically smallest when tied on press count', () => {\n    // Button 0 toggles [0], button 1 toggles [0] - both solve target alone\n    // Should prefer button 0 (lex smaller)\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('handles overlapping toggles with XOR behavior', () => {\n    const result = solveToggle({\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('handles larger instance with identity buttons', () => {\n    // 10 lights, 10 buttons, each button toggles one light (identity matrix)\n    const buttons = Array.from({ length: 10 }, (_, i) => [i]);\n    const target = Array.from({ length: 10 }, (_, i) => i % 2 === 0);\n    // Need to press buttons 0, 2, 4, 6, 8\n    const result = solveToggle({ target, buttons });\n    expect(result).toEqual([0, 2, 4, 6, 8]);\n  });\n\n  it('lex tie-breaking: prefers earlier indices when same count', () => {\n    // 2 lights, 3 buttons\n    // Button 0: toggles [0, 1]\n    // Button 1: toggles [0]\n    // Button 2: toggles [1]\n    // Target: [true, true]\n    // Solutions: {0} (1 press) or {1,2} (2 presses)\n    // Minimum is {0}\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0, 1], [0], [1]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('handles case with many free variables efficiently', () => {\n    // 5 lights, 40 buttons - many redundant buttons creating 35 free vars\n    const buttons: number[][] = [];\n    for (let i = 0; i < 40; i++) {\n      buttons.push([i % 5]); // button i toggles light (i%5)\n    }\n    const target = [true, true, true, true, true];\n    const result = solveToggle({ target, buttons });\n    expect(result).not.toBeNull();\n    expect(result!.length).toBe(5);\n    // Verify correctness\n    const state = new Array(5).fill(false);\n    for (const btnIdx of result!) {\n      for (const lightIdx of buttons[btnIdx]) {\n        state[lightIdx] = !state[lightIdx];\n      }\n    }\n    expect(state).toEqual(target);\n    // Verify lex smallest: should prefer earliest button indices\n    expect(result).toEqual([0, 1, 2, 3, 4]);\n  });\n\n  it('handles 40x40 instance within time limit', () => {\n    // Construct a solvable system with 40 lights and 40 buttons\n    const n = 40;\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      // Each button toggles light i and (i+1) % n\n      buttons.push([i, (i + 1) % n]);\n    }\n    // Target: all on\n    const target = new Array(n).fill(true);\n    const result = solveToggle({ target, buttons });\n    // Verify the solution is valid if it exists\n    if (result !== null) {\n      const state = new Array(n).fill(false);\n      for (const btnIdx of result) {\n        for (const lightIdx of buttons[btnIdx]) {\n          state[lightIdx] = !state[lightIdx];\n        }\n      }\n      expect(state).toEqual(target);\n    }\n    // The test mainly checks it completes in time\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('returns all zeros when target is all zeros', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('solves single button single counter', () => {\n    // Button 0 increments counter 0. Target: counter 0 = 3. Modulus 5.\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('handles modular arithmetic', () => {\n    // Button 0 increments counter 0. Target: counter 0 = 0. Modulus 5.\n    // Press 0 times (0 mod 5 = 0) or 5 times (but max is modulus-1=4).\n    // Minimum: 0 presses.\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('solves two buttons two counters', () => {\n    // Button 0 increments counters [0], button 1 increments counters [1]\n    // Target: [2, 3], modulus 5\n    const result = solveCounter([2, 3], [[0], [1]], 5);\n    expect(result).toEqual([2, 3]);\n  });\n\n  it('returns null when no solution exists', () => {\n    // 2 counters, 1 button. Button 0 increments both counters [0, 1].\n    // Target: [1, 2], modulus 3.\n    // Pressing x times gives [x, x]. Can't get [1, 2].\n    const result = solveCounter([1, 2], [[0, 1]], 3);\n    expect(result).toBeNull();\n  });\n\n  it('prefers minimum total presses', () => {\n    // Button 0 increments counter [0]. Target: counter 0 = 1. Modulus 5.\n    // Solution: press 1 time. Total = 1.\n    const result = solveCounter([1], [[0]], 5);\n    expect(result).toEqual([1]);\n  });\n\n  it('handles overlapping buttons', () => {\n    // Button 0 increments counters [0, 1], button 1 increments counters [1]\n    // Target: [1, 0], modulus 3\n    // Solution: button 0 pressed 1 time, button 1 pressed 2 times\n    // Counter 0: 1*1 = 1 (mod 3) ✓\n    // Counter 1: 1*1 + 1*2 = 3 = 0 (mod 3) ✓\n    // Total: 1 + 2 = 3\n    const result = solveCounter([1, 0], [[0, 1], [1]], 3);\n    expect(result).toEqual([1, 2]);\n  });\n\n  it('returns lex smallest when tied on total presses', () => {\n    // Button 0 and button 1 both increment counter [0].\n    // Target: [1], modulus 3\n    // Solutions: [1,0] (total=1) or [0,1] (total=1)\n    // Lex smallest: [0,1]... wait. [0,1] < [1,0] lex? Yes, 0 < 1 at index 0.\n    const result = solveCounter([1], [[0], [0]], 3);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('handles modular wrapping for optimal solution', () => {\n    // 1 counter, 1 button, target=4, modulus=5\n    // Press 4 times. Total = 4.\n    const result = solveCounter([4], [[0]], 5);\n    expect(result).toEqual([4]);\n  });\n\n  it('handles larger instance with identity buttons', () => {\n    // 10 counters, 10 buttons, each button increments one counter\n    // Target: [1,2,3,4,0,1,2,3,4,0], modulus 5\n    const buttons = Array.from({ length: 10 }, (_, i) => [i]);\n    const target = [1, 2, 3, 4, 0, 1, 2, 3, 4, 0];\n    const result = solveCounter(target, buttons, 5);\n    expect(result).toEqual(target);\n  });\n\n  it('handles prime modulus 7', () => {\n    // 2 counters, 2 buttons\n    // Button 0: counter 0, Button 1: counter 1\n    // Target: [3, 5], modulus 7\n    const result = solveCounter([3, 5], [[0], [1]], 7);\n    expect(result).toEqual([3, 5]);\n  });\n\n  it('handles 40x40 instance with prime modulus', () => {\n    // Identity: 40 counters, 40 buttons, each button increments one counter\n    const n = 40;\n    const buttons = Array.from({ length: n }, (_, i) => [i]);\n    const target = Array.from({ length: n }, (_, i) => (i * 3 + 1) % 7);\n    const result = solveCounter(target, buttons, 7);\n    expect(result).toEqual(target);\n  });\n\n  it('handles system with free variables and modulus 7', () => {\n    // 2 counters, 4 buttons with redundancy\n    // Button 0: [0], Button 1: [1], Button 2: [0], Button 3: [1]\n    // Target: [3, 5], modulus 7\n    // Optimal: minimize total. Options include [3,5,0,0], [0,5,3,0], etc.\n    // [0,0,3,5] would also work with total 8.\n    // [3,5,0,0] total=8, [0,5,3,0] total=8, [0,0,3,5] total=8\n    // Lex smallest with min total: [0,0,3,5] vs [0,5,0,3] vs [0,5,3,0] vs [3,0,0,5] vs [3,5,0,0]\n    // All have total 8. Lex smallest: [0,0,3,5]\n    const result = solveCounter([3, 5], [[0], [1], [0], [1]], 7);\n    expect(result).not.toBeNull();\n    // Verify correctness\n    const counters = new Array(2).fill(0);\n    for (let j = 0; j < 4; j++) {\n      for (const c of [[0], [1], [0], [1]][j]) {\n        counters[c] = (counters[c] + result![j]) % 7;\n      }\n    }\n    expect(counters).toEqual([3, 5]);\n    // Verify total is minimal (should be 8)\n    const total = result!.reduce((a, b) => a + b, 0);\n    expect(total).toBe(8);\n    // Verify lex smallest\n    expect(result).toEqual([0, 0, 3, 5]);\n  });\n\n  it('solves system with multiple equations needing GE', () => {\n    const result = solveCounter([2, 0, 1], [[0, 1], [1, 2], [0, 2]], 3);\n    expect(result).toEqual([2, 1, 0]);\n  });\n\n  it('handles many free variables with DP path', () => {\n    // 2 counters, 20 buttons, each button increments counter (i % 2)\n    // rank=2, 18 free variables. With modulus=97, enumeration space=97^18, too large.\n    // Should use DP path (p^rank = 97^2 = 9409 states).\n    const buttons: number[][] = [];\n    for (let i = 0; i < 20; i++) {\n      buttons.push([i % 2]);\n    }\n    const result = solveCounter([1, 1], buttons, 97);\n    expect(result).not.toBeNull();\n    // Verify correctness\n    const counters = [0, 0];\n    for (let j = 0; j < 20; j++) {\n      counters[buttons[j][0]] = (counters[buttons[j][0]] + result![j]) % 97;\n    }\n    expect(counters).toEqual([1, 1]);\n    // Total should be 2 (minimum: need at least one press for each counter)\n    const total = result!.reduce((a, b) => a + b, 0);\n    expect(total).toBe(2);\n  });\n});\n","structuredPatch":[{"oldStart":260,"oldLines":6,"newStart":260,"newLine