 (let ff = 0; ff < numFree; ff++) {\n          val = ((val - effectMatrix[i][ff] * freeVals[ff]) % modulus + modulus) % modulus;\n        }\n        cost += val;\n      }\n      if (cost < bestCost) {\n        bestCost = cost;\n        bestVal = v;\n      }\n    }\n    freeVals[f] = bestVal;\n  }\n\n  const solution = new Array(numButtons).fill(0);\n  for (let f = 0; f < numFree; f++) {\n    solution[freeVars[f]] = freeVals[f];\n  }\n  for (let i = 0; i < rank; i++) {\n    let val = matrix[i][numButtons];\n    for (let f = 0; f < numFree; f++) {\n      val = ((val - effectMatrix[i][f] * freeVals[f]) % modulus + modulus) % modulus;\n    }\n    solution[pivotCol[i]] = val;\n  }\n  return solution;\n}","originalFile":"export interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// Represent bitmasks as [lo, hi] pairs for up to 41 bits (40 buttons + augment)\ntype Pair = [number, number]; // [lo: bits 0-31, hi: bits 32+]\n\nfunction pairNew(): Pair { return [0, 0]; }\nfunction pairSetBit(p: Pair, bit: number): void {\n  if (bit < 32) p[0] |= (1 << bit) >>> 0;\n  else p[1] |= (1 << (bit - 32)) >>> 0;\n}\nfunction pairGetBit(p: Pair, bit: number): number {\n  if (bit < 32) return (p[0] >>> bit) & 1;\n  return (p[1] >>> (bit - 32)) & 1;\n}\nfunction pairXorMut(a: Pair, b: Pair): void {\n  a[0] = (a[0] ^ b[0]) >>> 0;\n  a[1] = (a[1] ^ b[1]) >>> 0;\n}\nfunction pairXor(a: Pair, b: Pair): Pair {\n  return [(a[0] ^ b[0]) >>> 0, (a[1] ^ b[1]) >>> 0];\n}\nfunction pairClone(p: Pair): Pair { return [p[0], p[1]]; }\nfunction pairIsZero(p: Pair): boolean { return p[0] === 0 && p[1] === 0; }\n\nfunction popcount32(x: number): number {\n  x = x - ((x >> 1) & 0x55555555);\n  x = (x & 0x33333333) + ((x >> 2) & 0x33333333);\n  x = (x + (x >> 4)) & 0x0f0f0f0f;\n  return (x * 0x01010101) >> 24;\n}\n\nfunction pairPopcount(p: Pair): number {\n  return popcount32(p[0]) + popcount32(p[1]);\n}\n\nfunction pairToSortedArray(p: Pair, maxBits: number): number[] {\n  const result: number[] = [];\n  for (let i = 0; i < maxBits; i++) {\n    if (pairGetBit(p, i)) result.push(i);\n  }\n  return result;\n}\n\n// Lex comparison of sorted bit sets: returns true if a < b lex.\n// Compares the sorted arrays of set bit positions element by element.\nfunction pairLexSmaller(a: Pair, b: Pair): boolean {\n  // We scan both bitmasks together from lowest bit upward, comparing\n  // corresponding elements in the sorted set representation.\n  // We combine lo and hi into a unified scan using bit position tracking.\n  let aLo = a[0] >>> 0, aHi = a[1] >>> 0;\n  let bLo = b[0] >>> 0, bHi = b[1] >>> 0;\n\n  // Process lo bits (0-31) first\n  while (aLo !== 0 || bLo !== 0 || aHi !== 0 || bHi !== 0) {\n    // Find next set bit in a\n    let posA: number;\n    if (aLo !== 0) {\n      posA = 31 - Math.clz32(aLo & (-aLo));\n      aLo ^= (1 << posA) >>> 0;\n    } else if (aHi !== 0) {\n      posA = 32 + (31 - Math.clz32(aHi & (-aHi)));\n      aHi ^= (1 << (posA - 32)) >>> 0;\n    } else {\n      // a exhausted, b has more -> a is shorter -> a < b\n      return true;\n    }\n\n    // Find next set bit in b\n    let posB: number;\n    if (bLo !== 0) {\n      posB = 31 - Math.clz32(bLo & (-bLo));\n      bLo ^= (1 << posB) >>> 0;\n    } else if (bHi !== 0) {\n      posB = 32 + (31 - Math.clz32(bHi & (-bHi)));\n      bHi ^= (1 << (posB - 32)) >>> 0;\n    } else {\n      // b exhausted, a has more -> b is shorter -> a > b\n      return false;\n    }\n\n    if (posA < posB) return true;\n    if (posA > posB) return false;\n  }\n  return false; // equal\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const numLights = machine.target.length;\n  const numButtons = machine.buttons.length;\n\n  // Build augmented matrix over GF(2).\n  // Row i: bit j set if button j affects light i. Bit numButtons = target[i].\n  const rows: Pair[] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = pairNew();\n    for (let j = 0; j < numButtons; j++) {\n      if (machine.buttons[j].includes(i)) {\n        pairSetBit(row, j);\n      }\n    }\n    if (machine.target[i]) {\n      pairSetBit(row, numButtons);\n    }\n    rows.push(row);\n  }\n\n  // Gaussian elimination over GF(2) - RREF\n  const pivotCol: number[] = [];\n  let curRow = 0;\n  for (let col = 0; col < numButtons; col++) {\n    let pivotRow = -1;\n    for (let r = curRow; r < numLights; r++) {\n      if (pairGetBit(rows[r], col)) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    [rows[curRow], rows[pivotRow]] = [rows[pivotRow], rows[curRow]];\n    pivotCol.push(col);\n\n    for (let r = 0; r < numLights; r++) {\n      if (r !== curRow && pairGetBit(rows[r], col)) {\n        pairXorMut(rows[r], rows[curRow]);\n      }\n    }\n    curRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < numLights; r++) {\n    if (pairGetBit(rows[r], numButtons)) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (!pivotSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Base solution (all free vars = 0)\n  const baseSol = pairNew();\n  for (let i = 0; i < rank; i++) {\n    if (pairGetBit(rows[i], numButtons)) {\n      pairSetBit(baseSol, pivotCol[i]);\n    }\n  }\n\n  // Effect vectors: toggling free var f changes these bits\n  const effectVec: Pair[] = [];\n  for (let f = 0; f < numFree; f++) {\n    const effect = pairNew();\n    pairSetBit(effect, freeVars[f]); // the free var itself\n    for (let i = 0; i < rank; i++) {\n      if (pairGetBit(rows[i], freeVars[f])) {\n        pairSetBit(effect, pivotCol[i]);\n      }\n    }\n    effectVec.push(effect);\n  }\n\n  // Find minimum weight solution\n  const searchDim = Math.min(numFree, rank);\n\n  if (searchDim <= 25) {\n    if (numFree <= 25) {\n      return searchByFreeVars(baseSol, effectVec, numFree, numButtons);\n    } else {\n      return searchByPivotTargets(baseSol, effectVec, freeVars, pivotCol, rows, rank, numFree, numButtons);\n    }\n  }\n\n  // Both rank and numFree > 25: shouldn't happen since rank + numFree <= 40\n  return pairToSortedArray(baseSol, numButtons);\n}\n\nfunction searchByFreeVars(\n  baseSol: Pair,\n  effectVec: Pair[],\n  numFree: number,\n  numButtons: number\n): number[] {\n  let bestSol = pairClone(baseSol);\n  let bestWeight = pairPopcount(baseSol);\n\n  const total = 1 << numFree;\n  const sol = pairClone(baseSol);\n  let prevGray = 0;\n  for (let i = 1; i < total; i++) {\n    const gray = i ^ (i >> 1);\n    const diff = gray ^ prevGray;\n    const f = 31 - Math.clz32(diff);\n    pairXorMut(sol, effectVec[f]);\n    prevGray = gray;\n    const w = pairPopcount(sol);\n    if (w < bestWeight || (w === bestWeight && pairLexSmaller(sol, bestSol))) {\n      bestWeight = w;\n      bestSol[0] = sol[0];\n      bestSol[1] = sol[1];\n    }\n  }\n  return pairToSortedArray(bestSol, numButtons);\n}\n\nfunction searchByPivotTargets(\n  baseSol: Pair,\n  _effectVec: Pair[],\n  freeVars: number[],\n  pivotCol: number[],\n  rows: Pair[],\n  rank: number,\n  numFree: number,\n  numButtons: number\n): number[] {\n  // When rank is small (≤ 20) but numFree is large, enumerate efficiently.\n  // Each free var has a \"pivot effect pattern\" (rank-bit number).\n  // Group free vars by pattern, then use DP over 2^rank states to find\n  // minimum cost selections.\n\n  const freeEffectOnPivots: number[] = [];\n  for (let f = 0; f < numFree; f++) {\n    let pattern = 0;\n    for (let i = 0; i < rank; i++) {\n      if (pairGetBit(rows[i], freeVars[f])) {\n        pattern |= (1 << i);\n      }\n    }\n    freeEffectOnPivots.push(pattern);\n  }\n\n  let basePivotPattern = 0;\n  for (let i = 0; i < rank; i++) {\n    if (pairGetBit(baseSol, pivotCol[i])) {\n      basePivotPattern |= (1 << i);\n    }\n  }\n\n  // Group free vars by pivot effect pattern\n  const patternToFreeVars = new Map<number, number[]>();\n  for (let f = 0; f < numFree; f++) {\n    const p = freeEffectOnPivots[f];\n    if (!patternToFreeVars.has(p)) {\n      patternToFreeVars.set(p, []);\n    }\n    patternToFreeVars.get(p)!.push(f);\n  }\n\n  // Get unique non-zero patterns\n  const uniquePatterns: number[] = [];\n  const patternFreeVarsList: number[][] = [];\n  for (const [pat, fvs] of patternToFreeVars) {\n    if (pat !== 0) {\n      uniquePatterns.push(pat);\n      patternFreeVarsList.push(fvs);\n    }\n  }\n\n  const numPat = uniquePatterns.length;\n  const stateSize = 1 << rank;\n\n  // DP: compute minimum number of patterns to XOR to reach each state.\n  // 0-1 knapsack style: each pattern used at most once.\n  const INF = numPat + 1;\n  const dpCost = new Int32Array(stateSize).fill(INF);\n  const dpFrom = new Int32Array(stateSize).fill(-1);\n  const dpPrev = new Int32Array(stateSize).fill(-1);\n  dpCost[0] = 0;\n\n  // Process patterns in lex order of their smallest free var (already ordered)\n  for (let p = 0; p < numPat; p++) {\n    const pat = uniquePatterns[p];\n    // Reverse iterate to ensure each pattern used at most once\n    for (let s = stateSize - 1; s >= 0; s--) {\n      if (dpCost[s] < INF) {\n        const ns = s ^ pat;\n        const nc = dpCost[s] + 1;\n        if (nc < dpCost[ns]) {\n          dpCost[ns] = nc;\n          dpFrom[ns] = p;\n          dpPrev[ns] = s;\n        }\n      }\n    }\n  }\n\n  // Now find best pivot target: minimize popcount(target) + dpCost[target XOR basePivotPattern]\n  let bestSol: Pair | null = null;\n  let bestWeight = numButtons + 1;\n\n  for (let target = 0; target < stateSize; target++) {\n    const delta = target ^ basePivotPattern;\n    if (dpCost[delta] >= INF) continue;\n\n    const pivotWeight = popcount32(target);\n    const freeVarWeight = dpCost[delta];\n    const totalWeight = pivotWeight + freeVarWeight;\n\n    if (totalWeight > bestWeight) continue;\n\n    // Reconstruct which patterns were used\n    const usedPatternIndices: number[] = [];\n    let state = delta;\n    while (state !== 0) {\n      usedPatternIndices.push(dpFrom[state]);\n      state = dpPrev[state];\n    }\n\n    // Build the solution\n    const sol = pairNew();\n\n    // Set pivot bits\n    for (let i = 0; i < rank; i++) {\n      if ((target >> i) & 1) {\n        pairSetBit(sol, pivotCol[i]);\n      }\n    }\n\n    // For each used pattern, pick the lex-smallest free var (freeVars[0] of that pattern)\n    for (const p of usedPatternIndices) {\n      const fv = patternFreeVarsList[p][0];\n      pairSetBit(sol, freeVars[fv]);\n    }\n\n    const w = pairPopcount(sol);\n    if (bestSol === null || w < bestWeight || (w === bestWeight && pairLexSmaller(sol, bestSol))) {\n      bestWeight = w;\n      bestSol = pairClone(sol);\n    }\n  }\n\n  if (bestSol === null) {\n    return pairToSortedArray(baseSol, numButtons);\n  }\n  return pairToSortedArray(bestSol, numButtons);\n}\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Check if target is all zeros\n  if (lights.every((v) => v === 0)) {\n    return new Array(numButtons).fill(0);\n  }\n\n  // Gaussian elimination over GF(modulus) where modulus is prime\n  // Build augmented matrix: rows = counters, columns = buttons + 1 (augment)\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = lights[i];\n    matrix.push(row);\n  }\n\n  // Modular inverse using extended GCD (modulus is prime)\n  function modInverse(a: number, m: number): number {\n    a = ((a % m) + m) % m;\n    // Extended GCD\n    let [old_r, r] = [a, m];\n    let [old_s, s] = [1, 0];\n    while (r !== 0) {\n      const q = Math.floor(old_r / r);\n      [old_r, r] = [r, old_r - q * r];\n      [old_s, s] = [s, old_s - q * s];\n    }\n    return ((old_s % m) + m) % m;\n  }\n\n  // Gaussian elimination over GF(modulus)\n  const pivotCol: number[] = [];\n  let curRow = 0;\n  for (let col = 0; col < numButtons; col++) {\n    // Find pivot row with non-zero entry in this column\n    let pivotRow = -1;\n    for (let r = curRow; r < numCounters; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n\n    // Swap rows\n    [matrix[curRow], matrix[pivotRow]] = [matrix[pivotRow], matrix[curRow]];\n    pivotCol.push(col);\n\n    // Scale pivot row so pivot element = 1\n    const inv = modInverse(matrix[curRow][col], modulus);\n    for (let j = 0; j <= numButtons; j++) {\n      matrix[curRow][j] = (matrix[curRow][j] * inv) % modulus;\n    }\n\n    // Eliminate this column from all other rows\n    for (let r = 0; r < numCounters; r++) {\n      if (r !== curRow && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let j = 0; j <= numButtons; j++) {\n          matrix[r][j] = ((matrix[r][j] - factor * matrix[curRow][j]) % modulus + modulus) % modulus;\n        }\n      }\n    }\n    curRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < numCounters; r++) {\n    if (matrix[r][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (!pivotSet.has(j)) {\n      freeVars.push(j);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Find minimum total presses solution\n  // For each free variable assignment (0 to modulus-1), compute the solution\n  // and track the minimum total presses with lex tie-breaking.\n\n  // Base solution