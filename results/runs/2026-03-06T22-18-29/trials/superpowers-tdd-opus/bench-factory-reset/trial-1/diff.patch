+    const result = solveToggle({ target: [true], buttons: [] });
+    expect(result).toBeNull();
+  });
+
+  it('returns empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('returns single button when one button solves target', () => {
+    const result = solveToggle({
+      target: [true, true, false],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('returns two buttons when both are needed', () => {
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0], [1]],
+    });
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('returns null when no solution exists (task example)', () => {
+    // From the task description example
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('prefers minimum number of button presses', () => {
+    // Button 0 toggles [0,1], button 1 toggles [0], button 2 toggles [1]
+    // Target [true, true]: can do button 0 alone (1 press) or buttons 1+2 (2 presses)
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('returns lexicographically smallest when tied on press count', () => {
+    // Button 0 toggles [0], button 1 toggles [0] - both solve target alone
+    // Should prefer button 0 (lex smaller)
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0]],
