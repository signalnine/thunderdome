4 = -1 = 4\n   252→    // Total: 12\n   253→    const result = solveCounter([3, 3, 3], [[0, 1], [1, 2], [0, 2]], 5);\n   254→    expect(result).toEqual([4, 4, 4]);\n   255→\n   256→    // Verify\n   257→    if (result) {\n   258→      const counters = [0, 0, 0];\n   259→      const btns = [[0, 1], [1, 2], [0, 2]];\n   260→      for (let b = 0; b < result.length; b++) {\n   261→        for (const c of btns[b]) {\n   262→          counters[c] = (counters[c] + result[b]) % 5;\n   263→        }\n   264→      }\n   265→      expect(counters).toEqual([3, 3, 3]);\n   266→    }\n   267→  });\n   268→});\n   269→\n   270→describe('performance', () => {\n   271→  it('should handle 40 buttons and 40 lights for toggle (full rank)', () => {\n   272→    const n = 40;\n   273→    const target: boolean[] = [];\n   274→    const buttons: number[][] = [];\n   275→    // Create an identity-like system: button i toggles light i\n   276→    for (let i = 0; i < n; i++) {\n   277→      target.push(true);\n   278→      buttons.push([i]);\n   279→    }\n   280→    const result = solveToggle({ target, buttons });\n   281→    expect(result).not.toBeNull();\n   282→    expect(result!.length).toBe(n);\n   283→    expect(verifyToggle(target, buttons, result!)).toBe(true);\n   284→  });\n   285→\n   286→  it('should handle 40 buttons and 40 lights for toggle (some free vars)', () => {\n   287→    const n = 40;\n   288→    const target: boolean[] = new Array(n).fill(false);\n   289→    target[0] = true;\n   290→    const buttons: number[][] = [];\n   291→    // Each button toggles light 0 and light i\n   292→    for (let i = 0; i < n; i++) {\n   293→      buttons.push(i === 0 ? [0] : [0, i]);\n   294→    }\n   295→    const result = solveToggle({ target, buttons });\n   296→    expect(result).not.toBeNull();\n   297→    expect(verifyToggle(target, buttons, result!)).toBe(true);\n   298→  });\n   299→\n   300→  it('should handle 40 buttons and 40 counters (full rank, mod 97)', () => {\n   301→    const n = 40;\n   302→    const lights: number[] = [];\n   303→    const buttons: number[][] = [];\n   304→    for (let i = 0; i < n; i++) {\n   305→      lights.push((i * 7 + 3) % 97);\n   306→      buttons.push([i]);\n   307→    }\n   308→    const result = solveCounter(lights, buttons, 97);\n   309→    expect(result).not.toBeNull();\n   310→    expect(verifyCounter(lights, buttons, 97, result!)).toBe(true);\n   311→  });\n   312→\n   313→  it('should handle counter puzzle with overlapping buttons', () => {\n   314→    const n = 20;\n   315→    const lights: number[] = [];\n   316→    const buttons: number[][] = [];\n   317→    for (let i = 0; i < n; i++) {\n   318→      lights.push((i * 3 + 1) % 7);\n   319→    }\n   320→    for (let i = 0; i < n; i++) {\n   321→      const affected: number[] = [];\n   322→      for (let j = 0; j < n; j++) {\n   323→        if ((i + j) % 3 === 0) affected.push(j);\n   324→      }\n   325→      buttons.push(affected);\n   326→    }\n   327→    const result = solveCounter(lights, buttons, 7);\n   328→    if (result) {\n   329→      expect(verifyCounter(lights, buttons, 7, result)).toBe(true);\n   330→    }\n   331→  });\n   332→});\n   333→"}]},"parent_tool_use_id":"toolu_01TmDEm1WoedLaYzEJs461k9","session_id":"f37faaaa-584f-4120-9fc4-ad3e333fe749","uuid":"10231dcb-af36-425c-87ee-bbd9b7430544"}
