+}
+
+function modInverse(a: number, mod: number): number {
+  a = ((a % mod) + mod) % mod;
+  return modPow(a, mod - 2, mod);
+}
+
+function modPow(base: number, exp: number, mod: number): number {
+  let result = 1;
+  base = base % mod;
+  while (exp > 0) {
+    if (exp % 2 === 1) {
+      result = (result * base) % mod;
+    }
+    exp = Math.floor(exp / 2);
+    base = (base * base) % mod;
+  }
+  return result;
+}
