let c = 0; c <= numButtons; c++) {\n          matrix[r][c] ^= matrix[row][c];\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    row++;\n  }\n\n  const rank = row;\n\n  // Check for inconsistency: any row with all-zero coefficients but non-zero target\n  for (let r = rank; r < numLights; r++) {\n    if (matrix[r][numButtons] === 1) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let c = 0; c < numButtons; c++) {\n    if (!pivotSet.has(c)) {\n      freeVars.push(c);\n    }\n  }\n\n  // Map pivot column to its row\n  const colToRow = new Map<number, number>();\n  for (let r = 0; r < rank; r++) {\n    colToRow.set(pivotCol[r], r);\n  }\n\n  // Try all combinations of free variables to find minimum presses,\n  // then lexicographically smallest.\n  const numFree = freeVars.length;\n\n  let bestResult: number[] | null = null;\n  let bestCount = numButtons + 1;\n\n  // Enumerate all 2^numFree combinations\n  for (let mask = 0; mask < (1 << numFree); mask++) {\n    const result = new Array(numButtons).fill(0);\n\n    // Set free variables\n    for (let i = 0; i < numFree; i++) {\n      result[freeVars[i]] = (mask >> i) & 1;\n    }\n\n    // Compute pivot variables (back substitution)\n    let valid = true;\n    for (let r = rank - 1; r >= 0; r--) {\n      const pc = pivotCol[r];\n      let val = matrix[r][numButtons];\n      for (let c = pc + 1; c < numButtons; c++) {\n        if (matrix[r][c] === 1) {\n          val ^= result[c];\n        }\n      }\n      result[pc] = val;\n    }\n\n    if (!valid) continue;\n\n    const count = result.reduce((a: number, b: number) => a + b, 0);\n    if (count < bestCount || (count === bestCount && lexSmaller(result, bestResult!, numButtons))) {\n      bestCount = count;\n      bestResult = result;\n    }\n  }\n\n  if (bestResult === null) return null;\n\n  // Convert to list of pressed button indices\n  const pressed: number[] = []