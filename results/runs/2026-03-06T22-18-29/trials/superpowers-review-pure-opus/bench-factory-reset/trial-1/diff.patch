+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve the toggle puzzle using Gaussian elimination over GF(2).
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build the augmented matrix over GF(2).
+  // matrix[light][button] = 1 if button toggles that light
+  // matrix[light][numButtons] = target value
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+  for (let b = 0; b < numButtons; b++) {
+    for (const light of buttons[b]) {
+      if (light < numLights) {
+        matrix[light][b] = 1;
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotCol: number[] = [];
+  let row = 0;
+  for (let col = 0; col < numButtons && row < numLights; col++) {
+    let pivotRow = -1;
+    for (let r = row; r < numLights; r++) {
+      if (matrix[r][col] === 1) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];
+
+    for (let r = 0; r < numLights; r++) {
+      if (r !== row && matrix[r][col] === 1) {
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[r][c] ^= matrix[row][c];
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    row++;
+  }
+
+  const rank = row;
+
+  // Check for inconsistency
+  for (let r = rank; r < numLights; r++) {
+    if (matrix[r][numButtons] === 1) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let c = 0; c < numButtons; c++) {
+    if (!pivotSet.has(c)) {
+      freeVars.push(c);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // For each pivot row, precompute which free variables appear in it.
+  // After reduced row echelon, matrix[r] has pivot at pivotCol[r]=1,
+  // and coefficients for free variables.
+  // pivotVal[r] = base value (from augmented column)
+  // pivotFreeCoeffs[r] = list of free variable indices that have coefficient 1
+  const pivotFreeCoeffs: number[][] = [];
+  const pivotBaseVal: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    pivotBaseVal.push(matrix[r][numButtons]);
+    const coeffs: number[] = [];
+    for (let fi = 0; fi < numFree; fi++) {
+      if (matrix[r][freeVars[fi]] === 1) {
+        coeffs.push(fi);
+      }
+    }
+    pivotFreeCoeffs.push(coeffs);
+  }
+
+  // Use branch-and-bound to enumerate free variable assignments
+  let bestResult: number[] | null = null;
+  let bestCount = numButtons + 1;
+
+  const freeValues = new Array(numFree).fill(0);
+
+  function computeAndEvaluate(): void {
+    const result = new Array(numButtons).fill(0);
+    for (let i = 0; i < numFree; i++) {
+      result[freeVars[i]] = freeValues[i];
+    }
+    let count = 0;
+    for (let i = 0; i < numFree; i++) count += freeValues[i];
+
+    for (let r = 0; r < rank; r++) {
+      let val = pivotBaseVal[r];
+      for (const fi of pivotFreeCoeffs[r]) {
+        val ^= freeValues[fi];
+      }
+      result[pivotCol[r]] = val;
+      count += val;
+    }
+
+    if (count < bestCount || (count === bestCount && lexSmallerToggle(result, bestResult!, numButtons))) {
+      bestCount = count;
+      bestResult = [...result];
+    }
+  }
+
+  function search(idx: number, currentFreeCount: number): void {
+    if (currentFreeCount > bestCount) return;
+
+    if (idx === numFree) {
+      computeAndEvaluate();
+      return;
+    }
+
+    // Try 0 first (lexicographically preferred)
+    freeValues[idx] = 0;
+    search(idx + 1, currentFreeCount);
+
+    freeValues[idx] = 1;
+    search(idx + 1, currentFreeCount + 1);
+  }
+
+  search(0, 0);
+
+  if (bestResult === null) return null;
+
+  const pressed: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if (bestResult[i] === 1) {
+      pressed.push(i);
+    }
+  }
+  return pressed;
+}
+
+function lexSmallerToggle(a: number[], b: number[], n: number): boolean {
+  const aIdx: number[] = [];
+  const bIdx: number[] = [];
+  for (let i = 0; i < n; i++) {
+    if (a[i]) aIdx.push(i);
+    if (b[i]) bIdx.push(i);
+  }
+  const len = Math.min(aIdx.length, bIdx.length);
+  for (let i = 0; i < len; i++) {
+    if (aIdx[i] < bIdx[i]) return true;
+    if (aIdx[i] > bIdx[i]) return false;
+  }
+  return aIdx.length < bIdx.length;
+}
