ith up to 40 free vars and modulus up to 97, brute force is infeasible.\n  // However, after Gaussian elimination, the number of free variables = numButtons - rank.\n  // With 40 buttons and 40 counters, rank can be up to 40, so 0 free vars possible.\n  // But in worst case we could have many free vars.\n  //\n  // Strategy: If numFree is small enough (say <=20 with small modulus), enumerate.\n  // Otherwise, use a smarter approach.\n  //\n  // For the general case with prime modulus, we can use the following:\n  // Each free variable can be 0..modulus-1. We want to minimize total presses.\n  // The pivot variables are determined by free variables:\n  //   pivot_var[r] = matrix[r][numButtons] - sum(matrix[r][freeVar] * freeVal) mod p\n  // Total cost = sum of pivot values + sum of free values\n  //\n  // For small number of free variables, enumerate all combinations.\n  // The constraint says up to 40 buttons and 40 lights, so typically rank is close to\n  // min(numButtons, numCounters), leaving few free variables.\n\n  if (numFree === 0) {\n    // Unique solution\n    const result = new Array(numButtons).fill(0);\n    for (let r = 0; r < rank; r++) {\n      result[pivotCol[r]] = matrix[r][numButtons];\n    }\n    return result;\n  }\n\n  // For manageable number of free variables, enumerate.\n  // With modulus p and numFree free vars, total combinations = p^numFree.\n  // If p^numFree > some threshold, we need a smarter approach.\n  //\n  // For the problem constraints (up to 40 buttons, 40 counters, modulus up to 97),\n  // worst case is many free variables. But typically the system is well-constrained.\n  //\n  // Use iterative deepening / branch and bound approach for free variables.\n\n  let bestResult: number[] | null = null;\n  let bestTotal = Infinity;\n\n  const freeValues = new Array(numFree).fill(0);\n\n  // Compute pivot values given free variable assignments\n  function computeResult(): number[] {\n    const result = new Array(numButtons).fill(0);\n    for (let i = 0; i < numFree; i++) {\n      result[freeVars[i]] = freeValues[i];\n    }\n    for (let r = rank - 1; r >= 0; r--) {\n      let val = matrix[r][numButtons];\n      for (let c = pivotCol[r] + 1; c < numButtons; c++) {\n        if (matrix[r][c] !== 0) {\n          val = ((val - matrix[r][c] * result[c]) % modulus + modulus) % modulus;\n        }\n      }\n      result[pivotCol[r]] = val;\n    }\n    return result;\n  }\n\n  function totalPresses(result: number[]): number {\n    return result.reduce((a, b) => a + b, 0);\n  }\n\n  // Check if enumeration is feasible\n  const totalCombinations = Math.pow(modulus, numFree);\n\n  if (totalCombinations <= 5_000_000) {\n    // Enumerate all combinations\n    const enumerate = (idx: number): void => {\n      if (idx === numFree) {\n        const result = computeResult();\n        const total = totalPresses(result);\n        if (total < bestTotal || (total === bestTotal && lexSmallerArr(result, bestResult!))) {\n          bestTotal = total;\n          bestResult = [...result];\n        }\n        return;\n      }\n      for (let v = 0; v < modulus; v++) {\n        freeValues[idx] = v;\n        enumerate(idx + 1);\n      }\n    };\n    enumerate(0);\n  } else {\n    // For large search spaces, use a greedy/optimization approach.\n    // Since modulus is prime, we can solve for the minimum cost using\n    // optimization over GF(p).\n    //\n    // Actually, for up to 40 buttons and 40 counters, rank should be close to\n    // min(40, 40) = 40 in most cases, so numFree should be small.\n    // But as a fallback, implement a smarter search.\n    //\n    // Strategy: Use iterative approach. For each free variable independently,\n    // try all values 0..p-1 and pick the one minimizing cost. This is greedy\n    // and may not find optimal, but with the branch-and-bound below it should work.\n    //\n    // Better: branch and bound with pruning.\n    const lowerBound = (idx: number, currentFreeSum: number): number => {