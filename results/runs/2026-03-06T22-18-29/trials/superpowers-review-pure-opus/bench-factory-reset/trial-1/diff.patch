+function verifyToggle(target: boolean[], buttons: number[][], pressed: number[]): boolean {
+  const state = new Array(target.length).fill(false);
+  for (const b of pressed) {
+    for (const l of buttons[b]) {
+      state[l] = !state[l];
+    }
+  }
+  return state.every((v, i) => v === target[i]);
+}
+
+function verifyCounter(lights: number[], buttons: number[][], modulus: number, result: number[]): boolean {
+  const counters = new Array(lights.length).fill(0);
+  for (let b = 0; b < result.length; b++) {
+    for (const c of buttons[b]) {
+      counters[c] = (counters[c] + result[b]) % modulus;
+    }
+  }
+  return counters.every((v, i) => v === lights[i]);
+}
