/ Compute pivot variables (back substitution)\n    let valid = true;\n    for (let r = rank - 1; r >= 0; r--) {\n      const pc = pivotCol[r];\n      let val = matrix[r][numButtons];\n      for (let c = pc + 1; c < numButtons; c++) {\n        if (matrix[r][c] === 1) {\n          val ^= result[c];\n        }\n      }\n      result[pc] = val;\n    }\n\n    if (!valid) continue;\n\n    const count = result.reduce((a: number, b: number) => a + b, 0);\n    if (count < bestCount || (count === bestCount && lexSmaller(result, bestResult!, numButtons))) {\n      bestCount = count;\n      bestResult = result;\n    }\n  }\n\n  if (bestResult === null) return null;\n\n  // Convert to list of pressed button indices\n  const pressed: number[] = [];\n  for (let i = 0; i < numButtons; i++) {\n    if (bestResult[i] === 1) {\n      pressed.push(i);\n    }\n  }\n  return pressed;\n}\n\n/**\n * Compare two arrays lexicographically as sets of pressed indices.\n * We want the lexicographically smallest set of indices.\n * For toggle: result arrays are 0/1, compare as arrays directly.\n */\nfunction lexSmaller(a: number[], b: number[], n: number): boolean {\n  // Convert to pressed indices and compare\n  const aIdx: number[] = [];\n  const bIdx: number[] = [];\n  for (let i = 0; i < n; i++) {\n    if (a[i]) aIdx.push(i);\n    if (b[i]) bIdx.push(i);\n  }\n  const len = Math.min(aIdx.length, bIdx.length);\n  for (let i = 0; i < len; i++) {\n    if (aIdx[i] < bIdx[i]) return true;\n    if (aIdx[i] > bIdx[i]) return false;\n  }\n  return aIdx.length < bIdx.length;\n}\n\n/**\n * Solve the counter puzzle using Gaussian elimination over GF(p).\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build the augmented matrix over GF(modulus).\n  // matrix[counter][button] = 1 if button affects that counter, 0 otherwise\n  // matrix[counter][numBut