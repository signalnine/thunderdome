+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function nextPosition(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':       return [row + 1, col];
+    case 'down-left':  return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') {
+      return [0, col];
+    }
+  }
+  return null;
+}
+
+function isInBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+/**
+ * Count the number of distinct cells visited by any beam.
+ */
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+  if (cols === 0) return 0;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visited = new Set<string>();
+  const beams: Beam[] = [{ row: source[0], col: source[1], dir: 'down' }];
+
+  // Track visited states to avoid infinite processing of duplicate beams
+  const seenStates = new Set<string>();
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const { row, col, dir } = beam;
+
+    if (!isInBounds(row, col, rows, cols)) continue;
+
+    const stateKey = `${row},${col},${dir}`;
+    if (seenStates.has(stateKey)) continue;
+    seenStates.add(stateKey);
+
+    visited.add(`${row},${col}`);
+
+    const cell = grid[row][col];
+
+    if (cell === '^') {
+      // Splitter: produce two diagonal beams
+      const [lr, lc] = nextPosition(row, col, 'down-left');
+      const [rr, rc] = nextPosition(row, col, 'down-right');
+      beams.push({ row: lr, col: lc, dir: 'down-left' });
+      beams.push({ row: rr, col: rc, dir: 'down-right' });
+    } else {
+      // Continue in current direction
+      const [nr, nc] = nextPosition(row, col, dir);
+      beams.push({ row: nr, col: nc, dir });
+    }
+  }
+
+  return visited.size;
+}
+
+/**
+ * Count distinct source-to-exit paths.
+ * Uses memoization on (row, col, direction) to count paths efficiently.
+ * At each splitter, the beam splits into two, so paths multiply.
+ * Returns bigint since the count can be astronomically large.
+ */
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+  if (cols === 0) return 0n;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // Memoize: for a beam entering cell (row,col) with direction dir,
+  // how many paths does it produce?
+  const memo = new Map<string, bigint>();
+
+  function countPaths(row: number, col: number, dir: Direction): bigint {
+    // If out of bounds, this beam has exited -> 1 completed path
+    if (!isInBounds(row, col, rows, cols)) {
+      return 1n;
+    }
+
+    const key = `${row},${col},${dir}`;
+    const cached = memo.get(key);
+    if (cached !== undefined) return cached;
+
+    const cell = grid[row][col];
+    let result: bigint;
+
+    if (cell === '^') {
+      // Splitter: beam splits into down-left and down-right
+      const [lr, lc] = nextPosition(row, col, 'down-left');
+      const [rr, rc] = nextPosition(row, col, 'down-right');
+      result = countPaths(lr, lc, 'down-left') + countPaths(rr, rc, 'down-right');
+    } else {
+      // Continue in current direction
+      const [nr, nc] = nextPosition(row, col, dir);
+      result = countPaths(nr, nc, dir);
+    }
+
+    memo.set(key, result);
+    return result;
+  }
+
+  return countPaths(source[0], source[1], 'down');
+}
