   177→  });\n   178→\n   179→  describe('prerequisites', () => {\n   180→    it('should schedule prerequisite before dependent event', () => {\n   181→      const events: Event[] = [\n   182→        { id: 'e1', name: 'Intro', duration: 60 },\n   183→        { id: 'e2', name: 'Advanced', duration: 60, prerequisites: ['e1'] },\n   184→      ];\n   185→      const result = schedule(events, defaultRooms, defaultOptions);\n   186→      expect(result.assignments).toHaveLength(2);\n   187→\n   188→      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n   189→      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n   190→      expect(a1.endTime).toBeLessThanOrEqual(a2.startTime);\n   191→    });\n   192→\n   193→    it('should enforce gap between prerequisite and dependent event', () => {\n   194→      const events: Event[] = [\n   195→        { id: 'e1', name: 'Intro', duration: 60 },\n   196→        { id: 'e2', name: 'Advanced', duration: 60, prerequisites: ['e1'] },\n   197→      ];\n   198→      const result = schedule(events, defaultRooms, defaultOptions);\n   199→      expect(result.assignments).toHaveLength(2);\n   200→\n   201→      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n   202→      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n   203→      expect(a2.startTime - a1.endTime).toBeGreaterThanOrEqual(15);\n   204→    });\n   205→\n   206→    it('should handle chains of prerequisites', () => {\n   207→      const events: Event[] = [\n   208→        { id: 'e1', name: 'Step 1', duration: 30 },\n   209→        { id: 'e2', name: 'Step 2', duration: 30, prerequisites: ['e1'] },\n   210→        { id: 'e3', name: 'Step 3', duration: 30, prerequisites: ['e2'] },\n   211→      ];\n   212→      const result = schedule(events, defaultRooms, defaultOptions);\n   213→      expect(result.assignments).toHaveLength(3);\n   214→\n   215→      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n   216→      c