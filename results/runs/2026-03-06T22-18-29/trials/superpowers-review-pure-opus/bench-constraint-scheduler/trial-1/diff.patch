st result = schedule([], defaultRooms, defaultOptions);\n    42→      expect(result.assignments).toHaveLength(0);\n    43→      expect(result.unscheduled).toHaveLength(0);\n    44→    });\n    45→\n    46→    it('should use default attendees of 1', () => {\n    47→      const events: Event[] = [\n    48→        { id: 'e1', name: 'Event 1', duration: 60 },\n    49→      ];\n    50→      const rooms: Room[] = [\n    51→        { id: 'r1', name: 'Small Room', capacity: 1 },\n    52→      ];\n    53→      const result = schedule(events, rooms, defaultOptions);\n    54→      expect(result.assignments).toHaveLength(1);\n    55→    });\n    56→  });\n    57→\n    58→  describe('capacity constraints', () => {\n    59→    it('should not schedule an event in a room that is too small', () => {\n    60→      const events: Event[] = [\n    61→        { id: 'e1', name: 'Big Event', duration: 60, attendees: 100 },\n    62→      ];\n    63→      const rooms: Room[] = [\n    64→        { id: 'r1', name: 'Small Room', capacity: 50 },\n    65→      ];\n    66→      const result = schedule(events, rooms, defaultOptions);\n    67→      expect(result.assignments).toHaveLength(0);\n    68→      expect(result.unscheduled).toContain('e1');\n    69→    });\n    70→\n    71→    it('should schedule event in room with sufficient capacity', () => {\n    72→      const events: Event[] = [\n    73→        { id: 'e1', name: 'Medium Event', duration: 60, attendees: 40 },\n    74→      ];\n    75→      const result = schedule(events, defaultRooms, defaultOptions);\n    76→      expect(result.assignments).toHaveLength(1);\n    77→      const assignment = result.assignments[0];\n    78→      const room = defaultRooms.find(r => r.id === assignment.roomId)!;\n    79→      expect(room.capacity).toBeGreaterThanOrEqual(40);\n    80→    });\n    81→  });\n    82→\n    83→  describe('time window constraints', () => {\n    84→    it('should not schedule event that exceeds the time window', () => {\n    85→    