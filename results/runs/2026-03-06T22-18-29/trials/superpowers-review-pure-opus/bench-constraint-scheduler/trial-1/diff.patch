st), so ~4 events can fit\n      const result = schedule(events, rooms, options);\n      expect(result.assignments.length + result.unscheduled.length).toBe(20);\n      expect(result.assignments.length).toBeGreaterThan(0);\n      expect(result.unscheduled.length).toBeGreaterThan(0);\n    });\n  });\n\n  describe('batch optimization', () => {\n    it('should maximize scheduled events even when greedy fails', () => {\n      // Scenario: 2 short events and 1 long event, only 1 room.\n      // If we schedule the long event first, we might not fit the 2 short ones.\n      // Optimal: schedule both short events instead of the one long event.\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Room', capacity: 50 },\n      ];\n      const options: ScheduleOptions = {\n        startTime: 0,\n        endTime: 150,\n        gap: 0,\n      };\n      const events: Event[] = [\n        { id: 'long', name: 'Long Event', duration: 120 },\n        { id: 'short1', name: 'Short 1', duration: 60 },\n        { id: 'short2', name: 'Short 2', duration: 60 },\n      ];\n      const result = schedule(events, rooms, options);\n      // Should schedule 2 short events (total 120 min) rather than 1 long + can't fit the other\n      // Or schedule all 3 if it fits: 120 doesn't leave room for 2x60, but 2x60=120 < 150\n      // Actually: long=120 fits, then short1 starts at 120, ends 180 > 150. So max 1 long or 2 shorts.\n      expect(result.assignments.length).toBe(2);\n      expect(result.unscheduled).toHaveLength(1);\n    });\n  });\n\n  describe('complex scenarios', () => {\n    it('should handle events with multiple prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Lecture 1', duration: 60 },\n        { id: 'e2', name: 'Lecture 2', duration: 60 },\n        { id: 'e3', name: 'Workshop', duration: 90, prerequisites: ['e1', 'e2'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(3);\n\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const a3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(a3.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n    });\n\n    it('should handle mix of constrained and unconstrained events', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Keynote', duration: 120, attendees: 45 },\n        { id: 'e2', name: 'Workshop A', duration: 60, attendees: 20, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Workshop B', duration: 60, attendees: 10 },\n        { id: 'e4', name: 'Panel', duration: 90, attendees: 25, preferredRoom: 'room-b' },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(4);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('should handle no available rooms', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const result = schedule(events, [], defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n  });\n\n  describe('assignment structure', () => {\n    it('should return correctly structured assignments', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      const a = result.assignments[0];\n      expect(a).toHaveProperty('eventId');\n      expect(a).toHaveProperty('roomId');\n      expect(a).toHaveProperty('startTime');\n      expect(a).toHaveProperty('endTime');\n      expect(typeof a.eventId).toBe('string');\n      expect(typeof a.roomId).toBe('string');\n      expect(typeof a.startTime).toBe('number');\n      expect(typeof a.endTime).to