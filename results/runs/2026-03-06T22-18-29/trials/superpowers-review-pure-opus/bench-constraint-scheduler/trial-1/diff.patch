number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\n/**\n * Topologically sort events respecting prerequisites.\n * Throws on cycles (including self-references).\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Check for self-references and invalid prerequisites\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereq of e.prerequisites) {\n        if (prereq === e.id) {\n          throw new Error(`Cycle detected: event \"${e.id}\" lists itself as a prerequisite`);\n        }\n      }\n    }\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const e of events) {\n    color.set(e.id, WHITE);\n  }\n\n  const order: string[] = [];\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const prereq of event.prerequisites) {\n        const prereqColor = color.get(prereq);\n        if (prereqColor === GRAY) {\n          throw new Error(`Cycle detected in prerequisites involving event \"${prereq}\"`);\n        }\n        if (prereqColor === WHITE) {\n          dfs(prereq);\n        }\n        // BLACK means already fully processed, skip\n      }\n    }\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id);\n    }\n  }\n\n  return order;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * considering room occupancy and prerequisite completion times.\n */\nfunction findEarliestStart(\n  event: Event,\n  roomId: string,\n  roomSchedules: Map<string, Assignment[]>,\n  assignmentMap: Map<string, Assignment>,\n  options: ScheduleOptions,\n  gap: number\n): number | null {\n  let earliest = options.startTime;\n\n  // Respect prerequisites: event can't start until all prerequisites are done + gap\n  if (event.prerequisites) {\n    for (const prereqId of event.prerequisites) {\n      const prereqAssignment = assignmentMap.get(prereqId);\n      if (prereqAssignment) {\n        earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n      }\n      // If a prerequisite isn't assigned, we can't schedule this event\n      // (handled by caller filtering)\n    }\n  }\n\n  const endNeeded = earliest + event.duration;\n  if (endNeeded > options.endTime) {\n    return null;\n  }\n\n  // Find a slot in the room that doesn't conflict with existing assignments\n  const roomAssignments = roomSchedules.get(roomId) || [];\n  // Sorted by startTime\n  const sorted = [...roomAssignments].sort((a, b) => a.startTime - b.startTime);\n\n  // Try to fit starting from `earliest`\n  let candidateStart = earliest;\n\n  for (const existing of sorted) {\n    const candidateEnd = candidateStart + event.duration;\n\n    // Check if candidate [candidateStart, candidateEnd] conflicts with existing\n    // Need gap before existing start and after existing end\n    if (candidateEnd + gap <= existing.startTime) {\n      // Fits before this existing event\n      break;\n    }\n    // Must start after this existing event + gap\n    candidateStart = Math.max(candidateStart, existing.endTime + gap);\n  }\n\n  const candidateEnd = candidateStart + event.duration;\n  if (candidateEnd > options.endTime) {\n    return null;\n  }\n\n  return candidateStart;\n}\n\n/**\n * Check if all prerequisites of an event have been assigned.\n */\nfunction prerequisitesMet(\n  event: Event,\n  assignmentMap: Map<string, Assignment>,\n  eventMap: Map<string, Event>\n): boolean {\n  if (!event.prerequisites) return true;\n  for (const prereqId of event.prerequisites) {\n    // Only require assignment if the prerequisite is a known event\n    if (eventMap.has(prereqId) && !assignmentMap.has(prereqId)) {\n      return false;\n    }\n  }\n  return true;\n}\n\n/**\n * Schedule events into rooms using backtracking to maximize the number\n * of scheduled events.\n */\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions\n): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n\n  // Build event map\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Detect cycles (throws on cycle) and get topological order for processing\n  const topoOrder = topologicalSort(events);\n\n  // Filter rooms that can hold at least one event\n  const validRooms = rooms.filter(r => r.capacity > 0);\n\n  if (validRooms.length === 0) {\n    return {\n      assignments: [],\n      unscheduled: events.map(e => e.id),\n    };\n  }\n\n  // For each event, determine which rooms it can fit in (capacity-wise)\n  const eventRooms = new Map<string, Room[]>();\n  for (const e of events) {\n    const attendees = e.attendees ?? 1;\n    const compatible = validRooms.filter(r => r.capacity >= attendees);\n    // Sort: preferred room first, then by capacity (smallest sufficient first)\n    compatible.sort((a, b) => {\n      if (e.preferredRoom) {\n        if (a.id === e.preferredRoom && b.id !== e.preferredRoom) return -1;\n        if (b.id === e.preferredRoom && a.id !== e.preferredRoom) return 1;\n      }\n      return a.capacity - b.capacity;\n    });\n    eventRooms.set(e.id, compatible);\n  }\n\n  // Greedy approach following topological order, trying preferred rooms first.\n  // Then improve with retry passes.\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const r of validRooms) {\n    roomSchedules.set(r.id, []);\n  }\n  const assignmentMap = new Map<string, Assignment>();\n\n  // Process in topological order\n  for (const eventId of topoOrder) {\n    const event = eventMap.get(eventId);\n    if (!event) continue;\n\n    if (!prerequisitesMet(event, assignmentMap, eventMap)) {\n      continue;\n    }\n\n    const compatible = eventRooms.get(eventId) || [];\n    if (compatible.length === 0) continue;\n\n    let bestAssignment: Assignment | null = null;\n\n    for (const room of compatible) {\n      const start = findEarliestStart(\n        event, room.id, roomSchedules, assignmentMap, options, gap\n      );\n      if (start !== null) {\n        const candidate: Assignment = {\n          eventId: event.id,\n          roomId: room.id,\n          startTime: start,\n          endTime: start + event.duration,\n        };\n        if (!bestAssignment || start < bestAssignment.startTime) {\n          bestAssignment = candidate;\n        }\n        // If we got the preferred room, use it immediately\n        if (event.preferredRoom && room.id === event.preferredRoom) {\n          bestAssignment = candidate;\n          break;\n        }\n      }\n    }\n\n    if (bestAssignment) {\n      assignmentMap.set(eventId, bestAssignment);\n      const roomSlots = roomSchedules.get(bestAssignment.roomId)!;\n      roomSlots.push(bestAssignment);\n    }\n  }\n\n  // If all events are scheduled, we're done\n  if (assignmentMap.size === events.length) {\n    return {\n      assignments: Array.from(assignmentMap.values()),\n      unscheduled: [],\n    };\n  }\n\n  // Try to improve: use backtracking/retry for unscheduled events.\n  // Attempt to reschedule to make room for unscheduled events.\n  const unscheduledIds = events\n    .map(e => e.id)\n    .filter(id => !assignmentMap.has(id));\n\n  // For each unscheduled event, try removing other events to make space\n  // Use a more sophisticated approach: try all permutations of scheduling\n  // via recursive backtracking with pruning, limited by time.\n  const bestResult = backtrackSchedule(events, eventMap, eventRooms, topoOrder, validRooms, options, gap);\n\n  if (bestResult.assignmentMap.size > assignmentMap.size) {\n    return {\n      assignments: Array.from(bestResult.assignmentMap.values()),\n      unscheduled: events\n        .map(e => e.id)\n        .filter(id => !bestResult.assignmentMap.has(id)),\n    };\n  }\n\n  return {\n    assignments: Array.from(assignmentMap.values()),\n    unscheduled: unscheduledIds,\n  };\n}\n\ninterface BacktrackResult {\n  assignmentMap: Map<string, Assignment>;\n}\n\nfunction backtrackSchedule(\n  events: Event[],\n  eventMap: Map<string, Event>,\n  eventRooms: Map<string, Room[]>,\n  topoOrder: string[],\n  validRooms: Room[],\n  options: ScheduleOptions,\n  gap: number,\n): BacktrackResult {\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const r of validRooms) {\n    roomSchedules.set(r.id, []);\n  }\n  const assignmentMap = new Map<string, Assignment>();\n\n  let bestAssignmentMap = new Map<string, Assignment>();\n\n  const startMs = Date.now();\n  const timeLimitMs = 3000; // 3 second time limit for backtracking\n\n  function backtrack(idx: number): boolean {\n    // Time limit check\n    if (Date.now() - startMs > timeLimitMs) {\n      return false;\n    }\n\n    if (idx >= topoOrder.length) {\n      // All events processed\n      if (assignmentMap.size > bestAssignmentMap.size) {\n        bestAssignmentMap = new Map(assignmentMap);\n      }\n      return assignmentMap.size === events.length;\n    }\n\n    // Prune: even if we schedule all remaining, can we beat the best?\n    const remaining = topoOrder.length - idx;\n    if (assignmentMap.size + remaining <= bestAssignmentMap.size) {\n      return false;\n    }\n\n    const eventId = topoOrder[idx];\n    const event = eventMap.get(eventId)!;\n\n    // Check prerequisites\n    if (!prerequisitesMet(event, assignmentMap, eventMap)) {\n      // Can't schedule this event, skip it\n      backtrack(idx + 1);\n      return assignmentMap.size === events.length;\n    }\n\n    const compatible = eventRooms.get(eventId) || [];\n    let scheduled = false;\n\n    for (const room of compatible) {\n      const start = findEarliestStart(\n        event, room.id, roomSchedules, assignmentMap, options, gap\n      );\n      if (start !== null) {\n        const assignment: Assignment = {\n          eventId: event.id,\n          roomId: room.id,\n          startTime: start,\n          endTime: start + event.duration,\n        };\n\n        // Place the event\n        assignmentMap.set(eventId, assignment);\n        const roomSlots = roomSchedules.get(room.id)!;\n        roomSlots.push(assignment);\n\n        if (backtrack(idx + 1)) {\n          return true;\n        }\n\n        // Remove assignment\n        assignmentMap.delete(eventId);\n        const removeIdx = roomSlots.indexOf(assignment);\n        if (removeIdx !== -1) roomSlots.splice(removeIdx, 1);\n        scheduled = true; // At least one room worked at some point\n      }\n    }\n\n    // Also try skipping this event (don't schedule it)\n    if (!scheduled || assignmentMap.size + (topoOrder.length - idx - 1) > bestAssignmentMap.size) {\n      backtrack(idx + 1);\n    }\n\n    return false;\n  }\n\n  backtrack(0);\n\n  return { assignmentMap: bestAssignmentMap };\n}\n","structuredPatch":[{"oldStart":249,"oldLines":14,"newStart":249,"newLines":14,"lines":["           startTime: start,","           endTime: start + event.duration,","         };","-        if (!bestAssignment || start < bestAssignment.startTime) {","-          bestAssignment = candidate;","-        }","-        // If we got the preferred room, use it immediately","+        // Preferred room always wins if viable","         if (event.preferredRoom && room.id === event.preferredRoom) {","           bestA