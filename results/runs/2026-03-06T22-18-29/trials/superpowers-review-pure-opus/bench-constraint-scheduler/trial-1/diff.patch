+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F8UjjJ5CzWNFuKhqwcNWSE","type":"tool_result","content":"     1→export interface Event {\n     2→  id: string;\n     3→  name: string;\n     4→  duration: number;\n     5→  attendees?: number;\n     6→  prerequisites?: string[];\n     7→  preferredRoom?: string;\n     8→}\n     9→\n    10→export interface Room {\n    11→  id: string;\n    12→  name: string;\n    13→  capacity: number;\n    14→}\n    15→\n    16→export interface ScheduleOptions {\n    17→  startTime: number;\n    18→  endTime: number;\n    19→  gap?: number;\n    20→}\n    21→\n    22→export interface Assignment {\n    23→  eventId: string;\n    24→  roomId: string;\n    25→  startTime: number;\n    26→  endTime: number;\n    27→}\n    28→\n    29→export interface ScheduleResult {\n    30→  assignments: Assignment[];\n    31→  unscheduled: string[];\n    32→}\n    33→\n    34→/**\n    35→ * Topologically sort events respecting prerequisites.\n    36→ * Throws on cycles (including self-references).\n    37→ */\n    38→function topologicalSort(events: Event[]): string[] {\n    39→  const eventMap = new Map<string, Event>();\n    40→  for (const e of events) {\n    41→    eventMap.set(e.id, e);\n    42→  }\n    43→\n    44→  // Check for self-references and invalid prerequisites\n    45→  for (const e of events) {\n    46→    if (e.prerequisites) {\n    47→      for (const prereq of e.prerequisites) {\n    48→        if (prereq === e.id) {\n    49→          throw new Error(`Cycle detected: event \"${e.id}\" lists itself as a prerequisite`);\n    50→        }\n    51→      }\n    52→    }\n    53→  }\n    54→\n    55→  const WHITE = 0, GRAY = 1, BLACK = 2;\n    56→  const color = new Map<string, number>();\n    57→  for (const e of events) {\n    58→    color.set(e.id, WHITE);\n    59→  }\n    60→\n    61→  const order: string[] = [];\n    62→\n    63→  function dfs(id: string): void {\n    64→    color.set(id, GRAY);\n    65→    const event = eventMap.get(id);\n    66→    if (event?.prerequisites) {\n    67→      for (const prereq of event.prerequisites) {\n    68→        const prereqColor = color.get(prereq);\n    69→        if (prereqColor === GRAY) {\n    70→          throw new Error(`Cycle detected in prerequisites involving event \"${prereq}\"`);\n    71→        }\n    72→        if (prereqColor === WHITE) {\n    73→          dfs(prereq);\n    74→        }\n    75→        // BLACK means already fully processed, skip\n    76→      }\n    77→    }\n    78→    color.set(id, BLACK);\n    79→    order.push(id);\n    80→  }\n    81→\n    82→  for (const e of events) {\n    83→    if (color.get(e.id) === WHITE) {\n    84→      dfs(e.id);\n    85→    }\n    86→  }\n    87→\n    88→  return order;\n    89→}\n    90→\n    91→/**\n    92→ * Find the earliest start time for an event in a given room,\n    93→ * considering room occupancy and prerequisite completion times.\n    94→ */\n    95→function findEarliestStart(\n    96→  event: Event,\n    97→  roomId: string,\n    98→  roomSchedules: Map<string, Assignment[]>,\n    99→  assignmentMap: Map<string, Assignment>,\n   100→  options: ScheduleOptions,\n   101→  gap: number\n   102→): number | null {\n   103→  let earliest = options.startTime;\n   104→\n   105→  // Respect prerequisites: event can't start until all prerequisites are done + gap\n   106→  if (event.prerequisites) {\n   107→    for (const prereqId of event.prerequisites) {\n   108→      const prereqAssignment = assignmentMap.get(prereqId);\n   109→      if (prereqAssignment) {\n   110→        earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n   111→      }\n   112→      // If a prerequisite isn't assigned, we can't schedule this event\n   113→      // (handled by caller filtering)\n   114→    }\n   115→  }\n   116→\n   117→  const endNeeded = earliest + event.duration;\n   118→  if (endNeeded > options.endTime) {\n   119→    return null;\n   120→  }\n   121→\n   122→  // Find a slot in the room that doesn't conflict with existing assignments\n   123→  const roomAssignments = roomSchedules.get(roomId) || [];\n   124→  // Sorted by startTime\n   125→  const sorted = [...roomAssignments].sort((a, b) => a.startTime - b.startTime);\n   126→\n   127→  // Try to fit starting from `earliest`\n   128→  let candidateStart = earliest;\n   129→\n   130→  for (const existing of sorted) {\n   131→    const candidateEnd = candidateStart + event.duration;\n   132→\n   133→    // Check if candidate [candidateStart, candidateEnd] conflicts with existing\n   134→    // Need gap before existing start and after existing end\n   135→    if (candidateEnd + gap <= existing.startTime) {\n   136→      // Fits before this existing event\n   137→      break;\n   138→    }\n   139→    // Must start after this existing event + gap\n   140→    candidateStart = Math.max(candidateStart, existing.endTime + gap);\n   141→  }\n   142→\n   143→  const candidateEnd = candidateStart + event.duration;\n   144→  if (candidateEnd > options.endTime) {\n   145→    return null;\n   146→  }\n   147→\n   148→  return candidateStart;\n   149→}\n   150→\n   151→/**\n   152→ * Check if all prerequisites of an event have been assigned.\n   153→ */\n   154→function prerequisitesMet(\n   155→  event: Event,\n   156→  assignmentMap: Map<string, Assignment>,\n   157→  eventMap: Map<string, Event>\n   158→): boolean {\n   159→  if (!event.prerequisites) return true;\n   160→  for (const prereqId of event.prerequisites) {\n   161→    // Only require assignment if the prerequisite is a known event\n   162→    if (eventMap.has(prereqId) && !assignmentMap.has(prereqId)) {\n   163→      return false;\n   164→    }\n   165→  }\n   166→  return true;\n   167→}\n   168→\n   169→/**\n   170→ * Schedule events into rooms using backtracking to maximize the number\n   171→ * of scheduled events.\n   172→ */\n   173→export function schedule(\n   174→  events: Event[],\n   175→  rooms: Room[],\n   176→  options: ScheduleOptions\n   177→): ScheduleResult {\n   178→  if (events.length === 0) {\n   179→    return { assignments: [], unscheduled: [] };\n   180→  }\n   181→\n   182→  const gap = options.gap ?? 15;\n   183→\n   184→  // Build event map\n   185→  const eventMap = new Map<string, Event>();\n   186→  for (const e of events) {\n   187→    eventMap.set(e.id, e);\n   188→  }\n   189→\n   190→  // Detect cycles (throws on cycle)\n   191→  topologicalSort(events);\n   192→\n   193→  // Get topological order for processing\n   194→  const topoOrder = topologicalSort(events);\n   195→\n   196→  // Filter rooms that can hold at least one event\n   197→  const validRooms = rooms.filter(r => r.capacity > 0);\n   198→\n   199→  if (validRooms.length === 0) {\n   200→    return {\n   201→      assignments: [],\n   202→      unscheduled: events.map(e => e.id),\n   203→    };\n   204→  }\n   205→\n   206→  // For each event, determine which rooms it can fit in (capacity-wise)\n   207→  const eventRooms = new Map<string, Room[]>();\n   208→  for (const e of events) {\n   209→    const attendees = e.attendees ?? 1;\n   210→    const compatible = validRooms.filter(r => r.capacity >= attendees);\n   211→    // Sort: preferred room first, then by capacity (smallest sufficient first)\n   212→    compatible.sort((a, b) => {\n   213→      if (e.preferredRoom) {\n   214→        if (a.id === e.preferredRoom && b.id !== e.preferredRoom) return -1;\n   215→        if (b.id === e.preferredRoom && a.id !== e.preferredRoom) return 1;\n   216→      }\n   217→      return a.capacity - b.capacity;\n   218→    });\n   219→    eventRooms.set(e.id, compatible);\n   220→  }\n   221→\n   222→  // Greedy approach following topological order, trying preferred rooms first.\n   223→  // Then improve with retry passes.\n   224→  const roomSchedules = new Map<string, Assignment[]>();\n   225→  for (const r of validRooms) {\n   226→    roomSchedules.set(r.id, []);\n   227→  }\n   228→  const assignmentMap = new Map<string, Assignment>();\n   229→\n   230→  // Process in topological order\n   231→  for (const eventId of topoOrder) {\n   232→    const event = eventMap.get(eventId);\n   233→    if (!event) continue;\n   234→\n   235→    if (!prerequisitesMet(event, assignmentMap, eventMap)) {\n   236→      continue;\n   237→    }\n   238→\n   239→    const compatible = eventRooms.get(eventId) || [];\n   240→    if (compatible.length === 0) continue;\n   241→\n   242→    let bestAssignment: Assignment | null = null;\n   243→\n   244→    for (const room of compatible) {\n   245→      const start = findEarliestStart(\n   246→        event, room.id, roomSchedules, assignmentMap, options, gap\n   247→      );\n   248→      if (start !== null) {\n   249→        const candidate: Assignment = {\n   250→          eventId: event.id,\n   251→          roomId: room.id,\n   252→          startTime: start,\n   253→          endTime: start + event.duration,\n   254→        };\n   255→        if (!bestAssignment || start < bestAssignment.startTime) {\n   256→          bestAssignment = candidate;\n   257→        }\n   258→        // If we got the preferred room, use it immediately\n   259→        if (event.preferredRoom && room.id === event.preferredRoom) {\n   260→          bestAssignment = candidate;\n   261→          break;\n   262→        }\n   263→      }\n   264→    }\n   265→\n   266→    if (bestAssignment) {\n   267→      assignmentMap.set(eventId, bestAssignment);\n   268→      const schedule = roomSchedules.get(bestAssignment.roomId)!;\n   269→      schedule.push(bestAssignment);\n   270→    }\n   271→  }\n   272→\n   273→  // If all events are scheduled, we're done\n   274→  if (assignmentMap.size === events.length) {\n   275→    return {\n   276→      assignments: Array.from(assignmentMap.values()),\n   277→      unscheduled: [],\n   278→    };\n   279→  }\n   280→\n   281→  // Try to improve: use backtracking/retry for unscheduled events.\n   282→  // Attempt to reschedule to make room for unscheduled events.\n   283→  const unscheduledIds = events\n   284→    .map(e => e.id)\n   285→    .filter(id => !assignmentMap.has(id));\n   286→\n   287→  // For each unscheduled event, try removing other events to make space\n   288→  // Use a more sophisticated approach: try all permutations of scheduling\n   289→  // via recursive backtracking with pruning, limited by time.\n   290→  const bestResult = backtrackSchedule(events, eventMap, eventRooms, topoOrder, validRooms, options, gap);\n   291→\n   292→  if (bestResult.assignmentMap.size > assignmentMap.size) {\n   293→    return {\n   294→      assignments: Array.from(bestResult.assignmentMap.values()),\n   295→      unscheduled: events\n   296→        .map(e => e.id)\n   297→        .filter(id => !bestResult.assignmentMap.has(id)),\n   298→    };\n   299→  }\n   300→\n   301→  return {\n   302→    assignments: Array.from(assignmentMap.values()),\n   303→    unscheduled: unscheduledIds,\n   304→  };\n   305→}\n   306→\n   307→interface BacktrackResult {\n   308→  assignmentMap: Map<string, Assignment>;\n   309→}\n   310→\n   311→function backtrackSchedule(\n   312→  events: Event[],\n   313→  eventMap: Map<string, Event>,\n   314→  eventRooms: Map<string, Room[]>,\n   315→  topoOrder: string[],\n   316→  validRooms: Room[],\n   317→  options: ScheduleOptions,\n   318→  gap: number,\n   319→): BacktrackResult {\n   320→  const roomSchedules = new Map<string, Assignment[]>();\n   321→  for (const r of validRooms) {\n   322→    roomSchedules.set(r.id, []);\n   323→  }\n   324→  const assignmentMap = new Map<string, Assignment>();\n   325→\n   326→  let bestAssignmentMap = new Map<string, Assignment>();\n   327→\n   328→  const startMs = Date.now();\n   329→  const timeLimitMs = 3000; // 3 second time limit for backtracking\n   330→\n   331→  function backtrack(idx: number): boolean {\n   332→    // Time limit check\n   333→    if (Date.now() - startMs > timeLimitMs) {\n   334→      return false;\n   335→    }\n   336→\n   337→    if (idx >= topoOrder.length) {\n   338→      // All events processed\n   339→      if (assignmentMap.size > bestAssignmentMap.size) {\n   340→        bestAssignmentMap = new Map(assignmentMap);\n   341→      }\n   342→      return assignmentMap.size === events.length;\n   343→    }\n   344→\n   345→    // Prune: even if we schedule all remaining, can we beat the best?\n   346→    const remaining = topoOrder.length - idx;\n   347→    if (assignmentMap.size + remaining <= bestAssignmentMap.size) {\n   348→      return false;\n   349→    }\n   350→\n   351→    const eventId = topoOrder[idx];\n   352→    const event = eventMap.get(eventId)!;\n   353→\n   354→    // Check prerequisites\n   355→    if (!prerequisitesMet(event, assignmentMap, eventMap)) {\n   356→      // Can't schedule this event, skip it\n   357→      backtrack(idx + 1);\n   358→      return assignmentMap.size === events.length;\n   359→    }\n   360→\n   361→    const compatible = eventRooms.get(eventId) || [];\n   362→    let scheduled = false;\n   363→\n   364→    for (const room of compatible) {\n   365→      const start = findEarliestStart(\n   366→        event, room.id, roomSchedules, assignmentMap, options, gap\n   367→      );\n   368→      if (start !== null) {\n   369→        const assignment: Assignment = {\n   370→          eventId: event.id,\n   371→          roomId: room.id,\n   372→          startTime: start,\n   373→          endTime: start + event.duration,\n   374→        };\n   375→\n   376→        // Place the event\n   377→        assignmentMap.set(eventId, assignment);\n   378→        const schedule = roomSchedules.get(room.id)!;\n   379→        schedule.push(assignment);\n   380→\n   381→        if (backtrack(idx + 1)) {\n   382→          return true;\n   383→        }\n   384→\n   385→        // Remove assignment\n   386→        assignmentMap.delete(eventId);\n   387→        schedule.pop();\n   388→        scheduled = true; // At least one room worked at some point\n   389→      }\n   390→    }\n   391→\n   392→    // Also try skipping this event (don't schedule it)\n   393→    if (!scheduled || assignmentMap.size + (topoOrder.length - idx - 1) > bestAssignmentMap.size) {\n   394→      backtrack(idx + 1);\n   395→    }\n   396→\n   397→    return false;\n   398→  }\n   399→\n   400→  backtrack(0);\n   401→\n   402→  return { assignmentMap: bestAssignmentMap };\n   403→}\n   404→"}]},"parent_tool_use_id":"toolu_01XN3KbYCFQPHiohnyV9Dtut","session_id":"276bddf2-dcb2-46f6-868b-619a5c5c38aa","uuid":"045c8f01-d2ac-4a77-a90a-6052664e053c"}
