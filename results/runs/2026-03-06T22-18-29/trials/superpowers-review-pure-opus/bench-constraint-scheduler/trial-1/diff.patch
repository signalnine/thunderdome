esult = schedule([], defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('should use default attendees of 1', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Small Room', capacity: 1 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n    });\n  });\n\n  describe('capacity constraints', () => {\n    it('should not schedule an event in a room that is too small', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Big Event', duration: 60, attendees: 100 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Small Room', capacity: 50 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should schedule event in room with sufficient capacity', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Medium Event', duration: 60, attendees: 40 },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      const assignment = result.assignments[0];\n      const room = defaultRooms.find(r => r.id === assignment.roomId)!;\n      expect(room.capacity).toBeGreaterThanOrEqual(40);\n    });\n  });\n\n  describe('time window constraints', () => {\n    it('should not schedule event that exceeds the time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Long Event', duration: 600 },\n      ];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 600,  // only 60 minute window\n      };\n      const result = schedule(events, defaultRooms, options);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should schedule event that exactly fits the time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Perfect Fit', duration: 60 },\n      ];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 600,\n      };\n      const result = schedule(events, defaultRooms, options);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBe(540);\n      expect(result.assignments[0].endTime).toBe(600);\n    });\n\n    it('should keep all events within the time window', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 90 },\n        { id: 'e3', name: 'Event 3', duration: 45 },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      for (const a of result.assignments) {\n        expect(a.startTime).toBeGreaterThanOrEqual(defaultOptions.startTime);\n        expect(a.endTime).toBeLessThanOrEqual(defaultOptions.endTime);\n      }\n    });\n  });\n\n  describe('gap constraints', () => {\n    it('should enforce default 15-minute gap between events in same room', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Only Room', capacity: 50 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);\n    });\n\n    it('should enforce custom gap', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Only Room', capacity: 50 },\n      ];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 1020,\n        gap: 30,\n      };\n      const result = schedule(events, rooms, options);\n      expect(result.assignments).toHaveLength(2);\n\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);\n    });\n\n    it('should allow zero gap', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms: Room[] = [\n        { id: 'r1', name: 'Only Room', capacity: 50 },\n      ];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 660,\n        gap: 0,\n      };\n      const result = schedule(events, rooms, options);\n      expect(result.assignments).toHaveLength(2);\n    });\n  });\n\n  describe('prerequisites', () => {\n    it('should schedule prerequisite before dependent event', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Intro', duration: 60 },\n        { id: 'e2', name: 'Advanced', duration: 60, prerequisites: ['e1'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      expect(a1.endTime).toBeLessThanOrEqual(a2.startTime);\n    });\n\n    it('should enforce gap between prerequisite and dependent event', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Intro', duration: 60 },\n        { id: 'e2', name: 'Advanced', duration: 60, prerequisites: ['e1'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      expect(a2.startTime - a1.endTime).toBeGreaterThanOrEqual(15);\n    });\n\n    it('should handle chains of prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Step 1', duration: 30 },\n        { id: 'e2', name: 'Step 2', duration: 30, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Step 3', duration: 30, prerequisites: ['e2'] },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(3);\n\n      const a1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const a3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(a1.endTime).toBeLessThanOrEqual(a2.startTime);\n      expect(a2.endTime).toBeLessThanOrEqual(a3.startTime);\n    });\n\n    it('should throw on self-referencing prerequisite', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Self Ref', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw on cycle in prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'A', duration: 60, prerequisites: ['e2'] },\n        { id: 'e2', name: 'B', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw on longer cycle in prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'A', duration: 60, prerequisites: ['e3'] },\n        { id: 'e2', name: 'B', duration: 60, prerequisites: ['e1'] },\n        { id: 'e3', name: 'C', duration: 60, prerequisites: ['e2'] },\n      ];\n      expect(() => schedule(events,