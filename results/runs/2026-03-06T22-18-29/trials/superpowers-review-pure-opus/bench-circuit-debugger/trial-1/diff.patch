+    // Swap c05 <-> z06
+    swapOutputs(gates, 'c05', 'z06');
+    // Swap z07 <-> c06
+    swapOutputs(gates, 'z07', 'c06');
+    // Swap t01 <-> z01
+    swapOutputs(gates, 't01', 'z01');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['c05', 'c06', 't01', 't03', 'z01', 'z03', 'z06', 'z07']);
+  });
+
+  it('should handle a 45-bit adder within time limit', () => {
+    const gates = makeNBitAdder(45);
+    // Swap some wires - all structurally detectable
+    swapOutputs(gates, 't05', 'z05');
+    swapOutputs(gates, 'c20', 'z21');
+    swapOutputs(gates, 'z30', 'c29');
+    swapOutputs(gates, 't44', 'z44');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).toEqual([
+      'c20', 'c29', 't05', 't44', 'z05', 'z21', 'z30', 'z44',
+    ]);
+  });
+
+  it('should verify the adder works after unswapping', () => {
+    const gates = make4BitAdder();
+    swapOutputs(gates, 'z01', 'a01');
+    swapOutputs(gates, 'z03', 'b02');
+
+    // The circuit is broken right now
+    const brokenResult = simulate(gates, {
+      x00: 1, x01: 1, x02: 1, x03: 1,
+      y00: 1, y01: 1, y02: 1, y03: 1,
+    });
+    // 15 + 15 = 30 = 11110
+    const brokenZ =
+      (brokenResult.z00 || 0) +
+      ((brokenResult.z01 || 0) << 1) +
+      ((brokenResult.z02 || 0) << 2) +
+      ((brokenResult.z03 || 0) << 3) +
+      ((brokenResult.z04 || 0) << 4);
+    // It should NOT be 30 since wires are swapped
+    expect(brokenZ).not.toBe(30);
+
+    // Find swaps and manually fix them
+    const swappedWires = findSwappedWires(gates);
+    expect(swappedWires).toEqual(['a01', 'b02', 'z01', 'z03']);
+
+    // Fix the swaps manually
+    swapOutputs(gates, 'z01', 'a01');
+    swapOutputs(gates, 'z03', 'b02');
+
+    // Now re-simulate - the circuit should be correct
+    const fixedResult = simulate(gates, {
+      x00: 1, x01: 1, x02: 1, x03: 1,
+      y00: 1, y01: 1, y02: 1, y03: 1,
+    });
+    const fixedZ =
+      (fixedResult.z00 || 0) +
+      ((fixedResult.z01 || 0) << 1) +
+      ((fixedResult.z02 || 0) << 2) +
+      ((fixedResult.z03 || 0) << 3) +
+      ((fixedResult.z04 || 0) << 4);
+    expect(fixedZ).toBe(30);
+  });
+
+  it('should work with randomized wire names', () => {
+    // Build a 4-bit adder with random internal wire names
+    const gates: Gate[] = [
+      // Bit 0: half adder
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'abc' }, // c00 -> abc
+
+      // Bit 1: full adder
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'def' }, // t01 -> def
+      { op: 'XOR', in1: 'def', in2: 'abc', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'ghi' }, // a01 -> ghi
+      { op: 'AND', in1: 'def', in2: 'abc', out: 'jkl' }, // b01 -> jkl
+      { op: 'OR', in1: 'ghi', in2: 'jkl', out: 'mno' },  // c01 -> mno
+
+      // Bit 2: full adder
+      { op: 'XOR', in1: 'x02', in2: 'y02', out: 'pqr' }, // t02 -> pqr
+      { op: 'XOR', in1: 'pqr', in2: 'mno', out: 'z02' },
+      { op: 'AND', in1: 'x02', in2: 'y02', out: 'stu' }, // a02 -> stu
+      { op: 'AND', in1: 'pqr', in2: 'mno', out: 'vwx' }, // b02 -> vwx
+      { op: 'OR', in1: 'stu', in2: 'vwx', out: 'yz1' },  // c02 -> yz1
