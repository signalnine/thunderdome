findSwappedWires, Gate } from './index.js';\n\ndescribe('simulate', () => {\n  it('should handle a single AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle a single OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle a single XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n  });\n\n  it('should handle gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n  });\n\n  it('should handle gates listed out of dependency order', () => {\n    // Gate listed before its dependency\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n  });\n\n  it('should simulate a correct 2-bit adder (0+0)', () => {\n    const gates = make2BitAdder();\n    const result = simulate(gates, {\n      x00: 0, x01: 0,\n      y00: 0, y01: 0,\n    });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n  });\n\n  it('should simulate a correct 2-bit adder (3+3=6)', () => {\n    const gates = make2BitAdder();\n    const result = simulate(gates, {\n      x00: 1, x01: 1,\n      y00: 1, y01: 1,\n    });\n    // 3 + 3 = 6 = 110 in binary\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n  });\n\n  it('should simulate a correct 2-bit adder (2+1=3)', () => {\n    const gates = make2BitAdder();\n    const result = simulate(gates, {\n      x00: 0, x01: 1,\n      y00: 1, y01: 0,\n    });\n    // 2 + 1 = 3 = 011\n    expect(result.z00).toBe(1);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  it('should find swapped wires in a small circuit', () => {\n    const gates = make4BitAdder();\n    // Swap z01 <-> a01\n    swapOutputs(gates, 'z01', 'a01');\n    // Swap z03 <-> b02\n    swapOutputs(gates, 'z03', 'b02');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'b02', 'z01', 'z03']);\n  });\n\n  it('should find swapped wires when carry wire is swapped', () => {\n    const gates = make4BitAdder();\n    // Swap t02 <-> z02\n    swapOutputs(gates, 't02', 'z02');\n    // Swap c03 <-> a03\n    swapOutputs(gates, 'c03', 'a03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a03', 'c03', 't02', 'z02']);\n  });\n\n  it('should find swapped wires including final carry', () => {\n    const gates = make4BitAdder();\n    // Swap c03 <-> z04 (final carry)\n    swapOutputs(gates, 'c03', 'z04');\n    // Swap t01 <-> a02\n    swapOutputs(gates, 't01', 'a02');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a02', 'c03', 't01', 'z04']);\n  });\n\n  it('should handle a larger circuit (8-bit adder)', () => {\n    const gates = makeNBitAdder(8);\n    // Swap t03 <-> z03\n    swapOutputs(gates, 't03', 'z03');\n    // Swap a05 <-> b05\n    swapOutputs(gates, 'a05', 'b05');\n    // Swap z07 <-> c06\n    swapOutputs(gates, 'z07', 'c06');\n    // Swap t01 <-> z01\n    swapOutputs(gates, 't01', 'z01');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a05', 'b05', 'c06', 't01', 't03', 'z01', 'z03', 'z07']);\n  });\n\n  it('should handle a 45-bit adder within time limit', () => {\n    const gates = makeNBitAdder(45);\n    // Swap some wires\n    swapOutputs(gates, 't05', 'z05');\n    swapOutputs(gates, 'a20', 'b20');\n    swapOutputs(gates, 'z30', 'c29');\n    swapOutputs(gates, 't44', 'z44');\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual([\n      'a20', 'b20', 'c29', 't05', 't44', 'z05', 'z30', 'z44',\n    ]);\n  });\n\n  it('should verify the adder works after unswapping', () => {\n    const gates = make4BitAdder();\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 'b02');\n\n    // The circuit is broken right now\n    const brokenResult = simulate(gates, {\n      x00: 1, x01: 1, x02: 1, x03: 1,\n      y00: 1, y01: 1, y02: 1, y03: 1,\n    });\n    // 15 + 15 = 30 = 11110\n    const brokenZ =\n      (brokenResult.z00 || 0) +\n      ((brokenResult.z01 || 0) << 1) +\n      ((brokenResult.z02 || 0) << 2) +\n      ((brokenResult.z03 || 0) << 3) +\n      ((brokenResult.z04 || 0) << 4);\n    // It should NOT be 30 since wires are swapped\n    expect(brokenZ).not.toBe(30);\n\n    // Now find and fix swaps\n    findSwappedWires(gates);\n\n    // After findSwappedWires, the gates have been fixed in-place\n    // Let's re-simulate\n    const fixedResult = simulate(gates, {\n      x00: 1, x01: 1, x02: 1, x03: 1,\n      y00: 1, y01: 1, y02: 1, y03: 1,\n    });\n    const fixedZ =\n      (fixedResult.z00 || 0) +\n      ((fixedResult.z01 || 0) << 1) +\n      ((fixedResult.z02 || 0) << 2) +\n      ((fixedResult.z03 || 0) << 3) +\n      ((fixedResult.z04 || 0) << 4);\n    expect(fixedZ).toBe(30);\n  });\n});\n\n// ---- Helpers ----\n\nfunction pad(n: number): string {\n  return String(n).padStart(2, '0');\n}\n\nfunction make2BitAdder(): Gate[] {\n  return makeNBitAdder(2);\n}\n\nfunction make4BitAdder(): Gate[] {\n  return makeNBitAdder(4);\n}\n\nfunction makeNBitAdder(bits: number): Gate[] {\n  const gates: Gate[] = [];\n\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `z${pad(0)}` });\n  gates.push({ op: 'AND', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `c${pad(0)}` });\n\n  // Bits 1..N-1: full adders\n  for (let i = 1; i < bits; i++) {\n    const x = `x${pad(i)}`;\n    const y = `y${pad(i)}`;\n    const z = `z${pad(i)}`;\n    const t = `t${pad(i)}`;\n    const a = `a${pad(i)}`;\n    const b = `b${pad(i)}`;\n    const c = `c${pad(i)}`;\n    const cPrev = `c${pad(i - 1)}`;\n\n    gates.push({ op: 'XOR', in1: x, in2: y, out: t });\n    gates.push({ op: 'XOR', in1: t, in2: cPrev, out: z });\n    gates.push({ op: 'AND', in1: x, in2: y, out: a });\n    gates.push({ op: 'AND', in1: t, in2: cPrev, out: b });\n    gates.push({ op: 'OR', in1: a, in2: b, out: c });\n  }\n\n  // Final carry\n  // In the actual circuit, the last carry IS z_N\n  // We need a wire from c_{N-1} to z_N. In a real circuit this might just be a direct connection,\n  // but since we only have gates, we use an OR with both inputs being the same wire,\n  // or we just set the last carry output to z_N directly.\n  // Actually, looking at the example: \"c03 -> z04\" - this is a direct wire.\n  // In our gate model, we can represent this as: the last OR gate outputs directly to z_N.\n  // Let's just rename the last carry output.\n  const lastCarry = `c${pad(bits - 1)}`;\n  const finalZ = `z${pad(bits)}`;\n  // Find the gate that outputs the last carry and rename it\n  const lastCarryGate = gates.find((g) => g.out === lastCarry);\n  if (lastCarryGate) {\n    lastCarryGate.out = finalZ;\n  }\n\n  return gates;\n}\n\nfunction swapOutputs(gates: Gate[], wire1: string, wire2: string) {\n  const gate1 = gates.find((g) => g.out === wire1);\n  const gate2 = gates.find((g) => g.out === wire2);\n  if (!gate1 || !gate2) {\n    throw new Error(`Cannot find gates with outputs ${wire1} and ${wire2}`);\n  }\n  gate1.out = wire2;\n  gate2.out = wire1;\n}\n","structuredPatch":[{"oldStart":97,"oldLines":22,"newStart":97,"newLines":23,"lines":["     const gates = make4BitAdder();","     // Swap t02 <-> z02","     swapOutputs(gates, 't02', 'z02');","-    // Swap c03 <-> a03","-    swapOutputs(gates, 'c03', 'a03');","+    // Swap c02 <-> a03","+    swapOutputs(gates, 'c02', 'a03');"," ","     const result = findSwappedWires(gates);","-    expect(result).toEqual(['a03', 'c03', 't02', 'z02']);","+    expect(result).toEqual(['a03', 'c02', 't02', 'z02']);","   });"," ","   it('should find swapped wires including final carry', () => {","     const gates = make4BitAdder();","-    // Swap c03 <-> z04 (final carry)","-    swapOutputs(gates, 'c03', 'z04');","+    // Swap z04 (which is what the last carry gate outputs) with a01","+    // The last carry gate outputs z04, swap that with t03","+    swapOutputs(gates, 'z04', 't03');","     // Swap t01 <-> a02","     swapOutputs(gates, 't01', 'a02');"," ","     const result = findSwappedWires(gates);","-    expect(result).toEqual(['a02', 'c03', 't01', 'z04']);","+    expect(result).toEqual(['a02', 't01', 't03', 'z04']);","   });"," ","   it('should handle a larger circuit (8-bit adder)', () => {"]}],"userModified":false,"replaceAll":false}}
