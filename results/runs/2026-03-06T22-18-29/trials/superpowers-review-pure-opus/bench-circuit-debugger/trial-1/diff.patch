r): string {\n  return String(n).padStart(2, '0');\n}\n\nfunction make2BitAdder(): Gate[] {\n  return makeNBitAdder(2);\n}\n\nfunction make4BitAdder(): Gate[] {\n  return makeNBitAdder(4);\n}\n\nfunction makeNBitAdder(bits: number): Gate[] {\n  const gates: Gate[] = [];\n\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `z${pad(0)}` });\n  gates.push({ op: 'AND', in1: `x${pad(0)}`, in2: `y${pad(0)}`, out: `c${pad(0)}` });\n\n  // Bits 1..N-1: full adders\n  for (let i = 1; i < bits; i++) {\n    const x = `x${pad(i)}`;\n    const y = `y${pad(i)}`;\n    const z = `z${pad(i)}`;\n    const t = `t${pad(i)}`;\n    const a = `a${pad(i)}`;\n    const b = `b${pad(i)}`;\n    const c = `c${pad(i)}`;\n    const cPrev = `c${pad(i - 1)}`;\n\n    gates.push({ op: 'XOR', in1: x, in2: y, out: t });\n    gates.push({ op: 'XOR', in1: t, in2: cPrev, out: z });\n    gates.push({ op: 'AND', in1: x, in2: y, out: a });\n    gates.push({ op: 'AND', in1: t, in2: cPrev, out: b });\n    gates.push({ op: 'OR', in1: a, in2: b, out: c });\n  }\n\n  // Final carry\n  // In the actual circuit, the last carry IS z_N\n  // We need a wire from c_{N-1} to z_N. In a real circuit this might just be a direct connection,\n  // but since we only have gates, we use an OR with both inputs being the same wire,\n  // or we just set the last carry output to z_N directly.\n  // Actually, looking at the example: \"c03 -> z04\" - this is a direct wire.\n  // In our gate model, we can represent this as: the last OR gate outputs directly to z_N.\n  // Let's just rename the last carry output.\n  const lastCarry = `c${pad(bits - 1)}`;\n  const finalZ = `z${pad(bits)}`;\n  // Find the gate that outputs the last carry and rename it\n  const lastCarryGate = gates.find((g) => g.out === lastCarry);\n  if (lastCarryGate) {\n    lastCarryGate.out = finalZ;\n  }\n\n  return gates;\n}\n\nfunction swapOutputs(gates: Gate[], wire1: string, wire2: string) {\n  const gate1 = gates.find((g) => g.out === wire1);\n  const gate2 = gates.find((g) => g.out === wire2);\n  if (!gate1 || !gate2) {\n    throw new Error(`Cannot find gates with outputs ${wire1} and ${wire2}`);\n  }\n  gate1.out = wire2;\n  gate2.out = wire1;\n}\n","structuredPatch":[{"oldStart":133,"oldLines":9,"newStart":133,"newLines":9,"lines":[" ","   it('should handle a 45-bit adder within time limit', () => {","     const gates = makeNBitAdder(45);","-    // Swap some wires","+    // Swap some wires - all structurally detectable","     swapOutputs(gates, 't05', 'z05');","-    swapOutputs(gates, 'a20', 'b20');","+    swapOutputs(gates, 'c20', 'z21');","     swapOutputs(gates, 'z30', 'c29');","     swapOutputs(gates, 't44', 'z44');"," "]},{"oldStart":145,"oldLines":7,"newStart":145,"newLines":7,"lines":[" ","     expect(elapsed).toBeLessThan(5000);","     expect(result).toEqual([","-      'a20', 'b20', 'c29', 't05', 't44', 'z05', 'z30', 'z44',","+      'c20', 'c29', 't05', 't44', 'z05', 'z21', 'z30', 'z44',","     ]);","   });"," "]}],"userModified":false,"replaceAll":false}}
