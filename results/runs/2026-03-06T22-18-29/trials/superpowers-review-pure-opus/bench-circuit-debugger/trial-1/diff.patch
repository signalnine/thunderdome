+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from './index.js';
+
+describe('simulate', () => {
+  it('should handle a single AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 0 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should handle a single OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should handle a single XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+  });
+
+  it('should handle gates in dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, c: 1, d: 0, e: 1,
+    });
+  });
+
+  it('should handle gates listed out of dependency order', () => {
+    // Gate listed before its dependency
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, c: 1, d: 0, e: 1,
+    });
+  });
+
+  it('should simulate a correct 2-bit adder (0+0)', () => {
+    const gates = make2BitAdder();
+    const result = simulate(gates, {
+      x00: 0, x01: 0,
+      y00: 0, y01: 0,
+    });
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(0);
+    expect(result.z02).toBe(0);
+  });
+
+  it('should simulate a correct 2-bit adder (3+3=6)', () => {
+    const gates = make2BitAdder();
+    const result = simulate(gates, {
+      x00: 1, x01: 1,
+      y00: 1, y01: 1,
+    });
+    // 3 + 3 = 6 = 110 in binary
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(1);
+  });
+
+  it('should simulate a correct 2-bit adder (2+1=3)', () => {
+    const gates = make2BitAdder();
+    const result = simulate(gates, {
+      x00: 0, x01: 1,
+      y00: 1, y01: 0,
+    });
+    // 2 + 1 = 3 = 011
+    expect(result.z00).toBe(1);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(0);
+  });
+});
+
+describe('findSwappedWires', () => {
+  it('should find swapped wires in a small circuit', () => {
+    const gates = make4BitAdder();
+    // Swap z01 <-> a01
+    swapOutputs(gates, 'z01', 'a01');
+    // Swap z03 <-> b02
+    swapOutputs(gates, 'z03', 'b02');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'b02', 'z01', 'z03']);
+  });
+
+  it('should find swapped wires when carry wire is swapped', () => {
+    const gates = make4BitAdder();
+    // Swap t02 <-> z02
+    swapOutputs(gates, 't02', 'z02');
+    // Swap c02 <-> a03
+    swapOutputs(gates, 'c02', 'a03');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a03', 'c02', 't02', 'z02']);
+  });
+
+  it('should find swapped wires including final carry', () => {
+    const gates = make4BitAdder();
+    // Swap z04 (which is what the last carry gate outputs) with a01
+    // The last carry gate outputs z04, swap that with t03
+    swapOutputs(gates, 'z04', 't03');
+    // Swap t01 <-> a02
+    swapOutputs(gates, 't01', 'a02');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a02', 't01', 't03', 'z04']);
+  });
+
+  it('should handle a larger circuit (8-bit adder)', () => {
