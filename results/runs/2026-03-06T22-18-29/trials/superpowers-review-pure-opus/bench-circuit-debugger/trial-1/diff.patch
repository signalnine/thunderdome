hA, aWire);\n          swap(bWire, correctBWire);\n          carryGate = orWithA;\n        } else {\n          const orWithB = findGateWithInput('OR', bWire);\n          if (orWithB) {\n            const correctAWire = otherInput(orWithB, bWire);\n            swap(aWire, correctAWire);\n            carryGate = orWithB;\n          } else {\n            throw new Error(`Cannot find carry OR gate for bit ${bit}`);\n          }\n        }\n      }\n\n      carry = carryGate.out;\n    }\n  }\n\n  // The final carry should be the final z wire\n  if (carry !== finalZWire) {\n    swap(carry!, finalZWire);\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":77,"oldLines":11,"newStart":77,"newLines":6,"lines":["     return /^[xy]\\d+$/.test(wire);","   }"," ","-  // Helper: check if a wire is a z output","-  function isZOutput(wire: string): boolean {","-    return /^z\\d+$/.test(wire);","-  }","-","   // Helper: find gate by op and inputs (unordered)","   function findGate(","     op: Gate['op'],"]}],"userModified":false,"replaceAll":false}}
