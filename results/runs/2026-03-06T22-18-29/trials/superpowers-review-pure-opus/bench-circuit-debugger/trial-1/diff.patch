s\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Find the number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n\n  // Helper: find gate by op and inputs (unordered)\n  function findGate(\n    op: Gate['op'],\n    in1: string,\n    in2: string\n  ): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) || (g.in1 === in2 && g.in2 === in1))\n    );\n  }\n\n  const swapped = new Set<string>();\n\n  function swap(a: string, b: string) {\n    const gateA = gateByOutput.get(a)!;\n    const gateB = gateByOutput.get(b)!;\n    gateA.out = b;\n    gateB.out = a;\n    gateByOutput.set(a, gateB);\n    gateByOutput.set(b, gateA);\n    swapped.add(a);\n    swapped.add(b);\n  }\n\n  // Validate the adder structure bit by bit, fixing swaps as we find them.\n  // We track the carry wire from the previous bit.\n  let carry: string | undefined;\n\n  for (let bit = 0; bit < numBits; bit++) {\n    const xWire = `x${String(bit).padStart(2, '0')}`;\n    const yWire = `y${String(bit).padStart(2, '0')}`;\n    const zWire = `z${String(bit).padStart(2, '0')}`;\n\n    if (bit === 0) {\n      // Half adder: x00 XOR y00 -> z00, x00 AND y00 -> c00\n      const xorGate = findGate('XOR', xWire, yWire);\n      if (!xorGate) throw new Error(`Missing XOR gate for bit 0`);\n\n      if (xorGate.out !== zWire) {\n        // The XOR output is swapped with something\n        swap(xorGate.out, zWire);\n      }\n\n      const andGate = findGate('AND', xWire, yWire);\n      if (!andGate) throw new Error(`Missing AND gate for bit 0`);\n\n      carry = andGate.out;\n    } else {\n      // Full adder for bit i:\n      // Step 1: x_i XOR y_i -> t_i\n      const xorGate = findGate('XOR', xWire, yWire);\n      if (!xorGate) throw new Error(`Missing XOR gate for bit ${bit}`);\n      let tWire = xorGate.out;\n\n      // Step 2: t_i XOR carry -> z_i\n      let sumGate = findGate('XOR', tWire, carry!);\n\n      if (!sumGate) {\n        // The tWire or carry might be swapped.\n        // Since carry was computed from previous (validated) stages, tWire is likely swapped.\n        // Find the XOR gate that uses carry as an input\n        const xorWithCarry = gates.find(\n          (g) =>\n            g.op === 'XOR' &&\n            (g.in1 === carry || g.in2 === carry)\n        );\n        if (xorWithCarry) {\n          // The other input of this gate should be tWire but it's something else\n          const otherInput =\n            xorWithCarry.in1 === carry ? xorWithCarry.in2 : xorWithCarry.in1;\n          // tWire should have been otherInput; swap them\n          swap(tWire, otherInput);\n          tWire = otherInput;\n          sumGate = xorWithCarry;\n        } else {\n          throw new Error(\n            `Cannot find sum XOR gate for bit ${bit}`\n          );\n        }\n      }\n\n      // The sum gate output should be z_i\n      if (sumGate.out !== zWire) {\n        swap(sumGate.out, zWire);\n        // After swap, update sumGate reference - sumGate.out is now zWire\n      }\n\n      // Step 3: x_i AND y_i -> a_i (generate)\n      const genGate = findGate('AND', xWire, yWire);\n      if (!genGate) throw new Error(`Missing AND(x,y) gate for bit ${bit}`);\n      const aWire = genGate.out;\n\n      // Step 4: t_i AND carry -> b_i (propagate)\n      const propGate = findGate('AND', tWire, carry!);\n      if (!propGate) throw new Error(`Missing AND(t,carry) gate for bit ${bit}`);\n      const bWire = propGate.out;\n\n      // Step 5: a_i OR b_i -> c_i (carry out)\n      let carryGate = findGate('OR', aWire, bWire);\n\n      if (!carryGate) {\n        // One of aWire or bWire might be swapped.\n        // Find the OR gat