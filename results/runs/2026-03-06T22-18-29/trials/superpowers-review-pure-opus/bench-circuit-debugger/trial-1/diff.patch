+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit: given gates and initial wire values, compute all wire values.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let progress = true;
+  while (remaining.length > 0 && progress) {
+    progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find 8 wires (4 pairs) whose outputs have been swapped in a ripple-carry adder circuit.
+ *
+ * Uses structural rules of a ripple-carry adder to identify wires that are out of place.
+ * Works by walking the adder bit-by-bit, fixing swaps as they are found.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Work on a copy so we don't mutate the input
+  const gatesCopy = gates.map((g) => ({ ...g }));
+
+  // Build lookup structures
+  const gateByOutput = new Map<string, Gate>();
+  for (const g of gatesCopy) {
+    gateByOutput.set(g.out, g);
+  }
+
+  // Find the number of input bits
+  let maxBit = 0;
+  for (const g of gatesCopy) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^[xy](\d+)$/);
+      if (m) {
+        maxBit = Math.max(maxBit, parseInt(m[1], 10));
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+  const finalZWire = `z${String(numBits).padStart(2, '0')}`;
+
+  // Helper: check if a wire is an x or y input
+  function isInput(wire: string): boolean {
+    return /^[xy]\d+$/.test(wire);
+  }
+
+  // Helper: find gate by op and inputs (unordered)
+  function findGate(
+    op: Gate['op'],
+    in1: string,
+    in2: string
+  ): Gate | undefined {
+    return gatesCopy.find(
+      (g) =>
+        g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) ||
+          (g.in1 === in2 && g.in2 === in1))
+    );
+  }
+
+  // Helper: find gate that has a specific wire as input
+  function findGateWithInput(
+    op: Gate['op'],
+    wire: string
+  ): Gate | undefined {
+    return gatesCopy.find(
+      (g) => g.op === op && (g.in1 === wire || g.in2 === wire)
+    );
+  }
+
+  // Helper: get the other input of a gate
+  function otherInput(gate: Gate, wire: string): string {
+    return gate.in1 === wire ? gate.in2 : gate.in1;
+  }
+
+  const swapped = new Set<string>();
+
+  function swap(a: string, b: string) {
+    const gateA = gateByOutput.get(a);
+    const gateB = gateByOutput.get(b);
+    if (!gateA || !gateB) {
+      throw new Error(`Cannot swap: missing gate for wire ${!gateA ? a : b}`);
+    }
+    gateA.out = b;
+    gateB.out = a;
+    gateByOutput.set(a, gateB);
+    gateByOutput.set(b, gateA);
+    swapped.add(a);
+    swapped.add(b);
+  }
+
+  // Helper: does a gate take x_i and y_i as inputs?
+  function gateHasXYInputs(gate: Gate): boolean {
+    return (
+      (isInput(gate.in1) && isInput(gate.in2)) &&
+      gate.in1[0] !== gate.in2[0] // one is x, other is y
+    );
+  }
+
+  // Walk the adder structure bit by bit
+  let carry: string | undefined;
+
+  for (let bit = 0; bit < numBits; bit++) {
+    const xWire = `x${String(bit).padStart(2, '0')}`;
+    const yWire = `y${String(bit).padStart(2, '0')}`;
+    const zWire = `z${String(bit).padStart(2, '0')}`;
+
+    if (bit === 0) {
+      // Half adder: x00 XOR y00 -> z00, x00 AND y00 -> c00
+      const xorGate = findGate('XOR', xWire, yWire);
+      if (!xorGate) throw new Error(`Missing XOR gate for bit 0`);
+
+      if (xorGate.out !== zWire) {
+        swap(xorGate.out, zWire);
+      }
+
+      const andGate = findGate('AND', xWire, yWire);
+      if (!andGate) throw new Error(`Missing AND gate for bit 0`);
+
+      carry = andGate.out;
+
+      // Check if carry is z-something (which would be wrong for a carry)
+      // This gets caught later when we try to use it
+    } else {
+      // Full adder for bit i:
+      // Step 1: x_i XOR y_i -> t_i (partial sum)
+      const xorGate = findGate('XOR', xWire, yWire);
+      if (!xorGate) throw new Error(`Missing XOR gate for bit ${bit}`);
+      let tWire = xorGate.out;
+
+      // Step 2: t_i XOR carry -> z_i (final sum)
+      // The sum gate uses tWire and carry as inputs
+      let sumGate = findGate('XOR', tWire, carry!);
+
+      if (!sumGate) {
+        // tWire might be swapped with something else.
+        // Since carry was validated in previous iterations (or is bit 0's AND output),
+        // tWire is the more likely swap candidate.
+        // But carry could also be swapped if the carry output from the previous stage was wrong.
+
+        // Strategy: Look for an XOR gate that uses carry as one input.
+        // That gate's other input should be tWire, but tWire was swapped.
+        const xorWithCarry = findGateWithInput('XOR', carry!);
+
+        if (xorWithCarry && !gateHasXYInputs(xorWithCarry)) {
+          // Found an XOR gate using carry. Its other input is what tWire should be.
+          const correctTWire = otherInput(xorWithCarry, carry!);
+          swap(tWire, correctTWire);
+          tWire = correctTWire;
+          sumGate = xorWithCarry;
+        } else {
+          // carry might be wrong. Look for an XOR gate that uses tWire as input.
+          const xorWithT = gatesCopy.find(
+            (g) =>
+              g.op === 'XOR' &&
+              (g.in1 === tWire || g.in2 === tWire) &&
+              !gateHasXYInputs(g)
+          );
+          if (xorWithT) {
+            const correctCarry = otherInput(xorWithT, tWire);
+            swap(carry!, correctCarry);
+            carry = correctCarry;
+            sumGate = xorWithT;
+          } else {
+            throw new Error(
+              `Cannot find sum XOR gate for bit ${bit}`
+            );
+          }
+        }
+      }
+
+      // The sum gate output should be z_i
+      if (sumGate.out !== zWire) {
+        swap(sumGate.out, zWire);
+      }
+
+      // Step 3: x_i AND y_i -> a_i (generate carry)
+      const genGate = findGate('AND', xWire, yWire);
+      if (!genGate) throw new Error(`Missing AND(x,y) gate for bit ${bit}`);
+      const aWire = genGate.out;
+
+      // Step 4: t_i AND carry -> b_i (propagate carry)
+      const propGate = findGate('AND', tWire, carry!);
+      if (!propGate)
+        throw new Error(`Missing AND(t,carry) gate for bit ${bit}`);
+      const bWire = propGate.out;
+
+      // Step 5: a_i OR b_i -> c_i (carry out)
+      let carryGate = findGate('OR', aWire, bWire);
+
+      if (!carryGate) {
+        // One of aWire or bWire might be swapped.
+        const orWithA = findGateWithInput('OR', aWire);
+        if (orWithA) {
+          const correctBWire = otherInput(orWithA, aWire);
+          swap(bWire, correctBWire);
+          carryGate = orWithA;
+        } else {
+          const orWithB = findGateWithInput('OR', bWire);
+          if (orWithB) {
+            const correctAWire = otherInput(orWithB, bWire);
+            swap(aWire, correctAWire);
+            carryGate = orWithB;
+          } else {
+            throw new Error(`Cannot find carry OR gate for bit ${bit}`);
+          }
+        }
+      }
+
+      carry = carryGate.out;
+    }
+  }
+
+  // The final carry should be the final z wire
+  if (carry !== finalZWire) {
+    swap(carry!, finalZWire);
+  }
+
+  return [...swapped].sort();
+}
