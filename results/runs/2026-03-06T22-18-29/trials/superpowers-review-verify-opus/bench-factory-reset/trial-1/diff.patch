+      if (zeroEntry) {
+        const totalCost = zeroEntry.freeSum + freeSum2; // all pivots are 0
+        if (totalCost < bestTotal || (totalCost === bestTotal)) {
+          const allFreeVals = [...zeroEntry.freeVals, ...vals2];
+          const pivotValues = new Array(rank).fill(0);
+          const candidate = buildCounterSolution(allFreeVals, pivotValues, freeVars, pivotCol, numButtons);
+          if (totalCost < bestTotal) {
+            bestTotal = totalCost;
+            bestSolution = candidate;
+          } else if (bestSolution === null || lexSmallerArr(candidate, bestSolution)) {
+            bestSolution = candidate;
+          }
+        }
+      }
+
+      // Also iterate all signature entries for completeness (the zero-pivot
+      // lookup is a fast path but may not always give the minimum total).
+      for (let e = 0; e < sigEntries.length; e++) {
+        const entry = sigEntries[e];
+
+        const totalFreeSum = entry.freeSum + freeSum2;
+        if (totalFreeSum > bestTotal) continue;
+
+        let total = totalFreeSum;
+        let pruned = false;
+        for (let r = 0; r < rank; r++) {
+          const pv = ((pivotConsts[r] - entry.partials[r] - partials2[r]) % p + p) % p;
+          total += pv;
+          if (total > bestTotal) {
+            pruned = true;
+            break;
+          }
+        }
+
+        if (pruned) continue;
+
+        const allFreeVals = [...entry.freeVals, ...vals2];
+        const pivotValues = new Array(rank);
+        for (let r = 0; r < rank; r++) {
+          pivotValues[r] = ((pivotConsts[r] - entry.partials[r] - partials2[r]) % p + p) % p;
+        }
+        const candidate = buildCounterSolution(allFreeVals, pivotValues, freeVars, pivotCol, numButtons);
+
+        if (total < bestTotal) {
+          bestTotal = total;
+          bestSolution = candidate;
+        } else if (total === bestTotal) {
+          if (bestSolution === null || lexSmallerArr(candidate, bestSolution)) {
+            bestSolution = candidate;
+          }
+        }
+      }
+    }
+
+    // Increment vals2 with carry-based termination.
+    done2 = true;
+    for (let i = half2Size - 1; i >= 0; i--) {
+      vals2[i]++;
+      if (vals2[i] < p) {
+        for (let r = 0; r < rank; r++) {
+          partials2[r] = (partials2[r] + pivotFreeCoeffs[r][half1Size + i]) % p;
+        }
+        done2 = false;
+        break;
+      }
+      vals2[i] = 0;
+      for (let r = 0; r < rank; r++) {
+        partials2[r] = ((partials2[r] - (p - 1) * pivotFreeCoeffs[r][half1Size + i]) % p + p) % p;
+      }
+    }
+  }
+
+  return bestSolution;
+}
+
+function buildCounterSolution(
+  freeVals: number[], pivotValues: number[],
+  freeVars: number[], pivotCol: number[],
+  numButtons: number
+): number[] {
+  const sol = new Array(numButtons).fill(0);
+  for (let f = 0; f < freeVals.length; f++) {
+    sol[freeVars[f]] = freeVals[f];
+  }
+  for (let r = 0; r < pivotValues.length; r++) {
+    sol[pivotCol[r]] = pivotValues[r];
+  }
+  return sol;
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function modInverse(a: number, p: number): number {
+  a = ((a % p) + p) % p;
+  let [old_r, r] = [a, p];
+  let [old_s, s] = [1, 0];
+
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+
+  return ((old_s % p) + p) % p;
+}
