(allZero && matrix[r][numButtons] !== 0) {\n   261→      return null;\n   262→    }\n   263→  }\n   264→\n   265→  // Identify free variables.\n   266→  const pivotColSet = new Set(pivotCol);\n   267→  const freeVars: number[] = [];\n   268→  for (let col = 0; col < numButtons; col++) {\n   269→    if (!pivotColSet.has(col)) {\n   270→      freeVars.push(col);\n   271→    }\n   272→  }\n   273→\n   274→  const numFree = freeVars.length;\n   275→\n   276→  // For GF(2) (toggle) we can enumerate 2^numFree combos.\n   277→  // For general primes, we have p^numFree combos — that could be huge.\n   278→  // With up to 40 buttons, numFree could be up to 40 and p up to 97.\n   279→  // We need a smarter approach for large search spaces.\n   280→  //\n   281→  // Strategy:\n   282→  //   - If p^numFree is small enough (≤ ~1M), enumerate directly.\n   283→  //   - Otherwise, use a meet-in-the-middle approach or greedy.\n   284→\n   285→  const totalCombinations = Math.pow(p, numFree);\n   286→\n   287→  if (totalCombinations <= 2_000_000) {\n   288→    return enumerateFreeSolutions(matrix, pivotCol, freeVars, numButtons, p);\n   289→  } else {\n   290→    // For large spaces, use meet-in-the-middle.\n   291→    return meetInTheMiddleSolve(matrix, pivotCol, freeVars, numButtons, p);\n   292→  }\n   293→}\n   294→\n   295→/**\n   296→ * Enumerate all free variable assignments, compute pivot vars,\n   297→ * and return the best solution.\n   298→ */\n   299→function enumerateFreeSolutions(\n   300→  matrix: number[][],\n   301→  pivotCol: number[],\n   302→  freeVars: number[],\n   303→  numButtons: number,\n   304→  p: number\n   305→): number[] | null {\n   306→  const rank = pivotCol.length;\n   307→  const numFree = freeVars.length;\n   308→\n   309→  // Build a mapping from pivot row to the free variable coefficients.\n   310→  // For row r (pivot in pivotCol[r]):\n   311→  //   x_{pivotCol[r]} = augmented[r] - sum_{fv in freeVars} matrix[r][fv] * x_{fv}  (mod p)\n   312→  // Since we've done full RREF, the pivot columns have a single 1.\n   313→\n   314→  let bestSolution: number[] | null = null;\n   315→  let bestTotal = Infinity;\n   316→\n   317→  // Enumerate using a counter array.\n   318→  const freeVals = new Array(numFree).fill(0);\n   319→\n   320→  const totalCombinations = Math.pow(p, numFree);\n   321→  for (let iter = 0; iter < totalCombinations; iter++) {\n   322→    const sol = new Array(numButtons).fill(0);\n   323→\n   324→    // Set free variables.\n   325→    for (let f = 0; f < numFree; f++) {\n   326→      sol[freeVars[f]] = freeVals[f];\n   327→    }\n   328→\n   329→    // Back-substitute pivot variables.\n   330→    for (let r = rank - 1; r >= 0; r--) {\n   331→      const col = pivotCol[r];\n   332→      let val = matrix[r][numButtons]; // augmented value\n   333→      for (let c = 0; c < numButtons; c++) {\n   334→        if (c !== col) {\n   335→          val = (((val - matrix[r][c] * sol[c]) % p) + p) % p;\n   336→        }\n   337→      }\n   338→      sol[col] = val % p;\n   339→    }\n   340→\n   341→    // Compute total presses.\n   342→    let total = 0;\n   343→    for (let i = 0; i < numButtons; i++) {\n   344→      total += sol[i];\n   345→    }\n   346→\n   347→    if (total < bestTotal || (total === bestTotal && lexSmallerArr(sol, bestSolution!))) {\n   348→      bestTotal = total;\n   349→      bestSolution = sol.slice();\n   350→    }\n   351→\n   352→    // Increment counter.\n   353→    incrementCounter(freeVals, p);\n   354→  }\n   355→\n   356→  return bestSolution;\n   357→}\n   358→\n   359→function incrementCounter(counter: number[], p: number): void {\n   360→  for (let i = counter.length - 1; i >= 0; i--) {\n   361→    counter[i]++;\n   362→    if (counter[i] < p) return;\n   363→    counter[i] = 0;\n   364→  }\n   365→}\n   366→\n   367→function lexSmallerArr(a: number[], b: number[]): boolean {\n   368→  for (let i = 0; i < a.length; i++) {\n   369→    if (a[i] < b[i]) return true;\n   370→    if (a[i] > b[i]) return false;\n   371→  }\n   372→  return false;\n   373→}\n   374→\n   375→/**\n   376→ * Meet-in-the-middle approach for large free variable spaces.\n   377→ * Split free variables into two halves, enumerate each half,\n   378→ * and find the best combination.\n   379→ */\n   380→function meetInTheMiddleSolve(\n   381→  matrix: number[][],\n   382→  pivotCol: number[],\n   383→  freeVars: number[],\n   384→  numButtons: number,\n   385→  p: number\n   386→): number[] | null {\n   387→  const rank = pivotCol.length;\n   388→  const numFree = freeVars.length;\n   389→\n   390→  // Split free variables into two halves.\n   391→  const half1 = Math.floor(numFree / 2);\n   392→  const half2 = numFree - half1;\n   393→  const freeVars1 = freeVars.slice(0, half1);\n   394→  const freeVars2 = freeVars.slice(half1);\n   395→\n   396→  // For each assignment of the first half, compute the \"partial effect\"\n   397→  // on each pivot variable. Then for each assignment of the second half,\n   398→  // compute the complementary effect and find the best total.\n   399→\n   400→  // Precompute: for each pivot row r, the coefficients for each free variable.\n   401→  // pivotVal[r] = matrix[r][numButtons] (the constant)\n   402→  // pivotCoeff[r][fv_index] = matrix[r][freeVars[fv_index]]\n   403→  // The pivot variable value = pivotVal[r] - sum(pivotCoeff[r][f] * freeVal[f]) mod p\n   404→\n   405→  // For meet-in-the-middle, we compute partial sums for each half.\n   406→\n   407→  // For the first half: for each assignment, compute:\n   408→  //   partialPivot[r] = sum(matrix[r][freeVars1[f]] * val1[f]) mod p  for each pivot row\n   409→  //   freeSum1 = sum of free variable values in first half\n   410→  //   pivotContrib1[r] = matrix[r][numButtons] - partialPivot[r] - (contribution from half2)\n   411→  //\n   412→  // Actually, the total cost is:\n   413→  //   sum of free variable values + sum of pivot variable values\n   414→  // where pivot var values depend on ALL free vars.\n   415→  //\n   416→  // Let's think about this differently. For each pivot row r:\n   417→  //   x_{pivotCol[r]} = (matrix[r][numButtons] - sum_f matrix[r][freeVars[f]] * x_{freeVars[f]}) mod p\n   418→  //\n   419→  // Total cost = sum_free x_free[f] + sum_r x_{pivotCol[r]}\n   420→  //            = sum_free x_free[f] + sum_r (matrix[r][numButtons] - sum_f matrix[r][freeVars[f]] * x_free[f]) mod p\n   421→  //\n   422→  // The mod p makes it hard to decompose additively. We need to track the\n   423→  // full pivot variable values, not just partial sums.\n   424→  //\n   425→  // Alternative approach for meet-in-the-middle:\n   426→  //   For each half-assignment, compute a \"signature\" that captures the\n   427→  //   partial contribution to each pivot variable. Then for each pair of\n   428→  //   half-assignments with matching signatures (that sum to the correct value),\n   429→  //   compute the total cost.\n   430→  //\n   431→  // Signature for first half: for each pivot row r, compute\n   432→  //   sig1[r] = sum(matrix[r][freeVars1[f]] * val1[f]) mod p\n   433→  //\n   434→  // Signature for second half: for each pivot row r, compute\n   435→  //   sig2[r] = sum(matrix[r][freeVars2[f]] * val2[f]) mod p\n   436→  //\n   437→  // Then the pivot variable value is:\n   438→  //   x_{pivotCol[r]} = (matrix[r][numButtons] - sig1[r] - sig2[r]) mod p\n   439→  //\n   440→  // We want to minimize total = freeSum1 + freeSum2 + sum_r pivotVal_r\n   441→  // where pivotVal_r = (matrix[r][numButtons] - sig1[r] - sig2[r]) mod p\n   442→  //\n   443→  // This is still hard because pivotVal depends on the combination of sig1 and sig2.\n   444→  //\n   445→  // For meet-in-the-middle to work, we need to group by sig1 and for each sig2,\n   446→  // look up the matching sig1 values.\n   447→  //\n   448→  // However with rank up to 40 and p up to 97, the signature space is huge (97^40).\n   449→  // We can't store all of them.\n   450→  //\n   451→  // A better approach: since numFree can be large (up to 40) but typically won't be\n   452→  // when there are meaningful constraints, let's consider that for practical cases\n   453→  // the free space is manageable.\n   454→  //\n   455→  // Actually, with 40 buttons and 40 lights, if the matrix has full rank then\n   456→  // numFree = 0. If rank = 35, numFree = 5, and 97^5 ≈ 8.6 billion — too many.\n   457→  //\n   458→  // Let's use a different strategy: if p = 2 (toggle), numFree can be up to 40\n   459→  // and 2^40 is too many but we handle toggle separately. For primes > 2 with\n   460→  // large free spaces, we need a smarter approach.\n   461→  //\n   462→  // Key insight: for minimum total presses, we want each variable to be as small\n   463→  // as possible. For free variables, choosing 0 minimizes their direct contribution,\n   464→  // but might increase pivot variables.\n   465→  //\n   466→  // For the general case with large free spaces, let's use a smarter approach:\n   467→  // Each free variable can take values 0..p-1. We want to minimize the sum of\n   468→  // all variables. We can define the \"cost\" of a free variable value as:\n   469→  //   direct cost (the value itself) + change in pivot variable values.\n   470→  //\n   471→  // Since pivot values depend linearly on free values (mod p), we can express the\n   472→  // total cost as a function of the free variables. However, the mod operation\n   473→  // makes this non-linear.\n   474→  //\n   475→  // For practical purposes, let's use the meet-in-the-middle with signature hashing.\n   476→  // We limit the signature to a hash and accept collisions.\n   477→\n   478→  // Actually, let's try a different approach: iterate free variables one at a time,\n   479→  // trying all p values and picking the one that leads to the best solution.\n   480→  // This is greedy and may not find the global optimum, but let's see.\n   481→\n   482→  // Better approach: use the structure of the problem.\n   483→  // The total cost function is:\n   484→  //   cost(x_free) = sum_f x_free[f] + sum_r ((c_r - sum_f a_{r,f} * x_free[f]) mod p)\n   485→  // where c_r = matrix[r][numButtons] and a_{r,f} = matrix[r][freeVars[f]].\n   486→  //\n   487→  // For each free variable, we have p choices. The total search space is p^numFree.\n   488→  // With meet-in-the-middle, we can reduce to p^(numFree/2) * stuff.\n   489→  //\n   490→  // For the \"stuff\" part: given a signature (the partial sums for each pivot row),\n   491→  // we need to find the best complementary assignment. The signature is a vector\n   492→  // in Z_p^rank. If rank is small (say ≤ 8), we can hash these signatures.\n   493→  //\n   494→  // For rank up to 40, we need to hash vectors of length up to 40 over Z_p.\n   495→  // We can use a string hash of the vector.\n   496→\n   497→  // Build coefficient arrays for efficiency.\n   498→  const coeffs1: number[][] = []; // coeffs1[r][f] for f in first half\n   499→  const coeffs2: number[][] = []; // coeffs2[r][f] for f in second half\n   500→  const constants: number[] = [];\n   501→\n   502→  for (let r = 0; r < rank; r++) {\n   503→    const c1: number[] = [];\n   504→    for (let f = 0; f < half1; f++) {\n   505→      c1.push(matrix[r][freeVars1[f]]);\n   506→    }\n   507→    coeffs1.push(c1);\n   508→\n   509→    const c2: number[] = [];\n   510→    for (let f = 0; f < half2; f++) {\n   511→      c2.push(matrix[r][freeVars2[f]]);\n   512→    }\n   513→    coeffs2.push(c2);\n   514→\n   515→    constants.push(matrix[r][numButtons]);\n   516→  }\n   517→\n   518→  // Enumerate first half: for each assignment, compute (sig, freeSum, freeVals).\n   519→  // Store in a map: sig -> best (freeSum, freeVals) for each sig.\n   520→  type HalfEntry = { freeSum: number; freeVals: number[]; partials: number[] };\n   521→  const firstHalfMap = new Map<string, HalfEntry>();\n   522→\n   523→  const vals1 = new Array(half1).fill(0);\n   524→  const total1 = Math.pow(p, half1);\n   525→\n   526→  for (let iter = 0; iter < total1; iter++) {\n   527→    // Compute partials: partials[r] = sum(coeffs1[r][f] * vals1[f]) mod p\n   528→    const partials = new Array(rank);\n   529→    for (let r = 0; r < rank; r++) {\n   530→      let s = 0;\n   531→      for (let f = 0; f < half1; f++) {\n   532→        s += coeffs1[r][f] * vals1[f];\n   533→      }\n   534→      partials[r] = ((s % p) + p) % p;\n   535→    }\n   536→\n   537→    let freeSum = 0;\n   538→    for (let f = 0; f < half1; f++) {\n   539→      freeSum += vals1[f];\n   540→    }\n   541→\n   542→    // The key for the map: we want to group by the \"needed\" complement.\n   543→    // For the second half, we need sig2[r] such that:\n   544→    //   pivotVal[r] = (constants[r] - partials[r] - sig2[r]) mod p\n   545→    // We want to find the pair that minimizes total cost.\n   546→    // We can store by partials as key.\n   547→    const key = partials.join(\",\");\n   548→\n   549→    const existing = firstHalfMap.get(key);\n   550→    if (!existing || freeSum < existing.freeSum ||\n   551→        (freeSum === existing.freeSum && lexSmallerArr(vals1, existing.freeVals))) {\n   552→      firstHalfMap.set(key, {\n   553→        freeSum,\n   554→        freeVals: vals1.slice(),\n   555→        partials: partials.slice()\n   556→      });\n   557→    }\n   558→\n   559→    incrementCounter(vals1, p);\n   560→  }\n   561→\n   562→  // Enumerate second half: for each assignment, compute sig2, then\n   563→  // for each first-half entry, compute the total cost and track the best.\n   564→  let bestSolution: number[] | null = null;\n   565→  let bestTotal = Infinity;\n   566→\n   567→  const vals2 = new Array(half2).fill(0);\n   568→  const total2 = Math.pow(p, half2);\n   569→\n   570→  for (let iter = 0; iter < total2; iter++) {\n   571→    // Compute partials for second half.\n   572→    const partials2 = new Array(rank);\n   573→    for (let r = 0; r < rank; r++) {\n   574→      let s = 0;\n   575→      for (let f = 0; f < half2; f++) {\n   576→        s += coeffs2[r][f] * vals2[f];\n   577→      }\n   578→      partials2[r] = ((s % p) + p) % p;\n   579→    }\n   580→\n   581→    let freeSum2 = 0;\n   582→    for (let f = 0; f < half2; f++) {\n   583→      freeSum2 += vals2[f];\n   584→    }\n   585→\n   586→    // For each first-half entry, compute pivot values and total cost.\n   587→    // This is still O(total1 * total2) which defeats the purpose.\n   588→    // We need to be smarter: for a given partials2, compute what partials1\n   589→    // would minimize cost. The pivot values are:\n   590→    //   pivotVal[r] = (constants[r] - partials1[r] - partials2[r]) mod p\n   591→    //\n   592→    // Total = freeSum1 + freeSum2 + sum_r pivotVal[r]\n   593→    //\n   594→    // We need to iterate over all first-half entries. But we can't hash\n   595→    // by the complement because the cost depends on both partials.\n   596→    //\n   597→    // Actually: the pivot sum = sum_r (constants[r] - partials1[r] - partials2[r]) mod p\n   598→    // This is NOT simply sum_r constants[r] - sum_r partials1[r] - sum_r partials2[r] mod p\n   599→    // because each term is taken mod p individually.\n   600→    //\n   601→    // So we DO need to iterate. But total1 * total2 = p^numFree which is\n   602→    // what we're trying to avoid.\n   603→    //\n   604→    // The meet-in-the-middle only helps if we can prune. Let's store\n   605→    // first-half entries grouped by their partials, and for each second-half\n   606→    // partials2, compute the expected partials1 key and look it up.\n   607→    //\n   608→    // Wait — the problem is that there's no single \"matching\" partials1.\n   609→    // For different pivot variable values, different partials1 are optimal.\n   610→    //\n   611→    // Let me reconsider. For each pair (partials1, partials2), the pivot values\n   612→    // are determined. But we want to minimize total cost, which includes the\n   613→    // pivot values. There's no constraint on what the pivot values should be\n   614→    // (other than being in [0, p-1] due to mod).\n   615→    //\n   616→    // Actually, we CAN decompose if we think about it differently.\n   617→    // The pivot cost for row r is: (constants[r] - partials1[r] - partials2[r]) mod p\n   618→    //                             = (constants[r] - partials2[r] - partials1[r]) mod p\n   619→    //\n   620→    // For a fixed partials2, we want to find partials1 that minimizes:\n   621→    //   freeSum1 + sum_r ((constants[r] - partials2[r] - partials1[r]) mod p)\n   622→    //\n   623→    // This depends on partials1 as a vector. We can't decompose this per-component\n   624→    // because freeSum1 couples all components.\n   625→    //\n   626→    // However, we stored first-half entries by their partials key. For a given\n   627→    // partials2, we iterate over ALL first-half entries. This is O(p^half1 * p^half2)\n   628→    // = O(p^numFree), no improvement.\n   629→    //\n   630→    // Meet-in-the-middle doesn't directly help here due to the mod-p cost function.\n   631→    // Let's fall back to greedy / branch-and-bound for large spaces.\n   632→\n   633→    // For now, iterate over all first-half entries.\n   634→    for (const [, entry] of firstHalfMap) {\n   635→      // Compute pivot values and total cost.\n   636→      let pivotSum = 0;\n   637→      for (let r = 0; r < rank; r++) {\n   638→        pivotSum += ((constants[r] - entry.partials[r] - partials2[r]) % p + p) % p;\n   639→      }\n   640→\n   641→      const totalCost = entry.freeSum + freeSum2 + pivotSum;\n   642→      if (totalCost < bestTotal) {\n   643→        bestTotal = totalCost;\n   644→        bestSolution = buildSolution(\n   645→          entry.freeVals, vals2, freeVars1, freeVars2,\n   646→          entry.partials, partials2, constants,\n   647→          matrix, pivotCol, numButtons, p, rank\n   648→        );\n   649→      } else if (totalCost === bestTotal) {\n   650→        const candidate = buildSolution(\n   651→          entry.freeVals, vals2, freeVars1, freeVars2,\n   652→          entry.partials, partials2, constants,\n   653→          matrix, pivotCol, numButtons, p, rank\n   654→        );\n   655→        if (bestSolution === null || lexSmallerArr(candidate, bestSolution)) {\n   656→          bestSolution = candidate;\n   657→        }\n   658→      }\n   659→    }\n   660→\n   661→    incrementCounter(vals2, p);\n   662→  }\n   663→\n   664→  return bestSolution;\n   665→}\n   666→\n   667→function buildSolution(\n   668→  freeVals1: number[], freeVals2: number[],\n   669→  freeVars1: number[], freeVars2: number[],\n   670→  partials1: number[], partials2: number[],\n   671→  constants: number[],\n   672→  matrix: number[][], pivotCol: number[],\n   673→  numButtons: number, p: number, rank: number\n   674→): number[] {\n   675→  const sol = new Array(numButtons).fill(0);\n   676→\n   677→  for (let f = 0; f < freeVals1.length; f++) {\n   678→    sol[freeVars1[f]] = freeVals1[f];\n   679→  }\n   680→  for (let f = 0; f < freeVals2.length; f++) {\n   681→    sol[freeVars2[f]] = freeVals2[f];\n   682→  }\n   683→\n   684→  for (let r = 0; r < rank; r++) {\n   685→    sol[pivotCol[r]] = ((constants[r] - partials1[r] - partials2[r]) % p + p) % p;\n   686→  }\n   687→\n   688→  return sol;\n   689→}\n   690→\n   691→/**\n   692→ * Modular inverse using extended Euclidean algorithm.\n   693→ * Requires gcd(a, p) = 1 (guaranteed when p is prime and a ≠ 0).\n   694→ */\n   695→function modInverse(a: number, p: number): number {\n   696→  a = ((a % p) + p) % p;\n   697→  let [old_r, r] = [a, p];\n   698→  let [old_s, s] = [1, 0];\n   699→\n   700→  while (r !== 0) {\n   701→    const q = Math.floor(old_r / r);\n   702→    [old_r, r] = [r, old_r - q * r];\n   703→    [old_s, s] = [s, old_s - q * s];\n   704→  }\n   705→\n   706→  return ((old_s % p) + p) % p;\n   707→}\n   708→"}]},"parent_tool_use_id":null,"session_id":"6d03e194-2895-4182-a156-42bf2d869f4c","uuid":"391642e8-96e6-4a79-a53f-239c2842b703","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/index.ts","content":"/**\n * Factory Reset — Toggle and Counter puzzle solvers.\n *\n * Both puzzles reduce to solving systems of linear equations over finite fields:\n *   - Toggle: GF(2) — each button is used 0 or 1 times\n *   - Counter: GF(p) — each button is used 0..p-1 times, p prime\n *\n * We use Gaussian elimination with back-substitution, enumerating\n * free variables to find the optimal (min presses, then lex smallest) solution.\n */\n\n// ─── Part 1: Toggle Puzzle ────────────────────────────────────────────\n\nexport interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve a toggle puzzle over GF(2).\n *\n * Build the augmented matrix [A | target] where A[j][i] = 1 iff button i\n * toggles light j. Row-reduce, then enumerate free-variable assignments\n * to find the solution with the fewest buttons pressed (lex smallest on tie).\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix over GF(2).\n  // Rows = lights, columns = buttons + 1 (augmented column = target).\n  // We'll use bitwise representation: each row is a bigint where bit i\n  // represents column i (buttons 0..numButtons-1, then augmented column at numButtons).\n  const numCols = numButtons + 1;\n  const rows: bigint[] = new Array(numLights);\n\n  for (let j = 0; j < numLights; j++) {\n    let row = 0n;\n    for (let i = 0; i < numButtons; i++) {\n      if (buttons[i].includes(j)) {\n        row |= 1n << BigInt(i);\n      }\n    }\n    if (target[j]) {\n      row |= 1n << BigInt(numButtons);\n    }\n    rows[j] = row;\n  }\n\n  // Gaussian elimination (row echelon form) over GF(2).\n  // pivotRow[col] = the row index that has the pivot in that column, or -1.\n  const pivotCol: number[] = []; // pivotCol[r] = column of the pivot in row r\n  let pivotRow = 0;\n\n  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {\n    // Find a row with a 1 in this column at or below pivotRow.\n    let found = -1;\n    for (let r = pivotRow; r < numLights; r++) {\n      if ((rows[r] >> BigInt(col)) & 1n) {\n        found = r;\n        break;\n      }\n    }\n    if (found === -1) continue; // free variable\n\n    // Swap to pivotRow.\n    [rows[pivotRow], rows[found]] = [rows[found], rows[pivotRow]];\n\n    // Eliminate all other rows that have a 1 in this column.\n    for (let r = 0; r < numLights; r++) {\n      if (r !== pivotRow && (rows[r] >> BigInt(col)) & 1n) {\n        rows[r] ^= rows[pivotRow];\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency: any row that is all zeros in button columns\n  // but has a 1 in the augmented column.\n  const buttonMask = (1n << BigInt(numButtons)) - 1n;\n  for (let r = rank; r < numLights; r++) {\n    if ((rows[r] & buttonMask) === 0n && (rows[r] >> BigInt(numButtons)) & 1n) {\n      return null; // inconsistent\n    }\n  }\n\n  // Identify free variables (columns not in pivotCol).\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (!pivotColSet.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Enumerate all 2^numFree assignments for free variables.\n  // For each, back-substitute to get pivot variables, then pick the\n  // solution with fewest presses, breaking ties lexicographically.\n  let bestSolution: number[] | null = null;\n  let bestCount = numButtons + 1;\n\n  const totalCombinations = 1 << numFree;\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    const sol = new Uint8Array(numButtons);\n\n    // Set free variables according to mask.\n    for (let f = 0; f < numFree; f++) {\n      if (mask & (1 << f)) {\n        sol[freeVars[f]] = 1;\n      }\n    }\n\n    // Back-substitute pivot variables (from bottom to top).\n    let valid = true;\n    for (let r = rank - 1; r >= 0; r--) {\n      const col = pivotCol[r];\n      // value = augmented bit XOR (sum of known variables in this row)\n      let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n      for (let c = 0; c < numButtons; c++) {\n        if (c !== col && (rows[r] >> BigInt(c)) & 1n) {\n          val ^= sol[c];\n        }\n      }\n      sol[col] = val & 1;\n    }\n\n    if (!valid) continue;\n\n    // Count presses.\n    let count = 0;\n    for (let i = 0; i < numButtons; i++) {\n      count += sol[i];\n    }\n\n    if (count < bestCount) {\n      bestCount = count;\n      bestSolution = [];\n      for (let i = 0; i < numButtons; i++) {\n        if (sol[i]) bestSolution.push(i);\n      }\n    } else if (count === bestCount) {\n      // Compare lexicographically.\n      const candidate: number[] = [];\n      for (let i = 0; i < numButtons; i++) {\n        if (sol[i]) candidate.push(i);\n      }\n      if (bestSolution === null || lexSmaller(candidate, bestSolution)) {\n        bestSolution = candidate;\n      }\n    }\n  }\n\n  return bestSolution;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  // Compare two sorted arrays of button indices lexicographically.\n  // Shorter (fewer presses) is always better, but here lengths are equal.\n  const len = Math.max(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    const av = i < a.length ? a[i] : Infinity;\n    const bv = i < b.length ? b[i] : Infinity;\n    if (av < bv) return true;\n    if (av > bv) return false;\n  }\n  return false;\n}\n\n// ─── Part 2: Counter Puzzle ───────────────────────────────────────────\n\n/**\n * Solve a counter puzzle over GF(p), p prime.\n *\n * Same Gaussian elimination approach but over a general prime field.\n * We enumerate free-variable assignments (each 0..p-1) to find the\n * solution with minimum total presses, breaking ties lexicographically.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numLights = lights.length;\n  const numButtons = buttons.length;\n  const p = modulus;\n\n  // Build augmented matrix [A | target] over GF(p).\n  // A[j][i] = 1 if button i increments counter j, else 0.\n  // Augmented column = target[j].\n  const numCols = numButtons + 1;\n  const matrix: number[][] = [];\n\n  for (let j = 0; j < numLights; j++) {\n    const row = new Array(numCols).fill(0);\n    for (let i = 0; i < numButtons; i++) {\n      if (buttons[i].includes(j)) {\n        row[i] = 1;\n      }\n    }\n    row[numButtons] = ((lights[j] % p) + p) % p;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p).\n  const pivotCol: number[] = [];\n  let pivotRow = 0;\n\n  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {\n    // Find a row with non-zero entry in this column.\n    let found = -1;\n    for (let r = pivotRow; r < numLights; r++) {\n      if (matrix[r][col] !== 0) {\n        found = r;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap.\n    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];\n\n    // Scale pivot row so that the pivot element = 1.\n    const inv = modInverse(matrix[pivotRow][col], p);\n    for (let c = 0; c < numCols; c++) {\n      matrix[pivotRow][c] = (matrix[pivotRow][c] * inv) % p;\n    }\n\n    // Eliminate all other rows.\n    for (let r = 0; r < numLights; r++) {\n      if (r !== pivotRow && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let c = 0; c < numCols; c++) {\n          matrix[r][c] = (((matrix[r][c] - factor * matrix[pivotRow][c]) % p) + p) % p;\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency.\n  for (let r = rank; r < numLights; r++) {\n    let allZero = true;\n    for (let c = 0; c < numButtons; c++) {\n      if (matrix[r][c] !== 0) {\n        allZero = false;\n        break;\n      }\n    }\n    if (allZero && matrix[r][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables.\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (!pivotColSet.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // For GF(2) (toggle) we can enumerate 2^numFree combos.\n  // For general primes, we have p^numFree combos — that could be huge.\n  // With up to 40 buttons, numFree could be up to 40 and p up to 97.\n  // We need a smarter approach for large search spaces.\n  //\n  // Strategy:\n  //   - If p^numFree is small enough (≤ ~1M), enumerate directly.\n  //   - Otherwise, use a meet-in-the-middle approach or greedy.\n\n  const totalCombinations = Math.pow(p, numFree);\n\n  if (totalCombinations <= 2_000_000) {\n    return enumerateFreeSolutions(matrix, pivotCol, freeVars, numButtons, p);\n  } else {\n    // For large spaces, use meet-in-the-middle.\n    return meetInTheMiddleSolve(matrix, pivotCol, freeVars, numButtons, p);\n  }\n}\n\n/**\n * Enumerate all free variable assignments, compute pivot vars,\n * and return the best solution.\n */\nfunction enumerateFreeSolutions(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  p: number\n): number[] | null {\n  const rank = pivotCol.length;\n  const numFree = freeVars.length;\n\n  // Build a mapping from pivot row to the free variable coefficients.\n  // For row r (pivot in pivotCol[r]):\n  //   x_{pivotCol[r]} = augmented[r] - sum_{fv in freeVars} matrix[r][fv] * x_{fv}  (mod p)\n  // Since we've done full RREF, the pivot columns have a single 1.\n\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  // Enumerate using a counter array.\n  const freeVals = new Array(numFree).fill(0);\n\n  const totalCombinations = Math.pow(p, numFree);\n  for (let iter = 0; iter < totalCombinations; iter++) {\n    const sol = new Array(numButtons).fill(0);\n\n    // Set free variables.\n    for (let f = 0; f < numFree; f++) {\n      sol[freeVars[f]] = freeVals[f];\n    }\n\n    // Back-substitute pivot variables.\n    for (let r = rank - 1; r >= 0; r--) {\n      const col = pivotCol[r];\n      let val = matrix[r][numButtons]; // augmented value\n      for (let c = 0; c < numButtons; c++) {\n        if (c !== col) {\n          val = (((val - matrix[r][c] * sol[c]) % p) + p) % p;\n        }\n      }\n      sol[col] = val % p;\n    }\n\n    // Compute total presses.\n    let total = 0;\n    for (let i = 0; i < numButtons; i++) {\n      total += sol[i];\n    }\n\n    if (total < bestTotal || (total === bestTotal && lexSmallerArr(sol, bestSolution!))) {\n      bestTotal = total;\n      bestSolution = sol.slice();\n    }\n\n    // Increment counter.\n    incrementCounter(freeVals, p);\n  }\n\n  return bestSolution;\n}\n\nfunction incrementCounter(counter: number[], p: number): void {\n  for (let i = counter.length - 1; i >= 0; i--) {\n    counter[i]++;\n    if (counter[i] < p) return;\n    counter[i] = 0;\n  }\n}\n\nfunction lexSmallerArr(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\n/**\n * Meet-in-the-middle approach for large free variable spaces.\n * Split free variables into two halves, enumerate each half,\n * and find the best combination.\n */\nfunction meetInTheMiddleSolve(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  p: number\n): number[] | null {\n  const rank = pivotCol.length;\n  const numFree = freeVars.length;\n\n  // Split free variables into two halves.\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n  const freeVars1 = freeVars.slice(0, half1);\n  const freeVars2 = freeVars.slice(half1);\n\n  // For each assignment of the first half, compute the \"partial effect\"\n  // on each pivot variable. Then for each assignment of the second half,\n  // compute the complementary effect and find the best total.\n\n  // Precompute: for each pivot row r, the coefficients for each free variable.\n  // pivotVal[r] = matrix[r][numButtons] (the constant)\n  // pivotCoeff[r][fv_index] = matrix[r][freeVars[fv_index]]\n  // The pivot variable value = pivotVal[r] - sum(pivotCoeff[r][f] * freeVal[f]) mod p\n\n  // For meet-in-the-middle, we compute partial sums for each half.\n\n  // For the first half: for each assignment, compute:\n  //   partialPivot[r] = sum(matrix[r][freeVars1[f]] * val1[f]) mod p  for each pivot row\n  //   freeSum1 = sum of free variable values in first half\n  //   pivotContrib1[r] = matrix[r][numButtons] - partialPivot[r] - (contribution from half2)\n  //\n  // Actually, the total cost is:\n  //   sum of free variable values + sum of pivot variable values\n  // where pivot var values depend on ALL free vars.\n  //\n  // Let's think about this differently. For each pivot row r:\n  //   x_{pivotCol[r]} = (matrix[r][numButtons] - sum_f matrix[r][freeVars[f]] * x_{freeVars[f]}) mod p\n  //\n  // Total cost = sum_free x_free[f] + sum_r x_{pivotCol[r]}\n  //            = sum_free x_free[f] + sum_r (matrix[r][numButtons] - sum_f matrix[r][freeVars[f]] * x_free[f]) mod p\n  //\n  // The mod p makes it hard to decompose additively. We need to track the\n  // full pivot variable values, not just partial sums.\n  //\n  // Alternative approach for meet-in-the-middle:\n  //   For each half-assignment, compute a \"signature\" that captures the\n  //   partial contribution to each pivot variable. Then for each pair of\n  //   half-assignments with matching signatures (that sum to the correct value),\n  //   compute the total cost.\n  //\n  // Signature for first half: for each pivot row r, compute\n  //   sig1[r] = sum(matrix[r][freeVars1[f]] * val1[f]) mod p\n  //\n  // Signature for second half: for each pivot row r, compute\n  //   sig2[r] = sum(matrix[r][freeVars2[f]] * val2[f]) mod p\n  //\n  // Then the pivot variable value is:\n  //   x_{pivotCol[r]} = (matrix[r][numButtons] - sig1[r] - sig2[r]) mod p\n  //\n  // We want to minimize total = freeSum1 + freeSum2 + sum_r pivotVal_r\n  // where pivotVal_r = (matrix[r][numButtons] - sig1[r] - sig2[r]) mod p\n  //\n  // This is still hard because pivotVal depends on the combination of sig1 and sig2.\n  //\n  // For meet-in-the-middle to work, we need to group by sig1 and for each sig2,\n  // look up the matching sig1 values.\n  //\n  // However with rank up to 40 and p up to 97, the signature space is huge (97^40).\n  // We can't store all of them.\n  //\n  // A better approach: since numFree can be large (up to 40) but typically won't be\n  // when there are meaningful constraints, let's consider that for practical cases\n  // the free space is manageable.\n  //\n  // Actually, with 40 buttons and 40 lights, if the matrix has full rank then\n  // numFree = 0. If rank = 35, numFree = 5, and 97^5 ≈ 8.6 billion — too many.\n  //\n  // Let's use a different strategy: if p = 2 (toggle), numFree can be up to 40\n  // and 2^40 is too many but we handle toggle separately. For primes > 2 with\n  // large free spaces, we need a smarter approach.\n  //\n  // Key insight: for minimum total presses, we want each variable to be as small\n  // as possible. For free variables, choosing 0 minimizes their direct contribution,\n  // but might increase pivot variables.\n  //\n  // For the general case with large free spaces, let's use a smarter approach:\n  // Each free variable can take values 0..p-1. We want to minimize the sum of\n  // all variables. We can define the \"cost\" of a free variable value as:\n  //   direct 