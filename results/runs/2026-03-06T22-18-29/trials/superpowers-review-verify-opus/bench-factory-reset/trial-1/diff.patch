 (let iter = 0; iter < total1; iter++) {\n    let freeSum = 0;\n    for (let f = 0; f < half1Size; f++) {\n      freeSum += vals1[f];\n    }\n\n    const key = partials1.join(\",\");\n\n    const existing = sigMap.get(key);\n    if (!existing || freeSum < existing.freeSum ||\n        (freeSum === existing.freeSum && lexSmallerArr(vals1, existing.freeVals))) {\n      sigMap.set(key, {\n        freeSum,\n        freeVals: vals1.slice(),\n        partials: partials1.slice()\n      });\n    }\n\n    // Increment vals1 and update partials1 incrementally.\n    for (let i = half1Size - 1; i >= 0; i--) {\n      vals1[i]++;\n      if (vals1[i] < p) {\n        for (let r = 0; r < rank; r++) {\n          partials1[r] = (partials1[r] + pivotFreeCoeffs[r][i]) % p;\n        }\n        break;\n      }\n      vals1[i] = 0;\n      for (let r = 0; r < rank; r++) {\n        partials1[r] = ((partials1[r] - (p - 1) * pivotFreeCoeffs[r][i]) % p + p) % p;\n      }\n    }\n  }\n\n  // Convert map to array for faster iteration.\n  const sigEntries = Array.from(sigMap.values());\n\n  // Enumerate second half.\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  const vals2 = new Array(half2Size).fill(0);\n  const total2 = Math.pow(p, half2Size);\n  const partials2 = new Array(rank).fill(0);\n\n  for (let iter = 0; iter < total2; iter++) {\n    let freeSum2 = 0;\n    for (let f = 0; f < half2Size; f++) {\n      freeSum2 += vals2[f];\n    }\n\n    // For each first-half signature entry, compute full cost.\n    for (let e = 0; e < sigEntries.length; e++) {\n      const entry = sigEntries[e];\n\n      const totalFreeSum = entry.freeSum + freeSum2;\n      if (totalFreeSum >= bestTotal) continue;\n\n      let pivotSum = 0;\n      let total = totalFreeSum;\n      let pruned = false;\n      for (let r = 0; r < rank; r++) {\n        pivotSum = ((pivotConsts[r] - entry.partials[r] - partials2[r]) % p + p) % p;\n        total += pivotSum;\n        if (total >= bestTotal) {\n  