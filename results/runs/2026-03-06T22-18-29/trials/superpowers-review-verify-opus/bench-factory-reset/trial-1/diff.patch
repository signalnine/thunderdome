],\n+  freeVars: number[], pivotCol: number[],\n+  numButtons: number\n+): number[] {\n+  const sol = new Array(numButtons).fill(0);\n+  for (let f = 0; f < freeVals.length; f++) {\n+    sol[freeVars[f]] = freeVals[f];\n+  }\n+  for (let r = 0; r < pivotValues.length; r++) {\n+    sol[pivotCol[r]] = pivotValues[r];\n+  }\n+  return sol;\n+}\n+\n+function lexSmallerArr(a: number[], b: number[]): boolean {\n+  for (let i = 0; i < a.length; i++) {\n+    if (a[i] < b[i]) return true;\n+    if (a[i] > b[i]) return false;\n+  }\n+  return false;\n+}\n+\n+function modInverse(a: number, p: number): number {\n+  a = ((a % p) + p) % p;\n+  let [old_r, r] = [a, p];\n+  let [old_s, s] = [1, 0];\n+\n+  while (r !== 0) {\n+    const q = Math.floor(old_r / r);\n+    [old_r, r] = [r, old_r - q * r];\n+    [old_s, s] = [s, old_s - q * s];\n+  }\n+\n+  return ((old_s % p) + p) % p;\n+}","is_error":false}]},"parent_tool_use_id":null,"session_id":"6d03e194-2895-4182-a156-42bf2d869f4c","uuid":"1ab674a5-8cc9-4d44-a05c-d217e3bd1fe9","tool_use_result":{"stdout":"diff --git a/src/index.test.ts b/src/index.test.ts\nnew file mode 100644\nindex 0000000..f5a7d29\n--- /dev/null\n+++ b/src/index.test.ts\n@@ -0,0 +1,318 @@\n+import { describe, it, expect } from 'vitest';\n+import { solveToggle, solveCounter, Machine } from './index.js';\n+\n+// ─── Helper: verify toggle solution ────────────────────────────────\n+\n+function verifyToggle(machine: Machine, solution: number[] | null): boolean {\n+  if (solution === null) return true; // can't verify null\n+  const lights = new Array(machine.target.length).fill(false);\n+  for (const btnIdx of solution) {\n+    for (const lightIdx of machine.buttons[btnIdx]) {\n+      lights[lightIdx] = !lights[lightIdx];\n+    }\n+  }\n+  return lights.every((v, i) => v === machine.target[i]);\n+}\n+\n+// ─── Helper: verify counter solution ───────────────────────────────\n+\n+function verifyCounter(\n+  target: number[], buttons: number[][], modulus: number,\n+  so