r < rank; r++) {\n   324→    pivotConsts[r] = matrix[r][numButtons];\n   325→    pivotFreeCoeffs[r] = new Array(numFree);\n   326→    for (let f = 0; f < numFree; f++) {\n   327→      pivotFreeCoeffs[r][f] = matrix[r][freeVars[f]];\n   328→    }\n   329→  }\n   330→\n   331→  // Determine enumeration strategy.\n   332→  const totalCombinations = Math.pow(p, numFree);\n   333→\n   334→  if (totalCombinations <= 5_000_000) {\n   335→    return enumerateCounterSolutions(\n   336→      pivotCol, freeVars, pivotFreeCoeffs, pivotConsts, numButtons, p, rank, numFree\n   337→    );\n   338→  } else {\n   339→    // For very large free spaces, use meet-in-the-middle with proper signature grouping.\n   340→    return meetInTheMiddleCounter(\n   341→      pivotCol, freeVars, pivotFreeCoeffs, pivotConsts, numButtons, p, rank, numFree\n   342→    );\n   343→  }\n   344→}\n   345→\n   346→function enumerateCounterSolutions(\n   347→  pivotCol: number[],\n   348→  freeVars: number[],\n   349→  pivotFreeCoeffs: number[][],\n   350→  pivotConsts: number[],\n   351→  numButtons: number,\n   352→  p: number,\n   353→  rank: number,\n   354→  numFree: number\n   355→): number[] {\n   356→  let bestSolution: number[] | null = null;\n   357→  let bestTotal = Infinity;\n   358→\n   359→  const freeVals = new Array(numFree).fill(0);\n   360→  const totalCombinations = Math.pow(p, numFree);\n   361→\n   362→  for (let iter = 0; iter < totalCombinations; iter++) {\n   363→    // Compute total cost.\n   364→    let total = 0;\n   365→\n   366→    // Add free variable costs.\n   367→    for (let f = 0; f < numFree; f++) {\n   368→      total += freeVals[f];\n   369→    }\n   370→\n   371→    // Early pruning.\n   372→    if (total >= bestTotal) {\n   373→      incrementCounter(freeVals, p);\n   374→      continue;\n   375→    }\n   376→\n   377→    // Compute pivot variable values and add to total.\n   378→    const pivotValues = new Array(rank);\n   379→    let pruned = false;\n   380→    for (let r = 0; r < rank; r++) {\n   381→      let val = pivotConsts[r];\n   382→      for (let f = 0; f < numFree; f++) {\n   383→        val -= pivotFreeCoeffs[r][f] * freeVals[f];\n   384→      }\n   385→      pivotValues[r] = ((val % p) + p) % p;\n   386→      total += pivotValues[r];\n   387→      if (total >= bestTotal) {\n   388→        pruned = true;\n   389→        break;\n   390→      }\n   391→    }\n   392→\n   393→    if (pruned) {\n   394→      incrementCounter(freeVals, p);\n   395→      continue;\n   396→    }\n   397→\n   398→    if (total < bestTotal) {\n   399→      bestTotal = total;\n   400→      bestSolution = buildCounterSolution(freeVals, pivotValues, freeVars, pivotCol, numButtons);\n   401→    } else if (total === bestTotal) {\n   402→      const candidate = buildCounterSolution(freeVals, pivotValues, freeVars, pivotCol, numButtons);\n   403→      if (bestSolution === null || lexSmallerArr(candidate, bestSolution)) {\n   404→        bestSolution = candidate;\n   405→      }\n   406→    }\n   407→\n   408→    incrementCounter(freeVals, p);\n   409→  }\n   410→\n   411→  return bestSolution!;\n   412→}\n   413→\n   414→function meetInTheMiddleCounter(\n   415→  pivotCol: number[],\n   416→  freeVars: number[],\n   417→  pivotFreeCoeffs: number[][],\n   418→  pivotConsts: number[],\n   419→  numButtons: number,\n   420→  p: number,\n   421→  rank: number,\n   422→  numFree: number\n   423→): number[] | null {\n   424→  // Split free variables into two halves.\n   425→  const half1Size = Math.floor(numFree / 2);\n   426→  const half2Size = numFree - half1Size;\n   427→\n   428→  // For the first half, enumerate all p^half1Size assignments.\n   429→  // For each, compute:\n   430→  //   - partial contribution to each pivot row: sum_f coeff[r][f] * val[f] mod p\n   431→  //   - free variable sum for this half\n   432→  // Group by the partial contribution signature. For each signature, keep\n   433→  // the one with minimum free sum (lex smallest on