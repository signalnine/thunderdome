+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W2iScGFrtuYGf1Dfypjewu","type":"tool_result","content":"diff --git a/src/index.test.ts b/src/index.test.ts\nnew file mode 100644\nindex 0000000..f5a7d29\n--- /dev/null\n+++ b/src/index.test.ts\n@@ -0,0 +1,318 @@\n+import { describe, it, expect } from 'vitest';\n+import { solveToggle, solveCounter, Machine } from './index.js';\n+\n+// ─── Helper: verify toggle solution ────────────────────────────────\n+\n+function verifyToggle(machine: Machine, solution: number[] | null): boolean {\n+  if (solution === null) return true; // can't verify null\n+  const lights = new Array(machine.target.length).fill(false);\n+  for (const btnIdx of solution) {\n+    for (const lightIdx of machine.buttons[btnIdx]) {\n+      lights[lightIdx] = !lights[lightIdx];\n+    }\n+  }\n+  return lights.every((v, i) => v === machine.target[i]);\n+}\n+\n+// ─── Helper: verify counter solution ───────────────────────────────\n+\n+function verifyCounter(\n+  target: number[], buttons: number[][], modulus: number,\n+  solution: number[] | null\n+): boolean {\n+  if (solution === null) return true;\n+  const counters = new Array(target.length).fill(0);\n+  for (let i = 0; i < buttons.length; i++) {\n+    for (let j = 0; j < solution[i]; j++) {\n+      for (const idx of buttons[i]) {\n+        counters[idx] = (counters[idx] + 1) % modulus;\n+      }\n+    }\n+  }\n+  return counters.every((v, i) => v === ((target[i] % modulus + modulus) % modulus));\n+}\n+\n+// ─── Part 1: Toggle Puzzle Tests ───────────────────────────────────\n+\n+describe('solveToggle', () => {\n+  it('should return empty array when target is all off', () => {\n+    const machine: Machine = {\n+      target: [false, false, false],\n+      buttons: [[0, 1], [1, 2]]\n+    };\n+    expect(solveToggle(machine)).toEqual([]);\n+  });\n+\n+  it('should return null for impossible configuration (from task example)', () => {\n+    const machine: Machine = {\n+      target: [true, true, false, true],\n+      buttons: [[0, 1], [1, 2, 3], [0, 3]]\n+    };\n+    // From the example: b1=0, b0=1, b2=0 => light3 = 0 XOR 0 = 0 ≠ 1. No solution.\n+    expect(solveToggle(machine)).toBeNull();\n+  });\n+\n+  it('should handle single button', () => {\n+    const machine: Machine = {\n+      target: [true, true],\n+      buttons: [[0, 1]]\n+    };\n+    const result = solveToggle(machine);\n+    expect(result).toEqual([0]);\n+    expect(verifyToggle(machine, result)).toBe(true);\n+  });\n+\n+  it('should find minimum press count', () => {\n+    const machine: Machine = {\n+      target: [true, false],\n+      buttons: [[0], [0, 1], [1]]\n+    };\n+    // Button 0 alone does it: [true, false]. That's 1 press.\n+    // Buttons 1+2 also works: [true, true] then [true, false]. That's 2 presses.\n+    const result = solveToggle(machine);\n+    expect(result).toEqual([0]);\n+    expect(verifyToggle(machine, result)).toBe(true);\n+  });\n+\n+  it('should return lex smallest on tie', () => {\n+    // Two buttons that each toggle light 0 independently.\n+    const machine: Machine = {\n+      target: [true],\n+      buttons: [[0], [0]]\n+    };\n+    // Both button 0 and button 1 work. Lex smallest is [0].\n+    const result = solveToggle(machine);\n+    expect(result).toEqual([0]);\n+    expect(verifyToggle(machine, result)).toBe(true);\n+  });\n+\n+  it('should handle larger system', () => {\n+    const machine: Machine = {\n+      target: [true, true, true, true],\n+      buttons: [[0], [1], [2], [3]]\n+    };\n+    const result = solveToggle(machine);\n+    expect(result).toEqual([0, 1, 2, 3]);\n+    expect(verifyToggle(machine, result)).toBe(true);\n+  });\n+\n+  it('should handle overlapping buttons', () => {\n+    const machine: Machine = {\n+      target: [true, false, true],\n+      buttons: [[0, 1], [1, 2]]\n+    };\n+    // Press both: light0 toggled by b0, light1 toggled by b0+b1 (cancel), light2 by b1.\n+    const result = solveToggle(machine);\n+    expect(result).toEqual([0, 1]);\n+    expect(verifyToggle(machine, result)).toBe(true);\n+  });\n+\n+  it('should handle no buttons with non-trivial target', () => {\n+    const machine: Machine = {\n+      target: [true],\n+      buttons: []\n+    };\n+    expect(solveToggle(machine)).toBeNull();\n+  });\n+\n+  it('should handle no buttons with all-off target', () => {\n+    const machine: Machine = {\n+      target: [false, false],\n+      buttons: []\n+    };\n+    expect(solveToggle(machine)).toEqual([]);\n+  });\n+\n+  it('should handle redundant buttons (free variables)', () => {\n+    // 3 buttons, 1 light. All toggle light 0.\n+    const machine: Machine = {\n+      target: [true],\n+      buttons: [[0], [0], [0]]\n+    };\n+    // Any odd number of presses works. Min is 1. Lex smallest is [0].\n+    const result = solveToggle(machine);\n+    expect(result).toEqual([0]);\n+    expect(verifyToggle(machine, result)).toBe(true);\n+  });\n+\n+  it('should handle 2 lights 3 buttons with free variable', () => {\n+    // Buttons: 0->[0], 1->[1], 2->[0,1]\n+    // Target: [true, true]\n+    // Solutions: {0,1} (2 presses), {2} (1 press)\n+    const machine: Machine = {\n+      target: [true, true],\n+      buttons: [[0], [1], [0, 1]]\n+    };\n+    const result = solveToggle(machine);\n+    expect(result).toEqual([2]);\n+    expect(verifyToggle(machine, result)).toBe(true);\n+  });\n+});\n+\n+// ─── Part 2: Counter Puzzle Tests ──────────────────────────────────\n+\n+describe('solveCounter', () => {\n+  it('should return all zeros when target is all zero', () => {\n+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);\n+    expect(result).toEqual([0, 0]);\n+  });\n+\n+  it('should handle single button single counter', () => {\n+    const result = solveCounter([3], [[0]], 5);\n+    expect(result).toEqual([3]);\n+    expect(verifyCounter([3], [[0]], 5, result)).toBe(true);\n+  });\n+\n+  it('should return null for impossible configuration', (