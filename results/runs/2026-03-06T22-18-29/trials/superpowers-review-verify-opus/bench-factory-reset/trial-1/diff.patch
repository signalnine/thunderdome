ly.","-    // The pivot cost for row r is: (constants[r] - partials1[r] - partials2[r]) mod p","-    //                             = (constants[r] - partials2[r] - partials1[r]) mod p","-    //","-    // For a fixed partials2, we want to find partials1 that minimizes:","-    //   freeSum1 + sum_r ((constants[r] - partials2[r] - partials1[r]) mod p)","-    //","-    // This depends on partials1 as a vector. We can't decompose this per-component","-    // because freeSum1 couples all components.","-    //","-    // However, we stored first-half entries by their partials key. For a given","-    // partials2, we iterate over ALL first-half entries. This is O(p^half1 * p^half2)","-    // = O(p^numFree), no improvement.","-    //","-    // Meet-in-the-middle doesn't directly help here due to the mod-p cost function.","-    // Let's fall back to greedy / branch-and-bound for large spaces.","+    // For each first-half signature, compute full cost.","+    for (const [sigKey, entries] of firstHalfBySig) {","+      const entry = entries[0];"," ","-    // For now, iterate over all first-half entries.","-    for (const [, entry] of firstHalfMap) {","-      // Compute pivot values and total cost.","+      // Parse signature (partials1).","+      const partials1 = sigKey.split(\",\").map(Number);","+","+      // Compute pivot variable values and total.","       let pivotSum = 0;","       for (let r = 0; r < rank; r++) {","-        pivotSum += ((constants[r] - entry.partials[r] - partials2[r]) % p + p) % p;","+        pivotSum += ((pivotConsts[r] - partials1[r] - partials2[r]) % p + p) % p;","       }"," ","       const totalCost = entry.freeSum + freeSum2 + pivotSum;","+","       if (totalCost < bestTotal) {","         bestTotal = totalCost;","-        bestSolution = buildSolution(","-          entry.freeVals, vals2, freeVars1, freeVars2,","-          entry.partials, partials2, constants,","-          matrix, pivotCol, numButtons, p, rank","-        );","+        // Build full solution.","+        const allFreeVals = [...entry.freeVals, ...vals2];","+        const pivotValues = new Array(rank);","+        for (let r = 0; r < rank; r++) {","+          pivotValues[r] = ((pivotConsts[r] - partials1[r] - partials2[r]) % p + p) % p;","+        }","+        bestSolution = buildCounterSolution(allFreeVals, pivotValues, freeVars, pivotCol, numButtons);","       } else if (totalCost === bestTotal) {","-        const candidate = buildSolution(","-          entry.freeVals, vals2, freeVars1, freeVars2,","-          entry.partials, partials2, constants,","-          matrix, pivotCol, numButtons, p, rank","-        );","+        const allFreeVals = [...entry.freeVals, ...vals2];","+        const pivotValues = new Array(rank);","+        for (let r = 0; r < rank; r++) {","+          pivotValues[r] = ((pivotConsts[r] - partials1[r] - partials2[r]) % p + p) % p;","+        }","+        const candidate = buildCounterSolution(allFreeVals, pivotValues, freeVars, pivotCol, numButtons);","         if (bestSolution === null || lexSmallerArr(candidate, bestSolution)) {","           bestSolution = candidate;","         }"]},{"oldStart":664,"oldLines":34,"newStart":538,"newLines":37,"lines":["   return bestSolution;"," }"," ","-function buildSolution(","-  freeVals1: number[], freeVals2: number[],","-  freeVars1: number[], freeVars2: number[],","-  partials1: number[], partials2: number[],","-  constants: number[],","-  matrix: number[][], pivotCol: number[],","-  numButtons: number, p: number, rank: number","+function buildCounterSolution(","+  freeVals: number[], pivotValues: number[],","+  freeVars: number[], pivotCol: number[],","+  numButtons: number"," ): number[] {","   const sol = new Array(numButtons).fill(0);","-","-  for (let f = 0; f < freeVals1.length; f++) {","-    sol[freeVars1[f]] = freeVals1[f];","+  for (let f = 0; f < freeVals.length; f++) {","+    sol[freeVars[f]] = freeVals[f];","   }","-  for (let f = 0; f < freeVals2.length; f++) {","-    sol