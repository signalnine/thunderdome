  const numCols = numButtons + 1;\n   220→  const matrix: number[][] = [];\n   221→\n   222→  for (let j = 0; j < numLights; j++) {\n   223→    const row = new Array(numCols).fill(0);\n   224→    for (let i = 0; i < numButtons; i++) {\n   225→      if (buttons[i].includes(j)) {\n   226→        row[i] = 1;\n   227→      }\n   228→    }\n   229→    row[numButtons] = ((lights[j] % p) + p) % p;\n   230→    matrix.push(row);\n   231→  }\n   232→\n   233→  // Gaussian elimination to RREF over GF(p).\n   234→  const pivotCol: number[] = [];\n   235→  let pivotRow = 0;\n   236→\n   237→  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {\n   238→    let found = -1;\n   239→    for (let r = pivotRow; r < numLights; r++) {\n   240→      if (matrix[r][col] !== 0) {\n   241→        found = r;\n   242→        break;\n   243→      }\n   244→    }\n   245→    if (found === -1) continue;\n   246→\n   247→    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];\n   248→\n   249→    const inv = modInverse(matrix[pivotRow][col], p);\n   250→    for (let c = 0; c < numCols; c++) {\n   251→      matrix[pivotRow][c] = (matrix[pivotRow][c] * inv) % p;\n   252→    }\n   253→\n   254→    for (let r = 0; r < numLights; r++) {\n   255→      if (r !== pivotRow && matrix[r][col] !== 0) {\n   256→        const factor = matrix[r][col];\n   257→        for (let c = 0; c < numCols; c++) {\n   258→          matrix[r][c] = (((matrix[r][c] - factor * matrix[pivotRow][c]) % p) + p) % p;\n   259→        }\n   260→      }\n   261→    }\n   262→\n   263→    pivotCol.push(col);\n   264→    pivotRow++;\n   265→  }\n   266→\n   267→  const rank = pivotCol.length;\n   268→\n   269→  // Check for inconsistency.\n   270→  for (let r = rank; r < numLights; r++) {\n   271→    let allZero = true;\n   272→    for (let c = 0; c < numButtons; c++) {\n   273→      if (matrix[r][c] !== 0) {\n   274→        allZero = false;\n   275→        break;\n   276→      }\n   277→    }\n   278→