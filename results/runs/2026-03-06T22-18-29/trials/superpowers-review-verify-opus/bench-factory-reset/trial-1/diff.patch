r(candidate, bestSolution)) {\n            bestSolution = candidate;\n          }\n        }\n      }\n    }","originalFile":"/**\n * Factory Reset — Toggle and Counter puzzle solvers.\n *\n * Both puzzles reduce to solving systems of linear equations over finite fields:\n *   - Toggle: GF(2) — each button is used 0 or 1 times\n *   - Counter: GF(p) — each button is used 0..p-1 times, p prime\n *\n * We use Gaussian elimination to RREF, then enumerate free-variable assignments\n * to find the optimal (min presses, then lex smallest) solution.\n */\n\n// ─── Part 1: Toggle Puzzle ────────────────────────────────────────────\n\nexport interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  if (numButtons === 0) {\n    return target.some(t => t) ? null : [];\n  }\n\n  // Build augmented matrix over GF(2) using bigint bit-vectors.\n  const rows: bigint[] = new Array(numLights);\n  for (let j = 0; j < numLights; j++) {\n    let row = 0n;\n    for (let i = 0; i < numButtons; i++) {\n      if (buttons[i].includes(j)) {\n        row |= 1n << BigInt(i);\n      }\n    }\n    if (target[j]) {\n      row |= 1n << BigInt(numButtons);\n    }\n    rows[j] = row;\n  }\n\n  // Gaussian elimination to RREF over GF(2).\n  const pivotCol: number[] = [];\n  let pivotRow = 0;\n\n  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {\n    let found = -1;\n    for (let r = pivotRow; r < numLights; r++) {\n      if ((rows[r] >> BigInt(col)) & 1n) {\n        found = r;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [rows[pivotRow], rows[found]] = [rows[found], rows[pivotRow]];\n\n    for (let r = 0; r < numLights; r++) {\n      if (r !== pivotRow && (rows[r] >> BigInt(col)) & 1n) {\n        rows[r] ^= rows[pivotRow];\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency.\n  const buttonMask = (1n << BigInt(numButtons)) - 1n;\n  for (let r = rank; r < numLights; r++) {\n    if ((rows[r] & buttonMask) === 0n && (rows[r] >> BigInt(numButtons)) & 1n) {\n      return null;\n    }\n  }\n\n  // Identify free variables.\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (!pivotColSet.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Precompute: for each pivot row, which free variables appear and the constant.\n  const pivotFreeMask: number[] = new Array(rank);\n  const pivotConstArr: number[] = new Array(rank);\n\n  for (let r = 0; r < rank; r++) {\n    let mask = 0;\n    for (let f = 0; f < numFree; f++) {\n      if ((rows[r] >> BigInt(freeVars[f])) & 1n) {\n        mask |= (1 << f);\n      }\n    }\n    pivotFreeMask[r] = mask;\n    pivotConstArr[r] = Number((rows[r] >> BigInt(numButtons)) & 1n);\n  }\n\n  if (numFree === 0) {\n    // Unique solution.\n    const result: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if (pivotConstArr[r]) result.push(pivotCol[r]);\n    }\n    return result;\n  }\n\n  // Enumerate all 2^numFree assignments.\n  const totalCombinations = 1 << numFree;\n  let bestSolution: number[] | null = null;\n  let bestCount = numButtons + 1;\n\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    let count = popcount(mask);\n    if (count >= bestCount) continue;\n\n    let pruned = false;\n    for (let r = 0; r < rank; r++) {\n      const val = pivotConstArr[r] ^ (popcount(mask & pivotFreeMask[r]) & 1);\n      count += val;\n      if (count >= bestCount) {\n        pruned = true;\n        break;\n      }\n    }\n    if (pruned) continue;\n\n    if (count < bestCount) {\n      bestCount = count;\n      bestSolution = buildToggleSolution(mask, freeVars, pivotCol, pivotFreeMask, pivotConstArr, numFree, rank);\n    } else {\n      const candidate = buildToggleSolution(mask, freeVars, pivotCol, pivotFreeMask, pivotConstArr, numFree, rank);\n      if (bestSolution === null || lexSmallerSorted(candidate, bestSolution)) {\n        bestSolution = candidate;\n      }\n    }\n  }\n\n  return bestSolution;\n}\n\nfunction buildToggleSolution(\n  freeMask: number, freeVars: number[], pivotCol: number[],\n  pivotFreeMask: number[], pivotConstArr: number[],\n  numFree: number, rank: number\n): number[] {\n  const freePressed: number[] = [];\n  const pivotPressed: number[] = [];\n\n  for (let f = 0; f < numFree; f++) {\n    if (freeMask & (1 << f)) {\n      freePressed.push(freeVars[f]);\n    }\n  }\n\n  for (let r = 0; r < rank; r++) {\n    const val = pivotConstArr[r] ^ (popcount(freeMask & pivotFreeMask[r]) & 1);\n    if (val) {\n      pivotPressed.push(pivotCol[r]);\n    }\n  }\n\n  // Merge two sorted arrays.\n  const result: number[] = [];\n  let i = 0, j = 0;\n  while (i < freePressed.length && j < pivotPressed.length) {\n    if (freePressed[i] < pivotPressed[j]) {\n      result.push(freePressed[i++]);\n    } else {\n      result.push(pivotPressed[j++]);\n    }\n  }\n  while (i < freePressed.length) result.push(freePressed[i++]);\n  while (j < pivotPressed.length) result.push(pivotPressed[j++]);\n\n  return result;\n}\n\nfunction popcount(n: number): number {\n  n = n - ((n >> 1) & 0x55555555);\n  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);\n  n = (n + (n >> 4)) & 0x0f0f0f0f;\n  return (n * 0x01010101) >> 24;\n}\n\nfunction lexSmallerSorted(a: number[], b: number[]): boolean {\n  const len = Math.max(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    const av = i < a.length ? a[i] : Infinity;\n    const bv = i < b.length ? b[i] : Infinity;\n    if (av < bv) return true;\n    if (av > bv) return false;\n  }\n  return false;\n}\n\n// ─── Part 2: Counter Puzzle ───────────────────────────────────────────\n\nexport function solveCounter(\n  