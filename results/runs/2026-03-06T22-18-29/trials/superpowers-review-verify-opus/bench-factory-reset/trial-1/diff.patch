ol++) {\n    let found = -1;\n    for (let r = pivotRow; r < numLights; r++) {\n      if ((rows[r] >> BigInt(col)) & 1n) {\n        found = r;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [rows[pivotRow], rows[found]] = [rows[found], rows[pivotRow]];\n\n    for (let r = 0; r < numLights; r++) {\n      if (r !== pivotRow && (rows[r] >> BigInt(col)) & 1n) {\n        rows[r] ^= rows[pivotRow];\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency.\n  const buttonMask = (1n << BigInt(numButtons)) - 1n;\n  for (let r = rank; r < numLights; r++) {\n    if ((rows[r] & buttonMask) === 0n && (rows[r] >> BigInt(numButtons)) & 1n) {\n      return null;\n    }\n  }\n\n  // Identify free variables.\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (!pivotColSet.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Precompute: for each pivot row, which free variables appear and the constant.\n  const pivotFreeMask: number[] = new Array(rank);\n  const pivotConstArr: number[] = new Array(rank);\n\n  for (let r = 0; r < rank; r++) {\n    let mask = 0;\n    for (let f = 0; f < numFree; f++) {\n      if ((rows[r] >> BigInt(freeVars[f])) & 1n) {\n        mask |= (1 << f);\n      }\n    }\n    pivotFreeMask[r] = mask;\n    pivotConstArr[r] = Number((rows[r] >> BigInt(numButtons)) & 1n);\n  }\n\n  if (numFree === 0) {\n    // Unique solution.\n    const result: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if (pivotConstArr[r]) result.push(pivotCol[r]);\n    }\n    return result;\n  }\n\n  // Enumerate all 2^numFree assignments.\n  const totalCombinations = 1 << numFree;\n  let bestSolution: number[] | null = null;\n  let bestCount = numButtons + 1;\n\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    let count = popcount(mask);\n    if (count >= bestCount) continue;\n\n    let pruned = false;\n    for (let r = 0; r < rank; r++) {\n      const val = pivotConstArr[r] ^ (popcount(mask & pivotFreeMask[r]) & 1);\n      count += val;\n      if (count >= bestCount) {\n        pruned = true;\n        break;\n      }\n    }\n    if (pruned) continue;\n\n    if (count < bestCount) {\n      bestCount = count;\n      bestSolution = buildToggleSolution(mask, freeVars, pivotCol, pivotFreeMask, pivotConstArr, numFree, rank);\n    } else {\n      const candidate = buildToggleSolution(mask, freeVars, pivotCol, pivotFreeMask, pivotConstArr, numFree, rank);\n      if (bestSolution === null || lexSmallerSorted(candidate, bestSolution)) {\n        bestSolution = candidate;\n      }\n    }\n  }\n\n  return bestSolution;\n}\n\nfunction buildToggleSolution(\n  freeMask: number, freeVars: number[], pivotCol: number[],\n  pivotFreeMask: number[], pivotConstArr: number[],\n  numFree: number, rank: number\n): number[] {\n  const freePressed: number[] = [];\n  const pivotPressed: number[] = [];\n\n  for (let f = 0; f < numFree; f++) {\n    if (freeMask & (1 << f)) {\n      freePressed.push(freeVars[f]);\n    }\n  }\n\n  for (let r = 0; r < rank; r++) {\n    const val = pivotConstArr[r] ^ (popcount(freeMask & pivotFreeMask[r]) & 1);\n    if (val) {\n      pivotPressed.push(pivotCol[r]);\n    }\n  }\n\n  // Merge two sorted arrays.\n  const result: number[] = [];\n  let i = 0, j = 0;\n  while (i < freePressed.length && j < pivotPressed.length) {\n    if (freePressed[i] < pivotPressed[j]) {\n      result.push(freePressed[i++]);\n    } else {\n      result.push(pivotPressed[j++]);\n    }\n  }\n  while (i < freePressed.length) result.push(freePressed[i++]);\n  while (j < pivotPressed.length) result.push(pivotPressed[j++]);\n\n  return result;\n}\n\nfunction popcount(n: number): number {\n  n = n - ((n >> 1) & 0x55555555);\n  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);\n  n = (n + (n >> 4)) & 0x0f0f0f0f;\n  return (n * 0x01010101) >> 24;\n}\n\nfunction lexSmallerSorted(a: number[], b: number[]): boolean {\n  const len = Math.max(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    const av = i < a.length ? a[i] : Infinity;\n    const bv = i < b.length ? b[i] : Infinity;\n    if (av < bv) return true;\n    if (av > bv) return false;\n  }\n  return false;\n}\n\n// ─── Part 2: Counter Puzzle ───────────────────────────────────────────\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numLights = lights.length;\n  const numButtons = buttons.length;\n  const p = modulus;\n\n  if (numButtons === 0) {\n    return lights.every(l => ((l % p) + p) % p === 0) ? [] : null;\n  }\n\n  // Build augmented matrix [A | target] over GF(p).\n  const numCols = numButtons + 1;\n  const matrix: number[][] = [];\n\n  for (let j = 0; j < numLights; j++) {\n    const row = new Array(numCols).fill(0);\n    for (let i = 0; i < numButtons; i++) {\n      if (buttons[i].includes(j)) {\n        row[i] = 1;\n      }\n    }\n    row[numButtons] = ((lights[j] % p) + p) % p;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination to RREF over GF(p).\n  const pivotCol: number[] = [];\n  let pivotRow = 0;\n\n  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {\n    let found = -1;\n    for (let r = pivotRow; r < numLights; r++) {\n      if (matrix[r][col] !== 0) {\n        found = r;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];\n\n    const inv = modInverse(matrix[pivotRow][col], p);\n    for (let c = 0; c < numCols; c++) {\n      matrix[pivotRow][c] = (matrix[pivotRow][c] * inv) % p;\n    }\n\n    for (let r = 0; r < numLights; r++) {\n      if (r !== pivotRow && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let c = 0; c < numCols; c++) {\n          matrix[r][c] = (((matrix[r][c] - factor * matrix[pivotRow][c]) % p) + p) % p;\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency.\n  for (let r = rank; r < numLights; r++) {\n    let allZero = true;\n    for (let c = 0; c < numButtons; c++) {\n      if (matrix[r][c] !== 0) {\n        allZero = false;\n        break;\n      }\n    }\n    if (allZero && matrix[r][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables.\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (!pivotColSet.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Precompute pivot row data.\n  const pivotFreeCoeffs: number[][] = new Array(rank);\n  const pivotConsts: number[] = new Array(rank);\n  for (let r = 0; r < rank; r++) {\n    pivotConsts[r] = matrix[r][numButtons];\n    pivotFreeCoeffs[r] = new Array(numFree);\n    for (let f = 0; f < numFree; f++) {\n      pivotFreeCoeffs[r][f] = matrix[r][freeVars[f]];\n    }\n  }\n\n  if (numFree === 0) {\n    const sol = new Array(numButtons).fill(0);\n    for (let r = 0; r < rank; r++) {\n      sol[pivotCol[r]] = pivotConsts[r];\n    }\n    return sol;\n  }\n\n  // Compute max feasible enumeration.\n  // For small spaces, enumerate directly. For larger ones, use MITM.\n  let logSpace = 0;\n  for (let f = 0; f < numFree; f++) {\n    logSpace += Math.log(p);\n  }\n  const LOG_THRESHOLD = Math.log(5_000_000);\n\n  if (logSpace <= LOG_THRESHOLD) {\n    return enumerateCounterSolutions(\n      pivotCol, freeVars, pivotFreeCoeffs, pivotConsts, numButtons, p, rank, numFree\n    );\n  } else {\n    return mitmCounterSolve(\n      pivotCol, freeVars, pivotFreeCoeffs, pivotConsts, numButtons, p, rank, numFree\n    );\n  }\n}\n\nfunction enumerateCounterSolutions(\n  pivotCol: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotConsts: number[],\n  numButtons: number,\n  p: number,\n  rank: number,\n  numFree: number\n): number[] {\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  // We enumerate by incrementing a counter array.\n  // To speed things up, maintain the running partial sums for each pivot row\n  // and update incrementally.\n  const freeVals = new Array(numFree).fill(0);\n\n  // pivotPartials[r] = sum_f pivotFreeCoeffs[r][f] * freeVals[f] mod p\n  const pivotPartials = new Array(rank).fill(0);\n\n  const totalCombinations = Math.pow(p, numFree);\n\n  for (let iter = 0; iter < totalCombinations; iter++) {\n    // Compute total cost.\n    let total = 0;\n    for (let f = 0; f < numFree; f++) {\n      total += freeVals[f];\n    }\n\n    if (total < bestTotal) {\n      const pivotValues = new Array(rank);\n      let pruned = false;\n      for (let r = 0; r < rank; r++) {\n        pivotValues[r] = ((pivotConsts[r] - pivotPartials[r]) % p + p) % p;\n        total += pivotValues[r];\n        if (total >= bestTotal) {\n          pruned = true;\n          break;\n        }\n      }\n\n      if (!pruned) {\n        if (total < bestTotal) {\n          bestTotal = total;\n          bestSolution = buildCounterSolution(freeVals, pivotValues, freeVars, pivotCol, numButtons);\n        } else if (total === bestTotal) {\n          const candidate = buildCounterSolution(freeVals, pivotValues, freeVars, pivotCol, numButtons);\n          if (bestSolution === null || lexSmallerArr(candidate, bestSolution)) {\n            bestSolution = candidate;\n          }\n        }\n      }\n    }\n\n    // Increment counter and update pivotPartials incrementally.\n    for (let i = numFree - 1; i >= 0; i--) {\n      freeVals[i]++;\n      if (freeVals[i] < p) {\n        // Update partials: added 1 to freeVals[i].\n        for (let r = 0; r < rank; r++) {\n          pivotPartials[r] = (pivotPartials[r] + pivotFreeCoeffs[r][i]) % p;\n        }\n        break;\n      }\n      // Carry: freeVals[i]