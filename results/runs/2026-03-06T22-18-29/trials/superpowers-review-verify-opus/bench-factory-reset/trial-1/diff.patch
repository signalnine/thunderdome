}\n  }\n\n  // Identify free variables.\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (!pivotColSet.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Precompute pivot row data.\n  const pivotFreeCoeffs: number[][] = new Array(rank);\n  const pivotConsts: number[] = new Array(rank);\n  for (let r = 0; r < rank; r++) {\n    pivotConsts[r] = matrix[r][numButtons];\n    pivotFreeCoeffs[r] = new Array(numFree);\n    for (let f = 0; f < numFree; f++) {\n      pivotFreeCoeffs[r][f] = matrix[r][freeVars[f]];\n    }\n  }\n\n  if (numFree === 0) {\n    const sol = new Array(numButtons).fill(0);\n    for (let r = 0; r < rank; r++) {\n      sol[pivotCol[r]] = pivotConsts[r];\n    }\n    return sol;\n  }\n\n  // Compute max feasible enumeration.\n  // For small spaces, enumerate directly. For larger ones, use MITM.\n  let logSpace = 0;\n  for (let f = 0; f < numFree; f++) {\n    logSpace += Math.log(p);\n  }\n  const LOG_THRESHOLD = Math.log(5_000_000);\n\n  if (logSpace <= LOG_THRESHOLD) {\n    return enumerateCounterSolutions(\n      pivotCol, freeVars, pivotFreeCoeffs, pivotConsts, numButtons, p, rank, numFree\n    );\n  } else {\n    return mitmCounterSolve(\n      pivotCol, freeVars, pivotFreeCoeffs, pivotConsts, numButtons, p, rank, numFree\n    );\n  }\n}\n\nfunction enumerateCounterSolutions(\n  pivotCol: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotConsts: number[],\n  numButtons: number,\n  p: number,\n  rank: number,\n  numFree: number\n): number[] {\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  // We enumerate by incrementing a counter array.\n  // To speed things up, maintain the running partial sums for each pivot row\n  // and update incrementally.\n  const freeVals = new Array(numFree).fill(0);\n\n  // pivotPartials[r] = sum_f pivotFreeCoeffs[r][f] * freeVals[f] mod p\n  const pivotPartials = new Array(rank).fill(0);\n\n  const totalCombinations = Math.pow(p, numFree);\n\n  for (let iter = 0; iter < totalCombinations; iter++) {\n    // Compute total cost.\n    let total = 0;\n    for (let f = 0; f < numFree; f++) {\n      total += freeVals[f];\n    }\n\n    if (total < bestTotal) {\n      const pivotValues = new Array(rank);\n      let pruned = false;\n      for (let r = 0; r < rank; r++) {\n        pivotValues[r] = ((pivotConsts[r] - pivotPartials[r]) % p + p) % p;\n        total += pivotValues[r];\n        if (total >= bestTotal) {\n          pruned = true;\n          break;\n        }\n      }\n\n      if (!pruned) {\n        if (total < bestTotal) {\n          bestTotal = total;\n          bestSolution = buildCounterSolution(freeVals, pivotValues, freeVars, pivotCol, numButtons);\n        } else if (total === bestTotal) {\n          const candidate = buildCounterSolution(freeVals, pivotValues, freeVars, pivotCol, numButtons);\n          if (bestSolution === null || lexSmallerArr(candidate, bestSolution)) {\n            bestSolution = candidate;\n          }\n        }\n      }\n    }\n\n    // Increment counter and update pivotPartials incrementally.\n    for (let i = numFree - 1; i >= 0; i--) {\n      freeVals[i]++;\n      if (freeVals[i] < p) {\n        // Update partials: added 1 to freeVals[i].\n        for (let r = 0; r < rank; r++) {\n          pivotPartials[r] = (pivotPartials[r] + pivotFreeCoeffs[r][i]) % p;\n        }\n        break;\n      }\n      // Carry: freeVals[i] went from p-1 to 0. Update partials.\n      freeVals[i] = 0;\n      for (let r = 0; r < rank; r++) {\n        // We subtracted (p-1) * coeff, but adding 1 and wrapping = subtracting (p-1) = adding 1 mod p.\n        // Actually: old value was p-1, new is 0. Delta = -(p-1) * coeff = +coeff mod p.\n        // Wait, let me think more carefully.\n        // Before increment: freeVals[i] was p-1. After: it becomes p, then wraps to 0.\n        // The partial was using freeVals[i]=p-1. Now freeVals[i]=0.\n        // Change in contribution for row r: (0 - (p-1)) * coeff = -(p-1)*coeff = coeff (mod p).\n        pivotPartials[r] = ((pivotPartials[r] - (p - 1) * pivotFreeCoeffs[r][i]) % p + p) % p;\n      }\n    }\n  }\n\n  return bestSolution!;\n}\n\n/**\n * Meet-in-the-middle for counter puzzle with large free variable spaces.\n * Split free vars into two halves. For each half, enumerate all assignments,\n * computing the partial contribution to pivot rows. Group first-half by\n * signature (partial vector mod p). For each second-half assignment, look up\n * ALL first-half signatures and compute full cost.\n *\n * This is O(p^(n/2) * numDistinctSigs) where numDistinctSigs ≤ p^rank\n * but is often much smaller. Combined with the fact that we keep only\n * the best entry per signature, this prunes heavily.\n */\nfunction mitmCounterSolve(\n  pivotCol: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotConsts: number[],\n  numButtons: number,\n  p: number,\n  rank: number,\n  numFree: number\n): number[] | null {\n  const half1Size = Math.floor(numFree / 2);\n  const half2Size = numFree - half1Size;\n\n  interface HalfEntry {\n    freeSum: number;\n    freeVals: number[];\n    partials: number[];\n  }\n\n  // Enumerate first half and store best entry per signature.\n  const sigMap = new Map<string, HalfEntry>();\n\n  const vals1 = new Array(half1Size).fill(0);\n  const total1 = Math.pow(p, half1Size);\n  const partials1 = new Array(rank).fill(0);\n\n  for (let iter = 0; iter < total1; iter++) {\n    let freeSum = 0;\n    for (let f = 0; f < half1Size; f++) {\n      freeSum += vals1[f];\n    }\n\n    const key = partials1.join(\",\");\n\n    const existing = sigMap.get(key);\n    if (!existing || freeSum < existing.freeSum ||\n        (freeSum === existing.freeSum && lexSmallerArr(vals1, existing.freeVals))) {\n      sigMap.set(key, {\n        freeSum,\n        freeVals: vals1.slice(),\n        partials: partials1.slice()\n      });\n    }\n\n    // Increment vals1 and update partials1 incrementally.\n    for (let i = half1Size - 1; i >= 0; i--) {\n      vals1[i]++;\n      if (vals1[i] < p) {\n        for (let r = 0; r < rank; r++) {\n          partials1[r] = (partials1[r] + pivotFreeCoeffs[r][i]) % p;\n        }\n        break;\n      }\n      vals1[i] = 0;\n      for (let r = 0; r < rank; r++) {\n        partials1[r] = ((partials1[r] - (p - 1) * pivotFreeCoeffs[r][i]) % p + p) % p;\n      }\n    }\n  }\n\n  // Convert map to array for faster iteration.\n  const sigEntries = Array.from(sigMap.values());\n\n  // Enumerate second half.\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  const vals2 = new Array(half2Size).fill(0);\n  const total2 = Math.pow(p, half2Size);\n  const partials2 = new Array(rank).fill(0);\n\n  for (let iter = 0; iter < total2; iter++) {\n    let freeSum2 = 0;\n    for (let f = 0; f < half2Size; f++) {\n      freeSum2 += vals2[f];\n    }\n\n    // For each first-half signature entry, compute full cost.\n    for (let e = 0; e < sigEntries.length; e++) {\n      const entry = sigEntries[e];\n\n      const totalFreeSum = entry.freeSum + freeSum2;\n      if (totalFreeSum >= bestTotal) continue;\n\n      let pivotSum = 0;\n      let total = totalFreeSum;\n      let pruned = false;\n      for (let r = 0; r < rank; r++) {\n        pivotSum = ((pivotConsts[r] - entry.partials[r] - partials2[r]) % p + p) % p;\n        total += pivotSum;\n        if (total >= bestTotal) {\n          pruned = true;\n          break;\n        }\n      }\n\n      if (pruned) continue;\n\n      if (total < bestTotal) {\n        bestTotal = total;\n        const allFreeVals = [...entry.freeVals, ...vals2];\n        const pivotValues = new Array(rank);\n        for (let r = 0; r < rank; r++) {\n          pivotValues[r] = ((pivotConsts[r] - entry.partials[r] - partials2[r]) % p + p) % p;\n        }\n        bestSolution = buildCounterSolution(allFre