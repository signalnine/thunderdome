e;\n   342→}\n   343→\n   344→// ─── Part 2: Counter Puzzle ───────────────────────────────────────────\n   345→\n   346→export function solveCounter(\n   347→  lights: number[],\n   348→  buttons: number[][],\n   349→  modulus: number\n   350→): number[] | null {\n   351→  const numLights = lights.length;\n   352→  const numButtons = buttons.length;\n   353→  const p = modulus;\n   354→\n   355→  if (numButtons === 0) {\n   356→    return lights.every(l => ((l % p) + p) % p === 0) ? [] : null;\n   357→  }\n   358→\n   359→  // Build augmented matrix [A | target] over GF(p).\n   360→  const numCols = numButtons + 1;\n   361→  const matrix: number[][] = [];\n   362→\n   363→  for (let j = 0; j < numLights; j++) {\n   364→    const row = new Array(numCols).fill(0);\n   365→    for (let i = 0; i < numButtons; i++) {\n   366→      if (buttons[i].includes(j)) {\n   367→        row[i] = 1;\n   368→      }\n   369→    }\n   370→    row[numButtons] = ((lights[j] % p) + p) % p;\n   371→    matrix.push(row);\n   372→  }\n   373→\n   374→  // Gaussian elimination to RREF over GF(p).\n   375→  const pivotCol: number[] = [];\n   376→  let pivotRow = 0;\n   377→\n   378→  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {\n   379→    let found = -1;\n   380→    for (let r = pivotRow; r < numLights; r++) {\n   381→      if (matrix[r][col] !== 0) {\n   382→        found = r;\n   383→        break;\n   384→      }\n   385→    }\n   386→    if (found === -1) continue;\n   387→\n   388→    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];\n   389→\n   390→    const inv = modInverse(matrix[pivotRow][col], p);\n   391→    for (let c = 0; c < numCols; c++) {\n   392→      matrix[pivotRow][c] = (matrix[pivotRow][c] * inv) % p;\n   393→    }\n   394→\n   395→    for (let r = 0; r < numLights; r++) {\n   396→      if (r !== pivotRow && matrix[r][col] !== 0) {\n   397→        const factor = matrix[r][col];\n   398→        for (let c = 0; c < numCols; c++) {\n   399→          matrix[r][c] = (((matrix[r][c] - factor * matrix[pivotRow][c]) % p) + p) % p;\n   400→        }\n   401→      }\n   402→    }\n   403→\n   404→    pivotCol.push(col);\n   405→    pivotRow++;\n   406→  }\n   407→\n   408→  const rank = pivotCol.length;\n   409→\n   410→  // Check for inconsistency.\n   411→  for (let r = rank; r < numLights; r++) {\n   412→    let allZero = true;\n   413→    for (let c = 0; c < numButtons; c++) {\n   414→      if (matrix[r][c] !== 0) {\n   415→        allZero = false;\n   416→        break;\n   417→      }\n   418→    }\n   419→    if (allZero && matrix[r][numButtons] !== 0) {\n   420→      return null;\n   421→    }\n   422→  }\n   423→\n   424→  // Identify free variables.\n   425→  const pivotColSet = new Set(pivotCol);\n   426→  const freeVars: number[] = [];\n   427→  for (let col = 0; col < numButtons; col++) {\n   428→    if (!pivotColSet.has(col)) {\n   429→      freeVars.push(col);\n   430→    }\n   431→  }\n   432→\n   433→  const numFree = freeVars.length;\n   434→\n   435→  // Precompute pivot row data.\n   436→  const pivotFreeCoeffs: number[][] = new Array(rank);\n   437→  const pivotConsts: number[] = new Array(rank);\n   438→  for (let r = 0; r < rank; r++) {\n   439→    pivotConsts[r] = matrix[r][numButtons];\n   440→    pivotFreeCoeffs[r] = new Array(numFree);\n   441→    for (let f = 0; f < numFree; f++) {\n   442→      pivotFreeCoeffs[r][f] = matrix[r][freeVars[f]];\n   443→    }\n   444→  }\n   445→\n   446→  if (numFree === 0) {\n   447→    const sol = new Array(numButtons).fill(0);\n   448→    for (let r = 0; r < rank; r++) {\n   449→      sol[pivotCol[r]] = pivotConsts[r];\n   450→    }\n   451→    return sol;\n   452→  }\n   453→\n   454→  // Determine enumeration strategy using log to avoid precision issues.\n   455→  const logSpace = numFree * Math.log(p);\n   456→  const LOG_THRESHOLD = Math.log(5_000_000);\n   457→\n   458→  if (logSpace <= LOG_THRESHOLD) {\n   459→    return enumerateCounterSolutions(\n   460→      pivotCol, freeVars, pivotFreeCoeffs, pivotConsts, numButtons, p, rank, numFree\n   461→    );\n   462→  } else {\n   463→    return mitmCounterSolve(\n   464→      pivotCol, freeVars, pivotFreeCoeffs, pivotConsts, numButtons, p, rank, numFree\n   465→    );\n   466→  }\n   467→}\n   468→\n   469→function enumerateCounterSolutions(\n   470→  pivotCol: number[],\n   471→  freeVars: number[],\n   472→  pivotFreeCoeffs: number[][],\n   473→  pivotConsts: number[],\n   474→  numButtons: number,\n   475→  p: number,\n   476→  rank: number,\n   477→  numFree: number\n   478→): number[] {\n   479→  let bestSolution: number[] | null = null;\n   480→  let bestTotal = Infinity;\n   481→\n   482→  const freeVals = new Array(numFree).fill(0);\n   483→  const pivotPartials = new Array(rank).fill(0);\n   484→\n   485→  // Use carry-based termination instead of Math.pow loop bounds (M5 fix).\n   486→  let done = false;\n   487→  while (!done) {\n   488→    // Compute total cost.\n   489→    let total = 0;\n   490→    for (let f = 0; f < numFree; f++) {\n   491→      total += freeVals[f];\n   492→    }\n   493→\n   494→    if (total <= bestTotal) {\n   495→      const pivotValues = new Array(rank);\n   496→      let pruned = false;\n   497→      for (let r = 0; r < rank; r++) {\n   498→        pivotValues[r] = ((pivotConsts[r] - pivotPartials[r]) % p + p) % p;\n   499→        total += pivotValues[r];\n   500→        if (total > bestTotal) {\n   501→          pruned = true;\n   502→          break;\n   503→        }\n   504→      }\n   505→\n   506→      if (!pruned) {\n   507→        if (total < bestTotal) {\n   508→          bestTotal = total;\n   509→          bestSolution = buildCounterSolution(freeVals, pivotValues, freeVars, pivotCol, numButtons);\n   510→        } else if (total === bestTotal) {\n   511→          const candidate = buildCounterSolution(freeVals, pivotValues, freeVars, pivotCol, numButtons);\n   512→          if (bestSolution === null || lexSmallerArr(candidate, bestSolution)) {\n   513→            bestSolution = candidate;\n   514→          }\n   515→        }\n   516→      }\n   517→    }\n   518→\n   519→    // Increment counter and update pivotPartials incrementally.\n   520→    // When all digits carry (wrap back to all zeros), we're done.\n   521→    done = true;\n   522→    for (let i = numFree - 1; i >= 0; i--) {\n   523→      freeVals[i]++;\n   524→      if (freeVals[i] < p) {\n   525→        for (let r = 0; r < rank; r++) {\n   526→          pivotPartials[r] = (pivotPartials[r] + pivotFreeCoeffs[r][i]) % p;\n   527→        }\n   528→        done = false;\n   529→        break;\n   530→      }\n   531→      freeVals[i] = 0;\n   532→      for (let r = 0; r < rank; r++) {\n   533→        pivotPartials[r] = ((pivotPartials[r] - (p - 1) * pivotFreeCoeffs[r][i]) % p + p) % p;\n   534→      }\n   535→    }\n   536→  }\n   537→\n   538→  return bestSolution!;\n   539→}\n   540→\n   541→/**\n   542→ * Meet-in-the-middle for counter puzzle with large free variable spaces.\n   543→ *\n   544→ * H2 fix: For each second-half assignment, we compute the \"needed\" first-half\n   545→ * partial signature that would make each pivot variable zero (minimizing cost),\n   546→ * and do a direct map lookup. We also check neighboring signatures since minimum\n   547→ * cost may not always correspond to all-zero pivots.\n   548→ *\n   549→ * Since the pivot cost is (c_r - partial1_r - partial2_r) mod p, and we can't\n   550→ * fully decompose this, we enumerate all first-half signatures but the map\n   551→ * deduplication (keeping only best per signature) reduces the search space.\n   552→ */\n   553→function mitmCounterSolve(\n   554→  pivotCol: number[],\n   555→  freeVars: number[],\n   556→  pivotFreeCoeffs: number[][],\n   557→  pivotConsts: number[],\n   558→  numButtons: number,\n   559→  p: number,\n   560→  rank: number,\n   561→  numFree: number\n   562→): number[] | null {\n   563→  const half1Size = Math.floor(numFree / 2);\n   564→  const half2Size = numFree - half1Size;\n   565→\n   566→  interface HalfEntry {\n   567→    freeSum: number;\n   568→    freeVals: number[];\n   569→    partials: number[];\n   570→  }\n   571→\n   572→  // Enumerate first half and store best entry per signature.\n   573→  const sigMap = new Map<string, HalfEntry>();\n   574→\n   575→  const vals1 = new Array(half1Size).fill(0);\n   576→  const partials1 = new Array(rank).fill(0);\n   577→\n   578→  let done1 = false;\n   579→  while (!done1) {\n   580→    let freeSum = 0;\n   581→    for (let f = 0; f < half1Size; f++) {\n   582→      freeSum += vals1[f];\n   583→    }\n   584→\n   585→    const key = partials1.join(\",\");\n   586→\n   587→    const existing = sigMap.get(key);\n   588→    if (!existing || freeSum < existing.freeSum ||\n   589→        (freeSum === existing.freeSum && lexSmallerArr(vals1, existing.freeVals))) {\n   590→      sigMap.set(key, {\n   591→        freeSum,\n   592→        freeVals: vals1.slice(),\n   593→        partials: partials1.slice()\n   594→      });\n   595→    }\n   596→\n   597→    // Increment with carry-based termination.\n   598→    done1 = true;\n   599→    for (let i = half1Size - 1; i >= 0; i--) {\n   600→      vals1[i]++;\n   601→      if (vals1[i] < p) {\n   602→        for (let r = 0; r < rank; r++) {\n   603→          partials1[r] = (partials1[r] + pivotFreeCoeffs[r][i]) % p;\n   604→        }\n   605→        done1 = false;\n   606→        break;\n   607→      }\n   608→      vals1[i] = 0;\n   609→      for (let r = 0; r < rank; r++) {\n   610→        partials1[r] = ((partials1[r] - (p - 1) * pivotFreeCoeffs[r][i]) % p + p) % p;\n   611→      }\n   612→    }\n   613→  }\n   614→\n   615→  // H2 fix: For each second-half assignment, compute the needed first-half\n   616→  // partials that would make each pivot variable zero, and do a direct lookup.\n   617→  // Also iterate all entries since there's no single \"optimal\" complement\n   618→  // due to the mod-p cost structure. The deduplication already reduces entries\n   619→  // to at most p^rank distinct signatures. For practical cases this is manageable.\n   620→  const sigEntries = Array.from(sigMap.values());\n   621→\n   622→  let bestSolution: number[] | null = null;\n   623→  let bestTotal = Infinity;\n   624→\n   625→  const vals2 = new Array(half2Size).fill(0);\n   626→  const partials2 = new Array(rank).fill(0);\n   627→\n   628→  let done2 = false;\n   629→  while (!done2) {\n   630→    let freeSum2 = 0;\n   631→    for (let f = 0; f < half2Size; f++) {\n   632→      freeSum2 += vals2[f];\n   633→    }\n   634→\n   635→    if (freeSum2 <= bestTotal) {\n   636→      // Try the \"zero pivot\" lookup first: find the first-half partials\n   637→      // that would make all pivot values = 0 (i.e., partials1[r] = (pivotConsts[r] - partials2[r]) mod p).\n   638→      const neededKey = new Array(rank);\n   639→      for (let r = 0; r < rank; r++) {\n   640→        neededKey[r] = ((pivotConsts[r] - partials2[r]) % p + p) % p;\n   641→      }\n   642→      const zeroEntry = sigMap.get(neededKey.join(\",\"));\n   643→      if (zeroEntry) {\n   644→        const totalCost = zeroEntry.freeSum + freeSum2; // all pivots are 0\n   645→        if (totalCost < bestTotal || (totalCost === bestTotal)) {\n   646→          const allFreeVals = [...zeroEntry.freeVals, ...vals2];\n   647→          const pivotValues = new Array(rank).fill(0);\n   648→          const candidate = buildCounterSolution(allFreeVals, pivotValues, freeVars, pivotCol, numButtons);\n   649→          if (totalCost < bestTotal) {\n   650→            bestTotal = totalCost;\n   651→            bestSolution = candidate;\n   652→          } else if (bestSolution === null || lexSmallerArr(candidate, bestSolution)) {\n   653→            bestSolution = candidate;\n   654→          }\n   655→        }\n   656→      }\n   657→\n   658→      // Also iterate all signature entries for co