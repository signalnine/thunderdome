al) {\n   165→      pivotPressed.push(pivotCol[r]);\n   166→    }\n   167→  }\n   168→\n   169→  // Merge two sorted arrays.\n   170→  const result: number[] = [];\n   171→  let i = 0, j = 0;\n   172→  while (i < freePressed.length && j < pivotPressed.length) {\n   173→    if (freePressed[i] < pivotPressed[j]) {\n   174→      result.push(freePressed[i++]);\n   175→    } else {\n   176→      result.push(pivotPressed[j++]);\n   177→    }\n   178→  }\n   179→  while (i < freePressed.length) result.push(freePressed[i++]);\n   180→  while (j < pivotPressed.length) result.push(pivotPressed[j++]);\n   181→\n   182→  return result;\n   183→}\n   184→\n   185→function popcount(n: number): number {\n   186→  n = n - ((n >> 1) & 0x55555555);\n   187→  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);\n   188→  n = (n + (n >> 4)) & 0x0f0f0f0f;\n   189→  return (n * 0x01010101) >> 24;\n   190→}\n   191→\n   192→function lexSmallerSorted(a: number[], b: number[]): boolean {\n   193→  const len = Math.max(a.length, b.length);\n   194→  for (let i = 0; i < len; i++) {\n   195→    const av = i < a.length ? a[i] : Infinity;\n   196→    const bv = i < b.length ? b[i] : Infinity;\n   197→    if (av < bv) return true;\n   198→    if (av > bv) return false;\n   199→  }\n   200→  return false;\n   201→}\n   202→\n   203→// ─── Part 2: Counter Puzzle ───────────────────────────────────────────\n   204→\n   205→export function solveCounter(\n   206→  lights: number[],\n   207→  buttons: number[][],\n   208→  modulus: number\n   209→): number[] | null {\n   210→  const numLights = lights.length;\n   211→  const numButtons = buttons.length;\n   212→  const p = modulus;\n   213→\n   214→  if (numButtons === 0) {\n   215→    return lights.every(l => ((l % p) + p) % p === 0) ? [] : null;\n   216→  }\n   217→\n   218→  // Build augmented matrix [A | target] over GF(p).\n   219→  const numCols = numButtons + 1;\n   220→  const matrix: number[][] = [];\n   221→\n   222→  for (let j = 0; j < numLights; j++) {\n   223→    const row = new Array(numCols).fill(0);\n   224→    for (let i = 0; i < numButtons; i++) {\n   225→      if (buttons[i].includes(j)) {\n   226→        row[i] = 1;\n   227→      }\n   228→    }\n   229→    row[numButtons] = ((lights[j] % p) + p) % p;\n   230→    matrix.push(row);\n   231→  }\n   232→\n   233→  // Gaussian elimination to RREF over GF(p).\n   234→  const pivotCol: number[] = [];\n   235→  let pivotRow = 0;\n   236→\n   237→  for (let col = 0; col < numButtons && pivotRow < numLights; col++) {\n   238→    let found = -1;\n   239→    for (let r = pivotRow; r < numLights; r++) {\n   240→      if (matrix[r][col] !== 0) {\n   241→        found = r;\n   242→        break;\n   243→      }\n   244→    }\n   245→    if (found === -1) continue;\n   246→\n   247→    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];\n   248→\n   249→    const inv = modInverse(matrix[pivotRow][col], p);\n   250→    for (let c = 0; c < numCols; c++) {\n   251→      matrix[pivotRow][c] = (matrix[pivotRow][c] * inv) % p;\n   252→    }\n   253→\n   254→    for (let r = 0; r < numLights; r++) {\n   255→      if (r !== pivotRow && matrix[r][col] !== 0) {\n   256→        const factor = matrix[r][col];\n   257→        for (let c = 0; c < numCols; c++) {\n   258→          matrix[r][c] = (((matrix[r][c] - factor * matrix[pivotRow][c]) % p) + p) % p;\n   259→        }\n   260→      }\n   261→    }\n   262→\n   263→    pivotCol.push(col);\n   264→    pivotRow++;\n   265→  }\n   266→\n   267→  const rank = pivotCol.length;\n   268→\n   269→  // Check for inconsistency.\n   270→  for (let r = rank; r < numLights; r++) {\n   271→    let allZero = true;\n   272→    for (let c = 0; c < numButtons; c++) {\n   273→      if (matrix[r][c] !== 0) {\n   274→        allZero = false;\n   275→        break;\n   276→      }\n   277→    }\n   278→    if (allZero && matrix[r][numButtons] !== 0) {\n   279→      return null;\n   280→    }\n   281→  }\n   282→\n   283→  // Identify free variables.\n   284→  const pivotColSet = new Set(pivotCol);\n   285→  const freeVars: number[] = [];\n   286→  for (let col = 0; col < numButtons; col++) {\n   287→    if (!pivotColSet.has(col)) {\n   288→      freeVars.push(col);\n   289→    }\n   290→  }\n   291→\n   292→  const numFree = freeVars.length;\n   293→\n   294→  // Precompute pivot row data.\n   295→  const pivotFreeCoeffs: number[][] = new Array(rank);\n   296→  const pivotConsts: number[] = new Array(rank);\n   297→  for (let r = 0; r < rank; r++) {\n   298→    pivotConsts[r] = matrix[r][numButtons];\n   299→    pivotFreeCoeffs[r] = new Array(numFree);\n   300→    for (let f = 0; f < numFree; f++) {\n   301→      pivotFreeCoeffs[r][f] = matrix[r][freeVars[f]];\n   302→    }\n   303→  }\n   304→\n   305→  if (numFree === 0) {\n   306→    const sol = new Array(numButtons).fill(0);\n   307→    for (let r = 0; r < rank; r++) {\n   308→      sol[pivotCol[r]] = pivotConsts[r];\n   309→    }\n   310→    return sol;\n   311→  }\n   312→\n   313→  // Compute max feasible enumeration.\n   314→  // For small spaces, enumerate directly. For larger ones, use MITM.\n   315→  let logSpace = 0;\n   316→  for (let f = 0; f < numFree; f++) {\n   317→    logSpace += Math.log(p);\n   318→  }\n   319→  const LOG_THRESHOLD = Math.log(5_000_000);\n   320→\n   321→  if (logSpace <= LOG_THRESHOLD) {\n   322→    return enumerateCounterSolutions(\n   323→      pivotCol, freeVars, pivotFreeCoeffs, pivotConsts, numButtons, p, rank, numFree\n   324→    );\n   325→  } else {\n   326→    return mitmCounterSolve(\n   327→      pivotCol, freeVars, pivotFreeCoeffs, pivotConsts, numButtons, p, rank, numFree\n   328→    );\n   329→  }\n   330→}\n   331→\n   332→function enumerateCounterSolutions(\n   333→  pivotCol: number[],\n   334→  freeVars: number[],\n   335→  pivotFreeCoeffs: number[][],\n   336→  pivotConsts: number[],\n   337→  numButtons: number,\n   338→  p: number,\n   339→  rank: number,\n   340→  numFree: number\n   341→): number[] {\n   342→  let bestSolution: number[] | null = null;\n   343→  let bestTotal = Infinity;\n   344→\n   345→  // We enumerate by incrementing a counter array.\n   346→  // To speed things up, maintain the running partial sums for each pivot row\n   347→  // and update incrementally.\n   348→  const freeVals = new Array(numFree).fill(0);\n   349→\n   350→  // pivotPartials[r] = sum_f pivotFreeCoeffs[r][f] * freeVals[f] mod p\n   351→  const pivotPartials = new Array(rank).fill(0);\n   352→\n   353→  const totalCombinations = Math.pow(p, numFree);\n   354→\n   355→  for (let iter = 0; iter < totalCombinations; iter++) {\n   356→    // Compute total cost.\n   357→    let total = 0;\n   358→    for (let f = 0; f < numFree; f++) {\n   359→      total += freeVals[f];\n   360→    }\n   361→\n   362→    if (total <= bestTotal) {\n   363→      const pivotValues = new Array(rank);\n   364→      let pruned = false;\n   365→      for (let r = 0; r < rank; r++) {\n   366→        pivotValues[r] = ((pivotConsts[r] - pivotPartials[r]) % p + p) % p;\n   367→        total += pivotValues[r];\n   368→        if (total > bestTotal) {\n   369→          pruned = true;\n   370→          break;\n   371→        }\n   372→      }\n   373→\n   374→      if (!pruned) {\n   375→        if (total < bestTotal) {\n   376→          bestTotal = total;\n   377→          bestSolution = buildCounterSolution(freeVals, pivotValues, freeVars, pivotCol, numButtons);\n   378→        } else if (total === bestTotal) {\n   379→          const candidate = buildCounterSolution(freeVals, pivotValues, freeVars, pivotCol, numButtons);\n   380→          if (bestSolution === null || lexSmallerArr(candidate, bestSolution)) {\n   381→            bestSolution = candidate;\n   382→          }\n   383→        }\n   384→      }\n   385→    }\n   386→\n   387→    // Increment counter and update pivotPartials incrementally.\n   388→    for (let i = numFree - 1; i >= 0; i--) {\n   389→      freeVals[i]++;\n   390→      if (freeVals[i] < p) {\n   391→        // Update partials: added 1 to freeVals[i].\n   392→        for (let r = 0; r < rank; r++) {\n   393→          pivotPartials[r] = (pivotPartials[r] + pivotFreeCoeffs[r][i]) % p;\n   394→        }\n   395→        break;\n   396→      }\n   397→      // Carry: freeVals[i] went from p-1 to 0. Update partials.\n   398→      freeVals[i] = 0;\n   399→      for (let r = 0; r < rank; r++) {\n   400→        // We subtracted (p-1) * coeff, but adding 1 and wrapping = subtracting (p-1) = adding 1 mod p.\n   401→        // Actually: old value was p-1, new is 0. Delta = -(p-1) * coeff = +coeff mod p.\n   402→        // Wait, let me think more carefully.\n   403→        // Before increment: freeVals[i] was p-1. After: it becomes p, then wraps to 0.\n   404→        // The partial was using freeVals[i]=p-1. Now freeVals[i]=0.\n   405→        // Change in contribution for row r: (0 - (p-1)) * coeff = -(p-1)*coeff = coeff (mod p).\n   406→        pivotPartials[r] = ((pivotPartials[r] - (p - 1) * pivotFreeCoeffs[r][i]) % p + p) % p;\n   407→      }\n   408→    }\n   409→  }\n   410→\n   411→  return bestSolution!;\n   412→}\n   413→\n   414→/**\n   415→ * Meet-in-the-middle for counter puzzle with large free variable spaces.\n   416→ * Split free vars into two halves. For each half, enumerate all assignments,\n   417→ * computing the partial contribution to pivot rows. Group first-half by\n   418→ * signature (partial vector mod p). For each second-half assignment, look up\n   419→ * ALL first-half signatures and compute full cost.\n   420→ *\n   421→ * This is O(p^(n/2) * numDistinctSigs) where numDistinctSigs ≤ p^rank\n   422→ * but is often much smaller. Combined with the fact that we keep only\n   423→ * the best entry per signature, this prunes heavily.\n   424→ */\n   425→function mitmCounterSolve(\n   426→  pivotCol: number[],\n   427→  freeVars: number[],\n   428→  pivotFreeCoeffs: number[][],\n   429→  pivotConsts: number[],\n   430→  numButtons: number,\n   431→  p: number,\n   432→  rank: number,\n   433→  numFree: number\n   434→): number[] | null {\n   435→  const half1Size = Math.floor(numFree / 2);\n   436→  const half2Size = numFree - half1Size;\n   437→\n   438→  interface HalfEntry {\n   439→    freeSum: number;\n   440→    freeVals: number[];\n   441→    partials: number[];\n   442→  }\n   443→\n   444→  // Enumerate first half and store best entry per signature.\n   445→  const sigMap = new Map<string, HalfEntry>();\n   446→\n   447→  const vals1 = new Array(half1Size).fill(0);\n   448→  const total1 = Math.pow(p, half1Size);\n   449→  const partials1 = new Array(rank).fill(0);\n   450→\n   451→  for (let iter = 0; iter < total1; iter++) {\n   452→    let freeSum = 0;\n   453→    for (let f = 0; f < half1Size; f++) {\n   454→      freeSum += vals1[f];\n   455→    }\n   456→\n   457→    const key = partials1.join(\",\");\n   458→\n   459→    const existing = sigMap.get(key);\n   460→    if (!existing || freeSum < existing.freeSum ||\n   461→        (freeSum === existing.freeSum && lexSmallerArr(vals1, existing.freeVals))) {\n   462→      sigMap.set(key, {\n   463→        freeSum,\n   464→        freeVals: vals1.slice(),\n   465→        partials: partials1.slice()\n   466→      });\n   467→    }\n   468→\n   469→    // Increment vals1 and update partials1 incrementally.\n   470→    for (let i = half1Size - 1; i >= 0; i--) {\n   471→      vals1[i]++;\n   472→      if (vals1[i] < p) {\n   473→        for (let r = 0; r < rank; r++) {\n   474→          partials1[r] = (partials1[r] + pivotFreeCoeffs[r][i]) % p;\n   475→        }\n   476→        break;\n   477→      }\n   478→      vals1[i] = 0;\n   479→      for (let r = 0; r < rank; r++) {\n   480→        partials1[r] = ((partials1[r] - (p - 1) * pivotFreeCoeffs[r][i]) % p + p) % p;\n   481→      }\n   482→    }\n   483→  }\n   484→\n   485→  // Convert map to array for faster iteration.\n   486→  const sigEntries = Array.from(sigMap.values());\n   487→\n   488→  // Enumerate second half.\n   489→  let bestSolution: number[] | null = null;\n   490→  let bestTotal = Infinity;\n   491→\n   492→  const vals2 = new Array(half2Size).fill(0);\n   493→  const total2 = Math.pow(p, half2Size);\n   494→  const partials2 = new Array(rank).fill(0);\n   495→\n   496→  for (let iter = 0; iter < total2; iter++) {\n   497→    let freeSum2 = 0;\n   498→    for (let f = 0; f < half2Size; f++) {\n   499→      freeSum2 += vals2[f];\n   500→    }\n   501→\n   502→    // For each first-half signature entry, compute full cost.\n   503→    for (let e = 0; e < sigEntries.length; e++) {\n   504→      const entry = sigEntries[e];\n   505→\n   506→      const totalFreeSum = entry.freeSum + freeSum2;\n   507→      if (totalFreeSum > bestTotal) continue;\n   508→\n   509→      let pivotSum = 0;\n   510→      let total = totalFreeSum;\n   511→      let pruned = false;\n   512→      for (let r = 0; r < rank; r++) {\n   513→        pivotSum = ((pivotConsts[r] - entry.partials[r] - partials2[r]) % p + p) % p;\n   514→        total += pivotSum;\n   515→        if (total > bestTotal) {\n   516→          pruned = true;\n   517→          break;\n   518→        }\n   519→      }\n   520→\n   521→      if (pruned) continue;\n   522→\n   523→      if (total < bestTotal) {\n   524→        bestTotal = total;\n   525→        const allFreeVals = [...entry.freeVals, ...vals2];\n   526→        const pivotValues = new Array(rank);\n   527→        for (let r = 0; r < rank; r++) {\n   528→          pivotValues[r] = ((pivotConsts[r] - entry.partials[r] - partials2[r]) % p + p) % p;\n   529→        }\n   530→        bestSolution = buildCounterSolution(allFreeVals, pivotValues, freeVars, pivotCol, numButtons);\n   531→      } else if (total === bestTotal) {\n   532→        const allFreeVals = [...entry.freeVals, ...vals2];\n   533→        const pivotValues = new Array(rank);\n   534→        for (let r = 0; r < rank; r++) {\n   535→          pivotValues[r] = ((pivotConsts[r] - entry.partials[r] - partials2[r]) % p + p) % p;\n   536→        }\n   537→        const candidate = buildCounterSolution(allFreeVals, pivotValues, freeVars, pivotCol, numButtons);\n   538→        if (bestSolution === null || lexSmallerArr(candidate, bestSolution)) {\n   539→          bestSolution = candidate;\n   540→        }\n   541→      }\n   542→    }\n   543→\n   544→    // Increment vals2 and update partials2 incrementally.\n   545→    for (let i = half2Size - 1; i >= 0; i--) {\n   546→      vals2[i]++;\n   547→      if (vals2[i] < p) {\n   548→        for (let r = 0; r < rank; r++) {\n   549→          partials2[r] = (partials2[r] + pivotFreeCoeffs[r][half1Size + i]) % p;\n   550→        }\n   551→        break;\n   552→      }\n   553→      vals2[i] = 0;\n   554→      for (let r = 0; r < rank; r++) {\n   555→        partials2[r] = ((partials2[r] - (p - 1) * pivotFreeCoeffs[r][half1Size + i]) % p + p) % p;\n   556→      }\n   557→    }\n   558→  }\n   559→\n   560→  return bestSolution;\n   561→}\n   562→\n   563→function buildCounterSolution(\n   564→  freeVals: number[], pivotValues: number[],\n   565→  freeVars: number[], pivotCol: number[],\n   566→  numButtons: number\n   567→): number[] {\n   568→  const sol = new Array(numButtons).fill(0);\n   569→  for (let f = 0; f < freeVals.length; f++) {\n   570→    sol[freeVars[f]] = freeVals[f];\n   571→  }\n   572→  for (let r = 0; r < pivotValues.length; r++) {\n   573→    sol[pivotCol[r]] = pivotValues[r];\n   574→  }\n   575→  return sol;\n   576→}\n   577→\n   578→function lexSmallerArr(a: number[], b: number[]): boolean {\n   579→  for (let i = 0; i < a.length; i++) {\n   580→    if (a[i] < b[i]) return true;\n   581→    if (a[i] > b[i]) return false;\n   582→  }\n   583→  return false;\n   584→}\n   585→\n   586→function modInverse(a: number, p: number): number {\n   587→  a = ((a % p) + p) % p;\n   588→  let [old_r, r] = [a, p];\n   589→  let [old_s, s] = [1, 0];\n  