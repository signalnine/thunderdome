rge when conflicts exist', () => {\n+      store.create('doc1', { a: 1 });\n+      store.createBranch('feature');\n+\n+      store.switchBranch('feature');\n+      store.update('doc1', { a: 100 });\n+\n+      store.switchBranch('main');\n+      store.update('doc1', { a: 200 });\n+\n+      store.merge('feature');\n+      // Should still have the pre-merge value\n+      expect(store.get('doc1')).toEqual({ a: 200 });\n+    });\n+\n+    it('should handle adding new fields on one side', () => {\n+      store.create('doc1', { a: 1 });\n+      store.createBranch('feature');\n+\n+      store.switchBranch('feature');\n+      store.update('doc1', { a: 1, newField: 'hello' });\n+\n+      store.switchBranch('main');\n+      const result = store.merge('feature');\n+      expect(result.applied).toBe(true);\n+      expect(store.get('doc1')).toEqual({ a: 1, newField: 'hello' });\n+    });\n+\n+    it('should throw when merging non-existent branch', () => {\n+      expect(() => store.merge('nonexistent')).toThrow();\n+    });\n+  });\n+});\ndiff --git a/src/index.ts b/src/index.ts\nnew file mode 100644\nindex 0000000..2299e17\n--- /dev/null\n+++ b/src/index.ts\n@@ -0,0 +1,382 @@\n+import { Version, MergeResult, Conflict, DocumentEntry } from './types.js';\n+import { deepClone, threeWayMerge } from './merge.js';\n+\n+export type { Version, MergeResult, Conflict };\n+\n+interface BranchData {\n+  documents: Map<string, DocumentEntry>;\n+  /** The name of the branch this was forked from, and snapshot at fork time */\n+  parent?: {\n+    branch: string;\n+    snapshot: Map<string, DocumentEntry>;\n+  };\n+}\n+\n+function cloneDocumentEntry(entry: DocumentEntry): DocumentEntry {\n+  return {\n+    content: deepClone(entry.content),\n+    versions: entry.versions.map((v) => ({\n+      id: v.id,\n+      timestamp: v.timestamp,\n+      content: deepClone(v.content),\n+    })),\n+    deleted: entry.deleted,\n+  };\n+}\n+\n+function cloneDocumentsMap(\n+  docs: Map<string, DocumentEntry>\n+):