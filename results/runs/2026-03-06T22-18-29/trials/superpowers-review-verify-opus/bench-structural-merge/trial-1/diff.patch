+++ b/src/index.ts
@@ -0,0 +1,382 @@
+import { Version, MergeResult, Conflict, DocumentEntry } from './types.js';
+import { deepClone, deepEqual, threeWayMerge } from './merge.js';
+
+export type { Version, MergeResult, Conflict };
+
+interface BranchData {
+  documents: Map<string, DocumentEntry>;
+  /** The name of the branch this was forked from, and snapshot at fork time */
+  parent?: {
+    branch: string;
+    snapshot: Map<string, DocumentEntry>;
+  };
+}
+
+function cloneDocumentEntry(entry: DocumentEntry): DocumentEntry {
+  return {
+    content: deepClone(entry.content),
+    versions: entry.versions.map((v) => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+    deleted: entry.deleted,
+  };
+}
+
+function cloneDocumentsMap(
+  docs: Map<string, DocumentEntry>
+): Map<string, DocumentEntry> {
+  const clone = new Map<string, DocumentEntry>();
+  for (const [id, entry] of docs) {
+    clone.set(id, cloneDocumentEntry(entry));
+  }
+  return clone;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+  private versionCounter: number = 0;
+
+  constructor() {
+    this.branches.set('main', { documents: new Map() });
+  }
+
+  private generateVersionId(): string {
+    return `v_${++this.versionCounter}_${Date.now()}`;
+  }
+
+  // --- Document CRUD ---
+
+  create(id: string, content: object): void {
+    const docs = this.currentDocs();
+    const existing = docs.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const cloned = deepClone(content);
+    const version: Version = {
+      id: this.generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(cloned),
+    };
+
+    docs.set(id, {
+      content: cloned,
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const entry = this.getEntry(id);
+    return deepClone(entry.content);
+  }
+
+  update(id: string, content: object): void {
+    const entry = this.getEntry(id);
+    const cloned = deepClone(content);
+    const version: Version = {
+      id: this.generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(cloned),
+    };
+
+    entry.content = cloned;
+    entry.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const docs = this.currentDocs();
+    const entry = docs.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    entry.deleted = true;
+  }
+
+  // --- Version History ---
+
+  getHistory(id: string): Version[] {
+    const docs = this.currentDocs();
+    const entry = docs.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return entry.versions.map((v) => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const docs = this.currentDocs();
+    const entry = docs.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = entry.versions.find((v) => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // --- Branching ---
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch "${sourceName}" does not exist`);
+    }
+
+    const snapshot = cloneDocumentsMap(source.documents);
+    const documents = cloneDocumentsMap(snapshot);
+
+    this.branches.set(name, {
+      documents,
+      parent: {
+        branch: sourceName,
+        snapshot,
+      },
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // --- Merging ---
+
+  merge(sourceBranch: string): MergeResult {
+    const source = this.branches.get(sourceBranch);
+    if (!source) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+
+    const target = this.branches.get(this.currentBranch)!;
+
+    // Find the common ancestor (base) state
+    const base = this.findCommonAncestor(sourceBranch, this.currentBranch);
+
+    const sourceDocs = source.documents;
+    const targetDocs = target.documents;
+
+    // Collect all document IDs across base, source, and target
+    const allDocIds = new Set<string>();
+    for (const id of base.keys()) allDocIds.add(id);
+    for (const id of sourceDocs.keys()) allDocIds.add(id);
+    for (const id of targetDocs.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseEntry = base.get(docId);
+      const sourceEntry = sourceDocs.get(docId);
+      const targetEntry = targetDocs.get(docId);
+
+      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : undefined;
+      const sourceContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : undefined;
+      const targetContent = targetEntry && !targetEntry.deleted ? targetEntry.content : undefined;
+
+      const sourceChanged = !this.contentsEqual(baseContent, sourceContent);
+      const targetChanged = !this.contentsEqual(baseContent, targetContent);
+
+      if (!sourceChanged && !targetChanged) {
+        // No changes on either side
+        if (targetContent !== undefined) {
+          merged[docId] = deepClone(targetContent);
+        }
+        continue;
+      }
+
+      if (sourceChanged && !targetChanged) {
+        // Only source changed
+        if (sourceContent !== undefined) {
+          merged[docId] = deepClone(sourceContent);
+        }
+        // If source deleted the doc, don't include in merged
+        continue;
+      }
+
+      if (!sourceChanged && targetChanged) {
+        // Only target changed
+        if (targetContent !== undefined) {
+          merged[docId] = deepClone(targetContent);
+        }
+        continue;
+      }
+
+      // Both changed
+      if (this.contentsEqual(sourceContent, targetContent)) {
+        // Both changed to the same thing
+        if (targetContent !== undefined) {
+          merged[docId] = deepClone(targetContent);
+        }
+        continue;
+      }
+
+      // Both changed differently - need three-way merge at field level
+      if (sourceContent !== undefined && targetContent !== undefined && baseContent !== undefined) {
+        const mergeResult = threeWayMerge(
+          baseContent as Record<string, unknown>,
+          targetContent as Record<string, unknown>,
+          sourceContent as Record<string, unknown>,
+          docId
+        );
+        merged[docId] = mergeResult.result as object;
+        conflicts.push(...mergeResult.conflicts);
+      } else if (sourceContent !== undefined && targetContent !== undefined) {
+        // Both created the same doc (no base) - merge with empty base
+        const mergeResult = threeWayMerge(
+          {},
+          targetContent as Record<string, unknown>,
+          sourceContent as Record<string, unknown>,
+          docId
+        );
+        merged[docId] = mergeResult.result as object;
+        conflicts.push(...mergeResult.conflicts);
+      } else {
+        // One side deleted, other modified - conflict on the whole document
+        conflicts.push({
+          documentId: docId,
+          path: '',
+          base: baseContent !== undefined ? deepClone(baseContent) : undefined,
+          ours: targetContent !== undefined ? deepClone(targetContent) : undefined,
+          theirs: sourceContent !== undefined ? deepClone(sourceContent) : undefined,
+        });
+        if (targetContent !== undefined) {
+          merged[docId] = deepClone(targetContent);
+        }
+      }
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge to the current branch
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const existingEntry = targetDocs.get(docId);
+          if (existingEntry) {
+            // Check if the content actually changed
+            if (!this.contentsEqual(existingEntry.content, merged[docId])) {
+              const version: Version = {
+                id: this.generateVersionId(),
+                timestamp: Date.now(),
+                content: deepClone(merged[docId]),
+              };
+              existingEntry.content = deepClone(merged[docId]);
+              existingEntry.deleted = false;
+              existingEntry.versions.push(version);
+            } else if (existingEntry.deleted) {
+              // Was deleted on target but source brought it back
+              existingEntry.content = deepClone(merged[docId]);
+              existingEntry.deleted = false;
+              const version: Version = {
+                id: this.generateVersionId(),
+                timestamp: Date.now(),
+                content: deepClone(merged[docId]),
+              };
+              existingEntry.versions.push(version);
+            }
+          } else {
+            // New document from source branch
+            const version: Version = {
+              id: this.generateVersionId(),
+              timestamp: Date.now(),
+              content: deepClone(merged[docId]),
+            };
+            targetDocs.set(docId, {
+              content: deepClone(merged[docId]),
+              versions: [version],
+              deleted: false,
+            });
+          }
+        } else {
+          // Document was deleted in the merge
+          const existingEntry = targetDocs.get(docId);
+          if (existingEntry && !existingEntry.deleted) {
+            existingEntry.deleted = true;
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts, applied };
+  }
+
+  // --- Private helpers ---
+
+  private currentDocs(): Map<string, DocumentEntry> {
+    return this.branches.get(this.currentBranch)!.documents;
+  }
+
+  private getEntry(id: string): DocumentEntry {
+    const docs = this.currentDocs();
+    const entry = docs.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return entry;
+  }
+
+  private contentsEqual(a: object | undefined, b: object | undefined): boolean {
+    if (a === undefined && b === undefined) return true;
+    if (a === undefined || b === undefined) return false;
+    return deepEqual(a, b);
+  }
+
+  private findCommonAncestor(
+    branchA: string,
+    branchB: string
+  ): Map<string, DocumentEntry> {
+    const branchAData = this.branches.get(branchA)!;
+    const branchBData = this.branches.get(branchB)!;
+
+    // If branchA was forked from branchB (or current branch)
+    if (branchAData.parent?.branch === branchB) {
+      return branchAData.parent.snapshot;
+    }
+
+    // If branchB was forked from branchA
+    if (branchBData.parent?.branch === branchA) {
+      return branchBData.parent.snapshot;
+    }
+
+    // If both were forked from the same parent, find common ancestor
+    // Try to find if they share a common parent
+    if (
+      branchAData.parent &&
+      branchBData.parent &&
+      branchAData.parent.branch === branchBData.parent.branch
+    ) {
+      // Both forked from the same branch - the earlier snapshot is the ancestor
+      // Use branchA's parent snapshot as a reasonable base
+      return branchAData.parent.snapshot;
+    }
+
+    // Default: empty base (treat as if both created everything from scratch)
+    return new Map();
+  }
+}
