  // Find the common ancestor (base) state\n   179→    const base = this.findCommonAncestor(sourceBranch, this.currentBranch);\n   180→\n   181→    const sourceDocs = source.documents;\n   182→    const targetDocs = target.documents;\n   183→\n   184→    // Collect all document IDs across base, source, and target\n   185→    const allDocIds = new Set<string>();\n   186→    for (const id of base.keys()) allDocIds.add(id);\n   187→    for (const id of sourceDocs.keys()) allDocIds.add(id);\n   188→    for (const id of targetDocs.keys()) allDocIds.add(id);\n   189→\n   190→    const merged: Record<string, object> = {};\n   191→    const conflicts: Conflict[] = [];\n   192→\n   193→    for (const docId of allDocIds) {\n   194→      const baseEntry = base.get(docId);\n   195→      const sourceEntry = sourceDocs.get(docId);\n   196→      const targetEntry = targetDocs.get(docId);\n   197→\n   198→      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : undefined;\n   199→      const sourceContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : undefined;\n   200→      const targetContent = targetEntry && !targetEntry.deleted ? targetEntry.content : undefined;\n   201→\n   202→      const sourceChanged = !this.contentsEqual(baseContent, sourceContent);\n   203→      const targetChanged = !this.contentsEqual(baseContent, targetContent);\n   204→\n   205→      if (!sourceChanged && !targetChanged) {\n   206→        // No changes on either side\n   207→        if (targetContent !== undefined) {\n   208→          merged[docId] = deepClone(targetContent);\n   209→        }\n   210→        continue;\n   211→      }\n   212→\n   213→      if (sourceChanged && !targetChanged) {\n   214→        // Only source changed\n   215→        if (sourceContent !== undefined) {\n   216→          merged[docId] = deepClone(sourceContent);\n   217→        }\n   218→        // If source deleted the doc, don't include in merged\n   219→        continue;\n   220→