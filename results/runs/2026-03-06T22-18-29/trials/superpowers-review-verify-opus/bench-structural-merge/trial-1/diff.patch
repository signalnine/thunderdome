@@ -0,0 +1,124 @@
+import { Conflict } from './types.js';
+
+function isPlainObject(val: unknown): val is Record<string, unknown> {
+  return val !== null && typeof val === 'object' && !Array.isArray(val);
+}
+
+export function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return a === b;
+  if (typeof a !== typeof b) return false;
+
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    for (let i = 0; i < a.length; i++) {
+      if (!deepEqual(a[i], b[i])) return false;
+    }
+    return true;
+  }
+
+  if (isPlainObject(a) && isPlainObject(b)) {
+    const keysA = Object.keys(a);
+    const keysB = Object.keys(b);
+    if (keysA.length !== keysB.length) return false;
+    for (const key of keysA) {
+      if (!Object.prototype.hasOwnProperty.call(b, key)) return false;
+      if (!deepEqual(a[key], b[key])) return false;
+    }
+    return true;
+  }
+
+  return false;
+}
+
+export function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+/**
+ * Three-way merge of two objects against a common base.
+ * Returns the merged result and any conflicts found.
+ */
+export function threeWayMerge(
+  base: Record<string, unknown>,
+  ours: Record<string, unknown>,
+  theirs: Record<string, unknown>,
+  documentId: string,
+  pathPrefix: string = ''
+): { result: Record<string, unknown>; conflicts: Conflict[] } {
+  const conflicts: Conflict[] = [];
+  const result: Record<string, unknown> = {};
+
+  const allKeys = new Set([
+    ...Object.keys(base),
+    ...Object.keys(ours),
+    ...Object.keys(theirs),
+  ]);
+
+  for (const key of allKeys) {
+    const currentPath = pathPrefix ? `${pathPrefix}.${key}` : key;
+    const baseVal = base[key];
+    const oursVal = ours[key];
+    const theirsVal = theirs[key];
+
+    const oursChanged = !deepEqual(baseVal, oursVal);
+    const theirsChanged = !deepEqual(baseVal, theirsVal);
+
+    if (!oursChanged && !theirsChanged) {
+      // Neither side changed - keep base value (only if it exists)
+      if (Object.prototype.hasOwnProperty.call(base, key)) {
+        result[key] = deepClone(baseVal);
+      }
+    } else if (oursChanged && !theirsChanged) {
+      // Only ours changed - take ours
+      if (Object.prototype.hasOwnProperty.call(ours, key)) {
+        result[key] = deepClone(oursVal);
+      }
+      // If ours deleted the key (not in ours), don't add to result
+    } else if (!oursChanged && theirsChanged) {
+      // Only theirs changed - take theirs
+      if (Object.prototype.hasOwnProperty.call(theirs, key)) {
+        result[key] = deepClone(theirsVal);
+      }
+      // If theirs deleted the key, don't add to result
+    } else {
+      // Both changed
+      if (deepEqual(oursVal, theirsVal)) {
+        // Both changed to the same value - no conflict
+        if (Object.prototype.hasOwnProperty.call(ours, key)) {
+          result[key] = deepClone(oursVal);
+        }
+      } else if (
+        isPlainObject(baseVal) &&
+        isPlainObject(oursVal) &&
+        isPlainObject(theirsVal)
+      ) {
+        // Both are objects - recurse
+        const nested = threeWayMerge(
+          baseVal as Record<string, unknown>,
+          oursVal as Record<string, unknown>,
+          theirsVal as Record<string, unknown>,
+          documentId,
+          currentPath
+        );
+        result[key] = nested.result;
+        conflicts.push(...nested.conflicts);
+      } else {
+        // Conflict - take ours for the merged result
+        conflicts.push({
+          documentId,
+          path: currentPath,
+          base: deepClone(baseVal),
+          ours: deepClone(oursVal),
+          theirs: deepClone(theirsVal),
+        });
+        // For merged output, use "ours"
+        if (Object.prototype.hasOwnProperty.call(ours, key)) {
+          result[key] = deepClone(oursVal);
+        }
+      }
+    }
+  }
+
+  return { result, conflicts };
+}
