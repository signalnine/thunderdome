+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GKFtLQYAzZuFWMcLEkZFbm","type":"tool_result","content":"     1→import { Version, MergeResult, Conflict, DocumentEntry } from './types.js';\n     2→import { deepClone, threeWayMerge } from './merge.js';\n     3→\n     4→export type { Version, MergeResult, Conflict };\n     5→\n     6→interface BranchData {\n     7→  documents: Map<string, DocumentEntry>;\n     8→  /** The name of the branch this was forked from, and snapshot at fork time */\n     9→  parent?: {\n    10→    branch: string;\n    11→    snapshot: Map<string, DocumentEntry>;\n    12→  };\n    13→}\n    14→\n    15→function cloneDocumentEntry(entry: DocumentEntry): DocumentEntry {\n    16→  return {\n    17→    content: deepClone(entry.content),\n    18→    versions: entry.versions.map((v) => ({\n    19→      id: v.id,\n    20→      timestamp: v.timestamp,\n    21→      content: deepClone(v.content),\n    22→    })),\n    23→    deleted: entry.deleted,\n    24→  };\n    25→}\n    26→\n    27→function cloneDocumentsMap(\n    28→  docs: Map<string, DocumentEntry>\n    29→): Map<string, DocumentEntry> {\n    30→  const clone = new Map<string, DocumentEntry>();\n    31→  for (const [id, entry] of docs) {\n    32→    clone.set(id, cloneDocumentEntry(entry));\n    33→  }\n    34→  return clone;\n    35→}\n    36→\n    37→let versionCounter = 0;\n    38→\n    39→function generateVersionId(): string {\n    40→  return `v_${++versionCounter}_${Date.now()}`;\n    41→}\n    42→\n    43→export class DocumentStore {\n    44→  private branches: Map<string, BranchData> = new Map();\n    45→  private currentBranch: string = 'main';\n    46→\n    47→  constructor() {\n    48→    this.branches.set('main', { documents: new Map() });\n    49→  }\n    50→\n    51→  // --- Document CRUD ---\n    52→\n    53→  create(id: string, content: object): void {\n    54→    const docs = this.currentDocs();\n    55→    const existing = docs.get(id);\n    56→    i