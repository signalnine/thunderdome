Id])) {\n              const version: Version = {\n                id: this.generateVersionId(),\n                timestamp: Date.now(),\n                content: deepClone(merged[docId]),\n              };\n              existingEntry.content = deepClone(merged[docId]);\n              existingEntry.deleted = false;\n              existingEntry.versions.push(version);\n            } else if (existingEntry.deleted) {\n              // Was deleted on target but source brought it back\n              existingEntry.content = deepClone(merged[docId]);\n              existingEntry.deleted = false;\n              const version: Version = {\n                id: this.generateVersionId(),\n                timestamp: Date.now(),\n                content: deepClone(merged[docId]),\n              };\n              existingEntry.versions.push(version);\n            }\n          } else {\n            // New document from source branch\n            const version: Version = {\n              id: this.generateVersionId(),\n              timestamp: Date.now(),\n              content: deepClone(merged[docId]),\n            };\n            targetDocs.set(docId, {\n              content: deepClone(merged[docId]),\n              versions: [version],\n              deleted: false,\n            });\n          }\n        } else {\n          // Document was deleted in the merge\n          const existingEntry = targetDocs.get(docId);\n          if (existingEntry && !existingEntry.deleted) {\n            existingEntry.deleted = true;\n          }\n        }\n      }\n    }\n\n    return { merged, conflicts, applied };\n  }\n\n  // --- Private helpers ---\n\n  private currentDocs(): Map<string, DocumentEntry> {\n    return this.branches.get(this.currentBranch)!.documents;\n  }\n\n  private getEntry(id: string): DocumentEntry {\n    const docs = this.currentDocs();\n    const entry = docs.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    return entry;\n  }\n\n  private contentsEqual(a: object | undefined, b: object | undefined): boolean {\n    if (a === undefined && b === undefined) return true;\n    if (a === undefined || b === undefined) return false;\n    return deepEqual(a, b);\n  }\n\n  private findCommonAncestor(\n    branchA: string,\n    branchB: string\n  ): Map<string, DocumentEntry> {\n    const branchAData = this.branches.get(branchA)!;\n    const branchBData = this.branches.get(branchB)!;\n\n    // If branchA was forked from branchB (or current branch)\n    if (branchAData.parent?.branch === branchB) {\n      return branchAData.parent.snapshot;\n    }\n\n    // If branchB was forked from branchA\n    if (branchBData.parent?.branch === branchA) {\n      return branchBData.parent.snapshot;\n    }\n\n    // If both were forked from the same parent, find common ancestor\n    // Try to find if they share a common parent\n    if (\n      branchAData.parent &&\n      branchBData.parent &&\n      branchAData.parent.branch === branchBData.parent.branch\n    ) {\n      // Both forked from the same branch - the earlier snapshot is the ancestor\n      // Use branchA's parent snapshot as a reasonable base\n      return branchAData.parent.snapshot;\n    }\n\n    // Default: empty base (treat as if both created everything from scratch)\n    return new Map();\n  }\n}\n","numLines":383,"startLine":1,"totalLines":383}}}
