+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('Document CRUD', () => {
+    it('should create and get a document', () => {
+      store.create('doc1', { name: 'test', value: 42 });
+      const result = store.get('doc1');
+      expect(result).toEqual({ name: 'test', value: 42 });
+    });
+
+    it('should throw when creating a document with existing ID', () => {
+      store.create('doc1', { name: 'test' });
+      expect(() => store.create('doc1', { name: 'other' })).toThrow();
+    });
+
+    it('should throw when getting a non-existent document', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+
+    it('should update a document', () => {
+      store.create('doc1', { name: 'test' });
+      store.update('doc1', { name: 'updated' });
+      expect(store.get('doc1')).toEqual({ name: 'updated' });
+    });
+
+    it('should throw when updating a non-existent document', () => {
+      expect(() => store.update('nonexistent', { name: 'test' })).toThrow();
+    });
+
+    it('should delete a document', () => {
+      store.create('doc1', { name: 'test' });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should throw when deleting a non-existent document', () => {
+      expect(() => store.delete('nonexistent')).toThrow();
+    });
+
+    it('should deep clone on create', () => {
+      const content = { nested: { value: 1 } };
+      store.create('doc1', content);
+      content.nested.value = 999;
+      expect(store.get('doc1')).toEqual({ nested: { value: 1 } });
+    });
+
+    it('should deep clone on get', () => {
+      store.create('doc1', { nested: { value: 1 } });
+      const result = store.get('doc1') as { nested: { value: number } };
+      result.nested.value = 999;
+      expect(store.get('doc1')).toEqual({ nested: { value: 1 } });
+    });
+
+    it('should deep clone on update', () => {
+      store.create('doc1', { name: 'test' });
+      const content = { name: 'updated', nested: { value: 1 } };
+      store.update('doc1', content);
+      content.nested.value = 999;
+      expect(store.get('doc1')).toEqual({ name: 'updated', nested: { value: 1 } });
+    });
+  });
+
+  describe('Version History', () => {
+    it('should track versions on create', () => {
+      store.create('doc1', { name: 'v1' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(1);
+      expect(history[0].content).toEqual({ name: 'v1' });
+    });
+
+    it('should track versions on update', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      store.update('doc1', { name: 'v3' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ name: 'v1' });
+      expect(history[1].content).toEqual({ name: 'v2' });
+      expect(history[2].content).toEqual({ name: 'v3' });
+    });
+
+    it('should return versions in chronological order', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);
+    });
+
+    it('should get a specific version', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      const history = store.getHistory('doc1');
+      const v1Content = store.getVersion('doc1', history[0].id);
+      expect(v1Content).toEqual({ name: 'v1' });
+    });
+
+    it('should throw for non-existent version', () => {
+      store.create('doc1', { name: 'v1' });
+      expect(() => store.getVersion('doc1', 'fake-id')).toThrow();
+    });
+
+    it('should throw getHistory for non-existent document', () => {
+      expect(() => store.getHistory('nonexistent')).toThrow();
+    });
+
+    it('should have unique version IDs', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(history[0].id).not.toBe(history[1].id);
+    });
+
+    it('should deep clone version content', () => {
+      store.create('doc1', { nested: { value: 1 } });
+      const history = store.getHistory('doc1');
+      (history[0].content as { nested: { value: number } }).nested.value = 999;
+      expect(store.getHistory('doc1')[0].content).toEqual({ nested: { value: 1 } });
+    });
+  });
+
+  describe('Branching', () => {
+    it('should start on main branch', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('should create and switch to a branch', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    it('should list branches', () => {
+      store.createBranch('feature');
+      store.createBranch('bugfix');
+      expect(store.listBranches()).toContain('main');
+      expect(store.listBranches()).toContain('feature');
+      expect(store.listBranches()).toContain('bugfix');
+    });
+
+    it('should isolate changes between branches', () => {
+      store.create('doc1', { name: 'main-value' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { name: 'feature-value' });
+
+      expect(store.get('doc1')).toEqual({ name: 'feature-value' });
+
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ name: 'main-value' });
+    });
+
+    it('should branch from a specific branch', () => {
+      store.create('doc1', { name: 'main-value' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { name: 'feature-value' });
+
+      store.switchBranch('main');
+      store.createBranch('from-feature', 'feature');
+      store.switchBranch('from-feature');
+      expect(store.get('doc1')).toEqual({ name: 'feature-value' });
+    });
+
+    it('should throw when creating a duplicate branch', () => {
+      store.createBranch('feature');
+      expect(() => store.createBranch('feature')).toThrow();
+    });
+
+    it('should throw when switching to non-existent branch', () => {
+      expect(() => store.switchBranch('nonexistent')).toThrow();
+    });
+
+    it('should not share new documents across branches', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('feature-only', { data: true });
+
+      store.switchBranch('main');
+      expect(() => store.get('feature-only')).toThrow();
+    });
+  });
+
+  describe('Merging', () => {
+    it('should merge non-conflicting changes', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      // Change on feature
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2 });
+
+      // Change on main
+      store.switchBranch('main');
+      store.update('doc1', { a: 1, b: 20 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 20 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 20 });
+    });
+
+    it('should detect conflicts', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 200 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0]).toMatchObject({
+        documentId: 'doc1',
+        path: 'a',
+        base: 1,
+        ours: 200,
+        theirs: 100,
+      });
+      // Current branch should be unchanged
+      expect(store.get('doc1')).toEqual({ a: 200 });
+    });
+
+    it('should handle same value changes as no conflict', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 42 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 42 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it('should merge new documents from source', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('new-doc', { value: 'from-feature' });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('new-doc')).toEqual({ value: 'from-feature' });
+    });
+
+    it('should handle independent documents across branches', () => {
+      store.create('doc1', { a: 1 });
+      store.create('doc2', { b: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10 });
+
+      store.switchBranch('main');
+      store.update('doc2', { b: 10 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(store.get('doc1')).toEqual({ a: 10 });
+      expect(store.get('doc2')).toEqual({ b: 10 });
+    });
+
+    it('should show merged result with ours for conflicts', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100, b: 2 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 200, b: 2 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      // Merged should use "ours" for conflicted field
+      expect(result.merged['doc1']).toEqual({ a: 200, b: 2 });
+    });
+
+    it('should handle nested object merges', () => {
+      store.create('doc1', { nested: { a: 1, b: 2 } });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { nested: { a: 10, b: 2 } });
+
+      store.switchBranch('main');
+      store.update('doc1', { nested: { a: 1, b: 20 } });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ nested: { a: 10, b: 20 } });
+    });
+
+    it('should handle no-op merge', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      // No changes on either branch
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it('should not apply merge when conflicts exist', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 200 });
+
+      store.merge('feature');
+      // Should still have the pre-merge value
+      expect(store.get('doc1')).toEqual({ a: 200 });
+    });
+
+    it('should handle adding new fields on one side', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, newField: 'hello' });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 1, newField: 'hello' });
+    });
+
+    it('should throw when merging non-existent branch', () => {
+      expect(() => store.merge('nonexistent')).toThrow();
+    });
+  });
+});
