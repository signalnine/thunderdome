 does not exist`);\n    }\n    return entry.versions.map((v) => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const docs = this.currentDocs();\n    const entry = docs.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    const version = entry.versions.find((v) => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n    }\n    return deepClone(version.content);\n  }\n\n  // --- Branching ---\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n\n    const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.branches.get(sourceName);\n    if (!source) {\n      throw new Error(`Branch \"${sourceName}\" does not exist`);\n    }\n\n    const snapshot = cloneDocumentsMap(source.documents);\n    const documents = cloneDocumentsMap(snapshot);\n\n    this.branches.set(name, {\n      documents,\n      parent: {\n        branch: sourceName,\n        snapshot,\n      },\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" does not exist`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // --- Merging ---\n\n  merge(sourceBranch: string): MergeResult {\n    const source = this.branches.get(sourceBranch);\n    if (!source) {\n      throw new Error(`Branch \"${sourceBranch}\" does not exist`);\n    }\n\n    const target = this.branches.get(this.currentBranch)!;\n\n    // Find the common ancestor (base) state\n    const base = this.findCommonAncestor(sourceBranch, this.currentBranch);\n\n    const sourceDocs = source.documents;\n    const targetDocs = target.documents;\n\n    // Collect all document IDs across base, source, and target\n    const allDocIds = new Set<string>();\n    for (const id of base.keys()) allDocIds.add(id);\n    for (const id of sourceDocs.keys()) allDocIds.add(id);\n    for (const id of targetDocs.keys()) allDocIds.add(id);\n\n    const merged: Record<string, object> = {};\n    const conflicts: Conflict[] = [];\n\n    for (const docId of allDocIds) {\n      const baseEntry = base.get(docId);\n      const sourceEntry = sourceDocs.get(docId);\n      const targetEntry = targetDocs.get(docId);\n\n      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : undefined;\n      const sourceContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : undefined;\n      const targetContent = targetEntry && !targetEntry.deleted ? targetEntry.content : undefined;\n\n      const sourceChanged = !this.contentsEqual(baseContent, sourceContent);\n      const targetChanged = !this.contentsEqual(baseContent, targetContent);\n\n      if (!sourceChanged && !targetChanged) {\n        // No changes on either side\n        if (targetContent !== undefined) {\n          merged[docId] = deepClone(targetContent);\n        }\n        continue;\n      }\n\n      if (sourceChanged && !targetChanged) {\n        // Only source changed\n        if (sourceContent !== undefined) {\n          merged[docId] = deepClone(sourceContent);\n        }\n        // If source deleted the doc, don't include in merged\n        continue;\n      }\n\n      if (!sourceChanged && targetChanged) {\n        // Only target changed\n        if (targetContent !== undefined) {\n          merged[docId] = deepClone(targetContent);\n        }\n        continue;\n      }\n\n      // Both changed\n      if (this.contentsEqual(sourceContent, targetContent)) {\n        // Both changed to the same thing\n        if (targetContent !== undefined) {\n          merged[d