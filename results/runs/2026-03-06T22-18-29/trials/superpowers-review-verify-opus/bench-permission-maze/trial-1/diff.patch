+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JcJB1hf8cQRf3jPN848k2n","type":"tool_result","content":"     1→import { Request, Response, NextFunction } from 'express';\n     2→import { Store } from './store.js';\n     3→import { User } from './types.js';\n     4→\n     5→export interface AuthenticatedRequest extends Request {\n     6→  user?: User;\n     7→}\n     8→\n     9→export function authMiddleware(store: Store) {\n    10→  return (req: AuthenticatedRequest, _res: Response, next: NextFunction): void => {\n    11→    const authHeader = req.headers.authorization;\n    12→    if (authHeader && authHeader.startsWith('Bearer ')) {\n    13→      const token = authHeader.slice(7);\n    14→      for (const user of store.users.values()) {\n    15→        if (user.token === token) {\n    16→          req.user = user;\n    17→          break;\n    18→        }\n    19→      }\n    20→    }\n    21→    next();\n    22→  };\n    23→}\n    24→\n    25→export function requireAuth(req: AuthenticatedRequest, res: Response, next: NextFunction): void {\n    26→  if (!req.user) {\n    27→    res.status(401).json({ error: 'Authentication required' });\n    28→    return;\n    29→  }\n    30→  next();\n    31→}\n    32→"}]},"parent_tool_use_id":"toolu_0158hvw9xtXLqpKc4qGFnLSF","session_id":"9cfe4609-ae8b-4666-82c5-b0be39bd6a82","uuid":"7f5cd2d9-76e4-4d4c-acde-e87f22286a36"}
