rent folder' });\n        return;\n      }\n    }\n\n    const id = generateId(store);\n    const folder = {\n      id,\n      name,\n      parentId: parentId || null,\n      ownerId: user.id,\n      createdAt: new Date().toISOString(),\n    };\n\n    store.folders.set(id, folder);\n\n    res.status(201).json(folder);\n  });\n\n  // Get folder\n  router.get('/:id', requireAuth, (req: AuthenticatedRequest, res) => {\n    const user = req.user!;\n    const folder = store.folders.get(req.params.id);\n\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    const role = getEffectiveRole(store, user.id, 'folder', folder.id);\n    if (!canRead(role)) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    // Get child folders and documents\n    const children: string[] = [];\n    for (const f of store.folders.values()) {\n      if (f.parentId === folder.id) {\n        children.push(f.id);\n      }\n    }\n\n    const documents: string[] = [];\n    for (const doc of store.documents.values()) {\n      if (doc.folderId === folder.id) {\n        documents.push(doc.id);\n      }\n    }\n\n    res.json({ ...folder, children, documents });\n  });\n\n  // Update folder\n  router.put('/:id', requireAuth, (req: AuthenticatedRequest, res) => {\n    const user = req.user!;\n    const folder = store.folders.get(req.params.id);\n\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    const role = getEffectiveRole(store, user.id, 'folder', folder.id);\n    if (!canEdit(role)) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const { name, parentId } = req.body;\n\n    if (name !== undefined) {\n      folder.name = name;\n    }\n\n    if (parentId !== undefined) {\n      // Prevent circular references\n      if (parentId === folder.id) {\n        res.status(400).json({ error: 'Folder cannot b