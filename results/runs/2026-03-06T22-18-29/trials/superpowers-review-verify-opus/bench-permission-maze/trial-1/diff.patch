+      expect(entry.action).toBeDefined();
+    });
+  });
+
+  // ==================== EDGE CASES ====================
+  describe('Edge Cases', () => {
+    it('should handle folder self-parenting', async () => {
+      const { token } = await registerAndLogin('alice', 'password123');
+
+      const folderRes = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Folder' });
+
+      const res = await request(app)
+        .put(`/folders/${folderRes.body.id}`)
+        .set('Authorization', `Bearer ${token}`)
+        .send({ parentId: folderRes.body.id });
+
+      expect(res.status).toBe(400);
+    });
+
+    it('should handle document with empty string content', async () => {
+      const { token } = await registerAndLogin('alice', 'password123');
+
+      const folderRes = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Folder' });
+
+      const res = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Empty Doc', content: '', folderId: folderRes.body.id });
+
+      expect(res.status).toBe(201);
+      expect(res.body.content).toBe('');
+    });
+
+    it('should get folder with children and documents listed', async () => {
+      const { token } = await registerAndLogin('alice', 'password123');
+
+      const folderRes = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Parent' });
+
+      const childRes = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Child', parentId: folderRes.body.id });
+
+      const docRes = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ title: 'Doc', content: 'text', folderId: folderRes.body.id });
+
+      const getRes = await request(app)
+        .get(`/folders/${folderRes.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(getRes.body.children).toContain(childRes.body.id);
+      expect(getRes.body.documents).toContain(docRes.body.id);
+    });
+
+    it('should allow owner shared user to delete resource', async () => {
+      const alice = await registerAndLogin('alice', 'password123');
+      const bob = await registerAndLogin('bob', 'password456');
+
+      const folderRes = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ name: 'Folder' });
+
+      // Share as owner with Bob
+      await request(app)
+        .post(`/folders/${folderRes.body.id}/share`)
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ userId: bob.userId, role: 'owner' });
+
+      // Bob can delete
+      const res = await request(app)
+        .delete(`/folders/${folderRes.body.id}`)
+        .set('Authorization', `Bearer ${bob.token}`);
+
+      expect(res.status).toBe(204);
+    });
+
+    it('should inherit permissions through deep folder hierarchy', async () => {
+      const alice = await registerAndLogin('alice', 'password123');
+      const bob = await registerAndLogin('bob', 'password456');
+
+      // Create folder hierarchy: root -> level1 -> level2
+      const rootRes = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ name: 'Root' });
+
+      const level1Res = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ name: 'Level 1', parentId: rootRes.body.id });
+
+      const level2Res = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ name: 'Level 2', parentId: level1Res.body.id });
+
+      // Share root with Bob as viewer
+      await request(app)
+        .post(`/folders/${rootRes.body.id}/share`)
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ userId: bob.userId, role: 'viewer' });
+
+      // Bob can read level2
+      const res = await request(app)
+        .get(`/folders/${level2Res.body.id}`)
+        .set('Authorization', `Bearer ${bob.token}`);
+
+      expect(res.status).toBe(200);
+
+      // Create doc in level2, Bob can read it too
+      const docRes = await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ title: 'Deep Doc', content: 'deep', folderId: level2Res.body.id });
+
+      const docGetRes = await request(app)
+        .get(`/documents/${docRes.body.id}`)
+        .set('Authorization', `Bearer ${bob.token}`);
+
+      expect(docGetRes.status).toBe(200);
+    });
+
+    it('should prevent deep circular folder hierarchy (A->B, move A under B)', async () => {
+      const { token } = await registerAndLogin('alice', 'password123');
+
+      // Create A -> B hierarchy
+      const folderA = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'A' });
+
+      const folderB = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'B', parentId: folderA.body.id });
+
+      // Try to move A under B (would create cycle)
+      const res = await request(app)
+        .put(`/folders/${folderA.body.id}`)
+        .set('Authorization', `Bearer ${token}`)
+        .send({ parentId: folderB.body.id });
+
+      expect(res.status).toBe(400);
+    });
+
+    it('should filter activity log to only accessible resources', async () => {
+      const alice = await registerAndLogin('alice', 'password123');
+      const bob = await registerAndLogin('bob', 'password456');
+
+      // Alice creates a folder and doc
+      const folderRes = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ name: 'Private Folder' });
+
+      await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ title: 'Private Doc', content: 'secret', folderId: folderRes.body.id });
+
+      // Bob creates his own folder
+      const bobFolder = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${bob.token}`)
+        .send({ name: 'Bob Folder' });
+
+      await request(app)
+        .post('/documents')
+        .set('Authorization', `Bearer ${bob.token}`)
+        .send({ title: 'Bob Doc', content: 'bob stuff', folderId: bobFolder.body.id });
+
+      // Bob should only see activity for his own resources
+      const bobActivity = await request(app)
+        .get('/activity')
+        .set('Authorization', `Bearer ${bob.token}`);
+
+      expect(bobActivity.status).toBe(200);
+      // Bob should not see Alice's folder or document activity
+      const aliceEntries = bobActivity.body.filter(
+        (e: { resourceId: string }) => e.resourceId === folderRes.body.id,
+      );
+      expect(aliceEntries.length).toBe(0);
+    });
+
+    it('should log folder creation, update, and deletion', async () => {
+      const { token } = await registerAndLogin('alice', 'password123');
+
+      const folderRes = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Logged Folder' });
+
+      await request(app)
+        .put(`/folders/${folderRes.body.id}`)
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Updated Logged Folder' });
+
+      await request(app)
+        .delete(`/folders/${folderRes.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      const activityRes = await request(app)
+        .get('/activity')
+        .set('Authorization', `Bearer ${token}`);
+
+      const actions = activityRes.body.map((e: { action: string }) => e.action);
+      expect(actions).toContain('folder_created');
+      expect(actions).toContain('folder_updated');
+      expect(actions).toContain('folder_deleted');
+    });
+  });
+});
