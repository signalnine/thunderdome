scribe('Authentication', () => {\n    it('should register a new user', async () => {\n      const res = await registerUser('alice', 'password123');\n      expect(res.status).toBe(201);\n      expect(res.body.username).toBe('alice');\n      expect(res.body.id).toBeDefined();\n    });\n\n    it('should reject duplicate usernames', async () => {\n      await registerUser('alice', 'password123');\n      const res = await registerUser('alice', 'password456');\n      expect(res.status).toBe(409);\n    });\n\n    it('should reject registration without username', async () => {\n      const res = await request(app)\n        .post('/auth/register')\n        .send({ password: 'password123' });\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject registration without password', async () => {\n      const res = await request(app)\n        .post('/auth/register')\n        .send({ username: 'alice' });\n      expect(res.status).toBe(400);\n    });\n\n    it('should login and return a token', async () => {\n      await registerUser('alice', 'password123');\n      const res = await loginUser('alice', 'password123');\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n      expect(res.body.userId).toBeDefined();\n    });\n\n    it('should reject login with wrong password', async () => {\n      await registerUser('alice', 'password123');\n      const res = await loginUser('alice', 'wrongpass');\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject login for non-existent user', async () => {\n      const res = await loginUser('nonexistent', 'password');\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject unauthenticated requests', async () => {\n      const res = await request(app).get('/folders/1');\n      expect(res.status).toBe(401);\n    });\n  });\n\n  // ==================== FOLDER TESTS ====================\n  describe('Folders', () => {\n    let aliceToken: string;\n\n    beforeEach(async () => {\n      const { token } = await registerAndLogin('alice', 'password123');\n      aliceToken = token;\n    });\n\n    it('should create a folder', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'My Folder' });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe('My Folder');\n      expect(res.body.parentId).toBeNull();\n    });\n\n    it('should create a nested folder', async () => {\n      const parentRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Parent' });\n\n      const childRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Child', parentId: parentRes.body.id });\n\n      expect(childRes.status).toBe(201);\n      expect(childRes.body.parentId).toBe(parentRes.body.id);\n    });\n\n    it('should reject folder creation without name', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({});\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject folder creation in non-existent parent', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Orphan', parentId: '9999' });\n      expect(res.status).toBe(404);\n    });\n\n    it('should get a folder', async () => {\n      const createRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Test Folder' });\n\n      const res = await request(app)\n        .get(`/folders/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Test Folder');\n      expect(res.body.children).toBeDefined();\n      expect(res.body.documents).toBeDefined();\n    });\n\n    it('should return 404 for non-existent folder', async () => {\n      const res = await request(app)\n        .get('/folders/9999')\n        .set('Authorization', `Bearer ${aliceToken}`);\n      expect(res.status).toBe(404);\n    });\n\n    it('should update a folder', async () => {\n      const createRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Original' });\n\n      const res = await request(app)\n        .put(`/folders/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Updated' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Updated');\n    });\n\n    it('should delete a folder', async () => {\n      const createRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'To Delete' });\n\n      const res = await request(app)\n        .delete(`/folders/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      expect(res.status).toBe(204);\n\n      // Verify it's gone\n      const getRes = await request(app)\n        .get(`/folders/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n      expect(getRes.status).toBe(404);\n    });\n\n    it('should delete a folder with children and documents', async () => {\n      const parentRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Parent' });\n\n      const childRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Child', parentId: parentRes.body.id });\n\n      await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'text', folderId: parentRes.body.id });\n\n      // Delete parent\n      const res = await request(app)\n        .delete(`/folders/${parentRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      expect(res.status).toBe(204);\n\n      // Child should also be gone\n      const childGet = await request(app)\n        .get(`/folders/${childRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n      expect(childGet.status).toBe(404);\n    });\n  });\n\n  // ==================== DOCUMENT TESTS ====================\n  describe('Documents', () => {\n    let aliceToken: string;\n    let folderId: string;\n\n    beforeEach(async () => {\n      const { token } = await registerAndLogin('alice', 'password123');\n      aliceToken = token;\n\n      const folderRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Docs Folder' });\n      folderId = folderRes.body.id;\n    });\n\n    it('should create a document', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Test Doc', content: 'Hello world', folderId });\n      expect(res.status).toBe(201);\n      expect(res.body.title).toBe('Test Doc');\n      expect(res.body.content).toBe('Hello world');\n      expect(res.body.folderId).toBe(folderId);\n    });\n\n    it('should reject document creation without required fields', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'No Content' });\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject document creation in non-existent folder', async () => {\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Test', content: 'text', folderId: '9999' });\n      expect(res.status).toBe(404);\n    });\n\n    it('should get a document', async () => {\n      const createRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Test Doc', content: 'Content', folderId });\n\n      const res = await request(app)\n        .get(`/documents/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.title).toBe('Test Doc');\n    });\n\n    it('should update a document', async () => {\n      const createRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Original', content: 'Original content', folderId });\n\n      const res = await request(app)\n        .put(`/documents/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Updated', content: 'Updated content' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.title).toBe('Updated');\n      expect(res.body.content).toBe('Updated content');\n    });\n\n    it('should delete a document', async () => {\n      const createRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'To Delete', content: 'text', folderId });\n\n      const res = await request(app)\n        .delete(`/documents/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      expect(res.status).toBe(204);\n\n      const getRes = await request(app)\n        .get(`/documents/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n      expect(getRes.status).toBe(404);\n    });\n  });\n\n  // ==================== SHARING & PERMISSIONS TESTS ====================\n  describe('Sharing & Permissions', () => {\n    let aliceToken: string;\n    let aliceId: string;\n    let bobToken: string;\n    let bobId: string;\n    let folderId: string;\n\n    beforeEach(async () => {\n      const alice = await registerAndLogin('alice', 'password123');\n      aliceToken = alice.token;\n      aliceId = alice.userId;\n\n      const bob = await registerAndLogin('bob', 'password456');\n      bobToken = bob.token;\n      bobId = bob.userId;\n\n      const folderRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared Folder' });\n      folderId = folderRes.body.id;\n    });\n\n    it('should share a folder with another user as viewer', async () => {\n      const res = await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      expect(res.status).toBe(201);\n      expect(res.body.role).toBe('viewer');\n    });\n\n    it('should allow viewer to read a shared folder', async () => {\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      const res = await request(app)\n        .get(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(200);\n    });\n\n    it('should deny viewer from editing a shared folder', async () => {\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      const res = await request(app)\n        .put(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Hacked' });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should deny viewer from deleting a shared folder', async () => {\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      const res = await request(app)\n        .delete(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should allow editor to edit a shared folder', async () => {\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'editor' });\n\n      const res = await request(app)\n        .put(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Edited by Bob' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Edited by Bob');\n    });\n\n    it('should deny editor from deleting a shared folder', async () => {\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'editor' });\n\n      const res = await request(app)\n        .delete(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should deny access to unshared resources', async () => {\n      const res = await request(app)\n        .get(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should share a document with another user', async () => {\n      const docRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Shared Doc', content: 'content', folderId });\n\n      const shareRes = await request(app)\n        .post(`/documents/${docRes.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      expect(shareRes.status).toBe(201);\n\n      // Bob can read the document\n      const getRes = await request(app)\n        .get(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(getRes.status).toBe(200);\n    });\n\n    it('should deny viewer from editing shared document', async () => {\n      const docRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'content', folderId });\n\n      await request(app)\n        .post(`/documents/${docRes.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      const res = await request(app)\n        .put(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ title: 'Hacked' });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should allow editor to edit shared document', async () => {\n      const docRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'content', folderId });\n\n      await request(app)\n        .post(`/documents/${docRes.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'editor' });\n\n      const res = await request(app)\n        .put(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ title: 'Edited by Bob' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.title).toBe('Edited by Bob');\n    });\n\n    it('should allow editor to share with others', async () => {\n      const { token: charlieToken, userId: charlieId } = await registerAndLogin('charlie', 'pass');\n\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'editor' });\n\n      // Bob (editor) shares with Charlie\n      const res = await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ userId: charlieId, role: 'viewer' });\n\n      expect(res.status).toBe(201);\n\n      // Charlie can now read\n      const getRes = await request(app)\n        .get(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${charlieToken}`);\n      expect(getRes.status).toBe(200);\n    });\n\n    it('should inherit permissions from folder to document', async () => {\n      // Share folder with Bob as viewer\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      // Alice creates a document in the folder\n      const docRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc in Shared Folder', content: 'content', folderId });\n\n      // Bob can read the document through folder permission\n      const getRes = await request(app)\n        .get(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(getRes.status).toBe(200);\n    });\n\n    it('should inherit permissions from parent folder to subfolder', async () => {\n      // Share parent folder with Bob as viewer\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      // Alice creates a subfolder\n      const subRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Subfolder', parentId: folderId });\n\n      // Bob can read the subfolder through parent folder permission\n      const getRes = await request(app)\n        .get(`/folders/${subRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(getRes.status).toBe(200);\n    });\n\n    it('should use most permissive role when user has multiple access paths', async () => {\n      // Share folder with Bob as viewer\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      // Alice creates a document\n      const docRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'content', folderId });\n\n      // Also share the document directly with Bob as editor\n      await request(app)\n        .post(`/documents/${docRes.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'editor' });\n\n      // Bob should have editor access (most permissive)\n      const editRes = await request(app)\n        .put(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ title: 'Edited' });\n\n      expect(editRes.status).toBe(200);\n    });\n\n    it('should reject sharing with invalid role', async () => {\n      const res = await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'admin' });\n\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject sharing with non-existent user', async () => {\n      const res = await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: '9999', role: 'viewer' });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('should reject viewer from sharing', async () => {\n      const { userId: charlieId } = await registerAndLogin('charlie', 'pass');\n\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      // Bob (viewer) tries to share with Charlie\n      const res = await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ userId: charlieId, role: 'viewer' });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should only allow owners to grant owner role', async () => {\n      const { userId: charlieId } = await registerAndLogin('charlie', 'pass');\n\n      // Share folder with Bob as editor\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'editor' });\n\n      // Bob (editor) tries to grant owner to Charlie\n      const res = await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ userId: charlieId, role: 'owner' });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should update existing share role', async () => {\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      // Upgrade to editor\n      const res = await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'editor' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe('editor');\n\n      // Bob can now edit\n      const editRes = await request(app)\n        .put(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Edited' });\n      expect(editRes.status).toBe(200);\n    });\n  });\n\n  // ==================== ACTIVITY LOG TESTS ====================\n  describe('Activity Log', () => {\n    let aliceToken: string;\n    let bobId: string;\n    let folderId: string;\n\n    beforeEach(async () => {\n      const alice = await registerAndLogin('alice', 'password123');\n      aliceToken = alice.token;\n\n      const bob = await registerAndLogin('bob', 'password456');\n      bobId = bob.userId;\n\n      const folderRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Log Folder' });\n      folderId = folderRes.body.id;\n    });\n\n    it('should log document creation', async () => {\n      await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Test', content: 'text', folderId });\n\n      const res = await request(app)\n        .get('/activity')\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.length).toBeGreaterThan(0);\n      const createEntry = res.body.find(\n        (e: { action: string }) => e.action === 'document_created',\n      );\n      expect(createEntry).toBeDefined();\n      expect(createEntry.timestamp).toBeDefined();\n    });\n\n    it('should log document updates', async () => {\n      const docRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Test', content: 'text', folderId });\n\n      await request(app)\n        .put(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Updated' });\n\n      const res = await request(app)\n        .get('/activity')\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      const updateEntry = res.body.find(\n        (e: { action: string }) => e.action === 'document_updated',\n      );\n      expect(updateEntry).toBeDefined();\n    });\n\n    it('should log document deletion', async () => {\n      const docRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Test', content: 'text', folderId });\n\n      await request(app)\n        .delete(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      const res = await request(app)\n        .get('/activity')\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      const deleteEntry = res.body.find(\n        (e: { action: string }) => e.action === 'document_deleted',\n      );\n      expect(deleteEntry).toBeDefined();\n    });\n\n    it('should log sharing events', async () => {\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      const res = await request(app)\n        .get('/activity')\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      const shareEntry = res.body.find(\n        (e: { action: string }) => e.action === 'share_created',\n      );\n      expect(shareEntry).toBeDefined();\n    });\n\n    it('should include user, resource, and timestamp in log entries', async () => {\n      const docRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Test', content: 'text', folderId });\n\n      const res = await request(app)\n        .get('/activity')\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      const entry = res.body[0];\n      expect(entry.userId).toBeDefined();\n      expect(entry.resourceType).toBeDefined();\n      expect(entry.resourceId).toBe(docRes.body.id);\n      expect(entry.timestamp).toBeDefined();\n      expect(entry.action).toBeDefined();\n    });\n  });\n\n  // ==================== EDGE CASES ====================\n  describe('Edge Cases', () => {\n    it('should handle folder self-parenting', async () => {\n      const { token } = await registerAndLogin('alice', 'password123');\n\n      const folderRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Folder' });\n\n      const res = await request(app)\n        .put(`/folders/${folderRes.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ parentId: folderRes.body.id });\n\n      expect(res.status).toBe(400);\n    });\n\n    it('should handle document with empty string content', async () => {\n      const { token } = await registerAndLogin('alice', 'password123');\n\n      const folderRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Folder' });\n\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Empty Doc', content: '', folderId: folderRes.body.id });\n\n      expect(res.status).toBe(201);\n      expect(res.body.content).toBe('');\n    });\n\n    it('should get folder with children and documents listed', async () => {\n      const { token } = await registerAndLogin('alice', 'password123');\n\n      const folderRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Parent' });\n\n      const childRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: folderRes.body.id });\n\n      const docRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'text', folderId: folderRes.body.id });\n\n      const getRes = await request(app)\n        .get(`/folders/${folderRes.body.id}`)\n        .set('Authorization', `Bearer ${token}`);\n\n      expect(getRes.body.children).toContain(childRes.body.id);\n      expect(getRes.body.documents).toContain(docRes.body.id);\n    });\n\n    it('should allow owner shared user to delete resource', async () => {\n      const alice = await registerAndLogin('alice', 'password123');\n      const bob = await registerAndLogin('bob', 'password456');\n\n      const folderRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'Folder' });\n\n      // Share as owner with Bob\n      await request(app)\n        .post(`/folders/${folderRes.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'owner' });\n\n      // Bob can delete\n      const res = await request(app)\n        .delete(`/folders/${folderRes.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`);\n\n      expect(res.status).toBe(204);\n    });\n\n    it('should inherit permissions through deep folder hierarchy', async () => {\n      const alice = await registerAndLogin('alice', 'password123');\n      const bob = await registerAndLogin('bob', 'password456');\n\n      // Create folder hierarchy: root -> level1 -> level2\n      const rootRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'Root' });\n\n      const level1Res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'Level 1', parentId: rootRes.body.id });\n\n      const level2Res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ name: 'Level 2', parentId: level1Res.body.id });\n\n      // Share root with Bob as viewer\n      await request(app)\n        .post(`/folders/${rootRes.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n\n      // Bob can read level2\n      const res = await request(app)\n        .get(`/folders/${level2Res.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`);\n\n      expect(res.status).toBe(200);\n\n      // Create doc in level2, Bob can read it too\n      const docRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ title: 'Deep Doc', content: 'deep', folderId: level2Res.body.id });\n\n      const docGetRes = await request(app)\n        .get(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`);\n\n      expect(docGetRes.status).toBe(200);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":318,"oldLines":7,"newStart":318,"newLines":6,"lines":["   // ==================== SHARING & PERMISSIONS TESTS ====================","   describe('Sharing & Permissions', () => {","     let aliceToken: string;","-    let aliceId: string;","     let bobToken: string;","     let bobId: string;","     let folderId: string;"]},{"oldStart":326,"oldLines":7,"newStart":325,"newLines":6,"lines":["     beforeEach(async () => {","       const alice = await registerAndLogin('alice', 'password123');","       aliceToken = alice.token;","-      aliceId = alice.userId;"," ","       const bob = await registerAndLogin('bob', 'password456');","       bobToken = bob.token;"]}],"userModified":false,"replaceAll":false}}
