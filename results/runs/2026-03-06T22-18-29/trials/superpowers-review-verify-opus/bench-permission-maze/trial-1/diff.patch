@@ -0,0 +1,25 @@
+import { Router } from 'express';
+import { Store } from '../store.js';
+import { AuthenticatedRequest, requireAuth } from '../middleware.js';
+import { getEffectiveRole, canRead } from '../permissions.js';
+
+export function activityRoutes(store: Store): Router {
+  const router = Router();
+
+  // Get activity log - filtered to resources the user can access
+  router.get('/', requireAuth, (req: AuthenticatedRequest, res) => {
+    const user = req.user!;
+
+    const filtered = store.activityLog.filter((entry) => {
+      // Show entries for actions the user performed
+      if (entry.userId === user.id) return true;
+      // Show entries for resources the user can access
+      const role = getEffectiveRole(store, user.id, entry.resourceType, entry.resourceId);
+      return canRead(role);
+    });
+
+    res.json(filtered);
+  });
+
+  return router;
+}
