+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VaykPYGyQ4SzS9u9F6XeXa","type":"tool_result","content":"     1→import { Role } from './types.js';\n     2→import { Store } from './store.js';\n     3→\n     4→const ROLE_LEVEL: Record<Role, number> = {\n     5→  viewer: 1,\n     6→  editor: 2,\n     7→  owner: 3,\n     8→};\n     9→\n    10→export function higherRole(a: Role, b: Role): Role {\n    11→  return ROLE_LEVEL[a] >= ROLE_LEVEL[b] ? a : b;\n    12→}\n    13→\n    14→export function getEffectiveRole(\n    15→  store: Store,\n    16→  userId: string,\n    17→  resourceType: 'folder' | 'document',\n    18→  resourceId: string,\n    19→): Role | null {\n    20→  // Check if user is the owner of the resource\n    21→  if (resourceType === 'folder') {\n    22→    const folder = store.folders.get(resourceId);\n    23→    if (folder && folder.ownerId === userId) return 'owner';\n    24→  } else {\n    25→    const doc = store.documents.get(resourceId);\n    26→    if (doc && doc.ownerId === userId) return 'owner';\n    27→  }\n    28→\n    29→  let bestRole: Role | null = null;\n    30→\n    31→  // Check direct shares on this resource\n    32→  for (const share of store.shares) {\n    33→    if (\n    34→      share.resourceType === resourceType &&\n    35→      share.resourceId === resourceId &&\n    36→      share.userId === userId\n    37→    ) {\n    38→      bestRole = bestRole ? higherRole(bestRole, share.role) : share.role;\n    39→    }\n    40→  }\n    41→\n    42→  // If resource is a document, also check shares on its folder hierarchy\n    43→  if (resourceType === 'document') {\n    44→    const doc = store.documents.get(resourceId);\n    45→    if (doc) {\n    46→      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);\n    47→      if (folderRole) {\n    48→        bestRole = bestRole ? higherRole(bestRole, folderRole) : folderRole;\n    49→      }\n    50→    }\n    51→  }\n    52→\n    53→  // If resource is a folder, also check shares on parent folder hierarchy\n    54→  if (resourceType === 'folder') {\n    55→    const folder = store.folders.get(resourceId);\n    56→    if (folder && folder.parentId) {\n    57→      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);\n    58→      if (parentRole) {\n    59→        bestRole = bestRole ? higherRole(bestRole, parentRole) : parentRole;\n    60→      }\n    61→    }\n    62→  }\n    63→\n    64→  return bestRole;\n    65→}\n    66→\n    67→export function canRead(role: Role | null): boolean {\n    68→  return role !== null;\n    69→}\n    70→\n    71→export function canEdit(role: Role | null): boolean {\n    72→  return role === 'editor' || role === 'owner';\n    73→}\n    74→\n    75→export function canDelete(role: Role | null): boolean {\n    76→  return role === 'owner';\n    77→}\n    78→\n    79→export function canShare(role: Role | null): boolean {\n    80→  return role === 'editor' || role === 'owner';\n    81→}\n    82→"}]},"parent_tool_use_id":"toolu_0158hvw9xtXLqpKc4qGFnLSF","session_id":"9cfe4609-ae8b-4666-82c5-b0be39bd6a82","uuid":"34036079-682b-49ee-b935-0b07b5195468"}
