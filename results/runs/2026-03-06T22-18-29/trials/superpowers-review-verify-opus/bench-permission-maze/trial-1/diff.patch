 childRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Child', parentId: parentRes.body.id });\n\n      expect(childRes.status).toBe(201);\n      expect(childRes.body.parentId).toBe(parentRes.body.id);\n    });\n\n    it('should reject folder creation without name', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({});\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject folder creation in non-existent parent', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Orphan', parentId: '9999' });\n      expect(res.status).toBe(404);\n    });\n\n    it('should get a folder', async () => {\n      const createRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Test Folder' });\n\n      const res = await request(app)\n        .get(`/folders/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Test Folder');\n      expect(res.body.children).toBeDefined();\n      expect(res.body.documents).toBeDefined();\n    });\n\n    it('should return 404 for non-existent folder', async () => {\n      const res = await request(app)\n        .get('/folders/9999')\n        .set('Authorization', `Bearer ${aliceToken}`);\n      expect(res.status).toBe(404);\n    });\n\n    it('should update a folder', async () => {\n      const createRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Original' });\n\n      const res = await request(app)\n        .put(`/folders/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n  