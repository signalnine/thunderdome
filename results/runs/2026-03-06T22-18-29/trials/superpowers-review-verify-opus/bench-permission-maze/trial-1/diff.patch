@@ -0,0 +1,81 @@
+import { Role } from './types.js';
+import { Store } from './store.js';
+
+const ROLE_LEVEL: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function higherRole(a: Role, b: Role): Role {
+  return ROLE_LEVEL[a] >= ROLE_LEVEL[b] ? a : b;
+}
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+): Role | null {
+  // Check if user is the owner of the resource
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.ownerId === userId) return 'owner';
+  } else {
+    const doc = store.documents.get(resourceId);
+    if (doc && doc.ownerId === userId) return 'owner';
+  }
+
+  let bestRole: Role | null = null;
+
+  // Check direct shares on this resource
+  for (const share of store.shares) {
+    if (
+      share.resourceType === resourceType &&
+      share.resourceId === resourceId &&
+      share.userId === userId
+    ) {
+      bestRole = bestRole ? higherRole(bestRole, share.role) : share.role;
+    }
+  }
+
+  // If resource is a document, also check shares on its folder hierarchy
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);
+      if (folderRole) {
+        bestRole = bestRole ? higherRole(bestRole, folderRole) : folderRole;
+      }
+    }
+  }
+
+  // If resource is a folder, also check shares on parent folder hierarchy
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);
+      if (parentRole) {
+        bestRole = bestRole ? higherRole(bestRole, parentRole) : parentRole;
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+export function canRead(role: Role | null): boolean {
+  return role !== null;
+}
+
+export function canEdit(role: Role | null): boolean {
+  return role === 'editor' || role === 'owner';
+}
+
+export function canDelete(role: Role | null): boolean {
+  return role === 'owner';
+}
+
+export function canShare(role: Role | null): boolean {
+  return role === 'editor' || role === 'owner';
+}
