pp)\n        .post(`/documents/${docRes.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'editor' });\n\n      // Bob should have editor access (most permissive)\n      const editRes = await request(app)\n        .put(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ title: 'Edited' });\n\n      expect(editRes.status).toBe(200);\n    });\n\n    it('should reject sharing with invalid role', async () => {\n      const res = await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'admin' });\n\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject sharing with non-existent user', async () => {\n      const res = await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: '9999', role: 'viewer' });\n\n      expect(res.status).toBe(404);\n    });\n\n    it('should reject viewer from sharing', async () => {\n      const { userId: charlieId } = await registerAndLogin('charlie', 'pass');\n\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      // Bob (viewer) tries to share with Charlie\n      const res = await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ userId: charlieId, role: 'viewer' });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should only allow owners to grant owner role', async () => {\n      const { userId: charlieId } = await registerAndLogin('charlie', 'pass');\n\n      // Share folder with Bob as editor\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\