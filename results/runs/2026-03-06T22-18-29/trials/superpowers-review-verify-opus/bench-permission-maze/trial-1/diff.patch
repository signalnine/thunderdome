ync () => {\n      const res = await request(app)\n        .post('/auth/register')\n        .send({ password: 'password123' });\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject registration without password', async () => {\n      const res = await request(app)\n        .post('/auth/register')\n        .send({ username: 'alice' });\n      expect(res.status).toBe(400);\n    });\n\n    it('should login and return a token', async () => {\n      await registerUser('alice', 'password123');\n      const res = await loginUser('alice', 'password123');\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n      expect(res.body.userId).toBeDefined();\n    });\n\n    it('should reject login with wrong password', async () => {\n      await registerUser('alice', 'password123');\n      const res = await loginUser('alice', 'wrongpass');\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject login for non-existent user', async () => {\n      const res = await loginUser('nonexistent', 'password');\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject unauthenticated requests', async () => {\n      const res = await request(app).get('/folders/1');\n      expect(res.status).toBe(401);\n    });\n  });\n\n  // ==================== FOLDER TESTS ====================\n  describe('Folders', () => {\n    let aliceToken: string;\n\n    beforeEach(async () => {\n      const { token } = await registerAndLogin('alice', 'password123');\n      aliceToken = token;\n    });\n\n    it('should create a folder', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'My Folder' });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe('My Folder');\n      expect(res.body.parentId).toBeNull();\n    });\n\n    it('should create a nested folder', async () => {\n      const parentRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Parent' });\n\n      const childRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Child', parentId: parentRes.body.id });\n\n      expect(childRes.status).toBe(201);\n      expect(childRes.body.parentId).toBe(parentRes.body.id);\n    });\n\n    it('should reject folder creation without name', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({});\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject folder creation in non-existent parent', async () => {\n      const res = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Orphan', parentId: '9999' });\n      expect(res.status).toBe(404);\n    });\n\n    it('should get a folder', async () => {\n      const createRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Test Folder' });\n\n      const res = await request(app)\n        .get(`/folders/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Test Folder');\n      expect(res.body.children).toBeDefined();\n      expect(res.body.documents).toBeDefined();\n    });\n\n    it('should return 404 for non-existent folder', async () => {\n      const res = await request(app)\n        .get('/folders/9999')\n        .set('Authorization', `Bearer ${aliceToken}`);\n      expect(res.status).toBe(404);\n    });\n\n    it('should update a folder', async () => {\n      const createRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Original' });\n\n      const res = await request(app)\n        .put(`/folders/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Updated' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Updated');\n    });\n\n    it('should delete a folder', async () => {\n      const createRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'To Delete' });\n\n      const res = await request(app)\n        .delete(`/folders/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      expect(res.status).toBe(204);\n\n      // Verify it's gone\n      const getRes = await request(app)\n        .get(`/folders/${createRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n      expect(getRes.status).toBe(404);\n    });\n\n    it('should delete a folder with children and documents', async () => {\n      const parentRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Parent' });\n\n      const childRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Child', parentId: parentRes.body.id });\n\n      await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'text', folderId: parentRes.body.id });\n\n      // Delete parent\n      const res = await request(app)\n        .delete(`/folders/${parentRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n\n      expect(res.status).toBe(204);\n\n      // Child should also be gone\n      const childGet = await request(app)\n        .get(`/folders/${childRes.body.id}`)\n        .set('Authorization', `Bearer ${aliceToken}`);\n      expect(childGet.status).toBe(404);\n    });\n  });\n\n  // ==================== DOCUMENT TESTS ====