erAndLogin('charlie', 'pass');\n\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'editor' });\n\n      // Bob (editor) shares with Charlie\n      const res = await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ userId: charlieId, role: 'viewer' });\n\n      expect(res.status).toBe(201);\n\n      // Charlie can now read\n      const getRes = await request(app)\n        .get(`/folders/${folderId}`)\n        .set('Authorization', `Bearer ${charlieToken}`);\n      expect(getRes.status).toBe(200);\n    });\n\n    it('should inherit permissions from folder to document', async () => {\n      // Share folder with Bob as viewer\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      // Alice creates a document in the folder\n      const docRes = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc in Shared Folder', content: 'content', folderId });\n\n      // Bob can read the document through folder permission\n      const getRes = await request(app)\n        .get(`/documents/${docRes.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(getRes.status).toBe(200);\n    });\n\n    it('should inherit permissions from parent folder to subfolder', async () => {\n      // Share parent folder with Bob as viewer\n      await request(app)\n        .post(`/folders/${folderId}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ userId: bobId, role: 'viewer' });\n\n      // Alice creates a subfolder\n      const subRes = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .sen