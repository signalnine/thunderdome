details: `Created document \"${title}\"`,\n    53→      timestamp: now,\n    54→    });\n    55→\n    56→    res.status(201).json(doc);\n    57→  });\n    58→\n    59→  // Get document\n    60→  router.get('/:id', requireAuth, (req: AuthenticatedRequest, res) => {\n    61→    const user = req.user!;\n    62→    const doc = store.documents.get(req.params.id);\n    63→\n    64→    if (!doc) {\n    65→      res.status(404).json({ error: 'Document not found' });\n    66→      return;\n    67→    }\n    68→\n    69→    const role = getEffectiveRole(store, user.id, 'document', doc.id);\n    70→    if (!canRead(role)) {\n    71→      res.status(403).json({ error: 'Insufficient permissions' });\n    72→      return;\n    73→    }\n    74→\n    75→    res.json(doc);\n    76→  });\n    77→\n    78→  // Update document\n    79→  router.put('/:id', requireAuth, (req: AuthenticatedRequest, res) => {\n    80→    const user = req.user!;\n    81→    const doc = store.documents.get(req.params.id);\n    82→\n    83→    if (!doc) {\n    84→      res.status(404).json({ error: 'Document not found' });\n    85→      return;\n    86→    }\n    87→\n    88→    const role = getEffectiveRole(store, user.id, 'document', doc.id);\n    89→    if (!canEdit(role)) {\n    90→      res.status(403).json({ error: 'Insufficient permissions' });\n    91→      return;\n    92→    }\n    93→\n    94→    const { title, content } = req.body;\n    95→    const now = new Date().toISOString();\n    96→\n    97→    if (title !== undefined) {\n    98→      doc.title = title;\n    99→    }\n   100→    if (content !== undefined) {\n   101→      doc.content = content;\n   102→    }\n   103→    doc.updatedAt = now;\n   104→\n   105→    // Log activity\n   106→    store.activityLog.push({\n   107→      id: String(store.nextId++),\n   108→      action: 'document_updated',\n   109→      userId: user.id,\n   110→      resourceType: 'document',\n   111→      resourceId: doc.id,\n   112→      details: `Updated document \"${doc.title}\"`,\n   113→      timestamp: now,\n   114→    });\n   115→\n   116→    res.json(doc);\n   117→  });\n   118→\n   119→  // Delete document\n   120→  router.delete('/:id', requireAuth, (req: AuthenticatedRequest, res) => {\n   121→    const user = req.user!;\n   122→    const doc = store.documents.get(req.params.id);\n   123→\n   124→    if (!doc) {\n   125→      res.status(404).json({ error: 'Document not found' });\n   126→      return;\n   127→    }\n   128→\n   129→    const role = getEffectiveRole(store, user.id, 'document', doc.id);\n   130→    if (!canDelete(role)) {\n   131→      res.status(403).json({ error: 'Insufficient permissions' });\n   132→      return;\n   133→    }\n   134→\n   135→    const now = new Date().toISOString();\n   136→\n   137→    // Log activity\n   138→    store.activityLog.push({\n   139→      id: String(store.nextId++),\n   140→      action: 'document_deleted',\n   141→      userId: user.id,\n   142→      resourceType: 'document',\n   143→      resourceId: doc.id,\n   144→      details: `Deleted document \"${doc.title}\"`,\n   145→      timestamp: now,\n   146→    });\n   147→\n   148→    // Remove shares for this document\n   149→    store.shares = store.shares.filter(\n   150→      (s) => !(s.resourceType === 'document' && s.resourceId === doc.id),\n   151→    );\n   152→\n   153→    store.documents.delete(doc.id);\n   154→    res.status(204).send();\n   155→  });\n   156→\n   157→  // Share document\n   158→  router.post('/:id/share', requireAuth, (req: AuthenticatedRequest, res) => {\n   159→    const user = req.user!;\n   160→    const doc = store.documents.get(req.params.id);\n   161→\n   162→    if (!doc) {\n   163→      res.status(404).json({ error: 'Document not found' });\n   164→      return;\n   165→    }\n   166→\n   167→    const role = getEffectiveRole(store, user.id, 'document', doc.id);\n   168→    if (!canEdit(role) && role !== 'owner') {\n   169→      res.status(403).json({ error: 'Insufficient permissions to share' });\n   170→      return;\n   171→    }\n   172→\n   173→    const { userId, role: shareRole } = req.body;\n   174→\n   175→    if (!userId || !shareRole) {\n   176→      res.status(400).json({ error: 'userId and role are required' });\n   177→      return;\n   178→    }\n   179→\n   180→    if (!['viewer', 'editor', 'owner'].includes(shareRole)) {\n   181→      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });\n   182→      return;\n   183→    }\n   184→\n   185→    // Only owners can grant owner role\n   186→    if (shareRole === 'owner' && role !== 'owner') {\n   187→      res.status(403).json({ error: 'Only owners can grant owner role' });\n   188→      return;\n   189→    }\n   190→\n   191→    const targetUser = store.users.get(userId);\n   192→    if (!targetUser) {\n   193→      res.status(404).json({ error: 'User not found' });\n   194→      return;\n   195→    }\n   196→\n   197→    // Check for existing share and update it\n   198→    const existingShare = store.shares.find(\n   199→      (s) => s.resourceType === 'document' && s.resourceId === doc.id && s.userId === userId,\n   200→    );\n   201→\n   202→    if (existingShare) {\n   203→      existingShare.role = shareRole;\n   204→      store.activityLog.push({\n   205→        id: String(store.nextId++),\n   206→        action: 'share_updated',\n   207→        userId: user.id,\n   208→        resourceType: 'document',\n   209→        resourceId: doc.id,\n   210→        details: `Updated share for user ${userId} to role ${shareRole}`,\n   211→        timestamp: new Date().toISOString(),\n   212→      });\n   213→      res.json(existingShare);\n   214→      return;\n   215→    }\n   216→\n   217→    const share = {\n   218→      id: String(store.nextId++),\n   219→      resourceType: 'document' as const,\n   220→      resourceId: doc.id,\n   221→      userId,\n   222→      role: shareRole,\n   223→      sharedBy: user.id,\n   224→      createdAt: new Date(