te().toISOString();\n    const doc = {\n      id,\n      title,\n      content,\n      folderId,\n      ownerId: user.id,\n      createdAt: now,\n      updatedAt: now,\n    };\n\n    store.documents.set(id, doc);\n\n    // Log activity\n    store.activityLog.push({\n      id: generateId(store),\n      action: 'document_created',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: id,\n      details: `Created document \"${title}\"`,\n      timestamp: now,\n    });\n\n    res.status(201).json(doc);\n  });\n\n  // Get document\n  router.get('/:id', requireAuth, (req: AuthenticatedRequest, res) => {\n    const user = req.user!;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    const role = getEffectiveRole(store, user.id, 'document', doc.id);\n    if (!canRead(role)) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    res.json(doc);\n  });\n\n  // Update document\n  router.put('/:id', requireAuth, (req: AuthenticatedRequest, res) => {\n    const user = req.user!;\n    const doc = store.documents.get(req.params.id);\n\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    const role = getEffectiveRole(store, user.id, 'document', doc.id);\n    if (!canEdit(role)) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    const { title, content } = req.body;\n    const now = new Date().toISOString();\n\n    if (title !== undefined) {\n      doc.title = title;\n    }\n    if (content !== undefined) {\n      doc.content = content;\n    }\n    doc.updatedAt = now;\n\n    // Log activity\n    store.activityLog.push({\n      id: generateId(store),\n      action: 'document_updated',\n      userId: user.id,\n      resourceType: 'document',\n      resourceId: doc.id,\n      details: `Updated document \"${doc.