+import { Router } from 'express';
+import { Store, generateId } from '../store.js';
+import crypto from 'crypto';
+
+export function authRoutes(store: Store): Router {
+  const router = Router();
+
+  // Register
+  router.post('/register', (req, res) => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    // Check if username already exists
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        res.status(409).json({ error: 'Username already exists' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const user = { id, username, password };
+    store.users.set(id, user);
+
+    res.status(201).json({ id, username });
+  });
+
+  // Login
+  router.post('/login', (req, res) => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    for (const user of store.users.values()) {
+      if (user.username === username && user.password === password) {
+        const token = crypto.randomBytes(32).toString('hex');
+        user.token = token;
+        res.json({ token, userId: user.id });
+        return;
+      }
+    }
+
+    res.status(401).json({ error: 'Invalid credentials' });
+  });
+
+  return router;
+}
diff --git a/src/routes/documents.ts b/src/routes/documents.ts
new file mode 100644
index 0000000..9b09f5f
--- /dev/null
+++ b/src/routes/documents.ts
@@ -0,0 +1,244 @@
+import { Router } from 'express';
+import { Store, generateId } from '../store.js';
+import { AuthenticatedRequest, requireAuth } from '../middleware.js';
+import { getEffectiveRole, canRead, canEdit, canDelete, canShare } from '../permissions.js';
+
+export function documentRoutes(store: Store): Router {
+  const router = Router();
+
+  // Create document
+  router.post('/', requireAuth, (req: AuthenticatedRequest, res) => {
+    const user = req.user!;
+    const { title, content, folderId } = req.body;
+
+    if (!title || content === undefined || !folderId) {
+      res.status(400).json({ error: 'title, content, and folderId are required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, user.id, 'folder', folderId);
+    if (!canEdit(role)) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: user.id,
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    store.documents.set(id, doc);
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'document_created',
+      userId: user.id,
+      resourceType: 'document',
+      resourceId: id,
+      details: `Created document "${title}"`,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', requireAuth, (req: AuthenticatedRequest, res) => {
+    const user = req.user!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, user.id, 'document', doc.id);
+    if (!canRead(role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/:id', requireAuth, (req: AuthenticatedRequest, res) => {
+    const user = req.user!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, user.id, 'document', doc.id);
+    if (!canEdit(role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { title, content } = req.body;
+    const now = new Date().toISOString();
+
+    if (title !== undefined) {
+      doc.title = title;
+    }
+    if (content !== undefined) {
+      doc.content = content;
+    }
+    doc.updatedAt = now;
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'document_updated',
+      userId: user.id,
+      resourceType: 'document',
+      resourceId: doc.id,
+      details: `Updated document "${doc.title}"`,
+      timestamp: now,
+    });
+
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', requireAuth, (req: AuthenticatedRequest, res) => {
+    const user = req.user!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, user.id, 'document', doc.id);
+    if (!canDelete(role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const now = new Date().toISOString();
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'document_deleted',
+      userId: user.id,
+      resourceType: 'document',
+      resourceId: doc.id,
+      details: `Deleted document "${doc.title}"`,
+      timestamp: now,
+    });
+
+    // Remove shares for this document
+    store.shares = store.shares.filter(
+      (s) => !(s.resourceType === 'document' && s.resourceId === doc.id),
+    );
+
+    store.documents.delete(doc.id);
+    res.status(204).send();
+  });
+
+  // Share document
+  router.post('/:id/share', requireAuth, (req: AuthenticatedRequest, res) => {
+    const user = req.user!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, user.id, 'document', doc.id);
+    if (!canShare(role)) {
+      res.status(403).json({ error: 'Insufficient permissions to share' });
+      return;
+    }
+
+    const { userId, role: shareRole } = req.body;
+
+    if (!userId || !shareRole) {
+      res.status(400).json({ error: 'userId and role are required' });
+      return;
+    }
+
+    if (!['viewer', 'editor', 'owner'].includes(shareRole)) {
+      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });
+      return;
+    }
+
+    // Only owners can grant owner role
+    if (shareRole === 'owner' && role !== 'owner') {
+      res.status(403).json({ error: 'Only owners can grant owner role' });
+      return;
+    }
+
+    const targetUser = store.users.get(userId);
+    if (!targetUser) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+
+    // Check for existing share and update it
+    const existingShare = store.shares.find(
+      (s) => s.resourceType === 'document' && s.resourceId === doc.id && s.userId === userId,
+    );
+
+    if (existingShare) {
+      existingShare.role = shareRole;
+      store.activityLog.push({
+        id: generateId(store),
+        action: 'share_updated',
+        userId: user.id,
+        resourceType: 'document',
+        resourceId: doc.id,
+        details: `Updated share for user ${userId} to role ${shareRole}`,
+        timestamp: new Date().toISOString(),
+      });
+      res.json(existingShare);
+      return;
+    }
+
+    const share = {
+      id: generateId(store),
+      resourceType: 'document' as const,
+      resourceId: doc.id,
+      userId,
+      role: shareRole,
+      sharedBy: user.id,
+      createdAt: new Date().toISOString(),
+    };
+
+    store.shares.push(share);
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'share_created',
+      userId: user.id,
+      resourceType: 'document',
+      resourceId: doc.id,
+      details: `Shared with user ${userId} as ${shareRole}`,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(201).json(share);
+  });
+
+  return router;
+}
