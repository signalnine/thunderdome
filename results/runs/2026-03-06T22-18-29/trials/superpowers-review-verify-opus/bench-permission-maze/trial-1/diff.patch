iddleware.ts\nnew file mode 100644\nindex 0000000..d934962\n--- /dev/null\n+++ b/src/middleware.ts\n@@ -0,0 +1,31 @@\n+import { Request, Response, NextFunction } from 'express';\n+import { Store } from './store.js';\n+import { User } from './types.js';\n+\n+export interface AuthenticatedRequest extends Request {\n+  user?: User;\n+}\n+\n+export function authMiddleware(store: Store) {\n+  return (req: AuthenticatedRequest, _res: Response, next: NextFunction): void => {\n+    const authHeader = req.headers.authorization;\n+    if (authHeader && authHeader.startsWith('Bearer ')) {\n+      const token = authHeader.slice(7);\n+      for (const user of store.users.values()) {\n+        if (user.token === token) {\n+          req.user = user;\n+          break;\n+        }\n+      }\n+    }\n+    next();\n+  };\n+}\n+\n+export function requireAuth(req: AuthenticatedRequest, res: Response, next: NextFunction): void {\n+  if (!req.user) {\n+    res.status(401).json({ error: 'Authentication required' });\n+    return;\n+  }\n+  next();\n+}\ndiff --git a/src/permissions.ts b/src/permissions.ts\nnew file mode 100644\nindex 0000000..ef88956\n--- /dev/null\n+++ b/src/permissions.ts\n@@ -0,0 +1,81 @@\n+import { Role } from './types.js';\n+import { Store } from './store.js';\n+\n+const ROLE_LEVEL: Record<Role, number> = {\n+  viewer: 1,\n+  editor: 2,\n+  owner: 3,\n+};\n+\n+export function higherRole(a: Role, b: Role): Role {\n+  return ROLE_LEVEL[a] >= ROLE_LEVEL[b] ? a : b;\n+}\n+\n+export function getEffectiveRole(\n+  store: Store,\n+  userId: string,\n+  resourceType: 'folder' | 'document',\n+  resourceId: string,\n+): Role | null {\n+  // Check if user is the owner of the resource\n+  if (resourceType === 'folder') {\n+    const folder = store.folders.get(resourceId);\n+    if (folder && folder.ownerId === userId) return 'owner';\n+  } else {\n+    const doc = store.documents.get(resourceId);\n+    if (doc && doc.ownerId === userId) return 'owner';\n+  }\n+\n+  let bestRole: