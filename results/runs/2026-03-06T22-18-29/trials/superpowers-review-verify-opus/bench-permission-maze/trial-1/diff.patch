+import { Router } from 'express';
+import { Store, generateId } from '../store.js';
+import { AuthenticatedRequest, requireAuth } from '../middleware.js';
+import { getEffectiveRole, canRead, canEdit, canDelete, canShare } from '../permissions.js';
+
+export function folderRoutes(store: Store): Router {
+  const router = Router();
+
+  // Create folder
+  router.post('/', requireAuth, (req: AuthenticatedRequest, res) => {
+    const user = req.user!;
+    const { name, parentId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    // Validate parent folder exists and user has access
+    if (parentId) {
+      const parent = store.folders.get(parentId);
+      if (!parent) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      const role = getEffectiveRole(store, user.id, 'folder', parentId);
+      if (!canEdit(role)) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: user.id,
+      createdAt: now,
+    };
+
+    store.folders.set(id, folder);
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'folder_created',
+      userId: user.id,
+      resourceType: 'folder',
+      resourceId: id,
+      details: `Created folder "${name}"`,
+      timestamp: now,
+    });
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', requireAuth, (req: AuthenticatedRequest, res) => {
+    const user = req.user!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, user.id, 'folder', folder.id);
+    if (!canRead(role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Get child folders and documents
+    const children: string[] = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folder.id) {
+        children.push(f.id);
+      }
+    }
+
+    const documents: string[] = [];
+    for (const doc of store.documents.values()) {
+      if (doc.folderId === folder.id) {
+        documents.push(doc.id);
+      }
+    }
+
+    res.json({ ...folder, children, documents });
+  });
+
+  // Update folder
+  router.put('/:id', requireAuth, (req: AuthenticatedRequest, res) => {
+    const user = req.user!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, user.id, 'folder', folder.id);
+    if (!canEdit(role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const { name, parentId } = req.body;
+
+    if (name !== undefined) {
+      folder.name = name;
+    }
+
+    if (parentId !== undefined) {
+      // Prevent circular references
+      if (parentId === folder.id) {
+        res.status(400).json({ error: 'Folder cannot be its own parent' });
+        return;
+      }
+      if (parentId) {
+        const parent = store.folders.get(parentId);
+        if (!parent) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Walk up the ancestor chain to detect cycles
+        let ancestor = parent;
+        while (ancestor.parentId) {
+          if (ancestor.parentId === folder.id) {
+            res.status(400).json({ error: 'Cannot create circular folder hierarchy' });
+            return;
+          }
+          const next = store.folders.get(ancestor.parentId);
+          if (!next) break;
+          ancestor = next;
+        }
+        // Check permission on destination parent
+        const parentRole = getEffectiveRole(store, user.id, 'folder', parentId);
+        if (!canEdit(parentRole)) {
+          res.status(403).json({ error: 'Insufficient permissions on destination folder' });
+          return;
+        }
+      }
+      folder.parentId = parentId ?? null;
+    }
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'folder_updated',
+      userId: user.id,
+      resourceType: 'folder',
+      resourceId: folder.id,
+      details: `Updated folder "${folder.name}"`,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', requireAuth, (req: AuthenticatedRequest, res) => {
+    const user = req.user!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, user.id, 'folder', folder.id);
+    if (!canDelete(role)) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Collect all descendant folder IDs first, then delete
+    const collectDescendants = (folderId: string): string[] => {
+      const descendants: string[] = [];
+      for (const [childId, child] of store.folders.entries()) {
+        if (child.parentId === folderId) {
+          descendants.push(childId);
+          descendants.push(...collectDescendants(childId));
+        }
+      }
+      return descendants;
+    };
+
+    const allFolderIds = [folder.id, ...collectDescendants(folder.id)];
+
+    // Delete all documents in these folders
+    for (const [docId, doc] of [...store.documents.entries()]) {
+      if (allFolderIds.includes(doc.folderId)) {
+        store.documents.delete(docId);
+        store.shares = store.shares.filter(
+          (s) => !(s.resourceType === 'document' && s.resourceId === docId),
+        );
+      }
+    }
+
+    // Delete all descendant folders and their shares
+    for (const fId of allFolderIds) {
+      store.folders.delete(fId);
+      store.shares = store.shares.filter(
+        (s) => !(s.resourceType === 'folder' && s.resourceId === fId),
+      );
+    }
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'folder_deleted',
+      userId: user.id,
+      resourceType: 'folder',
+      resourceId: folder.id,
+      details: `Deleted folder "${folder.name}"`,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(204).send();
+  });
+
+  // Share folder
+  router.post('/:id/share', requireAuth, (req: AuthenticatedRequest, res) => {
+    const user = req.user!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    const role = getEffectiveRole(store, user.id, 'folder', folder.id);
+    if (!canShare(role)) {
+      res.status(403).json({ error: 'Insufficient permissions to share' });
+      return;
+    }
+
+    const { userId, role: shareRole } = req.body;
+
+    if (!userId || !shareRole) {
+      res.status(400).json({ error: 'userId and role are required' });
+      return;
+    }
+
+    if (!['viewer', 'editor', 'owner'].includes(shareRole)) {
+      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });
+      return;
+    }
+
+    // Only owners can grant owner role
+    if (shareRole === 'owner' && role !== 'owner') {
+      res.status(403).json({ error: 'Only owners can grant owner role' });
+      return;
+    }
+
+    const targetUser = store.users.get(userId);
+    if (!targetUser) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+
+    // Check for existing share and update it
+    const existingShare = store.shares.find(
+      (s) => s.resourceType === 'folder' && s.resourceId === folder.id && s.userId === userId,
+    );
+
+    if (existingShare) {
+      existingShare.role = shareRole;
+      // Log activity
+      store.activityLog.push({
+        id: generateId(store),
+        action: 'share_updated',
+        userId: user.id,
+        resourceType: 'folder',
+        resourceId: folder.id,
+        details: `Updated share for user ${userId} to role ${shareRole}`,
+        timestamp: new Date().toISOString(),
+      });
+      res.json(existingShare);
+      return;
+    }
+
+    const share = {
+      id: generateId(store),
+      resourceType: 'folder' as const,
+      resourceId: folder.id,
+      userId,
+      role: shareRole,
+      sharedBy: user.id,
+      createdAt: new Date().toISOString(),
+    };
+
+    store.shares.push(share);
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(store),
+      action: 'share_created',
+      userId: user.id,
+      resourceType: 'folder',
+      resourceId: folder.id,
+      details: `Shared with user ${userId} as ${shareRole}`,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(201).json(share);
+  });
+
+  return router;
+}
