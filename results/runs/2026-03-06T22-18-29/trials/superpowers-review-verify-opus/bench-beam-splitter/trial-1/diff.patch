+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  it('basic example: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('two splitters example', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('no splitters: beam goes straight down', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('source only: single row', () => {
+    const grid = [['S']];
+    // Beam starts at (0,0), moves to (1,0) which is out of bounds
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('beam absorbed at boundary (left)', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Beam at (0,0) goes down to (1,0) hits splitter
+    // down-left -> (2,-1) absorbed, down-right -> (2,1)
+    expect(countBeamCells(grid)).toBe(3); // (0,0), (1,0), (2,1)
+  });
+
+  it('beam absorbed at boundary (right)', () => {
+    const grid = [
+      ['.', '.', 'S'],
+      ['.', '.', '^'],
+      ['.', '.', '.'],
+    ];
+    // Beam at (0,2) goes down to (1,2) hits splitter
+    // down-left -> (2,1), down-right -> (2,3) absorbed
+    expect(countBeamCells(grid)).toBe(3); // (0,2), (1,2), (2,1)
+  });
+
+  it('multiple beams converge on same cell', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '^', '.'],
+      ['^', '.', '^'],
+      ['.', '.', '.'],
+    ];
+    // (0,1) -> (1,1) splitter -> DL(2,0) splitter, DR(2,2) splitter
+    // (2,0) splitter -> DL(3,-1) absorbed, DR(3,1)
+    // (2,2) splitter -> DL(3,1), DR(3,3) absorbed
+    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1)
+    expect(countBeamCells(grid)).toBe(5);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('basic example: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('two splitters example', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('no splitters: single path', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('source only: single row', () => {
+    const grid = [['S']];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('chain of splitters doubles each time', () => {
+    // 3 splitters in a line, each hit creates 2x paths
+    const grid = [
+      ['.', '.', '.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '^', '.', '.', '.'],
+      ['.', '.', '^', '.', '^', '.', '.'],
+      ['.', '^', '.', '.', '.', '^', '.'],
+      ['.', '.', '.', '.', '.', '.', '.'],
+    ];
+    // S at (0,3), down to (1,3) splitter -> 2 beams
+    // DL to (2,2) splitter -> 2 beams, DR to (2,4) splitter -> 2 beams
+    // From (2,2): DL to (3,1) splitter -> 2, DR to (3,3)
+    // From (2,4): DL to (3,3), DR to (3,5) splitter -> 2
+    // From (3,1) splitter: DL to (4,0), DR to (4,2) -> 2 paths
+    // From (3,3): continues DL to (4,2) -> 1 path (from 2,2 branch)
+    // From (3,3): continues DR to (4,4) -> 1 path (from 2,4 branch)
+    // From (3,5) splitter: DL to (4,4), DR to (4,6) -> 2 paths
+    // Total: 2 + 1 + 1 + 2 = 6 paths
+    expect(countBeamPaths(grid)).toBe(6n);
+  });
+
+  it('empty grid returns 0', () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it('handles large grid with many splitters efficiently', () => {
+    // Create a 200x200 grid with splitters in a diamond/reconverging pattern
+    // so beams keep hitting splitters, producing exponentially many paths.
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+
+    // Place splitters in reconverging diamond pattern:
+    // Row 1: splitter at col 100 (beam hits directly)
+    // Row 2: splitters at 99, 101 (both diagonals reconverge)
+    // Row 3: splitter at 100 (both diagonals hit this)
+    // etc. - alternating pattern ensures beams keep hitting splitters
+    for (let i = 0; i < 50; i++) {
+      const row = 1 + i * 2;
+      if (row >= rows) break;
+      if (i % 2 === 0) {
+        grid[row][100] = '^';
+      } else {
+        grid[row][99] = '^';
+        grid[row][101] = '^';
+      }
+    }
+
+    // Should complete without timeout
+    const startTime = Date.now();
+    const cellCount = countBeamCells(grid);
+    const paths = countBeamPaths(grid);
+    const elapsed = Date.now() - startTime;
+
+    expect(cellCount).toBeGreaterThan(0);
+    expect(paths).toBeGreaterThan(0n);
+    expect(elapsed).toBeLessThan(5000);
+  });
+});
