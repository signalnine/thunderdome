  54→      ['.', '.', '^'],\n    55→      ['.', '.', '.'],\n    56→    ];\n    57→    // Beam at (0,2) goes down to (1,2) hits splitter\n    58→    // down-left -> (2,1), down-right -> (2,3) absorbed\n    59→    expect(countBeamCells(grid)).toBe(3); // (0,2), (1,2), (2,1)\n    60→  });\n    61→\n    62→  it('multiple beams converge on same cell', () => {\n    63→    const grid = [\n    64→      ['.', 'S', '.'],\n    65→      ['.', '^', '.'],\n    66→      ['^', '.', '^'],\n    67→      ['.', '.', '.'],\n    68→    ];\n    69→    // (0,1) -> (1,1) splitter -> DL(2,0) splitter, DR(2,2) splitter\n    70→    // (2,0) splitter -> DL(3,-1) absorbed, DR(3,1)\n    71→    // (2,2) splitter -> DL(3,1), DR(3,3) absorbed\n    72→    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1)\n    73→    expect(countBeamCells(grid)).toBe(5);\n    74→  });\n    75→});\n    76→\n    77→describe('countBeamPaths', () => {\n    78→  it('basic example: single splitter', () => {\n    79→    const grid = [\n    80→      ['.', 'S', '.', '.', '.'],\n    81→      ['.', '.', '.', '.', '.'],\n    82→      ['.', '^', '.', '.', '.'],\n    83→      ['.', '.', '.', '.', '.'],\n    84→    ];\n    85→    expect(countBeamPaths(grid)).toBe(2n);\n    86→  });\n    87→\n    88→  it('two splitters example', () => {\n    89→    const grid = [\n    90→      ['.', 'S', '.', '.', '.'],\n    91→      ['.', '^', '.', '.', '.'],\n    92→      ['^', '.', '^', '.', '.'],\n    93→      ['.', '.', '.', '.', '.'],\n    94→    ];\n    95→    expect(countBeamPaths(grid)).toBe(4n);\n    96→  });\n    97→\n    98→  it('no splitters: single path', () => {\n    99→    const grid = [\n   100→      ['.', 'S', '.'],\n   101→      ['.', '.', '.'],\n   102→      ['.', '.', '.'],\n   103→    ];\n   104→    expect(countBeamPaths(grid)).toBe(1n);\n   105→  });\n   106→\n   107→  it('source only: single row', () => {\n   108→    const grid = [['S']];\n   109→    expect(countBeamPaths(grid)).toBe(1n);\n   110→  });\n   111→\n   112→  it('chain