t01', in2: 'c00', out: 'z01' },\n+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n+    ];\n+    // 01 + 01 = 10 (1 + 1 = 2)\n+    const result = simulate(gates, { x00: 1, x01: 0, y00: 1, y01: 0 });\n+    expect(result.z00).toBe(0);\n+    expect(result.z01).toBe(1);\n+    expect(result.z02).toBe(0);\n+  });\n+\n+  it('should simulate a 2-bit adder: 3+3=6', () => {\n+    const gates: Gate[] = [\n+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n+    ];\n+    // 11 + 11 = 110 (3 + 3 = 6)\n+    const result = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n+    expect(result.z00).toBe(0);\n+    expect(result.z01).toBe(1);\n+    expect(result.z02).toBe(1);\n+  });\n+});\n+\n+describe('findSwappedWires', () => {\n+  function makeAdder(numBits: number): Gate[] {\n+    const gates: Gate[] = [];\n+    for (let i = 0; i < numBits; i++) {\n+      const xw = `x${String(i).padStart(2, '0')}`;\n+      const yw = `y${String(i).padStart(2, '0')}`;\n+      const zw = `z${String(i).padStart(2, '0')}`;\n+      if (i === 0) {\n+        gates.push({ op: 'XOR', in1: xw, in2: yw, out: zw });\n+        gates.push({ op: 'AND', in1: xw, in2: yw, out: `c${String(i).padStart(2, '0')}` });\n+      } else {\n+        const prevCarry = `c${String(i - 1).padStart(2, '0')}`;\n+        const t = `t${String(i).padStart(2, '0')}`;\n+        const a = `a${String(i).padStart(2, '0')}`;\n+        const b = `b${String(i).padStart(2, '0')}`;\n+        const c = `c${String(i).padStart(2, '0')}`;\n+        gates.push({ op: