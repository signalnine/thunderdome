+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit: given gates and initial wire values, compute all wire values.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      const v1 = wires[gate.in1];
+      const v2 = wires[gate.in2];
+      if (v1 !== undefined && v2 !== undefined) {
+        const result =
+          gate.op === 'AND' ? v1 & v2 :
+          gate.op === 'OR'  ? v1 | v2 :
+                              v1 ^ v2;
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 swap pairs in a broken binary adder circuit.
+ *
+ * Strategy: A ripple-carry adder for bit i has a known structure:
+ *   - Bit 0 (half adder):
+ *       x00 XOR y00 -> z00
+ *       x00 AND y00 -> carry0
+ *   - Bit i (full adder, i > 0):
+ *       xNN XOR yNN -> partial_sum   (XOR gate with xNN, yNN inputs)
+ *       partial_sum XOR carry_in -> zNN  (XOR gate producing zNN)
+ *       xNN AND yNN -> gen_carry    (AND gate with xNN, yNN inputs)
+ *       partial_sum AND carry_in -> prop_carry (AND gate)
+ *       gen_carry OR prop_carry -> carry_out  (OR gate)
+ *   - Final bit: last carry -> z(N+1)
+ *
+ * We trace the expected structure bit by bit, and when we find a violation,
+ * we identify the swap.
+ */
+export function findSwappedWires(inputGates: Gate[]): string[] {
+  // Clone gates to avoid mutating caller's data
+  const gates = inputGates.map(g => ({ ...g }));
+  const swapped: Set<string> = new Set();
+
+  // Build lookup maps
+  const gateByOutput: Map<string, Gate> = new Map();
+  for (const g of gates) {
+    gateByOutput.set(g.out, g);
+  }
+
+  // Find a gate by op and inputs (unordered)
+  function findGate(
+    op: string,
+    in1: string,
+    in2: string
+  ): Gate | undefined {
+    for (const g of gates) {
+      if (
+        g.op === op &&
+        ((g.in1 === in1 && g.in2 === in2) ||
+          (g.in1 === in2 && g.in2 === in1))
+      ) {
+        return g;
+      }
+    }
+    return undefined;
+  }
+
+  // Find the gate that produces a given output wire
+  function gateFor(out: string): Gate | undefined {
+    return gateByOutput.get(out);
+  }
+
+  // Determine number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2, g.out]) {
+      if (w.startsWith('x') || w.startsWith('y')) {
+        const n = parseInt(w.slice(1), 10);
+        if (n > maxBit) maxBit = n;
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+
+  // Helper: swap two gate outputs
+  function doSwap(wire1: string, wire2: string): void {
+    swapped.add(wire1);
+    swapped.add(wire2);
+
+    const g1 = gateByOutput.get(wire1)!;
+    const g2 = gateByOutput.get(wire2)!;
+    g1.out = wire2;
+    g2.out = wire1;
+    gateByOutput.set(wire1, g2);
+    gateByOutput.set(wire2, g1);
+  }
+
+  // Trace the adder structure bit by bit
+  let carry = '';
+
+  for (let bit = 0; bit < numBits; bit++) {
+    const xw = `x${String(bit).padStart(2, '0')}`;
+    const yw = `y${String(bit).padStart(2, '0')}`;
+    const zw = `z${String(bit).padStart(2, '0')}`;
+
+    if (bit === 0) {
+      // Half adder: x XOR y -> z00, x AND y -> carry
+      const xorGate = findGate('XOR', xw, yw);
+      if (!xorGate) throw new Error(`Missing XOR gate for bit 0`);
+
+      if (xorGate.out !== zw) {
+        // The XOR gate's output is swapped with z00
+        doSwap(xorGate.out, zw);
+      }
+
+      const andGate = findGate('AND', xw, yw);
+      if (!andGate) throw new Error(`Missing AND gate for bit 0`);
+      carry = andGate.out;
+    } else {
+      // Full adder for bit i
+      // Step 1: Find the XOR of xNN and yNN -> partial_sum
+      const xorGate = findGate('XOR', xw, yw);
+      if (!xorGate) throw new Error(`Missing XOR gate for bit ${bit}`);
+      let partialSum = xorGate.out;
+
+      // Step 2: Find XOR of partialSum and carry -> should be zNN
+      let sumGate = findGate('XOR', partialSum, carry);
+
+      if (!sumGate) {
+        // One of partialSum or carry might be swapped.
+        // Check if there's a gate that produces zNN and is an XOR
+        const zGate = gateFor(zw);
+        if (zGate && zGate.op === 'XOR' && zGate !== xorGate) {
+          // Figure out which input is carry or partialSum
+          if (zGate.in1 === carry) {
+            doSwap(partialSum, zGate.in2);
+            partialSum = zGate.in2;
+            sumGate = zGate;
+          } else if (zGate.in2 === carry) {
+            doSwap(partialSum, zGate.in1);
+            partialSum = zGate.in1;
+            sumGate = zGate;
+          } else if (zGate.in1 === partialSum) {
+            doSwap(carry, zGate.in2);
+            carry = zGate.in2;
+            sumGate = zGate;
+          } else if (zGate.in2 === partialSum) {
+            doSwap(carry, zGate.in1);
