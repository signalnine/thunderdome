+
+  // Verify the final carry wire is the expected z output
+  const finalZ = `z${String(numBits).padStart(2, '0')}`;
+  if (carry !== finalZ) {
+    doSwap(carry, finalZ);
+  }
+
+  return [...swapped].sort();
