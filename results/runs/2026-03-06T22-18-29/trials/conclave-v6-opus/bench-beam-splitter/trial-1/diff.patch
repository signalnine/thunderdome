+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  it('counts cells for basic beam with no splitters', () => {
+    // Beam goes straight down from S at (0,1)
+    // Visits: (0,1), (1,1), (2,1)
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('counts cells for example from spec (one splitter)', () => {
+    // S at (0,1), splitter at (2,1)
+    // Beam: (0,1) -> (1,1) -> (2,1) hits splitter
+    // Splits: (3,0) and (3,2)
+    // Visited: (0,1), (1,1), (2,1), (3,0), (3,2) = 5
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('counts cells for example from spec (two splitters on row 2)', () => {
+    // S at (0,1), splitter at (1,1)
+    // Splits to (2,0) and (2,2) — both are splitters
+    // (2,0) splits to (3,-1) absorbed and (3,1)
+    // (2,2) splits to (3,1) and (3,3)
+    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1), (3,3) = 6
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('counts S cell as visited even with 1-row grid', () => {
+    // S on top row, no rows below — beam exits immediately
+    const grid = [['S']];
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('handles beam going off left edge', () => {
+    // S at (0,0), splitter at (1,0)
+    // Splits: (2,-1) absorbed, (2,1)
+    // Visited: (0,0), (1,0), (2,1) = 3
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('handles beam going off right edge', () => {
+    // S at (0,2), splitter at (1,2)
+    // Splits: (2,1) and (2,3) absorbed
+    // Visited: (0,2), (1,2), (2,1) = 3
+    const grid = [
+      ['.', '.', 'S'],
+      ['.', '.', '^'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('handles multiple beams visiting same cell', () => {
+    // Two diagonal beams converge on same cell — count once
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '^', '.'],
+      ['^', '.', '^'],
+      ['.', '.', '.'],
+    ];
+    // S at (0,1), splitter at (1,1)
+    // Splits: down-left (2,0) splitter, down-right (2,2) splitter
+    // (2,0) splits: (3,-1) absorbed, (3,1)
+    // (2,2) splits: (3,1), (3,3) absorbed
+    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1) = 5
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('handles diagonal beam hitting a splitter', () => {
+    // Splitters split regardless of incoming direction
+    const grid = [
+      ['.', '.', 'S', '.', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '.', '.', '^', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // S at (0,2), splitter at (1,2)
+    // Splits: down-left (2,1), down-right (2,3) — (2,3) is a splitter
+    // (2,1) continues down-left: (3,0)
+    // (2,3) splitter splits: (3,2) and (3,4)
+    // Visited: (0,2), (1,2), (2,1), (2,3), (3,0), (3,2), (3,4) = 7
+    expect(countBeamCells(grid)).toBe(7);
+  });
+
+  it('handles S not at column 0', () => {
+    const grid = [
+      ['.', '.', '.', 'S', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Beam: (0,3) -> (1,3) -> exits
+    expect(countBeamCells(grid)).toBe(2);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('returns 1 for a straight beam with no splitters', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('returns 1 for a 1-row grid (beam exits immediately)', () => {
+    const grid = [['S']];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('returns 2 for one splitter (spec example 1)', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('returns 4 for two splitters in cascade (spec example 2)', () => {
+    // S at (0,1), splitter at (1,1)
+    // Splits: (2,0) splitter, (2,2) splitter
+    // (2,0): (3,-1) absorbed, (3,1) — 2 paths
+    // (2,2): (3,1), (3,3) — 2 paths
+    // Total: 4 paths (including absorbed ones — they all exit)
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('returns correct count when one branch is absorbed off edge', () => {
+    // S at (0,0), splitter at (1,0)
+    // Left beam goes to (2,-1) — absorbed (still a path)
+    // Right beam goes to (2,1) — exits bottom
+    // 2 paths total
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('returns 2^K for K splitters in sequence', () => {
+    // S, then 3 splitters aligned diagonally so beam hits each
+    // Actually, with splitters in a line below S:
+    // S at (0,2)
+    // ^ at (1,2) — splits to (2,1) and (2,3)
+    // No more splitters — 2 paths
+    // For 2^3 = 8 paths we need 3 layers of splitters
+    const grid = [
+      ['.', '.', '.', '.', 'S', '.', '.', '.', '.'],
+      ['.', '.', '.', '.', '^', '.', '.', '.', '.'],
+      ['.', '.', '.', '^', '.', '^', '.', '.', '.'],
+      ['.', '.', '^', '.', '^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.', '.', '.', '.', '.'],
+    ];
+    // S at (0,4), splitter at (1,4)
+    // splits to (2,3) and (2,5) — both splitters
+    // (2,3) splits to (3,2) and (3,4) — both splitters
+    // (2,5) splits to (3,4) and (3,6) — (3,4) is splitter, (3,6) is splitter
+    // (3,2) splits to (4,1) and (4,3) — 2 paths
+    // (3,4) hit by 2 beams: each splits to (4,3) and (4,5) — 2+2 = 4 paths
+    // (3,6) splits to (4,5) and (4,7) — 2 paths
+    // Total: 2 + 4 + 2 = 8 = 2^3
+    expect(countBeamPaths(grid)).toBe(8n);
+  });
+
+  it('handles diagonal beam hitting splitter', () => {
+    const grid = [
+      ['.', '.', 'S', '.', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '.', '.', '^', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // S at (0,2), splitter at (1,2)
+    // Splits: down-left to (2,1), down-right to (2,3) which is splitter
+    // (2,1) continues down-left: (3,0) — 1 path
+    // (2,3) splits: (3,2) and (3,4) — 2 paths
+    // Total: 3 paths
+    expect(countBeamPaths(grid)).toBe(3n);
+  });
+
+  it('returns bigint for many splitters', () => {
+    // 10 splitters in a cascade pattern = 2^10 = 1024 paths
+    // Build a grid where each splitter layer doubles the paths
+    const width = 21;
+    const rows: string[][] = [];
+
+    // Row 0: source at center
+    const row0 = Array(width).fill('.');
+    row0[10] = 'S';
+    rows.push(row0);
+
+    // Row 1: first splitter
+    const row1 = Array(width).fill('.');
+    row1[10] = '^';
+    rows.push(row1);
+
+    // Rows 2-10: expanding splitter pattern
+    for (let layer = 1; layer < 10; layer++) {
+      const row = Array(width).fill('.');
+      for (let i = 0; i <= layer; i++) {
+        const col = 10 - layer + 2 * i;
+        if (col >= 0 && col < width) {
+          row[col] = '^';
+        }
+      }
+      rows.push(row);
+    }
+
+    // Final empty row
+    rows.push(Array(width).fill('.'));
+
+    const result = countBeamPaths(rows);
+    expect(result).toBe(1024n);
+  });
+});
+
+describe('performance', () => {
+  it('handles 200x200 grid with 50 splitters in under 5 seconds', () => {
+    const size = 200;
+    const grid: string[][] = [];
+
+    for (let r = 0; r < size; r++) {
+      grid.push(Array(size).fill('.'));
+    }
+
+    // Place source at center of top row
+    grid[0][100] = 'S';
+
+    // Place 50 splitters in a cascading pattern
+    // Each layer: splitters at positions that beams from previous layer will hit
+    let splitterCount = 0;
+
+    // Place splitters in layers to form a tree
+    // Layer 0: one splitter directly below S
+    grid[10][100] = '^';
+    splitterCount++;
+
+    // Layer 1: two splitters at the split positions
+    grid[20][90] = '^';
+    grid[20][110] = '^';
+    splitterCount += 2;
+
+    // Layer 2: four splitters
+    grid[30][80] = '^';
+    grid[30][100] = '^';
+    grid[30][120] = '^';
+    splitterCount += 3;
+
+    // Fill remaining splitters spread around
+    const candidates = [
+      [40, 70], [40, 90], [40, 110], [40, 130],
+      [50, 60], [50, 80], [50, 100], [50, 120], [50, 140],
+      [60, 50], [60, 70], [60, 90], [60, 110], [60, 130], [60, 150],
+      [70, 40], [70, 60], [70, 80], [70, 100], [70, 120], [70, 140], [70, 160],
+      [80, 30], [80, 50], [80, 70], [80, 90], [80, 110], [80, 130], [80, 150], [80, 170],
+      [90, 20], [90, 40], [90, 60], [90, 80], [90, 100], [90, 120], [90, 140], [90, 160], [90, 180],
+      [100, 10], [100, 30], [100, 50], [100, 70], [100, 90],
+    ];
+
+    for (const [r, c] of candidates) {
+      if (splitterCount >= 50) break;
+      if (r < size && c < size && grid[r][c] === '.') {
+        grid[r][c] = '^';
+        splitterCount++;
+      }
+    }
+
+    const start = performance.now();
+    const cells = countBeamCells(grid);
+    const paths = countBeamPaths(grid);
+    const elapsed = performance.now() - start;
+
+    expect(cells).toBeGreaterThan(0);
+    expect(paths).toBeGreaterThan(0n);
+    expect(elapsed).toBeLessThan(5000);
+  });
+});
