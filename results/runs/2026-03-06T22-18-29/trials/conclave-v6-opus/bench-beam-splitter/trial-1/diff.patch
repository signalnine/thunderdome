@@ -0,0 +1,94 @@
+interface Beam {
+  row: number;
+  col: number;
+  dr: number;
+  dc: number;
+}
+
+function findSource(grid: string[][]): [number, number] {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  throw new Error('No source found');
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  const visited = new Set<string>();
+  visited.add(`${sr},${sc}`);
+
+  const beams: Beam[] = [{ row: sr, col: sc, dr: 1, dc: 0 }];
+
+  while (beams.length > 0) {
+    const next: Beam[] = [];
+    for (const beam of beams) {
+      const nr = beam.row + beam.dr;
+      const nc = beam.col + beam.dc;
+
+      if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) continue;
+
+      visited.add(`${nr},${nc}`);
+
+      if (grid[nr][nc] === '^') {
+        next.push({ row: nr, col: nc, dr: 1, dc: -1 });
+        next.push({ row: nr, col: nc, dr: 1, dc: 1 });
+      } else {
+        next.push({ row: nr, col: nc, dr: beam.dr, dc: beam.dc });
+      }
+    }
+    beams.length = 0;
+    beams.push(...next);
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  // Each entry: beam state key -> number of paths reaching that state
+  let beamCounts = new Map<string, bigint>();
+  const startKey = `${sr},${sc},1,0`;
+  beamCounts.set(startKey, 1n);
+
+  let totalPaths = 0n;
+
+  while (beamCounts.size > 0) {
+    const nextCounts = new Map<string, bigint>();
+
+    for (const [key, count] of beamCounts) {
+      const parts = key.split(',');
+      const row = parseInt(parts[0]);
+      const col = parseInt(parts[1]);
+      const dr = parseInt(parts[2]);
+      const dc = parseInt(parts[3]);
+
+      const nr = row + dr;
+      const nc = col + dc;
+
+      if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+        totalPaths += count;
+        continue;
+      }
+
+      if (grid[nr][nc] === '^') {
+        const leftKey = `${nr},${nc},1,-1`;
+        const rightKey = `${nr},${nc},1,1`;
+        nextCounts.set(leftKey, (nextCounts.get(leftKey) ?? 0n) + count);
+        nextCounts.set(rightKey, (nextCounts.get(rightKey) ?? 0n) + count);
+      } else {
+        const nextKey = `${nr},${nc},${dr},${dc}`;
+        nextCounts.set(nextKey, (nextCounts.get(nextKey) ?? 0n) + count);
+      }
+    }
+
+    beamCounts = nextCounts;
+  }
+
+  return totalPaths;
+}
