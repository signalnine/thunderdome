+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve a toggle puzzle over GF(2) using Gaussian elimination.
+ * Returns the minimum set of button indices (sorted ascending) to press,
+ * or null if no solution exists.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return target.some(t => t) ? null : [];
+  }
+
+  // Build augmented matrix over GF(2) using bigints.
+  // Each row is a light equation. Bit j = coefficient for button j.
+  // Bit numButtons = target value.
+  const rows: bigint[] = [];
+  for (let i = 0; i < numLights; i++) {
+    let row = 0n;
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row |= 1n << BigInt(j);
+      }
+    }
+    if (target[i]) {
+      row |= 1n << BigInt(numButtons);
+    }
+    rows.push(row);
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let rank = 0;
+  const augBit = BigInt(numButtons);
+
+  for (let col = 0; col < numButtons; col++) {
+    let found = -1;
+    const colBit = BigInt(col);
+    for (let row = rank; row < numLights; row++) {
+      if ((rows[row] >> colBit) & 1n) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [rows[rank], rows[found]] = [rows[found], rows[rank]];
+
+    for (let row = 0; row < numLights; row++) {
+      if (row !== rank && (rows[row] >> colBit) & 1n) {
+        rows[row] ^= rows[rank];
+      }
+    }
+
+    pivotCol.push(col);
+    pivotRow[col] = rank;
+    rank++;
+  }
+
+  // Check for inconsistency
+  for (let row = rank; row < numLights; row++) {
+    if ((rows[row] >> augBit) & 1n) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    // Unique solution: read off pivot values
+    const result: number[] = [];
+    for (let r = 0; r < rank; r++) {
+      if ((rows[r] >> augBit) & 1n) {
+        result.push(pivotCol[r]);
+      }
+    }
+    return result.sort((a, b) => a - b);
+  }
+
+  // Precompute: for each free variable, which pivot rows does it affect?
+  // Store as bitmask over pivot rows (rank bits).
+  const freeEffectMask: bigint[] = [];
+  for (const fv of freeVars) {
+    let mask = 0n;
+    const fvBit = BigInt(fv);
+    for (let r = 0; r < rank; r++) {
+      if ((rows[r] >> fvBit) & 1n) {
+        mask |= 1n << BigInt(r);
+      }
+    }
+    freeEffectMask.push(mask);
+  }
+
+  // Base pivot state (all free vars = 0)
+  let basePivotMask = 0n;
+  for (let r = 0; r < rank; r++) {
+    if ((rows[r] >> augBit) & 1n) {
+      basePivotMask |= 1n << BigInt(r);
+    }
+  }
+
+  // Choose approach based on number of free variables
+  if (numFree <= 23) {
+    return solveToggleDirect(numButtons, rank, pivotCol, freeVars, numFree, freeEffectMask, basePivotMask);
+  } else {
+    return solveToggleMITM(numButtons, rank, pivotCol, freeVars, freeEffectMask, basePivotMask);
+  }
+}
+
+function popcount(n: bigint): number {
+  let count = 0;
+  while (n > 0n) {
+    n &= n - 1n;
+    count++;
+  }
+  return count;
+}
+
+function popcountNum(n: number): number {
+  let count = 0;
+  while (n) {
+    n &= n - 1;
+    count++;
+  }
+  return count;
+}
+
+function solveToggleDirect(
+  numButtons: number,
+  rank: number,
+  pivotCol: number[],
+  freeVars: number[],
+  numFree: number,
+  freeEffectMask: bigint[],
+  basePivotMask: bigint
+): number[] {
+  let bestCount = numButtons + 1;
+  let bestFreeMask = 0;
+  let bestPivotMask = 0n;
+  const totalCombinations = 1 << numFree;
+
+  // Use Gray code enumeration for efficiency:
+  // Each step flips exactly one free variable, updating pivotMask incrementally.
+  let currentPivotMask = basePivotMask;
+  let currentFreeMask = 0;
+
+  // Evaluate mask=0
+  {
+    const freeCount = 0;
+    const pivotCount = popcount(currentPivotMask);
+    const total = freeCount + pivotCount;
+    if (total < bestCount) {
+      bestCount = total;
+      bestFreeMask = 0;
+      bestPivotMask = currentPivotMask;
+    }
+  }
+
+  for (let i = 1; i < totalCombinations; i++) {
+    // Gray code: find the bit that changes
+    const bitToFlip = ctz(i); // count trailing zeros
+    currentFreeMask ^= (1 << bitToFlip);
+    currentPivotMask ^= freeEffectMask[bitToFlip];
+
+    const freeCount = popcountNum(currentFreeMask);
+    const pivotCount = popcount(currentPivotMask);
+    const total = freeCount + pivotCount;
+
+    if (total < bestCount) {
+      bestCount = total;
+      bestFreeMask = currentFreeMask;
+      bestPivotMask = currentPivotMask;
+    } else if (total === bestCount) {
+      // Compare lexicographically - build solution and compare
+      if (lexSmallerSolution(currentFreeMask, currentPivotMask, bestFreeMask, bestPivotMask,
+                              freeVars, pivotCol, numButtons, rank)) {
+        bestFreeMask = currentFreeMask;
+        bestPivotMask = currentPivotMask;
+      }
+    }
+  }
+
+  return buildResult(bestFreeMask, bestPivotMask, freeVars, pivotCol, numButtons, rank);
+}
+
+function ctz(n: number): number {
+  if (n === 0) return 32;
+  let count = 0;
+  while ((n & 1) === 0) {
+    n >>= 1;
+    count++;
+  }
+  return count;
+}
+
+function lexSmallerSolution(
+  freeMaskA: number, pivotMaskA: bigint,
+  freeMaskB: number, pivotMaskB: bigint,
+  freeVars: number[], pivotCol: number[],
+  numButtons: number, rank: number
+): boolean {
+  // Compare two solutions lexicographically as sorted index sets.
+  // We need to merge freeVars and pivotCol in order and compare.
+  let fi = 0, pi = 0;
+  const numFree = freeVars.length;
+
+  for (let btn = 0; btn < numButtons; btn++) {
+    let valA: number, valB: number;
+
+    if (fi < numFree && freeVars[fi] === btn) {
+      valA = (freeMaskA >> fi) & 1;
+      valB = (freeMaskB >> fi) & 1;
+      fi++;
+    } else if (pi < rank && pivotCol[pi] === btn) {
+      valA = Number((pivotMaskA >> BigInt(pi)) & 1n);
+      valB = Number((pivotMaskB >> BigInt(pi)) & 1n);
+      pi++;
+    } else {
+      continue;
+    }
+
+    if (valA !== valB) {
+      // In set lex order: the solution that has this button pressed
+      // when the other doesn't... We need to compare as sorted index SETS.
+      // Set A is lex smaller if at the first element where they differ,
+      // A's element is smaller.
+      // Equivalently: at the first button index where exactly one solution
+      // presses it, the solution that presses it is lexicographically
+      // "contains a smaller element" which makes it smaller.
+      // Wait, no. If A has button 2 pressed and B doesn't, but B has button 3 pressed,
+      // then A = {..., 2, ...} and B = {..., 3, ...} and A is smaller because 2 < 3.
+      // But we're scanning in order from 0 upward. At button 2, A=1, B=0.
+      // A has an element (2) that B doesn't. B must have a later element to compensate
+      // (since they have the same count). So A is lex smaller.
+      // More generally: at the first difference, whichever solution has 1 is lex smaller.
+      return valA > valB;
+    }
+  }
+  return false;
+}
+
+function buildResult(
+  freeMask: number, pivotMask: bigint,
+  freeVars: number[], pivotCol: number[],
+  numButtons: number, rank: number
+): number[] {
+  const result: number[] = [];
+  for (let f = 0; f < freeVars.length; f++) {
+    if ((freeMask >> f) & 1) {
+      result.push(freeVars[f]);
+    }
+  }
+  for (let r = 0; r < rank; r++) {
+    if ((pivotMask >> BigInt(r)) & 1n) {
+      result.push(pivotCol[r]);
+    }
+  }
+  return result.sort((a, b) => a - b);
+}
+
+function solveToggleMITM(
+  numButtons: number,
+  rank: number,
+  pivotCol: number[],
+  freeVars: number[],
+  freeEffectMask: bigint[],
+  basePivotMask: bigint
+): number[] {
+  const numFree = freeVars.length;
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+
+  // For each halfA assignment, compute (pivotFlips, freeCount).
+  // Group by pivotFlips, keep best per group.
+  // But we also need to consider non-zero pivot states.
+  //
+  // Total cost = freeCountA + freeCountB + popcount(basePivotMask ^ pivotFlipsA ^ pivotFlipsB)
+  //
+  // For the MITM: for each B, we want to find the A that minimizes
+  // freeCountA + popcount(basePivotMask ^ pivotFlipsB ^ pivotFlipsA)
+  //
+  // Key insight: group A entries by (pivotFlips, freeCount).
+  // For each B, the ideal pivotFlipsA = basePivotMask ^ pivotFlipsB (makes pivot count 0).
+  // But if that's not available, we need nearby entries.
+  //
+  // With rank ≤ 40, the pivot effect space is 2^rank. For large rank, the map can be huge
+  // but the number of distinct effects is at most 2^halfA.
+  //
+  // Strategy: for each pivotFlips in mapA, store the minimum freeCount.
+  // For each B, check the exact match first. If exact match gives total ≤ bestCount,
+  // that's our candidate. But non-exact matches could also be better if freeCountA is
+  // much smaller and only adds a few pivot presses.
+  //
+  // For correctness: we need to iterate all A entries for each B, which is O(2^halfA * 2^halfB).
+  // But if halfA and halfB are each ~20, this is 2^40 which is too much.
+  //
+  // Better approach: for each B, look up the exact match (pivot count = 0),
+  // and also maintain a global minimum across all A entries grouped by cost.
+  // The minimum possible cost for any (A,B) pair where pivot is non-zero is at least
+  // freeCountA_min + freeCountB + 1. So if exact match gives total ≤ freeCountA_min + freeCountB + 1,
+  // no non-exact match can beat it.
+
+  // Build mapA: pivotFlips (as string) -> { freeCount, freeMask }
+  // Also keep a sorted list of (freeCount, pivotFlips, freeMask) for the fallback
+  const mapA = new Map<string, { freeCount: number; freeMask: number; pivotFlips: bigint }[]>();
+  const allAEntries: { freeCount: number; freeMask: number; pivotFlips: bigint }[] = [];
+
+  {
+    let currentPivotFlips = 0n;
+    let currentFreeMask = 0;
+
+    const addEntry = () => {
+      const freeCount = popcountNum(currentFreeMask);
+      const entry = { freeCount, freeMask: currentFreeMask, pivotFlips: currentPivotFlips };
+      const key = currentPivotFlips.toString();
+      const list = mapA.get(key);
+      if (list) {
+        // Only keep if this is better or equal to existing
+        if (freeCount < list[0].freeCount) {
+          list.length = 0;
+          list.push(entry);
+        } else if (freeCount === list[0].freeCount) {
+          list.push(entry);
+        }
+      } else {
+        mapA.set(key, [entry]);
+      }
+      allAEntries.push(entry);
+    };
+
+    addEntry(); // mask = 0
+
+    const totalA = 1 << halfA;
+    for (let i = 1; i < totalA; i++) {
+      const bitToFlip = ctz(i);
+      currentFreeMask ^= (1 << bitToFlip);
+      currentPivotFlips ^= freeEffectMask[bitToFlip];
+      addEntry();
+    }
+  }
+
+  // Sort all A entries by freeCount for potential early termination
+  allAEntries.sort((a, b) => a.freeCount - b.freeCount);
+  const minFreeCountA = allAEntries[0].freeCount;
+
+  let bestCount = numButtons + 1;
+  let bestFreeMaskFull = 0; // combined mask for all free vars
+  let bestPivotMask = 0n;
+
+  // Enumerate half B using Gray code
+  {
+    let currentPivotFlipsB = 0n;
+    let currentFreeMaskB = 0;
+
+    const processB = () => {
+      const freeCountB = popcountNum(currentFreeMaskB);
+
+      // Try exact match first (makes all pivots 0)
+      const needed = basePivotMask ^ currentPivotFlipsB;
+      const key = needed.toString();
+      const entriesA = mapA.get(key);
+
+      if (entriesA) {
+        const entryA = entriesA[0]; // Best (lowest freeCount) for this pivotFlips
+        const totalCount = entryA.freeCount + freeCountB;
+
+        if (totalCount < bestCount) {
+          bestCount = totalCount;
+          bestFreeMaskFull = entryA.freeMask | (currentFreeMaskB << halfA);
+          bestPivotMask = 0n; // all pivots are 0
+        } else if (totalCount === bestCount) {
+          const candidateFreeMask = entryA.freeMask | (currentFreeMaskB << halfA);
+          if (lexSmallerSolution(candidateFreeMask, 0n, bestFreeMaskFull, bestPivotMask,
+                                  freeVars, pivotCol, numButtons, rank)) {
+            bestFreeMaskFull = candidateFreeMask;
+            bestPivotMask = 0n;
+          }
+        }
+      }
+
+      // Check if non-exact matches could beat or tie the current best
+      // Minimum possible: minFreeCountA + freeCountB + 1 (at least 1 pivot pressed)
+      if (minFreeCountA + freeCountB + 1 <= bestCount) {
+        // Need to check all A entries. But this is expensive for large halfA.
+        // Limit: only check entries where freeCountA + freeCountB < bestCount
+        for (const entryA of allAEntries) {
+          if (entryA.freeCount + freeCountB >= bestCount) break; // sorted, so done
+          const combinedPivot = basePivotMask ^ entryA.pivotFlips ^ currentPivotFlipsB;
+          const pivotCount = popcount(combinedPivot);
+          const totalCount = entryA.freeCount + freeCountB + pivotCount;
+
+          if (totalCount < bestCount) {
+            bestCount = totalCount;
+            bestFreeMaskFull = entryA.freeMask | (currentFreeMaskB << halfA);
+            bestPivotMask = combinedPivot;
+          } else if (totalCount === bestCount) {
+            const candidateFreeMask = entryA.freeMask | (currentFreeMaskB << halfA);
+            if (lexSmallerSolution(candidateFreeMask, combinedPivot, bestFreeMaskFull, bestPivotMask,
+                                    freeVars, pivotCol, numButtons, rank)) {
+              bestFreeMaskFull = candidateFreeMask;
+              bestPivotMask = combinedPivot;
+            }
+          }
+        }
+      }
+    };
+
+    processB(); // mask = 0
+
+    const totalB = 1 << halfB;
+    for (let i = 1; i < totalB; i++) {
+      const bitToFlip = ctz(i);
+      currentFreeMaskB ^= (1 << bitToFlip);
+      currentPivotFlipsB ^= freeEffectMask[halfA + bitToFlip];
+      processB();
+    }
+  }
+
+  return buildResult(bestFreeMaskFull, bestPivotMask, freeVars, pivotCol, numButtons, rank);
+}
+
+/**
+ * Solve a counter puzzle over GF(p) using Gaussian elimination.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return lights.some(v => v !== 0) ? null : [];
+  }
+
+  // Build augmented matrix over GF(p)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = lights[i] % modulus;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let rank = 0;
+
+  for (let col = 0; col < numButtons; col++) {
+    let found = -1;
+    for (let row = rank; row < numCounters; row++) {
+      if (matrix[row][col] !== 0) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];
+
+    const pivotVal = matrix[rank][col];
+    const inv = modInverse(pivotVal, modulus);
+    for (let c = 0; c <= numButtons; c++) {
+      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;
+    }
+
+    for (let row = 0; row < numCounters; row++) {
+      if (row !== rank && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    pivotRow[col] = rank;
+    rank++;
+  }
+
+  // Check for inconsistency
+  for (let row = rank; row < numCounters; row++) {
+    if (matrix[row][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // Precompute coefficients
+  const pivotFreeCoeffs: number[][] = [];
+  const pivotBaseValues: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    const coeffs: number[] = [];
+    for (const fv of freeVars) {
+      coeffs.push(matrix[r][fv]);
+    }
+    pivotFreeCoeffs.push(coeffs);
+    pivotBaseValues.push(matrix[r][numButtons]);
+  }
+
+  if (numFree === 0) {
+    // Unique solution
+    const solution = new Array(numButtons).fill(0);
+    for (let r = 0; r < rank; r++) {
+      solution[pivotCol[r]] = pivotBaseValues[r];
+    }
+    return solution;
+  }
+
+  // Estimate search space
+  const logSpace = numFree * Math.log2(modulus);
+
+  if (logSpace <= 22) { // ~4M combinations
+    return solveCounterDirect(
+      numButtons, modulus, rank, pivotCol, freeVars, numFree,
+      pivotFreeCoeffs, pivotBaseValues
+    );
+  } else {
+    return solveCounterMITM(
+      numButtons, modulus, rank, pivotCol, freeVars,
+      pivotFreeCoeffs, pivotBaseValues
+    );
+  }
+}
+
+function solveCounterDirect(
+  numButtons: number,
+  modulus: number,
+  rank: number,
+  pivotCol: number[],
+  freeVars: number[],
+  numFree: number,
+  pivotFreeCoeffs: number[][],
+  pivotBaseValues: number[]
+): number[] {
+  let bestSum = Infinity;
+  let bestSolution: number[] | null = null;
+
+  const freeValues = new Array(numFree).fill(0);
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  for (let iter = 0; iter < totalCombinations; iter++) {
+    // Compute solution
+    let sum = 0;
+    for (let f = 0; f < numFree; f++) {
+      sum += freeValues[f];
+    }
+
+    // Early prune: if free vars alone exceed best, skip
+    if (sum <= bestSum) {
+      const solution = new Array(numButtons).fill(0);
+      for (let f = 0; f < numFree; f++) {
+        solution[freeVars[f]] = freeValues[f];
+      }
+
+      for (let r = 0; r < rank; r++) {
+        let val = pivotBaseValues[r];
+        for (let f = 0; f < numFree; f++) {
+          val -= pivotFreeCoeffs[r][f] * freeValues[f];
+        }
+        val = ((val % modulus) + modulus * modulus) % modulus; // ensure positive
+        solution[pivotCol[r]] = val;
+        sum += val;
+      }
+
+      if (sum < bestSum || (sum === bestSum && lexSmallerArr(solution, bestSolution!, numButtons))) {
+        bestSum = sum;
+        bestSolution = solution;
+      }
+    }
+
+    // Increment (odometer)
+    for (let f = numFree - 1; f >= 0; f--) {
+      freeValues[f]++;
+      if (freeValues[f] >= modulus) {
+        freeValues[f] = 0;
+      } else {
+        break;
+      }
+    }
+  }
+
+  return bestSolution!;
+}
+
+function lexSmallerArr(a: number[], b: number[], n: number): boolean {
+  for (let i = 0; i < n; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function solveCounterMITM(
+  numButtons: number,
+  modulus: number,
+  rank: number,
+  pivotCol: number[],
+  freeVars: number[],
+  pivotFreeCoeffs: number[][],
+  pivotBaseValues: number[]
+): number[] {
+  const numFree = freeVars.length;
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+
+  // For MITM on counter puzzle:
+  // Total cost = sum(freeA) + sum(freeB) + sum(pivotValues)
+  // pivotValues[r] = (baseVal[r] - effectA[r] - effectB[r]) mod p
+  //
+  // For minimum total, ideally we want pivot values to be 0, which means
+  // effectA[r] + effectB[r] ≡ baseVal[r] (mod p)
+  //
+  // Map A: for each half-A assignment, compute effectA[r] for each pivot row.
+  // Key = tuple of effectA values. Store best (min sum, lex smallest assignment).
+  //
+  // For each half-B assignment, compute what effectA values we need to make pivots 0:
+  // neededA[r] = (baseVal[r] - effectB[r]) mod p
+  // Look up in mapA. If found, total = sumA + sumB (pivots all 0).
+  //
+  // Also need to consider non-zero pivot values for optimality.
+  // For GF(p) with p prime, the pivot value contribution to sum can be smaller
+  // than a non-zero pivot value when some free vars would need to be increased to
+  // make it zero. But finding this optimally requires checking all combinations.
+  //
+  // Practical approach: first try exact match (zero pivots), then check if
+  // non-zero pivot solutions could be better. For the latter, we'd need to
+  // enumerate pivot value assignments too, which is expensive.
+  //
+  // For now, the zero-pivot approach is correct when free vars alone give the minimum sum.
+  // But there are cases where a non-zero pivot value (e.g., 1) saves more than 1 in free vars.
+  //
+  // For correctness with minimum sum guarantee, we need a more comprehensive approach.
+  // Let's use the zero-pivot MITM as primary, then do an exhaustive check for small spaces.
+
+  // Build mapA
+  const mapA = new Map<string, { sum: number; values: number[] }>();
+  const freeValuesA = new Array(halfA).fill(0);
+  const totalA = Math.pow(modulus, halfA);
+
+  for (let iterA = 0; iterA < totalA; iterA++) {
+    let sum = 0;
+    const effects: number[] = new Array(rank);
+    for (let f = 0; f < halfA; f++) {
+      sum += freeValuesA[f];
+    }
+    for (let r = 0; r < rank; r++) {
+      let effect = 0;
+      for (let f = 0; f < halfA; f++) {
+        effect += pivotFreeCoeffs[r][f] * freeValuesA[f];
+      }
+      effects[r] = effect % modulus;
+    }
+
+    const key = effects.join(',');
+    const existing = mapA.get(key);
+    if (!existing || sum < existing.sum ||
+        (sum === existing.sum && lexSmallerArrDirect(freeValuesA, existing.values, halfA))) {
+      mapA.set(key, { sum, values: [...freeValuesA] });
+    }
+
+    for (let f = halfA - 1; f >= 0; f--) {
+      freeValuesA[f]++;
+      if (freeValuesA[f] >= modulus) {
+        freeValuesA[f] = 0;
+      } else {
+        break;
+      }
+    }
+  }
+
+  let bestSum = Infinity;
+  let bestSolution: number[] | null = null;
+
+  // Enumerate half B
+  const freeValuesB = new Array(halfB).fill(0);
+  const totalB = Math.pow(modulus, halfB);
+
+  for (let iterB = 0; iterB < totalB; iterB++) {
+    let sumB = 0;
+    for (let f = 0; f < halfB; f++) {
+      sumB += freeValuesB[f];
+    }
+
+    // Compute needed effectA for zero pivots
+    const neededEffects = new Array(rank);
+    for (let r = 0; r < rank; r++) {
+      let effectB = 0;
+      for (let f = 0; f < halfB; f++) {
+        effectB += pivotFreeCoeffs[r][halfA + f] * freeValuesB[f];
+      }
+      neededEffects[r] = ((pivotBaseValues[r] - effectB) % modulus + modulus * modulus) % modulus;
+    }
+
+    const key = neededEffects.join(',');
+    const entryA = mapA.get(key);
+
+    if (entryA) {
+      const totalSum = entryA.sum + sumB;
+
+      if (totalSum < bestSum) {
+        bestSum = totalSum;
+        bestSolution = buildCounterSolution(
+          entryA.values, freeValuesB, halfA, halfB, freeVars,
+          pivotCol, pivotFreeCoeffs, pivotBaseValues, numButtons, rank, modulus
+        );
+      } else if (totalSum === bestSum && bestSolution) {
+        const candidate = buildCounterSolution(
+          entryA.values, freeValuesB, halfA, halfB, freeVars,
+          pivotCol, pivotFreeCoeffs, pivotBaseValues, numButtons, rank, modulus
+        );
+        if (lexSmallerArr(candidate, bestSolution, numButtons)) {
+          bestSolution = candidate;
+        }
+      }
+    }
+
+    for (let f = halfB - 1; f >= 0; f--) {
+      freeValuesB[f]++;
+      if (freeValuesB[f] >= modulus) {
+        freeValuesB[f] = 0;
+      } else {
+        break;
+      }
+    }
+  }
+
+  // If zero-pivot MITM didn't find a solution, it means no combination of
+  // A+B effects can produce the needed pivot effects. But this shouldn't happen
+  // since the system is consistent (we checked earlier). If halfA is large enough
+  // to cover all possible effects, we should find a match.
+  //
+  // If bestSolution is still null, fall back to exhaustive search over all A entries.
+  if (bestSolution === null) {
+    const allA = Array.from(mapA.values());
+    const freeValuesB2 = new Array(halfB).fill(0);
+
+    for (let iterB2 = 0; iterB2 < totalB; iterB2++) {
+      let sumB = 0;
+      for (let f = 0; f < halfB; f++) {
+        sumB += freeValuesB2[f];
+      }
+
+      const effectsB = new Array(rank);
+      for (let r = 0; r < rank; r++) {
+        let effectB = 0;
+        for (let f = 0; f < halfB; f++) {
+          effectB += pivotFreeCoeffs[r][halfA + f] * freeValuesB2[f];
+        }
+        effectsB[r] = effectB % modulus;
+      }
+
+      for (const entryA of allA) {
+        const effectsA = new Array(rank);
+        for (let r = 0; r < rank; r++) {
+          let effectA = 0;
+          for (let f = 0; f < halfA; f++) {
+            effectA += pivotFreeCoeffs[r][f] * entryA.values[f];
+          }
+          effectsA[r] = effectA % modulus;
+        }
+
+        let pivotSum = 0;
+        for (let r = 0; r < rank; r++) {
+          pivotSum += ((pivotBaseValues[r] - effectsA[r] - effectsB[r]) % modulus + modulus * modulus) % modulus;
+        }
+
+        const totalSum = entryA.sum + sumB + pivotSum;
+        if (totalSum < bestSum) {
+          bestSum = totalSum;
+          bestSolution = buildCounterSolution(
+            entryA.values, freeValuesB2, halfA, halfB, freeVars,
+            pivotCol, pivotFreeCoeffs, pivotBaseValues, numButtons, rank, modulus
+          );
+        } else if (totalSum === bestSum && bestSolution) {
+          const candidate = buildCounterSolution(
+            entryA.values, freeValuesB2, halfA, halfB, freeVars,
+            pivotCol, pivotFreeCoeffs, pivotBaseValues, numButtons, rank, modulus
+          );
+          if (lexSmallerArr(candidate, bestSolution, numButtons)) {
+            bestSolution = candidate;
+          }
+        }
+      }
+
+      for (let f = halfB - 1; f >= 0; f--) {
+        freeValuesB2[f]++;
+        if (freeValuesB2[f] >= modulus) {
+          freeValuesB2[f] = 0;
+        } else {
+          break;
+        }
+      }
+    }
+  }
+
+  return bestSolution!;
+}
+
+function lexSmallerArrDirect(a: number[], b: number[], n: number): boolean {
+  for (let i = 0; i < n; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function buildCounterSolution(
+  freeValuesA: number[],
+  freeValuesB: number[],
+  halfA: number,
+  halfB: number,
+  freeVars: number[],
+  pivotCol: number[],
+  pivotFreeCoeffs: number[][],
+  pivotBaseValues: number[],
+  numButtons: number,
+  rank: number,
+  modulus: number
+): number[] {
+  const solution = new Array(numButtons).fill(0);
+
+  for (let f = 0; f < halfA; f++) {
+    solution[freeVars[f]] = freeValuesA[f];
+  }
+  for (let f = 0; f < halfB; f++) {
+    solution[freeVars[halfA + f]] = freeValuesB[f];
+  }
+
+  for (let r = 0; r < rank; r++) {
+    let val = pivotBaseValues[r];
+    for (let fi = 0; fi < freeVars.length; fi++) {
+      val -= pivotFreeCoeffs[r][fi] * solution[freeVars[fi]];
+    }
+    solution[pivotCol[r]] = ((val % modulus) + modulus * modulus) % modulus;
+  }
+
+  return solution;
+}
+
+function modInverse(a: number, m: number): number {
+  let [old_r, r] = [((a % m) + m) % m, m];
+  let [old_s, s] = [1, 0];
+
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+
+  return ((old_s % m) + m) % m;
+}
