t freeEffectOnPivots: number[][] = []; // for each free var index, list of pivot row indices it affects\n   236→  for (const fv of freeVars) {\n   237→    const affected: number[] = [];\n   238→    for (let r = 0; r < rank; r++) {\n   239→      if ((rows[r] >> BigInt(fv)) & 1n) {\n   240→        affected.push(r);\n   241→      }\n   242→    }\n   243→    freeEffectOnPivots.push(affected);\n   244→  }\n   245→\n   246→  // Represent pivot state as bigint bitmask for efficiency\n   247→  let basePivotMask = 0n;\n   248→  let basePivotCount = 0;\n   249→  for (let r = 0; r < rank; r++) {\n   250→    if (basePivotValues[r]) {\n   251→      basePivotMask |= 1n << BigInt(r);\n   252→      basePivotCount++;\n   253→    }\n   254→  }\n   255→\n   256→  // Enumerate half A\n   257→  type HalfEntry = { pivotDelta: bigint; freeCount: number; freeMask: number };\n   258→\n   259→  // For halfA, store in a map: pivotDelta -> best (freeCount, freeMask)\n   260→  // But for MITM we need to combine, so store pivotDelta -> list sorted by (freeCount, lex)\n   261→  // Actually for efficiency, for each pivotDelta, keep only the best entry.\n   262→\n   263→  const mapA = new Map<string, { freeCount: number; freeMask: number; pivotFlips: bigint }>();\n   264→\n   265→  for (let mask = 0; mask < (1 << halfA); mask++) {\n   266→    let pivotFlips = 0n;\n   267→    let freeCount = 0;\n   268→    for (let f = 0; f < halfA; f++) {\n   269→      if (mask & (1 << f)) {\n   270→        freeCount++;\n   271→        for (const r of freeEffectOnPivots[f]) {\n   272→          pivotFlips ^= 1n << BigInt(r);\n   273→        }\n   274→      }\n   275→    }\n   276→\n   277→    const key = pivotFlips.toString();\n   278→    const existing = mapA.get(key);\n   279→    if (!existing || freeCount < existing.freeCount ||\n   280→        (freeCount === existing.freeCount && mask < existing.freeMask)) {\n   281→      mapA.set(key, { freeCount, freeMask: mask, pivotFlips });\n   282→    }\n   283→  }\n   284→\n   285→  let bestCount = numButtons + 1;\n   286→  let bestSolution: number[] | null = null;\n   287→\n   288→  // Enumerate half B and combine with half A\n   289→  for (let maskB = 0; maskB < (1 << halfB); maskB++) {\n   290→    let pivotFlipsB = 0n;\n   291→    let freeCountB = 0;\n   292→    for (let f = 0; f < halfB; f++) {\n   293→      if (maskB & (1 << f)) {\n   294→        freeCountB++;\n   295→        for (const r of freeEffectOnPivots[halfA + f]) {\n   296→          pivotFlipsB ^= 1n << BigInt(r);\n   297→        }\n   298→      }\n   299→    }\n   300→\n   301→    // The combined pivot state is: basePivotMask XOR pivotFlipsA XOR pivotFlipsB\n   302→    // The number of pivot vars set to 1 = popcount(basePivotMask ^ pivotFlipsA ^ pivotFlipsB)\n   303→    // We want to minimize: freeCountA + freeCountB + popcount(basePivotMask ^ pivotFlipsA ^ pivotFlipsB)\n   304→    //\n   305→    // For each B assignment, we need pivotFlipsA such that the total is minimized.\n   306→    // The desired: basePivotMask ^ pivotFlipsA ^ pivotFlipsB should have minimum popcount\n   307→    //   plus freeCountA should be minimum.\n   308→    //\n   309→    // We need: pivotFlipsA such that popcount(basePivotMask ^ pivotFlipsB ^ pivotFlipsA) + freeCountA is minimized.\n   310→    // Let needed = basePivotMask ^ pivotFlipsB. Then we want popcount(needed ^ pivotFlipsA) + freeCountA min.\n   311→    //\n   312→    // This is hard to optimize in general. But we can iterate over all entries in mapA.\n   313→    // With 2^20 entries in mapA and 2^20 in B, that's 2^40 which is too much.\n   314→    //\n   315→    // Alternative approach: we need a smarter MITM. Let me reconsider.\n   316→    //\n   317→    // Actually, for the GF(2) case, with up to 40 free variables,\n   318→    // we may need to accept that some pathological cases can't be solved in 5 seconds.\n   319→    // But in practice, 40 lights and 40 buttons with rank << 40 is unlikely in\n   320→    // well-formed puzzles. Let me optimize for realistic cases.\n   321→\n   322→    // For now, iterate mapA for each B (this works if mapA is small enough)\n   323→    // In practice with 20 free vars per half, mapA has up to 2^20 ≈ 1M entries\n   324→    // and we iterate 1M times for each of 1M B entries = 10^12, too slow.\n   325→\n   326→    // Better: for each B, compute the target pivotFlipsA = basePivotMask ^ pivotFlipsB\n   327→    // That would be ideal (all pivot vars become 0). But we need the closest match.\n   328→    // Store mapA keyed by pivotFlips, look up exact match (ideal case where pivotFlipsA = needed).\n   329→\n   330→    const needed = basePivotMask ^ pivotFlipsB;\n   331→    const key = needed.toString();\n   332→    const entryA = mapA.get(key);\n   333→\n   334→    if (entryA) {\n   335→      // This gives pivot state: basePivotMask ^ needed ^ pivotFlipsB = basePivotMask ^ basePivotMask = 0\n   336→      // So all pivot vars are 0. Total count = freeCountA + freeCountB + 0.\n   337→      const totalCount = entryA.freeCount + freeCountB;\n   338→\n   339→      if (totalCount < bestCount) {\n   340→        bestCount = totalCount;\n   341→        bestSolution = buildSolutionFromMITM(\n   342→          entryA.freeMask, maskB, halfA, halfB, freeVars,\n   343→          freeEffectOnPivots, basePivotMask, numButtons, rank, pivotCol\n   344→        );\n   345→      } else if (totalCount === bestCount) {\n   346→        const candidate = buildSolutionFromMITM(\n   347→          entryA.freeMask, maskB, halfA, halfB, freeVars,\n   348→          freeEffectOnPivots, basePivotMask, numButtons, rank, pivotCol\n   349→        );\n   350→        if (lexSmaller(candidate, bestSolution!, numButtons)) {\n   351→          bestSolution = candidate;\n   352→        }\n   353→      }\n   354→    }\n   355→  }\n   356→\n   357→  // Also consider solutions where some pivot vars are 1 (i.e., pressed).\n   358→  // The above only finds solutions where all pivot vars are 0.\n   359→  // But