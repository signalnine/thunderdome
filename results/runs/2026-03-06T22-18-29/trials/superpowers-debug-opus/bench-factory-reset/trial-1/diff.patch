freeMaskA >> fi) & 1;\n   227→      valB = (freeMaskB >> fi) & 1;\n   228→      fi++;\n   229→    } else if (pi < rank && pivotCol[pi] === btn) {\n   230→      valA = Number((pivotMaskA >> BigInt(pi)) & 1n);\n   231→      valB = Number((pivotMaskB >> BigInt(pi)) & 1n);\n   232→      pi++;\n   233→    } else {\n   234→      continue;\n   235→    }\n   236→\n   237→    if (valA !== valB) {\n   238→      // In set lex order: the solution that has this button pressed\n   239→      // when the other doesn't... We need to compare as sorted index SETS.\n   240→      // Set A is lex smaller if at the first element where they differ,\n   241→      // A's element is smaller.\n   242→      // Equivalently: at the first button index where exactly one solution\n   243→      // presses it, the solution that presses it is lexicographically\n   244→      // \"contains a smaller element\" which makes it smaller.\n   245→      // Wait, no. If A has button 2 pressed and B doesn't, but B has button 3 pressed,\n   246→      // then A = {..., 2, ...} and B = {..., 3, ...} and A is smaller because 2 < 3.\n   247→      // But we're scanning in order from 0 upward. At button 2, A=1, B=0.\n   248→      // A has an element (2) that B doesn't. B must have a later element to compensate\n   249→      // (since they have the same count). So A is lex smaller.\n   250→      // More generally: at the first difference, whichever solution has 1 is lex smaller.\n   251→      return valA > valB;\n   252→    }\n   253→  }\n   254→  return false;\n   255→}\n   256→\n   257→function buildResult(\n   258→  freeMask: number, pivotMask: bigint,\n   259→  freeVars: number[], pivotCol: number[],\n   260→  numButtons: number, rank: number\n   261→): number[] {\n   262→  const result: number[] = [];\n   263→  for (let f = 0; f < freeVars.length; f++) {\n   264→    if ((freeMask >> f) & 1) {\n   265→      result.push(freeVars[f]);\n   266→    }\n   267→  }\n   268→  for (let r = 0; r < rank; r++) {\n   269→    if ((pivotMask >> BigInt(r)) & 1n) {\n   270→      result.push(pivotCol[r]);\n   271→    }\n   272→  }\n   273→  return result.sort((a, b) => a - b);\n   274→}\n   275→\n   276→function solveToggleMITM(\n   277→  numButtons: number,\n   278→  rank: number,\n   279→  pivotCol: number[],\n   280→  freeVars: number[],\n   281→  freeEffectMask: bigint[],\n   282→  basePivotMask: bigint\n   283→): number[] {\n   284→  const numFree = freeVars.length;\n   285→  const halfA = Math.floor(numFree / 2);\n   286→  const halfB = numFree - halfA;\n   287→\n   288→  // For each halfA assignment, compute (pivotFlips, freeCount).\n   289→  // Group by pivotFlips, keep best per group.\n   290→  // But we also need to consider non-zero pivot states.\n   291→  //\n   292→  // Total cost = freeCountA + freeCountB + popcount(basePivotMask ^ pivotFlipsA ^ pivotFlipsB)\n   293→  //\n   294→  // For the MITM: for each B, we want to find the A that minimizes\n   295→  // freeCountA + popcount(basePivotMask ^ pivotFlipsB ^ pivotFlipsA)\n   296→  //\n   297→  // Key insight: group A entries by (pivotFlips, freeCount).\n   298→  // For each B, the ideal pivotFlipsA = basePivotMask ^ pivotFlipsB (makes pivot count 0).\n   299→  // But if that's not available, we need nearby entries.\n   300→  //\n   301→  // With rank ≤ 40, the pivot effect space is 2^rank. For large rank, the map can be huge\n   302→  // but the number of distinct effects is at most 2^halfA.\n   303→  //\n   304→  // Strategy: for each pivotFlips in mapA, store the minimum freeCount.\n   305→  // For each B, check the exact match first. If exact match gives total ≤ bestCount,\n   306→  // that's our candidate. But non-exact matches could also be better if freeCountA is\n   307→  // much smaller and only adds a few pivot presses.\n   308→  //\n   309→  // For correctness: we need to iterate all A entries for each B, which is O(2^halfA * 2^halfB).\n   310→  // But if halfA and halfB are each ~20, this is 2^40 which is too much.\n   311→  //\n   312→  // Better approach: for each B, look up the exact match (pivot count = 0),\n   313→  // and also maintain a global minimum across all A entries grouped by cost.\n   314→  // The minimum possible cost for any (A,B) pair where pivot is non-zero is at least\n   315→  // freeCountA_min + freeCountB + 1. So if exact match gives total ≤ freeCountA_min + freeCountB + 1,\n   316→  // no non-exact match can beat it.\n   317→\n   318→  // Build mapA: pivotFlips (as string) -> { freeCount, freeMask }\n   319→  // Also keep a sorted list of (freeCount, pivotFlips, freeMask) for the fallback\n   320→  const mapA = new Map<string, { freeCount: number; freeMask: number; pivotFlips: bigint }[]>();\n   321→  const allAEntries: { freeCount: number; freeMask: number; pivotFlips: bigint }[] = [];\n   322→\n   323→  {\n   324→    let currentPivotFlips = 0n;\n   325→    let currentFreeMask = 0;\n   326→\n   327→    const addEntry = () => {\n   328→      const freeCount = popcountNum(currentFreeMask);\n   329→      const entry = { freeCount, freeMask: currentFreeMask, pivotFlips: currentPivotFlips };\n   330→      const key = currentPivotFlips.toString();\n   331→      const list = mapA.get(key);\n   332→      if (list) {\n   333→        // Only keep if this is better or equal to existing\n   334→        if (freeCount < list[0].freeCount) {\n   335→          list.length = 0;\n   336→          list.push(entry);\n   337→        } else if (freeCount === list[0].freeCount) {\n   338→          list.push(entry);\n   339→        }\n   340→      } else {\n   341→        mapA.set(key, [entry]);\n   342→      }\n   343→      allAEntries.push(entry);\n   344→    };\n   345→\n   346→    addEntry(); // mask = 0\n   347→\n   348→    const totalA = 1 << halfA;\n   349→    for (let i = 1; i < totalA; i++) {\n   350→      const bitToFlip = ctz(i);\n   351→      currentFreeMask ^= (1 << bitToFlip);\n   352→      currentPivotFlips ^= freeEffectMask[bitToFlip];\n   353→      addEntry();\n   354→    }\n   355→  }\n   356→\n   357→  // Sort all A entries by freeCount for potential early termination\n   358→  allAEntries.sort((a, b) => a.freeCount - b.freeCount);\n   359→  const minFreeCountA = allAEntries[0].freeCount;\n   360→\n   361→  let bestCount = numButtons + 1;\n   362→  let bestFreeMaskFull = 0; // combined mask for all free vars\n   363→  let bestPivotMask = 0n;\n   364→\n   365→  // Enumerate half B using Gray code\n   366→  {\n   367→    let currentPivotFlipsB = 0n;\n   368→    let currentFreeMaskB = 0;\n   369→\n   370→    const processB = () => {\n   371→      const freeCountB = popcountNum(currentFreeMaskB);\n   372→\n   373→      // Try exact match first (makes all pivots 0)\n   374→      const needed = basePivotMask ^ currentPivotFlipsB;\n   375→      const key = needed.toString();\n   376→      const entriesA = mapA.get(key);\n   377→\n   378→      if (entriesA) {\n   379→        const entryA = entriesA[0]; // Best (lowest freeCount) for this pivotFlips\n   380→        const totalCount = entryA.freeCount + freeCountB;\n   381→\n   382→        if (totalCount < bestCount) {\n   383→          bestCount = totalCount;\n   384→          bestFreeMaskFull = entryA.freeMask | (currentFreeMaskB << halfA);\n   385→          bestPivotMask = 0n; // all pivots are 0\n   386→        } else if (totalCount === bestCount) {\n   387→          const candidateFreeMask = entryA.freeMask | (currentFreeMaskB << halfA);\n   388→          if (lexSmallerSolution(candidateFreeMask, 0n, bestFreeMaskFull, bestPivotMask,\n   389→                                  freeVars, pivotCol, numButtons, rank)) {\n   390→            bestFreeMaskFull = candidateFreeMask;\n   391→            bestPivotMask = 0n;\n   392→          }\n   393→        }\n   394→      }\n   395→\n   396→      // Check if non-exact matches could beat the current best\n   397→      // Minimum possible: minFreeCountA + freeCountB + 1 (at least 1 pivot pressed)\n   398→      if (minFreeCountA + freeCountB + 1 < bestCount) {\n   399→        // Need to check all A entries. But this is expensive for large halfA.\n   400→        // Limit: only check entries where freeCountA + freeCountB < bestCount\n   401→        for (const entryA of allAEntries) {\n   402→          if (entryA.freeCount + freeCountB >= bestCount) break; // sorted, so done\n   403→          const combinedPivot = basePivotMask ^ entryA.pivotFlips ^ currentPivotFlipsB;\n   404→          const pivotCount = popcount(combinedPivot);\n   405→          const totalCount = entryA.freeCount + freeCountB + pivotCount;\n   406→\n   407→          if (totalCount < bestCount) {\n   408→            bestCount = totalCount;\n   409→            bestFreeMaskFull = entryA.freeMask | (currentFreeMaskB << halfA);\n   410→            bestPivotMask = combinedPivot;\n   411→          } else if (totalCount === bestCount) {\n   412→            const candidateFreeMask = entryA.freeMask | (currentFreeMaskB << halfA);\n   413→            if (lexSmallerSolution(candidateFreeMask, combinedPivot, bestFreeMaskFull, bestPivotMask,\n   414→                                    freeVars, pivotCol, numButtons, rank)) {\n   415→              bestFreeMaskFull = candidateFreeMask;\n   416→              bestPivotMask = combinedPivot;\n   417→            }\n   418→          }\n   419→        }\n   420→      }\n   421→    };\n   422→\n   423→    processB(); // mask = 0\n   424→\n   425→    const totalB = 1 << halfB;\n   426→    for (let i = 1; i < totalB; i++) {\n   427→      const bitToFlip = ctz(i);\n   428→      currentFreeMaskB ^= (1 << bitToFlip);\n   429→      currentPivotFlipsB ^= freeEffectMask[halfA + bitToFlip];\n   430→      processB();\n   431→    }\n   432→  }\n   433→\n   434→  return buildResult(bestFreeMaskFull, bestPivotMask, freeVars, pivotCol, numButtons, rank);\n   435→}\n   436→\n   437→/**\n   438→ * Solve a counter puzzle over GF(p) using Gaussian elimination.\n   439→ */\n   440→export function solveCounter(\n   441→  lights: number[],\n   442→  buttons: number[][],\n   443→  modulus: number\n   444→): number[] | null {\n   445→  const numCounters = lights.length;\n   446→  const numButtons = buttons.length;\n   447→\n   448→  if (numButtons === 0) {\n   449→    return lights.some(v => v !== 0) ? null : [];\n   450→  }\n   451→\n   452→  // Build augmented matrix over GF(p)\n   453→  const matrix: number[][] = [];\n   454→  for (let i = 0; i < numCounters; i++) {\n   455→    const row = new Array(numButtons + 1).fill(0);\n   456→    for (let j = 0; j < numButtons; j++) {\n   457→      if (buttons[j].includes(i)) {\n   458→        row[j] = 1;\n   459→      }\n   460→    }\n   461→    row[numButtons] = lights[i] % modulus;\n   462→    matrix.push(row);\n   463→  }\n   464→\n   465→  // Gaussian elimination over GF(p)\n   466→  const pivotCol: number[] = [];\n   467→  const pivotRow: number[] = new Array(numButtons).fill(-1);\n   468→  let rank = 0;\n   469→\n   470→  for (let col = 0; col < numButtons; col++) {\n   471→    let found = -1;\n   472→    for (let row = rank; row < numCounters; row++) {\n   473→      if (matrix[row][col] !== 0) {\n   474→        found = row;\n   475→        break;\n   476→      }\n   477→    }\n   478→    if (found === -1) continue;\n   479→\n   480→    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n   481→\n   482→    const pivotVal = matrix[rank][col];\n   483→    const inv = modInverse(pivotVal, modulus);\n   484→    for (let c = 0; c <= numButtons; c++) {\n   485→      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;\n   486→    }\n   487→\n   488→    for (let row = 0; row < numCounters; row++) {\n   489→      if (row !== rank && matrix[row][col] !== 0) {\n   490→        const factor = matrix[row][col];\n   491→        for (let c = 0; c <= numButtons; c++) {\n   492→          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;\n   493→        }\n   494→      }\n   495→    }\n   496→\n   497→ 