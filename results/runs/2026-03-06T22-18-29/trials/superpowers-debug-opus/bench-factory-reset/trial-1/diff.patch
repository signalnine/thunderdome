nt < existing.freeCount ||\n        (freeCount === existing.freeCount && mask < existing.freeMask)) {\n      mapA.set(key, { freeCount, freeMask: mask, pivotFlips });\n    }\n  }\n\n  let bestCount = numButtons + 1;\n  let bestSolution: number[] | null = null;\n\n  // Enumerate half B and combine with half A\n  for (let maskB = 0; maskB < (1 << halfB); maskB++) {\n    let pivotFlipsB = 0n;\n    let freeCountB = 0;\n    for (let f = 0; f < halfB; f++) {\n      if (maskB & (1 << f)) {\n        freeCountB++;\n        for (const r of freeEffectOnPivots[halfA + f]) {\n          pivotFlipsB ^= 1n << BigInt(r);\n        }\n      }\n    }\n\n    // The combined pivot state is: basePivotMask XOR pivotFlipsA XOR pivotFlipsB\n    // The number of pivot vars set to 1 = popcount(basePivotMask ^ pivotFlipsA ^ pivotFlipsB)\n    // We want to minimize: freeCountA + freeCountB + popcount(basePivotMask ^ pivotFlipsA ^ pivotFlipsB)\n    //\n    // For each B assignment, we need pivotFlipsA such that the total is minimized.\n    // The desired: basePivotMask ^ pivotFlipsA ^ pivotFlipsB should have minimum popcount\n    //   plus freeCountA should be minimum.\n    //\n    // We need: pivotFlipsA such that popcount(basePivotMask ^ pivotFlipsB ^ pivotFlipsA) + freeCountA is minimized.\n    // Let needed = basePivotMask ^ pivotFlipsB. Then we want popcount(needed ^ pivotFlipsA) + freeCountA min.\n    //\n    // This is hard to optimize in general. But we can iterate over all entries in mapA.\n    // With 2^20 entries in mapA and 2^20 in B, that's 2^40 which is too much.\n    //\n    // Alternative approach: we need a smarter MITM. Let me reconsider.\n    //\n    // Actually, for the GF(2) case, with up to 40 free variables,\n    // we may need to accept that some pathological cases can't be solved in 5 seconds.\n    // But in practice, 40 lights and 40 buttons with rank << 40 is unlikely in\n    // well-formed puzzles. Let me optimize for realistic cases.\n\n    // For now, iterate mapA for each B (this works if mapA is small enough)\n    // In practice with 20 free vars per half, mapA has up to 2^20 ≈ 1M entries\n    // and we iterate 1M times for each of 1M B entries = 10^12, too slow.\n\n    // Better: for each B, compute the target pivotFlipsA = basePivotMask ^ pivotFlipsB\n    // That would be ideal (all pivot vars become 0). But we need the closest match.\n    // Store mapA keyed by pivotFlips, look up exact match (ideal case where pivotFlipsA = needed).\n\n    const needed = basePivotMask ^ pivotFlipsB;\n    const key = needed.toString();\n    const entryA = mapA.get(key);\n\n    if (entryA) {\n      // This gives pivot state: basePivotMask ^ needed ^ pivotFlipsB = basePivotMask ^ basePivotMask = 0\n      // So all pivot vars are 0. Total count = freeCountA + freeCountB + 0.\n      const totalCount = entryA.freeCount + freeCountB;\n\n      if (totalCount < bestCount) {\n        bestCount = totalCount;\n        bestSolution = buildSolutionFromMITM(\n          entryA.freeMask, maskB, halfA, halfB, freeVars,\n          freeEffectOnPivots, basePivotMask, numButtons, rank, pivotCol\n        );\n      } else if (totalCount === bestCount) {\n        const candidate = buildSolutionFromMITM(\n          entryA.freeMask, maskB, halfA, halfB, freeVars,\n          freeEffectOnPivots, basePivotMask, numButtons, rank, pivotCol\n        );\n        if (lexSmaller(candidate, bestSolution!, numButtons)) {\n          bestSolution = candidate;\n        }\n      }\n    }\n  }\n\n  // Also consider solutions where some pivot vars are 1 (i.e., pressed).\n  // The above only finds solutions where all pivot vars are 0.\n  // But pivot vars being 1 means they're pressed too, contributing to count.\n  // We actually need to also consider non-exact matches where the pivot count overhead\n  // is compensated by fewer free presses.\n  //\n  // For a full MITM, we'd need to consider all combinations, which gets complex.\n  // Let's handle this more carefully:\n  // The total count = sum(free vars pressed) + sum(pivot vars that are 1)\n  // where pivot var r is 1 iff basePivotValues[r] XOR (contributions from free vars)\n  //\n  // For exact MITM match (needed key found), all pivot vars are 0.\n  // For inexact matches, some pivot vars are 1.\n  //\n  // Actually, the approach above might miss solutions where pressing fewer free variables\n  // but having some pivot variables pressed gives a lower total. Let me reconsider.\n  //\n  // For a correct MITM: we should enumerate ALL half-A possibilities,\n  // for each computing (freeCountA, pivotEffect). Then for each half-B,\n  // compute the combined pivot state and total count.\n  //\n  // But this is O(2^halfA * 2^halfB) = O(2^numFree) which we're trying to avoid.\n  //\n  // The key insight: if the ideal lookup doesn't find a match, it means we need\n  // a different approach. Let's try: group mapA by pivotFlips, and for each B,\n  // instead of trying all A entries, try to find the A entry that minimizes\n  // freeCountA + popcount(pivotFlipsA XOR needed).\n  //\n  // This is a minimum weight codeword problem which is hard in general.\n  // For practical purposes, let's also iterate over \"close\" matches.\n  //\n  // Actually, let's just use a different approach for the MITM:\n  // Store ALL half-A entries. For each half-B, compute needed, and look up\n  // not just exact match but consider pivotCount too.\n  //\n  // Since the total = freeCountA + freeCountB + popcount(combined_pivot),\n  // and combined_pivot = needed ^ pivotFlipsA,\n  // we want to minimize freeCountA + popcount(needed ^ pivotFlipsA).\n  //\n  // Let's group mapA entries by freeCount, and for each freeCount level,\n  // check if there's a good match. This is still hard in general.\n  //\n  // Pragmatic approach: just store all A entries, and for each B iterate\n  // through all A entries. Cap the search.\n\n  if (bestSolution === null) {\n    // Fallback: full enumeration (only if MITM exact match failed)\n    // Try all mapA entries for each mapB\n    const allA = Array.from(mapA.values());\n\n    for (let maskB = 0; maskB < (1 << halfB); maskB++) {\n      let pivotFlipsB = 0n;\n      let freeCountB = 0;\n      for (let f = 0; f < halfB; f++) {\n        if (maskB & (1 << f)) {\n          freeCountB++;\n          for (const r of freeEffectOnPivots[halfA + f]) {\n            pivotFlipsB ^= 1n << BigInt(r);\n          }\n        }\n      }\n\n      for (const entryA of allA) {\n        const combinedPivot = basePivotMask ^ entryA.pivotFlips ^ pivotFlipsB;\n        const pivotCount = popcount64(combinedPivot);\n        const totalCount = entryA.freeCount + freeCountB + pivotCount;\n\n        if (totalCount < bestCount) {\n          bestCount = totalCount;\n          bestSolution = buildSolutionFromMITM(\n            entryA.freeMask, maskB, halfA, halfB, freeVars,\n            freeEffectOnPivots, basePivotMask, numButtons, rank, pivotCol\n          );\n        } else if (totalCount === bestCount && bestSolution) {\n          const candidate = buildSolutionFromMITM(\n            entryA.freeMask, maskB, halfA, halfB, freeVars,\n            freeEffectOnPivots, basePivotMask, numButtons, rank, pivotCol\n          );\n          if (lexSmaller(candidate, bestSolution, numButtons)) {\n            bestSolution = candidate;\n          }\n        }\n      }\n    }\n  }\n\n  if (!bestSolution) return null;\n\n  const result: number[] = [];\n  for (let i = 0; i < numButtons; i++) {\n    if (bestSolution[i]) result.push(i);\n  }\n  return result;\n}\n\nfunction popcount64(n: bigint): number {\n  let count = 0;\n  while (n > 0n) {\n    n &= n - 1n;\n    count++;\n  }\n  return count;\n}\n\nfunction buildSolutionFromMITM(\n  freeMaskA: number,\n  freeMaskB: number,\n  halfA: number,\n  halfB: number,\n  freeVars: number[],\n  freeEffectOnPivots: number[][],\n  basePivotMask: bigint,\n  numButtons: number,\n  rank: number,\n  pivotCol: number[]\n): number[] {\n  const solution = new Array(numButtons).fill(0);\n\n  // Set free variables\n  for (let f = 0; f < halfA; f++) {\n    if (freeMaskA & (1 << f)) {\n      solution[freeVars[f]] = 1;\n    }\n  }\n  for (let f = 0; f < halfB; f++) {\n    if (freeMaskB & (1 << f)) {\n      solution[freeVars[halfA + f]] = 1;\n    }\n  }\n\n  // Compute pivot variables\n  let pivotMask = basePivotMask;\n  for (let fi = 0; fi < freeVars.length; fi++) {\n    if (solution[freeVars[fi]]) {\n      for (const r of freeEffectOnPivots[fi]) {\n        pivotMask ^= 1n << BigInt(r);\n      }\n    }\n  }\n\n  for (let r = 0; r < rank; r++) {\n    solution[pivotCol[r]] = Number((pivotMask >> BigInt(r)) & 1n);\n  }\n\n  return solution;\n}\n\n/**\n * Solve a counter puzzle over GF(p) using Gaussian elimination.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix over GF(p)\n  // Each row represents a counter equation\n  // matrix[i][j] = 1 if button j affects counter i, 0 otherwise\n  // matrix[i][numButtons] = target value for counter i\n\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = lights[i];\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p)\n  const pivotCol: number[] = [];\n  const pivotRow: number[] = new Array(numButtons).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    // Find pivot row\n    let found = -1;\n    for (let row = rank; row < numCounters; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n\n    // Normalize pivot row (multiply by modular inverse of pivot element)\n    const pivotVal = matrix[rank][col];\n    const inv = modInverse(pivotVal, modulus);\n    for (let c = 0; c <= numButtons; c++) {\n      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;\n    }\n\n    // Eliminate column from all other rows\n    for (let row = 0; row < numCounters; row++) {\n      if (row !== rank && matrix[row][col] !== 0) {\n        const factor = matrix[row][col];\n        for (let c = 0; c <= numButtons; c++) {\n          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = rank;\n    rank++;\n  }\n\n  // Check for inconsistency\n  for (let row = rank; row < numCounters; row++) {\n    if (matrix[row][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // For each assignment of free variables (each 0..modulus-1),\n  // compute total presses and find minimum.\n  // Total combinations = modulus^numFree\n  // For small numFree, enumerate directly.\n  // For larger numFree, use MITM or IDA*.\n\n  // Precompute: for each pivot row, the coefficients of free variables\n  const pivotFreeCoeffs: number[][] = []; // pivotFreeCoeffs[r][f] = coefficient of freeVars[f] in row r\n  const pivotBaseValues: number[] = []; // base value of pivot var (when all free = 0)\n  for (let r = 0; r < rank; r++) {\n    const coeffs: number[] = [];\n    for (const fv of freeVars) {\n      // In reduced form, pivot var = target - sum(coeff * free_var) mod p\n      // The coefficient in the matrix is the amount to subtract\n      coeffs.push(matrix[r][fv]);\n    }\n    pivotFreeCoeffs.push(coeffs);\n    pivotBaseValues.push(matrix[r][numButtons]);\n  }\n\n  // Estimate search space\n  const searchSpace = Math.pow(modulus, numFree);\n\n  if (numFree === 0 || searchSpace <= 5000000) {\n    return solveCounterDirect(\n      numButtons, modulus, rank, pivotCol, freeVars, numFree,\n      pivotFreeCoeffs, pivotBaseValues\n    );\n  } else {\n    return solveCounterMITM(\n      numButtons, modulus, rank, pivotCol, freeVars,\n      pivotFreeCoeffs, pivotBaseValues\n    );\n  }\n}\n\nfunction solveCounterDirect(\n  numButtons: number,\n  modulus: number,\n  rank: number,\n  pivotCol: number[],\n  freeVars: number[],\n  numFree: number,\n  pivotFreeCoeffs: number[][],\n  pivotBaseValues: number[]\n): number[] | null {\n  let bestSum = Infinity;\n  let bestSolution: number[] | null = null;\n\n  // Enumerate all assignments of free variables\n  const freeValues = new Array(numFree).fill(0);\n\n  const iterate = (): void => {\n    while (true) {\n      // Compute solution for current free variable assignment\n      const solution = new Array(numButtons).fill(0);\n      let sum = 0;\n\n      // Set free variables\n      for (let f = 0; f < numFree; f++) {\n        solution[freeVars[f]] = freeValues[f];\n        sum += freeValues[f];\n      }\n\n      // Compute pivot variables\n      for (let r = 0; r < rank; r++) {\n        let val = pivotBaseValues[r];\n        for (let f = 0; f < numFree; f++) {\n          val = ((val - pivotFreeCoeffs[r][f] * freeValues[f]) % modulus + modulus) % modulus;\n        }\n        solution[pivotCol[r]] = val;\n        sum += val;\n      }\n\n      if (sum < bestSum || (sum === bestSum && lexSmallerArr(solution, bestSolution!, numButtons))) {\n        bestSum = sum;\n        bestSolution = [...solution];\n      }\n\n      // Increment freeValues (odometer-style)\n      let carry = true;\n      for (let f = numFree - 1; f >= 0 && carry; f--) {\n        freeValues[f]++;\n        if (freeValues[f] >= modulus) {\n          freeValues[f] = 0;\n        } else {\n          carry = false;\n        }\n      }\n      if (carry) break; // All combinations exhausted\n    }\n  };\n\n  iterate();\n  return bestSolution;\n}\n\nfunction lexSmallerArr(a: number[], b: number[], n: number): boolean {\n  for (let i = 0; i < n; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\nfunction solveCounterMITM(\n  numButtons: number,\n  modulus: number,\n  rank: number,\n  pivotCol: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotBaseValues: number[]\n): number[] | null {\n  const numFree = freeVars.length;\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n\n  // For each half-A assignment, compute:\n  // 1. The partial effect on each pivot variable (mod p)\n  // 2. The sum of free variable values in this half\n  // Store as: key = tuple of partial pivot effects -> best (sum, assignment)\n\n  // Enumerate half A\n  const mapA = new Map<string, { sum: number; values: number[] }>();\n  const freeValuesA = new Array(halfA).fill(0);\n\n  const iterateA = (): void => {\n    while (true) {\n      // Compute partial pivot effects\n      const effects: number[] = [];\n      let sum = 0;\n      for (let f = 0; f < halfA; f++) {\n        sum += freeValuesA[f];\n      }\n      for (let r = 0; r < rank; r++) {\n        let effect = 0;\n        for (let f = 0; f < halfA; f++) {\n          effect = (effect + pivotFreeCoeffs[r][f] * freeValuesA[f]) % modulus;\n        }\n        effects.push(effect);\n      }\n\n      const key = effects.join(',');\n      const existing = mapA.get(key);\n      if (!existing || sum < existing.sum ||\n          (sum === existing.sum && lexSmallerArrDirect(freeValuesA, existing.values))) {\n        mapA.set(key, { sum, values: [...freeValuesA] });\n      }\n\n      // Increment\n      let carry = true;\n      for (let f = halfA - 1; f >= 0 && carry; f--) {\n        freeValuesA[f]++;\n        if (freeValuesA[f] >= modulus) {\n          freeValuesA[f] = 0;\n        } else {\n        