/ Since the total = freeCountA + freeCountB + popcount(combined_pivot),\n   393→  // and combined_pivot = needed ^ pivotFlipsA,\n   394→  // we want to minimize freeCountA + popcount(needed ^ pivotFlipsA).\n   395→  //\n   396→  // Let's group mapA entries by freeCount, and for each freeCount level,\n   397→  // check if there's a good match. This is still hard in general.\n   398→  //\n   399→  // Pragmatic approach: just store all A entries, and for each B iterate\n   400→  // through all A entries. Cap the search.\n   401→\n   402→  if (bestSolution === null) {\n   403→    // Fallback: full enumeration (only if MITM exact match failed)\n   404→    // Try all mapA entries for each mapB\n   405→    const allA = Array.from(mapA.values());\n   406→\n   407→    for (let maskB = 0; maskB < (1 << halfB); maskB++) {\n   408→      let pivotFlipsB = 0n;\n   409→      let freeCountB = 0;\n   410→      for (let f = 0; f < halfB; f++) {\n   411→        if (maskB & (1 << f)) {\n   412→          freeCountB++;\n   413→          for (const r of freeEffectOnPivots[halfA + f]) {\n   414→            pivotFlipsB ^= 1n << BigInt(r);\n   415→          }\n   416→        }\n   417→      }\n   418→\n   419→      for (const entryA of allA) {\n   420→        const combinedPivot = basePivotMask ^ entryA.pivotFlips ^ pivotFlipsB;\n   421→        const pivotCount = popcount64(combinedPivot);\n   422→        const totalCount = entryA.freeCount + freeCountB + pivotCount;\n   423→\n   424→        if (totalCount < bestCount) {\n   425→          bestCount = totalCount;\n   426→          bestSolution = buildSolutionFromMITM(\n   427→            entryA.freeMask, maskB, halfA, halfB, freeVars,\n   428→            freeEffectOnPivots, basePivotMask, numButtons, rank, pivotCol\n   429→          );\n   430→        } else if (totalCount === bestCount && bestSolution) {\n   431→          const candidate = buildSolutionFromMITM(\n   432→            entryA.freeMask, maskB, halfA, halfB, freeVars,\n   433→            freeEffectOnPivots, basePivotMask, numButtons, rank, pivotCol\n   434→          );\n   435→          if (lexSmaller(candidate, bestSolution, numButtons)) {\n   436→            bestSolution = candidate;\n   437→          }\n   438→        }\n   439→      }\n   440→    }\n   441→  }\n   442→\n   443→  if (!bestSolution) return null;\n   444→\n   445→  const result: number[] = [];\n   446→  for (let i = 0; i < numButtons; i++) {\n   447→    if (bestSolution[i]) result.push(i);\n   448→  }\n   449→  return result;\n   450→}\n   451→\n   452→function popcount64(n: bigint): number {\n   453→  let count = 0;\n   454→  while (n > 0n) {\n   455→    n &= n - 1n;\n   456→    count++;\n   457→  }\n   458→  return count;\n   459→}\n   460→\n   461→function buildSolutionFromMITM(\n   462→  freeMaskA: number,\n   463→  freeMaskB: number,\n   464→  halfA: number,\n   465→  halfB: number,\n   466→  freeVars: number[],\n   467→  freeEffectOnPivots: number[][],\n   468→  basePivotMask: bigint,\n   469→  numButtons: number,\n   470→  rank: number,\n   471→  pivotCol: number[]\n   472→): number[] {\n   473→  const solution = new Array(numButtons).fill(0);\n   474→\n   475→  // Set free variables\n   476→  for (let f = 0; f < halfA; f++) {\n   477→    if (freeMaskA & (1 << f)) {\n   478→      solution[freeVars[f]] = 1;\n   479→    }\n   480→  }\n   481→  for (let f = 0; f < halfB; f++) {\n   482→    if (freeMaskB & (1 << f)) {\n   483→      solution[freeVars[halfA + f]] = 1;\n   484→    }\n   485→  }\n   486→\n   487→  // Compute pivot variables\n   488→  let pivotMask = basePivotMask;\n   489→  for (let fi = 0; fi < freeVars.length; fi++) {\n   490→    if (solution[freeVars[fi]]) {\n   491→      for (const r of freeEffectOnPivots[fi]) {\n   492→        pivotMask ^= 1n << BigInt(r);\n   493→      }\n   494→    }\n   495→  }\n   496→\n   497→  for (let r = 0; r < rank; r++) {\n   498→    solution[pivotCol[r]] = Number((pivotMask >> BigInt(r)) & 1n);\n   499→  }\n   500→\n   501→  return solution;\n   502→}\n   503→\n   504→/**\n   505→ * Solve a counter puzzle over GF(p) using Gaussian elimination.\n   506→ */\n   507→export function solveCounter(\n   508→  lights: number[],\n   509→  buttons: number[][],\n   510→  modulus: number\n   511→): number[] | null {\n   512→  const numCounters = lights.length;\n   513→  const numButtons = buttons.length;\n   514→\n   515→  // Build augmented matrix over GF(p)\n   516→  // Each row represents a counter equation\n   517→  // matrix[i][j] = 1 if button j affects counter i, 0 otherwise\n   518→  // matrix[i][numButtons] = target value for counter i\n   519→\n   520→  const matrix: number[][] = [];\n   521→  for (let i = 0; i < numCounters; i++) {\n   522→    const row = new Array(numButtons + 1).fill(0);\n   523→    for (let j = 0; j < numButtons; j++) {\n   524→      if (buttons[j].includes(i)) {\n   525→        row[j] = 1;\n   526→      }\n   527→    }\n   528→    row[numButtons] = lights[i];\n   529→    matrix.push(row);\n   530→  }\n   531→\n   532→  // Gaussian elimination over GF(p)\n   533→  const pivotCol: number[] = [];\n   534→  const pivotRow: number[] = new Array(numButtons).fill(-1);\n   535→  let rank = 0;\n   536→\n   537→  for (let col = 0; col < numButtons; col++) {\n   538→    // Find pivot row\n   539→    let found = -1;\n   540→    for (let row = rank; row < numCounters; row++) {\n   541→      if (matrix[row][col] !== 0) {\n   542→        found = row;\n   543→        break;\n   544→      }\n   545→    }\n   546→    if (found === -1) continue;\n   547→\n   548→    // Swap rows\n   549→    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n   550→\n   551→    // Normalize pivot row (multiply by modular inverse of pivot element)\n   552→    const pivotVal = matrix[rank][col];\n   553→    const inv = modInverse(pivotVal, modulus);\n   554→    for (let c = 0; c <= numButtons; c++) {\n   555→      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;\n   556→    }\n   557→\n   558→    // Eliminate column from all other rows\n   559→    for (let row = 0; row < numCounters; row++) {\n   560→      if (row !== rank && matrix[row][col] !== 0) {\n   561→        const factor = matrix[row][col];\n   562→        for (let c = 0; c <= numButtons; c++) {\n   563→          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;\n   564→        }\n   565→      }\n   566→    }\n   567→\n   568→    pivotCol.push(col);\n   569→    pivotRow[col] = rank;\n   570→    rank++;\n   571→  }\n   572→\n   573→  // Check for inconsistency\n   574→  for (let row = rank; row < numCounters; row++) {\n   575→    if (matrix[row][numButtons] !== 0) {\n   576→      return null;\n   577→    }\n   578→  }\n   579→\n   580→  // Identify free variables\n   581→  const freeVars: number[] = [];\n   582→  for (let col = 0; col < numButtons; col++) {\n   583→    if (pivotRow[col] === -1) {\n   584→      freeVars.push(col);\n   585→    }\n   586→  }\n   587→\n   588→  const numFree = freeVars.length;\n   589→\n   590→  // For each assignment of free variables (each 0..modulus-1),\n   591→  // compute total presses and find minimum.\n   592→  // Total combinations = modulus^numFree\n   593→  // For small numFree, enumerate directly.\n   594→  // For larger numFree, use MITM or IDA*.\n   595→\n   596→  // Precompute: for each pivot row, the coefficients of free variables\n   597→  const pivotFreeCoeffs: number[][] = []; // pivotFreeCoeffs[r][f] = coefficient of freeVars[f] in row r\n   598→  const pivotBaseValues: number[] = []; // base value of pivot var (when all free = 0)\n   599→  for (let r = 0; r < rank; r++) {\n   600→    const coeffs: number[] = [];\n   601→    for (const fv of freeVars) {\n   602→      // In reduced form, pivot var = target - sum(coeff * free_var) mod p\n   603→      // The coefficient in the matrix is the amount to subtract\n   604→      coeffs.push(matrix[r][fv]);\n   605→    }\n   606→    pivotFreeCoeffs.push(coeffs);\n   607→    pivotBaseValues.push(matrix[r][numButtons]);\n   608→  }\n   609→\n   610→  // Estimate search space\n   611→  const searchSpace = Math.pow(modulus, numFree);\n   612→\n   613→  if (numFree === 0 || searchSpace <= 5000000) {\n   614→    return solveCounterDirect(\n   615→      numButtons, modulus, rank, pivotCol, freeVars, numFree,\n   616→      pivotFreeCoeffs, pivotBaseValues\n   617→    );\n   618→  } else {\n   619→    return solveCounterMITM(\n   620→      numButtons, modulus, rank, pivotCol, freeVars,\n   621→      pivotFreeCoeffs, pivotBaseValues\n   622→    );\n   623→  }\n   624→}\n   625→\n   626→function solveCounterDirect(\n   627→  numButtons: number,\n   628→  modulus: number,\n   629→  rank: number,\n   630→  pivotCol: number[],\n   631→  freeVars: number[],\n   632→  numFree: number,\n   633→  pivotFreeCoeffs: number[][],\n   634→  pivotBaseValues: number[]\n   635→): number[] | null {\n   636→  let bestSum = Infinity;\n   637→  let bestSolution: number[] | null = null;\n   638→\n   639→  // Enumerate all assignments of free variables\n   640→  const freeValues = new Array(numFree).fill(0);\n   641→\n   642→  const iterate = (): void => {\n   643→    while (true) {\n   644→      // Compute solution for current free variable assignment\n   645→      const solution = new Array(numButtons).fill(0);\n   646→      let sum = 0;\n   647→\n   648→      // Set free variables\n   649→      for (let f = 0; f < numFree; f++) {\n   650→        solution[freeVars[f]] = freeValues[f];\n   651→        sum += freeValues[f];\n   652→      }\n   653→\n   654→      // Compute pivot variables\n   655→      for (let r = 0; r < rank; r++) {\n   656→        let val = pivotBaseValues[r];\n   657→        for (let f = 0; f < numFree; f++) {\n   658→          val = ((val - pivotFreeCoeffs[r][f] * freeValues[f]) % modulus + modulus) % modulus;\n   659→        }\n   660→        solution[pivotCol[r]] = val;\n   661→        sum += val;\n   662→      }\n   663→\n   664