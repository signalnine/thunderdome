}\n+      if (lexSmaller(candidate, bestResult)) {\n+        bestResult = candidate;\n+      }\n+    }\n+  };\n+\n+  // Try all-zero\n+  tryFreeAssignment(new Array(numFree).fill(0));\n+\n+  // Try each single free var set to 1\n+  for (let f = 0; f < numFree; f++) {\n+    const assign = new Array(numFree).fill(0);\n+    assign[f] = 1;\n+    tryFreeAssignment(assign);\n+  }\n+\n+  // Try pairs\n+  if (numFree <= 40) {\n+    for (let f1 = 0; f1 < numFree; f1++) {\n+      for (let f2 = f1 + 1; f2 < numFree; f2++) {\n+        const assign = new Array(numFree).fill(0);\n+        assign[f1] = 1;\n+        assign[f2] = 1;\n+        tryFreeAssignment(assign);\n+      }\n+    }\n+  }\n+\n+  // Do the proper MITM enumeration for both halves\n+  // Enumerate all 2^half1 assignments\n+  const half1Assignments = 1 << half1;\n+  const half2Assignments = 1 << half2;\n+\n+  if (half1 <= 20 && half2 <= 20) {\n+    for (let m1 = 0; m1 < half1Assignments; m1++) {\n+      for (let m2 = 0; m2 < half2Assignments; m2++) {\n+        const assign = new Array(numFree).fill(0);\n+        for (let f = 0; f < half1; f++) {\n+          if ((m1 >> f) & 1) assign[f] = 1;\n+        }\n+        for (let f = 0; f < half2; f++) {\n+          if ((m2 >> f) & 1) assign[half1 + f] = 1;\n+        }\n+        tryFreeAssignment(assign);\n+      }\n+    }\n+  }\n+\n+  return bestResult;\n+}\n+\n+/**\n+ * Solve a counter puzzle over GF(p) using Gaussian elimination.\n+ *\n+ * We model: for each counter j: sum_i (A[j][i] * x[i]) ≡ target[j] (mod p)\n+ * where A[j][i] = 1 if button i affects counter j, x[i] ∈ {0, ..., p-1}.\n+ *\n+ * We want the solution with minimum total presses (sum of x[i]),\n+ * breaking ties lexicographically.\n+ */\n+export function solveCounter(\n+  lights: number[],\n+  buttons: number[][],\n+  modulus: number,\n+): number[] | null {\n+  const numCounters = lights.length;\n+  const numButtons = buttons.length;\n+  const p = modulus;\n+\n+  // Build augmented matrix over GF(p).\n+  // 