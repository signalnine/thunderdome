ons; col++) {\n+    // Find a row with a 1 in this column, at or below 'rank'.\n+    let found = -1;\n+    for (let r = rank; r < numLights; r++) {\n+      if ((rows[r] >> BigInt(col)) & 1n) {\n+        found = r;\n+        break;\n+      }\n+    }\n+    if (found === -1) continue;\n+\n+    // Swap rows\n+    [rows[rank], rows[found]] = [rows[found], rows[rank]];\n+    pivotRow[col] = rank;\n+\n+    // Eliminate this column from all other rows\n+    for (let r = 0; r < numLights; r++) {\n+      if (r !== rank && ((rows[r] >> BigInt(col)) & 1n)) {\n+        rows[r] ^= rows[rank];\n+      }\n+    }\n+    rank++;\n+  }\n+\n+  // Check consistency: any row that is all zeros in button columns but 1 in target column\n+  for (let r = 0; r < numLights; r++) {\n+    const buttonBits = rows[r] & ((1n << BigInt(numButtons)) - 1n);\n+    const targetBit = (rows[r] >> BigInt(numButtons)) & 1n;\n+    if (buttonBits === 0n && targetBit === 1n) {\n+      return null;\n+    }\n+  }\n+\n+  // Identify free variables (columns without pivots).\n+  const freeVars: number[] = [];\n+  for (let col = 0; col < numButtons; col++) {\n+    if (pivotRow[col] === -1) {\n+      freeVars.push(col);\n+    }\n+  }\n+\n+  // Enumerate all 2^(freeVars.length) assignments to free variables.\n+  // For each, compute the determined pivot variables and evaluate total presses.\n+  // Keep the solution with min presses, then lex smallest.\n+  const numFree = freeVars.length;\n+\n+  // With up to 40 buttons, free vars can be large. But rank ≤ 40 and numButtons ≤ 40,\n+  // so numFree = numButtons - rank. In the worst case this could be ~40 but that would\n+  // mean rank=0, so all buttons are free and target must be all false.\n+  // For practical purposes, if numFree > 25 we need a smarter approach.\n+  // However, with up to 40 lights constraining things, rank is typically close to numButtons.\n+  // We'll handle the case where numFree is large with a greedy/BFS approach.\n+\n+  if (numFree > 20) {\n+    /