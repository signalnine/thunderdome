+    }\n+    // Back-substitute for pivot variables\n+    for (let col = numButtons - 1; col >= 0; col--) {\n+      if (pivotRow[col] === -1) continue;\n+      const r = pivotRow[col];\n+      let val = matrix[r][numButtons];\n+      for (let c = 0; c < numButtons; c++) {\n+        if (c !== col) {\n+          val = (((val - matrix[r][c] * solution[c]) % p) + p) % p;\n+        }\n+      }\n+      solution[col] = val % p;\n+    }\n+    return solution;\n+  };\n+\n+  let bestResult: number[] | null = null;\n+  let bestTotal = Infinity;\n+\n+  const updateBest = (solution: number[]) => {\n+    const total = solution.reduce((a, b) => a + b, 0);\n+    if (total < bestTotal) {\n+      bestTotal = total;\n+      bestResult = [...solution];\n+    } else if (total === bestTotal && bestResult !== null) {\n+      if (lexSmallerArr(solution, bestResult)) {\n+        bestResult = [...solution];\n+      }\n+    }\n+  };\n+\n+  if (numFree === 0 || totalCombinations <= 1_000_000) {\n+    // Enumerate all combinations\n+    const freeAssign = new Array(numFree).fill(0);\n+\n+    const enumerate = (idx: number) => {\n+      if (idx === numFree) {\n+        const solution = computeSolution(freeAssign);\n+        updateBest(solution);\n+        return;\n+      }\n+      for (let v = 0; v < p; v++) {\n+        freeAssign[idx] = v;\n+        enumerate(idx + 1);\n+      }\n+    };\n+\n+    enumerate(0);\n+  } else {\n+    // Too many combinations. Use meet-in-the-middle or heuristic.\n+    // Split free variables in half and enumerate.\n+    solveCounterLargeFree(\n+      matrix, pivotRow, freeVars, numButtons, p, updateBest, computeSolution\n+    );\n+  }\n+\n+  return bestResult;\n+}\n+\n+function lexSmallerArr(a: number[], b: number[]): boolean {\n+  for (let i = 0; i < a.length; i++) {\n+    if (a[i] < b[i]) return true;\n+    if (a[i] > b[i]) return false;\n+  }\n+  return false;\n+}\n+\n+function solveCounterLargeFree(\n+  matrix: number[][],\n+  pivotRow: number[],\n+  freeVars: number[],\n+  numButtons: number,\n+  p: number,\n+  updateBest: (solution: number[]) => void,\n+  computeSolution: (freeAssign: number[]) => number[],\n+): void {\n+  const numFree = freeVars.length;\n+\n+  // Try all-zero assignment\n+  updateBest(computeSolution(new Array(numFree).fill(0)));\n+\n+  // Try each free variable set to each value 1..p-1\n+  for (let f = 0; f < numFree; f++) {\n+    for (let v = 1; v < p; v++) {\n+      const assign = new Array(numFree).fill(0);\n+      assign[f] = v;\n+      updateBest(computeSolution(assign));\n+    }\n+  }\n+\n+  // Try pairs of free variables\n+  for (let f1 = 0; f1 < numFree; f1++) {\n+    for (let f2 = f1 + 1; f2 < numFree; f2++) {\n+      for (let v1 = 1; v1 < p; v1++) {\n+        for (let v2 = 1; v2 < p; v2++) {\n+          const assign = new Array(numFree).fill(0);\n+          assign[f1] = v1;\n+          assign[f2] = v2;\n+          updateBest(computeSolution(assign));\n+        }\n+      }\n+    }\n+  }\n+}\ndiff --git a/tests/index.test.ts b/tests/index.test.ts\nnew file mode 100644\nindex 0000000..5cd9e1e\n--- /dev/null\n+++ b/tests/index.test.ts\n@@ -0,0 +1,217 @@\n+import { describe, it, expect } from 'vitest';\n+import { solveToggle, solveCounter, Machine } from '../src/index.js';\n+\n+describe('solveToggle', () => {\n+  it('returns empty array when target is all off', () => {\n+    const machine: Machine = {\n+      target: [false, false, false],\n+      buttons: [[0, 1], [1, 2]],\n+    };\n+    expect(solveToggle(machine)).toEqual([]);\n+  });\n+\n+  it('returns null when no solution exists', () => {\n+    // From the TASK example:\n+    // target [T, T, F, T], buttons: [0,1], [1,2,3], [0,3]\n+    // System: b0^b2=1, b0^b1=1, b1=0, b1^b2=1\n+    // b1=0, b0=1, b2=0, check: b1^b2=0≠1 → no solution\n+    const machine: Machine = {\n+      target: [true, true, false, true],\n+      buttons: [[0, 1], [1, 2, 3], [0, 3]],\n+    };\n+    expect(solveToggle(machine)).toBeNull();\n+  });\n+\n+  it('solves a sim