pect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('returns lexicographically smallest when tied on press count', () => {\n    // target: [true]\n    // button 0: toggles [0]\n    // button 1: toggles [0]\n    // Both are 1 press. Lex smallest is [0].\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0], [0]],\n    };\n    expect(solveToggle(machine)).toEqual([0]);\n  });\n\n  it('handles no buttons and all-off target', () => {\n    const machine: Machine = {\n      target: [false, false],\n      buttons: [],\n    };\n    expect(solveToggle(machine)).toEqual([]);\n  });\n\n  it('handles no buttons and non-zero target', () => {\n    const machine: Machine = {\n      target: [true],\n      buttons: [],\n    };\n    expect(solveToggle(machine)).toBeNull();\n  });\n\n  it('handles overlapping buttons requiring cancellation', () => {\n    // target: [true, false]\n    // button 0: toggles [0, 1]\n    // button 1: toggles [1]\n    // Press both: light0=on, light1=on^on=off → matches\n    const machine: Machine = {\n      target: [true, false],\n      buttons: [[0, 1], [1]],\n    };\n    expect(solveToggle(machine)).toEqual([0, 1]);\n  });\n\n  it('handles a larger puzzle', () => {\n    // 5 lights, 5 buttons\n    // button 0: [0]\n    // button 1: [1]\n    // button 2: [2]\n    // button 3: [3]\n    // button 4: [4]\n    // target: [T, T, T, T, T]\n    // Solution: press all 5\n    const machine: Machine = {\n      target: [true, true, true, true, true],\n      buttons: [[0], [1], [2], [3], [4]],\n    };\n    expect(solveToggle(machine)).toEqual([0, 1, 2, 3, 4]);\n  });\n\n  it('handles redundant buttons correctly', () => {\n    // target: [true, true]\n    // button 0: [0, 1] -- solves it alone\n    // button 1: [0, 1] -- identical to 0\n    // button 2: [0]\n    // button 3: [1]\n    // Minimum: 1 press → button 0 (lex smallest single press)\n    const machine: Machine = {\n      target: [true, true],\n      buttons: [[0, 1], [0, 1], [0], [1]