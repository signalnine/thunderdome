96→  // For practical purposes, if numFree > 25 we need a smarter approach.\n    97→  // However, with up to 40 lights constraining things, rank is typically close to numButtons.\n    98→  // We'll handle the case where numFree is large with a greedy/BFS approach.\n    99→\n   100→  if (numFree > 20) {\n   101→    // Too many free variables for brute force. Use greedy: set all free vars to 0.\n   102→    // This gives minimum presses among solutions reachable this way.\n   103→    // Actually, for minimum weight codeword in GF(2), this is NP-hard in general.\n   104→    // But the problem says up to 40 buttons and 40 lights, so rank should be ≤ 40.\n   105→    // If numFree > 20, we still try to find the best solution.\n   106→    // Use a meet-in-the-middle approach.\n   107→    return solveToggleMITM(rows, pivotRow, freeVars, numButtons, numLights);\n   108→  }\n   109→\n   110→  let bestResult: number[] | null = null;\n   111→  let bestCount = numButtons + 1;\n   112→\n   113→  for (let mask = 0; mask < (1 << numFree); mask++) {\n   114→    const solution = new Array(numButtons).fill(0);\n   115→\n   116→    // Set free variables\n   117→    for (let f = 0; f < numFree; f++) {\n   118→      if ((mask >> f) & 1) {\n   119→        solution[freeVars[f]] = 1;\n   120→      }\n   121→    }\n   122→\n   123→    // Compute pivot variables via back-substitution\n   124→    // For each pivot column, the row pivotRow[col] gives:\n   125→    //   x[col] = target_bit XOR (sum of other non-zero coefficients * their x values)\n   126→    // Since we've done full elimination, each pivot row has exactly one pivot column set.\n   127→    for (let col = numButtons - 1; col >= 0; col--) {\n   128→      if (pivotRow[col] === -1) continue;\n   129→      const r = pivotRow[col];\n   130→      let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n   131→      for (let c = 0; c < numButtons; c++) {\n   132→        if (c !== col && ((rows[r] >> BigInt(c)) & 1n)) {\n   133→          val ^= solution[c];\n   134→        }\n   135→      }\n   136→      solution[col] = val;\n   137→    }\n   138→\n   139→    const count = solution.reduce((a: number, b: number) => a + b, 0);\n   140→    if (count < bestCount) {\n   141→      bestCount = count;\n   142→      bestResult = [];\n   143→      for (let i = 0; i < numButtons; i++) {\n   144→        if (solution[i]) bestResult.push(i);\n   145→      }\n   146→    } else if (count === bestCount && bestResult !== null) {\n   147→      // Compare lexicographically\n   148→      const candidate: number[] = [];\n   149→      for (let i = 0; i < numButtons; i++) {\n   150→        if (solution[i]) candidate.push(i);\n   151→      }\n   152→      if (lexSmaller(candidate, bestResult)) {\n   153→        bestResult = candidate;\n   154→      }\n   155→    }\n   156→  }\n   157→\n   158→  return bestResult;\n   159→}\n   160→\n   161→function lexSmaller(a: number[], b: number[]): boolean {\n   162→  const len = Math.min(a.length, b.length);\n   163→  for (let i = 0; i < len; i++) {\n   164→    if (a[i] < b[i]) return true;\n   165→    if (a[i] > b[i]) return false;\n   166→  }\n   167→  return a.length < b.length;\n   168→}\n   169→\n   170→/**\n   171→ * Meet-in-the-middle approach for large number of free variables.\n   172→ *\n   173→ * For each pivot column col with pivot row r, after full elimination:\n   174→ *   x[col] = rhs[r] XOR sum_over_free_vars(coeff[r][freeVar] * x[freeVar])\n   175→ *\n   176→ * We represent the \"effect\" of a set of free vars on pivot vars as a bigint bitmask.\n   177→ * Each bit position corresponds to a pivot column index.\n   178→ *\n   179→ * We split free vars into two halves. For each half1 assignment, we compute:\n   180→ *   - The free-var contribution to pivot vars (effect1 bitmask)\n   181→ *   - The total weight = popcount(half1 free vars set) + popcount(pivot vars that\n   182→ *     would be set if half2 contributes nothing, i.e., rhs XOR effect1)\n   183→ *\n   184→ * We store the best (min weight, then lex) half1 assignment for each effect1 bitmask.\n   185→ *\n   186→ * For each half2 assignment, compute effect2. The combined pivot result is:\n   187→ *   rhs XOR effect1 XOR effect2\n   188→ * For each possible effect2, the needed effect1 to minimize pivot weight depends on\n   189→ * which bits of (rhs XOR effect2) we want to cancel. Since we want minimum total\n   190→ * weight, we need to consider all possible effect1 values and pick the best.\n   191→ *\n   192→ * Unfortunately this doesn't decompose nicely for minimum weight. Instead, for each\n   193→ * (effect1, effect2) pair, the pivot weight = popcount(rhs XOR effect1 XOR effect2).\n   194→ * Total weight = popcount(freeH1) + popcount(freeH2) + popcount(rhs XOR effect1 XOR effect2).\n   195→ *\n   196→ * We use the approach: for each half2 assignment, we want to find the half1 assignment\n   197→ * that minimizes popcount(freeH1) + popcount(rhs XOR effect1 XOR effect2).\n   198→ * Let target2 = rhs XOR effect2. We want to minimize popcount(freeH1) + popcount(target2 XOR effect1).\n   199→ *\n   200→ * We group half1 assignments by effect1 and keep only the best (min popcount(freeH1))\n   201→ * for each effect1. Then for each half2 assignment, we iterate over all stored effect1\n   202→ * values (up to 2^half1) to find the best match.\n   203→ *\n   204→ * Total work: 2^half1 + 2^half2 * (unique effect1 values).\n   205→ * With half1 = half2 = 20, this could still be 2^20 * 2^20 = 2^40.\n   206→ *\n   207→ * Better approach: since the number of pivot columns ≤ 40, but typically much less,\n   208→ * we can limit the number of distinct effect1 bitmasks. If rank is small (which it is\n   209→ * when numFree > 20, since rank = numButtons - numFree), the number of bits in the\n   210→ * effect bitmask is small, limiting distinct values.\n   211→ *\n   212→ * With numFree > 20 and numButtons ≤ 40, rank ≤ 19. So the effect bitmask has ≤ 19 bits,\n   213→ * meaning at most 2^19 = 524288 distinct effect1 values. This makes the lookup feasible.\n   214→ */\n   215→function solveToggleMITM(\n   216→  rows: bigint[],\n   217→  pivotRow: number[],\n   218→  freeVars: number[],\n   219→  numButtons: number,\n   220→  _numLights: number,\n   221→): number[] | null {\n   222→  const numFree = freeVars.length;\n   223→  const half1Size = Math.floor(numFree / 2);\n   224→  const half2Size = numFree - half1Size;\n   225→\n   226→  // Identify pivot columns and build compact mapping\n   227→  const pivotCols: number[] = [];\n   228→  for (let col = 0; col < numButtons; col++) {\n   229→    if (pivotRow[col] !== -1) pivotCols.push(col);\n   230→  }\n   231→  const numPivots = pivotCols.length;\n   232→\n   233→  // For each free variable, precompute which pivot columns it affects.\n   234→  // freeEffect[f] is a bitmask over pivotCols indices.\n   235→  const freeEffect: number[] = new Array(numFree).fill(0);\n   236→  for (let f = 0; f < numFree; f++) {\n   237→    const freeCol = freeVars[f];\n   238→    for (let pi = 0; pi < numPivots; pi++) {\n   239→      const col = pivotCols[pi];\n   240→      const r = pivotRow[col];\n   241→      if ((rows[r] >> BigInt(freeCol)) & 1n) {\n   242→        freeEffect[f] |= 1 << pi;\n   243→      }\n   244→    }\n   245→  }\n   246→\n   247→  // Compute rhs bitmask (base pivot values when all free vars = 0)\n   248→  let rhsMask = 0;\n   249→  for (let pi = 0; pi < numPivots; pi++) {\n   250→    const col = pivotCols[pi];\n   251→    const r = pivotRow[col];\n   252→    if ((rows[r] >> BigInt(numButtons)) & 1n) {\n   253→      rhsMask |= 1 << pi;\n   254→    }\n   255→  }\n   256→\n   257→  const popcount = (x: number): number => {\n   258→    let count = 0;\n   259→    while (x) { count++; x &= x - 1; }\n   260→    return count;\n   261→  };\n   262→\n   263→  // Phase 1: enumerate all 2^half1Size assignments for the first half of free vars.\n   264→  // For each, compute effect1 and freeWeight1 (number of free vars set to 1).\n   265→  // Store the best (min freeWeight1, then lex smallest mask) for each effect1.\n   266→  const half1Count = 1 << half1Size;\n   267→  // Map from effect1 → { freeWeight: number, mask: number }\n   268→  const half1Map = new Map<number, { freeWeight: number; mask: number }>();\n   269→\n   270→  for (let m = 0; m < half1Count; m++) {\n   271→    let effect = 0;\n   272→    let freeWeight = 0;\n   273→    for (let f = 0; f < half1Size; f++) {\n   274→      if ((m >> f) & 1) {\n   275→        effect ^= freeEffect[f];\n   276→        freeWeight++;\n   277→      }\n   278→    }\n   279→    const existing = half1Map.get(effect);\n   280→    if (!existing || freeWeight < existing.freeWeight ||\n   281→        (freeWeight === existing.freeWeight && m < existing.mask)) {\n   282→      half1Map.set(effect, { freeWeight, mask: m });\n   283→    }\n   284→  }\n   285→\n   286→  // Phase 2: enumerate all 2^half2Size assignments for the second half.\n   287→  // For each, compute effect2 and freeWeight2, then iterate over all stored\n   288→  // effect1 values to find the best total.\n   289→  const half2Count = 1 << half2Size;\n   290→\n   291→  let bestCount = numButtons + 1;\n   292→  let bestH1Mask = 0;\n   293→  let bestH2Mask = 0;\n   294→\n   295→  // Convert map to array for faster iteration\n   296→  const half1Entries = Array.from(half1Map.entries());\n   297→\n   298→  for (let m2 = 0; m2 < half2Count; m2++) {\n   299→    let effect2 = 0;\n   300→    let freeWeight2 = 0;\n   301→    for (let f = 0; f < half2Size; f++) {\n   302→      if ((m2 >> f) & 1) {\n   303→        effect2 ^= freeEffect[half1Size + f];\n   304→        freeWeight2++;\n   305→      }\n   306→    }\n   307→\n   308→    const target2 = rhsMask ^ effect2;\n   309→\n   310→    for (const [effect1, { freeWeight: freeWeight1, mask: m1 }] of half1Entries) {\n   311→      const pivotResult = target2 ^ effect1;\n   312→      const pivotWeight = popcount(pivotResult);\n   313→      const totalWeight = freeWeight1 + freeWeight2 + pivotWeight;\n   314→\n   315→      if (totalWeight < bestCount) {\n   316→        bestCount = totalWeight;\n   317→        bestH1Mask = m1;\n   318→        bestH2Mask = m2;\n   319→      } else if (totalWeight === bestCount) {\n   320→        // Build and compare solutions lexicographically\n   321→        // For efficiency, we compare the free var assignments first,\n   322→        // then pivot vars if needed. But this is complex, so we build full solutions.\n   323→        const candidateSol = buildSolution(m1, m2, half1Size, half2Size,\n   324→          freeVars, pivotRow, pivotCols, rows, numButtons);\n   325→        const bestSol = buildSolution(bestH1Mask, bestH2Mask, half1Size, half2Size,\n   326→          freeVars, pivotRow, pivotCols, rows, numButtons);\n   327→        const candidateIndices = indicesToArray(candidateSol);\n   328→        const bestIndices = indicesToArray(bestSol);\n   329→        if (lexSmaller(candidateIndices, bestIndices)) {\n   330→          bestH1Mask = m1;\n   331→          bestH2Mask = m2;\n   332→        }\n   333→      }\n   334→    }\n   335→  }\n   336→\n   337→  const finalSol = buildSolution(bestH1Mask, bestH2Mask, half1Size, half2Size,\n   338→    freeVars, pivotRow, pivotCols, rows, numButtons);\n   339→  return indicesToArray(finalSol);\n   340→}\n   341→\n   342→function buildSolution(\n   343→  h1Mask: number, h2Mask: number,\n   344→  half1Size: number, half2Size: number,\n   345→  freeVars: number[], pivotRow: number[], _pivotCols: number[],\n   346→  rows: bigint[], numButtons: number,\n   347→): number[] {\n   348→  const solution = new Array(numButtons).fill(0);\n   349→  for (let f = 0; f < half1Size; f++) {\n   350→    if ((h1Mask >> f) & 1) solution[freeVars[f]] = 1;\n   351→  }\n   352→  for (let f = 0; f < half2Size; f++) {\n   353→    if ((h2Mask >> f) & 1) solution[freeVars[half1Size + f]] = 1;\n   354→  }\n   355→  for (let col = numButtons - 1; col >= 0; col--) {\n   356→    if (pivotRow[col] === -1) continue;\n   357→    const r = pivotRow[col];\n   358→    let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n   359→    for (let c = 0; c < numButtons; c++) {\n   360→      if (c !== col && ((rows[r] >> BigInt(c)) & 1n)) {\n   361→        val ^= solution[c];\n   362→      }\n   363→    }\n   364→    solution[col] = val;\n   365→  }\n   366→  return solution;\n   367→}\n   368→\n   369→function indicesToArray(solution: number[]): number[] {\n   370→  const result: number[] = [];\n   371→  for (let i = 0; i < solution.length; i++) {\n   372→    if (solution[i]) result.push(i);\n   373→  }\n   374→  return result;\n   375→}\n   376→\n   377→/**\n   378→ * Solve a counter puzzle over GF(p) using Gaussian elimination.\n   379→ *\n   380→ * We model: for each counter j: sum_i (A[j][i] * x[i]) ≡ target[j] (mod p)\n   381→ * where A[j][i] = 1 if button i affects counter j, x[i] ∈ {0, ..., p-1}.\n   382→ *\n   383→ * We want the solution with minimum total presses (sum of x[i]),\n   384→ * breaking ties lexicographically.\n   385→ */\n   386→export function solveCounter(\n   387→  lights: number[],\n   388→  buttons: number[][],\n   389→  modulus: number,\n   390→): number[] | null {\n   391→  const numCounters = lights.length;\n   392→  const numButtons = buttons.length;\n   393→  const p = modulus;\n   394→\n   395→  // Build augmented matrix over GF(p).\n   396→  // matrix[j] = array of numButtons+1 values, representing coefficients + target.\n   397→  const matrix: number[][] = [];\n   398→  for (let j = 0; j < numCounters; j++) {\n   399→    const row = new Array(numButtons + 1).fill(0);\n   400→    for (let i = 0; i < numButtons; i++) {\n   401→      if (buttons[i].includes(j)) {\n   402→        row[i] = 1;\n   403→      }\n   404→    }\n   405→    row[numButtons] = ((lights[j] % p) + p) % p;\n   406→    matrix.push(row);\n   407→  }\n   408→\n   409→  // Compute modular inverse using Fermat's little theorem (p is prime).\n   410→  const modInv = (a: number, mod: number): number => {\n   411→    let result = 1;\n   412→    let base = ((a % mod) + mod) % mod;\n   413→    let exp = mod - 2;\n   414→    while (exp > 0) {\n   415→      if (exp & 1) result = (result * base) % mod;\n   416→      base = (base * base) % mod;\n   417→      exp >>= 1;\n   418→    }\n   419→    return result;\n   420→  };\n   421→\n   422→  // Gaussian elimination over GF(p).\n   423→  const pivotRow: number[] = new Array(numButtons).fill(-1);\n   424→  let rank = 0;\n   425→\n   426→  for (let col = 0; col < numButtons; col++) {\n   427→    let found = -1;\n   428→    for (let r = rank; r < numCounters; r++) {\n   429→      if (matrix[r][col] !== 0) {\n   430→        found = r;\n   431→        break;\n   432→      }\n   433→    }\n   434→    if (found === -1) continue;\n   435→\n   436→    // Swap\n   437→    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n   438→    pivotRow[col] = rank;\n   439→\n   440→    // Normalize pivot row\n   441→    const inv = modInv(matrix[rank][col], p);\n   442→    for (let c = 0; c <= numButtons; c++) {\n   443→      matrix[rank][c] = (matrix[rank][c] * inv) % p;\n   444→    }\n   445→\n   446→    // Eliminate column from other rows\n   447→    for (let r = 0; r < numCounters; r++) {\n   448→      if (r !== rank && matrix[r][col] !== 0) {\n   449→        const factor = matrix[r][col];\n   450→        for (let c = 0; c <= numButtons; c++) {\n   451→          matrix[r][c] = (((matrix[r][c] - factor * matrix[rank][c]) % p) + p) % p;\n   452→        }\n   453→      }\n   454→    }\n   455→    rank++;\n   456→  }\n   457→\n   458→  // Check consistency\n   459→  for (let r = 0; r < numCounters; r++) {\n   460→    let allZero = true;\n   461→    for (let c = 0; c < numButtons; c++) {\n   462→      if (matrix[r][c] !== 0) {\n   463→        allZero = false;\n   464→        break;\n   465→      }\n   466→    }\n   467→    if (allZero && matrix[r][numButtons] !== 0) {\n   468→      return null;\n   469→    }\n   470→  }\n   471→\n   472→  // Identify free variables\n   473→  const freeVars: number[] = [];\n   474→  for (let col = 0; col < numButtons; col++) {\n   475→    if (pivotRow[col] === -1) {\n   476→      freeVars.push(col);\n   477→    }\n   478→  }\n   479→\n   480→  const numFree = freeVars.length;\n   481→\n   482→  // For GF(p), each free variable can take p values.\n   483→  // Total combinations: p^numFree. We need this to be tractable.\n   484→  // If p^numFree > some limit, we need a smarter approach.\n   485→\n   486→  const totalCombinations = Math.pow(p, numFree);\n   487→\n   488→  const computeSolution = (freeAssign: number[]): number[] => {\n   489→    const solution = new Array(numButtons).fill(0);\n   490→    for (let f = 0; f < numFree; f++) {\n   491→      solution[freeVars[f]] = freeAssign[f];\n   492→    }\n   493→    // Back-substitute for pivot variables\n   494→    for (let col = numButtons - 1; col >= 0; col--) {\n   495→      if (pivotRow[col] === -1) continue;\n   496→      const r = pivotRow[col];\n   497→      let val = matrix[r][numButtons];\n   498→      for (let c = 0; c < numButtons; c++) {\n   499→        if (c !== col) {\n   500→          val = (((val - matrix[r][c] * solution[c]) % p) + p) % p;\n   501→        }\n   502→      }\n   503→      solution[col] = val % p;\n   504→    }\n   505→    return solution;\n   506→  };\n   507→\n   508→  let bestResult: number[] | null = null;\n   509→  let bestTotal = Infinity;\n   510→\n   511→  const updateBest = (solution: number[]) => {\n   512→    const total = solution.reduce((a, b) => a + b, 0);\n   513→    if (total < bestTotal) {\n   514→      bestTotal = total;\n   515→      bestResult = [...solution];\n   516→    } else if (total === bestTotal && bestResult !== null) {\n   517→      if (lexSmallerArr(solution, bestResult)) {\n   518→        bestResult = [...solution];\n   519→      }\n   520→    }\n   521→  };\n   522→\n   523→  if (numFree ===