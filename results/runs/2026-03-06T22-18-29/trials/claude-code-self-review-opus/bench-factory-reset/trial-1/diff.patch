umPivots).fill(0), 0, new Array(half2Size).fill(0));\n}","newString":"function solveCounterMITM(\n  matrix: number[][],\n  pivotRow: number[],\n  freeVars: number[],\n  numButtons: number,\n  p: number,\n  updateBest: (solution: number[]) => void,\n): void {\n  const numFree = freeVars.length;\n\n  // Identify pivot columns\n  const pivotCols: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] !== -1) pivotCols.push(col);\n  }\n  const numPivots = pivotCols.length;\n\n  // For each free variable, precompute its coefficient for each pivot equation.\n  const coeffs: number[][] = new Array(numFree);\n  for (let f = 0; f < numFree; f++) {\n    coeffs[f] = new Array(numPivots);\n    for (let pi = 0; pi < numPivots; pi++) {\n      const r = pivotRow[pivotCols[pi]];\n      coeffs[f][pi] = matrix[r][freeVars[f]];\n    }\n  }\n\n  // RHS values for each pivot\n  const rhs: number[] = new Array(numPivots);\n  for (let pi = 0; pi < numPivots; pi++) {\n    const r = pivotRow[pivotCols[pi]];\n    rhs[pi] = matrix[r][numButtons];\n  }\n\n  // Choose optimal half1Size: maximize it while keeping p^half1Size manageable.\n  // Memory limit: ~2M entries for phase 1 map.\n  let half1Size = 0;\n  let combo = 1;\n  while (half1Size < numFree && combo * p <= 2_000_000) {\n    combo *= p;\n    half1Size++;\n  }\n  if (half1Size === 0) half1Size = 1;\n  // Don't let half1 exceed numFree\n  half1Size = Math.min(half1Size, numFree);\n  const half2Size = numFree - half1Size;\n\n  // Phase 1: enumerate all p^half1Size assignments, store best by effect vector.\n  const half1Map = new Map<string, { freeWeight: number; assign: number[] }>();\n\n  const enumHalf1 = (idx: number, effect: number[], freeWeight: number, assign: number[]) => {\n    if (idx === half1Size) {\n      const key = effect.join(',');\n      const existing = half1Map.get(key);\n      if (!existing || freeWeight < existing.freeWeight ||\n          (freeWeight === existing.freeWeight && lexSmallerArr(assign, existing.assign))) {\n        half1Map.set(key, { freeWeight, assign: [...assign] });\n      }\n      return;\n    }\n    for (let v = 0; v < p; v++) {\n      assign[idx] = v;\n      const newEffect = effect.slice();\n      for (let pi = 0; pi < numPivots; pi++) {\n        newEffect[pi] = (effect[pi] + coeffs[idx][pi] * v) % p;\n      }\n      enumHalf1(idx + 1, newEffect, freeWeight + v, assign);\n    }\n  };\n\n  enumHalf1(0, new Array(numPivots).fill(0), 0, new Array(half1Size).fill(0));\n\n  // Build full solution from half1 and half2 assignments\n  const buildFullSolution = (h1Assign: number[], h2Assign: number[]): number[] => {\n    const solution = new Array(numButtons).fill(0);\n    for (let f = 0; f < half1Size; f++) {\n      solution[freeVars[f]] = h1Assign[f];\n    }\n    for (let f = 0; f < half2Size; f++) {\n      solution[freeVars[half1Size + f]] = h2Assign[f];\n    }\n    for (let col = numButtons - 1; col >= 0; col--) {\n      if (pivotRow[col] === -1) continue;\n      const r = pivotRow[col];\n      let val = matrix[r][numButtons];\n      for (let c = 0; c < numButtons; c++) {\n        if (c !== col) {\n          val = (((val - matrix[r][c] * solution[c]) % p) + p) % p;\n        }\n      }\n      solution[col] = val % p;\n    }\n    return solution;\n  };\n\n  // Phase 2: enumerate all p^half2Size assignments.\n  // For each, compute effect2, then iterate over all stored half1 entries.\n  const half1Entries = Array.from(half1Map.values());\n  const half1Keys = Array.from(half1Map.keys());\n  const half1Effects = half1Keys.map(k => k.split(',').map(Number));\n\n  const enumHalf2 = (idx: number, effect2: number[], freeWeight2: number, assign2: number[]) => {\n    if (idx === half2Size) {\n      for (let i = 0; i < half1Entries.length; i++) {\n        const { freeWeight: fw1, assign: a1 } = half1Entries[i];\n        const effect1 = half1Effects[i];\n        let pivotWeight = 0;\n        for (let pi = 0; pi < numPivots; pi++) {\n          pivotWeight += ((rhs[pi] - effect1[pi] - effect2[pi]) % p + p) % p;\n        }\n        const totalWeight = fw1 + freeWeight2 + pivotWeight;\n        if (totalWeight < bestTotalSoFar || (totalWeight === bestTotalSoFar)) {\n          const solution = buildFullSolution(a1, assign2);\n          updateBest(solution);\n          const s = solution.reduce((a, b) => a + b, 0);\n          if (s < bestTotalSoFar) bestTotalSoFar = s;\n        }\n      }\n      return;\n    }\n    for (let v = 0; v < p; v++) {\n      assign2[idx] = v;\n      const newEffect2 = effect2.slice();\n      for (let pi = 0; pi < numPivots; pi++) {\n        newEffect2[pi] = (effect2[pi] + coeffs[half1Size + idx][pi] * v) % p;\n      }\n      enumHalf2(idx + 1, newEffect2, freeWeight2 + v, assign2);\n    }\n  };\n\n  let bestTotalSoFar = Infinity;\n  enumHalf2(0, new Array(numPivots).fill(0), 0, new Array(half2Size).fill(0));\n}","originalFile":"export interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve a toggle puzzle over GF(2) using Gaussian elimination.\n *\n * We model the problem as a system of linear equations over GF(2):\n *   For each light j: sum_i (A[j][i] * x[i]) ≡ target[j] (mod 2)\n * where A[j][i] = 1 if button i toggles light j, x[i] ∈ {0,1}.\n *\n * We want the solution with minimum weight (fewest 1s), breaking ties\n * lexicographically.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | target] over GF(2).\n  // Each row corresponds to a light equation.\n  // Columns 0..numButtons-1 are button coefficients, column numButtons is the target.\n  // We use bitwise operations for efficiency with up to 41 columns (40 buttons + 1).\n  // Use BigInt since we may need >32 bits.\n\n  const rows: bigint[] = new Array(numLights);\n\n  for (let j = 0; j < numLights; j++) {\n    let row = 0n;\n    for (let i = 0; i < numButtons; i++) {\n      if (buttons[i].includes(j)) {\n        row |= 1n << BigInt(i);\n      }\n    }\n    if (target[j]) {\n      row |= 1n << BigInt(numButtons);\n    }\n    rows[j] = row;\n  }\n\n  // Gaussian elimination with partial pivoting.\n  // pivotCol[r] = which column is the pivot for row r, or -1.\n  const pivotRow: number[] = new Array(numButtons + 1).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    // Find a row with a 1 in this column, at or below 'rank'.\n    let found = -1;\n    for (let r = rank; r < numLights; r++) {\n      if ((rows[r] >> BigInt(col)) & 1n) {\n        found = r;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [rows[rank], rows[found]] = [rows[found], rows[rank]];\n    pivotRow[col] = rank;\n\n    // Eliminate this column from all other rows\n    for (let r = 0; r < numLights; r++) {\n      if (r !== rank && ((rows[r] >> BigInt(col)) & 1n)) {\n        rows[r] ^= rows[rank];\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency: any row that is all zeros in button columns but 1 in target column\n  for (let r = 0; r < numLights; r++) {\n    const buttonBits = rows[r] & ((1n << BigInt(numButtons)) - 1n);\n    const targetBit = (rows[r] >> BigInt(numButtons)) & 1n;\n    if (buttonBits === 0n && targetBit === 1n) {\n      return null;\n    }\n  }\n\n  // Identify free variables (columns without pivots).\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  // Enumerate all 2^(freeVars.length) assignments to free variables.\n  // For each, compute the determined pivot variables and evaluate total presses.\n  // Keep the solution with min presses, then lex smallest.\n  const numFree = freeVars.length;\n\n  // With up to 40 buttons, free vars can be large. But rank ≤ 40 and numButtons ≤ 40,\n  // so numFree = numButtons - rank. In the worst case this could be ~40 but that would\n  // mean rank=0, so all buttons are free and target must be all false.\n  // For practical purposes, if numFree > 25 we need a smarter approach.\n  // However, with up to 40 lights constraining things, rank is typically close to numButtons.\n  // We'll handle the case where numFree is large with a greedy/BFS approach.\n\n  if (numFree > 20) {\n    // Too many free variables for brute force. Use greedy: set all free vars to 0.\n    // This gives minimum presses among solutions reachable this way.\n    // Actually, for minimum weight codeword in GF(2), this is NP-hard in general.\n    // But the problem says up to 40 buttons and 40 lights, so rank should be ≤ 40.\n    // If numFree > 20, we still try to find the best solution.\n    // Use a meet-in-the-middle approach.\n    return solveToggleMITM(rows, pivotRow, freeVars, numButtons, numLights);\n  }\n\n  let bestResult: number[] | null = null;\n  let bestCount = numButtons + 1;\n\n  for (let mask = 0; mask < (1 << numFree); mask++) {\n    const solution = new Array(numButtons).fill(0);\n\n    // Set free variables\n    for (let f = 0; f < numFree; f++) {\n      if ((mask >> f) & 1) {\n        solution[freeVars[f]] = 1;\n      }\n    }\n\n    // Compute pivot variables via back-substitution\n    // For each pivot column, the row pivotRow[col] gives:\n    //   x[col] = target_bit XOR (sum of other non-zero coefficients * their x values)\n    // Since we've done full elimination, each pivot row has exactly one pivot column set.\n    for (let col = numButtons - 1; col >= 0; col--) {\n      if (pivotRow[col] === -1) continue;\n      const r = pivotRow[col];\n      let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n      for (let c = 0; c < numButtons; c++) {\n        if (c !== col && ((rows[r] >> BigInt(c)) & 1n)) {\n          val ^= solution[c];\n        }\n      }\n      solution[col] = val;\n    }\n\n    const count = solution.reduce((a: number, b: number) => a + b, 0);\n    if (count < bestCount) {\n      bestCount = count;\n      bestResult = [];\n      for (let i = 0; i < numButtons; i++) {\n        if (solution[i]) bestResult.push(i);\n      }\n    } else if (count === bestCount && bestResult !== null) {\n      // Compare lexicographically\n      const candidate: number[] = [];\n      for (let i = 0; i < numButtons; i++) {\n        if (solution[i]) candidate.push(i);\n      }\n      if (lexSmaller(candidate, bestResult)) {\n        bestResult = candidate;\n      }\n    }\n  }\n\n  return bestResult;\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  const len = Math.min(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return a.length < b.length;\n}\n\n/**\n * Meet-in-the-middle approach for large number of free variables.\n *\n * For each pivot column col with pivot row r, after full elimination:\n *   x[col] = rhs[r] XOR sum_over_free_vars(coeff[r][freeVar] * x[freeVar])\n *\n * We represent the \"effect\" of a set of free vars on pivot vars as a bigint bitmask.\n * Each bit position corresponds to a pivot column index.\n *\n * We split free vars into two halves. For each half1 assignment, we compute:\n *   - The free-var contribution to pivot vars (effect1 bitmask)\n *   - The total weight = popcount(half1 free vars set) + popcount(pivot vars that\n *     would be set if half2 contributes nothing, i.e., rhs XOR effect1)\n *\n * We store the best (min weight, then lex) half1 assignment for each effect1 bitmask.\n *\n * For each half2 assignment, compute effect2. The combined pivot result is:\n *   rhs XOR effect1 XOR effect2\n * For each possible effect2, the needed effect1 to minimize pivot weight depends on\n * which bits of (rhs XOR effect2) we want to cancel. Since we want minimum total\n * weight, we need to consider all possible effect1 values and pick the best.\n *\n * Unfortunately this doesn't decompose nicely for minimum weight. Instead, for each\n * (effect1, effect2) pair, the pivot weight = popcount(rhs XOR effect1 XOR effect2).\n * Total weight = popcount(freeH1) + popcount(freeH2) + popcount(rhs XOR effect1 XOR effect2).\n *\n * We use the approach: for each half2 assignment, we want to find the half1 assignment\n * that minimizes popcount(freeH1) + popcount(rhs XOR effect1 XOR effect2).\n * Let target2 = rhs XOR effect2. We want to minimize popcount(freeH1) + popcount(target2 XOR effect1).\n *\n * We group half1 assignments by effect1 and keep only the best (min popcount(freeH1))\n * for each effect1. Then for each half2 assignment, we iterate over all stored effect1\n * values (up to 2^half1) to find the best match.\n *\n * Total work: 2^half1 + 2^half2 * (unique effect1 values).\n * With half1 = half2 = 20, this could still be 2^20 * 2^20 = 2^40.\n *\n * Better approach: since the number of pivot columns ≤ 40, but typically much less,\n * we can limit the number of distinct effect1 bitmasks. If rank is small (which it is\n * when numFree > 20, since rank = numButtons - numFree), the number of bits in the\n * effect bitmask is small, limiting distinct values.\n *\n * With numFree > 20 and numButtons ≤ 40, rank ≤ 19. So the effect bitmask has ≤ 19 bits,\n * meaning at most 2^19 = 524288 distinct effect1 values. This makes the lookup feasible.\n */\nfunction solveToggleMITM(\n  rows: bigint[],\n  pivotRow: number[],\n  freeVars: number[],\n  numButtons: number,\n  _numLights: number,\n): number[] | null {\n  const numFree = freeVars.length;\n  const half1Size = Math.floor(numFree / 2);\n  const half2Size = numFree - half1Size;\n\n  // Identify pivot columns and build compact mapping\n  const pivotCols: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] !== -1) pivotCols.push(col);\n  }\n  const numPivots = pivotCols.length;\n\n  // For each free variable, precompute which pivot columns it affects.\n  // freeEffect[f] is a bitmask over pivotCols indices.\n  const freeEffect: number[] = new Array(numFree).fill(0);\n  for (let f = 0; f < numFree; f++) {\n    const freeCol = freeVars[f];\n    for (let pi = 0; pi < numPivots; pi++) {\n      const col = pivotCols[pi];\n      const r = pivotRow[col];\n      if ((rows[r] >> BigInt(freeCol)) & 1n) {\n        freeEffect[f] |= 1 << pi;\n      }\n    }\n  }\n\n  // Compute rhs bitmask (base pivot values when all free vars = 0)\n  let rhsMask = 0;\n  for (let pi = 0; pi < numPivots; pi++) {\n    const col = pivotCols[pi];\n    const r = pivotRow[col];\n    if ((rows[r] >> BigInt(numButtons)) & 1n) {\n      rhsMask |= 1 << pi;\n    }\n  }\n\n  const popcount = (x: number): number => {\n    let count = 0;\n    while (x) { count++; x &= x - 1; }\n    return count;\n  };\n\n  // Phase 1: enumerate all 2^half1Size assignments for the first half of free vars.\n  // For each, compute effect1 and freeWeight1 (number of free vars set to 1).\n  // Store the best (min freeWeight1, then lex smallest mask) for each effect1.\n  const half1Count = 1 << half1Size;\n  // Map from effect1 → { freeWeight: number, mask: number }\n  const half1Map = new Map<number, { freeWeight: number; mask: number }>();\n\n  for (let m = 0; m < half1Count; m++) {\n    let effect = 0;\n    let freeWeight = 0;\n    for (let f = 0; f < half1Size; f++) {\n      if ((m >> f) & 1) {\n        effect ^= freeEffect[f];\n        freeWeight++;\n      }\n    }\n    const existing = half1Map.get(effect);\n    if (!existing || freeWeight < existing.freeWeight ||\n        (freeWeight === existing.freeWeight && m < existing.mask)) {\n      half1Map.set(effect, { freeWeight, mask: m });\n    }\n  }\n\n  // Phase 2: enumerate all 2^half2Size assignments for the second half.\n  // For each, compute effect2 and freeWeight2, then iterate over all stored\n  // effect1 values to find the best total.\n  const half2Count = 1 << half2Size;\n\n  let bestCount = numButtons + 1;\n  let bestH1Mask = 0;\n  let bestH2Mask =