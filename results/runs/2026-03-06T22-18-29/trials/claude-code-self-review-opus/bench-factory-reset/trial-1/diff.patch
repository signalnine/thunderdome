+describe('solveCounter', () => {
+  it('returns all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('solves a simple single-button case', () => {
+    // target: [3], button 0 affects counter 0, mod 5
+    // Press button 0 three times: counter 0 = 3
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('returns null when no solution exists', () => {
+    // target: [1, 0], button 0 affects both counters, mod 3
+    // Pressing button 0 x times: counter0=x, counter1=x
+    // Need x≡1(mod3) and x≡0(mod3) → impossible
+    const result = solveCounter([1, 0], [[0, 1]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('solves a two-button case', () => {
+    // target: [1, 1], mod 3
+    // button 0 affects counter 0
+    // button 1 affects counter 1
+    // Solution: press each once
+    const result = solveCounter([1, 1], [[0], [1]], 3);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('handles modular arithmetic correctly', () => {
+    // target: [0], button 0 affects counter 0, mod 5
+    // Press 0 times or 5 times (but max is mod-1=4). 0 presses is best.
+    const result = solveCounter([0], [[0]], 5);
+    expect(result).toEqual([0]);
+  });
+
+  it('returns minimum total presses', () => {
+    // target: [2], mod 5
+    // button 0 affects counter 0
+    // button 1 affects counter 0
+    // Solutions: (2,0)→total 2, (1,1)→total 2, (0,2)→total 2,
+    //            (3,4)→total 7, (4,3)→total 7
+    // Min total is 2, lex smallest is [0, 2]
+    const result = solveCounter([2], [[0], [0]], 5);
+    expect(result).not.toBeNull();
+    const total = result!.reduce((a, b) => a + b, 0);
+    // Any solution with total 2 is acceptable; lex smallest with total 2
+    expect(total).toBe(2);
+    expect(result).toEqual([0, 2]);
+  });
+
+  it('solves with overlapping buttons', () => {
+    // target: [1, 2], mod 3
+    // button 0 affects [0, 1]
+    // button 1 affects [1]
+    // Equations: x0 ≡ 1 (mod 3), x0 + x1 ≡ 2 (mod 3)
+    // x0 = 1, x1 = 1
+    const result = solveCounter([1, 2], [[0, 1], [1]], 3);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('handles larger modulus', () => {
+    // target: [50], mod 97, button 0 affects counter 0
+    // Solution: press 50 times
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+  });
+
+  it('handles no buttons with zero target', () => {
+    const result = solveCounter([0, 0], [], 3);
+    expect(result).toEqual([]);
+  });
+
+  it('handles no buttons with non-zero target', () => {
+    const result = solveCounter([1], [], 3);
+    expect(result).toBeNull();
+  });
+
+  it('handles multiple solutions and picks lex smallest', () => {
+    // target: [0], mod 3
+    // button 0 affects counter 0
+    // button 1 affects counter 0
+    // Solutions: (0,0)→total 0, best
+    const result = solveCounter([0], [[0], [0]], 3);
+    expect(result).toEqual([0, 0]);
+  });
+});
