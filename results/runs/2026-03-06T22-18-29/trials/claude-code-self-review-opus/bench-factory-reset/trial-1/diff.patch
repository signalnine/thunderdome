   const col = pivotCols[pi];\n    const r = pivotRow[col];\n    if ((rows[r] >> BigInt(numButtons)) & 1n) {\n      rhsMask |= 1 << pi;\n    }\n  }\n\n  const popcount = (x: number): number => {\n    let count = 0;\n    while (x) { count++; x &= x - 1; }\n    return count;\n  };\n\n  // Phase 1: enumerate all 2^half1Size assignments for the first half of free vars.\n  // For each, compute effect1 and freeWeight1 (number of free vars set to 1).\n  // Store the best (min freeWeight1, then lex smallest mask) for each effect1.\n  const half1Count = 1 << half1Size;\n  // Map from effect1 → { freeWeight: number, mask: number }\n  const half1Map = new Map<number, { freeWeight: number; mask: number }>();\n\n  for (let m = 0; m < half1Count; m++) {\n    let effect = 0;\n    let freeWeight = 0;\n    for (let f = 0; f < half1Size; f++) {\n      if ((m >> f) & 1) {\n        effect ^= freeEffect[f];\n        freeWeight++;\n      }\n    }\n    const existing = half1Map.get(effect);\n    if (!existing || freeWeight < existing.freeWeight ||\n        (freeWeight === existing.freeWeight && m < existing.mask)) {\n      half1Map.set(effect, { freeWeight, mask: m });\n    }\n  }\n\n  // Phase 2: enumerate all 2^half2Size assignments for the second half.\n  // For each, compute effect2 and freeWeight2, then iterate over all stored\n  // effect1 values to find the best total.\n  const half2Count = 1 << half2Size;\n\n  let bestCount = numButtons + 1;\n  let bestH1Mask = 0;\n  let bestH2Mask = 0;\n\n  // Convert map to array for faster iteration\n  const half1Entries = Array.from(half1Map.entries());\n\n  for (let m2 = 0; m2 < half2Count; m2++) {\n    let effect2 = 0;\n    let freeWeight2 = 0;\n    for (let f = 0; f < half2Size; f++) {\n      if ((m2 >> f) & 1) {\n        effect2 ^= freeEffect[half1Size + f];\n        freeWeight2++;\n      }\n    }\n\n    const target2 = rhsMask ^ effect2;\n\n    for (const [effect1, { freeWeight: freeWeight1, mask: m1 }] of half1Entries) {\n      const piv