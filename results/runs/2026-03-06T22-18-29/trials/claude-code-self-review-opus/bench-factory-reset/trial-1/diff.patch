\n   564→    // compute pivot weight and total.\n   565→    //\n   566→    // The effect vectors are over numPivots dimensions mod p, so the number of\n   567→    // distinct effects is at most p^numPivots. With numPivots = numButtons - numFree,\n   568→    // and numFree large enough to trigger this branch, numPivots is small.\n   569→\n   570→    solveCounterMITM(matrix, pivotRow, freeVars, numButtons, p, updateBest);\n   571→  }\n   572→\n   573→  return bestResult;\n   574→}\n   575→\n   576→function lexSmallerArr(a: number[], b: number[]): boolean {\n   577→  for (let i = 0; i < a.length; i++) {\n   578→    if (a[i] < b[i]) return true;\n   579→    if (a[i] > b[i]) return false;\n   580→  }\n   581→  return false;\n   582→}\n   583→\n   584→function solveCounterMITM(\n   585→  matrix: number[][],\n   586→  pivotRow: number[],\n   587→  freeVars: number[],\n   588→  numButtons: number,\n   589→  p: number,\n   590→  updateBest: (solution: number[]) => void,\n   591→): void {\n   592→  const numFree = freeVars.length;\n   593→\n   594→  // Identify pivot columns\n   595→  const pivotCols: number[] = [];\n   596→  for (let col = 0; col < numButtons; col++) {\n   597→    if (pivotRow[col] !== -1) pivotCols.push(col);\n   598→  }\n   599→  const numPivots = pivotCols.length;\n   600→\n   601→  // For each free variable, precompute its coefficient for each pivot equation.\n   602→  const coeffs: number[][] = new Array(numFree);\n   603→  for (let f = 0; f < numFree; f++) {\n   604→    coeffs[f] = new Array(numPivots);\n   605→    for (let pi = 0; pi < numPivots; pi++) {\n   606→      const r = pivotRow[pivotCols[pi]];\n   607→      coeffs[f][pi] = matrix[r][freeVars[f]];\n   608→    }\n   609→  }\n   610→\n   611→  // RHS values for each pivot\n   612→  const rhs: number[] = new Array(numPivots);\n   613→  for (let pi = 0; pi < numPivots; pi++) {\n   614→    const r = pivotRow[pivotCols[pi]];\n   615→    rhs[pi] = matrix[r][numButtons];\n   616→  }\n   617→\n   618→ 