+    // target [T, T, F, T], buttons: [0,1], [1,2,3], [0,3]
+    // System: b0^b2=1, b0^b1=1, b1=0, b1^b2=1
+    // b1=0, b0=1, b2=0, check: b1^b2=0≠1 → no solution
+    const machine: Machine = {
+      target: [true, true, false, true],
