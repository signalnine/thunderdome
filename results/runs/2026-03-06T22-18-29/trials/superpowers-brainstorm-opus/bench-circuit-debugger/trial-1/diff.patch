es.length - 1] = { ...gates[gates.length - 1], out: finalZ };\n   156→    return gates;\n   157→  }\n   158→\n   159→  function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n   160→    return gates.map(g => {\n   161→      if (g.out === wire1) return { ...g, out: wire2 };\n   162→      if (g.out === wire2) return { ...g, out: wire1 };\n   163→      return { ...g };\n   164→    });\n   165→  }\n   166→\n   167→  it('should detect swapped z-wires with intermediate wires (valid swaps)', () => {\n   168→    let gates = make4BitAdder();\n   169→    // Swap z01<->a01 (z output with generate)\n   170→    // Swap z02<->b02 (z output with propagate)\n   171→    // Swap z03<->a03 (z output with generate)\n   172→    // Swap z04<->c02 (final z with carry)\n   173→    gates = swapOutputs(gates, 'z01', 'a01');\n   174→    gates = swapOutputs(gates, 'z02', 'b02');\n   175→    gates = swapOutputs(gates, 'z03', 'a03');\n   176→    gates = swapOutputs(gates, 'z04', 'c02');\n   177→\n   178→    const result = findSwappedWires(gates);\n   179→    expect(result).toEqual(['a01', 'a03', 'b02', 'c02', 'z01', 'z02', 'z03', 'z04']);\n   180→  });\n   181→\n   182→  it('should detect swaps between carry and z-wire', () => {\n   183→    let gates = make4BitAdder();\n   184→    // Swap z00<->c00 (bit 0 sum with bit 0 carry)\n   185→    // Swap z01<->a01 (bit 1 sum with bit 1 generate)\n   186→    // Swap z02<->b02 (bit 2 sum with bit 2 propagate)\n   187→    // Swap z03<->b03 (bit 3 sum with bit 3 propagate)\n   188→    gates = swapOutputs(gates, 'z00', 'c00');\n   189→    gates = swapOutputs(gates, 'z01', 'a01');\n   190→    gates = swapOutputs(gates, 'z02', 'b02');\n   191→    gates = swapOutputs(gates, 'z03', 'b03');\n   192→\n   193→    const result = findSwappedWires(gates);\n   194→    expect(result).toEqual(['a01', 'b02', 'b03', 'c00', 'z00', 'z01', 'z02', 'z03']);\n   195→  });\n   196→\n   197→  it('should detect swaps between intermediate wires across bits', () 