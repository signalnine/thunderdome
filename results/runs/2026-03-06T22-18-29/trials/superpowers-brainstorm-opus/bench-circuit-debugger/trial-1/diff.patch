dle gracefully\n        continue;\n      }\n\n      // Step 5: OR(generate, propagate) -> carryOut\n      let orGate = findGate('OR', generate, propagate);\n\n      if (!orGate) {\n        // One of generate or propagate was swapped\n        const byGen = findGateByOpAndInput('OR', generate);\n        if (byGen) {\n          swapped.add(propagate);\n          swapped.add(byGen.otherInput);\n          orGate = byGen.gate;\n        } else {\n          const byProp = findGateByOpAndInput('OR', propagate);\n          if (byProp) {\n            swapped.add(generate);\n            swapped.add(byProp.otherInput);\n            orGate = byProp.gate;\n          }\n        }\n      }\n\n      if (!orGate) continue;\n\n      carry = orGate.out;\n    }\n  }\n\n  // Final carry should be z{numBits}\n  const finalZ = `z${bitStr(numBits)}`;\n  if (carry !== finalZ) {\n    swapped.add(carry);\n    swapped.add(finalZ);\n  }\n\n  return [...swapped].sort();\n}","originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\n/**\n * Simulate a logic gate circuit given initial wire values.\n * Returns the final value of every wire (inputs + computed).\n */\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>\n): Record<string, number> {\n  const wireValues: Record<string, number> = { ...inputs };\n\n  // Map each wire to gates that depend on it as input\n  const dependents = new Map<string, Gate[]>();\n  // Track how many inputs are ready for each gate\n  const readyCount = new Map<Gate, number>();\n\n  for (const gate of gates) {\n    readyCount.set(gate, 0);\n    for (const inputWire of [gate.in1, gate.in2]) {\n      if (!dependents.has(inputWire)) {\n        dependents.set(inputWire, []);\n      }\n      dependents.get(inputWire)!.push(gate);\n    }\n  }\n\n  // Initialize ready counts from known wire values\n  const queue: Gate[] = [];\n  for (const wire of Object.keys(wireValues)) {\n    const deps = dependents.get(wire);\n    if (deps) {\n      for (const gate of deps) {\n        const count = readyCount.get(gate)! + 1;\n        readyCount.set(gate, count);\n        if (count === 2) {\n          queue.push(gate);\n        }\n      }\n    }\n  }\n\n  // Process gates in dependency order\n  while (queue.length > 0) {\n    const gate = queue.pop()!;\n    const a = wireValues[gate.in1];\n    const b = wireValues[gate.in2];\n\n    let result: number;\n    switch (gate.op) {\n      case 'AND':\n        result = a & b;\n        break;\n      case 'OR':\n        result = a | b;\n        break;\n      case 'XOR':\n        result = a ^ b;\n        break;\n    }\n\n    wireValues[gate.out] = result;\n\n    // Notify downstream gates\n    const deps = dependents.get(gate.out);\n    if (deps) {\n      for (const dep of deps) {\n        const count = readyCount.get(dep)! + 1;\n        readyCount.set(dep, count);\n        if (count === 2) {\n          queue.push(dep);\n        }\n      }\n    }\n  }\n\n  return wireValues;\n}\n\n/**\n * Find the 8 wires involved in 4 swap pairs in a broken ripple-carry adder circuit.\n * Returns sorted array of the 8 wire names.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped = new Set<string>();\n\n  // Index gates by (op, sorted inputs) for structural lookup\n  const gateBySignature = new Map<string, Gate>();\n  // Index gate by output wire\n  const gateByOutput = new Map<string, Gate>();\n\n  for (const gate of gates) {\n    const inputs = [gate.in1, gate.in2].sort();\n    const sig = `${gate.op}:${inputs[0]}:${inputs[1]}`;\n    gateBySignature.set(sig, gate);\n    gateByOutput.set(gate.out, gate);\n  }\n\n  function findGate(op: string, wire1: string, wire2: string): Gate | undefined {\n    const inputs = [wire1, wire2].sort();\n    const sig = `${op}:${inputs[0]}:${inputs[1]}`;\n    return gateBySignature.get(sig);\n  }\n\n  function bitStr(n: number): string {\n    return n.toString().padStart(2, '0');\n  }\n\n  // Determine number of input bits by finding max x-wire index\n  let maxBit = 0;\n  for (const gate of gates) {\n    for (const wire of [gate.in1, gate.in2, gate.out]) {\n      const match = wire.match(/^x(\\d+)$/);\n      if (match) {\n        maxBit = Math.max(maxBit, parseInt(match[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n\n  // Walk the adder structure bit by bit\n  let carry = '';\n\n  for (let i = 0; i < numBits; i++) {\n    const xi = `x${bitStr(i)}`;\n    const yi = `y${bitStr(i)}`;\n    const zi = `z${bitStr(i)}`;\n\n    if (i === 0) {\n      // Half adder: XOR -> z00, AND -> carry\n      const xorGate = findGate('XOR', xi, yi);\n      const andGate = findGate('AND', xi, yi);\n\n      if (!xorGate || !andGate) continue;\n\n      if (xorGate.out !== zi) {\n        swapped.add(xorGate.out);\n        swapped.add(zi);\n      }\n\n      carry = andGate.out;\n\n      // Check if carry got a z-name it shouldn't have\n      if (carry.startsWith('z')) {\n        swapped.add(carry);\n        // Find what it was swapped with - the gate that should output this z wire\n        // We'll handle this through the z-check below\n      }\n    } else {\n      // Full adder\n      // Step 1: XOR(xi, yi) -> partial_sum\n      const xorXY = findGate('XOR', xi, yi);\n      if (!xorXY) continue;\n\n      let partialSum = xorXY.out;\n\n      // Step 2: XOR(partial_sum, carry) -> zi\n      let xorSumCarry = findGate('XOR', partialSum, carry);\n\n      // If we can't find this gate, one of partialSum or carry might be swapped.\n      // Try to identify the correct wires.\n      if (!xorSumCarry) {\n        // partialSum might have been swapped with something else.\n        // We know the XOR gate that produces zi must exist.\n        // Look for any XOR gate that uses carry as one input.\n        // Or look for any XOR gate that uses partialSum as one input (other than xorXY).\n\n        // Strategy: check if partialSum was swapped\n        // The gate outputting partialSum should be xorXY.\n        // If partialSum is wrong, we need to find what it was swapped with.\n\n        // Try: find a XOR gate using carry as input\n        let found = false;\n        for (const gate of gates) {\n          if (gate.op === 'XOR' && gate !== xorXY) {\n            if (gate.in1 === carry || gate.in2 === carry) {\n              // This gate uses carry. Its other input should be partialSum.\n              const otherInput = gate.in1 === carry ? gate.in2 : gate.in1;\n              // otherInput is the actual partialSum wire, which means partialSum was swapped\n              // Actually: xorXY.out (partialSum) was swapped with something\n              // The gate that actually connects carry expects the real partial sum as input\n              // otherInput IS the wire that acts as partial sum in the circuit\n              // But xorXY outputs to 'partialSum' which went somewhere else\n              // So xorXY.out was swapped with otherInput? No...\n\n              // Let me think again. xorXY's output is named `partialSum` but it might\n              // have been swapped. If the XOR-carry gate uses `otherInput` instead of\n              // `partialSum`, it means `partialSum` (xorXY.out) was swapped with something.\n              // We need to figure out what.\n\n              // Actually, swap means: xorXY.out and some other gate's output were exchanged.\n              // So xorXY.out has the name that belongs to another gate, and another gate\n              // has the name that should be xorXY.out.\n              //\n              // The real partial sum wire flows into xorSumCarry. So the \"real\" partial sum\n              // wire name is `otherInput`. That means some gate outputs `otherInput` but\n              // shouldn't - it should output `partialSum`, and xorXY should output `otherInput`.\n\n              swapped.add(partialSum);\n              swapped.add(otherInput);\n\n              // Fix partialSum for the rest of this bit's processing\n              partialSum = otherInput;\n              xorSumCarry = gate;\n              found = true;\n              break;\n            }\n            if (gate.in1 === partialSum || gate.in2 === partialSum) {\n              // This gate uses partialSum. Its other input should be carry.\n              const otherInput = gate.in1 === partialSum ? gate.in2 : gate.in1;\n              // otherInput should be carry, but carry is wrong\n              // carry (from previous bit) was swapped with something\n              swapped.add(carry);\n              swapped.add(otherInput);\n\n              carry = otherInput;\n              xorSumCarry = gate;\n              found = true;\n              break;\n            }\n          }\n        }\n        if (!found) continue;\n      }\n\n      // Check if the sum XOR gate outputs the correct z-wire\n      if (xorSumCarry!.out !== zi) {\n        swapped.add(xorSumCarry!.out);\n        swapped.add(zi);\n\n        // If xorSumCarry.out was swapped with zi, and zi is used elsewhere,\n        // we need to fix the name for subsequent lookups\n        // But since we only check z-names, and the actual wire connectivity\n        // uses the real names, we just record the swap\n      }\n\n      // Step 3: AND(xi, yi) -> generate\n      const andXY = findGate('AND', xi, yi);\n      if (!andXY) continue;\n      const generate = andXY.out;\n\n      // Step 4: AND(partial_sum, carry) -> propagate\n      const andSumCarry = findGate('AND', partialSum, carry);\n      if (!andSumCarry) continue;\n      const propagate = andSumCarry.out;\n\n      // Step 5: OR(generate, propagate) -> carry_out\n      let orGate = findGate('OR', generate, propagate);\n\n      if (!orGate) {\n        // One of generate or propagate may be swapped\n        // Try to find the OR gate that uses one of them\n        for (const gate of gates) {\n          if (gate.op === 'OR') {\n            if (gate.in1 === generate || gate.in2 === generate) {\n              const otherInput = gate.in1 === generate ? gate.in2 : gate.in1;\n              swapped.add(propagate);\n              swapped.add(otherInput);\n              orGate = gate;\n              break;\n            }\n            if (gate.in1 === propagate || gate.in2 === propagate) {\n              const otherInput = gate.in1 === propagate ? gate.in2 : gate.in1;\n              swapped.add(generate);\n              swapped.add(otherInput);\n              orGate = gate;\n              break;\n            }\n          }\n        }\n        if (!orGate) continue;\n      }\n\n      carry = orGate.out;\n\n      // Check if intermediate wires got z-names they shouldn't have\n      if (generate.startsWith('z') && generate !== zi) {\n        swapped.add(generate);\n      }\n      if (propagate.startsWith('z') && propagate !== zi) {\n        swapped.add(propagate);\n      }\n      if (carry.startsWith('z') && carry !== `z${bitStr(numBits)}`) {\n        // Carry should not be a z-wire (except possibly the final carry)\n        swapped.add(carry);\n        // Need to find what it was swapped with - this will be caught\n        // when we check the z-output for the bit that this z-wire belongs to\n      }\n    }\n  }\n\n  // Final carry should be z{numBits}\n  const finalZ = `z${bitStr(numBits)}`;\n  if (carry !== finalZ) {\n    swapped.add(carry);\n    swapped.add(finalZ);\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":85,"oldLines":6,"newStart":85,"newLines":14,"lines":[" /**","  * Find the 8 wires involved in 4 swap pairs in a broken ripple-carry adder circuit.","  * Returns sorted array of the 8 wire names.","+ *","+ * Strategy: Walk the expected ripple-carry adder structure bit by bit.","+ * Since only OUTPUT wire names are swapped (not inputs or operations), we can","+ * identify each gate by (op, {in1, in2}). We track the actual wire name that","+ * carries each signal, and detect swaps when:","+ * 1. A z-output gate doesn't output 