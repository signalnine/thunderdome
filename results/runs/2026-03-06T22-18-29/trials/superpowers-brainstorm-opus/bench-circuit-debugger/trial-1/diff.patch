nerateWire, 'OR');\n        const propOrConsumers = getConsumers(propagateWire, 'OR');\n\n        if (genOrConsumers.length > 0) {\n          orGate = genOrConsumers[0];\n          const otherInput = orGate.in1 === generateWire ? orGate.in2 : orGate.in1;\n          swapped.add(propagateWire);\n          swapped.add(otherInput);\n        } else if (propOrConsumers.length > 0) {\n          orGate = propOrConsumers[0];\n          const otherInput = orGate.in1 === propagateWire ? orGate.in2 : orGate.in1;\n          swapped.add(generateWire);\n          swapped.add(otherInput);\n        }\n      }\n    }\n\n    if (orGate) {\n      carryWire = orGate.out;\n    } else {\n      break;\n    }\n  }\n\n  // Final carry should be z{numBits}\n  const finalZ = `z${bitStr(numBits)}`;\n  if (carryWire !== finalZ) {\n    swapped.add(carryWire);\n    swapped.add(finalZ);\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":213,"oldLines":29,"newStart":213,"newLines":50,"lines":["         if (!candidates.includes(g)) candidates.push(g);","       }"," ","-      // Find the candidate that has a matching AND gate with the same inputs","+      // Find the candidate that belongs to THIS bit position.","+      // The sum XOR for bit i should have one input that is the output of","+      // XOR(xi, yi) — i.e., one input should be `partialSumWire` OR should be","+      // the output of the first-level XOR gate for bit i (if partialSum was swapped,","+      // the input still references the OLD name, which traces back to xorI).","+      //","+      // We verify by checking: one of the candidate's inputs should be produced","+      // by xorI (the first-level XOR for this bit), even if the wire name differs.","       for (const candidate of candidates) {","         const matchingAnd = findGate('AND', candidate.in1, candidate.in2);","-        if (matchingAnd) {","-          sumXorGate = candidate;","-          // Determine which wire was swapped","-          const hasParti