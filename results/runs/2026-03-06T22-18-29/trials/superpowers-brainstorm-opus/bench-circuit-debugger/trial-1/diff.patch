:"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from './index.js';\n\ndescribe('simulate', () => {\n  it('should evaluate a single AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should evaluate a single OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n  });\n\n  it('should evaluate a single XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n  });\n\n  it('should handle chained gates (dependency order)', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    expect(result).toEqual({ a: 1, b: 1, c: 1, d: 0, e: 1 });\n  });\n\n  it('should simulate a 4-bit adder computing 3+5=8', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n    ];\n\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 0, x03: 0,\n      y00: 1, y01: 0, y02: 1, y03: 0,\n    };\n\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(1);\n    expect(result.c03).toBe(0);\n  });\n\n  it('should simulate a 4-bit adder computing 7+7=14', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n    ];\n\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 1, x03: 0,\n      y00: 1, y01: 1, y02: 1, y03: 0,\n    };\n\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n    expect(result.z03).toBe(1);\n    expect(result.c03).toBe(0);\n  });\n\n  it('should handle gates listed in reverse order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    expect(result.e).toBe(1);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function make4BitAdder(): Gate[] {\n    return [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n  }\n\n  function makeNBitAdder(n: number): Gate[] {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    ];\n    for (let i = 1; i < n; i++) {\n      const bi = i.toString().padStart(2, '0');\n      const bprev = (i - 1).toString().padStart(2, '0');\n      gates.push(\n        { op: 'XOR', in1: 'x' + bi, in2: 'y' + bi, out: 't' + bi },\n        { op: 'XOR', in1: 't' + bi, in2: 'c' + bprev, out: 'z' + bi },\n        { op: 'AND', in1: 'x' + bi, in2: 'y' + bi, out: 'a' + bi },\n        { op: 'AND', in1: 't' + bi, in2: 'c' + bprev, out: 'b' + bi },\n        { op: 'OR', in1: 'a' + bi, in2: 'b' + bi, out: 'c' + bi },\n      );\n    }\n    const finalZ = 'z' + n.toString().padStart(2, '0');\n    gates[gates.length - 1] = { ...gates[gates.length - 1], out: finalZ };\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n    return gates.map(g => {\n      if (g.out === wire1) return { ...g, out: wire2 };\n      if (g.out === wire2) return { ...g, out: wire1 };\n      return { ...g };\n    });\n  }\n\n  it('should detect swapped z-wires with intermediate wires (valid swaps)', () => {\n    let gates = make4BitAdder();\n    // Swap z01<->a01 (z output with generate)\n    // Swap z02<->b02 (z output with propagate)\n    // Swap z03<->a03 (z output with generate)\n    // Swap z04<->c02 (final z with carry)\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z02', 'b02');\n    gates = swapOutputs(gates, 'z03', 'a03');\n    gates = swapOutputs(gates, 'z04', 'c02');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a03', 'b02', 'c02', 'z01', 'z02', 'z03', 'z04']);\n  });\n\n  it('should detect swaps between carry and z-wire', () => {\n    let gates = make4BitAdder();\n    // Swap z00<->c00 (bit 0 sum with bit 0 carry)\n    // Swap z01<->a01 (bit 1 sum with bit 1 generate)\n    // Swap z02<->b02 (bit 2 sum with bit 2 propagate)\n    // Swap z03<->b03 (bit 3 sum with bit 3 propagate)\n    gates = swapOutputs(gates, 'z00', 'c00');\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z02', 'b02');\n    gates = swapOutputs(gates, 'z03', 'b03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'b02', 'b03', 'c00', 'z00', 'z01', 'z02', 'z03']);\n  });\n\n  it('should detect swaps between intermediate wires across bits', () => {\n    let gates = make4BitAdder();\n    // Swap z01<->a03 (z output of bit 1 with generate of bit 3)\n    // Swap z02<->b01 (z output of bit 2 with propagate of bit 1)\n    // Swap z03<->a02 (z output of bit 3 with generate of bit 2)\n    // Swap z04<->c01 (final z with carry of bit 1)\n    gates = swapOutputs(gates, 'z01', 'a03');\n    gates = swapOutputs(gates, 'z02', 'b01');\n    gates = swapOutputs(gates, 'z03', 'a02');\n    gates = swapOutputs(gates, 'z04', 'c01');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a02', 'a03', 'b01', 'c01', 'z01', 'z02', 'z03', 'z04']);\n  });\n\n  it('should handle larger adder circuits', () => {\n    const gates = makeNBitAdder(8);\n    // Apply 4 swaps: z-wires with non-z intermediate wires\n    let swapped = swapOutputs(gates, 'z01', 'a01');\n    swapped = swapOutputs(swapped, 'z03', 'b03');\n    swapped = swapOutputs(swapped, 'z05', 'a05');\n    swapped = swapOutputs(swapped, 'z07', 'b07');\n\n    const result = findSwappedWires(swapped);\n    expect(result).toEqual(['a01', 'a05', 'b03', 'b07', 'z01', 'z03', 'z05', 'z07']);\n  });\n\n  it('should handle 45-bit adder within performance constraints', () => {\n    const gates = makeNBitAdder(45);\n    // Apply 4 swaps spread across the circuit\n    let swapped = swapOutputs(gates, 'z10', 'a10');\n    swapped = swapOutputs(swapped, 'z20', 'b20');\n    swapped = swapOutputs(swapped, 'z30', 'a30');\n    swapped = swapOutputs(swapped, 'z44', 'b44');\n\n    const start = Date.now();\n    const result = findSwappedWires(swapped);\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(['a10', 'a30', 'b20', 'b44', 'z10', 'z20', 'z30', 'z44']);\n  });\n\n  it('should detect partial sum swapped with generate across bits', () => {\n    const gates = makeNBitAdder(8);\n    // Swap t01<->a03 (partial sum of bit 1 with generate of bit 3)\n    // Swap z02<->b02 (z output with propagate, same bit)\n    // Swap z04<->a04 (z output with generate, same bit)\n    // Swap z06<->a06 (z output with generate, same bit)\n    let swapped = swapOutputs(gates, 't01', 'a03');\n    swapped = swapOutputs(swapped, 'z02', 'b02');\n    swapped = swapOutputs(swapped, 'z04', 'a04');\n    swapped = swapOutputs(swapped, 'z06', 'a06');\n\n    const result = findSwappedWires(swapped);\n    expect(result).toEqual(['a03', 'a04', 'a06', 'b02', 't01', 'z02', 'z04', 'z06']);\n  });\n\n  it('should detect carry output swapped with z-wire of different bit', () => {\n    const gates = makeNBitAdder(8);\n    // Swap c01<->z05 (carry of bit 1 with z output of bit 5)\n    // Swap z01<->a01 (z output with generate)\n    // Swap z03<->b03 (z output with propagate)\n    // Swap z08<->c06 (final z with carry of bit 6)\n    let swapped = swapOutputs(gates, 'c01', 'z05');\n    swapped = swapOutputs(swapped, 'z01', 'a01');\n    swapped = swapOutputs(swapped, 'z03', 'b03');\n    swapped = swapOutputs(swapped, 'z08', 'c06');\n\n    const result = findSwappedWires(swapped);\n    expect(result).toEqual(['a01', 'b03', 'c01', 'c06', 'z01', 'z03', 'z05', 'z08']);\n  });\n});\n","structuredPatch":[{"oldStart":35,"oldLines":24,"newStart":35,"newLines":19,"lines":["   });"," ","   it('should simulate a 4-bit adder computing 3+5=8', () => {","-    // 3 = 0011, 5 = 0101, 8 = 01000","     const gates: Gate[] = [","-      // Bit 0","       { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },","       { op: 'AND', in1: 'x00', in2: 'y00', out: