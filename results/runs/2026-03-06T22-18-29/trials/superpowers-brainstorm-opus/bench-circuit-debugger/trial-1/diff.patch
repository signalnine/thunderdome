+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a logic gate circuit given initial wire values.
+ * Returns the final value of every wire (inputs + computed).
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wireValues: Record<string, number> = { ...inputs };
+
+  // Map each wire to gates that depend on it as input
+  const dependents = new Map<string, Gate[]>();
+  // Track how many inputs are ready for each gate
+  const readyCount = new Map<Gate, number>();
+
+  for (const gate of gates) {
+    readyCount.set(gate, 0);
+    for (const inputWire of [gate.in1, gate.in2]) {
+      if (!dependents.has(inputWire)) {
+        dependents.set(inputWire, []);
+      }
+      dependents.get(inputWire)!.push(gate);
+    }
+  }
+
+  // Initialize ready counts from known wire values
+  const queue: Gate[] = [];
+  for (const wire of Object.keys(wireValues)) {
+    const deps = dependents.get(wire);
+    if (deps) {
+      for (const gate of deps) {
+        const count = readyCount.get(gate)! + 1;
+        readyCount.set(gate, count);
+        if (count === 2) {
+          queue.push(gate);
+        }
+      }
+    }
+  }
+
+  // Process gates in dependency order
+  while (queue.length > 0) {
+    const gate = queue.pop()!;
+    const a = wireValues[gate.in1];
+    const b = wireValues[gate.in2];
+
+    let result: number;
+    switch (gate.op) {
+      case 'AND':
+        result = a & b;
+        break;
+      case 'OR':
+        result = a | b;
+        break;
+      case 'XOR':
+        result = a ^ b;
+        break;
+    }
+
+    wireValues[gate.out] = result;
+
+    // Notify downstream gates
+    const deps = dependents.get(gate.out);
+    if (deps) {
+      for (const dep of deps) {
+        const count = readyCount.get(dep)! + 1;
+        readyCount.set(dep, count);
+        if (count === 2) {
+          queue.push(dep);
+        }
+      }
+    }
+  }
+
+  return wireValues;
+}
+
+/**
+ * Find the 8 wires involved in 4 swap pairs in a broken ripple-carry adder circuit.
+ * Returns sorted array of the 8 wire names.
+ *
+ * Uses a forward walk through the adder structure, identifying gates by their
+ * (operation, sorted inputs) signature which is invariant under output-only swaps.
+ * Compares actual output wire names against expected names to detect swaps.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  const swapped = new Set<string>();
+
+  function bitStr(n: number): string {
+    return n.toString().padStart(2, '0');
+  }
+
+  // Build index: (op, sorted inputs) -> gate
+  const gateBySignature = new Map<string, Gate>();
+  // Build index: wire -> gates consuming it
+  const consumers = new Map<string, Gate[]>();
+
+  for (const gate of gates) {
+    const inputs = [gate.in1, gate.in2].sort();
+    gateBySignature.set(`${gate.op}:${inputs[0]}:${inputs[1]}`, gate);
+    for (const w of [gate.in1, gate.in2]) {
+      if (!consumers.has(w)) consumers.set(w, []);
+      consumers.get(w)!.push(gate);
+    }
+  }
+
+  function findGate(op: string, w1: string, w2: string): Gate | undefined {
+    const inputs = [w1, w2].sort();
+    return gateBySignature.get(`${op}:${inputs[0]}:${inputs[1]}`);
+  }
+
+  function getConsumers(wire: string, op: string): Gate[] {
+    return (consumers.get(wire) || []).filter(g => g.op === op);
+  }
+
+  // Determine number of input bits
+  let maxBit = 0;
+  for (const gate of gates) {
+    for (const wire of [gate.in1, gate.in2]) {
+      const match = wire.match(/^x(\d+)$/);
+      if (match) {
+        maxBit = Math.max(maxBit, parseInt(match[1], 10));
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+  const finalZ = `z${bitStr(numBits)}`;
+
+  // Categorize XOR(xi,yi) and AND(xi,yi) gates by bit position
+  const xorXY = new Map<number, Gate>();
+  const andXY = new Map<number, Gate>();
+
+  for (const gate of gates) {
+    const inputs = [gate.in1, gate.in2].sort();
+    const xMatch = inputs[0].match(/^x(\d+)$/);
+    const yMatch = inputs[1].match(/^y(\d+)$/);
+    if (xMatch && yMatch && xMatch[1] === yMatch[1]) {
+      const bit = parseInt(xMatch[1], 10);
+      if (gate.op === 'XOR') xorXY.set(bit, gate);
+      else if (gate.op === 'AND') andXY.set(bit, gate);
+    }
+  }
+
+  // Bit 0: half adder
+  const xor0 = xorXY.get(0)!;
+  const and0 = andXY.get(0)!;
+
+  if (xor0.out !== 'z00') {
+    swapped.add(xor0.out);
+    swapped.add('z00');
+  }
+
+  let carryWire = and0.out;
+
+  // Bits 1..N-1: full adders
+  for (let i = 1; i < numBits; i++) {
+    const zi = `z${bitStr(i)}`;
+    const xorI = xorXY.get(i)!;
+    const andI = andXY.get(i)!;
+    const partialSumWire = xorI.out;
+
+    // Find the sum XOR gate: XOR(partialSum, carry) -> zi
+    let sumXorGate = findGate('XOR', partialSumWire, carryWire);
+
+    if (!sumXorGate) {
+      // The gate XOR(partialSum, carry) doesn't exist. This means either
+      // partialSumWire or carryWire was swapped with something else.
+      // Try to find the sum XOR gate via consumers of partialSumWire.
+      const psXorConsumers = getConsumers(partialSumWire, 'XOR')
+        .filter(g => g !== xorI); // exclude the first-level XOR(xi,yi) itself
+
+      if (psXorConsumers.length > 0) {
+        // The XOR consumer of partialSum uses a different carry wire
+        sumXorGate = psXorConsumers[0];
+        const otherInput = sumXorGate.in1 === partialSumWire
+          ? sumXorGate.in2 : sumXorGate.in1;
+        // carryWire and otherInput are swapped
+        swapped.add(carryWire);
+        swapped.add(otherInput);
+        carryWire = otherInput;
+      } else {
+        // partialSumWire has no XOR consumers (other than its own producer).
+        // This means partialSumWire itself was swapped. The real partial sum
+        // wire is whatever the other XOR gate (sum gate) at this bit uses.
+        // Look for XOR consumers of carryWire instead.
+        const carryXorConsumers = getConsumers(carryWire, 'XOR');
+        if (carryXorConsumers.length > 0) {
+          sumXorGate = carryXorConsumers[0];
+          const otherInput = sumXorGate.in1 === carryWire
+            ? sumXorGate.in2 : sumXorGate.in1;
+          // partialSumWire and otherInput are swapped
+          swapped.add(partialSumWire);
+          swapped.add(otherInput);
+        }
+      }
+    }
+
+    if (!sumXorGate) {
+      // Can't find the sum gate at all; skip this bit
+      continue;
+    }
+
+    // Check if sum gate output is correct
+    if (sumXorGate.out !== zi) {
+      swapped.add(sumXorGate.out);
+      swapped.add(zi);
+    }
+
+    // Find the propagate AND gate: AND(sumXorGate.in1, sumXorGate.in2)
+    const propAndGate = findGate('AND', sumXorGate.in1, sumXorGate.in2);
+    if (!propAndGate) continue;
+
+    const generateWire = andI.out;
+    const propagateWire = propAndGate.out;
+
+    // Find the carry OR gate: OR(generate, propagate)
+    let orGate = findGate('OR', generateWire, propagateWire);
+
+    if (!orGate) {
+      // OR gate not found. Either generateWire or propagateWire was swapped.
+      const genOrConsumers = getConsumers(generateWire, 'OR');
+      const propOrConsumers = getConsumers(propagateWire, 'OR');
+
+      if (genOrConsumers.length > 0) {
+        orGate = genOrConsumers[0];
+        const otherInput = orGate.in1 === generateWire
+          ? orGate.in2 : orGate.in1;
+        swapped.add(propagateWire);
+        swapped.add(otherInput);
+      } else if (propOrConsumers.length > 0) {
+        orGate = propOrConsumers[0];
+        const otherInput = orGate.in1 === propagateWire
+          ? orGate.in2 : orGate.in1;
+        swapped.add(generateWire);
+        swapped.add(otherInput);
+      }
+    }
+
+    if (orGate) {
+      carryWire = orGate.out;
+    }
+  }
+
+  // Final carry should be finalZ
+  if (carryWire !== finalZ) {
+    swapped.add(carryWire);
+    swapped.add(finalZ);
+  }
+
+  return [...swapped].sort();
+}
