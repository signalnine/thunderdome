+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'b02', 'b03', 'c00', 'z00', 'z01', 'z02', 'z03']);
+  });
+
+  it('should detect swaps between intermediate wires across bits', () => {
+    let gates = make4BitAdder();
+    // Swap z01<->a03 (z output of bit 1 with generate of bit 3)
+    // Swap z02<->b01 (z output of bit 2 with propagate of bit 1)
+    // Swap z03<->a02 (z output of bit 3 with generate of bit 2)
+    // Swap z04<->c01 (final z with carry of bit 1)
+    gates = swapOutputs(gates, 'z01', 'a03');
+    gates = swapOutputs(gates, 'z02', 'b01');
+    gates = swapOutputs(gates, 'z03', 'a02');
+    gates = swapOutputs(gates, 'z04', 'c01');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a02', 'a03', 'b01', 'c01', 'z01', 'z02', 'z03', 'z04']);
+  });
+
+  it('should handle larger adder circuits', () => {
+    const gates = makeNBitAdder(8);
+    // Apply 4 swaps: z-wires with non-z intermediate wires
+    let swapped = swapOutputs(gates, 'z01', 'a01');
+    swapped = swapOutputs(swapped, 'z03', 'b03');
+    swapped = swapOutputs(swapped, 'z05', 'a05');
+    swapped = swapOutputs(swapped, 'z07', 'b07');
+
+    const result = findSwappedWires(swapped);
+    expect(result).toEqual(['a01', 'a05', 'b03', 'b07', 'z01', 'z03', 'z05', 'z07']);
+  });
+
+  it('should handle 45-bit adder within performance constraints', () => {
+    const gates = makeNBitAdder(45);
+    // Apply 4 swaps spread across the circuit
+    let swapped = swapOutputs(gates, 'z10', 'a10');
+    swapped = swapOutputs(swapped, 'z20', 'b20');
+    swapped = swapOutputs(swapped, 'z30', 'a30');
+    swapped = swapOutputs(swapped, 'z44', 'b44');
+
+    const start = Date.now();
+    const result = findSwappedWires(swapped);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).toEqual(['a10', 'a30', 'b20', 'b44', 'z10', 'z20', 'z30', 'z44']);
+  });
+
+  it('should detect partial sum swapped with generate across bits', () => {
+    const gates = makeNBitAdder(8);
+    // Swap t01<->a03 (partial sum of bit 1 with generate of bit 3)
+    // Swap z02<->b02 (z output with propagate, same bit)
+    // Swap z04<->a04 (z output with generate, same bit)
+    // Swap z06<->a06 (z output with generate, same bit)
+    let swapped = swapOutputs(gates, 't01', 'a03');
+    swapped = swapOutputs(swapped, 'z02', 'b02');
+    swapped = swapOutputs(swapped, 'z04', 'a04');
+    swapped = swapOutputs(swapped, 'z06', 'a06');
+
+    const result = findSwappedWires(swapped);
+    expect(result).toEqual(['a03', 'a04', 'a06', 'b02', 't01', 'z02', 'z04', 'z06']);
+  });
+
+  it('should detect carry output swapped with z-wire of different bit', () => {
+    const gates = makeNBitAdder(8);
+    // Swap c01<->z05 (carry of bit 1 with z output of bit 5)
+    // Swap z01<->a01 (z output with generate)
+    // Swap z03<->b03 (z output with propagate)
+    // Swap z08<->c06 (final z with carry of bit 6)
+    let swapped = swapOutputs(gates, 'c01', 'z05');
+    swapped = swapOutputs(swapped, 'z01', 'a01');
+    swapped = swapOutputs(swapped, 'z03', 'b03');
+    swapped = swapOutputs(swapped, 'z08', 'c06');
+
+    const result = findSwappedWires(swapped);
+    expect(result).toEqual(['a01', 'b03', 'c01', 'c06', 'z01', 'z03', 'z05', 'z08']);
+  });
+});
