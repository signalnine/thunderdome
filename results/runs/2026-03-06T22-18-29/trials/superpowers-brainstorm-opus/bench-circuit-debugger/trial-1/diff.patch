+    // Swap z02<->b02 (z output with propagate)
+    // Swap z03<->a03 (z output with generate)
+    // Swap z04<->c02 (final z with carry)
+    gates = swapOutputs(gates, 'z01', 'a01');
+    gates = swapOutputs(gates, 'z02', 'b02');
+    gates = swapOutputs(gates, 'z03', 'a03');
+    gates = swapOutputs(gates, 'z04', 'c02');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'a03', 'b02', 'c02', 'z01', 'z02', 'z03', 'z04']);
+  });
+
+  it('should detect swaps between carry and z-wire', () => {
+    let gates = make4BitAdder();
+    // Swap z00<->c00 (bit 0 sum with bit 0 carry)
+    // Swap z01<->a01 (bit 1 sum with bit 1 generate)
+    // Swap z02<->b02 (bit 2 sum with bit 2 propagate)
+    // Swap z03<->b03 (bit 3 sum with bit 3 propagate)
+    gates = swapOutputs(gates, 'z00', 'c00');
+    gates = swapOutputs(gates, 'z01', 'a01');
+    gates = swapOutputs(gates, 'z02', 'b02');
+    gates = swapOutputs(gates, 'z03', 'b03');
