rategy: check each gate's output against structural rules.\n  // A gate's output is \"wrong\" if:\n  //   1. It should be a z-wire but isn't\n  //   2. It IS a z-wire but shouldn't be\n  //   3. It doesn't connect properly to expected downstream gates\n\n  // We'll use a different approach: check structural rules for each gate.\n  // Rule 1: XOR gates with x/y inputs (partial sum) should NOT output z-wires\n  //         (except bit 0 which should output z00)\n  // Rule 2: XOR gates without x/y inputs (final sum) SHOULD output z-wires\n  // Rule 3: AND gates should NOT output z-wires\n  // Rule 4: OR gates should NOT output z-wires (except the final carry -> z{N})\n  // Rule 5: For each z-wire, the gate producing it should be appropriate\n\n  // But this alone won't catch all swaps (e.g., two intermediate wires swapped).\n  // We need the structural walk too.\n\n  // Combined approach: Walk the structure using INPUT wire names to identify\n  // gate roles, then check outputs.\n\n  // The trick for walking: we need to find \"the gate that uses wire W as input\"\n  // to trace from one gate's output to the next gate.\n  // Build: wire -> list of gates that use it as input\n  const consumers = new Map<string, Gate[]>();\n  for (const gate of gates) {\n    for (const w of [gate.in1, gate.in2]) {\n      if (!consumers.has(w)) consumers.set(w, []);\n      consumers.get(w)!.push(gate);\n    }\n  }\n\n  // For bit 0: check half adder\n  const xor0 = xorXY.get(0)!;\n  const and0 = andXY.get(0)!;\n\n  if (xor0.out !== 'z00') {\n    swapped.add(xor0.out);\n    swapped.add('z00');\n  }\n\n  // The carry wire name for bit 0 is and0.out\n  // Downstream gates reference this wire by name in their inputs\n  let carryWire = and0.out;\n\n  for (let i = 1; i < numBits; i++) {\n    const zi = `z${bitStr(i)}`;\n\n    const xorI = xorXY.get(i)!;\n    const andI = andXY.get(i)!;\n\n    // XOR(xi, yi).out = partial sum wire name\n    const partialSumWire = xorI.out;\n\n    // The partial sum wire should be used by exactly 2 downstream gates:\n    // 1. XOR(partialSum, carry) -> zi (sum)\n    // 2. AND(partialSum, carry) -> propagate\n    // The carry wire should also be used by these same 2 gates.\n\n    // Find the sum XOR gate: it uses partialSumWire as input and is a XOR\n    // But we need to distinguish it from xorI itself.\n    let sumXorGate: Gate | undefined;\n    let propAndGate: Gate | undefined;\n\n    const psConsumers = consumers.get(partialSumWire) || [];\n    for (const g of psConsumers) {\n      if (g.op === 'XOR') sumXorGate = g;\n      if (g.op === 'AND') propAndGate = g;\n    }\n\n    // If we can't find the sum XOR gate using partialSumWire, the partial sum\n    // wire was swapped. The gate that should consume the partial sum instead\n    // consumes a different wire (the one that was swapped with partialSumWire).\n    if (!sumXorGate) {\n      // partialSumWire (xorI.out) is swapped. The downstream XOR gate that\n      // produces zi has an input that should be partialSumWire but instead\n      // references whatever wire was swapped into xorI's output.\n      //\n      // Find it by looking at carryWire consumers: the sum XOR uses carry too.\n      const carryConsumers = consumers.get(carryWire) || [];\n      for (const g of carryConsumers) {\n        if (g.op === 'XOR') {\n          sumXorGate = g;\n          // The other input of this gate is what partialSumWire should have been\n          const correctPSWire = g.in1 === carryWire ? g.in2 : g.in1;\n          swapped.add(partialSumWire);\n          swapped.add(correctPSWire);\n          break;\n        }\n      }\n    }\n\n    // If we still can't find it via carry consumers, carry itself might be swapped\n    if (!sumXorGate) {\n      // Both partialSum and carry might be swapped, or carry is swapped\n      // This is a complex case. For now, skip.\n      // Actually: if carry wire doesn't appear in any XOR gate input,\n      // then carry was swapped. We should have detected this earlier or\n      // handle it now.\n      // TODO: handle this case\n      continue;\n    }\n\n    // Verify the sum XOR gate also uses the carry wire\n    const sumXorOtherInput = sumXorGate.in1 === partialSumWire ? sumXorGate.in2 :\n                              sumXorGate.in2 === partialSumWire ? sumXorGate.in1 :\n                              // partialSumWire was corrected above, so check both inputs\n                              sumXorGate.in1 === carryWire ? sumXorGate.in2 : sumXorGate.in1;\n\n    if (sumXorOtherInput !== carryWire) {\n      // The sum XOR gate uses a different wire instead of carry.\n      // This means carry was swapped.\n      // Actually, this could mean partialSum was swapped and we already\n      // found the gate via carry. Let's check.\n      if (sumXorGate.in1 !== carryWire && sumXorGate.in2 !== carryWire) {\n        // Neither input is carry. This shouldn't happen if we found it via carry.\n        // Skip for now.\n      }\n    }\n\n    // Check if sum XOR outputs the correct z-wire\n    if (sumXorGate.out !== zi) {\n      swapped.add(sumXorGate.out);\n      swapped.add(zi);\n    }\n\n    // Find the propagate AND gate (uses partialSum and carry as inputs)\n    if (!propAndGate) {\n      // Similar to above - if partialSumWire was swapped, we need to find\n      // the AND gate via carry consumers\n      const carryConsumers = consumers.get(carryWire) || [];\n      for (const g of carryConsumers) {\n        if (g.op === 'AND') {\n          propAndGate = g;\n          break;\n        }\n      }\n    }\n\n    // The generate wire is andI.out\n    const generateWire = andI.out;\n    // The propagate wire is propAndGate?.out\n    const propagateWire = propAndGate?.out;\n\n    // Find the OR gate: it uses generate and propagate as inputs\n    let orGate: Gate | undefined;\n\n    if (propagateWire) {\n      // Look for OR gate that uses generateWire\n      const genConsumers = consumers.get(generateWire) || [];\n      for (const g