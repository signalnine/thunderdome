boolean {\n    return isXYInput(gate.in1) || isXYInput(gate.in2);\n  }\n\n  function isFirstBitGate(gate: Gate): boolean {\n    const inputs = [gate.in1, gate.in2].sort();\n    return (inputs[0] === 'x00' && inputs[1] === 'y00');\n  }\n\n  // Check each gate against structural rules\n  for (const gate of gates) {\n    const out = gate.out;\n\n    if (gate.op === 'XOR') {\n      if (hasXYInputs(gate)) {\n        // This is a first-level XOR: XOR(xi, yi) -> partial sum\n        if (isFirstBitGate(gate)) {\n          // Bit 0: XOR(x00, y00) should output z00\n          if (out !== 'z00') {\n            swapped.add(out);\n          }\n        } else {\n          // Bits 1+: XOR(xi, yi) should output a non-z wire (partial sum)\n          // AND it should be consumed by exactly one XOR and one AND gate\n          if (out.startsWith('z')) {\n            swapped.add(out);\n          } else {\n            const consumerOps = getConsumerOps(out);\n            // Partial sum should be used by XOR and AND (sum and propagate gates)\n            if (!consumerOps.has('XOR') || !consumerOps.has('AND')) {\n              swapped.add(out);\n            }\n          }\n        }\n      } else {\n        // This is a second-level XOR: XOR(partial_sum, carry) -> z output\n        // Its output should be a z-wire\n        if (!out.startsWith('z')) {\n          swapped.add(out);\n        }\n      }\n    } else if (gate.op === 'AND') {\n      // AND gate output should feed into an OR gate (carry computation)\n      // Exception: AND(x00, y00) at bit 0 feeds directly into XOR and AND\n      if (!isFirstBitGate(gate)) {\n        const consumerOps = getConsumerOps(out);\n        if (!consumerOps.has('OR')) {\n          swapped.add(out);\n        }\n      }\n    } else if (gate.op === 'OR') {\n      // OR gate produces carry. Should NOT be a z-wire (except final carry)\n      if (out.startsWith('z') && out !== finalZ) {\n        swapped.add(out);\n      }\n      // Carry should be consumed by X