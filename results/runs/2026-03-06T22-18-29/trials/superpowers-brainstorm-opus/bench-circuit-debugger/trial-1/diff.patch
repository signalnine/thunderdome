};\n\n  // Map each wire to gates that depend on it as input\n  const dependents = new Map<string, Gate[]>();\n  // Track how many inputs are ready for each gate\n  const readyCount = new Map<Gate, number>();\n\n  for (const gate of gates) {\n    readyCount.set(gate, 0);\n    for (const inputWire of [gate.in1, gate.in2]) {\n      if (!dependents.has(inputWire)) {\n        dependents.set(inputWire, []);\n      }\n      dependents.get(inputWire)!.push(gate);\n    }\n  }\n\n  // Initialize ready counts from known wire values\n  const queue: Gate[] = [];\n  for (const wire of Object.keys(wireValues)) {\n    const deps = dependents.get(wire);\n    if (deps) {\n      for (const gate of deps) {\n        const count = readyCount.get(gate)! + 1;\n        readyCount.set(gate, count);\n        if (count === 2) {\n          queue.push(gate);\n        }\n      }\n    }\n  }\n\n  // Process gates in dependency order\n  while (queue.length > 0) {\n    const gate = queue.pop()!;\n    const a = wireValues[gate.in1];\n    const b = wireValues[gate.in2];\n\n    let result: number;\n    switch (gate.op) {\n      case 'AND':\n        result = a & b;\n        break;\n      case 'OR':\n        result = a | b;\n        break;\n      case 'XOR':\n        result = a ^ b;\n        break;\n    }\n\n    wireValues[gate.out] = result;\n\n    // Notify downstream gates\n    const deps = dependents.get(gate.out);\n    if (deps) {\n      for (const dep of deps) {\n        const count = readyCount.get(dep)! + 1;\n        readyCount.set(dep, count);\n        if (count === 2) {\n          queue.push(dep);\n        }\n      }\n    }\n  }\n\n  return wireValues;\n}\n\n/**\n * Find the 8 wires involved in 4 swap pairs in a broken ripple-carry adder circuit.\n * Returns sorted array of the 8 wire names.\n *\n * Uses structural rule checking: each gate in a ripple-carry adder has a specific\n * role determined by its operation and inputs. We verify that each gate's output\n * wire is used in the expected way by downstream gates. Violations indicate swaps.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped = new Set<string>();\n\n  function bitStr(n: number): string {\n    return n.toString().padStart(2, '0');\n  }\n\n  // Determine number of input bits\n  let maxBit = 0;\n  for (const gate of gates) {\n    for (const wire of [gate.in1, gate.in2]) {\n      const match = wire.match(/^x(\\d+)$/);\n      if (match) {\n        maxBit = Math.max(maxBit, parseInt(match[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n  const finalZ = `z${bitStr(numBits)}`;\n\n  // Index: wire -> gates using it as input\n  const consumers = new Map<string, Gate[]>();\n  // Index: output wire -> gate that produces it\n  const producer = new Map<string, Gate>();\n  for (const gate of gates) {\n    producer.set(gate.out, gate);\n    for (const w of [gate.in1, gate.in2]) {\n      if (!consumers.has(w)) consumers.set(w, []);\n      consumers.get(w)!.push(gate);\n    }\n  }\n\n  function getConsumerOps(wire: string): Set<string> {\n    const ops = new Set<string>();\n    const cs = consumers.get(wire) || [];\n    for (const g of cs) ops.add(g.op);\n    return ops;\n  }\n\n  function isXYInput(wire: string): boolean {\n    return /^[xy]\\d+$/.test(wire);\n  }\n\n  function hasXYInputs(gate: Gate): boolean {\n    return isXYInput(gate.in1) || isXYInput(gate.in2);\n  }\n\n  function isFirstBitGate(gate: Gate): boolean {\n    const inputs = [gate.in1, gate.in2].sort();\n    return (inputs[0] === 'x00' && inputs[1] === 'y00');\n  }\n\n  // Check each gate against structural rules\n  for (const gate of gates) {\n    const out = gate.out;\n\n    if (gate.op === 'XOR') {\n      if (hasXYInputs(gate)) {\n        // This is a first-level XOR: XOR(xi, yi) -> partial sum\n        if (isFirstBitGate(gate)) {\n          // Bit 0: XOR(x00, y00) should output z00\n          if (out !== 'z00') {\n            swapped.add(out);\n          }\n        } else {\n          // Bits 1+: XOR(xi, yi) should output a non-z wire (partial sum)\n          // AND it should be consumed by exactly one XOR and one AND gate\n          if (out.startsWith('z')) {\n            swapped.add(out);\n          } else {\n            const consumerOps = getConsumerOps(out);\n            // Partial sum should be used by XOR and AND (sum and propagate gates)\n            if (!consumerOps.has('XOR') || !consumerOps.has('AND')) {\n              swapped.add(out);\n            }\n          }\n        }\n      } else {\n        // This is a second-level XOR: XOR(partial_sum, carry) -> z output\n        // Its output should be a z-wire\n        if (!out.startsWith('z')) {\n          swapped.add(out);\n        }\n      }\n    } else if (gate.op === 'AND') {\n      if (isFirstBitGate(gate)) {\n        // AND(x00, y00) at bit 0: output is carry, should feed into XOR and AND\n        const consumerOps = getConsumerOps(out);\n        if (!consumerOps.has('XOR') || !consumerOps.has('AND')) {\n          swapped.add(out);\n        }\n      } else {\n        // AND gate output should feed into an OR gate (carry computation)\n        const consumerOps = getConsumerOps(out);\n        if (!consumerOps.has('OR')) {\n          swapped.add(out);\n        }\n      }\n    } else if (gate.op === 'OR') {\n      // OR gate produces carry. Should NOT be a z-wire (except final carry)\n      if (out.startsWith('z') && out !== finalZ) {\n        swapped.add(out);\n      }\n      // Check consumer pattern:\n      // - Non-final carry: should be consumed by XOR and AND\n      // - Final carry (finalZ): verify this is actually the last bit's OR gate\n      const consumerOps = getConsumerOps(out);\n      if (out === finalZ) {\n        // Verify this OR gate is at the last bit position by checking that\n        // one of its inputs comes from AND(x_{N-1}, y_{N-1}).\n        const lastBitX = `x${bitStr(numBits - 1)}`;\n        const lastBitY = `y${bitStr(numBits - 1)}`;\n        let isLastBit = false;\n        for (const inp of [gate.in1, gate.in2]) {\n          const p = producer.get(inp);\n          if (p && p.op === 'AND') {\n            const pInputs = [p.in1, p.in2].sort();\n            if (pInputs[0] === lastBitX && pInputs[1] === lastBitY) {\n              isLastBit = true;\n              break;\n            }\n          }\n        }\n        if (!isLastBit) {\n          swapped.add(out);\n        }\n      } else {\n        if (!consumerOps.has('XOR') || !consumerOps.has('AND')) {\n          swapped.add(out);\n        }\n      }\n    }\n  }\n\n  // Post-processing: for each swapped z-wire, find its swap partner.\n  // The swap partner is the gate that SHOULD produce this z-wire but\n  // currently outputs a different wire (the partner).\n  //\n  // For z-output of a second-level XOR gate: the correct gate is\n  // XOR(partial_sum_i, carry_{i-1}). We can identify it by finding the\n  // second-level XOR gate at that bit position.\n  //\n  // For finalZ: the correct gate is the last bit's OR gate.\n\n  // Find swap partners for flagged z-wires that don't have their partner\n  const flaggedZWires = [...swapped].filter(w => w.startsWith('z'));\n  for (const zWire of flaggedZWires) {\n    // Check if the z-wire's expected producer is already flagged\n    const currentProducer = producer.get(zWire);\n    if (currentProducer && swapped.has(currentProducer.out)) {\n      continue; // Already found the partner via the producer\n    }\n\n    if (zWire === finalZ) {\n      // Find the last bit's OR gate and flag its current output\n      const lastBitX = `x${bitStr(numBits - 1)}`;\n      const lastBitY = `y${bitStr(numBits - 1)}`;\n      for (const g of gates) {\n        if (g.op !== 'OR') continue;\n        for (const inp of [g.in1, g.in2]) {\n          const p = producer.get(inp);\n          if (p && p.op === 'AND') {\n            const pInputs = [p.in1, p.in2].sort();\n            if (pInputs[0] === lastBitX && pInputs[1] === lastBitY) {\n              if (g.out !== finalZ) {\n                swapped.add(g.out);\n              }\n            }\n          }\n        }\n      }\n    }\n    // For non-final z-wires: the correct producer is a second-level XOR.\n    // If the current producer of zWire is NOT a second-level XOR, then\n    // the real second-level XOR for this bit has a different output (the partner).\n    // We can find it, but this requires the structural walk which we avoided.\n    // For now, rely on the fact that most z-swaps involve an intermediate wire\n    // that also fails the rule check.\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":224,"oldLines":50,"newStart":224,"newLines":32,"lines":["     }","   }"," ","-  // Post-processing: for each swapped z-wire, find its swap partner.","-  // The swap partner is the gate that SHOULD produce this z-wire but","-  // currently outputs a different wire (the partner).","-  //","-  // For z-output of a second-level XOR gate: the correct gate is","-  // XOR(partial_sum_i, carry_{i-1}). We can identify it by finding the","-  // second-level XOR gate at that bit position.","-  //","-  // For finalZ: the correct gate is the last bit's OR gate.","+  // Post-processing: ensure we have all 8 wires by finding swap partners.","+  // If a z-wire is flagged but fewer than 8 wires found, the swap partner","+  // (a non-z wire that looks valid in its new position) is missing."," ","-  // Find swap partners for flagged z-wires that don't have their partner","-  const flaggedZWires = [...swapped].filter(w => w.startsWith('z'));","-  for (const zWire of flaggedZWires) {","-    // Check if the z-wire's expected producer is already flagged","-    const currentProducer = producer.get(zWire);","-    if (currentProducer && swapped.has(currentProducer.out)) {","-      continue; // Already found the partner via the producer","-    }","-","-    if (zWire === finalZ) {","-      // Find the last bit's OR gate and flag its current output","-      const lastB