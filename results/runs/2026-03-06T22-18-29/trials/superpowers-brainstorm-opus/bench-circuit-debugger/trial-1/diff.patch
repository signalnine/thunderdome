n hasXYInputs(gate: Gate): boolean {\n   134→    return isXYInput(gate.in1) || isXYInput(gate.in2);\n   135→  }\n   136→\n   137→  function isFirstBitGate(gate: Gate): boolean {\n   138→    const inputs = [gate.in1, gate.in2].sort();\n   139→    return (inputs[0] === 'x00' && inputs[1] === 'y00');\n   140→  }\n   141→\n   142→  // Check each gate against structural rules\n   143→  for (const gate of gates) {\n   144→    const out = gate.out;\n   145→\n   146→    if (gate.op === 'XOR') {\n   147→      if (hasXYInputs(gate)) {\n   148→        // This is a first-level XOR: XOR(xi, yi) -> partial sum\n   149→        if (isFirstBitGate(gate)) {\n   150→          // Bit 0: XOR(x00, y00) should output z00\n   151→          if (out !== 'z00') {\n   152→            swapped.add(out);\n   153→          }\n   154→        } else {\n   155→          // Bits 1+: XOR(xi, yi) should output a non-z wire (partial sum)\n   156→          // AND it should be consumed by exactly one XOR and one AND gate\n   157→          if (out.startsWith('z')) {\n   158→            swapped.add(out);\n   159→          } else {\n   160→            const consumerOps = getConsumerOps(out);\n   161→            // Partial sum should be used by XOR and AND (sum and propagate gates)\n   162→            if (!consumerOps.has('XOR') || !consumerOps.has('AND')) {\n   163→              swapped.add(out);\n   164→            }\n   165→          }\n   166→        }\n   167→      } else {\n   168→        // This is a second-level XOR: XOR(partial_sum, carry) -> z output\n   169→        // Its output should be a z-wire\n   170→        if (!out.startsWith('z')) {\n   171→          swapped.add(out);\n   172→        }\n   173→      }\n   174→    } else if (gate.op === 'AND') {\n   175→      if (isFirstBitGate(gate)) {\n   176→        // AND(x00, y00) at bit 0: output is carry, should feed into XOR and AND\n   177→        const consumerOps = getConsumerOps(out);\n   178→        if (!consumerOps.has('XOR') || !consumerOps.has