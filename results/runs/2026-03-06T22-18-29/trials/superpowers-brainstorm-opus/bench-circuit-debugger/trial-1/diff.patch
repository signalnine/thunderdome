t gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n  });\n\n  it('should evaluate a single XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n  });\n\n  it('should handle chained gates (dependency order)', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    expect(result).toEqual({ a: 1, b: 1, c: 1, d: 0, e: 1 });\n  });\n\n  it('should simulate a 4-bit adder computing 3+5=8', () => {\n    // 3 = 0011, 5 = 0101, 8 = 01000\n    const gates: Gate[] = [\n      // Bit 0\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      // Bit 2\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      // Bit 3\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n    ];\n\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 0, x03: 0, // 3\n      y00: 1, y01: 0, y02: 1, y03: 0, // 5\n    };\n\n    const result = simulate(gates, inputs);\n    // 3 + 5 = 8 = 01000\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(1);\n    expect(result.c03).toBe(0);\n  });\n\n  it('should simulate a 4-bit adder computing 7+7=14', () => {\n    // 7 = 0111, 7 = 0111, 14 = 01110\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n    ];\n\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 1, x03: 0,\n      y00: 1, y01: 1, y02: 1, y03: 0,\n    };\n\n    const result = simulate(gates, inputs);\n    // 7 + 7 = 14 = 01110\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n    expect(result.z03).toBe(1);\n    expect(result.c03).toBe(0);\n  });\n\n  it('should handle gates listed in reverse order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    expect(result.e).toBe(1);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function make4BitAdder(): Gate[] {\n    return [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n  }\n\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n    return gates.map(g => {\n      if (g.out === wire1) return { ...g, out: wire2 };\n      if (g.out === wire2) return { ...g, out: wire1 };\n      return { ...g };\n    });\n  }\n\n  it('should detect swapped z-wires with intermediate wires', () => {\n    let gates = make4BitAdder();\n    // Swap z01 with a01, z02 with b02, z03 with t03, z04 with c01\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z02', 'b02');\n    gates = swapOutputs(gates, 'z03', 't03');\n    gates = swapOutputs(gates, 'z04', 'c01');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'b02', 'c01', 't03', 'z01', 'z02', 'z03', 'z04']);\n  });\n\n  it('should detect swaps between carry and z-wire', () => {\n    let gates = make4BitAdder();\n    // Swap z00 with c00, z01 with a01, z02 with c02, z03 with b03\n    gates = swapOutputs(gates, 'z00', 'c00');\n    gates = swapOutputs(gates, 'z01', 'a01');\n    gates = swapOutputs(gates, 'z02', 'c02');\n    gates = swapOutputs(gates, 'z03', 'b03');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'b03', 'c00', 'c02', 'z00', 'z01', 'z02', 'z03']);\n  });\n\n  it('should detect swaps between intermediate wires across bits', () => {\n    let gates = make4BitAdder();\n    // Swap t01 with a02, z01 with t03, c01 with z03, z04 with b01\n    gates = swapOutputs(gates, 't01', 'a02');\n    gates = swapOutputs(gates, 'z01', 't03');\n    gates = swapOutputs(gates, 'c01', 'z03');\n    gates = swapOutputs(gates, 'z04', 'b01');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a02', 'b01', 'c01', 't01', 't03', 'z01', 'z03', 'z04']);\n  });\n\n  it('should handle larger adder circuits', () => {\n    // Build an 8-bit adder\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    ];\n\n    for (let i = 1; i < 8; i++) {\n      const bi = i.toString().padStart(2, '0');\n      const bprev = (i - 1).toString().padStart(2, '0');\n      gates.push(\n        { op: 'XOR', in1: `x${bi}`, in2: `y${bi}`, out: `t${bi}` },\n        { op: 'XOR', in1: `t${bi}`, in2: `c${bprev}`, out: `z${bi}` },\n        { op: 'AND', in1: `x${bi}`, in2: `y${bi}`, out: `a${bi}` }