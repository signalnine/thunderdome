    // The generate wire is andI.out\n    const generateWire = andI.out;\n    const propagateWire = propAndGate?.out;\n\n    // Find the OR gate: OR(generate, propagate) -> carry_out\n    let orGate: Gate | undefined;\n\n    if (propagateWire) {\n      orGate = findGate('OR', generateWire, propagateWire);\n\n      if (!orGate) {\n        // One of generate or propagate was swapped.\n        // Check which one is consumed by an OR gate.\n        const genOrConsumers = getConsumers(generateWire, 'OR');\n        const propOrConsumers = getConsumers(propagateWire, 'OR');\n\n        if (genOrConsumers.length > 0) {\n          orGate = genOrConsumers[0];\n          const otherInput = orGate.in1 === generateWire ? orGate.in2 : orGate.in1;\n          swapped.add(propagateWire);\n          swapped.add(otherInput);\n        } else if (propOrConsumers.length > 0) {\n          orGate = propOrConsumers[0];\n          const otherInput = orGate.in1 === propagateWire ? orGate.in2 : orGate.in1;\n          swapped.add(generateWire);\n          swapped.add(otherInput);\n        }\n      }\n    }\n\n    if (orGate) {\n      carryWire = orGate.out;\n    } else {\n      break;\n    }\n  }\n\n  // Final carry should be z{numBits}\n  const finalZ = `z${bitStr(numBits)}`;\n  if (carryWire !== finalZ) {\n    swapped.add(carryWire);\n    swapped.add(finalZ);\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":197,"oldLines":45,"newStart":197,"newLines":43,"lines":["       // Either partialSum or carry was swapped (their output wire names changed).","       //","       // The sum XOR gate still exists with its original input wire names.","-      // We need to find it by looking at consumers of one of the two wires.","+      // We find it by looking at consumers of partialSumWire or carryWire.","       //","-      // Strategy: try both consumer lists. The correct gate uses exactly one","-      // of our known wires. We prefer the carry-based lookup when both have","-     