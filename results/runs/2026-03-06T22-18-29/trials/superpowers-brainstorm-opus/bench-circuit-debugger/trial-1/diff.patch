55→    switch (gate.op) {\n    56→      case 'AND':\n    57→        result = a & b;\n    58→        break;\n    59→      case 'OR':\n    60→        result = a | b;\n    61→        break;\n    62→      case 'XOR':\n    63→        result = a ^ b;\n    64→        break;\n    65→    }\n    66→\n    67→    wireValues[gate.out] = result;\n    68→\n    69→    // Notify downstream gates\n    70→    const deps = dependents.get(gate.out);\n    71→    if (deps) {\n    72→      for (const dep of deps) {\n    73→        const count = readyCount.get(dep)! + 1;\n    74→        readyCount.set(dep, count);\n    75→        if (count === 2) {\n    76→          queue.push(dep);\n    77→        }\n    78→      }\n    79→    }\n    80→  }\n    81→\n    82→  return wireValues;\n    83→}\n    84→\n    85→/**\n    86→ * Find the 8 wires involved in 4 swap pairs in a broken ripple-carry adder circuit.\n    87→ * Returns sorted array of the 8 wire names.\n    88→ *\n    89→ * Strategy: Walk the expected ripple-carry adder structure bit by bit.\n    90→ * Since only OUTPUT wire names are swapped (not inputs or operations), we can\n    91→ * identify each gate by (op, {in1, in2}). We track the actual wire name that\n    92→ * carries each signal, and detect swaps when:\n    93→ * 1. A z-output gate doesn't output the expected z-wire\n    94→ * 2. A gate lookup fails because an upstream output was swapped\n    95→ * 3. An intermediate wire has a z-name it shouldn't\n    96→ */\n    97→export function findSwappedWires(gates: Gate[]): string[] {\n    98→  const swapped = new Set<string>();\n    99→\n   100→  // Index gates by (op, sorted inputs) for structural lookup\n   101→  const gateBySignature = new Map<string, Gate>();\n   102→  // Index gate by output wire\n   103→  const gateByOutput = new Map<string, Gate>();\n   104→  // Index gates by: one input wire -> list of gates using that wire\n   105→  const gatesByInput = new Map<string, Gate[]>();\n   106→\n   107→  for (const gate of gates) {\