e.\n      // If partialSum was swapped: xorI.out has a different name, but the sum\n      // XOR gate's input still says the old partialSum name.\n      //\n      // Strategy: look at consumers of partialSumWire and carryWire to find\n      // the sum XOR gate.\n\n      // Check if partialSumWire is consumed by any XOR gate\n      const psXorConsumers = getConsumers(partialSumWire, 'XOR');\n      // Check if carryWire is consumed by any XOR gate\n      const carryXorConsumers = getConsumers(carryWire, 'XOR');\n\n      if (psXorConsumers.length > 0) {\n        // partialSumWire IS consumed by a XOR gate.\n        // That gate's other input should be carry but it references the old carry name.\n        sumXorGate = psXorConsumers[0];\n        const otherInput = sumXorGate.in1 === partialSumWire ? sumXorGate.in2 : sumXorGate.in1;\n        // otherInput is the old carry name. carryWire is the new carry name.\n        // The carry was swapped: old name (otherInput) <-> new name (carryWire)\n        swapped.add(carryWire);\n        swapped.add(otherInput);\n        carryWire = otherInput; // Fix carry for current bit\n      } else if (carryXorConsumers.length > 0) {\n        // carryWire IS consumed by a XOR gate, but partialSumWire isn't.\n        // partialSum was swapped.\n        sumXorGate = carryXorConsumers[0];\n        const otherInput = sumXorGate.in1 === carryWire ? sumXorGate.in2 : sumXorGate.in1;\n        // otherInput is the old partialSum name. partialSumWire is the new name.\n        swapped.add(partialSumWire);\n        swapped.add(otherInput);\n        // Note: for AND(partialSum, carry) lookup later, we need the old partialSum name\n        // since that's what the AND gate references in its inputs.\n        // We'll handle this below.\n      }\n\n      if (sumXorGate) {\n        if (sumXorGate.out !== zi) {\n          swapped.add(sumXorGate.out);\n          swapped.add(zi);\n        }\n      } else {\n        continue;\n      }\n    }\n\n    // Find the