@@ -0,0 +1,567 @@
+import { describe, it, expect } from 'vitest';
+import { Spreadsheet } from '../index.js';
+
+describe('Spreadsheet', () => {
+  describe('basic values', () => {
+    it('should set and get numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should set and get floating point numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 3.14);
+      expect(sheet.get('A1')).toBe(3.14);
+    });
+
+    it('should set and get strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should set and get booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.get('A1')).toBe(null);
+    });
+
+    it('should overwrite cell values', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A1', 20);
+      expect(sheet.get('A1')).toBe(20);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('should display numbers as strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should display strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should display booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should display empty string for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('should display computed formula result', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('getCells', () => {
+    it('should return all non-empty cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(3);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+    });
+
+    it('should return empty map for empty spreadsheet', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getCells().size).toBe(0);
+    });
+  });
+
+  describe('simple formulas', () => {
+    it('should evaluate addition', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate subtraction', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 50);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate multiplication', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate division', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 100);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(25);
+    });
+
+    it('should evaluate formulas with constants', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1*2');
+      expect(sheet.get('A2')).toBe(20);
+    });
+
+    it('should handle references to empty cells as 0', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1+B1');
+      expect(sheet.get('A2')).toBe(10);
+    });
+  });
+
+  describe('operator precedence', () => {
+    it('should respect multiplication over addition', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('B1', '=A1+A2*A3');
+      expect(sheet.get('B1')).toBe(14); // 2 + 3*4 = 14
+    });
+
+    it('should respect parentheses', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('B1', '=(A1+A2)*A3');
+      expect(sheet.get('B1')).toBe(20); // (2+3)*4 = 20
+    });
+
+    it('should handle unary minus', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', '=-A1');
+      expect(sheet.get('A2')).toBe(-5);
+    });
+
+    it('should handle complex expressions with constants', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=(1+2)*3');
+      expect(sheet.get('A1')).toBe(9);
+    });
+  });
+
+  describe('cell references', () => {
+    it('should handle multi-letter columns', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('AA1', 42);
+      expect(sheet.get('AA1')).toBe(42);
+    });
+
+    it('should handle multi-letter columns in formulas', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('AA1', 10);
+      sheet.set('AB1', 20);
+      sheet.set('AC1', '=AA1+AB1');
+      expect(sheet.get('AC1')).toBe(30);
+    });
+
+    it('should handle high row numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A100', 99);
+      expect(sheet.get('A100')).toBe(99);
+    });
+
+    it('should normalize cell references (case insensitive)', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('a1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+  });
+
+  describe('built-in functions', () => {
+    describe('SUM', () => {
+      it('should sum a column range', () => {
+        const sheet = new Spreadsheet();
+        sheet.set('A1', 10);
+        sheet.set('A2', 20);
+        sheet.set('A3', 30);
