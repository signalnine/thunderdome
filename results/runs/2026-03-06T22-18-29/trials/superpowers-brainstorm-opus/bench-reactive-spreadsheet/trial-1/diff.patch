@@ -0,0 +1,164 @@
+export class DependencyGraph {
+  // cell → set of cells it depends on (references in its formula)
+  private dependsOn = new Map<string, Set<string>>();
+  // cell → set of cells that depend on it (reverse index)
+  private dependedBy = new Map<string, Set<string>>();
+
+  /**
+   * Update the dependencies for a cell.
+   * Returns the old dependencies for rollback purposes.
+   */
+  setDependencies(cell: string, newDeps: Set<string>): Set<string> {
+    const oldDeps = this.dependsOn.get(cell) ?? new Set<string>();
+
+    // Remove old reverse edges
+    for (const dep of oldDeps) {
+      this.dependedBy.get(dep)?.delete(cell);
+    }
+
+    // Set new forward edges
+    if (newDeps.size > 0) {
+      this.dependsOn.set(cell, newDeps);
+    } else {
+      this.dependsOn.delete(cell);
+    }
+
+    // Add new reverse edges
+    for (const dep of newDeps) {
+      if (!this.dependedBy.has(dep)) {
+        this.dependedBy.set(dep, new Set());
+      }
+      this.dependedBy.get(dep)!.add(cell);
+    }
+
+    return oldDeps;
+  }
+
+  /**
+   * Restore dependencies to a previous state (for rollback on cycle detection).
+   */
+  rollback(cell: string, oldDeps: Set<string>): void {
+    this.setDependencies(cell, oldDeps);
+  }
+
+  /**
+   * Remove a cell from the dependency graph entirely.
+   */
+  removeCell(cell: string): void {
+    this.setDependencies(cell, new Set());
+    this.dependedBy.delete(cell);
+  }
+
+  /**
+   * Check if setting the given dependencies for a cell would create a cycle.
+   * This does DFS from each dependency to see if we can reach `cell`.
+   */
+  hasCycle(cell: string): boolean {
+    // Check direct self-reference
+    const directDeps = this.dependsOn.get(cell);
+    if (directDeps?.has(cell)) {
+      return true;
+    }
+
+    // DFS from cell's dependencies following dependsOn edges — if we reach cell again, cycle
+    if (!directDeps) return false;
+
+    const visited = new Set<string>();
+    const stack = [...directDeps];
+    for (const d of directDeps) {
+      visited.add(d);
+    }
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      const deps = this.dependsOn.get(current);
+      if (!deps) continue;
+
+      for (const dep of deps) {
+        if (dep === cell) {
+          return true;
+        }
+        if (!visited.has(dep)) {
+          visited.add(dep);
+          stack.push(dep);
+        }
+      }
+    }
+
+    return false;
+  }
+
+  /**
+   * Get all transitive dependents of a cell (cells that need recalculation).
+   * Uses BFS on the dependedBy graph.
+   */
+  getTransitiveDependents(cell: string): Set<string> {
+    const result = new Set<string>();
+    const queue = [cell];
+
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const dependents = this.dependedBy.get(current);
+      if (!dependents) continue;
+
+      for (const dep of dependents) {
+        if (!result.has(dep)) {
+          result.add(dep);
+          queue.push(dep);
+        }
+      }
+    }
+
+    return result;
+  }
+
+  /**
+   * Topologically sort a set of cells based on their dependency relationships.
+   * Returns cells in evaluation order (dependencies before dependents).
+   */
+  topologicalSort(cells: Set<string>): string[] {
+    // Build in-degree counts for the subgraph
+    const inDegree = new Map<string, number>();
+    for (const cell of cells) {
+      inDegree.set(cell, 0);
+    }
+
+    for (const cell of cells) {
+      const deps = this.dependsOn.get(cell);
+      if (!deps) continue;
+      for (const dep of deps) {
+        if (cells.has(dep)) {
+          inDegree.set(cell, (inDegree.get(cell) ?? 0) + 1);
+        }
+      }
+    }
+
+    // Kahn's algorithm
+    const queue: string[] = [];
+    for (const [cell, degree] of inDegree) {
+      if (degree === 0) {
+        queue.push(cell);
+      }
+    }
+
+    const sorted: string[] = [];
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      sorted.push(current);
+
+      const dependents = this.dependedBy.get(current);
+      if (!dependents) continue;
+
+      for (const dep of dependents) {
+        if (!cells.has(dep)) continue;
+        const newDegree = (inDegree.get(dep) ?? 0) - 1;
+        inDegree.set(dep, newDegree);
+        if (newDegree === 0) {
+          queue.push(dep);
+        }
+      }
+    }
+
+    return sorted;
+  }
+}
