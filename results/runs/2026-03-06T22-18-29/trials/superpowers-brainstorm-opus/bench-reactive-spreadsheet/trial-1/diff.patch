@@ -0,0 +1,171 @@
+import { ASTNode, CellValue } from './types.js';
+import { expandRange } from './cell-ref.js';
+
+type CellGetter = (key: string) => CellValue;
+
+export function evaluate(node: ASTNode, getCellValue: CellGetter): CellValue {
+  switch (node.type) {
+    case 'number':
+      return node.value;
+
+    case 'string':
+      return node.value;
+
+    case 'boolean':
+      return node.value;
+
+    case 'cell_ref':
+      return getCellValue(node.key);
+
+    case 'range':
+      // Ranges should only appear inside function calls; evaluating standalone is an error
+      throw new Error('Range cannot be evaluated as a standalone expression');
+
+    case 'unary_op':
+      return evaluateUnary(node.op, evaluate(node.operand, getCellValue));
+
+    case 'binary_op':
+      return evaluateBinary(
+        node.op,
+        evaluate(node.left, getCellValue),
+        evaluate(node.right, getCellValue),
+      );
+
+    case 'function_call':
+      return evaluateFunction(node.name, node.args, getCellValue);
+  }
+}
+
+function toNumber(value: CellValue): number {
+  if (typeof value === 'number') return value;
+  if (typeof value === 'boolean') return value ? 1 : 0;
+  if (value === null) return 0;
+  const n = Number(value);
+  return isNaN(n) ? 0 : n;
+}
+
+function evaluateUnary(op: string, operand: CellValue): CellValue {
+  if (op === '-') {
+    return -toNumber(operand);
+  }
+  return toNumber(operand);
+}
+
+function evaluateBinary(op: string, left: CellValue, right: CellValue): CellValue {
+  // Comparison operators
+  switch (op) {
+    case '=': {
+      // Null equality
+      if (left === null && right === null) return true;
+      if (left === null || right === null) return false;
+      // Same type comparison
+      if (typeof left === typeof right) return left === right;
+      // Mixed: compare as numbers
+      return toNumber(left) === toNumber(right);
+    }
+    case '<>': {
+      if (left === null && right === null) return false;
+      if (left === null || right === null) return true;
+      if (typeof left === typeof right) return left !== right;
+      return toNumber(left) !== toNumber(right);
+    }
+    case '>':
+      return toNumber(left) > toNumber(right);
+    case '<':
+      return toNumber(left) < toNumber(right);
+    case '>=':
+      return toNumber(left) >= toNumber(right);
+    case '<=':
+      return toNumber(left) <= toNumber(right);
+  }
+
+  // Arithmetic operators
+  const l = toNumber(left);
+  const r = toNumber(right);
+  switch (op) {
+    case '+':
+      return l + r;
+    case '-':
+      return l - r;
+    case '*':
+      return l * r;
+    case '/':
+      return r === 0 ? Infinity : l / r;
+    default:
+      throw new Error(`Unknown operator: ${op}`);
+  }
+}
+
+/**
+ * Resolve function arguments, expanding ranges into arrays of values.
+ */
+function resolveArgs(args: ASTNode[], getCellValue: CellGetter): CellValue[] {
+  const values: CellValue[] = [];
+  for (const arg of args) {
+    if (arg.type === 'range') {
+      const cells = expandRange(arg.start, arg.end);
+      for (const key of cells) {
+        values.push(getCellValue(key));
+      }
+    } else {
+      values.push(evaluate(arg, getCellValue));
+    }
+  }
+  return values;
+}
+
+function getNumericValues(values: CellValue[]): number[] {
+  return values.filter((v): v is number => typeof v === 'number');
+}
+
+function evaluateFunction(name: string, args: ASTNode[], getCellValue: CellGetter): CellValue {
+  switch (name) {
+    case 'SUM': {
+      const values = resolveArgs(args, getCellValue);
+      const nums = getNumericValues(values);
+      return nums.reduce((sum, n) => sum + n, 0);
+    }
+
+    case 'AVERAGE': {
+      const values = resolveArgs(args, getCellValue);
+      const nums = getNumericValues(values);
+      if (nums.length === 0) return 0;
+      return nums.reduce((sum, n) => sum + n, 0) / nums.length;
+    }
+
+    case 'MIN': {
+      const values = resolveArgs(args, getCellValue);
+      const nums = getNumericValues(values);
+      if (nums.length === 0) return 0;
+      return Math.min(...nums);
+    }
+
+    case 'MAX': {
+      const values = resolveArgs(args, getCellValue);
+      const nums = getNumericValues(values);
+      if (nums.length === 0) return 0;
+      return Math.max(...nums);
+    }
+
+    case 'COUNT': {
+      const values = resolveArgs(args, getCellValue);
+      return getNumericValues(values).length;
+    }
+
+    case 'IF': {
+      if (args.length < 3) {
+        throw new Error('IF requires 3 arguments');
+      }
+      const condition = evaluate(args[0], getCellValue);
+      const isTruthy = typeof condition === 'boolean' ? condition : !!condition;
+      if (isTruthy) {
+        return evaluate(args[1], getCellValue);
+      } else {
+        return evaluate(args[2], getCellValue);
+      }
+    }
+
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..e0473eb
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,108 @@
+import { CellData, CellValue } from './types.js';
+import { cellKeyFromRef } from './cell-ref.js';
+import { parseFormula, extractDependencies } from './parser.js';
+import { evaluate } from './evaluator.js';
+import { DependencyGraph } from './dependency-graph.js';
+
+export class Spreadsheet {
+  private cells = new Map<string, CellData>();
+  private graph = new DependencyGraph();
+
+  /**
+   * Set a cell's value. Can be a raw value or a formula string starting with '='.
+   */
+  set(cell: string, value: string | number | boolean): void {
+    const key = cellKeyFromRef(cell);
+
+    // Parse the value
+    let formula = null;
+    let dependencies = new Set<string>();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      formula = parseFormula(value);
+      dependencies = extractDependencies(formula);
+    }
+
+    // Update dependency graph and check for cycles
+    const oldDeps = this.graph.setDependencies(key, dependencies);
+
+    if (this.graph.hasCycle(key)) {
+      // Rollback
+      this.graph.rollback(key, oldDeps);
+      throw new Error('Circular reference detected');
+    }
+
+    // Compute the cell's value
+    const computed = formula
+      ? evaluate(formula, (ref) => this.getComputed(ref))
+      : this.normalizeRawValue(value);
+
+    // Store cell data
+    this.cells.set(key, {
+      raw: value,
+      formula,
+      computed,
+      dependencies,
+    });
+
+    // Recompute all transitive dependents
+    this.recomputeDependents(key);
+  }
+
+  /**
+   * Get a cell's computed value. Returns null for empty cells.
+   */
+  get(cell: string): CellValue {
+    const key = cellKeyFromRef(cell);
+    return this.getComputed(key);
+  }
+
+  /**
+   * Get the display string for a cell's computed value.
+   */
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  /**
+   * Get all non-empty cells as a Map from cell reference to computed value.
+   */
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [key, data] of this.cells) {
+      result.set(key, data.computed);
+    }
+    return result;
+  }
+
+  private getComputed(key: string): CellValue {
+    const data = this.cells.get(key);
+    return data ? data.computed : null;
+  }
+
+  private normalizeRawValue(value: string | number | boolean): CellValue {
+    if (typeof value === 'number' || typeof value === 'boolean') {
+      return value;
+    }
+    // String values — check if it's a numeric string
+    return value;
+  }
+
+  private recomputeDependents(changedCell: string): void {
+    const dependents = this.graph.getTransitiveDependents(changedCell);
+    if (dependents.size === 0) return;
+
+    const order = this.graph.topologicalSort(dependents);
+
+    for (const key of order) {
+      const data = this.cells.get(key);
+      if (!data || !data.formula) continue;
+
+      data.computed = evaluate(data.formula, (ref) => this.getComputed(ref));
+    }
+  }
+}
+
+export type { CellValue } from './types.js';
diff --git a/src/parser.ts b/src/parser.ts
new file mode 100644
index 0000000..4d36eef
--- /dev/null
+++ b/src/parser.ts
@@ -0,0 +1,230 @@
+import { Token, TokenType, tokenize } from './tokenizer.js';
+import { parseCellRef, cellKey } from './cell-ref.js';
+import { ASTNode } from './types.js';
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private current(): Token {
+    return this.tokens[this.pos];
+  }
+
+  private peek(offset = 0): Token {
+    return this.tokens[this.pos + offset] ?? { type: TokenType.EOF, value: '' };
+  }
+
+  private advance(): Token {
+    const token = this.tokens[this.pos];
+    this.pos++;
+    return token;
+  }
+
+  private expect(type: TokenType): Token {
+    const token = this.current();
+    if (token.type !== type) {
+      throw new Error(`Expected ${type} but got ${token.type} (${token.value})`);
+    }
+    return this.advance();
+  }
+
+  parse(): ASTNode {
+    const node = this.parseExpression();
+    if (this.current().type !== TokenType.EOF) {
+      throw new Error(`Unexpected token: ${this.current().value}`);
+    }
+    return node;
+  }
+
+  // Lowest precedence: comparison operators
+  private parseExpression(): ASTNode {
+    let left = this.parseAddSub();
+
+    while (this.current().type === TokenType.COMPARISON) {
+      const op = this.advance().value;
+      const right = this.parseAddSub();
+      left = { type: 'binary_op', op, left, right };
+    }
+
+    return left;
+  }
+
+  private parseAddSub(): ASTNode {
+    let left = this.parseMulDiv();
+
+    while (
+      this.current().type === TokenType.OPERATOR &&
+      (this.current().value === '+' || this.current().value === '-')
+    ) {
+      const op = this.advance().value;
+      const right = this.parseMulDiv();
+      left = { type: 'binary_op', op, left, right };
+    }
+
+    return left;
+  }
+
+  private parseMulDiv(): ASTNode {
+    let left = this.parseUnary();
+
+    while (
+      this.current().type === TokenType.OPERATOR &&
+      (this.current().value === '*' || this.current().value === '/')
+    ) {
+      const op = this.advance().value;
+      const right = this.parseUnary();
+      left = { type: 'binary_op', op, left, right };
+    }
+
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    if (
+      this.current().type === TokenType.OPERATOR &&
+      (this.current().value === '-' || this.current().value === '+')
+    ) {
+      const op = this.advance().value;
+      const operand = this.parseUnary();
+      if (op === '+') return operand; // Unary + is a no-op
+      return { type: 'unary_op', op, operand };
+    }
+
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const token = this.current();
+
+    // Number literal
+    if (token.type === TokenType.NUMBER) {
+      this.advance();
+      return { type: 'number', value: parseFloat(token.value) };
+    }
+
+    // String literal
+    if (token.type === TokenType.STRING) {
+      this.advance();
+      return { type: 'string', value: token.value };
+    }
+
+    // Boolean literal
+    if (token.type === TokenType.BOOLEAN) {
+      this.advance();
+      return { type: 'boolean', value: token.value === 'TRUE' };
+    }
+
+    // Function call: IDENTIFIER followed by (
+    if (token.type === TokenType.IDENTIFIER && this.peek(1).type === TokenType.LPAREN) {
+      const name = this.advance().value;
+      this.expect(TokenType.LPAREN);
+      const args: ASTNode[] = [];
+
+      if (this.current().type !== TokenType.RPAREN) {
+        args.push(this.parseExpression());
+        while (this.current().type === TokenType.COMMA) {
+          this.advance();
+          args.push(this.parseExpression());
+        }
+      }
+
+      this.expect(TokenType.RPAREN);
+      return { type: 'function_call', name, args };
+    }
+
+    // Cell reference (possibly with range)
+    if (token.type === TokenType.CELL_REF) {
+      const refStr = this.advance().value;
+      const pos = parseCellRef(refStr);
+
+      // Check for range
+      if (this.current().type === TokenType.COLON) {
+        this.advance();
+        const endToken = this.expect(TokenType.CELL_REF);
+        const endPos = parseCellRef(endToken.value);
+        return {
+          type: 'range',
+          start: { col: pos.col, row: pos.row },
+          end: { col: endPos.col, row: endPos.row },
+        };
+      }
+
+      return {
+        type: 'cell_ref',
+        col: pos.col,
+        row: pos.row,
+        key: cellKey(pos.col, pos.row),
+      };
+    }
+
+    // Parenthesized expression
+    if (token.type === TokenType.LPAREN) {
+      this.advance();
+      const expr = this.parseExpression();
+      this.expect(TokenType.RPAREN);
+      return expr;
+    }
+
+    throw new Error(`Unexpected token: ${token.type} (${token.value})`);
+  }
+}
+
+export function parseFormula(formula: string): ASTNode {
+  // Strip leading '='
+  const expr = formula.startsWith('=') ? formula.slice(1) : formula;
+  const tokens = tokenize(expr);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+/**
+ * Extract all cell reference keys from an AST.
+ */
+export function extractDependencies(node: ASTNode): Set<string> {
+  const deps = new Set<string>();
+  collectDeps(node, deps);
+  return deps;
+}
+
+function collectDeps(node: ASTNode, deps: Set<string>): void {
+  switch (node.type) {
+    case 'cell_ref':
+      deps.add(node.key);
+      break;
+    case 'range': {
+      // Expand range to individual cell keys
+      const minCol = Math.min(node.start.col, node.end.col);
+      const maxCol = Math.max(node.start.col, node.end.col);
+      const minRow = Math.min(node.start.row, node.end.row);
+      const maxRow = Math.max(node.start.row, node.end.row);
+      for (let r = minRow; r <= maxRow; r++) {
+        for (let c = minCol; c <= maxCol; c++) {
+          deps.add(cellKey(c, r));
+        }
+      }
+      break;
+    }
+    case 'binary_op':
+      collectDeps(node.left, deps);
+      collectDeps(node.right, deps);
+      break;
+    case 'unary_op':
+      collectDeps(node.operand, deps);
+      break;
+    case 'function_call':
+      for (const arg of node.args) {
+        collectDeps(arg, deps);
+      }
+      break;
+    // Literals have no dependencies
+    case 'number':
+    case 'string':
+    case 'boolean':
+      break;
+  }
+}
diff --git a/src/tokenizer.ts b/src/tokenizer.ts
new file mode 100644
index 0000000..f90e3f6
--- /dev/null
+++ b/src/tokenizer.ts
@@ -0,0 +1,176 @@
+export enum TokenType {
+  NUMBER = 'NUMBER',
+  STRING = 'STRING',
+  BOOLEAN = 'BOOLEAN',
+  CELL_REF = 'CELL_REF',
+  OPERATOR = 'OPERATOR',
+  COMPARISON = 'COMPARISON',
+  LPAREN = 'LPAREN',
+  RPAREN = 'RPAREN',
+  COMMA = 'COMMA',
+  COLON = 'COLON',
+  IDENTIFIER = 'IDENTIFIER',
+  EOF = 'EOF',
+}
+
+export interface Token {
+  type: TokenType;
+  value: string;
+}
+
+const FUNCTIONS = new Set(['SUM', 'AVERAGE', 'MIN', 'MAX', 'COUNT', 'IF']);
+
+export function tokenize(formula: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < formula.length) {
+    const ch = formula[i];
+
+    // Skip whitespace
+    if (ch === ' ' || ch === '\t') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (ch === '"') {
+      i++;
+      let str = '';
+      while (i < formula.length && formula[i] !== '"') {
+        str += formula[i];
+        i++;
+      }
+      if (i >= formula.length) {
+        throw new Error('Unterminated string literal');
+      }
+      i++; // skip closing "
+      tokens.push({ type: TokenType.STRING, value: str });
+      continue;
+    }
+
+    // Number
+    if (isDigit(ch) || (ch === '.' && i + 1 < formula.length && isDigit(formula[i + 1]))) {
+      let num = '';
+      while (i < formula.length && (isDigit(formula[i]) || formula[i] === '.')) {
+        num += formula[i];
+        i++;
+      }
+      tokens.push({ type: TokenType.NUMBER, value: num });
+      continue;
+    }
+
+    // Comparison operators (multi-char first)
+    if (ch === '<' && i + 1 < formula.length && formula[i + 1] === '>') {
+      tokens.push({ type: TokenType.COMPARISON, value: '<>' });
+      i += 2;
+      continue;
+    }
+    if (ch === '<' && i + 1 < formula.length && formula[i + 1] === '=') {
+      tokens.push({ type: TokenType.COMPARISON, value: '<=' });
+      i += 2;
+      continue;
+    }
+    if (ch === '>' && i + 1 < formula.length && formula[i + 1] === '=') {
+      tokens.push({ type: TokenType.COMPARISON, value: '>=' });
+      i += 2;
+      continue;
+    }
+    if (ch === '<') {
+      tokens.push({ type: TokenType.COMPARISON, value: '<' });
+      i++;
+      continue;
+    }
+    if (ch === '>') {
+      tokens.push({ type: TokenType.COMPARISON, value: '>' });
+      i++;
+      continue;
+    }
+    // Single '=' as comparison (only in formula context, not assignment)
+    if (ch === '=') {
+      tokens.push({ type: TokenType.COMPARISON, value: '=' });
+      i++;
+      continue;
+    }
+
+    // Arithmetic operators
+    if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {
+      tokens.push({ type: TokenType.OPERATOR, value: ch });
+      i++;
+      continue;
+    }
+
+    // Parentheses
+    if (ch === '(') {
+      tokens.push({ type: TokenType.LPAREN, value: '(' });
+      i++;
+      continue;
+    }
+    if (ch === ')') {
+      tokens.push({ type: TokenType.RPAREN, value: ')' });
+      i++;
+      continue;
+    }
+
+    // Comma
+    if (ch === ',') {
+      tokens.push({ type: TokenType.COMMA, value: ',' });
+      i++;
+      continue;
+    }
+
+    // Colon
+    if (ch === ':') {
+      tokens.push({ type: TokenType.COLON, value: ':' });
+      i++;
+      continue;
+    }
+
+    // Identifier (cell ref, function name, boolean)
+    if (isAlpha(ch)) {
+      let ident = '';
+      while (i < formula.length && isAlphaNumeric(formula[i])) {
+        ident += formula[i];
+        i++;
+      }
+      const upper = ident.toUpperCase();
+
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: TokenType.BOOLEAN, value: upper });
+        continue;
+      }
+
+      if (FUNCTIONS.has(upper)) {
+        tokens.push({ type: TokenType.IDENTIFIER, value: upper });
+        continue;
+      }
+
+      // Cell reference: letters followed by digits
+      if (/^[A-Za-z]+\d+$/.test(ident)) {
+        tokens.push({ type: TokenType.CELL_REF, value: upper });
+        continue;
+      }
+
+      // Generic identifier (could be function name we don't know)
+      tokens.push({ type: TokenType.IDENTIFIER, value: upper });
+      continue;
+    }
+
+    throw new Error(`Unexpected character: ${ch}`);
+  }
+
+  tokens.push({ type: TokenType.EOF, value: '' });
+  return tokens;
+}
+
+function isDigit(ch: string): boolean {
+  return ch >= '0' && ch <= '9';
+}
+
+function isAlpha(ch: string): boolean {
+  return (ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z');
+}
+
+function isAlphaNumeric(ch: string): boolean {
+  return isAlpha(ch) || isDigit(ch);
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..6e4ed73
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,70 @@
+export type CellValue = string | number | boolean | null;
+
+export interface CellPosition {
+  col: number; // 0-based: A=0, B=1, ..., Z=25, AA=26
+  row: number; // 1-based
+}
+
+export type ASTNode =
+  | NumberNode
+  | StringNode
+  | BooleanNode
+  | CellRefNode
+  | RangeNode
+  | BinaryOpNode
+  | UnaryOpNode
+  | FunctionCallNode;
+
+export interface NumberNode {
+  type: 'number';
+  value: number;
+}
+
+export interface StringNode {
+  type: 'string';
+  value: string;
+}
+
+export interface BooleanNode {
+  type: 'boolean';
+  value: boolean;
+}
+
+export interface CellRefNode {
+  type: 'cell_ref';
+  col: number;
+  row: number;
+  key: string;
+}
+
+export interface RangeNode {
+  type: 'range';
+  start: CellPosition;
+  end: CellPosition;
+}
+
+export interface BinaryOpNode {
+  type: 'binary_op';
+  op: string;
+  left: ASTNode;
+  right: ASTNode;
+}
+
+export interface UnaryOpNode {
+  type: 'unary_op';
+  op: string;
+  operand: ASTNode;
+}
+
+export interface FunctionCallNode {
+  type: 'function_call';
+  name: string;
+  args: ASTNode[];
+}
+
+export interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  computed: CellValue;
+  dependencies: Set<string>;
+}
