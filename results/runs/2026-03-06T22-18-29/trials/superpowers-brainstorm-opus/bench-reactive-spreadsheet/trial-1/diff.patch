lue.\n   */\n  getDisplay(cell: string): string {\n    const value = this.get(cell);\n    if (value === null) return '';\n    return String(value);\n  }\n\n  /**\n   * Get all non-empty cells as a Map from cell reference to computed value.\n   */\n  getCells(): Map<string, CellValue> {\n    const result = new Map<string, CellValue>();\n    for (const [key, data] of this.cells) {\n      result.set(key, data.computed);\n    }\n    return result;\n  }\n\n  private getComputed(key: string): CellValue {\n    const data = this.cells.get(key);\n    return data ? data.computed : null;\n  }\n\n  private normalizeRawValue(value: string | number | boolean): CellValue {\n    if (typeof value === 'number' || typeof value === 'boolean') {\n      return value;\n    }\n    // String values — check if it's a numeric string\n    return value;\n  }\n\n  private recomputeDependents(changedCell: string): void {\n    const dependents = this.graph.getTransitiveDependents(changedCell);\n    if (dependents.size === 0) return;\n\n    const order = this.graph.topologicalSort(dependents);\n\n    for (const key of order) {\n      const data = this.cells.get(key);\n      if (!data || !data.formula) continue;\n\n      data.computed = evaluate(data.formula, (ref) => this.getComputed(ref));\n    }\n  }\n}\n\nexport type { CellValue } from './types.js';\n","numLines":109,"startLine":1,"totalLines":109}}}
