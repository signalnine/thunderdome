+  it('should find minimum presses', () => {
+    // Target: [true, false]
+    // Button 0: toggles [0, 1]
+    // Button 1: toggles [1]
+    // Button 2: toggles [0]
+    // Solutions: {0, 1} (2 presses) or {2} (1 press)
+    const machine: Machine = {
+      target: [true, false],
+      buttons: [[0, 1], [1], [0]],
+    };
+    expect(solveToggle(machine)).toEqual([2]);
+  });
+
+  it('should return lexicographically smallest when tied on count', () => {
+    // Target: [true]
+    // Button 0: toggles [0]
+    // Button 1: toggles [0]
+    // Both are 1-press solutions, should return [0] (lex smallest)
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should handle empty buttons array', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should handle empty target with buttons', () => {
