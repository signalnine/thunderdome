ree;\n  let bestSolution: number[] | null = null;\n  let bestWeight = numButtons + 1;\n\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    const solution = new Array(numButtons).fill(0);\n\n    // Set free variables from mask.\n    for (let i = 0; i < numFree; i++) {\n      solution[freeVars[i]] = (mask >> i) & 1;\n    }\n\n    // Back-substitute to find pivot variables.\n    for (let r = rank - 1; r >= 0; r--) {\n      let val = matrix[r][numButtons];\n      for (let c = 0; c < numButtons; c++) {\n        if (c !== pivotCol[r]) {\n          val ^= (matrix[r][c] & solution[c]);\n        }\n      }\n      solution[pivotCol[r]] = val;\n    }\n\n    // Count weight (number of 1s).\n    let weight = 0;\n    for (let j = 0; j < numButtons; j++) {\n      weight += solution[j];\n    }\n\n    if (weight < bestWeight || (weight === bestWeight && solutionIndicesLexSmaller(solution, bestSolution!, numButtons))) {\n      bestWeight = weight;\n      bestSolution = solution.slice();\n    }\n  }\n\n  if (bestSolution === null) return null;\n\n  // Return indices of pressed buttons, sorted.\n  const result: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (bestSolution[j] === 1) {\n      result.push(j);\n    }\n  }\n  return result;\n}\n\n/**\n * Compare two solutions by their pressed-button index lists lexicographically.\n * Returns true if a's index list is lexicographically smaller than b's.\n */\nfunction solutionIndicesLexSmaller(a: number[], b: number[], n: number): boolean {\n  // Compare index lists directly: iterate through buttons in order.\n  // First difference in whether a button is pressed determines the order.\n  for (let i = 0; i < n; i++) {\n    if (a[i] !== b[i]) {\n      // If a has this button pressed and b doesn't, a has an earlier index\n      // that b doesn't, which means a's index set starts earlier.\n      // But we need to think about this as set comparison.\n      // Actually, for lex comparison of sorted index arrays:\n      