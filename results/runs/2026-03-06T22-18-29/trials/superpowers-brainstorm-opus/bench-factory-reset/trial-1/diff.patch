+import { describe, it, expect } from 'vitest';
+import { solveCounter } from './counter.js';
+
+describe('solveCounter', () => {
+  it('should return all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should solve a simple single-button case', () => {
+    // Target: counter 0 = 3. Button 0 affects counter 0. Modulus 5.
+    // Press button 0 three times.
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('should solve a two-button case', () => {
+    // Counters: [2, 3], Buttons: [0] and [1], Modulus 5
+    // Button 0 increments counter 0, button 1 increments counter 1.
+    const result = solveCounter([2, 3], [[0], [1]], 5);
+    expect(result).toEqual([2, 3]);
+  });
+
+  it('should handle overlapping buttons', () => {
+    // Counters: [1, 1], Buttons: [[0, 1]], Modulus 3
+    // Button 0 increments both counters. Press once -> [1, 1]. Done.
+    const result = solveCounter([1, 1], [[0, 1]], 3);
+    expect(result).toEqual([1]);
+  });
+
+  it('should return null when no solution exists', () => {
+    // Counters: [1, 2], Button affects both counters. Modulus 5.
+    // Can only reach [x, x] for any x, never [1, 2].
+    const result = solveCounter([1, 2], [[0, 1]], 5);
+    expect(result).toBeNull();
+  });
+
+  it('should find minimum total presses', () => {
+    // Counters: [0], Buttons: [[0], [0]], Modulus 3
+    // Target 0: both buttons = 0 presses (sum = 0).
+    // Since target is 0, solution is [0, 0].
+    const result = solveCounter([0], [[0], [0]], 3);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should find minimum sum when multiple solutions exist', () => {
+    // Counter: [1], Buttons: [[0], [0]], Modulus 3
+    // b0 + b1 = 1 (mod 3).
+    // Solutions: (0,1)=sum1, (1,0)=sum1, (2,2)=sum4.
+    // Lex smallest with sum 1: [0, 1].
+    // Wait, (1,0) is lex smaller than (0,1)? No, [0,1] < [1,0] lex.
+    const result = solveCounter([1], [[0], [0]], 3);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should return lex smallest when tied on sum', () => {
+    // Counter: [2], Buttons: [[0], [0]], Modulus 5
+    // b0 + b1 = 2 (mod 5).
+    // Sum-2 solutions: (0,2), (1,1), (2,0).
+    // Lex smallest: [0, 2].
+    const result = solveCounter([2], [[0], [0]], 5);
+    expect(result).toEqual([0, 2]);
+  });
+
+  it('should handle empty targets', () => {
+    const result = solveCounter([], [[0]], 5);
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle empty buttons with zero target', () => {
+    const result = solveCounter([0, 0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  it('should handle empty buttons with non-zero target', () => {
+    const result = solveCounter([1, 0], [], 5);
+    expect(result).toBeNull();
+  });
+
+  it('should handle modulus 2 (equivalent to toggle)', () => {
+    // Counter: [1, 1], Buttons: [[0], [1]], Modulus 2
+    const result = solveCounter([1, 1], [[0], [1]], 2);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('should handle larger modulus', () => {
+    // Counter: [96], Button: [[0]], Modulus 97
+    // Press button 96 times.
+    const result = solveCounter([96], [[0]], 97);
+    expect(result).toEqual([96]);
+  });
+
+  it('should handle wrapping', () => {
+    // Counter: [0], Button: [[0]], Modulus 5
+    // 0 presses achieves 0.
+    const result = solveCounter([0], [[0]], 5);
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle multiple counters and buttons with overlap', () => {
+    // Counters: [1, 2, 0]
+    // Buttons: [[0, 1], [1, 2]], Modulus 3
+    // b0 + 0 = 1 (counter 0) -> b0 = 1
+    // b0 + b1 = 2 (counter 1) -> 1 + b1 = 2 -> b1 = 1
+    // 0 + b1 = 0 (counter 2) -> b1 = 0
+    // Contradiction: b1 = 1 and b1 = 0. No solution.
+    const result = solveCounter([1, 2, 0], [[0, 1], [1, 2]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('should solve system with unique solution', () => {
+    // Counters: [1, 1]
+    // Buttons: [[0], [1]], Modulus 3
+    const result = solveCounter([1, 1], [[0], [1]], 3);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('should handle performance with moderate matrix', () => {
+    // 15 counters, 15 buttons - identity mapping
+    const n = 15;
+    const target = new Array(n).fill(1);
+    const btns = Array.from({ length: n }, (_, i) => [i]);
+    const result = solveCounter(target, btns, 7);
+    expect(result).toEqual(new Array(n).fill(1));
+  });
+});
