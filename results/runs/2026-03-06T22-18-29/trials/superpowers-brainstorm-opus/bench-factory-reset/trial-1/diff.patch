nimum sum when multiple solutions exist', () => {\n    // Counter: [1], Buttons: [[0], [0]], Modulus 3\n    // b0 + b1 = 1 (mod 3).\n    // Solutions: (0,1)=sum1, (1,0)=sum1, (2,2)=sum4.\n    // Lex smallest with sum 1: [0, 1].\n    // Wait, (1,0) is lex smaller than (0,1)? No, [0,1] < [1,0] lex.\n    const result = solveCounter([1], [[0], [0]], 3);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('should return lex smallest when tied on sum', () => {\n    // Counter: [2], Buttons: [[0], [0]], Modulus 5\n    // b0 + b1 = 2 (mod 5).\n    // Sum-2 solutions: (0,2), (1,1), (2,0).\n    // Lex smallest: [0, 2].\n    const result = solveCounter([2], [[0], [0]], 5);\n    expect(result).toEqual([0, 2]);\n  });\n\n  it('should handle empty targets', () => {\n    const result = solveCounter([], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle empty buttons with zero target', () => {\n    const result = solveCounter([0, 0], [], 5);\n    expect(result).toEqual([]);\n  });\n\n  it('should handle empty buttons with non-zero target', () => {\n    const result = solveCounter([1, 0], [], 5);\n    expect(result).toBeNull();\n  });\n\n  it('should handle modulus 2 (equivalent to toggle)', () => {\n    // Counter: [1, 1], Buttons: [[0], [1]], Modulus 2\n    const result = solveCounter([1, 1], [[0], [1]], 2);\n    expect(result).toEqual([1, 1]);\n  });\n\n  it('should handle larger modulus', () => {\n    // Counter: [96], Button: [[0]], Modulus 97\n    // Press button 96 times.\n    const result = solveCounter([96], [[0]], 97);\n    expect(result).toEqual([96]);\n  });\n\n  it('should handle wrapping', () => {\n    // Counter: [0], Button: [[0]], Modulus 5\n    // 0 presses achieves 0.\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle multiple counters and buttons with overlap', () => {\n    // Counters: [1, 2, 0]\n    // Buttons: [[0, 1], [1, 2]], Modulus 3\n    // b0 + 0 = 1 (counter 0) -> b0 =