@@ -0,0 +1,262 @@
+/**
+ * Solve the counter puzzle using Gaussian elimination over GF(p).
+ *
+ * We model this as a system of linear equations over GF(p):
+ *   A * x = b  (mod p)
+ * where A[i][j] = 1 if button j affects counter i,
+ * x[j] = number of times button j is pressed (0..p-1),
+ * b[i] = target value for counter i.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  if (numCounters === 0) return new Array(numButtons).fill(0);
+  if (numButtons === 0) {
+    return lights.every(v => v === 0) ? [] : null;
+  }
+
+  // Build augmented matrix [A | b] over GF(p).
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const counterIdx of buttons[j]) {
+      if (counterIdx >= 0 && counterIdx < numCounters) {
+        matrix[counterIdx][j] = (matrix[counterIdx][j] + 1) % modulus;
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(p).
+  const pivotCol: number[] = new Array(numCounters).fill(-1);
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let rank = 0;
+
+  for (let col = 0; col < numButtons && rank < numCounters; col++) {
+    // Find pivot row.
+    let pivRow = -1;
+    for (let row = rank; row < numCounters; row++) {
+      if (matrix[row][col] !== 0) {
+        pivRow = row;
+        break;
+      }
+    }
+    if (pivRow === -1) continue;
+
+    // Swap rows.
+    [matrix[rank], matrix[pivRow]] = [matrix[pivRow], matrix[rank]];
+    pivotCol[rank] = col;
+    pivotRow[col] = rank;
+
+    // Normalize pivot row so pivot element = 1.
+    const inv = modInverse(matrix[rank][col], modulus);
+    for (let c = 0; c <= numButtons; c++) {
+      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;
+    }
+
+    // Eliminate this column from all other rows.
+    for (let row = 0; row < numCounters; row++) {
+      if (row !== rank && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Check consistency.
+  for (let row = rank; row < numCounters; row++) {
+    if (matrix[row][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables.
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // Check feasibility of enumeration.
+  // p^k combinations: need to be reasonable (< ~10M).
+  const maxEnumerable = computeMaxEnumerable(modulus, numFree);
+
+  if (maxEnumerable <= 10_000_000) {
+    return enumerateSolutions(matrix, rank, numButtons, modulus, pivotCol, pivotRow, freeVars);
+  }
+
+  // Fallback: greedy approach for large free spaces.
+  return solveCounterLargeFreeSpace(matrix, rank, numButtons, modulus, pivotCol, freeVars);
+}
+
+function computeMaxEnumerable(modulus: number, numFree: number): number {
+  let result = 1;
+  for (let i = 0; i < numFree; i++) {
+    result *= modulus;
+    if (result > 10_000_000) return result;
+  }
+  return result;
+}
+
+function enumerateSolutions(
+  matrix: number[][],
+  rank: number,
+  numButtons: number,
+  modulus: number,
+  pivotCol: number[],
+  _pivotRow: number[],
+  freeVars: number[]
+): number[] | null {
+  const numFree = freeVars.length;
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+
+  // Enumerate all free variable assignments.
+  const freeAssignment = new Array(numFree).fill(0);
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    // Decode combo into free variable assignment.
+    if (combo > 0) {
+      // Increment the free assignment like a base-p counter.
+      let carry = 1;
+      for (let i = 0; i < numFree && carry; i++) {
+        freeAssignment[i] += carry;
+        if (freeAssignment[i] >= modulus) {
+          freeAssignment[i] = 0;
+          carry = 1;
+        } else {
+          carry = 0;
+        }
+      }
+    }
+
+    const solution = new Array(numButtons).fill(0);
+
+    // Set free variables.
+    for (let i = 0; i < numFree; i++) {
+      solution[freeVars[i]] = freeAssignment[i];
+    }
+
+    // Back-substitute to find pivot variables.
+    for (let r = rank - 1; r >= 0; r--) {
+      let val = matrix[r][numButtons];
+      for (let c = 0; c < numButtons; c++) {
+        if (c !== pivotCol[r]) {
+          val = ((val - matrix[r][c] * solution[c]) % modulus + modulus) % modulus;
+        }
+      }
+      solution[pivotCol[r]] = val;
+    }
+
+    // Compute sum.
+    let sum = 0;
+    for (let j = 0; j < numButtons; j++) {
+      sum += solution[j];
+    }
+
+    if (sum < bestSum || (sum === bestSum && lexSmaller(solution, bestSolution!))) {
+      bestSum = sum;
+      bestSolution = solution.slice();
+    }
+  }
+
+  return bestSolution;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function solveCounterLargeFreeSpace(
+  matrix: number[][],
+  rank: number,
+  numButtons: number,
+  modulus: number,
+  pivotCol: number[],
+  freeVars: number[]
+): number[] | null {
+  // Start with all free variables = 0, then try each value to minimize sum.
+  let solution = new Array(numButtons).fill(0);
+
+  // Back-substitute with all free vars = 0.
+  for (let r = rank - 1; r >= 0; r--) {
+    let val = matrix[r][numButtons];
+    for (let c = 0; c < numButtons; c++) {
+      if (c !== pivotCol[r]) {
+        val = ((val - matrix[r][c] * solution[c]) % modulus + modulus) % modulus;
+      }
+    }
+    solution[pivotCol[r]] = val;
+  }
+
+  // Greedy: for each free variable, try all values and pick the one minimizing sum.
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (const fv of freeVars) {
+      let bestLocalSum = computeSum(solution, numButtons);
+
+      for (let v = 0; v < modulus; v++) {
+        if (v === solution[fv]) continue;
+        // Compute what solution would look like with this free var changed.
+        const delta = (v - solution[fv] + modulus) % modulus;
+        const testSolution = solution.slice();
+        testSolution[fv] = v;
+        // Recompute pivot variables.
+        for (let r = 0; r < rank; r++) {
+          if (matrix[r][fv] !== 0) {
+            testSolution[pivotCol[r]] = ((solution[pivotCol[r]] - matrix[r][fv] * delta) % modulus + modulus) % modulus;
+          }
+        }
+        const testSum = computeSum(testSolution, numButtons);
+        if (testSum < bestLocalSum || (testSum === bestLocalSum && lexSmaller(testSolution, solution))) {
+          bestLocalSum = testSum;
+          solution = testSolution;
+          improved = true;
+        }
+      }
+    }
+  }
+
+  return solution;
+}
+
+function computeSum(arr: number[], len: number): number {
+  let s = 0;
+  for (let i = 0; i < len; i++) s += arr[i];
+  return s;
+}
+
+function modInverse(a: number, p: number): number {
+  // Using extended Euclidean algorithm.
+  a = ((a % p) + p) % p;
+  if (a === 0) return 0;
+  let [old_r, r] = [a, p];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % p) + p) % p;
+}
