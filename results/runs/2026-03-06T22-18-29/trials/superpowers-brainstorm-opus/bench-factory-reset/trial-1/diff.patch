+import type { Machine } from './index.js';
+
+/**
+ * Solve the toggle puzzle using Gaussian elimination over GF(2).
+ *
+ * We model this as a system of linear equations over GF(2):
+ *   A * x = b  (mod 2)
+ * where A[i][j] = 1 if button j toggles light i,
+ * x[j] = 1 if we press button j,
+ * b[i] = target[i] (1 if on, 0 if off).
+ *
+ * After Gaussian elimination, we enumerate free variable assignments
+ * to find the solution with minimum weight (fewest presses),
+ * breaking ties lexicographically.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (numLights === 0) return [];
+  if (numButtons === 0) {
+    return target.every(t => !t) ? [] : null;
+  }
+
+  // Build augmented matrix [A | b] over GF(2).
+  // Rows = lights, Columns = buttons + 1 (augmented column for target).
+  // A[i][j] = 1 if button j toggles light i.
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+  for (let j = 0; j < numButtons; j++) {
+    for (const lightIdx of buttons[j]) {
+      if (lightIdx >= 0 && lightIdx < numLights) {
+        matrix[lightIdx][j] ^= 1;
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(2) with partial pivoting.
+  // We track which column is the pivot for each row.
+  const pivotCol: number[] = new Array(numLights).fill(-1);
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let rank = 0;
+
+  for (let col = 0; col < numButtons && rank < numLights; col++) {
+    // Find pivot row for this column.
+    let pivRow = -1;
+    for (let row = rank; row < numLights; row++) {
+      if (matrix[row][col] === 1) {
+        pivRow = row;
+        break;
+      }
+    }
+    if (pivRow === -1) continue;
+
+    // Swap rows.
+    [matrix[rank], matrix[pivRow]] = [matrix[pivRow], matrix[rank]];
+    pivotCol[rank] = col;
+    pivotRow[col] = rank;
+
+    // Eliminate this column from all other rows.
+    for (let row = 0; row < numLights; row++) {
+      if (row !== rank && matrix[row][col] === 1) {
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[row][c] ^= matrix[rank][c];
+        }
+      }
+    }
+    rank++;
+  }
+
+  // Check consistency: any row with all zeros in A but 1 in augmented column.
+  for (let row = rank; row < numLights; row++) {
+    if (matrix[row][numButtons] === 1) {
+      return null; // No solution.
+    }
+  }
+
+  // Identify free variables (columns without pivots).
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // If too many free variables, we need a smarter approach.
+  // For GF(2), 2^25 ~ 33M which is borderline. Let's cap at 25.
+  // Beyond that, use a greedy/heuristic approach.
+  if (numFree > 25) {
+    return solveToggleLargeFreeSpace(matrix, rank, numButtons, pivotCol, pivotRow, freeVars);
+  }
+
+  const totalCombinations = 1 << numFree;
+  let bestSolution: number[] | null = null;
+  let bestWeight = numButtons + 1;
+
+  for (let mask = 0; mask < totalCombinations; mask++) {
+    const solution = new Array(numButtons).fill(0);
+
+    // Set free variables from mask.
+    for (let i = 0; i < numFree; i++) {
+      solution[freeVars[i]] = (mask >> i) & 1;
+    }
+
+    // Back-substitute to find pivot variables.
+    for (let r = rank - 1; r >= 0; r--) {
+      let val = matrix[r][numButtons];
+      for (let c = 0; c < numButtons; c++) {
+        if (c !== pivotCol[r]) {
+          val ^= (matrix[r][c] & solution[c]);
+        }
+      }
+      solution[pivotCol[r]] = val;
+    }
+
+    // Count weight (number of 1s).
+    let weight = 0;
+    for (let j = 0; j < numButtons; j++) {
+      weight += solution[j];
+    }
+
+    if (weight < bestWeight || (weight === bestWeight && solutionIndicesLexSmaller(solution, bestSolution!, numButtons))) {
+      bestWeight = weight;
+      bestSolution = solution.slice();
+    }
+  }
+
+  if (bestSolution === null) return null;
+
+  // Return indices of pressed buttons, sorted.
+  const result: number[] = [];
+  for (let j = 0; j < numButtons; j++) {
+    if (bestSolution[j] === 1) {
+      result.push(j);
+    }
+  }
+  return result;
+}
+
+/**
+ * Compare two solutions by their pressed-button index lists lexicographically.
+ * Returns true if a's index list is lexicographically smaller than b's.
+ */
+function solutionIndicesLexSmaller(a: number[], b: number[], n: number): boolean {
+  // Compare index lists directly: iterate through buttons in order.
+  // First difference in whether a button is pressed determines the order.
+  for (let i = 0; i < n; i++) {
+    if (a[i] !== b[i]) {
+      // If a has this button pressed and b doesn't, a has an earlier index
+      // that b doesn't, which means a's index set starts earlier.
+      // But we need to think about this as set comparison.
+      // Actually, for lex comparison of sorted index arrays:
+      // The first index where they differ determines order.
+      // If a[i]=1 and b[i]=0: a includes this button but b doesn't.
+      //   If they have the same count, then at some later index b has one a doesn't.
+      //   The first difference favors a (it has the smaller index), so a < b.
+      // If a[i]=0 and b[i]=1: b includes this button but a doesn't, so b < a.
+      return a[i] > b[i]; // a[i]=1 means a includes this earlier index -> a is lex smaller
+    }
+  }
+  return false;
+}
+
+/**
+ * Fallback for when there are too many free variables to enumerate.
+ * Uses a greedy approach: try to minimize presses by setting free variables
+ * to minimize the total weight.
+ */
+function solveToggleLargeFreeSpace(
+  matrix: number[][],
+  rank: number,
+  numButtons: number,
+  pivotCol: number[],
+  _pivotRow: number[],
+  freeVars: number[]
+): number[] | null {
+  // For toggle, setting all free variables to 0 gives one valid solution.
+  // Then we can try flipping each free variable and see if it reduces the weight.
+  const solution = new Array(numButtons).fill(0);
+
+  // Back-substitute with all free vars = 0.
+  for (let r = rank - 1; r >= 0; r--) {
+    let val = matrix[r][numButtons];
+    for (let c = 0; c < numButtons; c++) {
+      if (c !== pivotCol[r]) {
+        val ^= (matrix[r][c] & solution[c]);
+      }
+    }
+    solution[pivotCol[r]] = val;
+  }
+
+  // Greedy improvement: for each free variable, see if flipping it reduces weight.
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (const fv of freeVars) {
+      // Compute the effect of flipping this free variable.
+      // It flips itself and all pivot variables that depend on it.
+      let deltaWeight = solution[fv] === 0 ? 1 : -1; // Effect on the free var itself.
+      for (let r = 0; r < rank; r++) {
+        if (matrix[r][fv] === 1) {
+          const pv = pivotCol[r];
+          // Flipping free var flips this pivot var.
+          deltaWeight += solution[pv] === 0 ? 1 : -1;
+        }
+      }
+      if (deltaWeight < 0) {
+        // Flip it.
+        solution[fv] ^= 1;
+        for (let r = 0; r < rank; r++) {
+          if (matrix[r][fv] === 1) {
+            solution[pivotCol[r]] ^= 1;
+          }
+        }
+        improved = true;
+      }
+    }
+  }
+
+  const result: number[] = [];
+  for (let j = 0; j < numButtons; j++) {
+    if (solution[j] === 1) {
+      result.push(j);
+    }
+  }
+  return result;
+}
