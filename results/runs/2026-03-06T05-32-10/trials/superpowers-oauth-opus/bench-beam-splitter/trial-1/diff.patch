+// Direction encoding: 0=down, 1=down-left, 2=down-right
+const DOWN = 0;
+const DOWN_LEFT = 1;
+const DOWN_RIGHT = 2;
+
+function findSource(grid: string[][]): number {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return c;
+  }
+  throw new Error('No source found');
+}
+
+function nextPos(row: number, col: number, dir: number): [number, number] {
+  const nr = row + 1;
+  if (dir === DOWN) return [nr, col];
+  if (dir === DOWN_LEFT) return [nr, col - 1];
+  return [nr, col + 1];
+}
+
+// Encode (col, dir) into a single number for use as Map key
+function stateKey(col: number, dir: number): number {
+  return col * 3 + dir;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const sCol = findSource(grid);
+
+  const visitedCells = new Set<number>();
+  visitedCells.add(sCol); // row 0, source cell. Encode as row*cols+col
+
+  // Track unique (col, dir) states on current row
+  // Since all beams move downward, we process row by row
+  // Current states: set of (col, dir) pairs currently at this row
+  let current = new Map<number, boolean>(); // key=stateKey, value=true (just existence)
+  current.set(stateKey(sCol, DOWN), true);
+
+  for (let row = 0; row < rows - 1; row++) {
+    const next = new Map<number, boolean>();
+
+    for (const key of current.keys()) {
+      const col = Math.floor(key / 3);
+      const dir = key % 3;
+
+      const [nr, nc] = nextPos(row, col, dir);
+      if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) continue;
+
+      visitedCells.add(nr * cols + nc);
+
+      if (grid[nr][nc] === '^') {
+        next.set(stateKey(nc, DOWN_LEFT), true);
+        next.set(stateKey(nc, DOWN_RIGHT), true);
+      } else {
+        next.set(stateKey(nc, dir), true);
+      }
+    }
+
+    current = next;
+  }
+
+  return visitedCells.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const sCol = findSource(grid);
+
+  // Track path counts per (col, dir) state, processing row by row
+  let current = new Map<number, bigint>();
+  current.set(stateKey(sCol, DOWN), 1n);
+  let totalPaths = 0n;
+
+  for (let row = 0; row < rows - 1; row++) {
+    const next = new Map<number, bigint>();
+
+    for (const [key, paths] of current) {
+      const col = Math.floor(key / 3);
+      const dir = key % 3;
+
+      const [nr, nc] = nextPos(row, col, dir);
+      if (nr < 0 || nr >= rows || nc < 0 || nc >= cols) {
+        totalPaths += paths;
+        continue;
+      }
+
+      if (grid[nr][nc] === '^') {
+        const lk = stateKey(nc, DOWN_LEFT);
+        const rk = stateKey(nc, DOWN_RIGHT);
+        next.set(lk, (next.get(lk) ?? 0n) + paths);
+        next.set(rk, (next.get(rk) ?? 0n) + paths);
+      } else {
+        const nk = stateKey(nc, dir);
+        next.set(nk, (next.get(nk) ?? 0n) + paths);
+      }
+    }
+
+    current = next;
+  }
+
+  // Beams still in the grid at the last row exit downward
+  for (const paths of current.values()) {
+    totalPaths += paths;
+  }
+
+  return totalPaths;
+}
