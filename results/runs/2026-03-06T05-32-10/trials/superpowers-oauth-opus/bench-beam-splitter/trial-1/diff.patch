+import { countBeamCells, countBeamPaths } from '../src/index.js';
+
+describe('countBeamCells', () => {
+  test('single source, no splitters, beam goes straight down', () => {
+    // S on top row, beam goes down through empty cells
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Visited: (0,1), (1,1), (2,1) = 3 cells
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('source at edge of 1-row grid', () => {
+    // Only source, beam exits immediately downward (no row below)
+    const grid = [['S']];
+    // Visited: (0,0) = 1 cell
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  test('example from spec: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Beam: (0,1) -> (1,1) -> (2,1) hits splitter -> (3,0) and (3,2)
+    // Visited: (0,1), (1,1), (2,1), (3,0), (3,2) = 5
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  test('example from spec: two splitters on row 2', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Beam: (0,1) -> (1,1) splitter -> DL(2,0) splitter, DR(2,2) splitter
+    // (2,0) splitter -> (3,-1) absorbed, (3,1)
+    // (2,2) splitter -> (3,1), (3,3)
+    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1), (3,3) = 6
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  test('beam goes off left edge', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Beam: (0,0) -> (1,0) splitter -> DL(2,-1) absorbed, DR(2,1)
+    // Visited: (0,0), (1,0), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('beam goes off right edge', () => {
+    const grid = [
+      ['.', '.', 'S'],
+      ['.', '.', '^'],
+      ['.', '.', '.'],
+    ];
+    // Beam: (0,2) -> (1,2) splitter -> DL(2,1), DR(2,3) absorbed
+    // Visited: (0,2), (1,2), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  test('multiple beams pass through same cell', () => {
+    // Two splitters that converge beams to the same cell
+    const grid = [
+      ['.', '.', 'S', '.', '.'],
+      ['.', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // Beam: (0,2) -> (1,2) splitter -> DL path: (2,1), (3,0); DR path: (2,3), (3,4)
+    // Visited: (0,2), (1,2), (2,1), (2,3), (3,0), (3,4) = 6
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  test('chain of splitters on diagonal', () => {
+    const grid = [
+      ['.', 'S', '.', '.'],
+      ['.', '^', '.', '.'],
+      ['.', '.', '^', '.'],
+      ['.', '.', '.', '.'],
+    ];
+    // Beam: (0,1) -> (1,1) splitter -> DL(2,0), DR(2,2) splitter
+    // DL continues: (2,0) -> (3,0) (no splitter, continues down-left but was going DL so (3,-1) absorbed)
+    // Wait, DL beam from (1,1) goes to (2,0), then continues DL to (3,-1) absorbed
+    // DR beam from (1,1) goes to (2,2) splitter -> DL(3,1), DR(3,3)
+    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1), (3,3) = 6
+    expect(countBeamCells(grid)).toBe(6);
+  });
+});
+
+describe('countBeamPaths', () => {
+  test('single source, no splitters - one path', () => {
+    const grid = [
+      ['.', 'S', '.'],
+      ['.', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  test('source on 1-row grid - one path', () => {
+    const grid = [['S']];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  test('example from spec: single splitter - 2 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  test('example from spec: two splitters - 4 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    // 4 paths total (including the one absorbed at col -1)
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  test('splitter at edge - one beam absorbed, one continues', () => {
+    const grid = [
+      ['S', '.', '.'],
+      ['^', '.', '.'],
+      ['.', '.', '.'],
+    ];
+    // Beam hits splitter at (1,0): DL(2,-1) absorbed, DR(2,1) exits bottom
+    // 2 paths (absorbed counts as a path that exits the grid)
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  test('three splitters in sequence - 8 paths', () => {
+    const grid = [
+      ['.', '.', '.', '.', 'S', '.', '.', '.', '.'],
+      ['.', '.', '.', '.', '^', '.', '.', '.', '.'],
+      ['.', '.', '.', '^', '.', '^', '.', '.', '.'],
+      ['.', '.', '^', '.', '^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.', '.', '.', '.', '.'],
+    ];
+    // First splitter splits to 2, each hits a splitter -> 4, each of those 4 hits a splitter -> 8
+    expect(countBeamPaths(grid)).toBe(8n);
+  });
+});
+
+describe('performance', () => {
+  test('200x200 grid with 50 splitters in a column - worst case 2^50 paths', () => {
+    // Place 50 splitters directly below the source, each on consecutive rows.
+    // After a splitter, beams go DL and DR. The DL and DR beams move diagonally
+    // and won't hit the next splitter (which is directly below).
+    // Instead, we need splitters arranged so multiple beams reconverge.
+    //
+    // Best worst case: place splitters so each DL/DR beam from one splitter
+    // reconverges onto the next splitter.
+    // Splitter at (r, c) -> beams to (r+1, c-1) and (r+1, c+1)
+    // We need both to hit the next splitter at (r+2, c):
+    //   - DL beam at (r+1, c-1) continues DL to (r+2, c-2) -- no
+    // That doesn't work. Let's use a zig-zag pattern instead:
+    // Splitter at (1, 100) -> DR beam goes (2,101), (3,102)...
+    // Put next splitter at (3,102) -> it splits again
+    // Each splitter's DR beam hits the next one 2 rows down and 2 cols right
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+
+    grid[0][100] = 'S';
+    // Place 50 splitters along the DR path, each 2 rows apart
+    // DR beam from (r,c) goes to (r+1,c+1), continues DR to (r+2,c+2)
+    // Place splitter at (r+2, c+2)
+    let r = 1, c = 100;
+    for (let i = 0; i < 50 && r < rows && c < cols; i++) {
+      grid[r][c] = '^';
+      r += 2;
+      c += 2;
+    }
+    // This creates: source beam hits first splitter, DR beam hits next,
+    // DL beams go off on their own. Only DR chain propagates through all 50.
+    // Total paths = 50 + 1 (not exponential). Not the hard case.
+    //
+    // For truly exponential: need BOTH children of every splitter to hit another splitter.
+    // This requires diamond/grid patterns.
+    // Place splitters in a triangular grid:
+    // Row 2: 1 splitter at col 100
+    // Row 4: 2 splitters at cols 98, 102
+    // Row 6: 3 splitters at cols 96, 100, 104
+    // etc.
+    // After K rows of splitters, we get C(K, floor(K/2)) paths roughly.
+    // With 50 rows of splitters that's enormous.
+
+    // Reset grid
+    for (let i = 0; i < rows; i++)
+      for (let j = 0; j < cols; j++)
+        grid[i][j] = '.';
+
+    grid[0][100] = 'S';
+    // Place splitters in a triangular cascade
+    // Row 1: col 100 (directly below S, beam hits going down)
+    // Row 2: cols 99, 101 (DL and DR from row 1 splitter)
+    // Row 3: cols 98, 100, 102 (DL from 99, DR from 99=DL from 101, DR from 101)
+    // etc.
+    for (let i = 0; i < 50; i++) {
+      const row = 1 + i;
+      if (row >= rows) break;
+      for (let j = 0; j <= i; j++) {
+        const col = 100 - i + 2 * j;
+        if (col >= 0 && col < cols) {
+          grid[row][col] = '^';
+        }
+      }
+    }
+
+    const start = performance.now();
+    const cells = countBeamCells(grid);
+    const paths = countBeamPaths(grid);
+    const elapsed = performance.now() - start;
+
+    expect(cells).toBeGreaterThan(0);
+    expect(paths).toBeGreaterThan(0n);
+    // With 50 rows of triangular splitters, paths should be astronomically large
+    // (Pascal's triangle-like growth)
+    expect(paths).toBeGreaterThan(1000000n);
+    expect(elapsed).toBeLessThan(5000);
+  });
+});
