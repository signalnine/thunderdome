ol + 1];\n  }\n}\n\nfunction inBounds(row: number, col: number, rows: number, cols: number): boolean {\n  return row >= 0 && row < rows && col >= 0 && col < cols;\n}\n\nexport function countBeamCells(grid: string[][]): number {\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const [sRow, sCol] = findSource(grid);\n\n  const visited = new Set<string>();\n  visited.add(`${sRow},${sCol}`);\n\n  const beams: Beam[] = [{ row: sRow, col: sCol, dir: 'down' }];\n\n  while (beams.length > 0) {\n    const beam = beams.pop()!;\n    const [nr, nc] = advance(beam);\n\n    if (!inBounds(nr, nc, rows, cols)) continue;\n\n    visited.add(`${nr},${nc}`);\n\n    if (grid[nr][nc] === '^') {\n      beams.push({ row: nr, col: nc, dir: 'down-left' });\n      beams.push({ row: nr, col: nc, dir: 'down-right' });\n    } else {\n      beams.push({ row: nr, col: nc, dir: beam.dir });\n    }\n  }\n\n  return visited.size;\n}\n\nexport function countBeamPaths(grid: string[][]): bigint {\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const [sRow, sCol] = findSource(grid);\n\n  interface PathBeam {\n    row: number;\n    col: number;\n    dir: Direction;\n    paths: bigint;\n  }\n\n  const beams: PathBeam[] = [{ row: sRow, col: sCol, dir: 'down', paths: 1n }];\n  let totalPaths = 0n;\n\n  while (beams.length > 0) {\n    const beam = beams.pop()!;\n    const [nr, nc] = advance(beam);\n\n    if (!inBounds(nr, nc, rows, cols)) {\n      // Beam exits the grid - count the paths\n      totalPaths += beam.paths;\n      continue;\n    }\n\n    if (grid[nr][nc] === '^') {\n      beams.push({ row: nr, col: nc, dir: 'down-left', paths: beam.paths });\n      beams.push({ row: nr, col: nc, dir: 'down-right', paths: beam.paths });\n    } else {\n      beams.push({ row: nr, col: nc, dir: beam.dir, paths: beam.paths });\n    }\n  }\n\n  return totalPaths;\n}\n","numLines":92,"startLine":1,"totalLines":92}}}
