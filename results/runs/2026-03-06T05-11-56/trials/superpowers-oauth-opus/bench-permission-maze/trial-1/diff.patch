+      expect(res.body.content).toBe('edited by bob');
+    });
+
+    it('deeply nested folder inherits permissions from ancestor', async () => {
+      const alice = await registerAndLogin('alice', 'pass');
+      const bob = await registerAndLogin('bob', 'pass');
+
+      const root = await createFolder(alice.token, 'Root');
+      const mid = await createFolder(alice.token, 'Mid', root.body.id);
+      const deep = await createFolder(alice.token, 'Deep', mid.body.id);
+
+      // Share root with bob
+      await request(app)
+        .post(`/folders/${root.body.id}/share`)
+        .set('Authorization', `Bearer ${alice.token}`)
+        .send({ userId: bob.userId, role: 'viewer' });
+
+      // Bob can access the deeply nested folder
+      const res = await request(app)
+        .get(`/folders/${deep.body.id}`)
+        .set('Authorization', `Bearer ${bob.token}`);
+      expect(res.status).toBe(200);
+    });
+
+    it('each activity log entry has required fields', async () => {
+      const { token, userId } = await registerAndLogin('alice', 'pass');
+      const folder = await createFolder(token, 'Folder');
+      await createDocument(token, 'Doc', 'content', folder.body.id);
+
+      const res = await request(app)
+        .get('/activity')
+        .set('Authorization', `Bearer ${token}`);
+
+      for (const entry of res.body) {
+        expect(entry.action).toBeDefined();
+        expect(entry.userId).toBe(userId);
+        expect(entry.resourceType).toBeDefined();
+        expect(entry.resourceId).toBeDefined();
+        expect(entry.timestamp).toBeDefined();
+      }
+    });
+  });
+});
