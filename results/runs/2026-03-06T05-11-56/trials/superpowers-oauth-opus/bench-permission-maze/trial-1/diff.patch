 document creation without title', async () => {\n      const { token } = await registerAndLogin('alice', 'pass');\n      const folder = await createFolder(token, 'Folder');\n      const res = await request(app)\n        .post('/documents')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ content: 'content', folderId: folder.body.id });\n      expect(res.status).toBe(400);\n    });\n  });\n\n  // --- Sharing & Permissions Tests ---\n  describe('Sharing & Permissions', () => {\n    it('should share a folder with another user as viewer', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n\n      const folder = await createFolder(alice.token, 'Shared Folder');\n\n      const res = await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n      expect(res.status).toBe(200);\n\n      // Bob should be able to read the folder\n      const getRes = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`);\n      expect(getRes.status).toBe(200);\n    });\n\n    it('viewer cannot modify resources', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n\n      const folder = await createFolder(alice.token, 'Folder');\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n\n      const res = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`)\n        .send({ name: 'Hacked' });\n      expect(res.status).toBe(403);\n    });\n\n    it('editor can modify resources', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n\n      const folder = await createFolder(alice.token, 'Folder');\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'editor' });\n\n      const res = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`)\n        .send({ name: 'Updated By Bob' });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('Updated By Bob');\n    });\n\n    it('editor cannot delete resources', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n\n      const folder = await createFolder(alice.token, 'Folder');\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'editor' });\n\n      const res = await request(app)\n        .delete(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`);\n      expect(res.status).toBe(403);\n    });\n\n    it('viewer cannot share resources', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n      const charlie = await registerAndLogin('charlie', 'pass');\n\n      const folder = await createFolder(alice.token, 'Folder');\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n\n      const res = await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${bob.token}`)\n        .send({ userId: charlie.userId, role: 'viewer' });\n      expect(res.status).toBe(403);\n    });\n\n    it('editor can share resources', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n      const charlie = await registerAndLogin('charlie', 'pass');\n\n      const folder = await createFolder(alice.token, 'Folder');\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'editor' });\n\n      const res = await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${bob.token}`)\n        .send({ userId: charlie.userId, role: 'viewer' });\n      expect(res.status).toBe(200);\n    });\n\n    it('editor cannot assign owner role', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n      const charlie = await registerAndLogin('charlie', 'pass');\n\n      const folder = await createFolder(alice.token, 'Folder');\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'editor' });\n\n      const res = await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${bob.token}`)\n        .send({ userId: charlie.userId, role: 'owner' });\n      expect(res.status).toBe(403);\n    });\n\n    it('should share a document', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n\n      const folder = await createFolder(alice.token, 'Folder');\n      const doc = await createDocument(alice.token, 'Doc', 'content', folder.body.id);\n\n      await request(app)\n        .post(`/documents/${doc.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n\n      const res = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`);\n      expect(res.status).toBe(200);\n    });\n\n    it('user without permission cannot access resource', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n\n      const folder = await createFolder(alice.token, 'Private Folder');\n\n      const res = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`);\n      expect(res.status).toBe(403);\n    });\n\n    it('folder permission should grant access to documents inside', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n\n      const folder = await createFolder(alice.token, 'Folder');\n      const doc = await createDocument(alice.token, 'Doc', 'content', folder.body.id);\n\n      // Share folder with bob as viewer\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n\n      // Bob should be able to read the document via folder permission\n      const res = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`);\n      expect(res.status).toBe(200);\n    });\n\n    it('parent folder permission should propagate to child folders', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n\n      const parent = await createFolder(alice.token, 'Parent');\n      const child = await createFolder(alice.token, 'Child', parent.body.id);\n\n      // Share parent folder with bob\n      await request(app)\n        .post(`/folders/${parent.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n\n      // Bob should be able to read child folder\n      const res = await request(app)\n        .get(`/folders/${child.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`);\n      expect(res.status).toBe(200);\n    });\n\n    it('most permissive role should be effective when multiple paths grant access', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n\n      const folder = await createFolder(alice.token, 'Folder');\n      const doc = await createDocument(alice.token, 'Doc', 'content', folder.body.id);\n\n      // Share folder with bob as viewer\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n\n      // Share document directly with bob as editor\n      await request(app)\n        .post(`/documents/${doc.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'editor' });\n\n      // Bob should be able to edit the document (most permissive)\n      const res = await request(app)\n        .put(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`)\n        .send({ content: 'updated by bob' });\n      expect(res.status).toBe(200);\n    });\n\n    it('should update existing permission when sharing again', async () => {\n      const alice = await registerAndLogin('alice', 'pass');\n      const bob = await registerAndLogin('bob', 'pass');\n\n      const folder = await createFolder(alice.token, 'Folder');\n\n      // Share as viewer first\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n\n      // Update to editor\n      await request(app)\n  