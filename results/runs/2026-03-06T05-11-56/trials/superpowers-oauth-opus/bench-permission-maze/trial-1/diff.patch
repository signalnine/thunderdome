@@ -0,0 +1,66 @@
+import { Router, Request, Response } from 'express';
+import { Store } from '../store.js';
+import { generateId, generateToken } from '../helpers.js';
+
+export function authRoutes(store: Store): Router {
+  const router = Router();
+
+  // Register
+  router.post('/register', (req: Request, res: Response): void => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    if (typeof username !== 'string' || typeof password !== 'string') {
+      res.status(400).json({ error: 'Username and password must be strings' });
+      return;
+    }
+
+    // Check if username already exists
+    for (const user of store.users.values()) {
+      if (user.username === username) {
+        res.status(409).json({ error: 'Username already exists' });
+        return;
+      }
+    }
+
+    const id = generateId();
+    const user = { id, username, password };
+    store.users.set(id, user);
+
+    res.status(201).json({ id, username });
+  });
+
+  // Login
+  router.post('/login', (req: Request, res: Response): void => {
+    const { username, password } = req.body;
+
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+
+    let foundUser = null;
+    for (const user of store.users.values()) {
+      if (user.username === username && user.password === password) {
+        foundUser = user;
+        break;
+      }
+    }
+
+    if (!foundUser) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+
+    const token = generateToken();
+    foundUser.token = token;
+
+    res.status(200).json({ token, userId: foundUser.id });
+  });
+
+  return router;
+}
diff --git a/src/routes/documents.ts b/src/routes/documents.ts
new file mode 100644
index 0000000..c6ed5d1
--- /dev/null
+++ b/src/routes/documents.ts
@@ -0,0 +1,177 @@
+import { Router, Response } from 'express';
+import { Store } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { generateId, hasPermission } from '../helpers.js';
+
+export function documentRoutes(store: Store): Router {
+  const router = Router();
+
+  router.use(authMiddleware(store));
+
+  // Create document
+  router.post('/', (req: AuthRequest, res: Response): void => {
+    const { title, content, folderId } = req.body;
+    const userId = req.userId!;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Document title is required' });
+      return;
+    }
+
+    if (content === undefined || content === null) {
+      res.status(400).json({ error: 'Document content is required' });
+      return;
+    }
+
+    if (!folderId || typeof folderId !== 'string') {
+      res.status(400).json({ error: 'Folder ID is required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    // User needs at least editor permission on the folder to create a doc
+    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const now = new Date().toISOString();
+    const id = generateId();
+    const doc = {
+      id,
+      title,
+      content: String(content),
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+
+    store.documents.set(id, doc);
+
+    // Add owner permission
+    store.permissions.push({
+      id: generateId(),
+      resourceType: 'document',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(),
+      action: 'document_created',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', (req: AuthRequest, res: Response): void => {
+    const { id } = req.params;
+    const userId = req.userId!;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.status(200).json(doc);
+  });
+
+  // Update document
+  router.put('/:id', (req: AuthRequest, res: Response): void => {
+    const { id } = req.params;
+    const userId = req.userId!;
+    const { title, content } = req.body;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    if (title !== undefined) {
+      if (typeof title !== 'string' || !title) {
+        res.status(400).json({ error: 'Title must be a non-empty string' });
+        return;
+      }
+      doc.title = title;
+    }
+
+    if (content !== undefined) {
+      doc.content = String(content);
+    }
+
+    doc.updatedAt = new Date().toISOString();
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(),
+      action: 'document_updated',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: doc.updatedAt,
+    });
+
+    res.status(200).json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', (req: AuthRequest, res: Response): void => {
+    const { id } = req.params;
+    const userId = req.userId!;
+
+    const doc = store.documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'document', id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    store.documents.delete(id);
+    store.permissions = store.permissions.filter(
+      (p) => !(p.resourceType === 'document' && p.resourceId === id)
+    );
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(),
+      action: 'document_deleted',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/routes/folders.ts b/src/routes/folders.ts
new file mode 100644
index 0000000..03e7a0d
--- /dev/null
+++ b/src/routes/folders.ts
@@ -0,0 +1,199 @@
+import { Router, Response } from 'express';
+import { Store } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { generateId, hasPermission } from '../helpers.js';
+
+export function folderRoutes(store: Store): Router {
+  const router = Router();
+
+  router.use(authMiddleware(store));
+
+  // Create folder
+  router.post('/', (req: AuthRequest, res: Response): void => {
+    const { name, parentId } = req.body;
+    const userId = req.userId!;
+
+    if (!name || typeof name !== 'string') {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    // If parentId is specified, check it exists and user has access
+    if (parentId) {
+      const parentFolder = store.folders.get(parentId);
+      if (!parentFolder) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      if (!hasPermission(store, userId, 'folder', parentId, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId();
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+
+    store.folders.set(id, folder);
+
+    // Add owner permission
+    store.permissions.push({
+      id: generateId(),
+      resourceType: 'folder',
+      resourceId: id,
+      userId,
+      role: 'owner',
+    });
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', (req: AuthRequest, res: Response): void => {
+    const { id } = req.params;
+    const userId = req.userId!;
+
+    const folder = store.folders.get(id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Get child folders
+    const children: string[] = [];
+    for (const [childId, childFolder] of store.folders) {
+      if (childFolder.parentId === id) {
+        children.push(childId);
+      }
+    }
+
+    // Get documents in this folder
+    const documents: string[] = [];
+    for (const [docId, doc] of store.documents) {
+      if (doc.folderId === id) {
+        documents.push(docId);
+      }
+    }
+
+    res.status(200).json({ ...folder, children, documents });
+  });
+
+  // Update folder
+  router.put('/:id', (req: AuthRequest, res: Response): void => {
+    const { id } = req.params;
+    const userId = req.userId!;
+    const { name, parentId } = req.body;
+
+    const folder = store.folders.get(id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    if (name !== undefined) {
+      if (typeof name !== 'string' || !name) {
+        res.status(400).json({ error: 'Name must be a non-empty string' });
+        return;
+      }
+      folder.name = name;
+    }
+
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parentFolder = store.folders.get(parentId);
+        if (!parentFolder) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Prevent circular references
+        if (parentId === id) {
+          res.status(400).json({ error: 'Folder cannot be its own parent' });
+          return;
+        }
+      }
+      folder.parentId = parentId;
+    }
+
+    res.status(200).json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', (req: AuthRequest, res: Response): void => {
+    const { id } = req.params;
+    const userId = req.userId!;
+
+    const folder = store.folders.get(id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, 'folder', id, 'owner')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Delete all documents in this folder
+    for (const [docId, doc] of store.documents) {
+      if (doc.folderId === id) {
+        store.documents.delete(docId);
+        store.permissions = store.permissions.filter(
+          (p) => !(p.resourceType === 'document' && p.resourceId === docId)
+        );
+      }
+    }
+
+    // Delete child folders recursively
+    deleteFolderRecursive(store, id);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
+
+function deleteFolderRecursive(store: Store, folderId: string): void {
+  // Find child folders
+  const childFolderIds: string[] = [];
+  for (const [childId, childFolder] of store.folders) {
+    if (childFolder.parentId === folderId) {
+      childFolderIds.push(childId);
+    }
+  }
+
+  // Delete children recursively
+  for (const childId of childFolderIds) {
+    // Delete documents in child folder
+    for (const [docId, doc] of store.documents) {
+      if (doc.folderId === childId) {
+        store.documents.delete(docId);
+        store.permissions = store.permissions.filter(
+          (p) => !(p.resourceType === 'document' && p.resourceId === docId)
+        );
+      }
+    }
+    deleteFolderRecursive(store, childId);
+  }
+
+  // Delete the folder itself
+  store.folders.delete(folderId);
+  store.permissions = store.permissions.filter(
+    (p) => !(p.resourceType === 'folder' && p.resourceId === folderId)
+  );
+}
diff --git a/src/routes/sharing.ts b/src/routes/sharing.ts
new file mode 100644
index 0000000..aa497d7
--- /dev/null
+++ b/src/routes/sharing.ts
@@ -0,0 +1,154 @@
+import { Router, Response } from 'express';
+import { Store } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { generateId, hasPermission, getEffectiveRole } from '../helpers.js';
+import { Role } from '../types.js';
+
+export function sharingRoutes(store: Store): Router {
+  const router = Router();
+
+  router.use(authMiddleware(store));
+
+  // Share a resource
+  router.post('/:resourceType/:resourceId/share', (req: AuthRequest, res: Response): void => {
+    const { resourceType, resourceId } = req.params;
+    const { userId: targetUserId, role } = req.body;
+    const currentUserId = req.userId!;
+
+    // Validate resource type
+    if (resourceType !== 'folders' && resourceType !== 'documents') {
+      res.status(400).json({ error: 'Invalid resource type. Use "folders" or "documents"' });
+      return;
+    }
+
+    const normalizedType = resourceType === 'folders' ? 'folder' : 'document';
+
+    // Validate role
+    const validRoles: Role[] = ['viewer', 'editor', 'owner'];
+    if (!role || !validRoles.includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Use "viewer", "editor", or "owner"' });
+      return;
+    }
+
+    // Validate target user
+    if (!targetUserId || typeof targetUserId !== 'string') {
+      res.status(400).json({ error: 'Target userId is required' });
+      return;
+    }
+
+    const targetUser = store.users.get(targetUserId);
+    if (!targetUser) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Validate resource exists
+    if (normalizedType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check permission: editors can share, owners can do anything
+    const currentUserRole = getEffectiveRole(store, currentUserId, normalizedType, resourceId);
+    if (!currentUserRole) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    // Editors can share but only viewer or editor roles, not owner
+    if (currentUserRole === 'editor' && role === 'owner') {
+      res.status(403).json({ error: 'Only owners can assign owner role' });
+      return;
+    }
+
+    // Viewers cannot share
+    if (currentUserRole === 'viewer') {
+      res.status(403).json({ error: 'Viewers cannot share resources' });
+      return;
+    }
+
+    // Check if there's already a direct permission for this user on this resource
+    const existingPermIdx = store.permissions.findIndex(
+      (p) =>
+        p.resourceType === normalizedType &&
+        p.resourceId === resourceId &&
+        p.userId === targetUserId
+    );
+
+    if (existingPermIdx !== -1) {
+      // Update existing permission
+      store.permissions[existingPermIdx].role = role;
+    } else {
+      // Create new permission
+      store.permissions.push({
+        id: generateId(),
+        resourceType: normalizedType,
+        resourceId,
+        userId: targetUserId,
+        role,
+      });
+    }
+
+    // Log activity
+    store.activityLog.push({
+      id: generateId(),
+      action: 'resource_shared',
+      userId: currentUserId,
+      resourceType: normalizedType,
+      resourceId,
+      timestamp: new Date().toISOString(),
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.status(200).json({
+      message: 'Resource shared successfully',
+      resourceType: normalizedType,
+      resourceId,
+      userId: targetUserId,
+      role,
+    });
+  });
+
+  // Get permissions for a resource
+  router.get('/:resourceType/:resourceId/permissions', (req: AuthRequest, res: Response): void => {
+    const { resourceType, resourceId } = req.params;
+    const userId = req.userId!;
+
+    if (resourceType !== 'folders' && resourceType !== 'documents') {
+      res.status(400).json({ error: 'Invalid resource type' });
+      return;
+    }
+
+    const normalizedType = resourceType === 'folders' ? 'folder' : 'document';
+
+    // Check resource exists
+    if (normalizedType === 'folder' && !store.folders.has(resourceId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (normalizedType === 'document' && !store.documents.has(resourceId)) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, userId, normalizedType, resourceId, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    const permissions = store.permissions.filter(
+      (p) => p.resourceType === normalizedType && p.resourceId === resourceId
+    );
+
+    res.status(200).json(permissions);
+  });
+
+  return router;
+}
