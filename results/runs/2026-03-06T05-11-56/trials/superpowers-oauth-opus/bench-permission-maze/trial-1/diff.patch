new file mode 100644
index 0000000..af3efb3
--- /dev/null
+++ b/src/app.test.ts
@@ -0,0 +1,758 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from './app.js';
+import type { Express } from 'express';
+
+describe('Document Management API', () => {
+  let app: Express;
+
+  beforeEach(() => {
+    app = createApp();
+  });
+
+  // --- Helper functions ---
+  async function registerUser(username: string, password: string) {
+    const res = await request(app)
+      .post('/auth/register')
+      .send({ username, password });
+    return res;
+  }
+
+  async function loginUser(username: string, password: string) {
+    const res = await request(app)
+      .post('/auth/login')
+      .send({ username, password });
+    return res;
+  }
+
+  async function registerAndLogin(username: string, password: string) {
+    await registerUser(username, password);
+    const loginRes = await loginUser(username, password);
+    return { token: loginRes.body.token, userId: loginRes.body.userId };
+  }
+
+  async function createFolder(token: string, name: string, parentId?: string) {
+    const body: Record<string, string> = { name };
+    if (parentId) body.parentId = parentId;
+    const res = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send(body);
+    return res;
+  }
+
+  async function createDocument(token: string, title: string, content: string, folderId: string) {
+    const res = await request(app)
+      .post('/documents')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title, content, folderId });
+    return res;
+  }
+
+  // --- Auth Tests ---
+  describe('Authentication', () => {
+    it('should register a new user', async () => {
+      const res = await registerUser('alice', 'pass123');
+      expect(res.status).toBe(201);
+      expect(res.body.username).toBe('alice');
+      expect(res.body.id).toBeDefined();
+      expect(res.body.password).toBeUndefined();
+    });
+
+    it('should reject duplicate username', async () => {
+      await registerUser('alice', 'pass123');
+      const res = await registerUser('alice', 'pass456');
+      expect(res.status).toBe(409);
+    });
+
+    it('should reject registration without username', async () => {
+      const res = await registerUser('', 'pass123');
+      expect(res.status).toBe(400);
+    });
+
+    it('should login successfully', async () => {
+      await registerUser('alice', 'pass123');
+      const res = await loginUser('alice', 'pass123');
+      expect(res.status).toBe(200);
+      expect(res.body.token).toBeDefined();
+      expect(res.body.userId).toBeDefined();
+    });
+
+    it('should reject login with wrong password', async () => {
+      await registerUser('alice', 'pass123');
+      const res = await loginUser('alice', 'wrongpass');
+      expect(res.status).toBe(401);
+    });
+
+    it('should reject requests without auth token', async () => {
+      const res = await request(app).get('/folders/some-id');
+      expect(res.status).toBe(401);
+    });
+
+    it('should reject requests with invalid token', async () => {
+      const res = await request(app)
+        .get('/folders/some-id')
+        .set('Authorization', 'Bearer invalidtoken');
+      expect(res.status).toBe(401);
+    });
+  });
+
+  // --- Folder Tests ---
+  describe('Folders', () => {
+    it('should create a folder', async () => {
+      const { token } = await registerAndLogin('alice', 'pass');
+      const res = await createFolder(token, 'My Folder');
+      expect(res.status).toBe(201);
+      expect(res.body.name).toBe('My Folder');
+      expect(res.body.parentId).toBeNull();
+      expect(res.body.id).toBeDefined();
+    });
+
+    it('should create a nested folder', async () => {
+      const { token } = await registerAndLogin('alice', 'pass');
+      const parent = await createFolder(token, 'Parent');
+      const child = await createFolder(token, 'Child', parent.body.id);
+      expect(child.status).toBe(201);
+      expect(child.body.parentId).toBe(parent.body.id);
+    });
+
+    it('should get a folder with children and documents', async () => {
+      const { token } = await registerAndLogin('alice', 'pass');
+      const folder = await createFolder(token, 'Parent');
+      const folderId = folder.body.id;
+      await createFolder(token, 'Child', folderId);
+      await createDocument(token, 'Doc', 'content', folderId);
+
+      const res = await request(app)
+        .get(`/folders/${folderId}`)
