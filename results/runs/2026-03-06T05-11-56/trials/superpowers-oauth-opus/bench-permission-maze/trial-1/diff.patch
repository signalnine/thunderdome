+++ b/src/app.ts
@@ -0,0 +1,32 @@
+import express from 'express';
+import { createStore } from './store.js';
+import { authRoutes } from './routes/auth.js';
+import { folderRoutes } from './routes/folders.js';
+import { documentRoutes } from './routes/documents.js';
+import { sharingRoutes } from './routes/sharing.js';
+import { activityRoutes } from './routes/activity.js';
+import { resetIdCounter } from './helpers.js';
+
+export function createApp(): express.Express {
+  const app = express();
+  const store = createStore();
+
+  resetIdCounter();
+
+  app.use(express.json());
+
+  // Auth routes (no auth required)
+  app.use('/auth', authRoutes(store));
+
+  // Protected routes
+  app.use('/folders', folderRoutes(store));
+  app.use('/documents', documentRoutes(store));
+
+  // Sharing routes (under root, handles /:resourceType/:id/share)
+  app.use('/', sharingRoutes(store));
+
+  // Activity log
+  app.use('/activity', activityRoutes(store));
+
+  return app;
+}
diff --git a/src/helpers.ts b/src/helpers.ts
new file mode 100644
index 0000000..a20851e
--- /dev/null
+++ b/src/helpers.ts
@@ -0,0 +1,113 @@
+import { Store } from './store.js';
+import { Role } from './types.js';
+
+let idCounter = 0;
+
+export function generateId(): string {
+  idCounter++;
+  return `id_${idCounter}_${Date.now()}`;
+}
+
+export function generateToken(): string {
+  return `token_${generateId()}_${Math.random().toString(36).slice(2)}`;
+}
+
+export function resetIdCounter(): void {
+  idCounter = 0;
+}
+
+const roleHierarchy: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): Role | null {
+  let bestRole: Role | null = null;
+
+  // Check direct permissions on this resource
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === resourceType &&
+      perm.resourceId === resourceId &&
+      perm.userId === userId
+    ) {
+      if (!bestRole || roleHierarchy[perm.role] > roleHierarchy[bestRole]) {
+        bestRole = perm.role;
+      }
+    }
+  }
+
+  // If document, also check folder permissions (inherited)
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveFolderRole(store, userId, doc.folderId);
+      if (folderRole && (!bestRole || roleHierarchy[folderRole] > roleHierarchy[bestRole])) {
+        bestRole = folderRole;
+      }
+    }
+  }
+
+  // If folder, also check parent folder permissions (inherited)
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getEffectiveFolderRole(store, userId, folder.parentId);
+      if (parentRole && (!bestRole || roleHierarchy[parentRole] > roleHierarchy[bestRole])) {
+        bestRole = parentRole;
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+function getEffectiveFolderRole(
+  store: Store,
+  userId: string,
+  folderId: string
+): Role | null {
+  let bestRole: Role | null = null;
+
+  // Direct permissions on this folder
+  for (const perm of store.permissions) {
+    if (
+      perm.resourceType === 'folder' &&
+      perm.resourceId === folderId &&
+      perm.userId === userId
+    ) {
+      if (!bestRole || roleHierarchy[perm.role] > roleHierarchy[bestRole]) {
+        bestRole = perm.role;
+      }
+    }
+  }
+
+  // Check parent folder permissions (recursive)
+  const folder = store.folders.get(folderId);
+  if (folder && folder.parentId) {
+    const parentRole = getEffectiveFolderRole(store, userId, folder.parentId);
+    if (parentRole && (!bestRole || roleHierarchy[parentRole] > roleHierarchy[bestRole])) {
+      bestRole = parentRole;
+    }
+  }
+
+  return bestRole;
+}
+
+export function hasPermission(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  requiredRole: Role
+): boolean {
+  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);
+  if (!effectiveRole) return false;
+  return roleHierarchy[effectiveRole] >= roleHierarchy[requiredRole];
+}
