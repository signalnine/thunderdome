+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01BgBXL7FN8YDNZG8unNqeji","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01PqTNt2D7ev9ZvHVENxcrdw","name":"Write","input":{"file_path":"/workspace/src/index.ts","content":"export interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\n/**\n * Detect cycles in the prerequisite graph using DFS.\n * Throws if any cycle (including self-references) is found.\n * Returns a topological ordering of event IDs.\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Check for self-references and references to existing events\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereq of e.prerequisites) {\n        if (prereq === e.id) {\n          throw new Error(`Cycle detected: event \"${e.id}\" has itself as a prerequisite`);\n        }\n      }\n    }\n  }\n\n  // DFS-based cycle detection and topological sort\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const e of events) {\n    color.set(e.id, WHITE);\n  }\n\n  const order: string[] = [];\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const prereq of event.prerequisites) {\n        // Only consider prerequisites that are in our event set\n        if (!eventMap.has(prereq)) continue;\n        const c = color.get(prereq)!;\n        if (c === GRAY) {\n          throw new Error(`Cycle detected in prerequisites involving event \"${prereq}\"`);\n        }\n        if (c === WHITE) {\n          dfs(prereq);\n        }\n      }\n    }\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id);\n    }\n  }\n\n  return order;\n}\n\n/**\n * Compute the depth of each event in the prerequisite DAG.\n * Events with no prerequisites have depth 0.\n */\nfunction computeDepths(events: Event[]): Map<string, number> {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const depths = new Map<string, number>();\n\n  function getDepth(id: string): number {\n    if (depths.has(id)) return depths.get(id)!;\n    const event = eventMap.get(id);\n    if (!event?.prerequisites || event.prerequisites.length === 0) {\n      depths.set(id, 0);\n      return 0;\n    }\n    let maxDepth = 0;\n    for (const prereq of event.prerequisites) {\n      if (eventMap.has(prereq)) {\n        maxDepth = Math.max(maxDepth, getDepth(prereq) + 1);\n      }\n    }\n    depths.set(id, maxDepth);\n    return maxDepth;\n  }\n\n  for (const e of events) {\n    getDepth(e.id);\n  }\n\n  return depths;\n}\n\n/**\n * Core scheduling function. Uses constraint-based approach:\n * 1. Topological sort (with cycle detection)\n * 2. Most-constrained-first ordering within topological levels\n * 3. Backtracking search to maximize scheduled events\n */\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  if (rooms.length === 0) {\n    return { assignments: [], unscheduled: events.map(e => e.id) };\n  }\n\n  // Step 1: Cycle detection + topological ordering\n  const topoOrder = topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Step 2: Compute depths and order events\n  const depths = computeDepths(events);\n\n  // Count how many rooms each event can fit in (capacity constraint)\n  const validRoomCount = new Map<string, number>();\n  for (const e of events) {\n    const attendees = e.attendees ?? 1;\n    let count = 0;\n    for (const r of rooms) {\n      if (r.capacity >= attendees) count++;\n    }\n    validRoomCount.set(e.id, count);\n  }\n\n  // Order: respect topological order, but within same depth level,\n  // prioritize most-constrained (fewest valid rooms, then longest duration)\n  const topoIndex = new Map<string, number>();\n  for (let i = 0; i < topoOrder.length; i++) {\n    topoIndex.set(topoOrder[i], i);\n  }\n\n  const sortedEvents = [...events].sort((a, b) => {\n    const depthA = depths.get(a.id)!;\n    const depthB = depths.get(b.id)!;\n    if (depthA !== depthB) return depthA - depthB;\n\n    // Within same depth, most constrained first\n    const roomsA = validRoomCount.get(a.id)!;\n    const roomsB = validRoomCount.get(b.id)!;\n    if (roomsA !== roomsB) return roomsA - roomsB;\n\n    // Longer events are harder to place\n    if (a.duration !== b.duration) return b.duration - a.duration;\n\n    // Fall back to topological index\n    return topoIndex.get(a.id)! - topoIndex.get(b.id)!;\n  });\n\n  // Step 3: Schedule using backtracking\n  // Track room timelines: for each room, sorted list of (start, end) intervals\n  type Interval = { start: number; end: number; eventId: string };\n  const roomTimelines = new Map<string, Interval[]>();\n  for (const r of rooms) {\n    roomTimelines.set(r.id, []);\n  }\n\n  const assignments = new Map<string, Assignment>();\n\n  /**\n   * Find the earliest start time for an event in a given room,\n   * respecting gaps and the time window.\n   */\n  function findEarliestSlot(roomId: string, duration: number, earliestStart: number): number | null {\n    const timeline = roomTimelines.get(roomId)!;\n    const eventStart = Math.max(startTime, earliestStart);\n    const eventEnd = eventStart + duration;\n\n    if (eventEnd > endTime) return null;\n\n    if (timeline.length === 0) return eventStart;\n\n    // Try to fit before all existing events, between them, or after them\n    // Timeline is sorted by start time\n    // Try before first event\n    if (eventEnd + gap <= timeline[0].start && eventStart >= startTime) {\n      return eventStart;\n    }\n\n    // Try between events\n    for (let i = 0; i < timeline.length; i++) {\n      const slotStart = Math.max(timeline[i].end + gap, eventStart);\n      const slotEnd = slotStart + duration;\n\n      if (slotEnd > endTime) return null;\n\n      if (i + 1 < timeline.length) {\n        if (slotEnd + gap <= timeline[i + 1].start) {\n          return slotStart;\n        }\n      } else {\n        // After last event\n        return slotStart;\n      }\n    }\n\n    return null;\n  }\n\n  /**\n   * Get the earliest possible start time for an event considering prerequisites.\n   */\n  function getEarliestFromPrereqs(event: Event): number {\n    let earliest = startTime;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        const prereqAssignment = assignments.get(prereqId);\n        if (prereqAssignment) {\n          earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n        }\n        // If prerequisite is not in our event set, ignore it\n        // If prerequisite is in our event set but not yet assigned,\n        // it should already be assigned due to topological ordering\n      }\n    }\n    return earliest;\n  }\n\n  /**\n   * Insert an interval into a room's timeline, keeping it sorted.\n   */\n  function insertInterval(roomId: string, interval: Interval): void {\n    const timeline = roomTimelines.get(roomId)!;\n    let idx = 0;\n    while (idx < timeline.length && timeline[idx].start < interval.start) {\n      idx++;\n    }\n    timeline.splice(idx, 0, interval);\n  }\n\n  /**\n   * Remove an interval from a room's timeline.\n   */\n  function removeInterval(roomId: string, eventId: string): void {\n    const timeline = roomTimelines.get(roomId)!;\n    const idx = timeline.findIndex(i => i.eventId === eventId);\n    if (idx !== -1) {\n      timeline.splice(idx, 1);\n    }\n  }\n\n  /**\n   * Get all valid placements for an event: (roomId, startTime) pairs.\n   * Ordered: preferred room first, then by earliest start time.\n   */\n  function getValidPlacements(event: Event): Array<{ roomId: string; start: number }> {\n    const attendees = event.attendees ?? 1;\n    const earliestFromPrereqs = getEarliestFromPrereqs(event);\n    const placements: Array<{ roomId: string; start: number }> = [];\n\n    // Sort rooms: preferred first, then by capacity (smallest sufficient first)\n    const sortedRooms = [...rooms]\n      .filter(r => r.capacity >= attendees)\n      .sort((a, b) => {\n        // Preferred room gets priority\n        if (event.preferredRoom) {\n          if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n          if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n        }\n        // Then smallest sufficient room\n        return a.capacity - b.capacity;\n      });\n\n    for (const room of sortedRooms) {\n      const slotStart = findEarliestSlot(room.id, event.duration, earliestFromPrereqs);\n      if (slotStart !== null) {\n        placements.push({ roomId: room.id, start: slotStart });\n      }\n    }\n\n    return placements;\n  }\n\n  // Use a greedy approach with retry: schedule events in constrained order,\n  // and if an event can't be placed, try different placements for earlier events.\n\n  // For practical purposes with potentially many events, full backtracking\n  // over all permutations is too expensive. Instead, we use a smarter approach:\n  //\n  // Phase 1: Greedy assignment in topological/constrained order\n  // Phase 2: For unscheduled events, try to reschedule by finding alternative\n  //          placements for conflicting events\n\n  // Phase 1: Greedy pass\n  const unscheduledSet = new Set<string>();\n\n  for (const event of sortedEvents) {\n    const attendees = event.attendees ?? 1;\n\n    // Check if event can fit in any room at all\n    if (!rooms.some(r => r.capacity >= attendees)) {\n      unscheduledSet.add(event.id);\n      continue;\n    }\n\n    // Check if event fits in the time window at all\n    if (event.duration > endTime - startTime) {\n      unscheduledSet.add(event.id);\n      continue;\n    }\n\n    // Check if all prerequisites are scheduled (only those in event set)\n    if (event.prerequisites) {\n      const unmetPrereqs = event.prerequisites.filter(\n        p => eventMap.has(p) && !assignments.has(p)\n      );\n      if (unmetPrereqs.length > 0) {\n        unscheduledSet.add(event.id);\n        continue;\n      }\n    }\n\n    const placements = getValidPlacements(event);\n    if (placements.length > 0) {\n      const best = placements[0];\n      const assignment: Assignment = {\n        eventId: event.id,\n        roomId: best.roomId,\n        startTime: best.start,\n        endTime: best.start + event.duration,\n      };\n      assignments.set(event.id, assignment);\n      insertInterval(best.roomId, {\n        start: best.start,\n        end: best.start + event.duration,\n        eventId: event.id,\n      });\n    } else {\n      unscheduledSet.add(event.id);\n    }\n  }\n\n  // Phase 2: Try to improve by rescheduling\n  // For each unscheduled event, see if we can make room by moving existing events\n  if (unscheduledSet.size > 0) {\n    let improved = true;\n    let iterations = 0;\n    const maxIterations = unscheduledSet.size * rooms.length;\n\n    while (improved && iterations < maxIterations) {\n      improved = false;\n      iterations++;\n\n      for (const eventId of [...unscheduledSet]) {\n        const event = eventMap.get(eventId)!;\n        const attendees = event.attendees ?? 1;\n\n        // Check prerequisites\n        if (event.prerequisites) {\n          const unmetPrereqs = event.prerequisites.filter(\n            p => eventMap.has(p) && !assignments.has(p)\n          );\n          if (unmetPrereqs.length > 0) continue;\n        }\n\n        // Find rooms that could fit this event capacity-wise\n        const candidateRooms = rooms.filter(r => r.capacity >= attendees);\n        if (candidateRooms.length === 0) continue;\n\n        const earliestFromPrereqs = getEarliestFromPrereqs(event);\n\n        for (const room of candidateRooms) {\n          // Try to find a slot by temporarily removing events and rescheduling them\n          const timeline = roomTimelines.get(room.id)!;\n\n          // Find conflicting events in this room's timeline\n          // An event conflicts if moving it would free up space for our event\n          const conflicting = timeline.filter(interval => {\n            const otherEvent = eventMap.get(interval.eventId)!;\n            // Only consider displacing if the other event has more placement options\n            const otherAttendees = otherEvent.attendees ?? 1;\n            const otherRooms = rooms.filter(r => r.capacity >= otherAttendees && r.id !== room.id);\n            return otherRooms.length > 0;\n          });\n\n          for (const conflict of conflicting) {\n            const conflictEvent = eventMap.get(conflict.eventId)!;\n\n            // Temporarily remove the conflicting event\n            removeInterval(room.id, conflict.eventId);\n            const savedAssignment = assignments.get(conflict.eventId)!;\n            assignments.delete(conflict.eventId);\n\n            // Try to place our event\n            const slot = findEarliestSlot(room.id, event.duration, earliestFromPrereqs);\n            if (slot !== null && slot + event.duration <= endTime) {\n              // Try to reschedule the displaced event elsewhere\n              const displacedPlacements = getValidPlacements(conflictEvent);\n              if (displacedPlacements.length > 0) {\n                // Success: place our event and reschedule the displaced one\n                const assignment: Assignment = {\n                  eventId: event.id,\n                  roomId: room.id,\n                  startTime: slot,\n                  endTime: slot + event.duration,\n                };\n                assignments.set(event.id, assignment);\n                insertInterval(room.id, {\n                  start: slot,\n                  end: slot + event.duration,\n                  eventId: event.id,\n                });\n\n                const dp = displacedPlacements[0];\n                const displacedAssignment: Assignment = {\n                  eventId: conflict.eventId,\n                  roomId: dp.roomId,\n                  startTime: dp.start,\n                  endTime: dp.start + conflictEvent.duration,\n                };\n                assignments.set(conflict.eventId, displacedAssignment);\n                insertInterval(dp.roomId, {\n                  start: dp.start,\n                  end: dp.start + conflictEvent.duration,\n                  eventId: conflict.eventId,\n                });\n\n                unscheduledSet.delete(event.id);\n                improved = true;\n                break;\n              }\n            }\n\n            // Restore the conflicting event\n            if (!assignments.has(conflict.eventId)) {\n              assignments.set(conflict.eventId, savedAssignment);\n              insertInterval(room.id, {\n                start: savedAssignment.startTime,\n                end: savedAssignment.endTime,\n                eventId: conflict.eventId,\n              });\n            }\n          }\n\n          if (!unscheduledSet.has(eventId)) break;\n        }\n      }\n    }\n  }\n\n  // Phase 3: Try a different ordering approach for remaining unscheduled events\n  // Attempt to reschedule everything with unscheduled events given priority\n  if (unscheduledSet.size > 0) {\n    // Check if we can improve by trying alternative placements\n    // For each unscheduled event, try all possible (room, time) combinations\n    for (const eventId of [...unscheduledSet]) {\n      const event = eventMap.get(eventId)!;\n\n      // Check prerequisites\n      if (event.prerequisites) {\n        const unmetPrereqs = event.prerequisites.filter(\n          p => eventMap.has(p) && !assignments.has(p)\n        );\n        if (unmetPrereqs.length > 0) continue;\n      }\n\n      const placements = getValidPlacements(event);\n      if (placements.length > 0) {\n        const best = placements[0];\n        const assignment: Assignment = {\n          eventId: event.id,\n          roomId: best.roomId,\n          startTime: best.start,\n          endTime: best.start + event.duration,\n        };\n        assignments.set(event.id, assignment);\n        insertInterval(best.roomId, {\n          start: best.start,\n          end: best.start + event.duration,\n          eventId: event.id,\n        });\n        unscheduledSet.delete(event.id);\n      }\n    }\n  }\n\n  return {\n    assignments: Array.from(assignments.values()),\n    unscheduled: Array.from(unscheduledSet),\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":284,"cache_read_input_tokens":22321,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":284},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f4932607-fbc6-4ee9-a746-1aff0d825a4b","uuid":"8ef27436-c6f2-4aed-8b78-c167e55ef05a"}
