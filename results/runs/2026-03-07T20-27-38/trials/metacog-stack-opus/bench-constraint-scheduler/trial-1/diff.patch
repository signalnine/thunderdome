t !== null) {\n              // Temporarily insert our event so displaced event placement\n              // correctly sees the room as occupied\n              insertInterval(timeline, {\n                start: slot,\n                end: slot + event.duration,\n                eventId: eid,\n              });\n\n              // Try to find a new home for the displaced event\n              let conflictEarliest = startTime;\n              if (conflictEvent.prerequisites) {\n                for (const pid of conflictEvent.prerequisites) {\n                  const pa = asgn.get(pid);\n                  if (pa) conflictEarliest = Math.max(conflictEarliest, pa.endTime + gap);\n                }\n              }\n\n              const conflictValidRooms = validRoomsForEvent.get(conflict.eventId)!;\n              const conflictOrderedRooms = [...conflictValidRooms].sort((a, b) => {\n                if (conflictEvent.preferredRoom) {\n                  if (a.id === conflictEvent.preferredRoom && b.id !== conflictEvent.preferredRoom) return -1;\n                  if (b.id === conflictEvent.preferredRoom && a.id !== conflictEvent.preferredRoom) return 1;\n                }\n                return a.capacity - b.capacity;\n              });\n\n              let conflictPlaced = false;\n              for (const cr of conflictOrderedRooms) {\n                const crTimeline = tls.get(cr.id)!;\n                const crSlot = findEarliestSlot(crTimeline, conflictEvent.duration, conflictEarliest, startTime, endTime, gap);\n                if (crSlot !== null) {\n                  // Check this doesn't break any dependent events\n                  let valid = true;\n\n                  for (const [depId, depAssignment] of asgn) {\n                    const depEvent = eventMap.get(depId)!;\n                    if (depEvent.prerequisites?.includes(conflict.eventId)) {\n                      if (depAssignment.startTime < crSlot + conflictEvent.duration + gap) {\n                        valid = false;\n                        break;\n                      }\n                    }\n                  }\n\n                  if (valid) {\n                    // Place both events (our event is already in the timeline)\n                    asgn.set(eid, {\n                      eventId: eid,\n                      roomId: room.id,\n                      startTime: slot,\n                      endTime: slot + event.duration,\n                    });\n\n                    asgn.set(conflict.eventId, {\n                      eventId: conflict.eventId,\n                      roomId: cr.id,\n                      startTime: crSlot,\n                      endTime: crSlot + conflictEvent.duration,\n                    });\n                    insertInterval(crTimeline, {\n                      start: crSlot,\n                      end: crSlot + conflictEvent.duration,\n                      eventId: conflict.eventId,\n                    });\n\n                    unsched.delete(eid);\n                    improved = true;\n                    conflictPlaced = true;\n                    placed = true;\n                    break;\n                  }\n                }\n              }\n\n              // If displacement failed, remove our temporarily inserted event\n              if (!conflictPlaced) {\n                removeInterval(timeline, eid);\n              }\n\n              if (conflictPlaced) break;\n            }","originalFile":"export interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\n/**\n * Detect cycles in the prerequisite graph using DFS.\n * Throws if any cycle (including self-references) is found.\n * Returns a topological ordering of event IDs.\n */\nfunction topologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Explicit self-reference check\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereq of e.prerequisites) {\n        if (prereq === e.id) {\n          throw new Error(`Cycle detected: event \"${e.id}\" has itself as a prerequisite`);\n        }\n      }\n    }\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const e of events) {\n    color.set(e.id, WHITE);\n  }\n\n  const order: string[] = [];\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const prereq of event.prerequisites) {\n        if (!eventMap.has(prereq)) continue;\n        const c = color.get(prereq)!;\n        if (c === GRAY) {\n          throw new Error(`Cycle detected in prerequisites involving event \"${prereq}\"`);\n        }\n        if (c === WHITE) {\n          dfs(prereq);\n        }\n      }\n    }\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id);\n    }\n  }\n\n  return order;\n}\n\ntype Interval = { start: number; end: number; eventId: string };\n\n/**\n * Find the earliest valid start time for an event in a room's timeline.\n */\nfunction findEarliestSlot(\n  timeline: Interval[],\n  duration: number,\n  earliestStart: number,\n  windowStart: number,\n  windowEnd: number,\n  gap: number,\n): number | null {\n  const eventStart = Math.max(windowStart, earliestStart);\n\n  if (eventStart + duration > windowEnd) return null;\n  if (timeline.length === 0) return eventStart;\n\n  // Try before first event\n  if (eventStart + duration + gap <= timeline[0].start) {\n    return eventStart;\n  }\n\n  // Try between events or after the last one\n  for (let i = 0; i < timeline.length; i++) {\n    const slotStart = Math.max(timeline[i].end + gap, eventStart);\n    const slotEnd = slotStart + duration;\n\n    if (slotEnd > windowEnd) return null;\n\n    if (i + 1 < timeline.length) {\n      if (slotEnd + gap <= timeline[i + 1].start) {\n        return slotStart;\n      }\n    } else {\n      // After last event\n      return slotStart;\n    }\n  }\n\n  return null;\n}\n\n/**\n * Insert an interval into a timeline, maintaining sorted order by start time.\n */\nfunction insertInterval(timeline: Interval[], interval: Interval): void {\n  let idx = 0;\n  while (idx < timeline.length && timeline[idx].start < interval.start) {\n    idx++;\n  }\n  timeline.splice(idx, 0, interval);\n}\n\n/**\n * Remove an interval from a timeline by event ID.\n */\nfunction removeInterval(timeline: Interval[], eventId: string): void {\n  const idx = timeline.findIndex(i => i.eventId === eventId);\n  if (idx !== -1) {\n    timeline.splice(idx, 1);\n  }\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  if (rooms.length === 0) {\n    return { assignments: [], unscheduled: events.map(e => e.id) };\n  }\n\n  // Step 1: Cycle detection + topological ordering\n  const topoOrder = topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Build the set of valid rooms per event (capacity constraint)\n  const validRoomsForEvent = new Map<string, Room[]>();\n  for (const e of events) {\n    const attendees = e.attendees ?? 1;\n    const valid = rooms.filter(r => r.capacity >= attendees);\n    validRoomsForEvent.set(e.id, valid);\n  }\n\n  // Compute prerequisite depth for ordering\n  const depths = new Map<string, number>();\n  function getDepth(id: string): number {\n    if (depths.has(id)) return depths.get(id)!;\n    const event = eventMap.get(id)!;\n    if (!event.prerequisites || event.prerequisites.length === 0) {\n      depths.set(id, 0);\n      return 0;\n    }\n    let maxD = 0;\n    for (const prereq of event.prerequisites) {\n      if (eventMap.has(prereq)) {\n        maxD = Math.max(maxD, getDepth(prereq) + 1);\n      }\n    }\n    depths.set(id, maxD);\n    return maxD;\n  }\n  for (const e of events) getDepth(e.id);\n\n  // Build topological index map\n  const topoIndex = new Map<string, number>();\n  for (let i = 0; i < topoOrder.length; i++) {\n    topoIndex.set(topoOrder[i], i);\n  }\n\n  // Sort events: by depth first (prerequisites before dependents),\n  // then most-constrained-first within same depth\n  const sortedEventIds = [...events].sort((a, b) => {\n    const da = depths.get(a.id)!;\n    const db = depths.get(b.id)!;\n    if (da !== db) return da - db;\n\n    const ra = validRoomsForEvent.get(a.id)!.length;\n    const rb = validRoomsForEvent.get(b.id)!.length;\n    if (ra !== rb) return ra - rb;\n\n    if (a.duration !== b.duration) return b.duration - a.duration;\n\n    return topoIndex.get(a.id)! - topoIndex.get(b.id)!;\n  }).map(e => e.id);\n\n  // Helper: run a greedy scheduling pass given a specific event ordering\n  function greedySchedule(eventOrder: string[]): {\n    assignments: Map<string, Assignment>;\n    timelines: Map<string, Interval[]>;\n    unscheduled: Set<string>;\n  } {\n    const asgn = new Map<string, Assignment>();\n    const tls = new Map<string, Interval[]>();\n    for (const r of rooms) tls.set(r.id, []);\n    const unsched = new Set<string>();\n\n    for (const eid of eventOrder) {\n      const event = eventMap.get(eid)!;\n      const validRooms = validRoomsForEvent.get(eid)!;\n\n      // Check basic feasibility\n      if (validRooms.length === 0 || event.duration > endTime - startTime) {\n        unsched.add(eid);\n        continue;\n      }\n\n      // Check prerequisites are scheduled\n      if (event.prerequisites) {\n        const unmet = event.prerequisites.filter(\n          p => eventMap.has(p) && !asgn.has(p)\n        );\n        if (unmet.length > 0) {\n          unsched.add(eid);\n          continue;\n        }\n      }\n\n      // Compute earliest start from prerequisites\n      let earliest = startTime;\n      if (event.prerequisites) {\n        for (const pid of event.prerequisites) {\n          const pa = asgn.get(pid);\n          if (pa) {\n            earliest = Math.max(earliest, pa.endTime + gap);\n          }\n        }\n      }\n\n      // Sort rooms: preferred first, then smallest sufficient\n      const orderedRooms = [...validRooms].sort((a, b) => {\n        if (event.preferredRoom) {\n          if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n          if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n        }\n        return a.capacity - b.capacity;\n      });\n\n      let placed = false;\n      for (const room of orderedRooms) {\n        const timeline = tls.get(room.id)!;\n        const slotStart = findEarliestSlot(timeline, event.duration, earliest, startTime, endTime, gap);\n        if (slotStart !== null) {\n          const assignment: Assignment = {\n            eventId: eid,\n            roomId: room.id,\n            startTime: slotStart,\n            endTime: slotStart + event.duration,\n          };\n          asgn.set(eid, assignment);\n          insertInterval(timeline, {\n            start: slotStart,\n            end: slotStart + event.duration,\n            eventId: eid,\n          });\n          placed = true;\n          break;\n        }\n      }\n\n      if (!placed) {\n        unsched.add(eid);\n      }\n    }\n\n    return { assignments: asgn, timelines: tls, unscheduled: unsched };\n  }\n\n  // Run primary greedy pass\n  let best = greedySchedule(sortedEventIds);\n\n  // If there are unscheduled events, try alternative orderings to maximize placement\n  if (best.unscheduled.size > 0) {\n    // Strategy: try multiple orderings and keep the best result\n\n    // Alternative 1: Reverse priority within depth levels (shortest duration first)\n    const altOrder1 = [...events].sort((a, b) => {\n      const da = depths.get(a.id)!;\n      const db = depths.get(b.id)!;\n      if (da !== db) return da - db;\n      if (a.duration !== b.duration) return a.duration - b.duration;\n      return topoIndex.get(a.id)! - topoIndex.get(b.id)!;\n    }).map(e => e.id);\n\n    const result1 = greedySchedule(altOrder1);\n    if (result1.unscheduled.size < best.unscheduled.size) {\n      best = result1;\n    }\n\n    // Alternative 2: Pure topological order\n    const result2 = greedySchedule(topoOrder);\n    if (result2.unscheduled.size < best.unscheduled.size) {\n      best = result2;\n    }\n\n    // Alternative 3: Largest attendees first (within depth)\n    const altOrder3 = [...events].sort((a, b) => {\n      const da = depths.get(a.id)!;\n      const db = depths.get(b.id)!;\n      if (da !== db) return da - db;\n      const aa = a.attendees ?? 1;\n      const ab = b.attendees ?? 1;\n      if (aa !== ab) return ab - aa;\n      return topoIndex.get(a.id)! - topoIndex.get(b.id)!;\n    }).map(e => e.id);\n\n    const result3 = greedySchedule(altOrder3);\n    if (result3.unscheduled.size < best.unscheduled.size) {\n      best = result3;\n    }\n  }\n\n  // Phase 2: Displacement-based improvement for remaining unscheduled events\n  if (best.unscheduled.size > 0) {\n    const { assignments: asgn, timelines: tls, unscheduled: unsched } = best;\n\n    let improved = true;\n    let iterations = 0;\n    const maxIterations = unsched.size * rooms.length * 2;\n\n    while (improved && iterations < maxIterations) {\n      improved = false;\n      iterations++;\n\n      for (const eid of [...unsched]) {\n        const event = eventMap.get(eid)!;\n        const validRooms = validRoomsForEvent.get(eid)!;\n        if (validRooms.length === 0) continue;\n\n        // Check prerequisites\n        if (event.prerequisites) {\n          const unmet = event.prerequisites.filter(p => eventMap.has(p) && !asgn.has(p));\n          if (unmet.length > 0) continue;\n        }\n\n        let earliest = startTime;\n        if (event.prerequisites) {\n          for (const pid of event.prerequisites) {\n            const pa = asgn.get(pid);\n            if (pa) earliest = Math.max(earliest, pa.endTime + gap);\n          }\n        }\n\n        let placed = false;\n\n        for (const room of validRooms) {\n          const timeline = tls.get(room.id)!;\n\n          // First, try direct placement\n          const directSlot = findEarliestSlot(timeline, event.duration, earliest, startTime, endTime, gap);\n          if (directSlot !== null) {\n            asgn.set(eid, {\n              eventId: eid,\n              roomId: room.id,\n              startTime: directSlot,\n              endTime: directSlot + event.duration,\n            });\n            insertInterval(timeline, {\n              start: directSlot,\n              end: directSlot + event.duration,\n              eventId: eid,\n            });\n            unsched.delete(eid);\n            improved = true;\n            placed = true;\n            break;\n          }\n\n          // Try displacing each event in this room\n          const candidates = [...timeline].filter(interval => {\n            // Can we move this event elsewhere?\n            const otherRooms = validRoomsForEvent.get(interval.eventId)!;\n            return otherRooms.some(r => r.id !== room.id);\n          });\n\n          for (const conflict of candidates) {\n            const conflictEvent = eventMap.get(conflict.eventId)!;\n            const savedAssignment = asgn.get(conflict.eventId)!;\n\n            // Remove the conflicting event\n            removeInterval(timeline, conflict.eventId);\n            asgn.delete(conflict.eventId);\n\n            // Try to place our event\n            const slot = findEarliestSlot(timeline, event.duration, earliest, startTime, endTime, gap);\n            if (slot !== null) {\n              // Try to find a new home for the displaced event\n              let conflictEarliest = startTime;\n              if (conflictEvent.prerequisites) {\n                for (const pid of conflictEvent.prerequisites) {\n                  const pa = asgn.get(pid);\n                  if (pa) conflictEarliest = Math.max(conflictEarliest, pa.endTime + gap);\n                }\n              }\n\n              const conflictValidRooms = validRoomsForEvent.get(conflict.eventId)!;\n              const conflictOrderedRooms = [...conflictValidRooms].sort((a, b) => {\n                if (conflictEvent.preferredRoom) {\n                  if (a.id === conflictEvent.preferredRoom && b.id !== conflictEvent.preferredRoom) return -1;\n                  if (b.id === conflictEvent.preferredRoom && a.id !== conflictEvent.preferredRoom) return 1;\n                }\n                return a.capacity - b.capacity;\n              });\n\n              let conflictPlaced = false;\n              for (const cr of conflictOrderedRooms) {\n                const crTimeline = tls.get(cr.id)!;\n                const crSlot = findEarliestSlot(crTimeline, conflictEvent.duration, conflictEarliest, startTime, endTime, gap);\n                if (crSlot !== null) {\n                  // Check this doesn't break any dependent events\n                  let valid = true;\n\n                  // Check if any event depends on the conflict event\n                  // and still starts after the new end time + gap\n                  for (const [depId, depAssignment] of asgn) {\n                    const depEvent = eventMap.get(depId)!;\n                    if (depEvent.prerequisites?.includes(conflict.eventId)) {\n                      if (depAssignment.startTime < crSlot + conflictEvent.duration + gap) {\n                        valid = false;\n                        break;\n                      }\n                    }\n                  }\n\n                  if (valid) {\n                    // Place both events\n                    asgn.set(eid, {\n                      eventId: eid,\n                      roomId: room.id,\n                      startTime: slot,\n                      endTime: slot + event.duration,\n                    });\n                    insertInterval(timeline, {\n                      start: slot,\n                      end: slot + event.duration,\n                      eventId: eid,\n                    });\n\n                    asgn.set(conflict.eventId, {\n                      eventId: conflict.eventId,\n                      roomId: cr.id,\n                      startTime: crSlot,\n                      endTime: crSlot + conflictEvent.duration,\n                    });\n                    insertInterval(crTimeline, {\n                      start: crSlot,\n                      end: crSlot + conflictEvent.duration,\n                      eventId: conflict.eventId,\n                    });\n\n                    unsched.delete(eid);\n                    improved = true;\n                    conflictPlaced = true;\n                    placed = true;\n                    break;\n                  }\n                }\n              }\n\n              if (conflictPlaced) break;\n            }\n\n            // Restore if we couldn't place both\n            if (!asgn.has(conflict.eventId)) {\n              asgn.set(conflict.eventId, savedAssignment);\n              insertInterval(timeline, {\n                start: savedAssignment.startTime,\n                end: savedAssignment.endTime,\n                eventId: conflict.eventId,\n              });\n            }\n          }\n\n          if (placed) break;\n        }\n      }\n    }\n  }\n\n  return {\n    assignments: Array.from(best.assignments.values()),\n    unscheduled: Array.from(best.unscheduled),\n  };\n}\n","structuredPatch":[{"oldStart":423,"oldLines":6,"newStart":423,"newLines":14,"lines":["             // Try to place our event","             const slot = findEarliestSlot(timeline, event.duration, earliest, startTime, endTime, gap);","             if (slot !== null) {","+              // Temporarily insert our event so displaced event placement","+              // correctly sees the room as occupied","+              insertInterval(timeline, {","+                start: slot,","+                end: slot + event.duration,","+                eventId: eid,","+              });","+","               // Try to find a new home for the displaced event","               let conflictEarliest = startTime;","               if (conflictEvent.prerequisites) {"]},{"oldStart":449,"oldLines":8,"newStart":457,"newLines":6,"lines":["                   // Check this doesn't break any dependent events","                   let valid = true;"," ","-                  // Check if any event depends on the conflict event","-                  // and still starts after the new end time + gap","                   for (const [depId, depAssignment] of asgn) {","                     const depEvent = eventMap.get(depId)!;","                     if (depEvent.prerequisites?.includes(conflict.eventId)) {"]},{"oldStart":462,"oldLines":18,"newStart":468,"newLines":13,"lines":["                   }"," ","                   if (valid) {","-                    // Place both events","+                    // Place both events (our event is already in the timeline)","                     asgn.set(eid, {","                       eventId: eid,","                       roomId: room.id,","                       startTime: slot,","                       endTime: slot + event.duration,","                     });","-                    insertInterv