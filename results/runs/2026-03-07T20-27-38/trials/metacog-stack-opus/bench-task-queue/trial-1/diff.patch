+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BfXLAjQe3huFaVc6BuD9Si","type":"tool_result","content":"The file /workspace/tests/TaskQueue.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"3ccc1ea1-daac-4bb2-8b68-95565e689b6d","uuid":"15e092c9-edf9-4356-816d-15fd7db211da","tool_use_result":{"filePath":"/workspace/tests/TaskQueue.test.ts","oldString":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from './TaskQueue.js';","newString":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueue } from '../src/TaskQueue.js';","originalFile":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from './TaskQueue.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ── Phase 1: Basic FIFO Queue ──────────────────────────────────────\n\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object with id, status, and createdAt', () => {\n      const task = tq.add({ message: 'hello' });\n      expect(task.id).toBeDefined();\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n      expect(task.payload).toEqual({ message: 'hello' });\n    });\n\n    it('should generate unique IDs', () => {\n      const t1 = tq.add('a');\n      const t2 = tq.add('b');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      tq.add('first');\n      tq.add('second');\n      tq.add('third');\n\n      const t1 = tq.take();\n      const t2 = tq.take();\n      const t3 = tq.take();\n\n      expect(t1?.payload).toBe('first');\n      expect(t2?.payload).toBe('second');\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should transition task to processing when taken', () => {\n      tq.add('work');\n      const task = tq.take();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      expect(tq.take()).toBeNull();\n    });\n\n    it('should track pending count with size()', () => {\n      expect(tq.size()).toBe(0);\n      tq.add('a');\n      tq.add('b');\n      expect(tq.size()).toBe(2);\n      tq.take();\n      expect(tq.size()).toBe(1);\n    });\n\n    it('should not return already-processing tasks', () => {\n      tq.add('work');\n      tq.take();\n      expect(tq.take()).toBeNull();\n    });\n  });\n\n  // ── Phase 2: Named Queues ──────────────────────────────────────────\n\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name given', () => {\n      tq.add('payload');\n      const task = tq.take();\n      expect(task?.queue).toBe('default');\n    });\n\n    it('should support named queues independently', () => {\n      tq.add('email', { queue: 'emails' });\n      tq.add('sms', { queue: 'sms' });\n\n      expect(tq.take('emails')?.payload).toBe('email');\n      expect(tq.take('sms')?.payload).toBe('sms');\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.take('nonexistent')).toBeNull();\n    });\n\n    it('should list queue names', () => {\n      tq.add('a', { queue: 'q1' });\n      tq.add('b', { queue: 'q2' });\n      const names = tq.getQueueNames();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n    });\n\n    it('queues are independent for size()', () => {\n      tq.add('a', { queue: 'q1' });\n      tq.add('b', { queue: 'q1' });\n      tq.add('c', { queue: 'q2' });\n\n      expect(tq.size('q1')).toBe(2);\n      expect(tq.size('q2')).toBe(1);\n    });\n  });\n\n  // ── Phase 3: Priority ─────────────────────────────────────────────\n\n  describe('Phase 3: Priority', () => {\n    it('should default to priority 5', () => {\n      const task = tq.add('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher-priority tasks first', () => {\n      tq.add('low', { priority: 10 });\n      tq.add('high', { priority: 1 });\n      tq.add('medium', { priority: 5 });\n\n      expect(tq.take()?.payload).toBe('high');\n      expect(tq.take()?.payload).toBe('medium');\n      expect(tq.take()?.payload).toBe('low');\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      tq.add('first', { priority: 3 });\n      tq.add('second', { priority: 3 });\n\n      expect(tq.take()?.payload).toBe('first');\n      expect(tq.take()?.payload).toBe('second');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => tq.add('test', { priority: 0 })).toThrow();\n      expect(() => tq.add('test', { priority: 11 })).toThrow();\n      expect(() => tq.add('test', { priority: 1.5 })).toThrow();\n    });\n\n    it('priority is per-queue', () => {\n      tq.add('q1-low', { queue: 'q1', priority: 10 });\n      tq.add('q1-high', { queue: 'q1', priority: 1 });\n      tq.add('q2-med', { queue: 'q2', priority: 5 });\n\n      expect(tq.take('q1')?.payload).toBe('q1-high');\n      expect(tq.take('q2')?.payload).toBe('q2-med');\n    });\n  });\n\n  // ── Phase 4: Delayed Tasks ────────────────────────────────────────\n\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their time', () => {\n      tq.add('delayed', { delay: 60000 }); // 1 minute in the future\n      expect(tq.take()).toBeNull();\n    });\n\n    it('should return delayed tasks after their time', () => {\n      tq.add('delayed', { delay: 0 }); // immediate\n      const task = tq.take();\n      expect(task?.payload).toBe('delayed');\n    });\n\n    it('should support processAt date', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.add('past', { processAt: past });\n      expect(tq.take()?.payload).toBe('past');\n\n      const future = new Date(Date.now() + 60000);\n      tq.add('future', { processAt: future });\n      expect(tq.take()).toBeNull();\n    });\n\n    it('non-delayed tasks preferred over not-yet-available delayed tasks', () => {\n      tq.add('delayed', { delay: 60000 });\n      tq.add('immediate');\n\n      const task = tq.take();\n      expect(task?.payload).toBe('immediate');\n    });\n\n    it('task should indicate availability time', () => {\n      const task = tq.add('test', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n  });\n\n  // ── Phase 5: Retry with Backoff ───────────────────────────────────\n\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      tq.add('work');\n      const task = tq.take()!;\n      tq.complete(task.id);\n      expect(task.status).toBe('completed');\n    });\n\n    it('should fail and re-enqueue with retry', () => {\n      tq.add('work', { maxRetries: 3, backoffDelay: 100 });\n      const task = tq.take()!;\n      expect(task.attempts).toBe(1);\n\n      tq.fail(task.id, 'oops');\n      expect(task.status).toBe('pending');\n      expect(task.attempts).toBe(1); // attempts stays at 1, was attempted once\n    });\n\n    it('should exhaust retries and move to failed', () => {\n      const task = tq.add('work', { maxRetries: 1, backoffDelay: 0 });\n\n      // Attempt 1\n      const t1 = tq.take()!;\n      expect(t1.id).toBe(task.id);\n      tq.fail(t1.id, 'error');\n      expect(t1.status).toBe('failed');\n    });\n\n    it('should track attempt count', () => {\n      tq.add('work', { maxRetries: 3, backoffDelay: 0 });\n      const t1 = tq.take()!;\n      expect(t1.attempts).toBe(1);\n      tq.fail(t1.id, 'err');\n\n      // Task is re-queued but delayed. Set availableAt to now for testing.\n      t1.availableAt = new Date();\n      const t2 = tq.take()!;\n      expect(t2.attempts).toBe(2);\n    });\n\n    it('should apply exponential backoff delay', () => {\n      tq.add('work', { maxRetries: 3, backoffDelay: 1000 });\n      const task = tq.take()!;\n\n      const beforeFail = Date.now();\n      tq.fail(task.id, 'err');\n      // First retry: 1000 * 2^0 = 1000ms delay\n      expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(beforeFail + 900);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      tq.add('work', { queue: 'myqueue', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      const task = tq.take('myqueue')!;\n      tq.fail(task.id, 'err');\n      expect(task.queue).toBe('myqueue');\n      expect(task.priority).toBe(2);\n    });\n\n    it('should error when completing non-processing task', () => {\n      const task = tq.add('work');\n      expect(() => tq.complete(task.id)).toThrow();\n    });\n\n    it('should default maxRetries to 3', () => {\n      const task = tq.add('work');\n      expect(task.maxRetries).toBe(3);\n    });\n  });\n\n  // ── Phase 6: Dead Letter Queue ────────────────────────────────────\n\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move exhausted tasks to DLQ', () => {\n      tq.add('work', { maxRetries: 1, backoffDelay: 0 });\n      const task = tq.take()!;\n      tq.fail(task.id, 'final error');\n\n      const dlq = tq.getDeadLetterQueue();\n      expect(dlq).toHaveLength(1);\n      expect(dlq[0].id).toBe(task.id);\n      expect(dlq[0].error).toBe('final error');\n    });\n\n    it('should support per-queue DLQs', () => {\n      tq.add('a', { queue: 'q1', maxRetries: 1 });\n      tq.add('b', { queue: 'q2', maxRetries: 1 });\n\n      const t1 = tq.take('q1')!;\n      tq.fail(t1.id, 'err');\n      const t2 = tq.take('q2')!;\n      tq.fail(t2.id, 'err');\n\n      expect(tq.getDeadLetterQueue('q1')).toHaveLength(1);\n      expect(tq.getDeadLetterQueue('q2')).toHaveLength(1);\n    });\n\n    it('should retry dead-lettered task', () => {\n      tq.add('work', { maxRetries: 1 });\n      const task = tq.take()!;\n      tq.fail(task.id, 'err');\n\n      const retried = tq.retryDeadLetter(task.id);\n      expect(retried).not.toBeNull();\n      expect(retried!.status).toBe('pending');\n      expect(retried!.attempts).toBe(0);\n      expect(tq.getDeadLetterQueue()).toHaveLength(0);\n    });\n\n    it('should clear DLQ', () => {\n      tq.add('work', { maxRetries: 1 });\n      const task = tq.take()!;\n      tq.fail(task.id, 'err');\n\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterQueue()).toHaveLength(0);\n    });\n  });\n\n  // ── Phase 7: Task Dependencies ────────────────────────────────────\n\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.add('dependency');\n      tq.add('dependent', { dependencies: [dep.id] });\n\n      // Should only return the dependency, not the dependent\n      const t1 = tq.take()!;\n      expect(t1.id).toBe(dep.id);\n      expect(tq.take()).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.add('dependency');\n      const dependent = tq.add('dependent', { dependencies: [dep.id] });\n\n      const t1 = tq.take()!;\n      tq.complete(t1.id);\n\n      const t2 = tq.take()!;\n      expect(t2.id).toBe(dependent.id);\n    });\n\n    it('should reject non-existent dependencies', () => {\n      expect(() => tq.add('test', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should detect circular dependencies', () => {\n      const t1 = tq.add('first');\n      // t1 has no deps, so we can't create a direct cycle easily.\n      // But we can test indirect cycles:\n      const t2 = tq.add('second', { dependencies: [t1.id] });\n      // t3 depends on t2, which depends on t1\n      const t3 = tq.add('third', { dependencies: [t2.id] });\n      // This is fine - no cycle. Just a chain.\n      expect(t3.dependencies).toContain(t2.id);\n    });\n\n    it('should provide dependency status', () => {\n      const dep1 = tq.add('dep1');\n      const dep2 = tq.add('dep2');\n      const task = tq.add('work', { dependencies: [dep1.id, dep2.id] });\n\n      const t1 = tq.take()!;\n      tq.complete(t1.id);\n\n      const status = tq.getDependencyStatus(task.id);\n      expect(status).not.toBeNull();\n      expect(status!.resolved).toContain(dep1.id);\n      expect(status!.pending).toContain(dep2.id);\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const dep = tq.add('dep', { maxRetries: 1 });\n      tq.add('dependent', { dependencies: [dep.id] });\n\n      const t = tq.take()!;\n      tq.fail(t.id, 'error');\n\n      expect(tq.take()).toBeNull();\n    });\n  });\n\n  // ── Phase 8: Concurrency Control ──────────────────────────────────\n\n  describe('Phase 8: Concurrency Control', () => {\n    it('should default to unlimited concurrency', () => {\n      const info = tq.getConcurrency();\n      expect(info.limit).toBeNull();\n      expect(info.active).toBe(0);\n    });\n\n    it('should limit concurrent processing', () => {\n      tq.setConcurrency('default', 2);\n      tq.add('a');\n      tq.add('b');\n      tq.add('c');\n\n      const t1 = tq.take()!;\n      const t2 = tq.take()!;\n      expect(t1).not.toBeNull();\n      expect(t2).not.toBeNull();\n      expect(tq.take()).toBeNull(); // 3rd blocked by concurrency\n\n      tq.complete(t1.id);\n      expect(tq.take()?.payload).toBe('c'); // Now space available\n    });\n\n    it('should track active count', () => {\n      tq.setConcurrency('default', 5);\n      tq.add('a');\n      tq.add('b');\n\n      tq.take();\n      expect(tq.getConcurrency().active).toBe(1);\n      tq.take();\n      expect(tq.getConcurrency().active).toBe(2);\n    });\n\n    it('failing a task frees concurrency slot', () => {\n      tq.setConcurrency('default', 1);\n      tq.add('a', { maxRetries: 1 });\n      tq.add('b');\n\n      const t1 = tq.take()!;\n      expect(tq.take()).toBeNull(); // blocked by concurrency\n\n      tq.fail(t1.id, 'err'); // Moves to DLQ, frees slot\n      expect(tq.take()?.payload).toBe('b');\n    });\n  });\n\n  // ── Phase 9: Progress Tracking and Cancellation ───────────────────\n\n  describe('Phase 9: Progress Tracking and Cancellation', () => {\n    it('should report and query progress', () => {\n      tq.add('work');\n      const task = tq.take()!;\n\n      tq.reportProgress(task.id, 50, 'halfway');\n      expect(task.progress).toBe(50);\n      expect(task.progressMessage).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      tq.add('work');\n      const task = tq.take()!;\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      tq.reportProgress(task.id, 25, 'quarter');\n      tq.reportProgress(task.id, 75, 'three quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n      expect(updates[1]).toEqual({ progress: 75, message: 'three quarters' });\n    });\n\n    it('should allow unsubscribing from progress', () => {\n      tq.add('work');\n      const task = tq.take()!;\n      let count = 0;\n\n      const unsub = tq.onProgress(task.id, () => count++);\n      tq.reportProgress(task.id, 25);\n      unsub();\n      tq.reportProgress(task.id, 50);\n\n      expect(count).toBe(1);\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = tq.add('work');\n      expect(tq.cancel(task.id)).toBe(true);\n      expect(task.status).toBe('cancelled');\n      expect(tq.take()).toBeNull();\n    });\n\n    it('should cancel processing tasks', () => {\n      tq.add('work');\n      const task = tq.take()!;\n      expect(tq.cancel(task.id)).toBe(true);\n      expect(task.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      tq.add('work', { maxRetries: 3 });\n      const task = tq.take()!;\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      // Task should not re-appear\n      expect(tq.take()).toBeNull();\n    });\n\n    it('should reject invalid progress values', () => {\n      tq.add('work');\n      const task = tq.take()!;\n      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('cannot cancel completed tasks', () => {\n      tq.add('work');\n      const task = tq.take()!;\n      tq.complete(task.id);\n      expect(tq.cancel(task.id)).toBe(false);\n    });\n  });\n\n  // ── Phase 10: Recurring Tasks ──────────────────────────────────────\n\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(schedule.id).toBe('s1');\n      expect(schedule.cron).toBe('*/5 * * * *');\n    });\n\n    it('should list schedules', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', {});\n      tq.addSchedule('s2', '0 * * * *', 'emails', {});\n      expect(tq.getSchedules()).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', {});\n      expect(tq.removeSchedule('s1')).toBe(true);\n      expect(tq.getSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue task on tick when schedule matches', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', { type: 'job' });\n\n      // Tick at a time that matches */5 (minute divisible by 5)\n      const matchTime = new Date('2025-01-01T10:00:00');\n      const tasks = tq.tick(matchTime);\n\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'job' });\n    });\n\n    it('should not enqueue when cron does not match', () => {\n      tq.addSchedule('s1', '0 0 * * *', 'default', {}); // midnight only\n\n      const nonMidnight = new Date('2025-01-01T10:30:00');\n      const tasks = tq.tick(nonMidnight);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not duplicate within same minute', () => {\n      tq.addSchedule('s1', '*/5 * * * *', 'default', {});\n\n      const time = new Date('2025-01-01T10:00:00');\n      tq.tick(time);\n      const tasks2 = tq.tick(time);\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should validate cron expressions', () => {\n      expect(() => tq.addSchedule('bad', 'invalid', 'default', {})).toThrow();\n    });\n  });\n\n  // ── Phase 11: Middleware Pipeline ──────────────────────────────────\n\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run processor on tasks', async () => {\n      const results: string[] = [];\n      tq.setProcessor('default', (task) => {\n        results.push(task.payload as string);\n      });\n      tq.add('hello');\n\n      await tq.process();\n      expect(results).toEqual(['hello']);\n    });\n\n    it('should run middleware before processor', async () => {\n      const order: string[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push('middleware1');\n        await next();\n      });\n\n      tq.use('default', async (_task, next) => {\n        order.push('middleware2');\n        await next();\n      });\n\n      tq.setProcessor('default', () => {\n        order.push('processor');\n      });\n\n      tq.add('work');\n      await tq.process();\n\n      expect(order).toEqual(['middleware1', 'middleware2', 'processor']);\n    });\n\n    it('middleware can skip processing by not calling next', async () => {\n      const processed: string[] = [];\n\n      tq.use('default', async (_task, _next) => {\n        // Don't call next - skip processing\n      });\n\n      tq.setProcessor('default', (task) => {\n        processed.push(task.payload as string);\n      });\n\n      tq.add('work');\n      const task = await tq.process();\n\n      expect(processed).toHaveLength(0);\n      // Task should still complete since middleware ran without error\n      expect(task?.status).toBe('completed');\n    });\n\n    it('middleware error should fail the task', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware boom');\n      });\n\n      tq.add('work', { maxRetries: 1 });\n      const task = await tq.process();\n\n      expect(task?.status).toBe('failed');\n      expect(task?.error).toBe('middleware boom');\n    });\n\n    it('middleware can modify task', async () => {\n      tq.use('default', async (task, next) => {\n        (task as Record<string, unknown>).metadata = 'added by middleware';\n        await next();\n      });\n\n      let receivedTask: Record<string, unknown> | null = null;\n      tq.setProcessor('default', (task) => {\n        receivedTask = task as Record<string, unknown>;\n      });\n\n      tq.add('work');\n      await tq.process();\n\n      expect(receivedTask).not.toBeNull();\n      expect(receivedTask!.metadata).toBe('added by middleware');\n    });\n\n    it('each queue has independent middleware', async () => {\n      const q1Results: string[] = [];\n      const q2Results: string[] = [];\n\n      tq.use('q1', async (task, next) => {\n        q1Results.push(task.payload as string);\n        await next();\n      });\n\n      tq.use('q2', async (task, next) => {\n        q2Results.push(task.payload as string);\n        await next();\n      });\n\n      tq.add('a', { queue: 'q1' });\n      tq.add('b', { queue: 'q2' });\n\n      await tq.process('q1');\n      await tq.process('q2');\n\n      expect(q1Results).toEqual(['a']);\n      expect(q2Results).toEqual(['b']);\n    });\n  });\n\n  // ── Phase 12: Graceful Shutdown ────────────────────────────────────\n\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.add('work')).toThrow('shutting down');\n    });\n\n    it('should complete immediately with no processing tasks', async () => {\n      const result = await tq.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks', async () => {\n      tq.add('work');\n      const task = tq.take()!;\n\n      // Complete the task asynchronously\n      setTimeout(() => tq.complete(task.id), 50);\n\n      const result = await tq.shutdown(5000);\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force-cancel on timeout', async () => {\n      tq.add('long-work');\n      tq.take()!; // Now processing, never completed\n\n      const result = await tq.shutdown(100);\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should be idempotent', async () => {\n      const r1 = await tq.shutdown();\n      const r2 = await tq.shutdown();\n      expect(r1).toBe(r2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let called = false;\n      tq.onShutdown(() => {\n        called = true;\n      });\n\n      await tq.shutdown();\n      expect(called).toBe(true);\n    });\n\n    it('should report shutdown duration', async () => {\n      const result = await tq.shutdown();\n      expect(typeof result.durationMs).toBe('number');\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n  });\n\n  // ── Integration Tests ─────────────────────────────────────────────\n\n  describe('Integration', () => {\n    it('priority + delay interaction', () => {\n      const past = new Date(Date.now() - 1000);\n      tq.add('high-delayed', { priority: 1, processAt: past });\n      tq.add('low-immediate', { priority: 10 });\n\n      // High priority should come first even though it was delayed\n      expect(tq.take()?.payload).toBe('high-delayed');\n      expect(tq.take()?.payload).toBe('low-immediate');\n    });\n\n    it('retry preserves queue and priority', () => {\n      tq.add('work', { queue: 'special', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      const task = tq.take('special')!;\n      tq.fail(task.id, 'err');\n\n      expect(task.queue).toBe('special');\n      expect(task.priority).toBe(2);\n      expect(task.status).toBe('pending');\n    });\n\n    it('dependencies + priority: blocked tasks skipped', () => {\n      const dep = tq.add('dep', { priority: 10 });\n      tq.add('dependent', { priority: 1, dependencies: [dep.id] });\n      tq.add('independent', { priority: 5 });\n\n      // Even though 'dependent' has highest priority, it's blocked\n      // dep (priority 10) vs independent (priority 5) - independent wins\n      const first = tq.take()!;\n      expect(first.payload).toBe('independent');\n    });\n\n    it('concurrency + priority interaction', () => {\n      tq.setConcurrency('default', 1);\n      tq.add('high', { priority: 1 });\n      tq.add('low', { priority: 10 });\n\n      const t1 = tq.take()!;\n      expect(t1.payload).toBe('high');\n      expect(tq.take()).toBeNull(); // blocked by concurrency\n\n      tq.complete(t1.id);\n      expect(tq.take()?.payload).toBe('low');\n    });\n\n    it('getTask retrieves any task by ID', () => {\n      const task = tq.add('hello');\n      const found = tq.getTask(task.id);\n      expect(found).not.toBeNull();\n      expect(found!.payload).toBe('hello');\n    });\n\n    it('getTask returns null for unknown ID', () => {\n      expect(tq.getTask('nonexistent')).toBeNull();\n    });\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":5,"newStart":1,"newLines":5,"lines":["-import { describe, it, expect, beforeEach, vi } from 'vitest';","-import { TaskQueue } from './TaskQueue.js';","+import { describe, it, expect, beforeEach } from 'vitest';","+import { TaskQueue } from '../src/TaskQueue.js';"," "," describe('TaskQueue', () => {","   let tq: TaskQueue;"]}],"userModified":false,"replaceAll":false}}
