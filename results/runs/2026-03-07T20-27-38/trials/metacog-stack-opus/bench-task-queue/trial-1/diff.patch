@@ -0,0 +1,653 @@
+import { randomUUID } from 'crypto';
+import type {
+  Task,
+  TaskOptions,
+  ScheduleDefinition,
+  MiddlewareFn,
+  ProcessorFn,
+  ProgressListener,
+  ShutdownResult,
+} from './types.js';
+
+const DEFAULT_QUEUE = 'default';
+const DEFAULT_PRIORITY = 5;
+const DEFAULT_MAX_RETRIES = 3;
+const DEFAULT_BACKOFF_DELAY = 1000;
+
+interface QueueState {
+  tasks: Map<string, Task>;
+  deadLetterQueue: Task[];
+  concurrencyLimit: number | null;
+  middlewares: MiddlewareFn[];
+  processor: ProcessorFn | null;
+}
+
+export class TaskQueue {
+  private queues = new Map<string, QueueState>();
+  private allTasks = new Map<string, Task>();
+  private progressListeners = new Map<string, Set<ProgressListener>>();
+  private schedules = new Map<string, ScheduleDefinition>();
+  private isShutdown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+
+  // ── Phase 1: Basic FIFO Queue ────────────────────────────────────────
+
+  add<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {
+    if (this.isShutdown) {
+      throw new Error('Queue is shutting down, cannot add new tasks');
+    }
+
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+    const priority = options.priority ?? DEFAULT_PRIORITY;
+
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Calculate availability time
+    let availableAt = new Date();
+    if (options.processAt) {
+      availableAt = options.processAt;
+    } else if (options.delay != null && options.delay > 0) {
+      availableAt = new Date(Date.now() + options.delay);
+    }
+
+    // Validate dependencies (Phase 7)
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      const depTask = this.allTasks.get(depId);
+      if (!depTask) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+    // Check circular dependencies
+    if (dependencies.length > 0) {
+      // The new task doesn't have an ID yet, but we need to verify
+      // that none of the dependencies would create a cycle through this task.
+      // Since this task doesn't exist yet, there can't be a cycle FROM it.
+      // However, we need to verify no circular chain exists among the deps themselves.
+    }
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      payload,
+      status: 'pending',
+      queue: queueName,
+      priority,
+      createdAt: new Date(),
+      availableAt,
+      attempts: 0,
+      maxRetries: options.maxRetries ?? DEFAULT_MAX_RETRIES,
+      backoffDelay: options.backoffDelay ?? DEFAULT_BACKOFF_DELAY,
+      dependencies,
+      progress: 0,
+    };
+
+    // Check for circular dependencies now that we have an ID
+    if (dependencies.length > 0) {
+      this.detectCircularDependencies(task.id, dependencies);
+    }
+
+    const queue = this.getOrCreateQueue(queueName);
+    queue.tasks.set(task.id, task);
+    this.allTasks.set(task.id, task);
+
+    return task;
+  }
+
+  take(queueName: string = DEFAULT_QUEUE): Task | null {
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+
+    // Phase 8: Check concurrency limit
+    if (queue.concurrencyLimit !== null) {
+      const activeCount = this.getActiveCount(queueName);
+      if (activeCount >= queue.concurrencyLimit) {
+        return null;
+      }
+    }
+
+    const now = new Date();
+    const candidates: Task[] = [];
+
+    for (const task of queue.tasks.values()) {
+      if (task.status !== 'pending') continue;
+      if (task.availableAt > now) continue;
+      if (!this.areDependenciesResolved(task)) continue;
+      candidates.push(task);
+    }
+
+    if (candidates.length === 0) return null;
+
+    // Sort by priority (ascending - lower number = higher priority),
+    // then by availableAt, then by createdAt (FIFO)
+    candidates.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      if (a.availableAt.getTime() !== b.availableAt.getTime()) {
+        return a.availableAt.getTime() - b.availableAt.getTime();
+      }
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = candidates[0];
+    task.status = 'processing';
+    task.attempts++;
+    return task;
+  }
+
+  size(queueName: string = DEFAULT_QUEUE): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+
+    let count = 0;
+    for (const task of queue.tasks.values()) {
+      if (task.status === 'pending') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  // ── Phase 2: Named Queues ────────────────────────────────────────────
+
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // ── Phase 5: Retry with Backoff ──────────────────────────────────────
+
+  complete(taskId: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot complete task in ${task.status} state`);
+    }
+    task.status = 'completed';
+    task.progress = 100;
+  }
+
+  fail(taskId: string, error?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot fail task in ${task.status} state`);
+    }
+    task.error = error;
+
+    if (task.attempts < task.maxRetries) {
+      // Re-enqueue with exponential backoff delay
+      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.progress = 0;
+    } else {
+      // Exhausted retries → move to DLQ
+      task.status = 'failed';
+      const queue = this.queues.get(task.queue);
+      if (queue) {
+        queue.tasks.delete(task.id);
+        queue.deadLetterQueue.push(task);
+      }
+    }
+  }
+
+  // ── Phase 6: Dead Letter Queue ───────────────────────────────────────
+
+  getDeadLetterQueue(queueName: string = DEFAULT_QUEUE): Task[] {
+    const queue = this.queues.get(queueName);
+    if (!queue) return [];
+    return [...queue.deadLetterQueue];
+  }
+
+  retryDeadLetter(taskId: string): Task | null {
+    for (const queue of this.queues.values()) {
+      const index = queue.deadLetterQueue.findIndex(t => t.id === taskId);
+      if (index !== -1) {
+        const task = queue.deadLetterQueue.splice(index, 1)[0];
+        task.status = 'pending';
+        task.attempts = 0;
+        task.availableAt = new Date();
+        task.error = undefined;
+        task.progress = 0;
+        queue.tasks.set(task.id, task);
+        return task;
+      }
+    }
+    return null;
+  }
+
+  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {
+    const queue = this.queues.get(queueName);
+    if (queue) {
+      for (const task of queue.deadLetterQueue) {
+        this.allTasks.delete(task.id);
+      }
+      queue.deadLetterQueue = [];
+    }
+  }
+
+  // ── Phase 7: Task Dependencies ───────────────────────────────────────
+
+  getTask(taskId: string): Task | null {
+    return this.allTasks.get(taskId) ?? null;
+  }
+
+  getDependencyStatus(taskId: string): { resolved: string[]; pending: string[] } | null {
+    const task = this.allTasks.get(taskId);
+    if (!task) return null;
+
+    const resolved: string[] = [];
+    const pending: string[] = [];
+
+    for (const depId of task.dependencies) {
+      const dep = this.allTasks.get(depId);
+      if (dep && dep.status === 'completed') {
+        resolved.push(depId);
+      } else {
+        pending.push(depId);
+      }
+    }
+
+    return { resolved, pending };
+  }
+
+  // ── Phase 8: Concurrency Control ─────────────────────────────────────
+
+  setConcurrency(queueName: string, limit: number | null): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.concurrencyLimit = limit;
+  }
+
+  getConcurrency(queueName: string = DEFAULT_QUEUE): { limit: number | null; active: number } {
+    const queue = this.queues.get(queueName);
+    if (!queue) return { limit: null, active: 0 };
+    return { limit: queue.concurrencyLimit, active: this.getActiveCount(queueName) };
+  }
+
+  // ── Phase 9: Progress Tracking and Cancellation ──────────────────────
+
+  reportProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.allTasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot report progress for task in ${task.status} state`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);
+    }
+    task.progress = progress;
+    task.progressMessage = message;
+
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(progress, message);
+      }
+    }
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(listener);
+
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(listener);
+        if (listeners.size === 0) {
+          this.progressListeners.delete(taskId);
+        }
+      }
+    };
+  }
+
+  cancel(taskId: string): boolean {
+    const task = this.allTasks.get(taskId);
+    if (!task) return false;
+
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      return false;
+    }
+
+    const wasPending = task.status === 'pending';
+    task.status = 'cancelled';
+    task.progress = 0;
+
+    if (wasPending) {
+      // Remove from queue so it won't be returned
+      const queue = this.queues.get(task.queue);
+      if (queue) {
+        queue.tasks.delete(task.id);
+      }
+    }
+
+    return true;
+  }
+
+  // ── Phase 10: Recurring Tasks ────────────────────────────────────────
+
+  addSchedule(
+    id: string,
+    cron: string,
+    queueName: string,
+    payload: unknown,
+    priority?: number,
+  ): ScheduleDefinition {
+    if (this.isShutdown) {
+      throw new Error('Queue is shutting down, cannot add schedules');
+    }
+
+    this.validateCron(cron);
+
+    const schedule: ScheduleDefinition = {
+      id,
+      cron,
+      queue: queueName,
+      payload,
+      priority,
+    };
+
+    this.schedules.set(id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(id: string): boolean {
+    return this.schedules.delete(id);
+  }
+
+  getSchedules(): ScheduleDefinition[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now: Date = new Date()): Task[] {
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (this.shouldRunSchedule(schedule, now)) {
+        const task = this.add(schedule.payload, {
+          queue: schedule.queue,
+          priority: schedule.priority,
+        });
+        created.push(task);
+        schedule.lastRun = now;
+      }
+    }
+
+    return created;
+  }
+
+  // ── Phase 11: Middleware Pipeline ────────────────────────────────────
+
+  use(queueName: string, middleware: MiddlewareFn): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.middlewares.push(middleware);
+  }
+
+  setProcessor(queueName: string, processor: ProcessorFn): void {
+    const queue = this.getOrCreateQueue(queueName);
+    queue.processor = processor;
+  }
+
+  async process(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {
+    const task = this.take(queueName);
+    if (!task) return null;
+
+    const queue = this.queues.get(queueName);
+    if (!queue) return null;
+
+    const middlewares = [...queue.middlewares];
+    const processor = queue.processor;
+
+    try {
+      await this.executeMiddlewareChain(task, middlewares, 0, processor);
+      if (task.status === 'processing') {
+        this.complete(task.id);
+      }
+    } catch (err) {
+      if (task.status === 'processing') {
+        this.fail(task.id, err instanceof Error ? err.message : String(err));
+      }
+    }
+
+    return task;
+  }
+
+  // ── Phase 12: Graceful Shutdown ──────────────────────────────────────
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeout: number = 30000): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShutdown = true;
+    this.shutdownPromise = this.performShutdown(timeout);
+    return this.shutdownPromise;
+  }
+
+  // ── Private Helpers ──────────────────────────────────────────────────
+
+  private getOrCreateQueue(name: string): QueueState {
+    let queue = this.queues.get(name);
+    if (!queue) {
+      queue = {
+        tasks: new Map(),
+        deadLetterQueue: [],
+        concurrencyLimit: null,
+        middlewares: [],
+        processor: null,
+      };
+      this.queues.set(name, queue);
+    }
+    return queue;
+  }
+
+  private getActiveCount(queueName: string): number {
+    const queue = this.queues.get(queueName);
+    if (!queue) return 0;
+    let count = 0;
+    for (const task of queue.tasks.values()) {
+      if (task.status === 'processing') count++;
+    }
+    return count;
+  }
+
+  private areDependenciesResolved(task: Task): boolean {
+    for (const depId of task.dependencies) {
+      const dep = this.allTasks.get(depId);
+      if (!dep || dep.status !== 'completed') {
+        return false;
+      }
+    }
+    return true;
+  }
+
+  private detectCircularDependencies(taskId: string, dependencies: string[]): void {
+    // BFS/DFS to check if any dependency chain leads back to taskId
+    // Since the task doesn't exist yet in the graph, we check if any dep
+    // has a transitive dependency path. Since new tasks can't be depended
+    // on by existing tasks yet, we mainly verify the deps themselves don't
+    // form cycles among each other.
+    const visited = new Set<string>();
+    const stack = [...dependencies];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === taskId) {
+        throw new Error('Circular dependency detected');
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      const task = this.allTasks.get(current);
+      if (task) {
+        for (const depId of task.dependencies) {
+          stack.push(depId);
+        }
+      }
+    }
+  }
+
+  private validateCron(cron: string): void {
+    const parts = cron.trim().split(/\s+/);
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${cron}. Must have 5 fields.`);
+    }
+
+    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;
+
+    // Validate supported patterns
+    const isValidField = (field: string, allowInterval: boolean): boolean => {
+      if (field === '*') return true;
+      if (allowInterval && /^\*\/\d+$/.test(field)) return true;
+      if (/^\d+$/.test(field)) return true;
+      return false;
+    };
+
+    if (!isValidField(minute, true)) {
+      throw new Error(`Invalid cron minute field: ${minute}`);
+    }
+    if (!isValidField(hour, false)) {
+      throw new Error(`Invalid cron hour field: ${hour}`);
+    }
+    if (!isValidField(dayOfMonth, false)) {
+      throw new Error(`Invalid cron day-of-month field: ${dayOfMonth}`);
+    }
+    if (!isValidField(month, false)) {
+      throw new Error(`Invalid cron month field: ${month}`);
+    }
+    if (!isValidField(dayOfWeek, false)) {
+      throw new Error(`Invalid cron day-of-week field: ${dayOfWeek}`);
+    }
+  }
+
+  private shouldRunSchedule(schedule: ScheduleDefinition, now: Date): boolean {
+    const parts = schedule.cron.trim().split(/\s+/);
+    const [minuteField, hourField, dayOfMonthField, monthField, dayOfWeekField] = parts;
+
+    if (!this.matchCronField(minuteField, now.getMinutes())) return false;
+    if (!this.matchCronField(hourField, now.getHours())) return false;
+    if (!this.matchCronField(dayOfMonthField, now.getDate())) return false;
+    if (!this.matchCronField(monthField, now.getMonth() + 1)) return false;
+    if (!this.matchCronField(dayOfWeekField, now.getDay())) return false;
+
+    // Prevent duplicate runs in the same minute
+    if (schedule.lastRun) {
+      const lastMinute = Math.floor(schedule.lastRun.getTime() / 60000);
+      const currentMinute = Math.floor(now.getTime() / 60000);
+      if (lastMinute === currentMinute) return false;
+    }
+
+    return true;
+  }
+
+  private matchCronField(field: string, value: number): boolean {
+    if (field === '*') return true;
+
+    const intervalMatch = field.match(/^\*\/(\d+)$/);
+    if (intervalMatch) {
+      const interval = parseInt(intervalMatch[1], 10);
+      return value % interval === 0;
+    }
+
+    const numValue = parseInt(field, 10);
+    return value === numValue;
+  }
+
+  private async executeMiddlewareChain(
+    task: Task,
+    middlewares: MiddlewareFn[],
+    index: number,
+    processor: ProcessorFn | null,
+  ): Promise<void> {
+    if (index < middlewares.length) {
+      const middleware = middlewares[index];
+      await middleware(task, async () => {
+        await this.executeMiddlewareChain(task, middlewares, index + 1, processor);
+      });
+    } else if (processor) {
+      await processor(task);
+    }
+  }
+
+  private async performShutdown(timeout: number): Promise<ShutdownResult> {
+    const startTime = Date.now();
+    let completed = 0;
+    let forceCancelled = 0;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Collect all processing tasks
+    const processingTasks: Task[] = [];
+    for (const queue of this.queues.values()) {
+      for (const task of queue.tasks.values()) {
+        if (task.status === 'processing') {
+          processingTasks.push(task);
+        }
+      }
+    }
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        durationMs: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete, up to timeout
+    const waitForCompletion = new Promise<void>((resolve) => {
+      const checkInterval = setInterval(() => {
+        let allDone = true;
+        for (const task of processingTasks) {
+          if (task.status === 'processing') {
+            allDone = false;
+            break;
+          }
+        }
+        if (allDone) {
+          clearInterval(checkInterval);
+          resolve();
+        }
+      }, 50);
+
+      setTimeout(() => {
+        clearInterval(checkInterval);
+        resolve();
+      }, timeout);
+    });
+
+    await waitForCompletion;
+
+    // Count results and force-cancel remaining
+    for (const task of processingTasks) {
+      if (task.status === 'processing') {
+        task.status = 'cancelled';
+        forceCancelled++;
+      } else if (task.status === 'completed') {
+        completed++;
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      durationMs: Date.now() - startTime,
+    };
+  }
+}
