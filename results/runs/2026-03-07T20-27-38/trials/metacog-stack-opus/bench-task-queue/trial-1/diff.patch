+      expect(q2Results).toEqual(['b']);
+    });
+  });
+
+  // ── Phase 12: Graceful Shutdown ────────────────────────────────────
+
+  describe('Phase 12: Graceful Shutdown', () => {
+    it('should reject new tasks after shutdown', async () => {
+      await tq.shutdown();
+      expect(() => tq.add('work')).toThrow('shutting down');
+    });
+
+    it('should complete immediately with no processing tasks', async () => {
+      const result = await tq.shutdown();
+      expect(result.completed).toBe(0);
+      expect(result.forceCancelled).toBe(0);
+      expect(result.durationMs).toBeGreaterThanOrEqual(0);
+    });
+
+    it('should wait for processing tasks', async () => {
+      tq.add('work');
+      const task = tq.take()!;
+
+      // Complete the task asynchronously
+      setTimeout(() => tq.complete(task.id), 50);
+
+      const result = await tq.shutdown(5000);
+      expect(result.completed).toBe(1);
+      expect(result.forceCancelled).toBe(0);
+    });
+
+    it('should force-cancel on timeout', async () => {
+      tq.add('long-work');
+      tq.take()!; // Now processing, never completed
+
+      const result = await tq.shutdown(100);
+      expect(result.forceCancelled).toBe(1);
+    });
+
+    it('should be idempotent', async () => {
+      const r1 = await tq.shutdown();
+      const r2 = await tq.shutdown();
+      expect(r1).toBe(r2);
+    });
+
+    it('should run shutdown callbacks', async () => {
+      let called = false;
+      tq.onShutdown(() => {
+        called = true;
+      });
+
+      await tq.shutdown();
+      expect(called).toBe(true);
+    });
+
+    it('should report shutdown duration', async () => {
+      const result = await tq.shutdown();
+      expect(typeof result.durationMs).toBe('number');
+      expect(result.durationMs).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  // ── Integration Tests ─────────────────────────────────────────────
+
+  describe('Integration', () => {
+    it('priority + delay interaction', () => {
+      const past = new Date(Date.now() - 1000);
+      tq.add('high-delayed', { priority: 1, processAt: past });
+      tq.add('low-immediate', { priority: 10 });
+
+      // High priority should come first even though it was delayed
+      expect(tq.take()?.payload).toBe('high-delayed');
+      expect(tq.take()?.payload).toBe('low-immediate');
+    });
+
+    it('retry preserves queue and priority', () => {
+      tq.add('work', { queue: 'special', priority: 2, maxRetries: 3, backoffDelay: 0 });
+      const task = tq.take('special')!;
+      tq.fail(task.id, 'err');
+
+      expect(task.queue).toBe('special');
+      expect(task.priority).toBe(2);
+      expect(task.status).toBe('pending');
+    });
+
+    it('dependencies + priority: blocked tasks skipped', () => {
+      const dep = tq.add('dep', { priority: 10 });
+      tq.add('dependent', { priority: 1, dependencies: [dep.id] });
+      tq.add('independent', { priority: 5 });
+
+      // Even though 'dependent' has highest priority, it's blocked
+      // dep (priority 10) vs independent (priority 5) - independent wins
+      const first = tq.take()!;
+      expect(first.payload).toBe('independent');
+    });
+
+    it('concurrency + priority interaction', () => {
+      tq.setConcurrency('default', 1);
+      tq.add('high', { priority: 1 });
+      tq.add('low', { priority: 10 });
+
+      const t1 = tq.take()!;
+      expect(t1.payload).toBe('high');
+      expect(tq.take()).toBeNull(); // blocked by concurrency
+
+      tq.complete(t1.id);
+      expect(tq.take()?.payload).toBe('low');
+    });
+
+    it('getTask retrieves any task by ID', () => {
+      const task = tq.add('hello');
+      const found = tq.getTask(task.id);
+      expect(found).not.toBeNull();
+      expect(found!.payload).toBe('hello');
+    });
+
+    it('getTask returns null for unknown ID', () => {
+      expect(tq.getTask('nonexistent')).toBeNull();
+    });
+  });
+});
