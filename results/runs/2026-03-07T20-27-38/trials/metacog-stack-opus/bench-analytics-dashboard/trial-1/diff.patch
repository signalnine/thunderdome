+import { Router, Response } from "express";
+import { v4 as uuidv4 } from "uuid";
+import { getDb } from "../db.js";
+import { authMiddleware, AuthenticatedRequest } from "../middleware.js";
+
+const router = Router();
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+// List dashboards for tenant
+router.get("/", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+  const db = getDb();
+  const dashboards = db
+    .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+    .all(req.user!.tenantId) as DashboardRow[];
+
+  res.json({
+    dashboards: dashboards.map((d) => ({
+      id: d.id,
+      name: d.name,
+      ownerId: d.owner_id,
+      config: JSON.parse(d.config),
+      createdAt: d.created_at,
+      updatedAt: d.updated_at,
+    })),
+  });
+});
+
+// Create a dashboard
+router.post("/", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+  const { name, config } = req.body;
+
+  if (!name) {
+    res.status(400).json({ error: "Dashboard name is required" });
+    return;
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const now = new Date().toISOString();
+  const dashConfig = config ? JSON.stringify(config) : "{}";
+
+  db.prepare(
+    "INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)"
+  ).run(id, req.user!.tenantId, name, req.user!.userId, dashConfig, now, now);
+
+  res.status(201).json({
+    id,
+    name,
+    ownerId: req.user!.userId,
+    config: config ?? {},
+    createdAt: now,
+    updatedAt: now,
+  });
+});
+
+// Get a single dashboard
+router.get("/:id", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+  const db = getDb();
+  const dashboard = db
+    .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+    .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: "Dashboard not found" });
+    return;
+  }
+
+  const widgets = db
+    .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+    .all(dashboard.id) as WidgetRow[];
+
+  res.json({
+    id: dashboard.id,
+    name: dashboard.name,
+    ownerId: dashboard.owner_id,
+    config: JSON.parse(dashboard.config),
+    createdAt: dashboard.created_at,
+    updatedAt: dashboard.updated_at,
+    widgets: widgets.map((w) => ({
+      id: w.id,
+      type: w.type,
+      config: JSON.parse(w.config),
+      positionX: w.position_x,
+      positionY: w.position_y,
+      width: w.width,
+      height: w.height,
+    })),
+  });
+});
+
+// Update a dashboard
+router.put("/:id", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+  const { name, config } = req.body;
+
+  const db = getDb();
+  const dashboard = db
+    .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+    .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: "Dashboard not found" });
+    return;
+  }
+
+  const updatedName = name ?? dashboard.name;
+  const updatedConfig = config ? JSON.stringify(config) : dashboard.config;
+  const now = new Date().toISOString();
+
+  db.prepare(
+    "UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?"
+  ).run(updatedName, updatedConfig, now, req.params.id);
+
+  res.json({
+    id: dashboard.id,
+    name: updatedName,
+    ownerId: dashboard.owner_id,
+    config: JSON.parse(updatedConfig),
+    createdAt: dashboard.created_at,
+    updatedAt: now,
+  });
+});
+
+// Delete a dashboard
+router.delete("/:id", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+  const db = getDb();
+  const dashboard = db
+    .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+    .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: "Dashboard not found" });
+    return;
+  }
+
+  db.prepare("DELETE FROM dashboards WHERE id = ?").run(req.params.id);
+
+  res.status(204).send();
+});
+
+// Add widget to dashboard
+router.post("/:id/widgets", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+  const { type, config, positionX, positionY, width, height } = req.body;
+
+  if (!type || !["counter", "timeseries", "breakdown", "funnel"].includes(type)) {
+    res.status(400).json({ error: "Valid widget type is required" });
+    return;
+  }
+
+  const db = getDb();
+  const dashboard = db
+    .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+    .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: "Dashboard not found" });
+    return;
+  }
+
+  const id = uuidv4();
+  const widgetConfig = config ? JSON.stringify(config) : "{}";
+
+  db.prepare(
+    "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+  ).run(id, dashboard.id, type, widgetConfig, positionX ?? 0, positionY ?? 0, width ?? 1, height ?? 1);
+
+  res.status(201).json({
+    id,
+    dashboardId: dashboard.id,
+    type,
+    config: config ?? {},
+    positionX: positionX ?? 0,
+    positionY: positionY ?? 0,
+    width: width ?? 1,
+    height: height ?? 1,
+  });
+});
+
+export default router;
