diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..34e695c
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,113 @@
+import { Router, Response } from "express";
+import { getDb } from "../db.js";
+import { authMiddleware, AuthenticatedRequest } from "../middleware.js";
+
+const router = Router();
+
+interface QueryFilter {
+  eventName?: string;
+  startDate?: string;
+  endDate?: string;
+  properties?: Record<string, string>;
+}
+
+function buildWhereClause(tenantId: string, filter?: QueryFilter): { sql: string; params: unknown[] } {
+  const conditions: string[] = ["tenant_id = ?"];
+  const params: unknown[] = [tenantId];
+
+  if (filter?.eventName) {
+    conditions.push("name = ?");
+    params.push(filter.eventName);
+  }
+  if (filter?.startDate) {
+    conditions.push("timestamp >= ?");
+    params.push(filter.startDate);
+  }
+  if (filter?.endDate) {
+    conditions.push("timestamp <= ?");
+    params.push(filter.endDate);
+  }
+  if (filter?.properties) {
+    for (const [key, value] of Object.entries(filter.properties)) {
+      conditions.push("json_extract(properties, ?) = ?");
+      params.push(`$.${key}`, value);
+    }
+  }
+
+  return { sql: conditions.join(" AND "), params };
+}
+
+// Count query
+router.post("/count", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+  const { filter } = req.body as { filter?: QueryFilter };
+
+  const db = getDb();
+  const { sql, params } = buildWhereClause(req.user!.tenantId, filter);
+
+  const result = db
+    .prepare(`SELECT COUNT(*) as count FROM events WHERE ${sql}`)
+    .get(...params) as { count: number };
+
+  res.json({ count: result.count });
+});
+
+// Timeseries query
+router.post("/timeseries", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+  const { filter, interval } = req.body as { filter?: QueryFilter; interval?: string };
+
+  const db = getDb();
+  const { sql, params } = buildWhereClause(req.user!.tenantId, filter);
+
+  let dateFormat: string;
+  switch (interval) {
+    case "hour":
+      dateFormat = "%Y-%m-%dT%H:00:00";
+      break;
+    case "month":
+      dateFormat = "%Y-%m-01";
+      break;
+    case "day":
+    default:
+      dateFormat = "%Y-%m-%d";
+      break;
+  }
+
+  const rows = db
+    .prepare(
+      `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count
+       FROM events
+       WHERE ${sql}
+       GROUP BY bucket
+       ORDER BY bucket ASC`
+    )
+    .all(...params) as Array<{ bucket: string; count: number }>;
+
+  res.json({ timeseries: rows });
+});
+
+// Breakdown query
+router.post("/breakdown", authMiddleware, (req: AuthenticatedRequest, res: Response): void => {
+  const { filter, property } = req.body as { filter?: QueryFilter; property?: string };
+
+  if (!property) {
+    res.status(400).json({ error: "property is required for breakdown queries" });
+    return;
+  }
+
+  const db = getDb();
+  const { sql, params } = buildWhereClause(req.user!.tenantId, filter);
+
+  const rows = db
+    .prepare(
+      `SELECT json_extract(properties, ?) as value, COUNT(*) as count
+       FROM events
+       WHERE ${sql}
+       GROUP BY value
+       ORDER BY count DESC`
+    )
+    .all(`$.${property}`, ...params) as Array<{ value: string | null; count: number }>;
+
+  res.json({ breakdown: rows });
+});
+
+export default router;
