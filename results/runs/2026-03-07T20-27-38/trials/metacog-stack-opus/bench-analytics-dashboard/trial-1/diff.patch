--- /dev/null
+++ b/src/app.test.ts
@@ -0,0 +1,389 @@
+import { describe, it, expect, beforeEach } from "vitest";
+import request from "supertest";
+import { createApp } from "./app.js";
+import type { Application } from "express";
+
+describe("Analytics Dashboard API", () => {
+  let app: Application;
+
+  beforeEach(() => {
+    app = createApp();
+  });
+
+  describe("Health check", () => {
+    it("should return ok", async () => {
+      const res = await request(app).get("/api/health");
+      expect(res.status).toBe(200);
+      expect(res.body.status).toBe("ok");
+    });
+  });
+
+  describe("User Management", () => {
+    it("should register a new user", async () => {
+      const res = await request(app).post("/api/users/register").send({
+        email: "test@example.com",
+        password: "password123",
+        tenantId: "tenant-1",
+      });
+      expect(res.status).toBe(201);
+      expect(res.body.user.email).toBe("test@example.com");
+      expect(res.body.token).toBeDefined();
+    });
+
+    it("should not register duplicate email", async () => {
+      await request(app).post("/api/users/register").send({
+        email: "test@example.com",
+        password: "password123",
+        tenantId: "tenant-1",
+      });
+      const res = await request(app).post("/api/users/register").send({
+        email: "test@example.com",
+        password: "password456",
+        tenantId: "tenant-1",
+      });
+      expect(res.status).toBe(409);
+    });
+
+    it("should login with valid credentials", async () => {
+      await request(app).post("/api/users/register").send({
+        email: "test@example.com",
+        password: "password123",
+        tenantId: "tenant-1",
+      });
+      const res = await request(app).post("/api/users/login").send({
+        email: "test@example.com",
+        password: "password123",
+      });
+      expect(res.status).toBe(200);
+      expect(res.body.token).toBeDefined();
+    });
+
+    it("should reject invalid credentials", async () => {
+      await request(app).post("/api/users/register").send({
+        email: "test@example.com",
+        password: "password123",
+        tenantId: "tenant-1",
+      });
+      const res = await request(app).post("/api/users/login").send({
+        email: "test@example.com",
+        password: "wrongpassword",
+      });
+      expect(res.status).toBe(401);
+    });
+
+    it("should get user profile", async () => {
+      const regRes = await request(app).post("/api/users/register").send({
+        email: "test@example.com",
+        password: "password123",
+        tenantId: "tenant-1",
+      });
+      const res = await request(app)
+        .get("/api/users/me")
+        .set("Authorization", `Bearer ${regRes.body.token}`);
+      expect(res.status).toBe(200);
+      expect(res.body.email).toBe("test@example.com");
+    });
+
+    it("should reject unauthenticated profile request", async () => {
+      const res = await request(app).get("/api/users/me");
+      expect(res.status).toBe(401);
+    });
+
+    it("should allow admin to change roles", async () => {
+      const adminRes = await request(app).post("/api/users/register").send({
+        email: "admin@example.com",
+        password: "password123",
+        tenantId: "tenant-1",
+        role: "admin",
+      });
+      const userRes = await request(app).post("/api/users/register").send({
+        email: "user@example.com",
+        password: "password123",
+        tenantId: "tenant-1",
+      });
+      const res = await request(app)
+        .put(`/api/users/${userRes.body.user.id}/role`)
+        .set("Authorization", `Bearer ${adminRes.body.token}`)
+        .send({ role: "editor" });
+      expect(res.status).toBe(200);
+      expect(res.body.role).toBe("editor");
+    });
+  });
+
+  describe("Event Ingestion", () => {
+    let token: string;
+
+    beforeEach(async () => {
+      const res = await request(app).post("/api/users/register").send({
+        email: "test@example.com",
+        password: "password123",
+        tenantId: "tenant-1",
+      });
+      token = res.body.token;
+    });
+
+    it("should ingest a single event", async () => {
+      const res = await request(app)
+        .post("/api/events")
+        .set("Authorization", `Bearer ${token}`)
+        .send({ name: "page_view", properties: { url: "/home" } });
+      expect(res.status).toBe(201);
+      expect(res.body.name).toBe("page_view");
+    });
+
+    it("should reject unauthenticated event", async () => {
+      const res = await request(app)
+        .post("/api/events")
+        .send({ name: "page_view" });
+      expect(res.status).toBe(401);
+    });
+
+    it("should ingest batch events", async () => {
+      const res = await request(app)
+        .post("/api/events/batch")
+        .set("Authorization", `Bearer ${token}`)
+        .send({
+          events: [
+            { name: "page_view", properties: { url: "/home" } },
+            { name: "page_view", properties: { url: "/about" } },
+            { name: "click", properties: { button: "signup" } },
+          ],
+        });
+      expect(res.status).toBe(201);
+      expect(res.body.inserted).toBe(3);
+    });
+  });
+
+  describe("Query Engine", () => {
+    let token: string;
+
+    beforeEach(async () => {
+      const res = await request(app).post("/api/users/register").send({
+        email: "test@example.com",
+        password: "password123",
+        tenantId: "tenant-1",
+      });
+      token = res.body.token;
+
+      // Ingest test events
+      await request(app)
+        .post("/api/events/batch")
+        .set("Authorization", `Bearer ${token}`)
+        .send({
+          events: [
+            { name: "page_view", properties: { url: "/home" }, timestamp: "2024-01-01T10:00:00Z" },
+            { name: "page_view", properties: { url: "/about" }, timestamp: "2024-01-01T14:00:00Z" },
+            { name: "page_view", properties: { url: "/home" }, timestamp: "2024-01-02T10:00:00Z" },
+            { name: "click", properties: { button: "signup" }, timestamp: "2024-01-01T12:00:00Z" },
+          ],
+        });
+    });
+
+    it("should count events", async () => {
+      const res = await request(app)
+        .post("/api/queries/count")
+        .set("Authorization", `Bearer ${token}`)
+        .send({ filter: { eventName: "page_view" } });
+      expect(res.status).toBe(200);
+      expect(res.body.count).toBe(3);
+    });
+
+    it("should return timeseries", async () => {
+      const res = await request(app)
+        .post("/api/queries/timeseries")
+        .set("Authorization", `Bearer ${token}`)
+        .send({ filter: { eventName: "page_view" }, interval: "day" });
+      expect(res.status).toBe(200);
+      expect(res.body.timeseries.length).toBe(2);
+    });
+
+    it("should return breakdown", async () => {
+      const res = await request(app)
+        .post("/api/queries/breakdown")
+        .set("Authorization", `Bearer ${token}`)
+        .send({ filter: { eventName: "page_view" }, property: "url" });
+      expect(res.status).toBe(200);
+      expect(res.body.breakdown.length).toBe(2);
+    });
+  });
+
+  describe("Tenant Isolation", () => {
+    it("should isolate data between tenants", async () => {
