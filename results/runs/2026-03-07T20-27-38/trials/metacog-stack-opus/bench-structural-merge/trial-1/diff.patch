+
+  private updateForkPointAfterMerge(sourceBranch: string, targetBranch: string): void {
+    // After a successful merge, update the fork point so future merges
+    // use the current state as the new common ancestor
+    const sourceData = this.branches.get(sourceBranch)!;
+    const targetData = this.branches.get(targetBranch)!;
+
+    // Create a new snapshot of the current state for future merges
+    const newSnapshot = new Map<string, object | null>();
+    const allDocs = new Set([
+      ...sourceData.documents.keys(),
+      ...targetData.documents.keys(),
+    ]);
+
+    for (const docId of allDocs) {
+      const targetEntry = targetData.documents.get(docId);
+      if (targetEntry && !targetEntry.deleted) {
+        newSnapshot.set(docId, deepClone(targetEntry.content));
+      } else {
+        newSnapshot.set(docId, null);
+      }
+    }
+
+    // Update the fork point on the source branch (since it's the one being merged FROM)
+    if (sourceData.parentBranch === targetBranch) {
+      sourceData.forkPointSnapshot = newSnapshot;
+    } else if (targetData.parentBranch === sourceBranch) {
+      targetData.forkPointSnapshot = newSnapshot;
+    }
+  }
+}
