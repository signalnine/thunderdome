avior\n        const oursVal = targetDeleted ? undefined : targetContent;\n        const theirsVal = sourceDeleted ? undefined : sourceContent;\n\n        if (oursVal !== undefined) {\n          merged[docId] = deepClone(oursVal) as object;\n        }\n\n        conflicts.push({\n          documentId: docId,\n          path: '',\n          base: effectiveBase !== undefined ? deepClone(effectiveBase) : undefined,\n          ours: oursVal !== undefined ? deepClone(oursVal) : undefined,\n          theirs: theirsVal !== undefined ? deepClone(theirsVal) : undefined,\n        });\n        continue;\n      }\n\n      // Both sides have content - do field-level merge\n      const baseObj = (effectiveBase ?? {}) as Record<string, unknown>;\n      const sourceObj = sourceContent as Record<string, unknown>;\n      const targetObj = targetContent as Record<string, unknown>;\n\n      const sourceDiffs = collectDiffPaths(baseObj, sourceObj, '');\n      const targetDiffs = collectDiffPaths(baseObj, targetObj, '');\n\n      const sourcePathSet = new Set(sourceDiffs);\n      const targetPathSet = new Set(targetDiffs);\n\n      const mergedObj = deepClone(targetObj) as Record<string, unknown>;\n\n      // Apply non-conflicting source changes\n      for (const path of sourceDiffs) {\n        if (!targetPathSet.has(path)) {\n          // Only source changed this path - apply source's change\n          const sourceVal = getAtPath(sourceObj, path);\n          if (sourceVal === undefined) {\n            // Source deleted this path\n            deleteAtPath(mergedObj, path);\n          } else {\n            setAtPath(mergedObj, path, deepClone(sourceVal));\n          }\n        }\n      }\n\n      // Check for conflicts on paths changed by both\n      for (const path of sourceDiffs) {\n        if (targetPathSet.has(path)) {\n          const sourceVal = getAtPath(sourceObj, path);\n          const targetVal = getAtPath(targetObj, path);\n\n          if (!deepEqual(sourceVal, targetVal)) {\n            // Conflict! Both changed to different values\n            const baseVal = getAtPath(baseObj, path);\n            conflicts.push({\n              documentId: docId,\n              path,\n              base: deepClone(baseVal),\n              ours: deepClone(targetVal),\n              theirs: deepClone(sourceVal),\n            });\n            // merged keeps \"ours\" (target) value - already in mergedObj\n          }\n          // If both changed to same value, no conflict - target value is already correct\n        }\n      }\n\n      merged[docId] = mergedObj as object;\n    }\n\n    const applied = conflicts.length === 0;\n\n    if (applied) {\n      // Apply the merge to the current branch\n      for (const [docId, content] of Object.entries(merged)) {\n        const existing = targetBranchData.documents.get(docId);\n        if (existing) {\n          const cloned = deepClone(content);\n          const version: Version = {\n            id: generateVersionId(),\n            timestamp: Date.now(),\n            content: deepClone(cloned),\n          };\n          existing.content = cloned;\n          existing.versions.push(version);\n          existing.deleted = false;\n        } else {\n          const cloned = deepClone(content);\n          const version: Version = {\n            id: generateVersionId(),\n            timestamp: Date.now(),\n            content: deepClone(cloned),\n          };\n          targetBranchData.documents.set(docId, {\n            content: cloned,\n            versions: [version],\n            deleted: false,\n          });\n        }\n      }\n\n      // Handle deletions from source that should be applied\n      for (const docId of allDocIds) {\n        if (!(docId in merged)) {\n          const targetEntry = targetBranchData.documents.get(docId);\n          const sourceEntry = sourceBranchData.documents.get(docId);\n          if (targetEntry && !targetEntry.deleted) {\n            // This doc was deleted by the merge (source