> {\n    it('default branch is main', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('creates and switches branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    it('lists branches', () => {\n      store.createBranch('feature');\n      store.createBranch('bugfix');\n      expect(store.listBranches()).toContain('main');\n      expect(store.listBranches()).toContain('feature');\n      expect(store.listBranches()).toContain('bugfix');\n    });\n\n    it('throws when switching to non-existent branch', () => {\n      expect(() => store.switchBranch('nope')).toThrow();\n    });\n\n    it('throws when creating duplicate branch', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('isolates changes between branches', () => {\n      store.create('doc1', { value: 'original' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { value: 'modified' });\n\n      expect(store.get('doc1')).toEqual({ value: 'modified' });\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ value: 'original' });\n    });\n\n    it('branch from a specific branch', () => {\n      store.create('doc1', { value: 'main' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { value: 'feature' });\n\n      store.createBranch('feature2', 'feature');\n      store.switchBranch('feature2');\n      expect(store.get('doc1')).toEqual({ value: 'feature' });\n    });\n\n    it('new documents on one branch are not visible on another', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { a: 1 });\n\n      store.switchBranch('main');\n      expect(() => store.get('doc1')).toThrow();\n    });\n  });\n\n  describe('Merging', 