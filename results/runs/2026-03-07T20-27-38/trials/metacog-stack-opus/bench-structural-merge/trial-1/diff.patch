@@ -0,0 +1,371 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('CRUD operations', () => {
+    it('creates and retrieves a document', () => {
+      store.create('doc1', { name: 'test', value: 42 });
+      expect(store.get('doc1')).toEqual({ name: 'test', value: 42 });
+    });
+
+    it('throws when creating a document that already exists', () => {
+      store.create('doc1', { a: 1 });
+      expect(() => store.create('doc1', { a: 2 })).toThrow();
+    });
+
+    it('throws when getting a non-existent document', () => {
+      expect(() => store.get('nope')).toThrow();
+    });
+
+    it('updates a document', () => {
+      store.create('doc1', { a: 1 });
+      store.update('doc1', { a: 2, b: 3 });
+      expect(store.get('doc1')).toEqual({ a: 2, b: 3 });
+    });
+
+    it('throws when updating a non-existent document', () => {
+      expect(() => store.update('nope', { a: 1 })).toThrow();
+    });
+
+    it('deletes a document', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('throws when deleting a non-existent document', () => {
+      expect(() => store.delete('nope')).toThrow();
+    });
+
+    it('throws when deleting an already deleted document', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.delete('doc1')).toThrow();
+    });
+
+    it('deep clones on store and retrieval', () => {
+      const content = { nested: { value: 1 } };
+      store.create('doc1', content);
+      content.nested.value = 999;
+      const retrieved = store.get('doc1') as { nested: { value: number } };
+      expect(retrieved.nested.value).toBe(1);
+      retrieved.nested.value = 888;
+      expect((store.get('doc1') as { nested: { value: number } }).nested.value).toBe(1);
+    });
+  });
+
+  describe('Version history', () => {
+    it('tracks versions on create and update', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      store.update('doc1', { v: 3 });
+
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ v: 1 });
+      expect(history[1].content).toEqual({ v: 2 });
+      expect(history[2].content).toEqual({ v: 3 });
+    });
+
+    it('versions are in chronological order', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      const history = store.getHistory('doc1');
+      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);
+    });
+
+    it('each version has a unique id', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      const history = store.getHistory('doc1');
+      expect(history[0].id).not.toBe(history[1].id);
+    });
+
+    it('getVersion retrieves content at specific version', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      const history = store.getHistory('doc1');
+      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });
+      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });
+    });
+
+    it('throws for non-existent version', () => {
+      store.create('doc1', { v: 1 });
+      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();
+    });
+
+    it('throws getHistory for non-existent document', () => {
+      expect(() => store.getHistory('nope')).toThrow();
+    });
+  });
+
+  describe('Branching', () => {
+    it('default branch is main', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('creates and switches branches', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    it('lists branches', () => {
+      store.createBranch('feature');
+      store.createBranch('bugfix');
+      expect(store.listBranches()).toContain('main');
+      expect(store.listBranches()).toContain('feature');
+      expect(store.listBranches()).toContain('bugfix');
+    });
+
+    it('throws when switching to non-existent branch', () => {
+      expect(() => store.switchBranch('nope')).toThrow();
+    });
+
+    it('throws when creating duplicate branch', () => {
+      store.createBranch('feature');
+      expect(() => store.createBranch('feature')).toThrow();
+    });
+
+    it('isolates changes between branches', () => {
+      store.create('doc1', { value: 'original' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { value: 'modified' });
+
+      expect(store.get('doc1')).toEqual({ value: 'modified' });
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ value: 'original' });
+    });
+
+    it('branch from a specific branch', () => {
+      store.create('doc1', { value: 'main' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { value: 'feature' });
+
+      store.createBranch('feature2', 'feature');
+      store.switchBranch('feature2');
+      expect(store.get('doc1')).toEqual({ value: 'feature' });
+    });
+
+    it('new documents on one branch are not visible on another', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { a: 1 });
+
+      store.switchBranch('main');
+      expect(() => store.get('doc1')).toThrow();
+    });
+  });
+
+  describe('Merging', () => {
+    it('merges non-conflicting changes from source branch', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      // Modify on feature branch
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, b: 3 });
+
+      // Merge into main
+      store.switchBranch('main');
+      const result = store.merge('feature');
+
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 1, b: 3 });
+      expect(store.get('doc1')).toEqual({ a: 1, b: 3 });
+    });
+
+    it('merges when only target changed', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      // Modify on main
+      store.update('doc1', { a: 1, b: 99 });
+
+      // Merge feature into main - no changes from feature
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 1, b: 99 });
+    });
+
+    it('merges non-overlapping field changes from both branches', () => {
+      store.create('doc1', { a: 1, b: 2, c: 3 });
+      store.createBranch('feature');
+
+      // Modify different fields
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2, c: 3 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 1, b: 20, c: 3 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 3 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 20, c: 3 });
+    });
+
+    it('detects conflicts when both sides change the same field differently', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100, b: 2 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 200, b: 2 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].documentId).toBe('doc1');
+      expect(result.conflicts[0].path).toBe('a');
+      expect(result.conflicts[0].base).toBe(1);
+      expect(result.conflicts[0].ours).toBe(200);
+      expect(result.conflicts[0].theirs).toBe(100);
+
+      // Current branch should remain unchanged
+      expect(store.get('doc1')).toEqual({ a: 200, b: 2 });
+    });
+
+    it('no conflict when both sides change a field to the same value', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
