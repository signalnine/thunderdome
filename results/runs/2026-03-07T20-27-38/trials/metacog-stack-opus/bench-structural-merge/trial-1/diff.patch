eturn a.every((val, i) => deepEqual(val, b[i]));\n  }\n  const aObj = a as Record<string, unknown>;\n  const bObj = b as Record<string, unknown>;\n  const aKeys = Object.keys(aObj);\n  const bKeys = Object.keys(bObj);\n  if (aKeys.length !== bKeys.length) return false;\n  return aKeys.every(key => key in bObj && deepEqual(aObj[key], bObj[key]));\n}\n\n// Collect all leaf-level paths where two objects differ\nfunction collectDiffPaths(\n  base: Record<string, unknown> | undefined,\n  changed: Record<string, unknown> | undefined,\n  prefix: string\n): string[] {\n  const paths: string[] = [];\n\n  if (base === undefined && changed === undefined) return paths;\n  if (base === undefined) {\n    // Everything in changed is new\n    if (isPlainObject(changed)) {\n      const keys = Object.keys(changed!);\n      if (keys.length === 0) {\n        paths.push(prefix);\n      } else {\n        for (const key of keys) {\n          const p = prefix ? `${prefix}.${key}` : key;\n          if (isPlainObject(changed![key])) {\n            paths.push(...collectDiffPaths(undefined, changed![key] as Record<string, unknown>, p));\n          } else {\n            paths.push(p);\n          }\n        }\n      }\n    } else {\n      paths.push(prefix);\n    }\n    return paths;\n  }\n  if (changed === undefined) {\n    // Everything in base was removed\n    if (isPlainObject(base)) {\n      const keys = Object.keys(base!);\n      if (keys.length === 0) {\n        paths.push(prefix);\n      } else {\n        for (const key of keys) {\n          const p = prefix ? `${prefix}.${key}` : key;\n          if (isPlainObject(base![key])) {\n            paths.push(...collectDiffPaths(base![key] as Record<string, unknown>, undefined, p));\n          } else {\n            paths.push(p);\n          }\n        }\n      }\n    } else {\n      paths.push(prefix);\n    }\n    return paths;\n  }\n\n  const allKeys = new Set([...Object.keys(base), ...Object.keys(changed)]);\n  for (const key of allKeys) {\n    const p = prefix ? `${prefix}.${key}` : key;\n    const bVal = base[key];\n    const cVal = changed[key];\n\n    if (deepEqual(bVal, cVal)) continue;\n\n    if (isPlainObject(bVal) && isPlainObject(cVal)) {\n      paths.push(...collectDiffPaths(\n        bVal as Record<string, unknown>,\n        cVal as Record<string, unknown>,\n        p\n      ));\n    } else {\n      paths.push(p);\n    }\n  }\n\n  return paths;\n}\n\nfunction getAtPath(obj: Record<string, unknown>, path: string): unknown {\n  const parts = path.split('.');\n  let current: unknown = obj;\n  for (const part of parts) {\n    if (!isPlainObject(current)) return undefined;\n    current = (current as Record<string, unknown>)[part];\n  }\n  return current;\n}\n\nfunction setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (!isPlainObject(current[parts[i]])) {\n      current[parts[i]] = {};\n    }\n    current = current[parts[i]] as Record<string, unknown>;\n  }\n  current[parts[parts.length - 1]] = value;\n}\n\nfunction deleteAtPath(obj: Record<string, unknown>, path: string): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (!isPlainObject(current[parts[i]])) return;\n    current = current[parts[i]] as Record<string, unknown>;\n  }\n  delete current[parts[parts.length - 1]];\n}\n\n// ── Internal types ───────────────────────────────────────────────────────────\n\ninterface DocumentEntry {\n  content: object;\n  versions: Version[];\n  deleted: boolean;\n}\n\ninterface BranchData {\n  documents: Map<string, DocumentEntry>;\n  parentBranch: string | null;\n  forkPointSnapshot: Map<string, object | null> | null; // null content = doc didn't exist or was deleted at fork\n}\n\n// ── DocumentStore ────────────────────────────────────────────────────────────\n\nlet versionCounter = 0;\n\nfunction generateVersionId(): string {\n  return `v_${++versionCounter}_${Date.now()}`;\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n      parentBranch: null,\n      forkPointSnapshot: null,\n    });\n  }\n\n  // ── CRUD ─────────────────────────────────────────────────────────────────\n\n  create(id: string, content: object): void {\n    const branch = this.getBranchData();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n\n    const cloned = deepClone(content);\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(cloned),\n    };\n\n    branch.documents.set(id, {\n      content: cloned,\n      versions: [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getBranchData();\n    const doc = branch.documents.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return deepClone(doc.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getBranchData();\n    const doc = branch.documents.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n\n    const cloned = deepClone(content);\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: deepClone(cloned),\n    };\n\n    doc.content = cloned;\n    doc.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getBranchData();\n    const doc = branch.documents.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    doc.deleted = true;\n  }\n\n  // ── Version history ──────────────────────────────────────────────────────\n\n  getHistory(id: string): Version[] {\n    const branch = this.getBranchData();\n    const doc = branch.documents.get(id);\n    if (!doc) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return doc.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.getBranchData();\n    const doc = branch.documents.get(id);\n    if (!doc) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    const version = doc.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n    }\n    return deepClone(version.content);\n  }\n\n  // ── Branching ────────────────────────────────────────────────────────────\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n\n    const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.branches.get(sourceName);\n    if (!source) {\n      throw new Error(`Branch \"${sourceName}\" not found`);\n    }\n\n    // Deep-clone all documents from the source branch\n    const newDocs = new Map<string, DocumentEntry>();\n    const forkSnapshot = new Map<string, object | null>();\n\n    for (const [docId, entry] of source.documents) {\n      newDocs.set(docId, {\n        content: deepClone(entry.content),\n        versions: entry.versions.map(v => ({\n          id: v.id,\n          timestamp: v.timestamp,\n          content: deepClone(v.content),\n        })),\n        deleted: entry.deleted,\n      });\n\n      // Record the fork-point snapshot: the state of each document at branch creation\n      forkSnapshot.set(docId, entry.deleted ? null : deepClone(entry.content));\n    }\n\n    // Also record the fork snapshot on the source branch side for merge purposes\n    // We need to know what the source looked like when this branch was created\n    this.branches.set(name, {\n      documents: newDocs,\n      parentBranch: sourceName,\n      forkPointSnapshot: forkSnapshot,\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" not found`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // ── Merging ──────────────────────────────────────────────────────────────\n\n  merge(sourceBranch: string): MergeResult {\n    const sourceBranchData = this.branches.get(sourceBranch);\n    if (!sourceBranchData) {\n      throw new Error(`Branch \"${sourceBranch}\" not found`);\n    }\n\n    const targetBranchData = this.getBranchData();\n    const targetBranchName = this.currentBranch;\n\n    // Determine the common ancestor (fork point).\n    // We look for the fork-point snapshot. The common ancestor is determined by\n    // which branch was created from which.\n    const forkSnapshot = this.findForkPointSnapshot(sourceBranch, targetBranchName);\n\n    // Collect all document IDs across base, source, and target\n    const allDocIds = new Set<string>();\n    if (forkSnapshot) {\n      for (const id of forkSnapshot.keys()) allDocIds.add(id);\n    }\n    for (const id of sourceBranchData.documents.keys()) allDocIds.add(id);\n    for (const id of targetBranchData.documents.keys()) allDocIds.add(id);\n\n    const merged: Record<string, object> = {};\n    const conflicts: Conflict[] = [];\n\n    for (const docId of allDocIds) {\n      const baseContent = forkSnapshot?.get(docId) ?? undefined;\n      const baseExists = forkSnapshot ? forkSnapshot.has(docId) : false;\n      const baseIsNull = baseExists && baseContent === 