+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VeqowUFfwPDjaXfniGREvz","type":"tool_result","content":"     1→/**\n     2→ * Schema validation using zod.\n     3→ * Uses z.pipe() for string-to-number coercion (requires zod >= 3.22).\n     4→ */\n     5→\n     6→import { z } from 'zod';\n     7→import type { Role } from './types.js';\n     8→\n     9→export const roleSchema = z.enum(['admin', 'user', 'viewer']);\n    10→\n    11→export const createUserSchema = z.object({\n    12→  name: z\n    13→    .string()\n    14→    .min(1, 'Name is required')\n    15→    .max(100, 'Name must be 100 characters or less'),\n    16→  email: z.string().email('Invalid email address'),\n    17→  role: roleSchema,\n    18→});\n    19→\n    20→export const userIdSchema = z\n    21→  .string()\n    22→  .pipe(z.coerce.number().int().positive('User ID must be a positive integer'));\n    23→\n    24→export const userFiltersSchema = z.object({\n    25→  role: roleSchema.optional(),\n    26→  search: z.string().optional(),\n    27→  limit: z\n    28→    .string()\n    29→    .pipe(z.coerce.number().int().min(1).max(100))\n    30→    .optional()\n    31→    .default('20'),\n    32→  offset: z\n    33→    .string()\n    34→    .pipe(z.coerce.number().int().min(0))\n    35→    .optional()\n    36→    .default('0'),\n    37→});\n    38→\n    39→export function validateCreateUser(data: unknown): {\n    40→  success: boolean;\n    41→  data?: { name: string; email: string; role: Role };\n    42→  errors?: string[];\n    43→} {\n    44→  const result = createUserSchema.safeParse(data);\n    45→  if (result.success) {\n    46→    return { success: true, data: result.data };\n    47→  }\n    48→  return {\n    49→    success: false,\n    50→    errors: result.error.errors.map((e) => e.message),\n    51→  };\n    52→}\n    53→\n    54→export function validateUserId(id: string): {\n    55→  success: boolean;\n    56→  data?: number;\n    57→  errors?: string[];\n    58→} {\n    59→  const result = userIdSchema.safeParse(id);\n    60→  if (result.success) {\n    61→    return { success: true, data: result.data };\n    62→  }\n    63→  return {\n    64→    success: false,\n    65→    errors: result.error.errors.map((e) => e.message),\n    66→  };\n    67→}\n    68→"}]},"parent_tool_use_id":null,"session_id":"1269afec-1fd3-491e-a03f-63521920d2f8","uuid":"26bc817e-20cf-40b8-b4cf-b5da0a2b20dc","tool_use_result":{"type":"text","file":{"filePath":"/workspace/packages/core/src/validation.ts","content":"/**\n * Schema validation using zod.\n * Uses z.pipe() for string-to-number coercion (requires zod >= 3.22).\n */\n\nimport { z } from 'zod';\nimport type { Role } from './types.js';\n\nexport const roleSchema = z.enum(['admin', 'user', 'viewer']);\n\nexport const createUserSchema = z.object({\n  name: z\n    .string()\n    .min(1, 'Name is required')\n    .max(100, 'Name must be 100 characters or less'),\n  email: z.string().email('Invalid email address'),\n  role: roleSchema,\n});\n\nexport const userIdSchema = z\n  .string()\n  .pipe(z.coerce.number().int().positive('User ID must be a positive integer'));\n\nexport const userFiltersSchema = z.object({\n  role: roleSchema.optional(),\n  search: z.string().optional(),\n  limit: z\n    .string()\n    .pipe(z.coerce.number().int().min(1).max(100))\n    .optional()\n    .default('20'),\n  offset: z\n    .string()\n    .pipe(z.coerce.number().int().min(0))\n    .optional()\n    .default('0'),\n});\n\nexport function validateCreateUser(data: unknown): {\n  success: boolean;\n  data?: { name: string; email: string; role: Role };\n  errors?: string[];\n} {\n  const result = createUserSchema.safeParse(data);\n  if (result.success) {\n    return { success: true, data: result.data };\n  }\n  return {\n    success: false,\n    errors: result.error.errors.map((e) => e.message),\n  };\n}\n\nexport function validateUserId(id: string): {\n  success: boolean;\n  data?: number;\n  errors?: string[];\n} {\n  const result = userIdSchema.safeParse(id);\n  if (result.success) {\n    return { success: true, data: result.data };\n  }\n  return {\n    success: false,\n    errors: result.error.errors.map((e) => e.message),\n  };\n}\n","numLines":68,"startLine":1,"totalLines":68}}}
