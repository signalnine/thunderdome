+import { describe, it, expect } from 'vitest';
+import { createRunner } from './index.js';
+
+describe('RunnerService', () => {
+  const runner = createRunner();
+
+  it('executes simple code and returns result', async () => {
+    const result = await runner.execute('1 + 1');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(2);
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+    expect(result.memoryUsed).toBeGreaterThanOrEqual(0);
+  });
+
+  it('passes context variables into sandbox', async () => {
+    const result = await runner.execute('x + y', { x: 10, y: 20 });
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(30);
+  });
+
+  it('captures console.log output', async () => {
+    const result = await runner.execute('console.log("hello world")');
+    expect(result.success).toBe(true);
+    // output should be the console output or undefined (last expression)
+  });
+
+  it('handles runtime errors gracefully', async () => {
+    const result = await runner.execute('throw new Error("boom")');
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('boom');
+  });
+
+  it('handles syntax errors', async () => {
+    const result = await runner.execute('function {{{');
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  });
+
+  it('enforces timeout', async () => {
+    const result = await runner.executeWithTimeout('while(true){}', 100);
+    expect(result.success).toBe(false);
+    expect(result.error).toBeDefined();
+  });
+
+  it('returns duration info', async () => {
+    const result = await runner.execute('42');
+    expect(typeof result.duration).toBe('number');
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+  });
+
+  it('returns memory info', async () => {
+    const result = await runner.execute('42');
+    expect(typeof result.memoryUsed).toBe('number');
+  });
+
+  it('executes code with context in executeWithTimeout', async () => {
+    const result = await runner.executeWithTimeout('value * 2', 5000, { value: 21 });
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(42);
+  });
+
+  it('isolates sandbox from host environment', async () => {
+    const result = await runner.execute('typeof require');
+    expect(result.success).toBe(true);
+    expect(result.output).toBe('undefined');
+  });
+});
