+    expect(reviews.getReviews('test')).toHaveLength(0);
+  });
+
+  it('removeReview returns false for unknown id', () => {
+    expect(reviews.removeReview(9999)).toBe(false);
+  });
+
+  it('gets reviews by user', () => {
+    reviews.addReview({
+      pluginName: 'a',
+      pluginVersion: '1.0.0',
+      userId: 'alice',
+      rating: 5,
+      comment: 'great',
+    });
+    reviews.addReview({
+      pluginName: 'b',
+      pluginVersion: '1.0.0',
+      userId: 'bob',
+      rating: 4,
+      comment: 'good',
+    });
+    const aliceReviews = reviews.getReviewsByUser('alice');
+    expect(aliceReviews).toHaveLength(1);
+    expect(aliceReviews[0].userId).toBe('alice');
+  });
+
+  it('counts reviews for a plugin', () => {
+    reviews.addReview({
+      pluginName: 'test',
+      pluginVersion: '1.0.0',
+      userId: 'u1',
+      rating: 5,
+      comment: 'a',
+    });
+    reviews.addReview({
+      pluginName: 'test',
+      pluginVersion: '1.0.0',
+      userId: 'u2',
+      rating: 4,
+      comment: 'b',
