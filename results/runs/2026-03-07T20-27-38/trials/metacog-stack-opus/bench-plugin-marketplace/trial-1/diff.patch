+import { describe, it, expect } from 'vitest';
+import { createResolver } from './index.js';
+
+describe('ResolverService', () => {
+  const resolver = createResolver();
+
+  it('resolves a simple constraint', () => {
+    const result = resolver.resolve(
+      [{ name: 'foo', range: '^1.0.0' }],
+      { foo: ['1.0.0', '1.2.3', '2.0.0'] }
+    );
+    expect(result).toHaveLength(1);
+    expect(result[0].name).toBe('foo');
+    expect(result[0].version).toBe('1.2.3');
+    expect(result[0].satisfies).toBe('^1.0.0');
+  });
+
+  it('resolves multiple constraints', () => {
+    const result = resolver.resolve(
+      [
+        { name: 'foo', range: '^1.0.0' },
+        { name: 'bar', range: '~2.1.0' },
+      ],
+      {
+        foo: ['1.0.0', '1.5.0', '2.0.0'],
+        bar: ['2.1.0', '2.1.5', '2.2.0'],
+      }
+    );
+    expect(result).toHaveLength(2);
+    expect(result[0].version).toBe('1.5.0');
+    expect(result[1].version).toBe('2.1.5');
+  });
+
+  it('throws when no versions available', () => {
+    expect(() =>
+      resolver.resolve([{ name: 'foo', range: '^1.0.0' }], {})
+    ).toThrow('No versions available for foo');
+  });
+
+  it('throws when no version satisfies range', () => {
+    expect(() =>
+      resolver.resolve(
+        [{ name: 'foo', range: '^3.0.0' }],
+        { foo: ['1.0.0', '2.0.0'] }
+      )
+    ).toThrow('No version of foo satisfies range ^3.0.0');
+  });
+
+  it('satisfies returns true for matching version', () => {
+    expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);
+  });
+
+  it('satisfies returns false for non-matching version', () => {
+    expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+  });
+
+  it('maxSatisfying returns best match', () => {
+    expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0')).toBe('1.5.0');
+  });
+
+  it('maxSatisfying returns null when none match', () => {
+    expect(resolver.maxSatisfying(['3.0.0'], '^1.0.0')).toBeNull();
+  });
+
+  it('validRange returns true for valid range', () => {
+    expect(resolver.validRange('^1.0.0')).toBe(true);
+    expect(resolver.validRange('~2.1.0')).toBe(true);
+    expect(resolver.validRange('>=1.0.0 <3.0.0')).toBe(true);
+  });
+
+  it('validRange returns false for invalid range', () => {
+    expect(resolver.validRange('not-a-range')).toBe(false);
+  });
+});
