+import { describe, it, expect, beforeEach } from 'vitest';
+import { createRegistry } from './index.js';
+import type { PluginManifest, RegistryService } from '../types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: 'console.log("hello")',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('RegistryService', () => {
+  let registry: RegistryService;
+
+  beforeEach(() => {
+    registry = createRegistry();
+  });
+
+  it('registers and retrieves a plugin', () => {
+    const manifest = makeManifest();
+    registry.register(manifest);
+    const result = registry.get('test-plugin');
+    expect(result).not.toBeNull();
+    expect(result!.name).toBe('test-plugin');
+    expect(result!.version).toBe('1.0.0');
+  });
+
+  it('returns null for unknown plugin', () => {
+    expect(registry.get('nonexistent')).toBeNull();
+  });
+
+  it('supports multiple versions of a plugin', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    const versions = registry.listVersions('test-plugin');
+    expect(versions).toContain('1.0.0');
+    expect(versions).toContain('2.0.0');
+    expect(versions).toHaveLength(2);
+  });
+
+  it('getVersion retrieves specific version', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    const v1 = registry.getVersion('test-plugin', '1.0.0');
+    expect(v1).not.toBeNull();
+    expect(v1!.version).toBe('1.0.0');
+    const v2 = registry.getVersion('test-plugin', '2.0.0');
+    expect(v2!.version).toBe('2.0.0');
+  });
+
+  it('getVersion returns null for unknown version', () => {
+    registry.register(makeManifest());
+    expect(registry.getVersion('test-plugin', '9.9.9')).toBeNull();
+  });
+
+  it('lists all plugins', () => {
+    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));
+    registry.register(makeManifest({ name: 'b', version: '1.0.0' }));
+    const all = registry.list();
+    expect(all).toHaveLength(2);
+  });
+
+  it('searches by name', () => {
+    registry.register(makeManifest({ name: 'foo-bar', description: 'xyz' }));
+    registry.register(makeManifest({ name: 'baz', description: 'xyz' }));
+    const results = registry.search('foo');
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('foo-bar');
+  });
+
+  it('searches by description', () => {
+    registry.register(makeManifest({ name: 'a', description: 'image processing' }));
+    registry.register(makeManifest({ name: 'b', description: 'text editor' }));
+    const results = registry.search('image');
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('a');
+  });
+
+  it('searches by author', () => {
+    registry.register(makeManifest({ name: 'a', author: 'alice' }));
+    registry.register(makeManifest({ name: 'b', author: 'bob' }));
+    const results = registry.search('alice');
+    expect(results).toHaveLength(1);
+    expect(results[0].name).toBe('a');
+  });
+
+  it('removes a specific version', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    const removed = registry.remove('test-plugin', '1.0.0');
+    expect(removed).toBe(true);
+    expect(registry.listVersions('test-plugin')).toEqual(['2.0.0']);
+  });
+
+  it('remove returns false for unknown plugin', () => {
+    expect(registry.remove('nonexistent', '1.0.0')).toBe(false);
+  });
+
+  it('updates a plugin', () => {
+    registry.register(makeManifest());
+    registry.update('test-plugin', '1.0.0', { description: 'updated' });
+    const result = registry.get('test-plugin');
+    expect(result!.description).toBe('updated');
+  });
