+      rating: 1,
+      comment: 'b',
+    });
+    reviews.addReview({
+      pluginName: 'test',
+      pluginVersion: '1.0.0',
+      userId: 'u3',
+      rating: 3,
+      comment: 'c',
+    });
+
+    // Average of 5, 1, 3 = 3
+    expect(reviews.getAverageRating('test')).toBe(3);
+
+    // Flag the bad review
+    reviews.flagReview(r2.id);
+    // Average of 5, 3 = 4
+    expect(reviews.getAverageRating('test')).toBe(4);
