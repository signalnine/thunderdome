@@ -0,0 +1,121 @@
+import { describe, it, expect } from 'vitest';
+import { createDepsService } from './index.js';
+import { createRegistry } from '../registry/index.js';
+import type { PluginManifest } from '../types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'a',
+    version: '1.0.0',
+    description: '',
+    author: '',
+    dependencies: {},
+    entryPoint: '',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('DepsService', () => {
+  const deps = createDepsService();
+
+  it('builds a simple dependency tree', () => {
+    const registry = createRegistry();
+    registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'b', dependencies: {} }));
+
+    const tree = deps.buildTree('a', registry);
+    expect(tree.name).toBe('a');
+    expect(tree.dependencies).toHaveLength(1);
+    expect(tree.dependencies[0].name).toBe('b');
+  });
+
+  it('builds tree with nested dependencies', () => {
+    const registry = createRegistry();
+    registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'c', dependencies: {} }));
+
+    const tree = deps.buildTree('a', registry);
+    expect(tree.dependencies[0].dependencies[0].name).toBe('c');
+  });
+
+  it('detects circular dependencies', () => {
+    const registry = createRegistry();
+    registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'b', dependencies: { a: '^1.0.0' } }));
+
+    const cycles = deps.detectCycles('a', registry);
+    expect(cycles).not.toBeNull();
+    expect(cycles!.length).toBeGreaterThan(0);
+  });
+
+  it('returns null when no cycles exist', () => {
+    const registry = createRegistry();
+    registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'b', dependencies: {} }));
+
+    const cycles = deps.detectCycles('a', registry);
+    expect(cycles).toBeNull();
+  });
+
+  it('hasCircularDependency returns true for cycles', () => {
+    const registry = createRegistry();
+    registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'b', dependencies: { a: '^1.0.0' } }));
+
+    expect(deps.hasCircularDependency('a', registry)).toBe(true);
+  });
+
+  it('hasCircularDependency returns false when no cycles', () => {
+    const registry = createRegistry();
+    registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'b', dependencies: {} }));
+
+    expect(deps.hasCircularDependency('a', registry)).toBe(false);
+  });
+
+  it('produces topological sort', () => {
+    const registry = createRegistry();
+    registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0', c: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'c', dependencies: {} }));
+
+    const sorted = deps.topologicalSort('a', registry);
+    // c should come before b, b before a
+    expect(sorted.indexOf('c')).toBeLessThan(sorted.indexOf('b'));
+    expect(sorted.indexOf('b')).toBeLessThan(sorted.indexOf('a'));
+  });
+
+  it('flattens dependencies (excludes root)', () => {
+    const registry = createRegistry();
+    registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'c', dependencies: {} }));
+
+    const flat = deps.flattenDependencies('a', registry);
+    expect(flat).toContain('b');
+    expect(flat).toContain('c');
+    expect(flat).not.toContain('a');
+  });
+
+  it('handles missing plugins gracefully in tree', () => {
+    const registry = createRegistry();
+    registry.register(makeManifest({ name: 'a', dependencies: { missing: '^1.0.0' } }));
+
+    const tree = deps.buildTree('a', registry);
+    expect(tree.dependencies[0].name).toBe('missing');
+    expect(tree.dependencies[0].version).toBe('unknown');
+  });
+
+  it('detects 3-node circular dependency', () => {
+    const registry = createRegistry();
+    registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));
+    registry.register(makeManifest({ name: 'c', dependencies: { a: '^1.0.0' } }));
+
+    expect(deps.hasCircularDependency('a', registry)).toBe(true);
+    const cycles = deps.detectCycles('a', registry);
+    expect(cycles).not.toBeNull();
+  });
+});
