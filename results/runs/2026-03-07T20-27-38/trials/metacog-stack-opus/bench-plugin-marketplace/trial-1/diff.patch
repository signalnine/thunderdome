+import { describe, it, expect } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '1 + 1',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('createMarketplace', () => {
+  it('returns all service handles', () => {
+    const mp = createMarketplace();
+    expect(mp.registry).toBeDefined();
+    expect(mp.resolver).toBeDefined();
+    expect(mp.runner).toBeDefined();
+    expect(mp.reviews).toBeDefined();
+    expect(mp.deps).toBeDefined();
+    expect(mp.installPlugin).toBeTypeOf('function');
+  });
+
+  it('installPlugin registers, resolves, and executes', async () => {
+    const mp = createMarketplace();
+    const result = await mp.installPlugin(makeManifest());
+
+    expect(result.resolvedDependencies).toEqual([]);
+    expect(result.executionResult.success).toBe(true);
+    expect(result.executionResult.output).toBe(2);
+
+    // Plugin should be in registry
+    expect(mp.registry.get('test-plugin')).not.toBeNull();
+  });
+
+  it('installPlugin resolves dependencies', async () => {
+    const mp = createMarketplace();
+    // Register the dependency first
+    mp.registry.register(makeManifest({ name: 'dep-a', version: '1.0.0' }));
+    mp.registry.register(makeManifest({ name: 'dep-a', version: '1.2.0' }));
+
+    const result = await mp.installPlugin(
+      makeManifest({
+        name: 'main-plugin',
+        dependencies: { 'dep-a': '^1.0.0' },
+      })
+    );
+
+    expect(result.resolvedDependencies).toHaveLength(1);
+    expect(result.resolvedDependencies[0].name).toBe('dep-a');
+    expect(result.resolvedDependencies[0].version).toBe('1.2.0');
+  });
+
+  it('installPlugin rejects missing name', async () => {
+    const mp = createMarketplace();
+    await expect(
+      mp.installPlugin(makeManifest({ name: '' }))
+    ).rejects.toThrow('name');
+  });
+
+  it('installPlugin rejects missing version', async () => {
+    const mp = createMarketplace();
+    await expect(
+      mp.installPlugin(makeManifest({ version: '' }))
+    ).rejects.toThrow('version');
+  });
+
+  it('installPlugin rejects missing entryPoint', async () => {
+    const mp = createMarketplace();
+    await expect(
+      mp.installPlugin(makeManifest({ entryPoint: '' }))
+    ).rejects.toThrow('entryPoint');
+  });
+
+  it('installPlugin rejects circular dependencies', async () => {
+    const mp = createMarketplace();
+    // Register A depending on B
+    mp.registry.register(
+      makeManifest({ name: 'a', version: '1.0.0', dependencies: { b: '^1.0.0' } })
+    );
+    // Register B depending on A
+    mp.registry.register(
+      makeManifest({ name: 'b', version: '1.0.0', dependencies: { a: '^1.0.0' } })
+    );
+
+    // Try to install C which depends on A (which has a cycle with B)
+    // Actually, let's create a direct cycle: install a plugin that creates a cycle
+    await expect(
+      mp.installPlugin(
+        makeManifest({ name: 'a', version: '2.0.0', dependencies: { b: '^1.0.0' } })
+      )
+    ).rejects.toThrow('Circular dependency');
+  });
+
+  it('installPlugin handles sandbox errors gracefully', async () => {
+    const mp = createMarketplace();
+    const result = await mp.installPlugin(
+      makeManifest({ entryPoint: 'throw new Error("init failed")' })
+    );
+    expect(result.executionResult.success).toBe(false);
+    expect(result.executionResult.error).toContain('init failed');
+  });
+});
diff --git a/src/index.ts b/src/index.ts
