rom spec)', () => {\n    // From the problem: target [T, T, F, T] with buttons {0,1}, {1,2,3}, {0,3}\n    // The system is inconsistent\n    const result = solveToggle({\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('should solve a simple single-button toggle', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should solve a two-button toggle', () => {\n    // Lights: 3, target: [T, F, T]\n    // Button 0: toggles [0, 1]\n    // Button 1: toggles [1, 2]\n    // Press both: light 0 = on, light 1 = on^on = off, light 2 = on -> [T, F, T]\n    const result = solveToggle({\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2]],\n    });\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('should return the minimum number of presses', () => {\n    // Light 0 needs to be on.\n    // Button 0: toggles [0]\n    // Button 1: toggles [0]\n    // Button 2: toggles [0]\n    // Best: press just one button (button 0, lexicographically smallest)\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should return lexicographically smallest among minimum solutions', () => {\n    // Light 0 needs to be on.\n    // Button 0: toggles [0]\n    // Button 1: toggles [0]\n    // Both single-press solutions: [0] or [1]. Lex smallest = [0]\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle all lights on target', () => {\n    // 2 lights, target [T, T]\n    // Button 0: toggles [0, 1] -> press button 0 to get [T, T]\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0, 1]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle identity-like buttons', () => {\n    // Each button toggles exactly one light\n    const result = solveToggle({\n      target: [true, false, true],\n      buttons: [[0], [1], [2]],\n    });\n    expect(result).toEqual([0, 2]);\n  });\n\n  it('should handle no buttons', () => {\n    // Target is all off, no buttons needed\n    const result = solveToggle({\n      target: [false, false],\n      buttons: [],\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('should return null with no buttons but non-trivial target', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [],\n    });\n    expect(result).toBeNull();\n  });\n\n  it('should handle redundant buttons correctly', () => {\n    // target: [T, T]\n    // Button 0: [0]\n    // Button 1: [1]\n    // Button 2: [0, 1]\n    // Options: {0,1} (2 presses) or {2} (1 press)\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0], [1], [0, 1]],\n    });\n    expect(result).toEqual([2]);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('should return all zeros when target is all zero', () => {\n    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('should solve a simple single-button counter', () => {\n    // Counter 0 needs value 3 (mod 5)\n    // Button 0 affects counter 0\n    // Press 3 times\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('should solve a two-counter system', () => {\n    // Counter 0 needs 1, counter 1 needs 1 (mod 5)\n    // Button 0: affects [0, 1]\n    // Press once: both counters = 1\n    const result = solveCounter([1, 1], [[0, 1]], 5);\n    expect(result).toEqual([1]);\n  });\n\n  it('should return null when no solution exists', () => {\n    // Counter 0 needs 1, counter 1 needs 2 (mod 5)\n    // Button 0: affects [0, 1] (increments both by same amount)\n    // No single button can set different values\n    const result = solveCounter(