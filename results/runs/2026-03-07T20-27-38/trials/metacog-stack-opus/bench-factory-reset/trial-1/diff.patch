lf1-1 and mask2 covers bits half1..numFree-1\n  //\n  // The pivot variable's contribution depends on both halves through XOR.\n  // We can characterize each half by its \"signature\" — for each pivot variable,\n  // the parity of the overlap with that half's free variables.\n  //\n  // Signature = for each pivot, parity(freeMask_low & mask1)\n  // Combined: pivot_val = rhs XOR sig1[p] XOR sig2[p]\n  //\n  // For a given (sig1, sig2), each pivot var's value is determined.\n  // Total weight = weight(mask1) + weight(mask2) + sum_p(rhs_p XOR sig1_p XOR sig2_p)\n\n  // Number of pivot variables\n  const numPivots = pivotInfo.length;\n\n  // For first half: enumerate all 2^half1 masks\n  // Build a map: signature -> {minWeight, bestMask}\n  // Signature is an array of bits (one per pivot), encoded as a number\n\n  // Actually, for each pivot, the \"low signature bit\" is parity(pivot.freeMask_low & mask1)\n  // where freeMask_low = pivot.freeMask & ((1 << half1) - 1)\n  const lowMasks = pivotInfo.map(p => p.freeMask & ((1 << half1) - 1));\n  const highMasks = pivotInfo.map(p => (p.freeMask >> half1) & ((1 << half2) - 1));\n\n  // For the first half, signature is a numPivots-bit number\n  // For each signature, we want the minimum-weight mask1, with lex-smallest as tiebreaker\n\n  // However, numPivots can be up to 40, so signatures could be 2^40 different values.\n  // In practice, many signatures will be the same for different mask1 values.\n\n  // Actually, the signature space is at most min(2^half1, 2^numPivots).\n  // With half1 ~20, that's at most 2^20 entries in the map. That's manageable.\n\n  // For first half: enumerate all 2^half1 masks\n  // Compute signature (numPivots bits) and weight (popcount of mask1 + base pivot contribution)\n\n  // But we also need to track which buttons in the first half are free buttons being pressed.\n  // And we need to account for the actual button indices for lex comparison.\n\n  // Simpler approach: we enumerate first half, store per-signature the best (weight, mask).\n  // Then enumerate second half, look up complementary signature, combine.\n\n  // For combining: total_weight = weight1(mask1) + weight2(mask2) + pivot_weight(sig1 XOR sig2)\n  // where pivot_weight depends on rhs XOR sig1 XOR sig2 for each pivot.\n\n  // But pivot_weight changes with the combination. Let's define:\n  // For a given combined signature s = sig1 XOR sig2:\n  //   pivot_weight(s) = sum_p(rhs_p XOR s_p)\n  // Total = freeWeight1 + freeWeight2 + pivot_weight(sig1 XOR sig2)\n\n  // We want to minimize: freeWeight1 + freeWeight2 + pivot_weight(sig1 XOR sig2)\n\n  // For each value of combinedSig = sig1 XOR sig2, we want minimum freeWeight1 + freeWeight2.\n  // For a given combinedSig c, we need sig1 XOR sig2 = c, so sig2 = sig1 XOR c.\n  // For each sig1 in our first-half map, we need sig2 = sig1 XOR c in the second-half map.\n\n  // Strategy:\n  // 1. Build map1: sig1 -> (minFreeWeight1, bestMask1) for first half\n  // 2. Build map2: sig2 -> (minFreeWeight2, bestMask2) for second half\n  // 3. For each possible combinedSig c (up to 2^numPivots):\n  //    a. Compute pivotWeight = sum_p(rhs_p XOR c_p)\n  //    b. For each sig1 in map1, check if sig1 XOR c exists in map2\n  //    c. Track minimum total\n\n  // But 2^numPivots could be 2^40, too many for outer loop.\n  // Better: iterate over all sig1 in map1 × all sig2 in map2 directly.\n\n  // map1 has at most 2^half1 entries (~2^20 = 1M entries)\n  // map2 has at most 2^half2 entries (~2^20 = 1M entries)\n  // Direct product is 2^40, too much.\n\n  // Better approach: for each sig2 in map2:\n  //   for each possible combinedSig c:\n  //     look up sig1 = sig2 XOR c in map1\n  // But this is still bounded by |map2| * 2^numPivots.\n\n  // The right approach: for each sig1 in map1, for each sig2 in map2:\n  //   compute c = sig1 XOR sig2\n  //   compute pivotWeight(c)\n  //   total = fw1 + fw2 + pivotWeight(c)\n  // But |map1| * |map2| is still potentially 2^40.\n\n  // However, in practice map sizes are much smaller since many masks map\n  // to the same signature. And the maps are keyed by signature, not by mask.\n  // The number of distinct signatures is bounded by min(2^half, 2^numPivots).\n  // With numPivots <= 40, and half ~20, distinct signatures <= 2^20.\n\n  // So: iterate over distinct sig1 values and distinct sig2 values.\n  // Each map has at most 2^20 distinct signatures.\n  // But 2^20 * 2^20 = 2^40 pairs, still too many.\n\n  // We need a smarter approach. Since pivot_weight(c) only depends on c,\n  // and we want to minimize fw1 + fw2 + pivot_weight(c) where c = sig1 XOR sig2:\n  //\n  // For each sig1 in map1:\n  //   For each sig2 in map2:\n  //     total = map1[sig1].fw + map2[sig2].fw + pivotWeight(sig1 XOR sig2)\n  //\n  // This can be rewritten: for each sig1, we want to find sig2 that minimizes\n  //   map2[sig2].fw + pivotWeight(sig1 XOR sig2)\n  //\n  // If we precompute for each sig2: f(sig2, sig1) = map2[sig2].fw + pivotWeight(sig1 XOR sig2),\n  // we want min over sig2. This is a XOR convolution problem.\n\n  // For now, since the constraint says up to 40 buttons and 40 lights,\n  // the maximum rank is 40, so at most 0 free variables if the system has full rank.\n  // In practice with 40 lights and 40 buttons, free vars = max(0, 40 - rank).\n  // With a random matrix, rank ≈ min(40, 40) = 40, so numFree ≈ 0.\n  // Free vars only exist when buttons are linearly dependent.\n\n  // Let's use a practical limit: if numFree > 30 (extremely unlikely), fall back to heuristic.\n  // For numFree <= 30, MITM with half ~15 each, map sizes 2^15 = 32768.\n  // For each sig1, iterate all sig2: 32768 * 32768 = 1 billion. Still too slow.\n\n  // Better: for each sig1, we want to minimize over sig2:\n  //   map2[sig2].fw + pivotWeight(sig1 XOR sig2)\n  // Let target_sig2 = sig1 XOR c* where c* minimizes pivotWeight(c) + map2[sig1 XOR c].fw\n  // This is equivalent to finding the best sig2.\n\n  // Actually, let's just do it differently. Group by combinedSig c:\n  // For each c, precompute pivotWeight(c).\n  // For each c, find min(map1[sig1].fw) + min(map2[sig1 XOR c].fw) over sig1.\n  // But this requires iterating over sig1 for each c.\n\n  // Alternative cleaner approach for the toggle case:\n  // Use the fact that we want minimum Hamming weight.\n  // Enumerate first half, build map: signature -> list of (freeWeight, mask1) sorted by weight.\n  // For second half, enumerate, compute needed sig1 = sig2 XOR c for all interesting c,\n  // look up in map.\n\n  // Let me take a completely different approach that's simpler and practical:\n  // Since numPivots <= 40 and numFree <= 40-rank, and the total is 40,\n  // we know numFree + rank = numButtons <= 40 (but rank <= numLights <= 40).\n  // In the worst case numFree could be 40 if rank = 0 (all buttons affect no lights,\n  // but then target must be all false, and any solution works, best is empty set).\n\n  // Practically, for the given constraint of 40 buttons, let me use MITM properly:\n\n  // Split free vars into halves A (half1 bits) and B (half2 bits).\n  // For each assignment of A (2^half1 combos):\n  //   Compute:\n  //   - freeWeightA = popcount of A bits set\n  //   - For each pivot var p: parity_A_p = popcount(lowMasks[p] & maskA) & 1\n  //   - signatureA = concat of parity_A_p for all pivots (numPivots-bit number)\n  //   Store in mapA keyed by signatureA: { freeWeight, maskA }\n  //     Keep only the best (min weight, then lex smallest mask) per signature.\n\n  // For each assignment of B (2^half2 combos):\n  //   Compute signatureB similarly using highMasks\n  //   For each pivot var p, the combined parity is parity_A_p XOR parity_B_p\n  //   The pivot var value = rhs_p XOR combinedParity_p\n  //   So for a given B with signatureB, we need signatureA such that\n  //   for each pivot p: rhs_p XOR (sigA_p XOR sigB_p) gives the best weight.\n  //\n  //   Actually, the pivot variables' total contribution depends on the combined signature.\n  //   We can't optimize A and B independently because their combination determines pivot weights.\n\n  // OK here's the final practical approach. Since numPivots <= 40 but the signature\n  // is only numPivots bits, and numPivots could be up to 40, the signature space is huge.\n  // But the number of DISTINCT signatures from each half is at most 2^half (~2^20).\n\n  // For each pair (sigA, sigB), compute:\n  //   combined_sig = sigA XOR sigB\n  //   pivotWeight = number of pivots where rhs XOR combined_sig bit = 1\n  //   totalWeight = fwA + fwB + pivotWeight\n\n  // To avoid 2^20 * 2^20 = 2^40 pairs, we use the following optimization:\n  // For each sigB in mapB:\n  //   For each sigA in mapA:\n  //     This is still 2^40. We need another approach.\n\n  // CRITICAL INSIGHT: the signature has at most numPivots bits, but the PRACTICAL\n  // number of distinct signatures is at most min(2^half, 2^numPivots).\n  // If numPivots is small (say <= 20), then there are at most 2^numPivots distinct\n  // combined signatures, and we can iterate over those efficiently.\n  // If numPivots > 20, then we have at most 2^20 entries in each map.\n\n  // For the problem constraints (40 buttons, 40 lights), if numFree > 20,\n  // then rank = numButtons - numFree < 20, so numPivots < 20.\n  // This means 2^numPivots < 2^20 = 1M.\n  // We can precompute pivotWeight for all 2^numPivots combined signatures.\n  // Then for each combinedSig c:\n  //   Find best sigA, sigB with sigA XOR sigB = c\n  //   by looking up min(mapA[sigA].fw) + min(mapB[sigA XOR c].fw) over sigA\n\n  // Since |mapA| <= 2^half1 and we iterate over all sigA for each c:\n  //   Total work: 2^numPivots * |mapA| which is at most 2^20 * 2^20 = 2^40. Still too much.\n\n  // But wait: if numFree > 20, then numPivots < 20, so 2^numPivots is small.\n  // And |mapA| <= 2^half1 = 2^(numFree/2).\n  // Total = 2^numPivots * 2^(numFree/2).\n  // If numFree = 40, numPivots = 0, total = 1 * 2^20 = 1M. Fine.\n  // If numFree = 30, numPivots = 10, total = 1024 * 2^15 = 32M. OK.\n  // If numFree = 20, numPivots = 20, total = 1M * 2^10 = 1G. Borderline.\n\n  // Actually when numFree = 20, we already handle it with direct enumeration (2^20 = 1M).\n  // So MITM is only needed for numFree > 20. Then numPivots < 20.\n\n  // Let's use: for each combinedSig c (2^numPivots values):\n  //   Build best-of-mapB for this c: for each sigA in mapA, look up mapB[sigA XOR c]\n  //   This is |mapA| lookups per c.\n  //   But we can flip it: for each c, iterate mapB entries and look up mapA.\n  //   Total = sum over c of min(|mapA|, |mapB|) = 2^numPivots * 2^(numFree/2)\n\n  // For numFree > 20: numPivots = 40 - numFree < 20.\n  // 2^numPivots * 2^(numFree/2) <= 2^20 * 2^20 = 2^40 when numPivots + numFree/2 = 40.\n  // That's numPivots = 40 - numFree, so (40-numFree) + numFree/2 = 40 - numFree/2.\n  // Max is when numFree = 0: 40. But numFree > 20, so max = 40 - 10 = 30. 2^30 = 1G. Still too much.\n\n  // Different strategy: just iterate mapA entries × mapB entries since\n  // |mapA| = distinct signatures in A ≤ 2^min(half1, numPivots)\n  // |mapB| = distinct signatures in B ≤ 2^min(half2, numPivots)\n  // Product ≤ 2^(min(h1,np) + min(h2,np))\n  // When np < 20: product ≤ 2^(np + np) = 2^(2*np) ≤ 2^38. Hmm still large.\n\n  // Actually I think for the given constraints (up to 40), the worst case of numFree\n  // is bounded. With 40 lights and 40 buttons, and buttons affecting subsets,\n  // rank is usually close to min(numLights, numButtons). Let me just set the\n  // threshold for direct enumeration at 25 (2^25 = 33M, ~1-2 seconds),\n  // and use MITM for the rest.\n\n  // For MITM: enumerate half1 (2^~13 = 8K), for each compute full solution's weight.\n  // Store in map: signature -> best (weight, mask).\n  // Then enumerate half2, look up matching entries.\n\n  // Actually, the simplest correct MITM:\n  // For each maskA (first half1 free vars assigned), compute:\n  //   - the partial solution (only free vars in first half assigned)\n  //   - this determines some of the solution bits\n  //   For each maskB (second half2 free vars assigned), compute:\n  //   - the full solution (all free vars assigned)\n  //   - count total weight\n\n  // To make MITM work, the weight must decompose. Let's think about it:\n  // x[freeVar_f] = bit f of full mask (either in A or B)\n  // x[pivotVar_p] = rhs_p XOR parity(pivotFreeMask_p & fullMask)\n  //               = rhs_p XOR parity(lowMask_p & maskA) XOR parity(highMask_p & maskB)\n  // Weight of pivot p = rhs_p XOR parA_p XOR parB_p\n  // Total free weight = popcount(maskA) + popcount(maskB)\n  // Total pivot weight = sum_p(rhs_p XOR parA_p XOR parB_p)\n  //\n  // Total = popcnt(maskA) + popcnt(maskB) + sum_p(rhs_p XOR parA_p XOR parB_p)\n  //\n  // The last sum depends on parA XOR parB for each pivot. It's not separable.\n  // But if we define sigA = (parA_0, parA_1, ..., parA_{np-1}) as a numPivots-bit number,\n  // and similarly sigB, then:\n  //   pivotWeight = sum_p(rhs_p XOR (sigA_p XOR sigB_p))\n  //   This depends on sigA XOR sigB.\n  //\n  // So total = popcnt(maskA) + popcnt(maskB) + pivotWeight(sigA XOR sigB)\n  //\n  // For MITM: group first-half results by sigA. For each sigA, keep best (min popcnt, lex smallest).\n  // Then for each second-half maskB with sigB:\n  //   For each possible target combined sig c (2^numPivots options):\n  //     need sigA = sigB XOR c\n  //     look up mapA[sigA XOR c] => fwA\n  //     total = fwA + fwB + pivotWeight(c)\n  //\n  // But iterating over all c for each maskB is 2^numPivots per maskB.\n  // Total: 2^half2 * 2^numPivots. With half2 ~20 and numPivots ~20: 2^40. No good.\n  //\n  // Better: for each maskB with sigB, iterate over all sigA in mapA:\n  //   c = sigA XOR sigB\n  //   total = mapA[sigA].fw + fwB + pivotWeight(c)\n  // Total: 2^half2 * |mapA| where |mapA| <= 2^half1.\n  // This is just 2^half1 * 2^half2 = 2^numFree. Same as brute force!\n  //\n  // The MITM advantage comes when |mapA| << 2^half1 because many masks\n  // map to the same signature. This happens when half1 > numPivots,\n  // giving |mapA| <= 2^numPivots.\n  //\n  // When numFree = 30, numPivots = 10, half1 = 15:\n  //   |mapA| = min(2^15, 2^10) = 1024\n  //   Total: 2^15 * 1024 = 32M. Fine!\n  //\n  // When numFree = 25, numPivots = 15, half1 = 12:\n  //   |mapA| = min(2^12, 2^15) = 4096\n  //   Total: 2^13 * 4096 = 32M. Fine!\n  //\n  // When numFree = 20, numPivots = 20, half1 = 10:\n  //   |mapA| = min(2^10, 2^20) = 1024\n  //   Total: 2^10 * 1024 = 1M. Fine!\n  //\n  // So |mapA| is always bounded by 2^min(half1, numPivots) and the total work is\n  // 2^half2 * 2^min(half1, numPivots).\n  // With numFree + numPivots = numButtons <= 40 and half1 + half2 = numFree:\n  //   work = 2^half2 * 2^min(half1, numPivots)\n  //   <= 2^(numFree - half1) * 2^min(half1, 40-numFree)\n  //\n  // To minimize, pick half1 = min(numFree, numPivots) if possible.\n  // But half1 + half2 = numFree, so half1 <= numFree.\n  // Set half1 = min(floor(numFree/2), numPivots) for balance? No.\n  //\n  // Actually let's just try: half1 = floor(numFree/2), and the product is:\n  // 2^ceil(numFree/2) * min(2^floor(numFree/2), 2^numPivots)\n  // Since numPivots = numButtons - numFree, and numFree > 20 implies numPivots < 20:\n  // = 2^ceil(numFree/2) * 2^min(floor(numFree/2), numPivots)\n  // Worst case: numFree = 30, numPivots = 10: 2^15 * 2^10 = 2^25 = 33M. Fine!\n  // numFree = 40, numPivots = 0: 2^20 * 2^0 = 1M. Fine!\n\n  // Let's implement this.\n\n  // Compute signatures for first half\n  type MapEntry = { freeWeight: number; maskA: number; fullMask: number };\n  const mapA = new Map<number, MapEntry>();\n\n  const size1 = 1 << half1;\n  for (let maskA = 0; maskA < size1; maskA++) {\n    let sigA = 0;\n    for (let p = 0; p < numPivots; p++) {\n      const par = popcount(lowMasks[p] & maskA) & 1;\n      if (par) sigA |= (1 << p);\n    }\n    const fw = popcount(maskA);\n    const existing = mapA.get(sigA);\n    if (!existing || fw < existing.freeWeight ||\n        (fw === existing.freeWeight && maskA < existing.maskA)) {\n      mapA.set(sigA, { freeWeight: fw, maskA, fullMask: maskA });\n    }\n  }\n\n  // Precompute pivotWeight for all possible combined signatures\n  const numSigs = 1 << numPivots;\n  const pivotWeights = new Array(numSigs);\n  for (let c = 0; c < numSigs; c++) {\n    let w = 0;\n    for (let p = 0; p < numPivots; p++) {\n      const bit = (c >> p) & 1;\n      w += pivotInfo[p].rhs ^ bit;\n    }\n    pivotWeights[c] = w;\n  }\n\n  let bestWeight = numButtons + 1;\n  let bestFullMask = 0; // full numFree-bit mask of free vars\n\n  const size2 = 1 << half2;\n  for (let maskB = 0; maskB < size2; maskB++) {\n    let sigB = 0;\n    for (let p = 0; p < numPivots; p++) {\n      const par = popcount(highMasks[p] & maskB) & 1;\n      if (par) sigB |= (1 << p);\n    }\n    const fwB = popcount(maskB);\n    const fullMaskB = maskB << half1;\n\n    // Iterate over all entries in mapA\n    for (const [sigA, entryA] of mapA) {\n      const c = sigA ^ sigB;\n      const totalWeight = entryA.freeWeight + fwB + pivotWeights[c];\n\n      const fullMask = entryA.maskA | fullMaskB;\n\n      if (totalWeight < bestWeight) {\n        bestWeight = totalWeight;\n        bestFullMask = fullMask;\n      } else if (totalWeight === bestWeight) {\n        // Compare solutions lexicographically\n        const solNew = computeToggleSolution(fullMask, numButtons, numFree, freeVars, pivotInfo);\n        const solOld = computeToggleSolution(bestFullMask, numButtons, numFree, freeVars, pivotInfo);\n        const pressedNew = solutionToPressed(solNew, numButtons);\n        const pressedOld = solutionToPressed(solOld, numButtons);\n        if (isLexSmaller(pressedNew, pressedOld)) {\n          bestFullMask = fullMask;\n        }\n      }\n    }\n  }\n\n  const bestX = computeToggleSolution(bestFullMask, numButtons, numFree, freeVars, pivotInfo);\n  return solutionToPressed(bestX, numButtons);\n}\n\nfunction isLexSmaller(a: number[], b: number[]): boolean {\n  if (a.length !== b.length) return a.length < b.length;\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) return a[i] < b[i];\n  }\n  return false;\n}\n\n\n// ─── GF(p) Counter Solver ───────────────────────────────────────────\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | b] over GF(p)\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p) with full reduction (RREF)\n  const pivotCol: number[] = [];\n  const pivotRow: number[] = new Array(numButtons).fill(-1);\n  let currentRow = 0;\n\n  for (let col = 0; col < numButtons && currentRow < numCounters; col++) {\n    let pr = -1;\n    for (let r = currentRow; r < numCounters; r++) {\n      if (matrix[r][col] !== 0) { pr = r; break; }\n    }\n    if (pr === -1) continue;\n\n    [matrix[currentRow], matrix[pr]] = [matrix[pr], matrix[currentRow]];\n    pivotCol.push(col);\n    pivotRow[col] = currentRow;\n\n    const inv = modInverse(matrix[currentRow][col], modulus);\n    for (let c = col; c <= numButtons; c++) {\n      matrix[currentRow][c] = (matrix[currentRow][c] * inv) % modulus;\n    }\n\n    for (let r = 0; r < numCounters; r++) {\n      if (r !== currentRow && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let c = col; c <= numButtons; c++) {\n          matrix[r][c] = (((matrix[r][c] - factor * matrix[currentRow][c]) % modulus) + modulus) % modulus;\n  