ree, freeVars, pivotInfo);\n   100→}\n   101→\n   102→function computeToggleSolution(\n   103→  freeMask: number,\n   104→  numButtons: number,\n   105→  numFree: number,\n   106→  freeVars: number[],\n   107→  pivotInfo: { col: number; rhs: number; freeMask: number }[]\n   108→): number[] {\n   109→  const x = new Array(numButtons).fill(0);\n   110→  for (let f = 0; f < numFree; f++) {\n   111→    x[freeVars[f]] = (freeMask >> f) & 1;\n   112→  }\n   113→  for (const p of pivotInfo) {\n   114→    // Count bits in intersection of freeMask and p.freeMask\n   115→    const overlap = freeMask & p.freeMask;\n   116→    const bitCount = popcount(overlap);\n   117→    x[p.col] = p.rhs ^ (bitCount & 1);\n   118→  }\n   119→  return x;\n   120→}\n   121→\n   122→function popcount(n: number): number {\n   123→  n = n - ((n >> 1) & 0x55555555);\n   124→  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);\n   125→  return (((n + (n >> 4)) & 0x0F0F0F0F) * 0x01010101) >> 24;\n   126→}\n   127→\n   128→function solutionToPressed(x: number[], numButtons: number): number[] {\n   129→  const pressed: number[] = [];\n   130→  for (let j = 0; j < numButtons; j++) {\n   131→    if (x[j] === 1) pressed.push(j);\n   132→  }\n   133→  return pressed;\n   134→}\n   135→\n   136→function solveToggleEnumerate(\n   137→  numButtons: number,\n   138→  numFree: number,\n   139→  freeVars: number[],\n   140→  pivotInfo: { col: number; rhs: number; freeMask: number }[]\n   141→): number[] {\n   142→  let bestSolution: number[] | null = null;\n   143→  let bestCount = numButtons + 1;\n   144→\n   145→  const total = 1 << numFree;\n   146→  for (let mask = 0; mask < total; mask++) {\n   147→    const x = computeToggleSolution(mask, numButtons, numFree, freeVars, pivotInfo);\n   148→    const pressed = solutionToPressed(x, numButtons);\n   149→\n   150→    if (pressed.length < bestCount ||\n   151→        (pressed.length === bestCount && isLexSmaller(pressed, bestSolution!))) {\n   152→      bestCount = pressed.length;\n   153→      bestSolution = pressed;\n   154→    }\n   155→  }\n   156→\n   157→  return bestSolution!;\n   158→}\n   159→\n   160→function solveToggleMITM(\n   161→  numButtons: number,\n   162→  numFree: number,\n   163→  freeVars: number[],\n   164→  pivotInfo: { col: number; rhs: number; freeMask: number }[]\n   165→): number[] {\n   166→  // Split free variables into two halves\n   167→  const half1 = Math.floor(numFree / 2);\n   168→  const half2 = numFree - half1;\n   169→\n   170→  // For the first half, we enumerate all 2^half1 combinations.\n   171→  // For each, we compute the \"effect\" on each pivot variable and count total weight.\n   172→  // Then for the second half, we enumerate and combine.\n   173→\n   174→  // Key insight: after RREF, each pivot variable's value is determined by:\n   175→  //   pivot_val = rhs XOR parity(freeMask & full_free_assignment)\n   176→  // The weight (number of pressed buttons) = sum of free vars + sum of pivot vars.\n   177→  //\n   178→  // We need to minimize total weight across all buttons.\n   179→  //\n   180→  // For each pivot variable with freeMask m:\n   181→  //   pivot_val = rhs XOR parity((m & mask1) XOR (m & mask2))\n   182→  //   where mask1 covers bits 0..half1-1 and mask2 covers bits half1..numFree-1\n   183→  //\n   184→  // The pivot variable's contribution depends on both halves through XOR.\n   185→  // We can characterize each half by its \"signature\" — for each pivot variable,\n   186→  // the parity of the overlap with that half's free variables.\n   187→  //\n   188→  // Signature = for each pivot, parity(freeMask_low & mask1)\n   189→  // Combined: pivot_val = rhs XOR sig1[p] XOR sig2[p]\n   190→  //\n   191→  // For a given (sig1, sig2), each pivot var's value is determined.\n   192→  // Total weight = weight(mask1) + weight(mask2) + sum_p(rhs_p XOR sig1_p XOR sig2_p)\n   193→\n   194→  // Number of pivot variables\n   195→  const numPivots = pivotInfo.length;\n   196→\n   197→  // For first half: enumerate all 2^half1 masks\n   198→  // Build a map: signature -> {minWeight, bestMask}\n   199→  // Signature is an array of bits (one per pivot), encoded as a number\n   200→\n   201→  // Actually, for each pivot, the \"low signature bit\" is parity(pivot.freeMask_low & mask1)\n   202→  // where freeMask_low = pivot.freeMask & ((1 << half1) - 1)\n   203→  const lowMasks = pivotInfo.map(p => p.freeMask & ((1 << half1) - 1));\n   204→  const highMasks = pivotInfo.map(p => (p.freeMask >> half1) & ((1 << half2) - 1));\n   205→\n   206→  // For the first half, signature is a numPivots-bit number\n   207→  // For each signature, we want the minimum-weight mask1, with lex-smallest as tiebreaker\n   208→\n   209→  // However, numPivots can be up to 40, so signatures could be 2^40 different values.\n   210→  // In practice, many signatures will be the same for different mask1 values.\n   211→\n   212→  // Actually, the signature space is at most min(2^half1, 2^numPivots).\n   213→  // With half1 ~20, that's at most 2^20 entries in the map. That's manageable.\n   214→\n   215→  // For first half: enumerate all 2^half1 masks\n   216→  // Compute signature (numPivots bits) and weight (popcount of mask1 + base pivot contribution)\n   217→\n   218→  // But we also need to track which buttons in the first half are free buttons being pressed.\n   219→  // And we need to account for the actual button indices for lex comparison.\n   220→\n   221→  // Simpler approach: we enumerate first half, store per-signature the best (weight, mask).\n   222→  // Then enumerate second half, look up complementary signature, combine.\n   223→\n   224→  // For combining: total_weight = weight1(mask1) + weight2(mask2) + pivot_weight(sig1 XOR sig2)\n   225→  // where pivot_weight depends on rhs XOR sig1 XOR sig2 for each pivot.\n   226→\n   227→  // But pivot_weight changes with the combination. Let's define:\n   228→  // For a given combined signature s = sig1 XOR sig2:\n   229→  //   pivot_weight(s) = sum_p(rhs_p XOR s_p)\n   230→  // Total = freeWeight1 + freeWeight2 + pivot_weight(sig1 XOR sig2)\n   231→\n   232→  // We want to minimize: freeWeight1 + freeWeight2 + pivot_weight(sig1 XOR sig2)\n   233→\n   234→  // For each value of combinedSig = sig1 XOR sig2, we want minimum freeWeight1 + freeWeight2.\n   235→  // For a given combinedSig c, we need sig1 XOR sig2 = c, so sig2 = sig1 XOR c.\n   236→  // For each sig1 in our first-half map, we need sig2 = sig1 XOR c in the second-half map.\n   237→\n   238→  // Strategy:\n   239→  // 1. Build map1: sig1 -> (minFreeWeight1, bestMask1) for first half\n   240→  // 2. Build map2: sig2 -> (minFreeWeight2, bestMask2) for second half\n   241→  // 3. For each possible combinedSig c (up to 2^numPivots):\n   242→  //    a. Compute pivotWeight = sum_p(rhs_p XOR c_p)\n   243→  //    b. For each sig1 in map1, check if sig1 XOR c exists in map2\n   244→  //    c. Track minimum total\n   245→\n   246→  // But 2^numPivots could be 2^40, too many for outer loop.\n   247→  // Better: iterate over all sig1 in map1 × all sig2 in map2 directly.\n   248→\n   249→  // map1 has at most 2^half1 entries (~2^20 = 1M entries)\n   250→  // map2 has at most 2^half2 entries (~2^20 = 1M entries)\n   251→  // Direct product is 2^40, too much.\n   252→\n   253→  // Better approach: for each sig2 in map2:\n   254→  //   for each possible combinedSig c:\n   255→  //     look up sig1 = sig2 XOR c in map1\n   256→  // But this is still bounded by |map2| * 2^numPivots.\n   257→\n   258→  // The right approach: for each sig1 in map1, for each sig2 in map2:\n   259→  //   compute c = sig1 XOR sig2\n   260→  //   compute pivotWeight(c)\n   261→  //   total = fw1 + fw2 + pivotWeight(c)\n   262→  // But |map1| * |map2| is still potentially 2^40.\n   263→\n   264→  // However, in practice map sizes are much smaller since many masks map\n   265→  // to the same signature. And the maps are keyed by signature, not by mask.\n   266→  // The number of distinct signatures is bounded by min(2^half, 2^numPivots).\n   267→  // With numPivots <= 40, and half ~20, distinct signatures <= 2^20.\n   268→\n   269→  // So: iterate over distinct sig1 values and distinct sig2 values.\n   270→  // Each map has at most 2^20 distinct signatures.\n   271→  // But 2^20 * 2^20 = 2^40 pairs, still too many.\n   272→\n   273→  // We need a smarter approach. Since pivot_weight(c) only depends on c,\n   274→  // and we want to minimize fw1 + fw2 + pivot_weight(c) where c = sig1 XOR sig2:\n   275→  //\n   276→  // For each sig1 in map1:\n   277→  //   For each sig2 in map2:\n   278→  //     total = map1[sig1].fw + map2[sig2].fw + pivotWeight(sig1 XOR sig2)\n   279→  //\n   280→  // This can be rewritten: for each sig1, we want to find sig2 that minimizes\n   281→  //   map2[sig2].fw + pivotWeight(sig1 XOR sig2)\n   282→  //\n   283→  // If we precompute for each sig2: f(sig2, sig1) = map2[sig2].fw + pivotWeight(sig1 XOR sig2),\n   284→  // we want min over sig2. This is a XOR convolution problem.\n   285→\n   286→  // For now, since the constraint says up to 40 buttons and 40 lights,\n   287→  // the maximum rank is 40, so at most 0 free variables if the system has full rank.\n   288→  // In practice with 40 lights and 40 buttons, free vars = max(0, 40 - rank).\n   289→  // With a random matrix, rank ≈ min(40, 40) = 40, so numFree ≈ 0.\n   290→  // Free vars only exist when buttons are linearly dependent.\n   291→\n   292→  // Let's use a practical limit: if numFree > 30 (extremely unlikely), fall back to heuristic.\n   293→  // For numFree <= 30, MITM with half ~15 each, map sizes 2^15 = 32768.\n   294→  // For each sig1, iterate all sig2: 32768 * 32768 = 1 billion. Still too slow.\n   295→\n   296→  // Better: for each sig1, we want to minimize over sig2:\n   297→  //   map2[sig2].fw + pivotWeight(sig1 XOR sig2)\n   298→  // Let target_sig2 = sig1 XOR c* where c* minimizes pivotWeight(c) + map2[sig1 XOR c].fw\n   299→  // This is equivalent to finding the best sig2.\n   300→\n   301→  // Actually, let's just do it differently. Group by combinedSig c:\n   302→  // For each c, precompute pivotWeight(c).\n   303→  // For each c, find min(map1[sig1].fw) + min(map2[sig1 XOR c].fw) over sig1.\n   304→  // But this requires iterating over sig1 for each c.\n   305→\n   306→  // Alternative cleaner approach for the toggle case:\n   307→  // Use the fact that we want minimum Hamming weight.\n   308→  // Enumerate first half, build map: signature -> list of (freeWeight, mask1) sorted by weight.\n   309→  // For second half, enumerate, compute needed sig1 = sig2 XOR c for all interesting c,\n   310→  // look up in map.\n   311→\n   312→  // Let me take a completely different approach that's simpler and practical:\n   313→  // Since numPivots <= 40 and numFree <= 40-rank, and the total is 40,\n   314→  // we know numFree + rank = numButtons <= 40 (but rank <= numLights <= 40).\n   315→  // In the worst case numFree could be 40 if rank = 0 (all buttons affect no lights,\n   316→  // but then target must be all false, and any solution works, best is empty set).\n   317→\n   318→  // Practically, for the given constraint of 40 buttons, let me use MITM properly:\n   319→\n   320→  // Split free vars into halves A (half1 bits) and B (half2 bits).\n   321→  // For each assignment of A (2^half1 combos):\n   322→  //   Compute:\n   323→  //   - freeWeightA = popcount of A bits set\n   324→  //   - For each pivot var p: parity_A_p = popcount(lowMasks[p] & maskA) & 1\n   325→  //   - signatureA = concat of parity_A_p for all pivots (numPivots-bit number)\n   326→  //   Store in mapA keyed by signatureA: { freeWeight, maskA }\n   327→  //     Keep only the best (min weight, then lex smallest mask) per signature.\n   328→\n   329→  // For each assignment of B (2^half2 combos):\n   330→  //   Compute signatureB similarly using highMasks\n   331→  //   For each pivot var p, the combined parity is parity_A_p XOR parity_B_p\n   332→  //   The pivot var value = rhs_p XOR combinedParity_p\n   333→  //   So for a given B with signatureB, we need signatureA such that\n   334→  //   for each pivot p: rhs_p XOR (sigA_p XOR sigB_p) gives the best weight.\n   335→  //\n   336→  //   Actually, the pivot variables' total contribution depends on the combined signature.\n   337→  //   We can't optimize A and B independently because their combination determines pivot weights.\n   338→\n   339→  // OK here's the final practical approach. Since numPivots <= 40 but the signature\n   340→  // is only numPivots bits, and numPivots could be up to 40, the signature space is huge.\n   341→  // But the number of DISTINCT signatures from each half is at most 2^half (~2^20).\n   342→\n   343→  // For each pair (sigA, sigB), compute:\n   344→  //   combined_sig = sigA XOR sigB\n   345→  //   pivotWeight = number of pivots where rhs XOR combined_sig bit = 1\n   346→  //   totalWeight = fwA + fwB + pivotWeight\n   347→\n   348→  // To avoid 2^20 * 2^20 = 2^40 pairs, we use the following optimization:\n   349→  // For each sigB in mapB:\n   350→  //   For each sigA in mapA:\n   351→  //     This is still 2^40. We need another approach.\n   352→\n   353→  // CRITICAL INSIGHT: the signature has at most numPivots bits, but the PRACTICAL\n   354→  // number of distinct signatures is at most min(2^half, 2^numPivots).\n   355→  // If numPivots is small (say <= 20), then there are at most 2^numPivots distinct\n   356→  // combined signatures, and we can iterate over those efficiently.\n   357→  // If numPivots > 20, then we have at most 2^20 entries in each map.\n   358→\n   359→  // For the problem constraints (40 buttons, 40 lights), if numFree > 20,\n   360→  // then rank = numButtons - numFree < 20, so numPivots < 20.\n   361→  // This means 2^numPivots < 2^20 = 1M.\n   362→  // We can precompute pivotWeight for all 2^numPivots combined signatures.\n   363→  // Then for each combinedSig c:\n   364→  //   Find best sigA, sigB with sigA XOR sigB = c\n   365→  //   by looking up min(mapA[sigA].fw) + min(mapB[sigA XOR c].fw) over sigA\n   366→\n   367→  // Since |mapA| <= 2^half1 and we iterate over all sigA for each c:\n   368→  //   Total work: 2^numPivots * |mapA| which is at most 2^20 * 2^20 = 2^40. Still too much.\n   369→\n   370→  // But wait: if numFree > 20, then numPivots < 20, so 2^numPivots is small.\n   371→  // And |mapA| <= 2^half1 = 2^(numFree/2).\n   372→  // Total = 2^numPivots * 2^(numFree/2).\n   373→  // If numFree = 40, numPivots = 0, total = 1 * 2^20 = 1M. Fine.\n   374→  // If numFree = 30, numPivots = 10, total = 1024 * 2^15 = 32M. OK.\n   375→  // If numFree = 20, numPivots = 20, total = 1M * 2^10 = 1G. Borderline.\n   376→\n   377→  // Actually when numFree = 20, we already handle it with direct enumeration (2^20 = 1M).\n   378→  // So MITM is only needed for numFree > 20. Then numPivots < 20.\n   379→\n   380→  // Let's use: for each combinedSig c (2^numPivots values):\n   381→  //   Build best-of-mapB for this c: for each sigA in mapA, look up mapB[sigA XOR c]\n   382→  //   This is |mapA| lookups per c.\n   383→  //   But we can flip it: for each c, iterate mapB entries and look up mapA.\n   384→  //   Total = sum over c of min(|mapA|, |mapB|) = 2^numPivots * 2^(numFree/2)\n   385→\n   386→  // For numFree > 20: numPivots = 40 - numFree < 20.\n   387→  // 2^numPivots * 2^(numFree/2) <= 2^20 * 2^20 = 2^40 when numPivots + numFree/2 = 40.\n   388→  // That's numPivots = 40 - numFree, so (40-numFree) + numFree/2 = 40 - numFree/2.\n   389→  // Max is when numFree = 0: 40. But numFree > 20, so max = 40 - 10 = 30. 2^30 = 1G. Still too much.\n   390→\n   391→  // Different strategy: just iterate mapA entries × mapB entries since\n   392→  // |mapA| = distinct signatures in A ≤ 2^min(half1, numPivots)\n   393→  // |mapB| = distinct signatures in B ≤ 2^min(half2, numPivots)\n   394→  // Product ≤ 2^(min(h1,np) + min(h2,np))\n   395→  // When np < 20: product ≤ 2^(np + np) = 2^(2*np) ≤ 2^38. Hmm still large.\n   396→\n   397→  // Actually I think for the given constraints (up to 40), the worst case of numFree\n   398→  // is bounded. With 40 lights and 40 buttons, and buttons affecting subsets,\n   399→  // rank is usually close to min(numLights, numButtons). Let me just set the\n   400→  // threshold for direct enumeration at 25 (2^25 = 33M, ~1-2 seconds),\n   401→  // and use MITM for the rest.\n   402→\n   403→  // For MITM: enumerate half1 (2^~13 = 8K), for each compute full solution's weight.\n   404→  // Store in map: signature -> best (weight, mask).\n   405→  // Then enumerate half2, look up matching entries.\n   406→\n   407→  // Actually, the simplest correct MITM:\n   408→  // For each maskA (first half1 free vars assigned), compute:\n   409→  //   - the partial solution (only free vars in first half assigned)\n   410→  //   - this determines some of the solution bits\n   411→  //   For each maskB (second half2 free vars assigned), compute:\n   412→  //   - the full solution (all free vars assigned)\n   413→  //   - count total weight\n   414→\n   415→  // To make MITM work, the weight must decompose. Let's think about it:\n   416→  // x[freeVar_f] = bit f of full mask (either in A or B)\n   417→  // x[pivotVar_p] = rhs_p XOR parity(pivotFreeMask_p & fullMask)\n   418→  //               = rhs_p XOR parity(lowMask_p & maskA) XOR parity(highMask_p & maskB)\n   419→  // Weight of pivot p = rhs_p XOR parA_p XOR parB_p\n   420→  // Total free weight = popcount(maskA) + popcount(maskB)\n   421→  // Total pivot weight = sum_p(rhs_p XOR parA_p XOR parB_p)\n   422→  //\n   423→  // Total = popcnt(maskA) + popcnt(maskB) + sum_p(rhs_p XOR parA_p XOR parB_p)\n   424→  //\n   425→  // The last sum depends on parA XOR parB for each pivot. It's not separable.\n   426→  // But if we define sigA = (parA_0, parA_1, ..., parA_{np-1}) as a numPivots-bit number,\n   427→  // and similarly sigB, then:\n   428→  //   pivotWeight = sum_p(rhs_p XOR (sigA_p XOR sigB_p))\n   429→  //   This depends on sigA XOR sigB.\n   430→  //\n   431→  // So total = popcnt(maskA) + popcnt(maskB) + pivotWeight(sigA XOR sigB)\n   432→  //\n   433→  // For MITM: group first-half results by sigA. For each sigA, keep best (min popcnt, lex smallest).\n   434→  // Then for each second-half maskB with sigB:\n   435→  //   For each possible target combined sig c (2^numPivots options):\n   436→  //     need sigA = sigB XOR c\n   437→  //     look up mapA[sigA XOR c] => fwA\n   438→  //     total = fwA + fwB + pivotWeight(c)\n   439→  //\n   440→  // But iterating over all c for each maskB is 2^numPivots per maskB.\n   441→  // Total: 2^half2 * 2^numPivots. With half2 ~20 and numPivots ~20: 2^40. No good.\n   442→  //\n   443→  // Better: for each maskB with sigB, iterate over all sigA in mapA:\n   444→  //   c = sigA XOR sigB\n   445→  //   total = mapA[sigA].fw + fwB + pivotWeight(c)\n   446→  // Total: 2^half2 * |mapA| where |mapA| <= 2^half1.\n   447→  // This is just 2^half1 * 2^half2 = 2^numFree. Same as brute force!\n   448→  //\n   449→  // The MITM advantage comes when |mapA| << 2^half1 because many masks\n   450→  // map to the same signature. This happens when half1 > numPivots,\n   451→  // giving |mapA| <= 2^numPivots.\n   452→  //\n   453→  // When numFree = 30, numPivots = 10, half1 = 15:\n   454→  //   |mapA| = min(2^15, 2^10) = 1024\n   455→  //   Total: 2^15 * 1024 = 32M. Fine!\n   456→  //\n   457→  // When numFree = 25, numPivots = 15, half1 = 12:\n   458→  //   |mapA| = min(2^12, 2^15) = 4096\n   459→  //   Total: 2^13 * 4096 = 32M. Fine!\n   460→  //\n   461→  // When numFree = 20, numPivots = 20, half1 = 10:\n   462→  //   |mapA| = min(2^10, 2^20) = 1024\n   463→  //   Total: 2^10 * 1024 = 1M. Fine!\n   464→  //\n   465→  // So |mapA| is always bounded by 2^min(half1, numPivots) and the total work is\n   466→  // 2^half2 * 2^min(half1, numPivots).\n   467→  // With numFree + numPivots = numButtons <= 40 and half1 + half2 = numFree:\n   468→  //   work = 2^half2 * 2^min(half1, numPivots)\n   469→  //   <= 2^(numFree - half1) * 2^min(half1, 40-numFree)\n   470→  //\n   471→  // To minimize, pick half1 = min(numFree, numPivots) if possible.\n   472→  // But half1 + half2 = numFree, so half1 <= numFree.\n   473→  // Set half1 = min(floor(numFree/2), numPivots) for balance? No.\n   474→  //\n   475→  // Actually let's just try: half1 = floor(numFree/2), and the product is:\n   476→  // 2^ceil(numFree/2) * min(2^floor(numFree/2), 2^numPivots)\n   477→  // Since numPivots = numButtons - numFree, and numFree > 20 implies numPivots < 20:\n   478→  // = 2^ceil(numFree/2) * 2^min(floor(numFree/2), numPivots)\n   479→  // Worst case: numFree = 30, numPivots = 10: 2^15 * 2^10 = 2^25 = 33M. Fine!\n   480→  // numFree = 40, numPivots = 0: 2^20 * 2^0 = 1M. Fine!\n   481→\n   482→  // Let's implement this.\n   483→\n   484→  // Compute signatures for first half\n   485→  type MapEntry = { freeWeight: number; maskA: number; fullMask: number };\n   486→  const mapA = new Map<number, MapEntry>();\n   487→\n   488→  const size1 = 1 << half1;\n   489→  for (let maskA = 0; maskA < size1; maskA++) {\n   490→    let sigA = 0;\n   491→    for (let p = 0; p < numPivots; p++) {\n   492→      const par = popcount(lowMasks[p] & maskA) & 1;\n   493→      if (par) sigA |= (1 << p);\n   494→    }\n   495→    const fw = popcount(maskA);\n   496→    const existing = mapA.get(sigA);\n   497→    if (!existing || fw < existing.freeWeight ||\n   498→        (fw === existing.freeWeight && maskA < existing.maskA)) {\n   499→      mapA.set(sigA, { freeWeight: fw, maskA, fullMask: maskA });\n   500→    }\n   501→  }\n   502→\n   503→  // Precompute pivotWeight for all possible combined signatures\n   504→  const numSigs = 1 << numPivots;\n   505→  const pivotWeights = new Array(numSigs);\n   506→  for (let c = 0; c < numSigs; c++) {\n   507→    let w = 0;\n   508→    for (let p = 0; p < numPivots; p++) {\n   509→      const bit = (c >> p) & 1;\n   510→      w += pivotInfo[p].rhs ^ bit;\n   511→    }\n   512→    pivotWeights[c] = w;\n   513→  }\n   514→\n   515→  let bestWeight = numButtons + 1;\n   516→  let bestFullMask = 0; // full numFree-bit mask of free vars\n   517→\n   518→  const size2 = 1 << half2;\n   519→  for (let maskB = 0; maskB < size2; maskB++) {\n   520→    let sigB = 0;\n   521→    for (let p = 0; p < numPivots; p++) {\n   522→      const par = popcount(highMasks[p] & maskB) & 1;\n   523→      if (par) sigB |= (1 << p);\n   524→    }\n   525→    const fwB = popcount(maskB);\n   526→    const fullMaskB = maskB << half1;\n   527→\n   528→    // Iterate over all entries in mapA\n   529→    for (const [sigA, entryA] of mapA) {\n   530→      const c = sigA ^ sigB;\n   531→      const totalWeight = entryA.freeWeight + fwB + pivotWeights[c];\n   532→\n   533→      const fullMask = entryA.maskA | fullMaskB;\n   534→\n   535→      if (totalWeight < bestWeight) {\n   536→        bestWeight = totalWeight;\n   537→        bestFullMask = fullMask;\n   538→      } else if (totalWeight === bestWeight) {\n   539→        // Compare solutions lexicographically\n   540→        const solNew = computeToggleSolution(fullMask, numButtons, numFree, freeVars, pivotInfo);\n   541→        const solOld = computeToggleSolution(bestFullMask, numButtons, numFree, freeVars, pivotInfo);\n   542→        const pressedNew = solutionToPressed(solNew, numButtons);\n   543→        const pressedOld = solutionToPressed(solOld, numButtons);\n   544→        if (isLexSmaller(pressedNew, pressedOld)) {\n   545→          bestFullMask = fullMask;\n   546→        }\n   547→      }\n   548→    }\n   549→  }\n   550→\n   551→  const bestX = computeToggleSolution(bestFullMask, numButtons, numFree, freeVars, pivotInfo);\n   552→  return solutionToPressed(bestX, numButtons);\n   553→}\n   554→\n   555→function isLexSmaller(a: number[], b: number[]): boolean {\n   556→  if (a.length !== b.length) return a.length < b.length;\n   557→  for (let i = 0; i < a.length; i++) {\n   558→    if (a[i] !== b[i]) return a[i] < b[i];\n   559→  }\n   560→  return false;\n   561→}\n   562→\n   563→\n   564→// ─── GF(p) Counter Solver ───────────────────────────────────────────\n   565→\n   566→export function solveCounter(\n   567→  lights: number[],\n   568→  buttons: number[][],\n   569→  modulus: number\n   570→): number[] | null {\n   571→  const numCounters = lights.length;\n   572→  const numButtons = buttons.length;\n   573→\n   574→  // Build augmented matrix [A | b] over GF(p)\n   575→  const matrix: number[][] = [];\n   576→  for (let i = 0; i < numCounters; i++) {\n   577→    const row = new Array(numButtons + 1).fill(0);\n   578→    for (let j = 0; j < numButtons; j++) {\n   579→      if (buttons[j].includes(i)) {\n   580→        row[j] = 1;\n   581→      }\n   582→    }\n   583→    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;\n   584→    matrix.push(row);\n   585→  }\n   586→\n   587→  // Gaussian elimination over GF(p) with full reduction (RREF)\n   588→  const pivotCol: number[] = [];\n   589→  const pivotRow: number[] = new Array(numButtons).fill(-1);\n   590→  let currentRow = 0;\n   591→\n   592→  for (let col = 0; col < numButtons && currentRow < numCounters; col++) {\n   593→    let pr = -1;\n   594→    for (let r = currentRow; r < numCounters; r++) {\n   595→      if (matrix[r][col] !== 0) { pr = r; break; }\n   596→    }\n   597→    if (pr === -1) continue;\n   598→\n   599→    [matrix[currentRow], matrix[pr]] = [matrix[pr], matrix[currentRow]];\n   600→    pivotCol.push(col);\n   601→    pivotRow[col] = currentRow;\n   602→\n   603→    const inv = modInverse(matrix[currentRow][col], modulus);\n   604→    for (let c = col; c <= numButtons; c++) {\n   605→      matrix[currentRow][c] = (matrix[currentRow][c] * inv) % modulus;\n   606→    }\n   607→\n   608→    for (let r = 0; r < numCounters; r++) {\n   609→      if (r !== currentRow && matrix[r][col] !== 0) {\n   610→        const factor = matrix[r][col];\n   611→        for (let c = col; c <= numButtons; c++) {\n   612→          matrix[r][c] = (((matrix[r][c] - factor * matrix[currentRow][c]) % modulus) + modulus) % modulus;\n   613→        }\n   614→      }\n   615→    }\n   616→    currentRow++;\n   617→  }\n   618→\n   619→  const rank = currentRow;\n   620→\n   621→  // Check consistency\n   622→  for (let r = rank; r < numCounters; r++) {\n   623→    if (matrix[r][numButtons] !== 0) return null;\n   624→  }\n   625→\n   626→  // Identify free variables\n   627→  const freeVars: number[] = [];\n   628→  for (let col = 0; col < numButtons; col++) {\n   629→    if (pivotRow[col] === -1) freeVars.push(col);\n   630→  }\n   631→\n   632→  const numFree = freeVars.length;\n   633→  const numPivots = pivotCol.length;\n   634→\n   635→  // Precompute pivot info\n   636→  const pivotInfoC: { col: number; rhs: number; freeCoeffs: number[] }[] = [];\n   637→  for (let i = 0; i < numPivots; i++) {\n   638→    const freeCoeffs: number[] = [];\n   639→    for (let f = 0; f < numFree; f++) {\n   640→      freeCoeffs.push(matrix[i][freeVars[f]]);\n   641→    }\n   642→    pivotInfoC.push({ col: pivotCol[i], rhs: matrix[i][numButtons], freeCoeffs });\n   643→  }\n   644→\n   645→  if (numFree === 0) {\n   646→    const result = new Array(numButtons).fill(0);\n   647→    for (const p of pivotInfoC) {\n   648→      result[p.col] = p.rhs;\n   649→    }\n   650→    return result;\n   651→  }\n   652→\n   653→  // For small search spaces, enumerate directly\n   654→  const searchSize = Math.pow(modulus, numFree);\n   655→  if (searchSize <= 5_000_000) {\n   656→    return solveCounterEnumerate(numButtons, numFree, freeVars, pivotInfoC, modulus);\n   657→  }\n   658→\n   659→  // For larger spaces, use meet-in-the-middle\n   660→  return solveCounterMITM(numButtons, numFree, freeVars, pivotInfoC, modulus);\n   661→}\n   662→\n   663→function computeCounterSolution(\n   664→  freeValues: number[],\n   665→  numButtons: number,\n   666→  numFree: number,\n   667→  freeVars: number[],\n   668→  pivotInfo: { col: number; rhs: number; freeCoeffs: number[] }[],\n   669→  modulus: number\n   670→): number[] {\n   671→  const x = new Array(numButtons).fill(0);\n   672→  for (let f = 0; f < numFree; f++) {\n   673→    x[freeVars[f]] = freeValues[f];\n   674→  }\n   675→  for (const p of pivotInfo) {\n   676→    let val = p.rhs;\n   677→    for (let f = 0; f < numFree; f++) {\n   678→      val -= p.freeCoeffs[f] * freeValues[f];\n   679→    }\n   680→    x[p.col] = (((val % modulus) + modulus * numFree * 100) % modulus);\n   681→  }\n   682→  return x;\n   683→}\n   684→\n   685→function solveCounterEnumerate(\n   686→  numButtons: number,\n   687→  numFree: number,\n   688→  freeVars: number[],\n   689→  pivotInfo: { col: number; rhs: number; freeCoeffs: number[] }[],\n   690→  modulus: number\n   691→): number[] {\n   692→  let bestSolution: number[] | null = null;\n   693→  let bestTotal = Infinity;\n   694→\n   695→  const freeValues = new Array(numFree).fill(0);\n   696→  const totalCombinations = Math.pow(modulus, numFree);\n   697→\n   698→  for (let combo = 0; combo < totalCombinations; combo++) {\n   699→    const x = computeCounterSolution(freeValues, numButtons, numFree, freeVars, pivotInfo, modulus);\n   700→\n   701→    let total = 0;\n   702→    for (let j = 0; j < numButtons; j++) total += x[j];\n   703→\n   704→    if (total < bestTotal || (total === bestTotal && isLexSmallerArray(x, bestSolution!))) {\n   705→      bestTotal = total;\n   706→      bestSolution = [...x];\n   707→    }\n   708→\n   709→    incrementBaseCounter(freeValues, modulus);\n   710→  }\n   711→\n   712→  return bestSolution!;\n   713→}\n   714→\n   715→function solveCounterMITM(\n   716→  numButtons: number,\n   717→  numFree: number,\n   718→  freeVars: number[],\n   719→  pivotInfo: { col: number; rhs: number; freeCoeffs: number[] }[],\n   720→  modulus: number\n   721→): number[] {\n   722→  // Split free variables into two halves\n   723→  const half1 = Math.floor(numFree / 2);\n   724→  const half2 = numFree - half1;\n   725→  const numPivots = pivotInfo.length;\n   726→\n   727→  // For each pivot variable:\n   728→  //   x[pivot] = rhs - sum(coeff_f * freeVal_f) mod p\n   729→  //            = (rhs - sum_A(coeff_f * freeVal_f) - sum_B(coeff_f * freeVal_f)) mod p\n   730→  //            = (partialA + partialB) mod p   where partialA, partialB are per-pivot\n   731→  //\n   732→  // Total weight = sum(freeVals_A) + sum(freeVals_B) + sum_pivot((partialA_p + partialB_p) mod p)\n   733→  //\n   734→  // The pivot contributions are not separable due to the mod operation.\n   735→  // However, we can characterize each half by its \"residue vector\":\n   736→  //   For half A: resA[p] = (rhs_p - sum(coeff_f * freeVal_f for f in A)) mod p\n   737→  //   For half B: resB[p] = (- sum(coeff_f * freeVal_f for f in B)) mod p\n   738→  //   Then x[pivot_p] = (resA[p] + resB[p]) mod p\n   739→  //\n   740→  // The residue vector has numPivots components, each in [0, p-1].\n   741→  // Total distinct residue vectors: p^numPivots. Could be huge.\n   742→  //\n   743→  // For MITM to work, we need the space of residue vectors to be manageable.\n   744→  // With numPivots up to ~40 and modulus up to 97, p^numPivots is astronomical.\n   745→  //\n   746→  // However, the number of distinct residue vectors from each half is bounded\n   747→  // by p^half, and we store them in a hash map.\n   748→  //\n   749→  // For each residue vector from half A, we need to find the complementary\n   750→  // residue vector from half B that minimizes the total.\n   751→  //\n   752→  // total = fwA + fwB + sum_p((resA_p + resB_p) mod p)\n   753→  //\n   754→  // For each pair (resA, resB), the pivot weight depends on their element-wise sum mod p.\n   755→  // We'd need to iterate over all pairs, which defeats the p