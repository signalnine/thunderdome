old_s, s] = [s, old_s - q * s];","   }","-  return mod(old_s, m);","+  return pmod(old_s, m);"," }"]}],"originalFile":"interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// ─── GF(2) Toggle Solver ────────────────────────────────────────────\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | b] over GF(2)\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) row[j] = 1;\n    }\n    row[numButtons] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(2), producing RREF\n  const pivotCol: number[] = [];\n  const pivotRow: number[] = new Array(numButtons).fill(-1);\n  let currentRow = 0;\n\n  for (let col = 0; col < numButtons && currentRow < numLights; col++) {\n    let pr = -1;\n    for (let r = currentRow; r < numLights; r++) {\n      if (matrix[r][col] === 1) { pr = r; break; }\n    }\n    if (pr === -1) continue;\n    [matrix[currentRow], matrix[pr]] = [matrix[pr], matrix[currentRow]];\n    pivotCol.push(col);\n    pivotRow[col] = currentRow;\n    for (let r = 0; r < numLights; r++) {\n      if (r !== currentRow && matrix[r][col] === 1) {\n        for (let c = col; c <= numButtons; c++) matrix[r][c] ^= matrix[currentRow][c];\n      }\n    }\n    currentRow++;\n  }\n\n  const rank = currentRow;\n  for (let r = rank; r < numLights; r++) {\n    if (matrix[r][numButtons] !== 0) return null;\n  }\n\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] === -1) freeVars.push(col);\n  }\n  const numFree = freeVars.length;\n\n  if (numFree === 0) {\n    const solution: number[] = [];\n    for (let col = 0; col < numButtons; col++) {\n      if (pivotRow[col]