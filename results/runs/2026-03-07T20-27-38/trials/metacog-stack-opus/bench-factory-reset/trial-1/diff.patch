+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  it('should return empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should return null when no solution exists (example from spec)', () => {
+    // From the problem: target [T, T, F, T] with buttons {0,1}, {1,2,3}, {0,3}
+    // The system is inconsistent
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should solve a simple single-button toggle', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should solve a two-button toggle', () => {
+    // Lights: 3, target: [T, F, T]
+    // Button 0: toggles [0, 1]
+    // Button 1: toggles [1, 2]
+    // Press both: light 0 = on, light 1 = on^on = off, light 2 = on -> [T, F, T]
+    const result = solveToggle({
+      target: [true, false, true],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should return the minimum number of presses', () => {
+    // Light 0 needs to be on.
+    // Button 0: toggles [0]
+    // Button 1: toggles [0]
+    // Button 2: toggles [0]
+    // Best: press just one button (button 0, lexicographically smallest)
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should return lexicographically smallest among minimum solutions', () => {
+    // Light 0 needs to be on.
+    // Button 0: toggles [0]
+    // Button 1: toggles [0]
+    // Both single-press solutions: [0] or [1]. Lex smallest = [0]
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle all lights on target', () => {
+    // 2 lights, target [T, T]
+    // Button 0: toggles [0, 1] -> press button 0 to get [T, T]
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle identity-like buttons', () => {
+    // Each button toggles exactly one light
+    const result = solveToggle({
+      target: [true, false, true],
+      buttons: [[0], [1], [2]],
+    });
+    expect(result).toEqual([0, 2]);
+  });
+
+  it('should handle no buttons', () => {
+    // Target is all off, no buttons needed
+    const result = solveToggle({
+      target: [false, false],
+      buttons: [],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should return null with no buttons but non-trivial target', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should handle redundant buttons correctly', () => {
+    // target: [T, T]
+    // Button 0: [0]
+    // Button 1: [1]
+    // Button 2: [0, 1]
+    // Options: {0,1} (2 presses) or {2} (1 press)
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0], [1], [0, 1]],
+    });
+    expect(result).toEqual([2]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return all zeros when target is all zero', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should solve a simple single-button counter', () => {
+    // Counter 0 needs value 3 (mod 5)
+    // Button 0 affects counter 0
+    // Press 3 times
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('should solve a two-counter system', () => {
+    // Counter 0 needs 1, counter 1 needs 1 (mod 5)
+    // Button 0: affects [0, 1]
+    // Press once: both counters = 1
+    const result = solveCounter([1, 1], [[0, 1]], 5);
+    expect(result).toEqual([1]);
+  });
+
+  it('should return null when no solution exists', () => {
+    // Counter 0 needs 1, counter 1 needs 2 (mod 5)
+    // Button 0: affects [0, 1] (increments both by same amount)
+    // No single button can set different values
+    const result = solveCounter([1, 2], [[0, 1]], 5);
+    expect(result).toBeNull();
+  });
+
+  it('should find minimum total presses', () => {
+    // Counter 0 needs 1 (mod 5)
+    // Button 0: affects [0]
+    // Button 1: affects [0]
+    // Can press button 0 once OR button 1 once. Minimum total = 1.
+    // Lex smallest: [1, 0] vs [0, 1] -> [0, 1]
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should handle modular wrapping', () => {
+    // Counter 0 needs 0 (mod 3). Button 0 affects [0].
+    // Press 0 times (or 3 times, but 0 is minimum)
+    const result = solveCounter([0], [[0]], 3);
+    expect(result).toEqual([0]);
+  });
+
+  it('should solve with multiple buttons and counters', () => {
+    // Counters: [2, 3] (mod 5)
+    // Button 0: affects [0]
+    // Button 1: affects [1]
+    // Press button 0 twice, button 1 three times
+    const result = solveCounter([2, 3], [[0], [1]], 5);
+    expect(result).toEqual([2, 3]);
+  });
+
+  it('should handle no buttons with zero target', () => {
+    const result = solveCounter([0, 0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  it('should return null with no buttons and non-zero target', () => {
+    const result = solveCounter([1], [], 5);
+    expect(result).toBeNull();
+  });
+
+  it('should prefer lexicographically smallest solution', () => {
+    // Counter 0 needs 2 (mod 7)
+    // Button 0: affects [0]
+    // Button 1: affects [0]
+    // Solutions with total=2: [0,2], [1,1], [2,0]
+    // Lex smallest with total 2: [0, 2]
+    const result = solveCounter([2], [[0], [0]], 7);
+    expect(result).toEqual([0, 2]);
+  });
+
+  it('should handle larger modulus', () => {
+    // Counter 0 needs 50 (mod 97)
+    // Button 0: affects [0]
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+  });
+
+  it('should handle a counter puzzle with overlapping buttons', () => {
+    // Counters: [3, 2] (mod 5)
+    // Button 0: affects [0, 1]  (increments both)
+    // Button 1: affects [0]     (increments counter 0 only)
+    // System: b0 + b1 = 3 (mod 5), b0 = 2 (mod 5)
+    // So b0 = 2, b1 = 1
+    const result = solveCounter([3, 2], [[0, 1], [0]], 5);
+    expect(result).toEqual([2, 1]);
+  });
+});
+
+describe('solution verification', () => {
