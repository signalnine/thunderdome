butions\n  // For each combo, compute the values of free vars in first half\n  // and their contribution to pivot variables\n\n  // This is getting complex. Let me use a different approach:\n  // If we have many free vars, we can try all values of each free var\n  // and greedily pick the best, since the problem is linear.\n\n  // Actually the key insight: total presses = sum of x[j] for all j.\n  // x[pivot_j] = rhs_j - sum(matrix[j][free] * x[free]) mod p\n  // total = sum(x[free]) + sum(rhs_j - sum(matrix[j][free] * x[free]) mod p)\n\n  // Each x[free] value contributes to the total both directly (+x[free])\n  // and through its effect on pivot variables.\n\n  // For each free variable, we can compute its marginal effect on each pivot variable.\n  // But since we're working mod p, the total is not a simple linear function to minimize.\n\n  // Fall back: try setting each free variable to each possible value (0..p-1)\n  // and for each one, solve the remaining. This is O(p * numFree) if done greedily.\n  // Not optimal but much better than exhaustive.\n\n  // Better: since the system is linear mod p, we can express each pivot var as\n  // a linear combination of free vars. The total cost is:\n  // total = sum_free(x_f) + sum_pivot(b_i - sum_f(a_if * x_f) mod p)\n  // We need to minimize this.\n\n  // For small modulus, we can do iterative coordinate descent.\n  // For each free var, fix all others, find the optimal value.\n  // Repeat until convergence.","newString":"  const numFree = freeVars.length;","originalFile":"interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve the toggle puzzle using Gaussian elimination over GF(2).\n * Each button press toggles specific lights. We need to find the minimum\n * set of buttons to press to reach the target configuration.\n *\n * This is a system of linear equations over GF(2):\n *   A * x = b  (mod 2)\n * where A[i][j] = 1 if button j affects light i, x[j] = whether button j is pressed,\n * and b[i] = target[i].\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | b] over GF(2)\n  // Rows = lights, Columns = buttons + 1 (augmented with target)\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(2)\n  const pivotCol: number[] = []; // pivotCol[row] = column index of pivot\n  const pivotRow: number[] = new Array(numButtons).fill(-1); // pivotRow[col] = row index of pivot, -1 if free\n  let row = 0;\n\n  for (let col = 0; col < numButtons && row < numLights; col++) {\n    // Find pivot row\n    let pivotR = -1;\n    for (let r = row; r < numLights; r++) {\n      if (matrix[r][col] === 1) {\n        pivotR = r;\n        break;\n      }\n    }\n    if (pivotR === -1) continue; // Free variable\n\n    // Swap rows\n    [matrix[row], matrix[pivotR]] = [matrix[pivotR], matrix[row]];\n    pivotCol.push(col);\n    pivotRow[col] = row;\n\n    // Eliminate this column from all other rows\n    for (let r = 0; r < numLights; r++) {\n      if (r !== row && matrix[r][col] === 1) {\n        for (let c = col; c <= numButtons; c++) {\n          matrix[r][c] ^= matrix[row][c];\n        }\n      }\n    }\n    row++;\n  }\n\n  const rank = row;\n\n  // Check consistency: any row with all-zero coefficients but non-zero RHS\n  for (let r = rank; r < numLights; r++) {\n    if (matrix[r][numButtons] !== 0) {\n      return null; // No solution\n    }\n  }\n\n  // Identify free variables (columns not in pivotCol)\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // If no free variables, there's exactly one solution\n  if (numFree === 0) {\n    const solution: number[] = [];\n    for (let col = 0; col < numButtons; col++) {\n      if (pivotRow[col] !== -1 && matrix[pivotRow[col]][numButtons] === 1) {\n        solution.push(col);\n      }\n    }\n    return solution;\n  }\n\n  // Enumerate all 2^numFree combinations of free variables\n  // to find solution with minimum weight, then lexicographically smallest\n  let bestSolution: number[] | null = null;\n  let bestCount = numButtons + 1;\n\n  const totalCombinations = 1 << numFree;\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    // Set free variables according to mask\n    const x = new Array(numButtons).fill(0);\n    for (let f = 0; f < numFree; f++) {\n      x[freeVars[f]] = (mask >> f) & 1;\n    }\n\n    // Determine pivot variables from free variables\n    for (let i = pivotCol.length - 1; i >= 0; i--) {\n      const pc = pivotCol[i];\n      const pr = i; // pivotCol[i] corresponds to row i after elimination\n      let val = matrix[pr][numButtons];\n      for (let col = 0; col < numButtons; col++) {\n        if (col !== pc) {\n          val ^= (matrix[pr][col] & x[col]);\n        }\n      }\n      x[pc] = val;\n    }\n\n    // Count pressed buttons and build solution\n    const pressed: number[] = [];\n    for (let j = 0; j < numButtons; j++) {\n      if (x[j] === 1) pressed.push(j);\n    }\n\n    if (pressed.length < bestCount ||\n        (pressed.length === bestCount && isLexSmaller(pressed, bestSolution!))) {\n      bestCount = pressed.length;\n      bestSolution = pressed;\n    }\n  }\n\n  return bestSolution;\n}\n\nfunction isLexSmaller(a: number[], b: number[]): boolean {\n  // Compare two sorted arrays of button indices lexicographically\n  // First compare by length (fewer is \"smaller\" / preferred), then element by element\n  if (a.length !== b.length) return a.length < b.length;\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) return a[i] < b[i];\n  }\n  return false;\n}\n\n/**\n * Solve the counter puzzle using Gaussian elimination over GF(p).\n * Each button press increments specific counters mod p.\n * We need: A * x = b (mod p) where A[i][j] = 1 if button j affects counter i.\n *\n * Since p is prime, GF(p) is a field and we can do standard Gaussian elimination\n * with modular inverses.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | b] over GF(p)\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p)\n  const pivotCol: number[] = [];\n  const pivotRow: number[] = new Array(numButtons).fill(-1);\n  let row = 0;\n\n  for (let col = 0; col < numButtons && row < numCounters; col++) {\n    // Find pivot row\n    let pivotR = -1;\n    for (let r = row; r < numCounters; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotR = r;\n        break;\n      }\n    }\n    if (pivotR === -1) continue;\n\n    // Swap rows\n    [matrix[row], matrix[pivotR]] = [matrix[pivotR], matrix[row]];\n    pivotCol.push(col);\n    pivotRow[col] = row;\n\n    // Scale pivot row so pivot element is 1\n    const inv = modInverse(matrix[row][col], modulus);\n    for (let c = col; c <= numButtons; c++) {\n      matrix[row][c] = (matrix[row][c] * inv) % modulus;\n    }\n\n    // Eliminate this column from all other rows\n    for (let r = 0; r < numCounters; r++) {\n      if (r !== row && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let c = col; c <= numButtons; c++) {\n          matrix[r][c] = (((matrix[r][c] - factor * matrix[row][c]) % modulus) + modulus) % modulus;\n        }\n      }\n    }\n    row++;\n  }\n\n  const rank = row;\n\n  // Check consistency\n  for (let r = rank; r < numCounters; r++) {\n    if (matrix[r][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRow[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // If no free variables, there's exactly one solution\n  if (numFree === 0) {\n    const result = new Array(numButtons).fill(0);\n    for (let col = 0; col < numButtons; col++) {\n      if (pivotRow[col] !== -1) {\n        result[col] = matrix[pivotRow[col]][numButtons];\n      }\n    }\n    return result;\n  }\n\n  // Enumerate all p^numFree combinations of free variables\n  // For up to 40 free vars and modulus up to 97, we need to be smart.\n  // But with Gaussian elimination on a 40x40 system, free vars are typically few.\n  // If p^numFree is too large, we need a different approach.\n\n  const totalCombinations = Math.pow(modulus, numFree);\n\n  if (totalCombinations > 5_000_000) {\n    // Too many to enumerate - use a smarter approach\n    return solveCounterLarge(matrix, pivotCol, pivotRow, freeVars, numButtons, modulus);\n  }\n\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  // Enumerate all combinations of free variable values\n  const freeValues = new Array(numFree).fill(0);\n\n  for (let combo = 0; combo < totalCombinations; combo++) {\n    // Set free variables\n    const x = new Array(numButtons).fill(0);\n    for (let f = 0; f < numFree; f++) {\n      x[freeVars[f]] = freeValues[f];\n    }\n\n    // Determine pivot variables\n    for (let i = pivotCol.length - 1; i >= 0; i--) {\n      const pc = pivotCol[i];\n      const pr = i;\n      let val = matrix[pr][numButtons];\n      for (let col = 0; col < numButtons; col++) {\n        if (col !== pc) {\n          val = (((val - matrix[pr][col] * x[col]) % modulus) + modulus) % modulus;\n        }\n      }\n      x[pc] = val;\n    }\n\n    // Compute total presses\n    let total = 0;\n    for (let j = 0; j < numButtons; j++) {\n      total += x[j];\n    }\n\n    if (total < bestTotal || (total === bestTotal && isLexSmallerArray(x, bestSolution!))) {\n      bestTotal = total;\n      bestSolution = [...x];\n    }\n\n    // Increment free values (base-modulus counter)\n    incrementCounter(freeValues, modulus);\n  }\n\n  return bestSolution;\n}\n\n/**\n * For cases with too many free variables to enumerate, use an optimized approach.\n * We iterate over subsets of free variables more intelligently.\n */\nfunction solveCounterLarge(\n  matrix: number[][],\n  pivotCol: number[],\n  pivotRow: number[],\n  freeVars: number[],\n  numButtons: number,\n  modulus: number\n): number[] | null {\n  // With many free variables and large modulus, we need a meet-in-the-middle approach\n  // Split free variables into two halves and enumerate each\n  const numFree = freeVars.length;\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n\n  const freeVars1 = freeVars.slice(0, half1);\n  const freeVars2 = freeVars.slice(half1);\n\n  // For each combination of the first half, compute the contribution to each pivot variable\n  // and store in a map keyed by the pivot contributions\n\n  // Actually, for the counter problem with modular arithmetic, meet-in-the-middle\n  // on the total is more appropriate.\n\n  // Simpler approach: since all buttons affect counters by +1 (mod p),\n  // and we want minimum total presses, we can use the fact that\n  // for each free variable, its optimal value minimizes the total\n  // sum of all button presses.\n\n  // For each free variable f, each pivot variable is a linear function of f (mod p).\n  // T