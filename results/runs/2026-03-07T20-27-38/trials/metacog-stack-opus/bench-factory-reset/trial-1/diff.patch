+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+// ─── GF(2) Toggle Solver ────────────────────────────────────────────
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix [A | b] over GF(2)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) row[j] = 1;
+    }
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(2), producing RREF
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let currentRow = 0;
+
+  for (let col = 0; col < numButtons && currentRow < numLights; col++) {
+    let pr = -1;
+    for (let r = currentRow; r < numLights; r++) {
+      if (matrix[r][col] === 1) { pr = r; break; }
+    }
+    if (pr === -1) continue;
+    [matrix[currentRow], matrix[pr]] = [matrix[pr], matrix[currentRow]];
+    pivotCol.push(col);
+    pivotRow[col] = currentRow;
+    for (let r = 0; r < numLights; r++) {
+      if (r !== currentRow && matrix[r][col] === 1) {
+        for (let c = col; c <= numButtons; c++) matrix[r][c] ^= matrix[currentRow][c];
+      }
+    }
+    currentRow++;
+  }
+
+  const rank = currentRow;
+  for (let r = rank; r < numLights; r++) {
+    if (matrix[r][numButtons] !== 0) return null;
+  }
+
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) freeVars.push(col);
+  }
+  const numFree = freeVars.length;
+
+  if (numFree === 0) {
+    const solution: number[] = [];
+    for (let col = 0; col < numButtons; col++) {
+      if (pivotRow[col] !== -1 && matrix[pivotRow[col]][numButtons] === 1) solution.push(col);
+    }
+    return solution;
+  }
+
+  // For each pivot row, store which free vars affect it and its RHS
+  const pivotFreeFlags: number[][] = []; // pivotFreeFlags[i][f] = 0 or 1
+  const pivotRhsArr: number[] = [];
+  for (let i = 0; i < pivotCol.length; i++) {
+    const flags: number[] = [];
+    for (let f = 0; f < numFree; f++) {
+      flags.push(matrix[i][freeVars[f]]);
+    }
+    pivotFreeFlags.push(flags);
+    pivotRhsArr.push(matrix[i][numButtons]);
+  }
+
+  if (numFree <= 25) {
+    // Use bitmask-based enumeration
+    const pivotFreeMasks: number[] = [];
+    for (let i = 0; i < pivotCol.length; i++) {
+      let fm = 0;
+      for (let f = 0; f < numFree; f++) {
+        if (pivotFreeFlags[i][f]) fm |= (1 << f);
+      }
+      pivotFreeMasks.push(fm);
+    }
+    return toggleEnumerate(numButtons, numFree, freeVars, pivotCol, pivotFreeMasks, pivotRhsArr);
+  }
+
+  // Meet-in-the-middle for numFree > 25
+  return toggleMITM(numButtons, numFree, freeVars, pivotCol, pivotFreeFlags, pivotRhsArr);
+}
+
+function toggleGetSolution(
+  mask: number, numButtons: number, _numFree: number,
+  freeVars: number[], pivotCol: number[],
+  pivotFreeMasks: number[], pivotRhs: number[]
+): number[] {
+  const x = new Array(numButtons).fill(0);
+  // Extract free variable values from mask
+  for (let f = 0; f < freeVars.length; f++) x[freeVars[f]] = (mask >>> f) & 1;
+  for (let i = 0; i < pivotCol.length; i++) {
+    x[pivotCol[i]] = pivotRhs[i] ^ (bitCount32(mask & pivotFreeMasks[i]) & 1);
+  }
+  return x;
+}
+
+function bitCount32(n: number): number {
+  n = n - ((n >>> 1) & 0x55555555);
+  n = (n & 0x33333333) + ((n >>> 2) & 0x33333333);
+  return (((n + (n >>> 4)) & 0x0F0F0F0F) * 0x01010101) >>> 24;
+}
+
+function toPressed(x: number[]): number[] {
+  const p: number[] = [];
+  for (let j = 0; j < x.length; j++) if (x[j] === 1) p.push(j);
+  return p;
+}
+
+function toggleEnumerate(
+  numButtons: number, numFree: number, freeVars: number[],
+  pivotCol: number[], pivotFreeMasks: number[], pivotRhs: number[]
+): number[] {
+  let best: number[] | null = null;
+  let bestCount = numButtons + 1;
+  const total = 1 << numFree;
+
+  for (let mask = 0; mask < total; mask++) {
+    const x = toggleGetSolution(mask, numButtons, numFree, freeVars, pivotCol, pivotFreeMasks, pivotRhs);
+    const pressed = toPressed(x);
+    if (pressed.length < bestCount || (pressed.length === bestCount && lexSmaller(pressed, best!))) {
+      bestCount = pressed.length;
+      best = pressed;
+    }
+  }
+  return best!;
+}
+
+function toggleMITM(
+  numButtons: number, numFree: number, freeVars: number[],
+  pivotCol: number[], pivotFreeFlags: number[][], pivotRhs: number[]
+): number[] {
+  const half1 = Math.floor(numFree / 2);
+  const half2 = numFree - half1;
+  const numPivots = pivotCol.length;
+
+  // For each pivot, compute bitmasks for low half and high half of free vars
+  // These each fit in 32 bits since half1, half2 <= 20
+  const lowMasks: number[] = [];
+  const highMasks: number[] = [];
+  for (let i = 0; i < numPivots; i++) {
+    let lm = 0, hm = 0;
+    for (let f = 0; f < half1; f++) {
+      if (pivotFreeFlags[i][f]) lm |= (1 << f);
+    }
+    for (let f = 0; f < half2; f++) {
+      if (pivotFreeFlags[i][half1 + f]) hm |= (1 << f);
+    }
+    lowMasks.push(lm);
+    highMasks.push(hm);
+  }
+
+  function sigFromLow(maskA: number): number {
+    let sig = 0;
+    for (let p = 0; p < numPivots; p++) {
+      if (bitCount32(maskA & lowMasks[p]) & 1) sig |= (1 << p);
+    }
+    return sig;
+  }
+  function sigFromHigh(maskB: number): number {
+    let sig = 0;
+    for (let p = 0; p < numPivots; p++) {
+      if (bitCount32(maskB & highMasks[p]) & 1) sig |= (1 << p);
+    }
+    return sig;
+  }
+
+  // Build solution from two half-masks
+  function getSolutionFromHalves(maskA: number, maskB: number): number[] {
+    const x = new Array(numButtons).fill(0);
+    for (let f = 0; f < half1; f++) x[freeVars[f]] = (maskA >>> f) & 1;
+    for (let f = 0; f < half2; f++) x[freeVars[half1 + f]] = (maskB >>> f) & 1;
+    for (let i = 0; i < numPivots; i++) {
+      const parLow = bitCount32(maskA & lowMasks[i]) & 1;
+      const parHigh = bitCount32(maskB & highMasks[i]) & 1;
+      x[pivotCol[i]] = pivotRhs[i] ^ parLow ^ parHigh;
+    }
+    return x;
+  }
+
+  // Build map: signature -> best {freeWeight, maskA}
+  const mapA = new Map<number, { fw: number; maskA: number }>();
+  const size1 = 1 << half1;
+  for (let maskA = 0; maskA < size1; maskA++) {
+    const sig = sigFromLow(maskA);
+    const fw = bitCount32(maskA);
+    const existing = mapA.get(sig);
+    if (!existing || fw < existing.fw || (fw === existing.fw && maskA < existing.maskA)) {
+      mapA.set(sig, { fw, maskA });
+    }
+  }
+
+  // Precompute pivot weight for all combined signatures (2^numPivots entries)
+  // numPivots = numButtons - numFree. Since numFree > 25 and numButtons <= 40,
+  // numPivots <= 15, so 2^numPivots <= 32768. Perfectly fine.
+  const numSigs = 1 << numPivots;
+  const pivotWeights = new Int32Array(numSigs);
+  for (let c = 0; c < numSigs; c++) {
+    let w = 0;
+    for (let p = 0; p < numPivots; p++) w += pivotRhs[p] ^ ((c >>> p) & 1);
+    pivotWeights[c] = w;
+  }
+
+  let bestWeight = numButtons + 1;
+  let bestMaskA = 0;
+  let bestMaskB = 0;
+
+  const size2 = 1 << half2;
+  for (let maskB = 0; maskB < size2; maskB++) {
+    const sigB = sigFromHigh(maskB);
+    const fwB = bitCount32(maskB);
+
+    for (const [sigA, entryA] of mapA) {
+      const combined = sigA ^ sigB;
+      const totalWeight = entryA.fw + fwB + pivotWeights[combined];
+
+      if (totalWeight < bestWeight) {
+        bestWeight = totalWeight;
+        bestMaskA = entryA.maskA;
+        bestMaskB = maskB;
+      } else if (totalWeight === bestWeight) {
+        const solNew = getSolutionFromHalves(entryA.maskA, maskB);
+        const solOld = getSolutionFromHalves(bestMaskA, bestMaskB);
+        if (lexSmaller(toPressed(solNew), toPressed(solOld))) {
+          bestMaskA = entryA.maskA;
+          bestMaskB = maskB;
+        }
+      }
+    }
+  }
+
+  return toPressed(getSolutionFromHalves(bestMaskA, bestMaskB));
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  if (a.length !== b.length) return a.length < b.length;
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] < b[i];
+  }
+  return false;
+}
+
+
+// ─── GF(p) Counter Solver ───────────────────────────────────────────
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix [A | b] over GF(p)
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) row[j] = 1;
+    }
+    row[numButtons] = pmod(lights[i], modulus);
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(p), producing RREF
+  const pivotCol: number[] = [];
+  const pivotRow: number[] = new Array(numButtons).fill(-1);
+  let currentRow = 0;
+
+  for (let col = 0; col < numButtons && currentRow < numCounters; col++) {
+    let pr = -1;
+    for (let r = currentRow; r < numCounters; r++) {
+      if (matrix[r][col] !== 0) { pr = r; break; }
+    }
+    if (pr === -1) continue;
+    [matrix[currentRow], matrix[pr]] = [matrix[pr], matrix[currentRow]];
+    pivotCol.push(col);
+    pivotRow[col] = currentRow;
+
+    const inv = modInverse(matrix[currentRow][col], modulus);
+    for (let c = col; c <= numButtons; c++) {
+      matrix[currentRow][c] = (matrix[currentRow][c] * inv) % modulus;
+    }
+    for (let r = 0; r < numCounters; r++) {
+      if (r !== currentRow && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = col; c <= numButtons; c++) {
+          matrix[r][c] = pmod(matrix[r][c] - factor * matrix[currentRow][c], modulus);
+        }
+      }
+    }
+    currentRow++;
+  }
+
+  const rank = currentRow;
+  for (let r = rank; r < numCounters; r++) {
+    if (matrix[r][numButtons] !== 0) return null;
+  }
+
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (pivotRow[col] === -1) freeVars.push(col);
+  }
+  const numFree = freeVars.length;
+
+  // Precompute pivot info
+  const pivotRhsArr: number[] = [];
+  const pivotCoeffsArr: number[][] = [];
+  for (let i = 0; i < pivotCol.length; i++) {
+    const coeffs: number[] = [];
+    for (let f = 0; f < numFree; f++) coeffs.push(matrix[i][freeVars[f]]);
+    pivotRhsArr.push(matrix[i][numButtons]);
+    pivotCoeffsArr.push(coeffs);
+  }
+
+  if (numFree === 0) {
+    const result = new Array(numButtons).fill(0);
+    for (let i = 0; i < pivotCol.length; i++) result[pivotCol[i]] = pivotRhsArr[i];
+    return result;
+  }
+
+  const searchSize = Math.pow(modulus, numFree);
+  if (searchSize <= 5_000_000) {
+    return counterEnumerate(numButtons, numFree, freeVars, pivotCol, pivotRhsArr, pivotCoeffsArr, modulus);
+  }
+
+  return counterCoordinateDescent(numButtons, numFree, freeVars, pivotCol, pivotRhsArr, pivotCoeffsArr, modulus);
+}
+
+function counterGetSolution(
+  freeValues: number[], numButtons: number,
+  freeVars: number[], pivotCol: number[],
+  pivotRhs: number[], pivotCoeffs: number[][], modulus: number
+): number[] {
+  const x = new Array(numButtons).fill(0);
+  for (let f = 0; f < freeVars.length; f++) x[freeVars[f]] = freeValues[f];
+  for (let i = 0; i < pivotCol.length; i++) {
+    let val = pivotRhs[i];
+    for (let f = 0; f < freeVars.length; f++) val -= pivotCoeffs[i][f] * freeValues[f];
+    x[pivotCol[i]] = pmod(val, modulus);
+  }
+  return x;
+}
+
+function counterEnumerate(
+  numButtons: number, numFree: number, freeVars: number[],
+  pivotCol: number[], pivotRhs: number[], pivotCoeffs: number[][],
+  modulus: number
+): number[] {
+  let best: number[] | null = null;
+  let bestTotal = Infinity;
+  const freeValues = new Array(numFree).fill(0);
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    const x = counterGetSolution(freeValues, numButtons, freeVars, pivotCol, pivotRhs, pivotCoeffs, modulus);
+    let total = 0;
+    for (let j = 0; j < numButtons; j++) total += x[j];
+
+    if (total < bestTotal || (total === bestTotal && lexSmallerArr(x, best!))) {
+      bestTotal = total;
+      best = [...x];
+    }
+    incrementBase(freeValues, modulus);
+  }
+  return best!;
+}
+
+function counterCoordinateDescent(
+  numButtons: number, numFree: number, freeVars: number[],
+  pivotCol: number[], pivotRhs: number[], pivotCoeffs: number[][],
+  modulus: number
+): number[] {
+  function evalFV(fv: number[]): { total: number; x: number[] } {
+    const x = counterGetSolution(fv, numButtons, freeVars, pivotCol, pivotRhs, pivotCoeffs, modulus);
+    let total = 0;
+    for (let j = 0; j < numButtons; j++) total += x[j];
+    return { total, x };
+  }
+
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  for (let start = 0; start < modulus; start++) {
+    const fv = new Array(numFree).fill(start);
+    let improved = true;
+    while (improved) {
+      improved = false;
+      for (let f = 0; f < numFree; f++) {
+        let bestVal = fv[f];
+        let bestT = evalFV(fv).total;
+        for (let v = 0; v < modulus; v++) {
+          if (v === bestVal) continue;
+          fv[f] = v;
+          const t = evalFV(fv).total;
+          if (t < bestT) { bestT = t; bestVal = v; }
+        }
+        if (bestVal !== fv[f]) { fv[f] = bestVal; improved = true; }
+        else fv[f] = bestVal;
+      }
+    }
+    const { total, x } = evalFV(fv);
+    if (total < bestTotal || (total === bestTotal && lexSmallerArr(x, bestSolution!))) {
+      bestTotal = total;
+      bestSolution = [...x];
+    }
+  }
+
+  // Also try with lex tiebreaking from zero start
+  {
+    const fv = new Array(numFree).fill(0);
+    let improved = true;
+    while (improved) {
+      improved = false;
+      for (let f = 0; f < numFree; f++) {
+        let bestVal = fv[f];
+        let bestResult = evalFV(fv);
+        for (let v = 0; v < modulus; v++) {
+          if (v === bestVal) continue;
+          fv[f] = v;
+          const result = evalFV(fv);
+          if (result.total < bestResult.total ||
+              (result.total === bestResult.total && lexSmallerArr(result.x, bestResult.x))) {
+            bestResult = result;
+            bestVal = v;
+          }
+        }
+        if (bestVal !== fv[f]) { fv[f] = bestVal; improved = true; }
+        else fv[f] = bestVal;
+      }
+    }
+    const { total, x } = evalFV(fv);
+    if (total < bestTotal || (total === bestTotal && lexSmallerArr(x, bestSolution!))) {
+      bestSolution = [...x];
+    }
+  }
+
+  return bestSolution!;
+}
+
+function incrementBase(values: number[], modulus: number): void {
+  for (let i = 0; i < values.length; i++) {
+    values[i]++;
+    if (values[i] < modulus) return;
+    values[i] = 0;
+  }
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] < b[i];
+  }
+  return false;
+}
+
+function pmod(a: number, m: number): number {
+  return ((a % m) + m) % m;
+}
+
+function modInverse(a: number, m: number): number {
+  a = pmod(a, m);
+  let [old_r, r] = [a, m];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return pmod(old_s, m);
+}
