uttons: number,\n  numFree: number,\n  freeVars: number[],\n  pivotInfo: { col: number; rhs: number; freeCoeffs: number[] }[],\n  modulus: number\n): number[] {\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  const freeValues = new Array(numFree).fill(0);\n  const totalCombinations = Math.pow(modulus, numFree);\n\n  for (let combo = 0; combo < totalCombinations; combo++) {\n    const x = computeCounterSolution(freeValues, numButtons, numFree, freeVars, pivotInfo, modulus);\n\n    let total = 0;\n    for (let j = 0; j < numButtons; j++) total += x[j];\n\n    if (total < bestTotal || (total === bestTotal && isLexSmallerArray(x, bestSolution!))) {\n      bestTotal = total;\n      bestSolution = [...x];\n    }\n\n    incrementBaseCounter(freeValues, modulus);\n  }\n\n  return bestSolution!;\n}\n\nfunction solveCounterMITM(\n  numButtons: number,\n  numFree: number,\n  freeVars: number[],\n  pivotInfo: { col: number; rhs: number; freeCoeffs: number[] }[],\n  modulus: number\n): number[] {\n  // Split free variables into two halves\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n  const numPivots = pivotInfo.length;\n\n  // For each pivot variable:\n  //   x[pivot] = rhs - sum(coeff_f * freeVal_f) mod p\n  //            = (rhs - sum_A(coeff_f * freeVal_f) - sum_B(coeff_f * freeVal_f)) mod p\n  //            = (partialA + partialB) mod p   where partialA, partialB are per-pivot\n  //\n  // Total weight = sum(freeVals_A) + sum(freeVals_B) + sum_pivot((partialA_p + partialB_p) mod p)\n  //\n  // The pivot contributions are not separable due to the mod operation.\n  // However, we can characterize each half by its \"residue vector\":\n  //   For half A: resA[p] = (rhs_p - sum(coeff_f * freeVal_f for f in A)) mod p\n  //   For half B: resB[p] = (- sum(coeff_f * freeVal_f for f in B)) mod p\n  //   Then x[pivot_p] = (resA[p] + resB[p]) mod p\n  //\n  // The residue vector has numPivots components, each in [0, p-1].\n  // Total distinct residue vectors: p^numPivots. Could be huge.\n  //\n  // For MITM to work, we need the space of residue vectors to be manageable.\n  // With numPivots up to ~40 and modulus up to 97, p^numPivots is astronomical.\n  //\n  // However, the number of distinct residue vectors from each half is bounded\n  // by p^half, and we store them in a hash map.\n  //\n  // For each residue vector from half A, we need to find the complementary\n  // residue vector from half B that minimizes the total.\n  //\n  // total = fwA + fwB + sum_p((resA_p + resB_p) mod p)\n  //\n  // For each pair (resA, resB), the pivot weight depends on their element-wise sum mod p.\n  // We'd need to iterate over all pairs, which defeats the purpose of MITM.\n  //\n  // Alternative: for the counter problem with large free spaces,\n  // use coordinate descent (each free variable independently optimized).\n  // This is a heuristic but works well when the objective is \"smooth\" mod p.\n\n  // Since MITM doesn't decompose well for GF(p) with p > 2,\n  // use multi-start coordinate descent.\n  return solveCounterCoordinateDescent(numButtons, numFree, freeVars, pivotInfo, modulus, half1, half2);\n}\n\nfunction solveCounterCoordinateDescent(\n  numButtons: number,\n  numFree: number,\n  freeVars: number[],\n  pivotInfo: { col: number; rhs: number; freeCoeffs: number[] }[],\n  modulus: number,\n  _half1: number,\n  _half2: number\n): number[] {\n  function evalSolution(fv: number[]): { total: number; x: number[] } {\n    const x = computeCounterSolution(fv, numButtons, numFree, freeVars, pivotInfo, modulus);\n    let total = 0;\n    for (let j = 0; j < numButtons; j++) total += x[j];\n    return { total, x };\n  }\n\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  // Try multiple starting points\n  for (let start = 0; start < modulus; start++) {\n    const fv = new Array(numFree).fill(start);\n\n    // Coordinate descent\n    let improved = true;\n    while (improv