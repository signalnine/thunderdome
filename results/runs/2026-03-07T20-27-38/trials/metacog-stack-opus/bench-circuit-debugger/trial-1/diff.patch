    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(0);\n    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(0);\n    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n  });\n\n  it('should simulate OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(1);\n    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);\n    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);\n    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n  });\n\n  it('should simulate XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 }).c).toBe(0);\n    expect(simulate(gates, { a: 1, b: 0 }).c).toBe(1);\n    expect(simulate(gates, { a: 0, b: 1 }).c).toBe(1);\n    expect(simulate(gates, { a: 0, b: 0 }).c).toBe(0);\n  });\n\n  it('should handle dependency ordering', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'a', in2: 'b', out: 'd' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result.c).toBe(1);\n    expect(result.d).toBe(1);\n    expect(result.e).toBe(1);\n  });\n\n  it('should simulate the example 4-bit adder (1 + 1 = 2)', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 0, x02: 0, x03: 0,\n      y00: 1, y01: 0, y02: 0, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(0);\n    expect(result.c03).toBe(0);\n  });\n\n  it('should simulate 4-bit adder (15 + 1 = 16)', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 1, x03: 1,\n      y00: 1, y01: 0, y02: 0, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(0);\n    expect(result.c03).toBe(1);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function make8BitAdder(): Gate[] {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    ];\n\n    for (let i = 1; i <= 7; i++) {\n      const pad = String(i).padStart(2, '0');\n      const prevPad = String(i - 1).padStart(2, '0');\n      gates.push(\n        { op: 'XOR', in1: `x${pad}`, in2: `y${pad}`, out: `t${pad}` },\n        { op: 'XOR', in1: `t${pad}`, in2: `c${prevPad}`, out: `z${pad}` },\n        { op: 'AND', in1: `x${pad}`, in2: `y${pad}`, out: `a${pad}` },\n        { op: 'AND', in1: `t${pad}`, in2: `c${prevPad}`, out: `b${pad}` },\n        { op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: `c${pad}` },\n      );\n    }\n\n    // Final carry output\n    const lastOr = gates.find(g => g.out === 'c07');\n    if (lastOr) lastOr.out = 'z08';\n\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): void {\n    const g1 = gates.find(g => g.out === wire1)!;\n    const g2 = gates.find(g => g.out === wire2)!;\n    g1.out = wire2;\n    g2.out = wire1;\n  }\n\n  it('should find swapped z-wire with internal wire', () => {\n    const gates = make8BitAdder();\n    // Swap z01 with a01 (z-wire ↔ AND output)\n    swapOutputs(gates, 'z01', 'a01');\n    // Swap z03 with b03 (z-wire ↔ AND output)\n    swapOutputs(gates, 'z03', 'b03');\n    // Swap t05 with a05 (first-level XOR ↔ AND output)\n    swapOutputs(gates, 't05', 'a05');\n    // Swap c06 with z06 (OR carry ↔ z-wire)\n    swapOutputs(gates, 'c06', 'z06');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a05', 'b03', 'c06', 't05', 'z01', 'z03', 'z06']);\n  });\n\n  it('should find swaps between different wire types', () => {\n    const gates = make8BitAdder();\n    // Swap z02 with t02 (z-wire ↔ first-level XOR output)\n    swapOutputs(gates, 'z02', 't02');\n    // Swap z04 with a04 (z-wire ↔ AND generate output)\n    swapOutputs(gates, 'z04', 'a04');\n    // Swap c05 with z06 (carry ↔ z-wire)\n    swapOutputs(gates, 'c05', 'z06');\n    // Swap a07 with z07 (AND ↔ z-wire)\n    swapOutputs(gates, 'a07', 'z07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a04', 'a07', 'c05', 't02', 'z02', 'z04', 'z06', 'z07']);\n  });\n\n  it('should find swaps involving carry wires', () => {\n    const gates = make8BitAdder();\n    // Swap c00 with t01 (bit-0 carry ↔ first-level XOR output)\n    swapOutputs(gates, 'c00', 't01');\n    // Swap a02 with z02 (AND ↔ z-wire)\n    swapOutputs(gates, 'a02', 'z02');\n    // Swap z04 with b04 (z-wire ↔ AND propagate)\n    swapOutputs(gates, 'z04', 'b04');\n    // Swap c06 with z08 (carry ↔ last z-wire)\n    swapOutputs(gates, 'c06', 'z08');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a02', 'b04', 'c00', 'c06', 't01', 'z02', 'z04', 'z08']);\n  });\n});\n","structuredPatch":[{"oldStart":41,"oldLines":9,"newStart":41,"newLines":9,"lines":["       { op: 'OR', in1: 'a', in2: 'b', out: 'd' },","     ];","     const result = simulate(gates, { a: 1, b: 0 });","-    expect(result.c).toBe(1); // 1 XOR 0 = 1","-    expect(result.d).toBe(1); // 1 OR 0 = 1","-    expect(result.e).toBe(1); // 1 AND 1 = 1","+    expect(result.c).toBe(1);","+    expect(result.d).toBe(1);","+    expect(result.e).toBe(1);","   });"," ","   it('should simulate the example 4-bit adder (1 + 1 = 2)', () => {"]},{"oldStart":66,"oldLines":7,"newStart":66,"newLines":6,"lines":["       { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },","       { op: 'OR', in1: 'a03', in2: 'b03', out: 'c03' },","     ];","-    // x = 0001 (1), y = 0001 (1), z should be 00010 (2)","     const inputs: Record<string, number> = {","  