+
+describe('findSwappedWires', () => {
+  function make8BitAdder(): Gate[] {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+    ];
+
+    for (let i = 1; i <= 7; i++) {
+      const pad = String(i).padStart(2, '0');
+      const prevPad = String(i - 1).padStart(2, '0');
+      gates.push(
+        { op: 'XOR', in1: `x${pad}`, in2: `y${pad}`, out: `t${pad}` },
+        { op: 'XOR', in1: `t${pad}`, in2: `c${prevPad}`, out: `z${pad}` },
+        { op: 'AND', in1: `x${pad}`, in2: `y${pad}`, out: `a${pad}` },
+        { op: 'AND', in1: `t${pad}`, in2: `c${prevPad}`, out: `b${pad}` },
+        { op: 'OR', in1: `a${pad}`, in2: `b${pad}`, out: `c${pad}` },
+      );
+    }
+
+    // Final carry output
+    const lastOr = gates.find(g => g.out === 'c07');
+    if (lastOr) lastOr.out = 'z08';
+
+    return gates;
+  }
+
+  function swapOutputs(gates: Gate[], wire1: string, wire2: string): void {
+    const g1 = gates.find(g => g.out === wire1)!;
+    const g2 = gates.find(g => g.out === wire2)!;
+    g1.out = wire2;
+    g2.out = wire1;
+  }
+
+  it('should find swapped z-wire with internal wire', () => {
+    const gates = make8BitAdder();
+    // Swap z01 with a01 (z-wire ↔ AND output at same bit)
+    swapOutputs(gates, 'z01', 'a01');
+    // Swap z03 with b03 (z-wire ↔ AND output at same bit)
+    swapOutputs(gates, 'z03', 'b03');
+    // Swap t05 with a05 (first-level XOR ↔ AND output at same bit)
+    swapOutputs(gates, 't05', 'a05');
+    // Swap c06 with z06 (OR carry ↔ z-wire at same bit)
+    swapOutputs(gates, 'c06', 'z06');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a01', 'a05', 'b03', 'c06', 't05', 'z01', 'z03', 'z06']);
+  });
+
+  it('should find swaps at same bit position', () => {
+    const gates = make8BitAdder();
+    // Swap z02 with a02 (z-wire ↔ AND generate, same bit)
+    swapOutputs(gates, 'z02', 'a02');
+    // Swap z04 with c04 (z-wire ↔ carry, same bit)
+    swapOutputs(gates, 'z04', 'c04');
+    // Swap z06 with b06 (z-wire ↔ AND propagate, same bit)
+    swapOutputs(gates, 'z06', 'b06');
+    // Swap a07 with z07 (AND ↔ z-wire at same bit)
+    swapOutputs(gates, 'a07', 'z07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a02', 'a07', 'b06', 'c04', 'z02', 'z04', 'z06', 'z07']);
+  });
+
+  it('should find swaps of carry with distant wire', () => {
+    const gates = make8BitAdder();
+    // Swap c01 with a05 (carry from bit 1 ↔ AND generate at bit 5 — no cycle)
+    swapOutputs(gates, 'c01', 'a05');
+    // Swap z03 with b03 (z-wire ↔ AND propagate, same bit)
+    swapOutputs(gates, 'z03', 'b03');
+    // Swap z06 with a06 (z-wire ↔ AND generate, same bit)
+    swapOutputs(gates, 'z06', 'a06');
+    // Swap z02 with c02 (z-wire ↔ carry at same bit — no cycle)
+    swapOutputs(gates, 'z02', 'c02');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(['a05', 'a06', 'b03', 'c01', 'c02', 'z02', 'z03', 'z06']);
+  });
+});
