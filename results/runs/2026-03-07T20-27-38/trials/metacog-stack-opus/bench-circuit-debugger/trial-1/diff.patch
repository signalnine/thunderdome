st a = wires[gate.in1];\n        const b = wires[gate.in2];\n        switch (gate.op) {\n          case 'AND':\n            wires[gate.out] = a & b;\n            break;\n          case 'OR':\n            wires[gate.out] = a | b;\n            break;\n          case 'XOR':\n            wires[gate.out] = a ^ b;\n            break;\n        }\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\nfunction isXYInput(wire: string): boolean {\n  return /^[xy]\\d+$/.test(wire);\n}\n\nfunction hasXYInput(gate: Gate): boolean {\n  return isXYInput(gate.in1) || isXYInput(gate.in2);\n}\n\nfunction isZOutput(wire: string): boolean {\n  return /^z\\d+$/.test(wire);\n}\n\nfunction getBitNum(wire: string): number {\n  const m = wire.match(/\\d+$/);\n  return m ? parseInt(m[0], 10) : -1;\n}\n\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup structures\n  const gateByOutput = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Build map from wire -> gates that use it as input\n  const gatesUsingWire = new Map<string, Gate[]>();\n  for (const g of gates) {\n    if (!gatesUsingWire.has(g.in1)) gatesUsingWire.set(g.in1, []);\n    if (!gatesUsingWire.has(g.in2)) gatesUsingWire.set(g.in2, []);\n    gatesUsingWire.get(g.in1)!.push(g);\n    gatesUsingWire.get(g.in2)!.push(g);\n  }\n\n  // Find max z-bit to know the last output\n  let maxZ = 0;\n  for (const g of gates) {\n    if (isZOutput(g.out)) {\n      maxZ = Math.max(maxZ, getBitNum(g.out));\n    }\n  }\n  const lastZWire = `z${String(maxZ).padStart(2, '0')}`;\n\n  const swapped = new Set<string>();\n\n  // Structural rules for a ripple-carry adder:\n  //\n  // Rule 1: Every XOR gate either:\n  //   a) Takes x/y inputs (first-level XOR), OR\n  //   b) Outputs a z-wire (second-level XOR producing the sum bit)\n  //   Exception: z00 is produced by a first-level XOR (half adder)\n  //\n  // Rule 2: Every z-wire (e