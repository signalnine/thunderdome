merOps.includes('OR')) {\n          // AND output should feed into OR, but doesn't\n          swapped.add(out);\n        }\n        if (isZOutput(out)) {\n          // AND should never directly output to z\n          swapped.add(out);\n        }\n      }\n    } else if (gate.op === 'OR') {\n      // OR gate produces carry, should NOT be a z-wire (except last z)\n      if (isZOutput(out) && out !== lastZWire) {\n        swapped.add(out);\n      }\n      // OR output feeds into XOR and AND for the next bit\n      if (!isZOutput(out)) {\n        const consumers = gatesUsingWire.get(out) || [];\n        const consumerOps = consumers.map((c) => c.op);\n        // Should feed into XOR and AND\n        if (consumers.length > 0 && !consumerOps.includes('XOR')) {\n          swapped.add(out);\n        }\n      }\n    }\n  }\n\n  // For z-wires (except last), check they're produced by XOR\n  for (let i = 0; i <= maxZ; i++) {\n    const zWire = `z${String(i).padStart(2, '0')}`;\n    const producer = gateByOutput.get(zWire);\n    if (producer) {\n      if (i < maxZ && producer.op !== 'XOR') {\n        swapped.add(zWire);\n      }\n      if (i === maxZ && producer.op !== 'OR') {\n        swapped.add(zWire);\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":130,"oldLines":11,"newStart":130,"newLines":20,"lines":["         }","       }","     } else if (gate.op === 'AND') {","-      // AND gate output should feed into an OR gate (except for bit 0 carry)","-      if (hasXYInput(gate) && getBitNum(gate.in1) === 0) {","+      if (isZOutput(out) && out !== lastZWire) {","+        swapped.add(out);","+      }","+      const xyBit = hasXYInput(gate)","+        ? getBitNum(isXYInput(gate.in1) ? gate.in1 : gate.in2)","+        : -1;","+      if (xyBit === 0) {","         // x00 AND y00 -> carry for bit 0","-        // This carry feeds into XOR and AND for bit 1 (or could feed OR if bit count is weird)","-        // No strict rule violation here usua