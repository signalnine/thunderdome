t byInputs = new Map<string, Gate>();\n    for (const g of mutableGates) {\n      byOutput.set(g.out, g);\n      // Key: \"OP:sortedIn1,sortedIn2\"\n      const ins = [g.in1, g.in2].sort();\n      byInputs.set(`${g.op}:${ins[0]},${ins[1]}`, g);\n    }\n    return { byOutput, byInputs };\n  }\n\n  function findGate(\n    byInputs: Map<string, Gate>,\n    op: Gate['op'],\n    in1: string,\n    in2: string,\n  ): Gate | undefined {\n    const ins = [in1, in2].sort();\n    return byInputs.get(`${op}:${ins[0]},${ins[1]}`);\n  }\n\n  function findGateWithInput(\n    op: Gate['op'],\n    input: string,\n  ): Gate | undefined {\n    return mutableGates.find(\n      (g) => g.op === op && (g.in1 === input || g.in2 === input),\n    );\n  }\n\n  function otherInput(gate: Gate, known: string): string {\n    return gate.in1 === known ? gate.in2 : gate.in1;\n  }\n\n  function doSwap(\n    byOutput: Map<string, Gate>,\n    wire1: string,\n    wire2: string,\n  ): void {\n    swapped.push(wire1, wire2);\n    const g1 = byOutput.get(wire1)!;\n    const g2 = byOutput.get(wire2)!;\n    g1.out = wire2;\n    g2.out = wire1;\n    byOutput.set(wire1, g2);\n    byOutput.set(wire2, g1);\n  }\n\n  // Determine number of input bits\n  let maxInputBit = 0;\n  for (const g of mutableGates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxInputBit = Math.max(maxInputBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxInputBit + 1;\n\n  // Walk through the adder bit by bit, tracking carry and fixing swaps\n  let carry = '';\n\n  for (let bit = 0; bit < numBits; bit++) {\n    let { byOutput, byInputs } = buildIndexes();\n    const xWire = `x${String(bit).padStart(2, '0')}`;\n    const yWire = `y${String(bit).padStart(2, '0')}`;\n    const zWire = `z${String(bit).padStart(2, '0')}`;\n\n    if (bit === 0) {\n      // Half adder: x00 XOR y00 -> z00\n      const xorGate = findGate(byInputs, 'XOR', xWire, yWire);\n      if (xorGate && xorGate.out !== zWire) {\n        doSwap(byOutput, xorGate.out, zWire);\n        ({ byOutput, byInputs } = buildIndexes());\n      }\n\n      // x00 AND y00 -> carry\n      const andGate = findGate(byInputs, 'AND', xWire, yWire);\n      if (andGate) {\n        carry = andGate.out;\n      }\n    } else {\n      // Full adder for bit i\n\n      // Step 1: Find xNN XOR yNN -> partialSum\n      const xorXY = findGate(byInputs, 'XOR', xWire, yWire);\n      if (!xorXY) continue;\n      let partialSum = xorXY.out;\n\n      // Step 2: Find partialSum XOR carry -> zNN\n      let sumXor = findGate(byInputs, 'XOR', partialSum, carry);\n\n      if (!sumXor) {\n        // One of partialSum or carry is wrong (swapped away).\n        // Strategy: find an XOR gate that uses carry. Its other input should be\n        // partialSum. If it's not, then partialSum output is swapped.\n        const xorWithCarry = findGateWithInput('XOR', carry);\n        if (xorWithCarry && xorWithCarry !== xorXY) {\n          // The other input should be partialSum but isn't\n          const actual = otherInput(xorWithCarry, carry);\n          if (actual !== partialSum) {\n            doSwap(byOutput, partialSum, actual);\n            ({ byOutput, byInputs } = buildIndexes());\n            partialSum = xorXY.out;\n            sumXor = findGate(byInputs, 'XOR', partialSum, carry);\n          }\n        } else {\n          // Try the other direction: find an XOR that uses partialSum\n          const xorWithPartial = findGateWithInput('XOR', partialSum);\n          if (xorWithPartial && xorWithPartial !== xorXY) {\n            const actual = otherInput(xorWithPartial, partialSum);\n            if (actual !== carry) {\n              doSwap(byOutput, carry, actual);\n              ({ byOutput, byInputs } = buildIndexes());\n              // carry variable needs updating — it was swapped\n              // After swap, the gate that produced old carry now produces actual,\n              // and vice ver