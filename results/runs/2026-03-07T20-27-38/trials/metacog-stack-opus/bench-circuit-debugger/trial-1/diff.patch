+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (changed && remaining.length > 0) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // We work on a mutable copy so we can fix swaps as we find them
+  const mutableGates = gates.map((g) => ({ ...g }));
+
+  const swapped: string[] = [];
+
+  // Rebuild indexes after any swap
+  function buildIndexes(): {
+    byOutput: Map<string, Gate>;
+    byInputs: Map<string, Gate>;
+  } {
+    const byOutput = new Map<string, Gate>();
+    const byInputs = new Map<string, Gate>();
+    for (const g of mutableGates) {
+      byOutput.set(g.out, g);
+      // Key: "OP:sortedIn1,sortedIn2"
+      const ins = [g.in1, g.in2].sort();
+      byInputs.set(`${g.op}:${ins[0]},${ins[1]}`, g);
+    }
+    return { byOutput, byInputs };
+  }
+
+  function findGate(
+    byInputs: Map<string, Gate>,
+    op: Gate['op'],
+    in1: string,
+    in2: string,
+  ): Gate | undefined {
+    const ins = [in1, in2].sort();
+    return byInputs.get(`${op}:${ins[0]},${ins[1]}`);
+  }
+
+  function findGateWithInput(
+    op: Gate['op'],
+    input: string,
+  ): Gate | undefined {
+    return mutableGates.find(
+      (g) => g.op === op && (g.in1 === input || g.in2 === input),
+    );
+  }
+
+  function otherInput(gate: Gate, known: string): string {
+    return gate.in1 === known ? gate.in2 : gate.in1;
+  }
+
+  function doSwap(
+    byOutput: Map<string, Gate>,
+    wire1: string,
+    wire2: string,
+  ): void {
+    swapped.push(wire1, wire2);
+    const g1 = byOutput.get(wire1)!;
+    const g2 = byOutput.get(wire2)!;
+    g1.out = wire2;
+    g2.out = wire1;
+    byOutput.set(wire1, g2);
+    byOutput.set(wire2, g1);
+  }
+
+  // Determine number of input bits
+  let maxInputBit = 0;
+  for (const g of mutableGates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^[xy](\d+)$/);
+      if (m) {
+        maxInputBit = Math.max(maxInputBit, parseInt(m[1], 10));
+      }
+    }
+  }
+  const numBits = maxInputBit + 1;
+
+  // Walk through the adder bit by bit, tracking carry and fixing swaps
+  let carry = '';
+
+  for (let bit = 0; bit < numBits; bit++) {
+    let { byOutput, byInputs } = buildIndexes();
+    const xWire = `x${String(bit).padStart(2, '0')}`;
+    const yWire = `y${String(bit).padStart(2, '0')}`;
+    const zWire = `z${String(bit).padStart(2, '0')}`;
+
+    if (bit === 0) {
+      // Half adder: x00 XOR y00 -> z00
+      const xorGate = findGate(byInputs, 'XOR', xWire, yWire);
+      if (xorGate && xorGate.out !== zWire) {
+        doSwap(byOutput, xorGate.out, zWire);
+        ({ byOutput, byInputs } = buildIndexes());
+      }
+
+      // x00 AND y00 -> carry
+      const andGate = findGate(byInputs, 'AND', xWire, yWire);
+      if (andGate) {
+        carry = andGate.out;
+      }
+    } else {
+      // Full adder for bit i
+
+      // Step 1: Find xNN XOR yNN -> partialSum
+      const xorXY = findGate(byInputs, 'XOR', xWire, yWire);
+      if (!xorXY) continue;
+      let partialSum = xorXY.out;
+
+      // Step 2: Find partialSum XOR carry -> zNN
+      let sumXor = findGate(byInputs, 'XOR', partialSum, carry);
+
+      if (!sumXor) {
+        // One of partialSum or carry is wrong (swapped away).
+        // Strategy: find an XOR gate that uses carry. Its other input should be
+        // partialSum. If it's not, then partialSum output is swapped.
+        const xorWithCarry = findGateWithInput('XOR', carry);
+        if (xorWithCarry && xorWithCarry !== xorXY) {
+          // The other input should be partialSum but isn't
+          const actual = otherInput(xorWithCarry, carry);
+          if (actual !== partialSum) {
+            doSwap(byOutput, partialSum, actual);
+            ({ byOutput, byInputs } = buildIndexes());
+            partialSum = xorXY.out;
+            sumXor = findGate(byInputs, 'XOR', partialSum, carry);
+          }
+        } else {
+          // Try the other direction: find an XOR that uses partialSum
+          const xorWithPartial = findGateWithInput('XOR', partialSum);
+          if (xorWithPartial && xorWithPartial !== xorXY) {
+            const actual = otherInput(xorWithPartial, partialSum);
+            if (actual !== carry) {
+              doSwap(byOutput, carry, actual);
+              ({ byOutput, byInputs } = buildIndexes());
+              // The carry wire was swapped. The XOR gate at this bit references
+              // 'actual' as its input (the correct carry name). Update carry.
+              carry = actual;
+              sumXor = findGate(byInputs, 'XOR', partialSum, carry);
+            }
+          }
+        }
+      }
+
+      if (sumXor) {
+        // Its output should be zNN
+        if (sumXor.out !== zWire) {
+          doSwap(byOutput, sumXor.out, zWire);
+          ({ byOutput, byInputs } = buildIndexes());
+        }
+      }
+
+      // Step 3: Find xNN AND yNN -> generate
+      const andXY = findGate(byInputs, 'AND', xWire, yWire);
+      if (!andXY) continue;
+      const generate = andXY.out;
+
+      // Step 4: Find partialSum AND carry -> propagate
+      const andPC = findGate(byInputs, 'AND', partialSum, carry);
+      if (!andPC) continue;
+      const propagate = andPC.out;
+
+      // Step 5: Find generate OR propagate -> carryOut
+      let orGate = findGate(byInputs, 'OR', generate, propagate);
+
+      if (!orGate) {
+        // One of generate or propagate might be swapped
+        const orWithGen = findGateWithInput('OR', generate);
+        if (orWithGen) {
+          const actual = otherInput(orWithGen, generate);
+          if (actual !== propagate) {
+            doSwap(byOutput, propagate, actual);
+            ({ byOutput, byInputs } = buildIndexes());
+            // OR gate inputs unchanged; propagate wire name still in gate
+            orGate = orWithGen;
+          }
+        } else {
+          const orWithProp = findGateWithInput('OR', propagate);
+          if (orWithProp) {
+            const actual = otherInput(orWithProp, propagate);
+            if (actual !== generate) {
+              doSwap(byOutput, generate, actual);
+              ({ byOutput, byInputs } = buildIndexes());
+              orGate = orWithProp;
+            }
+          }
+        }
+      }
+
+      if (orGate) {
+        carry = orGate.out;
+      }
+    }
+  }
+
+  return [...new Set(swapped)].sort();
+}
