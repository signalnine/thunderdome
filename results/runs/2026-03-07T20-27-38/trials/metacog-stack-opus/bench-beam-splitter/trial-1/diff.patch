+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function nextStep(beam: Beam): { row: number; col: number } {
+  switch (beam.dir) {
+    case 'down':
+      return { row: beam.row + 1, col: beam.col };
+    case 'down-left':
+      return { row: beam.row + 1, col: beam.col - 1 };
+    case 'down-right':
+      return { row: beam.row + 1, col: beam.col + 1 };
+  }
+}
+
+function isInBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+function findSource(grid: string[][]): { row: number; col: number } | null {
+  const cols = grid[0]?.length ?? 0;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      return { row: 0, col: c };
+    }
+  }
+  return null;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+  if (cols === 0) return 0;
+
+  const source = findSource(grid);
+  if (!source) return 0;
+
+  const visitedCells = new Set<string>();
+  visitedCells.add(`${source.row},${source.col}`);
+
+  // Track visited beam states to avoid reprocessing the same (row, col, dir)
+  const visitedStates = new Set<string>();
+
+  const beams: Beam[] = [{ row: source.row, col: source.col, dir: 'down' }];
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const stateKey = `${beam.row},${beam.col},${beam.dir}`;
+    if (visitedStates.has(stateKey)) continue;
+    visitedStates.add(stateKey);
+
+    const next = nextStep(beam);
+
+    if (!isInBounds(next.row, next.col, rows, cols)) {
+      continue;
+    }
+
+    visitedCells.add(`${next.row},${next.col}`);
+
+    const cell = grid[next.row][next.col];
+    if (cell === '^') {
+      beams.push({ row: next.row, col: next.col, dir: 'down-left' });
+      beams.push({ row: next.row, col: next.col, dir: 'down-right' });
+    } else {
+      beams.push({ row: next.row, col: next.col, dir: beam.dir });
+    }
+  }
+
+  return visitedCells.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+  if (cols === 0) return 0n;
+
+  const source = findSource(grid);
+  if (!source) return 0n;
+
+  // Memoize by (row, col, direction) -> number of paths from this state to exit
+  const memo = new Map<string, bigint>();
+
+  function countFrom(row: number, col: number, dir: Direction): bigint {
+    const key = `${row},${col},${dir}`;
+    const cached = memo.get(key);
+    if (cached !== undefined) return cached;
+
+    // Trace the beam forward until it hits a splitter or exits
+    let r = row;
+    let c = col;
+    const d = dir;
+
+    // Move one step in the current direction
+    switch (d) {
+      case 'down':
+        r += 1;
+        break;
+      case 'down-left':
+        r += 1;
+        c -= 1;
+        break;
+      case 'down-right':
+        r += 1;
+        c += 1;
+        break;
+    }
+
+    if (!isInBounds(r, c, rows, cols)) {
+      // Beam exits grid — this is 1 complete path
+      memo.set(key, 1n);
+      return 1n;
+    }
+
+    let result: bigint;
+    if (grid[r][c] === '^') {
+      // Hit a splitter — split into two beams
+      const leftPaths = countFrom(r, c, 'down-left');
+      const rightPaths = countFrom(r, c, 'down-right');
+      result = leftPaths + rightPaths;
+    } else {
+      // Continue in same direction
+      result = countFrom(r, c, d);
+    }
+
+    memo.set(key, result);
+    return result;
+  }
+
+  return countFrom(source.row, source.col, 'down');
+}
