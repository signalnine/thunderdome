new file mode 100644
index 0000000..31ba7fc
--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,90 @@
+import { EventBus } from '../bus.js';
+import {
+  AnalyticsService,
+  Events,
+  OrderCreatedEvent,
+  PaymentProcessedEvent,
+  PaymentStatus,
+  CartUpdatedEvent,
+} from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let revenue = 0;
+  const cartIds = new Set<string>();
+  let orderCount = 0;
+  const productCounts = new Map<string, number>();
+
+  function trackEvent(eventType: string) {
+    eventCounts.set(eventType, (eventCounts.get(eventType) ?? 0) + 1);
+  }
+
+  // Listen to all events for counting and specific tracking
+  const allEvents = Object.values(Events);
+  for (const eventName of allEvents) {
+    bus.on(eventName, (payload: unknown) => {
+      trackEvent(eventName);
+
+      if (eventName === Events.CART_UPDATED) {
+        const event = payload as CartUpdatedEvent;
+        cartIds.add(event.cartId);
+      }
+
+      if (eventName === Events.ORDER_CREATED) {
+        const event = payload as OrderCreatedEvent;
+        orderCount++;
+        // Track product quantities from the most recent cart state in the bus log
+        const log = bus.getLog();
+        for (let i = log.length - 1; i >= 0; i--) {
+          if (log[i].event === Events.CART_UPDATED) {
+            const cartEvent = log[i].payload as CartUpdatedEvent;
+            if (cartEvent.cartId === event.cartId) {
+              for (const item of cartEvent.items) {
+                productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);
+              }
+              break;
+            }
+          }
+        }
+      }
+
+      if (eventName === Events.PAYMENT_PROCESSED) {
+        const event = payload as PaymentProcessedEvent;
+        if (event.status === PaymentStatus.SUCCESS) {
+          const log = bus.getLog();
+          for (const entry of log) {
+            if (entry.event === Events.ORDER_CREATED) {
+              const orderEvent = entry.payload as OrderCreatedEvent;
+              if (orderEvent.orderId === event.orderId) {
+                revenue += orderEvent.total;
+                break;
+              }
+            }
+          }
+        }
+      }
+    });
+  }
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) ?? 0;
+    },
+
+    getRevenue(): number {
+      return revenue;
+    },
+
+    getConversionRate(): number {
+      if (cartIds.size === 0) return 0;
+      return orderCount / cartIds.size;
+    },
+
+    getTopProducts(limit: number) {
+      return Array.from(productCounts.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
