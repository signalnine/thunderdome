tions('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(3);\n\n    // Verify analytics\n    expect(analytics.getRevenue()).toBe(priceResult.total);\n    expect(analytics.getConversionRate()).toBe(1);\n    expect(analytics.getTopProducts(1)[0].productId).toBe(p1);\n  });\n});\n","structuredPatch":[{"oldStart":349,"oldLines":6,"newStart":349,"newLines":8,"lines":["     // Create products","     const p1 = catalog.createProduct('Widget', 10, 'gadgets');","     const p2 = catalog.createProduct('Gizmo', 20, 'gadgets');","+    // Flush microtasks so all event handlers (including pricing) complete","+    await flush();"," ","     // Set inventory","     inventory.setStock(p1, 100);"]},{"oldStart":358,"oldLines":6,"newStart":360,"newLines":7,"lines":["     const cartId = cartService.createCart('user1');","     cartService.addItem(cartId, p1, 2);","     cartService.addItem(cartId, p2, 1);","+    await flush();"," ","     // Calculate pricing","     const priceResult = pricing.calculateTotal(["]}],"userModified":false,"replaceAll":false}}
