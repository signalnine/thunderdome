rtId);\n      if (!cart) return;\n      cart.items = [];\n      emitCartUpdated(cart);\n    },\n\n    updateQuantity(cartId: string, productId: string, quantity: number) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      const item = cart.items.find(i => i.productId === productId);\n      if (item) {\n        item.quantity = quantity;\n        emitCartUpdated(cart);\n      }\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":379,"cache_read_input_tokens":26239,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":379},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"27ae9e91-eaa1-486f-81ac-6cc3839834ee","uuid":"ab83eac4-36a7-4e30-a32a-86348891681b"}
