--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,107 @@
+import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string; // ISO 8601
+  stop: string | null; // ISO 8601 or null if running
+}
+
+export interface TimeSummary {
+  [task: string]: number; // milliseconds
+}
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.entries = this.load();
+  }
+
+  private load(): TimeEntry[] {
+    try {
+      const data = readFileSync(this.filePath, "utf-8");
+      return JSON.parse(data) as TimeEntry[];
+    } catch {
+      return [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.entries.find((e) => e.stop === null);
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    };
+
+    this.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  stop(): TimeEntry {
+    const running = this.entries.find((e) => e.stop === null);
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    if (!from && !to) {
+      return [...this.entries];
+    }
+
+    return this.entries.filter((entry) => {
+      const startTime = new Date(entry.start).getTime();
+      if (from && startTime < from.getTime()) {
+        return false;
+      }
+      if (to && startTime > to.getTime()) {
+        return false;
+      }
+      return true;
+    });
+  }
+
+  getSummary(from?: Date, to?: Date): TimeSummary {
+    const entries = this.getEntries(from, to);
+    const summary: TimeSummary = {};
+
+    for (const entry of entries) {
+      const startTime = new Date(entry.start).getTime();
+      const endTime = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = endTime - startTime;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+}
