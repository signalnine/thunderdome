+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { TimeTracker } from "../src/index.js";
+import { rmSync, existsSync, readFileSync, mkdirSync } from "node:fs";
+import { join } from "node:path";
+import { tmpdir } from "node:os";
+
+function tempFile(): string {
+  return join(
+    tmpdir(),
+    `time-tracker-test-${Date.now()}-${Math.random().toString(36).slice(2)}`,
+    "data.json"
+  );
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+  let tracker: TimeTracker;
+
+  beforeEach(() => {
+    filePath = tempFile();
+    tracker = new TimeTracker(filePath);
+  });
+
+  afterEach(() => {
+    try {
+      const dir = filePath.substring(0, filePath.lastIndexOf("/"));
+      rmSync(dir, { recursive: true, force: true });
+    } catch {
+      // ignore
+    }
+  });
+
+  describe("start/stop", () => {
+    it("should start a timer", () => {
+      const entry = tracker.start("coding");
+      expect(entry.task).toBe("coding");
+      expect(entry.start).toBeTruthy();
+      expect(entry.stop).toBeNull();
+    });
+
+    it("should stop a running timer", () => {
+      tracker.start("coding");
+      const stopped = tracker.stop();
+      expect(stopped.task).toBe("coding");
+      expect(stopped.stop).toBeTruthy();
+    });
+
+    it("should auto-stop previous timer when starting new one", () => {
+      tracker.start("coding");
+      tracker.start("meeting");
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("coding");
+      expect(entries[0].stop).toBeTruthy();
+      expect(entries[1].task).toBe("meeting");
+      expect(entries[1].stop).toBeNull();
+    });
+
+    it("should throw when starting with empty name", () => {
+      expect(() => tracker.start("")).toThrow();
+      expect(() => tracker.start("  ")).toThrow();
+    });
+
+    it("should throw when stopping with no running timer", () => {
+      expect(() => tracker.stop()).toThrow();
+    });
+
+    it("should throw when stopping after already stopped", () => {
+      tracker.start("coding");
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow();
+    });
+  });
+
+  describe("persistence", () => {
+    it("should create file and directories automatically", () => {
+      tracker.start("coding");
+      expect(existsSync(filePath)).toBe(true);
+    });
+
+    it("should persist entries between instances", () => {
+      tracker.start("coding");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+    });
+
+    it("should save valid JSON", () => {
+      tracker.start("coding");
+      tracker.stop();
+      const data = JSON.parse(readFileSync(filePath, "utf-8"));
+      expect(Array.isArray(data)).toBe(true);
+      expect(data[0].task).toBe("coding");
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries when no filter", () => {
+      tracker.start("coding");
+      tracker.start("meeting");
+      tracker.stop();
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter by date range", () => {
+      const past = new Date("2020-01-01");
+      const future = new Date("2099-01-01");
+
+      tracker.start("coding");
+      tracker.stop();
+
+      expect(tracker.getEntries(past, future)).toHaveLength(1);
+      expect(tracker.getEntries(future)).toHaveLength(0);
+      expect(tracker.getEntries(undefined, past)).toHaveLength(0);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations per task", () => {
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(Object.keys(summary)).toHaveLength(1);
+    });
+
+    it("should include running tasks using current time", () => {
+      tracker.start("coding");
+      // Don't stop - should use Date.now()
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should separate different task names", () => {
+      tracker.start("coding");
+      tracker.start("meeting");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect("coding" in summary).toBe(true);
+      expect("meeting" in summary).toBe(true);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle emoji task names", () => {
+      tracker.start("🚀 deploy");
+      tracker.stop();
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("🚀 deploy");
+    });
+
+    it("should handle unicode characters", () => {
+      tracker.start("café meeting");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      expect(tracker2.getEntries()[0].task).toBe("café meeting");
+    });
+
+    it("should handle CJK characters", () => {
+      tracker.start("会议");
+      tracker.stop();
+      const summary = tracker.getSummary();
+      expect("会议" in summary).toBe(true);
+    });
+
+    it("should handle mixed unicode and emoji", () => {
+      tracker.start("📝 レビュー review");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("📝 レビュー review");
+    });
   });
 });
