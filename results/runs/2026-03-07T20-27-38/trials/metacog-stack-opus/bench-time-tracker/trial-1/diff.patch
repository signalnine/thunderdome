acker.getEntries(future)).toHaveLength(0);\n      expect(tracker.getEntries(undefined, past)).toHaveLength(0);\n    });\n  });\n\n  describe(\"getSummary\", () => {\n    it(\"should sum durations per task\", () => {\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"coding\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThan(0);\n      expect(Object.keys(summary)).toHaveLength(1);\n    });\n\n    it(\"should include running tasks using current time\", () => {\n      tracker.start(\"coding\");\n      // Don't stop - should use Date.now()\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThanOrEqual(0);\n    });\n\n    it(\"should separate different task names\", () => {\n      tracker.start(\"coding\");\n      tracker.start(\"meeting\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(\"coding\" in summary).toBe(true);\n      expect(\"meeting\" in summary).toBe(true);\n    });\n  });\n\n  describe(\"unicode support\", () => {\n    it(\"should handle emoji task names\", () => {\n      tracker.start(\"🚀 deploy\");\n      tracker.stop();\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe(\"🚀 deploy\");\n    });\n\n    it(\"should handle unicode characters\", () => {\n      tracker.start(\"café meeting\");\n      tracker.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      expect(tracker2.getEntries()[0].task).toBe(\"café meeting\");\n    });\n\n    it(\"should handle CJK characters\", () => {\n      tracker.start(\"会议\");\n      tracker.stop();\n      const summary = tracker.getSummary();\n      expect(\"会议\" in summary).toBe(true);\n    });\n\n    it(\"should handle mixed unicode and emoji\", () => {\n      tracker.start(\"📝 レビュー review\");\n      tracker.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries[0].task).toBe(\"📝 レビュー review\");\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
