+++ b/src/db.ts
@@ -0,0 +1,113 @@
+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { resolve, dirname } from 'path';
+import { fileURLToPath } from 'url';
+import { randomUUID } from 'crypto';
+import type { Operation } from './ot.js';
+
+const __filename = fileURLToPath(import.meta.url);
+const __dirname = dirname(__filename);
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDb(dbPath?: string): Database.Database {
+  const db = new Database(dbPath || ':memory:');
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  const schemaPath = resolve(__dirname, '..', 'schema.sql');
+  const schema = readFileSync(schemaPath, 'utf-8');
+  db.exec(schema);
+
+  return db;
+}
+
+export function createDocument(db: Database.Database, title: string, content: string = ''): DocumentRow {
+  const id = randomUUID();
+  const stmt = db.prepare(
+    'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+  );
+  stmt.run(id, title, content);
+
+  // Create initial version
+  db.prepare(
+    'INSERT INTO versions (document_id, version, content) VALUES (?, 1, ?)'
+  ).run(id, content);
+
+  return getDocument(db, id)!;
+}
+
+export function getDocument(db: Database.Database, id: string): DocumentRow | null {
+  const row = db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as DocumentRow | undefined;
+  return row || null;
+}
+
+export function listDocuments(db: Database.Database): DocumentRow[] {
+  return db.prepare('SELECT * FROM documents ORDER BY updated_at DESC').all() as DocumentRow[];
+}
+
+export function updateDocument(db: Database.Database, id: string, updates: { title?: string; content?: string }): DocumentRow | null {
+  const doc = getDocument(db, id);
+  if (!doc) return null;
+
+  const title = updates.title ?? doc.title;
+  const content = updates.content ?? doc.content;
+
+  db.prepare(
+    "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+  ).run(title, content, id);
+
+  // If content changed, create a new version
+  if (updates.content !== undefined && updates.content !== doc.content) {
+    const latestVersion = getLatestVersion(db, id);
+    const nextVersion = latestVersion ? latestVersion.version + 1 : 1;
+    db.prepare(
+      'INSERT INTO versions (document_id, version, content) VALUES (?, ?, ?)'
+    ).run(id, nextVersion, content);
+  }
+
+  return getDocument(db, id);
+}
+
+export function deleteDocument(db: Database.Database, id: string): boolean {
+  const result = db.prepare('DELETE FROM documents WHERE id = ?').run(id);
+  return result.changes > 0;
+}
+
+export function getDocumentVersions(db: Database.Database, documentId: string): VersionRow[] {
+  return db.prepare(
+    'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+  ).all(documentId) as VersionRow[];
+}
+
+export function getLatestVersion(db: Database.Database, documentId: string): VersionRow | null {
+  const row = db.prepare(
+    'SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC LIMIT 1'
+  ).get(documentId) as VersionRow | undefined;
+  return row || null;
+}
+
+export function addVersion(db: Database.Database, documentId: string, version: number, content: string, operation: Operation | null): void {
+  db.prepare(
+    'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+  ).run(documentId, version, content, operation ? JSON.stringify(operation) : null);
+
+  db.prepare(
+    "UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?"
+  ).run(content, documentId);
+}
diff --git a/src/ot.test.ts b/src/ot.test.ts
new file mode 100644
index 0000000..20e3e77
--- /dev/null
+++ b/src/ot.test.ts
@@ -0,0 +1,204 @@
+import { describe, it, expect } from 'vitest';
+import { applyOp, transformOp, validateOp, transformOpAgainstOps } from './ot.js';
+import type { InsertOp, DeleteOp, Operation } from './ot.js';
+
+describe('applyOp', () => {
+  it('should insert text at position', () => {
+    expect(applyOp('hello', { type: 'insert', position: 5, text: ' world', clientId: 'a' }))
+      .toBe('hello world');
+  });
+
+  it('should insert at beginning', () => {
+    expect(applyOp('world', { type: 'insert', position: 0, text: 'hello ', clientId: 'a' }))
+      .toBe('hello world');
+  });
+
+  it('should insert in middle', () => {
+    expect(applyOp('hllo', { type: 'insert', position: 1, text: 'e', clientId: 'a' }))
+      .toBe('hello');
+  });
+
+  it('should delete text at position', () => {
+    expect(applyOp('hello world', { type: 'delete', position: 5, count: 6, clientId: 'a' }))
+      .toBe('hello');
+  });
+
+  it('should delete from beginning', () => {
+    expect(applyOp('hello', { type: 'delete', position: 0, count: 2, clientId: 'a' }))
+      .toBe('llo');
+  });
+
+  it('should clamp insert position', () => {
+    expect(applyOp('ab', { type: 'insert', position: 100, text: 'c', clientId: 'a' }))
+      .toBe('abc');
+  });
+});
+
+describe('transformOp - insert vs insert', () => {
+  it('should not shift when op1 is before op2', () => {
+    const op1: InsertOp = { type: 'insert', position: 1, text: 'a', clientId: 'a' };
+    const op2: InsertOp = { type: 'insert', position: 5, text: 'b', clientId: 'b' };
+    const result = transformOp(op1, op2);
+    expect(result).toEqual({ ...op1 });
+  });
+
+  it('should shift op1 when op2 is before', () => {
+    const op1: InsertOp = { type: 'insert', position: 5, text: 'a', clientId: 'a' };
+    const op2: InsertOp = { type: 'insert', position: 1, text: 'bcd', clientId: 'b' };
+    const result = transformOp(op1, op2);
+    expect(result).toEqual({ ...op1, position: 8 });
+  });
+
+  it('should break ties by clientId at same position', () => {
+    const op1: InsertOp = { type: 'insert', position: 3, text: 'X', clientId: 'a' };
+    const op2: InsertOp = { type: 'insert', position: 3, text: 'Y', clientId: 'b' };
+    // 'a' < 'b', so op1 stays at 3
+    const result1 = transformOp(op1, op2);
+    expect(result1).toEqual({ ...op1 });
+
+    // 'b' > 'a', so op2 shifts
+    const result2 = transformOp(op2, op1);
+    expect(result2).toEqual({ ...op2, position: 4 });
+  });
+
+  it('convergence: two inserts at same position produce same doc', () => {
+    const doc = 'hello';
+    const op1: InsertOp = { type: 'insert', position: 3, text: 'X', clientId: 'a' };
+    const op2: InsertOp = { type: 'insert', position: 3, text: 'Y', clientId: 'b' };
+
+    // Path 1: apply op1 then transformed op2
+    const doc1a = applyOp(doc, op1);
+    const op2t = transformOp(op2, op1);
+    const doc1 = applyOp(doc1a, op2t);
+
+    // Path 2: apply op2 then transformed op1
+    const doc2a = applyOp(doc, op2);
+    const op1t = transformOp(op1, op2);
+    const doc2 = applyOp(doc2a, op1t);
+
+    expect(doc1).toBe(doc2);
+    expect(doc1).toContain('X');
+    expect(doc1).toContain('Y');
+  });
+});
+
+describe('transformOp - insert vs delete', () => {
+  it('should not shift insert before delete', () => {
+    const op1: InsertOp = { type: 'insert', position: 1, text: 'a', clientId: 'a' };
+    const op2: DeleteOp = { type: 'delete', position: 5, count: 3, clientId: 'b' };
+    const result = transformOp(op1, op2);
+    expect(result).toEqual({ ...op1 });
+  });
+
+  it('should shift insert back when delete is before', () => {
+    const op1: InsertOp = { type: 'insert', position: 5, text: 'a', clientId: 'a' };
+    const op2: DeleteOp = { type: 'delete', position: 1, count: 2, clientId: 'b' };
+    const result = transformOp(op1, op2);
+    expect(result).toEqual({ ...op1, position: 3 });
+  });
+
+  it('should move insert to delete start when inside deleted range', () => {
+    const op1: InsertOp = { type: 'insert', position: 3, text: 'a', clientId: 'a' };
+    const op2: DeleteOp = { type: 'delete', position: 2, count: 5, clientId: 'b' };
+    const result = transformOp(op1, op2);
+    expect(result).toEqual({ ...op1, position: 2 });
+  });
+});
+
+describe('transformOp - delete vs insert', () => {
+  it('should shift delete when insert is before', () => {
+    const op1: DeleteOp = { type: 'delete', position: 5, count: 3, clientId: 'a' };
+    const op2: InsertOp = { type: 'insert', position: 1, text: 'XX', clientId: 'b' };
+    const result = transformOp(op1, op2);
+    expect(result).toEqual({ ...op1, position: 7 });
+  });
+
+  it('should expand delete when insert is inside range', () => {
+    const op1: DeleteOp = { type: 'delete', position: 2, count: 5, clientId: 'a' };
+    const op2: InsertOp = { type: 'insert', position: 4, text: 'XX', clientId: 'b' };
+    const result = transformOp(op1, op2);
+    expect(result).toEqual({ ...op1, count: 7 });
+  });
+});
+
+describe('transformOp - delete vs delete', () => {
+  it('should shift when op1 is entirely after op2', () => {
+    const op1: DeleteOp = { type: 'delete', position: 10, count: 3, clientId: 'a' };
+    const op2: DeleteOp = { type: 'delete', position: 2, count: 3, clientId: 'b' };
+    const result = transformOp(op1, op2);
+    expect(result).toEqual({ ...op1, position: 7 });
+  });
+
+  it('should handle completely overlapping deletes', () => {
+    const op1: DeleteOp = { type: 'delete', position: 2, count: 3, clientId: 'a' };
+    const op2: DeleteOp = { type: 'delete', position: 2, count: 3, clientId: 'b' };
+    const result = transformOp(op1, op2) as DeleteOp;
+    expect(result.count).toBe(0);
+  });
+
+  it('should handle partial overlap', () => {
+    const op1: DeleteOp = { type: 'delete', position: 3, count: 5, clientId: 'a' };
+    const op2: DeleteOp = { type: 'delete', position: 5, count: 5, clientId: 'b' };
+    // op2 deletes [5,10), op1 wants to delete [3,8)
+    // After op2 applied, the overlap [5,8) is gone, so op1 should delete [3,5) which is count=2
+    const result = transformOp(op1, op2) as DeleteOp;
+    expect(result.count).toBe(2);
+    expect(result.position).toBe(3);
+  });
+
+  it('convergence: overlapping deletes produce same doc', () => {
+    const doc = '0123456789';
+    const op1: DeleteOp = { type: 'delete', position: 2, count: 4, clientId: 'a' }; // delete "2345"
+    const op2: DeleteOp = { type: 'delete', position: 4, count: 4, clientId: 'b' }; // delete "4567"
+
+    const doc1a = applyOp(doc, op1);
+    const op2t = transformOp(op2, op1) as DeleteOp;
+    const doc1 = op2t.count > 0 ? applyOp(doc1a, op2t) : doc1a;
+
+    const doc2a = applyOp(doc, op2);
+    const op1t = transformOp(op1, op2) as DeleteOp;
+    const doc2 = op1t.count > 0 ? applyOp(doc2a, op1t) : doc2a;
+
+    expect(doc1).toBe(doc2);
+    expect(doc1).toBe('0189');
+  });
+});
+
+describe('transformOpAgainstOps', () => {
+  it('should transform against multiple ops', () => {
+    const op: InsertOp = { type: 'insert', position: 0, text: 'X', clientId: 'c' };
+    const ops: Operation[] = [
+      { type: 'insert', position: 0, text: 'AB', clientId: 'a' },
+      { type: 'insert', position: 2, text: 'CD', clientId: 'b' },
+    ];
+    const result = transformOpAgainstOps(op, ops);
+    // 'c' > 'a' so shifts by 2, then 'c' > 'b' so shifts by 2 more
+    expect((result as InsertOp).position).toBe(4);
+  });
+});
+
+describe('validateOp', () => {
+  it('should accept valid insert', () => {
+    expect(validateOp({ type: 'insert', position: 0, text: 'hi', clientId: 'a' }, 5)).toBeNull();
+  });
+
+  it('should reject insert beyond doc length', () => {
+    expect(validateOp({ type: 'insert', position: 10, text: 'hi', clientId: 'a' }, 5)).not.toBeNull();
+  });
+
+  it('should reject empty insert text', () => {
+    expect(validateOp({ type: 'insert', position: 0, text: '', clientId: 'a' }, 5)).not.toBeNull();
+  });
+
+  it('should accept valid delete', () => {
+    expect(validateOp({ type: 'delete', position: 0, count: 3, clientId: 'a' }, 5)).toBeNull();
+  });
+
+  it('should reject delete beyond doc length', () => {
+    expect(validateOp({ type: 'delete', position: 3, count: 5, clientId: 'a' }, 5)).not.toBeNull();
+  });
+
+  it('should reject unknown type', () => {
+    expect(validateOp({ type: 'unknown' } as unknown as Operation, 5)).not.toBeNull();
+  });
+});
diff --git a/src/ot.ts b/src/ot.ts
new file mode 100644
index 0000000..9477169
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,160 @@
+// Operational Transform Engine
+// Pure functions for transforming concurrent text operations.
+// Operations are either insertions or deletions at a position in the document.
+
+export interface InsertOp {
+  type: 'insert';
+  position: number;
+  text: string;
+  clientId: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  position: number;
+  count: number;
+  clientId: string;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+export interface OperationMessage {
+  op: Operation;
+  version: number; // the document version this op was generated against
+}
+
+// Apply an operation to a document string, returning the new string.
+export function applyOp(doc: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const pos = Math.min(Math.max(0, op.position), doc.length);
+    return doc.slice(0, pos) + op.text + doc.slice(pos);
+  } else {
+    const pos = Math.min(Math.max(0, op.position), doc.length);
+    const end = Math.min(pos + op.count, doc.length);
+    return doc.slice(0, pos) + doc.slice(end);
+  }
+}
+
+// Transform op1 against op2 (both concurrent).
+// Returns the transformed version of op1, assuming op2 has already been applied.
+// This implements the inclusion transformation: IT(op1, op2).
+export function transformOp(op1: Operation, op2: Operation): Operation {
+  if (op1.type === 'insert' && op2.type === 'insert') {
+    return transformInsertInsert(op1, op2);
+  } else if (op1.type === 'insert' && op2.type === 'delete') {
+    return transformInsertDelete(op1, op2);
+  } else if (op1.type === 'delete' && op2.type === 'insert') {
+    return transformDeleteInsert(op1 as DeleteOp, op2 as InsertOp);
+  } else {
+    return transformDeleteDelete(op1 as DeleteOp, op2 as DeleteOp);
+  }
+}
+
+function transformInsertInsert(op1: InsertOp, op2: InsertOp): InsertOp {
+  if (op1.position < op2.position) {
+    return { ...op1 };
+  } else if (op1.position > op2.position) {
+    return { ...op1, position: op1.position + op2.text.length };
+  } else {
+    // Same position: break tie by clientId (deterministic ordering)
+    if (op1.clientId <= op2.clientId) {
+      return { ...op1 };
+    } else {
+      return { ...op1, position: op1.position + op2.text.length };
+    }
+  }
+}
+
+function transformInsertDelete(op1: InsertOp, op2: DeleteOp): InsertOp {
+  if (op1.position <= op2.position) {
+    return { ...op1 };
+  } else if (op1.position >= op2.position + op2.count) {
+    return { ...op1, position: op1.position - op2.count };
+  } else {
+    // Insert is within the deleted range — move to deletion start
+    return { ...op1, position: op2.position };
+  }
+}
+
+function transformDeleteInsert(op1: DeleteOp, op2: InsertOp): DeleteOp {
+  if (op2.position >= op1.position + op1.count) {
+    return { ...op1 };
+  } else if (op2.position <= op1.position) {
+    return { ...op1, position: op1.position + op2.text.length };
+  } else {
+    // Insert is within the deleted range — expand the delete to go around it
+    return { ...op1, count: op1.count + op2.text.length };
+  }
+}
+
+function transformDeleteDelete(op1: DeleteOp, op2: DeleteOp): DeleteOp {
+  if (op1.position >= op2.position + op2.count) {
+    // op1 is entirely after op2
+    return { ...op1, position: op1.position - op2.count };
+  } else if (op1.position + op1.count <= op2.position) {
+    // op1 is entirely before op2
+    return { ...op1 };
+  } else {
+    // Overlapping deletes
+    const start1 = op1.position;
+    const end1 = op1.position + op1.count;
+    const start2 = op2.position;
+    const end2 = op2.position + op2.count;
+
+    const overlapStart = Math.max(start1, start2);
+    const overlapEnd = Math.min(end1, end2);
+    const overlap = Math.max(0, overlapEnd - overlapStart);
+
+    // The new position is the minimum of the two starts, but adjusted
+    // because op2 has already been applied
+    const newPosition = start1 <= start2 ? start1 : start1 - (Math.min(end2, start1) - start2);
+    const newCount = op1.count - overlap;
+
+    if (newCount <= 0) {
+      // op1's entire range was already deleted by op2 — return a no-op delete
+      return { ...op1, position: newPosition < 0 ? 0 : newPosition, count: 0 };
+    }
+
+    return { ...op1, position: newPosition < 0 ? 0 : newPosition, count: newCount };
+  }
+}
+
+// Transform op against a series of operations that have already been applied.
+export function transformOpAgainstOps(op: Operation, ops: Operation[]): Operation {
+  let result = op;
+  for (const applied of ops) {
+    result = transformOp(result, applied);
+  }
+  return result;
+}
+
+// Validate that an operation is well-formed for a given document length.
+export function validateOp(op: Operation, docLength: number): string | null {
+  if (!op || typeof op !== 'object') {
+    return 'Operation must be an object';
+  }
+  if (op.type === 'insert') {
+    if (typeof op.position !== 'number' || op.position < 0) {
+      return 'Insert position must be a non-negative number';
+    }
+    if (op.position > docLength) {
+      return `Insert position ${op.position} is beyond document length ${docLength}`;
+    }
+    if (typeof op.text !== 'string' || op.text.length === 0) {
+      return 'Insert text must be a non-empty string';
+    }
+  } else if (op.type === 'delete') {
+    if (typeof op.position !== 'number' || op.position < 0) {
+      return 'Delete position must be a non-negative number';
+    }
+    if (typeof op.count !== 'number' || op.count < 0) {
+      return 'Delete count must be a non-negative number';
+    }
+    if (op.position + op.count > docLength) {
+      return `Delete range [${op.position}, ${op.position + op.count}) exceeds document length ${docLength}`;
+    }
+  } else {
+    return `Unknown operation type: ${(op as { type: string }).type}`;
+  }
+  return null;
+}
