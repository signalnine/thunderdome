+import { WebSocketServer, WebSocket } from 'ws';
+import type { Server as HttpServer } from 'http';
+import type Database from 'better-sqlite3';
+import { getDocument, addVersion, getLatestVersion } from './db.js';
+import { applyOp, transformOp, validateOp } from './ot.js';
+import type { Operation } from './ot.js';
+
+interface Client {
+  ws: WebSocket;
+  clientId: string;
+  documentId: string;
+}
+
+interface DocumentState {
+  content: string;
+  version: number;
+  baseVersion: number; // the version when we started tracking ops in memory
+  ops: Operation[];    // ops[i] transforms baseVersion+i to baseVersion+i+1
+}
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  private clients: Map<string, Client> = new Map();
+  private documentStates: Map<string, DocumentState> = new Map();
+  private db: Database.Database;
+
+  constructor(server: HttpServer, db: Database.Database) {
+    this.db = db;
+    this.wss = new WebSocketServer({ noServer: true });
+
+    server.on('upgrade', (request, socket, head) => {
+      const url = new URL(request.url || '/', `http://${request.headers.host}`);
+      const pathMatch = url.pathname.match(/^\/ws\/documents\/([^/]+)$/);
+
+      if (!pathMatch) {
+        socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+        socket.destroy();
+        return;
+      }
+
+      const documentId = pathMatch[1];
+
+      this.wss.handleUpgrade(request, socket, head, (ws) => {
+        this.wss.emit('connection', ws, request, documentId);
+      });
+    });
+
+    this.wss.on('connection', (ws: WebSocket, _request: unknown, documentId: string) => {
+      this.handleConnection(ws, documentId);
+    });
+  }
+
+  private getDocumentState(documentId: string): DocumentState | null {
+    if (this.documentStates.has(documentId)) {
+      return this.documentStates.get(documentId)!;
+    }
+
+    const doc = getDocument(this.db, documentId);
+    if (!doc) return null;
+
+    const latestVersion = getLatestVersion(this.db, documentId);
+    const version = latestVersion ? latestVersion.version : 1;
+
+    const state: DocumentState = {
+      content: doc.content,
+      version,
+      baseVersion: version,
+      ops: [],
+    };
+    this.documentStates.set(documentId, state);
+    return state;
+  }
+
+  private handleConnection(ws: WebSocket, documentId: string) {
+    const state = this.getDocumentState(documentId);
+    if (!state) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close();
+      return;
+    }
+
+    const clientId = Math.random().toString(36).substring(2, 15);
+    const client: Client = { ws, clientId, documentId };
+    this.clients.set(clientId, client);
+
+    ws.send(JSON.stringify({
+      type: 'sync',
+      content: state.content,
+      version: state.version,
+      clientId,
+    }));
+
+    ws.on('message', (data) => {
+      try {
+        const raw = data.toString();
+        const message = JSON.parse(raw);
+        if (message.type === 'operation') {
+          this.handleOperation(client, message as { type: string; op: Operation; version: number });
+        }
+      } catch (err) {
+        ws.send(JSON.stringify({
+          type: 'error',
+          message: err instanceof Error ? err.message : 'Invalid message',
+        }));
+      }
+    });
+
+    ws.on('close', () => {
+      this.clients.delete(clientId);
+    });
+
+    ws.on('error', () => {
+      this.clients.delete(clientId);
+    });
+  }
+
+  private handleOperation(client: Client, message: { type: string; op: Operation; version: number }) {
+    const state = this.documentStates.get(client.documentId);
+    if (!state) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Document state not found' }));
+      return;
+    }
+
+    let op = { ...message.op, clientId: client.clientId };
+    const clientVersion = message.version;
+
+    if (clientVersion < state.baseVersion || clientVersion > state.version) {
+      client.ws.send(JSON.stringify({
+        type: 'error',
+        message: `Invalid version ${clientVersion}. Current version is ${state.version}`,
+      }));
+      return;
+    }
+
+    // Transform op against all operations that happened since the client's version
+    // ops index = clientVersion - baseVersion
+    const startIdx = clientVersion - state.baseVersion;
+    const opsToTransformAgainst = state.ops.slice(startIdx);
+    for (const appliedOp of opsToTransformAgainst) {
+      op = transformOp(op, appliedOp) as typeof op;
+    }
+
+    // Validate the transformed operation against current document
+    const validationError = validateOp(op, state.content.length);
+    if (validationError) {
+      if (op.type === 'delete' && op.count === 0) {
+        client.ws.send(JSON.stringify({
+          type: 'ack',
+          version: state.version,
+        }));
+        return;
+      }
+      client.ws.send(JSON.stringify({
+        type: 'error',
+        message: validationError,
+      }));
+      return;
+    }
+
+    // Apply the operation
+    state.content = applyOp(state.content, op);
+    state.version++;
+    state.ops.push(op);
+
+    // Persist to database
+    addVersion(this.db, client.documentId, state.version, state.content, op);
+
+    // Send ack to the originating client
+    client.ws.send(JSON.stringify({
+      type: 'ack',
+      version: state.version,
+    }));
+
+    // Broadcast to all other clients on the same document
+    for (const [id, c] of this.clients) {
+      if (id !== client.clientId && c.documentId === client.documentId && c.ws.readyState === WebSocket.OPEN) {
+        c.ws.send(JSON.stringify({
+          type: 'operation',
+          op,
+          version: state.version,
+        }));
+      }
+    }
+  }
+
+  closeAll(): void {
+    for (const [, client] of this.clients) {
+      client.ws.close();
+    }
+    this.clients.clear();
+    this.documentStates.clear();
+    this.wss.close();
+  }
