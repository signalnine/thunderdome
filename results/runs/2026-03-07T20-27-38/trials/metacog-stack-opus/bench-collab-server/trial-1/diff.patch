\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.status(204).send();\n  });\n\n  // Get document version history\n  router.get('/documents/:id/versions', (req, res) => {\n    const doc = getDocument(db, req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versions = getDocumentVersions(db, req.params.id);\n    res.json(versions);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1220,"cache_read_input_tokens":26970,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1220},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"923dc531-77c6-44d6-86fb-a3d550dda8a9","uuid":"7664a543-fd4a-476d-8710-c5b309bc3bd9"}
