peration) VALUES (?, ?, ?, ?)'\n  ).run(documentId, version, content, operation ? JSON.stringify(operation) : null);\n\n  db.prepare(\n    \"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"\n  ).run(content, documentId);\n}\n","structuredPatch":[],"originalFile":null}}
