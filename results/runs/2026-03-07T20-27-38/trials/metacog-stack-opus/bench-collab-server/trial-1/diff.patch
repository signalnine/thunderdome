ON.stringify({\n      type: 'ack',\n      version: state.version,\n    }));\n\n    // Broadcast to all other clients on the same document\n    for (const [id, c] of this.clients) {\n      if (id !== client.clientId && c.documentId === client.documentId && c.ws.readyState === WebSocket.OPEN) {\n        c.ws.send(JSON.stringify({\n          type: 'operation',\n          op,\n          version: state.version,\n        }));\n      }\n    }\n  }\n\n  closeAll(): void {\n    for (const [, client] of this.clients) {\n      client.ws.close();\n    }\n    this.clients.clear();\n    this.documentStates.clear();\n    this.wss.close();\n  }\n}\n","structuredPatch":[{"oldStart":3,"oldLines":7,"newStart":3,"newLines":7,"lines":[" import type Database from 'better-sqlite3';"," import { getDocument, addVersion, getLatestVersion } from './db.js';"," import { applyOp, transformOp, validateOp } from './ot.js';","-import type { Operation, OperationMessage } from './ot.js';","+import type { Operation } from './ot.js';"," "," interface Client {","   ws: WebSocket;"]}],"userModified":false,"replaceAll":false}}
