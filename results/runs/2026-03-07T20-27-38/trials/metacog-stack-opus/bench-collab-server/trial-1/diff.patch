documents/${doc.id}`);\n    const updated = await res.json();\n    expect(updated.content).toContain('World');\n    expect(updated.content).toContain('!');\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const clients: WebSocket[] = [];\n    const syncs: Record<string, unknown>[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(doc.id);\n      const sync = await waitForMessage(ws);\n      clients.push(ws);\n      syncs.push(sync);\n    }\n\n    // Each client inserts a character, one at a time\n    for (let i = 0; i < 10; i++) {\n      const broadcastPromises = clients\n        .filter((_, idx) => idx !== i)\n        .map(ws => waitForMessage(ws));\n\n      sendOp(clients[i], { type: 'insert', position: i, text: String(i) }, syncs[i].version as number + i);\n\n      const ack = await waitForMessage(clients[i]);\n      expect(ack.type).toBe('ack');\n\n      // Wait for all broadcasts\n      await Promise.all(broadcastPromises);\n    }\n\n    // Close all clients\n    clients.forEach(ws => ws.close());\n    await new Promise(r => setTimeout(r, 100));\n\n    // Verify all characters are present\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await res.json();\n    expect(updated.content.length).toBe(10);\n    for (let i = 0; i < 10; i++) {\n      expect(updated.content).toContain(String(i));\n    }\n  });\n\n  it('should reject invalid operations', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: 'Hi' }),\n    });\n    const doc = await 