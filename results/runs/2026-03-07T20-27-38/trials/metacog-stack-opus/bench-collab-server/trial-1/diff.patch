JSON.stringify({ title: 'Doc 1' }),\n    });\n    await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Doc 2' }),\n    });\n\n    const res = await fetch(`${baseUrl}/api/documents`);\n    const docs = await res.json();\n    expect(docs.length).toBe(2);\n  });\n\n  it('should get a document by id', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: 'Content' }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('Test');\n    expect(doc.content).toBe('Content');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await fetch(`${baseUrl}/api/documents/nonexistent`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should update a document', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: 'Old' }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'PUT',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Updated', content: 'New' }),\n    });\n    expect(res.status).toBe(200);\n    const doc = await res.json();\n    expect(doc.title).toBe('Updated');\n    expect(doc.content).toBe('New');\n  });\n\n  it('should delete a document', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test' }),\n    });\n    const created = await createRes.json();\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'DELETE',\n    });\n    expect(res.status).toBe(204);\n\n    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should get version history', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: 'v1' }),\n    });\n    const created = await createRes.json();\n\n    await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'PUT',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ content: 'v2' }),\n    });\n\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}/versions`);\n    const versions = await res.json();\n    expect(versions.length).toBe(2);\n    expect(versions[0].content).toBe('v1');\n    expect(versions[1].content).toBe('v2');\n  });\n\n  it('should reject document creation without title', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(400);\n  });\n});\n\ndescribe('WebSocket Collaboration', () => {\n  it('should send sync message on connect', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: 'Hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe('sync');\n    expect(msg.content).toBe('Hello');\n    expect(msg.version).toBe(1);\n    expect(msg.clientId).toBeDefined();\n\n    ws.close();\n  });\n\n  it('should send error for non-existent document', async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n    const msg = await waitForMessage(ws);\n    expect(msg.type).toBe('error');\n    ws.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: 'Hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    const sync1 = await waitForMessage(ws1);\n\n    const ws2 = await connectWs(doc.id);\n    const sync2 = await waitForMessage(ws2);\n\n    // Client 1 sends an insert\n    const broadcastPromise = waitForMessage(ws2);\n    sendOp(ws1, { type: 'insert', position: 5, text: ' World' }, sync1.version as number);\n\n    // Client 1 should get an ack\n    const ack = await waitForMessage(ws1);\n    expect(ack.type).toBe('ack');\n\n    // Client 2 should get the broadcast\n    const broadcast = await broadcastPromise;\n    expect(broadcast.type).toBe('operation');\n    expect((broadcast.op as Record<string, unknown>).type).toBe('insert');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should persist operations and update document', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: 'Hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    const sync = await waitForMessage(ws);\n\n    sendOp(ws, { type: 'insert', position: 5, text: ' World' }, sync.version as number);\n    await waitForMessage(ws); // ack\n\n    ws.close();\n\n    // Wait a bit for close to propagate\n    await new Promise(r => setTimeout(r, 100));\n\n    // Verify via REST\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await res.json();\n    expect(updated.content).toBe('Hello World');\n\n    // Verify version history\n    const versionsRes = await fetch(`${baseUrl}/api/documents/${doc.id}/versions`);\n    const versions = await versionsRes.json();\n    expect(versions.length).toBe(2);\n  });\n\n  it('should handle concurrent edits from multiple clients', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: 'Hello' }),\n    });\n    const doc = await createRes.json();\n\n    const ws1 = await connectWs(doc.id);\n    const sync1 = await waitForMessage(ws1);\n\n    const ws2 = await connectWs(doc.id);\n    const sync2 = await waitForMessage(ws2);\n\n    // Both clients send operations based on the same version\n    // Client 1: insert \" World\" at position 5\n    // Client 2: insert \"!\" at position 5\n    const broadcast1Promise = waitForMessage(ws2);\n    sendOp(ws1, { type: 'insert', position: 5, text: ' World' }, sync1.version as number);\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe('ack');\n    await broadcast1Promise;\n\n    // Client 2 sends based on the ORIGINAL version (concurrent with client 1)\n    const broadcast2Promise = waitForMessage(ws1);\n    sendOp(ws2, { type: 'insert', position: 5, text: '!' }, sync2.version as number);\n    const ack2 = await waitForMessage(ws2);\n    expect(ack2.type).toBe('ack');\n    await broadcast2Promise;\n\n    ws1.close();\n    ws2.close();\n    await new Promise(r => setTimeout(r, 100));\n\n    // Verify the document has both inserts\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await res.json();\n    expect(updated.content).toContain('World');\n    expect(updated.content).toContain('!');\n  });\n\n  it('should handle 10 concurrent clients', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const clients: WebSocket[] = [];\n    const syncs: Record<string, unknown>[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(doc.id);\n      const sync = await waitForMessage(ws);\n      clients.push(ws);\n      syncs.push(sync);\n    }\n\n    // Each client inserts a character, one at a time\n    for (let i = 0; i < 10; i++) {\n      const broadcastPromises = clients\n        .filter((_, idx) => idx !== i)\n        .map(ws => waitForMessage(ws));\n\n      sendOp(clients[i], { type: 'insert', position: i, text: String(i) }, syncs[i].version as number + i);\n\n      const ack = await waitForMessage(clients[i]);\n      expect(ack.type).toBe('ack');\n\n      // Wait for all broadcasts\n      await Promise.all(broadcastPromises);\n    }\n\n    // Close all clients\n    clients.forEach(ws => ws.close());\n    await new Promise(r => setTimeout(r, 100));\n\n    // Verify all characters are present\n    const res = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n    const updated = await res.json();\n    expect(updated.content.length).toBe(10);\n    for (let i = 0; i < 10; i++) {\n      expect(updated.content).toContain(String(i));\n    }\n  });\n\n  it('should reject invalid operations', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: 'Hi' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    const sync = await waitForMessage(ws);\n\n    // Send an invalid delete (beyond document length)\n    sendOp(ws, { type: 'delete', position: 0, count: 100 }, sync.version as number);\n    const response = await waitForMessage(ws);\n    expect(response.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle malformed messages gracefully', async () => {\n    const createRes = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test', content: '' }),\n    });\n    const doc = await createRes.json();\n\n    const ws = await connectWs(doc.id);\n    await waitForMessage(ws); // sync\n\n    ws.send('not valid json {{{');\n    const response = await waitForMessage(ws);\n    expect(response.type).toBe('error');\n\n    ws.close();\n  });\n});\n\ndescribe('Persistence', () => {\n  it('should persist documents across server restarts', async () => {\n    const tmpDb = `/tmp/test-collab-${Date.now()}.db`;\n\n    // Create server 1, add a document\n    const server1 = createApp(tmpDb);\n    const port1 = await server1.start(0);\n    const res1 = await fetch(`http://localhost:${port1}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Persistent', content: 'Data survives' }),\n    });\n    const doc = await res1.json();\n    await server1.stop();\n\n    // Create server 2 with same DB, verify document exists\n    const server2 = createApp(tmpDb);\n    const port2 = await server2.start(0);\n    const res2 = await fetch(`http://localhost:${port2}/api/documents/${doc.id}`);\n    expect(res2.status).toBe(200);\n    const retrieved = await res2.json();\n    expect(retrieved.title).toBe('Persistent');\n    expect(retrieved.content).toBe('Data survives');\n    await server2.stop();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3264,"cache_read_input_tokens":3