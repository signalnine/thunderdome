2);\n  } else if (op1.type === 'insert' && op2.type === 'delete') {\n    return transformInsertDelete(op1, op2);\n  } else if (op1.type === 'delete' && op2.type === 'insert') {\n    return transformDeleteInsert(op1 as DeleteOp, op2 as InsertOp);\n  } else {\n    return transformDeleteDelete(op1 as DeleteOp, op2 as DeleteOp);\n  }\n}\n\nfunction transformInsertInsert(op1: InsertOp, op2: InsertOp): InsertOp {\n  if (op1.position < op2.position) {\n    return { ...op1 };\n  } else if (op1.position > op2.position) {\n    return { ...op1, position: op1.position + op2.text.length };\n  } else {\n    // Same position: break tie by clientId (deterministic ordering)\n    if (op1.clientId <= op2.clientId) {\n      return { ...op1 };\n    } else {\n      return { ...op1, position: op1.position + op2.text.length };\n    }\n  }\n}\n\nfunction transformInsertDelete(op1: InsertOp, op2: DeleteOp): InsertOp {\n  if (op1.position <= op2.position) {\n    return { ...op1 };\n  } else if (op1.position >= op2.position + op2.count) {\n    return { ...op1, position: op1.position - op2.count };\n  } else {\n    // Insert is within the deleted range — move to deletion start\n    return { ...op1, position: op2.position };\n  }\n}\n\nfunction transformDeleteInsert(op1: DeleteOp, op2: InsertOp): DeleteOp {\n  if (op2.position >= op1.position + op1.count) {\n    return { ...op1 };\n  } else if (op2.position <= op1.position) {\n    return { ...op1, position: op1.position + op2.text.length };\n  } else {\n    // Insert is within the deleted range — expand the delete to go around it\n    return { ...op1, count: op1.count + op2.text.length };\n  }\n}\n\nfunction transformDeleteDelete(op1: DeleteOp, op2: DeleteOp): DeleteOp {\n  if (op1.position >= op2.position + op2.count) {\n    // op1 is entirely after op2\n    return { ...op1, position: op1.position - op2.count };\n  } else if (op1.position + op1.count <= op2.position) {\n    // op1 is entirely before op2\n    return { ...op1 };\n  } else {\n    // Overlapping deletes\n    const start1 = op1.position;\n    const end1 = op1.position + op1.count;\n    const start2 = op2.position;\n    const end2 = op2.position + op2.count;\n\n    const newStart = Math.min(start1, start2);\n    const overlapStart = Math.max(start1, start2);\n    const overlapEnd = Math.min(end1, end2);\n    const overlap = Math.max(0, overlapEnd - overlapStart);\n\n    // The new position is the minimum of the two starts, but adjusted\n    // because op2 has already been applied\n    const newPosition = start1 <= start2 ? start1 : start1 - (Math.min(end2, start1) - start2);\n    const newCount = op1.count - overlap;\n\n    if (newCount <= 0) {\n      // op1's entire range was already deleted by op2 — return a no-op delete\n      return { ...op1, position: newPosition < 0 ? 0 : newPosition, count: 0 };\n    }\n\n    return { ...op1, position: newPosition < 0 ? 0 : newPosition, count: newCount };\n  }\n}\n\n// Transform op against a series of operations that have already been applied.\nexport function transformOpAgainstOps(op: Operation, ops: Operation[]): Operation {\n  let result = op;\n  for (const applied of ops) {\n    result = transformOp(result, applied);\n  }\n  return result;\n}\n\n// Validate that an operation is well-formed for a given document length.\nexport function validateOp(op: Operation, docLength: number): string | null {\n  if (!op || typeof op !== 'object') {\n    return 'Operation must be an object';\n  }\n  if (op.type === 'insert') {\n    if (typeof op.position !== 'number' || op.position < 0) {\n      return 'Insert position must be a non-negative number';\n    }\n    if (op.position > docLength) {\n      return `Insert position ${op.position} is beyond document length ${docLength}`;\n    }\n    if (typeof op.text !== 'string' || op.text.length === 0) {\n      return 'Insert text must be a non-empty string';\n    }\n  } else if (op.type === 'delete') {\n    if (typeof op.position !== 'number' || op.position < 0) {\n     