eleteOp, op2 as DeleteOp);\n  }\n}\n\nfunction transformInsertInsert(op1: InsertOp, op2: InsertOp): InsertOp {\n  if (op1.position < op2.position) {\n    return { ...op1 };\n  } else if (op1.position > op2.position) {\n    return { ...op1, position: op1.position + op2.text.length };\n  } else {\n    // Same position: break tie by clientId (deterministic ordering)\n    if (op1.clientId <= op2.clientId) {\n      return { ...op1 };\n    } else {\n      return { ...op1, position: op1.position + op2.text.length };\n    }\n  }\n}\n\nfunction transformInsertDelete(op1: InsertOp, op2: DeleteOp): InsertOp {\n  if (op1.position <= op2.position) {\n    return { ...op1 };\n  } else if (op1.position >= op2.position + op2.count) {\n    return { ...op1, position: op1.position - op2.count };\n  } else {\n    // Insert is within the deleted range — move to deletion start\n    return { ...op1, position: op2.position };\n  }\n}\n\nfunction transformDeleteInsert(op1: DeleteOp, op2: InsertOp): DeleteOp {\n  if (op2.position >= op1.position + op1.count) {\n    return { ...op1 };\n  } else if (op2.position <= op1.position) {\n    return { ...op1, position: op1.position + op2.text.length };\n  } else {\n    // Insert is within the deleted range — expand the delete to go around it\n    return { ...op1, count: op1.count + op2.text.length };\n  }\n}\n\nfunction transformDeleteDelete(op1: DeleteOp, op2: DeleteOp): DeleteOp {\n  if (op1.position >= op2.position + op2.count) {\n    // op1 is entirely after op2\n    return { ...op1, position: op1.position - op2.count };\n  } else if (op1.position + op1.count <= op2.position) {\n    // op1 is entirely before op2\n    return { ...op1 };\n  } else {\n    // Overlapping deletes\n    const start1 = op1.position;\n    const end1 = op1.position + op1.count;\n    const start2 = op2.position;\n    const end2 = op2.position + op2.count;\n\n    const newStart = Math.min(start1, start2);\n    const overlapStart = Math.max(start1, start2);\n    const overlapE