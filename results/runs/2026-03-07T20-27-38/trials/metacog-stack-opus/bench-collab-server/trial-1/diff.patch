+import express from 'express';
+import { createServer, type Server as HttpServer } from 'http';
+import { createDb } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './ws.js';
+import type Database from 'better-sqlite3';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const app = express();
+  const db: Database.Database = createDb(dbPath);
+  const httpServer: HttpServer = createServer(app);
+  const collab = new CollaborationServer(httpServer, db);
+
+  const router = createRouter(db);
+  app.use('/api', router);
+
+  // Health check
+  app.get('/health', (_req, res) => {
+    res.json({ status: 'ok' });
+  });
+
+  return {
+    app,
+    async start(port?: number): Promise<number> {
+      return new Promise((resolve) => {
+        httpServer.listen(port ?? 0, () => {
+          const addr = httpServer.address();
+          const actualPort = typeof addr === 'object' && addr ? addr.port : 0;
+          resolve(actualPort);
+        });
+      });
+    },
+    async stop(): Promise<void> {
+      collab.closeAll();
+      return new Promise((resolve, reject) => {
+        httpServer.close((err) => {
+          db.close();
+          if (err) reject(err);
+          else resolve();
+        });
+      });
+    },
+  };
+}
