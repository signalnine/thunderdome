+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TmLNsjMkcY6MZwWqeNy4yK","type":"tool_result","content":[{"type":"text","text":"Excellent! Now let me compile the comprehensive report. Let me create a clear summary document:\n\n## COMPREHENSIVE SSG TOOLKIT CODEBASE EXPLORATION\n\nI have thoroughly explored the entire SSG toolkit codebase. Here is the complete analysis:\n\n---\n\n## 1. COMPLETE DIRECTORY STRUCTURE\n\n```\n/workspace/\n├── .eslintrc.cjs\n├── .gitignore\n├── TASK.md\n├── package.json\n├── package-lock.json\n├── tsconfig.json\n├── vitest.config.ts\n├── .git/\n├── .thunderdome/\n├── src/\n│   ├── core/\n│   │   ├── engine.ts         (117 lines)\n│   │   ├── index.ts          (4 lines)\n│   │   ├── templates.ts      (43 lines)\n│   │   └── types.ts          (44 lines)\n│   └── plugins/\n│       └── .gitkeep          (plugins to be created)\n└── tests/\n    ├── core.test.ts          (195 lines)\n    └── plugins/\n        ├── asset-pipeline.test.ts    (108 lines)\n        ├── dev-server.test.ts        (96 lines)\n        ├── markdown-ext.test.ts      (91 lines)\n        ├── rss-feed.test.ts          (121 lines)\n        ├── search-index.test.ts      (115 lines)\n        ├── sitemap.test.ts           (102 lines)\n        ├── syntax-highlight.test.ts  (108 lines)\n        └── taxonomy.test.ts          (127 lines)\n```\n\n---\n\n## 2. PLUGIN INTERFACE - COMPLETE DEFINITION\n\n### From `/workspace/src/core/types.ts` (FULL CONTENTS):\n\n```typescript\nexport interface SiteConfig {\n  title: string;\n  baseUrl: string;\n  outputDir: string;\n  contentDir: string;\n  templateDir: string;\n}\n\nexport interface ContentFile {\n  slug: string;\n  title: string;\n  content: string;        // raw content (markdown or html)\n  metadata: Record<string, unknown>;\n  date?: string;\n  tags?: string[];\n  template?: string;\n}\n\nexport interface BuildContext {\n  config: SiteConfig;\n  files: ContentFile[];\n  output: Map<string, string>;  // output path -> rendered content\n  assets: Map<string, Buffer>;  // output path -> binary data\n  data: Map<string, unknown>;   // shared plugin data store\n}\n\nexport interface PluginHooks {\n  beforeBuild?: (ctx: BuildContext) => Promise<void> | void;\n  transformContent?: (file: ContentFile, ctx: BuildContext) => Promise<ContentFile> | ContentFile;\n  afterBuild?: (ctx: BuildContext) => Promise<void> | void;\n}\n\nexport interface Plugin {\n  name: string;\n  version: string;\n  dependencies: string[];  // names of plugins this depends on\n  hooks: PluginHooks;\n}\n\nexport interface Template {\n  name: string;\n  render: (content: string, data: Record<string, unknown>) => string;\n}\n```\n\n**Key Plugin Fields:**\n- `name`: string - unique identifier\n- `version`: string - semantic version\n- `dependencies`: string[] - plugin dependency names for DAG resolution\n- `hooks`: PluginHooks object with optional lifecycle methods\n\n**PluginHooks Methods:**\n- `beforeBuild?(ctx: BuildContext)` - runs before content transformation, can read/write ctx.data\n- `transformContent?(file: ContentFile, ctx: BuildContext)` - transforms each file, must return ContentFile\n- `afterBuild?(ctx: BuildContext)` - runs after content transformation, can write to ctx.output, ctx.assets, ctx.data\n\n---\n\n## 3. BUILD ENGINE - HOW IT PROCESSES PLUGINS\n\n### From `/workspace/src/core/engine.ts` (FULL CONTENTS):\n\n```typescript\nimport { BuildContext, ContentFile, Plugin, SiteConfig, Template } from './types.js';\n\nexport class BuildEngine {\n  private plugins: Plugin[] = [];\n  private templates: Map<string, Template> = new Map();\n\n  constructor(private config: SiteConfig) {}\n\n  registerPlugin(plugin: Plugin): void {\n    this.plugins.push(plugin);\n  }\n\n  registerTemplate(template: Template): void {\n    this.templates.set(template.name, template);\n  }\n\n  // Resolve plugin execution order using topological sort\n  resolvePluginOrder(): Plugin[] {\n    const sorted: Plugin[] = [];\n    const visited = new Set<string>();\n    const visiting = new Set<string>();\n    const pluginMap = new Map(this.plugins.map(p => [p.name, p]));\n\n    const visit = (name: string) => {\n      if (visited.has(name)) return;\n      if (visiting.has(name)) {\n        throw new Error(`Circular dependency detected: ${name}`);\n      }\n      visiting.add(name);\n      const plugin = pluginMap.get(name);\n      if (plugin) {\n        for (const dep of plugin.dependencies) {\n          if (!pluginMap.has(dep)) {\n            throw new Error(`Missing dependency: ${name} requires ${dep}`);\n          }\n          visit(dep);\n        }\n      }\n      visiting.delete(name);\n      visited.add(name);\n      if (plugin) sorted.push(plugin);\n    };\n\n    for (const plugin of this.plugins) {\n      visit(plugin.name);\n    }\n    return sorted;\n  }\n\n  async build(files: ContentFile[]): Promise<BuildContext> {\n    const ctx: BuildContext = {\n      config: this.config,\n      files: [...files],\n      output: new Map(),\n      assets: new Map(),\n      data: new Map(),\n    };\n\n    const orderedPlugins = this.resolvePluginOrder();\n\n    // beforeBuild hooks\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.beforeBuild) {\n        await plugin.hooks.beforeBuild(ctx);\n      }\n    }\n\n    // transformContent hooks (applied to each file in plugin order)\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.transformContent) {\n        const transformed: ContentFile[] = [];\n        for (const file of ctx.files) {\n          transformed.push(await plugin.hooks.transformContent(file, ctx));\n        }\n        ctx.files = transformed;\n      }\n    }\n\n    // Render templates\n    for (const file of ctx.files) {\n      const templateName = file.template || 'default';\n      const template = this.templates.get(templateName);\n      if (template) {\n        const rendered = template.render(file.content, {\n          title: file.title,\n          slug: file.slug,\n          date: file.date,\n          tags: file.tags,\n          ...file.metadata,\n          siteTitle: this.config.title,\n          baseUrl: this.config.baseUrl,\n        });\n        ctx.output.set(`${file.slug}.html`, rendered);\n      } else {\n        ctx.output.set(`${file.slug}.html`, file.content);\n      }\n    }\n\n    // afterBuild hooks\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.afterBuild) {\n        await plugin.hooks.afterBuild(ctx);\n      }\n    }\n\n    return ctx;\n  }\n\n  getPlugins(): Plugin[] {\n    return [...this.plugins];\n  }\n\n  getTemplates(): Map<string, Template> {\n    return new Map(this.templates);\n  }\n}\n```\n\n**Build Pipeline Sequence:**\n1. Create BuildContext with config, files, and empty output/assets/data maps\n2. Resolve plugin execution order using topological sort (detects circular/missing deps)\n3. Execute `beforeBuild` hooks in dependency order\n4. Execute `transformContent` hooks sequentially on all files - each plugin processes the entire file list\n5. Render templates using default or specified template, passing file metadata and config to render function\n6. Execute `afterBuild` hooks in dependency order\n7. Return final BuildContext\n\n**Key Points:**\n- Template rendering happens AFTER all transformContent hooks\n- transformContent is called once per plugin per file\n- Output paths are set to `${file.slug}.html` for content files\n- Plugins can add to `ctx.output`, `ctx.assets`, and `ctx.data` in afterBuild\n\n---\n\n## 4. TEMPLATE SYSTEM\n\n### From `/workspace/src/core/templates.ts` (FULL CONTENTS):\n\n```typescript\nimport { Template } from './types.js';\n\nexport function createDefaultTemplate(): Template {\n  return {\n    name: 'default',\n    render: (content: string, data: Record<string, unknown>) => {\n      return `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n</head>\n<body>\n  <article>\n    <h1>${data.title || ''}</h1>\n    ${data.date ? `<time>${data.date}</time>` : ''}\n    <div class=\"content\">${content}</div>\n  </article>\n</body>\n</html>`;\n    }\n  };\n}\n\nexport function createListTemplate(): Template {\n  return {\n    name: 'list',\n    render: (content: string, data: Record<string, unknown>) => {\n      return `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n</head>\n<body>\n  <h1>${data.title || ''}</h1>\n  <div class=\"list\">${content}</div>\n</body>\n</html>`;\n    }\n  };\n}\n```\n\n**Data Available to Templates:**\n- From file: `title`, `slug`, `date`, `tags`, and all `metadata` fields\n- From config: `siteTitle`, `baseUrl`\n- Content passed separately as first argument\n\n---\n\n## 5. CORE TESTS - `/workspace/tests/core.test.ts` (COMPLETE)\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { BuildEngine, createDefaultTemplate, createListTemplate } from '../src/core/index.js';\nimport { ContentFile, Plugin, SiteConfig } from '../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test-post',\n    title: 'Test Post',\n    content: '<p>Hello world</p>',\n    metadata: {},\n    ...overrides,\n  };\n}\n\nfunction makePlugin(overrides: Partial<Plugin> = {}): Plugin {\n  return {\n    name: 'test-plugin',\n    version: '1.0.0',\n    dependencies: [],\n    hooks: {},\n    ...overrides,\n  };\n}\n\ndescribe('BuildEngine', () => {\n  it('registers plugins', () => {\n    const engine = new BuildEngine(testConfig);\n    const plugin = makePlugin({ name: 'my-plugin' });\n    engine.registerPlugin(plugin);\n    expect(engine.getPlugins()).toHaveLength(1);\n    expect(engine.getPlugins()[0].name).toBe('my-plugin');\n  });\n\n  it('registers templates', () => {\n    const engine = new BuildEngine(testConfig);\n    const template = createDefaultTemplate();\n    engine.registerTemplate(template);\n    expect(engine.getTemplates().has('default')).toBe(true);\n  });\n\n  it('builds with default template and renders HTML', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerTemplate(createDefaultTemplate());\n    const file = makeFile({ title: 'My Post', content: '<p>Content here</p>' });\n    const ctx = await engine.build([file]);\n    const output = ctx.output.get('test-post.html')!;\n    expect(output).toContain('<!DOCTYPE html>');\n    expect(output).toContain('My Post');\n    expect(output).toContain('<p>Content here</p>');\n    expect(output).toContain('Test Site');\n  });\n\n  it('builds with list template and renders list HTML', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerTemplate(createListTemplate());\n    const file = makeFile({ title: 'My List', content: '<ul><li>Item</li></ul>', template: 'list' });\n    const ctx = await engine.build([file]);\n    const output = ctx.output.get('test-post.html')!;\n    expect(output).toContain('<!DOCTYPE html>');\n    expect(output).toContain('My List');\n    expect(output).toContain('<div class=\"list\">');\n    expect(output).toContain('<ul><li>Item</li></ul>');\n  });\n\n  it('outputs raw content when no matching template', async () => {\n    const engine = new BuildEngine(testConfig);\n    const file = makeFile({ content: '<p>Raw content</p>' });\n    const ctx = await engine.build([file]);\n    expect(ctx.output.get('test-post.html')).toBe('<p>Raw content</p>');\n  });\n\n  it('calls plugin beforeBuild hook', async () => {\n    const engine = new BuildEngine(testConfig);\n    let called = false;\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        beforeBuild: () => { called = true; },\n      },\n    }));\n    await engine.build([]);\n    expect(called).toBe(true);\n  });\n\n  it('calls plugin transformContent hook to transform files', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        transformContent: (file) => ({\n          ...file,\n          content: file.content.toUpperCase(),\n        }),\n      },\n    }));\n    const ctx = await engine.build([makeFile({ content: 'hello' })]);\n    expect(ctx.files[0].content).toBe('HELLO');\n  });\n\n  it('calls plugin afterBuild hook', async () => {\n    const engine = new BuildEngine(testConfig);\n    let called = false;\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        afterBuild: () => { called = true; },\n      },\n    }));\n    await engine.build([]);\n    expect(called).toBe(true);\n  });\n\n  it('executes plugins in dependency order', () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n    engine.registerPlugin(makePlugin({ name: 'a', dependencies: [] }));\n    const order = engine.resolvePluginOrder();\n    expect(order.map(p => p.name)).toEqual(['a', 'b']);\n  });\n\n  it('throws on circular dependency', () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['b'] }));\n    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n    expect(() => engine.resolvePluginOrder()).toThrow('Circular dependency');\n  });\n\n  it('throws on missing dependency', () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['missing'] }));\n    expect(() => engine.resolvePluginOrder()).toThrow('Missing dependency');\n  });\n\n  it('applies multiple plugins transformContent in order', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({\n      name: 'first',\n      hooks: {\n        transformContent: (file) => ({\n          ...file,\n          content: file.content + ' [first]',\n        }),\n      },\n    }));\n    engine.registerPlugin(makePlugin({\n      name: 'second',\n      hooks: {\n        transformContent: (file) => ({\n          ...file,\n          content: file.content + ' [second]',\n        }),\n      },\n    }));\n    const ctx = await engine.build([makeFile({ content: 'start' })]);\n    expect(ctx.files[0].content).toBe('start [first] [second]');\n  });\n\n  it('provides shared data store in build context', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        beforeBuild: (ctx) => { ctx.data.set('key', 'value'); },\n      },\n    }));\n    const ctx = await engine.build([]);\n    expect(ctx.data.get('key')).toBe('value');\n  });\n\n  it('retains file metadata through build', async () => {\n    const engine = new BuildEngine(testConfig);\n    const file = makeFile({\n      metadata: { author: 'Alice', category: 'tech' },\n      date: '2024-01-01',\n      tags: ['js', 'node'],\n    });\n    const ctx = await engine.build([file]);\n    expect(ctx.files[0].metadata).toEqual({ author: 'Alice', category: 'tech' });\n    expect(ctx.files[0].date).toBe('2024-01-01');\n    expect(ctx.files[0].tags).toEqual(['js', 'node']);\n  });\n\n  it('produces empty output for empty file list', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerTemplate(createDefaultTemplate());\n    const ctx = await engine.build([]);\n    expect(ctx.output.size).toBe(0);\n    expect(ctx.files).toHaveLength(0);\n  });\n});\n```\n\n---\n\n## 6. ALL PLUGIN TEST FILES\n\n### `/workspace/tests/plugins/asset-pipeline.test.ts` (COMPLETE)\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createAssetPipelinePlugin } from '../../src/plugins/asset-pipeline.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: new Map(),\n    assets: new Map(),\n    data: new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('asset-pipeline plugin', () => {\n  const plugin = createAssetPipelinePlugin();\n\n  it('rewrites relative image URLs to /assets/ path', async () => {\n    const file = makeFile({ content: '<img src=\"./image.png\" alt=\"test\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('src=\"/assets/image.png\"');\n    expect(result.content).not.toContain('src=\"./image.png\"');\n  });\n\n  it('rewrites relative link URLs to /assets/ path', async () => {\n    const file = makeFile({ content: '<a href=\"./doc.pdf\">Download</a>' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('href=\"/assets/doc.pdf\"');\n    expect(result.content).not.toContain('href=\"./doc.pdf\"');\n  });\n\n  it('leaves absolute URLs unchanged', async () => {\n    const file = makeFile({ content: '<img src=\"https://cdn.example.com/image.png\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('src=\"https://cdn.example.com/image.png\"');\n  });\n\n  it('generates asset manifest in ctx.data', async () => {\n    const file = makeFile({ content: '<img src=\"./photo.jpg\">' });\n    const ctx = makeCtx();\n    await plugin.hooks.transformContent!(file, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest).toBeDefined();\n    expect(manifest.assets).toContain('photo.jpg');\n  });\n\n  it('handles files with no asset references', async () => {\n    const file = makeFile({ content: '<p>No assets here</p>' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toBe('<p>No assets here</p>');\n  });\n\n  it('handles multiple assets in one file', async () => {\n    const file = makeFile({\n      content: '<img src=\"./a.png\"><img src=\"./b.jpg\"><a href=\"./c.pdf\">link</a>',\n    });\n    const ctx = makeCtx();\n    await plugin.hooks.transformContent!(file, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest.assets).toContain('a.png');\n    expect(manifest.assets).toContain('b.jpg');\n    expect(manifest.assets).toContain('c.pdf');\n  });\n\n  it('asset manifest includes all discovered assets', async () => {\n    const ctx = makeCtx();\n    const file1 = makeFile({ content: '<img src=\"./one.png\">' });\n    const file2 = makeFile({ content: '<img src=\"./two.png\">' });\n    await plugin.hooks.transformContent!(file1, ctx);\n    await plugin.hooks.transformContent!(file2, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest.assets).toHaveLength(2);\n    expect(manifest.assets).toContain('one.png');\n    expect(manifest.assets).toContain('two.png');\n  });\n\n  it('does not double-process already-rewritten URLs', async () => {\n    const file = makeFile({ content: '<img src=\"/assets/image.png\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toBe('<img src=\"/assets/image.png\">');\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;\n    expect(!manifest || manifest.assets.length === 0).toBe(true);\n  });\n});\n```\n\n**Expected Factory Function:** `createAssetPipelinePlugin()` returns Plugin\n\n**Expected Hooks:** `transformContent`\n\n**Expected Behavior:**\n- Rewrites relative URLs in img src and a href to `/assets/` paths\n- Leaves absolute URLs unchanged\n- Tracks discovered assets in `ctx.data.set('asset-manifest', { assets: string[] })`\n- Accumulates assets across all files processed\n\n---\n\n### `/workspace/tests/plugins/dev-server.test.ts` (COMPLETE)\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createDevServerPlugin } from '../../src/plugins/dev-server.js';\nimport { BuildContext, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\ninterface DevServerConfig {\n  port: number;\n  routes: Array<{ path: string; handler: string }>;\n  assetPaths: string[];\n  searchIndexPath: string;\n}\n\nfunction makeCtx(\n  output?: Map<string, string>,\n  data?: Map<string, unknown>\n): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: output || new Map(),\n    assets: new Map(),\n    data: data || new Map(),\n  };\n}\n\ndescribe('dev-server plugin', () => {\n  const plugin = createDevServerPlugin();\n\n  it('stores dev-server-config in ctx.data', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.data.has('dev-server-config')).toBe(true);\n  });\n\n  it('config includes port setting', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.port).toBeDefined();\n    expect(typeof config.port).toBe('number');\n  });\n\n  it('config includes asset routes from asset-pipeline', async () => {\n    const data = new Map<string, unknown>();\n    data.set('asset-manifest', { assets: ['image.png', 'style.css'] });\n    const ctx = makeCtx(new Map(), data);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.assetPaths).toContain('image.png');\n    expect(config.assetPaths).toContain('style.css');\n    const assetRoutes = config.routes.filter(r => r.handler === 'asset');\n    expect(assetRoutes.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it('config includes search index path', async () => {\n    const output = new Map<string, string>();\n    output.set('search-index.json', '[]');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.searchIndexPath).toBe('/search-index.json');\n  });\n\n  it('config includes content routes', async () => {\n    const output = new Map<string, string>();\n    output.set('post-1.html', '<html></html>');\n    output.set('post-2.html', '<html></html>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    const contentRoutes = config.routes.filter(r => r.handler === 'static');\n    expect(contentRoutes.length).toBe(2);\n  });\n\n  it('default port is 3000', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.port).toBe(3000);\n  });\n\n  it('handles missing asset-pipeline data gracefully', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.assetPaths).toEqual([]);\n  });\n});\n```\n\n**Expected Factory Function:** `createDevServerPlugin()` returns Plugin\n\n**Expected Hooks:** `afterBuild`\n\n**Expected Behavior:**\n- Creates dev-server-config object in `ctx.data`\n- Config includes