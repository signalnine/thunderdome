--- /dev/null
+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,135 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function parseFootnotes(content: string): { body: string; footnotes: Map<string, string> } {
+  const footnotes = new Map<string, string>();
+  const defRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  let match: RegExpExecArray | null;
+
+  while ((match = defRegex.exec(content)) !== null) {
+    footnotes.set(match[1], match[2]);
+  }
+
+  // Remove footnote definitions from content
+  const body = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '').trimEnd();
+
+  return { body, footnotes };
+}
+
+function renderFootnoteRefs(html: string): string {
+  return html.replace(/\[\^(\d+)\]/g, '<sup><a href="#fn-$1">$1</a></sup>');
+}
+
+function renderFootnoteSection(footnotes: Map<string, string>): string {
+  if (footnotes.size === 0) return '';
+  const items = Array.from(footnotes.entries())
+    .map(([id, text]) => `<li id="fn-${id}">${text}</li>`)
+    .join('\n');
+  return `\n<section class="footnotes">\n<ol>\n${items}\n</ol>\n</section>`;
+}
+
+function processAdmonitions(content: string): string {
+  return content.replace(/^:::(note|warning|tip)\n([\s\S]*?)^:::/gm, (_match, type: string, body: string) => {
+    return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+  });
+}
+
+function markdownToHtml(text: string): string {
+  let html = text;
+
+  // Process headings (# to ######)
+  html = html.replace(/^######\s+(.+)$/gm, '<h6>$1</h6>');
+  html = html.replace(/^#####\s+(.+)$/gm, '<h5>$1</h5>');
+  html = html.replace(/^####\s+(.+)$/gm, '<h4>$1</h4>');
+  html = html.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
+  html = html.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
+  html = html.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');
+
+  // Process bold and italic
+  html = html.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
+  html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
+  html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
+
+  // Process inline code
+  html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
+
+  // Process links
+  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
+
+  // Process paragraphs - wrap lines that aren't already HTML block elements
+  const lines = html.split('\n');
+  const result: string[] = [];
+  let paragraphLines: string[] = [];
+
+  const flushParagraph = () => {
+    if (paragraphLines.length > 0) {
+      result.push('<p>' + paragraphLines.join(' ') + '</p>');
+      paragraphLines = [];
+    }
+  };
+
+  for (const line of lines) {
+    const trimmed = line.trim();
+    if (trimmed === '') {
+      flushParagraph();
+      continue;
+    }
+    // Check if it's already an HTML block element or heading
+    if (/^<(h[1-6]|div|section|pre|ul|ol|li|blockquote|table|hr|p)[>\s/]/.test(trimmed) ||
+        /^<\/(h[1-6]|div|section|pre|ul|ol|li|blockquote|table|hr|p)>/.test(trimmed)) {
+      flushParagraph();
+      result.push(line);
+    } else {
+      paragraphLines.push(trimmed);
+    }
+  }
+  flushParagraph();
+
+  return result.join('\n');
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        if (!content || content.trim() === '') {
+          return { ...file, content: '' };
+        }
+
+        // Check if content is already HTML (starts with an HTML tag)
+        const trimmed = content.trim();
+        if (trimmed.startsWith('<') && !trimmed.startsWith('<') === false) {
+          return { ...file, content };
+        }
+
+        // Process admonitions before markdown conversion
+        content = processAdmonitions(content);
+
+        // Parse footnotes
+        const { body, footnotes } = parseFootnotes(content);
+        content = body;
+
+        // Convert markdown to HTML
+        // Only convert if it looks like markdown (has markdown markers, not pure HTML)
+        const hasMarkdownSyntax = /(?:^#|\*\*|^\[\^|\[.*\]\(|^:::)/m.test(content);
+        const isPureHtml = trimmed.startsWith('<') && !hasMarkdownSyntax;
+
+        if (!isPureHtml) {
+          content = markdownToHtml(content);
+        }
+
+        // Process footnote references in the HTML
+        content = renderFootnoteRefs(content);
+
+        // Add footnote section
+        content += renderFootnoteSection(footnotes);
+
+        return { ...file, content };
+      },
+    },
+  };
+}
diff --git a/src/plugins/rss-feed.ts b/src/plugins/rss-feed.ts
