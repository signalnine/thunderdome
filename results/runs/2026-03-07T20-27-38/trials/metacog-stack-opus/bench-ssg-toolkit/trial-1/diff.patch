= makeFile({\n      content:\n        '<pre><code class=\"language-js\">let a = 1;</code></pre>' +\n        '<p>Some text</p>' +\n        '<pre><code class=\"language-py\">x = 2</code></pre>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('data-language=\"js\"');\n    expect(result.content).toContain('data-language=\"py\"');\n  });\n\n  it('handles code block with no language specified', async () => {\n    const file = makeFile({\n      content: '<pre><code>plain code</code></pre>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    // Should not add highlighted class or data-language to blocks without language\n    expect(result.content).toBe('<pre><code>plain code</code></pre>');\n    expect(result.content).not.toContain('highlighted');\n  });\n\n  it('adds highlighted class to processed blocks', async () => {\n    const file = makeFile({\n      content: '<pre><code class=\"language-rust\">fn main() {}</code></pre>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('highlighted');\n  });\n\n  it('preserves code block content', async () => {\n    const file = makeFile({\n      content: '<pre><code class=\"language-ts\">const x: number = 42;</code></pre>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('const x: number = 42;');\n  });\n\n  it('handles empty code blocks', async () => {\n    const file = makeFile({\n      content: '<pre><code class=\"language-js\"></code></pre>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('data-language=\"js\"');\n    expect(result.content).toContain('highlighted');\n  });\n\n  it('does not modify inline code', async () => {\n    const file = makeFile({\n      content: '<p>Use <code>console.log()</code> for debugging.</p>',\n    });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toBe('<p>Use <code>console.log()</code> for debugging.</p>');\n    expect(result.content).not.toContain('highlighted');\n  });\n});\n```\n\n**Expected Factory Function:** `createSyntaxHighlightPlugin()` returns Plugin\n\n**Expected Hooks:** `transformContent`\n\n**Expected Behavior:**\n- Processes `<pre><code class=\"language-XXX\">` blocks only\n- Adds `highlighted` class to code element\n- Adds `data-language=\"XXX\"` attribute to pre tag\n- Does not process code blocks without language class\n- Does not modify inline `<code>` tags (outside of pre)\n- Preserves code block content exactly\n\n---\n\n### `/workspace/tests/plugins/taxonomy.test.ts` (COMPLETE)\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createTaxonomyPlugin } from '../../src/plugins/taxonomy.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(files: ContentFile[] = []): BuildContext {\n  return {\n    config: testConfig,\n    files,\n    output: new Map(),\n    assets: new Map(),\n    data: new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '<p>content</p>',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('taxonomy plugin', () => {\n  const plugin = createTaxonomyPlugin();\n\n  it('builds tag index from file tags', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['javascript', 'node'] }),\n      makeFile({ slug: 'post-2', title: 'Post 2', tags: ['javascript'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap).toBeDefined();\n    expect(tagMap.get('javascript')).toHaveLength(2);\n    expect(tagMap.get('node')).toHaveLength(1);\n  });\n\n  it('generates tag listing pages in ctx.output', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['javascript'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.output.has('tags/javascript.html')).toBe(true);\n    expect(ctx.output.get('tags/javascript.html')).toContain('Post 1');\n  });\n\n  it('handles files with no tags', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1' }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.size).toBe(0);\n  });\n\n  it('handles files with multiple tags', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['js', 'node', 'web'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.size).toBe(3);\n    expect(tagMap.has('js')).toBe(true);\n    expect(tagMap.has('node')).toBe(true);\n    expect(tagMap.has('web')).toBe(true);\n  });\n\n  it('tag pages list all files with that tag', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'First Post', tags: ['tech'] }),\n      makeFile({ slug: 'post-2', title: 'Second Post', tags: ['tech'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    await plugin.hooks.afterBuild!(ctx);\n    const tagPage = ctx.output.get('tags/tech.html')!;\n    expect(tagPage).toContain('First Post');\n    expect(tagPage).toContain('Second Post');\n  });\n\n  it('stores tag map in ctx.data', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['alpha'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    expect(ctx.data.has('taxonomy-tags')).toBe(true);\n  });\n\n  it('handles empty file list', async () => {\n    const ctx = makeCtx([]);\n    await plugin.hooks.beforeBuild!(ctx);\n    await plugin.hooks.afterBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.size).toBe(0);\n  });\n\n  it('tags are case-normalized to lowercase', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['JavaScript'] }),\n      makeFile({ slug: 'post-2', title: 'Post 2', tags: ['JAVASCRIPT'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.beforeBuild!(ctx);\n    const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;\n    expect(tagMap.has('javascript')).toBe(true);\n    expect(tagMap.get('javascript')).toHaveLength(2);\n    expect(tagMap.has('JavaScript')).toBe(false);\n    expect(tagMap.has('JAVASCRIPT')).toBe(false);\n  });\n});\n```\n\n**Expected Factory Function:** `createTaxonomyPlugin()` returns Plugin\n\n**Expected Hooks:** `beforeBuild` and `afterBuild`\n\n**Expected Behavior:**\n- `beforeBuild`: Creates tag map from `ctx.files[].tags` and stores in `ctx.data.set('taxonomy-tags', Map<string, ContentFile[]>)`\n- Tags normalized to lowercase\n- `afterBuild`: Generates tag listing pages as `tags/{tag}.html` in `ctx.output`\n- Tag pages list all files with that tag (include titles or content)\n- Handles empty files and files without tags gracefully\n\n---\n\n## 7. PACKAGE.JSON DEPENDENCIES AND SCRIPTS\n\n### `/workspace/package.json` (COMPLETE):\n\n```json\n{\n  \"name\": \"bench-ssg-toolkit\",\n  \"version\": \"1.0.0\",\n  \"description\": \"SSG Toolkit benchmark - static site generator with DAG plugin system\",\n  \"main\": \"dist/core/index.js\",\n  \"scripts\": {\n    \"build\": \"tsc\",\n    \"lint\": \"eslint src/ tests/\",\n    \"test\": \"vitest run\"\n  },\n  \"keywords\": [],\n  \"author\": \"\",\n  \"license\": \"ISC\",\n  \"type\": \"module\",\n  \"devDependencies\": {\n    \"@typescript-eslint/eslint-plugin\": \"^7.18.0\",\n    \"@typescript-eslint/parser\": \"^7.18.0\",\n    \"eslint\": \"^8.57.1\",\n    \"typescript\": \"^5.9.3\",\n    \"vitest\": \"^2.1.9\"\n  },\n  \"dependencies\": {\n    \"@types/express\": \"^5.0.6\",\n    \"@types/marked\": \"^5.0.2\",\n    \"express\": \"^5.2.1\",\n    \"marked\": \"^17.0.2\"\n  }\n}\n```\n\n**Dev Dependencies:**\n- TypeScript, ESLint, Vitest (for development and testing)\n- Linting with @typescript-eslint\n\n**Runtime Dependencies:**\n- `marked` (^17.0.2) - markdown parsing\n- `express` (^5.2.1) - dev server\n- Type definitions for both\n\n**Available Scripts:**\n- `npm run build` - TypeScript compilation to dist/\n- `npm run lint` - ESLint\n- `npm test` - Run vitest tests\n\n---\n\n## 8. TSCONFIG.JSON SETTINGS\n\n### `/workspace/tsconfig.json` (COMPLETE):\n\n```json\n{\n  \"compilerOptions\": {\n    \"strict\": true,\n    \"target\": \"ES2022\",\n    \"module\": \"Node16\",\n    \"moduleResolution\": \"Node16\",\n    \"outDir\": \"./dist\",\n    \"rootDir\": \"./src\",\n    \"declaration\": true,\n    \"esModuleInterop\": true,\n    \"skipLibCheck\": true\n  },\n  \"include\": [\"src/**/*\"]\n}\n```\n\n**Key Settings:**\n- `strict: true` - Full type checking enabled\n- `target: ES2022` - Compile to modern JavaScript\n- `module: Node16` - ES modules with Node resolution\n- `outDir: ./dist` - Output compiled JavaScript\n- `rootDir: ./src` - Source directory\n- `declaration: true` - Generate `.d.ts` files\n- `esModuleInterop: true` - CommonJS interoperability\n- Includes only `src/**/*` files\n\n---\n\n## 9. VITEST CONFIGURATION\n\n### `/workspace/vitest.config.ts` (COMPLETE):\n\n```typescript\nimport { defineConfig } from 'vitest/config';\n\nexport default defineConfig({\n  test: {\n    globals: true,\n    testTimeout: 10000,\n  },\n});\n```\n\n**Settings:**\n- `globals: true` - Global test APIs (describe, it, expect)\n- `testTimeout: 10000` - 10 second timeout per test\n\n---\n\n## 10. SUMMARY OF PLUGIN REQUIREMENTS\n\n| Plugin | Factory Function | Hooks | Dependencies | Wave |\n|--------|------------------|-------|--------------|------|\n| markdown-ext | `createMarkdownExtPlugin()` | `transformContent` | none | 1 |\n| asset-pipeline | `createAssetPipelinePlugin()` | `transformContent` | none | 1 |\n| syntax-highlight | `createSyntaxHighlightPlugin()` | `transformContent` | none | 1 |\n| taxonomy | `createTaxonomyPlugin()` | `beforeBuild`, `afterBuild` | none | 1 |\n| rss-feed | `createRssFeedPlugin()` | `afterBuild` | markdown-ext, taxonomy | 2 |\n| search-index | `createSearchIndexPlugin()` | `afterBuild` | markdown-ext, syntax-highlight | 2 |\n| sitemap | `createSitemapPlugin()` | `afterBuild` | taxonomy, rss-feed | 3 |\n| dev-server | `createDevServerPlugin()` | `afterBuild` | asset-pipeline, search-index | 3 |\n\n---\n\n## 11. KEY DATA FLOWS\n\n**Plugin Data Store Keys (ctx.data):**\n- `asset-manifest`: `{ assets: string[] }` - from asset-pipeline\n- `taxonomy-tags`: `Map<string, ContentFile[]>` - from taxonomy\n- `dev-server-config`: DevServerConfig object - from dev-server\n\n**Output Files (ctx.output):**\n- `{slug}.html` - rendered content pages (from engine)\n- `tags/{tag}.html` - tag index pages (from taxonomy)\n- `feed.xml` - RSS feed (from rss-feed)\n- `sitemap.xml` - XML sitemap (from sitemap)\n- `search-index.json` - search index (from search-index)\n\n**Build Pipeline Order:**\n1. All beforeBuild hooks (in dependency order)\n2. All transformContent hooks (for each file, in dependency order)\n3. Template rendering (engine)\n4. All afterBuild hooks (in dependency order)\n\nThis completes the comprehensive exploration of the SSG toolkit codebase. All files have been read in their entirety, and the complete interfaces, dependencies, and expected behaviors are documented above."},{"type":"text","text":"agentId: aeb2d1d (for resuming to continue this agent's work if needed)\n<usage>total_tokens: 50656\ntool_uses: 22\nduration_ms: 107851</usage>"}]}]},"parent_tool_use_id":null,"session_id":"2ed8f53b-2468-4ef7-be48-a2d033e01ba4","uuid":"ce4afb0d-8772-4348-ba55-2118bb24b917","tool_use_result":{"status":"completed","prompt":"Thoroughly explore this SSG toolkit codebase. I need to understand:\n\n1. The complete directory structure (all files)\n2. The Plugin interface from src/core/types.ts - every field and method\n3. The build engine in src/core/ - how it processes plugins\n4. The template system\n5. ALL test files in tests/ - both core.test.ts and every file in tests/plugins/\n6. package.json dependencies and scripts\n7. tsconfig.json settings\n\nRead EVERY file completely. I need the full contents, not summaries. Pay special attention to:\n- The exact Plugin interface definition\n- What factory function signatures the tests expect\n- What methods each plugin test expects (hooks, transforms, etc.)\n- The ContentFile / Site / BuildContext types\n- How the build pipeline calls plugin hooks\n\nList all files and provide their full contents.","agentId":"aeb2d1d","content":[{"type":"text","text":"Excellent! Now let me compile the comprehensive report. Let me create a clear summary document:\n\n## COMPREHENSIVE SSG TOOLKIT CODEBASE EXPLORATION\n\nI have thoroughly explored the entire SSG toolkit codebase. Here is the complete analysis:\n\n---\n\n## 1. COMPLETE DIRECTORY STRUCTURE\n\n```\n/workspace/\n├── .eslintrc.cjs\n├── .gitignore\n├── TASK.md\n├── package.json\n├── package-lock.json\n├── tsconfig.json\n├── vitest.config.ts\n├── .git/\n├── .thunderdome/\n├── src/\n│   ├── core/\n│   │   ├── engine.ts         (117 lines)\n│   │   ├── index.ts          (4 lines)\n│   │   ├── templates.ts      (43 lines)\n│   │   └── types.ts          (44 lines)\n│   └── plugins/\n│       └── .gitkeep          (plugins to be created)\n└── tests/\n    ├── core.test.ts          (195 lines)\n    └── plugins/\n        ├── asset-pipeline.test.ts    (108 lines)\n        ├── dev-server.test.ts        (96 lines)\n        ├── markdown-ext.test.ts      (91 lines)\n        ├── rss-feed.test.ts          (121 lines)\n        ├── search-index.test.ts      (115 lines)\n        ├── sitemap.test.ts           (102 lines)\n        ├── syntax-highlight.test.ts  (108 lines)\n        └── taxonomy.test.ts          (127 lines)\n```\n\n---\n\n## 2. PLUGIN INTERFACE - COMPLETE DEFINITION\n\n### From `/workspace/src/core/types.ts` (FULL CONTENTS):\n\n```typescript\nexport interface SiteConfig {\n  title: string;\n  baseUrl: string;\n  outputDir: string;\n  contentDir: string;\n  templateDir: string;\n}\n\nexport interface ContentFile {\n  slug: string;\n  title: string;\n  content: string;        // raw content (markdown or html)\n  metadata: Record<string, unknown>;\n  date?: string;\n  tags?: string[];\n  template?: string;\n}\n\nexport interface BuildContext {\n  config: SiteConfig;\n  files: ContentFile[];\n  output: Map<string, string>;  // output path -> rendered content\n  assets: Map<string, Buffer>;  // output path -> binary data\n  data: Map<string, unknown>;   // shared plugin data store\n}\n\nexport interface PluginHooks {\n  beforeBuild?: (ctx: BuildContext) => Promise<void> | void;\n  transformContent?: (file: ContentFile, ctx: BuildContext) => Promise<ContentFile> | ContentFile;\n  afterBuild?: (ctx: BuildContext) => Promise<void> | void;\n}\n\nexport interface Plugin {\n  name: string;\n  version: string;\n  dependencies: string[];  // names of plugins this depends on\n  hooks: PluginHooks;\n}\n\nexport interface Template {\n  name: string;\n  render: (content: string, data: Record<string, unknown>) => string;\n}\n```\n\n**Key Plugin Fields:**\n- `name`: string - unique identifier\n- `version`: string - semantic version\n- `dependencies`: string[] - plugin dependency names for DAG resolution\n- `hooks`: PluginHooks object with optional lifecycle methods\n\n**PluginHooks Methods:**\n- `beforeBuild?(ctx: BuildContext)` - runs before content transformation, can read/write ctx.data\n- `transformContent?(file: ContentFile, ctx: BuildContext)` - transforms each file, must return ContentFile\n- `afterBuild?(ctx: BuildContext)` - runs after content transformation, can write to ctx.output, ctx.assets, ctx.data\n\n---\n\n## 3. BUILD ENGINE - HOW IT PROCESSES PLUGINS\n\n### From `/workspace/src/core/engine.ts` (FULL CONTENTS):\n\n```typescript\nimport { BuildContext, ContentFile, Plugin, SiteConfig, Template } from './types.js';\n\nexport class BuildEngine {\n  private plugins: Plugin[] = [];\n  private templates: Map<string, Template> = new Map();\n\n  constructor(private config: SiteConfig) {}\n\n  registerPlugin(plugin: Plugin): void {\n    this.plugins.push(plugin);\n  }\n\n  registerTemplate(template: Template): void {\n    this.templates.set(template.name, template);\n  }\n\n  // Resolve plugin execution order using topological sort\n  resolvePluginOrder(): Plugin[] {\n    const sorted: Plugin[] = [];\n    const visited = new Set<string>();\n    const visiting = new Set<string>();\n    const pluginMap = new Map(this.plugins.map(p => [p.name, p]));\n\n    const visit = (name: string) => {\n      if (visited.has(name)) return;\n      if (visiting.has(name)) {\n        throw new Error(`Circular dependency detected: ${name}`);\n      }\n      visiting.add(name);\n      const plugin = pluginMap.get(name);\n      if (plugin) {\n        for (const dep of plugin.dependencies) {\n          if (!pluginMap.has(dep)) {\n            throw new Error(`Missing dependency: ${name} requires ${dep}`);\n          }\n          visit(dep);\n        }\n      }\n      visiting.delete(name);\n      visited.add(name);\n      if (plugin) sorted.push(plugin);\n    };\n\n    for (const plugin of this.plugins) {\n      visit(plugin.name);\n    }\n    return sorted;\n  }\n\n  async build(files: ContentFile[]): Promise<BuildContext> {\n    const ctx: BuildContext = {\n      config: this.config,\n      files: [...files],\n      output: new Map(),\n      assets: new Map(),\n      data: new Map(),\n    };\n\n    const orderedPlugins = this.resolvePluginOrder();\n\n    // beforeBuild hooks\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.beforeBuild) {\n        await plugin.hooks.beforeBuild(ctx);\n      }\n    }\n\n    // transformContent hooks (applied to each file in plugin order)\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.transformContent) {\n        const transformed: ContentFile[] = [];\n        for (const file of ctx.files) {\n          transformed.push(await plugin.hooks.transformContent(file, ctx));\n        }\n        ctx.files = transformed;\n      }\n    }\n\n    // Render templates\n    for (const file of ctx.files) {\n      const templateName = file.template || 'default';\n      const template = this.templates.get(templateName);\n      if (template) {\n        const rendered = template.render(file.content, {\n          title: file.title,\n          slug: file.slug,\n          date: file.date,\n          tags: file.tags,\n          ...file.metadata,\n          siteTitle: this.config.title,\n          baseUrl: this.config.baseUrl,\n        });\n        ctx.output.set(`${file.slug}.html`, rendered);\n      } else {\n        ctx.output.set(`${file.slug}.html`, file.content);\n      }\n    }\n\n    // afterBuild hooks\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.afterBuild) {\n        await plugin.hooks.afterBuild(ctx);\n      }\n    }\n\n    return ctx;\n  }\n\n  getPlugins(): Plugin[] {\n    return [...this.plugins];\n  }\n\n  getTemplates(): Map<string, Template> {\n    return new Map(this.templates);\n  }\n}\n```\n\n**Build Pipeline Sequence:**\n1. Create BuildContext with config, files, and empty output/assets/data maps\n2. Resolve plugin execution order using topological sort (detects circular/missing deps)\n3. Execute `beforeBuild` hooks in dependency order\n4. Execute `transformContent` hooks sequentially on all files - each plugin processes the entire file list\n5. Render templates using default or specified template, passing file metadata and config to render function\n6. Execute `afterBuild` hooks in dependency order\n7. Return final BuildContext\n\n**Key Points:**\n- Template rendering happens AFTER all transformContent hooks\n- transformContent is called once per plugin per file\n- Output paths are set to `${file.slug}.html` for content files\n- Plugins can add to `ctx.output`, `ctx.assets`, and `ctx.data` in afterBuild\n\n---\n\n## 4. TEMPLATE SYSTEM\n\n### From `/workspace/src/core/templates.ts` (FULL CONTENTS):\n\n```typescript\nimport { Template } from './types.js';\n\nexport function createDefaultTemplate(): Template {\n  return {\n    name: 'default',\n    render: (content: string, data: Record<string, unknown>) => {\n      return `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n</head>\n<body>\n  <article>\n    <h1>${data.title || ''}</h1>\n    ${data.date ? `<time>${data.date}</time>` : ''}\n    <div class=\"content\">${content}</div>\n  </article>\n</body>\n</html>`;\n    }\n  };\n}\n\nexport function createListTemplate(): Template {\n  return {\n    name: 'list',\n    render: (content: string, data: Record<string, unknown>) => {\n      return `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>${data.title || ''} | ${data.siteTitle || ''}</title>\n</head>\n<body>\n  <h1>${data.title || ''}</h1>\n  <div class=\"list\">${content}</div>\n</body>\n</html>`;\n    }\n  };\n}\n```\n\n**Data Available to Templates:**\n- From file: `title`, `slug`, `date`, `tags`, and all `metadata` fields\n- From config: `siteTitle`, `baseUrl`\n- Content passed separately as first argument\n\n---\n\n## 5. CORE TESTS - `/workspace/tests/core.test.ts` (COMPLETE)\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { BuildEngine, createDefaultTemplate, createListTemplate } from '../src/core/index.js';\nimport { ContentFile, Plugin, SiteConfig } from '../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test-post',\n    title: 'Test Post',\n    content: '<p>Hello world</p>',\n    metadata: {},\n    ...overrides,\n  };\n}\n\nfunction makePlugin(overrides: Partial<Plugin> = {}): Plugin {\n  return {\n    name: 'test-plugin',\n    version: '1.0.0',\n    dependencies: [],\n    hooks: {},\n    ...overrides,\n  };\n}\n\ndescribe('BuildEngine', () => {\n  it('registers plugins', () => {\n    const engine = new BuildEngine(testConfig);\n    const plugin = makePlugin({ name: 'my-plugin' });\n    engine.registerPlugin(plugin);\n    expect(engine.getPlugins()).toHaveLength(1);\n    expect(engine.getPlugins()[0].name).toBe('my-plugin');\n  });\n\n  it('registers templates', () => {\n    const engine = new BuildEngine(testConfig);\n    const template = createDefaultTemplate();\n    engine.registerTemplate(template);\n    expect(engine.getTemplates().has('default')).toBe(true);\n  });\n\n  it('builds with default template and renders HTML', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerTemplate(createDefaultTemplate());\n    const file = makeFile({ title: 'My Post', content: '<p>Content here</p>' });\n    const ctx = await engine.build([file]);\n    const output = ctx.output.get('test-post.html')!;\n    expect(output).toContain('<!DOCTYPE html>');\n    expect(output).toContain('My Post');\n    expect(output).toContain('<p>Content here</p>');\n    expect(output).toContain('Test Site');\n  });\n\n  it('builds with list template and renders list HTML', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerTemplate(createListTemplate());\n    const file = makeFile({ title: 'My List', content: '<ul><li>Item</li></ul>', template: 'list' });\n    const ctx = await engine.build([file]);\n    const output = ctx.output.get('test-post.html')!;\n    expect(output).toContain('<!DOCTYPE html>');\n    expect(output).toContain('My List');\n    expect(output).toContain('<div class=\"list\">');\n    expect(output).toContain('<ul><li>Item</li></ul>');\n  });\n\n  it('outputs raw content when no matching template', async () => {\n    const engine = new BuildEngine(testConfig);\n    const file = makeFile({ content: '<p>Raw content</p>' });\n    const ctx = await engine.build([file]);\n    expect(ctx.output.get('test-post.html')).toBe('<p>Raw content</p>');\n  });\n\n  it('calls plugin beforeBuild hook', async () => {\n    const engine = new BuildEngine(testConfig);\n    let called = false;\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        beforeBuild: () => { called = true; },\n      },\n    }));\n    await engine.build([]);\n    expect(called).toBe(true);\n  });\n\n  it('calls plugin transformContent hook to transform files', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        transformContent: (file) => ({\n          ...file,\n          content: file.content.toUpperCase(),\n        }),\n      },\n    }));\n    const ctx = await engine.build([makeFile({ content: 'hello' })]);\n    expect(ctx.files[0].content).toBe('HELLO');\n  });\n\n  it('calls plugin afterBuild hook', async () => {\n    const engine = new BuildEngine(testConfig);\n    let called = false;\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        afterBuild: () => { called = true; },\n      },\n    }));\n    await engine.build([]);\n    expect(called).toBe(true);\n  });\n\n  it('executes plugins in dependency order', () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n    engine.registerPlugin(makePlugin({ name: 'a', dependencies: [] }));\n    const order = engine.resolvePluginOrder();\n    expect(order.map(p => p.name)).toEqual(['a', 'b']);\n  });\n\n  it('throws on circular dependency', () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['b'] }));\n    engine.registerPlugin(makePlugin({ name: 'b', dependencies: ['a'] }));\n    expect(() => engine.resolvePluginOrder()).toThrow('Circular dependency');\n  });\n\n  it('throws on missing dependency', () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({ name: 'a', dependencies: ['missing'] }));\n    expect(() => engine.resolvePluginOrder()).toThrow('Missing dependency');\n  });\n\n  it('applies multiple plugins transformContent in order', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({\n      name: 'first',\n      hooks: {\n        transformContent: (file) => ({\n          ...file,\n          content: file.content + ' [first]',\n        }),\n      },\n    }));\n    engine.registerPlugin(makePlugin({\n      name: 'second',\n      hooks: {\n        transformContent: (file) => ({\n          ...file,\n          content: file.content + ' [second]',\n        }),\n      },\n    }));\n    const ctx = await engine.build([makeFile({ content: 'start' })]);\n    expect(ctx.files[0].content).toBe('start [first] [second]');\n  });\n\n  it('provides shared data store in build context', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerPlugin(makePlugin({\n      hooks: {\n        beforeBuild: (ctx) => { ctx.data.set('key', 'value'); },\n      },\n    }));\n    const ctx = await engine.build([]);\n    expect(ctx.data.get('key')).toBe('value');\n  });\n\n  it('retains file metadata through build', async () => {\n    const engine = new BuildEngine(testConfig);\n    const file = makeFile({\n      metadata: { author: 'Alice', category: 'tech' },\n      date: '2024-01-01',\n      tags: ['js', 'node'],\n    });\n    const ctx = await engine.build([file]);\n    expect(ctx.files[0].metadata).toEqual({ author: 'Alice', category: 'tech' });\n    expect(ctx.files[0].date).toBe('2024-01-01');\n    expect(ctx.files[0].tags).toEqual(['js', 'node']);\n  });\n\n  it('produces empty output for empty file list', async () => {\n    const engine = new BuildEngine(testConfig);\n    engine.registerTemplate(createDefaultTemplate());\n    const ctx = await engine.build([]);\n    expect(ctx.output.size).toBe(0);\n    expect(ctx.files).toHaveLength(0);\n  });\n});\n```\n\n---\n\n## 6. ALL PLUGIN TEST FILES\n\n### `/workspace/tests/plugins/asset-pipeline.test.ts` (COMPLETE)\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createAssetPipelinePlugin } from '../../src/plugins/asset-pipeline.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: new Map(),\n    assets: new Map(),\n    data: new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('asset-pipeline plugin', () => {\n  const plugin = createAssetPipelinePlugin();\n\n  it('rewrites relative image URLs to /assets/ path', async () => {\n    const file = makeFile({ content: '<img src=\"./image.png\" alt=\"test\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('src=\"/assets/image.png\"');\n    expect(result.content).not.toContain('src=\"./image.png\"');\n  });\n\n  it('rewrites relative link URLs to /assets/ path', async () => {\n    const file = makeFile({ content: '<a href=\"./doc.pdf\">Download</a>' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('href=\"/assets/doc.pdf\"');\n    expect(result.content).not.toContain('href=\"./doc.pdf\"');\n  });\n\n  it('leaves absolute URLs unchanged', async () => {\n    const file = makeFile({ content: '<img src=\"https://cdn.example.com/image.png\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('src=\"https://cdn.example.com/image.png\"');\n  });\n\n  it('generates asset manifest in ctx.data', async () => {\n    const file = makeFile({ content: '<img src=\"./photo.jpg\">' });\n    const ctx = makeCtx();\n    await plugin.hooks.transformContent!(file, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest).toBeDefined();\n    expect(manifest.assets).toContain('photo.jpg');\n  });\n\n  it('handles files with no asset references', async () => {\n    const file = makeFile({ content: '<p>No assets here</p>' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toBe('<p>No assets here</p>');\n  });\n\n  it('handles multiple assets in one file', async () => {\n    const file = makeFile({\n      content: '<img src=\"./a.png\"><img src=\"./b.jpg\"><a href=\"./c.pdf\">link</a>',\n    });\n    const ctx = makeCtx();\n    await plugin.hooks.transformContent!(file, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest.assets).toContain('a.png');\n    expect(manifest.assets).toContain('b.jpg');\n    expect(manifest.assets).toContain('c.pdf');\n  });\n\n  it('asset manifest includes all discovered assets', async () => {\n    const ctx = makeCtx();\n    const file1 = makeFile({ content: '<img src=\"./one.png\">' });\n    const file2 = makeFile({ content: '<img src=\"./two.png\">' });\n    await plugin.hooks.transformContent!(file1, ctx);\n    await plugin.hooks.transformContent!(file2, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest.assets).toHaveLength(2);\n    expect(manifest.assets).toContain('one.png');\n    expect(manifest.assets).toContain('two.png');\n  });\n\n  it('does not double-process already-rewritten URLs', async () => {\n    const file = makeFile({ content: '<img src=\"/assets/image.png\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toBe('<img src=\"/assets/image.png\">');\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;\n    expect(!manifest || manifest.assets.length === 0).toBe(true);\n  });\n});\n```\n\n**Expected Factory Function:** `createAssetPipelinePlugin()` returns Plugin\n\n**Expected Hooks:** `transformContent`\n\n**Expected Behavior:**\n- Rewrites relative URLs in img src and a href to `/assets/` paths\n- Leaves absolute URLs unchanged\n- Tracks discovered assets in `ctx.data.set('asset-manifest', { assets: string[] })`\n- Accumulates assets across all files processed\n\n---\n\n### `/workspace/tests/plugins/dev-server.test.ts` (COMPLETE)\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createDevServerPlugin } from '../../src/plugins/dev-server.js';\nimport { BuildContext, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\ninterface DevServerConfig {\n  port: number;\n  routes: Array<{ path: string; handler: string }>;\n  assetPaths: string[];\n  searchIndexPath: string;\n}\n\nfunction makeCtx(\n  output?: Map<string, string>,\n  data?: Map<string, unknown>\n): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: output || new Map(),\n    assets: new Map(),\n    data: data || new Map(),\n  };\n}\n\ndescribe('dev-server plugin', () => {\n  const plugin = createDevServerPlugin();\n\n  it('stores dev-server-config in ctx.data', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.data.has('dev-server-config')).toBe(true);\n  });\n\n  it('config includes port setting', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.port).toBeDefined();\n    expect(typeof config.port).toBe('number');\n  });\n\n  it('config includes asset routes from asset-pipeline', async () => {\n    const data = new Map<string, unknown>();\n    data.set('asset-manifest', { assets: ['image.png', 'style.css'] });\n    const ctx = makeCtx(new Map(), data);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.assetPaths).toContain('image.png');\n    expect(config.assetPaths).toContain('style.css');\n    const assetRoutes = config.routes.filter(r => r.handler === 'asset');\n    expect(assetRoutes.length).toBeGreaterThanOrEqual(2);\n  });\n\n  it('config includes search index path', async () => {\n    const output = new Map<string, string>();\n    output.set('search-index.json', '[]');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.searchIndexPath).toBe('/search-index.json');\n  });\n\n  it('config includes content routes', async () => {\n    const output = new Map<string, string>();\n    output.set('post-1.html', '<html></html>');\n    output.set('post-2.html', '<html></html>');\n    const ctx = makeCtx(output);\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    const contentRoutes = config.routes.filter(r => r.handler === 'static');\n    expect(contentRoutes.length).toBe(2);\n  });\n\n  it('default port is 3000', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.port).toBe(3000);\n  });\n\n  it('handles missing asset-pipeline data gracefully', async () => {\n    const ctx = makeCtx();\n    await plugin.hooks.afterBuild!(ctx);\n    const config = ctx.data.get('dev-server-config') as DevServerConfig;\n    expect(config.assetPaths).toEqual([]);\n  });\n});\n```\n\n**Expected Factory Function:** `createDevServerPlugin()` returns Plugin\n\n**Expected Hooks:** `afterBuild`\n\n**Expected Behavior:**\n- Creates dev-server-config object in `ctx.data`\n- Config includes: `port` (default 3000), `routes` (array with path and handler), `assetPaths`, `searchIndexPath`\n- Routes include content routes with `handler: 'static'` for each output file\n- Routes include asset routes with `handler: 'asset'` for each asset from asset-pipeline\n- searchIndexPath defaults to `/search-index.json` if search-index.json exists in output\n- Should handle missing asset-pipeline data gracefully\n\n---\n\n### `/workspace/tests/plugins/markdown-ext.test.ts` (COMPLETE)\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createMarkdownExtPlugin } from '../../src/plugins/markdown-ext.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: new Map(),\n    assets: new Map(),\n    data: new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('markdown-ext plugin', () => {\n  const plugin = createMarkdownExtPlugin();\n\n  it('converts basic markdown to HTML', async () => {\n    const file = makeFile({ content: '# Hello\\n\\nThis is a **bold** paragraph.' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<h1>');\n    expect(result.content).toContain('Hello');\n    expect(result.content).toContain('<strong>bold</strong>');\n  });\n\n  it('handles footnotes with [^1] syntax', async () => {\n    const file = makeFile({ content: 'Some text[^1] here.\\n\\n[^1]: This is the footnote.' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<sup><a href=\"#fn-1\">1</a></sup>');\n  });\n\n  it('renders footnote section at bottom of content', async () => {\n    const file = makeFile({ content: 'Text[^1] and more[^2].\\n\\n[^1]: First note.\\n[^2]: Second note.' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<section class=\"footnotes\">');\n    expect(result.content).toContain('<li id=\"fn-1\">First note.</li>');\n    expect(result.content).toContain('<li id=\"fn-2\">Second note.</li>');\n  });\n\n  it('converts :::note container to admonition div', async () => {\n    const file = makeFile({ content: ':::note\\nThis is a note.\\n:::' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<div class=\"admonition admonition-note\">');\n    expect(result.content).toContain('This is a note.');\n  });\n\n  it('converts :::warning container to admonition div', async () => {\n    const file = makeFile({ content: ':::warning\\nBe careful!\\n:::' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<div class=\"admonition admonition-warning\">');\n    expect(result.content).toContain('Be careful!');\n  });\n\n  it('converts :::tip container to admonition div', async () => {\n    const file = makeFile({ content: ':::tip\\nHelpful hint.\\n:::' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('<div class=\"admonition admonition-tip\">');\n    expect(result.content).toContain('Helpful hint.');\n  });\n\n  it('preserves existing HTML in content', async () => {\n    const file = makeFile({ content: '<div class=\"custom\">Already HTML</div>' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toContain('Already HTML');\n  });\n\n  it('handles empty content', async () => {\n    const file = makeFile({ content: '' });\n    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    expect(result.content).toBeDefined();\n  });\n});\n```\n\n**Expected Factory Function:** `createMarkdownExtPlugin()` returns Plugin\n\n**Expected Hooks:** `transformContent`\n\n**Expected Behavior:**\n- Converts markdown syntax to HTML\n- Supports footnotes with `[^1]` syntax - creates superscript links\n- Renders footnote section at bottom with `<section class=\"footnotes\">`\n- Converts `:::note`, `:::warning`, `:::tip` containers to `<div class=\"admonition admonition-{type}\">`\n- Preserves existing HTML\n- Handles empty content gracefully\n\n---\n\n### `/workspace/tests/plugins/rss-feed.test.ts` (COMPLETE)\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createRssFeedPlugin } from '../../src/plugins/rss-feed.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(files: ContentFile[] = [], data?: Map<string, unknown>): BuildContext {\n  return {\n    config: testConfig,\n    files,\n    output: new Map(),\n    assets: new Map(),\n    data: data || new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '<p>HTML content</p>',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('rss-feed plugin', () => {\n  const plugin = createRssFeedPlugin();\n\n  it('generates valid RSS 2.0 XML', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1', date: '2024-01-01' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<?xml version=\"1.0\"');\n    expect(feed).toContain('<rss version=\"2.0\">');\n    expect(feed).toContain('<channel>');\n    expect(feed).toContain('<item>');\n    expect(feed).toContain('</rss>');\n  });\n\n  it('feed items contain HTML content not raw markdown', async () => {\n    const files = [\n      makeFile({\n        slug: 'post-1',\n        title: 'Post 1',\n        content: '<p>This is <strong>HTML</strong> content</p>',\n        date: '2024-01-01',\n      }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<![CDATA[<p>This is <strong>HTML</strong> content</p>]]>');\n  });\n\n  it('feed items include category tags from taxonomy', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', tags: ['javascript'], date: '2024-01-01' }),\n    ];\n    const tagMap = new Map<string, ContentFile[]>();\n    tagMap.set('javascript', [files[0]]);\n    const data = new Map<string, unknown>();\n    data.set('taxonomy-tags', tagMap);\n    const ctx = makeCtx(files, data);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<category>javascript</category>');\n  });\n\n  it('feed includes channel title from config', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<title>Test Site</title>');\n  });\n\n  it('feed items sorted by date newest first', async () => {\n    const files = [\n      makeFile({ slug: 'old', title: 'Old Post', date: '2023-01-01' }),\n      makeFile({ slug: 'new', title: 'New Post', date: '2024-06-15' }),\n      makeFile({ slug: 'mid', title: 'Mid Post', date: '2024-01-01' }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    const newIdx = feed.indexOf('New Post');\n    const midIdx = feed.indexOf('Mid Post');\n    const oldIdx = feed.indexOf('Old Post');\n    expect(newIdx).toBeLessThan(midIdx);\n    expect(midIdx).toBeLessThan(oldIdx);\n  });\n\n  it('handles files without dates', async () => {\n    const files = [\n      makeFile({ slug: 'no-date', title: 'No Date Post', content: '<p>No date</p>' }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('No Date Post');\n    expect(feed).not.toContain('<pubDate>undefined</pubDate>');\n  });\n\n  it('feed link uses baseUrl from config', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const feed = ctx.output.get('feed.xml')!;\n    expect(feed).toContain('<link>https://example.com</link>');\n    expect(feed).toContain('<link>https://example.com/post-1.html</link>');\n  });\n});\n```\n\n**Expected Factory Function:** `createRssFeedPlugin()` returns Plugin\n\n**Expected Hooks:** `afterBuild`\n\n**Expected Dependencies:** `['markdown-ext', 'taxonomy']`\n\n**Expected Behavior:**\n- Generates RSS 2.0 XML with valid structure\n- Stores feed as `feed.xml` in `ctx.output`\n- Feed items use HTML content (wrapped in CDATA)\n- Includes category tags from `ctx.data.get('taxonomy-tags')`\n- Channel title uses `config.title`\n- Sorts items by date (newest first)\n- Gracefully handles files without dates\n- Links use `config.baseUrl`\n\n---\n\n### `/workspace/tests/plugins/search-index.test.ts` (COMPLETE)\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createSearchIndexPlugin } from '../../src/plugins/search-index.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(files: ContentFile[] = []): BuildContext {\n  return {\n    config: testConfig,\n    files,\n    output: new Map(),\n    assets: new Map(),\n    data: new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('search-index plugin', () => {\n  const plugin = createSearchIndexPlugin();\n\n  it('generates search-index.json in ctx.output', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1', content: '<p>Hello</p>' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.output.has('search-index.json')).toBe(true);\n  });\n\n  it('index entries have title, slug, and plain text content', async () => {\n    const files = [makeFile({ slug: 'my-post', title: 'My Post', content: '<p>Some text here</p>' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].slug).toBe('my-post');\n    expect(index[0].title).toBe('My Post');\n    expect(index[0].content).toBe('Some text here');\n  });\n\n  it('HTML tags stripped from indexed content', async () => {\n    const files = [\n      makeFile({\n        slug: 'post',\n        title: 'Post',\n        content: '<h1>Title</h1><p>This is <strong>bold</strong> text.</p>',\n      }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].content).not.toContain('<');\n    expect(index[0].content).not.toContain('>');\n    expect(index[0].content).toContain('bold');\n    expect(index[0].content).toContain('text');\n  });\n\n  it('code blocks included in searchable text', async () => {\n    const files = [\n      makeFile({\n        slug: 'post',\n        title: 'Code Post',\n        content: '<p>Example:</p><pre><code class=\"language-js\">const x = 1;</code></pre>',\n      }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].content).toContain('const x = 1;');\n  });\n\n  it('handles empty file list', async () => {\n    const ctx = makeCtx([]);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index).toEqual([]);\n  });\n\n  it('search index is valid JSON', async () => {\n    const files = [\n      makeFile({ slug: 'post-1', title: 'Post 1', content: '<p>Content</p>' }),\n      makeFile({ slug: 'post-2', title: 'Post 2', content: '<p>More</p>' }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const raw = ctx.output.get('search-index.json')!;\n    expect(() => JSON.parse(raw)).not.toThrow();\n    const index = JSON.parse(raw);\n    expect(Array.isArray(index)).toBe(true);\n    expect(index).toHaveLength(2);\n  });\n\n  it('index entries include tags if present', async () => {\n    const files = [\n      makeFile({ slug: 'post', title: 'Tagged Post', content: '<p>Text</p>', tags: ['js', 'web'] }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].tags).toEqual(['js', 'web']);\n  });\n});\n```\n\n**Expected Factory Function:** `createSearchIndexPlugin()` returns Plugin\n\n**Expected Hooks:** `afterBuild`\n\n**Expected Dependencies:** `['markdown-ext', 'syntax-highlight']`\n\n**Expected Behavior:**\n- Generates `search-index.json` in `ctx.output`\n- Index is array of objects with: `slug`, `title`, `content` (plain text), and optional `tags`\n- HTML tags completely stripped from content\n- Code blocks (including content) included in searchable text\n- Valid JSON array format\n- Handles empty file list\n\n---\n\n### `/workspace/tests/plugins/sitemap.test.ts` (COMPLETE)\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { createSitemapPlugin } from '../../src/plugins/sitemap.js';\nimport { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n\nconst testConfig: SiteConfig = {\n  title: 'Test Site',\n  baseUrl: 'https://example.com',\n  outputDir: './dist',\n  contentDir: './content',\n  templateDir: './templates',\n};\n\nfunction makeCtx(\n  output?: Map<string, string>,\n  data?: Map<string, unknown>\n): BuildContext {\n  return {\n    config: testConfig,\n    files: [],\n    output: output || new Map(),\n    assets: new Map(),\n    data: data || new Map(),\n  };\n}\n\ndescribe('sitemap plugin', () => {\n  co