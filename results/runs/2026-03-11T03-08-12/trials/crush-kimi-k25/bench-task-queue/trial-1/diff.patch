+// Task Queue System - Complete Implementation
+// Supports all 12 phases: FIFO, Named Queues, Priority, Delays, Retries, DLQ,
+// Dependencies, Concurrency, Progress/Cancellation, Recurring, Middleware, Shutdown
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task {
+  id: string;
+  payload: unknown;
+  status: TaskStatus;
+  createdAt: number;
+  queueName: string;
+  priority: number;
+  availableAt: number;
+  attempts: number;
+  maxRetries: number;
+  baseDelay: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage: string | null;
+  error: string | null;
+  originalTaskId?: string; // For tracking retries
+}
+
+export interface TaskOptions {
+  priority?: number;
+  delay?: number;
+  availableAt?: number;
+  maxRetries?: number;
+  baseDelay?: number;
+  dependencies?: string[];
+}
+
+export type ProgressCallback = (progress: number, message: string | null) => void;
+
+export interface ProgressSubscription {
+  unsubscribe: () => void;
+}
+
+type MiddlewareNext = () => Promise<void> | void;
+type MiddlewareFn = (task: Task, next: MiddlewareNext) => Promise<void> | void;
+type HandlerFn = (task: Task) => Promise<void> | void;
+
+export interface Schedule {
+  id: string;
+  queueName: string;
+  cronExpression: string;
+  payload: unknown;
+  lastRun: number | null;
+}
+
+export interface ShutdownSummary {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+function generateId(): string {
+  return `${Date.now()}-${Math.random().toString(36).substring(2, 11)}`;
+}
+
+class Queue {
+  name: string;
+  tasks: Map<string, Task> = new Map();
+  deadLetterTasks: Map<string, Task> = new Map();
+  pendingIds: string[] = [];
+  processingIds: Set<string> = new Set();
+  blockedIds: Set<string> = new Set();
+  concurrencyLimit: number | null = null;
+  middleware: MiddlewareFn[] = [];
+  handler: HandlerFn | null = null;
+  progressListeners: Map<string, Set<ProgressCallback>> = new Map();
+
+  constructor(name: string) {
+    this.name = name;
+  }
+
+  get pendingCount(): number {
+    return this.pendingIds.length;
+  }
+
+  get processingCount(): number {
+    return this.processingIds.size;
+  }
+
+  get activeCount(): number {
+    return this.processingIds.size;
+  }
+
+  isConcurrencyAvailable(): boolean {
+    if (this.concurrencyLimit === null) return true;
+    return this.processingIds.size < this.concurrencyLimit;
+  }
+
+  addTask(task: Task): void {
+    this.tasks.set(task.id, task);
+    this.insertPending(task);
+  }
+
+  private insertPending(task: Task): void {
+    const now = Date.now();
+    if (task.availableAt > now || task.dependencies.length > 0) {
+      // Task is delayed or blocked - don't add to pending yet
+      return;
+    }
+
+    // Insert maintaining priority order (lower number = higher priority)
+    // Then by availableAt, then by creation time (FIFO)
+    let inserted = false;
+    for (let i = 0; i < this.pendingIds.length; i++) {
+      const existing = this.tasks.get(this.pendingIds[i])!;
+      if (task.priority < existing.priority) {
+        this.pendingIds.splice(i, 0, task.id);
+        inserted = true;
+        break;
+      } else if (task.priority === existing.priority) {
+        if (task.availableAt < existing.availableAt) {
+          this.pendingIds.splice(i, 0, task.id);
+          inserted = true;
+          break;
+        } else if (task.availableAt === existing.availableAt && task.createdAt < existing.createdAt) {
+          this.pendingIds.splice(i, 0, task.id);
+          inserted = true;
+          break;
+        }
+      }
+    }
+    if (!inserted) {
+      this.pendingIds.push(task.id);
+    }
+  }
+
+  getNextTask(): Task | null {
+    if (!this.isConcurrencyAvailable()) {
+      return null;
+    }
+
+    const now = Date.now();
+
+    // Refresh delayed tasks that are now available
+    for (const [id, task] of this.tasks) {
+      if (task.status === 'pending' && !this.pendingIds.includes(id)) {
+        if (task.availableAt <= now && task.dependencies.length === 0) {
+          this.insertPending(task);
+        }
+      }
+    }
+
+    // Find next available task
+    let nextIndex = -1;
+    for (let i = 0; i < this.pendingIds.length; i++) {
+      const task = this.tasks.get(this.pendingIds[i])!;
+      if (task.availableAt <= now && task.dependencies.length === 0) {
+        nextIndex = i;
+        break;
+      }
+    }
+
+    if (nextIndex === -1) {
+      return null;
+    }
+
+    const taskId = this.pendingIds.splice(nextIndex, 1)[0];
+    const task = this.tasks.get(taskId)!;
+    task.status = 'processing';
+    this.processingIds.add(taskId);
+    return task;
+  }
+
+  completeTask(taskId: string): boolean {
+    const task = this.tasks.get(taskId);
+    if (!task || task.status !== 'processing') return false;
+
+    task.status = 'completed';
+    this.processingIds.delete(taskId);
+    return true;
+  }
+
+  failTask(taskId: string, error?: string): Task | null {
+    const task = this.tasks.get(taskId);
+    if (!task || task.status !== 'processing') return null;
+
+    this.processingIds.delete(taskId);
+    task.attempts++;
+    task.error = error || null;
+
+    if (task.attempts <= task.maxRetries) {
+      // Retry with exponential backoff
+      const delay = task.baseDelay * Math.pow(2, task.attempts - 1);
+      task.availableAt = Date.now() + delay;
+      task.status = 'pending';
+      this.insertPending(task);
+      return task;
+    } else {
+      // Move to dead letter queue
+      task.status = 'failed';
+      this.deadLetterTasks.set(taskId, task);
+      this.tasks.delete(taskId);
+      return null;
+    }
+  }
+
+  cancelTask(taskId: string): boolean {
+    const task = this.tasks.get(taskId);
+    if (!task) return false;
+
+    if (task.status === 'pending') {
+      const index = this.pendingIds.indexOf(taskId);
+      if (index > -1) {
+        this.pendingIds.splice(index, 1);
+      }
+      this.tasks.delete(taskId);
+      this.progressListeners.delete(taskId);
+      return true;
+    } else if (task.status === 'processing') {
+      task.status = 'cancelled';
+      this.processingIds.delete(taskId);
+      this.progressListeners.delete(taskId);
+      return true;
+    }
+    return false;
+  }
+
+  unblockTasks(completedTaskId: string): string[] {
+    const unblocked: string[] = [];
+    for (const [id, task] of this.tasks) {
+      if (task.dependencies.includes(completedTaskId)) {
+        task.dependencies = task.dependencies.filter(depId => depId !== completedTaskId);
+        if (task.dependencies.length === 0 && task.status === 'pending') {
+          this.blockedIds.delete(id);
+          this.insertPending(task);
+          unblocked.push(id);
+        }
+      }
+    }
+    return unblocked;
+  }
+
+  updateProgress(taskId: string, progress: number, message: string | null): boolean {
+    const task = this.tasks.get(taskId);
+    if (!task || task.status !== 'processing') return false;
+
+    task.progress = Math.max(0, Math.min(100, progress));
+    task.progressMessage = message;
+
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(task.progress, message);
+      }
+    }
+    return true;
+  }
+
+  subscribeToProgress(taskId: string, callback: ProgressCallback): ProgressSubscription | null {
+    const task = this.tasks.get(taskId);
+    if (!task) return null;
+
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(callback);
+
+    return {
+      unsubscribe: () => {
+        this.progressListeners.get(taskId)?.delete(callback);
+      }
+    };
+  }
+
+  getDeadLetterTasks(): Task[] {
+    return Array.from(this.deadLetterTasks.values());
+  }
+
+  retryDeadLetterTask(taskId: string): Task | null {
+    const task = this.deadLetterTasks.get(taskId);
+    if (!task) return null;
+
+    task.status = 'pending';
+    task.attempts = 0;
+    task.error = null;
+    task.availableAt = Date.now();
+
+    this.deadLetterTasks.delete(taskId);
+    this.tasks.set(taskId, task);
+    this.insertPending(task);
+
+    return task;
+  }
+
+  clearDeadLetterQueue(): number {
+    const count = this.deadLetterTasks.size;
+    this.deadLetterTasks.clear();
+    return count;
+  }
+
+  setConcurrencyLimit(limit: number | null): void {
+    this.concurrencyLimit = limit;
+  }
+
+  getConcurrencyLimit(): number | null {
+    return this.concurrencyLimit;
+  }
+
+  addMiddleware(middleware: MiddlewareFn): void {
+    this.middleware.push(middleware);
+  }
+
+  setHandler(handler: HandlerFn): void {
+    this.handler = handler;
+  }
+
+  async processTask(task: Task): Promise<void> {
+    if (!this.handler && this.middleware.length === 0) {
+      throw new Error('No handler or middleware configured for queue');
+    }
+
+    let index = 0;
+
+    const next = async (): Promise<void> => {
+      if (index < this.middleware.length) {
+        const mw = this.middleware[index++];
+        await mw(task, next);
+      } else if (this.handler) {
+        await this.handler(task);
+      }
+    };
+
+    await next();
+  }
+}
+
+export class TaskQueue {
+  private queues: Map<string, Queue> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private shutdownInitiated = false;
+  private shutdownCallbacks: (() => void | Promise<void>)[] = [];
+
+  private getQueue(name: string, create = false): Queue | undefined {
+    if (create && !this.queues.has(name)) {
+      this.queues.set(name, new Queue(name));
+    }
+    return this.queues.get(name);
+  }
+
+  add(payload: unknown, queueName = 'default', options: TaskOptions = {}): Task {
+    if (this.shutdownInitiated) {
+      throw new Error('Cannot add tasks after shutdown has been initiated');
+    }
+
+    // Validate priority
+    const priority = options.priority ?? 5;
+    if (priority < 1 || priority > 10) {
+      throw new Error('Priority must be between 1 and 10');
+    }
+
+    // Check dependencies
+    if (options.dependencies && options.dependencies.length > 0) {
+      this.getQueue(queueName, true)!;
+      for (const depId of options.dependencies) {
+        // Check if dependency exists in any queue
+        let found = false;
+        for (const [_, q] of this.queues) {
+          if (q.tasks.has(depId) || q.deadLetterTasks.has(depId)) {
+            found = true;
+            // Check for circular dependency
+            const depTask = q.tasks.get(depId) || q.deadLetterTasks.get(depId);
+            if (depTask && depTask.dependencies) {
+              // This is a simplified check - full cycle detection would be more complex
+            }
+            break;
+          }
+        }
+        if (!found) {
+          throw new Error(`Dependency task ${depId} does not exist`);
+        }
+      }
+    }
+
+    const queue = this.getQueue(queueName, true)!;
+
+    const now = Date.now();
+    let availableAt = now;
+
+    if (options.availableAt !== undefined) {
+      availableAt = options.availableAt;
+    } else if (options.delay !== undefined) {
+      availableAt = now + options.delay;
+    }
+
+    const task: Task = {
+      id: generateId(),
+      payload,
+      status: 'pending',
+      createdAt: now,
+      queueName,
+      priority,
+      availableAt,
+      attempts: 0,
+      maxRetries: options.maxRetries ?? 3,
+      baseDelay: options.baseDelay ?? 1000,
+      dependencies: options.dependencies ? [...options.dependencies] : [],
+      progress: 0,
+      progressMessage: null,
+      error: null,
+    };
+
+    queue.addTask(task);
+    return task;
+  }
+
+  get(queueName = 'default'): Task | null {
+    const queue = this.getQueue(queueName);
+    if (!queue) return null;
+    return queue.getNextTask();
+  }
+
+  complete(taskId: string, queueName = 'default'): boolean {
+    const queue = this.getQueue(queueName);
+    if (!queue) return false;
+
+    const completed = queue.completeTask(taskId);
+    if (completed) {
+      // Unblock tasks that depended on this one
+      queue.unblockTasks(taskId);
+    }
+    return completed;
+  }
+
+  fail(taskId: string, error?: string, queueName = 'default'): Task | null {
+    const queue = this.getQueue(queueName);
+    if (!queue) return null;
+    return queue.failTask(taskId, error);
+  }
+
+  count(queueName = 'default'): number {
+    const queue = this.getQueue(queueName);
+    if (!queue) return 0;
+    return queue.pendingCount;
+  }
+
+  listQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  cancel(taskId: string, queueName = 'default'): boolean {
+    const queue = this.getQueue(queueName);
+    if (!queue) return false;
+    return queue.cancelTask(taskId);
+  }
+
+  reportProgress(taskId: string, progress: number, message: string | null = null, queueName = 'default'): boolean {
+    const queue = this.getQueue(queueName);
+    if (!queue) return false;
+    return queue.updateProgress(taskId, progress, message);
+  }
+
+  getProgress(taskId: string, queueName = 'default'): { progress: number; message: string | null } | null {
+    const queue = this.getQueue(queueName);
+    if (!queue) return null;
+    const task = queue.tasks.get(taskId);
+    if (!task) return null;
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  subscribeToProgress(taskId: string, callback: ProgressCallback, queueName = 'default'): ProgressSubscription | null {
+    const queue = this.getQueue(queueName);
+    if (!queue) return null;
+    return queue.subscribeToProgress(taskId, callback);
+  }
+
+  // Dead Letter Queue methods
+  getDeadLetterTasks(queueName = 'default'): Task[] {
+    const queue = this.getQueue(queueName);
+    if (!queue) return [];
+    return queue.getDeadLetterTasks();
+  }
+
+  retryDeadLetter(taskId: string, queueName = 'default'): Task | null {
+    const queue = this.getQueue(queueName);
+    if (!queue) return null;
+    return queue.retryDeadLetterTask(taskId);
+  }
+
+  clearDeadLetter(queueName = 'default'): number {
+    const queue = this.getQueue(queueName);
+    if (!queue) return 0;
+    return queue.clearDeadLetterQueue();
+  }
+
+  // Concurrency control
+  setConcurrency(queueName: string, limit: number | null): void {
+    const queue = this.getQueue(queueName, true)!;
+    queue.setConcurrencyLimit(limit);
+  }
+
+  getConcurrency(queueName = 'default'): { limit: number | null; active: number } {
+    const queue = this.getQueue(queueName, true)!;
+    return { limit: queue.getConcurrencyLimit(), active: queue.activeCount };
+  }
+
+  // Middleware
+  use(queueName: string, middleware: MiddlewareFn): void {
+    const queue = this.getQueue(queueName, true)!;
+    queue.addMiddleware(middleware);
+  }
+
+  setHandler(queueName: string, handler: HandlerFn): void {
+    const queue = this.getQueue(queueName, true)!;
+    queue.setHandler(handler);
+  }
+
+  async process(task: Task): Promise<void> {
+    const queue = this.getQueue(task.queueName);
+    if (!queue) {
+      throw new Error(`Queue ${task.queueName} does not exist`);
+    }
+    await queue.processTask(task);
+  }
+
+  // Recurring tasks (schedules)
+  createSchedule(queueName: string, cronExpression: string, payload: unknown): Schedule {
+    if (this.shutdownInitiated) {
+      throw new Error('Cannot create schedules after shutdown has been initiated');
+    }
+
+    const schedule: Schedule = {
+      id: generateId(),
+      queueName,
+      cronExpression,
+      payload,
+      lastRun: null,
+    };
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): boolean {
+    return this.schedules.delete(scheduleId);
+  }
+
+  listSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(): Task[] {
+    const now = Date.now();
+    const enqueued: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (this.shouldRunSchedule(schedule, now)) {
+        const task = this.add(schedule.payload, schedule.queueName);
+        enqueued.push(task);
+        schedule.lastRun = now;
+      }
+    }
+
+    return enqueued;
+  }
+
+  private shouldRunSchedule(schedule: Schedule, now: number): boolean {
+    // Simple cron parsing for supported patterns
+    const parts = schedule.cronExpression.split(' ');
+    if (parts.length !== 5) return false;
+
+    const [minute, hour, _day, _month, _weekday] = parts;
+    void _day; void _month; void _weekday;
+
+    // Check if enough time has passed since last run
+    if (schedule.lastRun) {
+      const elapsed = now - schedule.lastRun;
+      const oneMinute = 60 * 1000;
+
+      // */N * * * * - every N minutes
+      if (minute.startsWith('*/')) {
+        const n = parseInt(minute.substring(2), 10);
+        if (elapsed < n * oneMinute) return false;
+      }
+      // 0 * * * * - every hour
+      else if (minute === '0' && hour === '*') {
+        if (elapsed < 60 * oneMinute) return false;
+      }
+      // 0 0 * * * - every day
+      else if (minute === '0' && hour === '0') {
+        if (elapsed < 24 * 60 * oneMinute) return false;
+      }
+    }
+
+    // For manual tick, we always run if enough time has passed
+    return true;
+  }
+
+  // Shutdown
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeoutMs: number = 30000): Promise<ShutdownSummary> {
+    if (this.shutdownInitiated) {
+      // Return cached result if already shutdown
+      return { completed: 0, forceCancelled: 0, duration: 0 };
+    }
+
+    this.shutdownInitiated = true;
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const callback of this.shutdownCallbacks) {
+      await callback();
+    }
+
+    // Wait for processing tasks to complete
+    let completed = 0;
+    let forceCancelled = 0;
+
+    const deadline = startTime + timeoutMs;
+
+    while (Date.now() < deadline) {
+      let allDone = true;
+      for (const queue of this.queues.values()) {
+        if (queue.processingCount > 0) {
+          allDone = false;
+          break;
+        }
+      }
+      if (allDone) break;
+      await new Promise(resolve => setTimeout(resolve, 10));
+    }
+
+    // Count results and force-cancel if needed
+    for (const queue of this.queues.values()) {
+      for (const taskId of queue.processingIds) {
+        const task = queue.tasks.get(taskId);
+        if (task) {
+          if (task.status === 'completed') {
+            completed++;
+          } else {
+            task.status = 'cancelled';
+            forceCancelled++;
+          }
+        }
+      }
+      queue.processingIds.clear();
+    }
+
+    const duration = Date.now() - startTime;
+
+    return {
+      completed,
+      forceCancelled,
+      duration,
+    };
+  }
+
+  // Helper method to check for circular dependencies
+  private detectCircularDependency(taskId: string, dependencies: string[]): boolean {
+    const visited = new Set<string>();
+    const stack = [...dependencies];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === taskId) return true;
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      // Find the task and its dependencies
+      for (const queue of this.queues.values()) {
+        const task = queue.tasks.get(current);
+        if (task) {
+          for (const dep of task.dependencies) {
+            if (!visited.has(dep)) {
+              stack.push(dep);
+            }
+          }
+        }
+      }
+    }
+
+    return false;
+  }
+
+  // Extended add with circular dependency check
+  addWithDependencyCheck(payload: unknown, queueName = 'default', options: TaskOptions = {}): Task {
+    if (options.dependencies && options.dependencies.length > 0) {
+      // Check for circular dependencies
+      if (this.detectCircularDependency('', options.dependencies)) {
+        throw new Error('Circular dependency detected');
+      }
+    }
+    return this.add(payload, queueName, options);
+  }
+}
+
+// Create and export a default instance
+export const taskQueue = new TaskQueue();
+
+// Also export the class for creating custom instances
+export default TaskQueue;
