+import express from 'express';
+import { WebSocketServer, WebSocket } from 'ws';
+import { createServer } from 'http';
+import { randomUUID } from 'crypto';
+import { DatabaseManager, Operation } from './db.js';
+import {
+  applyOperation,
+  transformOperationAgainstMany,
+  validateOperation,
+} from './ot.js';
+
+// WebSocket message types
+interface WSMessage {
+  type: string;
+  data?: unknown;
+}
+
+interface SyncMessage extends WSMessage {
+  type: 'sync';
+  data: {
+    documentId: string;
+    content: string;
+    version: number;
+  };
+}
+
+interface OperationMessage extends WSMessage {
+  type: 'operation';
+  data: Operation;
+}
+
+interface ErrorMessage extends WSMessage {
+  type: 'error';
+  data: {
+    message: string;
+  };
+}
+
+interface AckMessage extends WSMessage {
+  type: 'ack';
+  data: {
+    version: number;
+  };
+}
+
+// Client connection info
+interface ClientInfo {
+  ws: WebSocket;
+  documentId: string;
+  clientId: string;
+}
+
+export interface AppInstance {
+  app: express.Application;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = new DatabaseManager(dbPath);
+  const app = express();
+  const clients = new Map<string, ClientInfo>();
+  let isShuttingDown = false;
+
+  app.use(express.json());
+
+  // REST API Routes
+
+  // Create document
+  app.post('/documents', (req, res) => {
+    const { title, content } = req.body;
+
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'Title is required' });
+      return;
+    }
+
+    const document = db.createDocument(title, content || '');
+    res.status(201).json(document);
+  });
+
+  // List documents
+  app.get('/documents', (_req, res) => {
+    const documents = db.listDocuments();
+    res.json(documents);
+  });
+
+  // Get document
+  app.get('/documents/:id', (req, res) => {
+    const document = db.getDocument(req.params.id);
+    if (!document) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(document);
+  });
+
+  // Update document (REST API)
+  app.put('/documents/:id', (req, res) => {
+    const { title, content } = req.body;
+    const updates: { title?: string; content?: string } = {};
+
+    if (title !== undefined) updates.title = title;
+    if (content !== undefined) updates.content = content;
+
+    const document = db.updateDocument(req.params.id, updates);
+    if (!document) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(document);
+  });
+
+  // Delete document
+  app.delete('/documents/:id', (req, res) => {
+    const success = db.deleteDocument(req.params.id);
+    if (!success) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.status(204).send();
+  });
+
+  // Get document versions
+  app.get('/documents/:id/versions', (req, res) => {
+    const document = db.getDocument(req.params.id);
+    if (!document) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = db.getDocumentVersions(req.params.id);
+    res.json(versions);
+  });
+
+  // HTTP server
+  const server = createServer(app);
+
+  // WebSocket server - no path restriction, handle all upgrade requests
+  const wss = new WebSocketServer({ server });
+
+  // Helper to broadcast to all clients viewing the same document except sender
+  function broadcastToDocument(
+    documentId: string,
+    message: WSMessage,
+    excludeClientId?: string
+  ): void {
+    for (const [clientId, client] of clients.entries()) {
+      if (client.documentId === documentId && clientId !== excludeClientId) {
+        if (client.ws.readyState === WebSocket.OPEN) {
+          client.ws.send(JSON.stringify(message));
+        }
+      }
+    }
+  }
+
+  // Helper to send message to specific client
+  function sendToClient(clientId: string, message: WSMessage): void {
+    const client = clients.get(clientId);
+    if (client && client.ws.readyState === WebSocket.OPEN) {
+      client.ws.send(JSON.stringify(message));
+    }
+  }
+
+  // WebSocket connection handler
+  wss.on('connection', (ws: WebSocket, req) => {
+    // Parse document ID from URL query string or path
+    const url = new URL(req.url || '', 'http://localhost');
+    const documentId = url.searchParams.get('documentId');
+
+    if (!documentId) {
+      const errorMsg: ErrorMessage = {
+        type: 'error',
+        data: { message: 'Document ID is required. Connect with ?documentId=xxx' },
+      };
+      ws.send(JSON.stringify(errorMsg));
+      ws.close();
+      return;
+    }
+
+    // Verify document exists
+    const document = db.getDocument(documentId);
+    if (!document) {
+      const errorMsg: ErrorMessage = {
+        type: 'error',
+        data: { message: 'Document not found' },
+      };
+      ws.send(JSON.stringify(errorMsg));
+      ws.close();
+      return;
+    }
+
+    const clientId = randomUUID();
+    clients.set(clientId, { ws, documentId, clientId });
+    db.addConnection(clientId, documentId);
+
+    // Send initial sync with current document state
+    const latestVersion = db.getLatestVersion(documentId);
+    const syncMsg: SyncMessage = {
+      type: 'sync',
+      data: {
+        documentId,
+        content: document.content,
+        version: latestVersion,
+      },
+    };
+    ws.send(JSON.stringify(syncMsg));
+
+    // Handle messages from client
+    ws.on('message', (data: Buffer) => {
+      try {
+        const message = JSON.parse(data.toString()) as WSMessage;
+
+        if (message.type === 'operation') {
+          const op = message.data as Operation;
+
+          // Validate operation
+          if (!validateOperation(op)) {
+            const errorMsg: ErrorMessage = {
+              type: 'error',
+              data: { message: 'Invalid operation format' },
+            };
+            sendToClient(clientId, errorMsg);
+            return;
+          }
+
+          // Get current document state
+          const currentDoc = db.getDocument(documentId);
+          if (!currentDoc) {
+            const errorMsg: ErrorMessage = {
+              type: 'error',
+              data: { message: 'Document not found' },
+            };
+            sendToClient(clientId, errorMsg);
+            return;
+          }
+
+          // Get the current server version
+          const serverVersion = db.getLatestVersion(documentId);
+
+          // If client's base version is older than server, transform the operation
+          let transformedOp = op;
+          if (op.version < serverVersion) {
+            // Get all operations since the client's version
+            const versionsSince = db.getVersionsAfter(documentId, op.version);
+            const serverOps: Operation[] = versionsSince
+              .map((v) => (v.operation ? JSON.parse(v.operation) : null))
+              .filter((o): o is Operation => o !== null);
+
+            // Transform the client's operation against all server operations
+            transformedOp = transformOperationAgainstMany(op, serverOps);
+          }
+
+          // Apply the transformed operation
+          const newContent = applyOperation(currentDoc.content, transformedOp);
+
+          // Save the new version
+          const newVersion = db.addVersion(documentId, newContent, transformedOp);
+
+          // Send ack to the client who sent the operation
+          const ackMsg: AckMessage = {
+            type: 'ack',
+            data: { version: newVersion.version },
+          };
+          sendToClient(clientId, ackMsg);
+
+          // Broadcast the operation to all other clients viewing this document
+          const opMsg: OperationMessage = {
+            type: 'operation',
+            data: { ...transformedOp, version: newVersion.version },
+          };
+          broadcastToDocument(documentId, opMsg, clientId);
+        } else {
+          const errorMsg: ErrorMessage = {
+            type: 'error',
+            data: { message: `Unknown message type: ${message.type}` },
+          };
+          sendToClient(clientId, errorMsg);
+        }
+      } catch (err) {
+        const errorMsg: ErrorMessage = {
+          type: 'error',
+          data: { message: 'Failed to process message' },
+        };
+        sendToClient(clientId, errorMsg);
+      }
+    });
+
+    // Handle client disconnect
+    ws.on('close', () => {
+      clients.delete(clientId);
+      if (!isShuttingDown) {
+        try {
+          db.removeConnection(clientId);
+        } catch {
+          // Ignore database errors during shutdown
+        }
+      }
+    });
+
+    // Handle errors
+    ws.on('error', () => {
+      clients.delete(clientId);
+      if (!isShuttingDown) {
+        try {
+          db.removeConnection(clientId);
+        } catch {
+          // Ignore database errors during shutdown
+        }
+      }
+    });
+  });
+
+  return {
+    app,
+    start(port?: number): Promise<number> {
+      return new Promise((resolve) => {
+        server.listen(port ?? 0, () => {
+          const address = server.address();
+          const actualPort = typeof address === 'object' && address ? address.port : 0;
+          resolve(actualPort);
+        });
+      });
+    },
+    stop(): Promise<void> {
+      return new Promise((resolve) => {
+        isShuttingDown = true;
+
+        // Close all WebSocket connections
+        const closePromises: Promise<void>[] = [];
+        for (const client of clients.values()) {
+          const closePromise = new Promise<void>((res) => {
+            if (client.ws.readyState === WebSocket.OPEN) {
+              client.ws.once('close', res);
+              client.ws.close();
+            } else {
+              res();
+            }
+          });
+          closePromises.push(closePromise);
+        }
+
+        // Wait for all connections to close, then clean up
+        Promise.all(closePromises).then(() => {
+          clients.clear();
+
+          // Close WebSocket server
+          wss.close();
+
+          // Close HTTP server
+          server.close(() => {
+            // Close database
+            db.close();
+            resolve();
+          });
+        });
+      });
+    },
+  };
+}
+
+// Export types for consumers
+export { DatabaseManager, Operation };
+export { validateOperation, applyOperation, transformOperationAgainstMany } from './ot.js';
