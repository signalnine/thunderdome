diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..41cc071
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,195 @@
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export interface Operation {
+  type: 'insert' | 'delete';
+  position: number;
+  text?: string;
+  length?: number;
+  version: number;
+}
+
+export class DatabaseManager {
+  private db: Database.Database;
+
+  constructor(dbPath: string = ':memory:') {
+    this.db = new Database(dbPath);
+    this.initializeSchema();
+  }
+
+  private initializeSchema(): void {
+    this.db.exec(`
+      CREATE TABLE IF NOT EXISTS documents (
+        id TEXT PRIMARY KEY,
+        title TEXT NOT NULL,
+        content TEXT NOT NULL DEFAULT '',
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+
+      CREATE TABLE IF NOT EXISTS versions (
+        id INTEGER PRIMARY KEY AUTOINCREMENT,
+        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+        version INTEGER NOT NULL,
+        content TEXT NOT NULL,
+        operation TEXT,
+        created_at TEXT NOT NULL DEFAULT (datetime('now')),
+        UNIQUE(document_id, version)
+      );
+
+      CREATE TABLE IF NOT EXISTS active_connections (
+        id TEXT PRIMARY KEY,
+        document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+        connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+      );
+    `);
+  }
+
+  createDocument(title: string, content: string = ''): Document {
+    const id = randomUUID();
+    const now = new Date().toISOString();
+
+    const stmt = this.db.prepare(
+      'INSERT INTO documents (id, title, content, created_at, updated_at) VALUES (?, ?, ?, ?, ?)'
+    );
+    stmt.run(id, title, content, now, now);
+
+    // Create initial version
+    const versionStmt = this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    );
+    versionStmt.run(id, 1, content, null);
+
+    return {
+      id,
+      title,
+      content,
+      created_at: now,
+      updated_at: now,
+    };
+  }
+
+  getDocument(id: string): Document | null {
+    const stmt = this.db.prepare('SELECT * FROM documents WHERE id = ?');
+    return (stmt.get(id) as Document) || null;
+  }
+
+  listDocuments(): Document[] {
+    const stmt = this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC');
+    return stmt.all() as Document[];
+  }
+
+  updateDocument(id: string, updates: { title?: string; content?: string }): Document | null {
+    const doc = this.getDocument(id);
+    if (!doc) return null;
+
+    const newTitle = updates.title ?? doc.title;
+    const newContent = updates.content ?? doc.content;
+    const now = new Date().toISOString();
+
+    const stmt = this.db.prepare(
+      'UPDATE documents SET title = ?, content = ?, updated_at = ? WHERE id = ?'
+    );
+    stmt.run(newTitle, newContent, now, id);
+
+    return {
+      ...doc,
+      title: newTitle,
+      content: newContent,
+      updated_at: now,
+    };
+  }
+
+  deleteDocument(id: string): boolean {
+    const stmt = this.db.prepare('DELETE FROM documents WHERE id = ?');
+    const result = stmt.run(id);
+    return result.changes > 0;
+  }
+
+  getDocumentVersions(id: string): Version[] {
+    const stmt = this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+    );
+    return stmt.all(id) as Version[];
+  }
+
+  getLatestVersion(documentId: string): number {
+    const stmt = this.db.prepare(
+      'SELECT MAX(version) as maxVersion FROM versions WHERE document_id = ?'
+    );
+    const result = stmt.get(documentId) as { maxVersion: number | null };
+    return result.maxVersion || 0;
+  }
+
+  addVersion(documentId: string, content: string, operation: Operation): Version {
+    const version = this.getLatestVersion(documentId) + 1;
+
+    const stmt = this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    );
+    const result = stmt.run(documentId, version, content, JSON.stringify(operation));
+
+    // Update document content
+    const updateStmt = this.db.prepare(
+      'UPDATE documents SET content = ?, updated_at = ? WHERE id = ?'
+    );
+    updateStmt.run(content, new Date().toISOString(), documentId);
+
+    return {
+      id: result.lastInsertRowid as number,
+      document_id: documentId,
+      version,
+      content,
+      operation: JSON.stringify(operation),
+      created_at: new Date().toISOString(),
+    };
+  }
+
+  getVersionsAfter(documentId: string, version: number): Version[] {
+    const stmt = this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? AND version > ? ORDER BY version ASC'
+    );
+    return stmt.all(documentId, version) as Version[];
+  }
+
+  addConnection(connectionId: string, documentId: string): void {
+    const stmt = this.db.prepare(
+      'INSERT OR REPLACE INTO active_connections (id, document_id, connected_at) VALUES (?, ?, ?)'
+    );
+    stmt.run(connectionId, documentId, new Date().toISOString());
+  }
+
+  removeConnection(connectionId: string): void {
+    const stmt = this.db.prepare('DELETE FROM active_connections WHERE id = ?');
+    stmt.run(connectionId);
+  }
+
+  getDocumentConnections(documentId: string): string[] {
+    const stmt = this.db.prepare(
+      'SELECT id FROM active_connections WHERE document_id = ?'
+    );
+    const results = stmt.all(documentId) as { id: string }[];
+    return results.map((r) => r.id);
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
diff --git a/src/ot.ts b/src/ot.ts
new file mode 100644
index 0000000..7464956
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,179 @@
+export interface Operation {
+  type: 'insert' | 'delete';
+  position: number;
+  text?: string;
+  length?: number;
+  version: number;
+}
+
+export interface TransformedOperation extends Operation {
+  originalVersion: number;
+}
+
+/**
+ * Apply an operation to a string and return the new string.
+ */
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert' && op.text !== undefined) {
+    const pos = Math.max(0, Math.min(op.position, content.length));
+    return content.slice(0, pos) + op.text + content.slice(pos);
+  } else if (op.type === 'delete' && op.length !== undefined) {
+    const pos = Math.max(0, Math.min(op.position, content.length));
+    const endPos = Math.min(pos + op.length, content.length);
+    return content.slice(0, pos) + content.slice(endPos);
+  }
+  return content;
+}
+
+/**
+ * Transform operation op1 against operation op2.
+ * This is the core of Operational Transform - it adjusts op1 so that
+ * it can be applied after op2, producing the same result as if
+ * op1 had been applied before op2.
+ *
+ * Returns the transformed version of op1.
+ */
+export function transformOperation(op1: Operation, op2: Operation): Operation {
+  // If op2 is an insert
+  if (op2.type === 'insert' && op2.text !== undefined) {
+    // If op1 is an insert
+    if (op1.type === 'insert' && op1.text !== undefined) {
+      if (op1.position < op2.position) {
+        // op1 comes before op2, no change needed
+        return op1;
+      } else {
+        // op1 comes at same position or after op2, shift position by length of inserted text
+        return {
+          ...op1,
+          position: op1.position + op2.text.length,
+        };
+      }
+    }
+    // If op1 is a delete
+    else if (op1.type === 'delete' && op1.length !== undefined) {
+      if (op2.position <= op1.position) {
+        // Insert is before the delete start, shift delete position
+        return {
+          ...op1,
+          position: op1.position + op2.text.length,
+        };
+      } else if (op2.position >= op1.position + op1.length) {
+        // Insert is after the delete end, no change
+        return op1;
+      } else {
+        // Insert is inside the deleted range, expand the delete
+        return {
+          ...op1,
+          length: op1.length + op2.text.length,
+        };
+      }
+    }
+  }
+
+  // If op2 is a delete
+  else if (op2.type === 'delete' && op2.length !== undefined) {
+    const op2End = op2.position + op2.length;
+
+    // If op1 is an insert
+    if (op1.type === 'insert' && op1.text !== undefined) {
+      if (op1.position <= op2.position) {
+        // Insert is before the delete, no change
+        return op1;
+      } else if (op1.position >= op2End) {
+        // Insert is after the delete, shift position back
+        return {
+          ...op1,
+          position: op1.position - op2.length,
+        };
+      } else {
+        // Insert is inside the deleted range - insert at the delete position
+        return {
+          ...op1,
+          position: op2.position,
+        };
+      }
+    }
+    // If op1 is a delete
+    else if (op1.type === 'delete' && op1.length !== undefined) {
+      const op1End = op1.position + op1.length;
+
+      if (op1End <= op2.position) {
+        // op1 is entirely before op2, no change
+        return op1;
+      } else if (op1.position >= op2End) {
+        // op1 is entirely after op2, shift position
+        return {
+          ...op1,
+          position: op1.position - op2.length,
+        };
+      } else {
+        // Overlapping deletes - merge them
+        const newPosition = Math.min(op1.position, op2.position);
+        const newEnd = Math.max(op1End, op2End);
+        // Total length of the merged delete
+        const mergedLength = newEnd - newPosition;
+
+        return {
+          ...op1,
+          position: newPosition,
+          length: mergedLength,
+        };
+      }
+    }
+  }
+
+  return op1;
+}
+
+/**
+ * Transform an operation against a series of operations.
+ * This is used when a client sends an operation based on an old version,
+ * and we need to transform it against all operations that have happened since.
+ */
+export function transformOperationAgainstMany(
+  op: Operation,
+  serverOps: Operation[]
+): Operation {
+  let transformed = op;
+  for (const serverOp of serverOps) {
+    transformed = transformOperation(transformed, serverOp);
+  }
+  return transformed;
+}
+
+/**
+ * Validate an operation to ensure it's well-formed.
+ */
+export function validateOperation(op: unknown): op is Operation {
+  if (typeof op !== 'object' || op === null) {
+    return false;
+  }
+
+  const operation = op as Record<string, unknown>;
+
+  // Check required fields
+  if (operation.type !== 'insert' && operation.type !== 'delete') {
+    return false;
+  }
+
+  if (typeof operation.position !== 'number' || operation.position < 0) {
+    return false;
+  }
+
+  if (typeof operation.version !== 'number' || operation.version < 1) {
+    return false;
+  }
+
+  // Check type-specific fields
+  if (operation.type === 'insert') {
+    if (typeof operation.text !== 'string') {
+      return false;
+    }
+  } else if (operation.type === 'delete') {
+    if (typeof operation.length !== 'number' || operation.length < 1) {
+      return false;
+    }
+  }
+
+  return true;
+}
