@@ -0,0 +1,508 @@
+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { createApp } from './server.js';
+import request from 'supertest';
+import type { Application } from 'express';
+import WebSocket from 'ws';
+import { Operation, applyOperation, transformOperation, validateOperation } from './ot.js';
+
+describe('Document REST API', () => {
+  let appInstance: ReturnType<typeof createApp>;
+  let app: Application;
+  // eslint-disable-next-line @typescript-eslint/no-unused-vars
+  let _port: number;
+
+  beforeEach(async () => {
+    appInstance = createApp(':memory:');
+    app = appInstance.app;
+    _port = await appInstance.start(0);
+  });
+
+  afterEach(async () => {
+    await appInstance.stop();
+  });
+
+  describe('POST /documents', () => {
+    it('should create a new document', async () => {
+      const response = await request(app)
+        .post('/documents')
+        .send({ title: 'Test Doc', content: 'Hello World' });
+
+      expect(response.status).toBe(201);
+      expect(response.body.title).toBe('Test Doc');
+      expect(response.body.content).toBe('Hello World');
+      expect(response.body.id).toBeDefined();
+    });
+
+    it('should reject missing title', async () => {
+      const response = await request(app)
+        .post('/documents')
+        .send({ content: 'Hello' });
+
+      expect(response.status).toBe(400);
+    });
+  });
+
+  describe('GET /documents', () => {
+    it('should list all documents', async () => {
+      await request(app).post('/documents').send({ title: 'Doc 1' });
+      await request(app).post('/documents').send({ title: 'Doc 2' });
+
+      const response = await request(app).get('/documents');
+      expect(response.status).toBe(200);
+      expect(response.body.length).toBe(2);
+    });
+  });
+
+  describe('GET /documents/:id', () => {
+    it('should get a document by id', async () => {
+      const createResponse = await request(app)
+        .post('/documents')
+        .send({ title: 'Test', content: 'Content' });
+
+      const response = await request(app).get(`/documents/${createResponse.body.id}`);
+      expect(response.status).toBe(200);
+      expect(response.body.title).toBe('Test');
+    });
+
+    it('should return 404 for non-existent document', async () => {
+      const response = await request(app).get('/documents/nonexistent');
+      expect(response.status).toBe(404);
+    });
+  });
+
+  describe('PUT /documents/:id', () => {
+    it('should update a document', async () => {
+      const createResponse = await request(app)
+        .post('/documents')
+        .send({ title: 'Original', content: 'Original content' });
+
+      const response = await request(app)
+        .put(`/documents/${createResponse.body.id}`)
+        .send({ title: 'Updated', content: 'Updated content' });
+
+      expect(response.status).toBe(200);
+      expect(response.body.title).toBe('Updated');
+      expect(response.body.content).toBe('Updated content');
+    });
+  });
+
+  describe('DELETE /documents/:id', () => {
+    it('should delete a document', async () => {
+      const createResponse = await request(app)
+        .post('/documents')
+        .send({ title: 'To Delete' });
+
+      const deleteResponse = await request(app).delete(`/documents/${createResponse.body.id}`);
+      expect(deleteResponse.status).toBe(204);
+
+      const getResponse = await request(app).get(`/documents/${createResponse.body.id}`);
+      expect(getResponse.status).toBe(404);
+    });
+  });
+
+  describe('GET /documents/:id/versions', () => {
+    it('should get version history', async () => {
+      const createResponse = await request(app)
+        .post('/documents')
+        .send({ title: 'Test', content: 'Initial' });
+
+      const response = await request(app).get(`/documents/${createResponse.body.id}/versions`);
+      expect(response.status).toBe(200);
+      expect(response.body.length).toBeGreaterThanOrEqual(1);
+    });
+  });
+});
+
+describe('WebSocket Real-time Collaboration', () => {
+  let appInstance: ReturnType<typeof createApp>;
+  let port: number;
+  let documentId: string;
+
+  beforeEach(async () => {
+    appInstance = createApp(':memory:');
+    port = await appInstance.start(0);
+
+    // Create a document via REST API
+    const response = await request(appInstance.app)
+      .post('/documents')
+      .send({ title: 'Collab Test', content: 'Hello' });
+    documentId = response.body.id;
+  });
+
+  afterEach(async () => {
+    await appInstance.stop();
+  });
+
+  function connectClient(docId: string): Promise<WebSocket> {
+    return new Promise((resolve, reject) => {
+      const ws = new WebSocket(`ws://localhost:${port}/ws?documentId=${docId}`);
+      const timeout = setTimeout(() => {
+        ws.terminate();
+        reject(new Error('WebSocket connection timeout'));
+      }, 5000);
+      ws.on('open', () => {
+        clearTimeout(timeout);
+        resolve(ws);
+      });
+      ws.on('error', (err) => {
+        clearTimeout(timeout);
+        reject(err);
+      });
+    });
+  }
+
+  function waitForMessage(ws: WebSocket): Promise<unknown> {
+    return new Promise((resolve) => {
+      ws.once('message', (data) => {
+        resolve(JSON.parse(data.toString()));
+      });
+    });
+  }
+
+  it('should receive sync message on connection', async () => {
+    return new Promise<void>((resolve, reject) => {
+      const ws = new WebSocket(`ws://localhost:${port}/ws?documentId=${documentId}`);
+
+      const timeout = setTimeout(() => {
+        ws.terminate();
+        reject(new Error('WebSocket test timeout'));
+      }, 8000);
+
+      ws.on('open', () => {
+        console.log('WebSocket opened');
+      });
+
+      ws.on('message', (data) => {
+        clearTimeout(timeout);
+        const msg = JSON.parse(data.toString());
+        expect(msg).toMatchObject({
+          type: 'sync',
+          data: {
+            documentId,
+            content: 'Hello',
+            version: 1,
+          },
+        });
+        ws.close();
+        resolve();
+      });
+
+      ws.on('error', (err) => {
+        clearTimeout(timeout);
+        reject(err);
+      });
+
+      ws.on('close', (code, reason) => {
+        console.log('WebSocket closed:', code, reason.toString());
+      });
+    });
+  });
+
+  it('should reject connection without documentId', async () => {
+    return new Promise<void>((resolve) => {
+      const ws = new WebSocket(`ws://localhost:${port}/ws`);
+      ws.on('message', (data) => {
+        const msg = JSON.parse(data.toString());
+        expect(msg.type).toBe('error');
+        ws.close();
+        resolve();
+      });
+    });
+  });
+
+  it('should reject connection for non-existent document', async () => {
+    return new Promise<void>((resolve) => {
+      const ws = new WebSocket(`ws://localhost:${port}/ws?documentId=nonexistent`);
+      ws.on('message', (data) => {
+        const msg = JSON.parse(data.toString());
+        expect(msg.type).toBe('error');
+        ws.close();
+        resolve();
+      });
+    });
+  });
+
+  it('should broadcast operations to other clients', async () => {
+    const ws1 = await connectClient(documentId);
+    await waitForMessage(ws1); // sync message
+
+    const ws2 = await connectClient(documentId);
+    await waitForMessage(ws2); // sync message
+
+    // Send operation from ws1
+    const operation: Operation = {
+      type: 'insert',
+      position: 5,
+      text: ' World',
+      version: 1,
+    };
+
+    ws1.send(JSON.stringify({ type: 'operation', data: operation }));
+
+    // Wait for ack on ws1
+    const ack = await waitForMessage(ws1);
+    expect(ack).toMatchObject({ type: 'ack' });
+
+    // Wait for operation broadcast on ws2
+    const broadcast = await waitForMessage(ws2);
+    expect(broadcast).toMatchObject({
+      type: 'operation',
+      data: {
+        type: 'insert',
+        text: ' World',
+      },
+    });
+
+    ws1.close();
+    ws2.close();
+  });
+
+  it('should handle invalid operations gracefully', async () => {
+    const ws = await connectClient(documentId);
+    await waitForMessage(ws); // sync message
+
+    ws.send(JSON.stringify({ type: 'operation', data: { invalid: true } }));
+
+    const response = await waitForMessage(ws);
+    expect(response).toMatchObject({
+      type: 'error',
+      data: { message: 'Invalid operation format' },
+    });
+
+    ws.close();
+  });
+});
+
+describe('Operational Transform', () => {
+  describe('applyOperation', () => {
+    it('should insert text at position', () => {
+      const result = applyOperation('Hello', { type: 'insert', position: 5, text: ' World', version: 1 });
+      expect(result).toBe('Hello World');
+    });
+
+    it('should delete text at position', () => {
+      const result = applyOperation('Hello World', { type: 'delete', position: 5, length: 6, version: 1 });
+      expect(result).toBe('Hello');
+    });
+
+    it('should handle insert at position beyond length', () => {
+      const result = applyOperation('Hi', { type: 'insert', position: 10, text: '!', version: 1 });
+      expect(result).toBe('Hi!');
+    });
+  });
+
+  describe('transformOperation', () => {
+    it('should transform insert against insert at same position', () => {
+      const op1: Operation = { type: 'insert', position: 5, text: 'A', version: 1 };
+      const op2: Operation = { type: 'insert', position: 5, text: 'B', version: 1 };
+
+      const transformed = transformOperation(op1, op2);
+      // op1 should shift because op2 is inserted at same position
+      expect(transformed.position).toBe(6);
+    });
+
+    it('should not transform insert when it comes before', () => {
+      const op1: Operation = { type: 'insert', position: 3, text: 'A', version: 1 };
+      const op2: Operation = { type: 'insert', position: 5, text: 'B', version: 1 };
+
+      const transformed = transformOperation(op1, op2);
+      expect(transformed.position).toBe(3);
+    });
+
+    it('should transform delete position when insert comes before', () => {
+      const op1: Operation = { type: 'delete', position: 5, length: 3, version: 1 };
+      const op2: Operation = { type: 'insert', position: 3, text: 'ABC', version: 1 };
+
+      const transformed = transformOperation(op1, op2);
+      expect(transformed.position).toBe(8); // 5 + 3
+    });
+  });
+
+  describe('validateOperation', () => {
+    it('should validate insert operation', () => {
+      const op = { type: 'insert' as const, position: 0, text: 'hello', version: 1 };
+      expect(validateOperation(op)).toBe(true);
+    });
+
+    it('should validate delete operation', () => {
+      const op = { type: 'delete' as const, position: 0, length: 5, version: 1 };
+      expect(validateOperation(op)).toBe(true);
+    });
+
+    it('should reject invalid type', () => {
+      const op = { type: 'invalid', position: 0, text: 'hello', version: 1 };
+      expect(validateOperation(op)).toBe(false);
+    });
+
+    it('should reject negative position', () => {
+      const op = { type: 'insert' as const, position: -1, text: 'hello', version: 1 };
+      expect(validateOperation(op)).toBe(false);
+    });
+
+    it('should reject missing text for insert', () => {
+      const op = { type: 'insert' as const, position: 0, version: 1 };
+      expect(validateOperation(op)).toBe(false);
+    });
+
+    it('should reject invalid length for delete', () => {
+      const op = { type: 'delete' as const, position: 0, length: 0, version: 1 };
+      expect(validateOperation(op)).toBe(false);
+    });
+  });
+});
+
+describe('Concurrent Editing', () => {
+  let appInstance: ReturnType<typeof createApp>;
+  let port: number;
+  let documentId: string;
+
+  beforeEach(async () => {
+    appInstance = createApp(':memory:');
+    port = await appInstance.start(0);
+
+    const response = await request(appInstance.app)
+      .post('/documents')
+      .send({ title: 'Concurrent Test', content: '' });
+    documentId = response.body.id;
+  });
+
+  afterEach(async () => {
+    await appInstance.stop();
+  });
+
+  function connectClient(docId: string): Promise<WebSocket> {
+    return new Promise((resolve, reject) => {
+      const ws = new WebSocket(`ws://localhost:${port}/ws?documentId=${docId}`);
+      ws.on('open', () => resolve(ws));
+      ws.on('error', reject);
+    });
+  }
+
+  function waitForMessage(ws: WebSocket, timeout = 2000): Promise<unknown> {
+    return new Promise((resolve, reject) => {
+      const timer = setTimeout(() => reject(new Error('Timeout')), timeout);
+      ws.once('message', (data) => {
+        clearTimeout(timer);
+        resolve(JSON.parse(data.toString()));
+      });
+    });
+  }
+
+  it('should converge with two concurrent inserts', async () => {
+    const ws1 = await connectClient(documentId);
+    const sync1 = await waitForMessage(ws1) as { type: string; data: { version: number } };
+    expect(sync1.type).toBe('sync');
+
+    const ws2 = await connectClient(documentId);
+    const sync2 = await waitForMessage(ws2) as { type: string; data: { version: number } };
+    expect(sync2.type).toBe('sync');
+
+    // Both clients insert at position 0 based on version 1
+    const op1: Operation = { type: 'insert', position: 0, text: 'A', version: 1 };
+    const op2: Operation = { type: 'insert', position: 0, text: 'B', version: 1 };
+
+    // Send both operations concurrently
+    ws1.send(JSON.stringify({ type: 'operation', data: op1 }));
+    ws2.send(JSON.stringify({ type: 'operation', data: op2 }));
+
+    // Wait for acks
+    const ack1 = await waitForMessage(ws1);
+    const ack2 = await waitForMessage(ws2);
+
+    expect(ack1).toMatchObject({ type: 'ack' });
+    expect(ack2).toMatchObject({ type: 'ack' });
+
+    // Wait for broadcasts
+    const msg1 = await waitForMessage(ws1);
+    const msg2 = await waitForMessage(ws2);
+
+    expect(msg1).toMatchObject({ type: 'operation' });
+    expect(msg2).toMatchObject({ type: 'operation' });
+
+    ws1.close();
+    ws2.close();
+
+    // Verify final state via REST API
+    const docResponse = await request(appInstance.app).get(`/documents/${documentId}`);
+    const finalContent = docResponse.body.content;
+
+    // Both inserts should be preserved
+    expect(finalContent).toContain('A');
+    expect(finalContent).toContain('B');
+  });
+
+  it('should handle 10 concurrent clients', async () => {
+    const clients: WebSocket[] = [];
+
+    // Connect 10 clients
+    for (let i = 0; i < 10; i++) {
+      const ws = await connectClient(documentId);
+      const sync = await waitForMessage(ws);
+      expect((sync as { type: string }).type).toBe('sync');
+      clients.push(ws);
+    }
+
+    // Each client sends an insert
+    const promises: Promise<unknown>[] = [];
+    for (let i = 0; i < 10; i++) {
+      const op: Operation = {
+        type: 'insert',
+        position: 0,
+        text: String.fromCharCode(65 + i), // A, B, C, ...
+        version: 1,
+      };
+      clients[i].send(JSON.stringify({ type: 'operation', data: op }));
+
+      // Wait for ack for each client
+      promises.push(waitForMessage(clients[i]));
+    }
+
+    // Wait for all acks
+    const acks = await Promise.all(promises);
+    acks.forEach(ack => {
+      expect((ack as { type: string }).type).toBe('ack');
+    });
+
+    // Close all clients
+    clients.forEach(ws => ws.close());
+
+    // Verify final state
+    const docResponse = await request(appInstance.app).get(`/documents/${documentId}`);
+    const finalContent = docResponse.body.content;
+
+    // All 10 characters should be present
+    for (let i = 0; i < 10; i++) {
+      expect(finalContent).toContain(String.fromCharCode(65 + i));
+    }
+  });
+});
+
+describe('Persistence', () => {
+  it('should persist documents across server restarts', async () => {
+    const dbPath = '/tmp/test-persistence.db';
+
+    // Create first server instance
+    const app1 = createApp(dbPath);
+    await app1.start(0);
+
+    // Create a document
+    const response = await request(app1.app)
+      .post('/documents')
+      .send({ title: 'Persistent Doc', content: 'Initial' });
+    const docId = response.body.id;
+
+    await app1.stop();
+
+    // Create second server instance with same database
+    const app2 = createApp(dbPath);
+    await app2.start(0);
+
+    // Document should still exist
+    const getResponse = await request(app2.app).get(`/documents/${docId}`);
+    expect(getResponse.status).toBe(200);
+    expect(getResponse.body.title).toBe('Persistent Doc');
+    expect(getResponse.body.content).toBe('Initial');
+
+    await app2.stop();
+  });
+});
