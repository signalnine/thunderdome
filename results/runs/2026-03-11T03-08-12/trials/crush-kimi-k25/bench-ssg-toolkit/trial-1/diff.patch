+++ b/src/plugins/syntax-highlight.ts
@@ -0,0 +1,31 @@
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // Match pre > code blocks with language class
+        // Pattern: <pre><code class="language-xxx">...</code></pre>
+        content = content.replace(
+          /<pre><code\s+class="language-([^"]+)"([^>]*)>([\s\S]*?)<\/code><\/pre>/g,
+          (match, language, existingAttrs, codeContent) => {
+            // Add 'highlighted' class to code
+            const newCodeAttrs = `class="language-${language} highlighted"${existingAttrs}`;
+            // Add data-language to pre tag
+            return `<pre data-language="${language}"><code ${newCodeAttrs}>${codeContent}</code></pre>`;
+          }
+        );
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
diff --git a/src/plugins/taxonomy.ts b/src/plugins/taxonomy.ts
new file mode 100644
index 0000000..054e38d
--- /dev/null
+++ b/src/plugins/taxonomy.ts
@@ -0,0 +1,60 @@
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: (ctx: BuildContext): void => {
+        // Build tag index from file tags
+        const tagMap = new Map<string, ContentFile[]>();
+
+        for (const file of ctx.files) {
+          if (file.tags && file.tags.length > 0) {
+            for (const tag of file.tags) {
+              // Normalize tag to lowercase
+              const normalizedTag = tag.toLowerCase();
+              if (!tagMap.has(normalizedTag)) {
+                tagMap.set(normalizedTag, []);
+              }
+              tagMap.get(normalizedTag)!.push(file);
+            }
+          }
+        }
+
+        // Store in shared data
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+
+      afterBuild: (ctx: BuildContext): void => {
+        // Generate tag listing pages
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+        if (!tagMap) return;
+
+        for (const [tag, files] of tagMap) {
+          // Generate tag listing page HTML
+          const fileList = files.map(f =>
+            `<li><a href="/${f.slug}.html">${f.title}</a></li>`
+          ).join('\n');
+
+          const html = `<!DOCTYPE html>
+<html>
+<head>
+  <meta charset="utf-8">
+  <title>Tag: ${tag} | ${ctx.config.title}</title>
+</head>
+<body>
+  <h1>Tag: ${tag}</h1>
+  <ul>
+    ${fileList}
+  </ul>
+</body>
+</html>`;
+
+          ctx.output.set(`tags/${tag}.html`, html);
+        }
+      },
+    },
+  };
+}
