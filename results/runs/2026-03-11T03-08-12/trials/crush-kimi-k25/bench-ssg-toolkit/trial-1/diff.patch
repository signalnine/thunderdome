diff --git a/src/plugins/asset-pipeline.ts b/src/plugins/asset-pipeline.ts
new file mode 100644
index 0000000..28e6854
--- /dev/null
+++ b/src/plugins/asset-pipeline.ts
@@ -0,0 +1,50 @@
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+interface AssetManifest {
+  assets: string[];
+}
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // Get or initialize asset manifest from shared data
+        let manifest = ctx.data.get('asset-manifest') as AssetManifest | undefined;
+        if (!manifest) {
+          manifest = { assets: [] };
+          ctx.data.set('asset-manifest', manifest);
+        }
+
+        // Find and rewrite image URLs: src="./file" or src="file"
+        content = content.replace(/src="\.\/([^"]+)"/g, (match, path) => {
+          if (!manifest!.assets.includes(path)) {
+            manifest!.assets.push(path);
+          }
+          return `src="/assets/${path}"`;
+        });
+
+        // Find and rewrite link URLs for assets: href="./file" or href="file"
+        content = content.replace(/href="\.\/([^"]+)"/g, (match, path) => {
+          // Only rewrite if it looks like an asset file (has extension)
+          if (/\.[a-zA-Z0-9]+$/.test(path)) {
+            if (!manifest!.assets.includes(path)) {
+              manifest!.assets.push(path);
+            }
+            return `href="/assets/${path}"`;
+          }
+          return match;
+        });
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
diff --git a/src/plugins/dev-server.ts b/src/plugins/dev-server.ts
