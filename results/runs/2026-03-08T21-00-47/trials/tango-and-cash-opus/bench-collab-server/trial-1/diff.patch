index 0000000..f614b0f
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,173 @@
+/**
+ * Operational Transform (OT) implementation for collaborative text editing.
+ *
+ * Operations are either:
+ *   { type: "insert", position: number, text: string }
+ *   { type: "delete", position: number, length: number }
+ */
+
+export interface InsertOp {
+  type: "insert";
+  position: number;
+  text: string;
+}
+
+export interface DeleteOp {
+  type: "delete";
+  position: number;
+  length: number;
+}
+
+export type Operation = InsertOp | DeleteOp;
+
+/**
+ * Apply an operation to a document string.
+ */
+export function applyOperation(doc: string, op: Operation): string {
+  if (op.type === "insert") {
+    const pos = Math.min(Math.max(0, op.position), doc.length);
+    return doc.slice(0, pos) + op.text + doc.slice(pos);
+  } else {
+    const pos = Math.min(Math.max(0, op.position), doc.length);
+    const end = Math.min(pos + op.length, doc.length);
+    return doc.slice(0, pos) + doc.slice(end);
+  }
+}
+
+/**
+ * Transform operation `op` against a previously applied operation `appliedOp`.
+ * Returns the transformed version of `op` that can be applied after `appliedOp`.
+ *
+ * This implements the core OT transform function (inclusion transformation).
+ */
+export function transformOp(op: Operation, appliedOp: Operation): Operation {
+  if (op.type === "insert" && appliedOp.type === "insert") {
+    // Both inserts: if op is at or after appliedOp's position, shift right
+    if (op.position <= appliedOp.position) {
+      return { ...op };
+    } else {
+      return { ...op, position: op.position + appliedOp.text.length };
+    }
+  }
+
+  if (op.type === "insert" && appliedOp.type === "delete") {
+    // Insert vs Delete
+    if (op.position <= appliedOp.position) {
+      return { ...op };
+    } else if (op.position >= appliedOp.position + appliedOp.length) {
+      return { ...op, position: op.position - appliedOp.length };
+    } else {
+      // Insert position is within the deleted range - move to delete start
+      return { ...op, position: appliedOp.position };
+    }
+  }
+
+  if (op.type === "delete" && appliedOp.type === "insert") {
+    // Delete vs Insert
+    if (op.position + op.length <= appliedOp.position) {
+      // Delete is entirely before the insert
+      return { ...op };
+    } else if (op.position >= appliedOp.position) {
+      // Delete is at or after the insert position - shift right
+      return { ...op, position: op.position + appliedOp.text.length };
+    } else {
+      // Delete range spans the insert position - split around it
+      // The delete covers [op.position, op.position + op.length)
+      // The insert happened at appliedOp.position
+      // After the insert, the part before stays the same, the part after shifts
+      return {
+        ...op,
+        length: op.length + appliedOp.text.length,
+      };
+    }
+  }
+
+  if (op.type === "delete" && appliedOp.type === "delete") {
+    // Both deletes
+    const opEnd = op.position + op.length;
+    const appliedEnd = appliedOp.position + appliedOp.length;
+
+    if (opEnd <= appliedOp.position) {
+      // op is entirely before appliedOp
+      return { ...op };
+    } else if (op.position >= appliedEnd) {
+      // op is entirely after appliedOp
+      return { ...op, position: op.position - appliedOp.length };
+    } else if (
+      op.position >= appliedOp.position &&
+      opEnd <= appliedEnd
+    ) {
+      // op is entirely within appliedOp (already deleted)
+      return { type: "delete", position: appliedOp.position, length: 0 };
+    } else if (
+      op.position <= appliedOp.position &&
+      opEnd >= appliedEnd
+    ) {
+      // op encompasses appliedOp
+      return {
+        type: "delete",
+        position: op.position,
+        length: op.length - appliedOp.length,
+      };
+    } else if (op.position < appliedOp.position && opEnd <= appliedEnd) {
+      // op overlaps the start of appliedOp
+      return {
+        type: "delete",
+        position: op.position,
+        length: appliedOp.position - op.position,
+      };
+    } else {
+      // op overlaps the end of appliedOp
+      return {
+        type: "delete",
+        position: appliedOp.position,
+        length: opEnd - appliedEnd,
+      };
+    }
+  }
+
+  return { ...op };
+}
+
+/**
+ * Validate an operation against a document.
+ * Returns null if valid, or an error message if invalid.
+ */
+export function validateOperation(
+  doc: string,
+  op: unknown
+): string | null {
+  if (!op || typeof op !== "object") {
+    return "Operation must be an object";
+  }
+
+  const o = op as Record<string, unknown>;
+
+  if (o.type !== "insert" && o.type !== "delete") {
+    return 'Operation type must be "insert" or "delete"';
+  }
+
+  if (typeof o.position !== "number" || o.position < 0 || !Number.isInteger(o.position)) {
+    return "Position must be a non-negative integer";
+  }
+
+  if (o.type === "insert") {
+    if (typeof o.text !== "string" || o.text.length === 0) {
+      return "Insert operation must have a non-empty text string";
+    }
+    if (o.position > doc.length) {
+      return `Insert position ${o.position} is out of bounds (doc length: ${doc.length})`;
+    }
+  }
+
+  if (o.type === "delete") {
+    if (typeof o.length !== "number" || o.length < 0 || !Number.isInteger(o.length)) {
+      return "Delete operation must have a non-negative integer length";
+    }
+    if (o.position + (o.length as number) > doc.length) {
+      return `Delete range [${o.position}, ${o.position + (o.length as number)}) is out of bounds (doc length: ${doc.length})`;
+    }
+  }
+
+  return null;
+}
