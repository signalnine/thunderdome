+    expect(doc.title).toBe("Persistent Doc");
+    expect(doc.content).toBe("persisted content");
+
+    await appB.stop();
+
+    // Cleanup
+    const { unlinkSync } = await import("node:fs");
+    try {
+      unlinkSync(tmpDb);
+      unlinkSync(tmpDb + "-wal");
+      unlinkSync(tmpDb + "-shm");
+    } catch {
+      // files may not exist
+    }
+  });
+});
