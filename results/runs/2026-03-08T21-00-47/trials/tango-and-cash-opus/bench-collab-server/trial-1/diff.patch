+      })
+    );
+
+    const ack1 = await client1.waitForMessage();
+    expect(ack1.type).toBe("ack");
+
+    // Client 2 also inserts "Y" at position 6 based on same original version
+    // (simulating concurrent edit - client 2 hasn't seen client 1's edit yet)
+    client2.ws.send(
+      JSON.stringify({
+        type: "operation",
+        operation: { type: "insert", position: 6, text: "Y" },
+        version, // same version as client1 started with
+      })
+    );
