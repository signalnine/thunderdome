diff --git a/src/__tests__/api.test.ts b/src/__tests__/api.test.ts
new file mode 100644
index 0000000..921c519
--- /dev/null
+++ b/src/__tests__/api.test.ts
@@ -0,0 +1,125 @@
+import { describe, it, expect, beforeAll, afterAll } from "vitest";
+import { createApp, type AppInstance } from "../server.js";
+
+let app: AppInstance;
+let baseUrl: string;
+
+beforeAll(async () => {
+  app = createApp(); // in-memory DB
+  const port = await app.start(0);
+  baseUrl = `http://localhost:${port}`;
+});
+
+afterAll(async () => {
+  await app.stop();
+});
+
+describe("REST API", () => {
+  let docId: string;
+
+  it("should create a document", async () => {
+    const res = await fetch(`${baseUrl}/api/documents`, {
+      method: "POST",
+      headers: { "Content-Type": "application/json" },
+      body: JSON.stringify({ title: "Test Doc", content: "hello" }),
+    });
+    expect(res.status).toBe(201);
+    const doc = await res.json();
+    expect(doc.title).toBe("Test Doc");
+    expect(doc.content).toBe("hello");
+    expect(doc.id).toBeDefined();
+    docId = doc.id;
+  });
+
+  it("should reject creating a document without title", async () => {
+    const res = await fetch(`${baseUrl}/api/documents`, {
+      method: "POST",
+      headers: { "Content-Type": "application/json" },
+      body: JSON.stringify({ content: "no title" }),
+    });
+    expect(res.status).toBe(400);
+  });
+
+  it("should list documents", async () => {
+    const res = await fetch(`${baseUrl}/api/documents`);
+    expect(res.status).toBe(200);
+    const docs = await res.json();
+    expect(Array.isArray(docs)).toBe(true);
+    expect(docs.length).toBeGreaterThanOrEqual(1);
+  });
+
+  it("should get a document by id", async () => {
+    const res = await fetch(`${baseUrl}/api/documents/${docId}`);
+    expect(res.status).toBe(200);
+    const doc = await res.json();
+    expect(doc.id).toBe(docId);
+    expect(doc.title).toBe("Test Doc");
+  });
+
+  it("should return 404 for non-existent document", async () => {
+    const res = await fetch(`${baseUrl}/api/documents/non-existent`);
+    expect(res.status).toBe(404);
+  });
+
+  it("should update a document", async () => {
+    const res = await fetch(`${baseUrl}/api/documents/${docId}`, {
+      method: "PUT",
+      headers: { "Content-Type": "application/json" },
+      body: JSON.stringify({ title: "Updated Title", content: "updated content" }),
+    });
+    expect(res.status).toBe(200);
+    const doc = await res.json();
+    expect(doc.title).toBe("Updated Title");
+    expect(doc.content).toBe("updated content");
+  });
+
+  it("should partially update a document with PATCH", async () => {
+    const res = await fetch(`${baseUrl}/api/documents/${docId}`, {
+      method: "PATCH",
+      headers: { "Content-Type": "application/json" },
+      body: JSON.stringify({ title: "Patched Title" }),
+    });
+    expect(res.status).toBe(200);
+    const doc = await res.json();
+    expect(doc.title).toBe("Patched Title");
+    expect(doc.content).toBe("updated content"); // unchanged
+  });
+
+  it("should get version history", async () => {
+    const res = await fetch(`${baseUrl}/api/documents/${docId}/versions`);
+    expect(res.status).toBe(200);
+    const versions = await res.json();
+    expect(Array.isArray(versions)).toBe(true);
+    expect(versions.length).toBeGreaterThanOrEqual(1);
+    expect(versions[0].version).toBe(1);
+  });
+
+  it("should get a specific version", async () => {
+    const res = await fetch(`${baseUrl}/api/documents/${docId}/versions/1`);
+    expect(res.status).toBe(200);
+    const version = await res.json();
+    expect(version.version).toBe(1);
+  });
+
+  it("should return 404 for non-existent version", async () => {
+    const res = await fetch(`${baseUrl}/api/documents/${docId}/versions/999`);
+    expect(res.status).toBe(404);
+  });
+
+  it("should delete a document", async () => {
+    const res = await fetch(`${baseUrl}/api/documents/${docId}`, {
+      method: "DELETE",
+    });
+    expect(res.status).toBe(204);
+
+    const getRes = await fetch(`${baseUrl}/api/documents/${docId}`);
+    expect(getRes.status).toBe(404);
+  });
+
+  it("should return 404 deleting non-existent document", async () => {
+    const res = await fetch(`${baseUrl}/api/documents/non-existent`, {
+      method: "DELETE",
+    });
+    expect(res.status).toBe(404);
+  });
+});
diff --git a/src/__tests__/ot.test.ts b/src/__tests__/ot.test.ts
new file mode 100644
index 0000000..0134527
--- /dev/null
+++ b/src/__tests__/ot.test.ts
@@ -0,0 +1,199 @@
+import { describe, it, expect } from "vitest";
+import {
+  applyOperation,
+  transformOp,
+  validateOperation,
+  type Operation,
+} from "../ot.js";
+
+describe("applyOperation", () => {
+  it("should insert text at the beginning", () => {
+    expect(applyOperation("world", { type: "insert", position: 0, text: "hello " })).toBe(
+      "hello world"
+    );
+  });
+
+  it("should insert text at the end", () => {
+    expect(applyOperation("hello", { type: "insert", position: 5, text: " world" })).toBe(
+      "hello world"
+    );
+  });
+
+  it("should insert text in the middle", () => {
+    expect(applyOperation("heo", { type: "insert", position: 2, text: "ll" })).toBe(
+      "hello"
+    );
+  });
+
+  it("should delete text from the beginning", () => {
+    expect(applyOperation("hello world", { type: "delete", position: 0, length: 6 })).toBe(
+      "world"
+    );
+  });
+
+  it("should delete text from the end", () => {
+    expect(applyOperation("hello world", { type: "delete", position: 5, length: 6 })).toBe(
+      "hello"
+    );
+  });
+
+  it("should delete text from the middle", () => {
+    expect(applyOperation("hello", { type: "delete", position: 2, length: 2 })).toBe(
+      "heo"
+    );
+  });
+
+  it("should handle insert on empty string", () => {
+    expect(applyOperation("", { type: "insert", position: 0, text: "hello" })).toBe(
+      "hello"
+    );
+  });
+
+  it("should clamp insert position beyond doc length", () => {
+    expect(applyOperation("ab", { type: "insert", position: 100, text: "c" })).toBe(
+      "abc"
+    );
+  });
+});
+
+describe("transformOp", () => {
+  it("should transform insert vs insert (op before applied)", () => {
+    const op: Operation = { type: "insert", position: 0, text: "a" };
+    const applied: Operation = { type: "insert", position: 2, text: "b" };
+    const result = transformOp(op, applied);
+    expect(result.type).toBe("insert");
+    expect((result as typeof op).position).toBe(0);
+  });
+
+  it("should transform insert vs insert (op after applied)", () => {
+    const op: Operation = { type: "insert", position: 5, text: "a" };
+    const applied: Operation = { type: "insert", position: 2, text: "bbb" };
+    const result = transformOp(op, applied);
+    expect(result.type).toBe("insert");
+    expect((result as typeof op).position).toBe(8); // 5 + 3
+  });
+
+  it("should transform insert vs delete (op before delete)", () => {
+    const op: Operation = { type: "insert", position: 1, text: "x" };
+    const applied: Operation = { type: "delete", position: 3, length: 2 };
+    const result = transformOp(op, applied);
+    expect((result as typeof op).position).toBe(1);
+  });
+
+  it("should transform insert vs delete (op after delete)", () => {
+    const op: Operation = { type: "insert", position: 5, text: "x" };
+    const applied: Operation = { type: "delete", position: 1, length: 2 };
+    const result = transformOp(op, applied);
+    expect((result as typeof op).position).toBe(3); // 5 - 2
+  });
+
+  it("should transform delete vs insert (delete before insert)", () => {
+    const op: Operation = { type: "delete", position: 0, length: 2 };
+    const applied: Operation = { type: "insert", position: 5, text: "abc" };
+    const result = transformOp(op, applied);
+    expect((result as typeof op).position).toBe(0);
+  });
+
+  it("should transform delete vs insert (delete after insert)", () => {
+    const op: Operation = { type: "delete", position: 5, length: 2 };
+    const applied: Operation = { type: "insert", position: 2, text: "abc" };
+    const result = transformOp(op, applied);
+    expect((result as typeof op).position).toBe(8); // 5 + 3
+  });
+
+  it("should transform delete vs delete (non-overlapping, op before)", () => {
+    const op: Operation = { type: "delete", position: 0, length: 2 };
+    const applied: Operation = { type: "delete", position: 5, length: 2 };
+    const result = transformOp(op, applied);
+    expect((result as typeof op).position).toBe(0);
+    expect((result as typeof op).length).toBe(2);
+  });
+
+  it("should transform delete vs delete (non-overlapping, op after)", () => {
+    const op: Operation = { type: "delete", position: 5, length: 2 };
+    const applied: Operation = { type: "delete", position: 0, length: 2 };
+    const result = transformOp(op, applied);
+    expect((result as typeof op).position).toBe(3); // 5 - 2
+    expect((result as typeof op).length).toBe(2);
+  });
+
+  it("should transform delete vs delete (op inside applied - already deleted)", () => {
+    const op: Operation = { type: "delete", position: 2, length: 2 };
+    const applied: Operation = { type: "delete", position: 1, length: 5 };
+    const result = transformOp(op, applied);
+    expect((result as typeof op).length).toBe(0);
