ndle insert on empty string\", () => {\n    expect(applyOperation(\"\", { type: \"insert\", position: 0, text: \"hello\" })).toBe(\n      \"hello\"\n    );\n  });\n\n  it(\"should clamp insert position beyond doc length\", () => {\n    expect(applyOperation(\"ab\", { type: \"insert\", position: 100, text: \"c\" })).toBe(\n      \"abc\"\n    );\n  });\n});\n\ndescribe(\"transformOp\", () => {\n  it(\"should transform insert vs insert (op before applied)\", () => {\n    const op: Operation = { type: \"insert\", position: 0, text: \"a\" };\n    const applied: Operation = { type: \"insert\", position: 2, text: \"b\" };\n    const result = transformOp(op, applied);\n    expect(result.type).toBe(\"insert\");\n    expect((result as typeof op).position).toBe(0);\n  });\n\n  it(\"should transform insert vs insert (op after applied)\", () => {\n    const op: Operation = { type: \"insert\", position: 5, text: \"a\" };\n    const applied: Operation = { type: \"insert\", position: 2, text: \"bbb\" };\n    const result = transformOp(op, applied);\n    expect(result.type).toBe(\"insert\");\n    expect((result as typeof op).position).toBe(8); // 5 + 3\n  });\n\n  it(\"should transform insert vs delete (op before delete)\", () => {\n    const op: Operation = { type: \"insert\", position: 1, text: \"x\" };\n    const applied: Operation = { type: \"delete\", position: 3, length: 2 };\n    const result = transformOp(op, applied);\n    expect((result as typeof op).position).toBe(1);\n  });\n\n  it(\"should transform insert vs delete (op after delete)\", () => {\n    const op: Operation = { type: \"insert\", position: 5, text: \"x\" };\n    const applied: Operation = { type: \"delete\", position: 1, length: 2 };\n    const result = transformOp(op, applied);\n    expect((result as typeof op).position).toBe(3); // 5 - 2\n  });\n\n  it(\"should transform delete vs insert (delete before insert)\", () => {\n    const op: Operation = { type: \"delete\", position: 0, length: 2 };\n    const applied: Operation = { type: \"insert\", position: 5, text: \"abc\" };\n    const result = transformOp(op, applied);\n    expect((result as typeof op).position).toBe(0);\n  });\n\n  it(\"should transform delete vs insert (delete after insert)\", () => {\n    const op: Operation = { type: \"delete\", position: 5, length: 2 };\n    const applied: Operation = { type: \"insert\", position: 2, text: \"abc\" };\n    const result = transformOp(op, applied);\n    expect((result as typeof op).position).toBe(8); // 5 + 3\n  });\n\n  it(\"should transform delete vs delete (non-overlapping, op before)\", () => {\n    const op: Operation = { type: \"delete\", position: 0, length: 2 };\n    const applied: Operation = { type: \"delete\", position: 5, length: 2 };\n    const result = transformOp(op, applied);\n    expect((result as typeof op).position).toBe(0);\n    expect((result as typeof op).length).toBe(2);\n  });\n\n  it(\"should transform delete vs delete (non-overlapping, op after)\", () => {\n    const op: Operation = { type: \"delete\", position: 5, length: 2 };\n    const applied: Operation = { type: \"delete\", position: 0, length: 2 };\n    const result = transformOp(op, applied);\n    expect((result as typeof op).position).toBe(3); // 5 - 2\n    expect((result as typeof op).length).toBe(2);\n  });\n\n  it(\"should transform delete vs delete (op inside applied - already deleted)\", () => {\n    const op: Operation = { type: \"delete\", position: 2, length: 2 };\n    const applied: Operation = { type: \"delete\", position: 1, length: 5 };\n    const result = transformOp(op, applied);\n    expect((result as typeof op).length).toBe(0);\n  });\n\n  it(\"should preserve both insertions at the same position\", () => {\n    // Two users insert at position 0\n    const doc = \"hello\";\n    const op1: Operation = { type: \"insert\", position: 0, text: \"A\" };\n    const op2: Operation = { type: \"insert\", position: 0, text: \"B\" };\n\n    // Apply op1, then transform op2 agains