ait createDoc(\"Many Clients\", \"\");\n    const clients: WebSocket[] = [];\n    const versions: number[] = [];\n\n    // Connect 10 clients\n    for (let i = 0; i < 10; i++) {\n      const ws = await connectWs(docId);\n      const sync = await waitForMessage(ws);\n      versions.push(sync.version as number);\n      clients.push(ws);\n    }\n\n    // Each client inserts its number sequentially\n    for (let i = 0; i < 10; i++) {\n      const ws = clients[i];\n\n      ws.send(\n        JSON.stringify({\n          type: \"operation\",\n          operation: { type: \"insert\", position: i, text: String(i) },\n          version: versions[i],\n        })\n      );\n\n      // Wait for ack\n      const ack = await waitForMessage(ws);\n      expect(ack.type).toBe(\"ack\");\n      const newVersion = ack.version as number;\n\n      // Update versions for subsequent clients by consuming their broadcasts\n      for (let j = i + 1; j < 10; j++) {\n        const broadcast = await waitForMessage(clients[j]);\n        expect(broadcast.type).toBe(\"operation\");\n        versions[j] = broadcast.version as number;\n      }\n      // Also consume broadcasts for previous clients (they get broadcasts from current)\n      for (let j = 0; j < i; j++) {\n        const broadcast = await waitForMessage(clients[j]);\n        expect(broadcast.type).toBe(\"operation\");\n      }\n\n      versions[i] = newVersion;\n    }\n\n    // Verify final state - all 10 digits should be present\n    const res = await fetch(`${baseUrl}/api/documents/${docId}`);\n    const doc = await res.json();\n    expect(doc.content.length).toBe(10);\n    for (let i = 0; i < 10; i++) {\n      expect(doc.content).toContain(String(i));\n    }\n\n    // Cleanup\n    for (const ws of clients) {\n      ws.close();\n    }\n  });\n});\n\ndescribe(\"Persistence\", () => {\n  it(\"should persist documents across server restarts\", async () => {\n    // Create a document using one server\n    const app1 = createApp(\":memory:\");