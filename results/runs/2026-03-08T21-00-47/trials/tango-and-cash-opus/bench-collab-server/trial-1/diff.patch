+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CJigEZQ5LMP4MBrXAsurR4","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from \"ws\";\n     2→import type { Server as HttpServer } from \"node:http\";\n     3→import type { DocumentStore } from \"./documents.js\";\n     4→import {\n     5→  applyOperation,\n     6→  transformOp,\n     7→  validateOperation,\n     8→  type Operation,\n     9→} from \"./ot.js\";\n    10→\n    11→interface ClientInfo {\n    12→  ws: WebSocket;\n    13→  documentId: string;\n    14→  clientId: string;\n    15→}\n    16→\n    17→interface OperationHistoryEntry {\n    18→  version: number;\n    19→  operation: Operation;\n    20→}\n    21→\n    22→export class CollaborationServer {\n    23→  private wss: WebSocketServer;\n    24→  private clients: Map<string, ClientInfo> = new Map();\n    25→  // documentId -> list of operations applied since version 0\n    26→  private operationHistory: Map<string, OperationHistoryEntry[]> = new Map();\n    27→  // documentId -> current server version\n    28→  private documentVersions: Map<string, number> = new Map();\n    29→\n    30→  constructor(\n    31→    private server: HttpServer,\n    32→    private store: DocumentStore\n    33→  ) {\n    34→    this.wss = new WebSocketServer({ server, path: undefined });\n    35→\n    36→    // Use noServer approach for path-based routing\n    37→    this.wss.close();\n    38→    this.wss = new WebSocketServer({ noServer: true });\n    39→\n    40→    server.on(\"upgrade\", (request, socket, head) => {\n    41→      const url = request.url ?? \"\";\n    42→      const match = url.match(/^\\/ws\\/documents\\/([^/?]+)/);\n    43→      if (!match) {\n    44→        socket.destroy();\n    45→        return;\n    46→      }\n    47→\n    48→      const documentId = match[1];\n    49→      const doc = this.store.getById(documentId);\n    50→      if (!doc) {\n    51→        socket.write(\"HTTP/1.1 404 Not Found\\r