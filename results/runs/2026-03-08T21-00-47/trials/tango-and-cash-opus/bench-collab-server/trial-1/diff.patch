llaborationServer = null;\n    50→      }\n    51→      if (httpServer) {\n    52→        return new Promise<void>((resolve, reject) => {\n    53→          httpServer!.close((err) => {\n    54→            if (err) reject(err);\n    55→            else resolve();\n    56→          });\n    57→          httpServer = null;\n    58→        });\n    59→      }\n    60→      db.close();\n    61→    },\n    62→  };\n    63→}\n    64→"}]},"parent_tool_use_id":null,"session_id":"21cda2ec-edc2-46f0-8fda-ab2c6e58ee41","uuid":"882e0bb4-62df-41cb-ac23-f7444107d07b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/server.ts","content":"import express from \"express\";\nimport { createServer, type Server as HttpServer } from \"node:http\";\nimport { createDatabase } from \"./db.js\";\nimport { DocumentStore } from \"./documents.js\";\nimport { createRouter } from \"./routes.js\";\nimport { CollaborationServer } from \"./websocket.js\";\nimport type Database from \"better-sqlite3\";\n\nexport interface AppInstance {\n  app: express.Express;\n  start(port?: number): Promise<number>;\n  stop(): Promise<void>;\n}\n\nexport function createApp(dbPath?: string): AppInstance {\n  const db: Database.Database = createDatabase(dbPath);\n  const store = new DocumentStore(db);\n  const app = express();\n  const router = createRouter(store);\n\n  app.use(\"/api\", router);\n\n  let httpServer: HttpServer | null = null;\n  let collaborationServer: CollaborationServer | null = null;\n\n  return {\n    app,\n\n    async start(port = 0): Promise<number> {\n      httpServer = createServer(app);\n      collaborationServer = new CollaborationServer(httpServer, store);\n\n      return new Promise<number>((resolve, reject) => {\n        httpServer!.on(\"error\", reject);\n        httpServer!.listen(port, () => {\n          const addr = httpServer!.address();\n          if (addr && typeof addr === \"object\") {\n            resolve(addr.port);\n          } else {\n            resolve(port);\n          }\n        });\n      });\n    },\n\n    async stop(): Promise<void> {\n      if (collaborationServer) {\n        collaborationServer.closeAll();\n        collaborationServer = null;\n      }\n      if (httpServer) {\n        return new Promise<void>((resolve, reject) => {\n          httpServer!.close((err) => {\n            if (err) reject(err);\n            else resolve();\n          });\n          httpServer = null;\n        });\n      }\n      db.close();\n    },\n  };\n}\n","numLines":64,"startLine":1,"totalLines":64}}}
