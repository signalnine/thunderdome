+
+    const ack = await client.waitForMessage();
+    expect(ack.type).toBe("ack");
+
+    const res = await fetch(`${baseUrl}/api/documents/${docId}`);
+    const doc = await res.json();
+    expect(doc.content).toBe("llo");
+
+    client.ws.close();
+  });
+
+  it("should broadcast operations to other clients", async () => {
+    const client1 = await connectWs(docId);
+    const sync1 = await client1.waitForMessage();
+
+    const client2 = await connectWs(docId);
+    await client2.waitForMessage(); // sync
+
+    // client1 sends an operation
+    client1.ws.send(
+      JSON.stringify({
+        type: "operation",
+        operation: { type: "insert", position: 5, text: " world" },
+        version: sync1.version,
+      })
+    );
+
+    // client1 gets ack
+    const ack = await client1.waitForMessage();
+    expect(ack.type).toBe("ack");
