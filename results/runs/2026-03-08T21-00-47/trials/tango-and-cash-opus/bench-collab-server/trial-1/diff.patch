d: Operation = { type: \"insert\", position: 5, text: \"abc\" };\n    const result = transformOp(op, applied);\n    expect((result as typeof op).position).toBe(0);\n  });\n\n  it(\"should transform delete vs insert (delete after insert)\", () => {\n    const op: Operation = { type: \"delete\", position: 5, length: 2 };\n    const applied: Operation = { type: \"insert\", position: 2, text: \"abc\" };\n    const result = transformOp(op, applied);\n    expect((result as typeof op).position).toBe(8); // 5 + 3\n  });\n\n  it(\"should transform delete vs delete (non-overlapping, op before)\", () => {\n    const op: Operation = { type: \"delete\", position: 0, length: 2 };\n    const applied: Operation = { type: \"delete\", position: 5, length: 2 };\n    const result = transformOp(op, applied);\n    expect((result as typeof op).position).toBe(0);\n    expect((result as typeof op).length).toBe(2);\n  });\n\n  it(\"should transform delete vs delete (non-overlapping, op after)\", () => {\n    const op: Operation = { type: \"delete\", position: 5, length: 2 };\n    const applied: Operation = { type: \"delete\", position: 0, length: 2 };\n    const result = transformOp(op, applied);\n    expect((result as typeof op).position).toBe(3); // 5 - 2\n    expect((result as typeof op).length).toBe(2);\n  });\n\n  it(\"should transform delete vs delete (op inside applied - already deleted)\", () => {\n    const op: Operation = { type: \"delete\", position: 2, length: 2 };\n    const applied: Operation = { type: \"delete\", position: 1, length: 5 };\n    const result = transformOp(op, applied);\n    expect((result as typeof op).length).toBe(0);\n  });\n\n  it(\"should preserve both insertions at the same position\", () => {\n    // Two users insert at position 0\n    const doc = \"hello\";\n    const op1: Operation = { type: \"insert\", position: 0, text: \"A\" };\n    const op2: Operation = { type: \"insert\", position: 0, text: \"B\" };\n\n    // Apply op1, then transform op2 against op1\n    const doc1 = applyOperation(doc, op1);\n    const transformedOp2 = transformOp(op2, op1);\n    const finalDoc = applyOperation(doc1, transformedOp2);\n\n    // Both insertions should be preserved\n    expect(finalDoc).toContain(\"A\");\n    expect(finalDoc).toContain(\"B\");\n    expect(finalDoc).toContain(\"hello\");\n    expect(finalDoc.length).toBe(7); // \"hello\" + \"A\" + \"B\"\n  });\n});\n\ndescribe(\"validateOperation\", () => {\n  it(\"should accept valid insert operation\", () => {\n    expect(validateOperation(\"hello\", { type: \"insert\", position: 0, text: \"a\" })).toBeNull();\n  });\n\n  it(\"should accept valid delete operation\", () => {\n    expect(validateOperation(\"hello\", { type: \"delete\", position: 0, length: 2 })).toBeNull();\n  });\n\n  it(\"should reject non-object\", () => {\n    expect(validateOperation(\"hello\", null)).not.toBeNull();\n    expect(validateOperation(\"hello\", \"string\")).not.toBeNull();\n  });\n\n  it(\"should reject invalid type\", () => {\n    expect(validateOperation(\"hello\", { type: \"replace\", position: 0 })).not.toBeNull();\n  });\n\n  it(\"should reject negative position\", () => {\n    expect(\n      validateOperation(\"hello\", { type: \"insert\", position: -1, text: \"a\" })\n    ).not.toBeNull();\n  });\n\n  it(\"should reject insert with empty text\", () => {\n    expect(\n      validateOperation(\"hello\", { type: \"insert\", position: 0, text: \"\" })\n    ).not.toBeNull();\n  });\n\n  it(\"should reject insert beyond doc length\", () => {\n    expect(\n      validateOperation(\"hi\", { type: \"insert\", position: 10, text: \"a\" })\n    ).not.toBeNull();\n  });\n\n  it(\"should reject delete beyond doc length\", () => {\n    expect(\n      validateOperation(\"hi\", { type: \"delete\", position: 0, length: 10 })\n    ).not.toBeNull();\n  });\n\n  it(\"should reject negative delete length\", () => {\n    expect(\n      validateOperation(\"hi\", { type: \"delete\", position: 0, length: -1 })\