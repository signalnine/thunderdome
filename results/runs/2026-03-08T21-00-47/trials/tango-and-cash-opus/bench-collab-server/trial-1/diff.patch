s: WebSocket, _request: unknown, documentId: string) => {\n      this.handleConnection(ws, documentId);\n    });\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string): void {\n    const clientId = crypto.randomUUID();\n    this.clients.set(clientId, { ws, documentId, clientId });\n\n    // Initialize operation history for this document if needed\n    if (!this.operationHistory.has(documentId)) {\n      this.operationHistory.set(documentId, []);\n      const currentVersion = this.store.getCurrentVersion(documentId);\n      this.documentVersions.set(documentId, currentVersion);\n    }\n\n    // Send current document state\n    const doc = this.store.getById(documentId);\n    if (doc) {\n      const version = this.documentVersions.get(documentId) ?? 0;\n      ws.send(\n        JSON.stringify({\n          type: \"sync\",\n          content: doc.content,\n          version,\n          clientId,\n        })\n      );\n    }\n\n    ws.on(\"message\", (data) => {\n      try {\n        const message = JSON.parse(data.toString());\n        this.handleMessage(clientId, message);\n      } catch {\n        ws.send(\n          JSON.stringify({\n            type: \"error\",\n            message: \"Invalid JSON message\",\n          })\n        );\n      }\n    });\n\n    ws.on(\"close\", () => {\n      this.clients.delete(clientId);\n    });\n\n    ws.on(\"error\", () => {\n      this.clients.delete(clientId);\n    });\n  }\n\n  private handleMessage(\n    clientId: string,\n    message: Record<string, unknown>\n  ): void {\n    const client = this.clients.get(clientId);\n    if (!client) return;\n\n    if (message.type === \"operation\") {\n      this.handleOperation(client, message);\n    }\n  }\n\n  private handleOperation(\n    client: ClientInfo,\n    message: Record<string, unknown>\n  ): void {\n    const { documentId, ws } = client;\n    const op = message.operation as Operation | undefined;\n    const clientVersion = message.version as number | undefined;\n\n    if (op === undefined || clientVersion === undefined) {\n      ws.send(\n        JSON.stringify({\n          type: \"error\",\n          message: \"Operation message must include 'operation' and 'version'\",\n        })\n      );\n      return;\n    }\n\n    if (\n      typeof clientVersion !== \"number\" ||\n      !Number.isInteger(clientVersion) ||\n      clientVersion < 0\n    ) {\n      ws.send(\n        JSON.stringify({\n          type: \"error\",\n          message: \"Version must be a non-negative integer\",\n        })\n      );\n      return;\n    }\n\n    const doc = this.store.getById(documentId);\n    if (!doc) {\n      ws.send(\n        JSON.stringify({ type: \"error\", message: \"Document not found\" })\n      );\n      return;\n    }\n\n    const history = this.operationHistory.get(documentId) ?? [];\n    const serverVersion = this.documentVersions.get(documentId) ?? 0;\n\n    // Transform the operation against all operations that happened after clientVersion\n    let transformedOp = { ...op } as Operation;\n\n    if (clientVersion > serverVersion) {\n      ws.send(\n        JSON.stringify({\n          type: \"error\",\n          message: `Client version ${clientVersion} is ahead of server version ${serverVersion}`,\n        })\n      );\n      return;\n    }\n\n    // Transform against all operations since clientVersion\n    for (const entry of history) {\n      if (entry.version > clientVersion) {\n        transformedOp = transformOp(transformedOp, entry.operation);\n      }\n    }\n\n    // Validate the transformed operation against current document\n    const validationError = validateOperation(doc.content, transformedOp);\n    if (validationError) {\n      ws.send(\n        JSON.stringify({ type: \"error\", message: validationError })\n      );\n      return;\n    }\n\n    // Apply the operation\n    const newContent = applyOperation(doc.content, transformedOp);\n    const newVersion = serverVersion + 1;\n\n    // Update document\n    this.store.updateContent(\n      documentId,\n      newContent,\n      JSON.stringify(transformedOp)\n    );\n\n    // Record in operation history\n    history.push({ version: newVersion, operation: transformedOp });\n    this.operationHistory.set(documentId, history);\n    this.documentVersions.set(documentId, newVersion);\n\n    // Acknowledge to sender\n    ws.send(\n      JSON.stringify({\n        type: \"ack\",\n        version: newVersion,\n        operation: transformedOp,\n      })\n    );\n\n    // Broadcast to other clients on the same document\n    for (const [id, other] of this.clients) {\n      if (\n        id !== client.clientId &&\n        other.documentId === documentId &&\n        other.ws.readyState === WebSocket.OPEN\n      ) {\n        other.ws.send(\n          JSON.stringify({\n            type: \"operation\",\n            operation: transformedOp,\n            version: newVersion,\n            clientId: client.clientId,\n          })\n        );\n      }\n    }\n  }\n\n  closeAll(): void {\n    for (const [, client] of this.clients) {\n      client.ws.close();\n    }\n    this.clients.clear();\n    this.wss.close();\n  }\n}\n","structuredPatch":[{"oldStart":31,"oldLines":10,"newStart":31,"newLines":6,"lines":["     private server: HttpServer,","     private store: DocumentStore","   ) {","-    this.wss = new WebSocketServer({ server, path: undefined });","-","-    // Use noServer approach for path-based routing","-    this.wss.close();","     this.wss = new WebSocketServer({ noServer: true });"," ","     server.on(\"upgrade\", (request, socket, head) => {"]},{"oldStart":54,"oldLines":13,"newStart":50,"newLines":9,"lines":["       }"," ","       this.wss.handleUpgrade(request, socket, head, (ws) => {","-        this.wss.emit(\"connection\", ws, request, documentId);","+        this.handleConnection(ws, documentId);","       });","     });","-","-    this.wss.on(\"connection\", (ws: WebSocket, _request: unknown, documentId: string) => {","-      this