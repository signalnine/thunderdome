passes appliedOp\n      return {\n        type: \"delete\",\n        position: op.position,\n        length: op.length - appliedOp.length,\n      };\n    } else if (op.position < appliedOp.position && opEnd <= appliedEnd) {\n      // op overlaps the start of appliedOp\n      return {\n        type: \"delete\",\n        position: op.position,\n        length: appliedOp.position - op.position,\n      };\n    } else {\n      // op overlaps the end of appliedOp\n      return {\n        type: \"delete\",\n        position: appliedOp.position,\n        length: opEnd - appliedEnd,\n      };\n    }\n  }\n\n  return { ...op };\n}\n\n/**\n * Validate an operation against a document.\n * Returns null if valid, or an error message if invalid.\n */\nexport function validateOperation(\n  doc: string,\n  op: unknown\n): string | null {\n  if (!op || typeof op !== \"object\") {\n    return \"Operation must be an object\";\n  }\n\n  const o = op as Record<string, unknown>;\n\n  if (o.type !== \"insert\" && o.type !== \"delete\") {\n    return 'Operation type must be \"insert\" or \"delete\"';\n  }\n\n  if (typeof o.position !== \"number\" || o.position < 0 || !Number.isInteger(o.position)) {\n    return \"Position must be a non-negative integer\";\n  }\n\n  if (o.type === \"insert\") {\n    if (typeof o.text !== \"string\" || o.text.length === 0) {\n      return \"Insert operation must have a non-empty text string\";\n    }\n    if (o.position > doc.length) {\n      return `Insert position ${o.position} is out of bounds (doc length: ${doc.length})`;\n    }\n  }\n\n  if (o.type === \"delete\") {\n    if (typeof o.length !== \"number\" || o.length < 0 || !Number.isInteger(o.length)) {\n      return \"Delete operation must have a non-negative integer length\";\n    }\n    if (o.position + (o.length as number) > doc.length) {\n      return `Delete range [${o.position}, ${o.position + (o.length as number)}) is out of bounds (doc length: ${doc.length})`;\n    }\n  }\n\n  return null;\n}\n