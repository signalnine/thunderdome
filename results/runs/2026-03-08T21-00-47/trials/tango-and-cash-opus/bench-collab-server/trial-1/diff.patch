+import type Database from "better-sqlite3";
+import { randomUUID } from "node:crypto";
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export class DocumentStore {
+  constructor(private db: Database.Database) {}
+
+  create(title: string, content = ""): Document {
+    const id = randomUUID();
+    this.db
+      .prepare(
+        "INSERT INTO documents (id, title, content) VALUES (?, ?, ?)"
+      )
+      .run(id, title, content);
+
+    // Create initial version
+    this.db
+      .prepare(
+        "INSERT INTO versions (document_id, version, content) VALUES (?, 1, ?)"
+      )
+      .run(id, content);
+
+    return this.getById(id)!;
+  }
+
+  getById(id: string): Document | undefined {
+    return this.db
+      .prepare("SELECT * FROM documents WHERE id = ?")
+      .get(id) as Document | undefined;
+  }
+
+  list(): Document[] {
+    return this.db
+      .prepare("SELECT * FROM documents ORDER BY updated_at DESC")
+      .all() as Document[];
+  }
+
+  update(
+    id: string,
+    updates: { title?: string; content?: string }
+  ): Document | undefined {
+    const doc = this.getById(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+
+    this.db
+      .prepare(
+        "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+      )
+      .run(title, content, id);
+
+    return this.getById(id);
+  }
+
+  updateContent(id: string, content: string, operation?: string): void {
+    this.db
+      .prepare(
+        "UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?"
+      )
+      .run(content, id);
+
+    // Get current max version
+    const row = this.db
+      .prepare(
+        "SELECT COALESCE(MAX(version), 0) as max_version FROM versions WHERE document_id = ?"
+      )
+      .get(id) as { max_version: number };
+
+    const nextVersion = row.max_version + 1;
+
+    this.db
+      .prepare(
+        "INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)"
+      )
+      .run(id, nextVersion, content, operation ?? null);
+  }
+
+  delete(id: string): boolean {
+    const result = this.db
+      .prepare("DELETE FROM documents WHERE id = ?")
+      .run(id);
+    return result.changes > 0;
+  }
+
+  getVersions(documentId: string): Version[] {
+    return this.db
+      .prepare(
+        "SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC"
+      )
+      .all(documentId) as Version[];
+  }
+
+  getVersion(documentId: string, version: number): Version | undefined {
+    return this.db
+      .prepare(
+        "SELECT * FROM versions WHERE document_id = ? AND version = ?"
+      )
+      .get(documentId, version) as Version | undefined;
+  }
+
+  getCurrentVersion(documentId: string): number {
+    const row = this.db
+      .prepare(
+        "SELECT COALESCE(MAX(version), 0) as max_version FROM versions WHERE document_id = ?"
+      )
+      .get(documentId) as { max_version: number };
+    return row.max_version;
+  }
+}
