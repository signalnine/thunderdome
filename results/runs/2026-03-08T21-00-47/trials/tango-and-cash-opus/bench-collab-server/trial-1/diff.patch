@@ -0,0 +1,97 @@
+import { Router, json } from "express";
+import type { DocumentStore } from "./documents.js";
+
+export function createRouter(store: DocumentStore): Router {
+  const router = Router();
+  router.use(json());
+
+  // List all documents
+  router.get("/documents", (_req, res) => {
+    const docs = store.list();
+    res.json(docs);
+  });
+
+  // Create a document
+  router.post("/documents", (req, res) => {
+    const { title, content } = req.body;
+    if (!title || typeof title !== "string") {
+      res.status(400).json({ error: "Title is required and must be a string" });
+      return;
+    }
+    const doc = store.create(title, content ?? "");
+    res.status(201).json(doc);
+  });
+
+  // Get a document
+  router.get("/documents/:id", (req, res) => {
+    const doc = store.getById(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: "Document not found" });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update a document
+  router.put("/documents/:id", (req, res) => {
+    const { title, content } = req.body;
+    const doc = store.update(req.params.id, { title, content });
+    if (!doc) {
+      res.status(404).json({ error: "Document not found" });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Partially update a document
+  router.patch("/documents/:id", (req, res) => {
+    const { title, content } = req.body;
+    const doc = store.update(req.params.id, { title, content });
+    if (!doc) {
+      res.status(404).json({ error: "Document not found" });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Delete a document
+  router.delete("/documents/:id", (req, res) => {
+    const deleted = store.delete(req.params.id);
+    if (!deleted) {
+      res.status(404).json({ error: "Document not found" });
+      return;
+    }
+    res.status(204).send();
+  });
+
+  // Get document version history
+  router.get("/documents/:id/versions", (req, res) => {
+    const doc = store.getById(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: "Document not found" });
+      return;
+    }
+    const versions = store.getVersions(req.params.id);
+    res.json(versions);
+  });
+
+  // Get specific version
+  router.get("/documents/:id/versions/:version", (req, res) => {
+    const doc = store.getById(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: "Document not found" });
+      return;
+    }
+    const version = store.getVersion(
+      req.params.id,
+      parseInt(req.params.version, 10)
+    );
+    if (!version) {
+      res.status(404).json({ error: "Version not found" });
+      return;
+    }
+    res.json(version);
+  });
+
+  return router;
+}
