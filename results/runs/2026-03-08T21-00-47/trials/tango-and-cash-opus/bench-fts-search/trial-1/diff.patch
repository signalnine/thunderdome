pare(`\n          SELECT notes.id, notes.title,\n            snippet(notes_fts, -1, '<mark>', '</mark>', '...', 64) as snippet,\n            rank\n          FROM notes_fts\n          JOIN notes ON notes.id = notes_fts.rowid\n          WHERE notes_fts MATCH ?\n          ORDER BY rank\n          LIMIT ? OFFSET ?\n        `);\n        const results = searchStmt.all(query, perPage, offset);\n\n        const countStmt = db.prepare(`\n          SELECT COUNT(*) as cnt FROM notes_fts WHERE notes_fts MATCH ?\n        `);\n        const total = (countStmt.get(query) as { cnt: number }).cnt;\n\n        return { results, total };\n      };\n\n      let result;\n      try {\n        result = doSearch(sanitized);\n      } catch {\n        // If the query has special FTS characters that cause errors, sanitize and retry\n        const cleaned = sanitized.replace(/[^\\w\\s\"]/g, ' ').trim();\n        if (cleaned === '') {\n          result = { results: [], total: 0 };\n        } else {\n          try {\n            result = doSearch(cleaned);\n          } catch {\n            result = { results: [], total: 0 };\n          }\n        }\n      }\n\n      res.json({\n        results: result.results,\n        total: result.total,\n        page,\n        perPage,\n      });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /notes/:id - Get single note\n  router.get('/notes/:id', (req: Request, res: Response, next: NextFunction) => {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":250,"cache_read_input_tokens":40343,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":250},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4edb710e-b6c2-4b37-bdd5-5a6180ebaeb9","uuid":"19cd4792-6db7-44b1-8f00-a743657a23d9"}
