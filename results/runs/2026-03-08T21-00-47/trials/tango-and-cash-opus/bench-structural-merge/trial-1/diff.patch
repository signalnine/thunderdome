diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..b9e6c38
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,459 @@
+import { randomUUID } from 'node:crypto';
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  base: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  ours: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  theirs: any;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocEntry {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchState {
+  docs: Map<string, DocEntry>;
+  parentBranch: string | null;
+  branchPointSnapshot: Map<string, DocEntry> | null;
+}
+
+function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+function cloneDocEntry(entry: DocEntry): DocEntry {
+  return {
+    content: deepClone(entry.content),
+    versions: entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+    deleted: entry.deleted,
+  };
+}
+
+function cloneDocs(docs: Map<string, DocEntry>): Map<string, DocEntry> {
+  const result = new Map<string, DocEntry>();
+  for (const [id, entry] of docs) {
+    result.set(id, cloneDocEntry(entry));
+  }
+  return result;
+}
+
+type JsonValue = string | number | boolean | null | JsonValue[] | { [key: string]: JsonValue };
+type JsonObject = Record<string, JsonValue>;
+
+function getNestedValue(obj: unknown, pathParts: string[]): unknown {
+  let current: unknown = obj;
+  for (const part of pathParts) {
+    if (current === undefined || current === null || typeof current !== 'object') {
+      return undefined;
+    }
+    current = (current as JsonObject)[part];
+  }
+  return current;
+}
+
+function setNestedValue(obj: JsonObject, pathParts: string[], value: unknown): void {
+  let current: JsonObject = obj;
+  for (let i = 0; i < pathParts.length - 1; i++) {
+    const key = pathParts[i];
+    if (current[key] === undefined || current[key] === null || typeof current[key] !== 'object') {
+      current[key] = {} as JsonValue;
+    }
+    current = current[key] as JsonObject;
+  }
+  current[pathParts[pathParts.length - 1]] = value as JsonValue;
+}
+
+function deleteNestedValue(obj: JsonObject, pathParts: string[]): void {
+  let current: JsonObject = obj;
+  for (let i = 0; i < pathParts.length - 1; i++) {
+    const key = pathParts[i];
+    if (current[key] === undefined || typeof current[key] !== 'object') {
+      return;
+    }
+    current = current[key] as JsonObject;
+  }
+  delete current[pathParts[pathParts.length - 1]];
+}
+
+function collectLeafPaths(obj: unknown, prefix: string[] = []): string[][] {
+  const paths: string[][] = [];
+  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {
+    return paths;
+  }
+  for (const key of Object.keys(obj)) {
+    const currentPath = [...prefix, key];
+    const val = (obj as JsonObject)[key];
+    if (val !== null && val !== undefined && typeof val === 'object' && !Array.isArray(val)) {
+      const childPaths = collectLeafPaths(val, currentPath);
+      if (childPaths.length === 0) {
+        paths.push(currentPath);
+      } else {
+        paths.push(...childPaths);
+      }
+    } else {
+      paths.push(currentPath);
+    }
+  }
+  return paths;
+}
+
+function valuesEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === undefined && b === undefined) return true;
+  if (a === null && b === null) return true;
+  if (a === undefined || b === undefined) return false;
+  if (a === null || b === null) return false;
+  return JSON.stringify(a) === JSON.stringify(b);
+}
+
+function threeWayMergeDoc(
+  base: object | null,
+  ours: object | null,
+  theirs: object | null,
+  documentId: string
+): { merged: object; conflicts: Conflict[] } {
+  const baseObj = base ?? {};
+  const oursObj = ours ?? {};
+  const theirsObj = theirs ?? {};
+
+  const leafPaths = new Set<string>();
+  for (const p of collectLeafPaths(baseObj)) leafPaths.add(p.join('.'));
+  for (const p of collectLeafPaths(oursObj)) leafPaths.add(p.join('.'));
+  for (const p of collectLeafPaths(theirsObj)) leafPaths.add(p.join('.'));
+
+  const conflicts: Conflict[] = [];
+  const merged = deepClone(oursObj) as JsonObject;
+
+  for (const pathStr of leafPaths) {
+    const pathParts = pathStr.split('.');
+    const baseVal = getNestedValue(baseObj, pathParts);
+    const oursVal = getNestedValue(oursObj, pathParts);
+    const theirsVal = getNestedValue(theirsObj, pathParts);
+
+    const oursChanged = !valuesEqual(baseVal, oursVal);
+    const theirsChanged = !valuesEqual(baseVal, theirsVal);
+
+    if (!oursChanged && !theirsChanged) {
+      continue;
+    }
+
+    if (oursChanged && !theirsChanged) {
+      continue;
+    }
+
+    if (!oursChanged && theirsChanged) {
+      if (theirsVal === undefined) {
+        deleteNestedValue(merged, pathParts);
+      } else {
+        setNestedValue(merged, pathParts, deepClone(theirsVal));
+      }
+      continue;
+    }
+
+    // Both changed
+    if (valuesEqual(oursVal, theirsVal)) {
+      continue;
+    }
+
+    conflicts.push({
+      documentId,
+      path: pathStr,
+      base: baseVal === undefined ? undefined : deepClone(baseVal),
+      ours: oursVal === undefined ? undefined : deepClone(oursVal),
+      theirs: theirsVal === undefined ? undefined : deepClone(theirsVal),
+    });
+  }
+
+  return { merged, conflicts };
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      docs: new Map(),
+      parentBranch: null,
+      branchPointSnapshot: null,
+    });
+  }
+
+  private getBranchState(name?: string): BranchState {
+    const branchName = name ?? this.currentBranch;
+    const state = this.branches.get(branchName);
+    if (!state) {
+      throw new Error(`Branch "${branchName}" does not exist`);
+    }
+    return state;
+  }
+
+  create(id: string, content: object): void {
+    const state = this.getBranchState();
+    const existing = state.docs.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const clonedContent = deepClone(content);
+    const version: Version = {
+      id: randomUUID(),
+      timestamp: Date.now(),
+      content: deepClone(clonedContent),
+    };
+    state.docs.set(id, {
+      content: clonedContent,
+      versions: existing?.deleted ? [...existing.versions, version] : [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const state = this.getBranchState();
+    const doc = state.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const state = this.getBranchState();
+    const doc = state.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const clonedContent = deepClone(content);
+    const version: Version = {
+      id: randomUUID(),
+      timestamp: Date.now(),
+      content: deepClone(clonedContent),
+    };
+    doc.content = clonedContent;
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const state = this.getBranchState();
+    const doc = state.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    doc.deleted = true;
+  }
+
+  getHistory(id: string): Version[] {
+    const state = this.getBranchState();
+    const doc = state.docs.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const state = this.getBranchState();
+    const doc = state.docs.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceBranchName = fromBranch ?? this.currentBranch;
+    const sourceState = this.getBranchState(sourceBranchName);
+    const snapshot = cloneDocs(sourceState.docs);
+    this.branches.set(name, {
+      docs: cloneDocs(sourceState.docs),
+      parentBranch: sourceBranchName,
+      branchPointSnapshot: snapshot,
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    if (!this.branches.has(sourceBranch)) {
+      throw new Error(`Branch "${sourceBranch}" does not exist`);
+    }
+
+    const targetState = this.getBranchState();
+    const sourceState = this.getBranchState(sourceBranch);
+
+    // Find common ancestor: use the branch point snapshot
+    let baseSnapshot: Map<string, DocEntry>;
+
+    const sourceBranchState = this.branches.get(sourceBranch)!;
+    if (sourceBranchState.parentBranch === this.currentBranch && sourceBranchState.branchPointSnapshot) {
+      baseSnapshot = sourceBranchState.branchPointSnapshot;
+    } else {
+      const targetBranchState = this.branches.get(this.currentBranch)!;
+      if (targetBranchState.parentBranch === sourceBranch && targetBranchState.branchPointSnapshot) {
+        baseSnapshot = targetBranchState.branchPointSnapshot;
+      } else {
+        baseSnapshot = new Map();
+      }
+    }
+
+    // Collect all document IDs
+    const allDocIds = new Set<string>();
+    for (const id of baseSnapshot.keys()) allDocIds.add(id);
+    for (const id of targetState.docs.keys()) allDocIds.add(id);
+    for (const id of sourceState.docs.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseEntry = baseSnapshot.get(docId);
+      const oursEntry = targetState.docs.get(docId);
+      const theirsEntry = sourceState.docs.get(docId);
+
+      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;
+      const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : null;
+      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : null;
+
+      const oursChanged = !valuesEqual(baseContent, oursContent);
+      const theirsChanged = !valuesEqual(baseContent, theirsContent);
+
+      if (!oursChanged && !theirsChanged) {
+        continue;
+      }
+
+      if (!oursChanged && theirsChanged) {
+        if (theirsContent !== null) {
+          merged[docId] = deepClone(theirsContent);
+        }
+        continue;
+      }
+
+      if (oursChanged && !theirsChanged) {
+        if (oursContent !== null) {
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      // Both changed
+      if (oursContent === null && theirsContent === null) {
+        continue;
+      }
+
+      if (oursContent === null || theirsContent === null) {
+        const conflict: Conflict = {
+          documentId: docId,
+          path: '',
+          base: baseContent !== null ? deepClone(baseContent) : undefined,
+          ours: oursContent !== null ? deepClone(oursContent) : undefined,
+          theirs: theirsContent !== null ? deepClone(theirsContent) : undefined,
+        };
+        allConflicts.push(conflict);
+        if (oursContent !== null) {
+          merged[docId] = deepClone(oursContent);
+        }
+        continue;
+      }
+
+      // Both exist and both changed - structural merge
+      const { merged: mergedDoc, conflicts } = threeWayMergeDoc(
+        baseContent,
+        oursContent,
+        theirsContent,
+        docId
+      );
+      merged[docId] = mergedDoc;
+      allConflicts.push(...conflicts);
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      // Apply merge to current branch
+      for (const docId of allDocIds) {
+        const baseEntry = baseSnapshot.get(docId);
+        const theirsEntry = sourceState.docs.get(docId);
+
+        const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;
+        const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : null;
+
+        const theirsChanged = !valuesEqual(baseContent, theirsContent);
+        if (!theirsChanged) continue;
+
+        if (merged[docId] !== undefined) {
+          const existingEntry = targetState.docs.get(docId);
+          const newContent = deepClone(merged[docId]);
+          const version: Version = {
+            id: randomUUID(),
+            timestamp: Date.now(),
+            content: deepClone(newContent),
+          };
+
+          if (existingEntry && !existingEntry.deleted) {
+            existingEntry.content = newContent;
+            existingEntry.versions.push(version);
+          } else {
+            targetState.docs.set(docId, {
+              content: newContent,
+              versions: existingEntry ? [...existingEntry.versions, version] : [version],
+              deleted: false,
+            });
+          }
+        } else {
+          // Document was deleted on source and not changed on target
+          const existingEntry = targetState.docs.get(docId);
+          if (existingEntry) {
+            existingEntry.deleted = true;
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+}
