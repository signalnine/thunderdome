+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('Document CRUD', () => {
+    it('should create and get a document', () => {
+      store.create('doc1', { name: 'test' });
+      expect(store.get('doc1')).toEqual({ name: 'test' });
+    });
+
+    it('should throw when creating a document with existing id', () => {
+      store.create('doc1', { name: 'test' });
+      expect(() => store.create('doc1', { name: 'other' })).toThrow();
+    });
+
+    it('should throw when getting a non-existent document', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+
+    it('should update a document', () => {
+      store.create('doc1', { name: 'test' });
+      store.update('doc1', { name: 'updated' });
+      expect(store.get('doc1')).toEqual({ name: 'updated' });
+    });
+
+    it('should throw when updating a non-existent document', () => {
+      expect(() => store.update('nonexistent', { name: 'test' })).toThrow();
+    });
+
+    it('should delete a document', () => {
+      store.create('doc1', { name: 'test' });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should throw when deleting a non-existent document', () => {
+      expect(() => store.delete('nonexistent')).toThrow();
+    });
+
+    it('should throw when deleting an already deleted document', () => {
+      store.create('doc1', { name: 'test' });
+      store.delete('doc1');
+      expect(() => store.delete('doc1')).toThrow();
+    });
+
+    it('should throw when updating a deleted document', () => {
+      store.create('doc1', { name: 'test' });
+      store.delete('doc1');
+      expect(() => store.update('doc1', { name: 'updated' })).toThrow();
+    });
+
+    it('should deep clone on create - mutations should not affect stored data', () => {
+      const content = { name: 'test', nested: { value: 1 } };
+      store.create('doc1', content);
+      content.name = 'mutated';
+      content.nested.value = 999;
+      expect(store.get('doc1')).toEqual({ name: 'test', nested: { value: 1 } });
+    });
+
+    it('should deep clone on get - mutations should not affect stored data', () => {
+      store.create('doc1', { name: 'test', nested: { value: 1 } });
+      const result = store.get('doc1') as Record<string, unknown>;
+      result.name = 'mutated';
+      (result.nested as Record<string, unknown>).value = 999;
+      expect(store.get('doc1')).toEqual({ name: 'test', nested: { value: 1 } });
+    });
+
+    it('should deep clone on update - mutations should not affect stored data', () => {
+      store.create('doc1', { name: 'test' });
+      const newContent = { name: 'updated', nested: { value: 2 } };
+      store.update('doc1', newContent);
+      newContent.name = 'mutated';
+      expect(store.get('doc1')).toEqual({ name: 'updated', nested: { value: 2 } });
+    });
+  });
+
+  describe('Version History', () => {
+    it('should track versions on create', () => {
+      store.create('doc1', { name: 'v1' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(1);
+      expect(history[0].content).toEqual({ name: 'v1' });
+      expect(typeof history[0].id).toBe('string');
+      expect(typeof history[0].timestamp).toBe('number');
+    });
+
+    it('should track versions on update', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      store.update('doc1', { name: 'v3' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ name: 'v1' });
+      expect(history[1].content).toEqual({ name: 'v2' });
+      expect(history[2].content).toEqual({ name: 'v3' });
+    });
+
+    it('should return versions in chronological order', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);
+    });
+
+    it('should get a specific version', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(store.getVersion('doc1', history[0].id)).toEqual({ name: 'v1' });
+      expect(store.getVersion('doc1', history[1].id)).toEqual({ name: 'v2' });
+    });
+
+    it('should throw for non-existent document in getHistory', () => {
+      expect(() => store.getHistory('nonexistent')).toThrow();
+    });
+
+    it('should throw for non-existent version in getVersion', () => {
+      store.create('doc1', { name: 'v1' });
+      expect(() => store.getVersion('doc1', 'bad-version')).toThrow();
+    });
+
+    it('should throw for non-existent document in getVersion', () => {
+      expect(() => store.getVersion('nonexistent', 'any')).toThrow();
+    });
+
+    it('should have unique version ids', () => {
+      store.create('doc1', { name: 'v1' });
+      store.update('doc1', { name: 'v2' });
+      store.update('doc1', { name: 'v3' });
+      const history = store.getHistory('doc1');
+      const ids = history.map(v => v.id);
+      expect(new Set(ids).size).toBe(ids.length);
+    });
+
+    it('should deep clone version content', () => {
+      store.create('doc1', { name: 'v1', nested: { x: 1 } });
+      const history = store.getHistory('doc1');
+      (history[0].content as Record<string, unknown>).name = 'mutated';
+      expect(store.getHistory('doc1')[0].content).toEqual({ name: 'v1', nested: { x: 1 } });
+    });
+  });
+
+  describe('Branching', () => {
+    it('should default to main branch', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('should create and switch branches', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    it('should list branches', () => {
+      store.createBranch('feature');
+      store.createBranch('bugfix');
