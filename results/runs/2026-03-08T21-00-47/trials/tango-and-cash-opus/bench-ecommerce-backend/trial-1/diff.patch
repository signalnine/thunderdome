): number {\n      return prices.get(productId) ?? 0;\n    },\n  };\n}\n","structuredPatch":[{"oldStart":1,"oldLines":5,"newStart":1,"newLines":5,"lines":[" import { EventBus } from '../bus.js';","-import { PricingService, Events, ProductCreatedEvent, PriceCalculatedEvent } from '../types.js';","+import { PricingService, Events, ProductCreatedEvent } from '../types.js';"," "," export function createPricingService(bus: EventBus): PricingService {","   const prices = new Map<string, number>();"]}],"userModified":false,"replaceAll":false}}
