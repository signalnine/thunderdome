ew Promise(r => setTimeout(r, 10));\n    expect(events).toHaveLength(1);\n  });\n});\n\n// ==================== PAYMENT ====================\ndescribe('PaymentService', () => {\n  it('should process payment successfully by default', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should not refund a failed payment', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(false);\n  });\n\n  it('should not refund non-existent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit PAYMENT_PROCESSED event', async () => {\n    const payment = createPaymentService(bus);\n    const events: unknown[] = [];\n    bus.on(Events.PAYMENT_PROCESSED, (payload) => { events.push(payload); });\n    await payment.processPayment('order1', 100);\n    expect(events).toHaveLength(1);\n  });\n});\n\n// ==================== NOTIFICATIONS ====================\ndescribe('NotificationService', () => {\n  it('should not notify unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    createOrderService(bus);\n    const orders = createOrderService(bus);\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n\n  it('should notify subscribed users on order status change', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(1);\n    expect(notifs.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should notify subscribed users on payment processed', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n    await payment.processPayment(orderId, 100);\n    await new Promise(r => setTimeout(r, 10));\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('should return empty array for user with no notifications', () => {\n    const notifications = createNotificationService(bus);\n    expect(notifications.getNotifications('user1')).toEqual([]);\n  });\n});\n\n// ==================== ANALYTICS ====================\ndescribe('AnalyticsService', () => {\n  it('should count events', async () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 10, 'cat');\n    catalog.createProduct('B', 20, 'cat');\n    await new Promise(r => setTimeout(r, 10));\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const orderId = orders.createOrder('user1', 'cart1', 150);\n    await new Promise(r => setTimeout(r, 10));\n    await payment.processPayment(orderId, 150);\n    await new Promise(r => setTimeout(r, 10));\n    expect(analytics.getRevenue()).toBe(150);\n  });\n\n  it('should not track revenue from failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const orderId = orders.createOrder('user1', 'cart1', 150);\n    await new Promise(r => setTimeout(r, 10));\n    await payment.processPayment(orderId, 150);\n    await new Promise(r => setTimeout(r, 10));\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cartService = createCartService(bus);\n    const orders = createOrderService(bus);\n    const cartId1 = cartService.createCart('user1');\n    cartService.addItem(cartId1, 'p1', 1);\n    await new Promise(r => setTimeout(r, 10));\n    const cartId2 = cartService.createCart('user2');\n    cartService.addItem(cartId2, 'p2', 1);\n    await new Promise(r => setTimeout(r, 10));\n    orders.createOrder('user1', cartId1, 100);\n    await new Promise(r => setTimeout(r, 10));\n    // 1 order / 2 unique carts = 0.5\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should track top products', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cartService = createCartService(bus);\n    const orders = createOrderService(bus);\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, 'p1', 5);\n    cartService.addItem(cartId, 'p2', 3);\n    await new Promise(r => setTimeout(r, 10));\n    orders.createOrder('user1', cartId, 100);\n    await new Promise(r => setTimeout(r, 10));\n    const top = analytics.getTopProducts(2);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(3);\n  });\n\n  it('should return 0 for unknown event type', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getEventCount('unknown:event')).toBe(0);\n  });\n});\n\n// ==================== INTEGRATION ====================\ndescribe('Integration', () => {\n  it('should handle a full purchase flow', async () => {\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartService = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Laptop', 999, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29, 'electronics');\n    await new Promise(r => setTimeout(r, 10));\n\n    // Set inventory\n    inventory.setStock(p1, 10);\n    inventory.setStock(p2, 50);\n\n    // Create cart and add items\n    const cartId = cartService.createCart('user1');\n    cartService.addItem(cartId, p1, 1);\n    cartService.addItem(cartId, p2, 2);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Calculate price\n    const cart = cartService.getCart(cartId)!;\n    const items = cart.items.map(item => ({\n      productId: item.productId,\n      quantity: item.quantity,\n      price: pricing.getPrice(item.productId),\n    }));\n    const total = pricing.calculateTotal(items);\n    expect(total.subtotal).toBe(999 + 29 * 2);\n\n    // Reserve inventory\n    for (const item of cart.items) {\n      expect(inventory.reserve(item.productId, item.quantity)).toBe(true);\n    }\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, total.total);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, total.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Check notifications\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n\n    // Check analytics\n    expect(analytics.getRevenue()).toBe(total.total);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBeGreaterThanOrEqual(1);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":161,"cache_read_input_tokens