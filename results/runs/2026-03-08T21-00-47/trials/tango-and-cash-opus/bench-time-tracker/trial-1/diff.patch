('Task name cannot be empty');\n    });\n  });\n\n  describe('recording entries', () => {\n    it('should capture task name, start, and stop', () => {\n      tracker.start('reading');\n      const stopped = tracker.stop();\n      expect(stopped.task).toBe('reading');\n      expect(new Date(stopped.start).getTime()).toBeGreaterThan(0);\n      expect(stopped.stop).not.toBeNull();\n      expect(new Date(stopped.stop!).getTime()).toBeGreaterThan(0);\n    });\n\n    it('should leave stop as null for running entries', () => {\n      tracker.start('running-task');\n      const entries = tracker.getEntries();\n      expect(entries[0].stop).toBeNull();\n    });\n  });\n\n  describe('persistence', () => {\n    it('should save to a JSON file', () => {\n      tracker.start('persist-test');\n      tracker.stop();\n      expect(existsSync(filePath)).toBe(true);\n      const data = JSON.parse(readFileSync(filePath, 'utf-8'));\n      expect(data.entries).toHaveLength(1);\n    });\n\n    it('should survive between sessions', () => {\n      tracker.start('session1');\n      tracker.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe('session1');\n    });\n\n    it('should create parent directories if they do not exist', () => {\n      const nested = join(tmpdir(), `deep-${Date.now()}`, 'nested', 'dir', 'data.json');\n      const t = new TimeTracker(nested);\n      t.start('deep');\n      t.stop();\n      expect(existsSync(nested)).toBe(true);\n      try { rmSync(join(tmpdir(), `deep-${Date.now()}`), { recursive: true }); } catch { /* ignore */ }\n    });\n\n    it('should handle configurable file path', () => {\n      const customPath = tempFile();\n      const t = new TimeTracker(customPath);\n      t.start('custom');\n      t.stop();\n      expect(existsSync(customPath)).toBe(true);\n      try { rmSync(customPath); } catch { /* ignore */ }\n    });\n  });\n\n  describe('querying entries', () => {\n    it('should retrieve all entries', () => {\n      tracker.start('a');\n      tracker.start('b');\n      tracker.stop();\n      expect(tracker.getEntries()).toHaveLength(2);\n    });\n\n    it('should filter entries by date range', () => {\n      const past = new Date('2020-01-01');\n      const future = new Date('2099-12-31');\n\n      tracker.start('now');\n      tracker.stop();\n\n      expect(tracker.getEntries(past, future)).toHaveLength(1);\n      expect(tracker.getEntries(future)).toHaveLength(0);\n      expect(tracker.getEntries(undefined, past)).toHaveLength(0);\n    });\n  });\n\n  describe('summarizing time', () => {\n    it('should sum time per task name in milliseconds', () => {\n      tracker.start('coding');\n      tracker.stop();\n      tracker.start('coding');\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary['coding']).toBeGreaterThan(0);\n    });\n\n    it('should use current time for running tasks', () => {\n      tracker.start('running');\n      const summary = tracker.getSummary();\n      expect(summary['running']).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should handle multiple different task names', () => {\n      tracker.start('a');\n      tracker.start('b');\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect('a' in summary).toBe(true);\n      expect('b' in summary).toBe(true);\n    });\n  });\n\n  describe('unicode support', () => {\n    it('should handle emoji task names', () => {\n      tracker.start('🚀 Launch');\n      tracker.stop();\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe('🚀 Launch');\n    });\n\n    it('should handle CJK characters', () => {\n      tracker.start('编程任务');\n      tracker.stop();\n      const summary = tracker.getSummary();\n      expect('编程任务' in summary).toBe(true);\n    });\n\n    it('should handle mixed unicode', () => {\n      tracker.start('Ñoño 日本語