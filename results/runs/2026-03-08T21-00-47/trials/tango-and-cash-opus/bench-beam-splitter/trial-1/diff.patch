+export function countBeamCells(grid: string[][]): number {
+    const rows = grid.length;
+    if (rows === 0) return 0;
+    const cols = grid[0].length;
+    if (cols === 0) return 0;
+
+    let visitedCount = 0;
+
+    // state[c][dir] where dir is 0 for DL, 1 for D, 2 for DR
+    // representing dc = -1, 0, 1
+    let currentRow = Array.from({ length: cols }, () => [false, false, false]);
+
+    // Initialize row 0 with 'S'
+    for (let c = 0; c < cols; c++) {
+        if (grid[0][c] === 'S') {
+            currentRow[c][1] = true; // D direction
+        }
+    }
+
+    for (let r = 0; r < rows; r++) {
+        const nextRow = Array.from({ length: cols }, () => [false, false, false]);
+        
+        for (let c = 0; c < cols; c++) {
+            const hasDL = currentRow[c][0];
+            const hasD = currentRow[c][1];
+            const hasDR = currentRow[c][2];
+            
+            if (hasDL || hasD || hasDR) {
+                visitedCount++;
+                
+                const cell = grid[r][c];
+                if (cell === '^') {
+                    // Splits into DL and DR
+                    if (c - 1 >= 0) nextRow[c - 1][0] = true;
+                    if (c + 1 < cols) nextRow[c + 1][2] = true;
+                } else {
+                    // Continues in current direction
+                    if (hasDL && c - 1 >= 0) nextRow[c - 1][0] = true;
+                    if (hasD) nextRow[c][1] = true;
+                    if (hasDR && c + 1 < cols) nextRow[c + 1][2] = true;
+                }
+            }
+        }
+        currentRow = nextRow;
+    }
+
+    return visitedCount;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+    const rows = grid.length;
+    if (rows === 0) return 0n;
+    const cols = grid[0].length;
+    if (cols === 0) return 0n;
+
+    let totalPaths = 0n;
+
+    // currentRow[c][dir] stores the number of paths
+    let currentRow = Array.from({ length: cols }, () => [0n, 0n, 0n]);
+
+    for (let c = 0; c < cols; c++) {
+        if (grid[0][c] === 'S') {
+            currentRow[c][1] = 1n; // D direction
+        }
+    }
+
+    for (let r = 0; r < rows; r++) {
+        const nextRow = Array.from({ length: cols }, () => [0n, 0n, 0n]);
+        
+        for (let c = 0; c < cols; c++) {
+            const countDL = currentRow[c][0];
+            const countD = currentRow[c][1];
+            const countDR = currentRow[c][2];
+            
+            const total = countDL + countD + countDR;
+            if (total > 0n) {
+                const cell = grid[r][c];
+                if (cell === '^') {
+                    // Splits into DL and DR
+                    // Out of bounds check
+                    if (c - 1 < 0) totalPaths += total;
+                    else nextRow[c - 1][0] += total;
+                    
+                    if (c + 1 >= cols) totalPaths += total;
+                    else nextRow[c + 1][2] += total;
+                } else {
+                    // Continues in current direction
+                    if (countDL > 0n) {
+                        if (c - 1 < 0) totalPaths += countDL;
+                        else nextRow[c - 1][0] += countDL;
+                    }
+                    if (countD > 0n) {
+                        // D never goes out of bounds on the sides
+                        nextRow[c][1] += countD;
+                    }
+                    if (countDR > 0n) {
+                        if (c + 1 >= cols) totalPaths += countDR;
+                        else nextRow[c + 1][2] += countDR;
+                    }
+                }
+            }
+        }
+        currentRow = nextRow;
+    }
+
+    // Any paths remaining in currentRow after all rows are processed have exited the bottom of the grid
+    for (let c = 0; c < cols; c++) {
+        totalPaths += currentRow[c][0] + currentRow[c][1] + currentRow[c][2];
+    }
+
+    return totalPaths;
+}
