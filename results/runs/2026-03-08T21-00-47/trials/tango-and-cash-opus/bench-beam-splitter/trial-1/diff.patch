+import { expect, test, describe } from 'vitest';
+import { countBeamCells, countBeamPaths } from '../src/index';
+
+function parseGrid(str: string): string[][] {
+    return str.trim().split('\n').map(line => line.trim().split(' '));
+}
+
+describe('Beam Splitter', () => {
+    test('Example 1', () => {
+        const grid = parseGrid(`
+. S . . .
+. . . . .
+. ^ . . .
+. . . . .
+        `);
+        expect(countBeamCells(grid)).toBe(5);
+        expect(countBeamPaths(grid)).toBe(2n);
+    });
+
+    test('Example 2', () => {
+        const grid = parseGrid(`
+. S . . .
+. ^ . . .
+^ . ^ . .
+. . . . .
+        `);
+        expect(countBeamCells(grid)).toBe(6);
+        expect(countBeamPaths(grid)).toBe(4n);
+    });
+
+    test('Edge case: no splitters', () => {
+        const grid = parseGrid(`
+. S . . .
+. . . . .
+. . . . .
+        `);
+        expect(countBeamCells(grid)).toBe(3);
+        expect(countBeamPaths(grid)).toBe(1n);
+    });
+
+    test('Edge case: beam exits sides immediately after split', () => {
+        const grid = parseGrid(`
+S . .
+^ . .
+        `);
+        expect(countBeamCells(grid)).toBe(2);
+        // Path splits at (1,0): down-left goes to (2,-1) which is out of bounds (absorbed)
+        // down-right goes to (2,1) which is out of bounds (absorbed at bottom)
+        expect(countBeamPaths(grid)).toBe(2n);
+    });
+
+    test('Edge case: multiple sources', () => {
+        const grid = parseGrid(`
+S . S . S
+. . . . .
+. . ^ . .
+        `);
+        // Three sources.
+        // Left S visits (0,0), (1,0), (2,0)
+        // Middle S visits (0,2), (1,2), (2,2) splitter. Splits to (3,1) and (3,3) (exit grid)
+        // Right S visits (0,4), (1,4), (2,4)
+        // Total cells: 3 (left) + 3 (middle) + 3 (right) = 9
+        expect(countBeamCells(grid)).toBe(9);
+        // Paths: left (1), middle (2), right (1) = 4
+        expect(countBeamPaths(grid)).toBe(4n);
+    });
+
+    test('Boundary: beam immediately exits', () => {
+        const grid = parseGrid(`
+S
+        `);
+        expect(countBeamCells(grid)).toBe(1);
+        expect(countBeamPaths(grid)).toBe(1n);
+    });
+
+    test('Large Grid without splitters', () => {
+        const rows = 200;
+        const cols = 200;
+        const grid = Array.from({ length: rows }, (_, r) => 
+            Array.from({ length: cols }, (_, c) => r === 0 && c === 100 ? 'S' : '.')
+        );
+        expect(countBeamCells(grid)).toBe(200);
+        expect(countBeamPaths(grid)).toBe(1n);
+    });
+
+    test('Large Grid with many splitters', () => {
+        const fullSplitterGrid = Array.from({ length: 50 }, (_, r) => 
+            Array.from({ length: 100 }, (_, c) => {
+                if (r === 0 && c === 50) return 'S';
+                return '^';
+            })
+        );
+        expect(countBeamCells(fullSplitterGrid)).toBeGreaterThan(0);
+        expect(countBeamPaths(fullSplitterGrid)).toBeGreaterThan(0n);
+    });
+});
