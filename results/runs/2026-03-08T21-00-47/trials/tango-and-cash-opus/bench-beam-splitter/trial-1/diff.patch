=== 1) {\n    // Beam exits immediately below row 0\n    return 1n;\n  }\n\n  currentBeams.set(`${sourceCol},D`, 1n);\n\n  for (let r = 1; r < rows; r++) {\n    const nextBeams: Map<string, bigint> = new Map();\n\n    for (const [key, count] of currentBeams.entries()) {\n      const parts = key.split(',');\n      const col = parseInt(parts[0]);\n      const dir = parts[1] as Direction;\n\n      if (col < 0 || col >= cols) {\n        // Beam exited grid sideways — count as completed path\n        totalPaths += count;\n        continue;\n      }\n\n      const cell = grid[r][col];\n\n      if (cell === '^') {\n        // Split into DL and DR\n        if (r + 1 < rows) {\n          const nlCol = col - 1;\n          const nrCol = col + 1;\n\n          // Left beam\n          if (nlCol >= 0 && nlCol < cols) {\n            const lKey = `${nlCol},DL`;\n            nextBeams.set(lKey, (nextBeams.get(lKey) ?? 0n) + count);\n          } else {\n            // Exits grid\n            totalPaths += count;\n          }\n\n          // Right beam\n          if (nrCol >= 0 && nrCol < cols) {\n            const rKey = `${nrCol},DR`;\n            nextBeams.set(rKey, (nextBeams.get(rKey) ?? 0n) + count);\n          } else {\n            // Exits grid\n            totalPaths += count;\n          }\n        } else {\n          // Both children exit below\n          totalPaths += count * 2n;\n        }\n      } else {\n        // Continue in same direction\n        const [nr, nc] = nextPos(r, col, dir);\n        if (nr >= rows || nc < 0 || nc >= cols) {\n          // Beam exits grid\n          totalPaths += count;\n        } else {\n          const nKey = `${nc},${dir}`;\n          nextBeams.set(nKey, (nextBeams.get(nKey) ?? 0n) + count);\n        }\n      }\n    }\n\n    currentBeams = nextBeams;\n    if (currentBeams.size === 0) break;\n  }\n\n  // Any beams still active after the last row exit the grid\n  for (const count of currentBeams.values()) {\n    totalPaths += count;\n  }\n\n