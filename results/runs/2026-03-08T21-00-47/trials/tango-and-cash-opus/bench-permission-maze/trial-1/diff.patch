nd retrieve folders, including nested', async () => {\n    const alice = await setupUser('alice');\n\n    // Create root folder\n    const rootRes = await request(app).post('/folders').set('Authorization', alice.auth)\n      .send({ name: 'Root Folder' });\n    expect(rootRes.status).toBe(201);\n    const rootId = rootRes.body.id;\n\n    // Create nested folder\n    const childRes = await request(app).post('/folders').set('Authorization', alice.auth)\n      .send({ name: 'Child Folder', parentId: rootId });\n    expect(childRes.status).toBe(201);\n    expect(childRes.body.parentId).toBe(rootId);\n\n    // Get folder\n    const getRes = await request(app).get(`/folders/${childRes.body.id}`).set('Authorization', alice.auth);\n    expect(getRes.status).toBe(200);\n    expect(getRes.body.name).toBe('Child Folder');\n  });\n\n  it('should perform document CRUD operations', async () => {\n    const alice = await setupUser('alice');\n    const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)\n      .send({ name: 'Docs' });\n    const folderId = folderRes.body.id;\n\n    // Create document\n    const docRes = await request(app).post('/documents').set('Authorization', alice.auth)\n      .send({ title: 'My Doc', content: 'Hello World', folderId });\n    expect(docRes.status).toBe(201);\n    const docId = docRes.body.id;\n\n    // Get document\n    const getRes = await request(app).get(`/documents/${docId}`).set('Authorization', alice.auth);\n    expect(getRes.status).toBe(200);\n    expect(getRes.body.title).toBe('My Doc');\n\n    // Update document\n    const putRes = await request(app).put(`/documents/${docId}`).set('Authorization', alice.auth)\n      .send({ title: 'Updated Doc' });\n    expect(putRes.status).toBe(200);\n    expect(putRes.body.title).toBe('Updated Doc');\n\n    // Delete document\n    const delRes = await request(app).delete(`/documents/${docId}`).set('Authorization', alice.auth);\n    expect(delRes.status).toBe(200);\n\n    // Verify deletion\n    const getDeleted = await request(app).get(`/documents/${docId}`).set('Authorization', alice.auth);\n    expect(getDeleted.status).toBe(404);\n  });\n\n  it('enforces permission checks (viewer/editor/owner)', async () => {\n    const alice = await setupUser('alice');\n    const bob = await setupUser('bob');\n    const charlie = await setupUser('charlie');\n    const dave = await setupUser('dave');\n\n    const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)\n      .send({ name: 'Shared' });\n    const folderId = folderRes.body.id;\n\n    // Alice shares folder with Bob as viewer, Charlie as editor\n    await request(app).post(`/folders/${folderId}/share`).set('Authorization', alice.auth)\n      .send({ userId: bob.id, role: 'viewer' });\n    await request(app).post(`/folders/${folderId}/share`).set('Authorization', alice.auth)\n      .send({ userId: charlie.id, role: 'editor' });\n\n    // Bob can read but not update or share\n    const getBob = await request(app).get(`/folders/${folderId}`).set('Authorization', bob.auth);\n    expect(getBob.status).toBe(200);\n\n    const putBob = await request(app).put(`/folders/${folderId}`).set('Authorization', bob.auth)\n      .send({ name: 'Bob Renamed' });\n    expect(putBob.status).toBe(403);\n\n    const shareBob = await request(app).post(`/folders/${folderId}/share`).set('Authorization', bob.auth)\n      .send({ userId: dave.id, role: 'viewer' });\n    expect(shareBob.status).toBe(403);\n\n    // Charlie can read, update, and share (up to editor)\n    const putCharlie = await request(app).put(`/folders/${folderId}`).set('Authorization', charlie.auth)\n      .send({ name: 'Charlie Renamed' });\n    expect(putCharlie.status).toBe(200);\n\n    const shareCharlie = await request(app).post(`/folders/${folderId}/share`).set('Authorization', charlie.auth)\n      .send({ userId: dave.id, role: 'viewer' });\n    expect(shareCharlie.status).toBe(200);\n\n    // Charlie cannot assign owner role\n    const shareCharlieOwner = await request(app).post(`/folders/${folderId}/share`).set('Authorization', charlie.auth)\n      .send({ userId: dave.id, role: 'owner' });\n    expect(shareCharlieOwner.status).toBe(403);\n\n    // Charlie cannot delete\n    const deleteCharlie = await request(app).delete(`/folders/${folderId}`).set('Authorization', charlie.auth);\n    expect(deleteCharlie.status).toBe(403);\n\n    // Alice (owner) can delete\n    const deleteAlice = await request(app).delete(`/folders/${folderId}`).set('Authorization', alice.auth);\n    expect(deleteAlice.status).toBe(200);\n  });\n\n  it('supports permission inheritance and most permissive role wins', async () => {\n    const alice = await setupUser('alice'); // owner\n    const bob = await setupUser('bob');\n\n    // Alice creates folder and doc\n    const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)\n      .send({ name: 'Parent' });\n    const folderId = folderRes.body.id;\n\n    const docRes = await request(app).post('/documents').set('Authorization', alice.auth)\n      .send({ title: 'Doc', content: '...', folderId });\n    const docId = docRes.body.id;\n\n    // Direct share on doc as viewer\n    await request(app).post(`/documents/${docId}/share`).set('Authorization', alice.auth)\n      .send({ userId: bob.id, role: 'viewer' });\n\n    // Bob can read doc but not edit\n    let putBob = await request(app).put(`/documents/${docId}`).set('Authorization', bob.auth)\n      .send({ title: 'Bob Edit' });\n    expect(putBob.status).toBe(403);\n\n    // Now Alice shares folder with Bob as editor\n    await request(app).post(`/folders/${folderId}/share`).set('Authorization', alice.auth)\n      .send({ userId: bob.id, role: 'editor' });\n\n    // Bob inherits editor permission on doc (most permissive wins)\n    putBob = await request(app).put(`/documents/${docId}`).set('Authorization', bob.auth)\n      .send({ title: 'Bob Edit 2' });\n    expect(putBob.status).toBe(200);\n  });\n\n  it('tracks activity log', async () => {\n    const alice = await setupUser('alice');\n\n    // Create folder\n    const fRes = await request(app).post('/folders').set('Authorization', alice.auth)\n      .send({ name: 'Log Test' });\n\n    // Update folder\n    await request(app).put(`/folders/${fRes.body.id}`).set('Authorization', alice.auth)\n      .send({ name: 'Log Test 2' });\n\n    // Get activity\n    const actRes = await request(app).get('/activity').set('Authorization', alice.auth);\n    expect(actRes.status).toBe(200);\n\n    const actions = actRes.body.map((a: { action: string }) => a.action);\n    expect(actions).toContain('create');\n    expect(actions).toContain('update');\n  });\n\n  it('returns appropriate error codes', async () => {\n    const alice = await setupUser('alice');\n\n    // 400 Bad Request\n    const badReq = await request(app).post('/folders').set('Authorization', alice.auth).send({});\n    expect(badReq.status).toBe(400);\n\n    // 404 Not Found\n    const notFound = await request(app).get('/folders/nonexistent').set('Authorization', alice.auth);\n    expect(notFound.status).toBe(404);\n\n    // 401 Unauthorized\n    const unauth = await request(app).get('/activity');\n    expect(unauth.status).toBe(401);\n  });\n});\n","numLines":218,"startLine":1,"totalLines":218}}}
