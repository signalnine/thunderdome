+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S1A2dDZPUziq1d8HRHUwWg","type":"tool_result","content":"     1→import express, { Request, Response, NextFunction } from 'express';\n     2→\n     3→export interface User {\n     4→  id: string;\n     5→  username: string;\n     6→  passwordHash: string;\n     7→}\n     8→\n     9→export interface Folder {\n    10→  id: string;\n    11→  name: string;\n    12→  parentId?: string;\n    13→  creatorId: string;\n    14→}\n    15→\n    16→export interface Document {\n    17→  id: string;\n    18→  title: string;\n    19→  content: string;\n    20→  folderId: string;\n    21→  creatorId: string;\n    22→}\n    23→\n    24→export type Role = 'viewer' | 'editor' | 'owner';\n    25→\n    26→const roleValues: Record<Role, number> = {\n    27→  viewer: 1,\n    28→  editor: 2,\n    29→  owner: 3\n    30→};\n    31→\n    32→export interface Activity {\n    33→  id: string;\n    34→  action: string;\n    35→  userId: string;\n    36→  targetType: 'folder' | 'document';\n    37→  targetId: string;\n    38→  timestamp: string;\n    39→}\n    40→\n    41→declare global {\n    42→  // eslint-disable-next-line @typescript-eslint/no-namespace\n    43→  namespace Express {\n    44→    interface Request {\n    45→      user?: User;\n    46→    }\n    47→  }\n    48→}\n    49→\n    50→export function createApp() {\n    51→  const app = express();\n    52→  app.use(express.json());\n    53→\n    54→  const users = new Map<string, User>();\n    55→  const tokens = new Map<string, string>();\n    56→  const folders = new Map<string, Folder>();\n    57→  const documents = new Map<string, Document>();\n    58→  const folderShares = new Map<string, Map<string, Role>>();\n    59→  const documentShares = new Map<string, Map<string, Role>>();\n    60→  const activities: Activity[] = [];\n    61→\n    62→  function getFolderRole(userId: string, folderId: string | null): number {\n    63→    if (!folderId) return 0;\n    64→    let maxRole = 0;\n    65→    const visited = new Set<string>();\n    66→    let currentId: string | undefined = folderId;\n    67→    \n    68→    while (currentId) {\n    69→      if (visited.has(currentId)) break;\n    70→      visited.add(currentId);\n    71→      \n    72→      const role = folderShares.get(currentId)?.get(userId);\n    73→      if (role) {\n    74→        maxRole = Math.max(maxRole, roleValues[role]);\n    75→      }\n    76→      const folder = folders.get(currentId);\n    77→      if (folder) {\n    78→        if (folder.creatorId === userId) maxRole = 3;\n    79→        currentId = folder.parentId;\n    80→      } else {\n    81→        break;\n    82→      }\n    83→    }\n    84→    return maxRole;\n    85→  }\n    86→\n    87→  function getDocumentRole(userId: string, documentId: string): number {\n    88→    const doc = documents.get(documentId);\n    89→    if (!doc) return 0;\n    90→    \n    91→    let maxRole = 0;\n    92→    if (doc.creatorId === userId) maxRole = 3;\n    93→    \n    94→    const directRole = documentShares.get(documentId)?.get(userId);\n    95→    if (directRole) {\n    96→      maxRole = Math.max(maxRole, roleValues[directRole]);\n    97→    }\n    98→    \n    99→    const folderRole = getFolderRole(userId, doc.folderId);\n   100→    maxRole = Math.max(maxRole, folderRole);\n   101→    \n   102→    return maxRole;\n   103→  }\n   104→\n   105→  function logActivity(userId: string, action: string, targetType: 'folder' | 'document', targetId: string) {\n   106→    activities.push({\n   107→      id: Math.random().toString(36).substring(2),\n   108→      userId,\n   109→      action,\n   110→      targetType,\n   111→      targetId,\n   112→      timestamp: new Date().toISOString()\n   113→    });\n   114→  }\n   115→\n   116→  const requireAuth = (req: Request, res: Response, next: NextFunction): void => {\n   117→    const authHeader = req.headers.authorization;\n   118→    if (!authHeader?.startsWith('Beare