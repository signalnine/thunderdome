id,\n      token: loginRes.body.token,\n      auth: `Bearer ${loginRes.body.token}`\n    };\n  }\n\n  describe('Auth', () => {\n    it('should register and login users', async () => {\n      const regRes = await request(app)\n        .post('/auth/register')\n        .send({ username: 'alice', password: 'password123' });\n      expect(regRes.status).toBe(201);\n      expect(regRes.body.id).toBeDefined();\n      expect(regRes.body.username).toBe('alice');\n\n      const loginRes = await request(app)\n        .post('/auth/login')\n        .send({ username: 'alice', password: 'password123' });\n      expect(loginRes.status).toBe(200);\n      expect(loginRes.body.token).toBeDefined();\n    });\n\n    it('should reject registration with missing fields', async () => {\n      const res1 = await request(app).post('/auth/register').send({ username: 'alice' });\n      expect(res1.status).toBe(400);\n\n      const res2 = await request(app).post('/auth/register').send({ password: '123' });\n      expect(res2.status).toBe(400);\n    });\n\n    it('should reject duplicate username registration', async () => {\n      await request(app).post('/auth/register').send({ username: 'alice', password: 'pass1' });\n      const res = await request(app).post('/auth/register').send({ username: 'alice', password: 'pass2' });\n      expect([400, 409]).toContain(res.status);\n    });\n\n    it('should reject login with wrong credentials', async () => {\n      await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });\n      const res = await request(app).post('/auth/login').send({ username: 'alice', password: 'wrong' });\n      expect(res.status).toBe(401);\n    });\n\n    it('should fail unauthenticated access', async () => {\n      const res = await request(app).get('/folders/123');\n      expect(res.status).toBe(401);\n    });\n\n    it('should fail with invalid token', async () => {\n      const res = await request(app).get('/folders/123').set('Authorization', 'Bearer invalidtoken');\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe('Folders', () => {\n    it('should create and retrieve folders, including nested', async () => {\n      const alice = await setupUser('alice');\n\n      const rootRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Root Folder' });\n      expect(rootRes.status).toBe(201);\n      expect(rootRes.body.id).toBeDefined();\n      expect(rootRes.body.name).toBe('Root Folder');\n      const rootId = rootRes.body.id;\n\n      const childRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Child Folder', parentId: rootId });\n      expect(childRes.status).toBe(201);\n      expect(childRes.body.parentId).toBe(rootId);\n\n      const getRes = await request(app).get(`/folders/${childRes.body.id}`).set('Authorization', alice.auth);\n      expect(getRes.status).toBe(200);\n      expect(getRes.body.name).toBe('Child Folder');\n    });\n\n    it('should update a folder', async () => {\n      const alice = await setupUser('alice');\n      const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Original' });\n\n      const putRes = await request(app).put(`/folders/${folderRes.body.id}`).set('Authorization', alice.auth)\n        .send({ name: 'Updated' });\n      expect(putRes.status).toBe(200);\n      expect(putRes.body.name).toBe('Updated');\n    });\n\n    it('should delete a folder', async () => {\n      const alice = await setupUser('alice');\n      const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'ToDelete' });\n\n      const delRes = await request(app).delete(`/folders/${folderRes.body.id}`).set('Authorization', alice.auth);\n      expect([200, 204]).toContain(delRes.status);\n\n      const getRes = await request(app).get(`/folders/${folderRes.body.id}`).set('Authorization', alice.auth);\n      expect(getRes.status).toBe(404);\n    });\n\n    it('should reject creating folder without name', async () => {\n      const alice = await setupUser('alice');\n      const res = await request(app).post('/folders').set('Authorization', alice.auth).send({});\n      expect(res.status).toBe(400);\n    });\n\n    it('should return 404 for non-existent folder', async () => {\n      const alice = await setupUser('alice');\n      const res = await request(app).get('/folders/nonexistent').set('Authorization', alice.auth);\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe('Documents', () => {\n    it('should perform document CRUD operations', async () => {\n      const alice = await setupUser('alice');\n      const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Docs' });\n      const folderId = folderRes.body.id;\n\n      const docRes = await request(app).post('/documents').set('Authorization', alice.auth)\n        .send({ title: 'My Doc', content: 'Hello World', folderId });\n      expect(docRes.status).toBe(201);\n      const docId = docRes.body.id;\n\n      const getRes = await request(app).get(`/documents/${docId}`).set('Authorization', alice.auth);\n      expect(getRes.status).toBe(200);\n      expect(getRes.body.title).toBe('My Doc');\n\n      const putRes = await request(app).put(`/documents/${docId}`).set('Authorization', alice.auth)\n        .send({ title: 'Updated Doc' });\n      expect(putRes.status).toBe(200);\n      expect(putRes.body.title).toBe('Updated Doc');\n\n      const delRes = await request(app).delete(`/documents/${docId}`).set('Authorization', alice.auth);\n      expect([200, 204]).toContain(delRes.status);\n\n      const getDeleted = await request(app).get(`/documents/${docId}`).set('Authorization', alice.auth);\n      expect(getDeleted.status).toBe(404);\n    });\n\n    it('should reject creating document with missing fields', async () => {\n      const alice = await setupUser('alice');\n      const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Docs' });\n\n      const res1 = await request(app).post('/documents').set('Authorization', alice.auth)\n        .send({ content: 'text', folderId: folderRes.body.id });\n      expect(res1.status).toBe(400);\n\n      const res2 = await request(app).post('/documents').set('Authorization', alice.auth)\n        .send({ title: 'Title', folderId: folderRes.body.id });\n      expect(res2.status).toBe(400);\n\n      const res3 = await request(app).post('/documents').set('Authorization', alice.auth)\n        .send({ title: 'Title', content: 'text' });\n      expect(res3.status).toBe(400);\n    });\n\n    it('should return 404 for non-existent document', async () => {\n      const alice = await setupUser('alice');\n      const res = await request(app).get('/documents/nonexistent').set('Authorization', alice.auth);\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe('Permissions', () => {\n    it('enforces viewer/editor/owner permission checks on folders', async () => {\n      const alice = await setupUser('alice');\n      const bob = await setupUser('bob');\n      const charlie = await setupUser('charlie');\n      const dave = await setupUser('dave');\n\n      const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Shared' });\n      const folderId = folderRes.body.id;\n\n      await request(app).post(`/folders/${folderId}/share`).set('Authorization', alice.auth)\n        .send({ userId: bob.id, role: 'viewer' });\n      await request(app).post(`/folders/${folderId}/share`).set('Authorization', alice.auth)\n        .send({ userId: charlie.id, role: 'editor' });\n\n      // Viewer can read\n      expect((await request(app).get(`/folders/${folderId}`).set('Authorization', bob.auth)).status).toBe(200);\n      // Viewer cannot update\n      expect((await request(app).put(`/folders/${folderId}`).set('Authorization', bob.auth).send({ name: 'x' })).status).toBe(403);\n      // Viewer cannot share\n      expect((await request(app).post(`/folders/${folderId}/share`).set('Authorization', bob.auth).send({ userId: dave.id, role: 'viewer' })).status).toBe(403);\n      // Viewer cannot delete\n      expect((await request(app).delete(`/folders/${folderId}`).set('Authorization', bob.auth)).status).toBe(403);\n\n      // Editor can update\n      expect((await request(app).put(`/folders/${folderId}`).set('Authorization', charlie.auth).send({ name: 'Renamed' })).status).toBe(200);\n      // Editor can share as viewer\n      expect((await request(app).post(`/folders/${folderId}/share`).set('Authorization', charlie.auth).send({ userId: dave.id, role: 'viewer' })).status).toBe(200);\n      // Editor cannot assign owner\n      expect((await request(app).post(`/folders/${folderId}/share`).set('Authorization', charlie.auth).send({ userId: dave.id, role: 'owner' })).status).toBe(403);\n      // Editor cannot delete\n      expect((await request(app).delete(`/folders/${folderId}`).set('Authorization', charlie.auth)).status).toBe(403);\n\n      // Owner can delete\n      const delRes = await request(app).delete(`/folders/${folderId}`).set('Authorization', alice.auth);\n      expect([200, 204]).toContain(delRes.status);\n    });\n\n    it('enforces permission checks on documents', async () => {\n      const alice = await setupUser('alice');\n      const bob = await setupUser('bob');\n      const charlie = await setupUser('charlie');\n\n      const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Folder' });\n      const docRes = await request(app).post('/documents').set('Authorization', alice.auth)\n        .send({ title: 'Doc', content: 'text', folderId: folderRes.body.id });\n      const docId = docRes.body.id;\n\n      await request(app).post(`/documents/${docId}/share`).set('Authorization', alice.auth)\n        .send({ userId: bob.id, role: 'viewer' });\n      await request(app).post(`/documents/${docId}/share`).set('Authorization', alice.auth)\n        .send({ userId: charlie.id, role: 'editor' });\n\n      // Viewer can read but not edit/delete\n      expect((await request(app).get(`/documents/${docId}`).set('Authorization', bob.auth)).status).toBe(200);\n      expect((await request(app).put(`/documents/${docId}`).set('Authorization', bob.auth).send({ title: 'x' })).status).toBe(403);\n      expect((await request(app).delete(`/documents/${docId}`).set('Authorization', bob.auth)).status).toBe(403);\n\n      // Editor can update but not delete\n      expect((await request(app).put(`/documents/${docId}`).set('Authorization', charlie.auth).send({ title: 'Updated' })).status).toBe(200);\n      expect((await request(app).delete(`/documents/${docId}`).set('Authorization', charlie.auth)).status).toBe(403);\n    });\n\n    it('denies access to unshared users', async () => {\n      const alice = await setupUser('alice');\n      const bob = await setupUser('bob');\n\n      const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Private' });\n      const docRes = await request(app).post('/documents').set('Authorization', alice.auth)\n        .send({ title: 'Private Doc', content: 'secret', folderId: folderRes.body.id });\n\n      expect((await request(app).get(`/folders/${folderRes.body.id}`).set('Authorization', bob.auth)).status).toBe(403);\n      expect((await request(app).get(`/documents/${docRes.body.id}`).set('Authorization', bob.auth)).status).toBe(403);\n    });\n  });\n\n  describe('Permission Inheritance', () => {\n    it('folder share gives access to documents in folder', async () => {\n      const alice = await setupUser('alice');\n      const bob = await setupUser('bob');\n\n      const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Shared Folder' });\n      const folderId = folderRes.body.id;\n      const docRes = await request(app).post('/documents').set('Authorization', alice.auth)\n        .send({ title: 'Doc', content: 'text', folderId });\n      const docId = docRes.body.id;\n\n      // Bob cannot read yet\n      expect((await request(app).get(`/documents/${docId}`).set('Authorization', bob.auth)).status).toBe(403);\n\n      // Share folder with Bob\n      await request(app).post(`/folders/${folderId}/share`).set('Authorization', alice.auth)\n        .send({ userId: bob.id, role: 'viewer' });\n\n      // Bob can now read doc through folder inheritance\n      expect((await request(app).get(`/documents/${docId}`).set('Authorization', bob.auth)).status).toBe(200);\n    });\n\n    it('most permissive role wins with multiple access paths', async () => {\n      const alice = await setupUser('alice');\n      const bob = await setupUser('bob');\n\n      const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Parent' });\n      const folderId = folderRes.body.id;\n      const docRes = await request(app).post('/documents').set('Authorization', alice.auth)\n        .send({ title: 'Doc', content: '...', folderId });\n      const docId = docRes.body.id;\n\n      // Direct doc share as viewer\n      await request(app).post(`/documents/${docId}/share`).set('Authorization', alice.auth)\n        .send({ userId: bob.id, role: 'viewer' });\n\n      // Bob cannot edit (only viewer)\n      expect((await request(app).put(`/documents/${docId}`).set('Authorization', bob.auth).send({ title: 'x' })).status).toBe(403);\n\n      // Folder share as editor\n      await request(app).post(`/folders/${folderId}/share`).set('Authorization', alice.auth)\n        .send({ userId: bob.id, role: 'editor' });\n\n      // Bob can now edit (editor > viewer)\n      expect((await request(app).put(`/documents/${docId}`).set('Authorization', bob.auth).send({ title: 'Updated' })).status).toBe(200);\n    });\n\n    it('inherits permissions from parent folders', async () => {\n      const alice = await setupUser('alice');\n      const bob = await setupUser('bob');\n\n      const parentRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Parent' });\n      const childRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Child', parentId: parentRes.body.id });\n\n      // Share parent with bob as editor\n      await request(app).post(`/folders/${parentRes.body.id}/share`).set('Authorization', alice.auth)\n        .send({ userId: bob.id, role: 'editor' });\n\n      // Bob can access and edit child\n      expect((await request(app).get(`/folders/${childRes.body.id}`).set('Authorization', bob.auth)).status).toBe(200);\n      expect((await request(app).put(`/folders/${childRes.body.id}`).set('Authorization', bob.auth).send({ name: 'Renamed' })).status).toBe(200);\n    });\n\n    it('inherits from grandparent to documents', async () => {\n      const alice = await setupUser('alice');\n      const bob = await setupUser('bob');\n\n      const parentRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Grandparent' });\n      const childRes = await request(app).post('/folders').set('Authorization', alice.auth)\n        .send({ name: 'Child', parentId: parentRes.body.id });\n      const docRes = await request(app).post('/documents').set('Authorization', alice.auth)\n        .send({ title: 'Deep Doc', content: 'deep', folderId: childRes.body.id });\n\n      await request(app).post(`/folders/${parentRes.body.id}/share`).set('Authorization', alice.auth)\n        .send({ userId: bob.id, role: 'viewer' });\n\n      expect((await request(app).get(`/documents/${docRes.body.id}`).set('Authorization', bob.auth)).status).toBe(200);\n    });\n  });\n\n  describe('Activity Log', () => {\n    it('tracks document creation, updates, deletion', async