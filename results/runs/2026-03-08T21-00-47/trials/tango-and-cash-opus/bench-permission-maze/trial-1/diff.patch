<string, string>();\n  const folders = new Map<string, Folder>();\n  const documents = new Map<string, Document>();\n  const folderShares = new Map<string, Map<string, Role>>();\n  const documentShares = new Map<string, Map<string, Role>>();\n  const activities: Activity[] = [];\n\n  function getFolderRole(userId: string, folderId: string | null): number {\n    if (!folderId) return 0;\n    let maxRole = 0;\n    const visited = new Set<string>();\n    let currentId: string | undefined = folderId;\n    \n    while (currentId) {\n      if (visited.has(currentId)) break;\n      visited.add(currentId);\n      \n      const role = folderShares.get(currentId)?.get(userId);\n      if (role) {\n        maxRole = Math.max(maxRole, roleValues[role]);\n      }\n      const folder = folders.get(currentId);\n      if (folder) {\n        if (folder.creatorId === userId) maxRole = 3;\n        currentId = folder.parentId;\n      } else {\n        break;\n      }\n    }\n    return maxRole;\n  }\n\n  function getDocumentRole(userId: string, documentId: string): number {\n    const doc = documents.get(documentId);\n    if (!doc) return 0;\n    \n    let maxRole = 0;\n    if (doc.creatorId === userId) maxRole = 3;\n    \n    const directRole = documentShares.get(documentId)?.get(userId);\n    if (directRole) {\n      maxRole = Math.max(maxRole, roleValues[directRole]);\n    }\n    \n    const folderRole = getFolderRole(userId, doc.folderId);\n    maxRole = Math.max(maxRole, folderRole);\n    \n    return maxRole;\n  }\n\n  function logActivity(userId: string, action: string, targetType: 'folder' | 'document', targetId: string) {\n    activities.push({\n      id: Math.random().toString(36).substring(2),\n      userId,\n      action,\n      targetType,\n      targetId,\n      timestamp: new Date().toISOString()\n    });\n  }\n\n  const requireAuth = (req: Request, res: Response, next: NextFunction): void => {\n    const authHeader = req.headers.authorization;\n    if (!authHeader?.startsWith('Bearer ')) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    const token = authHeader.split(' ')[1];\n    const userId = tokens.get(token);\n    if (!userId) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    const user = users.get(userId);\n    if (!user) {\n      res.status(401).json({ error: 'Unauthorized' });\n      return;\n    }\n    req.user = user;\n    next();\n  };\n\n  app.post('/auth/register', (req, res) => {\n    const { username, password } = req.body;\n    if (!username || !password) {\n      res.status(400).json({ error: 'Missing fields' });\n      return;\n    }\n    if (Array.from(users.values()).some(u => u.username === username)) {\n      res.status(400).json({ error: 'Username exists' });\n      return;\n    }\n    const id = Math.random().toString(36).substring(2);\n    const user = { id, username, passwordHash: password };\n    users.set(id, user);\n    res.status(201).json({ id, username });\n  });\n\n  app.post('/auth/login', (req, res) => {\n    const { username, password } = req.body;\n    const user = Array.from(users.values()).find(u => u.username === username && u.passwordHash === password);\n    if (!user) {\n      res.status(401).json({ error: 'Invalid credentials' });\n      return;\n    }\n    const token = Math.random().toString(36).substring(2);\n    tokens.set(token, user.id);\n    res.json({ token });\n  });\n\n  app.post('/folders', requireAuth, (req, res) => {\n    const { name, parentId } = req.body;\n    if (!name) {\n      res.status(400).json({ error: 'Missing name' });\n      return;\n    }\n    if (parentId && !folders.has(parentId)) {\n      res.status(400).json({ error: 'Invalid parentId' });\n      return;\n    }\n    if (parentId) {\n      const parentRole = getFolderRole(req.user!.id, parentId);\n      if (parentRole < 2) {\n        res.status(403).json({ error: 'Forbidden' });\n        return;\n      }\n    }\n    const id = Math.random().toString(36).substring(2);\n    const folder: Folder = { id, name, parentId, creatorId: req.user!.id };\n    folders.set(id, folder);\n    logActivity(req.user!.id, 'create', 'folder', id);\n    res.status(201).json(folder);\n  });\n\n  app.get('/folders/:id', requireAuth, (req, res) => {\n    const id = req.params.id;\n    const folder = folders.get(id);\n    if (!folder) {\n      res.status(404).json({ error: 'Not found' });\n      return;\n    }\n    if (getFolderRole(req.user!.id, id) < 1) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    res.json(folder);\n  });\n\n  app.put('/folders/:id', requireAuth, (req, res) => {\n    const id = req.params.id;\n    const folder = folders.get(id);\n    if (!folder) {\n      res.status(404).json({ error: 'Not found' });\n      return;\n    }\n    if (getFolderRole(req.user!.id, id) < 2) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    const { name, parentId } = req.body;\n    if (name) folder.name = name;\n    if (parentId !== undefined) {\n      if (parentId !== null && !folders.has(parentId)) {\n        res.status(400).json({ error: 'Invalid parentId' });\n        return;\n      }\n      folder.parentId = parentId;\n    }\n    logActivity(req.user!.id, 'update', 'folder', id);\n    res.json(folder);\n  });\n\n  app.delete('/folders/:id', requireAuth, (req, res) => {\n    const id = req.params.id;\n    const folder = folders.get(id);\n    if (!folder) {\n      res.status(404).json({ error: 'Not found' });\n      return;\n    }\n    if (getFolderRole(req.user!.id, id) < 3) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    folders.delete(id);\n    logActivity(req.user!.id, 'delete', 'folder', id);\n    res.status(200).json({ success: true });\n  });\n\n  app.post('/documents', requireAuth, (req, res) => {\n    const { title, content, folderId } = req.body;\n    if (!title || !content || !folderId) {\n      res.status(400).json({ error: 'Missing fields' });\n      return;\n    }\n    if (!folders.has(folderId)) {\n      res.status(400).json({ error: 'Invalid folderId' });\n      return;\n    }\n    if (getFolderRole(req.user!.id, folderId) < 2) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    const id = Math.random().toString(36).substring(2);\n    const doc: Document = { id, title, content, folderId, creatorId: req.user!.id };\n    documents.set(id, doc);\n    logActivity(req.user!.id, 'create', 'document', id);\n    res.status(201).json(doc);\n  });\n\n  app.get('/documents/:id', requireAuth, (req, res) => {\n    const id = req.params.id;\n    const doc = documents.get(id);\n    if (!doc) {\n      res.status(404).json({ error: 'Not found' });\n      return;\n    }\n    if (getDocumentRole(req.user!.id, id) < 1) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    res.json(doc);\n  });\n\n  app.put('/documents/:id', requireAuth, (req, res) => {\n    const id = req.params.id;\n    const doc = documents.get(id);\n    if (!doc) {\n      res.status(404).json({ error: 'Not found' });\n      return;\n    }\n    if (getDocumentRole(req.user!.id, id) < 2) {\n      res.status(403).json({ error: 'Forbidden' });\n      return;\n    }\n    const { title, content, folderId } = req.body;\n    if (title) doc.title = title;\n    if (content) doc.content = content;\n    if (folderId) {\n      if (!folders.has(folderId)) {\n        res.status(400).json({ error: 'Invalid folderId' });\n        return;\n      }\n      if (getFolderRole(req.user!.id, folderId) < 2) {\n        res.status(403).json({ error: 'Forbidden' });\n        return;\n      }\n      doc.folderId = folderId;\n    }\n    logActivity(req.user!.id, 'update', 'document', id);\n    res.json(doc);\n  });\n\n  app.delete('/documents/:id', requireAuth, (req, res) => {\n    const id = req.params.id;\n    const doc = documents.get(id);\n    if (!doc) {\n      res.status(404).json({ error: '