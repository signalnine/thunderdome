diff --git a/src/app.ts b/src/app.ts
new file mode 100644
index 0000000..db6ea59
--- /dev/null
+++ b/src/app.ts
@@ -0,0 +1,407 @@
+import express, { Request, Response, NextFunction } from 'express';
+
+export interface User {
+  id: string;
+  username: string;
+  passwordHash: string;
+}
+
+export interface Folder {
+  id: string;
+  name: string;
+  parentId?: string;
+  creatorId: string;
+}
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  creatorId: string;
+}
+
+export type Role = 'viewer' | 'editor' | 'owner';
+
+const roleValues: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3
+};
+
+export interface Activity {
+  id: string;
+  action: string;
+  userId: string;
+  targetType: 'folder' | 'document';
+  targetId: string;
+  timestamp: string;
+}
+
+declare global {
+  // eslint-disable-next-line @typescript-eslint/no-namespace
+  namespace Express {
+    interface Request {
+      user?: User;
+    }
+  }
+}
+
+export function createApp() {
+  const app = express();
+  app.use(express.json());
+
+  const users = new Map<string, User>();
+  const tokens = new Map<string, string>();
+  const folders = new Map<string, Folder>();
+  const documents = new Map<string, Document>();
+  const folderShares = new Map<string, Map<string, Role>>();
+  const documentShares = new Map<string, Map<string, Role>>();
+  const activities: Activity[] = [];
+
+  function getFolderRole(userId: string, folderId: string | null): number {
+    if (!folderId) return 0;
+    let maxRole = 0;
+    const visited = new Set<string>();
+    let currentId: string | undefined = folderId;
+    
+    while (currentId) {
+      if (visited.has(currentId)) break;
+      visited.add(currentId);
+      
+      const role = folderShares.get(currentId)?.get(userId);
+      if (role) {
+        maxRole = Math.max(maxRole, roleValues[role]);
+      }
+      const folder = folders.get(currentId);
+      if (folder) {
+        if (folder.creatorId === userId) maxRole = 3;
+        currentId = folder.parentId;
+      } else {
+        break;
+      }
+    }
+    return maxRole;
+  }
+
+  function getDocumentRole(userId: string, documentId: string): number {
+    const doc = documents.get(documentId);
+    if (!doc) return 0;
+    
+    let maxRole = 0;
+    if (doc.creatorId === userId) maxRole = 3;
+    
+    const directRole = documentShares.get(documentId)?.get(userId);
+    if (directRole) {
+      maxRole = Math.max(maxRole, roleValues[directRole]);
+    }
+    
+    const folderRole = getFolderRole(userId, doc.folderId);
+    maxRole = Math.max(maxRole, folderRole);
+    
+    return maxRole;
+  }
+
+  function logActivity(userId: string, action: string, targetType: 'folder' | 'document', targetId: string) {
+    activities.push({
+      id: Math.random().toString(36).substring(2),
+      userId,
+      action,
+      targetType,
+      targetId,
+      timestamp: new Date().toISOString()
+    });
+  }
+
+  const requireAuth = (req: Request, res: Response, next: NextFunction): void => {
+    const authHeader = req.headers.authorization;
+    if (!authHeader?.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    const token = authHeader.split(' ')[1];
+    const userId = tokens.get(token);
+    if (!userId) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    const user = users.get(userId);
+    if (!user) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    req.user = user;
+    next();
+  };
+
+  app.post('/auth/register', (req, res) => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Missing fields' });
+      return;
+    }
+    if (Array.from(users.values()).some(u => u.username === username)) {
+      res.status(409).json({ error: 'Username already exists' });
+      return;
+    }
+    const id = Math.random().toString(36).substring(2);
+    const user = { id, username, passwordHash: password };
+    users.set(id, user);
+    res.status(201).json({ id, username });
+  });
+
+  app.post('/auth/login', (req, res) => {
+    const { username, password } = req.body;
+    const user = Array.from(users.values()).find(u => u.username === username && u.passwordHash === password);
+    if (!user) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+    const token = Math.random().toString(36).substring(2);
+    tokens.set(token, user.id);
+    res.json({ token, userId: user.id });
+  });
+
+  app.post('/folders', requireAuth, (req, res) => {
+    const { name, parentId } = req.body;
+    if (!name) {
+      res.status(400).json({ error: 'Missing name' });
+      return;
+    }
+    if (parentId && !folders.has(parentId)) {
+      res.status(400).json({ error: 'Invalid parentId' });
+      return;
+    }
+    if (parentId) {
+      const parentRole = getFolderRole(req.user!.id, parentId);
+      if (parentRole < 2) {
+        res.status(403).json({ error: 'Forbidden' });
+        return;
+      }
+    }
+    const id = Math.random().toString(36).substring(2);
+    const folder: Folder = { id, name, parentId, creatorId: req.user!.id };
+    folders.set(id, folder);
+    logActivity(req.user!.id, 'create', 'folder', id);
+    res.status(201).json(folder);
+  });
+
+  app.get('/folders/:id', requireAuth, (req, res) => {
+    const id = req.params.id;
+    const folder = folders.get(id);
+    if (!folder) {
+      res.status(404).json({ error: 'Not found' });
+      return;
+    }
+    if (getFolderRole(req.user!.id, id) < 1) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    res.json(folder);
+  });
+
+  app.put('/folders/:id', requireAuth, (req, res) => {
+    const id = req.params.id;
+    const folder = folders.get(id);
+    if (!folder) {
+      res.status(404).json({ error: 'Not found' });
+      return;
+    }
+    if (getFolderRole(req.user!.id, id) < 2) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    const { name, parentId } = req.body;
+    if (name !== undefined) folder.name = name;
+    if (parentId !== undefined) {
+      if (parentId !== null && !folders.has(parentId)) {
+        res.status(400).json({ error: 'Invalid parentId' });
+        return;
+      }
+      folder.parentId = parentId;
+    }
+    logActivity(req.user!.id, 'update', 'folder', id);
+    res.json(folder);
+  });
+
+  app.delete('/folders/:id', requireAuth, (req, res) => {
+    const id = req.params.id;
+    const folder = folders.get(id);
+    if (!folder) {
+      res.status(404).json({ error: 'Not found' });
+      return;
+    }
+    if (getFolderRole(req.user!.id, id) < 3) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    folders.delete(id);
+    logActivity(req.user!.id, 'delete', 'folder', id);
+    res.status(200).json({ success: true });
+  });
+
+  app.post('/documents', requireAuth, (req, res) => {
+    const { title, content, folderId } = req.body;
+    if (!title || content === undefined || content === null || !folderId) {
+      res.status(400).json({ error: 'Missing fields' });
+      return;
+    }
+    if (!folders.has(folderId)) {
+      res.status(400).json({ error: 'Invalid folderId' });
+      return;
+    }
+    if (getFolderRole(req.user!.id, folderId) < 2) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    const id = Math.random().toString(36).substring(2);
+    const doc: Document = { id, title, content, folderId, creatorId: req.user!.id };
+    documents.set(id, doc);
+    logActivity(req.user!.id, 'create', 'document', id);
+    res.status(201).json(doc);
+  });
+
+  app.get('/documents/:id', requireAuth, (req, res) => {
+    const id = req.params.id;
+    const doc = documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Not found' });
+      return;
+    }
+    if (getDocumentRole(req.user!.id, id) < 1) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  app.put('/documents/:id', requireAuth, (req, res) => {
+    const id = req.params.id;
+    const doc = documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Not found' });
+      return;
+    }
+    if (getDocumentRole(req.user!.id, id) < 2) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    const { title, content, folderId } = req.body;
+    if (title !== undefined) doc.title = title;
+    if (content !== undefined) doc.content = content;
+    if (folderId !== undefined) {
+      if (!folders.has(folderId)) {
+        res.status(400).json({ error: 'Invalid folderId' });
+        return;
+      }
+      if (getFolderRole(req.user!.id, folderId) < 2) {
+        res.status(403).json({ error: 'Forbidden' });
+        return;
+      }
+      doc.folderId = folderId;
+    }
+    logActivity(req.user!.id, 'update', 'document', id);
+    res.json(doc);
+  });
+
+  app.delete('/documents/:id', requireAuth, (req, res) => {
+    const id = req.params.id;
+    const doc = documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Not found' });
+      return;
+    }
+    if (getDocumentRole(req.user!.id, id) < 3) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    documents.delete(id);
+    logActivity(req.user!.id, 'delete', 'document', id);
+    res.status(200).json({ success: true });
+  });
+
+  app.post('/folders/:id/share', requireAuth, (req, res) => {
+    const id = req.params.id;
+    const { userId, role } = req.body;
+    if (!userId || !role) {
+      res.status(400).json({ error: 'Missing fields' });
+      return;
+    }
+    const folder = folders.get(id);
+    if (!folder) {
+      res.status(404).json({ error: 'Not found' });
+      return;
+    }
+    if (!['viewer', 'editor', 'owner'].includes(role)) {
+      res.status(400).json({ error: 'Invalid role' });
+      return;
+    }
+    if (!users.has(userId)) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+    const callerRole = getFolderRole(req.user!.id, id);
+    if (callerRole < 2) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    if (roleValues[role as Role] > callerRole) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    if (!folderShares.has(id)) folderShares.set(id, new Map());
+    folderShares.get(id)!.set(userId, role as Role);
+    logActivity(req.user!.id, 'share', 'folder', id);
+    res.status(200).json({ success: true });
+  });
+
+  app.post('/documents/:id/share', requireAuth, (req, res) => {
+    const id = req.params.id;
+    const { userId, role } = req.body;
+    if (!userId || !role) {
+      res.status(400).json({ error: 'Missing fields' });
+      return;
+    }
+    const doc = documents.get(id);
+    if (!doc) {
+      res.status(404).json({ error: 'Not found' });
+      return;
+    }
+    if (!['viewer', 'editor', 'owner'].includes(role)) {
+      res.status(400).json({ error: 'Invalid role' });
+      return;
+    }
+    if (!users.has(userId)) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+    const callerRole = getDocumentRole(req.user!.id, id);
+    if (callerRole < 2) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    if (roleValues[role as Role] > callerRole) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+    if (!documentShares.has(id)) documentShares.set(id, new Map());
+    documentShares.get(id)!.set(userId, role as Role);
+    logActivity(req.user!.id, 'share', 'document', id);
+    res.status(200).json({ success: true });
+  });
+
+  app.get('/activity', requireAuth, (req, res) => {
+    const userActivities = activities.filter(a => {
+      if (a.userId === req.user!.id) return true;
+      if (a.targetType === 'folder') {
+        return getFolderRole(req.user!.id, a.targetId) >= 1;
+      } else if (a.targetType === 'document') {
+        return getDocumentRole(req.user!.id, a.targetId) >= 1;
+      }
+      return false;
+    });
+    res.json(userActivities);
+  });
+
+  return app;
+}
diff --git a/src/tests/app.test.ts b/src/tests/app.test.ts
new file mode 100644
index 0000000..039c1c4
--- /dev/null
+++ b/src/tests/app.test.ts
@@ -0,0 +1,420 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../app.js';
+import type { Express } from 'express';
+
+describe('Document Management API', () => {
+  let app: Express;
+
+  beforeEach(() => {
+    app = createApp();
+  });
+
+  async function setupUser(username: string) {
+    const regRes = await request(app)
+      .post('/auth/register')
+      .send({ username, password: 'password123' });
+    const loginRes = await request(app)
+      .post('/auth/login')
+      .send({ username, password: 'password123' });
+    return {
+      id: regRes.body.id,
+      token: loginRes.body.token,
+      auth: `Bearer ${loginRes.body.token}`
+    };
+  }
+
+  describe('Auth', () => {
+    it('should register and login users', async () => {
+      const regRes = await request(app)
+        .post('/auth/register')
+        .send({ username: 'alice', password: 'password123' });
+      expect(regRes.status).toBe(201);
+      expect(regRes.body.id).toBeDefined();
+      expect(regRes.body.username).toBe('alice');
+
+      const loginRes = await request(app)
+        .post('/auth/login')
+        .send({ username: 'alice', password: 'password123' });
+      expect(loginRes.status).toBe(200);
+      expect(loginRes.body.token).toBeDefined();
+    });
+
+    it('should reject registration with missing fields', async () => {
+      const res1 = await request(app).post('/auth/register').send({ username: 'alice' });
+      expect(res1.status).toBe(400);
+
+      const res2 = await request(app).post('/auth/register').send({ password: '123' });
+      expect(res2.status).toBe(400);
+    });
+
+    it('should reject duplicate username registration', async () => {
+      await request(app).post('/auth/register').send({ username: 'alice', password: 'pass1' });
+      const res = await request(app).post('/auth/register').send({ username: 'alice', password: 'pass2' });
+      expect([400, 409]).toContain(res.status);
+    });
+
+    it('should reject login with wrong credentials', async () => {
+      await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });
+      const res = await request(app).post('/auth/login').send({ username: 'alice', password: 'wrong' });
+      expect(res.status).toBe(401);
+    });
+
+    it('should fail unauthenticated access', async () => {
+      const res = await request(app).get('/folders/123');
+      expect(res.status).toBe(401);
+    });
+
+    it('should fail with invalid token', async () => {
+      const res = await request(app).get('/folders/123').set('Authorization', 'Bearer invalidtoken');
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe('Folders', () => {
+    it('should create and retrieve folders, including nested', async () => {
+      const alice = await setupUser('alice');
+
+      const rootRes = await request(app).post('/folders').set('Authorization', alice.auth)
+        .send({ name: 'Root Folder' });
+      expect(rootRes.status).toBe(201);
+      expect(rootRes.body.id).toBeDefined();
+      expect(rootRes.body.name).toBe('Root Folder');
+      const rootId = rootRes.body.id;
+
+      const childRes = await request(app).post('/folders').set('Authorization', alice.auth)
+        .send({ name: 'Child Folder', parentId: rootId });
+      expect(childRes.status).toBe(201);
+      expect(childRes.body.parentId).toBe(rootId);
+
+      const getRes = await request(app).get(`/folders/${childRes.body.id}`).set('Authorization', alice.auth);
+      expect(getRes.status).toBe(200);
+      expect(getRes.body.name).toBe('Child Folder');
+    });
+
+    it('should update a folder', async () => {
+      const alice = await setupUser('alice');
+      const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)
+        .send({ name: 'Original' });
+
+      const putRes = await request(app).put(`/folders/${folderRes.body.id}`).set('Authorization', alice.auth)
+        .send({ name: 'Updated' });
+      expect(putRes.status).toBe(200);
+      expect(putRes.body.name).toBe('Updated');
+    });
+
+    it('should delete a folder', async () => {
+      const alice = await setupUser('alice');
+      const folderRes = await request(app).post('/folders').set('Authorization', alice.auth)
+        .send({ name: 'ToDelete' });
+
+      const delRes = await request(app).delete(`/folders/${folderRes.body.id}`).set('Authorization', alice.auth);
+      expect([200, 204]).toContain(delRes.status);
+
+      const getRes = await request(app).get(`/folders/${folderRes.body.id}`).set('Authorization', alice.auth);
+      expect(getRes.status).toBe(404);
+    });
+
+    it('should reject creating folder without name', async () => {
+      const alice = await setupUser('alice');
+      const res = await request(app).post('/folders').set('Authorization', alice.auth).send({});
+      expect(res.status).toBe(400);
+    });
