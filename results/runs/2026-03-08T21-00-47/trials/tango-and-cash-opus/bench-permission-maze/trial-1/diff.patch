    let maxRole = 0;\n    65→    const visited = new Set<string>();\n    66→    let currentId: string | undefined = folderId;\n    67→    \n    68→    while (currentId) {\n    69→      if (visited.has(currentId)) break;\n    70→      visited.add(currentId);\n    71→      \n    72→      const role = folderShares.get(currentId)?.get(userId);\n    73→      if (role) {\n    74→        maxRole = Math.max(maxRole, roleValues[role]);\n    75→      }\n    76→      const folder = folders.get(currentId);\n    77→      if (folder) {\n    78→        if (folder.creatorId === userId) maxRole = 3;\n    79→        currentId = folder.parentId;\n    80→      } else {\n    81→        break;\n    82→      }\n    83→    }\n    84→    return maxRole;\n    85→  }\n    86→\n    87→  function getDocumentRole(userId: string, documentId: string): number {\n    88→    const doc = documents.get(documentId);\n    89→    if (!doc) return 0;\n    90→    \n    91→    let maxRole = 0;\n    92→    if (doc.creatorId === userId) maxRole = 3;\n    93→    \n    94→    const directRole = documentShares.get(documentId)?.get(userId);\n    95→    if (directRole) {\n    96→      maxRole = Math.max(maxRole, roleValues[directRole]);\n    97→    }\n    98→    \n    99→    const folderRole = getFolderRole(userId, doc.folderId);\n   100→    maxRole = Math.max(maxRole, folderRole);\n   101→    \n   102→    return maxRole;\n   103→  }\n   104→\n   105→  function logActivity(userId: string, action: string, targetType: 'folder' | 'document', targetId: string) {\n   106→    activities.push({\n   107→      id: Math.random().toString(36).substring(2),\n   108→      userId,\n   109→      action,\n   110→      targetType,\n   111→      targetId,\n   112→      timestamp: new Date().toISOString()\n   113→    });\n   114→  }\n   115→\n   116→  const requireAuth = (req: Request, res: Response, next: NextFunction): void => {\n   117→    const authHeader = req.headers.authorization;\n   118→    if (!authHeader?.startsWith('Beare