*/')) {\n    const interval = parseInt(parts.hour.slice(2), 10);\n    if (isNaN(interval) || interval <= 0) {\n      throw new Error(`Invalid cron interval: \"${parts.hour}\"`);\n    }\n    if (hour % interval !== 0) return false;\n  } else if (parts.hour !== '*') {\n    const target = parseInt(parts.hour, 10);\n    if (hour !== target) return false;\n  }\n\n  // Avoid double-runs: don't run if lastRun is within the same minute\n  if (lastRun) {\n    if (\n      lastRun.getFullYear() === date.getFullYear() &&\n      lastRun.getMonth() === date.getMonth() &&\n      lastRun.getDate() === date.getDate() &&\n      lastRun.getHours() === date.getHours() &&\n      lastRun.getMinutes() === date.getMinutes()\n    ) {\n      return false;\n    }\n  }\n\n  return true;\n}\n","structuredPatch":[{"oldStart":1,"oldLines":6,"newStart":1,"newLines":6,"lines":[" /**","  * Simple cron expression parser supporting:","- * - *​/N * * * *  (every N minutes)","+ * - asterisk/N * * * *  (every N minutes)","  * - 0 * * * *    (every hour on the hour)","  * - 0 0 * * *    (every day at midnight)","  */"]}],"userModified":false,"replaceAll":false}}
