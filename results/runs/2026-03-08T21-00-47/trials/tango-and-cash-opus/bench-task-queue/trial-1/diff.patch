--- /dev/null
+++ b/src/TaskQueue.ts
@@ -0,0 +1,566 @@
+import { randomUUID } from 'node:crypto';
+import {
+  TaskData,
+  TaskOptions,
+  MiddlewareFn,
+  HandlerFn,
+  ProgressListener,
+  ShutdownCallback,
+  ShutdownSummary,
+  Schedule,
+  ScheduleOptions,
+} from './types.js';
+import { shouldRunAt } from './cron.js';
+
+const DEFAULT_QUEUE = 'default';
+
+export class TaskQueue {
+  private tasks: Map<string, TaskData> = new Map();
+  private deadLetterQueues: Map<string, TaskData[]> = new Map();
+  private queues: Set<string> = new Set();
+  private concurrencyLimits: Map<string, number> = new Map();
+  private middlewares: Map<string, MiddlewareFn[]> = new Map();
+  private handlers: Map<string, HandlerFn> = new Map();
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private shutdownCallbacks: ShutdownCallback[] = [];
+  private isShutdown = false;
+  private shutdownPromise: Promise<ShutdownSummary> | null = null;
+
+  // Phase 1: Add a task
+  add(payload: unknown, options: TaskOptions = {}): TaskData {
+    if (this.isShutdown) {
+      throw new Error('Queue is shut down and not accepting new tasks');
+    }
+
+    const queue = options.queue ?? DEFAULT_QUEUE;
+
+    // Phase 3: Validate priority
+    const priority = options.priority ?? 5;
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Phase 4: Calculate availability time
+    const now = new Date();
+    let availableAt = now;
+    if (options.processAt) {
+      availableAt = options.processAt;
+    } else if (options.delay != null && options.delay > 0) {
+      availableAt = new Date(now.getTime() + options.delay);
+    }
+
+    // Phase 7: Validate dependencies
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      if (!this.tasks.has(depId)) {
+        throw new Error(`Dependency task "${depId}" does not exist`);
+      }
+    }
+
+    const id = randomUUID();
+
+    // Phase 7: Circular dependency detection
+    if (dependencies.length > 0) {
+      this.detectCircularDependencies(id, dependencies);
+    }
+
+    const task: TaskData = {
+      id,
+      payload,
+      status: 'pending',
+      queue,
+      priority,
+      createdAt: now,
+      availableAt,
+      attempts: 0,
+      maxRetries: options.maxRetries ?? 3,
+      backoffDelay: options.backoffDelay ?? 1000,
+      progress: 0,
+      dependencies,
+    };
+
+    this.tasks.set(id, task);
+    this.queues.add(queue);
+
+    return { ...task };
+  }
+
+  // Phase 7: Circular dependency detection
+  private detectCircularDependencies(newTaskId: string, deps: string[]): void {
+    const visited = new Set<string>();
+
+    const hasCycle = (taskId: string): boolean => {
+      if (taskId === newTaskId) return true;
+      if (visited.has(taskId)) return false;
+      visited.add(taskId);
+
+      const task = this.tasks.get(taskId);
+      if (!task) return false;
+
+      for (const depId of task.dependencies) {
+        if (hasCycle(depId)) return true;
+      }
+      return false;
+    };
+
+    for (const depId of deps) {
+      if (depId === newTaskId || hasCycle(depId)) {
+        throw new Error('Circular dependency detected');
+      }
+    }
+  }
+
+  // Phase 1: Get next task from queue
+  next(queueName?: string): TaskData | null {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    const now = new Date();
+
+    // Phase 8: Check concurrency limit
+    const limit = this.concurrencyLimits.get(queue);
+    if (limit != null) {
+      const activeCount = this.getActiveCount(queue);
+      if (activeCount >= limit) {
+        return null;
+      }
+    }
+
+    // Get all pending tasks in this queue
+    const pendingTasks: TaskData[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.queue !== queue || task.status !== 'pending') continue;
+
+      // Phase 4: Skip tasks not yet available
+      if (task.availableAt > now) continue;
+
+      // Phase 7: Skip tasks with unresolved dependencies
+      if (this.hasUnresolvedDependencies(task)) continue;
+
+      pendingTasks.push(task);
+    }
+
+    if (pendingTasks.length === 0) return null;
+
+    // Phase 3: Sort by priority (ascending), then by availability time, then by creation time (FIFO)
+    pendingTasks.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();
+      if (availDiff !== 0) return availDiff;
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = pendingTasks[0];
+    task.status = 'processing';
+    task.attempts += 1;
+    return { ...task };
+  }
+
+  // Phase 7: Check if task has unresolved dependencies
+  private hasUnresolvedDependencies(task: TaskData): boolean {
+    for (const depId of task.dependencies) {
+      const dep = this.tasks.get(depId);
+      if (!dep || dep.status !== 'completed') return true;
+    }
+    return false;
+  }
+
+  // Phase 5: Complete a task
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found`);
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state`);
+    }
+    task.status = 'completed';
+    task.progress = 100;
+  }
+
+  // Phase 5: Fail a task
+  fail(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found`);
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state`);
+    }
+
+    task.error = error;
+
+    if (task.attempts < task.maxRetries) {
+      // Retry with exponential backoff
+      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.progress = 0;
+    } else {
+      // All retries exhausted
+      task.status = 'failed';
+
+      // Phase 6: Move to dead letter queue
+      this.addToDeadLetterQueue(task);
+    }
+  }
+
+  // Phase 6: Add task to dead letter queue
+  private addToDeadLetterQueue(task: TaskData): void {
+    const dlq = this.deadLetterQueues.get(task.queue) ?? [];
+    dlq.push(task);
+    this.deadLetterQueues.set(task.queue, dlq);
+  }
+
+  // Phase 6: Get dead-lettered tasks for a queue
+  getDeadLetterTasks(queueName?: string): TaskData[] {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    const dlq = this.deadLetterQueues.get(queue) ?? [];
+    return dlq.map(t => ({ ...t }));
+  }
+
+  // Phase 6: Retry a dead-lettered task
+  retryDeadLetter(taskId: string): TaskData {
+    for (const [queueName, dlq] of this.deadLetterQueues.entries()) {
+      const index = dlq.findIndex(t => t.id === taskId);
+      if (index !== -1) {
+        const task = dlq[index];
+        dlq.splice(index, 1);
+
+        // Reset the task for a fresh round
+        task.status = 'pending';
+        task.attempts = 0;
+        task.error = undefined;
+        task.progress = 0;
+        task.availableAt = new Date();
+
+        this.tasks.set(task.id, task);
+        this.queues.add(queueName);
+
+        return { ...task };
+      }
+    }
+    throw new Error(`Task "${taskId}" not found in any dead letter queue`);
+  }
+
+  // Phase 6: Clear dead letter queue
+  clearDeadLetterQueue(queueName?: string): void {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    this.deadLetterQueues.set(queue, []);
+  }
+
+  // Phase 1: Get pending count
+  size(queueName?: string): number {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.queue === queue && task.status === 'pending') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  // Phase 2: List all queue names
+  getQueues(): string[] {
+    return [...this.queues];
+  }
+
+  // Get a task by ID
+  getTask(taskId: string): TaskData | null {
+    const task = this.tasks.get(taskId);
+    return task ? { ...task } : null;
+  }
+
+  // Phase 7: Get dependency status
+  getDependencyStatus(taskId: string): { total: number; completed: number; pending: string[] } {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found`);
+
+    const pending: string[] = [];
+    let completed = 0;
+    for (const depId of task.dependencies) {
+      const dep = this.tasks.get(depId);
+      if (dep && dep.status === 'completed') {
+        completed++;
+      } else {
+        pending.push(depId);
+      }
+    }
+    return {
+      total: task.dependencies.length,
+      completed,
+      pending,
+    };
+  }
+
+  // Phase 8: Set concurrency limit
+  setConcurrency(queueName: string, limit: number): void {
+    if (limit < 1 || !Number.isInteger(limit)) {
+      throw new Error(`Invalid concurrency limit: ${limit}`);
+    }
+    this.concurrencyLimits.set(queueName, limit);
+  }
+
+  // Phase 8: Get concurrency limit
+  getConcurrency(queueName?: string): number | undefined {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    return this.concurrencyLimits.get(queue);
+  }
+
+  // Phase 8: Get active (processing) count
+  getActiveCount(queueName?: string): number {
+    const queue = queueName ?? DEFAULT_QUEUE;
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.queue === queue && task.status === 'processing') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  // Phase 9: Report progress
+  reportProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found`);
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);
+    }
+    task.progress = progress;
+    task.progressMessage = message;
+
+    // Notify listeners
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(progress, message);
+      }
+    }
+  }
+
+  // Phase 9: Subscribe to progress updates
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(listener);
+
+    // Return unsubscribe function
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(listener);
+      }
+    };
+  }
+
+  // Phase 9: Cancel a task
+  cancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found`);
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" cannot be cancelled (status: ${task.status})`);
+    }
+    task.status = 'cancelled';
+  }
+
+  // Phase 10: Add a recurring schedule
+  addSchedule(options: ScheduleOptions): Schedule {
+    if (this.isShutdown) {
+      throw new Error('Queue is shut down and not accepting new schedules');
+    }
+
+    const id = options.id ?? randomUUID();
+    const schedule: Schedule = {
+      id,
+      queue: options.queue ?? DEFAULT_QUEUE,
+      payload: options.payload,
+      cron: options.cron,
+      priority: options.priority ?? 5,
+    };
+
+    this.schedules.set(id, schedule);
+    return { ...schedule };
+  }
+
+  // Phase 10: Remove a schedule
+  removeSchedule(scheduleId: string): void {
+    if (!this.schedules.has(scheduleId)) {
+      throw new Error(`Schedule "${scheduleId}" not found`);
+    }
+    this.schedules.delete(scheduleId);
+  }
+
+  // Phase 10: List active schedules
+  getSchedules(): Schedule[] {
+    return [...this.schedules.values()].map(s => ({ ...s }));
+  }
+
+  // Phase 10: Tick - check schedules and enqueue due tasks
+  tick(now?: Date): TaskData[] {
+    const currentTime = now ?? new Date();
+    const created: TaskData[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (shouldRunAt(schedule.cron, currentTime, schedule.lastRun)) {
+        const task = this.add(schedule.payload, {
+          queue: schedule.queue,
+          priority: schedule.priority,
+        });
+        schedule.lastRun = currentTime;
+        created.push(task);
+      }
+    }
+
+    return created;
+  }
+
+  // Phase 11: Register middleware
+  use(queueName: string, middleware: MiddlewareFn): void;
+  use(middleware: MiddlewareFn): void;
+  use(queueNameOrMiddleware: string | MiddlewareFn, middleware?: MiddlewareFn): void {
+    let queue: string;
+    let fn: MiddlewareFn;
+
+    if (typeof queueNameOrMiddleware === 'string') {
+      queue = queueNameOrMiddleware;
+      fn = middleware!;
+    } else {
+      queue = DEFAULT_QUEUE;
+      fn = queueNameOrMiddleware;
+    }
+
+    if (!this.middlewares.has(queue)) {
+      this.middlewares.set(queue, []);
+    }
+    this.middlewares.get(queue)!.push(fn);
+  }
+
+  // Phase 11: Register handler
+  handle(queueName: string, handler: HandlerFn): void;
+  handle(handler: HandlerFn): void;
+  handle(queueNameOrHandler: string | HandlerFn, handler?: HandlerFn): void {
+    let queue: string;
+    let fn: HandlerFn;
+
+    if (typeof queueNameOrHandler === 'string') {
+      queue = queueNameOrHandler;
+      fn = handler!;
+    } else {
+      queue = DEFAULT_QUEUE;
+      fn = queueNameOrHandler;
+    }
+
+    this.handlers.set(queue, fn);
+  }
+
+  // Phase 11: Process a task through middleware pipeline and handler
+  async process(taskId: string): Promise<void> {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task "${taskId}" not found`);
+    if (task.status !== 'processing') {
+      throw new Error(`Task "${taskId}" is not in processing state`);
+    }
+
+    const middlewareStack = this.middlewares.get(task.queue) ?? [];
+    const handler = this.handlers.get(task.queue);
+
+    let index = 0;
+    const executeNext = async (): Promise<void> => {
+      if (index < middlewareStack.length) {
+        const mw = middlewareStack[index];
+        index++;
+        await mw(task, executeNext);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await executeNext();
+    } catch (err) {
+      const errorMsg = err instanceof Error ? err.message : String(err);
+      this.fail(taskId, errorMsg);
+      throw err;
+    }
+  }
+
+  // Phase 12: Register shutdown callback
+  onShutdown(callback: ShutdownCallback): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  // Phase 12: Graceful shutdown
+  async shutdown(timeoutMs: number = 30000): Promise<ShutdownSummary> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShutdown = true;
+    this.shutdownPromise = this._performShutdown(timeoutMs);
+    return this.shutdownPromise;
+  }
+
+  private async _performShutdown(timeoutMs: number): Promise<ShutdownSummary> {
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Find all processing tasks
+    const processingTasks: TaskData[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    let completed = 0;
+    let forceCancelled = 0;
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        durationMs: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete, up to timeout
+    const deadline = startTime + timeoutMs;
+
+    await new Promise<void>(resolve => {
+      const checkInterval = setInterval(() => {
+        let allDone = true;
+        for (const task of processingTasks) {
+          if (task.status === 'processing') {
+            allDone = false;
+            break;
+          }
+        }
+
+        if (allDone || Date.now() >= deadline) {
+          clearInterval(checkInterval);
+          resolve();
+        }
+      }, 10);
+    });
+
+    // Count completed vs force-cancel remaining
+    for (const task of processingTasks) {
+      if (task.status === 'processing') {
+        task.status = 'cancelled';
+        forceCancelled++;
+      } else if (task.status === 'completed') {
+        completed++;
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      durationMs: Date.now() - startTime,
+    };
+  }
+}
