@@ -0,0 +1,86 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  it('should have unlimited concurrency by default', () => {
+    expect(q.getConcurrency()).toBeUndefined();
+
+    q.add('a');
+    q.add('b');
+    q.add('c');
+
+    expect(q.next()).not.toBeNull();
+    expect(q.next()).not.toBeNull();
+    expect(q.next()).not.toBeNull();
+  });
+
+  it('should limit concurrent processing', () => {
+    q.setConcurrency('default', 2);
+
+    q.add('a');
+    q.add('b');
+    q.add('c');
+
+    expect(q.next()).not.toBeNull();
+    expect(q.next()).not.toBeNull();
+    expect(q.next()).toBeNull(); // limit reached
+  });
+
+  it('should free slot on completion', () => {
+    q.setConcurrency('default', 1);
+
+    q.add('a');
+    q.add('b');
+
+    const t1 = q.next()!;
+    expect(q.next()).toBeNull(); // limit reached
+
+    q.complete(t1.id);
+    expect(q.next()).not.toBeNull(); // slot freed
+  });
+
+  it('should free slot on failure', () => {
+    q.setConcurrency('default', 1);
+
+    q.add('a', { maxRetries: 0 });
+    q.add('b');
+
+    const t1 = q.next()!;
+    expect(q.next()).toBeNull(); // limit reached
+
+    q.fail(t1.id, 'err');
+    expect(q.next()?.payload).toBe('b'); // slot freed
+  });
+
+  it('should track active count', () => {
+    q.add('a');
+    q.add('b');
+
+    expect(q.getActiveCount()).toBe(0);
+    q.next();
+    expect(q.getActiveCount()).toBe(1);
+    q.next();
+    expect(q.getActiveCount()).toBe(2);
+  });
+
+  it('should still respect priority with concurrency limits', () => {
+    q.setConcurrency('default', 1);
+
+    q.add('low', { priority: 10 });
+    q.add('high', { priority: 1 });
+
+    const t = q.next()!;
+    expect(t.payload).toBe('high');
+  });
+
+  it('should reject invalid concurrency limit', () => {
+    expect(() => q.setConcurrency('default', 0)).toThrow();
+    expect(() => q.setConcurrency('default', -1)).toThrow();
+  });
+});
