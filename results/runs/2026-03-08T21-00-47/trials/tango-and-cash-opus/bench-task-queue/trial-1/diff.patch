est');\n    const t = q.next()!;\n    await q.process(t.id);\n\n    expect(received).not.toBeNull();\n    expect((received as Record<string, unknown>).enriched).toBe(true);\n  });\n\n  it('should fail task if middleware throws', async () => {\n    q.use(async () => {\n      throw new Error('middleware error');\n    });\n\n    q.add('test', { maxRetries: 0 });\n    const t = q.next()!;\n\n    await expect(q.process(t.id)).rejects.toThrow('middleware error');\n    expect(q.getTask(t.id)!.status).toBe('failed');\n  });\n\n  it('should have independent middleware per queue', async () => {\n    const order: string[] = [];\n\n    q.use('q1', async (_task, next) => {\n      order.push('q1-middleware');\n      await next();\n    });\n\n    q.use('q2', async (_task, next) => {\n      order.push('q2-middleware');\n      await next();\n    });\n\n    q.handle('q1', async () => { order.push('q1-handler'); });\n    q.handle('q2', async () => { order.push('q2-handler'); });\n\n    q.add('a', { queue: 'q1' });\n    q.add('b', { queue: 'q2' });\n\n    const t1 = q.next('q1')!;\n    await q.process(t1.id);\n\n    expect(order).toEqual(['q1-middleware', 'q1-handler']);\n  });\n\n  it('should run handler even without middleware', async () => {\n    let called = false;\n    q.handle(async () => { called = true; });\n\n    q.add('test');\n    const t = q.next()!;\n    await q.process(t.id);\n\n    expect(called).toBe(true);\n  });\n\n  it('should work without a handler (middleware only)', async () => {\n    let called = false;\n    q.use(async (_task, next) => {\n      called = true;\n      await next();\n    });\n\n    q.add('test');\n    const t = q.next()!;\n    await q.process(t.id);\n    expect(called).toBe(true);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
