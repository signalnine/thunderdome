+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 4: Delayed and Scheduled Tasks', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  it('should delay tasks by specified milliseconds', () => {
+    q.add('delayed', { delay: 60000 }); // 1 minute
+    // Should not be available yet
+    expect(q.next()).toBeNull();
+  });
+
+  it('should make delayed tasks available after delay expires', async () => {
+    q.add('delayed', { delay: 50 });
+    expect(q.next()).toBeNull();
+    await new Promise(r => setTimeout(r, 60));
+    expect(q.next()?.payload).toBe('delayed');
+  });
+
+  it('should accept a specific processAt date', () => {
+    const future = new Date(Date.now() + 60000);
+    const task = q.add('scheduled', { processAt: future });
+    expect(task.availableAt.getTime()).toBe(future.getTime());
+    expect(q.next()).toBeNull();
+  });
+
+  it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {
+    q.add('delayed', { delay: 60000 });
+    q.add('immediate');
+
+    expect(q.next()?.payload).toBe('immediate');
+  });
+
+  it('should order available delayed tasks by availability time', async () => {
+    q.add('later', { delay: 30 });
+    q.add('sooner', { delay: 10 });
+
+    await new Promise(r => setTimeout(r, 50));
+
+    expect(q.next()?.payload).toBe('sooner');
+    expect(q.next()?.payload).toBe('later');
+  });
+
+  it('should expose availableAt on task object', () => {
+    const task = q.add('test', { delay: 5000 });
+    expect(task.availableAt).toBeInstanceOf(Date);
+    expect(task.availableAt.getTime()).toBeGreaterThan(Date.now());
+  });
+
+  it('should work correctly with named queues', () => {
+    q.add('delayed', { queue: 'work', delay: 60000 });
+    q.add('immediate', { queue: 'work' });
+
+    expect(q.next('work')?.payload).toBe('immediate');
+    expect(q.next('work')).toBeNull(); // delayed not yet available
+  });
+});
