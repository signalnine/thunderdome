+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  it('should add a task and return a task object with required fields', () => {
+    const task = q.add({ name: 'test' });
+    expect(task.id).toBeDefined();
+    expect(task.payload).toEqual({ name: 'test' });
+    expect(task.status).toBe('pending');
+    expect(task.createdAt).toBeInstanceOf(Date);
+  });
+
+  it('should assign unique IDs to each task', () => {
