ts', () => {\n    q.setConcurrency('default', 1);\n\n    q.add('low', { priority: 10 });\n    q.add('high', { priority: 1 });\n\n    const t = q.next()!;\n    expect(t.payload).toBe('high');\n  });\n\n  it('should reject invalid concurrency limit', () => {\n    expect(() => q.setConcurrency('default', 0)).toThrow();\n    expect(() => q.setConcurrency('default', -1)).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":961,"cache_read_input_tokens":39330,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":961},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4b8303b8-8c3e-4855-9d5a-386b08b31c00","uuid":"10fe4e4b-c916-424f-91ce-656ed9a185e2"}
