+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Qob58gPsxLuZfXFht2MgDa","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WuYtFinDNGAmPPRPDRbeCJ","name":"Write","input":{"file_path":"/workspace/src/TaskQueue.ts","content":"import { randomUUID } from 'node:crypto';\nimport {\n  TaskData,\n  TaskOptions,\n  TaskStatus,\n  MiddlewareFn,\n  HandlerFn,\n  ProgressListener,\n  ShutdownCallback,\n  ShutdownSummary,\n  Schedule,\n  ScheduleOptions,\n} from './types.js';\nimport { shouldRunAt } from './cron.js';\n\nconst DEFAULT_QUEUE = 'default';\n\nexport class TaskQueue {\n  private tasks: Map<string, TaskData> = new Map();\n  private deadLetterQueues: Map<string, TaskData[]> = new Map();\n  private queues: Set<string> = new Set();\n  private concurrencyLimits: Map<string, number> = new Map();\n  private middlewares: Map<string, MiddlewareFn[]> = new Map();\n  private handlers: Map<string, HandlerFn> = new Map();\n  private progressListeners: Map<string, Set<ProgressListener>> = new Map();\n  private schedules: Map<string, Schedule> = new Map();\n  private shutdownCallbacks: ShutdownCallback[] = [];\n  private isShutdown = false;\n  private shutdownPromise: Promise<ShutdownSummary> | null = null;\n\n  // Phase 1: Add a task\n  add(payload: unknown, options: TaskOptions = {}): TaskData {\n    if (this.isShutdown) {\n      throw new Error('Queue is shut down and not accepting new tasks');\n    }\n\n    const queue = options.queue ?? DEFAULT_QUEUE;\n\n    // Phase 3: Validate priority\n    const priority = options.priority ?? 5;\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Phase 4: Calculate availability time\n    const now = new Date();\n    let availableAt = now;\n    if (options.processAt) {\n      availableAt = options.processAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    // Phase 7: Validate dependencies\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      if (!this.tasks.has(depId)) {\n        throw new Error(`Dependency task \"${depId}\" does not exist`);\n      }\n    }\n\n    const id = randomUUID();\n\n    // Phase 7: Circular dependency detection\n    if (dependencies.length > 0) {\n      this.detectCircularDependencies(id, dependencies);\n    }\n\n    const task: TaskData = {\n      id,\n      payload,\n      status: 'pending',\n      queue,\n      priority,\n      createdAt: now,\n      availableAt,\n      attempts: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoffDelay: options.backoffDelay ?? 1000,\n      progress: 0,\n      dependencies,\n    };\n\n    this.tasks.set(id, task);\n    this.queues.add(queue);\n\n    return { ...task };\n  }\n\n  // Phase 7: Circular dependency detection\n  private detectCircularDependencies(newTaskId: string, deps: string[]): void {\n    const visited = new Set<string>();\n\n    const hasCycle = (taskId: string): boolean => {\n      if (taskId === newTaskId) return true;\n      if (visited.has(taskId)) return false;\n      visited.add(taskId);\n\n      const task = this.tasks.get(taskId);\n      if (!task) return false;\n\n      for (const depId of task.dependencies) {\n        if (hasCycle(depId)) return true;\n      }\n      return false;\n    };\n\n    for (const depId of deps) {\n      if (depId === newTaskId || hasCycle(depId)) {\n        throw new Error('Circular dependency detected');\n      }\n    }\n  }\n\n  // Phase 1: Get next task from queue\n  next(queueName?: string): TaskData | null {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const now = new Date();\n\n    // Phase 8: Check concurrency limit\n    const limit = this.concurrencyLimits.get(queue);\n    if (limit != null) {\n      const activeCount = this.getActiveCount(queue);\n      if (activeCount >= limit) {\n        return null;\n      }\n    }\n\n    // Get all pending tasks in this queue\n    const pendingTasks: TaskData[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.queue !== queue || task.status !== 'pending') continue;\n\n      // Phase 4: Skip tasks not yet available\n      if (task.availableAt > now) continue;\n\n      // Phase 7: Skip tasks with unresolved dependencies\n      if (this.hasUnresolvedDependencies(task)) continue;\n\n      pendingTasks.push(task);\n    }\n\n    if (pendingTasks.length === 0) return null;\n\n    // Phase 3: Sort by priority (ascending), then by availability time, then by creation time (FIFO)\n    pendingTasks.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const availDiff = a.availableAt.getTime() - b.availableAt.getTime();\n      if (availDiff !== 0) return availDiff;\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = pendingTasks[0];\n    task.status = 'processing';\n    task.attempts += 1;\n    return { ...task };\n  }\n\n  // Phase 7: Check if task has unresolved dependencies\n  private hasUnresolvedDependencies(task: TaskData): boolean {\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (!dep || dep.status !== 'completed') return true;\n    }\n    return false;\n  }\n\n  // Phase 5: Complete a task\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not in processing state`);\n    }\n    task.status = 'completed';\n    task.progress = 100;\n  }\n\n  // Phase 5: Fail a task\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Task \"${taskId}\" is not in processing state`);\n    }\n\n    task.error = error;\n\n    if (task.attempts < task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n    } else {\n      // All retries exhausted\n      task.status = 'failed';\n\n      // Phase 6: Move to dead letter queue\n      this.addToDeadLetterQueue(task);\n    }\n  }\n\n  // Phase 6: Add task to dead letter queue\n  private addToDeadLetterQueue(task: TaskData): void {\n    const dlq = this.deadLetterQueues.get(task.queue) ?? [];\n    dlq.push(task);\n    this.deadLetterQueues.set(task.queue, dlq);\n  }\n\n  // Phase 6: Get dead-lettered tasks for a queue\n  getDeadLetterTasks(queueName?: string): TaskData[] {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const dlq = this.deadLetterQueues.get(queue) ?? [];\n    return dlq.map(t => ({ ...t }));\n  }\n\n  // Phase 6: Retry a dead-lettered task\n  retryDeadLetter(taskId: string): TaskData {\n    for (const [queueName, dlq] of this.deadLetterQueues.entries()) {\n      const index = dlq.findIndex(t => t.id === taskId);\n      if (index !== -1) {\n        const task = dlq[index];\n        dlq.splice(index, 1);\n\n        // Reset the task for a fresh round\n        task.status = 'pending';\n        task.attempts = 0;\n        task.error = undefined;\n        task.progress = 0;\n        task.availableAt = new Date();\n\n        this.tasks.set(task.id, task);\n        this.queues.add(queueName);\n\n        return { ...task };\n      }\n    }\n    throw new Error(`Task \"${taskId}\" not found in any dead letter queue`);\n  }\n\n  // Phase 6: Clear dead letter queue\n  clearDeadLetterQueue(queueName?: string): void {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    this.deadLetterQueues.set(queue, []);\n  }\n\n  // Phase 1: Get pending count\n  size(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queue && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // Phase 2: List all queue names\n  getQueues(): string[] {\n    return [...this.queues];\n  }\n\n  // Get a task by ID\n  getTask(taskId: string): TaskData | null {\n    const task = this.tasks.get(taskId);\n    return task ? { ...task } : null;\n  }\n\n  // Phase 7: Get dependency status\n  getDependencyStatus(taskId: string): { total: number; completed: number; pending: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task \"${taskId}\" not found`);\n\n    const pending: string[] = [];\n    let completed = 0;\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (dep && dep.status === 'completed') {\n        completed++;\n      } else {\n        pending.push(depId);\n      }\n    }\n    return {\n      total: task.dependencies.length,\n      completed,\n      pending,\n    };\n  }\n\n  // Phase 8: Set concurrency limit\n  setConcurrency(queueName: string, limit: number): void {\n    if (limit < 1 || !Number.isInteger(limit)) {\n      throw new Error(`Invalid concurrency limit: ${limit}`);\n    }\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  // Phase 8: Get concurrency limit\n  getConcurrency(queueName?: string): number | undefined {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    return this.concurrencyLimits.get(queue);\n  }\n\n  // Phase 8: Get active (processing) count\n  getActiveCount(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queue && task.status === 'processing') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // Phase 9: Report pr