--- /dev/null
+++ b/src/cron.ts
@@ -0,0 +1,66 @@
+/**
+ * Simple cron expression parser supporting:
+ * - asterisk/N * * * *  (every N minutes)
+ * - 0 * * * *    (every hour on the hour)
+ * - 0 0 * * *    (every day at midnight)
+ */
+export interface CronParts {
+  minute: string;
+  hour: string;
+}
+
+export function parseCron(expression: string): CronParts {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: "${expression}"`);
+  }
+  return {
+    minute: parts[0],
+    hour: parts[1],
+  };
+}
+
+export function shouldRunAt(expression: string, date: Date, lastRun?: Date): boolean {
+  const parts = parseCron(expression);
+  const minute = date.getMinutes();
+  const hour = date.getHours();
+
+  // Check minute field
+  if (parts.minute.startsWith('*/')) {
+    const interval = parseInt(parts.minute.slice(2), 10);
+    if (isNaN(interval) || interval <= 0) {
+      throw new Error(`Invalid cron interval: "${parts.minute}"`);
+    }
+    if (minute % interval !== 0) return false;
+  } else if (parts.minute !== '*') {
+    const target = parseInt(parts.minute, 10);
+    if (minute !== target) return false;
+  }
+
+  // Check hour field
+  if (parts.hour.startsWith('*/')) {
+    const interval = parseInt(parts.hour.slice(2), 10);
+    if (isNaN(interval) || interval <= 0) {
+      throw new Error(`Invalid cron interval: "${parts.hour}"`);
+    }
+    if (hour % interval !== 0) return false;
+  } else if (parts.hour !== '*') {
+    const target = parseInt(parts.hour, 10);
+    if (hour !== target) return false;
+  }
+
+  // Avoid double-runs: don't run if lastRun is within the same minute
+  if (lastRun) {
+    if (
+      lastRun.getFullYear() === date.getFullYear() &&
+      lastRun.getMonth() === date.getMonth() &&
+      lastRun.getDate() === date.getDate() &&
+      lastRun.getHours() === date.getHours() &&
+      lastRun.getMinutes() === date.getMinutes()
+    ) {
+      return false;
+    }
+  }
+
+  return true;
+}
