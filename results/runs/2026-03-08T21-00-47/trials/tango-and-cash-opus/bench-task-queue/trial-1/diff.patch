@@ -0,0 +1,68 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  it('should reject new tasks after shutdown', async () => {
+    await q.shutdown();
+    expect(() => q.add('test')).toThrow(/shut down/);
+  });
+
+  it('should complete immediately if no tasks are processing', async () => {
+    const summary = await q.shutdown();
+    expect(summary.completed).toBe(0);
+    expect(summary.forceCancelled).toBe(0);
+    expect(summary.durationMs).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should wait for processing tasks to complete', async () => {
+    q.add('test');
+    const t = q.next()!;
+
+    // Complete the task shortly after starting shutdown
+    setTimeout(() => q.complete(t.id), 50);
+
+    const summary = await q.shutdown(5000);
+    expect(summary.completed).toBe(1);
+    expect(summary.forceCancelled).toBe(0);
+  });
+
+  it('should force-cancel tasks that exceed timeout', async () => {
+    q.add('slow');
+    q.next(); // Start processing but never complete
+
+    const summary = await q.shutdown(50);
+    expect(summary.forceCancelled).toBe(1);
+  });
+
+  it('should run shutdown callbacks', async () => {
+    let callbackRan = false;
+    q.onShutdown(() => { callbackRan = true; });
+
+    await q.shutdown();
+    expect(callbackRan).toBe(true);
+  });
+
+  it('should return same result for multiple shutdown calls', async () => {
+    const s1 = q.shutdown();
+    const s2 = q.shutdown();
+    const [r1, r2] = await Promise.all([s1, s2]);
+    expect(r1).toEqual(r2);
+  });
+
+  it('should provide timing info', async () => {
+    const summary = await q.shutdown();
+    expect(typeof summary.durationMs).toBe('number');
+    expect(summary.durationMs).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should reject new schedules after shutdown', async () => {
+    await q.shutdown();
+    expect(() => q.addSchedule({ payload: 'x', cron: '* * * * *' })).toThrow(/shut down/);
+  });
+});
