+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 2: Named Queues', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  it('should use default queue when no name is given', () => {
+    const task = q.add('test');
+    expect(task.queue).toBe('default');
+  });
+
+  it('should add tasks to named queues', () => {
+    const task = q.add('email', { queue: 'emails' });
+    expect(task.queue).toBe('emails');
+  });
+
+  it('should keep named queues independent', () => {
+    q.add('email1', { queue: 'emails' });
+    q.add('log1', { queue: 'logs' });
+
+    expect(q.size('emails')).toBe(1);
+    expect(q.size('logs')).toBe(1);
+
+    const emailTask = q.next('emails');
+    expect(emailTask?.payload).toBe('email1');
+    expect(q.size('emails')).toBe(0);
+    expect(q.size('logs')).toBe(1);
+  });
+
+  it('should list all queue names', () => {
+    q.add('a', { queue: 'alpha' });
+    q.add('b', { queue: 'beta' });
