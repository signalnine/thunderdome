+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 7: Task Dependencies', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  it('should block tasks with unresolved dependencies', () => {
+    const dep = q.add('dependency');
+    q.add('dependent', { dependencies: [dep.id] });
+
+    // Only the dependency should be available
+    const task = q.next()!;
+    expect(task.payload).toBe('dependency');
+    expect(q.next()).toBeNull(); // dependent is blocked
+  });
+
+  it('should unblock task when dependencies complete', () => {
+    const dep = q.add('dependency');
+    q.add('dependent', { dependencies: [dep.id] });
+
+    const processing = q.next()!;
+    q.complete(processing.id);
+
+    const dependent = q.next();
+    expect(dependent?.payload).toBe('dependent');
+  });
+
+  it('should detect circular dependencies', () => {
+    const a = q.add('a');
+    const b = q.add('b', { dependencies: [a.id] });
+    expect(() => q.add('c', { dependencies: [b.id] })).not.toThrow();
+
+    // This should work since 'c' doesn't create a cycle
+    // But self-referencing is tricky with UUIDs generated internally
+  });
+
+  it('should error on non-existent dependency', () => {
+    expect(() => q.add('test', { dependencies: ['nonexistent'] })).toThrow();
+  });
+
+  it('should keep dependents blocked when dependency fails', () => {
+    const dep = q.add('dependency', { maxRetries: 0 });
+    q.add('dependent', { dependencies: [dep.id] });
+
+    const processing = q.next()!;
+    q.fail(processing.id, 'error');
+
+    // Dependent should still be blocked
+    expect(q.next()).toBeNull();
+  });
+
+  it('should support multiple dependencies', () => {
+    const dep1 = q.add('dep1');
+    const dep2 = q.add('dep2');
+    q.add('dependent', { dependencies: [dep1.id, dep2.id] });
+
+    const t1 = q.next()!;
+    q.complete(t1.id);
+    expect(q.next()?.payload).toBe('dep2'); // dep2, not dependent
+
+    // Dependent still blocked (dep2 not completed)
+    expect(q.next()).toBeNull();
+  });
+
+  it('should support inspecting dependency status', () => {
+    const dep1 = q.add('dep1');
+    const dep2 = q.add('dep2');
+    const dependent = q.add('dependent', { dependencies: [dep1.id, dep2.id] });
+
+    let status = q.getDependencyStatus(dependent.id);
+    expect(status.total).toBe(2);
+    expect(status.completed).toBe(0);
+    expect(status.pending.length).toBe(2);
+
+    const t1 = q.next()!;
+    q.complete(t1.id);
+
+    status = q.getDependencyStatus(dependent.id);
+    expect(status.completed).toBe(1);
+    expect(status.pending.length).toBe(1);
+  });
+});
