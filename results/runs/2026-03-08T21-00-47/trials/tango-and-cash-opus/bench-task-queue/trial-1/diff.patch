@@ -0,0 +1,102 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  it('should mark a task as completed', () => {
+    const task = q.add('test');
+    const processing = q.next()!;
+    q.complete(processing.id);
+    const completed = q.getTask(task.id);
+    expect(completed?.status).toBe('completed');
+  });
+
+  it('should mark a task as failed', () => {
+    q.add('test', { maxRetries: 0 });
+    const processing = q.next()!;
+    q.fail(processing.id, 'something went wrong');
+    const failed = q.getTask(processing.id);
+    expect(failed?.status).toBe('failed');
+    expect(failed?.error).toBe('something went wrong');
+  });
+
+  it('should re-add failed task with delay when retries remain', () => {
+    const task = q.add('test', { maxRetries: 3, backoffDelay: 100 });
+    const processing = q.next()!;
+    q.fail(processing.id, 'error');
+
+    const retried = q.getTask(task.id);
+    expect(retried?.status).toBe('pending');
+    expect(retried?.attempts).toBe(1);
+    // Should not be immediately available
+    expect(q.next()).toBeNull();
+  });
+
+  it('should use exponential backoff for retry delays', async () => {
+    const task = q.add('test', { maxRetries: 3, backoffDelay: 20 });
+
+    // First attempt: 20ms delay
+    let t = q.next()!;
+    q.fail(t.id, 'err');
+    let retried = q.getTask(task.id)!;
+    expect(retried.status).toBe('pending');
+
+    await new Promise(r => setTimeout(r, 30));
+    t = q.next()!;
+    expect(t).not.toBeNull();
+
+    // Second attempt: 40ms delay
+    q.fail(t.id, 'err');
+    retried = q.getTask(task.id)!;
+    expect(retried.status).toBe('pending');
+
+    await new Promise(r => setTimeout(r, 50));
+    t = q.next()!;
+    expect(t).not.toBeNull();
+
+    // Third attempt fails permanently
+    q.fail(t.id, 'err');
+    retried = q.getTask(task.id)!;
+    expect(retried.status).toBe('failed');
+  });
+
+  it('should track attempt count', () => {
+    q.add('test', { maxRetries: 2, backoffDelay: 1 });
+    const t = q.next()!;
+    expect(q.getTask(t.id)!.attempts).toBe(1);
+  });
+
+  it('should default maxRetries to 3', () => {
+    const task = q.add('test');
+    expect(task.maxRetries).toBe(3);
+  });
+
+  it('should default backoffDelay to 1000', () => {
+    const task = q.add('test');
+    expect(task.backoffDelay).toBe(1000);
+  });
+
+  it('should keep original queue and priority on retry', () => {
+    const task = q.add('test', { queue: 'work', priority: 2, maxRetries: 3, backoffDelay: 1 });
+    const t = q.next('work')!;
+    q.fail(t.id, 'err');
+    const retried = q.getTask(task.id)!;
+    expect(retried.queue).toBe('work');
+    expect(retried.priority).toBe(2);
+  });
+
+  it('should throw when completing a non-processing task', () => {
+    const task = q.add('test');
+    expect(() => q.complete(task.id)).toThrow();
+  });
+
+  it('should throw when failing a non-processing task', () => {
+    const task = q.add('test');
+    expect(() => q.fail(task.id)).toThrow();
+  });
+});
