+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 9: Progress Tracking and Cancellation', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  describe('Progress', () => {
+    it('should report progress on a processing task', () => {
+      q.add('test');
+      const t = q.next()!;
+      q.reportProgress(t.id, 50, 'halfway');
+
+      const updated = q.getTask(t.id)!;
+      expect(updated.progress).toBe(50);
+      expect(updated.progressMessage).toBe('halfway');
+    });
+
+    it('should reject progress outside 0-100', () => {
+      q.add('test');
+      const t = q.next()!;
+      expect(() => q.reportProgress(t.id, -1)).toThrow();
+      expect(() => q.reportProgress(t.id, 101)).toThrow();
+    });
+
+    it('should reject progress on non-processing task', () => {
+      const task = q.add('test');
+      expect(() => q.reportProgress(task.id, 50)).toThrow();
+    });
+
+    it('should notify progress listeners', () => {
+      q.add('test');
+      const t = q.next()!;
+
+      const updates: Array<{ progress: number; message?: string }> = [];
+      q.onProgress(t.id, (progress, message) => {
+        updates.push({ progress, message });
+      });
+
+      q.reportProgress(t.id, 25, 'quarter');
+      q.reportProgress(t.id, 75, 'three quarters');
+
+      expect(updates.length).toBe(2);
+      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });
+      expect(updates[1]).toEqual({ progress: 75, message: 'three quarters' });
+    });
+
+    it('should allow unsubscribing from progress', () => {
+      q.add('test');
+      const t = q.next()!;
+
+      let callCount = 0;
+      const unsub = q.onProgress(t.id, () => { callCount++; });
+
+      q.reportProgress(t.id, 25);
+      unsub();
+      q.reportProgress(t.id, 50);
+
+      expect(callCount).toBe(1);
+    });
+  });
+
+  describe('Cancellation', () => {
+    it('should cancel a pending task', () => {
+      const task = q.add('test');
+      q.cancel(task.id);
+      expect(q.getTask(task.id)!.status).toBe('cancelled');
+      expect(q.next()).toBeNull();
+    });
+
+    it('should cancel a processing task', () => {
+      q.add('test');
+      const t = q.next()!;
+      q.cancel(t.id);
+      expect(q.getTask(t.id)!.status).toBe('cancelled');
+    });
+
+    it('should not allow cancelling completed tasks', () => {
+      q.add('test');
+      const t = q.next()!;
+      q.complete(t.id);
+      expect(() => q.cancel(t.id)).toThrow();
+    });
+
+    it('should not allow cancelling failed tasks', () => {
+      q.add('test', { maxRetries: 0 });
+      const t = q.next()!;
+      q.fail(t.id, 'err');
+      expect(() => q.cancel(t.id)).toThrow();
+    });
+
+    it('should not retry cancelled tasks', () => {
+      q.add('test', { maxRetries: 3 });
+      const t = q.next()!;
+      q.cancel(t.id);
+
+      const task = q.getTask(t.id)!;
+      expect(task.status).toBe('cancelled');
+      // Should not have been re-queued
+      expect(q.next()).toBeNull();
+    });
+  });
+});
