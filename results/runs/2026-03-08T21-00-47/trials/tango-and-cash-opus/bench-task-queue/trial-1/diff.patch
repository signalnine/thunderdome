+    q.add('q1-low', { queue: 'q1', priority: 10 });
+    q.add('q1-high', { queue: 'q1', priority: 1 });
+    q.add('q2-low', { queue: 'q2', priority: 10 });
+
+    expect(q.next('q1')?.payload).toBe('q1-high');
+    expect(q.next('q2')?.payload).toBe('q2-low');
