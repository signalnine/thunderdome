q[0].attempts).toBe(1);\n  });\n\n  it('should retry a dead-lettered task', () => {\n    const task = q.add('test', { maxRetries: 1, backoffDelay: 0 });\n    const t = q.next()!;\n    q.fail(t.id, 'crash');\n\n    expect(q.getDeadLetterTasks().length).toBe(1);\n\n    const retried = q.retryDeadLetter(task.id);\n    expect(retried.status).toBe('pending');\n    expect(retried.attempts).toBe(0);\n\n    expect(q.getDeadLetterTasks().length).toBe(0);\n    expect(q.next()?.id).toBe(task.id);\n  });\n\n  it('should clear DLQ for a queue', () => {\n    q.add('test1', { maxRetries: 1, backoffDelay: 0 });\n    q.add('test2', { maxRetries: 1, backoffDelay: 0 });\n\n    let t = q.next()!;\n    q.fail(t.id, 'err');\n    t = q.next()!;\n    q.fail(t.id, 'err');\n\n    expect(q.getDeadLetterTasks().length).toBe(2);\n    q.clearDeadLetterQueue();\n    expect(q.getDeadLetterTasks().length).toBe(0);\n  });\n\n  it('should have independent DLQs per named queue', () => {\n    q.add('a', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n    q.add('b', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n\n    let t = q.next('q1')!;\n    q.fail(t.id, 'err');\n    t = q.next('q2')!;\n    q.fail(t.id, 'err');\n\n    expect(q.getDeadLetterTasks('q1').length).toBe(1);\n    expect(q.getDeadLetterTasks('q2').length).toBe(1);\n\n    q.clearDeadLetterQueue('q1');\n    expect(q.getDeadLetterTasks('q1').length).toBe(0);\n    expect(q.getDeadLetterTasks('q2').length).toBe(1);\n  });\n\n  it('should throw when retrying non-existent dead letter', () => {\n    expect(() => q.retryDeadLetter('nonexistent')).toThrow();\n  });\n});\n","structuredPatch":[{"oldStart":8,"oldLines":15,"newStart":8,"newLines":6,"lines":["     q = new TaskQueue();","   });"," ","-  function exhaustRetries(taskId: string, queueName?: string) {","-    const task = q.getTask(taskId)!;","-    for (let i = 0; i < task.maxRetries; i++) {","-      // Need to wait for backoff - use maxRetries=1, backoffDelay=1 in tests","-      const t