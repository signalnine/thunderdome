+
+  it('should return null from empty or non-existent queue', () => {
+    expect(q.next('nonexistent')).toBeNull();
+  });
+
+  it('should create queues implicitly on first add', () => {
+    q.add('task', { queue: 'new-queue' });
+    expect(q.getQueues()).toContain('new-queue');
+  });
+
+  it('should be backward-compatible with Phase 1 (omitting queue name)', () => {
+    q.add('task');
+    const task = q.next();
+    expect(task?.payload).toBe('task');
+  });
+});
