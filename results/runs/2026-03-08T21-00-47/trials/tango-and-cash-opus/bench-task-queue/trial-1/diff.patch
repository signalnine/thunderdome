+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  it('should run middleware in order before handler', async () => {
+    const order: string[] = [];
+
+    q.use(async (_task, next) => {
+      order.push('middleware1');
+      await next();
+    });
+
+    q.use(async (_task, next) => {
+      order.push('middleware2');
+      await next();
+    });
+
+    q.handle(async () => {
+      order.push('handler');
+    });
+
+    q.add('test');
+    const t = q.next()!;
+    await q.process(t.id);
+
+    expect(order).toEqual(['middleware1', 'middleware2', 'handler']);
+  });
+
+  it('should skip processing if middleware does not call next', async () => {
+    const order: string[] = [];
+
+    q.use(async (_task, _next) => {
+      order.push('blocker');
+      // intentionally not calling next
+    });
+
+    q.handle(async () => {
+      order.push('handler');
+    });
+
+    q.add('test');
+    const t = q.next()!;
+    await q.process(t.id);
+
+    expect(order).toEqual(['blocker']);
+  });
+
+  it('should allow middleware to modify task', async () => {
+    q.use(async (task, next) => {
+      // eslint-disable-next-line @typescript-eslint/no-explicit-any
+      (task as any).enriched = true;
+      await next();
+    });
+
+    // eslint-disable-next-line @typescript-eslint/no-explicit-any
+    let received: any = null;
+    q.handle(async (task) => {
+      received = task;
+    });
+
+    q.add('test');
+    const t = q.next()!;
+    await q.process(t.id);
+
+    expect(received).not.toBeNull();
+    expect(received.enriched).toBe(true);
+  });
+
+  it('should fail task if middleware throws', async () => {
+    q.use(async () => {
+      throw new Error('middleware error');
+    });
+
+    q.add('test', { maxRetries: 0 });
+    const t = q.next()!;
+
+    await expect(q.process(t.id)).rejects.toThrow('middleware error');
+    expect(q.getTask(t.id)!.status).toBe('failed');
+  });
+
+  it('should have independent middleware per queue', async () => {
+    const order: string[] = [];
+
+    q.use('q1', async (_task, next) => {
+      order.push('q1-middleware');
+      await next();
+    });
+
+    q.use('q2', async (_task, next) => {
+      order.push('q2-middleware');
+      await next();
+    });
+
+    q.handle('q1', async () => { order.push('q1-handler'); });
+    q.handle('q2', async () => { order.push('q2-handler'); });
+
+    q.add('a', { queue: 'q1' });
+    q.add('b', { queue: 'q2' });
+
+    const t1 = q.next('q1')!;
+    await q.process(t1.id);
+
+    expect(order).toEqual(['q1-middleware', 'q1-handler']);
+  });
+
+  it('should run handler even without middleware', async () => {
+    let called = false;
+    q.handle(async () => { called = true; });
+
+    q.add('test');
+    const t = q.next()!;
+    await q.process(t.id);
+
+    expect(called).toBe(true);
+  });
+
+  it('should work without a handler (middleware only)', async () => {
+    let called = false;
+    q.use(async (_task, next) => {
+      called = true;
+      await next();
+    });
+
+    q.add('test');
+    const t = q.next()!;
+    await q.process(t.id);
+    expect(called).toBe(true);
+  });
+});
