=== bestTotal) {\n          const newMask = e0.mask | (maskB << halfA);\n          const solnNew = buildSolnBigint(newMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n          const solnBest = buildSolnBigint(bestFreeMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n          if (indexSetSmallerBigint(solnNew, solnBest)) {\n            bestFreeMask = newMask;\n          }\n        }\n      }\n\n      // Check HD=1: flip each of the rank bits in idealSigA\n      if (costB + 1 < bestTotal) {\n        for (let bit = 0; bit < rank; bit++) {\n          const altSig = idealSigA ^ (1 << bit);\n          const e1 = mapA.get(altSig);\n          if (e1) {\n            const total = e1.cost + costB + 1;\n            if (total < bestTotal) {\n              bestTotal = total;\n              bestFreeMask = e1.mask | (maskB << halfA);\n            } else if (total === bestTotal) {\n              const newMask = e1.mask | (maskB << halfA);\n              const solnNew = buildSolnBigint(newMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n              const solnBest = buildSolnBigint(bestFreeMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n              if (indexSetSmallerBigint(solnNew, solnBest)) {\n                bestFreeMask = newMask;\n              }\n            }\n          }\n        }\n      }\n\n      // Check HD=2: flip pairs of bits\n      if (costB + 2 < bestTotal) {\n        for (let b1 = 0; b1 < rank; b1++) {\n          for (let b2 = b1 + 1; b2 < rank; b2++) {\n            const altSig = idealSigA ^ (1 << b1) ^ (1 << b2);\n            const e2 = mapA.get(altSig);\n            if (e2) {\n              const total = e2.cost + costB + 2;\n              if (total < bestTotal) {\n                bestTotal = total;\n                bestFreeMask = e2.mask | (maskB << halfA);\n              } else if (total === bestTotal) {\n                const newMask = e2.mask | (maskB << halfA);\n                const solnNew = buildSolnBigint(newMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n                const solnBest = buildSolnBigint(bestFreeMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n                if (indexSetSmallerBigint(solnNew, solnBest)) {\n                  bestFreeMask = newMask;\n                }\n              }\n            }\n          }\n        }\n      }\n\n      // For HD >= 3, the cost is at least costB + 3 + min_costA.\n      // With 40 buttons, the minimum possible total is often small enough that HD>=3 isn't needed.\n      // But for correctness, we should check up to the current best.\n      // For HD=k, there are C(rank,k) signatures to check. With rank up to 40 and k=3, that's ~10K.\n      // k=4 is ~100K per B assignment, which with 2^20 B is too many.\n      // So we check up to HD=3 for safety.\n      if (costB + 3 < bestTotal && rank >= 3) {\n        for (let b1 = 0; b1 < rank; b1++) {\n          for (let b2 = b1 + 1; b2 < rank; b2++) {\n            for (let b3 = b2 + 1; b3 < rank; b3++) {\n              const altSig = idealSigA ^ (1 << b1) ^ (1 << b2) ^ (1 << b3);\n              const e3 = mapA.get(altSig);\n              if (e3) {\n                const total = e3.cost + costB + 3;\n                if (total < bestTotal) {\n                  bestTotal = total;\n                  bestFreeMask = e3.mask | (maskB << halfA);\n                } else if (total === bestTotal) {\n                  const newMask = e3.mask | (maskB << halfA);\n                  const solnNew = buildSolnBigint(newMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n                  const solnBest = buildSolnBigint(bestFreeMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n                  if (indexSetSmallerBigint(solnNew, solnBest)) {\n                    bestFreeMask = newMask;\n                  }\n                }\n              }\n            }\n          }\n        }\n      }\n    }\n\n    // If we still haven't found a solution (unlikely), fall back\n    if (bestTotal > numCols) {\n      bestFreeMask = 0;\n      bestTotal = 0;\n      for (let p = 0; p < rank; p++) bestTotal += pivotAug[p];\n    }\n\n    const bestSoln = buildSolnBigint(bestFreeMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n    return bigintToIndices(bestSoln, numCols);\n  }","originalFile":"export interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\nfunction popcount(n: number): number {\n  n = n - ((n >> 1) & 0x55555555);\n  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);\n  return (((n + (n >> 4)) & 0x0f0f0f0f) * 0x01010101) >> 24;\n}\n\n/**\n * Solve toggle puzzle using Gaussian elimination over GF(2).\n * Uses bitmask representation for efficiency with many free variables.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numButtons = buttons.length;\n  const numLights = target.length;\n\n  if (target.every((t) => !t)) return [];\n  if (numButtons === 0) return null;\n\n  // We form the system: for each light j, sum_{i: j in buttons[i]} x_i = target[j] (mod 2)\n  // Rows = lights (equations), Columns = buttons (variables)\n  // We use bitmask rows where bit i represents button/column i.\n  // Since numButtons <= 40, we need BigInt or two 32-bit ints. We'll use BigInt for simplicity.\n\n  const numRows = numLights;\n  const numCols = numButtons;\n\n  // Build matrix rows as bigints (each bit = a column/button)\n  const rows: bigint[] = [];\n  const aug: number[] = [];\n\n  for (let j = 0; j < numRows; j++) {\n    rows.push(0n);\n    aug.push(target[j] ? 1 : 0);\n  }\n\n  for (let i = 0; i < numCols; i++) {\n    for (const lightIdx of buttons[i]) {\n      if (lightIdx < numRows) {\n        rows[lightIdx] |= 1n << BigInt(i);\n      }\n    }\n  }\n\n  // Gaussian elimination over GF(2)\n  const pivotCols: number[] = [];\n  const pivotRowForCol: number[] = new Array(numCols).fill(-1);\n  let curRow = 0;\n\n  for (let col = 0; col < numCols && curRow < numRows; col++) {\n    const colBit = 1n << BigInt(col);\n    let pivotIdx = -1;\n    for (let row = curRow; row < numRows; row++) {\n      if (rows[row] & colBit) {\n        pivotIdx = row;\n        break;\n      }\n    }\n    if (pivotIdx === -1) continue;\n\n    // Swap\n    if (pivotIdx !== curRow) {\n      [rows[curRow], rows[pivotIdx]] = [rows[pivotIdx], rows[curRow]];\n      [aug[curRow], aug[pivotIdx]] = [aug[pivotIdx], aug[curRow]];\n    }\n\n    pivotRowForCol[col] = curRow;\n    pivotCols.push(col);\n\n    // Eliminate\n    for (let row = 0; row < numRows; row++) {\n      if (row !== curRow && (rows[row] & colBit)) {\n        rows[row] ^= rows[curRow];\n        aug[row] ^= aug[curRow];\n      }\n    }\n    curRow++;\n  }\n\n  // Check inconsistency\n  for (let row = curRow; row < numRows; row++) {\n    if (aug[row] === 1) return null;\n  }\n\n  // Free variables\n  const pivotColSet = new Set(pivotCols);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numCols; col++) {\n    if (!pivotColSet.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n  const rank = pivotCols.length;\n\n  // For each pivot variable, precompute which free variables affect it\n  // After RREF, pivot variable col's row has: x_col + sum(matrix[row][freeCol] * x_freeCol) = aug[row]\n  // So x_col = aug[row] XOR (sum of free var contributions)\n  // We represent the free var contributions as a bitmask over free var indices\n  const pivotAug: number[] = new Array(rank).fill(0); // aug value for each pivot row\n  const pivotFreeMask: number[] = new Array(rank).fill(0); // which free vars affect this pivot\n\n  for (let p = 0; p < rank; p++) {\n    const col = pivotCols[p];\n    const row = pivotRowForCol[col];\n    pivotAug[p] = aug[row];\n    let mask = 0;\n    for (let f = 0; f < numFree; f++) {\n      if (rows[row] & (1n << BigInt(freeVars[f]))) {\n        mask |= 1 << f;\n      }\n    }\n    pivotFreeMask[p] = mask;\n  }\n\n  // For a given free variable assignment (as a bitmask over free vars),\n  // the total number of button presses = popcount(freeMask) + sum of pivot values\n  // pivot value p = pivotAug[p] XOR popcount(pivotFreeMask[p] & freeMask) % 2\n  //              = pivotAug[p] XOR parity(pivotFreeMask[p] & freeMask)\n\n  // We need to find freeMask that minimizes total presses.\n  // total = popcount(freeMask) + sum_p (pivotAug[p] XOR parity(pivotFreeMask[p] & freeMask))\n\n  // For the base solution (freeMask = 0):\n  // total = 0 + sum_p pivotAug[p]\n\n  // Toggling free variable f flips pivot p if bit f is set in pivotFreeMask[p].\n  // So toggling f: cost changes by +1 (for the free var itself)\n  //   and for each pivot p where f is in its mask: if pivot was 1, it becomes 0 (saves 1),\n  //   if pivot was 0, it becomes 1 (costs 1).\n\n  if (numFree <= 20) {\n    // Direct enumeration - up to 2^20 = 1M, very fast\n    let bestMask = 0;\n    let bestTotal = numCols + 1;\n    let bestSolnBigint = 0n;\n\n    const totalCombinations = 1 << numFree;\n\n    for (let freeMask = 0; freeMask < totalCombinations; freeMask++) {\n      let total = popcount(freeMask);\n\n      for (let p = 0; p < rank; p++) {\n        const pivotVal = pivotAug[p] ^ (popcount(pivotFreeMask[p] & freeMask) & 1);\n        total += pivotVal;\n      }\n\n      if (total < bestTotal) {\n        bestTotal = total;\n        bestMask = freeMask;\n        bestSolnBigint = 0n; // placeholder, will compute later\n      } else if (total === bestTotal) {\n        // Compare index sets: build solution bigint and compare\n        const solnA = buildSolnBigint(freeMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n        if (bestSolnBigint === 0n && bestMask !== freeMask) {\n          bestSolnBigint = buildSolnBigint(bestMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n        }\n        // For index sets, the lex smaller set has the smallest first element.\n        // As a bitmask, this means the lowest set bit should be lower.\n        // Comparing bigints directly: lower bigint doesn't mean lex smaller index set.\n        // We need to compare which has the lower first set bit, then second, etc.\n        // Actually for same count, comparing the bitmasks as numbers where lower bit positions\n        // are more significant... we want the set with smallest elements.\n        // bitmask comparison: if we treat bit 0 as most significant, we want the one\n        // that has bit 0 set first. So we need to compare by \"reverse bit significance\".\n        // Simplest: compare solution bigints where lower bits have priority.\n        // Actually, lex order on index sets [a0,a1,...] < [b0,b1,...] iff\n        // at first difference, a_k < b_k. This is equivalent to:\n        // the set with the smallest first element that isn't in the other set.\n        // If a has a lower first differing element, a's set is smaller.\n        // For bitmasks: find lowest bit where they differ. If that bit is set in a but not b,\n        // then a has that smaller element -> a is lex smaller.\n        if (indexSetSmallerBigint(solnA, bestSolnBigint)) {\n          bestTotal = total;\n          bestMask = freeMask;\n          bestSolnBigint = solnA;\n        }\n      }\n    }\n\n    // Build final solution\n    if (bestSolnBigint === 0n) {\n      bestSolnBigint = buildSolnBigint(bestMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n    }\n    return bigintToIndices(bestSolnBigint, numCols);\n\n  } else {\n    // Meet in the middle for numFree > 20\n    // Split free vars into two halves\n    const halfA = Math.min(numFree, Math.floor(numFree / 2));\n    const halfB = numFree - halfA;\n    const sizeA = 1 << halfA;\n    const sizeB = 1 << halfB;\n\n    // For each half-A assignment, compute the \"signature\" = effect on pivots\n    // and the cost contribution.\n    // Signature: for each pivot, parity(pivotFreeMask[p] & freeMaskA) - this is a rank-bit number\n    // Cost from A = popcount(freeMaskA) + contribution to pivots from A\n\n    // But pivots depend on BOTH halves. Let's think differently.\n    // For pivot p: value = pivotAug[p] XOR parityA(p) XOR parityB(p)\n    // where parityA = parity of (pivotFreeMask[p] & freeMaskA) for bits in half A\n    // and parityB = parity of (pivotFreeMask[p] & freeMaskB_shifted) for bits in half B\n\n    // Total cost = popcountA + popcountB + sum_p (pivotAug[p] XOR parityA(p) XOR parityB(p))\n    // = (popcountA + sum_p (pivotAug[p] XOR parityA(p))) + popcountB + adjustment for B\n\n    // This is complex. Let's use a simpler approach: enumerate all 2^halfA assignments,\n    // for each compute the pivot parity signature (a rank-bit number) and cost.\n    // Store in a map: signature -> (minCost, bestMask)\n    // Then enumerate all 2^halfB assignments, compute signature, look up complement, combine.\n\n    // Pivot parity signature for half A: for each pivot p, parity(pivotFreeMask[p] & freeMaskA_in_lower_bits)\n    // We only look at bits 0..halfA-1 of pivotFreeMask[p]\n\n    const pivotFreeMaskA: number[] = new Array(rank);\n    const pivotFreeMaskB: number[] = new Array(rank);\n    const maskABits = (1 << halfA) - 1;\n\n    for (let p = 0; p < rank; p++) {\n      pivotFreeMaskA[p] = pivotFreeMask[p] & maskABits;\n      pivotFreeMaskB[p] = pivotFreeMask[p] >> halfA;\n    }\n\n    // For half A: compute signature and cost\n    // signature_A[p] = parity(pivotFreeMaskA[p] & maskA) for each pivot\n    // costA = popcount(maskA) (just the free vars in A)\n    // We also need to track the pivot contributions, but they depend on both halves.\n\n    // The pivot p's value = pivotAug[p] XOR sigA[p] XOR sigB[p]\n    // Total = popcountFreeA + popcountFreeB + sum_p (pivotAug[p] XOR sigA[p] XOR sigB[p])\n    //       = popcountFreeA + popcountFreeB + sum_p pivotAug[p] XOR sum_p sigA[p] XOR sum_p sigB[p]\n    // No, XOR doesn't distribute over sum like that. Each pivot contributes 0 or 1.\n    // total = popcountFreeA + popcountFreeB + #{p: pivotAug[p] XOR sigA[p] XOR sigB[p] = 1}\n    // = popcountFreeA + popcountFreeB + #{p: sigA[p] XOR sigB[p] = NOT pivotAug[p]}\n    // Hmm, let's define targetSig[p] = pivotAug[p] (we want pivot to be 0, i.e., not pressed)\n    // We want sigA[p] XOR sigB[p] = pivotAug[p] to make pivot = 0.\n    // If they don't match, pivot is 1 (pressed, adding to cost).\n    // So cost from pivots = #{p: sigA[p] XOR sigB[p] != pivotAug[p]}\n    // = #{p: sigA[p] != pivotAug[p] XOR sigB[p]}\n\n    // Let's define: for half B, compute complementSig[p] = pivotAug[p] XOR sigB[p]\n    // Then cost from pivots = #{p: sigA[p] != complementSig[p]} = Hamming distance\n\n    // Total = popcountFreeA + popcountFreeB + HammingDist(sigA, complementSigB)\n\n    // To minimize, for each sigA and complementSigB that are equal (HD=0),\n    // total = popcountFreeA + popcountFreeB. Otherwise HD adds cost.\n\n    // Approach: for each half A assignment, compute (sigA as rank-bit number, popcountFreeA).\n    // Store in map: sigA -> min popcountFreeA + associated maskA info\n    // For each half B assignment, compute complementSigB, popcountFreeB.\n    // Look up exact match first (HD=0), then HD=1, etc.\n\n    // For rank <= 40, signatures are up to 40-bit numbers.\n\n    // Build signature for an assignment\n    const computeSig = (mask: number, pivotMasks: number[]): number => {\n      let sig = 0;\n      for (let p = 0; p < rank; p++) {\n        if (popcount(pivotMasks[p] & mask) & 1) {\n          sig |= 1 << p;\n        }\n      }\n      return sig;\n    };\n\n    // Phase 1: enumerate half A\n    interface HalfEntry { cost: number; mask: number; fullSolnBits: bigint; }\n    const mapA = new Map<number, HalfEntry[]>();\n\n    for (let maskA = 0; maskA < sizeA; maskA++) {\n      const sigA = computeSig(maskA, pivotFreeMaskA);\n      const costA = popcount(maskA);\n      const entry: HalfEntry = { cost: costA, mask: maskA, fullSolnBits: 0n };\n