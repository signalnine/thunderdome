iables)\n  // Equation for light j: sum of x_i where j in buttons[i] = target[j] (mod 2)\n\n  const numRows = numLights;\n  const numCols = numButtons;\n\n  // Matrix rows: each row is a Uint8Array for light equation\n  // matrix[j][i] = 1 if button i affects light j\n  const matrix: Uint8Array[] = [];\n  const augmented: number[] = [];\n\n  for (let j = 0; j < numRows; j++) {\n    matrix.push(new Uint8Array(numCols));\n    augmented.push(target[j] ? 1 : 0);\n  }\n\n  for (let i = 0; i < numCols; i++) {\n    for (const lightIdx of buttons[i]) {\n      if (lightIdx < numRows) {\n        matrix[lightIdx][i] = 1;\n      }\n    }\n  }\n\n  // Gaussian elimination over GF(2)\n  const pivotCol: number[] = []; // pivotCol[row] = column index of pivot, or -1\n  const pivotRow: number[] = new Array(numCols).fill(-1); // pivotRow[col] = row index where this col is pivot\n  let currentRow = 0;\n\n  for (let col = 0; col < numCols && currentRow < numRows; col++) {\n    // Find pivot row\n    let pivot = -1;\n    for (let row = currentRow; row < numRows; row++) {\n      if (matrix[row][col] === 1) {\n        pivot = row;\n        break;\n      }\n    }\n    if (pivot === -1) continue;\n\n    // Swap rows\n    if (pivot !== currentRow) {\n      const tmp = matrix[currentRow];\n      matrix[currentRow] = matrix[pivot];\n      matrix[pivot] = tmp;\n      const tmpAug = augmented[currentRow];\n      augmented[currentRow] = augmented[pivot];\n      augmented[pivot] = tmpAug;\n    }\n\n    pivotRow[col] = currentRow;\n    pivotCol.push(col);\n\n    // Eliminate other rows\n    for (let row = 0; row < numRows; row++) {\n      if (row !== currentRow && matrix[row][col] === 1) {\n        for (let c = 0; c < numCols; c++) {\n          matrix[row][c] ^= matrix[currentRow][c];\n        }\n        augmented[row] ^= augmented[currentRow];\n      }\n    }\n    currentRow++;\n  }\n\n  // Check for inconsistency: any row with all zeros but augmented = 1\n  for (let row = currentRow; row < numRow