_p pivotAug[p]\n\n  // Toggling free variable f flips pivot p if bit f is set in pivotFreeMask[p].\n  // So toggling f: cost changes by +1 (for the free var itself)\n  //   and for each pivot p where f is in its mask: if pivot was 1, it becomes 0 (saves 1),\n  //   if pivot was 0, it becomes 1 (costs 1).\n\n  if (numFree <= 20) {\n    // Direct enumeration - up to 2^20 = 1M, very fast\n    let bestMask = 0;\n    let bestTotal = numCols + 1;\n    let bestSolnBigint = 0n;\n\n    const totalCombinations = 1 << numFree;\n\n    for (let freeMask = 0; freeMask < totalCombinations; freeMask++) {\n      let total = popcount(freeMask);\n\n      for (let p = 0; p < rank; p++) {\n        const pivotVal = pivotAug[p] ^ (popcount(pivotFreeMask[p] & freeMask) & 1);\n        total += pivotVal;\n      }\n\n      if (total < bestTotal) {\n        bestTotal = total;\n        bestMask = freeMask;\n        bestSolnBigint = 0n; // placeholder, will compute later\n      } else if (total === bestTotal) {\n        // Compare index sets: build solution bigint and compare\n        const solnA = buildSolnBigint(freeMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n        if (bestSolnBigint === 0n && bestMask !== freeMask) {\n          bestSolnBigint = buildSolnBigint(bestMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n        }\n        // For index sets, the lex smaller set has the smallest first element.\n        // As a bitmask, this means the lowest set bit should be lower.\n        // Comparing bigints directly: lower bigint doesn't mean lex smaller index set.\n        // We need to compare which has the lower first set bit, then second, etc.\n        // Actually for same count, comparing the bitmasks as numbers where lower bit positions\n        // are more significant... we want the set with smallest elements.\n        // bitmask comparison: if we treat bit 0 as most significant, we want the one\n        // that has bit 0 set first. So we need to compare by \"rev