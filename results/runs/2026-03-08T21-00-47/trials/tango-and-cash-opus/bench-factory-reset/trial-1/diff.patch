Row] * inv) % mod;\n   566→\n   567→    pivotRowForCol[col] = currentRow;\n   568→    pivotCols.push(col);\n   569→\n   570→    for (let row = 0; row < numRows; row++) {\n   571→      if (row !== currentRow && matrix[row][col] !== 0) {\n   572→        const factor = matrix[row][col];\n   573→        for (let c = 0; c < numCols; c++) {\n   574→          matrix[row][c] = ((matrix[row][c] - factor * matrix[currentRow][c]) % mod + mod) % mod;\n   575→        }\n   576→        augmented[row] = ((augmented[row] - factor * augmented[currentRow]) % mod + mod) % mod;\n   577→      }\n   578→    }\n   579→    currentRow++;\n   580→  }\n   581→\n   582→  // Check inconsistency\n   583→  for (let row = currentRow; row < numRows; row++) {\n   584→    if (augmented[row] !== 0) return null;\n   585→  }\n   586→\n   587→  // Free variables\n   588→  const pivotColSet = new Set(pivotCols);\n   589→  const freeVars: number[] = [];\n   590→  for (let col = 0; col < numCols; col++) {\n   591→    if (!pivotColSet.has(col)) {\n   592→      freeVars.push(col);\n   593→    }\n   594→  }\n   595→\n   596→  const numFree = freeVars.length;\n   597→  const rank = pivotCols.length;\n   598→\n   599→  // For each pivot, precompute coefficients for free variables\n   600→  // After RREF: x_pivotCol = aug[row] - sum(matrix[row][freeCol] * x_freeCol) mod p\n   601→  const pivotAugVals: number[] = new Array(rank);\n   602→  const pivotFreeCoeffs: number[][] = new Array(rank);\n   603→\n   604→  for (let p = 0; p < rank; p++) {\n   605→    const col = pivotCols[p];\n   606→    const row = pivotRowForCol[col];\n   607→    pivotAugVals[p] = augmented[row];\n   608→    pivotFreeCoeffs[p] = new Array(numFree);\n   609→    for (let f = 0; f < numFree; f++) {\n   610→      pivotFreeCoeffs[p][f] = matrix[row][freeVars[f]];\n   611→    }\n   612→  }\n   613→\n   614→  const computeSolution = (freeAssign: number[]): number[] => {\n   615→    const solution = new Array(numCols).fill(0);\n   616→    for (let f