   for (let freeMask = 0; freeMask < totalCombinations; freeMask++) {\n   146→      let total = popcount(freeMask);\n   147→\n   148→      for (let p = 0; p < rank; p++) {\n   149→        const pivotVal = pivotAug[p] ^ (popcount(pivotFreeMask[p] & freeMask) & 1);\n   150→        total += pivotVal;\n   151→      }\n   152→\n   153→      if (total < bestTotal) {\n   154→        bestTotal = total;\n   155→        bestMask = freeMask;\n   156→        bestSolnBigint = 0n; // placeholder, will compute later\n   157→      } else if (total === bestTotal) {\n   158→        // Compare index sets: build solution bigint and compare\n   159→        const solnA = buildSolnBigint(freeMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n   160→        if (bestSolnBigint === 0n && bestMask !== freeMask) {\n   161→          bestSolnBigint = buildSolnBigint(bestMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n   162→        }\n   163→        // For index sets, the lex smaller set has the smallest first element.\n   164→        // As a bitmask, this means the lowest set bit should be lower.\n   165→        // Comparing bigints directly: lower bigint doesn't mean lex smaller index set.\n   166→        // We need to compare which has the lower first set bit, then second, etc.\n   167→        // Actually for same count, comparing the bitmasks as numbers where lower bit positions\n   168→        // are more significant... we want the set with smallest elements.\n   169→        // bitmask comparison: if we treat bit 0 as most significant, we want the one\n   170→        // that has bit 0 set first. So we need to compare by \"reverse bit significance\".\n   171→        // Simplest: compare solution bigints where lower bits have priority.\n   172→        // Actually, lex order on index sets [a0,a1,...] < [b0,b1,...] iff\n   173→        // at first difference, a_k < b_k. This is equivalent to:\n   174→        // the set with the smallest first element that isn't in the other set.\n   175→        // If a has a lower first differing element, a's set is smaller.\n   176→        // For bitmasks: find lowest bit where they differ. If that bit is set in a but not b,\n   177→        // then a has that smaller element -> a is lex smaller.\n   178→        if (indexSetSmallerBigint(solnA, bestSolnBigint)) {\n   179→          bestTotal = total;\n   180→          bestMask = freeMask;\n   181→          bestSolnBigint = solnA;\n   182→        }\n   183→      }\n   184→    }\n   185→\n   186→    // Build final solution\n   187→    if (bestSolnBigint === 0n) {\n   188→      bestSolnBigint = buildSolnBigint(bestMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n   189→    }\n   190→    return bigintToIndices(bestSolnBigint, numCols);\n   191→\n   192→  } else {\n   193→    // Meet in the middle for numFree > 20\n   194→    // Split free vars into two halves\n   195→    const halfA = Math.min(numFree, Math.floor(numFree / 2));\n   196→    const halfB = numFree - halfA;\n   197→    const sizeA = 1 << halfA;\n   198→    const sizeB = 1 << halfB;\n   199→\n   200→    // For each half-A assignment, compute the \"signature\" = effect on pivots\n   201→    // and the cost contribution.\n   202→    // Signature: for each pivot, parity(pivotFreeMask[p] & freeMaskA) - this is a rank-bit number\n   203→    // Cost from A = popcount(freeMaskA) + contribution to pivots from A\n   204→\n   205→    // But pivots depend on BOTH halves. Let's think differently.\n   206→    // For pivot p: value = pivotAug[p] XOR parityA(p) XOR parityB(p)\n   207→    // where parityA = parity of (pivotFreeMask[p] & freeMaskA) for bits in half A\n   208→    // and parityB = parity of (pivotFreeMask[p] & freeMaskB_shifted) for bits in half B\n   209→\n   210→    // Total cost = popcountA + popcountB + sum_p (pivotAug[p] XOR parityA(p) XOR parityB(p))\n   211→    // = (popcountA + sum_p (pivotAug[p] XOR parityA(p))) + popcountB + adjustment for B\n   212→\n   213→    // This is complex. Let's use a simpler approach: enumerate all 2^halfA assignments,\n   214→    // for each compute the pivot parity signature (a rank-bit number) and cost.\n   215→    // Store in a map: signature -> (minCost, bestMask)\n   216→    // Then enumerate all 2^halfB assignments, compute signature, look up complement, combine.\n   217→\n   218→    // Pivot parity signature for half A: for each pivot p, parity(pivotFreeMask[p] & freeMaskA_in_lower_bits)\n   219→    // We only look at bits 0..halfA-1 of pivotFreeMask[p]\n   220→\n   221→    const pivotFreeMaskA: number[] = new Array(rank);\n   222→    const pivotFreeMaskB: number[] = new Array(rank);\n   223→    const maskABits = (1 << halfA) - 1;\n   224→\n   225→    for (let p = 0; p < rank; p++) {\n   226→      pivotFreeMaskA[p] = pivotFreeMask[p] & maskABits;\n   227→      pivotFreeMaskB[p] = pivotFreeMask[p] >> halfA;\n   228→    }\n   229→\n   230→    // For half A: compute signature and cost\n   231→    // signature_A[p] = parity(pivotFreeMaskA[p] & maskA) for each pivot\n   232→    // costA = popcount(maskA) (just the free vars in A)\n   233→    // We also need to track the pivot contributions, but they depend on both halves.\n   234→\n   235→    // The pivot p's value = pivotAug[p] XOR sigA[p] XOR sigB[p]\n   236→    // Total = popcountFreeA + popcountFreeB + sum_p (pivotAug[p] XOR sigA[p] XOR sigB[p])\n   237→    //       = popcountFreeA + popcountFreeB + sum_p pivotAug[p] XOR sum_p sigA[p] XOR sum_p sigB[p]\n   238→    // No, XOR doesn't distribute over sum like that. Each pivot contributes 0 or 1.\n   239→    // total = popcountFreeA + popcountFreeB + #{p: pivotAug[p] XOR sigA[p] XOR sigB[p] = 1}\n   240→    // = popcountFreeA + popcountFreeB + #{p: sigA[p] XOR sigB[p] = NOT pivotAug[p]}\n   241→    // Hmm, let's define targetSig[p] = pivotAug[p] (we want pivot to be 0, i.e., not pressed)\n   242→    // We want sigA[p] XOR sigB[p] = pivotAug[p] to make pivot = 0.\n   243→    // If they don't match, pivot is 1 (pressed, adding to cost).\n   244→    // So cost from pivots = #{p: sigA[p] XOR sigB[p] != pivotAug[p]}\n   245→    // = #{p: sigA[p] != pivotAug[p] XOR sigB[p]}\n   246→\n   247→    // Let's define: for half B, compute complementSig[p] = pivotAug[p] XOR sigB[p]\n   248→    // Then cost from pivots = #{p: sigA[p] != complementSig[p]} = Hamming distance\n   249→\n   250→    // Total = popcountFreeA + popcountFreeB + HammingDist(sigA, complementSigB)\n   251→\n   252→    // To minimize, for each sigA and complementSigB that are equal (HD=0),\n   253→    // total = popcountFreeA + popcountFreeB. Otherwise HD adds cost.\n   254→\n   255→    // Approach: for each half A assignment, compute (sigA as rank-bit number, popcountFreeA).\n   256→    // Store in map: sigA -> min popcountFreeA + associated maskA info\n   257→    // For each half B assignment, compute complementSigB, popcountFreeB.\n   258→    // Look up exact match first (HD=0), then HD=1, etc.\n   259→\n   260→    // For rank <= 40, signatures are up to 40-bit numbers.\n   261→\n   262→    // Build signature for an assignment\n   263→    const computeSig = (mask: number, pivotMasks: number[]): number => {\n   264→      let sig = 0;\n   265→      for (let p = 0; p < rank; p++) {\n   266→        if (popcount(pivotMasks[p] & mask) & 1) {\n   267→          sig |= 1 << p;\n   268→        }\n   269→      }\n   270→      return sig;\n   271→    };\n   272→\n   273→    // Phase 1: enumerate half A\n   274→    interface HalfEntry { cost: number; mask: number; fullSolnBits: bigint; }\n   275→    const mapA = new Map<number, HalfEntry[]>();\n   276→\n   277→    for (let maskA = 0; maskA < sizeA; maskA++) {\n   278→      const sigA = computeSig(maskA, pivotFreeMaskA);\n   279→      const costA = popcount(maskA);\n   280→      const entry: HalfEntry = { cost: costA, mask: maskA, fullSolnBits: 0n };\n   281→\n   282→      const arr = mapA.get(sigA);\n   283→      if (arr) arr.push(entry);\n   284→      else mapA.set(sigA, [entry]);\n   285→    }\n   286→\n   287→    // For each signature, keep only the best entries (min cost, then lex smallest)\n   288→    // Actually we need to consider combinations, so we should keep the minimum cost entry\n   289→    // and possibly the lex-smallest among those with min cost.\n   290→    // For correctness with lex ordering, we might need a few entries per signature.\n   291→    // But for performance, let's keep just the best one per signature.\n   292→    const bestMapA = new Map<number, HalfEntry>();\n   293→    for (const [sig, entries] of mapA) {\n   294→      let best = entries[0];\n   295→      for (let i = 1; i < entries.length; i++) {\n   296→        if (entries[i].cost < best.cost) best = entries[i];\n   297→      }\n   298→      bestMapA.set(sig, best);\n   299→    }\n   300→\n   301→    let bestTotal = numCols + 1;\n   302→    let bestFreeMaskA = 0;\n   303→    let bestFreeMaskB = 0;\n   304→\n   305→    // Phase 2: enumerate half B, find best combination\n   306→    for (let maskB = 0; maskB < sizeB; maskB++) {\n   307→      const sigB = computeSig(maskB, pivotFreeMaskB);\n   308→      const costB = popcount(maskB);\n   309→\n   310→      // We want sigA XOR sigB to equal pivotAugSig (the target signature for zero pivot cost)\n   311→      // pivotAugSig[p] = pivotAug[p], want sigA[p] XOR sigB[p] = pivotAug[p]\n   312→      // So sigA = pivotAugSig XOR sigB\n   313→      let pivotAugSig = 0;\n   314→      for (let p = 0; p < rank; p++) {\n   315→        if (pivotAug[p]) pivotAugSig |= 1 << p;\n   316→      }\n   317→\n   318→      // Try exact match (HD=0 from pivots)\n   319→      const targetSigA = pivotAugSig ^ sigB;\n   320→      const entryA = bestMapA.get(targetSigA);\n   321→      if (entryA) {\n   322→        const total = entryA.cost + costB;\n   323→        if (total < bestTotal) {\n   324→          bestTotal = total;\n   325→          bestFreeMaskA = entryA.mask;\n   326→          bestFreeMaskB = maskB;\n   327→        } else if (total === bestTotal) {\n   328→          // Need lex comparison\n   329→          const fullMask = entryA.mask | (maskB << halfA);\n   330→          const bestFullMask = bestFreeMaskA | (bestFreeMaskB << halfA);\n   331→          const solnNew = buildSolnBigint(fullMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n   332→          const solnBest = buildSolnBigint(bestFullMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n   333→          if (indexSetSmallerBigint(solnNew, solnBest)) {\n   334→            bestFreeMaskA = entryA.mask;\n   335→            bestFreeMaskB = maskB;\n   336→          }\n   337→        }\n   338→      }\n   339→\n   340→      // Also try HD=1 (flip each pivot bit) to find solutions with 1 extra pivot cost\n   341→      // Only needed if current best is > costB + min_costA + 1\n   342→      for (let p = 0; p < rank && costB + 1 <= bestTotal; p++) {\n   343→        const altSigA = targetSigA ^ (1 << p);\n   344→        const altEntryA = bestMapA.get(altSigA);\n   345→        if (altEntryA) {\n   346→          const total = altEntryA.cost + costB + 1; // +1 for the mismatched pivot\n   347→          if (total < bestTotal) {\n   348→            bestTotal = total;\n   349→            bestFreeMaskA = altEntryA.mask;\n   350→            bestFreeMaskB = maskB;\n   351→          } else if (total === bestTotal) {\n   352→            const fullMask = altEntryA.mask | (maskB << halfA);\n   353→            const bestFullMask = bestFreeMaskA | (bestFreeMaskB << halfA);\n   354→            const solnNew = buildSolnBigint(fullMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n   355→            const solnBest = buildSolnBigint(bestFullMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n   356→            if (indexSetSmallerBigint(solnNew, solnBest)) {\n   357→              bestFreeMaskA = altEntryA.mask;\n   358→              bestFreeMaskB = maskB;\n   359→            }\n   360→          }\n   361→        }\n   362→      }\n   363→\n   364→      // For higher HD, we'd need to enumerate more, but for 40 buttons\n   365→      // the HD is bounded by rank <= 40. In practice, exact + HD=1 covers most cases.\n   366→      // For full correctness, we need to check all possible HDs.\n   367→      // But HD=k means k extra presses, so we only need to check up to bestTotal - costB - minCostA\n   368→    }\n   369→\n   370→    // Actually the meet-in-the-middle above isn't complete for all HDs.\n   371→    // Let me use a full enumeration approach that's correct but optimized.\n   372→    // Since we have the map, let's check all signatures in mapA against each B.\n   373→\n   374→    // Reset and do it properly if needed\n   375→    // For correctness, enumerate all combinations\n   376→    if (bestTotal > numCols) {\n   377→      // Fallback: try all-zero free vars\n   378→      const sol0 = buildSolnBigint(0, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);\n   379→      let count0 = 0;\n   380→      for (let p = 0; p < rank; p++) count0 += pivotAug[p];\n   381→      if (count0 < bestTotal) {\n   382→        bestTotal = count0;\n   383→        bestFreeMaskA = 0;\n   384→        bestFreeMaskB = 0;\n   385→      }\n   386→    }\n   387→\n   388→    // For completeness, try all B x best-per-sig-A combinations\n   389→    for (let maskB = 0; maskB < sizeB; maskB++) {\n   390→      const sigB = computeSig(maskB, pivotFreeMaskB);\n   391→      const costB = popcount(maskB);\n   392→\n   393→      if (costB >= bestTotal) continue; // Can't improve\n   394→\n   395→      for (const [sigA, entryA] of bestMapA) {\n   396→        const costA = entryA.cost;\n   397→        if (costA + costB >= bestTotal) continue;\n   398→\n   399→        // Count mismatched pivots\n   400→        let pivotAugSig = 0;\n   401→        for (let p = 0; p < rank; p++) {\n   402→          if (pivotAug[p]) pivotAugSig |= 1 << p;\n   403→        }\n   404→        const mismatch = popcount((sigA ^ sigB) ^ pivotAugS