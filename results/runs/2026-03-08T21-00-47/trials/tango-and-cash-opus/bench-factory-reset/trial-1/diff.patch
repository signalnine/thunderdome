 pivotCol: number[] = []; // pivotCol[row] = column index of pivot, or -1\n  const pivotRow: number[] = new Array(numCols).fill(-1); // pivotRow[col] = row index where this col is pivot\n  let currentRow = 0;\n\n  for (let col = 0; col < numCols && currentRow < numRows; col++) {\n    // Find pivot row\n    let pivot = -1;\n    for (let row = currentRow; row < numRows; row++) {\n      if (matrix[row][col] === 1) {\n        pivot = row;\n        break;\n      }\n    }\n    if (pivot === -1) continue;\n\n    // Swap rows\n    if (pivot !== currentRow) {\n      const tmp = matrix[currentRow];\n      matrix[currentRow] = matrix[pivot];\n      matrix[pivot] = tmp;\n      const tmpAug = augmented[currentRow];\n      augmented[currentRow] = augmented[pivot];\n      augmented[pivot] = tmpAug;\n    }\n\n    pivotRow[col] = currentRow;\n    pivotCol.push(col);\n\n    // Eliminate other rows\n    for (let row = 0; row < numRows; row++) {\n      if (row !== currentRow && matrix[row][col] === 1) {\n        for (let c = 0; c < numCols; c++) {\n          matrix[row][c] ^= matrix[currentRow][c];\n        }\n        augmented[row] ^= augmented[currentRow];\n      }\n    }\n    currentRow++;\n  }\n\n  // Check for inconsistency: any row with all zeros but augmented = 1\n  for (let row = currentRow; row < numRows; row++) {\n    if (augmented[row] === 1) return null;\n  }\n\n  // Identify free variables (columns not in pivot positions)\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numCols; col++) {\n    if (!pivotColSet.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Find best solution by enumerating free variable assignments\n  // For each assignment of free variables, compute the solution and count presses\n  let bestSolution: number[] | null = null;\n  let bestCount = numCols + 1;\n\n  // If too many free variables, we need a smarter approach\n  // With up to 40 buttons, we could