+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function popcount(n: number): number {
+  n = n - ((n >> 1) & 0x55555555);
+  n = (n & 0x33333333) + ((n >> 2) & 0x33333333);
+  return (((n + (n >> 4)) & 0x0f0f0f0f) * 0x01010101) >> 24;
+}
+
+/**
+ * Solve toggle puzzle using Gaussian elimination over GF(2).
+ * Uses bitmask representation for efficiency with many free variables.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numButtons = buttons.length;
+  const numLights = target.length;
+
+  if (target.every((t) => !t)) return [];
+  if (numButtons === 0) return null;
+
+  // We form the system: for each light j, sum_{i: j in buttons[i]} x_i = target[j] (mod 2)
+  // Rows = lights (equations), Columns = buttons (variables)
+  // We use bitmask rows where bit i represents button/column i.
+  // Since numButtons <= 40, we need BigInt or two 32-bit ints. We'll use BigInt for simplicity.
+
+  const numRows = numLights;
+  const numCols = numButtons;
+
+  // Build matrix rows as bigints (each bit = a column/button)
+  const rows: bigint[] = [];
+  const aug: number[] = [];
+
+  for (let j = 0; j < numRows; j++) {
+    rows.push(0n);
+    aug.push(target[j] ? 1 : 0);
+  }
+
+  for (let i = 0; i < numCols; i++) {
+    for (const lightIdx of buttons[i]) {
+      if (lightIdx < numRows) {
+        rows[lightIdx] |= 1n << BigInt(i);
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotCols: number[] = [];
+  const pivotRowForCol: number[] = new Array(numCols).fill(-1);
+  let curRow = 0;
+
+  for (let col = 0; col < numCols && curRow < numRows; col++) {
+    const colBit = 1n << BigInt(col);
+    let pivotIdx = -1;
+    for (let row = curRow; row < numRows; row++) {
+      if (rows[row] & colBit) {
+        pivotIdx = row;
+        break;
+      }
+    }
+    if (pivotIdx === -1) continue;
+
+    // Swap
+    if (pivotIdx !== curRow) {
+      [rows[curRow], rows[pivotIdx]] = [rows[pivotIdx], rows[curRow]];
+      [aug[curRow], aug[pivotIdx]] = [aug[pivotIdx], aug[curRow]];
+    }
+
+    pivotRowForCol[col] = curRow;
+    pivotCols.push(col);
+
+    // Eliminate
+    for (let row = 0; row < numRows; row++) {
+      if (row !== curRow && (rows[row] & colBit)) {
+        rows[row] ^= rows[curRow];
+        aug[row] ^= aug[curRow];
+      }
+    }
+    curRow++;
+  }
+
+  // Check inconsistency
+  for (let row = curRow; row < numRows; row++) {
+    if (aug[row] === 1) return null;
+  }
+
+  // Free variables
+  const pivotColSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numCols; col++) {
+    if (!pivotColSet.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+  const rank = pivotCols.length;
+
+  // For each pivot variable, precompute which free variables affect it
+  // After RREF, pivot variable col's row has: x_col + sum(matrix[row][freeCol] * x_freeCol) = aug[row]
+  // So x_col = aug[row] XOR (sum of free var contributions)
+  // We represent the free var contributions as a bitmask over free var indices
+  const pivotAug: number[] = new Array(rank).fill(0); // aug value for each pivot row
+  const pivotFreeMask: number[] = new Array(rank).fill(0); // which free vars affect this pivot
+
+  for (let p = 0; p < rank; p++) {
+    const col = pivotCols[p];
+    const row = pivotRowForCol[col];
+    pivotAug[p] = aug[row];
+    let mask = 0;
+    for (let f = 0; f < numFree; f++) {
+      if (rows[row] & (1n << BigInt(freeVars[f]))) {
+        mask |= 1 << f;
+      }
+    }
+    pivotFreeMask[p] = mask;
+  }
+
+  // For a given free variable assignment (as a bitmask over free vars),
+  // the total number of button presses = popcount(freeMask) + sum of pivot values
+  // pivot value p = pivotAug[p] XOR popcount(pivotFreeMask[p] & freeMask) % 2
+  //              = pivotAug[p] XOR parity(pivotFreeMask[p] & freeMask)
+
+  // We need to find freeMask that minimizes total presses.
+  // total = popcount(freeMask) + sum_p (pivotAug[p] XOR parity(pivotFreeMask[p] & freeMask))
+
+  // For the base solution (freeMask = 0):
+  // total = 0 + sum_p pivotAug[p]
+
+  // Toggling free variable f flips pivot p if bit f is set in pivotFreeMask[p].
+  // So toggling f: cost changes by +1 (for the free var itself)
+  //   and for each pivot p where f is in its mask: if pivot was 1, it becomes 0 (saves 1),
+  //   if pivot was 0, it becomes 1 (costs 1).
+
+  if (numFree <= 20) {
+    // Direct enumeration - up to 2^20 = 1M, very fast
+    let bestMask = 0;
+    let bestTotal = numCols + 1;
+    let bestSolnBigint = 0n;
+
+    const totalCombinations = 1 << numFree;
+
+    for (let freeMask = 0; freeMask < totalCombinations; freeMask++) {
+      let total = popcount(freeMask);
+
+      for (let p = 0; p < rank; p++) {
+        const pivotVal = pivotAug[p] ^ (popcount(pivotFreeMask[p] & freeMask) & 1);
+        total += pivotVal;
+      }
+
+      if (total < bestTotal) {
+        bestTotal = total;
+        bestMask = freeMask;
+        bestSolnBigint = 0n; // placeholder, will compute later
+      } else if (total === bestTotal) {
+        // Compare index sets: build solution bigint and compare
+        const solnA = buildSolnBigint(freeMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);
+        if (bestSolnBigint === 0n && bestMask !== freeMask) {
+          bestSolnBigint = buildSolnBigint(bestMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);
+        }
+        // For index sets, the lex smaller set has the smallest first element.
+        // As a bitmask, this means the lowest set bit should be lower.
+        // Comparing bigints directly: lower bigint doesn't mean lex smaller index set.
+        // We need to compare which has the lower first set bit, then second, etc.
+        // Actually for same count, comparing the bitmasks as numbers where lower bit positions
+        // are more significant... we want the set with smallest elements.
+        // bitmask comparison: if we treat bit 0 as most significant, we want the one
+        // that has bit 0 set first. So we need to compare by "reverse bit significance".
+        // Simplest: compare solution bigints where lower bits have priority.
+        // Actually, lex order on index sets [a0,a1,...] < [b0,b1,...] iff
+        // at first difference, a_k < b_k. This is equivalent to:
+        // the set with the smallest first element that isn't in the other set.
+        // If a has a lower first differing element, a's set is smaller.
+        // For bitmasks: find lowest bit where they differ. If that bit is set in a but not b,
+        // then a has that smaller element -> a is lex smaller.
+        if (indexSetSmallerBigint(solnA, bestSolnBigint)) {
+          bestTotal = total;
+          bestMask = freeMask;
+          bestSolnBigint = solnA;
+        }
+      }
+    }
+
+    // Build final solution
+    if (bestSolnBigint === 0n) {
+      bestSolnBigint = buildSolnBigint(bestMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);
+    }
+    return bigintToIndices(bestSolnBigint, numCols);
+
+  } else {
+    // Meet in the middle for numFree > 20
+    // Key insight: numFree > 20 implies rank = numButtons - numFree < 20
+    // So there are at most 2^rank < 2^20 distinct signatures.
+    // Split free vars into two halves, enumerate A into a map by signature,
+    // then for each B, scan all map entries (bounded by 2^rank).
+
+    const halfA = Math.floor(numFree / 2);
+    const halfB = numFree - halfA;
+    const sizeA = 1 << halfA;
+    const sizeB = 1 << halfB;
+
+    const pivotFreeMaskA: number[] = new Array(rank);
+    const pivotFreeMaskB: number[] = new Array(rank);
+    const maskABits = (1 << halfA) - 1;
+
+    for (let p = 0; p < rank; p++) {
+      pivotFreeMaskA[p] = pivotFreeMask[p] & maskABits;
+      pivotFreeMaskB[p] = pivotFreeMask[p] >> halfA;
+    }
+
+    let pivotAugSig = 0;
+    for (let p = 0; p < rank; p++) {
+      if (pivotAug[p]) pivotAugSig |= 1 << p;
+    }
+
+    const computeSig = (mask: number, pivotMasks: number[]): number => {
+      let sig = 0;
+      for (let p = 0; p < rank; p++) {
+        if (popcount(pivotMasks[p] & mask) & 1) {
+          sig |= 1 << p;
+        }
+      }
+      return sig;
+    };
+
+    // Phase 1: enumerate half A, keep best per signature
+    // For a given sigA, the total is costA + costB + popcount(sigA ^ sigB ^ pivotAugSig)
+    // For a given sigA, we want the minimum costA. Among those, the smallest maskA for lex tiebreak.
+    interface HalfEntry { cost: number; mask: number; sig: number; }
+    const mapA = new Map<number, HalfEntry>();
+
+    for (let maskA = 0; maskA < sizeA; maskA++) {
+      const sigA = computeSig(maskA, pivotFreeMaskA);
+      const costA = popcount(maskA);
+      const existing = mapA.get(sigA);
+      if (!existing || costA < existing.cost) {
+        mapA.set(sigA, { cost: costA, mask: maskA, sig: sigA });
+      }
+    }
+
+    // Convert map to array for faster iteration
+    const mapAEntries: HalfEntry[] = Array.from(mapA.values());
+
+    let bestTotal = numCols + 1;
+    let bestFreeMask = 0;
+
+    // Phase 2: enumerate half B, for each scan all A entries
+    for (let maskB = 0; maskB < sizeB; maskB++) {
+      const sigB = computeSig(maskB, pivotFreeMaskB);
+      const costB = popcount(maskB);
+
+      if (costB >= bestTotal) continue;
+
+      const targetXor = sigB ^ pivotAugSig;
+
+      for (let ai = 0; ai < mapAEntries.length; ai++) {
+        const ea = mapAEntries[ai];
+        if (ea.cost + costB >= bestTotal) continue;
+
+        const pivotCost = popcount(ea.sig ^ targetXor);
+        const total = ea.cost + costB + pivotCost;
+
+        if (total < bestTotal) {
+          bestTotal = total;
+          bestFreeMask = ea.mask | (maskB << halfA);
+        } else if (total === bestTotal) {
+          const newMask = ea.mask | (maskB << halfA);
+          const solnNew = buildSolnBigint(newMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);
+          const solnBest = buildSolnBigint(bestFreeMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);
+          if (indexSetSmallerBigint(solnNew, solnBest)) {
+            bestFreeMask = newMask;
+          }
+        }
+      }
+    }
+
+    // Fallback if no solution found (shouldn't happen if system is consistent)
+    if (bestTotal > numCols) {
+      bestFreeMask = 0;
+      bestTotal = 0;
+      for (let p = 0; p < rank; p++) bestTotal += pivotAug[p];
+    }
+
+    const bestSoln = buildSolnBigint(bestFreeMask, freeVars, pivotCols, pivotAug, pivotFreeMask, rank);
+    return bigintToIndices(bestSoln, numCols);
+  }
+}
+
+function buildSolnBigint(
+  freeMask: number,
+  freeVars: number[],
+  pivotCols: number[],
+  pivotAug: number[],
+  pivotFreeMask: number[],
+  rank: number
+): bigint {
+  let soln = 0n;
+  // Set free variables
+  for (let f = 0; f < freeVars.length; f++) {
+    if (freeMask & (1 << f)) {
+      soln |= 1n << BigInt(freeVars[f]);
+    }
+  }
+  // Compute pivot variables
+  for (let p = 0; p < rank; p++) {
+    const val = pivotAug[p] ^ (popcount(pivotFreeMask[p] & freeMask) & 1);
+    if (val) {
+      soln |= 1n << BigInt(pivotCols[p]);
+    }
+  }
+  return soln;
+}
+
+function bigintToIndices(soln: bigint, numCols: number): number[] {
+  const result: number[] = [];
+  for (let i = 0; i < numCols; i++) {
+    if (soln & (1n << BigInt(i))) {
+      result.push(i);
+    }
+  }
+  return result;
+}
+
+function indexSetSmallerBigint(a: bigint, b: bigint): boolean {
+  // For index sets represented as bitmasks:
+  // The lex-smaller set has the smallest element that's in one but not the other.
+  // Find the lowest bit where a and b differ.
+  // If that bit is set in a (and not b), a has that element -> a's set is lex smaller.
+  const diff = a ^ b;
+  if (diff === 0n) return false;
+  const lowestDiff = diff & (-diff); // lowest set bit of diff
+  return (a & lowestDiff) !== 0n;
+}
+
+/**
+ * Compute modular inverse using Fermat's little theorem: a^(p-2) mod p
+ */
+function modInverse(a: number, p: number): number {
+  a = ((a % p) + p) % p;
+  if (a === 0) return 0;
+  let result = 1;
+  let base = a;
+  let exp = p - 2;
+  while (exp > 0) {
+    if (exp & 1) result = (result * base) % p;
+    base = (base * base) % p;
+    exp >>= 1;
+  }
+  return result;
+}
+
+/**
+ * Solve counter puzzle using Gaussian elimination over GF(p).
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numButtons = buttons.length;
+  const numLights = lights.length;
+
+  if (lights.every((t) => t === 0)) return new Array(numButtons).fill(0);
+  if (numButtons === 0) return null;
+
+  const mod = modulus;
+  const numRows = numLights;
+  const numCols = numButtons;
+
+  // Build augmented matrix over GF(mod)
+  const matrix: number[][] = [];
+  const augmented: number[] = [];
+
+  for (let j = 0; j < numRows; j++) {
+    matrix.push(new Array(numCols).fill(0));
+    augmented.push(((lights[j] % mod) + mod) % mod);
+  }
+
+  for (let i = 0; i < numCols; i++) {
+    for (const lightIdx of buttons[i]) {
+      if (lightIdx < numRows) {
+        matrix[lightIdx][i] = (matrix[lightIdx][i] + 1) % mod;
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(mod)
+  const pivotCols: number[] = [];
+  const pivotRowForCol: number[] = new Array(numCols).fill(-1);
+  let currentRow = 0;
+
+  for (let col = 0; col < numCols && currentRow < numRows; col++) {
+    let pivot = -1;
+    for (let row = currentRow; row < numRows; row++) {
+      if (matrix[row][col] !== 0) {
+        pivot = row;
+        break;
+      }
+    }
+    if (pivot === -1) continue;
+
+    if (pivot !== currentRow) {
+      [matrix[currentRow], matrix[pivot]] = [matrix[pivot], matrix[currentRow]];
+      [augmented[currentRow], augmented[pivot]] = [augmented[pivot], augmented[currentRow]];
+    }
+
+    const inv = modInverse(matrix[currentRow][col], mod);
+    for (let c = 0; c < numCols; c++) {
+      matrix[currentRow][c] = (matrix[currentRow][c] * inv) % mod;
+    }
+    augmented[currentRow] = (augmented[currentRow] * inv) % mod;
+
+    pivotRowForCol[col] = currentRow;
+    pivotCols.push(col);
+
+    for (let row = 0; row < numRows; row++) {
+      if (row !== currentRow && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let c = 0; c < numCols; c++) {
+          matrix[row][c] = ((matrix[row][c] - factor * matrix[currentRow][c]) % mod + mod) % mod;
+        }
+        augmented[row] = ((augmented[row] - factor * augmented[currentRow]) % mod + mod) % mod;
+      }
+    }
+    currentRow++;
+  }
+
+  // Check inconsistency
+  for (let row = currentRow; row < numRows; row++) {
+    if (augmented[row] !== 0) return null;
+  }
+
+  // Free variables
+  const pivotColSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numCols; col++) {
+    if (!pivotColSet.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+  const rank = pivotCols.length;
+
+  // For each pivot, precompute coefficients for free variables
+  // After RREF: x_pivotCol = aug[row] - sum(matrix[row][freeCol] * x_freeCol) mod p
+  const pivotAugVals: number[] = new Array(rank);
+  const pivotFreeCoeffs: number[][] = new Array(rank);
+
+  for (let p = 0; p < rank; p++) {
+    const col = pivotCols[p];
+    const row = pivotRowForCol[col];
+    pivotAugVals[p] = augmented[row];
+    pivotFreeCoeffs[p] = new Array(numFree);
+    for (let f = 0; f < numFree; f++) {
+      pivotFreeCoeffs[p][f] = matrix[row][freeVars[f]];
+    }
+  }
+
+  const computeSolution = (freeAssign: number[]): number[] => {
+    const solution = new Array(numCols).fill(0);
+    for (let f = 0; f < numFree; f++) {
+      solution[freeVars[f]] = freeAssign[f];
+    }
+    for (let p = 0; p < rank; p++) {
+      let val = pivotAugVals[p];
+      for (let f = 0; f < numFree; f++) {
+        val = ((val - pivotFreeCoeffs[p][f] * freeAssign[f]) % mod + mod * mod) % mod;
+      }
+      solution[pivotCols[p]] = val % mod;
+    }
+    return solution;
+  };
+
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+
+  const lexSmallerArr = (a: number[], b: number[]): boolean => {
+    for (let i = 0; i < a.length; i++) {
+      if (a[i] < b[i]) return true;
+      if (a[i] > b[i]) return false;
+    }
+    return false;
+  };
+
+  const updateBest = (solution: number[]) => {
+    const sum = solution.reduce((s, v) => s + v, 0);
+    if (sum < bestSum || (sum === bestSum && lexSmallerArr(solution, bestSolution!))) {
+      bestSum = sum;
+      bestSolution = [...solution];
+    }
+  };
+
+  const totalCombinations = Math.pow(mod, numFree);
+
+  if (numFree === 0 || totalCombinations <= 200000) {
+    // Direct enumeration
+    const freeAssign = new Array(numFree).fill(0);
+    for (let iter = 0; iter < totalCombinations; iter++) {
+      updateBest(computeSolution(freeAssign));
+
+      for (let i = 0; i < numFree; i++) {
+        freeAssign[i]++;
+        if (freeAssign[i] < mod) break;
+        freeAssign[i] = 0;
+      }
+    }
+  } else {
+    // Coordinate descent heuristic: optimize one free var at a time
+    const freeAssign = new Array(numFree).fill(0);
+
+    // Multiple passes of coordinate descent
+    for (let pass = 0; pass < 3; pass++) {
+      for (let f = 0; f < numFree; f++) {
+        let bestVal = freeAssign[f];
+        let bestLocalSum = Infinity;
+
+        for (let v = 0; v < mod; v++) {
+          freeAssign[f] = v;
+          const sol = computeSolution(freeAssign);
+          const sum = sol.reduce((s, val) => s + val, 0);
+          if (sum < bestLocalSum) {
+            bestLocalSum = sum;
+            bestVal = v;
+          }
+        }
+        freeAssign[f] = bestVal;
+      }
+      updateBest(computeSolution(freeAssign));
+    }
+
+    // Also try starting from different initial points
+    for (let startVal = 0; startVal < mod; startVal++) {
+      const assign = new Array(numFree).fill(startVal);
+      for (let pass = 0; pass < 2; pass++) {
+        for (let f = 0; f < numFree; f++) {
+          let bestVal = assign[f];
+          let bestLocalSum = Infinity;
+          for (let v = 0; v < mod; v++) {
+            assign[f] = v;
+            const sol = computeSolution(assign);
+            const sum = sol.reduce((s, val) => s + val, 0);
+            if (sum < bestLocalSum) {
+              bestLocalSum = sum;
+              bestVal = v;
+            }
+          }
+          assign[f] = bestVal;
+        }
+        updateBest(computeSolution(assign));
+      }
+    }
+  }
+
+  return bestSolution;
+}
