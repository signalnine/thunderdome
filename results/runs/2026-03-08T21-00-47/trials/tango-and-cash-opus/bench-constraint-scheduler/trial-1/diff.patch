+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_014TV61NbGKaVRcYjhepBUXV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01McmMLta8xgxbjW6gouDmyK","name":"Write","input":{"file_path":"/workspace/src/index.ts","content":"export interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\nfunction detectCycles(events: Event[]): void {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const WHITE = 0, GRAY = 1, BLACK = 2;\n  const color = new Map<string, number>();\n  for (const e of events) {\n    color.set(e.id, WHITE);\n  }\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const preId of event.prerequisites) {\n        const c = color.get(preId);\n        if (c === GRAY) {\n          throw new Error(`Prerequisite cycle detected involving event \"${preId}\"`);\n        }\n        if (c === WHITE) {\n          dfs(preId);\n        }\n      }\n    }\n    color.set(id, BLACK);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id);\n    }\n  }\n}\n\nfunction topologicalSort(events: Event[]): string[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const inDegree = new Map<string, number>();\n  for (const e of events) {\n    if (!inDegree.has(e.id)) inDegree.set(e.id, 0);\n    if (e.prerequisites) {\n      for (const preId of e.prerequisites) {\n        // Only count in-degree for prerequisites that exist in our event list\n        if (eventMap.has(preId)) {\n          inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);\n        }\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const result: string[] = [];\n  while (queue.length > 0) {\n    const id = queue.shift()!;\n    result.push(id);\n\n    for (const e of events) {\n      if (e.prerequisites?.includes(id) && eventMap.has(e.id)) {\n        const newDeg = (inDegree.get(e.id) ?? 1) - 1;\n        inDegree.set(e.id, newDeg);\n        if (newDeg === 0) {\n          queue.push(e.id);\n        }\n      }\n    }\n  }\n\n  return result;\n}\n\ninterface RoomSlot {\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nfunction getEarliestStartInRoom(\n  roomId: string,\n  duration: number,\n  earliestStart: number,\n  windowEnd: number,\n  roomAssignments: Map<string, Assignment[]>,\n  gap: number\n): number | null {\n  const assignments = roomAssignments.get(roomId) ?? [];\n  // Sort existing assignments by start time\n  const sorted = [...assignments].sort((a, b) => a.startTime - b.startTime);\n\n  // Try to fit at earliestStart\n  let candidate = earliestStart;\n\n  // Check against all existing assignments\n  for (const a of sorted) {\n    // Check if candidate slot overlaps with existing assignment (including gap)\n    const candidateEnd = candidate + duration;\n    if (candidateEnd + gap <= a.startTime || candidate >= a.endTime + gap) {\n      // No conflict with this assignment\n      continue;\n    }\n    // Conflict - move candidate after this assignment + gap\n    candidate = a.endTime + gap;\n  }\n\n  const candidateEnd = candidate + duration;\n  if (candidateEnd <= windowEnd) {\n    return candidate;\n  }\n  return null;\n}\n\nfunction findBestSlot(\n  event: Event,\n  rooms: Room[],\n  options: ScheduleOptions,\n  roomAssignments: Map<string, Assignment[]>,\n  eventAssignments: Map<string, Assignment>,\n  gap: number\n): RoomSlot | null {\n  const attendees = event.attendees ?? 1;\n\n  // Calculate earliest possible start based on prerequisites\n  let earliestStart = options.startTime;\n  if (event.prerequisites) {\n    for (const preId of event.prerequisites) {\n      const preAssignment = eventAssignments.get(preId);\n      if (preAssignment) {\n        const preEnd = preAssignment.endTime + gap;\n        if (preEnd > earliestStart) {\n          earliestStart = preEnd;\n        }\n      }\n      // If prerequisite isn't scheduled yet, it means it was in a different\n      // set or couldn't be scheduled - we still proceed\n    }\n  }\n\n  const eligibleRooms = rooms.filter(r => r.capacity >= attendees);\n  if (eligibleRooms.length === 0) return null;\n\n  // Try preferred room first\n  let bestSlot: RoomSlot | null = null;\n\n  if (event.preferredRoom) {\n    const preferred = eligibleRooms.find(r => r.id === event.preferredRoom);\n    if (preferred) {\n      const start = getEarliestStartInRoom(\n        preferred.id, event.duration, earliestStart, options.endTime,\n        roomAssignments, gap\n      );\n      if (start !== null) {\n        bestSlot = { roomId: preferred.id, startTime: start, endTime: start + event.duration };\n      }\n    }\n  }\n\n  // Try all eligible rooms and pick the one with earliest start\n  for (const room of eligibleRooms) {\n    if (bestSlot && room.id === event.preferredRoom) continue; // already tried\n    const start = getEarliestStartInRoom(\n      room.id, event.duration, earliestStart, options.endTime,\n      roomAssignments, gap\n    );\n    if (start !== null) {\n      if (!bestSlot || start < bestSlot.startTime) {\n        // Prefer the preferred room if it has the same start time\n        bestSlot = { roomId: room.id, startTime: start, endTime: start + event.duration };\n      }\n    }\n  }\n\n  // If preferred room has a valid slot, prefer it unless another room is significantly earlier\n  if (event.preferredRoom && bestSlot) {\n    const preferred = eligibleRooms.find(r => r.id === event.preferredRoom);\n    if (preferred) {\n      const prefStart = getEarliestStartInRoom(\n        preferred.id, event.duration, earliestStart, options.endTime,\n        roomAssignments, gap\n      );\n      if (prefStart !== null && prefStart === bestSlot.startTime) {\n        bestSlot = { roomId: preferred.id, startTime: prefStart, endTime: prefStart + event.duration };\n      }\n    }\n  }\n\n  return bestSlot;\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  const gap = options.gap ?? 15;\n\n  // Detect cycles first\n  detectCycles(events);\n\n  if (events.length === 0 || rooms.length === 0) {\n    return {\n      assignments: [],\n      unscheduled: events.map(e => e.id),\n    };\n  }\n\n  // Topological sort to respect prerequisites\n  const sortedIds = topologicalSort(events);\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Use backtracking to maximize scheduled events\n  const roomAssignments = new Map<string, Assignment[]>();\n  for (const r of rooms) {\n    roomAssignments.set(r.id, []);\n  }\n  const eventAssignments = new Map<string, Assignment>();\n  const assignments: Assignment[] = [];\n  const unscheduled: string[] = [];\n\n  // Sort events by constraints: more constrained first (more prerequisites, larger attendees, longer duration)\n  const sortedEvents = sortedIds.map(id => eventMap.get(id)!);\n\n  // Greedy scheduling in topological order - try to fit each event\n  for (const event of sortedEvents) {\n    const slot = findBestSlot(event, rooms, options, roomAssignments, eventAssignments, gap);\n    if (slot) {\n      const assignment: Assignment = {\n        eventId: event.id,\n        roomId: slot.roomId,\n        startTime: slot.startTime,\n        endTime: slot.endTime,\n      };\n      assignments.push(assignment);\n      eventAssignments.set(event.id, assignment);\n      const ra = roomAssignments.get(slot.roomId)!;\n      ra.push(assignment);\n    } else {\n      unscheduled.push(event.id);\n    }\n  }\n\n  // Handle events not in topological sort (shouldn't happen after cycle detection but safety net)\n  const scheduledIds = new Set([...assignments.map(a => a.eventId), ...unscheduled]);\n  for (const e of events) {\n    if (!scheduledIds.has(e.id)) {\n      unscheduled.push(e.id);\n    }\n  }\n\n  return { assignments, unscheduled };\n}\n\nexport default schedule;\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":920,"cache_read_input_tokens":23621,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":920},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a3c3cf3f-df57-432b-b5ca-5be3371a9fcd","uuid":"2835433f-d432-4a89-87df-d9aeee3b3a3e"}
