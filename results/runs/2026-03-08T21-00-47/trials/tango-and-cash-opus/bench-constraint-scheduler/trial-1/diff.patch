 = {\n    startTime: 540, // 9:00 AM\n    endTime: 1020,  // 5:00 PM\n    gap: 15\n  };\n\n  it('detects cycles and throws', () => {\n    const events: Event[] = [\n      { id: '1', name: 'A', duration: 30, prerequisites: ['2'] },\n      { id: '2', name: 'B', duration: 30, prerequisites: ['1'] },\n    ];\n    const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n\n    expect(() => schedule(events, rooms, defaultOptions)).toThrowError(/cycle/i);\n  });\n\n  it('detects self-referential cycles', () => {\n    const events: Event[] = [\n      { id: '1', name: 'A', duration: 30, prerequisites: ['1'] }\n    ];\n    const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n\n    expect(() => schedule(events, rooms, defaultOptions)).toThrowError(/cycle/i);\n  });\n\n  it('schedules a simple event', () => {\n    const events: Event[] = [{ id: '1', name: 'A', duration: 60 }];\n    const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n    expect(result.unscheduled).toHaveLength(0);\n    expect(result.assignments[0]).toEqual({\n      eventId: '1',\n      roomId: 'R1',\n      startTime: 540,\n      endTime: 600\n    });\n  });\n\n  it('respects room capacity', () => {\n    const events: Event[] = [\n      { id: '1', name: 'A', duration: 60, attendees: 50 }\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Small', capacity: 10 },\n      { id: 'R2', name: 'Large', capacity: 100 }\n    ];\n\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n    expect(result.assignments[0].roomId).toBe('R2');\n  });\n\n  it('leaves events unscheduled if no room is large enough', () => {\n    const events: Event[] = [\n      { id: '1', name: 'A', duration: 60, attendees: 50 }\n    ];\n    const rooms: Room[] = [{ id: 'R1', name: 'Small', capacity: 10 }];\n\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toEqual(['1']);\n  });\n\n  it('respects prerequisites and their gaps', () => {\n    const events: Event[] = [\n      { id: '2', name: 'B', duration: 60, prerequisites: ['1'] },\n      { id: '1', name: 'A', duration: 60 }\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room 1', capacity: 10 },\n      { id: 'R2', name: 'Room 2', capacity: 10 }\n    ];\n\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(2);\n    \n    const a = result.assignments.find((x: Assignment) => x.eventId === '1')!;\n    const b = result.assignments.find((x: Assignment) => x.eventId === '2')!;\n    \n    expect(a.startTime).toBe(540);\n    expect(a.endTime).toBe(600);\n    expect(b.startTime).toBeGreaterThanOrEqual(a.endTime + 15);\n  });\n\n  it('respects gaps between events in the same room', () => {\n    const events: Event[] = [\n      { id: '1', name: 'A', duration: 60 },\n      { id: '2', name: 'B', duration: 60 }\n    ];\n    const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(2);\n    \n    const assignments = [...result.assignments].sort((a, b) => a.startTime - b.startTime);\n    expect(assignments[1].startTime).toBeGreaterThanOrEqual(assignments[0].endTime + 15);\n  });\n\n  it('honors preferredRoom if possible', () => {\n    const events: Event[] = [\n      { id: '1', name: 'A', duration: 60, preferredRoom: 'R2' }\n    ];\n    const rooms: Room[] = [\n      { id: 'R1', name: 'Room 1', capacity: 10 },\n      { id: 'R2', name: 'Room 2', capacity: 10 }\n    ];\n\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments[0].roomId).toBe('R2');\n  });\n\n  it('maximizes the number of scheduled events', () => {\n    const options: ScheduleOptions = { startTime: 540, endTime: 780, gap: 0 }; // 4 hours total\n    const events: Event[] = [\n      { id: 'Long', name: 'Long', duration: 240 },\n      { id: 'S1', name: 'S1', duration: 60 },\n      { id: 'S2', name: 'S2', duration: 60 },\n      { id: 'S3', name: 'S3', duration: 60 },\n      { id: 'S4', name: 'S4', duration: 60 }\n    ];\n    const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n\n    const result = schedule(events, rooms, options);\n    // It should pick the 4 short events instead of 1 long event\n    expect(result.assignments).toHaveLength(4);\n    expect(result.unscheduled).toEqual(['Long']);\n  });\n\n  it('leaves events unscheduled if they exceed the time window', () => {\n    const events: Event[] = [\n      { id: '1', name: 'A', duration: 600 } // 10 hours, window is 8 hours\n    ];\n    const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toEqual(['1']);\n  });\n});\n"}}
