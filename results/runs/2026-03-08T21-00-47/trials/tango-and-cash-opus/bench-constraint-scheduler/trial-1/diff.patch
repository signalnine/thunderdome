+++ b/src/__tests__/scheduler.test.ts
@@ -0,0 +1,409 @@
+import { describe, it, expect } from 'vitest';
+import { schedule, Event, Room, ScheduleOptions, Assignment } from '../index.js';
+
+describe('Constraint-Based Event Scheduler', () => {
+  const defaultOptions: ScheduleOptions = {
+    startTime: 540, // 9:00 AM
+    endTime: 1020,  // 5:00 PM
+    gap: 15
+  };
+
+  describe('cycle detection', () => {
+    it('detects A->B->A cycles and throws', () => {
+      const events: Event[] = [
+        { id: '1', name: 'A', duration: 30, prerequisites: ['2'] },
+        { id: '2', name: 'B', duration: 30, prerequisites: ['1'] },
+      ];
+      const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];
+
+      expect(() => schedule(events, rooms, defaultOptions)).toThrowError(/cycle/i);
+    });
+
+    it('detects self-referential cycles (A->A)', () => {
+      const events: Event[] = [
+        { id: '1', name: 'A', duration: 30, prerequisites: ['1'] }
+      ];
+      const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];
+
+      expect(() => schedule(events, rooms, defaultOptions)).toThrowError(/cycle/i);
+    });
+
+    it('detects longer cycles (A->B->C->A)', () => {
+      const events: Event[] = [
+        { id: '1', name: 'A', duration: 30, prerequisites: ['3'] },
+        { id: '2', name: 'B', duration: 30, prerequisites: ['1'] },
+        { id: '3', name: 'C', duration: 30, prerequisites: ['2'] },
+      ];
+      const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];
+
+      expect(() => schedule(events, rooms, defaultOptions)).toThrowError(/cycle/i);
+    });
+  });
+
+  describe('basic scheduling', () => {
+    it('schedules a simple event', () => {
+      const events: Event[] = [{ id: '1', name: 'A', duration: 60 }];
+      const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.unscheduled).toHaveLength(0);
+      expect(result.assignments[0]).toEqual({
+        eventId: '1',
+        roomId: 'R1',
+        startTime: 540,
+        endTime: 600
+      });
+    });
+
+    it('handles empty events array', () => {
+      const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];
+      const result = schedule([], rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toHaveLength(0);
+    });
+
+    it('handles empty rooms array', () => {
+      const events: Event[] = [{ id: '1', name: 'A', duration: 60 }];
+      const result = schedule(events, [], defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['1']);
+    });
+
+    it('defaults attendees to 1 when not specified', () => {
+      const events: Event[] = [{ id: '1', name: 'A', duration: 60 }];
+      const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 1 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+    });
+
+    it('defaults gap to 15 minutes when not specified', () => {
+      const events: Event[] = [
+        { id: '1', name: 'A', duration: 60 },
+        { id: '2', name: 'B', duration: 60 }
+      ];
+      const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];
+      const opts: ScheduleOptions = { startTime: 540, endTime: 1020 };
+
+      const result = schedule(events, rooms, opts);
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);
+    });
+  });
+
+  describe('room capacity', () => {
+    it('respects room capacity constraints', () => {
+      const events: Event[] = [
+        { id: '1', name: 'A', duration: 60, attendees: 50 }
+      ];
+      const rooms: Room[] = [
+        { id: 'R1', name: 'Small', capacity: 10 },
+        { id: 'R2', name: 'Large', capacity: 100 }
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(1);
+      expect(result.assignments[0].roomId).toBe('R2');
+    });
+
+    it('leaves events unscheduled if no room is large enough', () => {
+      const events: Event[] = [
+        { id: '1', name: 'A', duration: 60, attendees: 50 }
+      ];
+      const rooms: Room[] = [{ id: 'R1', name: 'Small', capacity: 10 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['1']);
+    });
+
+    it('all events unschedulable when no room has sufficient capacity', () => {
+      const events: Event[] = [
+        { id: '1', name: 'A', duration: 30, attendees: 100 },
+        { id: '2', name: 'B', duration: 30, attendees: 200 },
+      ];
+      const rooms: Room[] = [
+        { id: 'R1', name: 'Small', capacity: 10 },
+        { id: 'R2', name: 'Medium', capacity: 50 }
+      ];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toHaveLength(2);
+    });
+  });
+
+  describe('time window', () => {
+    it('leaves events unscheduled if they exceed the time window', () => {
+      const events: Event[] = [
+        { id: '1', name: 'A', duration: 600 } // 10 hours, window is 8 hours
+      ];
+      const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(0);
+      expect(result.unscheduled).toEqual(['1']);
+    });
+
+    it('events must end within the time window', () => {
+      const events: Event[] = [{ id: '1', name: 'A', duration: 60 }];
+      const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(defaultOptions.startTime);
+      expect(result.assignments[0].endTime).toBeLessThanOrEqual(defaultOptions.endTime);
+    });
+
+    it('events start at the beginning of the time window', () => {
+      const events: Event[] = [{ id: '1', name: 'A', duration: 60 }];
+      const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments[0].startTime).toBe(540);
+    });
+  });
+
+  describe('room gaps', () => {
+    it('enforces gaps between events in the same room', () => {
+      const events: Event[] = [
+        { id: '1', name: 'A', duration: 60 },
+        { id: '2', name: 'B', duration: 60 }
+      ];
+      const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];
+
+      const result = schedule(events, rooms, defaultOptions);
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);
+    });
+
+    it('uses custom gap value', () => {
+      const events: Event[] = [
+        { id: '1', name: 'A', duration: 60 },
+        { id: '2', name: 'B', duration: 60 }
+      ];
+      const rooms: Room[] = [{ id: 'R1', name: 'Room 1', capacity: 10 }];
+      const opts: ScheduleOptions = { startTime: 540, endTime: 1020, gap: 30 };
+
+      const result = schedule(events, rooms, opts);
+      expect(result.assignments).toHaveLength(2);
+
+      const sorted = [...result.assignments].sort((a, b) => a.startTime - b.startTime);
+      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);
+    });
+
+    it('supports zero gap', () => {
+      const events: Event[] = [
+        { id: '1', name: 'A', duration: 60 },
