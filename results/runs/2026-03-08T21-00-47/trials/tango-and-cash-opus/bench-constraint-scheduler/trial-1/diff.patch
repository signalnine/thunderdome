apacity: number;       // max attendees\n}\n\nexport interface ScheduleOptions {\n  startTime: number;      // minutes from midnight (e.g., 540 = 9:00 AM)\n  endTime: number;        // minutes from midnight (e.g., 1020 = 5:00 PM)\n  gap?: number;           // minimum gap in minutes between events in same room (default: 15)\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;      // minutes from midnight\n  endTime: number;        // minutes from midnight\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];  // event IDs that could not be scheduled\n}\n\nfunction checkCycles(events: Event[]) {\n  const adj = new Map<string, string[]>();\n  for (const e of events) {\n    adj.set(e.id, e.prerequisites || []);\n  }\n\n  const visited = new Set<string>();\n  const recStack = new Set<string>();\n\n  function dfs(node: string): boolean {\n    if (recStack.has(node)) return true;\n    if (visited.has(node)) return false;\n\n    visited.add(node);\n    recStack.add(node);\n\n    for (const neighbor of adj.get(node) || []) {\n      if (dfs(neighbor)) return true;\n    }\n\n    recStack.delete(node);\n    return false;\n  }\n\n  for (const e of events) {\n    if (dfs(e.id)) {\n      throw new Error(\"Prerequisite cycle detected\");\n    }\n  }\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  const gap = options.gap !== undefined ? options.gap : 15;\n\n  checkCycles(events);\n\n  let bestAssignments: Assignment[] = [];\n\n  const outDegree = new Map<string, number>();\n  for (const e of events) {\n    for (const req of e.prerequisites || []) {\n      outDegree.set(req, (outDegree.get(req) || 0) + 1);\n    }\n  }\n\n  const sortedEvents = [...events].sort((a, b) => {\n    const aOut = outDegree.get(a.id) || 0;\n    const bOut = outDegree.get(b.id) || 0;\n    if (aOut !== bOut) return bOut - aOut;\n    return a.duration - b.duration;\n  });\n\n  const maxPossible = events.length;\n  let statesExplored = 0;\n  const MAX_STATES = 100000;\n\n  function solve(remainingEvents: Event[], currentAssignments: Assignment[]): boolean {\n    if (statesExplored++ > MAX_STATES) return false;\n\n    if (currentAssignments.length > bestAssignments.length) {\n      bestAssignments = [...currentAssignments];\n    }\n\n    if (currentAssignments.length === maxPossible) {\n      return true;\n    }\n\n    if (currentAssignments.length + remainingEvents.length <= bestAssignments.length) {\n      return false;\n    }\n\n    for (let i = 0; i < remainingEvents.length; i++) {\n      const event = remainingEvents[i];\n\n      let prereqsMet = true;\n      let minStart = options.startTime;\n      for (const req of event.prerequisites || []) {\n        const reqAssignment = currentAssignments.find(a => a.eventId === req);\n        if (!reqAssignment) {\n          prereqsMet = false;\n          break;\n        }\n        minStart = Math.max(minStart, reqAssignment.endTime + gap);\n      }\n\n      if (!prereqsMet) continue;\n\n      const attendees = event.attendees !== undefined ? event.attendees : 1;\n      const validRooms = rooms.filter(r => attendees <= r.capacity);\n\n      validRooms.sort((a, b) => {\n        if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n        if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n        return a.capacity - b.capacity;\n      });\n\n      for (const room of validRooms) {\n        const roomAssignments = currentAssignments.filter(a => a.roomId === room.id);\n        roomAssignments.sort((a, b) => a.startTime - b.startTime);\n\n        let possibleStart = minStart;\n        let fit = false;\n\n        if (roomAssignments.length === 0) {\n          if (possibleStart + event.duration <= options.endTime) fit = true;\n        } else {\n          if (possibleStart + event.duration <= roomAssignments[0].startTime - gap) {\n          