2', name: 'Room 2', capacity: 10 }\n      ];\n\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(3);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('does not greedily block later events', () => {\n      // If we greedily assign the big event first to the only valid room,\n      // the two small events can't fit. Better to skip the big one.\n      const opts: ScheduleOptions = { startTime: 0, endTime: 120, gap: 0 };\n      const events: Event[] = [\n        { id: 'big', name: 'Big', duration: 120, attendees: 5 },\n        { id: 's1', name: 'S1', duration: 60, attendees: 5 },\n        { id: 's2', name: 'S2', duration: 60, attendees: 5 },\n      ];\n      const rooms: Room[] = [\n        { id: 'R1', name: 'Room', capacity: 5 },\n      ];\n\n      const result = schedule(events, rooms, opts);\n      // Should schedule 2 small events instead of 1 big event\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toContain('big');\n    });\n  });\n\n  describe('edge cases', () => {\n    it('handles event with duration exactly filling window', () => {\n      const opts: ScheduleOptions = { startTime: 0, endTime: 60, gap: 0 };\n      const events: Event[] = [{ id: '1', name: 'A', duration: 60 }];\n      const rooms: Room[] = [{ id: 'R1', name: 'Room', capacity: 10 }];\n\n      const result = schedule(events, rooms, opts);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBe(0);\n      expect(result.assignments[0].endTime).toBe(60);\n    });\n\n    it('handles tight schedule with gap making it impossible', () => {\n      // Two 60-min events with 15-min gap need 135 min total, but window is only 130\n      const opts: ScheduleOptions = { startTime: 0, endTime: 130, gap: 15 };\n      const events: Event[] = [\n        { id: '1', name: 'A', duration: 60 },\n        { id: '2', name: 'B', duration: 60 },\n      ];\n      const rooms: Room[] = [{ id: 'R1', name: 'Room', capacity: 10 }];\n\n      const result = schedule(events, rooms, opts);\n      // Only one event should fit\n      expect(result.assignments).toHaveLength(1);\n      expect(result.unscheduled).toHaveLength(1);\n    });\n\n    it('returns correct structure with no events and no rooms', () => {\n      const result = schedule([], [], defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":314,"cache_read_input_tokens":38413,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":314},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a3c3cf3f-df57-432b-b5ca-5be3371a9fcd","uuid":"dc135cb1-914a-474b-8ae6-929e307fbb00"}
