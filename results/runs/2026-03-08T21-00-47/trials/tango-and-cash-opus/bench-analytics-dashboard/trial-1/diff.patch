+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../src/app.js';
+import type { Express } from 'express';
+
+describe('Query Routes', () => {
+  let app: Express;
+  let token: string;
+
+  beforeEach(async () => {
+    app = createApp(':memory:');
+    const reg = await request(app)
+      .post('/api/auth/register')
+      .send({ email: 'test@example.com', password: 'pass123', tenantId: 'tenant1' });
+    token = reg.body.token;
+
+    // Seed events
+    await request(app)
+      .post('/api/events/batch')
+      .set('Authorization', `Bearer ${token}`)
+      .send({
+        events: [
+          { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-01T10:00:00Z' },
+          { name: 'page_view', properties: { url: '/about' }, timestamp: '2024-01-01T14:00:00Z' },
+          { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-02T10:00:00Z' },
+          { name: 'click', properties: { button: 'signup' }, timestamp: '2024-01-02T12:00:00Z' },
+          { name: 'click', properties: { button: 'login' }, timestamp: '2024-01-03T09:00:00Z' },
+        ],
+      });
+  });
+
+  describe('POST /api/query/count', () => {
+    it('should count all events', async () => {
+      const res = await request(app)
+        .post('/api/query/count')
+        .set('Authorization', `Bearer ${token}`)
+        .send({});
+
+      expect(res.status).toBe(200);
+      expect(res.body.count).toBe(5);
+    });
+
+    it('should count filtered events by name', async () => {
+      const res = await request(app)
+        .post('/api/query/count')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ eventName: 'page_view' });
