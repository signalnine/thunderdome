+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01R5AYMi4ZfcLUptVVQhS2Jn","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017MZzMGTLkfmbftsHEZNTVi","name":"Write","input":{"file_path":"/workspace/tests/auth.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport request from 'supertest';\nimport { createApp } from '../src/app.js';\nimport type { Express } from 'express';\n\ndescribe('Auth Routes', () => {\n  let app: Express;\n\n  beforeEach(() => {\n    app = createApp(':memory:');\n  });\n\n  describe('POST /api/auth/register', () => {\n    it('should register a new user', async () => {\n      const res = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'test@example.com', password: 'pass123', tenantId: 'tenant1' });\n\n      expect(res.status).toBe(201);\n      expect(res.body.email).toBe('test@example.com');\n      expect(res.body.tenantId).toBe('tenant1');\n      expect(res.body.role).toBe('viewer');\n      expect(res.body.token).toBeDefined();\n      expect(res.body.id).toBeDefined();\n    });\n\n    it('should register with a specific role', async () => {\n      const res = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'admin@example.com', password: 'pass123', tenantId: 'tenant1', role: 'admin' });\n\n      expect(res.status).toBe(201);\n      expect(res.body.role).toBe('admin');\n    });\n\n    it('should reject duplicate email', async () => {\n      await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'test@example.com', password: 'pass123', tenantId: 'tenant1' });\n\n      const res = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'test@example.com', password: 'pass456', tenantId: 'tenant1' });\n\n      expect(res.status).toBe(409);\n    });\n\n    it('should reject missing fields', async () => {\n      const res = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'test@example.com' });\n\n      expect(res.status).toBe(400);\n    });\n  });\n\n  describe('POST /api/auth/login', () => {\n    it('should login with valid credentials', async () => {\n      await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'test@example.com', password: 'pass123', tenantId: 'tenant1' });\n\n      const res = await request(app)\n        .post('/api/auth/login')\n        .send({ email: 'test@example.com', password: 'pass123' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.token).toBeDefined();\n      expect(res.body.user.email).toBe('test@example.com');\n    });\n\n    it('should reject invalid password', async () => {\n      await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'test@example.com', password: 'pass123', tenantId: 'tenant1' });\n\n      const res = await request(app)\n        .post('/api/auth/login')\n        .send({ email: 'test@example.com', password: 'wrong' });\n\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject unknown email', async () => {\n      const res = await request(app)\n        .post('/api/auth/login')\n        .send({ email: 'unknown@example.com', password: 'pass123' });\n\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe('GET /api/auth/profile', () => {\n    it('should return user profile with valid token', async () => {\n      const reg = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'test@example.com', password: 'pass123', tenantId: 'tenant1' });\n\n      const res = await request(app)\n        .get('/api/auth/profile')\n        .set('Authorization', `Bearer ${reg.body.token}`);\n\n      expect(res.status).toBe(200);\n      expect(res.body.email).toBe('test@example.com');\n      expect(res.body.tenantId).toBe('tenant1');\n    });\n\n    it('should return 401 without token', async () => {\n      const res = await request(app).get('/api/auth/profile');\n      expect(res.status).toBe(401);\n    });\n  });\n\n  describe('PUT /api/auth/users/:id/role', () => {\n    it('should allow admin to change role', async () => {\n      const admin = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'admin@example.com', password: 'pass123', tenantId: 'tenant1', role: 'admin' });\n\n      const user = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@example.com', password: 'pass123', tenantId: 'tenant1' });\n\n      const res = await request(app)\n        .put(`/api/auth/users/${user.body.id}/role`)\n        .set('Authorization', `Bearer ${admin.body.token}`)\n        .send({ role: 'editor' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.role).toBe('editor');\n    });\n\n    it('should reject non-admin role change', async () => {\n      const viewer = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'viewer@example.com', password: 'pass123', tenantId: 'tenant1' });\n\n      const user = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@example.com', password: 'pass123', tenantId: 'tenant1' });\n\n      const res = await request(app)\n        .put(`/api/auth/users/${user.body.id}/role`)\n        .set('Authorization', `Bearer ${viewer.body.token}`)\n        .send({ role: 'editor' });\n\n      expect(res.status).toBe(403);\n    });\n\n    it('should reject cross-tenant role change', async () => {\n      const admin = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'admin@example.com', password: 'pass123', tenantId: 'tenant1', role: 'admin' });\n\n      const user = await request(app)\n        .post('/api/auth/register')\n        .send({ email: 'user@example.com', password: 'pass123', tenantId: 'tenant2' });\n\n      const res = await request(app)\n        .put(`/api/auth/users/${user.body.id}/role`)\n        .set('Authorization', `Bear