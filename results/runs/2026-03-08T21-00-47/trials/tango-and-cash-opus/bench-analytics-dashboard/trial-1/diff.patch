tMany = db.transaction((evts: Array<{ name: string; properties?: Record<string, unknown>; timestamp?: string }>) => {\n      const results: Array<{ id: string; name: string }> = [];\n      for (const evt of evts) {\n        if (!evt.name) continue;\n        const id = uuidv4();\n        const eventTimestamp = evt.timestamp || new Date().toISOString();\n        const eventProperties = evt.properties ? JSON.stringify(evt.properties) : '{}';\n        insert.run(id, tenantId, evt.name, eventProperties, eventTimestamp, userId);\n        results.push({ id, name: evt.name });\n      }\n      return results;\n    });\n\n    const results = insertMany(events);\n    res.status(201).json({ inserted: results.length, events: results });\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1444,"cache_read_input_tokens":26767,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1444},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"cd6b16be-2b53-4fcc-825f-3c8101875fe6","uuid":"7126619b-7fa7-48e7-a275-815e7839286a"}
