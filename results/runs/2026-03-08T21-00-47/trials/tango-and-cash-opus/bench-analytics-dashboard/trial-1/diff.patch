@@ -0,0 +1,67 @@
+import { Router, Request, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import Database from 'better-sqlite3';
+import { authMiddleware } from '../middleware/auth.js';
+
+export function createEventsRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  // POST /api/events - single event
+  router.post('/', (req: Request, res: Response): void => {
+    const { name, properties, timestamp } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: 'Event name is required' });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+    const eventTimestamp = timestamp || new Date().toISOString();
+    const eventProperties = properties ? JSON.stringify(properties) : '{}';
+
+    db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)'
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, userId);
+
+    res.status(201).json({ id, name, properties: properties || {}, timestamp: eventTimestamp, tenantId });
+  });
+
+  // POST /api/events/batch - batch events
+  router.post('/batch', (req: Request, res: Response): void => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: 'events array is required and must not be empty' });
+      return;
+    }
+
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+
+    const insert = db.prepare(
+      'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id) VALUES (?, ?, ?, ?, ?, ?)'
+    );
+
+    const insertMany = db.transaction((evts: Array<{ name: string; properties?: Record<string, unknown>; timestamp?: string }>) => {
+      const results: Array<{ id: string; name: string }> = [];
+      for (const evt of evts) {
+        if (!evt.name) continue;
+        const id = uuidv4();
+        const eventTimestamp = evt.timestamp || new Date().toISOString();
+        const eventProperties = evt.properties ? JSON.stringify(evt.properties) : '{}';
+        insert.run(id, tenantId, evt.name, eventProperties, eventTimestamp, userId);
+        results.push({ id, name: evt.name });
+      }
+      return results;
+    });
+
+    const results = insertMany(events);
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  return router;
+}
diff --git a/src/routes/export.ts b/src/routes/export.ts
new file mode 100644
index 0000000..d8d72fe
--- /dev/null
+++ b/src/routes/export.ts
@@ -0,0 +1,119 @@
+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { authMiddleware } from '../middleware/auth.js';
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = 'id,name,properties,timestamp,user_id,session_id';
+  const rows = events.map(e => {
+    const props = e.properties.replace(/"/g, '""');
+    return `${e.id},${e.name},"${props}",${e.timestamp},${e.user_id || ''},${e.session_id || ''}`;
+  });
+  return [header, ...rows].join('\n');
+}
+
+export function createExportRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  // GET /api/export/events
+  router.get('/events', (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const format = (req.query.format as string) || 'json';
+
+    let sql = 'SELECT * FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [tenantId];
+
+    if (req.query.eventName) {
+      sql += ' AND name = ?';
+      params.push(req.query.eventName);
+    }
+
+    if (req.query.startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(req.query.startDate);
+    }
+
+    if (req.query.endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(req.query.endDate);
+    }
+
+    sql += ' ORDER BY timestamp DESC';
+
+    const events = db.prepare(sql).all(...params) as EventRow[];
+
+    if (format === 'csv') {
+      res.setHeader('Content-Type', 'text/csv');
+      res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+      res.send(eventsToCsv(events));
+    } else {
+      res.json({
+        events: events.map(e => ({
+          id: e.id,
+          name: e.name,
+          properties: JSON.parse(e.properties),
+          timestamp: e.timestamp,
+          userId: e.user_id,
+          sessionId: e.session_id,
+        })),
+      });
+    }
+  });
+
+  // GET /api/export/dashboards/:id
+  router.get('/dashboards/:id', (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const format = (req.query.format as string) || 'json';
+
+    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+      .get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: 'Dashboard not found' });
+      return;
+    }
+
+    const dashboardData = {
+      id: dashboard.id,
+      name: dashboard.name,
+      tenantId: dashboard.tenant_id,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+    };
+
+    if (format === 'csv') {
+      res.setHeader('Content-Type', 'text/csv');
+      res.setHeader('Content-Disposition', `attachment; filename="dashboard-${dashboard.id}.csv"`);
+      const configStr = dashboard.config.replace(/"/g, '""');
+      const csv = `id,name,tenant_id,owner_id,config,created_at,updated_at\n${dashboard.id},${dashboard.name},${dashboard.tenant_id},${dashboard.owner_id},"${configStr}",${dashboard.created_at},${dashboard.updated_at}`;
+      res.send(csv);
+    } else {
+      res.json(dashboardData);
+    }
+  });
+
+  return router;
+}
