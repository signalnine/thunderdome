+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01LCXscSn1MyPdNRyhj3tviN","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01ERtpfvcxrJrv88FvyU6VRG","name":"Write","input":{"file_path":"/workspace/src/routes/export.ts","content":"import { Router, Request, Response } from 'express';\nimport Database from 'better-sqlite3';\nimport { authMiddleware } from '../middleware/auth.js';\n\ninterface EventRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  properties: string;\n  timestamp: string;\n  user_id: string | null;\n  session_id: string | null;\n}\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\nfunction eventsToCsv(events: EventRow[]): string {\n  const header = 'id,name,properties,timestamp,user_id,session_id';\n  const rows = events.map(e => {\n    const props = e.properties.replace(/\"/g, '\"\"');\n    return `${e.id},${e.name},\"${props}\",${e.timestamp},${e.user_id || ''},${e.session_id || ''}`;\n  });\n  return [header, ...rows].join('\\n');\n}\n\nexport function createExportRouter(db: Database.Database): Router {\n  const router = Router();\n\n  router.use(authMiddleware);\n\n  // GET /api/export/events\n  router.get('/events', (req: Request, res: Response): void => {\n    const tenantId = req.user!.tenantId;\n    const format = (req.query.format as string) || 'json';\n\n    let sql = 'SELECT * FROM events WHERE tenant_id = ?';\n    const params: unknown[] = [tenantId];\n\n    if (req.query.eventName) {\n      sql += ' AND name = ?';\n      params.push(req.query.eventName);\n    }\n\n    if (req.query.startDate) {\n      sql += ' AND timestamp >= ?';\n      params.push(req.query.startDate);\n    }\n\n    if (req.query.endDate) {\n      sql += ' AND timestamp <= ?';\n      params.push(req.query.endDate);\n    }\n\n    sql += ' ORDER BY timestamp DESC';\n\n    const events = db.prepare(sql).all(...params) as EventRow[];\n\n    if (format === 'csv') {\n      res.setHeader('Content-Type', 'text/csv');\n      res.setHeader('Content-Disposition', 'attachment; filename=\"events.csv\"');\n      res.send(eventsToCsv(events));\n    } else {\n      res.json({\n        events: events.map(e => ({\n          id: e.id,\n          name: e.name,\n          properties: JSON.parse(e.properties),\n          timestamp: e.timestamp,\n          userId: e.user_id,\n          sessionId: e.session_id,\n        })),\n      });\n    }\n  });\n\n  // GET /api/export/dashboards/:id\n  router.get('/dashboards/:id', (req: Request, res: Response): void => {\n    const tenantId = req.user!.tenantId;\n    const format = (req.query.format as string) || 'json';\n\n    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n      .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n\n    const dashboardData = {\n      id: dashboard.id,\n      name: dashboard.name,\n      tenantId: dashboard.tenant_id,\n      ownerId: dashboard.owner_id,\n      config: JSON.parse(dashboard.config),\n      createdAt: dashboard.created_at,\n      updatedAt: dashboard.updated_at,\n    };\n\n    if (format === 'csv') {\n      res.setHeader('Content-Type', 'text/csv');\n      res.setHeader('Content-Disposition', `attachment; filename=\"dashboard-${dashboard.id}.csv\"`);\n      const configStr = dashboard.config.replace(/\"/g, '\"\"');\n      const csv = `id,name,tenant_id,owner_id,config,created_at,updated_at\\n${dashboard.id},${dashboard.name},${dashboard.tenant_id},${dashboard.owner_id},\"${configStr}\",${dashboard.created_at},${dashboard.updated_at}`;\n      res.send(csv);\n    } else {\n      res.json(dashboardData);\n    }\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens"