Bearer ${token}`)\n        .send({ eventName: 'page_view', property: 'url' });\n\n      expect(res.status).toBe(200);\n      expect(res.body.breakdown).toBeDefined();\n      const homeEntry = res.body.breakdown.find((b: { value: string }) => b.value === '/home');\n      expect(homeEntry.count).toBe(2);\n    });\n\n    it('should require property', async () => {\n      const res = await request(app)\n        .post('/api/query/breakdown')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ eventName: 'page_view' });\n\n      expect(res.status).toBe(400);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":825,"cache_read_input_tokens":38315,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":825},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"cd6b16be-2b53-4fcc-825f-3c8101875fe6","uuid":"cad9c52c-be45-49ae-acb7-29c0b6b47cfb"}
