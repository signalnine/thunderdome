+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../src/app.js';
+import type { Express } from 'express';
+
+describe('Dashboard Routes', () => {
+  let app: Express;
+  let token: string;
+
+  beforeEach(async () => {
+    app = createApp(':memory:');
+    const reg = await request(app)
+      .post('/api/auth/register')
+      .send({ email: 'test@example.com', password: 'pass123', tenantId: 'tenant1' });
+    token = reg.body.token;
+  });
+
+  describe('POST /api/dashboards', () => {
+    it('should create a dashboard', async () => {
+      const res = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Main Dashboard', config: { widgets: [] } });
+
+      expect(res.status).toBe(201);
+      expect(res.body.name).toBe('Main Dashboard');
+      expect(res.body.id).toBeDefined();
+      expect(res.body.tenantId).toBe('tenant1');
+    });
+
+    it('should reject dashboard without name', async () => {
+      const res = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ config: {} });
+
+      expect(res.status).toBe(400);
+    });
+
+    it('should reject unauthenticated request', async () => {
+      const res = await request(app)
+        .post('/api/dashboards')
+        .send({ name: 'Dashboard' });
+
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe('GET /api/dashboards', () => {
+    it('should list dashboards for tenant', async () => {
+      await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Dashboard 1' });
+
+      await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Dashboard 2' });
+
+      const res = await request(app)
+        .get('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.dashboards).toHaveLength(2);
+    });
+
+    it('should enforce tenant isolation', async () => {
+      await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Tenant1 Dashboard' });
+
+      const reg2 = await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'other@example.com', password: 'pass123', tenantId: 'tenant2' });
+
+      const res = await request(app)
+        .get('/api/dashboards')
+        .set('Authorization', `Bearer ${reg2.body.token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.dashboards).toHaveLength(0);
+    });
+  });
+
+  describe('GET /api/dashboards/:id', () => {
+    it('should get a dashboard by id', async () => {
+      const created = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'My Dashboard', config: { theme: 'dark' } });
+
+      const res = await request(app)
+        .get(`/api/dashboards/${created.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('My Dashboard');
+    });
+
+    it('should return 404 for non-existent dashboard', async () => {
+      const res = await request(app)
+        .get('/api/dashboards/nonexistent')
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(404);
+    });
+  });
+
+  describe('PUT /api/dashboards/:id', () => {
+    it('should update a dashboard', async () => {
+      const created = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Old Name' });
+
+      const res = await request(app)
+        .put(`/api/dashboards/${created.body.id}`)
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'New Name', config: { updated: true } });
+
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('New Name');
+    });
+  });
+
+  describe('DELETE /api/dashboards/:id', () => {
+    it('should delete a dashboard', async () => {
+      const created = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'To Delete' });
+
+      const res = await request(app)
+        .delete(`/api/dashboards/${created.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(204);
+
+      const get = await request(app)
+        .get(`/api/dashboards/${created.body.id}`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(get.status).toBe(404);
+    });
+  });
+});
