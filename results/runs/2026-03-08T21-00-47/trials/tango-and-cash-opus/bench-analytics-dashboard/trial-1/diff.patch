D timestamp <= ?';\n      params.push(req.query.endDate);\n    }\n\n    sql += ' ORDER BY timestamp DESC';\n\n    const events = db.prepare(sql).all(...params) as EventRow[];\n\n    if (format === 'csv') {\n      res.setHeader('Content-Type', 'text/csv');\n      res.setHeader('Content-Disposition', 'attachment; filename=\"events.csv\"');\n      res.send(eventsToCsv(events));\n    } else {\n      res.json({\n        events: events.map(e => ({\n          id: e.id,\n          name: e.name,\n          properties: JSON.parse(e.properties),\n          timestamp: e.timestamp,\n          userId: e.user_id,\n          sessionId: e.session_id,\n        })),\n      });\n    }\n  });\n\n  // GET /api/export/dashboards/:id\n  router.get('/dashboards/:id', (req: Request, res: Response): void => {\n    const tenantId = req.user!.tenantId;\n    const format = (req.query.format as string) || 'json';\n\n    const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')\n      .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: 'Dashboard not found' });\n      return;\n    }\n\n    const dashboardData = {\n      id: dashboard.id,\n      name: dashboard.name,\n      tenantId: dashboard.tenant_id,\n      ownerId: dashboard.owner_id,\n      config: JSON.parse(dashboard.config),\n      createdAt: dashboard.created_at,\n      updatedAt: dashboard.updated_at,\n    };\n\n    if (format === 'csv') {\n      res.setHeader('Content-Type', 'text/csv');\n      res.setHeader('Content-Disposition', `attachment; filename=\"dashboard-${dashboard.id}.csv\"`);\n      const configStr = dashboard.config.replace(/\"/g, '\"\"');\n      const csv = `id,name,tenant_id,owner_id,config,created_at,updated_at\\n${dashboard.id},${dashboard.name},${dashboard.tenant_id},${dashboard.owner_id},\"${configStr}\",${dashboard.created_at},${dashboard.updated_at}`;\n      res.send(csv);\n    } else {\n      res.json(dashboardData);\n    }\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
