+import type { Express } from 'express';
+
+describe('Export Routes', () => {
+  let app: Express;
+  let token: string;
+
+  beforeEach(async () => {
+    app = createApp(':memory:');
+    const reg = await request(app)
+      .post('/api/auth/register')
+      .send({ email: 'test@example.com', password: 'pass123', tenantId: 'tenant1' });
+    token = reg.body.token;
+
+    // Seed some events
+    await request(app)
+      .post('/api/events/batch')
+      .set('Authorization', `Bearer ${token}`)
+      .send({
+        events: [
+          { name: 'page_view', properties: { url: '/home' }, timestamp: '2024-01-01T10:00:00Z' },
+          { name: 'click', properties: { button: 'signup' }, timestamp: '2024-01-02T12:00:00Z' },
+        ],
+      });
+  });
+
+  describe('GET /api/export/events', () => {
+    it('should export events as JSON', async () => {
+      const res = await request(app)
+        .get('/api/export/events?format=json')
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.events).toHaveLength(2);
+    });
+
+    it('should export events as CSV', async () => {
+      const res = await request(app)
+        .get('/api/export/events?format=csv')
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.headers['content-type']).toContain('text/csv');
+      expect(res.text).toContain('id,name,properties,timestamp');
+      expect(res.text).toContain('page_view');
+    });
+
+    it('should enforce tenant isolation on export', async () => {
+      const reg2 = await request(app)
+        .post('/api/auth/register')
+        .send({ email: 'other@example.com', password: 'pass123', tenantId: 'tenant2' });
+
+      const res = await request(app)
+        .get('/api/export/events?format=json')
+        .set('Authorization', `Bearer ${reg2.body.token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.events).toHaveLength(0);
+    });
+
+    it('should reject unauthenticated request', async () => {
+      const res = await request(app).get('/api/export/events?format=json');
+      expect(res.status).toBe(401);
+    });
+  });
+
+  describe('GET /api/export/dashboards/:id', () => {
+    it('should export dashboard as JSON', async () => {
+      const dash = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'Export Test', config: { widgets: ['a'] } });
+
+      const res = await request(app)
+        .get(`/api/export/dashboards/${dash.body.id}?format=json`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.body.name).toBe('Export Test');
+    });
+
+    it('should export dashboard as CSV', async () => {
+      const dash = await request(app)
+        .post('/api/dashboards')
+        .set('Authorization', `Bearer ${token}`)
+        .send({ name: 'CSV Test' });
+
+      const res = await request(app)
+        .get(`/api/export/dashboards/${dash.body.id}?format=csv`)
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(200);
+      expect(res.headers['content-type']).toContain('text/csv');
+      expect(res.text).toContain('CSV Test');
+    });
+
+    it('should return 404 for non-existent dashboard', async () => {
+      const res = await request(app)
+        .get('/api/export/dashboards/nonexistent?format=json')
+        .set('Authorization', `Bearer ${token}`);
+
+      expect(res.status).toBe(404);
+    });
+  });
+});
