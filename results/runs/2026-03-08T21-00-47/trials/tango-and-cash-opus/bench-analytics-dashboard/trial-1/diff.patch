@@ -0,0 +1,126 @@
+import { Router, Request, Response } from 'express';
+import Database from 'better-sqlite3';
+import { authMiddleware } from '../middleware/auth.js';
+
+export function createQueryRouter(db: Database.Database): Router {
+  const router = Router();
+
+  router.use(authMiddleware);
+
+  // POST /api/query/count
+  router.post('/count', (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, filters } = req.body;
+
+    let sql = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ` AND json_extract(properties, '$.${key}') = ?`;
+        params.push(value as string);
+      }
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // POST /api/query/timeseries
+  router.post('/timeseries', (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, startDate, endDate, interval, filters } = req.body;
+
+    const bucket = interval === 'hour' ? '%Y-%m-%dT%H:00:00'
+      : interval === 'month' ? '%Y-%m-01'
+      : '%Y-%m-%d'; // default daily
+
+    let sql = `SELECT strftime('${bucket}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ` AND json_extract(properties, '$.${key}') = ?`;
+        params.push(value as string);
+      }
+    }
+
+    sql += ' GROUP BY bucket ORDER BY bucket ASC';
+
+    const results = db.prepare(sql).all(...params) as Array<{ bucket: string; count: number }>;
+    res.json({ timeseries: results });
+  });
+
+  // POST /api/query/breakdown
+  router.post('/breakdown', (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { eventName, property, startDate, endDate, filters } = req.body;
+
+    if (!property) {
+      res.status(400).json({ error: 'property is required for breakdown queries' });
+      return;
+    }
+
+    let sql = `SELECT json_extract(properties, '$.${property}') as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += ' AND name = ?';
+      params.push(eventName);
+    }
+
+    if (startDate) {
+      sql += ' AND timestamp >= ?';
+      params.push(startDate);
+    }
+
+    if (endDate) {
+      sql += ' AND timestamp <= ?';
+      params.push(endDate);
+    }
+
+    if (filters && typeof filters === 'object') {
+      for (const [key, value] of Object.entries(filters)) {
+        sql += ` AND json_extract(properties, '$.${key}') = ?`;
+        params.push(value as string);
+      }
+    }
+
+    sql += ' GROUP BY value ORDER BY count DESC';
+
+    const results = db.prepare(sql).all(...params) as Array<{ value: string | null; count: number }>;
+    res.json({ breakdown: results });
+  });
+
+  return router;
+}
