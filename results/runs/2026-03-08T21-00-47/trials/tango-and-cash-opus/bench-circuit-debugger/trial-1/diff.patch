=>\n        g.op === op &&\n        ((g.in1 === in1 && g.in2 === in2) ||\n          (g.in1 === in2 && g.in2 === in1))\n    );\n  }\n\n  // Helper: find a gate that uses a given op and has at least one of the given inputs\n  function findGateWithInput(op: Gate['op'], input: string): Gate | undefined {\n    return gates.find(\n      (g) => g.op === op && (g.in1 === input || g.in2 === input)\n    );\n  }\n\n  const swapped = new Set<string>();\n\n  // Structural analysis of ripple-carry adder\n  // For each bit position, verify the expected adder structure\n  // and identify swapped wires\n\n  // We'll work with the actual wire names and check structural rules:\n  // 1. z outputs (except last z) must come from XOR gates\n  // 2. XOR gates with x/y inputs should not output to z (except z00)\n  // 3. OR gates should not output to z\n  // 4. AND gates should not output to z\n\n  const lastZ = `z${String(maxBit + 1).padStart(2, '0')}`;\n\n  for (const g of gates) {\n    // Rule 1: z-outputs (except last) must be from XOR\n    if (\n      g.out.startsWith('z') &&\n      g.out !== lastZ &&\n      g.op !== 'XOR'\n    ) {\n      swapped.add(g.out);\n    }\n\n    // Rule 2: XOR with x/y inputs should not go to z (except z00)\n    if (g.op === 'XOR') {\n      const hasXY =\n        (g.in1.startsWith('x') || g.in1.startsWith('y')) &&\n        (g.in2.startsWith('x') || g.in2.startsWith('y'));\n      if (hasXY && g.out.startsWith('z') && g.out !== 'z00') {\n        swapped.add(g.out);\n      }\n    }\n\n    // Rule 3: XOR gates that don't have x/y inputs should output to z\n    if (g.op === 'XOR') {\n      const hasXY =\n        (g.in1.startsWith('x') || g.in1.startsWith('y')) &&\n        (g.in2.startsWith('x') || g.in2.startsWith('y'));\n      if (!hasXY && !g.out.startsWith('z')) {\n        // This XOR should output to a z wire but doesn't - it's swapped\n        swapped.add(g.out);\n      }\n    }\n\n    // Rule 4: AND gate outputs (except x00 AND y00) should feed into OR gates\