e consumed by\n  // a XOR and an AND gate that share the same \"other\" input (the carry wire).\n  // If the output is consumed by XOR and AND with different \"other\" inputs, it means\n  // one of those other inputs got swapped.\n  // Also: The XOR consumer should output to zN (same bit number).\n  for (const gate of gates) {\n    if (gate.op !== 'XOR') continue;\n    const { in1, in2, out } = gate;\n    const isInputXY = (in1.startsWith('x') && in2.startsWith('y')) || (in1.startsWith('y') && in2.startsWith('x'));\n    const is00 = (in1 === 'x00' && in2 === 'y00') || (in1 === 'y00' && in2 === 'x00');\n    if (!isInputXY || is00) continue;\n\n    // This is XOR(xN, yN) -> out, N > 0\n    // Find the XOR gate that consumes `out` (should produce zN)\n    const xorConsumer = gates.find(g => g.op === 'XOR' && (g.in1 === out || g.in2 === out));\n    if (!xorConsumer) continue; // Already caught by rule 3\n\n    // The xorConsumer should output to zN where N matches this gate's bit\n    const xBit = in1.startsWith('x') ? in1.slice(1) : in2.slice(1);\n    const expectedZ = `z${xBit}`;\n    if (xorConsumer.out !== expectedZ && !anomalies.has(xorConsumer.out)) {\n      // The XOR consumer doesn't output to the expected z - that z is probably swapped\n      // This could mean the xorConsumer's output is swapped with something\n      // But this should already be caught by other rules\n    }\n\n    // The other input to the xorConsumer should be the carry from bit N-1\n    const carryWire = xorConsumer.in1 === out ? xorConsumer.in2 : xorConsumer.in1;\n    const carryProducer = producerOf.get(carryWire);\n    if (carryProducer) {\n      // The carry should come from OR or from AND(x00,y00) for bit 1\n      const isValidCarry = carryProducer.op === 'OR' ||\n        (carryProducer.op === 'AND' &&\n         ((carryProducer.in1 === 'x00' && carryProducer.in2 === 'y00') ||\n          (carryProducer.in1 === 'y00' && carryProducer.in2 === 'x00')));\n      if (!isValidCarry) {\n        // The carry wire comes from the wrong type of gate - it's been swapped\n        anomalies.add(carryWire);\n        // Find what it should have been swapped with by looking for a nearby OR output\n        // that isn't being used as a carry\n      }\n    }\n  }\n\n  return Array.from(anomalies).sort();\n}\n"}}
