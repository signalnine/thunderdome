+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wireValues: Record<string, number> = { ...inputs };
+  const pendingGates = [...gates];
+
+  let progress = true;
+  while (pendingGates.length > 0 && progress) {
+    progress = false;
+    for (let i = 0; i < pendingGates.length; i++) {
+      const gate = pendingGates[i];
+      if (wireValues[gate.in1] !== undefined && wireValues[gate.in2] !== undefined) {
+        const val1 = wireValues[gate.in1];
+        const val2 = wireValues[gate.in2];
+        let outVal = 0;
+        if (gate.op === 'AND') {
+          outVal = val1 & val2;
+        } else if (gate.op === 'OR') {
+          outVal = val1 | val2;
+        } else if (gate.op === 'XOR') {
+          outVal = val1 ^ val2;
+        }
+        wireValues[gate.out] = outVal;
+        pendingGates.splice(i, 1);
+        progress = true;
+        i--;
+      }
+    }
+  }
+
+  return wireValues;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const anomalies = new Set<string>();
+
+  const zWires = gates.map(g => g.out).filter(o => o.startsWith('z')).sort();
+  const MSB = zWires[zWires.length - 1];
+
+  for (const gate of gates) {
+    const { op, in1, in2, out } = gate;
+    const isInputXY = (in1.startsWith('x') && in2.startsWith('y')) || (in1.startsWith('y') && in2.startsWith('x'));
+    const is00 = (in1 === 'x00' && in2 === 'y00') || (in1 === 'y00' && in2 === 'x00');
+
+    // Rule 1: All z outputs must come from XOR gates (except the MSB which is final carry)
+    if (out.startsWith('z') && out !== MSB && op !== 'XOR') {
+      anomalies.add(out);
+    }
+
+    // Rule 2: XOR gates that don't take x,y inputs must output to z
+    if (op === 'XOR' && !out.startsWith('z') && !isInputXY) {
+      anomalies.add(out);
+    }
+
+    // Rule 3: XOR gates with x,y inputs (except bit 0) must feed into another XOR gate
+    if (op === 'XOR' && isInputXY && !is00) {
+      const feedsIntoXor = gates.some(other => other.op === 'XOR' && (other.in1 === out || other.in2 === out));
+      if (!feedsIntoXor) {
+        anomalies.add(out);
+      }
+    }
+
+    // Rule 4: AND gates (except bit 0) must feed into an OR gate
+    if (op === 'AND' && !is00) {
+      const feedsIntoOr = gates.some(other => other.op === 'OR' && (other.in1 === out || other.in2 === out));
+      if (!feedsIntoOr) {
+        anomalies.add(out);
+      }
+    }
+
+    // Rule 5: OR gate outputs (except MSB) must feed into both XOR and AND (as carry)
+    if (op === 'OR' && out !== MSB) {
+      const feedsIntoXor = gates.some(other => other.op === 'XOR' && (other.in1 === out || other.in2 === out));
+      const feedsIntoAnd = gates.some(other => other.op === 'AND' && (other.in1 === out || other.in2 === out));
+      if (!feedsIntoXor || !feedsIntoAnd) {
+        anomalies.add(out);
+      }
+    }
+  }
+
+  return Array.from(anomalies).sort();
+}
