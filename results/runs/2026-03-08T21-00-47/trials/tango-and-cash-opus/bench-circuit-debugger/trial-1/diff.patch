in1: 'x00', in2: 'y00', out: 'c00' },\n    ];\n    const result = simulate(gates, { x00: 1, y00: 0 });\n    expect(result).toEqual({ x00: 1, y00: 0, z00: 1, c00: 0 });\n  });\n\n  test('half adder (bit 0)', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n    ];\n    // 1 + 1 = 10 in binary\n    const result = simulate(gates, { x00: 1, y00: 1 });\n    expect(result.z00).toBe(0);\n    expect(result.c00).toBe(1);\n  });\n\n  test('full 4-bit adder: 5 + 7 = 12', () => {\n    const gates: Gate[] = [\n      // bit 0\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // bit 1\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR',  in1: 'a01', in2: 'b01', out: 'c01' },\n      // bit 2\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR',  in1: 'a02', in2: 'b02', out: 'c02' },\n      // bit 3\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR',  in1: 'a03', in2: 'b03', out: 'c03' },\n    ];\n    // 5 = 0101, 7 = 0111\n    // x: bit0=1, bit1=0, bit2=1, bit3=0\n    // y: bit0=1, bit1=1, bit2=1, bit3=0\n    const result = simulate(gates, {\n      x00: 1, x01: 0, x02: 1, x03: 0,\n      y00: 1, y01: 1, y02: 1, y03: 0,\n    });\n    // 12 = 1100\n    expect(result.z00).toBe(0); // bit 0\n    expect(result.z01).toBe(0); // bit 1\n    expect(result.z02).toBe(1); // bit 2\n    expect(result.z03).toBe(1); // bit 3\n    expect(result.c03).toBe(0); // no carry out\n  });\n\n  test('gates in reverse order still resolve', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'ab', in2: 'c', out: 'result' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'ab' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, c: 0 }).result).toBe(1);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  // Helper to build an N-bit ripple carry adder\n  function buildAdder(bits: number): Gate[] {\n    const gates: Gate[] = [];\n    // Bit 0: half adder\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n    for (let i = 1; i < bits; i++) {\n      const pad = String(i).padStart(2, '0');\n      const prevPad = String(i - 1).padStart(2, '0');\n      gates.push({ op: 'XOR', in1: `x${pad}`, in2: `y${pad}`, out: `t${pad}` });\n      gates.push({ op: 'XOR', in1: `t${pad}`, in2: `c${prevPad}`, out: `z${pad}` });\n      gates.push({ op: 'AND', in1: `x${pad}`, in2: `y${pad}`, out: `a${pad}` });\n      gates.push({ op: 'AND', in1: `t${pad}`, in2: `c${prevPad}`, out: `b${pad}` });\n      gates.push({ op: 'OR',  in1: `a${pad}`, in2: `b${pad}`, out: `c${pad}` });\n    }\n\n    // Final carry -> last z\n    const lastPad = String(bits - 1).padStart(2, '0');\n    const outPad = String(bits).padStart(2, '0');\n    // The final carry c(N-1) becomes z(N)\n    // We'll model this as an OR gate with carry and 0, or we can use a direct wire\n    // Actually in the spec example the carry just becomes z04 directly\n    // We'll use an identity gate: c(N-1) OR c(N-1) -> z(N) (since no identity op)\n    // Actually, let's use XOR with a dummy 0 wire... but that'd be weird\n    // The spec says \"c03 -> z04\" which is just a direct connection, not a gate\n    // For the gate-based model, we don't need a gate for this - it's just that c(N-1) IS z(N)\n    // Let's just rename the last carry output\n    // Actually we need to change the last OR gate's output\n    const lastGate = gates[gates.length - 1]; // the OR gate for bit N-1\n    lastGate.out = `z${outPad}`;\n\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): void {\n    const g1 = gates.find(g => g.out === wire1)!;\n    const g2 = gates.find(g => g.out === wire2)!;\n    g1.out = wire2;\n    g2.out = wire1;\n  }\n\n  test('correct adder has no swaps', () => {\n    const gates = buildAdder(4);\n    expect(findSwappedWires(gates)).toEqual([]);\n  });\n\n  test('detect z01 and a01 swapped', () => {\n    const gates = buildAdder(8);\n    swapOutputs(gates, 'z01', 'a01');\n    // Need 4 pairs total, add 3 more swaps\n    swapOutputs(gates, 'z03', 'a03');\n    swapOutputs(gates, 'z05', 'b05');\n    swapOutputs(gates, 't07', 'c06');\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a03', 'b05', 'c06', 't07', 'z01', 'z03', 'z05']);\n  });\n\n  test('detect swaps with random wire names in larger adder', () => {\n    // Build a 10-bit adder and swap 4 pairs\n    const gates = buildAdder(10);\n    swapOutputs(gates, 'z02', 'b02');\n    swapOutputs(gates, 'z04', 'a04');\n    swapOutputs(gates, 't06', 'z06');\n    swapOutputs(gates, 'a08', 'c07');\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a04', 'a08', 'b02', 'c07', 't06', 'z02', 'z04', 'z06']);\n  });\n\n  test('handles 45-bit adder with swaps', () => {\n    const gates = buildAdder(45);\n    swapOutputs(gates, 'z10', 'a10');\n    swapOutputs(gates, 'z20', 'b20');\n    swapOutputs(gates, 't30', 'z30');\n    swapOutputs(gates, 'a40', 'c39');\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a10', 'a40', 'b20', 'c39', 't30', 'z10', 'z20', 'z30']);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":