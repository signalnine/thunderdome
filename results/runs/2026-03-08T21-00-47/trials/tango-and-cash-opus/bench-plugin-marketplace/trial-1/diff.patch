(makeManifest({ name: 'b', version: '1.0.0' }));\n    const all = registry.list();\n    expect(all).toHaveLength(2);\n  });\n\n  it('should return empty list when no plugins', () => {\n    expect(registry.list()).toHaveLength(0);\n  });\n\n  it('should search by name', () => {\n    registry.register(makeManifest({ name: 'foo-bar' }));\n    registry.register(makeManifest({ name: 'baz-qux' }));\n    const results = registry.search('foo');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('foo-bar');\n  });\n\n  it('should search by description', () => {\n    registry.register(makeManifest({ name: 'x', description: 'a logging plugin' }));\n    registry.register(makeManifest({ name: 'y', description: 'a math plugin' }));\n    const results = registry.search('logging');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('x');\n  });\n\n  it('should return empty search results for no match', () => {\n    registry.register(makeManifest());\n    expect(registry.search('zzzzz')).toHaveLength(0);\n  });\n\n  it('should remove a plugin version', () => {\n    registry.register(makeManifest());\n    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);\n    expect(registry.get('test-plugin')).toBeNull();\n  });\n\n  it('should return false when removing non-existent version', () => {\n    expect(registry.remove('nope', '1.0.0')).toBe(false);\n  });\n\n  it('should list versions of a plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    registry.register(makeManifest({ version: '1.5.0' }));\n    const versions = registry.listVersions('test-plugin');\n    expect(versions).toHaveLength(3);\n    expect(versions).toContain('1.0.0');\n    expect(versions).toContain('2.0.0');\n    expect(versions).toContain('1.5.0');\n  });\n\n  it('should return empty array for unknown plugin versions', () => {\n    expect(registry.listVersions('unknown')).toHaveLength(0);\n  });\n\n  it('should update a plugin', () => {\n    registry.register(makeManifest());\n    registry.update('test-plugin', '1.0.0', { description: 'updated' });\n    const result = registry.getVersion('test-plugin', '1.0.0');\n    expect(result!.description).toBe('updated');\n  });\n\n  it('should throw when updating non-existent plugin', () => {\n    expect(() => registry.update('nope', '1.0.0', {})).toThrow();\n  });\n\n  it('should handle multiple versions of same plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    expect(registry.listVersions('test-plugin')).toHaveLength(2);\n    // get() should return one of them\n    const result = registry.get('test-plugin');\n    expect(result).not.toBeNull();\n  });\n\n  it('should preserve dependencies as JSON', () => {\n    const deps = { 'dep-a': '^1.0.0', 'dep-b': '~2.0.0' };\n    registry.register(makeManifest({ dependencies: deps }));\n    const result = registry.get('test-plugin');\n    expect(result!.dependencies).toEqual(deps);\n  });\n\n  it('should preserve permissions as JSON', () => {\n    const perms = ['network', 'fs'];\n    registry.register(makeManifest({ permissions: perms }));\n    const result = registry.get('test-plugin');\n    expect(result!.permissions).toEqual(perms);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":106,"cache_read_input_tokens":32122,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":106},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"41d8807c-a87f-4a42-8c3a-173f27c65fca","uuid":"df9e1387-4668-48fc-aef5-28e128d32cbf"}
