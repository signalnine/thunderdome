+import { describe, it, expect, beforeEach } from 'vitest';
+import { createReviewService } from '../reviews/index.js';
+import type { ReviewService } from '../types.js';
+
+describe('ReviewService', () => {
+  let reviews: ReviewService;
+
+  beforeEach(() => {
+    reviews = createReviewService();
+  });
+
+  describe('addReview', () => {
+    it('should add a review and return it with id', () => {
+      const review = reviews.addReview({
+        pluginName: 'test-plugin',
+        pluginVersion: '1.0.0',
+        userId: 'user1',
+        rating: 5,
+        comment: 'Great plugin!',
+      });
+      expect(review.id).toBeDefined();
+      expect(review.pluginName).toBe('test-plugin');
+      expect(review.rating).toBe(5);
+      expect(review.flagged).toBe(false);
+      expect(review.createdAt).toBeDefined();
+    });
+
+    it('should auto-increment ids', () => {
+      const r1 = reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u', rating: 3, comment: '',
+      });
+      const r2 = reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u', rating: 4, comment: '',
+      });
+      expect(r2.id).toBeGreaterThan(r1.id);
+    });
+  });
+
+  describe('getReviews', () => {
+    it('should return reviews for a plugin', () => {
+      reviews.addReview({
+        pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'good',
+      });
+      reviews.addReview({
+        pluginName: 'b', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: 'ok',
+      });
+      reviews.addReview({
+        pluginName: 'a', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: 'nice',
+      });
+      const result = reviews.getReviews('a');
+      expect(result).toHaveLength(2);
+    });
+
+    it('should return empty array for unknown plugin', () => {
+      expect(reviews.getReviews('unknown')).toHaveLength(0);
+    });
+  });
+
+  describe('getAverageRating', () => {
+    it('should compute average rating', () => {
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: '',
+      });
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 2, comment: '',
+      });
+      expect(reviews.getAverageRating('p')).toBe(3);
+    });
+
+    it('should exclude flagged reviews from average', () => {
+      const r1 = reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '',
+      });
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 1, comment: 'spam',
+      });
+      reviews.flagReview(r1.id + 1); // flag the 1-star review
+      expect(reviews.getAverageRating('p')).toBe(5);
+    });
+
+    it('should return 0 for no reviews', () => {
+      expect(reviews.getAverageRating('unknown')).toBe(0);
+    });
+  });
+
+  describe('flagReview', () => {
+    it('should flag a review', () => {
+      const review = reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u', rating: 1, comment: 'bad',
+      });
+      reviews.flagReview(review.id);
+      const flagged = reviews.getFlaggedReviews();
+      expect(flagged).toHaveLength(1);
+      expect(flagged[0].id).toBe(review.id);
+      expect(flagged[0].flagged).toBe(true);
+    });
+  });
+
+  describe('getFlaggedReviews', () => {
+    it('should return only flagged reviews', () => {
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '',
+      });
+      const bad = reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 1, comment: 'spam',
+      });
+      reviews.flagReview(bad.id);
+      const flagged = reviews.getFlaggedReviews();
+      expect(flagged).toHaveLength(1);
+      expect(flagged[0].userId).toBe('u2');
+    });
+
+    it('should return empty if no flagged reviews', () => {
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u', rating: 5, comment: '',
+      });
+      expect(reviews.getFlaggedReviews()).toHaveLength(0);
+    });
+  });
+
+  describe('removeReview', () => {
+    it('should remove a review', () => {
+      const review = reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u', rating: 3, comment: '',
+      });
+      expect(reviews.removeReview(review.id)).toBe(true);
+      expect(reviews.getReviews('p')).toHaveLength(0);
+    });
+
+    it('should return false for non-existent review', () => {
+      expect(reviews.removeReview(999)).toBe(false);
+    });
+  });
+
+  describe('getReviewsByUser', () => {
+    it('should return reviews by a specific user', () => {
+      reviews.addReview({
+        pluginName: 'a', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: '',
+      });
+      reviews.addReview({
+        pluginName: 'b', pluginVersion: '1.0.0', userId: 'user2', rating: 3, comment: '',
+      });
+      reviews.addReview({
+        pluginName: 'c', pluginVersion: '1.0.0', userId: 'user1', rating: 4, comment: '',
+      });
+      const result = reviews.getReviewsByUser('user1');
+      expect(result).toHaveLength(2);
+    });
+
+    it('should return empty for unknown user', () => {
+      expect(reviews.getReviewsByUser('nobody')).toHaveLength(0);
+    });
+  });
+
+  describe('getReviewCount', () => {
+    it('should return count of reviews for a plugin', () => {
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '',
+      });
+      reviews.addReview({
+        pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: '',
+      });
+      expect(reviews.getReviewCount('p')).toBe(2);
+    });
+
+    it('should return 0 for unknown plugin', () => {
+      expect(reviews.getReviewCount('unknown')).toBe(0);
+    });
+  });
+});
