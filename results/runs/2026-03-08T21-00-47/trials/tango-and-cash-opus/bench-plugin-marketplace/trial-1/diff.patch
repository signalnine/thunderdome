) =>\n        resolver.resolve([{ name: 'missing', range: '^1.0.0' }], {})\n      ).toThrow('No versions available for missing');\n    });\n\n    it('should throw when no version satisfies range', () => {\n      expect(() =>\n        resolver.resolve(\n          [{ name: 'foo', range: '^3.0.0' }],\n          { foo: ['1.0.0', '2.0.0'] }\n        )\n      ).toThrow('No version of foo satisfies range ^3.0.0');\n    });\n\n    it('should handle empty constraints', () => {\n      const results = resolver.resolve([], {});\n      expect(results).toHaveLength(0);\n    });\n\n    it('should pick the max satisfying version', () => {\n      const results = resolver.resolve(\n        [{ name: 'x', range: '>=1.0.0 <2.0.0' }],\n        { x: ['0.9.0', '1.0.0', '1.5.0', '1.9.9', '2.0.0'] }\n      );\n      expect(results[0].version).toBe('1.9.9');\n    });\n  });\n\n  describe('satisfies', () => {\n    it('should return true for matching version', () => {\n      expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);\n    });\n\n    it('should return false for non-matching version', () => {\n      expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n    });\n\n    it('should work with exact versions', () => {\n      expect(resolver.satisfies('1.0.0', '1.0.0')).toBe(true);\n      expect(resolver.satisfies('1.0.1', '1.0.0')).toBe(false);\n    });\n\n    it('should work with tilde ranges', () => {\n      expect(resolver.satisfies('1.0.5', '~1.0.0')).toBe(true);\n      expect(resolver.satisfies('1.1.0', '~1.0.0')).toBe(false);\n    });\n  });\n\n  describe('maxSatisfying', () => {\n    it('should return highest matching version', () => {\n      expect(resolver.maxSatisfying(['1.0.0', '1.1.0', '2.0.0'], '^1.0.0')).toBe('1.1.0');\n    });\n\n    it('should return null when none match', () => {\n      expect(resolver.maxSatisfying(['0.1.0', '0.2.0'], '^1.0.0')).toBeNull();\n    });\n\n    it('should handle empty version list', () => {\n      expect(resolver.maxSatisfying([], '^1.0.0')).toBeNull();\n    });\n  });\n\n  describe('validRange', () => {\n    it('should return true for valid ranges', () => {\n      expect(resolver.validRange('^1.0.0')).toBe(true);\n      expect(resolver.validRange('~1.0.0')).toBe(true);\n      expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);\n      expect(resolver.validRange('1.0.0')).toBe(true);\n      expect(resolver.validRange('*')).toBe(true);\n    });\n\n    it('should return false for invalid ranges', () => {\n      expect(resolver.validRange('not-a-range')).toBe(false);\n      expect(resolver.validRange('')).toBe(false);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":108,"oldLines":7,"newStart":108,"newLines":6,"lines":[" ","     it('should return false for invalid ranges', () => {","       expect(resolver.validRange('not-a-range')).toBe(false);","-      expect(resolver.validRange('')).toBe(false);","     });","   });"," });"]}],"userModified":false,"replaceAll":false}}
