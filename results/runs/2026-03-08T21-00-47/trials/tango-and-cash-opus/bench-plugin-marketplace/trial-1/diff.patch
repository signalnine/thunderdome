 '' }))\n      ).rejects.toThrow('version');\n    });\n\n    it('should reject plugin without entryPoint', async () => {\n      await expect(\n        marketplace.installPlugin(makeManifest({ entryPoint: '' }))\n      ).rejects.toThrow('entryPoint');\n    });\n\n    it('should resolve dependencies during install', async () => {\n      // Register the dependency first\n      marketplace.registry.register(makeManifest({\n        name: 'dep-plugin',\n        version: '1.0.0',\n        entryPoint: '\"dep loaded\"',\n      }));\n      marketplace.registry.register(makeManifest({\n        name: 'dep-plugin',\n        version: '1.1.0',\n        entryPoint: '\"dep loaded\"',\n      }));\n\n      const result = await marketplace.installPlugin(makeManifest({\n        name: 'main-plugin',\n        dependencies: { 'dep-plugin': '^1.0.0' },\n      }));\n\n      expect(result.resolvedVersions).toHaveLength(1);\n      expect(result.resolvedVersions[0].name).toBe('dep-plugin');\n      expect(result.resolvedVersions[0].version).toBe('1.1.0');\n    });\n\n    it('should reject circular dependencies', async () => {\n      // Register plugin-b that depends on plugin-a\n      marketplace.registry.register(makeManifest({\n        name: 'plugin-b',\n        version: '1.0.0',\n        dependencies: { 'plugin-a': '^1.0.0' },\n      }));\n\n      // Try to install plugin-a that depends on plugin-b\n      await expect(\n        marketplace.installPlugin(makeManifest({\n          name: 'plugin-a',\n          version: '1.0.0',\n          dependencies: { 'plugin-b': '^1.0.0' },\n        }))\n      ).rejects.toThrow('Circular dependency');\n    });\n\n    it('should execute entry point code', async () => {\n      const result = await marketplace.installPlugin(makeManifest({\n        entryPoint: '42 * 2',\n      }));\n      expect(result.sandboxResult.success).toBe(true);\n      expect(result.sandboxResult.output).toBe(84);\n    });\n\n    it('should handle entry point errors', async () => {\n      const result = await marketplace.installPlugin(makeManifest({\n        entryPoint: 'throw new Error(\"init failed\")',\n      }));\n      expect(result.sandboxResult.success).toBe(false);\n      expect(result.sandboxResult.error).toBe('init failed');\n    });\n\n    it('should register plugin in registry after install', async () => {\n      await marketplace.installPlugin(makeManifest({ name: 'installed-plugin' }));\n      const plugin = marketplace.registry.get('installed-plugin');\n      expect(plugin).not.toBeNull();\n      expect(plugin!.name).toBe('installed-plugin');\n    });\n\n    it('should remove plugin from registry on circular dependency rejection', async () => {\n      marketplace.registry.register(makeManifest({\n        name: 'plugin-b',\n        version: '1.0.0',\n        dependencies: { 'plugin-a': '^1.0.0' },\n      }));\n\n      try {\n        await marketplace.installPlugin(makeManifest({\n          name: 'plugin-a',\n          version: '1.0.0',\n          dependencies: { 'plugin-b': '^1.0.0' },\n        }));\n      } catch {\n        // expected\n      }\n\n      // plugin-a should be removed since it had circular deps\n      expect(marketplace.registry.getVersion('plugin-a', '1.0.0')).toBeNull();\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2105,"cache_read_input_tokens":38517,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2105},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"41d8807c-a87f-4a42-8c3a-173f27c65fca","uuid":"9e703f79-d516-4fe8-9fe5-b0c033114cd4"}
