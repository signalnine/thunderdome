+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  if (m === 0) {
+    return target.every(t => !t) ? [] : null;
+  }
+
+  // Build augmented matrix [A | b] over GF(2), size n x (m+1)
+  // A[i][j] = 1 if button j toggles light i
+  const mat: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    row[m] = target[i] ? 1 : 0;
+    mat.push(row);
+  }
+  for (let j = 0; j < m; j++) {
+    for (const li of buttons[j]) {
+      if (li >= 0 && li < n) mat[li][j] ^= 1;
+    }
+  }
+
+  // Gaussian elimination to RREF over GF(2)
+  const pivotCols: number[] = [];
+  const isPivotCol = new Uint8Array(m);
+  let rank = 0;
+
+  for (let col = 0; col < m && rank < n; col++) {
+    // Find pivot row
+    let pr = -1;
+    for (let row = rank; row < n; row++) {
+      if (mat[row][col] === 1) { pr = row; break; }
+    }
+    if (pr === -1) continue;
+
+    // Swap rows
+    const tmp = mat[rank]; mat[rank] = mat[pr]; mat[pr] = tmp;
+
+    // Eliminate column from all other rows
+    for (let row = 0; row < n; row++) {
+      if (row !== rank && mat[row][col] === 1) {
+        for (let c = col; c <= m; c++) {
+          mat[row][c] ^= mat[rank][c];
+        }
+      }
+    }
+
+    pivotCols.push(col);
+    isPivotCol[col] = 1;
+    rank++;
+  }
+
+  // Check consistency: any row [0 ... 0 | 1] means no solution
+  for (let row = rank; row < n; row++) {
+    if (mat[row][m] === 1) return null;
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < m; col++) {
+    if (!isPivotCol[col]) freeVars.push(col);
+  }
+  const numFree = freeVars.length;
+
+  // Enumerate all 2^numFree assignments to find minimum-weight, lex-smallest solution
+  let bestIndices: number[] | null = null;
+  let bestCount = m + 1;
+
+  const freeVals = new Uint8Array(numFree);
+  let done = false;
+
+  while (!done) {
+    // Compute full solution from free variable assignment
+    const x = new Uint8Array(m);
+    for (let k = 0; k < numFree; k++) {
+      x[freeVars[k]] = freeVals[k];
+    }
+    for (let r = 0; r < rank; r++) {
+      const pcol = pivotCols[r];
+      let val = mat[r][m];
+      for (let c = pcol + 1; c < m; c++) {
+        val ^= mat[r][c] & x[c];
+      }
+      x[pcol] = val;
+    }
+
+    // Collect pressed button indices
+    const pressed: number[] = [];
+    for (let j = 0; j < m; j++) {
+      if (x[j]) pressed.push(j);
+    }
+
+    if (pressed.length < bestCount ||
+        (pressed.length === bestCount && lexSmaller(pressed, bestIndices!))) {
+      bestCount = pressed.length;
+      bestIndices = pressed;
+    }
+
+    // Increment binary counter over free variables
+    done = true;
+    for (let i = 0; i < numFree; i++) {
+      freeVals[i] ^= 1;
+      if (freeVals[i] === 1) { done = false; break; }
+    }
+  }
+
+  return bestIndices;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+
+  if (m === 0) {
+    return lights.every(l => l % modulus === 0) ? [] : null;
+  }
+
+  // Build augmented matrix [A | b] over GF(modulus), size n x (m+1)
+  const mat: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    row[m] = ((lights[i] % modulus) + modulus) % modulus;
+    mat.push(row);
+  }
+  for (let j = 0; j < m; j++) {
+    for (const li of buttons[j]) {
+      if (li >= 0 && li < n) {
+        mat[li][j] = (mat[li][j] + 1) % modulus;
+      }
+    }
+  }
+
+  // Gaussian elimination to RREF over GF(modulus) (modulus is prime)
+  const pivotCols: number[] = [];
+  const isPivotCol = new Uint8Array(m);
+  let rank = 0;
+
+  for (let col = 0; col < m && rank < n; col++) {
+    let pr = -1;
+    for (let row = rank; row < n; row++) {
+      if (mat[row][col] !== 0) { pr = row; break; }
+    }
+    if (pr === -1) continue;
+
+    const tmp = mat[rank]; mat[rank] = mat[pr]; mat[pr] = tmp;
+
+    // Scale pivot row so leading entry becomes 1
+    const inv = modInverse(mat[rank][col], modulus);
+    for (let c = col; c <= m; c++) {
+      mat[rank][c] = (mat[rank][c] * inv) % modulus;
+    }
+
+    // Eliminate column from all other rows
+    for (let row = 0; row < n; row++) {
+      if (row !== rank && mat[row][col] !== 0) {
+        const factor = mat[row][col];
+        for (let c = col; c <= m; c++) {
+          mat[row][c] = ((mat[row][c] - factor * mat[rank][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+
+    pivotCols.push(col);
+    isPivotCol[col] = 1;
+    rank++;
+  }
+
+  // Check consistency
+  for (let row = rank; row < n; row++) {
+    if (mat[row][m] !== 0) return null;
+  }
+
+  // Identify free variables
+  const freeVars: number[] = [];
+  for (let col = 0; col < m; col++) {
+    if (!isPivotCol[col]) freeVars.push(col);
+  }
+  const numFree = freeVars.length;
+
+  // Enumerate all modulus^numFree assignments to find min-total, lex-smallest solution
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  const freeVals = new Array(numFree).fill(0);
+  let done = false;
+
+  while (!done) {
+    const x = new Array(m).fill(0);
+    for (let k = 0; k < numFree; k++) {
+      x[freeVars[k]] = freeVals[k];
+    }
+    for (let r = 0; r < rank; r++) {
+      const pcol = pivotCols[r];
+      let val = mat[r][m];
+      for (let c = pcol + 1; c < m; c++) {
+        if (mat[r][c] !== 0 && x[c] !== 0) {
+          val = ((val - mat[r][c] * x[c]) % modulus + modulus) % modulus;
+        }
+      }
+      x[pcol] = val;
+    }
+
+    let total = 0;
+    for (let j = 0; j < m; j++) total += x[j];
+
+    if (total < bestTotal || (total === bestTotal && lexSmallerArr(x, bestSolution!))) {
+      bestTotal = total;
+      bestSolution = x.slice();
+    }
+
+    // Increment base-modulus counter over free variables
+    done = true;
+    for (let i = 0; i < numFree; i++) {
+      freeVals[i]++;
+      if (freeVals[i] < modulus) { done = false; break; }
+      freeVals[i] = 0;
+    }
+  }
+
+  return bestSolution;
+}
+
+function modInverse(a: number, p: number): number {
+  a = ((a % p) + p) % p;
+  let [old_r, r] = [a, p];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % p) + p) % p;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+function lexSmallerArr(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
