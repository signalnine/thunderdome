+/**
+ * Discovery layer for the factory reset implementation.
+ *
+ * Dynamically imports from ../src/ and tries to find solveToggle and
+ * solveCounter functions regardless of how the implementor exported them.
+ */
+
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export interface FactoryAPI {
+  solveToggle: (machine: Machine) => number[] | null;
+  solveCounter: (lights: number[], buttons: number[][], modulus: number) => number[] | null;
+}
+
+const TOGGLE_ALIASES = [
+  'solveToggle', 'toggle', 'solve', 'solvePuzzle',
+  'solveButtons', 'solveToggles', 'solveMachine',
+  'findSolution', 'findButtons',
+];
+const COUNTER_ALIASES = [
+  'solveCounter', 'counter', 'solveCounters', 'solveModular',
+  'solveIncrement', 'solveCounterPuzzle', 'solveMod',
+];
+
+function findFunction(obj: any, aliases: string[]): ((...args: any[]) => any) | null {
+  for (const name of aliases) {
+    if (typeof obj[name] === 'function') return obj[name].bind(obj);
+  }
+  return null;
+}
+
+async function tryImport(): Promise<any> {
+  const paths = [
+    '../src/index.js',
+    '../src/factory.js',
+    '../src/solver.js',
+    '../src/puzzle.js',
+    '../src/index.ts',
+    '../src/factory.ts',
+    '../src/solver.ts',
+    '../src/puzzle.ts',
+  ];
+  for (const p of paths) {
+    try {
+      return await import(p);
+    } catch {
+      // try next
+    }
+  }
+  throw new Error('Could not import factory reset from any of: ' + paths.join(', '));
+}
+
+function extractFromObject(obj: any): { toggle: Function | null; counter: Function | null } {
+  return {
+    toggle: findFunction(obj, TOGGLE_ALIASES),
+    counter: findFunction(obj, COUNTER_ALIASES),
+  };
+}
+
+export async function discover(): Promise<FactoryAPI> {
+  const mod = await tryImport();
+
+  // 1. Direct named exports
+  let { toggle, counter } = extractFromObject(mod);
+  if (toggle && counter) return { solveToggle: toggle as any, solveCounter: counter as any };
+
+  // 2. Class exports
+  const classNames = [
+    'Factory', 'FactoryReset', 'Solver', 'PuzzleSolver',
+    'ToggleSolver', 'MachineSolver',
+  ];
+  for (const name of classNames) {
+    if (mod[name] && typeof mod[name] === 'function') {
+      try {
+        const instance = new mod[name]();
+        const result = extractFromObject(instance);
+        if (result.toggle && result.counter) {
+          return { solveToggle: result.toggle as any, solveCounter: result.counter as any };
+        }
+      } catch {
+        // try next
+      }
+    }
+  }
+
+  // 3. Factory functions
+  const factoryNames = [
+    'createSolver', 'create', 'createFactory',
+    'makeSolver', 'makeFactory',
+  ];
+  for (const name of factoryNames) {
+    if (typeof mod[name] === 'function') {
+      try {
+        const instance = mod[name]();
+        const result = extractFromObject(instance);
+        if (result.toggle && result.counter) {
+          return { solveToggle: result.toggle as any, solveCounter: result.counter as any };
+        }
+      } catch {
+        // try next
+      }
+    }
+  }
+
+  // 4. Default export
+  const def = mod.default;
+  if (def) {
+    if (typeof def === 'function') {
+      try {
+        const instance = new def();
+        const result = extractFromObject(instance);
+        if (result.toggle && result.counter) {
+          return { solveToggle: result.toggle as any, solveCounter: result.counter as any };
+        }
+      } catch {
+        try {
+          const instance = def();
+          const result = extractFromObject(instance);
+          if (result.toggle && result.counter) {
+            return { solveToggle: result.toggle as any, solveCounter: result.counter as any };
+          }
+        } catch {
+          // skip
+        }
+      }
+    } else if (typeof def === 'object') {
+      const result = extractFromObject(def);
+      if (result.toggle && result.counter) {
+        return { solveToggle: result.toggle as any, solveCounter: result.counter as any };
+      }
+    }
+  }
+
+  // 5. Partial fallback
+  if (!toggle) toggle = findFunction(mod, TOGGLE_ALIASES);
+  if (!counter) counter = findFunction(mod, COUNTER_ALIASES);
+
+  for (const key of Object.keys(mod)) {
+    const val = mod[key];
+    if (val && typeof val === 'object') {
+      if (!toggle) toggle = findFunction(val, TOGGLE_ALIASES);
+      if (!counter) counter = findFunction(val, COUNTER_ALIASES);
+    }
+  }
+
+  if (!toggle) throw new Error('Could not find solveToggle function. Tried: ' + TOGGLE_ALIASES.join(', '));
+  if (!counter) throw new Error('Could not find solveCounter function. Tried: ' + COUNTER_ALIASES.join(', '));
+
+  return { solveToggle: toggle as any, solveCounter: counter as any };
+}
