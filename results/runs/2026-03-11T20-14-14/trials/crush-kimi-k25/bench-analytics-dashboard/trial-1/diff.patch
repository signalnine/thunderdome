+export type UserRole = 'admin' | 'editor' | 'viewer';
+
+export interface User {
+  id: string;
+  email: string;
+  password_hash: string;
+  tenant_id: string;
+  role: UserRole;
+  created_at: string;
+}
+
+export interface Event {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+export interface Dashboard {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface AuthenticatedRequest extends Request {
+  user?: User;
+}
+
+export interface EventInput {
+  name: string;
+  properties?: Record<string, unknown>;
+  timestamp?: string;
+  user_id?: string;
+  session_id?: string;
+}
+
+export interface QueryFilter {
+  name?: string;
+  startDate?: string;
+  endDate?: string;
+  properties?: Record<string, unknown>;
+}
+
+export interface TimeseriesBucket {
+  bucket: string;
+  count: number;
+}
+
+export interface BreakdownResult {
+  value: string;
+  count: number;
+}
