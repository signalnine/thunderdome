@@ -0,0 +1,100 @@
+import { Router } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../db.js';
+import { authMiddleware, type AuthRequest } from '../auth.js';
+import type { EventInput } from '../types.js';
+
+const router = Router();
+
+// Ingest single event
+router.post('/', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const { name, properties = {}, timestamp, user_id, session_id } = req.body as EventInput;
+  
+  if (!name) {
+    res.status(400).json({ error: 'Event name is required' });
+    return;
+  }
+  
+  const db = getDb();
+  const id = uuidv4();
+  const eventTimestamp = timestamp || new Date().toISOString();
+  
+  db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  ).run(
+    id,
+    user.tenant_id,
+    name,
+    JSON.stringify(properties),
+    eventTimestamp,
+    user_id || null,
+    session_id || null
+  );
+  
+  res.status(201).json({
+    id,
+    tenant_id: user.tenant_id,
+    name,
+    properties,
+    timestamp: eventTimestamp,
+    user_id: user_id || null,
+    session_id: session_id || null,
+  });
+});
+
+// Batch ingest events
+router.post('/batch', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const { events } = req.body as { events: EventInput[] };
+  
+  if (!Array.isArray(events) || events.length === 0) {
+    res.status(400).json({ error: 'Events array is required' });
+    return;
+  }
+  
+  const db = getDb();
+  const inserted: unknown[] = [];
+  
+  const insert = db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  );
+  
+  const batchInsert = db.transaction((eventList: EventInput[]) => {
+    for (const event of eventList) {
+      if (!event.name) continue;
+      
+      const id = uuidv4();
+      const eventTimestamp = event.timestamp || new Date().toISOString();
+      
+      insert.run(
+        id,
+        user.tenant_id,
+        event.name,
+        JSON.stringify(event.properties || {}),
+        eventTimestamp,
+        event.user_id || null,
+        event.session_id || null
+      );
+      
+      inserted.push({
+        id,
+        tenant_id: user.tenant_id,
+        name: event.name,
+        properties: event.properties || {},
+        timestamp: eventTimestamp,
+        user_id: event.user_id || null,
+        session_id: event.session_id || null,
+      });
+    }
+  });
+  
+  batchInsert(events);
+  
+  res.status(201).json({
+    inserted: inserted.length,
+    events: inserted,
+  });
+});
+
+export default router;
