@@ -0,0 +1,114 @@
+import { Router } from 'express';
+import { getDb } from '../db.js';
+import { authMiddleware, type AuthRequest } from '../auth.js';
+import type { QueryFilter, TimeseriesBucket, BreakdownResult } from '../types.js';
+
+const router = Router();
+
+// Build WHERE clause from filter
+function buildFilterClause(tenantId: string, filter: QueryFilter): { clause: string; params: unknown[] } {
+  const conditions: string[] = ['tenant_id = ?'];
+  const params: unknown[] = [tenantId];
+  
+  if (filter.name) {
+    conditions.push('name = ?');
+    params.push(filter.name);
+  }
+  
+  if (filter.startDate) {
+    conditions.push('timestamp >= ?');
+    params.push(filter.startDate);
+  }
+  
+  if (filter.endDate) {
+    conditions.push('timestamp <= ?');
+    params.push(filter.endDate);
+  }
+  
+  if (filter.properties) {
+    for (const [key, value] of Object.entries(filter.properties)) {
+      conditions.push(`json_extract(properties, '$.${key}') = ?`);
+      params.push(value);
+    }
+  }
+  
+  return { clause: conditions.join(' AND '), params };
+}
+
+// Count events
+router.post('/count', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const filter: QueryFilter = req.body;
+  
+  const { clause, params } = buildFilterClause(user.tenant_id, filter);
+  const db = getDb();
+  
+  const result = db.prepare(`SELECT COUNT(*) as count FROM events WHERE ${clause}`).get(...params) as { count: number };
+  
+  res.json({ count: result.count });
+});
+
+// Timeseries query
+router.post('/timeseries', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const { interval = 'day', ...filter } = req.body as QueryFilter & { interval?: 'hour' | 'day' | 'week' | 'month' };
+  
+  const { clause, params } = buildFilterClause(user.tenant_id, filter);
+  const db = getDb();
+  
+  let timeFormat: string;
+  switch (interval) {
+    case 'hour':
+      timeFormat = '%Y-%m-%dT%H:00:00';
+      break;
+    case 'week':
+      timeFormat = '%Y-%W';
+      break;
+    case 'month':
+      timeFormat = '%Y-%m';
+      break;
+    case 'day':
+    default:
+      timeFormat = '%Y-%m-%d';
+  }
+  
+  const results = db.prepare(`
+    SELECT 
+      strftime('${timeFormat}', timestamp) as bucket,
+      COUNT(*) as count
+    FROM events
+    WHERE ${clause}
+    GROUP BY bucket
+    ORDER BY bucket
+  `).all(...params) as TimeseriesBucket[];
+  
+  res.json(results);
+});
+
+// Breakdown query
+router.post('/breakdown', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const { property, ...filter } = req.body as QueryFilter & { property: string };
+  
+  if (!property) {
+    res.status(400).json({ error: 'Property name is required' });
+    return;
+  }
+  
+  const { clause, params } = buildFilterClause(user.tenant_id, filter);
+  const db = getDb();
+  
+  const results = db.prepare(`
+    SELECT 
+      json_extract(properties, '$.${property}') as value,
+      COUNT(*) as count
+    FROM events
+    WHERE ${clause} AND json_extract(properties, '$.${property}') IS NOT NULL
+    GROUP BY value
+    ORDER BY count DESC
+  `).all(...params) as BreakdownResult[];
+  
+  res.json(results);
+});
+
+export default router;
