+import { Router } from 'express';
+import { getDb } from '../db.js';
+import { authMiddleware, type AuthRequest } from '../auth.js';
+import type { QueryFilter, Event, Dashboard } from '../types.js';
+
+const router = Router();
+
+// Build WHERE clause from filter
+function buildFilterClause(tenantId: string, filter: QueryFilter): { clause: string; params: unknown[] } {
+  const conditions: string[] = ['tenant_id = ?'];
+  const params: unknown[] = [tenantId];
+  
+  if (filter.name) {
+    conditions.push('name = ?');
+    params.push(filter.name);
+  }
+  
+  if (filter.startDate) {
+    conditions.push('timestamp >= ?');
+    params.push(filter.startDate);
+  }
+  
+  if (filter.endDate) {
+    conditions.push('timestamp <= ?');
+    params.push(filter.endDate);
+  }
+  
+  if (filter.properties) {
+    for (const [key, value] of Object.entries(filter.properties)) {
+      conditions.push(`json_extract(properties, '$.${key}') = ?`);
+      params.push(value);
+    }
+  }
+  
+  return { clause: conditions.join(' AND '), params };
+}
+
+// Escape CSV value
+function escapeCsv(value: unknown): string {
+  if (value === null || value === undefined) return '';
+  const str = String(value);
+  if (str.includes(',') || str.includes('"') || str.includes('\n')) {
+    return `"${str.replace(/"/g, '""')}"`;
+  }
+  return str;
+}
+
+// Export events as JSON
+router.get('/events.json', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const filter: QueryFilter = {
+    name: req.query.name as string | undefined,
+    startDate: req.query.startDate as string | undefined,
+    endDate: req.query.endDate as string | undefined,
+  };
+  
+  const { clause, params } = buildFilterClause(user.tenant_id, filter);
+  const db = getDb();
+  
+  const events = db.prepare(`
+    SELECT id, tenant_id, name, properties, timestamp, user_id, session_id
+    FROM events
+    WHERE ${clause}
+    ORDER BY timestamp DESC
+  `).all(...params) as Event[];
+  
+  const formattedEvents = events.map(e => ({
+    ...e,
+    properties: JSON.parse(e.properties),
+  }));
+  
+  res.setHeader('Content-Type', 'application/json');
+  res.setHeader('Content-Disposition', 'attachment; filename="events.json"');
+  res.json(formattedEvents);
+});
+
+// Export events as CSV
+router.get('/events.csv', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const filter: QueryFilter = {
+    name: req.query.name as string | undefined,
+    startDate: req.query.startDate as string | undefined,
+    endDate: req.query.endDate as string | undefined,
+  };
+  
+  const { clause, params } = buildFilterClause(user.tenant_id, filter);
+  const db = getDb();
+  
+  const events = db.prepare(`
+    SELECT id, tenant_id, name, properties, timestamp, user_id, session_id
+    FROM events
+    WHERE ${clause}
+    ORDER BY timestamp DESC
+  `).all(...params) as Event[];
+  
+  const headers = ['id', 'tenant_id', 'name', 'properties', 'timestamp', 'user_id', 'session_id'];
+  const rows = events.map(e => [
+    e.id,
+    e.tenant_id,
+    e.name,
+    escapeCsv(e.properties),
+    e.timestamp,
+    e.user_id || '',
+    e.session_id || '',
+  ]);
+  
+  const csv = [
+    headers.join(','),
+    ...rows.map(row => row.map(escapeCsv).join(',')),
+  ].join('\n');
+  
+  res.setHeader('Content-Type', 'text/csv');
+  res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+  res.send(csv);
+});
+
+// Export dashboards as JSON
+router.get('/dashboards.json', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const db = getDb();
+  
+  const dashboards = db.prepare(
+    'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ?'
+  ).all(user.tenant_id) as Dashboard[];
+  
+  const formattedDashboards = dashboards.map(d => ({
+    ...d,
+    config: JSON.parse(d.config),
+  }));
+  
+  res.setHeader('Content-Type', 'application/json');
+  res.setHeader('Content-Disposition', 'attachment; filename="dashboards.json"');
+  res.json(formattedDashboards);
+});
+
+// Export dashboards as CSV
+router.get('/dashboards.csv', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const db = getDb();
+  
+  const dashboards = db.prepare(
+    'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ?'
+  ).all(user.tenant_id) as Dashboard[];
+  
+  const headers = ['id', 'tenant_id', 'name', 'owner_id', 'config', 'created_at', 'updated_at'];
+  const rows = dashboards.map(d => [
+    d.id,
+    d.tenant_id,
+    d.name,
+    d.owner_id,
+    escapeCsv(d.config),
+    d.created_at,
+    d.updated_at,
+  ]);
+  
+  const csv = [
+    headers.join(','),
+    ...rows.map(row => row.map(escapeCsv).join(',')),
+  ].join('\n');
+  
+  res.setHeader('Content-Type', 'text/csv');
+  res.setHeader('Content-Disposition', 'attachment; filename="dashboards.csv"');
+  res.send(csv);
+});
+
+export default router;
