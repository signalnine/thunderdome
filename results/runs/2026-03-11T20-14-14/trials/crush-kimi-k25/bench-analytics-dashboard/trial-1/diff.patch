+import { Router } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../db.js';
+import { authMiddleware, type AuthRequest } from '../auth.js';
+import type { Dashboard } from '../types.js';
+
+const router = Router();
+
+// List dashboards for tenant
+router.get('/', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const db = getDb();
+  
+  const dashboards = db.prepare(
+    'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ?'
+  ).all(user.tenant_id);
+  
+  res.json((dashboards as Dashboard[]).map(d => ({
+    ...d,
+    config: JSON.parse(d.config),
+  })));
+});
+
+// Get single dashboard
+router.get('/:id', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const { id } = req.params;
+  const db = getDb();
+  
+  const dashboard = db.prepare(
+    'SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE id = ? AND tenant_id = ?'
+  ).get(id, user.tenant_id) as Dashboard | undefined;
+  
+  if (!dashboard) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+  
+  res.json({
+    ...dashboard,
+    config: JSON.parse(dashboard.config),
+  });
+});
+
+// Create dashboard
+router.post('/', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const { name, config = {} } = req.body;
+  
+  if (!name) {
+    res.status(400).json({ error: 'Dashboard name is required' });
+    return;
+  }
+  
+  const db = getDb();
+  const id = uuidv4();
+  const now = new Date().toISOString();
+  
+  db.prepare(
+    'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  ).run(id, user.tenant_id, name, user.id, JSON.stringify(config), now, now);
+  
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(id) as Dashboard;
+  
+  res.status(201).json({
+    ...dashboard,
+    config: JSON.parse(dashboard.config),
+  });
+});
+
+// Update dashboard
+router.patch('/:id', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const { id } = req.params;
+  const { name, config } = req.body;
+  const db = getDb();
+  
+  const existing = db.prepare(
+    'SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?'
+  ).get(id, user.tenant_id) as Dashboard | undefined;
+  
+  if (!existing) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+  
+  // Only admin, editor, or owner can update
+  if (user.role === 'viewer' && existing.owner_id !== user.id) {
+    res.status(403).json({ error: 'Forbidden - Cannot update this dashboard' });
+    return;
+  }
+  
+  const updates: string[] = [];
+  const params: unknown[] = [];
+  
+  if (name !== undefined) {
+    updates.push('name = ?');
+    params.push(name);
+  }
+  
+  if (config !== undefined) {
+    updates.push('config = ?');
+    params.push(JSON.stringify(config));
+  }
+  
+  updates.push('updated_at = ?');
+  params.push(new Date().toISOString());
+  
+  params.push(id);
+  
+  db.prepare(`UPDATE dashboards SET ${updates.join(', ')} WHERE id = ?`).run(...params);
+  
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ?').get(id) as Dashboard;
+  
+  res.json({
+    ...dashboard,
+    config: JSON.parse(dashboard.config),
+  });
+});
+
+// Delete dashboard
+router.delete('/:id', authMiddleware, (req: AuthRequest, res) => {
+  const user = req.user!;
+  const { id } = req.params;
+  const db = getDb();
+  
+  const existing = db.prepare(
+    'SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?'
+  ).get(id, user.tenant_id) as Dashboard | undefined;
+  
+  if (!existing) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+  
+  // Only admin or owner can delete
+  if (user.role !== 'admin' && existing.owner_id !== user.id) {
+    res.status(403).json({ error: 'Forbidden - Cannot delete this dashboard' });
+    return;
+  }
+  
+  db.prepare('DELETE FROM dashboards WHERE id = ?').run(id);
+  
+  res.status(204).send();
+});
+
+export default router;
