+import { describe, it, expect } from 'vitest';
+import { simulate } from '../index.js';
+import type { Gate } from '../index.js';
+
+describe('simulate', () => {
+  it('should evaluate a single AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const inputs = { a: 1, b: 1 };
+    const result = simulate(gates, inputs);
+    expect(result['c']).toBe(1);
+    expect(result['a']).toBe(1);
+    expect(result['b']).toBe(1);
+  });
+
+  it('should evaluate AND gate with 0 input', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    const inputs = { a: 1, b: 0 };
+    const result = simulate(gates, inputs);
+    expect(result['c']).toBe(0);
+  });
+
+  it('should evaluate a single OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    const inputs = { a: 0, b: 1 };
+    const result = simulate(gates, inputs);
+    expect(result['c']).toBe(1);
+  });
+
+  it('should evaluate OR gate with both 0', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    const inputs = { a: 0, b: 0 };
+    const result = simulate(gates, inputs);
+    expect(result['c']).toBe(0);
+  });
+
+  it('should evaluate a single XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    const inputs = { a: 1, b: 1 };
+    const result = simulate(gates, inputs);
+    expect(result['c']).toBe(0);
+  });
+
+  it('should evaluate XOR gate with different inputs', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    const inputs = { a: 1, b: 0 };
+    const result = simulate(gates, inputs);
+    expect(result['c']).toBe(1);
+  });
+
+  it('should handle chained gates in dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    const inputs = { a: 1, b: 0, d: 1 };
+    const result = simulate(gates, inputs);
+    expect(result['c']).toBe(0);
+    expect(result['e']).toBe(1);
+  });
+
+  it('should handle gates listed in non-topological order', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    const inputs = { a: 1, b: 1, d: 0 };
+    const result = simulate(gates, inputs);
+    expect(result['c']).toBe(1);
+    expect(result['e']).toBe(1);
+  });
+
+  it('should simulate a 2-bit adder (11 + 11 = 110)', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },
+    ];
+    // 3 + 3 = 6 (binary: 11 + 11 = 110)
+    const inputs = { x00: 1, x01: 1, y00: 1, y01: 1 };
+    const result = simulate(gates, inputs);
+    expect(result['z00']).toBe(0);
+    expect(result['z01']).toBe(1);
+    expect(result['z02']).toBe(1);
+  });
+
+  it('should simulate a 2-bit adder (10 + 01 = 011)', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },
+    ];
+    // 2 + 1 = 3 (binary: 10 + 01 = 011)
+    const inputs = { x00: 0, x01: 1, y00: 1, y01: 0 };
+    const result = simulate(gates, inputs);
+    expect(result['z00']).toBe(1);
+    expect(result['z01']).toBe(1);
+    expect(result['z02']).toBe(0);
+  });
+
+  it('should return all wire values including intermediates', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'AND', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    const inputs = { a: 1, b: 0, d: 1 };
+    const result = simulate(gates, inputs);
+    expect(Object.keys(result).sort()).toEqual(['a', 'b', 'c', 'd', 'e']);
+    expect(result['c']).toBe(1);
+    expect(result['e']).toBe(1);
+  });
+});
