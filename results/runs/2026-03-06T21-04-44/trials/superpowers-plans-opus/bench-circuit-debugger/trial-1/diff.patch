\n        // It should be the wire that, together with carry, feeds into XOR to produce zi\n        // Look at the gate that outputs zi (if zi is not itself swapped)\n        if (!swapped.has(zi)) {\n          const ziGate = outToGate.get(zi);\n          if (ziGate && ziGate.op === 'XOR') {\n            // One of ziGate's inputs should be carry, the other should be the correct temp\n            const correctTemp = ziGate.in1 === carry ? ziGate.in2 : ziGate.in1;\n            if (correctTemp !== temp) {\n              swapped.add(correctTemp);\n              // Use the correct temp for further tracing\n              temp = correctTemp;\n            }\n          }\n        }\n      }\n\n      // Find XOR(temp, carry) -> should be zi\n      let xorSum = findGate('XOR', temp, carry);\n      if (xorSum) {\n        if (swapped.has(xorSum.out) && xorSum.out !== zi) {\n          swapped.add(zi);\n        }\n      }\n\n      // Find AND(xi, yi) -> gen\n      const andXY = findGate('AND', xi, yi);\n      const gen = andXY ? andXY.out : '';\n\n      // Find AND(temp, carry) -> prop\n      const andTC = findGate('AND', temp, carry);\n      const prop = andTC ? andTC.out : '';\n\n      // Find OR(gen, prop) -> next carry\n      let orGate: Gate | undefined;\n      if (gen && prop) {\n        orGate = findGate('OR', gen, prop);\n      }\n\n      if (orGate) {\n        carry = orGate.out;\n      } else if (gen || prop) {\n        // Can't find OR gate - one of gen/prop might be swapped\n        // Try to find the OR gate that uses one of them\n        const genUsers = gen ? (wireUsers.get(gen) || []).filter(u => u.op === 'OR') : [];\n        const propUsers = prop ? (wireUsers.get(prop) || []).filter(u => u.op === 'OR') : [];\n\n        if (genUsers.length === 1) {\n          carry = genUsers[0].out;\n        } else if (propUsers.length === 1) {\n          carry = propUsers[0].out;\n        }\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}","newString":"export function findSwappedWires(gates: Gate[]): string[] {\n  const swapped: Set<string> = new Set();\n\n  // Determine number of input bits\n  let maxBit = -1;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      if (w.startsWith('x')) {\n        const n = parseInt(w.slice(1));\n        if (n > maxBit) maxBit = n;\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  // Build indices\n  function makeKey(op: string, a: string, b: string): string {\n    return a < b ? `${op}:${a}:${b}` : `${op}:${b}:${a}`;\n  }\n\n  const keyToGate = new Map<string, Gate>();\n  for (const g of gates) {\n    keyToGate.set(makeKey(g.op, g.in1, g.in2), g);\n  }\n\n  const outToGate = new Map<string, Gate>();\n  for (const g of gates) {\n    outToGate.set(g.out, g);\n  }\n\n  function findGate(op: string, in1: string, in2: string): Gate | undefined {\n    return keyToGate.get(makeKey(op, in1, in2));\n  }\n\n  // Build reverse index: wire -> gates that use it as input\n  const wireUsers = new Map<string, Gate[]>();\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      if (!wireUsers.has(w)) wireUsers.set(w, []);\n      wireUsers.get(w)!.push(g);\n    }\n  }\n\n  function hasXYInput(g: Gate): boolean {\n    return (g.in1.startsWith('x') || g.in1.startsWith('y') ||\n            g.in2.startsWith('x') || g.in2.startsWith('y'));\n  }\n\n  function isZWire(w: string): boolean {\n    return w.startsWith('z');\n  }\n\n  // === Phase 1: Structural rule checks ===\n  // These detect violations of the ripple-carry adder invariants\n\n  for (const g of gates) {\n    if (g.op === 'XOR') {\n      if (hasXYInput(g)) {\n        // XOR(xNN, yNN) -> temp wire, should NOT be z (except z00 for bit 0)\n        if (isZWire(g.out) && g.out !== 'z00') {\n          swapped.add(g.out);\n        }\n      } else {\n        // XOR(temp, carry) -> sum bit, MUST be z\n        if (!isZWire(g.out)) {\n          swapped.add(g.out);\n        }\n      }\n    } else if (g.op === 'AND') {\n      // AND output should never be a z-wire\n      if (isZWire(g.out)) {\n        swapped.add(g.out);\n      }\n    } else if (g.op === 'OR') {\n      // OR output is carry -> should NOT be z (except lastZ for final carry)\n      if (isZWire(g.out) && g.out !== lastZ) {\n        swapped.add(g.out);\n      }\n    }\n  }\n\n  // === Phase 2: Connectivity checks ===\n  // Check that each gate's output feeds into the correct type of downstream gate\n\n  for (const g of gates) {\n    const users = wireUsers.get(g.out) || [];\n    const userOps = new Set(users.map(u => u.op));\n\n    if (g.op === 'XOR' && hasXYInput(g) && g.out !== 'z00') {\n      // temp wire should feed into XOR (for sum) and AND (for propagate carry)\n      // If it doesn't feed into XOR, it's swapped (unless it's already flagged as z-wire)\n      if (!userOps.has('XOR') && !userOps.has('AND')) {\n        swapped.add(g.out);\n      }\n    }\n\n    if (g.op === 'AND') {\n      // AND output should feed into OR (carry computation)\n      // Exception: AND(x00, y00) output IS the initial carry - it feeds XOR and AND for bit 1\n      const isBit0And = (g.in1 === 'x00' || g.in2 === 'x00');\n      if (!isBit0And && !userOps.has('OR') && !isZWire(g.out)) {\n        swapped.add(g.out);\n      }\n    }\n\n    if (g.op === 'OR') {\n      // OR output is carry -> should feed into XOR and AND for next bit\n      // Exception: if it's lastZ (final output), it has no downstream\n      if (g.out !== lastZ && !userOps.has('XOR') && !userOps.has('AND')) {\n        swapped.add(g.out);\n      }\n    }\n  }\n\n  // === Phase 3: Find swap partners by tracing the adder ===\n  // For each flagged wire, trace the structure to find what it was swapped with\n\n  if (swapped.size < 8) {\n    let carry = '';\n\n    // Bit 0: half adder\n    const and0 = findGate('AND', 'x00', 'y00');\n    if (and0) {\n      carry = and0.out;\n    }\n\n    for (let i = 1; i < numBits; i++) {\n      const p = String(i).padStart(2, '0');\n      const xi = `x${p}`, yi = `y${p}`, zi = `z${p}`;\n\n      const xorXY = findGate('XOR', xi, yi);\n      if (!xorXY) continue;\n      let temp = xorXY.out;\n\n      // If temp wire is in swapped set, find its partner\n      if (swapped.has(temp)) {\n        // The correct temp should be one of the inputs to the gate that outputs zi\n        const ziGate = outToGate.get(zi);\n        if (ziGate && ziGate.op === 'XOR') {\n          const correctTemp = ziGate.in1 === carry ? ziGate.in2 : ziGate.in1;\n          if (correctTemp !== temp) {\n            swapped.add(correctTemp);\n            temp = correctTemp;\n          }\n        }\n      }\n\n      // Find XOR(temp, carry) -> should produce zi\n      const xorSum = findGate('XOR', temp, carry);\n      if (xorSum && swapped.has(xorSum.out) && xorSum.out !== zi) {\n        swapped.add(zi);\n      }\n\n      // Find AND(xi, yi) -> gen\n      const andXY = findGate('AND', xi, yi);\n      const gen = andXY ? andXY.out : '';\n\n      // Find AND(temp, carry) -> prop\n      const andTC = findGate('AND', temp, carry);\n      const prop = andTC ? andTC.out : '';\n\n      // Find OR(gen, prop) -> next carry\n      let orGate: Gate | undefined;\n      if (gen && prop) {\n        orGate = findGate('OR', gen, prop);\n      }\n\n      if (orGate) {\n        carry = orGate.out;\n      } else {\n        // OR gate not found directly - one of gen/prop is swapped\n        // Try to find the OR gate from whichever of gen/prop is correct\n        let found = false;\n        for (const wire of [gen, prop]) {\n          if (!wire) continue;\n          const users = wireUsers.get(wire) || [];\n          const orUsers = users.filter(u => u.op === 'OR');\n          if (orUsers.length === 1) {\n            const or = orUsers[0];\n            // The other input to the OR is the swap partner\n            const otherInput = or.in1 === wire ? or.in2 : or.in1;\n            carry = or.out;\n          