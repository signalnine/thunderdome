ap<GateKey, Gate>();\n  for (const g of gates) {\n    keyToGate.set(makeKey(g.op, g.in1, g.in2), g);\n  }\n\n  const outToGate = new Map<string, Gate>();\n  for (const g of gates) {\n    outToGate.set(g.out, g);\n  }\n\n  function findGate(op: string, in1: string, in2: string): Gate | undefined {\n    return keyToGate.get(makeKey(op, in1, in2));\n  }\n\n  // Check structural rules and flag violations\n  // Rule 1: XOR gates with x/y inputs should NOT output z-wires (they produce temp wires)\n  // Rule 2: XOR gates without x/y inputs MUST output z-wires (they produce sum bits)\n  // Rule 3: AND/OR gates should NOT output z-wires (except last z for final carry from OR)\n  // Rule 4: z-wires should be outputs of XOR gates (except lastZ)\n\n  function hasXYInput(g: Gate): boolean {\n    return (g.in1.startsWith('x') || g.in1.startsWith('y') ||\n            g.in2.startsWith('x') || g.in2.startsWith('y'));\n  }\n\n  function isZWire(w: string): boolean {\n    return w.startsWith('z');\n  }\n\n  // Collect violations\n  for (const g of gates) {\n    if (g.op === 'XOR') {\n      if (hasXYInput(g)) {\n        // This is XOR(xNN, yNN) -> should produce a temp wire, NOT a z wire\n        // Exception: bit 0 where XOR(x00, y00) -> z00\n        if (isZWire(g.out) && g.out !== 'z00') {\n          swapped.add(g.out);\n        }\n      } else {\n        // This is XOR(temp, carry) -> should produce a z wire\n        if (!isZWire(g.out)) {\n          swapped.add(g.out);\n        }\n      }\n    } else if (g.op === 'AND') {\n      // AND gates should never output z-wires\n      if (isZWire(g.out)) {\n        swapped.add(g.out);\n      }\n    } else if (g.op === 'OR') {\n      // OR gates produce carry -> should NOT be z-wire, except the final carry = lastZ\n      if (isZWire(g.out) && g.out !== lastZ) {\n        swapped.add(g.out);\n      }\n    }\n  }\n\n  // Now for each flagged wire, find its swap partner\n  // We do this by tracing the adder structure bit by bit\n  // If a wire is flagged, we look at what role the gate should play and find\n  // which gate currently has the expected output\n\n  // We also need to check connectivity rules:\n  // - XOR(xNN, yNN) output should be used as input to another XOR and an AND\n  // - XOR(temp, carry) output should be zNN\n  // - AND outputs should be used as inputs to OR\n  // - OR output should be used as carry input to the next bit's XOR and AND\n\n  // Build reverse index: wire -> gates that use it as input\n  const wireUsers = new Map<string, Gate[]>();\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      if (!wireUsers.has(w)) wireUsers.set(w, []);\n      wireUsers.get(w)!.push(g);\n    }\n  }\n\n  // Additional check: XOR(xNN, yNN) output (for bit > 0) should be used by exactly\n  // one other XOR gate and one AND gate. If it's used by an OR gate, something is wrong.\n  for (const g of gates) {\n    if (g.op === 'XOR' && hasXYInput(g) && g.out !== 'z00') {\n      const users = wireUsers.get(g.out) || [];\n      const userOps = users.map(u => u.op);\n      // Should be used by XOR and AND, not OR\n      if (!userOps.includes('XOR') && !isZWire(g.out)) {\n        // This temp wire isn't feeding a XOR -> it's likely been swapped\n        swapped.add(g.out);\n      }\n    }\n  }\n\n  // For AND gates (except bit 0), output should feed into OR\n  for (const g of gates) {\n    if (g.op === 'AND' && !(g.in1 === 'x00' || g.in2 === 'x00' || g.in1 === 'y00' || g.in2 === 'y00')) {\n      const users = wireUsers.get(g.out) || [];\n      const userOps = users.map(u => u.op);\n      if (!userOps.includes('OR') && !isZWire(g.out)) {\n        swapped.add(g.out);\n      }\n    }\n  }\n\n  // Now find swap partners for each flagged wire by tracing structure\n  // For each flagged wire, determine what it SHOULD be and find the gate that has it\n  if (swapped.size < 8) {\n    // Try to find remaining swaps by tracing the adder bit by bit\n    let carry = '';\n\n    // Bit 0\n    const xor0 = f