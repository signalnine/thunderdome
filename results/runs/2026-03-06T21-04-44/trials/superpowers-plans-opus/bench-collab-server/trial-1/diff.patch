ise;\n\n    expect(errorMsg.type).toBe('error');\n    ws.close();\n  });\n\n  it('should reject delete operations that exceed document bounds', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Bounds Test', content: 'Short' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    const errorPromise = waitForMessage(ws, 'error');\n    sendOperation(ws, { type: 'delete', position: 0, count: 100 }, syncMessage.version as number);\n    const errorMsg = await errorPromise;\n\n    expect(errorMsg.type).toBe('error');\n    ws.close();\n  });\n});\n\ndescribe('Persistence', () => {\n  const testDbPath = '/tmp/test-persistence.db';\n\n  it('should persist documents across server restarts', async () => {\n    // Clean up any existing test db\n    try {\n      const fs = await import('fs');\n      fs.unlinkSync(testDbPath);\n    } catch {\n      // File doesn't exist, that's fine\n    }\n\n    // First server instance\n    const app1 = createApp(testDbPath);\n    await app1.start();\n\n    const created = await request(app1.app)\n      .post('/documents')\n      .send({ title: 'Persist Test', content: 'Original Content' });\n\n    const docId = created.body.id;\n    await app1.stop();\n\n    // Second server instance with same DB\n    const app2 = createApp(testDbPath);\n    await app2.start();\n\n    const res = await request(app2.app).get(`/documents/${docId}`);\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Persist Test');\n    expect(res.body.content).toBe('Original Content');\n\n    await app2.stop();\n  });\n\n  it('should persist WebSocket edits across restarts', async () => {\n    try {\n      const fs = await import('fs');\n      fs.unlinkSync(testDbPath);\n    } catch {\n      // File doesn't exist\n    }\n\n    // First server\n    const app1 = createApp(testDbPath);\n    port = await app1.start();\n\n    const created = await request(app1.app)\n      .post('/documents')\n      .send({ title: 'WS Persist', content: '' });\n\n    const { ws, syncMessage } = await connectWs(created.body.id);\n    const ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 0, text: 'Persisted!' }, syncMessage.version as number);\n    await ackPromise;\n    ws.close();\n    await sleep(100);\n    await app1.stop();\n\n    // Second server\n    const app2 = createApp(testDbPath);\n    port = await app2.start();\n\n    const res = await request(app2.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('Persisted!');\n\n    await app2.stop();\n  });\n\n  it('should persist version history across restarts', async () => {\n    try {\n      const fs = await import('fs');\n      fs.unlinkSync(testDbPath);\n    } catch {\n      // File doesn't exist\n    }\n\n    const app1 = createApp(testDbPath);\n    port = await app1.start();\n\n    const created = await request(app1.app)\n      .post('/documents')\n      .send({ title: 'Version Persist', content: 'v1' });\n\n    // Make some edits\n    const { ws, syncMessage } = await connectWs(created.body.id);\n    const ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 2, text: ' updated' }, syncMessage.version as number);\n    await ackPromise;\n    ws.close();\n    await sleep(100);\n    await app1.stop();\n\n    // Restart\n    const app2 = createApp(testDbPath);\n    port = await app2.start();\n\n    const versions = await request(app2.app).get(`/documents/${created.body.id}/versions`);\n    expect(versions.body.length).toBeGreaterThanOrEqual(2);\n\n    await app2.stop();\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":4,"lines":["-import { describe, it, expect, beforeEach, afterEach, beforeAll, afterAll } from 'vitest';","+import { describe, it, expect, beforeEach, afterEach } from 'vitest';"," import request from 'supertest';"," import WebSocket from 'ws';"," import { createApp, AppIns