+++ b/src/server.ts
@@ -0,0 +1,54 @@
+import express from 'express';
+import { createServer, Server } from 'http';
+import Database from 'better-sqlite3';
+import { createDatabase } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationManager } from './ws.js';
+
+export interface AppInstance {
+  app: express.Express;
+  server: Server;
+  db: Database.Database;
+  collaborationManager: CollaborationManager;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath);
+  const app = express();
+  const server = createServer(app);
+
+  app.use(express.json());
+
+  // REST routes
+  const router = createRouter(db);
+  app.use(router);
+
+  // WebSocket collaboration
+  const collaborationManager = new CollaborationManager(db);
+  collaborationManager.attach(server);
+
+  const start = (port?: number): Promise<number> => {
+    return new Promise((resolve) => {
+      server.listen(port || 0, () => {
+        const addr = server.address();
+        const actualPort = typeof addr === 'object' && addr ? addr.port : 0;
+        resolve(actualPort);
+      });
+    });
+  };
+
+  const stop = (): Promise<void> => {
+    return new Promise((resolve, reject) => {
+      collaborationManager.closeAll();
+      server.close((err) => {
+        db.close();
+        if (err) reject(err);
+        else resolve();
+      });
+    });
+  };
+
+  return { app, server, db, collaborationManager, start, stop };
+}
diff --git a/src/ws.ts b/src/ws.ts
new file mode 100644
index 0000000..fb9c03f
--- /dev/null
+++ b/src/ws.ts
@@ -0,0 +1,224 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage } from 'http';
+import { Server } from 'http';
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+import { getDocument, getLatestVersion, addVersion, updateDocumentContent } from './db.js';
+import { Operation, applyOperation, transformOperation, validateOperation } from './ot.js';
+
+interface ClientConnection {
+  ws: WebSocket;
+  id: string;
+  documentId: string;
+}
+
+interface DocumentState {
+  version: number;
+  content: string;
+  clients: Map<string, ClientConnection>;
+  // History of operations for OT transform, keyed by version they produced
+  operationLog: Array<{ version: number; operation: Operation }>;
+}
+
+export class CollaborationManager {
+  private documents: Map<string, DocumentState> = new Map();
+  private wss: WebSocketServer | null = null;
+  private db: Database.Database;
+
+  constructor(db: Database.Database) {
+    this.db = db;
+  }
+
+  attach(server: Server): void {
+    this.wss = new WebSocketServer({ noServer: true });
+
+    server.on('upgrade', (request: IncomingMessage, socket, head) => {
+      const url = request.url || '';
+      // Match /ws/:documentId
+      const match = url.match(/^\/ws\/([^/?]+)/);
+      if (!match) {
+        socket.destroy();
+        return;
+      }
+
+      const documentId = match[1];
+      this.wss!.handleUpgrade(request, socket, head, (ws) => {
+        this.handleConnection(ws, documentId);
+      });
+    });
+  }
+
+  private getOrLoadDocument(documentId: string): DocumentState | null {
+    let state = this.documents.get(documentId);
+    if (state) return state;
+
+    const doc = getDocument(this.db, documentId);
+    if (!doc) return null;
+
+    const version = getLatestVersion(this.db, documentId);
+    state = {
+      version,
+      content: doc.content,
+      clients: new Map(),
+      operationLog: [],
+    };
+    this.documents.set(documentId, state);
+    return state;
+  }
+
+  private handleConnection(ws: WebSocket, documentId: string): void {
+    const docState = this.getOrLoadDocument(documentId);
+    if (!docState) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close();
+      return;
+    }
+
+    const clientId = randomUUID();
+    const client: ClientConnection = { ws, id: clientId, documentId };
+    docState.clients.set(clientId, client);
+
+    // Send sync message with current state
+    ws.send(JSON.stringify({
+      type: 'sync',
+      content: docState.content,
+      version: docState.version,
+      clientId,
+    }));
+
+    ws.on('message', (data) => {
+      try {
+        const message = JSON.parse(data.toString());
+        this.handleMessage(client, docState, message);
+      } catch {
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid JSON' }));
+      }
+    });
+
+    ws.on('close', () => {
+      docState.clients.delete(clientId);
+      if (docState.clients.size === 0) {
+        // Keep in memory for a bit in case someone reconnects
+        // but the data is already persisted
+      }
+    });
+
+    ws.on('error', () => {
+      docState.clients.delete(clientId);
+    });
+  }
+
+  private handleMessage(
+    client: ClientConnection,
+    docState: DocumentState,
+    message: Record<string, unknown>
+  ): void {
+    if (message.type !== 'operation') {
+      client.ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${message.type}` }));
+      return;
+    }
+
+    const clientVersion = message.version as number;
+    if (typeof clientVersion !== 'number' || !Number.isInteger(clientVersion) || clientVersion < 0) {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Invalid version number' }));
+      return;
+    }
+
+    let op = message.operation as Operation;
+    if (!op || typeof op !== 'object') {
+      client.ws.send(JSON.stringify({ type: 'error', message: 'Missing operation' }));
+      return;
+    }
+
+    // Transform the operation against all operations that happened since the client's version
+    if (clientVersion < docState.version) {
+      const missedOps = docState.operationLog.filter(
+        (entry) => entry.version > clientVersion
+      );
+      for (const entry of missedOps) {
+        op = transformOperation(op, entry.operation);
+      }
+    }
+
+    // Validate the (transformed) operation against current content
+    const validation = validateOperation(op, docState.content.length);
+    if (!validation.valid) {
+      client.ws.send(JSON.stringify({ type: 'error', message: validation.error }));
+      return;
+    }
+
+    // Skip no-op deletes (can happen after OT transform)
+    if (op.type === 'delete' && op.count === 0) {
+      client.ws.send(JSON.stringify({
+        type: 'ack',
+        version: docState.version,
+      }));
+      return;
+    }
+
+    // Apply operation
+    const newContent = applyOperation(docState.content, op);
+    docState.version++;
+    docState.content = newContent;
+    docState.operationLog.push({ version: docState.version, operation: op });
+
+    // Persist to database
+    updateDocumentContent(this.db, client.documentId, newContent);
+    addVersion(this.db, client.documentId, docState.version, newContent, JSON.stringify(op));
+
+    // Send ack to sender
+    client.ws.send(JSON.stringify({
+      type: 'ack',
+      version: docState.version,
+    }));
+
+    // Broadcast to other clients
+    for (const [id, otherClient] of docState.clients) {
+      if (id !== client.id && otherClient.ws.readyState === WebSocket.OPEN) {
+        otherClient.ws.send(JSON.stringify({
+          type: 'operation',
+          operation: op,
+          version: docState.version,
+          clientId: client.id,
+        }));
+      }
+    }
+  }
+
+  closeAll(): void {
+    for (const [, docState] of this.documents) {
+      for (const [, client] of docState.clients) {
+        client.ws.close();
+      }
+    }
+    this.documents.clear();
+    if (this.wss) {
+      this.wss.close();
+    }
+  }
+
+  /** Refresh document state from DB (used after REST updates) */
+  refreshDocument(documentId: string): void {
+    const state = this.documents.get(documentId);
+    if (!state) return;
+
+    const doc = getDocument(this.db, documentId);
+    if (!doc) {
+      this.documents.delete(documentId);
+      return;
+    }
+
+    state.content = doc.content;
+  }
+
+  /** Remove document from in-memory state (used after REST delete) */
+  removeDocument(documentId: string): void {
+    const state = this.documents.get(documentId);
+    if (state) {
+      for (const [, client] of state.clients) {
+        client.ws.close();
+      }
+      this.documents.delete(documentId);
+    }
+  }
+}
