= waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 0, text: 'Hello' }, syncMessage.version as number);\n    const ack = await ackPromise;\n\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(2);\n\n    // Verify via REST\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('Hello');\n    ws.close();\n  });\n\n  it('should apply a delete operation', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Delete Test', content: 'Hello World' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    const ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'delete', position: 5, count: 6 }, syncMessage.version as number);\n    await ackPromise;\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('Hello');\n    ws.close();\n  });\n\n  it('should apply multiple sequential operations', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Sequential', content: '' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    let version = syncMessage.version as number;\n\n    // Insert \"Hello\"\n    let ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 0, text: 'Hello' }, version);\n    let ack = await ackPromise;\n    version = ack.version as number;\n\n    // Insert \" World\"\n    ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 5, text: ' World' }, version);\n    ack = await ackPromise;\n    version = ack.version as number;\n\n    // Delete \"World\"\n    ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'delete', position: 6, count: 5 }, version);\n    await ackPromise;\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('Hello ');\n    ws.close();\n  });\n\n  it('should create version history entries for each operation', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Version Test', content: '' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    let version = syncMessage.version as number;\n\n    const ackPromise1 = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 0, text: 'A' }, version);\n    const ack1 = await ackPromise1;\n    version = ack1.version as number;\n\n    const ackPromise2 = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 1, text: 'B' }, version);\n    await ackPromise2;\n\n    const res = await request(app.app).get(`/documents/${created.body.id}/versions`);\n    expect(res.body.length).toBeGreaterThanOrEqual(3); // initial + 2 ops\n    ws.close();\n  });\n\n  it('should persist content accurately', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Persist Test', content: 'Start' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    const ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 5, text: ' End' }, syncMessage.version as number);\n    await ackPromise;\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('Start End');\n    ws.close();\n  });\n\n  it('should handle insert at end of document', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'End Insert', content: 'ABC' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    const ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 3, text: 'DEF' }, syncMessage.version as number);\n    await ackPromise;\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('ABCDEF');\n    ws.close();\n  });\n});\n\ndescribe('Two-Client Convergence', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start();\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Broadcast Test', content: '' });\n    const { ws: ws1, syncMessage: sync1 } = await connectWs(created.body.id);\n    const { ws: ws2 } = await connectWs(created.body.id);\n\n    const broadcastPromise = waitForMessage(ws2, 'operation');\n    sendOperation(ws1, { type: 'insert', position: 0, text: 'Hello' }, sync1.version as number);\n    const broadcast = await broadcastPromise;\n\n    expect(broadcast.type).toBe('operation');\n    expect((broadcast.operation as Record<string, unknown>).type).toBe('insert');\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should converge with concurrent inserts at different positions', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Converge Test', content: 'Hello' });\n\n    const { ws: ws1, syncMessage: sync1 } = await connectWs(created.body.id);\n    const { ws: ws2, syncMessage: sync2 } = await connectWs(created.body.id);\n\n    const ack1Promise = waitForMessage(ws1, 'ack');\n    const ack2Promise = waitForMessage(ws2, 'ack');\n\n    // Both clients send operations based on same version\n    sendOperation(ws1, { type: 'insert', position: 0, text: 'A' }, sync1.version as number);\n    sendOperation(ws2, { type: 'insert', position: 5, text: 'B' }, sync2.version as number);\n\n    await ack1Promise;\n    await ack2Promise;\n\n    // Wait for broadcasts to settle\n    await sleep(200);\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    // Both insertions should be present\n    expect(res.body.content).toContain('A');\n    expect(res.body.content).toCon