nt[] {\n  return db.prepare('SELECT * FROM documents ORDER BY updated_at DESC').all() as Document[];\n}\n\nexport function updateDocument(\n  db: Database.Database,\n  id: string,\n  updates: { title?: string; content?: string }\n): Document | undefined {\n  const doc = getDocument(db, id);\n  if (!doc) return undefined;\n\n  const title = updates.title ?? doc.title;\n  const content = updates.content ?? doc.content;\n\n  db.prepare(\n    \"UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?\"\n  ).run(title, content, id);\n\n  return getDocument(db, id);\n}\n\nexport function deleteDocument(db: Database.Database, id: string): boolean {\n  const result = db.prepare('DELETE FROM documents WHERE id = ?').run(id);\n  return result.changes > 0;\n}\n\nexport function getVersions(db: Database.Database, documentId: string): Version[] {\n  return db.prepare(\n    'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'\n  ).all(documentId) as Version[];\n}\n\nexport function getLatestVersion(db: Database.Database, documentId: string): number {\n  const result = db.prepare(\n    'SELECT COALESCE(MAX(version), 0) as max_version FROM versions WHERE document_id = ?'\n  ).get(documentId) as { max_version: number };\n  return result.max_version;\n}\n\nexport function addVersion(\n  db: Database.Database,\n  documentId: string,\n  version: number,\n  content: string,\n  operation: string | null\n): void {\n  db.prepare(\n    'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'\n  ).run(documentId, version, content, operation);\n}\n\nexport function updateDocumentContent(db: Database.Database, id: string, content: string): void {\n  db.prepare(\n    \"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"\n  ).run(content, id);\n}\n","structuredPatch":[],"originalFile":null}}
