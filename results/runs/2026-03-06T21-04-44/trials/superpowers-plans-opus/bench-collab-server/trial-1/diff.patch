reated.body.id}`);\n    expect(res.body.content).toBe('Hello');\n    ws.close();\n  });\n\n  it('should apply a delete operation', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Delete Test', content: 'Hello World' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    const ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'delete', position: 5, count: 6 }, syncMessage.version as number);\n    await ackPromise;\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('Hello');\n    ws.close();\n  });\n\n  it('should apply multiple sequential operations', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Sequential', content: '' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    let version = syncMessage.version as number;\n\n    // Insert \"Hello\"\n    let ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 0, text: 'Hello' }, version);\n    let ack = await ackPromise;\n    version = ack.version as number;\n\n    // Insert \" World\"\n    ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 5, text: ' World' }, version);\n    ack = await ackPromise;\n    version = ack.version as number;\n\n    // Delete \"World\"\n    ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'delete', position: 6, count: 5 }, version);\n    await ackPromise;\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('Hello ');\n    ws.close();\n  });\n\n  it('should create version history entries for each operation', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Version Test', content: '' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    let version = s