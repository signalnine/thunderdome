cket, operation: Record<string, unknown>, version: number): void {\n  ws.send(JSON.stringify({ type: 'operation', operation, version }));\n}\n\n// Collect all messages received\nfunction collectMessages(ws: WebSocket): Record<string, unknown>[] {\n  const messages: Record<string, unknown>[] = [];\n  ws.on('message', (data) => {\n    messages.push(JSON.parse(data.toString()));\n  });\n  return messages;\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\ndescribe('REST CRUD', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start();\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should create a document', async () => {\n    const res = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Test Doc', content: 'Hello' })\n      .expect(201);\n\n    expect(res.body).toHaveProperty('id');\n    expect(res.body.title).toBe('Test Doc');\n    expect(res.body.content).toBe('Hello');\n  });\n\n  it('should create a document with empty content', async () => {\n    const res = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Empty Doc' })\n      .expect(201);\n\n    expect(res.body.content).toBe('');\n  });\n\n  it('should reject document creation without title', async () => {\n    await request(app.app)\n      .post('/documents')\n      .send({ content: 'no title' })\n      .expect(400);\n  });\n\n  it('should list documents', async () => {\n    await request(app.app).post('/documents').send({ title: 'Doc 1' });\n    await request(app.app).post('/documents').send({ title: 'Doc 2' });\n\n    const res = await request(app.app).get('/documents').expect(200);\n    expect(res.body).toHaveLength(2);\n  });\n\n  it('should get a single document', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'My Doc', content: 'Content' });\n    const res = await request(app.app).get(`/documents/${created.body.id}`).expect(200);\n    expect(res.body.title).toBe('My Doc');\n    expect(res.body.content).toBe('Content');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    await request(app.app).get('/documents/non-existent').expect(404);\n  });\n\n  it('should update a document', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Original' });\n    const res = await request(app.app)\n      .put(`/documents/${created.body.id}`)\n      .send({ title: 'Updated', content: 'New content' })\n      .expect(200);\n\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('New content');\n  });\n\n  it('should delete a document', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'To Delete' });\n    await request(app.app).delete(`/documents/${created.body.id}`).expect(204);\n    await request(app.app).get(`/documents/${created.body.id}`).expect(404);\n  });\n\n  it('should return 404 when deleting non-existent document', async () => {\n    await request(app.app).delete('/documents/non-existent').expect(404);\n  });\n\n  it('should get version history', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Versioned', content: 'v1' });\n\n    const res = await request(app.app)\n      .get(`/documents/${created.body.id}/versions`)\n      .expect(200);\n\n    expect(res.body.length).toBeGreaterThanOrEqual(1);\n    expect(res.body[0].version).toBe(1);\n  });\n});\n\ndescribe('WebSocket Lifecycle', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start();\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should connect and receive sync message', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'WS Test', content: 'Hello' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    expect(syncMessage.type).toBe('sync');\n    expect(syncMessage.content).toBe('Hello');\n    expect(syncMessage.version).toBe(1);\n    ws.close();\n  });\n\n  it('should reject connection to non-existent document', async () => {\n    const ws = new WebSocket(wsUrl('non-existent'));\n    const msg = await waitForMessage(ws, 'error');\n    expect(msg.type).toBe('error');\n    // Connection should close\n    await new Promise<void>((resolve) => {\n      ws.on('close', () => resolve());\n      setTimeout(resolve, 2000);\n    });\n  });\n\n  it('should assign unique client IDs', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Multi Client' });\n    const { ws: ws1, syncMessage: sync1 } = await connectWs(created.body.id);\n    const { ws: ws2, syncMessage: sync2 } = await connectWs(created.body.id);\n\n    expect(sync1.clientId).not.toBe(sync2.clientId);\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle client disconnect gracefully', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Disconnect Test' });\n    const { ws } = await connectWs(created.body.id);\n    ws.close();\n    // Server should not crash\n    await sleep(100);\n    const res = await request(app.app).get(`/documents/${created.body.id}`).expect(200);\n    expect(res.body.title).toBe('Disconnect Test');\n  });\n\n  it('should handle multiple clients connecting to same document', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Multi' });\n    const clients: WebSocket[] = [];\n    for (let i = 0; i < 3; i++) {\n      const { ws } = await connectWs(created.body.id);\n      clients.push(ws);\n    }\n    clients.forEach((ws) => ws.close());\n  });\n\n  it('should send correct content in sync after edits', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Sync Test', content: '' });\n    const { ws: ws1, syncMessage: sync1 } = await connectWs(created.body.id);\n\n    // Send an insert\n    const ackPromise = waitForMessage(ws1, 'ack');\n    sendOperation(ws1, { type: 'insert', position: 0, text: 'Hello' }, sync1.version as number);\n    await ackPromise;\n\n    // New client connects and should see the updated content\n    const { ws: ws2, syncMessage: sync2 } = await connectWs(created.body.id);\n    expect(sync2.content).toBe('Hello');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle rapid connect/disconnect', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Rapid Test' });\n    for (let i = 0; i < 5; i++) {\n      const { ws } = await connectWs(created.body.id);\n      ws.close();\n    }\n    // Server should still work\n    const res = await request(app.app).get(`/documents/${created.body.id}`).expect(200);\n    expect(res.body.title).toBe('Rapid Test');\n  });\n\n  it('should not crash when WebSocket path is invalid', async () => {\n    // Connection to a bad path should be rejected\n    const ws = new WebSocket(`ws://localhost:${port}/invalid`);\n    await new Promise<void>((resolve) => {\n      ws.on('close', () => resolve());\n      ws.on('error', () => resolve());\n      setTimeout(resolve, 1000);\n    });\n    // Server still alive\n    await request(app.app).get('/documents').expect(200);\n  });\n});\n\ndescribe('Single Client Editing', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start();\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should apply an insert operation', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Edit Test', content: '' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    const ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 0, text: 'Hello' }, syncMessage.version as number);\n    const ack = await ackPromise;\n\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(2);\n\n    // Verify via REST\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('Hello');\n    ws.close();\n  });\n\n  it('should apply a delete operation', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Delete Test', content: 'Hello World' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    const ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'delete', position: 5, count: 6 }, syncMessage.version as number);\n    await ackPromise;\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('Hello');\n    ws.close();\n  });\n\n  it('should apply multiple sequential operations', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Sequential', content: '' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    let version = syncMessage.version as number;\n\n    // Insert \"Hello\"\n    let ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 0, text: 'Hello' }, version);\n    let ack = await ackPromise;\n    version = ack.version as number;\n\n    // Insert \" World\"\n    ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 5, text: ' World' }, version);\n    ack = await ackPromise;\n    version = ack.version as number;\n\n    // Delete \"World\"\n    ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'delete', position: 6, count: 5 }, version);\n    await ackPromise;\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('Hello ');\n    ws.close();\n  });\n\n  it('should create version history entries for each operation', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Version Test', content: '' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    let version = syncMessage.version as number;\n\n    const ackPromise1 = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 0, text: 'A' }, version);\n    const ack1 = await ackPromise1;\n    version = ack1.version as number;\n\n    const ackPromise2 = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 1, text: 'B' }, version);\n    await ackPromise2;\n\n    const res = await request(app.app).get(`/documents/${created.body.id}/versions`);\n    expect(res.body.length).toBeGreaterThanOrEqual(3); // initial + 2 ops\n    ws.close();\n  });\n\n  it('should persist content accurately', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Persist Test', content: 'Start' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    const ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 5, text: ' End' }, syncMessage.version as number);\n    await ackPromise;\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('Start End');\n    ws.close();\n  });\n\n  it('should handle insert at end of document', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'End Insert', content: 'ABC' });\n    const { ws, syncMessage } = await connectWs(created.body.id);\n\n    const ackPromise = waitForMessage(ws, 'ack');\n    sendOperation(ws, { type: 'insert', position: 3, text: 'DEF' }, syncMessage.version as number);\n    await ackPromise;\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('ABCDEF');\n    ws.close();\n  });\n});\n\ndescribe('Two-Client Convergence', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start();\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const created = await request(app.app).post('/documents').send({ title: 'Broadcast Test', content: '' });\n    const { ws: ws1, syncMessage: sync1 } = await connectWs(created.body.id);\n    const { ws: ws2 } = await connectWs(created.body.id);\n\n    const broadcastPromise = waitForMessage(ws2, 'operation');\n    sendOperation(ws1, { type: 'insert', position: 0, text: 'Hello' }, sync1.version as number);\n    const broadcast = await broadcastPromise;\n\n    expect(broadcast.type).toBe('operation');\n    expect((broadcast.operation as Record<string, unknown>).type).toBe('insert');\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should converge with concurrent inserts at different positions', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Converge Test', content: 'Hello' });\n\n    const { ws: ws1, syncMessage: sync1 } = await connectWs(created.body.id);\n    const { ws: ws2, syncMessage: sync2 } = await connectWs(created.body.id);\n\n    const ack1Promise = waitForMessage(ws1, 'ack');\n    const ack2Promise = waitForMessage(ws2, 'ack');\n\n    // Both clients send operations based on same version\n    sendOperation(ws1, { type: 'insert', position: 0, text: 'A' }, sync1.version as number);\n    sendOperation(ws2, { type: 'insert', position: 5, text: 'B' }, sync2.version as number);\n\n    await ack1Promise;\n    await ack2Promise;\n\n    // Wait for broadcasts to settle\n    await sleep(200);\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    // Both insertions should be present\n    expect(res.body.content).toContain('A');\n    expect(res.body.content).toContain('B');\n    expect(res.body.content).toContain('Hello');\n    expect(res.body.content.length).toBe(7); // 'Hello' + 'A' + 'B'\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should converge with concurrent inserts at same position', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Same Pos Test', content: '' });\n\n    const { ws: ws1, syncMessage: sync1 } = await connectWs(created.body.id);\n    const { ws: ws2, syncMessage: sync2 } = await connectWs(created.body.id);\n\n    const ack1Promise = waitForMessage(ws1, 'ack');\n    const ack2Promise = waitForMessage(ws2, 'ack');\n\n    // Both insert at position 0\n    sendOperation(ws1, { type: 'insert', position: 0, text: 'A' }, sync1.version as number);\n    sendOperation(ws2, { type: 'insert', position: 0, text: 'B' }, sync2.version as number);\n\n    await ack1Promise;\n    await ack2Promise;\n\n    await sleep(200);\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    // Both characters present, order determined by server\n    expect(res.body.content.length).toBe(2);\n    expect(res.body.content).toContain('A');\n    expect(res.body.content).toContain('B');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should converge with concurrent insert and delete', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Insert Delete Test', content: 'Hello World' });\n\n    const { ws: ws1, syncMessage: sync1 } = await connectWs(created.body.id);\n    const { ws: ws2, syncMessage: sync2 } = await connectWs(created.body.id);\n\n    const ack1Promise = waitForMessage(ws1, 'ack');\n    const ack2Promise = waitForMessage(ws2, 'ack');\n\n    // Client 1 inserts at start, Client 2 deletes \" World\"\n    sendOperation(ws1, { type: 'insert', position: 0, text: '!' }, sync1.version as number);\n    sendOperation(ws2, { type: 'delete', position: 5, count: 6 }, sync2.version as number);\n\n    await ack1Promise;\n    await ack2Promise;\n\n    await sleep(200);\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    // Should have ! and Hello, but not World\n    expect(res.body.content).toContain('!');\n    expect(res.body.content).toContain('Hello');\n    expect(res.body.content).not.toContain('World');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle many sequential operations from two clients', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Many Ops Test', content: '' });\n\n    const { ws: ws1, syncMessage: sync1 } = await connectWs(created.body.id);\n    const { ws: ws2, syncMessage: sync2 } = await connectWs(created.body.id);\n\n    let v1 = sync1.version as number;\n    let v2 = sync2.version as number;\n\n    // Client 1 inserts characters one by one\n    for (let i = 0; i < 5; i++) {\n      const ack = waitForMessage(ws1, 'ack');\n      sendOperation(ws1, { type: 'insert', position: i, text: String.fromCharCode(65 + i) }, v1);\n      const ackMsg = await ack;\n      v1 = ackMsg.version as number;\n      // Also update v2 from broadcast\n      await waitForMessage(ws2, 'operation').catch(() => {/* already received */});\n      v2 = v1; // both are in sync after sequential ops\n    }\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('ABCDE');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should converge with concurrent deletes', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Delete Converge', content: 'ABCDEF' });\n\n    const { ws: ws1, syncMessage: sync1 } = await connectWs(created.body.id);\n    const { ws: ws2, syncMessage: sync2 } = await connectWs(created.body.id);\n\n    const ack1Promise = waitForMessage(ws1, 'ack');\n    const ack2Promise = waitForMessage(ws2, 'ack');\n\n    // Client 1 deletes 'AB', Client 2 deletes 'EF'\n    sendOperation(ws1, { type: 'delete', position: 0, count: 2 }, sync1.version as number);\n    sendOperation(ws2, { type: 'delete', position: 4, count: 2 }, sync2.version as number);\n\n    await ack1Promise;\n    await ack2Promise;\n\n    await sleep(200);\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content).toBe('CD');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should preserve both inserts in concurrent editing', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Preserve Test', content: 'XY' });\n\n    const { ws: ws1, syncMessage: sync1 } = await connectWs(created.body.id);\n    const { ws: ws2, syncMessage: sync2 } = await connectWs(created.body.id);\n\n    const ack1Promise = waitForMessage(ws1, 'ack');\n    const ack2Promise = waitForMessage(ws2, 'ack');\n\n    // Client 1 inserts 'A' at start, Client 2 inserts 'Z' at end\n    sendOperation(ws1, { type: 'insert', position: 0, text: 'A' }, sync1.version as number);\n    sendOperation(ws2, { type: 'insert', position: 2, text: 'Z' }, sync2.version as number);\n\n    await ack1Promise;\n    await ack2Promise;\n\n    await sleep(200);\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content.length).toBe(4); // 'XY' + 'A' + 'Z'\n    expect(res.body.content).toContain('A');\n    expect(res.body.content).toContain('Z');\n    expect(res.body.content).toContain('XY');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle version numbers correctly across clients', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Version Tracking', content: '' });\n\n    const { ws: ws1, syncMessage: sync1 } = await connectWs(created.body.id);\n\n    const ackPromise = waitForMessage(ws1, 'ack');\n    sendOperation(ws1, { type: 'insert', position: 0, text: 'Hi' }, sync1.version as number);\n    const ack = await ackPromise;\n\n    expect(ack.version).toBeGreaterThan(sync1.version as number);\n\n    // Second client connects and gets updated version\n    const { ws: ws2, syncMessage: sync2 } = await connectWs(created.body.id);\n    expect(sync2.version).toBe(ack.version);\n    expect(sync2.content).toBe('Hi');\n\n    ws1.close();\n    ws2.close();\n  });\n});\n\ndescribe('Stress Test', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start();\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Stress Test', content: '' });\n\n    const clients: { ws: WebSocket; syncMessage: Record<string, unknown> }[] = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(created.body.id);\n      clients.push(client);\n    }\n\n    // Each client inserts their number\n    const ackPromises: Promise<Record<string, unknown>>[] = [];\n    for (let i = 0; i < 10; i++) {\n      const ackPromise = waitForMessage(clients[i].ws, 'ack');\n      sendOperation(\n        clients[i].ws,\n        { type: 'insert', position: 0, text: String(i) },\n        clients[i].syncMessage.version as number\n      );\n      ackPromises.push(ackPromise);\n    }\n\n    await Promise.all(ackPromises);\n    await sleep(500);\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    // All digits should be present\n    for (let i = 0; i < 10; i++) {\n      expect(res.body.content).toContain(String(i));\n    }\n    expect(res.body.content.length).toBe(10);\n\n    clients.forEach((c) => c.ws.close());\n  });\n\n  it('should handle rapid sequential operations from many clients', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Rapid Stress', content: '' });\n\n    const clients: { ws: WebSocket; version: number }[] = [];\n    for (let i = 0; i < 5; i++) {\n      const { ws, syncMessage } = await connectWs(created.body.id);\n      clients.push({ ws, version: syncMessage.version as number });\n    }\n\n    // Each client sends 3 operations sequentially\n    for (const client of clients) {\n      for (let j = 0; j < 3; j++) {\n        const ackPromise = waitForMessage(client.ws, 'ack');\n        sendOperation(client.ws, { type: 'insert', position: 0, text: 'x' }, client.version);\n        const ack = await ackPromise;\n        client.version = ack.version as number;\n      }\n    }\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content.length).toBe(15); // 5 clients * 3 ops\n\n    clients.forEach((c) => c.ws.close());\n  });\n\n  it('should maintain document integrity under concurrent load', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Integrity Test', content: 'BASE' });\n\n    const clientPairs: { ws: WebSocket; syncMessage: Record<string, unknown> }[] = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(created.body.id);\n      clientPairs.push(client);\n    }\n\n    // All clients insert concurrently at position 0\n    const ackPromises: Promise<Record<string, unknown>>[] = [];\n    for (let i = 0; i < 10; i++) {\n      const ackPromise = waitForMessage(clientPairs[i].ws, 'ack');\n      sendOperation(\n        clientPairs[i].ws,\n        { type: 'insert', position: 0, text: `[${i}]` },\n        clientPairs[i].syncMessage.version as number\n      );\n      ackPromises.push(ackPromise);\n    }\n\n    await Promise.all(ackPromises);\n    await sleep(500);\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    // BASE should still be there, plus all insertions\n    expect(res.body.content).toContain('BASE');\n    for (let i = 0; i < 10; i++) {\n      expect(res.body.content).toContain(`[${i}]`);\n    }\n\n    clientPairs.forEach((c) => c.ws.close());\n  });\n\n  it('should not lose data with rapid connect/edit/disconnect cycles', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Cycle Test', content: '' });\n\n    for (let i = 0; i < 5; i++) {\n      const { ws, syncMessage } = await connectWs(created.body.id);\n      const ackPromise = waitForMessage(ws, 'ack');\n      sendOperation(ws, { type: 'insert', position: 0, text: String(i) }, syncMessage.version as number);\n      await ackPromise;\n      ws.close();\n      await sleep(50);\n    }\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content.length).toBe(5);\n  });\n\n  it('should handle mixed insert and delete operations under load', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Mixed Load', content: 'ABCDEFGHIJ' });\n\n    const clients: { ws: WebSocket; syncMessage: Record<string, unknown> }[] = [];\n    for (let i = 0; i < 5; i++) {\n      const client = await connectWs(created.body.id);\n      clients.push(client);\n    }\n\n    // First batch: all insert at different positions\n    const ackPromises: Promise<Record<string, unknown>>[] = [];\n    for (let i = 0; i < 5; i++) {\n      const ackPromise = waitForMessage(clients[i].ws, 'ack');\n      sendOperation(\n        clients[i].ws,\n        { type: 'insert', position: i * 2, text: `+${i}` },\n        clients[i].syncMessage.version as number\n      );\n      ackPromises.push(ackPromise);\n    }\n\n    await Promise.all(ackPromises);\n    await sleep(300);\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    // All original chars plus all insertions\n    for (let i = 0; i < 5; i++) {\n      expect(res.body.content).toContain(`+${i}`);\n    }\n\n    clients.forEach((c) => c.ws.close());\n  });\n});\n\ndescribe('Error Handling', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.