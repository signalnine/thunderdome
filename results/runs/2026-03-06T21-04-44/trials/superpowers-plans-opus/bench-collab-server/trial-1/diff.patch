g') updates.content = content;\n\n    const doc = updateDocument(db, req.params.id, updates);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.json(doc);\n  });\n\n  // Delete document\n  router.delete('/documents/:id', (req: Request, res: Response) => {\n    const deleted = deleteDocument(db, req.params.id);\n    if (!deleted) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.status(204).send();\n  });\n\n  // Get version history\n  router.get('/documents/:id/versions', (req: Request, res: Response) => {\n    const doc = getDocument(db, req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n\n    const versions = getVersions(db, req.params.id);\n    res.json(versions);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":307,"cache_read_input_tokens":27267,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":307},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9be9c029-775d-48d2-9ccc-bca8b96c3d90","uuid":"101e52a4-de89-4970-a20e-2674b9c140ac"}
