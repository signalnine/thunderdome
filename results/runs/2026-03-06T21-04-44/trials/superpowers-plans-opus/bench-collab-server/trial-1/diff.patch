on\n    const { ws: ws2, syncMessage: sync2 } = await connectWs(created.body.id);\n    expect(sync2.version).toBe(ack.version);\n    expect(sync2.content).toBe('Hi');\n\n    ws1.close();\n    ws2.close();\n  });\n});\n\ndescribe('Stress Test', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start();\n  });\n\n  afterEach(async () => {\n    await app.stop();\n  });\n\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Stress Test', content: '' });\n\n    const clients: { ws: WebSocket; syncMessage: Record<string, unknown> }[] = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(created.body.id);\n      clients.push(client);\n    }\n\n    // Each client inserts their number\n    const ackPromises: Promise<Record<string, unknown>>[] = [];\n    for (let i = 0; i < 10; i++) {\n      const ackPromise = waitForMessage(clients[i].ws, 'ack');\n      sendOperation(\n        clients[i].ws,\n        { type: 'insert', position: 0, text: String(i) },\n        clients[i].syncMessage.version as number\n      );\n      ackPromises.push(ackPromise);\n    }\n\n    await Promise.all(ackPromises);\n    await sleep(500);\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    // All digits should be present\n    for (let i = 0; i < 10; i++) {\n      expect(res.body.content).toContain(String(i));\n    }\n    expect(res.body.content.length).toBe(10);\n\n    clients.forEach((c) => c.ws.close());\n  });\n\n  it('should handle rapid sequential operations from many clients', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Rapid Stress', content: '' });\n\n    const clients: { ws: WebSocket; version: number }[] = [];\n    for (let i = 0; i < 5; i++) {\n      const { ws, syncMessage } = await connectWs(created.body.id);\n      clients.push({ ws, version: syncMessage.version as number });\n    }\n\n    // Each client sends 3 operations sequentially\n    for (const client of clients) {\n      for (let j = 0; j < 3; j++) {\n        const ackPromise = waitForMessage(client.ws, 'ack');\n        sendOperation(client.ws, { type: 'insert', position: 0, text: 'x' }, client.version);\n        const ack = await ackPromise;\n        client.version = ack.version as number;\n      }\n    }\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content.length).toBe(15); // 5 clients * 3 ops\n\n    clients.forEach((c) => c.ws.close());\n  });\n\n  it('should maintain document integrity under concurrent load', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Integrity Test', content: 'BASE' });\n\n    const clientPairs: { ws: WebSocket; syncMessage: Record<string, unknown> }[] = [];\n    for (let i = 0; i < 10; i++) {\n      const client = await connectWs(created.body.id);\n      clientPairs.push(client);\n    }\n\n    // All clients insert concurrently at position 0\n    const ackPromises: Promise<Record<string, unknown>>[] = [];\n    for (let i = 0; i < 10; i++) {\n      const ackPromise = waitForMessage(clientPairs[i].ws, 'ack');\n      sendOperation(\n        clientPairs[i].ws,\n        { type: 'insert', position: 0, text: `[${i}]` },\n        clientPairs[i].syncMessage.version as number\n      );\n      ackPromises.push(ackPromise);\n    }\n\n    await Promise.all(ackPromises);\n    await sleep(500);\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    // BASE should still be there, plus all insertions\n    expect(res.body.content).toContain('BASE');\n    for (let i = 0; i < 10; i++) {\n      expect(res.body.content).toContain(`[${i}]`);\n    }\n\n    clientPairs.forEach((c) => c.ws.close());\n  });\n\n  it('should not lose data with rapid connect/edit/disconnect cycles', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Cycle Test', content: '' });\n\n    for (let i = 0; i < 5; i++) {\n      const { ws, syncMessage } = await connectWs(created.body.id);\n      const ackPromise = waitForMessage(ws, 'ack');\n      sendOperation(ws, { type: 'insert', position: 0, text: String(i) }, syncMessage.version as number);\n      await ackPromise;\n      ws.close();\n      await sleep(50);\n    }\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    expect(res.body.content.length).toBe(5);\n  });\n\n  it('should handle mixed insert and delete operations under load', async () => {\n    const created = await request(app.app)\n      .post('/documents')\n      .send({ title: 'Mixed Load', content: 'ABCDEFGHIJ' });\n\n    const clients: { ws: WebSocket; syncMessage: Record<string, unknown> }[] = [];\n    for (let i = 0; i < 5; i++) {\n      const client = await connectWs(created.body.id);\n      clients.push(client);\n    }\n\n    // First batch: all insert at different positions\n    const ackPromises: Promise<Record<string, unknown>>[] = [];\n    for (let i = 0; i < 5; i++) {\n      const ackPromise = waitForMessage(clients[i].ws, 'ack');\n      sendOperation(\n        clients[i].ws,\n        { type: 'insert', position: i * 2, text: `+${i}` },\n        clients[i].syncMessage.version as number\n      );\n      ackPromises.push(ackPromise);\n    }\n\n    await Promise.all(ackPromises);\n    await sleep(300);\n\n    const res = await request(app.app).get(`/documents/${created.body.id}`);\n    // All original chars plus all insertions\n    for (let i = 0; i < 5; i++) {\n      expect(res.body.content).toContain(`+${i}`);\n    }\n\n    clients.forEach((c) => c.ws.close());\n  });\n});\n\ndescribe('Error Handling', () => {\n  beforeEach(async () => {\n    app = createApp();\n    port = await app.start();\n  });\n\n  afterEach(async () => {\n    await app.stop();\n 