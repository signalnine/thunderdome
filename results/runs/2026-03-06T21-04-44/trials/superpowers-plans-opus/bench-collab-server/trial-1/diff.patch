+
+    const created = await request(app1.app)
+      .post('/documents')
+      .send({ title: 'Version Persist', content: 'v1' });
+
+    // Make some edits
+    const { ws, syncMessage } = await connectWs(created.body.id);
+    const ackPromise = waitForMessage(ws, 'ack');
+    sendOperation(ws, { type: 'insert', position: 2, text: ' updated' }, syncMessage.version as number);
+    await ackPromise;
+    ws.close();
+    await sleep(100);
+    await app1.stop();
+
+    // Restart
+    const app2 = createApp(testDbPath);
+    port = await app2.start();
+
+    const versions = await request(app2.app).get(`/documents/${created.body.id}/versions`);
+    expect(versions.body.length).toBeGreaterThanOrEqual(2);
+
+    await app2.stop();
+  });
+});
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..1c1cbf3
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,111 @@
+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+import { join, dirname } from 'path';
+import { fileURLToPath } from 'url';
+
+const __dirname = dirname(fileURLToPath(import.meta.url));
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDatabase(dbPath?: string): Database.Database {
+  const db = new Database(dbPath || ':memory:');
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  const schemaPath = join(__dirname, '..', 'schema.sql');
+  const schema = readFileSync(schemaPath, 'utf-8');
+  db.exec(schema);
+
+  return db;
+}
+
+export function createDocument(db: Database.Database, id: string, title: string, content: string = ''): Document {
+  const stmt = db.prepare(
+    'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+  );
+  stmt.run(id, title, content);
+
+  // Create initial version
+  db.prepare(
+    'INSERT INTO versions (document_id, version, content, operation) VALUES (?, 1, ?, NULL)'
+  ).run(id, content);
+
+  return db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Document;
+}
+
+export function getDocument(db: Database.Database, id: string): Document | undefined {
+  return db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Document | undefined;
+}
+
+export function listDocuments(db: Database.Database): Document[] {
+  return db.prepare('SELECT * FROM documents ORDER BY updated_at DESC').all() as Document[];
+}
+
+export function updateDocument(
+  db: Database.Database,
+  id: string,
+  updates: { title?: string; content?: string }
+): Document | undefined {
+  const doc = getDocument(db, id);
+  if (!doc) return undefined;
+
+  const title = updates.title ?? doc.title;
+  const content = updates.content ?? doc.content;
+
+  db.prepare(
+    "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+  ).run(title, content, id);
+
+  return getDocument(db, id);
+}
+
+export function deleteDocument(db: Database.Database, id: string): boolean {
+  const result = db.prepare('DELETE FROM documents WHERE id = ?').run(id);
+  return result.changes > 0;
+}
+
+export function getVersions(db: Database.Database, documentId: string): Version[] {
+  return db.prepare(
+    'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+  ).all(documentId) as Version[];
+}
+
+export function getLatestVersion(db: Database.Database, documentId: string): number {
+  const result = db.prepare(
+    'SELECT COALESCE(MAX(version), 0) as max_version FROM versions WHERE document_id = ?'
+  ).get(documentId) as { max_version: number };
+  return result.max_version;
+}
+
+export function addVersion(
+  db: Database.Database,
+  documentId: string,
+  version: number,
+  content: string,
+  operation: string | null
+): void {
+  db.prepare(
+    'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+  ).run(documentId, version, content, operation);
+}
+
+export function updateDocumentContent(db: Database.Database, id: string, content: string): void {
+  db.prepare(
+    "UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?"
+  ).run(content, id);
+}
diff --git a/src/ot.ts b/src/ot.ts
new file mode 100644
index 0000000..b1c98e7
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,121 @@
+export type Operation =
+  | { type: 'insert'; position: number; text: string }
+  | { type: 'delete'; position: number; count: number };
+
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    return content.slice(0, pos) + op.text + content.slice(pos);
+  } else {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    const count = Math.min(op.count, content.length - pos);
+    return content.slice(0, pos) + content.slice(pos + count);
+  }
+}
+
+/**
+ * Transform op so it can be applied after `against` has already been applied.
+ * Both op and against were intended to apply to the same document state.
+ */
+export function transformOperation(op: Operation, against: Operation): Operation {
+  if (op.type === 'insert' && against.type === 'insert') {
+    if (op.position <= against.position) {
+      return { ...op };
+    }
+    return { type: 'insert', position: op.position + against.text.length, text: op.text };
+  }
+
+  if (op.type === 'insert' && against.type === 'delete') {
+    if (op.position <= against.position) {
+      return { ...op };
+    }
+    if (op.position >= against.position + against.count) {
+      return { type: 'insert', position: op.position - against.count, text: op.text };
+    }
+    // Insert point is within the deleted range - place at delete position
+    return { type: 'insert', position: against.position, text: op.text };
+  }
+
+  if (op.type === 'delete' && against.type === 'insert') {
+    if (op.position >= against.position) {
+      return { type: 'delete', position: op.position + against.text.length, count: op.count };
+    }
+    if (op.position + op.count <= against.position) {
+      return { ...op };
+    }
+    // Delete range spans the insert point - expand to include inserted text
+    return { type: 'delete', position: op.position, count: op.count + against.text.length };
+  }
+
+  // delete vs delete
+  if (op.type === 'delete' && against.type === 'delete') {
+    // op is entirely after against
+    if (op.position >= against.position + against.count) {
+      return { type: 'delete', position: op.position - against.count, count: op.count };
+    }
+    // op is entirely before against
+    if (op.position + op.count <= against.position) {
+      return { ...op };
+    }
+    // Overlapping deletes
+    const opEnd = op.position + op.count;
+    const againstEnd = against.position + against.count;
+
+    if (op.position >= against.position && opEnd <= againstEnd) {
+      // op is entirely within against - nothing left to delete
+      return { type: 'delete', position: against.position, count: 0 };
+    }
+
+    if (op.position <= against.position && opEnd >= againstEnd) {
+      // op fully contains against
+      return { type: 'delete', position: op.position, count: op.count - against.count };
+    }
+
+    if (op.position < against.position) {
+      // op starts before against, overlaps partially
+      const overlap = opEnd - against.position;
+      return { type: 'delete', position: op.position, count: op.count - overlap };
+    }
+
+    // op starts within against, extends beyond
+    const overlap = againstEnd - op.position;
+    return { type: 'delete', position: against.position, count: op.count - overlap };
+  }
+
+  return { ...op };
+}
+
+export function validateOperation(op: unknown, contentLength: number): { valid: boolean; error?: string } {
+  if (!op || typeof op !== 'object') {
+    return { valid: false, error: 'Operation must be a non-null object' };
+  }
+  const o = op as Record<string, unknown>;
+
+  if (o.type === 'insert') {
+    if (typeof o.position !== 'number' || !Number.isInteger(o.position) || o.position < 0) {
+      return { valid: false, error: 'Insert position must be a non-negative integer' };
+    }
+    if (typeof o.text !== 'string' || o.text.length === 0) {
+      return { valid: false, error: 'Insert text must be a non-empty string' };
+    }
+    if (o.position > contentLength) {
+      return { valid: false, error: `Insert position ${o.position} exceeds document length ${contentLength}` };
+    }
+    return { valid: true };
+  }
+
+  if (o.type === 'delete') {
+    if (typeof o.position !== 'number' || !Number.isInteger(o.position) || o.position < 0) {
+      return { valid: false, error: 'Delete position must be a non-negative integer' };
+    }
+    if (typeof o.count !== 'number' || !Number.isInteger(o.count) || o.count <= 0) {
+      return { valid: false, error: 'Delete count must be a positive integer' };
+    }
+    if (o.position + o.count > contentLength) {
+      return { valid: false, error: `Delete range [${o.position}, ${o.position + o.count}) exceeds document length ${contentLength}` };
+    }
+    return { valid: true };
+  }
+
+  return { valid: false, error: `Unknown operation type: ${String(o.type)}` };
+}
