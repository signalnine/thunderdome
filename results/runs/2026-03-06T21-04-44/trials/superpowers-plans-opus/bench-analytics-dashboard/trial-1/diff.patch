@@ -0,0 +1,141 @@
+import { Router, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import { getDb } from '../db.js';
+import { AuthRequest, authMiddleware } from '../auth.js';
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+const router = Router();
+
+// POST /api/dashboards
+router.post('/', authMiddleware, (req: AuthRequest, res: Response): void => {
+  const { name, config } = req.body;
+
+  if (!name) {
+    res.status(400).json({ error: 'Dashboard name is required' });
+    return;
+  }
+
+  const db = getDb();
+  const id = uuidv4();
+  const dashConfig = config ? JSON.stringify(config) : '{}';
+  const now = new Date().toISOString();
+
+  db.prepare(
+    'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  ).run(id, req.user!.tenantId, name, req.user!.userId, dashConfig, now, now);
+
+  res.status(201).json({
+    id,
+    tenantId: req.user!.tenantId,
+    name,
+    ownerId: req.user!.userId,
+    config: config || {},
+    createdAt: now,
+    updatedAt: now,
+  });
+});
+
+// GET /api/dashboards
+router.get('/', authMiddleware, (req: AuthRequest, res: Response): void => {
+  const db = getDb();
+  const dashboards = db
+    .prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC')
+    .all(req.user!.tenantId) as DashboardRow[];
+
+  res.json({
+    dashboards: dashboards.map((d) => ({
+      id: d.id,
+      tenantId: d.tenant_id,
+      name: d.name,
+      ownerId: d.owner_id,
+      config: JSON.parse(d.config),
+      createdAt: d.created_at,
+      updatedAt: d.updated_at,
+    })),
+  });
+});
+
+// GET /api/dashboards/:id
+router.get('/:id', authMiddleware, (req: AuthRequest, res: Response): void => {
+  const db = getDb();
+  const dashboard = db
+    .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+    .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  res.json({
+    id: dashboard.id,
+    tenantId: dashboard.tenant_id,
+    name: dashboard.name,
+    ownerId: dashboard.owner_id,
+    config: JSON.parse(dashboard.config),
+    createdAt: dashboard.created_at,
+    updatedAt: dashboard.updated_at,
+  });
+});
+
+// PUT /api/dashboards/:id
+router.put('/:id', authMiddleware, (req: AuthRequest, res: Response): void => {
+  const db = getDb();
+  const existing = db
+    .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+    .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+  if (!existing) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  const name = req.body.name || existing.name;
+  const config = req.body.config ? JSON.stringify(req.body.config) : existing.config;
+  const now = new Date().toISOString();
+
+  db.prepare('UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?').run(
+    name,
+    config,
+    now,
+    req.params.id
+  );
+
+  res.json({
+    id: existing.id,
+    tenantId: existing.tenant_id,
+    name,
+    ownerId: existing.owner_id,
+    config: JSON.parse(config),
+    createdAt: existing.created_at,
+    updatedAt: now,
+  });
+});
+
+// DELETE /api/dashboards/:id
+router.delete('/:id', authMiddleware, (req: AuthRequest, res: Response): void => {
+  const db = getDb();
+  const existing = db
+    .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+    .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+  if (!existing) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  db.prepare('DELETE FROM dashboards WHERE id = ?').run(req.params.id);
+
+  res.status(204).send();
+});
+
+export default router;
