@@ -0,0 +1,126 @@
+import { Router, Response } from 'express';
+import { getDb } from '../db.js';
+import { AuthRequest, authMiddleware } from '../auth.js';
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+const router = Router();
+
+function eventsToCsv(events: EventRow[]): string {
+  const headers = ['id', 'tenant_id', 'name', 'properties', 'timestamp', 'user_id', 'session_id'];
+  const lines = [headers.join(',')];
+
+  for (const event of events) {
+    const row = [
+      escapeCsvField(event.id),
+      escapeCsvField(event.tenant_id),
+      escapeCsvField(event.name),
+      escapeCsvField(event.properties),
+      escapeCsvField(event.timestamp),
+      escapeCsvField(event.user_id || ''),
+      escapeCsvField(event.session_id || ''),
+    ];
+    lines.push(row.join(','));
+  }
+
+  return lines.join('\n');
+}
+
+function escapeCsvField(value: string): string {
+  if (value.includes(',') || value.includes('"') || value.includes('\n')) {
+    return `"${value.replace(/"/g, '""')}"`;
+  }
+  return value;
+}
+
+// GET /api/export/events
+router.get('/events', authMiddleware, (req: AuthRequest, res: Response): void => {
+  const format = (req.query.format as string) || 'json';
+  const db = getDb();
+
+  const events = db
+    .prepare('SELECT * FROM events WHERE tenant_id = ? ORDER BY timestamp DESC')
+    .all(req.user!.tenantId) as EventRow[];
+
+  if (format === 'csv') {
+    const csv = eventsToCsv(events);
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+    res.send(csv);
+  } else {
+    const jsonEvents = events.map((e) => ({
+      id: e.id,
+      tenantId: e.tenant_id,
+      name: e.name,
+      properties: JSON.parse(e.properties),
+      timestamp: e.timestamp,
+      userId: e.user_id,
+      sessionId: e.session_id,
+    }));
+    res.json({ events: jsonEvents });
+  }
+});
+
+// GET /api/export/dashboards/:id
+router.get('/dashboards/:id', authMiddleware, (req: AuthRequest, res: Response): void => {
+  const format = (req.query.format as string) || 'json';
+  const db = getDb();
+
+  const dashboard = db
+    .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+    .get(req.params.id, req.user!.tenantId) as DashboardRow | undefined;
+
+  if (!dashboard) {
+    res.status(404).json({ error: 'Dashboard not found' });
+    return;
+  }
+
+  const dashboardData = {
+    id: dashboard.id,
+    tenantId: dashboard.tenant_id,
+    name: dashboard.name,
+    ownerId: dashboard.owner_id,
+    config: JSON.parse(dashboard.config),
+    createdAt: dashboard.created_at,
+    updatedAt: dashboard.updated_at,
+  };
+
+  if (format === 'csv') {
+    const headers = ['id', 'tenantId', 'name', 'ownerId', 'config', 'createdAt', 'updatedAt'];
+    const row = [
+      escapeCsvField(dashboardData.id),
+      escapeCsvField(dashboardData.tenantId),
+      escapeCsvField(dashboardData.name),
+      escapeCsvField(dashboardData.ownerId),
+      escapeCsvField(JSON.stringify(dashboardData.config)),
+      escapeCsvField(dashboardData.createdAt),
+      escapeCsvField(dashboardData.updatedAt),
+    ];
+    const csv = headers.join(',') + '\n' + row.join(',');
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', `attachment; filename="dashboard-${dashboard.id}.csv"`);
+    res.send(csv);
+  } else {
+    res.json({ dashboard: dashboardData });
+  }
+});
+
+export default router;
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..9e8b7dc
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,131 @@
+import { Router, Response } from 'express';
+import { getDb } from '../db.js';
+import { AuthRequest, authMiddleware } from '../auth.js';
+
+const router = Router();
+
+interface QueryFilter {
+  event_name?: string;
+  start?: string;
+  end?: string;
+  filters?: Record<string, string>;
+}
+
+function buildWhereClause(
+  tenantId: string,
+  params: QueryFilter
+): { where: string; values: (string | number)[] } {
+  const conditions: string[] = ['tenant_id = ?'];
+  const values: (string | number)[] = [tenantId];
+
+  if (params.event_name) {
+    conditions.push('name = ?');
+    values.push(params.event_name);
+  }
+
+  if (params.start) {
+    conditions.push('timestamp >= ?');
+    values.push(params.start);
+  }
+
+  if (params.end) {
+    conditions.push('timestamp <= ?');
+    values.push(params.end);
+  }
+
+  if (params.filters) {
+    for (const [key, value] of Object.entries(params.filters)) {
+      conditions.push(`json_extract(properties, ?) = ?`);
+      values.push(`$.${key}`, value);
+    }
+  }
+
+  return { where: conditions.join(' AND '), values };
+}
+
+// POST /api/queries/count
+router.post('/count', authMiddleware, (req: AuthRequest, res: Response): void => {
+  const { event_name, start, end, filters } = req.body;
+  const db = getDb();
+
+  const { where, values } = buildWhereClause(req.user!.tenantId, {
+    event_name,
+    start,
+    end,
+    filters,
+  });
+
+  const result = db
+    .prepare(`SELECT COUNT(*) as count FROM events WHERE ${where}`)
+    .get(...values) as { count: number };
+
+  res.json({ count: result.count });
+});
+
+// POST /api/queries/timeseries
+router.post('/timeseries', authMiddleware, (req: AuthRequest, res: Response): void => {
+  const { event_name, start, end, interval, filters } = req.body;
+  const db = getDb();
+
+  const { where, values } = buildWhereClause(req.user!.tenantId, {
+    event_name,
+    start,
+    end,
+    filters,
+  });
+
+  // Determine grouping format based on interval
+  let dateFormat: string;
+  switch (interval) {
+    case 'hour':
+      dateFormat = '%Y-%m-%dT%H:00:00';
+      break;
+    case 'month':
+      dateFormat = '%Y-%m-01';
+      break;
+    case 'week':
+      dateFormat = '%Y-%W';
+      break;
+    case 'day':
+    default:
+      dateFormat = '%Y-%m-%d';
+      break;
+  }
+
+  const rows = db
+    .prepare(
+      `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE ${where} GROUP BY bucket ORDER BY bucket`
+    )
+    .all(...values) as Array<{ bucket: string; count: number }>;
+
+  res.json({ timeseries: rows });
+});
+
+// POST /api/queries/breakdown
+router.post('/breakdown', authMiddleware, (req: AuthRequest, res: Response): void => {
+  const { event_name, property, start, end, filters } = req.body;
+
+  if (!property) {
+    res.status(400).json({ error: 'property is required for breakdown queries' });
+    return;
+  }
+
+  const db = getDb();
+
+  const { where, values } = buildWhereClause(req.user!.tenantId, {
+    event_name,
+    start,
+    end,
+    filters,
+  });
+
+  const rows = db
+    .prepare(
+      `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE ${where} AND json_extract(properties, ?) IS NOT NULL GROUP BY value ORDER BY count DESC`
+    )
+    .all(`$.${property}`, ...values, `$.${property}`) as Array<{ value: string; count: number }>;
+
+  res.json({ breakdown: rows });
+});
+
+export default router;
