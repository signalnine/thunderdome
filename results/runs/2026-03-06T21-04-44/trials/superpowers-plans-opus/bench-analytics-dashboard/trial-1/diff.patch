ait request(app)\n      .post('/api/auth/register')\n      .send({ email: 'test@example.com', password: 'password123', tenantId: 'tenant1' });\n\n    const res = await request(app)\n      .post('/api/auth/login')\n      .send({ email: 'test@example.com', password: 'wrong' });\n\n    expect(res.status).toBe(401);\n  });\n\n  it('should return profile for authenticated user', async () => {\n    const reg = await request(app)\n      .post('/api/auth/register')\n      .send({ email: 'test@example.com', password: 'pass', tenantId: 'tenant1' });\n\n    const res = await request(app)\n      .get('/api/auth/profile')\n      .set('Authorization', `Bearer ${reg.body.token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.email).toBe('test@example.com');\n  });\n\n  it('should return 401 for unauthenticated profile access', async () => {\n    const res = await request(app).get('/api/auth/profile');\n    expect(res.status).toBe(401);\n  });\n\n  it('should allow admin to change user role', async () => {\n    const admin = await request(app)\n      .post('/api/auth/register')\n      .send({ email: 'admin@example.com', password: 'pass', tenantId: 'tenant1', role: 'admin' });\n\n    const user = await request(app)\n      .post('/api/auth/register')\n      .send({ email: 'user@example.com', password: 'pass', tenantId: 'tenant1' });\n\n    const res = await request(app)\n      .put(`/api/auth/users/${user.body.id}/role`)\n      .set('Authorization', `Bearer ${admin.body.token}`)\n      .send({ role: 'editor' });\n\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe('editor');\n  });\n\n  it('should prevent non-admin from changing roles', async () => {\n    const viewer = await request(app)\n      .post('/api/auth/register')\n      .send({ email: 'viewer@example.com', password: 'pass', tenantId: 'tenant1' });\n\n    const user = await request(app)\n      .post('/api/auth/register')\n      .send({ email: 'user@example.com', password: 'pass', tenantId: 'tenan