onst gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  // Cycle detection + topological sort\n  const sortedEvents = topologicalSort(events);\n\n  // Build prerequisite map: eventId -> list of prerequisite event IDs\n  const prereqMap = new Map<string, string[]>();\n  for (const event of events) {\n    if (event.prerequisites && event.prerequisites.length > 0) {\n      prereqMap.set(event.id, event.prerequisites);\n    }\n  }\n\n  // Try to find the best assignment using backtracking to maximize placed events\n  const bestResult = optimizeSchedule(sortedEvents, rooms, startTime, endTime, gap, prereqMap);\n\n  return bestResult;\n}\n\nfunction optimizeSchedule(\n  sortedEvents: Event[],\n  rooms: Room[],\n  startTime: number,\n  endTime: number,\n  gap: number,\n  prereqMap: Map<string, string[]>\n): ScheduleResult {\n  // Use a greedy approach with smart ordering to maximize placements.\n  // Sort events by \"most constrained first\" - fewer valid rooms, more prerequisites, longer duration.\n\n  const eventMap = new Map<string, Event>();\n  for (const e of sortedEvents) eventMap.set(e.id, e);\n\n  // Calculate valid rooms for each event\n  const validRoomsMap = new Map<string, Room[]>();\n  for (const event of sortedEvents) {\n    const attendees = event.attendees ?? 1;\n    const validRooms = rooms.filter(r => r.capacity >= attendees);\n    validRoomsMap.set(event.id, validRooms);\n  }\n\n  // Build reverse dependency: for each event, who depends on it\n  const dependents = new Map<string, Set<string>>();\n  for (const event of sortedEvents) {\n    for (const prereq of event.prerequisites ?? []) {\n      if (!dependents.has(prereq)) dependents.set(prereq, new Set());\n      dependents.get(prereq)!.add(event.id);\n    }\n  }\n\n  // Try all combinations using backtracking with pruning\n  // For large inputs, limit iterations\n  const timelines = new Map<string, RoomTimeline>();\n  for (const room of rooms) {\n    timelines.set(room.id, { roomId: room.id, capacity: room.capacity, slots: [] });\n  }\n\n  const assignments = new Map<string, Assignment>();\n\n  // Greedy pass: try to place events in topological order\n  function greedyPlace(eventOrder: Event[]): { assignments: Map<string, Assignment>; unscheduled: string[] } {\n    const localTimelines = new Map<string, RoomTimeline>();\n    for (const room of rooms) {\n      localTimelines.set(room.id, { roomId: room.id, capacity: room.capacity, slots: [] });\n    }\n    const localAssignments = new Map<string, Assignment>();\n    const unscheduled: string[] = [];\n\n    for (const event of eventOrder) {\n      const attendees = event.attendees ?? 1;\n      const validRooms = rooms.filter(r => r.capacity >= attendees);\n\n      if (validRooms.length === 0 || event.duration > endTime - startTime) {\n        unscheduled.push(event.id);\n        continue;\n      }\n\n      // Determine earliest possible start from prerequisites\n      let earliest = startTime;\n      const prereqs = prereqMap.get(event.id) ?? [];\n      let prereqsMet = true;\n      for (const prereqId of prereqs) {\n        const prereqAssignment = localAssignments.get(prereqId);\n        if (!prereqAssignment) {\n          prereqsMet = false;\n          break;\n        }\n        earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n      }\n\n      if (!prereqsMet) {\n        unscheduled.push(event.id);\n        continue;\n      }\n\n      // Try preferred room first\n      const sortedRooms = [...validRooms].sort((a, b) => {\n        if (event.preferredRoom === a.id) return -1;\n        if (event.preferredRoom === b.id) return 1;\n        return a.capacity - b.capacity; // prefer smaller rooms to leave larger rooms for bigger events\n      });\n\n      let placed = false;\n      for (const room of sortedRooms) {\n        const timeline = localTimelines.get(room.id)!;\n        const start = getEarliestSlot(timeline, event.duration, earliest, endTime, gap);\n        if (start !== null) {\n          const assignment: Assignment = {\n            eventId: event.id,\n            roomId: room.id,\n            startTime: start,\n            endTime: start + event.duration,\n          };\n          localAssignments.set(event.id, assignment);\n          timeline.slots.push({ start, end: start + event.duration });\n          placed = true;\n          break;\n        }\n      }\n\n      if (!placed) {\n        unscheduled.push(event.id);\n      }\n    }\n\n    return { assignments: localAssignments, unscheduled };\n  }\n\n  // Try multiple orderings to maximize placement\n  // 1. Topological order (default)\n  // 2. Most constrained first (fewest valid rooms, then longest duration)\n  // 3. Shortest first (to maximize count)\n\n  const orderings: Event[][] = [];\n\n  // Ordering 1: topological\n  orderings.push([...sortedEvents]);\n\n  // Ordering 2: most constrained first (maintaining topological validity)\n  const constrainedOrder = topoSortByPriority(sortedEvents, prereqMap, (a, b) => {\n    const aRooms = validRoomsMap.get(a.id)?.length ?? 0;\n    const bRooms = validRoomsMap.get(b.id)?.length ?? 0;\n    if (aRooms !== bRooms) return aRooms - bRooms;\n    return b.duration - a.duration;\n  });\n  orderings.push(constrainedOrder);\n\n  // Ordering 3: shortest duration first (maintaining topological validity)\n  const shortestFirst = topoSortByPriority(sortedEvents, prereqMap, (a, b) => {\n    return a.duration - b.duration;\n  });\n  orderings.push(shortestFirst);\n\n  // Ordering 4: longest duration first\n  const longestFirst = topoSortByPriority(sortedEvents, prereqMap, (a, b) => {\n    return b.duration - a.duration;\n  });\n  orderings.push(longestFirst);\n\n  let bestResult: { assignments: Map<string, Assignment>; unscheduled: string[] } | null = null;\n\n  for (const ordering of orderings) {\n    const result = greedyPlace(ordering);\n    if (!bestResult || result.assignments.size > bestResult.assignments.size) {\n      bestResult = result;\n    }\n    if (result.unscheduled.length === 0) break; // perfect solution\n  }\n\n  return {\n    assignments: Array.from(bestResult!.assignments.values()),\n    unscheduled: bestResult!.unscheduled,\n  };\n}\n\nfunction getEarliestSlot(timeline: RoomTimeline, duration: number, earliest: number, endTime: number, gap: number): number | null {\n  const occupied = [...timeline.slots].sort((a, b) => a.start - b.start);\n\n  let candidateStart = earliest;\n\n  for (const slot of occupied) {\n    if (candidateStart + duration <= slot.start - gap) {\n      break;\n    }\n    candidateStart = Math.max(candidateStart, slot.end + gap);\n  }\n\n  if (candidateStart + duration <= endTime) return candidateStart;\n  return null;\n}\n\nfunction topoSortByPriority(\n  events: Event[],\n  prereqMap: Map<string, string[]>,\n  compareFn: (a: Event, b: Event) => number\n): Event[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) eventMap.set(e.id, e);\n\n  const inDegree = new Map<string, number>();\n  const adjacency = new Map<string, string[]>();\n\n  for (const event of events) {\n    if (!inDegree.has(event.id)) inDegree.set(event.id, 0);\n    if (!adjacency.has(event.id)) adjacency.set(event.id, []);\n\n    for (const prereq of event.prerequisites ?? []) {\n      if (!adjacency.has(prereq)) adjacency.set(prereq, []);\n      adjacency.get(prereq)!.push(event.id);\n      inDegree.set(event.id, (inDegree.get(event.id) ?? 0) + 1);\n    }\n  }\n\n  const available: Event[] = [];\n  for (const [id, degree] of inDegree) {\n    if (degree === 0) available.push(eventMap.get(id)!);\n  }\n  available.sort(compareFn);\n\n  const result: Event[] = [];\n  while (available.length > 0) {\n    const event = available.shift()!;\n    result.push(event);\n\n    for (const neighbor of adjacency.get(event.id) ?? []) {\n      const newDegree = (inDegree.get(neighbor) ?? 1) - 1;\n      inDegree.set(neighbor, newDegree);\n      if (newDegree === 0) {\n        available.push(eventMap.get(neighbor)!);\n        available.sort(compareFn);\n      }\n    }\n  }\n\n  return result;\n}\n```\n\n**Step 4: Run all tests**\n\nRun: `npx vitest run`\nExpected: ALL PASS\n\n**Step 5: Run build and lint**\n\nRun: `npm run build && npm run lint`\nExpected: PASS\n\n---\n\n### Task 5: Final Verification\n\n**Step 1:** Run `npm test`\n**Step 2:** Run `npm run build`\n**Step 3:** Run `npm run lint`\n\nAll should pass.\n","structuredPatch":[],"originalFile":null}}
