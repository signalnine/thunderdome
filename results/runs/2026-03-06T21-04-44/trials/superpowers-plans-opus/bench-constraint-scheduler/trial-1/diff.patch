+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_0186x4cgGbTd1qtJgDP9ZZH5","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0162GSogg7v7hj8fgxXj5znn","name":"Write","input":{"file_path":"/workspace/docs/plans/2026-03-06-constraint-scheduler.md","content":"# Constraint-Based Event Scheduler Implementation Plan\n\n> **For Claude:** REQUIRED SUB-SKILL: Use superpowers:executing-plans to implement this plan task-by-task.\n\n**Goal:** Build a constraint-based event scheduler that assigns events to rooms within a time window, respecting capacity limits, prerequisite ordering, and room preferences, while maximizing the number of scheduled events.\n\n**Architecture:** Topological sort for prerequisite ordering with cycle detection (Kahn's algorithm). Greedy scheduling with backtracking/optimization to maximize placed events. Events sorted by constraint tightness (prerequisites, capacity requirements) scheduled first.\n\n**Tech Stack:** TypeScript, Vitest for testing, ESLint for linting.\n\n---\n\n### Task 1: Types and Project Skeleton\n\n**Files:**\n- Create: `src/types.ts`\n- Create: `src/index.ts`\n\n**Step 1: Create types file**\n\n```typescript\n// src/types.ts\nexport interface Event {\n  id: string;\n  name: string;\n  duration: number;\n  attendees?: number;\n  prerequisites?: string[];\n  preferredRoom?: string;\n}\n\nexport interface Room {\n  id: string;\n  name: string;\n  capacity: number;\n}\n\nexport interface ScheduleOptions {\n  startTime: number;\n  endTime: number;\n  gap?: number;\n}\n\nexport interface Assignment {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n```\n\n**Step 2: Create index.ts with stub**\n\n```typescript\n// src/index.ts\nexport { schedule } from './scheduler.js';\nexport type { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';\n```\n\n**Step 3: Create scheduler stub**\n\n```typescript\n// src/scheduler.ts\nimport { Event, Room, ScheduleOptions, ScheduleResult } from './types.js';\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  throw new Error('Not implemented');\n}\n```\n\n**Step 4: Verify build**\n\nRun: `npm run build`\nExpected: PASS, no errors\n\n---\n\n### Task 2: Cycle Detection\n\n**Files:**\n- Create: `src/graph.ts`\n- Create: `src/__tests__/graph.test.ts`\n\n**Step 1: Write failing tests for cycle detection**\n\n```typescript\n// src/__tests__/graph.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { topologicalSort } from '../graph.js';\nimport { Event } from '../types.js';\n\ndescribe('topologicalSort', () => {\n  it('returns events in valid order when no prerequisites', () => {\n    const events: Event[] = [\n      { id: 'A', name: 'A', duration: 30 },\n      { id: 'B', name: 'B', duration: 30 },\n    ];\n    const sorted = topologicalSort(events);\n    expect(sorted.map(e => e.id)).toEqual(expect.arrayContaining(['A', 'B']));\n  });\n\n  it('orders events respecting prerequisites', () => {\n    const events: Event[] = [\n      { id: 'B', name: 'B', duration: 30, prerequisites: ['A'] },\n      { id: 'A', name: 'A', duration: 30 },\n    ];\n    const sorted = topologicalSort(events);\n    const ids = sorted.map(e => e.id);\n    expect(ids.indexOf('A')).toBeLessThan(ids.indexOf('B'));\n  });\n\n  it('throws on self-referencing prerequisite', () => {\n    const events: Event[] = [\n      { id: 'A', name: 'A', duration: 30, prerequisites: ['A'] },\n    ];\n    expect(() => topologicalSort(events)).toThrow();\n  });\n\n  it('throws on cycle A -> B -> A', () => {\n    const events: Event[] = [\n      { id: 'A', name: 'A', duration: 30, prerequisites: ['B'] },\n      { id: 'B', name: 'B', duration: 30, prerequisites: ['A'] },\n    ];\n    expect(() => topologicalSort(events)).toThrow();\n  });\n\n  it('throws on longer cycle A -> B -> C -> A', () => {\n    const events: Event[] = [\n      { id: 'A', name: 'A', duration: 30, prerequisites: ['C'] },\n      { id: 'B', name: 'B', duration: 30, prerequisites: ['A'] },\n      { id: 'C', name: 'C', duration: 30, prerequisites: ['B'] },\n    ];\n    expect(() => topologicalSort(events)).toThrow();\n  });\n\n  it('handles chain A -> B -> C', () => {\n    const events: Event[] = [\n      { id: 'C', name: 'C', duration: 30, prerequisites: ['B'] },\n      { id: 'A', name: 'A', duration: 30 },\n      { id: 'B', name: 'B', duration: 30, prerequisites: ['A'] },\n    ];\n    const sorted = topologicalSort(events);\n    const ids = sorted.map(e => e.id);\n    expect(ids.indexOf('A')).toBeLessThan(ids.indexOf('B'));\n    expect(ids.indexOf('B')).toBeLessThan(ids.indexOf('C'));\n  });\n});\n```\n\n**Step 2: Run tests to verify failure**\n\nRun: `npx vitest run src/__tests__/graph.test.ts`\nExpected: FAIL\n\n**Step 3: Implement topological sort with Kahn's algorithm**\n\n```typescript\n// src/graph.ts\nimport { Event } from './types.js';\n\nexport function topologicalSort(events: Event[]): Event[] {\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  const inDegree = new Map<string, number>();\n  const adjacency = new Map<string, string[]>();\n\n  for (const event of events) {\n    if (!inDegree.has(event.id)) inDegree.set(event.id, 0);\n    if (!adjacency.has(event.id)) adjacency.set(event.id, []);\n\n    for (const prereq of event.prerequisites ?? []) {\n      if (prereq === event.id) {\n        throw new Error(`Cycle detected: event \"${event.id}\" references itself`);\n      }\n      if (!adjacency.has(prereq)) adjacency.set(prereq, []);\n      adjacency.get(prereq)!.push(event.id);\n      inDegree.set(event.id, (inDegree.get(event.id) ?? 0) + 1);\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, degree] of inDegree) {\n    if (degree === 0) queue.push(id);\n  }\n\n  const sorted: Event[] = [];\n  while (queue.length > 0) {\n    const id = queue.shift()!;\n    const event = eventMap.get(id);\n    if (event) sorted.push(event);\n\n    for (const neighbor of adjacency.get(id) ?? []) {\n      const newDegree = (inDegree.get(neighbor) ?? 1) - 1;\n      inDegree.set(neighbor, newDegree);\n      if (newDegree === 0) queue.push(neighbor);\n    }\n  }\n\n  if (sorted.length < events.length) {\n    throw new Error('Prerequisite cycle detected');\n  }\n\n  return sorted;\n}\n```\n\n**Step 4: Run tests to verify pass**\n\nRun: `npx vitest run src/__tests__/graph.test.ts`\nExpected: PASS\n\n---\n\n### Task 3: Core Scheduler - Basic Scheduling\n\n**Files:**\n- Create: `src/__tests__/scheduler.test.ts`\n- Modify: `src/scheduler.ts`\n\n**Step 1: Write failing tests for basic scheduling**\n\n```typescript\n// src/__tests__/scheduler.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { schedule } from '../index.js';\n\nconst defaultOptions = { startTime: 540, endTime: 1020, gap: 15 };\n\ndescribe('schedule', () => {\n  describe('basic scheduling', () => {\n    it('schedules a single event into a single room', () => {\n      const events = [{ id: 'E1', name: 'Event 1', duration: 60 }];\n      const rooms = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(1);\n      expect(result.unscheduled).toHaveLength(0);\n      expect(result.assignments[0].eventId).toBe('E1');\n      expect(result.assignments[0].roomId).toBe('R1');\n      expect(result.assignments[0].startTime).toBeGreaterThanOrEqual(540);\n      expect(result.assignments[0].endTime).toBeLessThanOrEqual(1020);\n      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(60);\n    });\n\n    it('schedules multiple events in one room with gaps', () => {\n      const events = [\n        { id: 'E1', name: 'Event 1', duration: 60 },\n        { id: 'E2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, defaultOptions);\n\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(0);\n\n      const a1 = result.assignments.find(a => a.eventId === 'E1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'E2')!;\n      const [earlier, later] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n      expect(later.startTime - earlier.endTime).toBeGreaterThanOrEqual(15);\n    });\n\n    it('schedules events across multiple rooms', () => {\n      const events = [\n        { id: 'E1', name: 'Event 1', duration: 420 },\n        { id: 'E2', name: 'Event 2', duration: 420 },\n      ];\n      const rooms = [\n        { id: 'R1', name: 'Room 1', capacity: 10 },\n        { id: 'R2', name: 'Room 2', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(0);\n\n      const roomIds = result.assignments.map(a => a.roomId);\n      expect(new Set(roomIds).size).toBe(2);\n    });\n\n    it('returns empty assignments for empty events', () => {\n      const result = schedule([], [{ id: 'R1', name: 'Room 1', capacity: 10 }], defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it('uses default gap of 15 when not specified', () => {\n      const events = [\n        { id: 'E1', name: 'Event 1', duration: 60 },\n        { id: 'E2', name: 'Event 2', duration: 60 },\n      ];\n      const rooms = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, { startTime: 540, endTime: 1020 });\n\n      expect(result.assignments).toHaveLength(2);\n      const a1 = result.assignments.find(a => a.eventId === 'E1')!;\n      const a2 = result.assignments.find(a => a.eventId === 'E2')!;\n      const [earlier, later] = a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n      expect(later.startTime - earlier.endTime).toBeGreaterThanOrEqual(15);\n    });\n  });\n\n  describe('capacity constraints', () => {\n    it('does not place event in room with insufficient capacity', () => {\n      const events = [{ id: 'E1', name: 'Event 1', duration: 60, attendees: 20 }];\n      const rooms = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('E1');\n    });\n\n    it('places event in room with sufficient capacity', () => {\n      const events = [{ id: 'E1', name: 'Event 1', duration: 60, attendees: 10 }];\n      const rooms = [\n        { id: 'R1', name: 'Room 1', capacity: 5 },\n        { id: 'R2', name: 'Room 2', capacity: 15 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('R2');\n    });\n  });\n\n  describe('time window constraints', () => {\n    it('does not schedule event that exceeds the time window', () => {\n      const events = [{ id: 'E1', name: 'Event 1', duration: 600 }];\n      const rooms = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, { startTime: 540, endTime: 1020 });\n      expect(result.unscheduled).toContain('E1');\n    });\n\n    it('schedules event that exactly fits the window', () => {\n      const events = [{ id: 'E1', name: 'Event 1', duration: 480 }];\n      const rooms = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, { startTime: 540, endTime: 1020 });\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBe(540);\n      expect(result.assignments[0].endTime).toBe(1020);\n    });\n  });\n\n  describe('prerequisites', () => {\n    it('schedules prerequisite before dependent event', () => {\n      const events = [\n        { id: 'B', name: 'B', duration: 60, prerequisites: ['A'] },\n        { id: 'A', name: 'A', duration: 60 },\n      ];\n      const rooms = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n\n      const aAssign = result.assignments.find(a => a.eventId === 'A')!;\n      const bAssign = result.assignments.find(a => a.eventId === 'B')!;\n      expect(bAssign.startTime).toBeGreaterThanOrEqual(aAssign.endTime + 15);\n    });\n\n    it('throws error on prerequisite cycle', () => {\n      const events = [\n        { id: 'A', name: 'A', duration: 30, prerequisites: ['B'] },\n        { id: 'B', name: 'B', duration: 30, prerequisites: ['A'] },\n      ];\n      const rooms = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n\n    it('throws error on self-referencing prerequisite', () => {\n      const events = [\n        { id: 'A', name: 'A', duration: 30, prerequisites: ['A'] },\n      ];\n      const rooms = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n  });\n\n  describe('preferred room', () => {\n    it('assigns event to preferred room when possible', () => {\n      const events = [{ id: 'E1', name: 'Event 1', duration: 60, preferredRoom: 'R2' }];\n      const rooms = [\n        { id: 'R1', name: 'Room 1', capacity: 10 },\n        { id: 'R2', name: 'Room 2', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('R2');\n    });\n\n    it('assigns event to another room when preferred is full', () => {\n      const events = [\n        { id: 'E1', name: 'Event 1', duration: 450, preferredRoom: 'R1' },\n        { id: 'E2', name: 'Event 2', duration: 450, preferredRoom: 'R1' },\n      ];\n      const rooms = [\n        { id: 'R1', name: 'Room 1', capacity: 10 },\n        { id: 'R2', name: 'Room 2', capacity: 10 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n      const roomIds = result.assignments.map(a => a.roomId);\n      expect(roomIds).toContain('R1');\n      expect(roomIds).toContain('R2');\n    });\n  });\n\n  describe('unscheduled events', () => {\n    it('reports events that cannot fit', () => {\n      const events = [\n        { id: 'E1', name: 'Event 1', duration: 400 },\n        { id: 'E2', name: 'Event 2', duration: 400 },\n      ];\n      const rooms = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.unscheduled).toHaveLength(1);\n    });\n  });\n\n  describe('optimization', () => {\n    it('maximizes scheduled events over naive ordering', () => {\n      // One long event and several short events. A naive approach scheduling\n      // the long event first in the only room would block shorter events.\n      // Optimal: schedule the 3 short events (3 scheduled) rather than 1 long.\n      const events = [\n        { id: 'long', name: 'Long', duration: 450 },\n        { id: 'S1', name: 'Short 1', duration: 120 },\n        { id: 'S2', name: 'Short 2', duration: 120 },\n        { id: 'S3', name: 'Short 3', duration: 120 },\n      ];\n      const rooms = [{ id: 'R1', name: 'Room 1', capacity: 10 }];\n      // Window: 480 min. Long=450 leaves room for 0 more. 3 shorts = 120+15+120+15+120 = 390, fits.\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments.length).toBeGreaterThanOrEqual(3);\n    });\n  });\n});\n```\n\n**Step 2: Run tests to verify