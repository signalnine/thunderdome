+```typescript
+// src/tokenizer.ts
+export enum TokenType {
+  Number = 'Number',
+  String = 'String',
+  Boolean = 'Boolean',
+  CellRef = 'CellRef',
+  Function = 'Function',
+  Operator = 'Operator',
+  LParen = 'LParen',
+  RParen = 'RParen',
+  Comma = 'Comma',
+  Colon = 'Colon',
+}
+
+export interface Token {
+  type: TokenType;
+  value: string;
+}
+
+const FUNCTIONS = new Set(['SUM', 'AVERAGE', 'MIN', 'MAX', 'COUNT', 'IF']);
+
+export function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < input.length) {
+    if (input[i] === ' ') { i++; continue; }
+
+    // String literals
+    if (input[i] === '"') {
+      let str = '';
+      i++;
+      while (i < input.length && input[i] !== '"') {
+        str += input[i++];
+      }
+      i++; // skip closing quote
+      tokens.push({ type: TokenType.String, value: str });
+      continue;
+    }
+
+    // Numbers
+    if (/\d/.test(input[i])) {
+      let num = '';
+      while (i < input.length && /[\d.]/.test(input[i])) {
+        num += input[i++];
+      }
+      tokens.push({ type: TokenType.Number, value: num });
+      continue;
+    }
+
+    // Letters: cell refs, function names, booleans
+    if (/[A-Za-z]/.test(input[i])) {
+      let word = '';
+      while (i < input.length && /[A-Za-z0-9]/.test(input[i])) {
+        word += input[i++];
+      }
+      const upper = word.toUpperCase();
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: TokenType.Boolean, value: upper.toLowerCase() });
+      } else if (FUNCTIONS.has(upper) && i < input.length && input[i] === '(') {
+        tokens.push({ type: TokenType.Function, value: upper });
+      } else if (/^[A-Z]+\d+$/.test(upper)) {
+        tokens.push({ type: TokenType.CellRef, value: upper });
+      } else if (FUNCTIONS.has(upper)) {
+        tokens.push({ type: TokenType.Function, value: upper });
+      } else {
+        throw new Error(`Unknown identifier: ${word}`);
+      }
+      continue;
+    }
+
+    // Two-char operators
+    if (i + 1 < input.length) {
+      const two = input[i] + input[i + 1];
+      if (['>=', '<=', '<>'].includes(two)) {
+        tokens.push({ type: TokenType.Operator, value: two });
+        i += 2;
+        continue;
+      }
+    }
+
+    // Single-char tokens
+    const ch = input[i];
+    if ('+-*/'.includes(ch) || ch === '>' || ch === '<' || ch === '=') {
+      tokens.push({ type: TokenType.Operator, value: ch });
+    } else if (ch === '(') {
+      tokens.push({ type: TokenType.LParen, value: ch });
+    } else if (ch === ')') {
+      tokens.push({ type: TokenType.RParen, value: ch });
+    } else if (ch === ',') {
+      tokens.push({ type: TokenType.Comma, value: ch });
+    } else if (ch === ':') {
+      tokens.push({ type: TokenType.Colon, value: ch });
+    } else {
+      throw new Error(`Unexpected character: ${ch}`);
+    }
+    i++;
+  }
+
+  return tokens;
+}
+```
