new file mode 100644
index 0000000..af70aa3
--- /dev/null
+++ b/src/evaluator.ts
@@ -0,0 +1,127 @@
+import { ASTNode } from './parser.js';
+import { expandRange } from './cell-utils.js';
+
+export type CellValue = string | number | boolean | null;
+export type CellResolver = (ref: string) => CellValue;
+
+export function evaluate(node: ASTNode, resolve: CellResolver): CellValue {
+  switch (node.type) {
+    case 'number':
+      return node.value;
+
+    case 'string':
+      return node.value;
+
+    case 'boolean':
+      return node.value;
+
+    case 'cellref':
+      return resolve(node.ref);
+
+    case 'range':
+      throw new Error('Range can only be used inside a function');
+
+    case 'unary':
+      if (node.op === '-') {
+        const val = evaluate(node.operand, resolve);
+        if (typeof val === 'number') return -val;
+        throw new Error('Cannot negate non-number');
+      }
+      throw new Error(`Unknown unary operator: ${node.op}`);
+
+    case 'binary':
+      return evaluateBinary(node.op, node.left, node.right, resolve);
+
+    case 'function':
+      return evaluateFunction(node.name, node.args, resolve);
+
+    default:
+      throw new Error(`Unknown node type: ${(node as ASTNode).type}`);
+  }
+}
+
+function evaluateBinary(op: string, left: ASTNode, right: ASTNode, resolve: CellResolver): CellValue {
+  const l = evaluate(left, resolve);
+  const r = evaluate(right, resolve);
+
+  if (op === '+' || op === '-' || op === '*' || op === '/') {
+    const ln = typeof l === 'number' ? l : 0;
+    const rn = typeof r === 'number' ? r : 0;
+    switch (op) {
+      case '+': return ln + rn;
+      case '-': return ln - rn;
+      case '*': return ln * rn;
+      case '/':
+        if (rn === 0) throw new Error('Division by zero');
+        return ln / rn;
+    }
+  }
+
+  // Comparison operators
+  switch (op) {
+    case '>': return (l as number) > (r as number);
+    case '<': return (l as number) < (r as number);
+    case '>=': return (l as number) >= (r as number);
+    case '<=': return (l as number) <= (r as number);
+    case '=': return l === r;
+    case '<>': return l !== r;
+  }
+
+  throw new Error(`Unknown operator: ${op}`);
+}
+
+function resolveRange(node: ASTNode, resolve: CellResolver): CellValue[] {
+  if (node.type === 'range') {
+    const cells = expandRange(node.start, node.end);
+    return cells.map(resolve);
+  }
+  return [evaluate(node, resolve)];
+}
+
+function evaluateFunction(name: string, args: ASTNode[], resolve: CellResolver): CellValue {
+  switch (name) {
+    case 'SUM': {
+      const values = resolveRange(args[0], resolve);
+      return values.reduce<number>((sum, v) => sum + (typeof v === 'number' ? v : 0), 0);
+    }
+
+    case 'AVERAGE': {
+      const values = resolveRange(args[0], resolve);
+      const nums = values.filter((v): v is number => typeof v === 'number');
+      if (nums.length === 0) return 0;
+      return nums.reduce((sum, v) => sum + v, 0) / nums.length;
+    }
+
+    case 'MIN': {
+      const values = resolveRange(args[0], resolve);
+      const nums = values.filter((v): v is number => typeof v === 'number');
+      if (nums.length === 0) return 0;
+      return Math.min(...nums);
+    }
+
+    case 'MAX': {
+      const values = resolveRange(args[0], resolve);
+      const nums = values.filter((v): v is number => typeof v === 'number');
+      if (nums.length === 0) return 0;
+      return Math.max(...nums);
+    }
+
+    case 'COUNT': {
+      const values = resolveRange(args[0], resolve);
+      return values.filter((v): v is number => typeof v === 'number').length;
+    }
+
+    case 'IF': {
+      if (args.length < 3) throw new Error('IF requires 3 arguments');
+      const condition = evaluate(args[0], resolve);
+      if (condition) {
+        return evaluate(args[1], resolve);
+      } else {
+        return evaluate(args[2], resolve);
+      }
+    }
+
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
