@@ -0,0 +1,261 @@
+import { describe, it, expect } from 'vitest';
+import { Spreadsheet } from '../spreadsheet.js';
+
+describe('Spreadsheet', () => {
+  describe('basic values', () => {
+    it('sets and gets numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('sets and gets strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('sets and gets booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+    });
+
+    it('returns null for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.get('A1')).toBe(null);
+    });
+  });
+
+  describe('formulas', () => {
+    it('evaluates simple arithmetic', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('evaluates multiplication', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A3', '=A1*3');
+      expect(sheet.get('A3')).toBe(15);
+    });
+
+    it('evaluates division', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1/2');
+      expect(sheet.get('A2')).toBe(5);
+    });
+
+    it('evaluates subtraction', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', '=A1-3');
+      expect(sheet.get('A2')).toBe(7);
+    });
+
+    it('evaluates parenthesized expressions', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('B1', 3);
+      sheet.set('C1', '=(A1+B1)*2');
+      expect(sheet.get('C1')).toBe(10);
+    });
+  });
+
+  describe('functions', () => {
+    it('SUM', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(60);
+    });
+
+    it('AVERAGE', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=AVERAGE(A1:A3)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+
+    it('MIN', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=MIN(A1:A3)');
+      expect(sheet.get('B1')).toBe(5);
+    });
+
+    it('MAX', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 5);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=MAX(A1:A3)');
+      expect(sheet.get('B1')).toBe(30);
+    });
+
+    it('COUNT', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=COUNT(A1:A3)');
+      expect(sheet.get('B1')).toBe(3);
+    });
+
+    it('IF true branch', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 50);
+      sheet.set('C1', '=IF(A1>30,"big","small")');
+      expect(sheet.get('C1')).toBe('big');
+    });
+
+    it('IF false branch', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('C1', '=IF(A1>30,"big","small")');
+      expect(sheet.get('C1')).toBe('small');
+    });
+  });
+
+  describe('reactive updates', () => {
+    it('updates direct dependents', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+    });
+
+    it('updates transitive dependents', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('A2', '=A1+1');
+      sheet.set('A3', '=A2+1');
+      expect(sheet.get('A3')).toBe(3);
+
+      sheet.set('A1', 10);
+      expect(sheet.get('A2')).toBe(11);
+      expect(sheet.get('A3')).toBe(12);
+    });
+
+    it('updates function-based dependents', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('B1', '=SUM(A1:A2)');
+      expect(sheet.get('B1')).toBe(30);
+
+      sheet.set('A1', 50);
+      expect(sheet.get('B1')).toBe(70);
+    });
+  });
+
+  describe('circular reference detection', () => {
+    it('detects direct circular reference', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=B1');
+      expect(() => sheet.set('B1', '=A1')).toThrow('Circular reference');
+    });
+
+    it('detects indirect circular reference', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=B1');
+      sheet.set('B1', '=C1');
+      expect(() => sheet.set('C1', '=A1')).toThrow('Circular reference');
+    });
+
+    it('detects self-reference', () => {
+      const sheet = new Spreadsheet();
+      expect(() => sheet.set('A1', '=A1')).toThrow('Circular reference');
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('displays numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('displays strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('displays booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('displays formula results', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+
+    it('displays empty string for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+  });
+
+  describe('getCells', () => {
+    it('returns all non-empty cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(3);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+      expect(cells.get('C1')).toBe(30);
+    });
+  });
+
+  describe('case insensitivity', () => {
+    it('handles lowercase cell references', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('a1', 42);
+      expect(sheet.get('A1')).toBe(42);
+      expect(sheet.get('a1')).toBe(42);
+    });
+  });
+
+  describe('example from spec', () => {
+    it('runs the full example', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+      expect(sheet.getDisplay('A3')).toBe('30');
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+
+      sheet.set('B1', '=SUM(A1:A2)');
+      expect(sheet.get('B1')).toBe(70);
+
+      sheet.set('C1', '=IF(A1>30,"big","small")');
+      expect(sheet.get('C1')).toBe('big');
+    });
+  });
+});
