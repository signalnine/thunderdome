@@ -0,0 +1,154 @@
+import { parse, extractCellRefs, ASTNode } from './parser.js';
+import { evaluate, CellValue } from './evaluator.js';
+
+export class Spreadsheet {
+  private rawValues = new Map<string, string | number | boolean>();
+  private computedValues = new Map<string, CellValue>();
+  private formulas = new Map<string, ASTNode>();
+
+  // dependency graph: cell -> set of cells it depends on
+  private dependencies = new Map<string, Set<string>>();
+  // reverse dependency graph: cell -> set of cells that depend on it
+  private dependents = new Map<string, Set<string>>();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+
+    // Remove old dependencies
+    this.removeDependencies(ref);
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaStr = value.slice(1);
+      const ast = parse(formulaStr);
+      const deps = extractCellRefs(ast);
+
+      // Store
+      this.rawValues.set(ref, value);
+      this.formulas.set(ref, ast);
+
+      // Set up dependencies
+      const depSet = new Set(deps);
+      this.dependencies.set(ref, depSet);
+      for (const dep of depSet) {
+        if (!this.dependents.has(dep)) {
+          this.dependents.set(dep, new Set());
+        }
+        this.dependents.get(dep)!.add(ref);
+      }
+
+      // Check for circular references
+      if (this.hasCycle(ref)) {
+        // Rollback
+        this.removeDependencies(ref);
+        this.rawValues.delete(ref);
+        this.formulas.delete(ref);
+        this.computedValues.delete(ref);
+        throw new Error('Circular reference detected');
+      }
+
+      // Evaluate
+      this.computedValues.set(ref, this.evaluateCell(ref));
+    } else {
+      this.rawValues.set(ref, value);
+      this.formulas.delete(ref);
+      this.computedValues.set(ref, value);
+    }
+
+    // Recompute dependents
+    this.recomputeDependents(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = cell.toUpperCase();
+    if (!this.rawValues.has(ref)) return null;
+    return this.computedValues.get(ref) ?? null;
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [key] of this.rawValues) {
+      result.set(key, this.computedValues.get(key) ?? null);
+    }
+    return result;
+  }
+
+  private evaluateCell(ref: string): CellValue {
+    const ast = this.formulas.get(ref);
+    if (!ast) {
+      return this.rawValues.get(ref) ?? null;
+    }
+    return evaluate(ast, (cellRef: string) => {
+      const upper = cellRef.toUpperCase();
+      return this.computedValues.get(upper) ?? null;
+    });
+  }
+
+  private removeDependencies(ref: string): void {
+    const oldDeps = this.dependencies.get(ref);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        const depSet = this.dependents.get(dep);
+        if (depSet) {
+          depSet.delete(ref);
+          if (depSet.size === 0) this.dependents.delete(dep);
+        }
+      }
+      this.dependencies.delete(ref);
+    }
+  }
+
+  private hasCycle(startRef: string): boolean {
+    const visited = new Set<string>();
+    const stack = [startRef];
+
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      const deps = this.dependencies.get(current);
+      if (!deps) continue;
+
+      for (const dep of deps) {
+        if (dep === startRef) return true;
+        if (!visited.has(dep)) {
+          visited.add(dep);
+          stack.push(dep);
+        }
+      }
+    }
+    return false;
+  }
+
+  private recomputeDependents(ref: string): void {
+    const order = this.topologicalSort(ref);
+    for (const cellRef of order) {
+      if (cellRef === ref) continue;
+      this.computedValues.set(cellRef, this.evaluateCell(cellRef));
+    }
+  }
+
+  private topologicalSort(startRef: string): string[] {
+    const visited = new Set<string>();
+    const result: string[] = [];
+
+    const visit = (ref: string): void => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+      result.push(ref);
+    };
+
+    visit(startRef);
+    // Reverse so that cells are processed after their dependencies
+    return result.reverse();
+  }
+}
diff --git a/src/tokenizer.ts b/src/tokenizer.ts
new file mode 100644
index 0000000..b7b7bde
--- /dev/null
+++ b/src/tokenizer.ts
@@ -0,0 +1,100 @@
+export enum TokenType {
+  Number = 'Number',
+  String = 'String',
+  Boolean = 'Boolean',
+  CellRef = 'CellRef',
+  Function = 'Function',
+  Operator = 'Operator',
+  LParen = 'LParen',
+  RParen = 'RParen',
+  Comma = 'Comma',
+  Colon = 'Colon',
+}
+
+export interface Token {
+  type: TokenType;
+  value: string;
+}
+
+const FUNCTIONS = new Set(['SUM', 'AVERAGE', 'MIN', 'MAX', 'COUNT', 'IF']);
+
+export function tokenize(input: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < input.length) {
+    if (input[i] === ' ') { i++; continue; }
+
+    // String literals
+    if (input[i] === '"') {
+      let str = '';
+      i++;
+      while (i < input.length && input[i] !== '"') {
+        str += input[i++];
+      }
+      i++; // skip closing quote
+      tokens.push({ type: TokenType.String, value: str });
+      continue;
+    }
+
+    // Numbers
+    if (/\d/.test(input[i])) {
+      let num = '';
+      while (i < input.length && /[\d.]/.test(input[i])) {
+        num += input[i++];
+      }
+      tokens.push({ type: TokenType.Number, value: num });
+      continue;
+    }
+
+    // Letters: cell refs, function names, booleans
+    if (/[A-Za-z]/.test(input[i])) {
+      let word = '';
+      while (i < input.length && /[A-Za-z0-9]/.test(input[i])) {
+        word += input[i++];
+      }
+      const upper = word.toUpperCase();
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: TokenType.Boolean, value: upper.toLowerCase() });
+      } else if (FUNCTIONS.has(upper) && i < input.length && input[i] === '(') {
+        tokens.push({ type: TokenType.Function, value: upper });
+      } else if (/^[A-Z]+\d+$/.test(upper)) {
+        tokens.push({ type: TokenType.CellRef, value: upper });
+      } else if (FUNCTIONS.has(upper)) {
+        tokens.push({ type: TokenType.Function, value: upper });
+      } else {
+        throw new Error(`Unknown identifier: ${word}`);
+      }
+      continue;
+    }
+
+    // Two-char operators
+    if (i + 1 < input.length) {
+      const two = input[i] + input[i + 1];
+      if (['>=', '<=', '<>'].includes(two)) {
+        tokens.push({ type: TokenType.Operator, value: two });
+        i += 2;
+        continue;
+      }
+    }
+
+    // Single-char tokens
+    const ch = input[i];
+    if ('+-*/'.includes(ch) || ch === '>' || ch === '<' || ch === '=') {
+      tokens.push({ type: TokenType.Operator, value: ch });
+    } else if (ch === '(') {
+      tokens.push({ type: TokenType.LParen, value: ch });
+    } else if (ch === ')') {
+      tokens.push({ type: TokenType.RParen, value: ch });
+    } else if (ch === ',') {
+      tokens.push({ type: TokenType.Comma, value: ch });
+    } else if (ch === ':') {
+      tokens.push({ type: TokenType.Colon, value: ch });
+    } else {
+      throw new Error(`Unexpected character: ${ch}`);
+    }
+    i++;
+  }
+
+  return tokens;
+}
