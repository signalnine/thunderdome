@@ -0,0 +1,60 @@
+import { describe, it, expect } from 'vitest';
+import { parseCellRef, cellRefToString, columnToNumber, numberToColumn, expandRange } from '../cell-utils.js';
+
+describe('cell-utils', () => {
+  describe('columnToNumber', () => {
+    it('converts single letters', () => {
+      expect(columnToNumber('A')).toBe(1);
+      expect(columnToNumber('Z')).toBe(26);
+    });
+    it('converts multi-letter columns', () => {
+      expect(columnToNumber('AA')).toBe(27);
+      expect(columnToNumber('AZ')).toBe(52);
+      expect(columnToNumber('BA')).toBe(53);
+    });
+  });
+
+  describe('numberToColumn', () => {
+    it('converts numbers to column letters', () => {
+      expect(numberToColumn(1)).toBe('A');
+      expect(numberToColumn(26)).toBe('Z');
+      expect(numberToColumn(27)).toBe('AA');
+      expect(numberToColumn(52)).toBe('AZ');
+    });
+  });
+
+  describe('parseCellRef', () => {
+    it('parses simple refs', () => {
+      expect(parseCellRef('A1')).toEqual({ col: 1, row: 1 });
+      expect(parseCellRef('B2')).toEqual({ col: 2, row: 2 });
+      expect(parseCellRef('Z100')).toEqual({ col: 26, row: 100 });
+    });
+    it('parses multi-letter columns', () => {
+      expect(parseCellRef('AA1')).toEqual({ col: 27, row: 1 });
+    });
+    it('throws on invalid refs', () => {
+      expect(() => parseCellRef('1A')).toThrow();
+      expect(() => parseCellRef('')).toThrow();
+    });
+  });
+
+  describe('cellRefToString', () => {
+    it('converts back to string', () => {
+      expect(cellRefToString({ col: 1, row: 1 })).toBe('A1');
+      expect(cellRefToString({ col: 27, row: 1 })).toBe('AA1');
+    });
+  });
+
+  describe('expandRange', () => {
+    it('expands column range', () => {
+      expect(expandRange('A1', 'A3')).toEqual(['A1', 'A2', 'A3']);
+    });
+    it('expands row range', () => {
+      expect(expandRange('A1', 'C1')).toEqual(['A1', 'B1', 'C1']);
+    });
+    it('expands block range', () => {
+      const result = expandRange('A1', 'B2');
+      expect(result).toEqual(['A1', 'A2', 'B1', 'B2']);
+    });
+  });
+});
diff --git a/src/__tests__/parser.test.ts b/src/__tests__/parser.test.ts
new file mode 100644
index 0000000..00fa238
--- /dev/null
+++ b/src/__tests__/parser.test.ts
@@ -0,0 +1,84 @@
+import { describe, it, expect } from 'vitest';
+import { parse } from '../parser.js';
+
+describe('parser', () => {
+  it('parses numbers', () => {
+    expect(parse('42')).toEqual({ type: 'number', value: 42 });
+  });
+
+  it('parses strings', () => {
+    expect(parse('"hello"')).toEqual({ type: 'string', value: 'hello' });
+  });
+
+  it('parses booleans', () => {
+    expect(parse('true')).toEqual({ type: 'boolean', value: true });
+    expect(parse('false')).toEqual({ type: 'boolean', value: false });
+  });
+
+  it('parses cell references', () => {
+    expect(parse('A1')).toEqual({ type: 'cellref', ref: 'A1' });
+  });
+
+  it('parses addition', () => {
+    const ast = parse('A1+B1');
+    expect(ast).toEqual({
+      type: 'binary',
+      op: '+',
+      left: { type: 'cellref', ref: 'A1' },
+      right: { type: 'cellref', ref: 'B1' },
+    });
+  });
+
+  it('respects operator precedence', () => {
+    const ast = parse('A1+B1*2');
+    expect(ast.type).toBe('binary');
+    if (ast.type === 'binary') {
+      expect(ast.op).toBe('+');
+      expect(ast.right.type).toBe('binary');
+      if (ast.right.type === 'binary') {
+        expect(ast.right.op).toBe('*');
+      }
+    }
+  });
+
+  it('parses parentheses', () => {
+    const ast = parse('(A1+B1)*2');
+    expect(ast.type).toBe('binary');
+    if (ast.type === 'binary') {
+      expect(ast.op).toBe('*');
+      expect(ast.left.type).toBe('binary');
+    }
+  });
+
+  it('parses function calls', () => {
+    const ast = parse('SUM(A1:A3)');
+    expect(ast.type).toBe('function');
+    if (ast.type === 'function') {
+      expect(ast.name).toBe('SUM');
+      expect(ast.args).toHaveLength(1);
+      expect(ast.args[0].type).toBe('range');
+    }
+  });
+
+  it('parses IF with comparison', () => {
+    const ast = parse('IF(A1>30,"big","small")');
+    expect(ast.type).toBe('function');
+    if (ast.type === 'function') {
+      expect(ast.name).toBe('IF');
+      expect(ast.args).toHaveLength(3);
+    }
+  });
+
+  it('parses unary minus', () => {
+    const ast = parse('-A1');
+    expect(ast.type).toBe('unary');
+    if (ast.type === 'unary') {
+      expect(ast.op).toBe('-');
+    }
+  });
+
+  it('parses ranges', () => {
+    const ast = parse('A1:C3');
+    expect(ast).toEqual({ type: 'range', start: 'A1', end: 'C3' });
+  });
+});
