diff --git a/src/__tests__/index.test.ts b/src/__tests__/index.test.ts
new file mode 100644
index 0000000..be3cbd0
--- /dev/null
+++ b/src/__tests__/index.test.ts
@@ -0,0 +1,110 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace } from '../index.js';
+import type { Marketplace } from '../index.js';
+import type { PluginManifest } from '../types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '1 + 1',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('Marketplace Integration', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should expose all services', () => {
+    expect(marketplace.registry).toBeDefined();
+    expect(marketplace.resolver).toBeDefined();
+    expect(marketplace.runner).toBeDefined();
+    expect(marketplace.reviews).toBeDefined();
+    expect(marketplace.deps).toBeDefined();
+    expect(marketplace.installPlugin).toBeDefined();
+  });
+
+  describe('installPlugin', () => {
+    it('should install a simple plugin', async () => {
+      const manifest = makeManifest({ entryPoint: '2 + 2' });
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.resolvedDependencies).toEqual([]);
+      expect(result.executionResult.success).toBe(true);
+      expect(result.executionResult.output).toBe(4);
+    });
+
+    it('should register the plugin in the registry', async () => {
+      const manifest = makeManifest();
+      await marketplace.installPlugin(manifest);
+      const registered = marketplace.registry.get('test-plugin');
+      expect(registered).not.toBeNull();
+      expect(registered!.name).toBe('test-plugin');
+    });
+
+    it('should resolve dependencies', async () => {
+      // First register a dependency
+      marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.0.0' }));
+      marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.5.0' }));
+
+      const manifest = makeManifest({
+        name: 'my-plugin',
+        dependencies: { 'dep-a': '^1.0.0' },
+      });
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.resolvedDependencies).toHaveLength(1);
+      expect(result.resolvedDependencies[0].name).toBe('dep-a');
+      expect(result.resolvedDependencies[0].version).toBe('1.5.0');
+    });
+
+    it('should reject circular dependencies', async () => {
+      // Register a plugin that depends on our target
+      marketplace.registry.register(
+        makeManifest({ name: 'dep-b', dependencies: { 'circular-plugin': '^1.0.0' } })
+      );
+
+      const manifest = makeManifest({
+        name: 'circular-plugin',
+        dependencies: { 'dep-b': '^1.0.0' },
+      });
+
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('Circular dependency');
+    });
+
+    it('should reject manifest without name', async () => {
+      const manifest = makeManifest({ name: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('name');
+    });
+
+    it('should reject manifest without version', async () => {
+      const manifest = makeManifest({ version: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('version');
+    });
+
+    it('should reject manifest without entryPoint', async () => {
+      const manifest = makeManifest({ entryPoint: '' });
+      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('entryPoint');
+    });
+
+    it('should execute the entry point code', async () => {
+      const manifest = makeManifest({ entryPoint: '"hello world"' });
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.executionResult.success).toBe(true);
+      expect(result.executionResult.output).toBe('hello world');
+    });
+
+    it('should handle plugin execution errors gracefully', async () => {
+      const manifest = makeManifest({ entryPoint: 'throw new Error("boom")' });
+      const result = await marketplace.installPlugin(manifest);
+      expect(result.executionResult.success).toBe(false);
+      expect(result.executionResult.error).toContain('boom');
+    });
+  });
+});
diff --git a/src/deps/__tests__/deps.test.ts b/src/deps/__tests__/deps.test.ts
new file mode 100644
index 0000000..d6829fc
--- /dev/null
+++ b/src/deps/__tests__/deps.test.ts
@@ -0,0 +1,133 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { createDepsService } from '../index.js';
+import { createRegistry } from '../../registry/index.js';
+import type { DepsService, RegistryService, PluginManifest } from '../../types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'root',
+    version: '1.0.0',
+    description: '',
+    author: '',
+    dependencies: {},
+    entryPoint: '',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('Dependency Graph', () => {
+  let deps: DepsService;
+  let registry: RegistryService;
+
+  beforeEach(() => {
+    deps = createDepsService();
+    registry = createRegistry();
+  });
+
+  describe('buildTree', () => {
+    it('should build a tree for a plugin with no dependencies', () => {
+      registry.register(makeManifest({ name: 'a' }));
+      const tree = deps.buildTree('a', registry);
+      expect(tree.name).toBe('a');
+      expect(tree.version).toBe('1.0.0');
+      expect(tree.dependencies).toEqual([]);
+    });
+
+    it('should build a tree with nested dependencies', () => {
+      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+      registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));
+      registry.register(makeManifest({ name: 'c' }));
+      const tree = deps.buildTree('a', registry);
+      expect(tree.name).toBe('a');
+      expect(tree.dependencies).toHaveLength(1);
+      expect(tree.dependencies[0].name).toBe('b');
+      expect(tree.dependencies[0].dependencies).toHaveLength(1);
+      expect(tree.dependencies[0].dependencies[0].name).toBe('c');
+    });
+
+    it('should throw for non-existent plugin', () => {
+      expect(() => deps.buildTree('nonexistent', registry)).toThrow();
+    });
+  });
+
+  describe('detectCycles', () => {
+    it('should return null for no cycles', () => {
+      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+      registry.register(makeManifest({ name: 'b' }));
+      expect(deps.detectCycles('a', registry)).toBeNull();
+    });
+
+    it('should detect a direct cycle', () => {
+      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+      registry.register(makeManifest({ name: 'b', dependencies: { a: '^1.0.0' } }));
+      const cycles = deps.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+      expect(cycles!.length).toBeGreaterThan(0);
+    });
+
+    it('should detect an indirect cycle', () => {
+      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+      registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));
+      registry.register(makeManifest({ name: 'c', dependencies: { a: '^1.0.0' } }));
+      const cycles = deps.detectCycles('a', registry);
+      expect(cycles).not.toBeNull();
+    });
+  });
+
+  describe('topologicalSort', () => {
+    it('should return single plugin for no deps', () => {
+      registry.register(makeManifest({ name: 'a' }));
+      expect(deps.topologicalSort('a', registry)).toEqual(['a']);
+    });
+
+    it('should return dependencies before dependents', () => {
+      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));
+      registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));
+      registry.register(makeManifest({ name: 'c' }));
+      const sorted = deps.topologicalSort('a', registry);
+      expect(sorted.indexOf('c')).toBeLessThan(sorted.indexOf('b'));
+      expect(sorted.indexOf('b')).toBeLessThan(sorted.indexOf('a'));
+    });
+  });
+
+  describe('flattenDependencies', () => {
+    it('should return empty for no dependencies', () => {
+      registry.register(makeManifest({ name: 'a' }));
+      expect(deps.flattenDependencies('a', registry)).toEqual([]);
+    });
+
+    it('should return all transitive dependencies', () => {
