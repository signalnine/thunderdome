: 'u2', rating: 3, comment: '' });\n      reviews.flagReview(r1.id);\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n    });\n  });\n\n  describe('removeReview', () => {\n    it('should remove a review', () => {\n      const r = reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      expect(reviews.removeReview(r.id)).toBe(true);\n      expect(reviews.getReviews('p')).toHaveLength(0);\n    });\n\n    it('should return false for non-existent review', () => {\n      expect(reviews.removeReview(999)).toBe(false);\n    });\n  });\n\n  describe('getReviewsByUser', () => {\n    it('should return reviews by a specific user', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: '' });\n      reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'user1', rating: 3, comment: '' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user2', rating: 4, comment: '' });\n      const result = reviews.getReviewsByUser('user1');\n      expect(result).toHaveLength(2);\n    });\n  });\n\n  describe('getReviewCount', () => {\n    it('should return the number of reviews for a plugin', () => {\n      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n      reviews.addReview({ pluginName: 'p', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n      expect(reviews.getReviewCount('p')).toBe(2);\n    });\n\n    it('should return 0 for unknown plugin', () => {\n      expect(reviews.getReviewCount('nonexistent')).toBe(0);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":169,"cache_read_input_tokens":30938,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":169},"output_tokens":25,"service_tier":"standard",