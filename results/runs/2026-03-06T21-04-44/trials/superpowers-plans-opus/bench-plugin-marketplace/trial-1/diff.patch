thor.toLowerCase().includes(q)\n          ) {\n            result.push({ ...m });\n          }\n        }\n      }\n      return result;\n    },\n\n    remove(name: string, version: string): boolean {\n      const versions = plugins.get(name);\n      if (!versions) return false;\n      const deleted = versions.delete(version);\n      if (versions.size === 0) {\n        plugins.delete(name);\n      }\n      return deleted;\n    },\n\n    listVersions(name: string): string[] {\n      const versions = plugins.get(name);\n      if (!versions) return [];\n      return Array.from(versions.keys());\n    },\n\n    update(name: string, version: string, updates: Partial<PluginManifest>): void {\n      const versions = plugins.get(name);\n      if (!versions) throw new Error(`Plugin ${name} not found`);\n      const existing = versions.get(version);\n      if (!existing) throw new Error(`Plugin ${name}@${version} not found`);\n      versions.set(version, { ...existing, ...updates });\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":364,"cache_read_input_tokens":23610,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":364},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"33971a8e-8043-4682-a867-fc94570142c7","uuid":"bb499982-e9c6-411a-aef0-a701c51f90d3"}
