place.installPlugin(manifest);\n      expect(result.executionResult.success).toBe(true);\n      expect(result.executionResult.output).toBe('hello world');\n    });\n\n    it('should handle plugin execution errors gracefully', async () => {\n      const manifest = makeManifest({ entryPoint: 'throw new Error(\"boom\")' });\n      const result = await marketplace.installPlugin(manifest);\n      expect(result.executionResult.success).toBe(false);\n      expect(result.executionResult.error).toBe('boom');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":169,"cache_read_input_tokens":30938,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":169},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"33971a8e-8043-4682-a867-fc94570142c7","uuid":"35243b65-389c-433a-aabb-d2f2635c1410"}
