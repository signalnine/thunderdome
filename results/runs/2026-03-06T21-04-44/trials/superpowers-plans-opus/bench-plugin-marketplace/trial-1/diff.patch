+import { describe, it, expect, beforeEach } from 'vitest';
+import { createRunner } from '../index.js';
+import type { RunnerService } from '../../types.js';
+
+describe('Sandboxed Runner', () => {
+  let runner: RunnerService;
+
+  beforeEach(() => {
+    runner = createRunner();
+  });
+
+  describe('execute', () => {
+    it('should execute simple code and return result', async () => {
+      const result = await runner.execute('1 + 1');
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(2);
+      expect(result.duration).toBeGreaterThanOrEqual(0);
+      expect(result.memoryUsed).toBeGreaterThanOrEqual(0);
+    });
+
+    it('should execute code with context variables', async () => {
+      const result = await runner.execute('x + y', { x: 10, y: 20 });
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(30);
+    });
+
+    it('should return error for failing code', async () => {
+      const result = await runner.execute('throw new Error("fail")');
+      expect(result.success).toBe(false);
+      expect(result.error).toContain('fail');
+      expect(result.output).toBeNull();
+    });
+
+    it('should return error for syntax errors', async () => {
+      const result = await runner.execute('invalid code !!!');
+      expect(result.success).toBe(false);
+      expect(result.error).toBeDefined();
+    });
+
+    it('should handle undefined return', async () => {
+      const result = await runner.execute('var x = 1;');
+      expect(result.success).toBe(true);
+    });
+
+    it('should have structured result fields', async () => {
+      const result = await runner.execute('"hello"');
+      expect(result).toHaveProperty('success');
+      expect(result).toHaveProperty('output');
+      expect(result).toHaveProperty('duration');
+      expect(result).toHaveProperty('memoryUsed');
+    });
+  });
+
+  describe('executeWithTimeout', () => {
+    it('should execute within timeout', async () => {
+      const result = await runner.executeWithTimeout('1 + 1', 1000);
+      expect(result.success).toBe(true);
+      expect(result.output).toBe(2);
+    });
+
+    it('should timeout on infinite loop', async () => {
+      const result = await runner.executeWithTimeout('while(true) {}', 100);
+      expect(result.success).toBe(false);
+      expect(result.error).toBeDefined();
+    });
+
+    it('should pass context variables', async () => {
+      const result = await runner.executeWithTimeout('name', 1000, { name: 'test' });
+      expect(result.success).toBe(true);
+      expect(result.output).toBe('test');
+    });
+  });
+});
