egister the plugin in the registry', async () => {\n      const manifest = makeManifest();\n      await marketplace.installPlugin(manifest);\n      const registered = marketplace.registry.get('test-plugin');\n      expect(registered).not.toBeNull();\n      expect(registered!.name).toBe('test-plugin');\n    });\n\n    it('should resolve dependencies', async () => {\n      // First register a dependency\n      marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.0.0' }));\n      marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.5.0' }));\n\n      const manifest = makeManifest({\n        name: 'my-plugin',\n        dependencies: { 'dep-a': '^1.0.0' },\n      });\n      const result = await marketplace.installPlugin(manifest);\n      expect(result.resolvedDependencies).toHaveLength(1);\n      expect(result.resolvedDependencies[0].name).toBe('dep-a');\n      expect(result.resolvedDependencies[0].version).toBe('1.5.0');\n    });\n\n    it('should reject circular dependencies', async () => {\n      // Register a plugin that depends on our target\n      marketplace.registry.register(\n        makeManifest({ name: 'dep-b', dependencies: { 'circular-plugin': '^1.0.0' } })\n      );\n\n      const manifest = makeManifest({\n        name: 'circular-plugin',\n        dependencies: { 'dep-b': '^1.0.0' },\n      });\n\n      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('Circular dependency');\n    });\n\n    it('should reject manifest without name', async () => {\n      const manifest = makeManifest({ name: '' });\n      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('name');\n    });\n\n    it('should reject manifest without version', async () => {\n      const manifest = makeManifest({ version: '' });\n      await expect(marketplace.installPlugin(manifest)).rejects.toThrow('version');\n    });\n\n    it('should reject manifest without entryPoint', async () => {\n      const manifest = makeManifest({