(tree.dependencies[0].dependencies).toHaveLength(1);\n      expect(tree.dependencies[0].dependencies[0].name).toBe('c');\n    });\n\n    it('should throw for non-existent plugin', () => {\n      expect(() => deps.buildTree('nonexistent', registry)).toThrow();\n    });\n  });\n\n  describe('detectCycles', () => {\n    it('should return null for no cycles', () => {\n      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'b' }));\n      expect(deps.detectCycles('a', registry)).toBeNull();\n    });\n\n    it('should detect a direct cycle', () => {\n      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'b', dependencies: { a: '^1.0.0' } }));\n      const cycles = deps.detectCycles('a', registry);\n      expect(cycles).not.toBeNull();\n      expect(cycles!.length).toBeGreaterThan(0);\n    });\n\n    it('should detect an indirect cycle', () => {\n      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'c', dependencies: { a: '^1.0.0' } }));\n      const cycles = deps.detectCycles('a', registry);\n      expect(cycles).not.toBeNull();\n    });\n  });\n\n  describe('topologicalSort', () => {\n    it('should return single plugin for no deps', () => {\n      registry.register(makeManifest({ name: 'a' }));\n      expect(deps.topologicalSort('a', registry)).toEqual(['a']);\n    });\n\n    it('should return dependencies before dependents', () => {\n      registry.register(makeManifest({ name: 'a', dependencies: { b: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'b', dependencies: { c: '^1.0.0' } }));\n      registry.register(makeManifest({ name: 'c' }));\n      const sorted = deps.topologicalSort('a', registry);\n      expect(sorted.indexOf('c')).toBeLessTh