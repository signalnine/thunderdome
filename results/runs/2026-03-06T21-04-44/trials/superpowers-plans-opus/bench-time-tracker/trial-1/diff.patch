expect(filtered[0].task).toBe(\"task2\");\n    });\n\n    it(\"should filter entries with 'to' date\", () => {\n      const { writeFileSync } = require(\"node:fs\");\n      const entries = [\n        { task: \"task1\", start: \"2024-01-01T10:00:00.000Z\", stop: \"2024-01-01T11:00:00.000Z\" },\n        { task: \"task2\", start: \"2024-06-01T10:00:00.000Z\", stop: \"2024-06-01T11:00:00.000Z\" },\n      ];\n      writeFileSync(filePath, JSON.stringify(entries));\n\n      const tracker = new TimeTracker(filePath);\n      const to = new Date(\"2024-03-01T00:00:00.000Z\");\n      const filtered = tracker.getEntries(undefined, to);\n      expect(filtered).toHaveLength(1);\n      expect(filtered[0].task).toBe(\"task1\");\n    });","originalFile":"import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\nimport { TimeTracker } from \"./tracker.js\";\nimport { unlinkSync, existsSync, readFileSync, mkdirSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { tmpdir } from \"node:os\";\n\nfunction tempFile(): string {\n  return join(\n    tmpdir(),\n    `time-tracker-test-${Date.now()}-${Math.random().toString(36).slice(2)}.json`\n  );\n}\n\nfunction cleanUp(path: string) {\n  try {\n    if (existsSync(path)) unlinkSync(path);\n  } catch {\n    // ignore\n  }\n}\n\ndescribe(\"TimeTracker\", () => {\n  let filePath: string;\n\n  beforeEach(() => {\n    filePath = tempFile();\n  });\n\n  afterEach(() => {\n    cleanUp(filePath);\n  });\n\n  describe(\"start\", () => {\n    it(\"should start a timer and persist it\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe(\"coding\");\n      expect(entries[0].start).toBeTruthy();\n      expect(entries[0].stop).toBeNull();\n\n      // Verify persistence\n      const raw = JSON.parse(readFileSync(filePath, \"utf-8\"));\n      expect(raw).toHaveLength(1);\n      expect(raw[0].task).toBe(\"coding\");\n    });\n\n    it(\"should throw if task name is empty\", () => {\n      const tracker = new TimeTracker(filePath);\n      expect(() => tracker.start(\"\")).toThrow(\"Task name cannot be empty\");\n    });\n\n    it(\"should throw if task name is only whitespace\", () => {\n      const tracker = new TimeTracker(filePath);\n      expect(() => tracker.start(\"   \")).toThrow(\"Task name cannot be empty\");\n    });\n\n    it(\"should auto-stop the previous timer when starting a new one\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"task1\");\n      tracker.start(\"task2\");\n\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(2);\n      expect(entries[0].task).toBe(\"task1\");\n      expect(entries[0].stop).not.toBeNull();\n      expect(entries[1].task).toBe(\"task2\");\n      expect(entries[1].stop).toBeNull();\n    });\n  });\n\n  describe(\"stop\", () => {\n    it(\"should stop the running timer and return the entry\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      const stopped = tracker.stop();\n\n      expect(stopped.task).toBe(\"coding\");\n      expect(stopped.stop).not.toBeNull();\n    });\n\n    it(\"should throw if no timer is running\", () => {\n      const tracker = new TimeTracker(filePath);\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n\n    it(\"should throw if timer was already stopped\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      tracker.stop();\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n  });\n\n  describe(\"persistence\", () => {\n    it(\"should load entries from an existing file\", () => {\n      const tracker1 = new TimeTracker(filePath);\n      tracker1.start(\"task1\");\n      tracker1.stop();\n\n      // Create a new tracker instance pointing to the same file\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe(\"task1\");\n    });\n\n    it(\"should create parent directories automatically\", () => {\n      const nestedPath = join(\n        tmpdir(),\n        `time-tracker-test-${Date.now()}`,\n        \"nested\",\n        \"dir\",\n        \"data.json\"\n      );\n      const tracker = new TimeTracker(nestedPath);\n      tracker.start(\"test\");\n      tracker.stop();\n\n      expect(existsSync(nestedPath)).toBe(true);\n\n      // Clean up\n      const { rmSync } = require(\"node:fs\");\n      rmSync(join(tmpdir(), `time-tracker-test-${nestedPath.split(\"time-tracker-test-\")[1].split(\"/\")[0]}`), {\n        recursive: true,\n        force: true,\n      });\n    });\n\n    it(\"should handle non-existent file gracefully\", () => {\n      const tracker = new TimeTracker(\"/tmp/nonexistent-path-abc123.json\");\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(0);\n    });\n  });\n\n  describe(\"getEntries\", () => {\n    it(\"should return all entries when no filter is specified\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"task1\");\n      tracker.stop();\n      tracker.start(\"task2\");\n      tracker.stop();\n\n      expect(tracker.getEntries()).toHaveLength(2);\n    });\n\n    it(\"should filter entries by date range\", () => {\n      const tracker = new TimeTracker(filePath);\n\n      tracker.start(\"task1\");\n      tracker.stop();\n\n      const after = new Date();\n\n      // Small delay to ensure timestamps differ\n      tracker.start(\"task2\");\n      tracker.stop();\n\n      const filtered = tracker.getEntries(after);\n      expect(filtered.length).toBeGreaterThanOrEqual(1);\n      expect(filtered.every((e) => e.task === \"task2\")).toBe(true);\n    });\n\n    it(\"should filter entries with 'to' date\", () => {\n      const tracker = new TimeTracker(filePath);\n\n      tracker.start(\"task1\");\n      tracker.stop();\n\n      const before = new Date();\n\n      tracker.start(\"task2\");\n      tracker.stop();\n\n      const filtered = tracker.getEntries(undefined, before);\n      expect(filtered.every((e) => e.task === \"task1\")).toBe(true);\n    });\n  });\n\n  describe(\"getSummary\", () => {\n    it(\"should sum time per task name in milliseconds\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"coding\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThanOrEqual(0);\n      expect(typeof summary[\"coding\"]).toBe(\"number\");\n    });\n\n    it(\"should include running tasks using current time\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      // Don't stop - it's still running\n\n      const summary = tracker.getSummary();\n      expect(summary[\"coding\"]).toBeGreaterThanOrEqual(0);\n      expect(typeof summary[\"coding\"]).toBe(\"number\");\n    });\n\n    it(\"should separate different task names\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"coding\");\n      tracker.stop();\n      tracker.start(\"meeting\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(\"coding\" in summary).toBe(true);\n      expect(\"meeting\" in summary).toBe(true);\n    });\n  });\n\n  describe(\"unicode support\", () => {\n    it(\"should handle unicode task names\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"日本語タスク\");\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe(\"日本語タスク\");\n    });\n\n    it(\"should handle emoji task names\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"🚀 Launch Prep\");\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      expect(entries[0].task).toBe(\"🚀 Launch Prep\");\n    });\n\n    it(\"should persist and reload unicode names correctly\", () => {\n      const tracker1 = new TimeTracker(filePath);\n      tracker1.start(\"café ☕ работа\");\n      tracker1.stop();\n\n      const tracker2 = new TimeTracker(filePath);\n      const entries = tracker2.getEntries();\n      expect(entries[0].task).toBe(\"café ☕ работа\");\n    });\n\n    it(\"should summarize unicode task names correctly\", () => {\n      const tracker = new TimeTracker(filePath);\n      tracker.start(\"🎯 Focus\");\n      tracker.stop();\n      tracker.start(\"🎯 Focus\");\n      tracker.stop();\n\n      const summary = tracker.getSummary();\n      expect(\"🎯 Focus\" in summary).toBe(true);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":148,"oldLines":35,"newStart":148,"newLines":34,"lines":["     });"," ","     it(\"should filter entries by date range\", () => {","-      const tracker = new TimeTracker(filePath);","+      // Write entries with known timestamps directly","+      const { writeFileSync } = require(\"node:fs\");","+      const entries = [","+        { task: \"task1\", start: \"2024-01-01T10:00:00.000Z\", stop: \"2024-01-01T11:00:00.000Z\" },","+        { task: \"task2\", start: \"2024-06-01T10:00:00.000Z\", stop: \"2024-06-01T11:00:00.000Z\" },","+      ];","+      writeFileSync(filePath, JSON.stringify(entries));"," ","-      tracker.start(\"task1\");","-      tracker.stop();","-","-      const after = new Date();","-","-      // Small delay to ensure timestamps differ","-      tracker.start(\"task2\");","-      tracker.stop();","-","-      const filtered = tracker.getEntries(after);","-      expect(filtered.length).toBeGreaterThanOrEqual(1);","-      expect(filtered.every((e) => e.task === \"task2\")).toBe(true);","+      const tracker = new TimeTracker(filePath);","+      const from =