;\n      if (to && start > to) return false;\n      return true;\n    });\n  }\n\n  getSummary(from?: Date, to?: Date): TimeSummary {\n    const entries = this.getEntries(from, to);\n    const summary: TimeSummary = {};\n    const now = new Date();\n    for (const entry of entries) {\n      const start = new Date(entry.start).getTime();\n      const stop = entry.stop ? new Date(entry.stop).getTime() : now.getTime();\n      const duration = stop - start;\n      summary[entry.task] = (summary[entry.task] || 0) + duration;\n    }\n    return summary;\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":283,"cache_read_input_tokens":23723,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":283},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e3cd2cba-be6d-482e-91e8-792e7566c825","uuid":"29af2bab-a3c5-4586-bfe6-202a8e3fafad"}
