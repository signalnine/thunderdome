+# CLI Time Tracker Implementation Plan
+
+> **For Claude:** REQUIRED SUB-SKILL: Use superpowers:executing-plans to implement this plan task-by-task.
+
+**Goal:** Build a TypeScript time tracking library that supports starting/stopping timers, JSON persistence, date-range queries, and per-task summaries.
+
+**Architecture:** Single `TimeTracker` class backed by a JSON file. Entries are stored as an array of `TimeEntry` objects. The class handles auto-stopping running timers, persistence via `fs`, and querying/summarizing. All public API exported from `src/index.ts`.
+
+**Tech Stack:** TypeScript (strict, ES2022, Node16 modules), Node.js built-in `fs` and `path` modules only, Vitest for testing.
+
+---
+
+### Task 0: Install dependencies
+
+**Step 1: Run npm install**
+
+Run: `npm install`
+
+---
+
+### Task 1: Define types and TimeEntry interface
+
+**Files:**
+- Create: `src/types.ts`
+
+**Step 1: Write the types file**
+
+```typescript
+export interface TimeEntry {
+  task: string;
+  start: string; // ISO 8601
+  stop: string | null; // ISO 8601 or null if running
+}
+
+export interface TimeSummary {
+  [task: string]: number; // milliseconds
+}
+```
+
+**Step 2: Verify build**
+
+Run: `npx tsc --noEmit`
+Expected: PASS (no errors)
+
+---
+
+### Task 2: Implement TimeTracker class core (start/stop/persistence)
+
+**Files:**
+- Create: `src/tracker.ts`
+
+**Step 1: Write the TimeTracker class**
+
+```typescript
+import { readFileSync, writeFileSync, mkdirSync, existsSync } from "node:fs";
+import { dirname } from "node:path";
+import type { TimeEntry, TimeSummary } from "./types.js";
+
+export class TimeTracker {
+  private filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.entries = this.load();
+  }
+
+  private load(): TimeEntry[] {
+    try {
+      const data = readFileSync(this.filePath, "utf-8");
+      return JSON.parse(data) as TimeEntry[];
+    } catch {
+      return [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    if (!existsSync(dir)) {
+      mkdirSync(dir, { recursive: true });
+    }
+    writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+    // Auto-stop any running timer
+    const running = this.entries.find((e) => e.stop === null);
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+    this.entries.push({
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    });
+    this.save();
+  }
+
+  stop(): TimeEntry {
+    const running = this.entries.find((e) => e.stop === null);
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+    running.stop = new Date().toISOString();
+    this.save();
+    return { ...running };
+  }
+
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    return this.entries.filter((entry) => {
+      const start = new Date(entry.start);
+      if (from && start < from) return false;
+      if (to && start > to) return false;
+      return true;
+    });
+  }
+
+  getSummary(from?: Date, to?: Date): TimeSummary {
+    const entries = this.getEntries(from, to);
+    const summary: TimeSummary = {};
+    const now = new Date();
+    for (const entry of entries) {
+      const start = new Date(entry.start).getTime();
+      const stop = entry.stop ? new Date(entry.stop).getTime() : now.getTime();
+      const duration = stop - start;
+      summary[entry.task] = (summary[entry.task] || 0) + duration;
+    }
+    return summary;
+  }
+}
+```
