+# Permission Maze - Document Management API Implementation Plan
+
+> **For Claude:** REQUIRED SUB-SKILL: Use superpowers:executing-plans to implement this plan task-by-task.
+
+**Goal:** Build a document management API with users, hierarchical folders, documents, granular sharing permissions, and activity logging — all in-memory.
+
+**Architecture:** Express.js REST API with in-memory Maps for storage. Middleware handles auth via Bearer tokens. A central permissions module resolves effective permissions by merging direct shares with inherited folder shares. Activity log is an append-only array.
+
+**Tech Stack:** TypeScript, Express 4, Vitest + Supertest for testing, ESM modules (Node16 module resolution).
+
+---
+
+### Task 1: Types & In-Memory Store
+
+**Files:**
+- Create: `src/types.ts`
+- Create: `src/store.ts`
+
+**Step 1: Create type definitions**
+
+```typescript
+// src/types.ts
+export interface User {
+  id: string;
+  username: string;
+  password: string;
+  token: string | null;
+}
+
+export type Role = 'viewer' | 'editor' | 'owner';
+
+export interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+  createdAt: string;
+}
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+  createdAt: string;
+  updatedAt: string;
+}
+
+export interface Share {
+  id: string;
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+  userId: string;
+  role: Role;
+}
+
+export interface ActivityEntry {
+  id: string;
+  action: string;
+  userId: string;
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+  timestamp: string;
+  details?: string;
+}
+```
+
+**Step 2: Create in-memory store**
+
+```typescript
+// src/store.ts
+import { User, Folder, Document, Share, ActivityEntry } from './types.js';
+
+export function createStore() {
+  return {
+    users: new Map<string, User>(),
+    folders: new Map<string, Folder>(),
+    documents: new Map<string, Document>(),
+    shares: [] as Share[],
+    activity: [] as ActivityEntry[],
+  };
+}
+
+export type Store = ReturnType<typeof createStore>;
+```
+
+---
+
+### Task 2: Auth Middleware & User Routes
+
+**Files:**
+- Create: `src/auth.ts`
+- Create: `src/routes/users.ts`
+
+**Step 1: Create auth middleware**
+
+```typescript
+// src/auth.ts
+import { Request, Response, NextFunction } from 'express';
+import { Store } from './store.js';
+
+export function authMiddleware(store: Store) {
+  return (req: Request, res: Response, next: NextFunction): void => {
+    const header = req.headers.authorization;
+    if (!header || !header.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    const token = header.slice(7);
+    let foundUser = null;
+    for (const user of store.users.values()) {
+      if (user.token === token) {
+        foundUser = user;
+        break;
+      }
+    }
+    if (!foundUser) {
+      res.status(401).json({ error: 'Unauthorized' });
+      return;
+    }
+    (req as any).userId = foundUser.id;
+    next();
+  };
+}
+```
+
+**Step 2: Create user/auth routes**
+
+```typescript
+// src/routes/users.ts
+import { Router } from 'express';
+import crypto from 'crypto';
+import { Store } from '../store.js';
+
+export function userRoutes(store: Store): Router {
+  const router = Router();
+
+  router.post('/auth/register', (req, res) => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password required' });
+      return;
+    }
+    for (const u of store.users.values()) {
+      if (u.username === username) {
+        res.status(409).json({ error: 'Username already exists' });
+        return;
+      }
+    }
+    const id = crypto.randomUUID();
+    const user = { id, username, password, token: null };
+    store.users.set(id, user);
+    res.status(201).json({ id, username });
+  });
+
+  router.post('/auth/login', (req, res) => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password required' });
+      return;
+    }
+    let found = null;
+    for (const u of store.users.values()) {
+      if (u.username === username && u.password === password) {
+        found = u;
+        break;
+      }
+    }
+    if (!found) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+    const token = crypto.randomUUID();
+    found.token = token;
+    res.json({ token, userId: found.id });
+  });
+
+  return router;
+}
+```
+
+---
+
+### Task 3: Permissions Helper
+
+**Files:**
+- Create: `src/permissions.ts`
+
+Resolves effective permission for a user on a resource. Checks direct shares, ownership, and inherited folder permissions (walk up parent chain).
+
+```typescript
+// src/permissions.ts
+import { Store } from './store.js';
+import { Role } from './types.js';
+
+const ROLE_LEVEL: Record<Role, number> = { viewer: 1, editor: 2, owner: 3 };
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string
+): Role | null {
+  let best: Role | null = null;
+
+  // Check ownership
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc && doc.ownerId === userId) return 'owner';
+  } else {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.ownerId === userId) return 'owner';
+  }
+
+  // Direct shares on this resource
+  for (const s of store.shares) {
+    if (s.resourceType === resourceType && s.resourceId === resourceId && s.userId === userId) {
+      if (!best || ROLE_LEVEL[s.role] > ROLE_LEVEL[best]) {
+        best = s.role;
+      }
+    }
+  }
+
+  // If document, also check folder shares (walk up folder hierarchy)
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getFolderRole(store, userId, doc.folderId);
+      if (folderRole && (!best || ROLE_LEVEL[folderRole] > ROLE_LEVEL[best])) {
+        best = folderRole;
+      }
+    }
+  }
+
+  // If folder, check parent folders
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getFolderRole(store, userId, folder.parentId);
+      if (parentRole && (!best || ROLE_LEVEL[parentRole] > ROLE_LEVEL[best])) {
+        best = parentRole;
+      }
+    }
+  }
+
+  return best;
+}
+
+function getFolderRole(store: Store, userId: string, folderId: string): Role | null {
+  let best: Role | null = null;
+  let currentId: string | null = folderId;
+
+  while (currentId) {
+    const folder = store.folders.get(currentId);
+    if (!folder) break;
+
+    if (folder.ownerId === userId) return 'owner';
+
+    for (const s of store.shares) {
+      if (s.resourceType === 'folder' && s.resourceId === currentId && s.userId === userId) {
+        if (!best || ROLE_LEVEL[s.role] > ROLE_LEVEL[best]) {
+          best = s.role;
+        }
+      }
+    }
+
+    currentId = folder.parentId;
+  }
+
+  return best;
+}
+```
+
+---
+
+### Task 4: Folder Routes
+
+**Files:**
+- Create: `src/routes/folders.ts`
+
+CRUD for folders with permission checks.
+
+---
+
+### Task 5: Document Routes
+
+**Files:**
+- Create: `src/routes/documents.ts`
+
+CRUD for documents with permission checks plus activity logging.
+
+---
+
+### Task 6: Sharing Routes
+
+**Files:**
+- Create: `src/routes/sharing.ts`
+
+Share resources with other users, requires editor or owner role.
+
+---
+
+### Task 7: Activity Log Route
+
+**Files:**
+- Create: `src/routes/activity.ts`
+
+Return activity entries filtered to resources the requesting user can access.
+
+---
+
+### Task 8: App Entry Point
+
+**Files:**
+- Create: `src/app.ts`
+
+Wire up Express app with all routes, export `createApp()`.
+
+---
+
+### Task 9: Tests
+
+**Files:**
+- Create: `src/__tests__/app.test.ts`
+
+Comprehensive test suite covering all features using supertest.
+
+---
+
+### Task 10: Build, Lint, Test
+
+Run `npm run build`, `npm run lint`, `npm test` and fix any issues.
