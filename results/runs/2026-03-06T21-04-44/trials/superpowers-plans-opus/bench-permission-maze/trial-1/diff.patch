@@ -0,0 +1,157 @@
+import { Router } from 'express';
+import crypto from 'crypto';
+import { Store } from '../store.js';
+import { requireRole } from '../permissions.js';
+
+export function folderRoutes(store: Store): Router {
+  const router = Router();
+
+  // Create folder
+  router.post('/', (req, res) => {
+    const userId = req.userId!;
+    const { name, parentId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: 'Name is required' });
+      return;
+    }
+
+    if (parentId) {
+      const parent = store.folders.get(parentId);
+      if (!parent) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      // Need at least editor on parent to create subfolder
+      if (!requireRole(store, userId, 'folder', parentId, 'editor')) {
+        res.status(403).json({ error: 'Forbidden' });
+        return;
+      }
+    }
+
+    const id = crypto.randomUUID();
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', (req, res) => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!requireRole(store, userId, 'folder', folder.id, 'viewer')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    // Include children folders and documents
+    const children = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folder.id) {
+        children.push(f);
+      }
+    }
+    const documents = [];
+    for (const d of store.documents.values()) {
+      if (d.folderId === folder.id) {
+        documents.push(d);
+      }
+    }
+
+    res.json({ ...folder, children, documents });
+  });
+
+  // Update folder
+  router.put('/:id', (req, res) => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!requireRole(store, userId, 'folder', folder.id, 'editor')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    if (req.body.name !== undefined) {
+      folder.name = req.body.name;
+    }
+    if (req.body.parentId !== undefined) {
+      folder.parentId = req.body.parentId;
+    }
+
+    res.json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', (req, res) => {
+    const userId = req.userId!;
+    const folder = store.folders.get(req.params.id);
+
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!requireRole(store, userId, 'folder', folder.id, 'owner')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    // Delete all documents in folder
+    for (const [docId, doc] of store.documents) {
+      if (doc.folderId === folder.id) {
+        store.documents.delete(docId);
+      }
+    }
+
+    // Delete child folders recursively
+    deleteChildFolders(store, folder.id);
+
+    // Remove shares for this folder
+    store.shares = store.shares.filter(
+      s => !(s.resourceType === 'folder' && s.resourceId === folder.id)
+    );
+
+    store.folders.delete(folder.id);
+    res.status(204).send();
+  });
+
+  return router;
+}
+
+function deleteChildFolders(store: Store, parentId: string): void {
+  for (const [folderId, folder] of store.folders) {
+    if (folder.parentId === parentId) {
+      // Delete documents in child folder
+      for (const [docId, doc] of store.documents) {
+        if (doc.folderId === folderId) {
+          store.documents.delete(docId);
+        }
+      }
+      // Recursively delete children
+      deleteChildFolders(store, folderId);
+      // Remove shares
+      store.shares = store.shares.filter(
+        s => !(s.resourceType === 'folder' && s.resourceId === folderId)
+      );
+      store.folders.delete(folderId);
+    }
+  }
+}
diff --git a/src/routes/sharing.ts b/src/routes/sharing.ts
new file mode 100644
index 0000000..e0047bf
--- /dev/null
+++ b/src/routes/sharing.ts
@@ -0,0 +1,153 @@
+import { Router } from 'express';
+import crypto from 'crypto';
+import { Store } from '../store.js';
+import { Role } from '../types.js';
+import { requireRole } from '../permissions.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function sharingRoutes(store: Store): Router {
+  const router = Router();
+
+  // Share a resource
+  router.post('/', (req, res) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId, targetUserId, role } = req.body;
+
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, targetUserId, and role are required' });
+      return;
+    }
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be folder or document' });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'role must be viewer, editor, or owner' });
+      return;
+    }
+
+    // Verify resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Verify target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Sharing requires editor or owner role
+    if (!requireRole(store, userId, resourceType, resourceId, 'editor')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    // Only owners can grant owner role
+    if (role === 'owner' && !requireRole(store, userId, resourceType, resourceId, 'owner')) {
+      res.status(403).json({ error: 'Only owners can grant owner role' });
+      return;
+    }
+
+    // Check if share already exists, update role if so
+    const existing = store.shares.find(
+      s => s.resourceType === resourceType && s.resourceId === resourceId && s.userId === targetUserId
+    );
+
+    if (existing) {
+      existing.role = role;
+      const now = new Date().toISOString();
+      store.activity.push({
+        id: crypto.randomUUID(),
+        action: 'share_updated',
+        userId,
+        resourceType,
+        resourceId,
+        timestamp: now,
+        details: `Shared with user ${targetUserId} as ${role}`,
+      });
+      res.json(existing);
+      return;
+    }
+
+    const share = {
+      id: crypto.randomUUID(),
+      resourceType: resourceType as 'folder' | 'document',
+      resourceId,
+      userId: targetUserId,
+      role: role as Role,
+    };
+    store.shares.push(share);
+
+    const now = new Date().toISOString();
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'share_created',
+      userId,
+      resourceType,
+      resourceId,
+      timestamp: now,
+      details: `Shared with user ${targetUserId} as ${role}`,
+    });
+
+    res.status(201).json(share);
+  });
+
+  // Get shares for a resource
+  router.get('/:resourceType/:resourceId', (req, res) => {
+    const userId = req.userId!;
+    const { resourceType, resourceId } = req.params;
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be folder or document' });
+      return;
+    }
+
+    if (!requireRole(store, userId, resourceType, resourceId, 'viewer')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    const shares = store.shares.filter(
+      s => s.resourceType === resourceType && s.resourceId === resourceId
+    );
+
+    res.json(shares);
+  });
+
+  // Remove a share
+  router.delete('/:shareId', (req, res) => {
+    const userId = req.userId!;
+    const { shareId } = req.params;
+
+    const shareIndex = store.shares.findIndex(s => s.id === shareId);
+    if (shareIndex === -1) {
+      res.status(404).json({ error: 'Share not found' });
+      return;
+    }
+
+    const share = store.shares[shareIndex];
+
+    // Need owner role to remove shares
+    if (!requireRole(store, userId, share.resourceType, share.resourceId, 'owner')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    store.shares.splice(shareIndex, 1);
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/routes/users.ts b/src/routes/users.ts
