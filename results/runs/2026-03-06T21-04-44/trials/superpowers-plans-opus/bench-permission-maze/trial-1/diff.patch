+  app.use(userRoutes(store));
+
+  // Protected routes
+  const auth = authMiddleware(store);
+  app.use('/folders', auth, folderRoutes(store));
+  app.use('/documents', auth, documentRoutes(store));
+  app.use('/share', auth, sharingRoutes(store));
+  app.use('/activity', auth, activityRoutes(store));
+
+  return app;
+}
diff --git a/src/auth.ts b/src/auth.ts
new file mode 100644
