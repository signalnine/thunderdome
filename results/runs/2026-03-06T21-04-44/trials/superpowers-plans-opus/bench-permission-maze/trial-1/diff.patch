+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NwQmnqyJ5LPvnShdqUMExw","type":"tool_result","content":"File created successfully at: /workspace/src/__tests__/app.test.ts"}]},"parent_tool_use_id":null,"session_id":"94b86677-521d-4ee3-ba1f-61a36bc0ad46","uuid":"900fe075-f81e-42f1-b89e-6bff239b76a7","tool_use_result":{"type":"create","filePath":"/workspace/src/__tests__/app.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport request from 'supertest';\nimport type { Express } from 'express';\nimport { createApp } from '../app.js';\n\nlet app: Express;\n\n// Helper to register + login a user, returns { token, userId }\nasync function createUser(username: string, password: string) {\n  const regRes = await request(app)\n    .post('/auth/register')\n    .send({ username, password });\n  const loginRes = await request(app)\n    .post('/auth/login')\n    .send({ username, password });\n  return { token: loginRes.body.token as string, userId: regRes.body.id as string };\n}\n\n// Helper to create a folder\nasync function createFolder(token: string, name: string, parentId?: string) {\n  const res = await request(app)\n    .post('/folders')\n    .set('Authorization', `Bearer ${token}`)\n    .send({ name, parentId });\n  return res;\n}\n\n// Helper to create a document\nasync function createDocument(token: string, title: string, content: string, folderId: string) {\n  const res = await request(app)\n    .post('/documents')\n    .set('Authorization', `Bearer ${token}`)\n    .send({ title, content, folderId });\n  return res;\n}\n\n// Helper to share\nasync function shareResource(\n  token: string,\n  resourceType: string,\n  resourceId: string,\n  targetUserId: string,\n  role: string\n) {\n  const res = await request(app)\n    .post('/share')\n    .set('Authorization', `Bearer ${token}`)\n    .send({ resourceType, resourceId, targetUserId, role });\n  return res;\n}\n\ndescribe('User Management', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should register a new user', async () => {\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'pass123' });\n    expect(res.status).toBe(201);\n    expect(res.body).toHaveProperty('id');\n    expect(res.body.username).toBe('alice');\n  });\n\n  it('should reject registration without username', async () => {\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ password: 'pass123' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject registration without password', async () => {\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice' });\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject duplicate username', async () => {\n    await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'pass123' });\n    const res = await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'other' });\n    expect(res.status).toBe(409);\n  });\n\n  it('should login and return token', async () => {\n    await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'pass123' });\n    const res = await request(app)\n      .post('/auth/login')\n      .send({ username: 'alice', password: 'pass123' });\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveProperty('token');\n    expect(res.body).toHaveProperty('userId');\n  });\n\n  it('should reject login with wrong password', async () => {\n    await request(app)\n      .post('/auth/register')\n      .send({ username: 'alice', password: 'pass123' });\n    const res = await request(app)\n      .post('/auth/login')\n      .send({ username: 'alice', password: 'wrong' });\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject login for non-existent user', async () => {\n    const res = await request(app)\n      .post('/auth/login')\n      .send({ username: 'nobody', password: 'pass' });\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe('Auth Middleware', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should reject requests without auth header', async () => {\n    const res = await request(app).get('/folders/some-id');\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject requests with invalid token', async () => {\n    const res = await request(app)\n      .get('/folders/some-id')\n      .set('Authorization', 'Bearer invalid-token');\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe('Folders', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should create a folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await createFolder(token, 'My Folder');\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe('My Folder');\n    expect(res.body.parentId).toBeNull();\n    expect(res.body).toHaveProperty('id');\n  });\n\n  it('should reject folder creation without name', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({});\n    expect(res.status).toBe(400);\n  });\n\n  it('should create a nested folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const parent = await createFolder(token, 'Parent');\n    const child = await createFolder(token, 'Child', parent.body.id);\n    expect(child.status).toBe(201);\n    expect(child.body.parentId).toBe(parent.body.id);\n  });\n\n  it('should reject nested folder with non-existent parent', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await createFolder(token, 'Child', 'non-existent');\n    expect(res.status).toBe(404);\n  });\n\n  it('should get a folder with children and documents', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Root');\n    await createFolder(token, 'Sub', folder.body.id);\n    await createDocument(token, 'Doc1', 'content', folder.body.id);\n\n    const res = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Root');\n    expect(res.body.children).toHaveLength(1);\n    expect(res.body.documents).toHaveLength(1);\n  });\n\n  it('should return 404 for non-existent folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .get('/folders/non-existent')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should update a folder name', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Old Name');\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'New Name' });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('New Name');\n  });\n\n  it('should delete a folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'ToDelete');\n    const res = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(204);\n\n    // Verify it's gone\n    const getRes = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should delete folder with children and documents', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const parent = await createFolder(token, 'Parent');\n    await createFolder(token, 'Child', parent.body.id);\n    await createDocument(token, 'Doc', 'content', parent.body.id);\n\n    const res = await request(app)\n      .delete(`/folders/${parent.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(204);\n  });\n});\n\ndescribe('Documents', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should create a document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const res = await createDocument(token, 'My Doc', 'Hello World', folder.body.id);\n    expect(res.status).toBe(201);\n    expect(res.body.title).toBe('My Doc');\n    expect(res.body.content).toBe('Hello World');\n    expect(res.body.folderId).toBe(folder.body.id);\n    expect(res.body).toHaveProperty('ownerId');\n    expect(res.body).toHaveProperty('createdAt');\n    expect(res.body).toHaveProperty('updatedAt');\n  });\n\n  it('should reject document creation without required fields', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Doc', folderId: folder.body.id }); // missing content\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject document creation with non-existent folder', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await createDocument(token, 'Doc', 'content', 'non-existent');\n    expect(res.status).toBe(404);\n  });\n\n  it('should get a document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const doc = await createDocument(token, 'Doc', 'content', folder.body.id);\n    const res = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Doc');\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const res = await request(app)\n      .get('/documents/non-existent')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should update a document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const doc = await createDocument(token, 'Doc', 'old content', folder.body.id);\n    const res = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Updated', content: 'new content' });\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('new content');\n  });\n\n  it('should delete a document', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const doc = await createDocument(token, 'Doc', 'content', folder.body.id);\n    const res = await request(app)\n      .delete(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(204);\n\n    const getRes = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n    expect(getRes.status).toBe(404);\n  });\n});\n\ndescribe('Sharing & Permissions', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should share a folder with another user', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Shared');\n\n    const res = await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'viewer');\n    expect(res.status).toBe(201);\n    expect(res.body.role).toBe('viewer');\n    expect(res.body.userId).toBe(bob.userId);\n  });\n\n  it('should allow viewer to read a shared folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Shared');\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'viewer');\n\n    const res = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(200);\n  });\n\n  it('should deny viewer from editing a folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Shared');\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'viewer');\n\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ name: 'Hacked' });\n    expect(res.status).toBe(403);\n  });\n\n  it('should allow editor to modify a folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Shared');\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'editor');\n\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ name: 'Updated by Bob' });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Updated by Bob');\n  });\n\n  it('should deny viewer from deleting a folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Shared');\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'viewer');\n\n    const res = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('should deny editor from deleting a folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Shared');\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'editor');\n\n    const res = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('should share a document with another user', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'content', folder.body.id);\n\n    const res = await shareResource(alice.token, 'document', doc.body.id, bob.userId, 'viewer');\n    expect(res.status).toBe(201);\n  });\n\n  it('should allow viewer to read a shared document', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'content', folder.body.id);\n    await shareResource(alice.token, 'document', doc.body.id, bob.userId, 'viewer');\n\n    const res = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(200);\n  });\n\n  it('should deny non-shared user from reading a document', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'content', folder.body.id);\n\n    const res = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('should inherit folder permissions for documents', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'content', folder.body.id);\n\n    // Share folder with bob as viewer\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'viewer');\n\n    // Bob should be able to read doc because he has viewer on folder\n    const res = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(200);\n  });\n\n  it('should inherit nested folder permissions', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const parent = await createFolder(alice.token, 'Parent');\n    const child = await createFolder(alice.token, 'Child', parent.body.id);\n\n    // Share parent with bob as viewer\n    await shareResource(alice.token, 'folder', parent.body.id, bob.userId, 'viewer');\n\n    // Bob should be able to read child folder because he has viewer on parent\n    const res = await request(app)\n      .get(`/folders/${child.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(200);\n  });\n\n  it('should use most permissive role when multiple paths grant access', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'content', folder.body.id);\n\n    // Share folder as viewer\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'viewer');\n    // Share document directly as editor\n    await shareResource(alice.token, 'document', doc.body.id, bob.userId, 'editor');\n\n    // Bob should be able to edit (editor > viewer)\n    const res = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ content: 'updated by bob' });\n    expect(res.status).toBe(200);\n  });\n\n  it('should update existing share role', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'viewer');\n    const res = await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'editor');\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe('editor');\n  });\n\n  it('should allow editor to share', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const carol = await createUser('carol', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    // Share with bob as editor\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'editor');\n\n    // Bob shares with carol as viewer\n    const res = await shareResource(bob.token, 'folder', folder.body.id, carol.userId, 'viewer');\n    expect(res.status).toBe(201);\n  });\n\n  it('should deny viewer from sharing', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const carol = await createUser('carol', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'viewer');\n\n    const res = await shareResource(bob.token, 'folder', folder.body.id, carol.userId, 'viewer');\n    expect(res.status).toBe(403);\n  });\n\n  it('should reject sharing with invalid role', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    const res = await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'admin');\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject sharing non-existent resource', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n\n    const res = await shareResource(alice.token, 'folder', 'non-existent', bob.userId, 'viewer');\n    expect(res.status).toBe(404);\n  });\n\n  it('should reject sharing with non-existent target user', async () => {\n    const alice = await createUser('alice', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    const res = await shareResource(alice.token, 'folder', folder.body.id, 'non-existent', 'viewer');\n    expect(res.status).toBe(404);\n  });\n\n  it('should only allow owners to grant owner role', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const carol = await createUser('carol', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    // Share with bob as editor\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'editor');\n\n    // Bob (editor) tries to grant owner to carol - should fail\n    const res = await shareResource(bob.token, 'folder', folder.body.id, carol.userId, 'owner');\n    expect(res.status).toBe(403);\n  });\n\n  it('should get shares for a resource', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'viewer');\n\n    const res = await request(app)\n      .get(`/share/folder/${folder.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveLength(1);\n    expect(res.body[0].userId).toBe(bob.userId);\n  });\n\n  it('should remove a share', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const share = await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'viewer');\n\n    const res = await request(app)\n      .delete(`/share/${share.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n    expect(res.status).toBe(204);\n\n    // Bob can no longer read\n    const getRes = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(getRes.status).toBe(403);\n  });\n\n  it('should deny non-shared user from accessing a folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Private');\n\n    const res = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(403);\n  });\n\n  it('should allow folder editor to create documents in folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'editor');\n\n    const res = await createDocument(bob.token, 'BobDoc', 'bob content', folder.body.id);\n    expect(res.status).toBe(201);\n    expect(res.body.ownerId).toBe(bob.userId);\n  });\n\n  it('should deny folder viewer from creating documents in folder', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'viewer');\n\n    const res = await createDocument(bob.token, 'BobDoc', 'content', folder.body.id);\n    expect(res.status).toBe(403);\n  });\n});\n\ndescribe('Activity Log', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should log document creation', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    await createDocument(token, 'Doc', 'content', folder.body.id);\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    const createEvents = res.body.filter((e: { action: string }) => e.action === 'document_created');\n    expect(createEvents.length).toBeGreaterThanOrEqual(1);\n    expect(createEvents[0]).toHaveProperty('userId');\n    expect(createEvents[0]).toHaveProperty('timestamp');\n    expect(createEvents[0]).toHaveProperty('resourceType', 'document');\n  });\n\n  it('should log document updates', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const doc = await createDocument(token, 'Doc', 'content', folder.body.id);\n    await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ content: 'updated' });\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    const updateEvents = res.body.filter((e: { action: string }) => e.action === 'document_updated');\n    expect(updateEvents.length).toBeGreaterThanOrEqual(1);\n  });\n\n  it('should log document deletion', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const doc = await createDocument(token, 'Doc', 'content', folder.body.id);\n    const docId = doc.body.id;\n    await request(app)\n      .delete(`/documents/${docId}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n    // After deletion, the document no longer exists so the activity may not be visible\n    // unless we handle deleted resources specially. Let's check that activity was created.\n    expect(res.status).toBe(200);\n  });\n\n  it('should log sharing events', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n    const doc = await createDocument(alice.token, 'Doc', 'content', folder.body.id);\n    await shareResource(alice.token, 'document', doc.body.id, bob.userId, 'viewer');\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${alice.token}`);\n    const shareEvents = res.body.filter((e: { action: string }) => e.action === 'share_created');\n    expect(shareEvents.length).toBeGreaterThanOrEqual(1);\n    expect(shareEvents[0].details).toContain(bob.userId);\n  });\n\n  it('should only show activity for accessible resources', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const aliceFolder = await createFolder(alice.token, 'AliceFolder');\n    await createDocument(alice.token, 'AliceDoc', 'content', aliceFolder.body.id);\n\n    const bobFolder = await createFolder(bob.token, 'BobFolder');\n    await createDocument(bob.token, 'BobDoc', 'content', bobFolder.body.id);\n\n    // Alice should not see Bob's activity\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${alice.token}`);\n    const bobEntries = res.body.filter((e: { resourceId: string }) =>\n      e.resourceId === bobFolder.body.id\n    );\n    expect(bobEntries).toHaveLength(0);\n  });\n});\n\ndescribe('Edge Cases', () => {\n  beforeEach(() => {\n    app = createApp();\n  });\n\n  it('should handle document with empty content', async () => {\n    const { token } = await createUser('alice', 'pass');\n    const folder = await createFolder(token, 'Folder');\n    const res = await createDocument(token, 'Empty', '', folder.body.id);\n    expect(res.status).toBe(201);\n    expect(res.body.content).toBe('');\n  });\n\n  it('should handle deeply nested folder hierarchy permissions', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n\n    const root = await createFolder(alice.token, 'Root');\n    const level1 = await createFolder(alice.token, 'Level1', root.body.id);\n    const level2 = await createFolder(alice.token, 'Level2', level1.body.id);\n\n    // Share root with bob\n    await shareResource(alice.token, 'folder', root.body.id, bob.userId, 'editor');\n\n    // Bob should be able to access level2\n    const res = await request(app)\n      .get(`/folders/${level2.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(res.status).toBe(200);\n\n    // Bob should be able to create doc in level2\n    const docRes = await createDocument(bob.token, 'DeepDoc', 'deep content', level2.body.id);\n    expect(docRes.status).toBe(201);\n  });\n\n  it('should handle owner sharing with owner role', async () => {\n    const alice = await createUser('alice', 'pass');\n    const bob = await createUser('bob', 'pass');\n    const folder = await createFolder(alice.token, 'Folder');\n\n    const res = await shareResource(alice.token, 'folder', folder.body.id, bob.userId, 'owner');\n    expect(res.status).toBe(201);\n\n    // Bob should be able to delete (owner)\n    const delRes = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n    expect(delRes.status).toBe(204);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
