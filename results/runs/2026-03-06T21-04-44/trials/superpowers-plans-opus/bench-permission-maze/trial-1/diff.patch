+import { Router } from 'express';
+import { Store } from '../store.js';
+import { getEffectiveRole } from '../permissions.js';
+
+export function activityRoutes(store: Store): Router {
+  const router = Router();
+
+  router.get('/', (req, res) => {
+    const userId = req.userId!;
+
+    // Filter activity to entries the user can access
+    const accessible = store.activity.filter(entry => {
+      return getEffectiveRole(store, userId, entry.resourceType, entry.resourceId) !== null;
+    });
+
+    res.json(accessible);
+  });
+
+  return router;
+}
diff --git a/src/routes/documents.ts b/src/routes/documents.ts
new file mode 100644
index 0000000..75f9ae2
--- /dev/null
+++ b/src/routes/documents.ts
@@ -0,0 +1,148 @@
+import { Router } from 'express';
+import crypto from 'crypto';
+import { Store } from '../store.js';
+import { requireRole } from '../permissions.js';
+
+export function documentRoutes(store: Store): Router {
+  const router = Router();
+
+  // Create document
+  router.post('/', (req, res) => {
+    const userId = req.userId!;
+    const { title, content, folderId } = req.body;
+
+    if (!title || content === undefined || !folderId) {
+      res.status(400).json({ error: 'Title, content, and folderId are required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    // Need at least editor on folder to create a document in it
+    if (!requireRole(store, userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    const id = crypto.randomUUID();
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    // Activity log
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'document_created',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: now,
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', (req, res) => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!requireRole(store, userId, 'document', doc.id, 'viewer')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/:id', (req, res) => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!requireRole(store, userId, 'document', doc.id, 'editor')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    if (req.body.title !== undefined) {
+      doc.title = req.body.title;
+    }
+    if (req.body.content !== undefined) {
+      doc.content = req.body.content;
+    }
+    doc.updatedAt = new Date().toISOString();
+
+    // Activity log
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'document_updated',
+      userId,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: doc.updatedAt,
+    });
+
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', (req, res) => {
+    const userId = req.userId!;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!requireRole(store, userId, 'document', doc.id, 'owner')) {
+      res.status(403).json({ error: 'Forbidden' });
+      return;
+    }
+
+    const now = new Date().toISOString();
+
+    // Activity log
+    store.activity.push({
+      id: crypto.randomUUID(),
+      action: 'document_deleted',
+      userId,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: now,
+    });
+
+    // Remove shares for this document
+    store.shares = store.shares.filter(
+      s => !(s.resourceType === 'document' && s.resourceId === doc.id)
+    );
+
+    store.documents.delete(doc.id);
+    res.status(204).send();
+  });
+
+  return router;
+}
