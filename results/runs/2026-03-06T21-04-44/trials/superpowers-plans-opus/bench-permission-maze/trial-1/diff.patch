+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01MDUDfRCY6SV2BDmki3abkK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GxWbaiWnfp2JSArUJq5H4x","name":"Write","input":{"file_path":"/workspace/src/permissions.ts","content":"import { Store } from './store.js';\nimport { Role } from './types.js';\n\nconst ROLE_LEVEL: Record<Role, number> = { viewer: 1, editor: 2, owner: 3 };\n\nexport function getEffectiveRole(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string\n): Role | null {\n  let best: Role | null = null;\n\n  function update(role: Role) {\n    if (!best || ROLE_LEVEL[role] > ROLE_LEVEL[best]) {\n      best = role;\n    }\n  }\n\n  // Check ownership\n  if (resourceType === 'document') {\n    const doc = store.documents.get(resourceId);\n    if (doc && doc.ownerId === userId) return 'owner';\n  } else {\n    const folder = store.folders.get(resourceId);\n    if (folder && folder.ownerId === userId) return 'owner';\n  }\n\n  // Direct shares on this resource\n  for (const s of store.shares) {\n    if (s.resourceType === resourceType && s.resourceId === resourceId && s.userId === userId) {\n      update(s.role);\n    }\n  }\n\n  // If document, also check folder shares (walk up folder hierarchy)\n  if (resourceType === 'document') {\n    const doc = store.documents.get(resourceId);\n    if (doc) {\n      const folderRole = getFolderRole(store, userId, doc.folderId);\n      if (folderRole) update(folderRole);\n    }\n  }\n\n  // If folder, check parent folders\n  if (resourceType === 'folder') {\n    const folder = store.folders.get(resourceId);\n    if (folder && folder.parentId) {\n      const parentRole = getFolderRole(store, userId, folder.parentId);\n      if (parentRole) update(parentRole);\n    }\n  }\n\n  return best;\n}\n\nfunction getFolderRole(store: Store, userId: string, folderId: string): Role | null {\n  let best: Role | null = null;\n  let currentId: string | null = folderId;\n\n  while (currentId) {\n    const folder = store.folders.get(currentId);\n    if (!folder) break;\n\n    if (folder.ownerId === userId) return 'owner';\n\n    for (const s of store.shares) {\n      if (s.resourceType === 'folder' && s.resourceId === currentId && s.userId === userId) {\n        if (!best || ROLE_LEVEL[s.role] > ROLE_LEVEL[best]) {\n          best = s.role;\n        }\n      }\n    }\n\n    currentId = folder.parentId;\n  }\n\n  return best;\n}\n\nexport function requireRole(\n  store: Store,\n  userId: string,\n  resourceType: 'folder' | 'document',\n  resourceId: string,\n  minimumRole: Role\n): boolean {\n  const effective = getEffectiveRole(store, userId, resourceType, resourceId);\n  if (!effective) return false;\n  return ROLE_LEVEL[effective] >= ROLE_LEVEL[minimumRole];\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":390,"cache_read_input_tokens":27620,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":390},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"94b86677-521d-4ee3-ba1f-61a36bc0ad46","uuid":"4004bcfe-e9c6-4563-ae56-944d5e8bc35f"}
