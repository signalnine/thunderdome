> {\n  let service: NotificationService;\n\n  beforeEach(() => {\n    service = new NotificationService();\n  });\n\n  it('sends order confirmation', () => {\n    const record = service.sendConfirmation('O1', 99.99);\n    expect(record.type).toBe('confirmation');\n    expect(record.message).toContain('O1');\n    expect(record.message).toContain('99.99');\n  });\n\n  it('sends cancellation notice', () => {\n    const record = service.sendCancellation('O1', 'changed mind');\n    expect(record.type).toBe('cancellation');\n    expect(record.message).toContain('changed mind');\n  });\n\n  it('sends refund notice', () => {\n    const record = service.sendRefundNotice('O1', 50.00);\n    expect(record.type).toBe('refund');\n    expect(record.message).toContain('50.00');\n  });\n\n  it('tracks all sent notifications', () => {\n    service.sendConfirmation('O1', 100);\n    service.sendCancellation('O2', 'duplicate');\n    service.sendRefundNotice('O3', 75);\n    expect(service.getSentNotifications()).toHaveLength(3);\n  });\n});\n","numLines":37,"startLine":1,"totalLines":37}}}
