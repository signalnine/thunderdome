+### Task 1: Create `src/plugins/markdown-ext.ts`
+
+**Files:**
+- Create: `src/plugins/markdown-ext.ts`
+- Test: `tests/plugins/markdown-ext.test.ts` (already exists)
+
+**Step 1: Implement the plugin**
+
+```typescript
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+import { marked } from 'marked';
+
+function processFootnotes(content: string): string {
+  const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  const footnotes: { id: string; text: string }[] = [];
+  let processed = content.replace(footnoteDefRegex, (_match, id, text) => {
+    footnotes.push({ id, text });
+    return '';
+  });
+
+  processed = processed.replace(/\[\^(\d+)\]/g, '<sup><a href="#fn-$1">$1</a></sup>');
+
+  if (footnotes.length > 0) {
+    const footnotesSection = `<section class="footnotes"><ol>${footnotes.map(f => `<li id="fn-${f.id}">${f.text}</li>`).join('')}</ol></section>`;
+    processed += footnotesSection;
+  }
+
+  return processed;
+}
+
+function processAdmonitions(content: string): string {
+  return content.replace(/^:::(note|warning|tip)\n([\s\S]*?)^:::/gm, (_match, type, body) => {
+    return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+  });
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext): ContentFile => {
+        let content = file.content;
+        content = processAdmonitions(content);
+        content = processFootnotes(content);
+        content = marked.parse(content, { async: false }) as string;
+        return { ...file, content };
+      },
+    },
+  };
+}
+```
+
+**Key details:**
+- Process admonitions FIRST (before markdown), then footnotes, then run `marked.parse()`
+- Footnote references: `[^1]` → `<sup><a href="#fn-1">1</a></sup>`
+- Footnote defs: `[^1]: text` → collected and appended as `<section class="footnotes">` with `<li id="fn-1">`
+- Admonitions: `:::type\ncontent\n:::` → `<div class="admonition admonition-type">`
+- marked.parse() is sync with `{ async: false }`
+
+**Step 2: Run tests**
+
+```bash
+npx vitest run tests/plugins/markdown-ext.test.ts
+```
+
+Expected: 8 tests pass.
