in `ctx.data` as `taxonomy-tags`\n- `afterBuild`: Iterates tag map, generates HTML listing pages at `tags/{tag}.html`\n- Files without tags are skipped\n- Multiple tags on same file → file appears under each tag\n\n**Step 2: Run tests**\n\n```bash\nnpx vitest run tests/plugins/taxonomy.test.ts\n```\n\nExpected: 8 tests pass.\n\n---\n\n### Task 5: Create `src/plugins/rss-feed.ts`\n\n**Files:**\n- Create: `src/plugins/rss-feed.ts`\n- Test: `tests/plugins/rss-feed.test.ts` (already exists)\n\n**Step 1: Implement the plugin**\n\n```typescript\nimport { Plugin, BuildContext, ContentFile } from '../core/types.js';\n\nexport function createRssFeedPlugin(): Plugin {\n  return {\n    name: 'rss-feed',\n    version: '1.0.0',\n    dependencies: ['markdown-ext', 'taxonomy'],\n    hooks: {\n      afterBuild: (ctx: BuildContext): void => {\n        const sorted = [...ctx.files].sort((a, b) => {\n          const da = a.date ? new Date(a.date).getTime() : 0;\n          const db = b.date ? new Date(b.date).getTime() : 0;\n          return db - da;\n        });\n\n        const items = sorted.map(file => {\n          const categories = (file.tags || [])\n            .map(t => `      <category>${t}</category>`)\n            .join('\\n');\n\n          const pubDate = file.date ? `\\n      <pubDate>${file.date}</pubDate>` : '';\n\n          return `    <item>\n      <title>${file.title}</title>\n      <link>${ctx.config.baseUrl}/${file.slug}.html</link>${pubDate}\n      <description><![CDATA[${file.content}]]></description>\n${categories}\n    </item>`;\n        }).join('\\n');\n\n        const xml = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<rss version=\"2.0\">\n  <channel>\n    <title>${ctx.config.title}</title>\n    <link>${ctx.config.baseUrl}</link>\n${items}\n  </channel>\n</rss>`;\n\n        ctx.output.set('feed.xml', xml);\n      },\n    },\n  };\n}\n```\n\n**Key details:**\n- Dependencies: `markdown-ext`, `taxonomy`\n- Sort files by date descending (newest first), no-date files go to end (getTime() = 0)\n- Content wrapped in `<![CDATA[...]]>`\n- Tags from file.tags as `<category>` elements\n- Skip `<pubDate>` entirely if no date (don't output \"undefined\")\n- Channel title from `ctx.config.title`, link from `ctx.config.baseUrl`\n\n**Step 2: Run tests**\n\n```bash\nnpx vitest run tests/plugins/rss-feed.test.ts\n```\n\nExpected: 7 tests pass.\n\n---\n\n### Task 6: Create `src/plugins/search-index.ts`\n\n**Files:**\n- Create: `src/plugins/search-index.ts`\n- Test: `tests/plugins/search-index.test.ts` (already exists)\n\n**Step 1: Implement the plugin**\n\n```typescript\nimport { Plugin, BuildContext } from '../core/types.js';\n\nfunction stripHtml(html: string): string {\n  return html.replace(/<[^>]*>/g, '').trim();\n}\n\nexport function createSearchIndexPlugin(): Plugin {\n  return {\n    name: 'search-index',\n    version: '1.0.0',\n    dependencies: ['markdown-ext', 'syntax-highlight'],\n    hooks: {\n      afterBuild: (ctx: BuildContext): void => {\n        const index = ctx.files.map(file => {\n          const entry: Record<string, unknown> = {\n            slug: file.slug,\n            title: file.title,\n            content: stripHtml(file.content),\n          };\n          if (file.tags) {\n            entry.tags = file.tags;\n          }\n          return entry;\n        });\n\n        ctx.output.set('search-index.json', JSON.stringify(index));\n      },\n    },\n  };\n}\n```\n\n**Key details:**\n- Dependencies: `markdown-ext`, `syntax-highlight`\n- Strip all HTML tags from content using regex\n- Include tags only if present on file\n- Output valid JSON array\n\n**Step 2: Run tests**\n\n```bash\nnpx vitest run tests/plugins/search-index.test.ts\n```\n\nExpected: 7 tests pass.\n\n---\n\n### Task 7: Create `src/plugins/sitemap.ts`\n\n**Files:**\n- Create: `src/plugins/sitemap.ts`\n- Test: `tests/plugins/sitemap.test.ts` (already exists)\n\n**Step 1: Implement the plugin**\n\n```typescript\nimport { Plugin, BuildContext, ContentFile } from '../core/types.js';\n\nexport function createSitemapPlugin(): Plugin {\n  return {\n    name: 'sitemap',\n    version: '1.0.0',\n    dependencies: ['taxonomy', 'rss-feed'],\n    hooks: {\n      afterBuild: (ctx: BuildContext): void => {\n        const urls: string[] = [];\n\n        for (const [path] of ctx.output) {\n          if (path === 'sitemap.xml') continue;\n          urls.push(`${ctx.config.baseUrl}/${path}`);\n        }\n\n        const urlEntries = urls\n          .map(url => `  <url>\\n    <loc>${url}</loc>\\n  </url>`)\n          .join('\\n');\n\n        const xml = `<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n${urlEntries}\n</urlset>`;\n\n        ctx.output.set('sitemap.xml', xml);\n      },\n    },\n  };\n}\n```\n\n**Key details:**\n- Dependencies: `taxonomy`, `rss-feed`\n- Iterates all entries in `ctx.output` (HTML pages, tag pages, feed.xml)\n- Skips `sitemap.xml` itself\n- Prefixes all paths with `config.baseUrl`\n- Proper XML structure with urlset namespace\n\n**Step 2: Run tests**\n\n```bash\nnpx vitest run tests/plugins/sitemap.test.ts\n```\n\nExpected: 7 tests pass.\n\n---\n\n### Task 8: Create `src/plugins/dev-server.ts`\n\n**Files:**\n- Create: `src/plugins/dev-server.ts`\n- Test: `tests/plugins/dev-server.test.ts` (already exists)\n\n**Step 1: Implement the plugin**\n\n```typescript\nimport { Plugin, BuildContext } from '../core/types.js';\n\ninterface DevServerConfig {\n  port: number;\n  routes: Array<{ path: string; handler: string }>;\n  assetPaths: string[];\n  searchIndexPath: string;\n}\n\nexport function createDevServerPlugin(): Plugin {\n  return {\n    name: 'dev-server',\n    version: '1.0.0',\n    dependencies: ['asset-pipeline', 'search-index'],\n    hooks: {\n      afterBuild: (ctx: BuildContext): void => {\n        const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;\n        const assetPaths = manifest ? manifest.assets : [];\n\n        const routes: Array<{ path: string; handler: string }> = [];\n\n        // Asset routes\n        for (const asset of assetPaths) {\n          routes.push({ path: `/assets/${asset}`, handler: 'asset' });\n        }\n\n        // Content routes\n        for (const [path] of ctx.output) {\n          if (path.endsWith('.html')) {\n            routes.push({ path: `/${path}`, handler: 'static' });\n          }\n        }\n\n        const config: DevServerConfig = {\n          port: 3000,\n          routes,\n          assetPaths,\n          searchIndexPath: '/search-index.json',\n        };\n\n        ctx.data.set('dev-server-config', config);\n      },\n    },\n  };\n}\n```\n\n**Key details:**\n- Dependencies: `asset-pipeline`, `search-index`\n- Default port: 3000\n- Reads `asset-manifest` from ctx.data, gracefully handles missing data (empty array)\n- Creates routes for assets (handler: 'asset') and HTML files (handler: 'static')\n- Fixed searchIndexPath: '/search-index.json'\n- Stores config in `ctx.data['dev-server-config']`\n\n**Step 2: Run tests**\n\n```bash\nnpx vitest run tests/plugins/dev-server.test.ts\n```\n\nExpected: 7 tests pass.\n\n---\n\n### Task 9: Run full test suite\n\n```bash\nnpx vitest run\n```\n\nExpected: 75 tests pass (15 core + 60 plugin).\n\n### Task 10: Run build\n\n```bash\nnpm run build\n```\n\nExpected: Clean compile.\n\n### Task 11: Run lint\n\n```bash\nnpm run lint\n```\n\nExpected: No errors.\n","structuredPatch":[],"originalFile":null}}
