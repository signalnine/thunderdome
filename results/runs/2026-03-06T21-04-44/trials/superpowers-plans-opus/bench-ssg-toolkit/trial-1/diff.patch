+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ScrNoUNTZL1Ujp4SUJu6Dx","type":"tool_result","content":"     1→import { describe, it, expect } from 'vitest';\n     2→import { createSyntaxHighlightPlugin } from '../../src/plugins/syntax-highlight.js';\n     3→import { BuildContext, ContentFile, SiteConfig } from '../../src/core/types.js';\n     4→\n     5→const testConfig: SiteConfig = {\n     6→  title: 'Test Site',\n     7→  baseUrl: 'https://example.com',\n     8→  outputDir: './dist',\n     9→  contentDir: './content',\n    10→  templateDir: './templates',\n    11→};\n    12→\n    13→function makeCtx(): BuildContext {\n    14→  return {\n    15→    config: testConfig,\n    16→    files: [],\n    17→    output: new Map(),\n    18→    assets: new Map(),\n    19→    data: new Map(),\n    20→  };\n    21→}\n    22→\n    23→function makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n    24→  return {\n    25→    slug: 'test',\n    26→    title: 'Test',\n    27→    content: '',\n    28→    metadata: {},\n    29→    ...overrides,\n    30→  };\n    31→}\n    32→\n    33→describe('syntax-highlight plugin', () => {\n    34→  const plugin = createSyntaxHighlightPlugin();\n    35→\n    36→  it('adds language class to code blocks', async () => {\n    37→    const file = makeFile({\n    38→      content: '<pre><code class=\"language-javascript\">const x = 1;</code></pre>',\n    39→    });\n    40→    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    41→    expect(result.content).toContain('class=\"language-javascript highlighted\"');\n    42→  });\n    43→\n    44→  it('adds data-language attribute to pre tags', async () => {\n    45→    const file = makeFile({\n    46→      content: '<pre><code class=\"language-python\">print(\"hi\")</code></pre>',\n    47→    });\n    48→    const result = await plugin.hooks.transformContent!(file, makeCtx());\n    49→    expect(result.content).toContain('data-language=\"python