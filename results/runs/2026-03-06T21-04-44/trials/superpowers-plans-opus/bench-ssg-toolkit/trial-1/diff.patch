+```typescript
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+        const manifest = (ctx.data.get('asset-manifest') as { assets: string[] }) || { assets: [] };
+        const assetRegex = /(src|href)="\.\/([^"]+)"/g;
+
+        const content = file.content.replace(assetRegex, (_match, attr, path) => {
+          if (!manifest.assets.includes(path)) {
+            manifest.assets.push(path);
+          }
+          return `${attr}="/assets/${path}"`;
+        });
+
+        ctx.data.set('asset-manifest', manifest);
+        return { ...file, content };
+      },
+    },
+  };
+}
+```
+
+**Key details:**
+- Regex matches `src="./..."` and `href="./..."` patterns
+- Rewrites to `/assets/filename`
+- Accumulates assets in `ctx.data['asset-manifest']` across calls
+- Already-rewritten `/assets/` URLs don't match `./` pattern, so no double-processing
+- Absolute URLs (`https://...`) don't match `./` pattern
+
