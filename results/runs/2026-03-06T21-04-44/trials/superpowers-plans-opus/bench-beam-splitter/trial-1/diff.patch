// Process iteratively: each iteration advances all beams one step\n  let current = new Map<string, bigint>();\n  current.set(`${sr},${sc},down`, 1n);\n\n  let totalPaths = 0n;\n\n  while (current.size > 0) {\n    const next = new Map<string, bigint>();\n\n    for (const [key, count] of current) {\n      const parts = key.split(',');\n      const row = parseInt(parts[0]);\n      const col = parseInt(parts[1]);\n      const dir = parts[2] as Direction;\n\n      const [nr, nc] = advance(row, col, dir);\n\n      if (!inBounds(nr, nc, rows, cols)) {\n        totalPaths += count;\n        continue;\n      }\n\n      if (grid[nr][nc] === '^') {\n        const lk = `${nr},${nc},down-left`;\n        const rk = `${nr},${nc},down-right`;\n        next.set(lk, (next.get(lk) ?? 0n) + count);\n        next.set(rk, (next.get(rk) ?? 0n) + count);\n      } else {\n        const nk = `${nr},${nc},${dir}`;\n        next.set(nk, (next.get(nk) ?? 0n) + count);\n      }\n    }\n\n    current = next;\n  }\n\n  return totalPaths;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":339,"cache_read_input_tokens":25867,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":339},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"52f93981-13e3-49d8-a7bb-0172e9e3e9d6","uuid":"ebd06aa8-b1a2-4280-859f-0ccdd0e73a4f"}
