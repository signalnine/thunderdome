+  it('handles 200x200 grid with 50 splitters under 5 seconds', () => {
+    const rows = 200;
+    const cols = 200;
+    const grid: string[][] = Array.from({ length: rows }, () =>
+      Array.from({ length: cols }, () => '.')
+    );
+    grid[0][100] = 'S';
+
+    // Place 50 splitters in a diamond pattern that beams will actually hit
+    // First splitter catches the initial downward beam
+    // Subsequent rows catch the split beams
+    const splitterPositions: [number, number][] = [];
+    // Row 10: 1 splitter at col 100
+    splitterPositions.push([10, 100]);
+    // Row 20: 2 splitters at cols 90, 110 (catching down-left and down-right)
+    splitterPositions.push([20, 90], [20, 110]);
+    // Row 30: 4 splitters
+    splitterPositions.push([30, 80], [30, 100], [30, 100], [30, 120]);
+    // Remove duplicate and add more spread out
+    // Actually let's just place them strategically
+    const placed = new Set<string>();
+    placed.add('10,100');
+
+    // Place splitters at rows 20,30,...,100 in expanding pattern
+    let currentCols = [90, 110]; // after first split
+    for (let row = 20; row <= 190 && splitterPositions.length < 50; row += 10) {
+      const nextCols: number[] = [];
+      for (const c of currentCols) {
+        if (c >= 0 && c < cols && !placed.has(`${row},${c}`)) {
+          splitterPositions.push([row, c]);
+          placed.add(`${row},${c}`);
+          nextCols.push(c - 10, c + 10);
+        }
+      }
+      currentCols = [...new Set(nextCols)].filter(c => c >= 0 && c < cols);
+    }
+
+    // Trim to exactly 50
+    while (splitterPositions.length > 50) splitterPositions.pop();
+
+    for (const [r, c] of splitterPositions) {
+      if (r > 0 && r < rows && c >= 0 && c < cols) {
+        grid[r][c] = '^';
+      }
+    }
+
+    const start = Date.now();
+    const cells = countBeamCells(grid);
+    const paths = countBeamPaths(grid);
+    const elapsed = Date.now() - start;
+
+    expect(cells).toBeGreaterThan(0);
+    expect(paths).toBeGreaterThan(0n);
+    expect(elapsed).toBeLessThan(5000);
+  });
