am.dir);\n\n    if (!inBounds(nr, nc, rows, cols)) continue;\n\n    visited.add(`${nr},${nc}`);\n\n    if (grid[nr][nc] === '^') {\n      beams.push({ row: nr, col: nc, dir: 'down-left' });\n      beams.push({ row: nr, col: nc, dir: 'down-right' });\n    } else {\n      beams.push({ row: nr, col: nc, dir: beam.dir });\n    }\n  }\n\n  return visited.size;\n}\n\nexport function countBeamPaths(grid: string[][]): bigint {\n  throw new Error('Not implemented');\n}\n```\n\n**Step 2: Run tests**\n\nRun: `npm test`\nExpected: countBeamCells tests PASS, countBeamPaths tests still fail\n\n---\n\n### Task 4: Write tests for countBeamPaths\n\n**Files:**\n- Modify: `tests/index.test.ts`\n\n**Step 1: Add countBeamPaths tests**\n\n```typescript\ndescribe('countBeamPaths', () => {\n  it('no splitter, single path', () => {\n    const grid = [['S'], ['.'], ['.']];\n    expect(countBeamPaths(grid)).toBe(1n);\n  });\n\n  it('single splitter (task example 1)', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    expect(countBeamPaths(grid)).toBe(2n);\n  });\n\n  it('two splitters (task example 2)', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['^', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    expect(countBeamPaths(grid)).toBe(4n);\n  });\n\n  it('source only, 1x1 grid', () => {\n    const grid = [['S']];\n    // beam immediately exits below — 1 path\n    expect(countBeamPaths(grid)).toBe(1n);\n  });\n\n  it('splitter at edge, one branch absorbed', () => {\n    const grid = [\n      ['S', '.', '.'],\n      ['^', '.', '.'],\n      ['.', '.', '.'],\n    ];\n    // splits to (2,-1) absorbed and (2,1) exits bottom\n    // Both count as paths (absorbed = exits grid)\n    expect(countBeamPaths(grid)).toBe(2n);\n  });\n\n  it('chain of splitters on same diagonal', () => {\n    const grid = [\