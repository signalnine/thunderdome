+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01KvciKp92CPyzi6PVWK1fti","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01P2VpkciA653JPD3fDk2c8B","name":"Write","input":{"file_path":"/workspace/docs/plans/2026-03-06-beam-splitter.md","content":"# Beam Splitter Implementation Plan\n\n> **For Claude:** REQUIRED SUB-SKILL: Use superpowers:executing-plans to implement this plan task-by-task.\n\n**Goal:** Build a beam propagation simulator that counts visited cells and distinct paths through a 2D grid with sources and splitters.\n\n**Architecture:** Two exported functions in `src/index.ts`. `countBeamCells` uses BFS/simulation to track visited cells. `countBeamPaths` uses dynamic programming on splitters (sorted by row) to count paths as bigints without enumerating them — each splitter records how many paths reach it, and splits contribute 2x multiplied paths downstream. Both functions share a beam simulation core.\n\n**Tech Stack:** TypeScript (ES2022, Node16 modules), Vitest for testing, ESLint for linting.\n\n---\n\n### Task 1: Create src/index.ts with type definitions and stubs\n\n**Files:**\n- Create: `src/index.ts`\n\n**Step 1: Write stub implementation**\n\n```typescript\ntype Direction = 'down' | 'down-left' | 'down-right';\n\ninterface Beam {\n  row: number;\n  col: number;\n  dir: Direction;\n}\n\nexport function countBeamCells(grid: string[][]): number {\n  throw new Error('Not implemented');\n}\n\nexport function countBeamPaths(grid: string[][]): bigint {\n  throw new Error('Not implemented');\n}\n```\n\n**Step 2: Verify build**\n\nRun: `npm run build`\nExpected: PASS, compiles to dist/\n\n**Step 3: Verify lint**\n\nRun: `npm run lint`\nExpected: PASS, no lint errors\n\n---\n\n### Task 2: Write tests for countBeamCells\n\n**Files:**\n- Create: `tests/index.test.ts`\n\n**Step 1: Write tests**\n\n```typescript\nimport { describe, it, expect } from 'vitest';\nimport { countBeamCells, countBeamPaths } from '../src/index.js';\n\ndescribe('countBeamCells', () => {\n  it('single column, no splitter', () => {\n    const grid = [['S'], ['.'], ['.']];\n    expect(countBeamCells(grid)).toBe(3);\n  });\n\n  it('beam exits bottom', () => {\n    const grid = [\n      ['.', 'S', '.'],\n      ['.', '.', '.'],\n    ];\n    expect(countBeamCells(grid)).toBe(2);\n  });\n\n  it('single splitter (task example 1)', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    expect(countBeamCells(grid)).toBe(5);\n  });\n\n  it('two splitters (task example 2)', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['^', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    expect(countBeamCells(grid)).toBe(6);\n  });\n\n  it('source only, 1x1 grid', () => {\n    const grid = [['S']];\n    expect(countBeamCells(grid)).toBe(1);\n  });\n\n  it('diagonal beam absorbed at left edge', () => {\n    const grid = [\n      ['S', '.', '.'],\n      ['^', '.', '.'],\n      ['.', '.', '.'],\n    ];\n    // S at (0,0), down to (1,0) hits splitter\n    // splits: down-left (2,-1) absorbed, down-right (2,1) valid\n    expect(countBeamCells(grid)).toBe(3); // (0,0), (1,0), (2,1)\n  });\n\n  it('diagonal beam absorbed at right edge', () => {\n    const grid = [\n      ['.', '.', 'S'],\n      ['.', '.', '^'],\n      ['.', '.', '.'],\n    ];\n    // S at (0,2), down to (1,2) hits splitter\n    // splits: down-left (2,1), down-right (2,3) absorbed\n    expect(countBeamCells(grid)).toBe(3); // (0,2), (1,2), (2,1)\n  });\n\n  it('chain of splitters on diagonal', () => {\n    const grid = [\n      ['.', 'S', '.', '.'],\n      ['.', '.', '.', '.'],\n      ['.', '^', '.', '.'],\n      ['.', '.', '.', '.'],\n      ['.', '.', '^', '.'],\n      ['.', '.', '.', '.'],\n    ];\n    // S(0,1) -> (1,1) -> (2,1) splitter\n    // left: (3,0) -> (4,-1) absorbed -- wait, (3,0) continues down-left to (4,-1)\n    // right: (3,2) -> (4,2) splitter\n    //   right-left: (5,1), right-right: (5,3)\n    // Visited: (0,1),(1,1),(2,1),(3,0),(3,2),(4,2),(5,1),(5,3) -- but (4,-1) is absorbed\n    // Actually (3,0) goes down-left to (4,-1) which is out of bounds. So (3,0) is the last cell for that beam.\n    expect(countBeamCells(grid)).toBe(8); // (0,1),(1,1),(2,1),(3,0),(3,2),(4,2),(5,1),(5,3)\n  });\n});\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `npm test`\nExpected: FAIL with \"Not implemented\"\n\n---\n\n### Task 3: Implement countBeamCells\n\n**Files:**\n- Modify: `src/index.ts`\n\n**Step 1: Implement the beam simulation**\n\n```typescript\ntype Direction = 'down' | 'down-left' | 'down-right';\n\ninterface Beam {\n  row: number;\n  col: number;\n  dir: Direction;\n}\n\nfunction findSource(grid: string[][]): [number, number] {\n  for (let c = 0; c < grid[0].length; c++) {\n    if (grid[0][c] === 'S') return [0, c];\n  }\n  throw new Error('No source found');\n}\n\nfunction advance(row: number, col: number, dir: Direction): [number, number] {\n  switch (dir) {\n    case 'down': return [row + 1, col];\n    case 'down-left': return [row + 1, col - 1];\n    case 'down-right': return [row + 1, col + 1];\n  }\n}\n\nfunction inBounds(row: number, col: number, rows: number, cols: number): boolean {\n  return row >= 0 && row < rows && col >= 0 && col < cols;\n}\n\nexport function countBeamCells(grid: string[][]): number {\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const [sr, sc] = findSource(grid);\n\n  const visited = new Set<string>();\n  visited.add(`${sr},${sc}`);\n\n  const beams: Beam[] = [{ row: sr, col: sc, dir: 'down' }];\n\n  while (beams.length > 0) {\n    const beam = beams.pop()!;\n    const [nr, nc] = advance(beam.row, beam.col, beam.dir);\n\n    if (!inBounds(nr, nc, rows, cols)) continue;\n\n    visited.add(`${nr},${nc}`);\n\n    if (grid[nr][nc] === '^') {\n      beams.push({ row: nr, col: nc, dir: 'down-left' });\n      beams.push({ row: nr, col: nc, dir: 'down-right' });\n    } else {\n      beams.push({ row: nr, col: nc, dir: beam.dir });\n    }\n  }\n\n  return visited.size;\n}\n\nexport function countBeamPaths(grid: string[][]): bigint {\n  throw new Error('Not implemented');\n}\n```\n\n**Step 2: Run tests**\n\nRun: `npm test`\nExpected: countBeamCells tests PASS, countBeamPaths tests still fail\n\n---\n\n### Task 4: Write tests for countBeamPaths\n\n**Files:**\n- Modify: `tests/index.test.ts`\n\n**Step 1: Add countBeamPaths tests**\n\n```typescript\ndescribe('countBeamPaths', () => {\n  it('no splitter, single path', () => {\n    const grid = [['S'], ['.'], ['.']];\n    expect(countBeamPaths(grid)).toBe(1n);\n  });\n\n  it('single splitter (task example 1)', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    expect(countBeamPaths(grid)).toBe(2n);\n  });\n\n  it('two splitters (task example 2)', () => {\n    const grid = [\n      ['.', 'S', '.', '.', '.'],\n      ['.', '^', '.', '.', '.'],\n      ['^', '.', '^', '.', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    expect(countBeamPaths(grid)).toBe(4n);\n  });\n\n  it('source only, 1x1 grid', () => {\n    const grid = [['S']];\n    // beam immediately exits below — 1 path\n    expect(countBeamPaths(grid)).toBe(1n);\n  });\n\n  it('splitter at edge, one branch absorbed', () => {\n    const grid = [\n      ['S', '.', '.'],\n      ['^', '.', '.'],\n      ['.', '.', '.'],\n    ];\n    // splits to (2,-1) absorbed and (2,1) exits bottom\n    // Both count as paths (absorbed = exits grid)\n    expect(countBeamPaths(grid)).toBe(2n);\n  });\n\n  it('chain of splitters on same diagonal', () => {\n    const grid = [\n      ['.', 'S', '.', '.'],\n      ['.', '.', '.', '.'],\n      ['.', '^', '.', '.'],\n      ['.', '.', '.', '.'],\n      ['.', '.', '^', '.'],\n      ['.', '.', '.', '.'],\n    ];\n    // S -> splitter at (2,1): 2 beams\n    // left beam: (3,0) -> (4,-1) absorbed = 1 path\n    // right beam: (3,2) -> (4,2) splitter: 2 more beams\n    //   left: (5,1) exits = 1 path\n    //   right: (5,3) exits = 1 path\n    // Total: 3 paths\n    expect(countBeamPaths(grid)).toBe(3n);\n  });\n\n  it('three splitters, exponential paths', () => {\n    const grid = [\n      ['.', '.', 'S', '.', '.'],\n      ['.', '.', '^', '.', '.'],\n      ['.', '^', '.', '^', '.'],\n      ['.', '.', '.', '.', '.'],\n    ];\n    // S(0,2) -> (1,2) splitter -> left(2,1) splitter, right(2,3) splitter\n    // (2,1) splitter -> (3,0) and (3,2)\n    // (2,3) splitter -> (3,2) and (3,4)\n    // Total paths: 4\n    expect(countBeamPaths(grid)).toBe(4n);\n  });\n});\n```\n\n**Step 2: Run tests to confirm countBeamPaths tests fail**\n\nRun: `npm test`\nExpected: countBeamCells PASS, countBeamPaths FAIL\n\n---\n\n### Task 5: Implement countBeamPaths\n\n**Files:**\n- Modify: `src/index.ts`\n\n**Approach:** Use the same beam simulation but instead of tracking visited cells, track the number of paths reaching each cell+direction. When a beam hits a splitter, its path count is distributed to both branches. Each beam that exits the grid contributes its path count to the total. This avoids enumerating individual paths and handles 2^50 easily with bigint arithmetic.\n\n**Step 1: Implement countBeamPaths**\n\nThe approach: simulate beam propagation but instead of tracking individual beams, aggregate by (row, col, direction). For each unique position+direction, track the number of paths that reach it. Process row by row or use a queue. When a splitter is hit, the path count splits to both diagonals.\n\nActually, simpler: since beams only move downward (row always increases), we can process cells row by row. For each cell+direction, track the bigint count of paths passing through. When a beam reaches a splitter, its count splits into two directions.\n\n```typescript\nexport function countBeamPaths(grid: string[][]): bigint {\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const [sr, sc] = findSource(grid);\n\n  // Map from \"row,col,dir\" -> number of paths through that state\n  // Process using a queue, but aggregate by state\n  type State = { row: number; col: number; dir: Direction };\n  const stateKey = (s: State) => `${s.row},${s.col},${s.dir}`;\n\n  // Use a map to aggregate path counts by state\n  // Process row by row to ensure we handle everything in order\n  let current = new Map<string, bigint>();\n  const startState: State = { row: sr, col: sc, dir: 'down' };\n  current.set(stateKey(startState), 1n);\n\n  let totalPaths = 0n;\n\n  // Process until no more active beams\n  while (current.size > 0) {\n    const next = new Map<string, bigint>();\n\n    for (const [key, count] of current) {\n      const parts = key.split(',');\n      const row = parseInt(parts[0]);\n      const col = parseInt(parts[1]);\n      const dir = parts[2] as Direction;\n\n      const [nr, nc] = advance(row, col, dir);\n\n      if (!inBounds(nr, nc, rows, cols)) {\n        totalPaths += count;\n        continue;\n      }\n\n      if (grid[nr][nc] === '^') {\n        const leftState: State = { row: nr, col: nc, dir: 'down-left' };\n        const rightState: State = { row: nr, col: nc, dir: 'down-right' };\n        const lk = stateKey(leftState);\n        const rk = stateKey(rightState);\n        next.set(lk, (next.get(lk) ?? 0n) + count);\n        next.set(rk, (next.get(rk) ?? 0n) + count);\n      } else {\n        const nextState: State = { row: nr, col: nc, dir };\n        const nk = stateKey(nextState);\n        next.set(nk, (next.get(nk) ?? 0n) + count);\n      }\n    }\n\n    current = next;\n  }\n\n  return totalPaths;\n}\n```\n\n**Step 2: Run all tests**\n\nRun: `npm test`\nExpected: ALL PASS\n\n---\n\n### Task 6: Performance optimization and large grid test\n\n**Files:**\n- Modify: `tests/index.test.ts`\n\n**Step 1: Add perf