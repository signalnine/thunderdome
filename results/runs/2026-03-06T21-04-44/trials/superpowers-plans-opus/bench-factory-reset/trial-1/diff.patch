+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+type Comparator = (a: number[], b: number[]) => number;
+
+function lexCompare(a: number[], b: number[]): number {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return 0;
+}
+
+function indexSetCompare(a: number[], b: number[]): number {
+  // Compare binary vectors by their index sets lexicographically
+  // {0} < {1} < {0,1} < {0,2} etc.
+  // First compare by number of 1-bits (fewer is "smaller" for min presses)
+  // But we're called only when sums are equal, so sizes are equal for toggle.
+  // Compare the sets element by element.
+  let ai = 0, bi = 0;
+  while (ai < a.length && bi < b.length) {
+    // Find next 1 in a
+    while (ai < a.length && !a[ai]) ai++;
+    while (bi < b.length && !b[bi]) bi++;
+    if (ai >= a.length && bi >= b.length) return 0;
+    if (ai >= a.length) return -1;
+    if (bi >= b.length) return 1;
+    if (ai !== bi) return ai - bi;
+    ai++;
+    bi++;
+  }
+  return 0;
+}
+
+function modPow(base: number, exp: number, mod: number): number {
+  let result = 1;
+  base = base % mod;
+  while (exp > 0) {
+    if (exp & 1) {
+      result = (result * base) % mod;
+    }
+    exp >>= 1;
+    base = (base * base) % mod;
+  }
+  return result;
+}
+
+function solveLinearSystemGF(
+  numRows: number,
+  numCols: number,
+  A: number[][],
+  b: number[],
+  p: number,
+  compare: Comparator
+): number[] | null {
+  const aug: number[][] = [];
+  for (let i = 0; i < numRows; i++) {
+    const row = new Array(numCols + 1);
+    for (let j = 0; j < numCols; j++) {
+      row[j] = ((A[i][j] % p) + p) % p;
+    }
+    row[numCols] = ((b[i] % p) + p) % p;
+    aug.push(row);
+  }
+
+  const inv = new Array(p);
+  inv[0] = 0;
+  for (let a = 1; a < p; a++) {
+    inv[a] = modPow(a, p - 2, p);
+  }
+
+  // Gaussian elimination → RREF
+  const pivotCol: number[] = [];
+  let currentRow = 0;
+
+  for (let col = 0; col < numCols && currentRow < numRows; col++) {
+    let pivotR = -1;
+    for (let row = currentRow; row < numRows; row++) {
+      if (aug[row][col] !== 0) {
+        pivotR = row;
+        break;
+      }
+    }
+    if (pivotR === -1) continue;
+
+    if (pivotR !== currentRow) {
+      const tmp = aug[currentRow];
+      aug[currentRow] = aug[pivotR];
+      aug[pivotR] = tmp;
+    }
+
+    const scale = inv[aug[currentRow][col]];
+    for (let j = col; j <= numCols; j++) {
+      aug[currentRow][j] = (aug[currentRow][j] * scale) % p;
+    }
+
+    for (let row = 0; row < numRows; row++) {
+      if (row === currentRow || aug[row][col] === 0) continue;
+      const factor = aug[row][col];
+      for (let j = col; j <= numCols; j++) {
+        aug[row][j] = ((aug[row][j] - (factor * aug[currentRow][j]) % p) % p + p) % p;
+      }
+    }
+
+    pivotCol.push(col);
+    currentRow++;
+  }
+
+  const rank = pivotCol.length;
+
+  for (let row = rank; row < numRows; row++) {
+    if (aug[row][numCols] !== 0) {
+      return null;
+    }
+  }
+
+  const isPivot = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let j = 0; j < numCols; j++) {
+    if (!isPivot.has(j)) freeVars.push(j);
+  }
+
+  const numFree = freeVars.length;
+
+  // Precompute pivot coefficients on free variables
+  const pivotRHS: number[] = [];
+  const pivotFreeCoeffs: number[][] = [];
+  for (let i = 0; i < rank; i++) {
+    pivotRHS.push(aug[i][numCols]);
+    const coeffs: number[] = [];
+    for (const fv of freeVars) {
+      coeffs.push(aug[i][fv]);
+    }
+    pivotFreeCoeffs.push(coeffs);
+  }
+
+  function computeSolution(freeVals: number[]): number[] {
+    const x = new Array(numCols).fill(0);
+    for (let k = 0; k < numFree; k++) {
+      x[freeVars[k]] = freeVals[k];
+    }
+    for (let i = 0; i < rank; i++) {
+      let val = pivotRHS[i];
+      for (let k = 0; k < numFree; k++) {
+        val = ((val - pivotFreeCoeffs[i][k] * freeVals[k]) % p + p) % p;
+      }
+      x[pivotCol[i]] = val;
+    }
+    return x;
+  }
+
+  function sumArray(x: number[]): number {
+    let s = 0;
+    for (let i = 0; i < x.length; i++) s += x[i];
+    return s;
+  }
+
+  if (numFree === 0) {
+    const x = new Array(numCols).fill(0);
+    for (let i = 0; i < rank; i++) {
+      x[pivotCol[i]] = aug[i][numCols];
+    }
+    return x;
+  }
+
+  // For small search spaces, enumerate exhaustively
+  const totalSpace = Math.pow(p, numFree);
+  if (totalSpace <= 5000000) {
+    let bestSum = Infinity;
+    let bestX: number[] | null = null;
+
+    const freeVals = new Array(numFree).fill(0);
+    for (let iter = 0; iter < totalSpace; iter++) {
+      const x = computeSolution(freeVals);
+      const s = sumArray(x);
+
+      if (s < bestSum || (s === bestSum && bestX !== null && compare(x, bestX) < 0)) {
+        bestSum = s;
+        bestX = x;
+      }
+
+      for (let k = 0; k < numFree; k++) {
+        freeVals[k]++;
+        if (freeVals[k] >= p) {
+          freeVals[k] = 0;
+        } else {
+          break;
+        }
+      }
+    }
+
+    return bestX;
+  }
+
+  // For larger spaces, use coordinate descent (greedy optimization)
+  // Start with particular solution (all free vars = 0)
+  // Then optimize each free variable one at a time, cycling until convergence
+  const bestFreeVals = new Array(numFree).fill(0);
+
+  // Initialize with the particular solution
+  let currentSolution = computeSolution(bestFreeVals);
+  let currentSum = sumArray(currentSolution);
+
+  // Coordinate descent: optimize one free variable at a time
+  let improved = true;
+  const maxIters = 100;
+  let iter = 0;
+  while (improved && iter < maxIters) {
+    improved = false;
+    iter++;
+    for (let k = 0; k < numFree; k++) {
+      const origVal = bestFreeVals[k];
+      let bestVal = origVal;
+      let bestLocalSum = currentSum;
+      let bestLocalX = currentSolution;
+
+      for (let v = 0; v < p; v++) {
+        if (v === origVal) continue;
+        bestFreeVals[k] = v;
+        const x = computeSolution(bestFreeVals);
+        const s = sumArray(x);
+        if (s < bestLocalSum || (s === bestLocalSum && compare(x, bestLocalX) < 0)) {
+          bestLocalSum = s;
+          bestLocalX = x;
+          bestVal = v;
+        }
+      }
+
+      bestFreeVals[k] = bestVal;
+      if (bestLocalSum < currentSum) {
+        currentSum = bestLocalSum;
+        currentSolution = bestLocalX;
+        improved = true;
+      } else {
+        currentSum = bestLocalSum;
+        currentSolution = bestLocalX;
+      }
+    }
+  }
+
+  // After coordinate descent, do a local search: try pairs of free variables
+  if (numFree >= 2 && numFree <= 20) {
+    improved = true;
+    while (improved) {
+      improved = false;
+      for (let k1 = 0; k1 < numFree && !improved; k1++) {
+        for (let k2 = k1 + 1; k2 < numFree && !improved; k2++) {
+          const orig1 = bestFreeVals[k1];
+          const orig2 = bestFreeVals[k2];
+          let bestV1 = orig1, bestV2 = orig2;
+          let bestLocalSum = currentSum;
+          let bestLocalX = currentSolution;
+
+          for (let v1 = 0; v1 < p; v1++) {
+            bestFreeVals[k1] = v1;
+            for (let v2 = 0; v2 < p; v2++) {
+              bestFreeVals[k2] = v2;
+              const x = computeSolution(bestFreeVals);
+              const s = sumArray(x);
+              if (s < bestLocalSum || (s === bestLocalSum && compare(x, bestLocalX) < 0)) {
+                bestLocalSum = s;
+                bestLocalX = x;
+                bestV1 = v1;
+                bestV2 = v2;
+              }
+            }
+          }
+
+          bestFreeVals[k1] = bestV1;
+          bestFreeVals[k2] = bestV2;
+          if (bestLocalSum < currentSum) {
+            currentSum = bestLocalSum;
+            currentSolution = bestLocalX;
+            improved = true;
+          } else {
+            currentSum = bestLocalSum;
+            currentSolution = bestLocalX;
+          }
+        }
+      }
+    }
+  }
+
+  return currentSolution;
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (target.every(t => !t)) {
+    return [];
+  }
+
+  if (numButtons === 0) {
+    return null;
+  }
+
+  const A: number[][] = [];
+  const b: number[] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    A.push(row);
+    b.push(target[i] ? 1 : 0);
+  }
+
+  const solution = solveLinearSystemGF(numLights, numButtons, A, b, 2, indexSetCompare);
+  if (solution === null) return null;
+
+  const result: number[] = [];
+  for (let j = 0; j < numButtons; j++) {
+    if (solution[j] === 1) {
+      result.push(j);
+    }
+  }
+  return result;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  if (lights.every(l => l === 0)) {
+    return new Array(numButtons).fill(0);
+  }
+
+  if (numButtons === 0) {
+    return null;
+  }
+
+  const A: number[][] = [];
+  const b: number[] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    A.push(row);
+    b.push(((lights[i] % modulus) + modulus) % modulus);
+  }
+
+  return solveLinearSystemGF(numCounters, numButtons, A, b, modulus, lexCompare);
+}
