ible.\n    if (popcount > bestSum) break;\n  }\n\n  return bestX;\n}\n\nfunction generateByPopcount(n: number, k: number): number[] {\n  const result: number[] = [];\n  generateByPopcountHelper(n, k, 0, 0, result);\n  return result;\n}\n\nfunction generateByPopcountHelper(n: number, k: number, pos: number, mask: number, result: number[]): void {\n  if (k === 0) {\n    result.push(mask);\n    return;\n  }\n  if (pos + k > n) return; // Not enough positions left\n  // Set bit at position pos\n  generateByPopcountHelper(n, k - 1, pos + 1, mask | (1 << pos), result);\n  // Don't set bit at position pos\n  generateByPopcountHelper(n, k, pos + 1, mask, result);\n}\n\nfunction enumerateFreeVarsGeneral(\n  aug: number[][],\n  numCols: number,\n  pivotCol: number[],\n  pivotRow: number[],\n  freeVars: number[],\n  rank: number,\n  p: number\n): number[] | null {\n  const numFree = freeVars.length;\n\n  // Precompute pivot info\n  const pivotRHS: number[] = [];\n  const pivotFreeCoeffs: number[][] = [];\n  for (let i = 0; i < rank; i++) {\n    pivotRHS.push(aug[i][numCols]);\n    const coeffs: number[] = [];\n    for (const fv of freeVars) {\n      coeffs.push(aug[i][fv]);\n    }\n    pivotFreeCoeffs.push(coeffs);\n  }\n\n  let bestSum = Infinity;\n  let bestX: number[] | null = null;\n\n  // Enumerate all assignments of free variables (mixed radix)\n  const freeVals = new Array(numFree).fill(0);\n  const totalAssignments = Math.pow(p, numFree);\n\n  for (let iter = 0; iter < totalAssignments; iter++) {\n    // Compute pivot values\n    let totalSum = 0;\n    const pivotVals: number[] = [];\n    let tooLarge = false;\n\n    // Add free var sum\n    for (let k = 0; k < numFree; k++) {\n      totalSum += freeVals[k];\n    }\n\n    for (let i = 0; i < rank; i++) {\n      let val = pivotRHS[i];\n      for (let k = 0; k < numFree; k++) {\n        val = (val + (p - pivotFreeCoeffs[i][k]) * freeVals[k]) % p;\n      }\n      // In RREF, val = (aug[i][numCols] - sum(aug[i][fv] * freeV