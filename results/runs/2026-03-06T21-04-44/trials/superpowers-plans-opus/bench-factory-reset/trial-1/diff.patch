   // Find pivot row\n    let pivotR = -1;\n    for (let row = currentRow; row < numRows; row++) {\n      if (aug[row][col] !== 0) {\n        pivotR = row;\n        break;\n      }\n    }\n    if (pivotR === -1) continue; // No pivot in this column (free variable)\n\n    // Swap rows\n    if (pivotR !== currentRow) {\n      const tmp = aug[currentRow];\n      aug[currentRow] = aug[pivotR];\n      aug[pivotR] = tmp;\n    }\n\n    // Scale pivot row so pivot element = 1\n    const scale = inv[aug[currentRow][col]];\n    for (let j = col; j <= numCols; j++) {\n      aug[currentRow][j] = (aug[currentRow][j] * scale) % p;\n    }\n\n    // Eliminate all other rows (full reduction to RREF)\n    for (let row = 0; row < numRows; row++) {\n      if (row === currentRow || aug[row][col] === 0) continue;\n      const factor = aug[row][col];\n      for (let j = col; j <= numCols; j++) {\n        aug[row][j] = (aug[row][j] - factor * aug[currentRow][j] % p + p * p) % p;\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = currentRow;\n    currentRow++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency: any row with all-zero coefficients but nonzero b\n  for (let row = rank; row < numRows; row++) {\n    if (aug[row][numCols] !== 0) {\n      return null; // No solution\n    }\n  }\n\n  // Identify free variables\n  const isFree = new Array(numCols).fill(true);\n  for (const col of pivotCol) {\n    isFree[col] = false;\n  }\n  const freeVars: number[] = [];\n  for (let j = 0; j < numCols; j++) {\n    if (isFree[j]) freeVars.push(j);\n  }\n\n  const numFree = freeVars.length;\n\n  // For each assignment of free variables, compute the full solution via back-substitution\n  // and track the one with minimum sum, then lex-smallest.\n\n  // With RREF, each pivot variable x_{pivotCol[i]} = aug[i][numCols] - sum(aug[i][j] * x_j for free j)\n\n  // For GF(2) with many free variables, we need to be smart.\n  // For GF(p>2) with many free variables, enumeration