+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+describe('solveToggle', () => {
+  it('should return empty array when target is all false', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should return null when no solution exists (TASK.md example)', () => {
+    // From TASK.md: target [T,T,F,T] with buttons [0,1], [1,2,3], [0,3]
+    // System: b0 XOR b2 = 1, b0 XOR b1 = 1, b1 = 0, b1 XOR b2 = 1
+    // b1=0, b0=1, b2=0, but check: b1 XOR b2 = 0 != 1 => no solution
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should solve a simple 1-button 1-light case', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should solve a simple case with 2 buttons', () => {
+    // 2 lights, 2 buttons
+    // Button 0 toggles light 0
+    // Button 1 toggles light 1
+    // Target: [true, true]
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('should find minimum presses solution', () => {
+    // 2 lights, 3 buttons
+    // Button 0 toggles [0, 1]
+    // Button 1 toggles [0]
+    // Button 2 toggles [1]
+    // Target: [true, true]
+    // Solutions: {0} (1 press), {1,2} (2 presses)
+    // Should return [0]
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should return lexicographically smallest when tied on presses', () => {
+    // 1 light, 2 buttons that both toggle light 0
+    // Target: [true]
+    // Solutions: {0} or {1}, both 1 press
+    // Should return [0] (lex smallest)
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should return null when no buttons available but target not all off', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should handle overlapping buttons', () => {
+    // 3 lights, 2 buttons
+    // Button 0 toggles [0, 1, 2]
+    // Button 1 toggles [1, 2]
+    // Target: [true, false, false]
+    // b0=1, b1=1: light0 = 1, light1 = 1^1=0, light2 = 1^1=0 => [T,F,F] ✓
+    const machine: Machine = {
+      target: [true, false, false],
+      buttons: [[0, 1, 2], [1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('should handle a case where pressing no buttons is wrong but 1 is enough', () => {
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0, 1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should handle larger cases efficiently (20 buttons, 20 lights)', () => {
+    // Each button toggles only its own light
+    const numLights = 20;
+    const target = new Array(numLights).fill(true);
+    const buttons: number[][] = [];
+    for (let i = 0; i < numLights; i++) {
+      buttons.push([i]);
+    }
+    const machine: Machine = { target, buttons };
+    const result = solveToggle(machine);
+    expect(result).toEqual(Array.from({ length: numLights }, (_, i) => i));
+  });
+
+  it('should handle case where only some lights need toggling', () => {
+    const machine: Machine = {
+      target: [true, false, true, false],
+      buttons: [[0], [1], [2], [3]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 2]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return all zeros when target is all zero', () => {
+    expect(solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5)).toEqual([0, 0]);
+  });
+
+  it('should solve a simple 1-button 1-counter case', () => {
+    // Counter 0, target=3, button 0 affects counter 0, mod 5
+    // Press button 0 three times
+    expect(solveCounter([3], [[0]], 5)).toEqual([3]);
+  });
+
+  it('should return null when no buttons but target not zero', () => {
+    expect(solveCounter([1], [], 5)).toBeNull();
+  });
+
+  it('should solve with modulus 2 (equivalent to toggle)', () => {
+    // 2 counters, 2 buttons, mod 2
+    // Button 0 affects counter 0
+    // Button 1 affects counter 1
+    // Target: [1, 1]
+    expect(solveCounter([1, 1], [[0], [1]], 2)).toEqual([1, 1]);
+  });
+
+  it('should find minimum total presses', () => {
+    // 1 counter, 1 button, mod 5, target=3
+    // Options: press 3 times (sum=3) or press 8 times (impossible since max is 4)
+    // Only option: 3
+    expect(solveCounter([3], [[0]], 5)).toEqual([3]);
+  });
+
+  it('should find minimum total presses with multiple solutions', () => {
+    // 1 counter, 2 buttons both affecting counter 0, mod 5, target=1
+    // Solutions: (1,0) sum=1, (0,1) sum=1, (2,4) sum=6, (3,3) sum=6, (4,2) sum=6
+    // Minimum sum = 1, lex smallest = [0,1]
+    // Wait: (1,0) = [1,0], (0,1) = [0,1]
+    // Lex smallest: [0,1] < [1,0]
+    expect(solveCounter([1], [[0], [0]], 5)).toEqual([0, 1]);
+  });
+
+  it('should return null when no solution exists', () => {
+    // 2 counters, 1 button that affects both, mod 3, target=[1, 2]
+    // Pressing button x times: counter0 = x mod 3, counter1 = x mod 3
+    // Need x=1 and x=2 simultaneously — impossible
+    expect(solveCounter([1, 2], [[0, 1]], 3)).toBeNull();
+  });
+
+  it('should handle larger modulus', () => {
+    // mod 97, 1 counter, 1 button
+    expect(solveCounter([50], [[0]], 97)).toEqual([50]);
+  });
+
+  it('should handle multiple buttons and counters', () => {
+    // 3 counters, 3 buttons, mod 3
+    // Button 0 affects [0]
+    // Button 1 affects [1]
+    // Button 2 affects [2]
+    // Target: [1, 2, 1]
+    expect(solveCounter([1, 2, 1], [[0], [1], [2]], 3)).toEqual([1, 2, 1]);
+  });
+
+  it('should handle overlapping buttons with modular arithmetic', () => {
+    // 2 counters, 2 buttons, mod 3
+    // Button 0 affects [0, 1]
+    // Button 1 affects [1]
+    // Target: [1, 0]
+    // b0 = 1 (mod 3) for counter 0
+    // b0 + b1 = 0 (mod 3) for counter 1 => 1 + b1 = 0 => b1 = 2
+    // Total: 1 + 2 = 3
+    expect(solveCounter([1, 0], [[0, 1], [1]], 3)).toEqual([1, 2]);
+  });
+
+  it('should handle case where 0 presses is optimal for some buttons', () => {
+    // 2 counters, 2 buttons, mod 5
+    // Button 0 affects [0]
+    // Button 1 affects [1]
+    // Target: [3, 0]
+    expect(solveCounter([3, 0], [[0], [1]], 5)).toEqual([3, 0]);
+  });
+});
