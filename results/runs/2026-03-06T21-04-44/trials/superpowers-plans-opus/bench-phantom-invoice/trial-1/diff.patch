5', total: 200 },\n      { date: '2024-02-15', total: 300 },\n      { date: '2024-03-10', total: 400 },\n      { date: '2024-03-20', total: 150 },\n    ];\n    data.forEach(({ date, total }) => {\n      createInvoice(db, {\n        customer_id: 'cust-1',\n        date,\n        subtotal: total,\n        discount_rate: 0,\n        tax_rate: 0,\n        total,\n        status: 'paid',\n      });\n    });\n  });\n\n  it('generates monthly report with correct counts', () => {\n    const report = getMonthlyReport(db, 2024);\n    expect(report).toHaveLength(3);\n    expect(report[0].count).toBe(2); // January\n    expect(report[1].count).toBe(1); // February\n    expect(report[2].count).toBe(2); // March\n  });\n\n  it('generates monthly report with correct totals', () => {\n    const report = getMonthlyReport(db, 2024);\n    expect(report[0].total_revenue).toBe(300); // Jan: 100 + 200\n    expect(report[1].total_revenue).toBe(300); // Feb: 300\n    expect(report[2].total_revenue).toBe(550); // Mar: 400 + 150\n  });\n\n  it('returns empty report for year with no invoices', () => {\n    const report = getMonthlyReport(db, 2025);\n    expect(report).toHaveLength(0);\n  });\n\n  it('groups invoices correctly at month boundaries', () => {\n    // Add invoices at exact month boundaries\n    createInvoice(db, {\n      customer_id: 'cust-2',\n      date: '2024-01-31',\n      subtotal: 50, discount_rate: 0, tax_rate: 0, total: 50, status: 'paid',\n    });\n    createInvoice(db, {\n      customer_id: 'cust-2',\n      date: '2024-02-01',\n      subtotal: 75, discount_rate: 0, tax_rate: 0, total: 75, status: 'paid',\n    });\n\n    const report = getMonthlyReport(db, 2024);\n    const jan = report.find(r => r.month === 1)!;\n    const feb = report.find(r => r.month === 2)!;\n\n    // Jan should have 3 invoices (10th, 25th, 31st) = 100 + 200 + 50 = 350\n    expect(jan.count).toBe(3);\n    expect(jan.total_revenue).toBe(350);\n\n    // Feb should have 2 invoices (15th, 1st) = 300 + 75