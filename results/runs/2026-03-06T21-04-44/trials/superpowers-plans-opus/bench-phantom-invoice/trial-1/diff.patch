eves an invoice by ID', () => {\n    const id = createInvoice(db, {\n      customer_id: 'cust-1',\n      date: '2024-03-15',\n      subtotal: 200,\n      discount_rate: 0.1,\n      tax_rate: 0.08,\n      total: 194.40,\n      status: 'sent',\n    });\n    const invoice = getInvoiceById(db, id);\n    expect(invoice).toBeDefined();\n    expect(invoice!.customer_id).toBe('cust-1');\n    expect(invoice!.subtotal).toBe(200);\n  });\n\n  it('returns undefined for non-existent invoice', () => {\n    const invoice = getInvoiceById(db, 999);\n    expect(invoice).toBeUndefined();\n  });\n\n  it('creates an invoice with line items', () => {\n    const id = createInvoice(db, {\n      customer_id: 'cust-2',\n      date: '2024-04-01',\n      subtotal: 250,\n      discount_rate: 0,\n      tax_rate: 0.05,\n      total: 262.50,\n      status: 'draft',\n      line_items: [\n        { description: 'Widget A', quantity: 5, unit_price: 30 },\n        { description: 'Widget B', quantity: 2, unit_price: 50 },\n      ],\n    });\n    const invoice = getInvoiceById(db, id);\n    expect(invoice!.line_items).toHaveLength(2);\n    expect(invoice!.line_items[0].description).toBe('Widget A');\n  });\n\n  it('lists invoices by customer', () => {\n    createInvoice(db, {\n      customer_id: 'cust-A',\n      date: '2024-01-10',\n      subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'paid',\n    });\n    createInvoice(db, {\n      customer_id: 'cust-B',\n      date: '2024-01-12',\n      subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'paid',\n    });\n    createInvoice(db, {\n      customer_id: 'cust-A',\n      date: '2024-02-05',\n      subtotal: 150, discount_rate: 0, tax_rate: 0, total: 150, status: 'draft',\n    });\n\n    const invoices = getInvoicesByCustomer(db, 'cust-A');\n    expect(invoices).toHaveLength(2);\n    expect(invoices.every(inv => inv.customer_id === 'cust-A')).toBe(true);\n  });\n\n  it('returns invoices sorted by date', () => {\n    createInvoice(db, {\n      customer_id: 'cust-1',\n      date: '2024-03-15',\n      subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'draft',\n    });\n    createInvoice(db, {\n      customer_id: 'cust-1',\n      date: '2024-01-10',\n      subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'draft',\n    });\n    createInvoice(db, {\n      customer_id: 'cust-1',\n      date: '2024-02-20',\n      subtotal: 150, discount_rate: 0, tax_rate: 0, total: 150, status: 'draft',\n    });\n\n    const invoices = getInvoicesByDateRange(db, '2024-01-01', '2024-12-31');\n    expect(invoices[0].date).toBe('2024-01-10');\n    expect(invoices[1].date).toBe('2024-02-20');\n    expect(invoices[2].date).toBe('2024-03-15');\n  });\n\n  it('stores invoice status correctly', () => {\n    const id = createInvoice(db, {\n      customer_id: 'cust-1',\n      date: '2024-06-01',\n      subtotal: 500, discount_rate: 0.05, tax_rate: 0.1, total: 522.50,\n      status: 'paid',\n    });\n    const invoice = getInvoiceById(db, id);\n    expect(invoice!.status).toBe('paid');\n  });\n\n  it('calculates subtotal from line items', () => {\n    const items = [\n      { description: 'Item A', quantity: 3, unit_price: 10 },\n      { description: 'Item B', quantity: 1, unit_price: 25.50 },\n      { description: 'Item C', quantity: 2, unit_price: 7.25 },\n    ];\n    expect(calculateSubtotal(items)).toBe(70);\n  });\n});\n\n// ─── Billing Calculations (8 tests) ────────────────────────────────\n\ndescribe('Billing Calculations', () => {\n  it('calculates total without discount', () => {\n    // subtotal=100, no discount, 10% tax => 110\n    const total = calculateInvoiceTotal(100, 0, 0.1);\n    expect(total).toBe(110);\n  });\n\n  it('calculates total with 10% discount', () => {\n    // subtotal=200, 10% discount => 180, then 8% tax => 194.40\n    const total = calculateInvoiceTotal(200, 0.1, 0.08);\n    expect(total).toBe(194.40);\n  });\n\n  it('calculates total with 25% discount and 8% tax', () => {\n    // subtotal=400, 25% discount => 300, 8% tax => 324\n    const total = calculateInvoiceTotal(400, 0.25, 0.08);\n    expect(total).toBe(324);\n  });\n\n  it('applies discount correctly', () => {\n    expect(applyDiscount(200, 0.15)).toBe(170);\n  });\n\n  it('handles zero tax rate', () => {\n    const total = calculateInvoiceTotal(500, 0.2, 0);\n    expect(total).toBe(400);\n  });\n\n  it('handles zero subtotal', () => {\n    const total = calculateInvoiceTotal(0, 0.1, 0.08);\n    expect(total).toBe(0);\n  });\n\n  it('generates invoice with correct total', () => {\n    const id = generateInvoice(db, {\n      customer_id: 'cust-1',\n      date: '2024-05-10',\n      discount_rate: 0,\n      tax_rate: 0.08,\n      line_items: [\n        { description: 'Service', quantity: 1, unit_price: 1000 },\n      ],\n    });\n    const invoice = getInvoiceById(db, id);\n    // 1000 * 1.0 * 1.08 = 1080\n    expect(invoice!.total).toBe(1080);\n  });\n\n  it('generates invoice with multiple line items and discount', () => {\n    const id = generateInvoice(db, {\n      customer_id: 'cust-2',\n      date: '2024-07-20',\n      discount_rate: 0.15,\n      tax_rate: 0,\n      line_items: [\n        { description: 'Product A', quantity: 10, unit_price: 50 },\n        { description: 'Product B', quantity: 5, unit_price: 100 },\n      ],\n    });\n    const invoice = getInvoiceById(db, id);\n    // subtotal = 500 + 500 = 1000\n    // discounted = 1000 * 0.85 = 850\n    // total = 850 * 1.0 = 850\n    expect(invoice!.total).toBe(850);\n  });\n});\n\n// ─── Date Range Queries (7 tests) ──────────────────────────────────\n\ndescribe('Date Range Queries', () => {\n  beforeEach(() => {\n    // Seed some invoices across different dates\n    const dates = [\n      '2024-01-15', '2024-01-31', '2024-02-01',\n      '2024-02-28', '2024-03-01', '2024-03-31',\n      '2024-06-30',\n    ];\n    dates.forEach((date, i) => {\n      createInvoice(db, {\n        customer_id: `cust-${i}`,