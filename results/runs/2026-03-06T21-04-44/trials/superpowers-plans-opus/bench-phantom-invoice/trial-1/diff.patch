      customer_id: 'cust-1', date: '2024-04-15',\n      subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'paid',\n    });\n    createInvoice(db, {\n      customer_id: 'cust-1', date: '2024-05-15',\n      subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'paid',\n    });\n    createInvoice(db, {\n      customer_id: 'cust-1', date: '2024-06-15',\n      subtotal: 300, discount_rate: 0, tax_rate: 0, total: 300, status: 'paid',\n    });\n\n    const report = getMonthlyReport(db, 2024);\n    expect(report).toHaveLength(3);\n    expect(report[0].month).toBe(4);\n    expect(report[1].month).toBe(5);\n    expect(report[2].month).toBe(6);\n    expect(report[0].total_revenue).toBe(100);\n    expect(report[1].total_revenue).toBe(200);\n    expect(report[2].total_revenue).toBe(300);\n  });\n\n  it('zero discount rate still calculates correctly', () => {\n    // subtotal=1000, 0% discount => 1000, 7% tax => 1070\n    const total = calculateInvoiceTotal(1000, 0, 0.07);\n    expect(total).toBe(1070);\n  });\n\n  it('100% discount rate results in zero total', () => {\n    const total = calculateInvoiceTotal(500, 1.0, 0.1);\n    expect(total).toBe(0);\n  });\n\n  it('formatDate produces correct ISO string', () => {\n    const date = new Date(Date.UTC(2024, 5, 15)); // June 15, 2024\n    expect(formatDate(date)).toBe('2024-06-15');\n  });\n\n  it('large invoice totals maintain precision', () => {\n    // subtotal=99999.99, 5% discount => 94999.9905, 10% tax => 104499.98955 => 104499.99\n    const total = calculateInvoiceTotal(99999.99, 0.05, 0.1);\n    expect(total).toBe(104499.99);\n  });\n\n  it('date range with single day span returns matching invoices', () => {\n    createInvoice(db, {\n      customer_id: 'cust-1',\n      date: '2024-09-15',\n      subtotal: 100, discount_rate: 0, tax_rate: 0, total: 100, status: 'paid',\n    });\n    createInvoice(db, {\n      customer_id: 'cust-1',\n      date: '2024-09-16',\n      subtotal: 200, discount_rate: 0, tax_rate: 0, total: 200, status: 'paid',\n    });\n\n    // Single day range should only include the one on that day\n    const invoices = getInvoicesByDateRange(db, '2024-09-15', '2024-09-15');\n    expect(invoices).toHaveLength(1);\n    expect(invoices[0].date).toBe('2024-09-15');\n  });\n});\n","numLines":123,"startLine":1,"totalLines":123}}}
