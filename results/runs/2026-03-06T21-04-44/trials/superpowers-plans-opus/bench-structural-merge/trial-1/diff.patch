+      merged[id] = result;
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      // Apply deletions
+      for (const id of deletedIds) {
+        const doc = targetDocs.get(id);
+        if (doc) {
+          doc.deleted = true;
+        }
+      }
+
+      // Apply merge to current branch
+      for (const [id, content] of Object.entries(merged)) {
+        const existing = targetDocs.get(id);
+        if (existing && !existing.deleted) {
+          // Check if content actually changed
+          if (JSON.stringify(existing.content) !== JSON.stringify(content)) {
+            existing.content = deepClone(content);
+            const version: Version = {
+              id: generateId(),
+              timestamp: Date.now(),
+              content: deepClone(content),
+            };
+            existing.versions.push(version);
+          }
+        } else {
+          // New document from source branch
+          const version: Version = {
+            id: generateId(),
+            timestamp: Date.now(),
+            content: deepClone(content),
+          };
+          targetDocs.set(id, {
+            content: deepClone(content),
+            versions: [version],
+            deleted: false,
+          });
+        }
+      }
+    }
+
+    return { merged, conflicts, applied };
+  }
+}
+
+export { DocumentStore, Version, Conflict, MergeResult };
