= [];\n\n    // Collect all document IDs across base, source, target\n    const allIds = new Set<string>();\n    for (const id of baseDocs.keys()) allIds.add(id);\n    for (const id of sourceDocs.keys()) allIds.add(id);\n    for (const id of targetDocs.keys()) allIds.add(id);\n\n    for (const id of allIds) {\n      const baseDoc = baseDocs.get(id);\n      const sourceDoc = sourceDocs.get(id);\n      const targetDoc = targetDocs.get(id);\n\n      const baseExists = baseDoc && !baseDoc.deleted;\n      const sourceExists = sourceDoc && !sourceDoc.deleted;\n      const targetExists = targetDoc && !targetDoc.deleted;\n\n      // Document created only on source (not in base, not in target)\n      if (!baseDoc && sourceExists && !targetDoc) {\n        merged[id] = deepClone(sourceDoc!.content);\n        continue;\n      }\n\n      // Document created only on target (not in base, not in source)\n      if (!baseDoc && !sourceDoc && targetExists) {\n        merged[id] = deepClone(targetDoc!.content);\n        continue;\n      }\n\n      // Document deleted on source, unchanged on target\n      if (baseExists && !sourceExists && targetExists) {\n        const targetChanges = getChanges(baseDoc!.content, targetDoc!.content);\n        if (targetChanges.size === 0) {\n          // target unchanged, accept delete\n          merged[id] = deepClone(baseDoc!.content); // show base in merged\n          continue;\n        }\n      }\n\n      // Document deleted on target, unchanged on source\n      if (baseExists && sourceExists && !targetExists) {\n        merged[id] = deepClone(sourceDoc!.content);\n        continue;\n      }\n\n      // Both exist - perform field-level three-way merge\n      if (!baseExists && !sourceExists && !targetExists) continue;\n      if (!sourceExists && !targetExists) continue;\n\n      const baseContent = baseExists ? baseDoc!.content : {};\n      const sourceContent = sourceExists ? sourceDoc!.content : {};\n      const targetContent = targetExists ? targetDoc!.content : {};\n\n      const sourceChanges = getChanges(baseContent, sourceContent);\n      const targetChanges = getChanges(baseContent, targetContent);\n\n      // If no changes on either side for this doc, skip\n      if (sourceChanges.size === 0 && targetChanges.size === 0) continue;\n\n      const result = deepClone(targetContent);\n\n      // Apply source changes\n      for (const [path, { newVal }] of sourceChanges) {\n        const targetChange = targetChanges.get(path);\n        if (!targetChange) {\n          // Only source changed this path - apply it\n          if (newVal === undefined) {\n            deleteAtPath(result, path);\n          } else {\n            setAtPath(result, path, deepClone(newVal));\n          }\n        } else {\n          // Both changed\n          if (JSON.stringify(targetChange.newVal) === JSON.stringify(newVal)) {\n            // Same value - no conflict\n          } else {\n            // Conflict! merged uses \"ours\" (target), so no change to result\n            conflicts.push({\n              documentId: id,\n              path,\n              base: getAtPath(baseContent, path),\n              ours: deepClone(targetChange.newVal),\n              theirs: deepClone(newVal),\n            });\n          }\n        }\n      }\n\n      merged[id] = result;\n    }\n\n    const applied = conflicts.length === 0;\n\n    if (applied) {\n      // Apply merge to current branch\n      for (const [id, content] of Object.entries(merged)) {\n        const baseDoc = baseDocs.get(id);\n        const sourceDoc = sourceDocs.get(id);\n        const sourceExists = sourceDoc && !sourceDoc.deleted;\n        const baseExists = baseDoc && !baseDoc.deleted;\n\n        // Handle deletion case\n        if (baseExists && !sourceExists) {\n          const doc = targetDocs.get(id);\n          if (doc) {\n            doc.deleted = true;\n          }\n          continue;\n        }\n\n        const existing = targetDocs.get(id);\n        if (existing && !existing.deleted) {\n          existing.content = deepClone(content);\n          const version: Version = {\n            id: generateId(),\n            timestamp: Date.now(),\n            content: deepClone(content),\n          };\n          existing.versions.push(version);\n        } else {\n          const version: Version = {\n            id: generateId(),\n            timestamp: Date.now(),\n            content: deepClone(content),\n          };\n          targetDocs.set(id, {\n            content: deepClone(content),\n            versions: [version],\n            deleted: false,\n          });\n        }\n      }\n    }\n\n    return { merged, conflicts, applied };\n  }\n```\n\n**Step 3: Run all tests**\n\nRun: `npx vitest run`\nExpected: ALL PASS\n\n---\n\n### Task 6: Build, Lint, Final Verification\n\n**Step 1: Run build**\n\nRun: `npx tsc`\nExpected: No errors\n\n**Step 2: Run lint**\n\nRun: `npm run lint`\nExpected: No errors\n\n**Step 3: Run all tests**\n\nRun: `npm test`\nExpected: ALL PASS\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":119,"cache_read_input_tokens":20618,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":119},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0f83969c-3632-4c03-b91e-7716ffdd67bb","uuid":"14b2dec9-79cf-4258-901a-1c116bcd3826"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012GdZieeppn1RdjeJkUQwLU","type":"tool_result","content":"File created successfully at: /workspace/docs/plans/2026-03-06-versioned-document-store.md"}]},"parent_tool_use_id":null,"session_id":"0f83969c-3632-4c03-b91e-7716ffdd67bb","uuid":"65355e0e-c860-46a8-be9a-84a2a68741f6","tool_use_result":{"type":"create","filePath":"/workspace/docs/plans/2026-03-06-versioned-document-store.md","content":"# Versioned Document Store Implementation Plan\n\n> **For Claude:** REQUIRED SUB-SKILL: Use superpowers:executing-plans to implement this plan task-by-task.\n\n**Goal:** Build an in-memory versioned document store (\"Git for JSON documents\") with CRUD, version history, branching, and three-way structural merge.\n\n**Architecture:** Single `DocumentStore` class backed by per-branch maps of documents. Each branch stores a `Map<docId, Document>` where `Document` tracks current content, version history, and deleted status. Three-way merge computes diffs from common ancestor (branch-point snapshot) against both branches, detecting field-level conflicts via recursive deep diff.\n\n**Tech Stack:** TypeScript 5.4, Vitest 2.0, Node16 ESM\n\n---\n\n### Task 1: Core Types & DocumentStore Skeleton\n\n**Files:**\n- Create: `src/index.ts`\n- Test: `src/__tests__/crud.test.ts`\n\n**Step 1: Write failing tests for create & get**\n\n```typescript\n// src/__tests__/crud.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { DocumentStore } from '../index';\n\ndescribe('DocumentStore CRUD', () => {\n  it('should create and get a document', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { title: 'Hello' });\n    expect(store.get('doc1')).toEqual({ title: 'Hello' });\n  });\n\n  it('should throw when creating a duplicate id', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { title: 'Hello' });\n    expect(() => store.create('doc1', { title: 'World' })).toThrow();\n  });\n\n  it('should throw when getting a non-existent document', () => {\n    const store = new DocumentStore();\n    expect(() => store.get('missing')).toThrow();\n  });\n\n  it('should deep clone on create and get (no mutation leaking)', () => {\n    const store = new DocumentStore();\n    const original = { nested: { value: 1 } };\n    store.create('doc1', original);\n    original.nested.value = 999;\n    const retrieved = store.get('doc1') as any;\n    expect(retrieved.nested.value).toBe(1);\n    retrieved.nested.value = 888;\n    expect((store.get('doc1') as any).nested.value).toBe(1);\n  });\n});\n```\n\n**Step 2: Run tests to verify they fail**\n\nRun: `npx vitest run src/__tests__/crud.test.ts`\nExpected: FAIL - module not found\n\n**Step 3: Write minimal implementation**\n\n```typescript\n// src/index.ts\n\ninterface Version {\n  id: string;\n  timestamp: number;\n  content: object;\n}\n\ninterface Conflict {\n  documentId: string;\n  path: string;\n  base: any;\n  ours: any;\n  theirs: any;\n}\n\ninterface MergeResult {\n  merged: Record<string, object>;\n  conflicts: Conflict[];\n  applied: boolean;\n}\n\ninterface Document {\n  content: object;\n  versions: Version[];\n  deleted: boolean;\n}\n\nfunction deepClone<T>(obj: T): T {\n  return JSON.parse(JSON.stringify(obj));\n}\n\nfunction generateId(): string {\n  return Math.random().toString(36).substring(2) + Date.now().toString(36);\n}\n\nclass DocumentStore {\n  private branches: Map<string, Map<string, Document>> = new Map();\n  private currentBranch: string = 'main';\n  private branchPoints: Map<string, Map<string, Document>> = new Map();\n\n  constructor() {\n    this.branches.set('main', new Map());\n  }\n\n  private getCurrentDocs(): Map<string, Document> {\n    return this.branches.get(this.currentBranch)!;\n  }\n\n  create(id: string, content: object): void {\n    const docs = this.getCurrentDocs();\n    if (docs.has(id) && !docs.get(id)!.deleted) {\n      throw new Error(`Document '${id}' already exists`);\n    }\n    const version: Version = {\n      id: generateId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n    docs.set(id, {\n      content: deepClone(content),\n      versions: [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const docs = this.getCurrentDocs();\n    const doc = docs.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    return deepClone(doc.content);\n  }\n\n  update(id: string, content: object): void {\n    throw new Error('Not implemented');\n  }\n\n  delete(id: string): void {\n    throw new Error('Not implemented');\n  }\n\n  getHistory(id: string): Version[] {\n    throw new Error('Not implemented');\n  }\n\n  getVersion(id: string, versionId: string): object {\n    throw new Error('Not implemented');\n  }\n\n  createBranch(name: string, fromBranch?: string): void {\n    throw new Error('Not implemented');\n  }\n\n  switchBranch(name: string): void {\n    throw new Error('Not implemented');\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    throw new Error('Not implemented');\n  }\n\n  merge(sourceBranch: string): MergeResult {\n    throw new Error('Not implemented');\n  }\n}\n\nexport { DocumentStore, Version, Conflict, MergeResult };\n```\n\n**Step 4: Run tests to verify they pass**\n\nRun: `npx vitest run src/__tests__/crud.test.ts`\nExpected: PASS\n\n---\n\n### Task 2: Update & Delete\n\n**Files:**\n- Modify: `src/index.ts`\n- Modify: `src/__tests__/crud.test.ts`\n\n**Step 1: Add failing tests for update & delete**\n\n```typescript\n// Append to crud.test.ts describe block:\n\n  it('should update a document', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { title: 'v1' });\n    store.update('doc1', { title: 'v2' });\n    expect(store.get('doc1')).toEqual({ title: 'v2' });\n  });\n\n  it('should throw when updating non-existent document', () => {\n    const store = new DocumentStore();\n    expect(() => store.update('missing', { x: 1 })).toThrow();\n  });\n\n  it('should delete a document', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { title: 'Hello' });\n    store.delete('doc1');\n    expect(() => store.get('doc1')).toThrow();\n  });\n\n  it('should throw when deleting non-existent document', () => {\n    const store = new DocumentStore();\n    expect(() => store.delete('missing')).toThrow();\n  });\n\n  it('should deep clone on update', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { val: 1 });\n    const obj = { val: 2 };\n    store.update('doc1', obj);\n    obj.val = 999;\n    expect((store.get('doc1') as any).val).toBe(2);\n  });\n```\n\n**Step 2: Implement update & delete in src/index.ts**\n\n```typescript\n  update(id: string, content: object): void {\n    const docs = this.getCurrentDocs();\n    const doc = docs.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    const version: Version = {\n      id: generateId(),\n      timestamp: Date.now(),\n      content: deepClone(content),\n    };\n    doc.content = deepClone(content);\n    doc.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const docs = this.getCurrentDocs();\n    const doc = docs.get(id);\n    if (!doc || doc.deleted) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    doc.deleted = true;\n  }\n```\n\n**Step 3: Run tests**\n\nRun: `npx vitest run src/__tests__/crud.test.ts`\nExpected: PASS\n\n---\n\n### Task 3: Version History\n\n**Files:**\n- Modify: `src/index.ts`\n- Create: `src/__tests__/versioning.test.ts`\n\n**Step 1: Write failing tests**\n\n```typescript\n// src/__tests__/versioning.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { DocumentStore } from '../index';\n\ndescribe('Version History', () => {\n  it('should return versions in chronological order', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { v: 1 });\n    store.update('doc1', { v: 2 });\n    store.update('doc1', { v: 3 });\n    const history = store.getHistory('doc1');\n    expect(history).toHaveLength(3);\n    expect(history[0].content).toEqual({ v: 1 });\n    expect(history[1].content).toEqual({ v: 2 });\n    expect(history[2].content).toEqual({ v: 3 });\n    expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);\n  });\n\n  it('should retrieve a specific version by id', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { v: 1 });\n    store.update('doc1', { v: 2 });\n    const history = store.getHistory('doc1');\n    const firstVersionContent = store.getVersion('doc1', history[0].id);\n    expect(firstVersionContent).toEqual({ v: 1 });\n  });\n\n  it('should throw for non-existent document history', () => {\n    const store = new DocumentStore();\n    expect(() => store.getHistory('missing')).toThrow();\n  });\n\n  it('should throw for non-existent version id', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { v: 1 });\n    expect(() => store.getVersion('doc1', 'bad-id')).toThrow();\n  });\n\n  it('should deep clone version content', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { val: 1 });\n    const history = store.getHistory('doc1');\n    (history[0].content as any).val = 999;\n    expect((store.getHistory('doc1')[0].content as any).val).toBe(1);\n  });\n});\n```\n\n**Step 2: Implement getHistory & getVersion**\n\n```typescript\n  getHistory(id: string): Version[] {\n    const docs = this.getCurrentDocs();\n    const doc = docs.get(id);\n    if (!doc) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    return doc.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const docs = this.getCurrentDocs();\n    const doc = docs.get(id);\n    if (!doc) {\n      throw new Error(`Document '${id}' not found`);\n    }\n    const version = doc.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version '${versionId}' not found for document '${id}'`);\n    }\n    return deepClone(version.content);\n  }\n```\n\n**Step 3: Run tests**\n\nRun: `npx vitest run src/__tests__/versioning.test.ts`\nExpected: PASS\n\n---\n\n### Task 4: Branching\n\n**Files:**\n- Modify: `src/index.ts`\n- Create: `src/__tests__/branching.test.ts`\n\n**Step 1: Write failing tests**\n\n```typescript\n// src/__tests__/branching.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { DocumentStore } from '../index';\n\ndescribe('Branching', () => {\n  it('should default to main branch', () => {\n    const store = new DocumentStore();\n    expect(store.getBranch()).toBe('main');\n  });\n\n  it('should create and switch to a new branch', () => {\n    const store = new DocumentStore();\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    expect(store.getBranch()).toBe('feature');\n  });\n\n  it('should list all branches', () => {\n    const store = new DocumentStore();\n    store.createBranch('dev');\n    store.createBranch('staging');\n    expect(store.listBranches().sort()).toEqual(['dev', 'main', 'staging']);\n  });\n\n  it('should isolate changes between branches', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { val: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { val: 2 });\n    expect((store.get('doc1') as any).val).toBe(2);\n    store.switchBranch('main');\n    expect((store.get('doc1') as any).val).toBe(1);\n  });\n\n  it('should copy documents when branching', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { val: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    expect(store.get('doc1')).toEqual({ val: 1 });\n  });\n\n  it('should create branch from a specified branch', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { val: 1 });\n    store.createBranch('dev');\n    store.switchBranch('dev');\n    store.update('doc1', { val: 2 });\n    store.switchBranch('main');\n    store.createBranch('from-dev', 'dev');\n    store.switchBranch('from-dev');\n    expect((store.get('doc1') as any).val).toBe(2);\n  });\n\n  it('should throw when creating duplicate branch', () => {\n    const store = new DocumentStore();\n    store.createBranch('dev');\n    expect(() => store.createBranch('dev')).toThrow();\n  });\n\n  it('should throw when switching to non-existent branch', () => {\n    const store = new DocumentStore();\n    expect(() => store.switchBranch('nonexistent')).toThrow();\n  });\n\n  it('should not share version history references between branches', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { val: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { val: 2 });\n    const featureHistory = store.getHistory('doc1');\n    store.switchBranch('main');\n    const mainHistory = store.getHistory('doc1');\n    expect(featureHistory).toHaveLength(2);\n    expect(mainHistory).toHaveLength(1);\n  });\n});\n```\n\n**Step 2: Implement branching**\n\nKey implementation: `createBranch` deep-clones all documents from the source branch into the new branch. Also stores a \"branch point\" snapshot for merge base computation.\n\n```typescript\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch '${name}' already exists`);\n    }\n    const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.branches.get(sourceName);\n    if (!source) {\n      throw new Error(`Branch '${sourceName}' not found`);\n    }\n    const newDocs = new Map<string, Document>();\n    for (const [id, doc] of source) {\n      newDocs.set(id, deepClone(doc));\n    }\n    this.branches.set(name, newDocs);\n    // Store snapshot of source at branch point for merge base\n    const snapshot = new Map<string, Document>();\n    for (const [id, doc] of source) {\n      snapshot.set(id, deepClone(doc));\n    }\n    this.branchPoints.set(name, snapshot);\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch '${name}' not found`);\n    }\n    this.currentBranch = name;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n```\n\n**Step 3: Run tests**\n\nRun: `npx vitest run src/__tests__/branching.test.ts`\nExpected: PASS\n\n---\n\n### Task 5: Three-Way Merge\n\n**Files:**\n- Modify: `src/index.ts`\n- Create: `src/__tests__/merge.test.ts`\n\n**Step 1: Write failing tests for basic merge scenarios**\n\n```typescript\n// src/__tests__/merge.test.ts\nimport { describe, it, expect } from 'vitest';\nimport { DocumentStore } from '../index';\n\ndescribe('Three-Way Merge', () => {\n  it('should merge non-conflicting changes from source into current', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { a: 1, b: 2 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { a: 10, b: 2 }); // changed a\n    store.switchBranch('main');\n    store.update('doc1', { a: 1, b: 20 }); // changed b\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(result.conflicts).toHaveLength(0);\n    expect(result.merged['doc1']).toEqual({ a: 10, b: 20 });\n    expect(store.get('doc1')).toEqual({ a: 10, b: 20 });\n  });\n\n  it('should detect conflicts when both sides change same field differently', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { a: 2 