+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_016KL1L1WirkG3p993hPXAr6","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01QsfAEhSLR6yQt2RxFctKiK","name":"Write","input":{"file_path":"/workspace/src/__tests__/branching.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { DocumentStore } from '../index';\n\ndescribe('Branching', () => {\n  it('should default to main branch', () => {\n    const store = new DocumentStore();\n    expect(store.getBranch()).toBe('main');\n  });\n\n  it('should create and switch to a new branch', () => {\n    const store = new DocumentStore();\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    expect(store.getBranch()).toBe('feature');\n  });\n\n  it('should list all branches', () => {\n    const store = new DocumentStore();\n    store.createBranch('dev');\n    store.createBranch('staging');\n    expect(store.listBranches().sort()).toEqual(['dev', 'main', 'staging']);\n  });\n\n  it('should isolate changes between branches', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { val: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { val: 2 });\n    expect((store.get('doc1') as any).val).toBe(2);\n    store.switchBranch('main');\n    expect((store.get('doc1') as any).val).toBe(1);\n  });\n\n  it('should copy documents when branching', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { val: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    expect(store.get('doc1')).toEqual({ val: 1 });\n  });\n\n  it('should create branch from a specified branch', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { val: 1 });\n    store.createBranch('dev');\n    store.switchBranch('dev');\n    store.update('doc1', { val: 2 });\n    store.switchBranch('main');\n    store.createBranch('from-dev', 'dev');\