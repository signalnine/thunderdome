+import { describe, it, expect } from 'vitest';
+import { DocumentStore } from '../index.js';
+
+describe('Three-Way Merge', () => {
+  it('should merge non-conflicting changes from source into current', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: 1, b: 2 });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { a: 10, b: 2 }); // changed a
+    store.switchBranch('main');
+    store.update('doc1', { a: 1, b: 20 }); // changed b
+    const result = store.merge('feature');
+    expect(result.applied).toBe(true);
+    expect(result.conflicts).toHaveLength(0);
+    expect(result.merged['doc1']).toEqual({ a: 10, b: 20 });
+    expect(store.get('doc1')).toEqual({ a: 10, b: 20 });
+  });
+
+  it('should detect conflicts when both sides change same field differently', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: 1 });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { a: 2 });
+    store.switchBranch('main');
+    store.update('doc1', { a: 3 });
+    const result = store.merge('feature');
+    expect(result.applied).toBe(false);
+    expect(result.conflicts).toHaveLength(1);
+    expect(result.conflicts[0]).toEqual({
+      documentId: 'doc1',
+      path: 'a',
+      base: 1,
+      ours: 3,
+      theirs: 2,
+    });
+    // current branch unchanged
+    expect(store.get('doc1')).toEqual({ a: 3 });
+  });
+
+  it('should not conflict when both sides change to same value', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: 1 });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { a: 42 });
+    store.switchBranch('main');
+    store.update('doc1', { a: 42 });
+    const result = store.merge('feature');
+    expect(result.applied).toBe(true);
+    expect(result.conflicts).toHaveLength(0);
+    expect(result.merged['doc1']).toEqual({ a: 42 });
+  });
+
+  it('should handle only-source-changed (fast-forward-like)', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: 1 });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { a: 2 });
+    store.switchBranch('main');
+    // main unchanged
+    const result = store.merge('feature');
+    expect(result.applied).toBe(true);
+    expect(result.merged['doc1']).toEqual({ a: 2 });
+    expect(store.get('doc1')).toEqual({ a: 2 });
+  });
+
+  it('should handle only-target-changed', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: 1 });
+    store.createBranch('feature');
+    // feature unchanged
+    store.update('doc1', { a: 2 });
+    const result = store.merge('feature');
+    expect(result.applied).toBe(true);
+    expect(result.merged['doc1']).toEqual({ a: 2 });
+  });
+
+  it('should merge multiple documents independently', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { x: 1 });
+    store.create('doc2', { y: 1 });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { x: 10 });
+    store.switchBranch('main');
+    store.update('doc2', { y: 20 });
+    const result = store.merge('feature');
+    expect(result.applied).toBe(true);
+    expect(result.merged['doc1']).toEqual({ x: 10 });
+    expect(result.merged['doc2']).toEqual({ y: 20 });
+  });
+
+  it('should handle deep nested merge without conflict', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: { b: { c: 1, d: 2 } } });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { a: { b: { c: 10, d: 2 } } });
+    store.switchBranch('main');
+    store.update('doc1', { a: { b: { c: 1, d: 20 } } });
+    const result = store.merge('feature');
+    expect(result.applied).toBe(true);
+    expect(result.merged['doc1']).toEqual({ a: { b: { c: 10, d: 20 } } });
+  });
+
+  it('should report deep nested conflict with dot-path', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: { b: { c: 1 } } });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { a: { b: { c: 2 } } });
+    store.switchBranch('main');
+    store.update('doc1', { a: { b: { c: 3 } } });
+    const result = store.merge('feature');
+    expect(result.applied).toBe(false);
+    expect(result.conflicts[0].path).toBe('a.b.c');
+  });
+
+  it('merged field uses ours for conflicts', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: 1, b: 2 });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { a: 10, b: 20 });
+    store.switchBranch('main');
+    store.update('doc1', { a: 100, b: 200 });
+    const result = store.merge('feature');
+    expect(result.applied).toBe(false);
+    // merged uses "ours" for conflicted fields
+    expect(result.merged['doc1']).toEqual({ a: 100, b: 200 });
+  });
+
+  it('should handle document created only on source branch', () => {
+    const store = new DocumentStore();
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.create('doc1', { a: 1 });
+    store.switchBranch('main');
+    const result = store.merge('feature');
+    expect(result.applied).toBe(true);
+    expect(result.merged['doc1']).toEqual({ a: 1 });
+    expect(store.get('doc1')).toEqual({ a: 1 });
+  });
+
+  it('should handle document deleted on source branch', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: 1 });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.delete('doc1');
+    store.switchBranch('main');
+    const result = store.merge('feature');
+    expect(result.applied).toBe(true);
+    expect(() => store.get('doc1')).toThrow();
+  });
+
+  it('should handle new fields added on source', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: 1 });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { a: 1, b: 2 });
+    store.switchBranch('main');
+    const result = store.merge('feature');
+    expect(result.applied).toBe(true);
+    expect(result.merged['doc1']).toEqual({ a: 1, b: 2 });
+  });
+
+  it('should throw when merging non-existent branch', () => {
+    const store = new DocumentStore();
+    expect(() => store.merge('nonexistent')).toThrow();
+  });
+
+  it('should not apply changes when there are conflicts', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: 1, b: 2 });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { a: 10, b: 20 });
+    store.switchBranch('main');
+    store.update('doc1', { a: 100, b: 200 });
+    const result = store.merge('feature');
+    expect(result.applied).toBe(false);
+    // Main should still have its own values (unchanged)
+    expect(store.get('doc1')).toEqual({ a: 100, b: 200 });
+  });
+
+  it('should handle mix of conflicts and non-conflicts across multiple docs', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: 1 });
+    store.create('doc2', { x: 1, y: 1 });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { a: 2 }); // will conflict
+    store.update('doc2', { x: 10, y: 1 }); // no conflict on x
+    store.switchBranch('main');
+    store.update('doc1', { a: 3 }); // conflict
+    store.update('doc2', { x: 1, y: 20 }); // no conflict on y
+    const result = store.merge('feature');
+    expect(result.applied).toBe(false);
+    expect(result.conflicts).toHaveLength(1);
+    expect(result.conflicts[0].documentId).toBe('doc1');
+    // main branch should be unchanged
+    expect(store.get('doc1')).toEqual({ a: 3 });
+    expect(store.get('doc2')).toEqual({ x: 1, y: 20 });
+  });
+
+  it('should handle no-op merge (no changes on either side)', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: 1 });
+    store.createBranch('feature');
+    const result = store.merge('feature');
+    expect(result.applied).toBe(true);
+    expect(result.conflicts).toHaveLength(0);
+    expect(Object.keys(result.merged)).toHaveLength(0);
+  });
+
+  it('should handle fields removed on source branch', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { a: 1, b: 2 });
+    store.createBranch('feature');
+    store.switchBranch('feature');
+    store.update('doc1', { a: 1 }); // removed b
+    store.switchBranch('main');
+    const result = store.merge('feature');
+    expect(result.applied).toBe(true);
+    expect(result.merged['doc1']).toEqual({ a: 1 });
+    expect(store.get('doc1')).toEqual({ a: 1 });
+  });
+});
