+/* eslint-disable @typescript-eslint/no-explicit-any */
+import { describe, it, expect } from 'vitest';
+import { DocumentStore } from '../index.js';
+
+describe('Version History', () => {
+  it('should return versions in chronological order', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { v: 1 });
+    store.update('doc1', { v: 2 });
+    store.update('doc1', { v: 3 });
+    const history = store.getHistory('doc1');
+    expect(history).toHaveLength(3);
+    expect(history[0].content).toEqual({ v: 1 });
+    expect(history[1].content).toEqual({ v: 2 });
+    expect(history[2].content).toEqual({ v: 3 });
+    expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);
+  });
+
+  it('each version should have a unique id', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { v: 1 });
+    store.update('doc1', { v: 2 });
+    const history = store.getHistory('doc1');
+    expect(history[0].id).not.toBe(history[1].id);
+  });
+
+  it('should retrieve a specific version by id', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { v: 1 });
+    store.update('doc1', { v: 2 });
+    const history = store.getHistory('doc1');
+    const firstVersionContent = store.getVersion('doc1', history[0].id);
+    expect(firstVersionContent).toEqual({ v: 1 });
+    const secondVersionContent = store.getVersion('doc1', history[1].id);
+    expect(secondVersionContent).toEqual({ v: 2 });
+  });
+
+  it('should throw for non-existent document history', () => {
+    const store = new DocumentStore();
+    expect(() => store.getHistory('missing')).toThrow();
+  });
+
+  it('should throw for non-existent version id', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { v: 1 });
+    expect(() => store.getVersion('doc1', 'bad-id')).toThrow();
+  });
+
+  it('should throw for non-existent document in getVersion', () => {
+    const store = new DocumentStore();
+    expect(() => store.getVersion('missing', 'any-id')).toThrow();
+  });
+
+  it('should deep clone version content', () => {
+    const store = new DocumentStore();
+    store.create('doc1', { val: 1 });
+    const history = store.getHistory('doc1');
+    (history[0].content as any).val = 999;
+    expect((store.getHistory('doc1')[0].content as any).val).toBe(1);
+  });
+});
diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..3310ce1
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,393 @@
+/* eslint-disable @typescript-eslint/no-explicit-any */
+
+interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+interface Conflict {
+  documentId: string;
+  path: string;
+  base: any;
+  ours: any;
+  theirs: any;
+}
+
+interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface Document {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+let idCounter = 0;
+function generateId(): string {
+  idCounter++;
+  return `v_${idCounter}_${Date.now().toString(36)}`;
+}
+
+// Helper: recursively diff two objects, returning changed paths
+function getChanges(base: any, current: any, prefix: string = ''): Map<string, { oldVal: any; newVal: any }> {
+  const changes = new Map<string, { oldVal: any; newVal: any }>();
+  const allKeys = new Set([...Object.keys(base || {}), ...Object.keys(current || {})]);
+
+  for (const key of allKeys) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    const baseVal = base?.[key];
+    const currVal = current?.[key];
+
+    if (baseVal === currVal) continue;
+
+    if (
+      baseVal !== null && currVal !== null &&
+      baseVal !== undefined && currVal !== undefined &&
+      typeof baseVal === 'object' && typeof currVal === 'object' &&
+      !Array.isArray(baseVal) && !Array.isArray(currVal)
+    ) {
+      const nested = getChanges(baseVal, currVal, path);
+      for (const [p, v] of nested) {
+        changes.set(p, v);
+      }
+    } else if (JSON.stringify(baseVal) !== JSON.stringify(currVal)) {
+      changes.set(path, { oldVal: baseVal, newVal: currVal });
+    }
+  }
+  return changes;
+}
+
+// Helper: set a value at a dot-separated path
+function setAtPath(obj: any, path: string, value: any): void {
+  const parts = path.split('.');
+  let current = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (current[parts[i]] === undefined || typeof current[parts[i]] !== 'object') {
+      current[parts[i]] = {};
+    }
+    current = current[parts[i]];
+  }
+  current[parts[parts.length - 1]] = value;
+}
+
+// Helper: get a value at a dot-separated path
+function getAtPath(obj: any, path: string): any {
+  const parts = path.split('.');
+  let current = obj;
+  for (const part of parts) {
+    if (current === undefined || current === null) return undefined;
+    current = current[part];
+  }
+  return current;
+}
+
+// Helper: delete a key at a dot-separated path
+function deleteAtPath(obj: any, path: string): void {
+  const parts = path.split('.');
+  let current = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (current[parts[i]] === undefined) return;
+    current = current[parts[i]];
+  }
+  delete current[parts[parts.length - 1]];
+}
+
+class DocumentStore {
+  private branches: Map<string, Map<string, Document>> = new Map();
+  private currentBranch: string = 'main';
+  private branchPoints: Map<string, Map<string, Document>> = new Map();
+
+  constructor() {
+    this.branches.set('main', new Map());
+  }
+
+  private getCurrentDocs(): Map<string, Document> {
+    return this.branches.get(this.currentBranch)!;
+  }
+
+  // ---- CRUD ----
+
+  create(id: string, content: object): void {
+    const docs = this.getCurrentDocs();
+    if (docs.has(id) && !docs.get(id)!.deleted) {
+      throw new Error(`Document '${id}' already exists`);
+    }
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    docs.set(id, {
+      content: deepClone(content),
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const docs = this.getCurrentDocs();
+    const doc = docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const docs = this.getCurrentDocs();
+    const doc = docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    const version: Version = {
+      id: generateId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    doc.content = deepClone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const docs = this.getCurrentDocs();
+    const doc = docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    doc.deleted = true;
+  }
+
+  // ---- Version History ----
+
+  getHistory(id: string): Version[] {
+    const docs = this.getCurrentDocs();
+    const doc = docs.get(id);
+    if (!doc) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const docs = this.getCurrentDocs();
+    const doc = docs.get(id);
+    if (!doc) {
+      throw new Error(`Document '${id}' not found`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version '${versionId}' not found for document '${id}'`);
+    }
+    return deepClone(version.content);
+  }
+
+  // ---- Branching ----
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch '${name}' already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch '${sourceName}' not found`);
+    }
+    const newDocs = new Map<string, Document>();
+    for (const [id, doc] of source) {
+      newDocs.set(id, deepClone(doc));
+    }
+    this.branches.set(name, newDocs);
+
+    // Store snapshot of source at branch point for merge base
+    const snapshot = new Map<string, Document>();
+    for (const [id, doc] of source) {
+      snapshot.set(id, deepClone(doc));
+    }
+    this.branchPoints.set(name, snapshot);
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch '${name}' not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // ---- Merging ----
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceDocs = this.branches.get(sourceBranch);
+    if (!sourceDocs) {
+      throw new Error(`Branch '${sourceBranch}' not found`);
+    }
+    const targetDocs = this.getCurrentDocs();
+    const baseDocs = this.branchPoints.get(sourceBranch);
+    if (!baseDocs) {
+      throw new Error(`No branch point found for '${sourceBranch}'`);
+    }
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+    const deletedIds = new Set<string>();
+
+    // Collect all document IDs across base, source, target
+    const allIds = new Set<string>();
+    for (const id of baseDocs.keys()) allIds.add(id);
+    for (const id of sourceDocs.keys()) allIds.add(id);
+    for (const id of targetDocs.keys()) allIds.add(id);
+
+    for (const id of allIds) {
+      const baseDoc = baseDocs.get(id);
+      const sourceDoc = sourceDocs.get(id);
+      const targetDoc = targetDocs.get(id);
+
+      const baseExists = !!baseDoc && !baseDoc.deleted;
+      const sourceExists = !!sourceDoc && !sourceDoc.deleted;
+      const targetExists = !!targetDoc && !targetDoc.deleted;
+
+      // Document created only on source (not in base, not in target)
+      if (!baseExists && sourceExists && !targetExists) {
+        merged[id] = deepClone(sourceDoc!.content);
+        continue;
+      }
+
+      // Document created only on target (not in base, not in source)
+      if (!baseExists && !sourceExists && targetExists) {
+        // Target already has it, nothing to merge
+        continue;
+      }
+
+      // Both don't exist, skip
+      if (!baseExists && !sourceExists && !targetExists) continue;
+
+      // Document deleted on source, check target
+      if (baseExists && !sourceExists && targetExists) {
+        const targetChanges = getChanges(baseDoc!.content, targetDoc!.content);
+        if (targetChanges.size === 0) {
+          // target unchanged from base, accept delete from source
+          deletedIds.add(id);
+          continue;
+        }
+        // Target changed but source deleted - keep target version (ours wins)
+        merged[id] = deepClone(targetDoc!.content);
+        continue;
+      }
+
+      // Document deleted on target
+      if (baseExists && sourceExists && !targetExists) {
+        // Target deleted it - keep deleted (ours wins)
+        continue;
+      }
+
+      // Both deleted
+      if (baseExists && !sourceExists && !targetExists) continue;
+
+      // Both exist - perform field-level three-way merge
+      const baseContent = baseDoc!.content;
+      const sourceContent = sourceDoc!.content;
+      const targetContent = targetDoc!.content;
+
+      const sourceChanges = getChanges(baseContent, sourceContent);
+      const targetChanges = getChanges(baseContent, targetContent);
+
+      // If no changes on either side for this doc, skip
+      if (sourceChanges.size === 0 && targetChanges.size === 0) continue;
+
+      const result = deepClone(targetContent) as any;
+
+      // Apply source changes that don't conflict
+      for (const [path, { newVal }] of sourceChanges) {
+        const targetChange = targetChanges.get(path);
+        if (!targetChange) {
+          // Only source changed this path - apply it
+          if (newVal === undefined) {
+            deleteAtPath(result, path);
+          } else {
+            setAtPath(result, path, deepClone(newVal));
+          }
+        } else {
+          // Both changed this path
+          if (JSON.stringify(targetChange.newVal) === JSON.stringify(newVal)) {
+            // Same value - no conflict
+          } else {
+            // Conflict! merged uses "ours" (target), so result already has target value
+            conflicts.push({
+              documentId: id,
+              path,
+              base: deepClone(getAtPath(baseContent, path)),
+              ours: deepClone(targetChange.newVal),
+              theirs: deepClone(newVal),
+            });
+          }
+        }
+      }
