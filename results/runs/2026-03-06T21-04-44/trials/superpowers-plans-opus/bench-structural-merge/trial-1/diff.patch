qual({ a: 3 });\n  });\n\n  it('should not conflict when both sides change to same value', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { a: 42 });\n    store.switchBranch('main');\n    store.update('doc1', { a: 42 });\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(result.conflicts).toHaveLength(0);\n    expect(result.merged['doc1']).toEqual({ a: 42 });\n  });\n\n  it('should handle only-source-changed (fast-forward-like)', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { a: 2 });\n    store.switchBranch('main');\n    // main unchanged\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(result.merged['doc1']).toEqual({ a: 2 });\n    expect(store.get('doc1')).toEqual({ a: 2 });\n  });\n\n  it('should handle only-target-changed', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { a: 1 });\n    store.createBranch('feature');\n    // feature unchanged\n    store.update('doc1', { a: 2 });\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(result.merged['doc1']).toEqual({ a: 2 });\n  });\n\n  it('should merge multiple documents independently', () => {\n    const store = new DocumentStore();\n    store.create('doc1', { x: 1 });\n    store.create('doc2', { y: 1 });\n    store.createBranch('feature');\n    store.switchBranch('feature');\n    store.update('doc1', { x: 10 });\n    store.switchBranch('main');\n    store.update('doc2', { y: 20 });\n    const result = store.merge('feature');\n    expect(result.applied).toBe(true);\n    expect(result.merged['doc1']).toEqual({ x: 10 });\n    expect(result.merged['doc2']).toEqual({ y: 20 });\n  });\n\n  