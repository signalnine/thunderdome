+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SvE4Nx7JSR9w9sADhgbHxH","type":"tool_result","content":"File created successfully at: /workspace/docs/plans/2026-03-06-ecommerce-backend.md"}]},"parent_tool_use_id":null,"session_id":"e3f6e78b-2ff1-4755-b74d-43a4eb795369","uuid":"be51a1b8-038e-46c8-b051-ae057d5f2e89","tool_use_result":{"type":"create","filePath":"/workspace/docs/plans/2026-03-06-ecommerce-backend.md","content":"# E-Commerce Backend Implementation Plan\n\n> **For Claude:** REQUIRED SUB-SKILL: Use superpowers:executing-plans to implement this plan task-by-task.\n\n**Goal:** Build 8 event-driven e-commerce microservices communicating through a shared EventBus.\n\n**Architecture:** Each service is a factory function receiving an EventBus instance and returning an object implementing the corresponding interface from `types.ts`. Services communicate exclusively via events -- no direct imports between services. State is held in-memory within closures.\n\n**Tech Stack:** TypeScript, Vitest for testing, ESLint for linting, uuid for ID generation.\n\n---\n\n### Task 1: Catalog Service\n\n**Files:**\n- Create: `src/catalog/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { v4 as uuidv4 } from 'uuid';\nimport { EventBus } from '../bus.js';\nimport { CatalogService, Events, ProductCreatedEvent } from '../types.js';\n\nexport function createCatalogService(bus: EventBus): CatalogService {\n  const products = new Map<string, { id: string; name: string; price: number; category: string }>();\n\n  return {\n    createProduct(name, price, category) {\n      const id = uuidv4();\n      products.set(id, { id, name, price, category });\n      bus.emit(Events.PRODUCT_CREATED, { productId: id, name, price, category } satisfies ProductCreatedEvent);\n      return id;\n    },\n    getProduct(productId) {\n      return products.get(productId) ?? null;\n    },\n    listProducts(category?) {\n      const all = [...products.values()];\n      return category ? all.filter(p => p.category === category) : all;\n    },\n    searchProducts(query) {\n      const q = query.toLowerCase();\n      return [...products.values()].filter(p => p.name.toLowerCase().includes(q) || p.category.toLowerCase().includes(q));\n    },\n    updateProduct(productId, updates) {\n      const product = products.get(productId);\n      if (!product) return;\n      if (updates.name !== undefined) product.name = updates.name;\n      if (updates.price !== undefined) product.price = updates.price;\n      if (updates.category !== undefined) product.category = updates.category;\n    },\n    removeProduct(productId) {\n      return products.delete(productId);\n    },\n  };\n}\n```\n\n### Task 2: Inventory Service\n\n**Files:**\n- Create: `src/inventory/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { EventBus } from '../bus.js';\nimport { InventoryService, Events, InventoryUpdatedEvent, LowStockAlertEvent } from '../types.js';\n\nexport function createInventoryService(bus: EventBus): InventoryService {\n  const stock = new Map<string, number>();\n  const reserved = new Map<string, number>();\n  const thresholds = new Map<string, number>();\n\n  function checkLowStock(productId: string) {\n    const threshold = thresholds.get(productId);\n    const current = stock.get(productId) ?? 0;\n    if (threshold !== undefined && current <= threshold) {\n      bus.emit(Events.LOW_STOCK_ALERT, { productId, currentQuantity: current, threshold } satisfies LowStockAlertEvent);\n    }\n  }\n\n  return {\n    setStock(productId, quantity) {\n      stock.set(productId, quantity);\n      bus.emit(Events.INVENTORY_UPDATED, { productId, quantity } satisfies InventoryUpdatedEvent);\n      checkLowStock(productId);\n    },\n    getStock(productId) {\n      return (stock.get(productId) ?? 0) - (reserved.get(productId) ?? 0);\n    },\n    reserve(productId, quantity) {\n      const available = (stock.get(productId) ?? 0) - (reserved.get(productId) ?? 0);\n      if (available < quantity) return false;\n      reserved.set(productId, (reserved.get(productId) ?? 0) + quantity);\n      checkLowStock(productId);\n      return true;\n    },\n    release(productId, quantity) {\n      const currentReserved = reserved.get(productId) ?? 0;\n      reserved.set(productId, Math.max(0, currentReserved - quantity));\n    },\n    setLowStockThreshold(productId, threshold) {\n      thresholds.set(productId, threshold);\n      checkLowStock(productId);\n    },\n  };\n}\n```\n\n### Task 3: Cart Service\n\n**Files:**\n- Create: `src/cart/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { v4 as uuidv4 } from 'uuid';\nimport { EventBus } from '../bus.js';\nimport { CartService, Events, CartUpdatedEvent } from '../types.js';\n\nexport function createCartService(bus: EventBus): CartService {\n  const carts = new Map<string, { id: string; userId: string; items: Map<string, number> }>();\n\n  function getItemsArray(cartId: string): Array<{ productId: string; quantity: number }> {\n    const cart = carts.get(cartId);\n    if (!cart) return [];\n    return [...cart.items.entries()].map(([productId, quantity]) => ({ productId, quantity }));\n  }\n\n  function emitCartUpdated(cartId: string) {\n    const cart = carts.get(cartId);\n    if (!cart) return;\n    bus.emit(Events.CART_UPDATED, { cartId, userId: cart.userId, items: getItemsArray(cartId) } satisfies CartUpdatedEvent);\n  }\n\n  return {\n    createCart(userId) {\n      const id = uuidv4();\n      carts.set(id, { id, userId, items: new Map() });\n      return id;\n    },\n    addItem(cartId, productId, quantity) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      const existing = cart.items.get(productId) ?? 0;\n      cart.items.set(productId, existing + quantity);\n      emitCartUpdated(cartId);\n    },\n    removeItem(cartId, productId) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      cart.items.delete(productId);\n      emitCartUpdated(cartId);\n    },\n    getCart(cartId) {\n      const cart = carts.get(cartId);\n      if (!cart) return null;\n      return { id: cart.id, userId: cart.userId, items: getItemsArray(cartId) };\n    },\n    clearCart(cartId) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      cart.items.clear();\n      emitCartUpdated(cartId);\n    },\n    updateQuantity(cartId, productId, quantity) {\n      const cart = carts.get(cartId);\n      if (!cart) return;\n      if (quantity <= 0) {\n        cart.items.delete(productId);\n      } else {\n        cart.items.set(productId, quantity);\n      }\n      emitCartUpdated(cartId);\n    },\n  };\n}\n```\n\n### Task 4: Pricing Service\n\n**Files:**\n- Create: `src/pricing/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { EventBus } from '../bus.js';\nimport { PricingService, Events, ProductCreatedEvent } from '../types.js';\n\nexport function createPricingService(bus: EventBus): PricingService {\n  const prices = new Map<string, number>();\n  const discountCodes = new Map<string, number>();\n\n  bus.on(Events.PRODUCT_CREATED, (payload: unknown) => {\n    const event = payload as ProductCreatedEvent;\n    prices.set(event.productId, event.price);\n  });\n\n  return {\n    calculateTotal(items, discountCode?) {\n      const subtotal = items.reduce((sum, item) => sum + item.price * item.quantity, 0);\n      const discountPct = discountCode ? (discountCodes.get(discountCode) ?? 0) : 0;\n      const discount = Math.round(subtotal * discountPct * 100) / 100;\n      const taxableAmount = subtotal - discount;\n      const tax = Math.round(taxableAmount * 0.1 * 100) / 100;\n      const total = Math.round((taxableAmount + tax) * 100) / 100;\n      return { subtotal, discount, tax, total };\n    },\n    addDiscountCode(code, percentage) {\n      discountCodes.set(code, percentage / 100);\n    },\n    getPrice(productId) {\n      return prices.get(productId) ?? 0;\n    },\n  };\n}\n```\n\n### Task 5: Orders Service\n\n**Files:**\n- Create: `src/orders/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { v4 as uuidv4 } from 'uuid';\nimport { EventBus } from '../bus.js';\nimport { OrderService, Events, OrderStatus, OrderCreatedEvent, OrderStatusChangedEvent } from '../types.js';\n\nexport function createOrderService(bus: EventBus): OrderService {\n  const orders = new Map<string, { id: string; userId: string; status: OrderStatus; total: number; cartId: string }>();\n\n  return {\n    createOrder(userId, cartId, total) {\n      const id = uuidv4();\n      orders.set(id, { id, userId, status: OrderStatus.PENDING, total, cartId });\n      bus.emit(Events.ORDER_CREATED, { orderId: id, userId, cartId, total } satisfies OrderCreatedEvent);\n      return id;\n    },\n    getOrder(orderId) {\n      const order = orders.get(orderId);\n      if (!order) return null;\n      return { id: order.id, userId: order.userId, status: order.status, total: order.total };\n    },\n    updateStatus(orderId, status) {\n      const order = orders.get(orderId);\n      if (!order) return;\n      const previousStatus = order.status;\n      order.status = status;\n      bus.emit(Events.ORDER_STATUS_CHANGED, { orderId, status, previousStatus } satisfies OrderStatusChangedEvent);\n    },\n    listOrders(userId) {\n      return [...orders.values()]\n        .filter(o => o.userId === userId)\n        .map(o => ({ id: o.id, status: o.status, total: o.total }));\n    },\n  };\n}\n```\n\n### Task 6: Payment Service\n\n**Files:**\n- Create: `src/payment/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { v4 as uuidv4 } from 'uuid';\nimport { EventBus } from '../bus.js';\nimport { PaymentService, Events, PaymentStatus, PaymentProcessedEvent } from '../types.js';\n\ninterface PaymentOptions {\n  simulateFailure?: boolean;\n  simulateTimeout?: boolean;\n  delay?: number;\n}\n\nexport function createPaymentService(bus: EventBus, options: PaymentOptions = {}): PaymentService {\n  const transactions = new Map<string, { orderId: string; amount: number; status: PaymentStatus }>();\n\n  return {\n    async processPayment(orderId, amount) {\n      if (options.delay) {\n        await new Promise(resolve => setTimeout(resolve, options.delay));\n      }\n\n      let status: PaymentStatus;\n      let transactionId: string | undefined;\n      let error: string | undefined;\n\n      if (options.simulateTimeout) {\n        status = PaymentStatus.TIMEOUT;\n        error = 'Payment timed out';\n      } else if (options.simulateFailure) {\n        status = PaymentStatus.FAILED;\n        error = 'Payment failed';\n      } else {\n        status = PaymentStatus.SUCCESS;\n        transactionId = uuidv4();\n        transactions.set(transactionId, { orderId, amount, status });\n      }\n\n      const event: PaymentProcessedEvent = { orderId, status, transactionId, error };\n      await bus.emit(Events.PAYMENT_PROCESSED, event);\n\n      return { status, transactionId, error };\n    },\n    async refund(transactionId) {\n      const tx = transactions.get(transactionId);\n      if (!tx) return false;\n      tx.status = PaymentStatus.FAILED;\n      transactions.delete(transactionId);\n      return true;\n    },\n  };\n}\n```\n\n### Task 7: Notifications Service\n\n**Files:**\n- Create: `src/notifications/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { EventBus } from '../bus.js';\nimport { NotificationService, Events, OrderStatusChangedEvent, PaymentProcessedEvent, OrderCreatedEvent, NotificationSentEvent } from '../types.js';\n\nexport function createNotificationService(bus: EventBus): NotificationService {\n  const subscribers = new Set<string>();\n  const notifications = new Map<string, Array<{ type: string; message: string; timestamp: number }>>();\n  const orderToUser = new Map<string, string>();\n\n  function addNotification(userId: string, type: string, message: string) {\n    if (!subscribers.has(userId)) return;\n    if (!notifications.has(userId)) notifications.set(userId, []);\n    const entry = { type, message, timestamp: Date.now() };\n    notifications.get(userId)!.push(entry);\n    bus.emit(Events.NOTIFICATION_SENT, { userId, type, message } satisfies NotificationSentEvent);\n  }\n\n  bus.on(Events.ORDER_CREATED, (payload: unknown) => {\n    const event = payload as OrderCreatedEvent;\n    orderToUser.set(event.orderId, event.userId);\n    addNotification(event.userId, 'order_created', `Order ${event.orderId} has been created`);\n  });\n\n  bus.on(Events.ORDER_STATUS_CHANGED, (payload: unknown) => {\n    const event = payload as OrderStatusChangedEvent;\n    const userId = orderToUser.get(event.orderId);\n    if (userId) {\n      addNotification(userId, 'order_status', `Order ${event.orderId} status changed from ${event.previousStatus} to ${event.status}`);\n    }\n  });\n\n  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {\n    const event = payload as PaymentProcessedEvent;\n    const userId = orderToUser.get(event.orderId);\n    if (userId) {\n      addNotification(userId, 'payment', `Payment for order ${event.orderId}: ${event.status}`);\n    }\n  });\n\n  return {\n    subscribe(userId) {\n      subscribers.add(userId);\n    },\n    getNotifications(userId) {\n      return notifications.get(userId) ?? [];\n    },\n  };\n}\n```\n\n### Task 8: Analytics Service\n\n**Files:**\n- Create: `src/analytics/index.ts`\n\n**Implementation:**\n\n```typescript\nimport { EventBus } from '../bus.js';\nimport { AnalyticsService, Events, PaymentProcessedEvent, PaymentStatus, OrderCreatedEvent, CartUpdatedEvent } from '../types.js';\n\nexport function createAnalyticsService(bus: EventBus): AnalyticsService {\n  const eventCounts = new Map<string, number>();\n  let revenue = 0;\n  const uniqueCarts = new Set<string>();\n  let orderCount = 0;\n  const productCounts = new Map<string, number>();\n\n  function trackEvent(eventName: string) {\n    eventCounts.set(eventName, (eventCounts.get(eventName) ?? 0) + 1);\n  }\n\n  bus.on(Events.PRODUCT_CREATED, () => { trackEvent(Events.PRODUCT_CREATED); });\n  bus.on(Events.INVENTORY_UPDATED, () => { trackEvent(Events.INVENTORY_UPDATED); });\n  bus.on(Events.LOW_STOCK_ALERT, () => { trackEvent(Events.LOW_STOCK_ALERT); });\n  bus.on(Events.CART_UPDATED, (payload: unknown) => {\n    trackEvent(Events.CART_UPDATED);\n    const event = payload as CartUpdatedEvent;\n    uniqueCarts.add(event.cartId);\n  });\n  bus.on(Events.PRICE_CALCULATED, () => { trackEvent(Events.PRICE_CALCULATED); });\n  bus.on(Events.ORDER_CREATED, (payload: unknown) => {\n    trackEvent(Events.ORDER_CREATED);\n    orderCount++;\n    const event = payload as OrderCreatedEvent;\n    // Track products by looking at cart items - but we don't have cart items here\n    // We track the order itself\n  });\n  bus.on(Events.ORDER_STATUS_CHANGED, () => { trackEvent(Events.ORDER_STATUS_CHANGED); });\n  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {\n    trackEvent(Events.PAYMENT_PROCESSED);\n    const event = payload as PaymentProcessedEvent;\n    if (event.status === PaymentStatus.SUCCESS) {\n      // We need amount from somewhere -- track via order\n    }\n  });\n  bus.on(Events.NOTIFICATION_SENT, () => { trackEvent(Events.NOTIFICATION_SENT); });\n\n  // We need to correlate orders with their totals and cart items for revenue + product tracking\n  const orderTotals = new Map<string, number>();\n  const orderItems = new Map<string, Array<{ productId: string; quantity: number }>>();\n  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();\n\n  // Override order_created handler to capture total\n  bus.on(Events.ORDER_CREATED, (payload: unknown) => {\n    const event = payload as OrderCreatedEvent;\n    orderTotals.set(event.orderId, event.total);\n    // Get cart items from our tracking\n    const items = cartItems.get(event.cartId);\n    if (items) {\n      for (const item of items) {\n        productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);\n      }\n    }\n  });\n\n  // Track cart items\n  bus.on(Events.CART_UPDATED, (payload: unknown) => {\n    const event = payload as CartUpdatedEvent;\n    cartItems.set(event.cartId, event.items);\n  });\n\n  // Track revenue from successful payments\n  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {\n    const event = payload as PaymentProcessedEvent;\n    if (event.status === PaymentStatus.SUCCESS) {\n      const total = orderTotals.get(event.orderId) ?? 0;\n      revenue += total;\n    }\n  });\n\n  return {\n    getEventCount(eventType) {\n      return eventCounts.get(eventType) ?? 0;\n    },\n    getRevenue() {\n      return revenue;\n    },\n    getConversionRate() {\n      if (uniqueCarts.size === 0) return 0;\n      return orderCount / uniqueCarts.size;\n    },\n    getTopProducts(limit) {\n      return [...productCounts.entries()]\n        .map(([productId, count]) => ({ productId, count }))\n        .sort((a, b) => b.count - a.count)\n        .slice(0, limit);\n    },\n  };\n}\n```\n\nNote: The analytics service has duplicate event handlers. This needs to be cleaned up -- consolidate into single handlers per event.\n\n### Task 9: Index barrel file\n\n**Files:**\n- Create: `src/index.ts`\n\n**Implementation:**\n\n```typescript\nexport { createCatalogService } from './catalog/index.js';\nexport { createInventoryService } from './inventory/index.js';\nexport { createCartService } from './cart/index.js';\nexport { createPricingService } from './pricing/index.js';\nexport { createOrderService } from './orders/index.js';\nexport { createPaymentService } from './payment/index.js';\nexport { createNotificationService } from './notifications/index.js';\nexport { createAnalyticsService } from './analytics/index.js';\n```\n\n### Task 10: Write tests\n\nCreate comprehensive tests for all services.\n\n### Task 11: Build & Lint\n\nRun: `npm run build && npm run lint`\nExpected: Clean build and lint\n","structuredPatch":[],"originalFile":null}}
