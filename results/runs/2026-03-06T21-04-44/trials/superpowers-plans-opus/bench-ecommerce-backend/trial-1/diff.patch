', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    expect(catalog.listProducts()).toHaveLength(2);\n  });\n\n  it('should list products by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n    const cat1 = catalog.listProducts('cat1');\n    expect(cat1).toHaveLength(2);\n    expect(cat1.every(p => p.category === 'cat1')).toBe(true);\n  });\n\n  it('should search products by name', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Blue Widget', 1, 'gadgets');\n    catalog.createProduct('Red Gizmo', 2, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('Blue Widget');\n  });\n\n  it('should search products by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'Electronics');\n    catalog.createProduct('B', 2, 'Books');\n    const results = catalog.searchProducts('electron');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should update a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { name: 'Super Widget', price: 19.99 });\n    const product = catalog.getProduct(id);\n    expect(product!.name).toBe('Super Widget');\n    expect(product!.price).toBe(19.99);\n    expect(product!.category).toBe('gadgets');\n  });\n\n  it('should remove a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n    expect(catalog.removeProduct(id)).toBe(false);\n  });\n\n  it('should emit product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    const log = bus.getLog();\n    const event = log.find(e => e.event === Events.PRODUCT_CREATED);\n    expect(event).toBeDefined();\n    expect(event!.payload).toMatchObject({ name: 'Widget', price: 9.99, category: 'gadgets' });\n  });\n});\n\ndescribe('InventoryService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should set and get stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product', () => {\n    const inventory = createInventoryService(bus);\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 3)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(7);\n  });\n\n  it('should fail to reserve insufficient stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 2);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n    expect(inventory.getStock('p1')).toBe(2);\n  });\n\n  it('should release reserved stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit inventory:updated on setStock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 50);\n    const log = bus.getLog();\n    const event = log.find(e => e.event === Events.INVENTORY_UPDATED);\n    expect(event).toBeDefined();\n    expect(event!.payload).toMatchObject({ productId: 'p1', quantity: 50 });\n  });\n\n  it('should emit low stock alert when threshold is crossed', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.reserve('p1', 6);\n    const log = bus.getLog();\n    const alerts = log.filter(e => e.event === Events.LOW_STOCK_ALERT);\n    expect(alerts.length).toBeGreaterThan(0);\n  });\n});\n\ndescribe('CartService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    expect(id).toBeDefined();\n  });\n\n  it('should add items and retrieve cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c).toBeDefined();\n    expect(c!.items).toEqual([{ productId: 'p1', quantity: 2 }]);\n  });\n\n  it('should consolidate items for same product', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([{ productId: 'p1', quantity: 5 }]);\n  });\n\n  it('should remove items', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.removeItem(id, 'p1');\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([{ productId: 'p2', quantity: 1 }]);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([{ productId: 'p1', quantity: 10 }]);\n  });\n\n  it('should remove item when updating quantity to 0', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 0);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([]);\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p2', 1);\n    cart.clearCart(id);\n    const c = cart.getCart(id);\n    expect(c!.items).toEqual([]);\n  });\n\n  it('should return null for unknown cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('nonexistent')).toBeNull();\n  });\n\n  it('should emit cart:updated events', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 1);\n    const log = bus.getLog();\n    const event = log.find(e => e.event === Events.CART_UPDATED);\n    expect(event).toBeDefined();\n  });\n});\n\ndescribe('PricingService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // 90 * 0.1\n    expect(result.total).toBe(99);\n  });\n\n  it('should ignore unknown discount codes', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n  });\n\n  it('should track prices from product:created events', async () => {\n    const pricing = createPricingService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, {\n      productId: 'p1',\n      name: 'Widget',\n      price: 29.99,\n      category: 'gadgets',\n    });\n    expect(pricing.getPrice('p1')).toBe(29.99);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('OrderService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create an order with PENDING status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    const order = orders.getOrder(id);\n    expect(order).toBeDefined();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(99.99);\n    expect(order!.userId).toBe('user1');\n  });\n\n  it('should update order status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should emit order:created event', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 100);\n    const log = bus.getLog();\n    const event = log.find(e => e.event === Events.ORDER_CREATED);\n    expect(event).toBeDefined();\n    expect(event!.payload).toMatchObject({ userId: 'user1', cartId: 'cart1', total: 100 });\n  });\n\n  it('should emit order:status_changed event with previous status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    const log = bus.getLog();\n    const event = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(event).toBeDefined();\n    expect(event!.payload).toMatchObject({\n      status: OrderStatus.CONFIRMED,\n      previousStatus: OrderStatus.PENDING,\n    });\n  });\n\n  it('should list orders for a user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 50);\n    orders.createOrder('user1', 'cart2', 75);\n    orders.createOrder('user2', 'cart3', 100);\n    const user1Orders = orders.listOrders('user1');\n    expect(user1Orders).toHaveLength(2);\n  });\n\n  it('should return null for unknown order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('nonexistent')).toBeNull();\n  });\n\n  it('should support cancel status', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CANCELLED);\n  });\n\n  it('should support full lifecycle', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    orders.updateStatus(id, OrderStatus.DELIVERED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.DELIVERED);\n  });\n});\n\ndescribe('PaymentService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    const event = log.find(e => e.event === Events.PAYMENT_PROCESSED);\n    expect(event).toBeDefined();\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should fail to refund unknown transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n});\n\ndescribe('NotificationService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should subscribe a user and record notifications for order events', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    orders.createOrder('user1', 'cart1', 100);\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThan(0);\n    expect(notifs[0].type).toBe('order_created');\n  });\n\n  it('should record notifications for order status changes', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n\n    const notifs = notifications.getNotifications('user1');\n    const statusNotif = notifs.find(n => n.type === 'order_status');\n    expect(statusNotif).toBeDefined();\n  });\n\n  it('should record notifications for payment events', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n\n    const notifs = notifications.getNotifications('user1');\n    const paymentNotif = notifs.find(n => n.type === 'payment');\n    expect(paymentNotif).toBeDefined();\n  });\n\n  it('should not send notifications to unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    orders.createOrder('user1', 'cart1', 100);\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs).toEqual([]);\n  });\n\n  it('should return empty array for user with no notifications', () => {\n    const notifications = createNotificationService(bus);\n    expect(notifications.getNotifications('unknown')).toEqual([]);\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should count events by type', () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n\n    catalog.createProduct('A', 10, 'cat1');\n    catalog.createProduct('B', 20, 'cat1');\n\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not track revenue from failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n\n    const orderId = orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment(orderId, 100);\n\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const cartId1 = cart.createCart('user1');\n    cart.addItem(cartId1, 'p1', 1);\n    const cartId2 = cart.createCart('user2');\n    cart.addItem(cartId2, 'p1', 1);\n\n    orders.createOrder('user1', cartId1, 50);\n\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate when no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should track top products by order quantity', () => {\n    const analytics = createAnalyticsService(bus);\n    const cart = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 5);\n    cart.addItem(cartId, 'p2', 3);\n    orders.createOrder('user1', cartId, 100);\n\n    const top = analytics.getTopProducts(10);\n    expect(top).toHaveLength(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(3);\n  });\n\n  it('should return 0 for unknown event type', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getEventCount('unknown:event')).toBe(0);\n  });\n});\n\ndescribe('Integration: Full E-Commerce Flow', () => {\n  it('should handle a complete purchase flow', async () => {\n    const bus = new EventBus();\n\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartSvc = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const productId = catalog.createProduct('Laptop', 999.99, 'electronics');\n    inventory.setStock(productId, 50);\n    inventory.setLowStockThreshold(productId, 5);\n\n    // Verify pricing picks up product price\n    expect(pricing.getPrice(productId)).toBe(999.99);\n\n    // Create cart and add items\n    const cartId = cartSvc.createCart('user1');\n    cartSvc.addItem(cartId, productId, 2);\n\n    // Calculate total\n    const cart = cartSvc.getCart(cartId)!;\n    const priceResult = pricing.calculateTotal(\n      cart.items.map(item => ({\n        productId: item.productId,\n        quantity: item.quantity,\n        price: pricing.getPrice(item.productId),\n      }))\n    );\n    expect(priceResult.subtotal).toBe(1999.98);\n    expect(priceResult.tax).toBeCloseTo(200, 0);\n\n    // Reserve inventory\n    expect(inventory.reserve(productId, 2)).toBe(true);\n    expect(inventory.getStock(productId)).toBe(48);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, priceResult.total);\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, priceResult.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    // Verify notifications\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(4); // created + payment + status changes\n\n    // Verify analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(1);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getRevenue()).toBe(priceResult.total);\n    expect(analytics.getConversionRate()).toBe(1);\n\n    const topProducts = analytics.getTopProducts(5);\n    expect(topProducts).toHaveLength(1);\n    expect(topProducts[0].productId).toBe(productId);\n    expect(topProducts[0].count).toBe(2);\n  });\n\n  it('should handle order cancellation and refund', async () => {\n    const bus = new EventBus();\n\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartSvc = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n\n    notifications.subscribe('user1');\n\n    const productId = catalog.createProduct('Phone', 599, 'electronics');\n    inventory.setStock(productId, 20);\n\n    const cartId = cartSvc.createCart('user1');\n    cartSvc.addItem(cartId, productId, 1);\n\n    const cart = cartSvc.getCart(cartId)!;\n    const total = pricing.calculateTotal(\n      cart.items.map(i => ({ productId: i.productId, quantity: i.quantity, price: pricing.getPrice(i.productId) }))\n    );\n\n    inventory.reserve(productId, 1);\n    const orderId = orders.createOrder('user1', cart