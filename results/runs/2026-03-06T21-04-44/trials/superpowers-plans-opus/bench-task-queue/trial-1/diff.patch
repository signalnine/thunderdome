st t2 = queue.process()!;\n    expect(t2.id).toBe(task.id);\n    queue.fail(t2.id, 'err');\n    // Backoff: 1000 * 2^(2-1) = 2000ms\n    expect(queue.process()).toBeNull();\n\n    vi.advanceTimersByTime(2000);\n    // Attempt 3 (last)\n    const t3 = queue.process()!;\n    expect(t3.id).toBe(task.id);\n    queue.fail(t3.id, 'err');\n    // All retries exhausted\n    expect(t3.status).toBe('failed');\n\n    vi.useRealTimers();\n  });\n\n  it('should track attempt count', () => {\n    vi.useFakeTimers();\n\n    queue.add('data', { maxRetries: 2 });\n    const task = queue.process()!;\n    expect(task.attempts).toBe(1);\n\n    queue.fail(task.id, 'err');\n    vi.advanceTimersByTime(1000);\n\n    const t2 = queue.process()!;\n    expect(t2.attempts).toBe(2);\n\n    vi.useRealTimers();\n  });\n\n  it('should keep original queue and priority on retry', () => {\n    vi.useFakeTimers();\n\n    queue.add('data', { queue: 'emails', priority: 2, maxRetries: 2 });\n    const task = queue.process('emails')!;\n    queue.fail(task.id, 'err');\n\n    vi.advanceTimersByTime(1000);\n\n    const t2 = queue.process('emails')!;\n    expect(t2.queue).toBe('emails');\n    expect(t2.priority).toBe(2);\n\n    vi.useRealTimers();\n  });\n\n  it('should use default maxRetries of 3', () => {\n    const task = queue.add('data');\n    expect(task.maxRetries).toBe(3);\n  });\n\n  it('should use default backoffMs of 1000', () => {\n    const task = queue.add('data');\n    expect(task.backoffMs).toBe(1000);\n  });\n\n  it('should allow configurable maxRetries', () => {\n    const task = queue.add('data', { maxRetries: 5 });\n    expect(task.maxRetries).toBe(5);\n  });\n\n  it('should allow configurable backoffMs', () => {\n    const task = queue.add('data', { backoffMs: 500 });\n    expect(task.backoffMs).toBe(500);\n  });\n\n  it('should throw when completing a non-processing task', () => {\n    const task = queue.add('data');\n    expect(() => queue.complete(task.id)).toThrow();\n  });\n\n  it('s