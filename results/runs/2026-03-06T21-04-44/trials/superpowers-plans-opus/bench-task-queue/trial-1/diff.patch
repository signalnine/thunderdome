Schedule('hourly', '0 * * * *', 'default', { action: 'hourly' });\n\n    // Tick at minute 30 - not due\n    const notDueTime = new Date(2024, 0, 1, 12, 30, 0);\n    const tasks = queue.tick(notDueTime);\n\n    expect(tasks).toHaveLength(0);\n  });\n\n  it('should not double-fire for same minute', () => {\n    queue.addSchedule('every5', '*/5 * * * *', 'default', { action: 'report' });\n\n    const time = new Date(2024, 0, 1, 12, 0, 0);\n    queue.tick(time);\n    const tasks = queue.tick(time);\n\n    expect(tasks).toHaveLength(0);\n    expect(queue.size()).toBe(1);\n  });\n\n  it('should stop creating tasks after schedule is removed', () => {\n    queue.addSchedule('every5', '*/5 * * * *', 'default', { action: 'report' });\n\n    const time1 = new Date(2024, 0, 1, 12, 0, 0);\n    queue.tick(time1);\n    expect(queue.size()).toBe(1);\n\n    queue.removeSchedule('every5');\n\n    const time2 = new Date(2024, 0, 1, 12, 5, 0);\n    queue.tick(time2);\n    expect(queue.size()).toBe(1); // No new task\n  });\n\n  it('should create regular tasks subject to queue rules', () => {\n    queue.addSchedule('s1', '*/5 * * * *', 'emails', { type: 'digest' }, { priority: 1 });\n\n    const time = new Date(2024, 0, 1, 12, 0, 0);\n    const tasks = queue.tick(time);\n\n    expect(tasks[0].queue).toBe('emails');\n    expect(tasks[0].priority).toBe(1);\n    expect(tasks[0].status).toBe('pending');\n  });\n\n  it('should handle daily cron expression', () => {\n    queue.addSchedule('daily', '0 0 * * *', 'default', { action: 'daily' });\n\n    // Midnight\n    const midnight = new Date(2024, 0, 1, 0, 0, 0);\n    const tasks = queue.tick(midnight);\n    expect(tasks).toHaveLength(1);\n\n    // Not midnight\n    const noon = new Date(2024, 0, 1, 12, 0, 0);\n    const tasks2 = queue.tick(noon);\n    expect(tasks2).toHaveLength(0);\n  });\n\n  it('should handle hourly cron expression', () => {\n    queue.addSchedule('hourly', '0 * * * *', 'default', { action: 'hourly' });\n\n    // On the 