+export { TaskQueue } from './TaskQueue.js';
+export type {
+  Task,
+  TaskOptions,
+  TaskStatus,
+  Schedule,
+  MiddlewareFn,
+  HandlerFn,
+  ProgressCallback,
+  ShutdownOptions,
+  ShutdownSummary,
+} from './types.js';
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
