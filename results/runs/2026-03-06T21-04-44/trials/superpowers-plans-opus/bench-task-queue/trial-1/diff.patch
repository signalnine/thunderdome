nnot add new tasks.');\n    }\n\n    const queueName = options.queue ?? DEFAULT_QUEUE;\n    const priority = options.priority ?? 5;\n\n    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Validate dependencies\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Check for circular dependencies\n    if (dependencies.length > 0) {\n      // We need to check if adding this task would create a cycle.\n      // Since the task doesn't exist yet, we check if any dependency\n      // transitively depends on... well, the task doesn't exist yet,\n      // so direct circular deps are only possible if a dep depends on\n      // another dep that depends on... We check transitive deps.\n      // Actually, since the new task doesn't exist yet, there can't be\n      // a circular dependency involving it. But we should check if\n      // there are cycles among the dependencies themselves.\n      // The real circular dependency check matters when tasks reference each other.\n    }\n\n    let availableAt: Date;\n    if (options.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options.delay && options.delay > 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    } else {\n      availableAt = new Date();\n    }\n\n    const task: Task<T> = {\n      id: generateId(),\n      status: 'pending',\n      payload,\n      createdAt: new Date(),\n      queue: queueName,\n      priority,\n      availableAt,\n      attempts: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoffMs: options.backoffMs ?? 1000,\n      dependencies,\n      resolvedDependencies: new Set<string>(),\n      progress: 0,\n    };\n\n    // Check circular dependencies with the new task ID\n    if (dependencies.length > 0) {\n      this.detectCircularDependencies(task.id, dependencies);\n    }\n\n    this.tasks.set(task.id, task as Task);\n\n    // Ensure queue exists\n    if (!this.queues.has(queueName)) {\n      this.queues.set(queueName, []);\n    }\n    this.queues.get(queueName)!.push(task.id);\n\n    // Check which dependencies are already resolved\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId)!;\n      if (depTask.status === 'completed') {\n        task.resolvedDependencies.add(depId);\n      }\n    }\n\n    return task;\n  }\n\n  process(queueName: string = DEFAULT_QUEUE): Task | null {\n    const queueTaskIds = this.queues.get(queueName);\n    if (!queueTaskIds || queueTaskIds.length === 0) {\n      return null;\n    }\n\n    // Check concurrency limit\n    const concurrencyLimit = this.concurrencyLimits.get(queueName);\n    if (concurrencyLimit !== undefined) {\n      const activeCount = this.getActiveCount(queueName);\n      if (activeCount >= concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n\n    // Find best candidate: available, not blocked by dependencies\n    // Sort by: priority (asc), then availableAt (asc), then createdAt (asc/FIFO)\n    let bestIdx = -1;\n    let bestTask: Task | null = null;\n\n    for (let i = 0; i < queueTaskIds.length; i++) {\n      const task = this.tasks.get(queueTaskIds[i])!;\n\n      // Skip non-pending tasks\n      if (task.status !== 'pending') continue;\n\n      // Skip tasks not yet available\n      if (task.availableAt > now) continue;\n\n      // Skip tasks with unresolved dependencies\n      if (task.dependencies.length > 0) {\n        const allResolved = task.dependencies.every(depId => task.resolvedDependencies.has(depId));\n        if (!allResolved) continue;\n      }\n\n      if (bestTask === null) {\n        bestIdx = i;\n        bestTask = task;\n      } else {\n        // Compar