+let counter = 0;
+
+export function generateId(): string {
+  return `task_${Date.now()}_${++counter}_${Math.random().toString(36).slice(2, 8)}`;
+}
+
+export function generateScheduleId(): string {
+  return `sched_${Date.now()}_${++counter}_${Math.random().toString(36).slice(2, 8)}`;
+}
+
+export interface CronSchedule {
+  minute: number | null; // null = every minute
+  minuteInterval: number | null; // for */N
+  hour: number | null; // null = every hour
+  // day/month/weekday always * in our subset
+}
+
+export function parseCron(expr: string): CronSchedule {
+  const parts = expr.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: ${expr}`);
+  }
+
+  const [minutePart, hourPart, dayPart, monthPart, weekdayPart] = parts;
+
+  // We only support * for day, month, weekday
+  if (dayPart !== '*' || monthPart !== '*' || weekdayPart !== '*') {
+    throw new Error(`Unsupported cron expression: ${expr}. Only * supported for day/month/weekday.`);
+  }
+
+  const schedule: CronSchedule = {
+    minute: null,
+    minuteInterval: null,
+    hour: null,
+  };
+
+  // Parse minute field
+  if (minutePart === '*') {
+    // every minute
+  } else if (minutePart.startsWith('*/')) {
+    const interval = parseInt(minutePart.slice(2), 10);
+    if (isNaN(interval) || interval <= 0) {
+      throw new Error(`Invalid cron interval: ${minutePart}`);
+    }
+    schedule.minuteInterval = interval;
+  } else {
+    const min = parseInt(minutePart, 10);
+    if (isNaN(min) || min < 0 || min > 59) {
+      throw new Error(`Invalid cron minute: ${minutePart}`);
+    }
+    schedule.minute = min;
+  }
+
+  // Parse hour field
+  if (hourPart === '*') {
+    // every hour
+  } else {
+    const hr = parseInt(hourPart, 10);
+    if (isNaN(hr) || hr < 0 || hr > 23) {
+      throw new Error(`Invalid cron hour: ${hourPart}`);
+    }
+    schedule.hour = hr;
+  }
+
+  return schedule;
+}
+
+export function shouldRunAt(schedule: CronSchedule, now: Date, lastRun: Date | undefined): boolean {
+  const currentMinute = now.getMinutes();
+  const currentHour = now.getHours();
+
+  // Check hour constraint
+  if (schedule.hour !== null && currentHour !== schedule.hour) {
+    return false;
+  }
+
+  // Check minute constraint
+  if (schedule.minute !== null && currentMinute !== schedule.minute) {
+    return false;
+  }
+
+  // Check interval constraint
+  if (schedule.minuteInterval !== null) {
+    if (currentMinute % schedule.minuteInterval !== 0) {
+      return false;
+    }
+  }
+
+  // Prevent double-firing in the same minute
+  if (lastRun) {
+    const lastMinute = lastRun.getMinutes();
+    const lastHour = lastRun.getHours();
+    const lastDate = lastRun.toDateString();
+    const nowDate = now.toDateString();
+
+    if (lastDate === nowDate && lastHour === currentHour && lastMinute === currentMinute) {
+      return false;
+    }
+  }
+
+  return true;
+}
