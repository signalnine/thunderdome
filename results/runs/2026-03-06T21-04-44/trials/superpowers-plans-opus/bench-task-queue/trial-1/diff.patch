@@ -0,0 +1,52 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task<T = unknown> {
+  id: string;
+  status: TaskStatus;
+  payload: T;
+  createdAt: Date;
+  queue: string;
+  priority: number;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffMs: number;
+  error?: string;
+  dependencies: string[];
+  resolvedDependencies: Set<string>;
+  progress: number;
+  progressMessage?: string;
+}
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffMs?: number;
+  dependencies?: string[];
+}
+
+export interface Schedule {
+  id: string;
+  cronExpr: string;
+  queue: string;
+  payload: unknown;
+  options?: Omit<TaskOptions, 'queue'>;
+  lastRun?: Date;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFn = (task: Task) => Promise<void>;
+export type ProgressCallback = (progress: number, message?: string) => void;
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownSummary {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
