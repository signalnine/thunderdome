@@ -0,0 +1,647 @@
+import {
+  Task,
+  TaskOptions,
+  Schedule,
+  MiddlewareFn,
+  HandlerFn,
+  ProgressCallback,
+  ShutdownOptions,
+  ShutdownSummary,
+} from './types.js';
+import { generateId, parseCron, shouldRunAt } from './utils.js';
+
+const DEFAULT_QUEUE = 'default';
+
+export class TaskQueue {
+  private tasks: Map<string, Task> = new Map();
+  private queues: Map<string, string[]> = new Map(); // queue name -> task IDs in insertion order
+  private deadLetterQueues: Map<string, string[]> = new Map(); // queue name -> task IDs
+  private concurrencyLimits: Map<string, number> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private middleware: Map<string, MiddlewareFn[]> = new Map();
+  private handlers: Map<string, HandlerFn> = new Map();
+  private progressSubscriptions: Map<string, Set<ProgressCallback>> = new Map();
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+  private isShutdown = false;
+  private shutdownPromise: Promise<ShutdownSummary> | null = null;
+
+  // --- Phase 1: Basic FIFO Queue ---
+
+  add<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {
+    if (this.isShutdown) {
+      throw new Error('Queue system is shut down. Cannot add new tasks.');
+    }
+
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+    const priority = options.priority ?? 5;
+
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Validate dependencies
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      const depTask = this.tasks.get(depId);
+      if (!depTask) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+
+    // Check for circular dependencies
+    if (dependencies.length > 0) {
+      // We need to check if adding this task would create a cycle.
+      // Since the task doesn't exist yet, we check if any dependency
+      // transitively depends on... well, the task doesn't exist yet,
+      // so direct circular deps are only possible if a dep depends on
+      // another dep that depends on... We check transitive deps.
+      // Actually, since the new task doesn't exist yet, there can't be
+      // a circular dependency involving it. But we should check if
+      // there are cycles among the dependencies themselves.
+      // The real circular dependency check matters when tasks reference each other.
+    }
+
+    let availableAt: Date;
+    if (options.availableAt) {
+      availableAt = options.availableAt;
+    } else if (options.delay && options.delay > 0) {
+      availableAt = new Date(Date.now() + options.delay);
+    } else {
+      availableAt = new Date();
+    }
+
+    const task: Task<T> = {
+      id: generateId(),
+      status: 'pending',
+      payload,
+      createdAt: new Date(),
+      queue: queueName,
+      priority,
+      availableAt,
+      attempts: 0,
+      maxRetries: options.maxRetries ?? 3,
+      backoffMs: options.backoffMs ?? 1000,
+      dependencies,
+      resolvedDependencies: new Set<string>(),
+      progress: 0,
+    };
+
+    // Check circular dependencies with the new task ID
+    if (dependencies.length > 0) {
+      this.detectCircularDependencies(task.id, dependencies);
+    }
+
+    this.tasks.set(task.id, task as Task);
+
+    // Ensure queue exists
+    if (!this.queues.has(queueName)) {
+      this.queues.set(queueName, []);
+    }
+    this.queues.get(queueName)!.push(task.id);
+
+    // Check which dependencies are already resolved
+    for (const depId of dependencies) {
+      const depTask = this.tasks.get(depId)!;
+      if (depTask.status === 'completed') {
+        task.resolvedDependencies.add(depId);
+      }
+    }
+
+    return task;
+  }
+
+  process(queueName: string = DEFAULT_QUEUE): Task | null {
+    const queueTaskIds = this.queues.get(queueName);
+    if (!queueTaskIds || queueTaskIds.length === 0) {
+      return null;
+    }
+
+    // Check concurrency limit
+    const concurrencyLimit = this.concurrencyLimits.get(queueName);
+    if (concurrencyLimit !== undefined) {
+      const activeCount = this.getActiveCount(queueName);
+      if (activeCount >= concurrencyLimit) {
+        return null;
+      }
+    }
+
+    const now = new Date();
+
+    // Find best candidate: available, not blocked by dependencies
+    // Sort by: priority (asc), then availableAt (asc), then createdAt (asc/FIFO)
+    let bestTask: Task | null = null;
+
+    for (let i = 0; i < queueTaskIds.length; i++) {
+      const task = this.tasks.get(queueTaskIds[i])!;
+
+      // Skip non-pending tasks
+      if (task.status !== 'pending') continue;
+
+      // Skip tasks not yet available
+      if (task.availableAt > now) continue;
+
+      // Skip tasks with unresolved dependencies
+      if (task.dependencies.length > 0) {
+        const allResolved = task.dependencies.every(depId => task.resolvedDependencies.has(depId));
+        if (!allResolved) continue;
+      }
+
+      if (bestTask === null) {
+        bestTask = task;
+      } else {
+        // Compare: priority (lower number = higher priority), then availableAt, then FIFO (createdAt)
+        if (task.priority < bestTask.priority) {
+          bestTask = task;
+        } else if (task.priority === bestTask.priority) {
+          // Same priority: compare availableAt
+          if (task.availableAt < bestTask.availableAt) {
+            bestTask = task;
+          } else if (task.availableAt.getTime() === bestTask.availableAt.getTime()) {
+            // Same availableAt: FIFO (earlier createdAt wins)
+            if (task.createdAt < bestTask.createdAt) {
+              bestTask = task;
+            }
+          }
+        }
+      }
+    }
+
+    if (bestTask === null) {
+      return null;
+    }
+
+    bestTask.status = 'processing';
+    bestTask.attempts += 1;
+
+    return bestTask;
+  }
+
+  size(queueName: string = DEFAULT_QUEUE): number {
+    const queueTaskIds = this.queues.get(queueName);
+    if (!queueTaskIds) return 0;
+
+    return queueTaskIds.filter(id => {
+      const task = this.tasks.get(id)!;
+      return task.status === 'pending';
+    }).length;
+  }
+
+  // --- Phase 2: Named Queues ---
+
+  getQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // --- Phase 5: Retry with Backoff ---
+
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);
+    }
+
+    task.status = 'completed';
+
+    // Check for tasks that depend on this one and mark dependency as resolved
+    for (const [, t] of this.tasks) {
+      if (t.dependencies.includes(taskId)) {
+        t.resolvedDependencies.add(taskId);
+      }
+    }
+  }
+
+  fail(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task ${taskId} is not in processing state (current: ${task.status})`);
+    }
+
+    task.error = error;
+
+    if (task.attempts < task.maxRetries) {
+      // Re-enqueue with backoff delay
+      const delay = task.backoffMs * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.progress = 0;
+      task.progressMessage = undefined;
+    } else {
+      // Exhausted retries
+      task.status = 'failed';
+
+      // Move to dead letter queue
+      const dlqKey = task.queue;
+      if (!this.deadLetterQueues.has(dlqKey)) {
+        this.deadLetterQueues.set(dlqKey, []);
+      }
+      this.deadLetterQueues.get(dlqKey)!.push(task.id);
+
+      // Remove from active queue
+      const queueTaskIds = this.queues.get(task.queue);
+      if (queueTaskIds) {
+        const idx = queueTaskIds.indexOf(task.id);
+        if (idx !== -1) {
+          queueTaskIds.splice(idx, 1);
+        }
+      }
+    }
+  }
+
+  // --- Phase 6: Dead Letter Queue ---
+
+  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {
+    const dlqIds = this.deadLetterQueues.get(queueName);
+    if (!dlqIds) return [];
+    return dlqIds.map(id => this.tasks.get(id)!);
+  }
+
+  requeue(taskId: string): Task {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+
+    // Remove from DLQ
+    const dlqIds = this.deadLetterQueues.get(task.queue);
+    if (!dlqIds) {
+      throw new Error(`Task ${taskId} is not in a dead letter queue`);
+    }
+    const idx = dlqIds.indexOf(taskId);
+    if (idx === -1) {
+      throw new Error(`Task ${taskId} is not in a dead letter queue`);
+    }
+    dlqIds.splice(idx, 1);
+
+    // Reset task for fresh retries
+    task.status = 'pending';
+    task.attempts = 0;
+    task.error = undefined;
+    task.availableAt = new Date();
+    task.progress = 0;
+    task.progressMessage = undefined;
+
+    // Add back to queue
+    if (!this.queues.has(task.queue)) {
+      this.queues.set(task.queue, []);
+    }
+    this.queues.get(task.queue)!.push(task.id);
+
+    return task;
+  }
+
+  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {
+    const dlqIds = this.deadLetterQueues.get(queueName);
+    if (dlqIds) {
+      for (const id of dlqIds) {
+        this.tasks.delete(id);
+      }
+      this.deadLetterQueues.set(queueName, []);
+    }
+  }
+
+  // --- Phase 7: Task Dependencies ---
+
+  private detectCircularDependencies(newTaskId: string, dependencies: string[]): void {
+    // BFS/DFS from each dependency to check if any of them transitively
+    // depend on newTaskId. Since newTaskId doesn't exist yet in the graph,
+    // this check is about whether any dependency chain forms a cycle
+    // through the new task.
+
+    // Actually, since the new task doesn't exist yet, no other task can
+    // depend on it. So circular dependencies with the new task are impossible
+    // at creation time. However, we should check if dependencies themselves
+    // form valid references and that there are no issues.
+
+    // The real check: do any of the dependencies depend on each other in a way
+    // that would create a cycle? No — the cycle would need to include the new task.
+    // Since no existing task can reference the new task (it doesn't exist yet),
+    // a circular dependency is only possible if a dependency transitively depends
+    // on another one of the new task's dependencies — but that's not a cycle involving
+    // the new task.
+
+    // Wait — the requirement says "detect and reject circular dependencies at creation time".
+    // This means: if task A depends on task B, and task B depends on task A, then adding
+    // B should fail. But since A was added first (depending on B which doesn't exist yet),
+    // that would fail at "non-existent dependency" check. So the real scenario is:
+    // Task A exists. Task B is added depending on A. Task C is added depending on B.
+    // Then task D is added depending on C AND A depends on D — but A already exists.
+
+    // The only way to create a cycle: task A depends on task B, task B depends on task A.
+    // But task A was created first, and at that time B didn't exist, so A's creation would
+    // fail with "non-existent dependency". So... cycles can only happen with chains.
+
+    // Actually, let me reconsider. Dependencies are checked at creation. Let's say:
+    // 1. Create task A (no deps)
+    // 2. Create task B (depends on A) — OK
+    // 3. Create task C (depends on B) — OK
+    // Now if we try to make A depend on C — but A already exists and its deps are set.
+    // So actually, with immutable dependencies at creation, circular deps are impossible
+    // because you can't reference a task that doesn't exist yet.
+
+    // But to be safe and match the requirement, let's still check:
+    // For each dependency, walk the dependency chain and ensure we don't see any of
+    // the other dependencies creating a loop.
+    void newTaskId;
+    void dependencies;
+    // No-op: circular dependencies are structurally impossible when deps must exist at creation.
+  }
+
+  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; unresolved: string[] } {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+
+    const resolved = task.dependencies.filter(depId => task.resolvedDependencies.has(depId));
+    const unresolved = task.dependencies.filter(depId => !task.resolvedDependencies.has(depId));
+
+    return {
+      dependencies: [...task.dependencies],
+      resolved,
+      unresolved,
+    };
+  }
+
+  // --- Phase 8: Concurrency Control ---
+
+  setConcurrency(queueName: string, limit: number): void {
+    if (limit < 1 || !Number.isInteger(limit)) {
+      throw new Error(`Invalid concurrency limit: ${limit}`);
+    }
+    this.concurrencyLimits.set(queueName, limit);
+  }
+
+  getConcurrency(queueName: string): number | undefined {
+    return this.concurrencyLimits.get(queueName);
+  }
+
+  getActiveCount(queueName: string = DEFAULT_QUEUE): number {
+    const queueTaskIds = this.queues.get(queueName);
+    if (!queueTaskIds) return 0;
+    return queueTaskIds.filter(id => {
+      const task = this.tasks.get(id)!;
+      return task.status === 'processing';
+    }).length;
+  }
+
+  // --- Phase 9: Progress & Cancellation ---
+
+  reportProgress(taskId: string, percent: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task ${taskId} is not in processing state`);
+    }
+
+    task.progress = percent;
+    task.progressMessage = message;
+
+    // Notify subscribers
+    const subs = this.progressSubscriptions.get(taskId);
+    if (subs) {
+      for (const cb of subs) {
+        cb(percent, message);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, callback: ProgressCallback): () => void {
+    if (!this.progressSubscriptions.has(taskId)) {
+      this.progressSubscriptions.set(taskId, new Set());
+    }
+    this.progressSubscriptions.get(taskId)!.add(callback);
+
+    return () => {
+      const subs = this.progressSubscriptions.get(taskId);
+      if (subs) {
+        subs.delete(callback);
+      }
+    };
+  }
+
+  cancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task not found: ${taskId}`);
+    }
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Task ${taskId} cannot be cancelled (current: ${task.status})`);
+    }
+
+    task.status = 'cancelled';
+
+    // Remove from queue if pending
+    const queueTaskIds = this.queues.get(task.queue);
+    if (queueTaskIds) {
+      const idx = queueTaskIds.indexOf(task.id);
+      if (idx !== -1) {
+        queueTaskIds.splice(idx, 1);
+      }
+    }
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return this.tasks.get(taskId);
+  }
+
+  // --- Phase 10: Recurring Tasks ---
+
+  addSchedule(id: string, cronExpr: string, queueName: string, payload: unknown, options?: Omit<TaskOptions, 'queue'>): Schedule {
+    if (this.isShutdown) {
+      throw new Error('Queue system is shut down.');
+    }
+
+    // Validate cron expression by parsing it
+    parseCron(cronExpr);
+
+    const schedule: Schedule = {
+      id,
+      cronExpr,
+      queue: queueName,
+      payload,
+      options,
+    };
+
+    this.schedules.set(id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(id: string): void {
+    this.schedules.delete(id);
+  }
+
+  getSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const created: Task[] = [];
+
+    for (const [, schedule] of this.schedules) {
+      const cronSchedule = parseCron(schedule.cronExpr);
+      if (shouldRunAt(cronSchedule, currentTime, schedule.lastRun)) {
+        const task = this.add(schedule.payload, {
+          ...schedule.options,
+          queue: schedule.queue,
+        });
+        schedule.lastRun = currentTime;
+        created.push(task as Task);
+      }
+    }
+
+    return created;
+  }
+
+  // --- Phase 11: Middleware Pipeline ---
+
+  use(queueName: string, fn: MiddlewareFn): void {
+    if (!this.middleware.has(queueName)) {
+      this.middleware.set(queueName, []);
+    }
+    this.middleware.get(queueName)!.push(fn);
+  }
+
+  setHandler(queueName: string, fn: HandlerFn): void {
+    this.handlers.set(queueName, fn);
+  }
+
+  async processWithMiddleware(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {
+    const task = this.process(queueName);
+    if (!task) return null;
+
+    const middlewareStack = this.middleware.get(queueName) ?? [];
+    const handler = this.handlers.get(queueName);
+
+    let index = 0;
+    let handlerCalled = false;
+
+    const executeNext = async (): Promise<void> => {
+      if (index < middlewareStack.length) {
+        const mw = middlewareStack[index++];
+        await mw(task, executeNext);
+      } else if (handler && !handlerCalled) {
+        handlerCalled = true;
+        await handler(task);
+      }
+    };
+
+    try {
+      await executeNext();
+    } catch (err) {
+      // Middleware/handler error: fail the task
+      const errorMsg = err instanceof Error ? err.message : String(err);
+      task.error = errorMsg;
+      task.status = 'failed';
+
+      // Move to DLQ if retries exhausted
+      if (task.attempts >= task.maxRetries) {
+        const dlqKey = task.queue;
+        if (!this.deadLetterQueues.has(dlqKey)) {
+          this.deadLetterQueues.set(dlqKey, []);
+        }
+        this.deadLetterQueues.get(dlqKey)!.push(task.id);
+
+        const queueTaskIds = this.queues.get(task.queue);
+        if (queueTaskIds) {
+          const idx = queueTaskIds.indexOf(task.id);
+          if (idx !== -1) {
+            queueTaskIds.splice(idx, 1);
+          }
+        }
+      } else {
+        // Re-enqueue with backoff
+        const delay = task.backoffMs * Math.pow(2, task.attempts - 1);
+        task.status = 'pending';
+        task.availableAt = new Date(Date.now() + delay);
+      }
+    }
+
+    return task;
+  }
+
+  // --- Phase 12: Graceful Shutdown ---
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(options: ShutdownOptions = {}): Promise<ShutdownSummary> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShutdown = true;
+    this.shutdownPromise = this.performShutdown(options);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(options: ShutdownOptions): Promise<ShutdownSummary> {
+    const startTime = Date.now();
+    const timeout = options.timeout ?? 30000;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Find all currently processing tasks
+    const processingTasks: Task[] = [];
+    for (const [, task] of this.tasks) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    let completed = 0;
+    let forceCancelled = 0;
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        duration: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete, up to timeout
+    const waitStart = Date.now();
+    while (Date.now() - waitStart < timeout) {
+      const stillProcessing = processingTasks.filter(t => t.status === 'processing');
+      if (stillProcessing.length === 0) break;
+      await new Promise(resolve => setTimeout(resolve, 50));
+    }
+
+    // Count completed and force-cancel remaining
+    for (const task of processingTasks) {
+      if (task.status === 'completed') {
+        completed++;
+      } else if (task.status === 'processing') {
+        task.status = 'cancelled';
+        forceCancelled++;
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+}
