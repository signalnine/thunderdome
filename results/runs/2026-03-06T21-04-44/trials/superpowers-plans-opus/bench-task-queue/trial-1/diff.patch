d('task1');\n    queue.add('task2');\n\n    expect(queue.getActiveCount()).toBe(0);\n\n    queue.process();\n    expect(queue.getActiveCount()).toBe(1);\n\n    queue.process();\n    expect(queue.getActiveCount()).toBe(2);\n  });\n\n  it('should allow multiple concurrent tasks up to limit', () => {\n    queue.setConcurrency('default', 3);\n\n    queue.add('t1');\n    queue.add('t2');\n    queue.add('t3');\n    queue.add('t4');\n\n    expect(queue.process()).not.toBeNull();\n    expect(queue.process()).not.toBeNull();\n    expect(queue.process()).not.toBeNull();\n    expect(queue.process()).toBeNull(); // At limit\n  });\n\n  it('should still respect priority ordering with concurrency', () => {\n    queue.setConcurrency('default', 1);\n\n    queue.add('low', { priority: 10 });\n    queue.add('high', { priority: 1 });\n\n    const t = queue.process()!;\n    expect(t.payload).toBe('high');\n  });\n\n  it('should work per-queue', () => {\n    queue.setConcurrency('q1', 1);\n    // q2 has no limit\n\n    queue.add('q1-t1', { queue: 'q1' });\n    queue.add('q1-t2', { queue: 'q1' });\n    queue.add('q2-t1', { queue: 'q2' });\n    queue.add('q2-t2', { queue: 'q2' });\n\n    expect(queue.process('q1')).not.toBeNull();\n    expect(queue.process('q1')).toBeNull(); // At limit\n\n    expect(queue.process('q2')).not.toBeNull();\n    expect(queue.process('q2')).not.toBeNull(); // No limit\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3897,"cache_read_input_tokens":37456,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3897},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"469ec06b-c50f-485d-b15e-988b43ea0527","uuid":"f94e11f4-7431-4eb3-9bc3-61c0b31d32c9"}
