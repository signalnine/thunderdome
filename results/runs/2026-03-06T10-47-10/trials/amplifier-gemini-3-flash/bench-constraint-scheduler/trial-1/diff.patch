new file mode 100644
index 0000000..1a6df02
--- /dev/null
+++ b/src/scheduler.ts
@@ -0,0 +1,241 @@
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+
+  // 1. Check for prerequisite cycles
+  validatePrerequisites(events);
+
+  // 2. Prepare data structures
+  const eventMap = new Map<string, Event>(events.map((e) => [e.id, e]));
+  const assignments = new Map<string, Assignment>();
+  const unscheduled: string[] = [];
+
+  // 3. Sort events for scheduling
+  // Heuristic: Process events with more prerequisites first, or those that are prerequisites for others.
+  // Actually, a topological-like order is necessary for prerequisites.
+  const orderedEvents = getSchedulingOrder(events);
+
+  // 4. Scheduling loop
+  for (const eventId of orderedEvents) {
+    const event = eventMap.get(eventId)!;
+    const success = tryScheduleEvent(event, rooms, options, gap, assignments);
+    if (!success) {
+      unscheduled.push(eventId);
+    }
+  }
+
+  return {
+    assignments: Array.from(assignments.values()),
+    unscheduled,
+  };
+}
+
+function validatePrerequisites(events: Event[]): void {
+  const adj = new Map<string, string[]>();
+  for (const event of events) {
+    adj.set(event.id, event.prerequisites ?? []);
+  }
+
+  const visited = new Set<string>();
+  const recStack = new Set<string>();
+
+  function hasCycle(u: string): boolean {
+    visited.add(u);
+    recStack.add(u);
+
+    const neighbors = adj.get(u) ?? [];
+    for (const v of neighbors) {
+      if (!visited.has(v)) {
+        if (hasCycle(v)) return true;
+      } else if (recStack.has(v)) {
+        return true;
+      }
+    }
+
+    recStack.delete(u);
+    return false;
+  }
+
+  for (const event of events) {
+    if (!visited.has(event.id)) {
+      if (hasCycle(event.id)) {
+        throw new Error(`Prerequisite cycle detected involving event: ${event.id}`);
+      }
+    }
+  }
+}
+
+function getSchedulingOrder(events: Event[]): string[] {
+  const adj = new Map<string, string[]>();
+  const inDegree = new Map<string, number>();
+  const allIds = events.map((e) => e.id);
+  const eventMap = new Map<string, Event>(events.map((e) => [e.id, e]));
+
+  for (const id of allIds) {
+    inDegree.set(id, 0);
+  }
+
+  for (const event of events) {
+    for (const pre of event.prerequisites ?? []) {
+      if (!adj.has(pre)) adj.set(pre, []);
+      adj.get(pre)!.push(event.id);
+      inDegree.set(event.id, (inDegree.get(event.id) || 0) + 1);
+    }
+  }
+
+  // Calculate "weight" for each event to prioritize those that unblock more/longer chains
+  const weights = new Map<string, number>();
+  function calculateWeight(u: string): number {
+    if (weights.has(u)) return weights.get(u)!;
+    let maxChildWeight = 0;
+    for (const v of adj.get(u) ?? []) {
+      maxChildWeight = Math.max(maxChildWeight, calculateWeight(v));
+    }
+    // Weight is duration of this event + max duration of any dependent chain
+    const weight = (eventMap.get(u)?.duration ?? 0) + maxChildWeight;
+    weights.set(u, weight);
+    return weight;
+  }
+  for (const id of allIds) {
+    calculateWeight(id);
+  }
+
+  const queue: string[] = [];
+  for (const id of allIds) {
+    if (inDegree.get(id) === 0) {
+      queue.push(id);
+    }
+  }
+
+  const order: string[] = [];
+  while (queue.length > 0) {
+    // Sort queue by weight descending (unblock longest chains first)
+    // then by duration ascending (maximizes count for independent events)
+    queue.sort((a, b) => {
+      const weightDiff = (weights.get(b) || 0) - (weights.get(a) || 0);
+      if (weightDiff !== 0) return weightDiff;
+      return (eventMap.get(a)?.duration ?? 0) - (eventMap.get(b)?.duration ?? 0);
+    });
+
+    const u = queue.shift()!;
+    order.push(u);
+
+    for (const v of adj.get(u) ?? []) {
+      inDegree.set(v, inDegree.get(v)! - 1);
+      if (inDegree.get(v) === 0) {
+        queue.push(v);
+      }
+    }
+  }
+
+  return order;
+}
+
+function tryScheduleEvent(
+  event: Event,
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number,
+  assignments: Map<string, Assignment>
+): boolean {
+  const attendees = event.attendees ?? 1;
+
+  // Calculate earliest possible start time based on prerequisites
+  let earliestStart = options.startTime;
+  for (const preId of event.prerequisites ?? []) {
+    const preAssignment = assignments.get(preId);
+    if (!preAssignment) {
+      // Prerequisite not scheduled, so this event can't be scheduled
+      return false;
+    }
+    earliestStart = Math.max(earliestStart, preAssignment.endTime + gap);
+  }
+
+  // Filter rooms by capacity
+  const suitableRooms = rooms.filter((r) => r.capacity >= attendees);
+
+  // Sort rooms: preferred room first, then by capacity (smaller first to save larger rooms)
+  suitableRooms.sort((a, b) => {
+    if (a.id === event.preferredRoom) return -1;
+    if (b.id === event.preferredRoom) return 1;
+    return a.capacity - b.capacity;
+  });
+
+  for (const room of suitableRooms) {
+    const roomAssignments = Array.from(assignments.values())
+      .filter((a) => a.roomId === room.id)
+      .sort((a, b) => a.startTime - b.startTime);
+
+    // Try to find a slot in this room
+    let possibleStart = earliestStart;
+    
+    while (possibleStart + event.duration <= options.endTime) {
+      const possibleEnd = possibleStart + event.duration;
+      
+      // Check for overlap with existing assignments in this room
+      const overlap = roomAssignments.some((a) => {
+        // Check if [possibleStart, possibleEnd] overlaps with [a.startTime - gap, a.endTime + gap]
+        // Actually, the gap is only needed BETWEEN events.
+        // So we need:
+        // possibleEnd + gap <= a.startTime OR a.endTime + gap <= possibleStart
+        return !(possibleEnd + gap <= a.startTime || a.endTime + gap <= possibleStart);
+      });
+
+      if (!overlap) {
+        assignments.set(event.id, {
+          eventId: event.id,
+          roomId: room.id,
+          startTime: possibleStart,
+          endTime: possibleEnd,
+        });
+        return true;
+      }
+
+      // Move to next possible start time: after the next conflicting event
+      const nextConflict = roomAssignments.find((a) => !(possibleEnd + gap <= a.startTime || a.endTime + gap <= possibleStart));
+      if (nextConflict) {
+        possibleStart = nextConflict.endTime + gap;
+      } else {
+        break;
+      }
+    }
+  }
+
+  return false;
+}
diff --git a/tests/scheduler.test.ts b/tests/scheduler.test.ts
new file mode 100644
index 0000000..77cea37
--- /dev/null
+++ b/tests/scheduler.test.ts
@@ -0,0 +1,118 @@
+import { describe, it, expect } from 'vitest';
+import { schedule, Event, Room, ScheduleOptions } from '../src/scheduler';
+
+describe('Event Scheduler', () => {
+  const rooms: Room[] = [
+    { id: 'r1', name: 'Room 1', capacity: 10 },
+    { id: 'r2', name: 'Room 2', capacity: 20 },
+  ];
+
+  const options: ScheduleOptions = {
+    startTime: 540, // 9:00 AM
+    endTime: 1020,  // 5:00 PM
+    gap: 15,
+  };
+
+  it('should schedule a single event', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Event 1', duration: 60, attendees: 5 },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(1);
+    expect(result.unscheduled).toHaveLength(0);
+    expect(result.assignments[0].eventId).toBe('e1');
+    expect(result.assignments[0].startTime).toBe(540);
+    expect(result.assignments[0].endTime).toBe(600);
+  });
+
+  it('should respect room capacity', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Big Event', duration: 60, attendees: 15 },
+    ];
+    const smallRooms: Room[] = [{ id: 'r1', name: 'Small', capacity: 10 }];
+    const result = schedule(events, smallRooms, options);
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toContain('e1');
+  });
+
+  it('should respect time window', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Long Event', duration: 600, attendees: 5 },
+    ];
+    const result = schedule(events, rooms, options); // 9AM to 5PM is 480 mins
+    expect(result.assignments).toHaveLength(0);
+    expect(result.unscheduled).toContain('e1');
+  });
+
+  it('should respect room gaps', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'E1', duration: 60 },
+      { id: 'e2', name: 'E2', duration: 60 },
+    ];
+    const singleRoom: Room[] = [{ id: 'r1', name: 'R1', capacity: 10 }];
+    const result = schedule(events, singleRoom, options);
+    expect(result.assignments).toHaveLength(2);
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    
+    // Check gap
+    const first = a1.startTime < a2.startTime ? a1 : a2;
+    const second = a1.startTime < a2.startTime ? a2 : a1;
+    expect(second.startTime).toBeGreaterThanOrEqual(first.endTime + 15);
+  });
+
+  it('should respect prerequisites', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Intro', duration: 60 },
+      { id: 'e2', name: 'Advanced', duration: 60, prerequisites: ['e1'] },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments).toHaveLength(2);
+    const a1 = result.assignments.find(a => a.eventId === 'e1')!;
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);
+  });
+
+  it('should throw on prerequisite cycles', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'A', duration: 60, prerequisites: ['e2'] },
+      { id: 'e2', name: 'B', duration: 60, prerequisites: ['e1'] },
+    ];
+    expect(() => schedule(events, rooms, options)).toThrow(/cycle/i);
+  });
+
+  it('should honor preferred room if possible', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Pref', duration: 60, preferredRoom: 'r2' },
+    ];
+    const result = schedule(events, rooms, options);
+    expect(result.assignments[0].roomId).toBe('r2');
+  });
+
+  it('should schedule in another room if preferred room is full', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'Occupier', duration: 480 }, // Fills R2
+      { id: 'e2', name: 'Pref', duration: 60, preferredRoom: 'r2' },
+    ];
+    // We need to ensure e1 is scheduled first or takes R2
+    const result = schedule([
+      { id: 'e1', name: 'Occupier', duration: 480, preferredRoom: 'r2' },
+      { id: 'e2', name: 'Pref', duration: 60, preferredRoom: 'r2' }
+    ], rooms, options);
+    
+    const a2 = result.assignments.find(a => a.eventId === 'e2')!;
+    expect(a2.roomId).toBe('r1');
+  });
+
+  it('should handle unschedulable events', () => {
+    const events: Event[] = [
+      { id: 'e1', name: 'E1', duration: 300 },
+      { id: 'e2', name: 'E2', duration: 300 },
+      { id: 'e3', name: 'E3', duration: 300 },
+    ];
+    const singleRoom: Room[] = [{ id: 'r1', name: 'R1', capacity: 10 }];
+    const result = schedule(events, singleRoom, options);
+    expect(result.assignments.length).toBeLessThan(3);
+    expect(result.unscheduled.length).toBeGreaterThan(0);
+  });
+});
