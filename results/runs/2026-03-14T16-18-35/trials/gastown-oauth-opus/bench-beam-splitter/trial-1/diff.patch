--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,121 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface BeamState {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): number {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') return col;
+  }
+  return -1;
+}
+
+function nextPosition(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function stateKey(row: number, col: number, dir: Direction): string {
+  return `${row},${col},${dir}`;
+}
+
+function cellKey(row: number, col: number): string {
+  return `${row},${col}`;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const sourceCol = findSource(grid);
+  if (sourceCol === -1) return 0;
+
+  const visitedCells = new Set<string>();
+  const seenStates = new Set<string>();
+  const queue: BeamState[] = [];
+
+  // Start at source cell
+  visitedCells.add(cellKey(0, sourceCol));
+  queue.push({ row: 0, col: sourceCol, dir: 'down' });
+  seenStates.add(stateKey(0, sourceCol, 'down'));
+
+  while (queue.length > 0) {
+    const { row, col, dir } = queue.shift()!;
+
+    // Check what's at the current cell
+    const cell = grid[row][col];
+
+    if (cell === '^') {
+      // Splitter: split into down-left and down-right
+      const dirs: Direction[] = ['down-left', 'down-right'];
+      for (const newDir of dirs) {
+        const [nr, nc] = nextPosition(row, col, newDir);
+        if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
+          const sk = stateKey(nr, nc, newDir);
+          if (!seenStates.has(sk)) {
+            seenStates.add(sk);
+            visitedCells.add(cellKey(nr, nc));
+            queue.push({ row: nr, col: nc, dir: newDir });
+          }
+        }
+      }
+    } else {
+      // Continue in current direction
+      const [nr, nc] = nextPosition(row, col, dir);
+      if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
+        const sk = stateKey(nr, nc, dir);
+        if (!seenStates.has(sk)) {
+          seenStates.add(sk);
+          visitedCells.add(cellKey(nr, nc));
+          queue.push({ row: nr, col: nc, dir: dir });
+        }
+      }
+    }
+  }
+
+  return visitedCells.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const sourceCol = findSource(grid);
+  if (sourceCol === -1) return 0n;
+
+  // Memoization: for a beam at (row, col, dir), how many paths reach an exit?
+  const memo = new Map<string, bigint>();
+
+  function countPaths(row: number, col: number, dir: Direction): bigint {
+    // If out of bounds, this beam has exited — counts as 1 complete path
+    if (row < 0 || row >= rows || col < 0 || col >= cols) {
+      return 1n;
+    }
+
+    const key = stateKey(row, col, dir);
+    if (memo.has(key)) return memo.get(key)!;
+
+    let result: bigint;
+    const cell = grid[row][col];
+
+    if (cell === '^') {
+      // Splitter: split into down-left and down-right
+      const [lr, lc] = nextPosition(row, col, 'down-left');
+      const [rr, rc] = nextPosition(row, col, 'down-right');
+      result = countPaths(lr, lc, 'down-left') + countPaths(rr, rc, 'down-right');
+    } else {
+      // Continue in current direction
+      const [nr, nc] = nextPosition(row, col, dir);
+      result = countPaths(nr, nc, dir);
+    }
+
+    memo.set(key, result);
+    return result;
+  }
+
+  return countPaths(0, sourceCol, 'down');
+}
