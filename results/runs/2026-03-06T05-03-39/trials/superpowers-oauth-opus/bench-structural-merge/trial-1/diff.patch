+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 1, newField: 'hello' });
+    });
+
+    it('merge with multiple documents, some conflicting some not', () => {
+      store.create('doc1', { a: 1 });
+      store.create('doc2', { x: 10 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100 }); // conflict
+      store.update('doc2', { x: 20 }); // no conflict (only source changed)
+      store.switchBranch('main');
+      store.update('doc1', { a: 200 }); // conflict
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].documentId).toBe('doc1');
+      // doc2 should NOT be applied since there's a conflict on doc1
+      expect(store.get('doc2')).toEqual({ x: 10 });
+    });
+
+    it('does not apply merge when there are conflicts', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 2 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 3 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      // Main branch still has its own value
+      expect(store.get('doc1')).toEqual({ a: 3 });
+    });
+
+    it('handles deeply nested three-way merge', () => {
+      store.create('doc1', { level1: { level2: { a: 1, b: 2, c: 3 } } });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { level1: { level2: { a: 10, b: 2, c: 3 } } });
+      store.switchBranch('main');
+      store.update('doc1', { level1: { level2: { a: 1, b: 2, c: 30 } } });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ level1: { level2: { a: 10, b: 2, c: 30 } } });
+    });
+
+    it('merge creates a version for merged document', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 2 });
+      store.switchBranch('main');
+      const historyBefore = store.getHistory('doc1');
+      store.merge('feature');
+      const historyAfter = store.getHistory('doc1');
+      expect(historyAfter.length).toBe(historyBefore.length + 1);
+      expect(historyAfter[historyAfter.length - 1].content).toEqual({ a: 2 });
+    });
+
+    it('handles arrays as field values in merge', () => {
+      store.create('doc1', { tags: ['a', 'b'], name: 'test' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { tags: ['a', 'b', 'c'], name: 'test' });
+      store.switchBranch('main');
+      store.update('doc1', { tags: ['a', 'b'], name: 'updated' });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ tags: ['a', 'b', 'c'], name: 'updated' });
+    });
+
+    it('detects conflict on array field when both sides change it differently', () => {
+      store.create('doc1', { tags: ['a'] });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { tags: ['a', 'b'] });
+      store.switchBranch('main');
+      store.update('doc1', { tags: ['a', 'c'] });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].path).toBe('tags');
+    });
+
+    it('merged output contains unchanged documents that exist on target', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+      const result = store.merge('feature');
+      expect(result.merged['doc1']).toEqual({ a: 1 });
+    });
+  });
+});
