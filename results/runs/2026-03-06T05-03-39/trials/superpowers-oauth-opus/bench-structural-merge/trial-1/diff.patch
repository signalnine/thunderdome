--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,479 @@
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: any;
+  ours: any;
+  theirs: any;
+}
+
+interface DocumentEntry {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchData {
+  documents: Map<string, DocumentEntry>;
+  parentBranch: string | null;
+  branchPointSnapshot: Map<string, DocumentEntry> | null;
+}
+
+function clone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+function cloneDocumentEntry(entry: DocumentEntry): DocumentEntry {
+  return {
+    content: clone(entry.content),
+    versions: entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: clone(v.content),
+    })),
+    deleted: entry.deleted,
+  };
+}
+
+function cloneDocMap(map: Map<string, DocumentEntry>): Map<string, DocumentEntry> {
+  const result = new Map<string, DocumentEntry>();
+  for (const [key, value] of map) {
+    result.set(key, cloneDocumentEntry(value));
+  }
+  return result;
+}
+
+let versionCounter = 0;
+
+function generateVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+function getAllPaths(obj: any, prefix: string = ''): string[] {
+  const paths: string[] = [];
+  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {
+    return paths;
+  }
+  for (const key of Object.keys(obj)) {
+    const fullPath = prefix ? `${prefix}.${key}` : key;
+    paths.push(fullPath);
+    if (typeof obj[key] === 'object' && obj[key] !== null && !Array.isArray(obj[key])) {
+      paths.push(...getAllPaths(obj[key], fullPath));
+    }
+  }
+  return paths;
+}
+
+function getAtPath(obj: any, path: string): any {
+  const parts = path.split('.');
+  let current = obj;
+  for (const part of parts) {
+    if (current === null || current === undefined || typeof current !== 'object') {
+      return undefined;
+    }
+    current = current[part];
+  }
+  return current;
+}
+
+function setAtPath(obj: any, path: string, value: any): void {
+  const parts = path.split('.');
+  let current = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (current[parts[i]] === undefined || current[parts[i]] === null || typeof current[parts[i]] !== 'object') {
+      current[parts[i]] = {};
+    }
+    current = current[parts[i]];
+  }
+  current[parts[parts.length - 1]] = value;
+}
+
+function deleteAtPath(obj: any, path: string): void {
+  const parts = path.split('.');
+  let current = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (current[parts[i]] === undefined || typeof current[parts[i]] !== 'object') {
+      return;
+    }
+    current = current[parts[i]];
+  }
+  delete current[parts[parts.length - 1]];
+}
+
+function hasAtPath(obj: any, path: string): boolean {
+  const parts = path.split('.');
+  let current = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (current === null || current === undefined || typeof current !== 'object') {
+      return false;
+    }
+    current = current[parts[i]];
+  }
+  if (current === null || current === undefined || typeof current !== 'object') {
+    return false;
+  }
+  return parts[parts.length - 1] in current;
+}
+
+// Collect all leaf paths from an object
+function getLeafPaths(obj: any, prefix: string = ''): string[] {
+  const paths: string[] = [];
+  if (obj === null || obj === undefined || typeof obj !== 'object' || Array.isArray(obj)) {
+    return paths;
+  }
+  for (const key of Object.keys(obj)) {
+    const fullPath = prefix ? `${prefix}.${key}` : key;
+    const val = obj[key];
+    if (typeof val === 'object' && val !== null && !Array.isArray(val)) {
+      paths.push(...getLeafPaths(val, fullPath));
+    } else {
+      paths.push(fullPath);
+    }
+  }
+  return paths;
+}
+
+function deepEqual(a: any, b: any): boolean {
+  return JSON.stringify(a) === JSON.stringify(b);
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', {
+      documents: new Map(),
+      parentBranch: null,
+      branchPointSnapshot: null,
+    });
+  }
+
+  private getBranchData(name?: string): BranchData {
+    const branchName = name ?? this.currentBranch;
+    const branch = this.branches.get(branchName);
+    if (!branch) {
+      throw new Error(`Branch "${branchName}" does not exist`);
+    }
+    return branch;
+  }
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: clone(content),
+    };
+    branch.documents.set(id, {
+      content: clone(content),
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return clone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: clone(content),
+    };
+    doc.content = clone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    doc.deleted = true;
+  }
+
+  getHistory(id: string): Version[] {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: clone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getBranchData();
+    const doc = branch.documents.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return clone(version.content);
+  }
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceBranchName = fromBranch ?? this.currentBranch;
+    const sourceBranch = this.getBranchData(sourceBranchName);
+    this.branches.set(name, {
+      documents: cloneDocMap(sourceBranch.documents),
+      parentBranch: sourceBranchName,
+      branchPointSnapshot: cloneDocMap(sourceBranch.documents),
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    const source = this.getBranchData(sourceBranch);
+    const target = this.getBranchData();
+
+    // Find common ancestor - the branch point snapshot
+    // We need to find the common ancestor. For branches created from the current branch,
+    // the branchPointSnapshot on the source represents the state of the target at branch time.
+    // For branches created from a different branch, we need to use the source's branchPointSnapshot.
+    let baseSnapshot: Map<string, DocumentEntry>;
+
+    // Determine the base: the snapshot of the state when the source branch was created
+    if (source.branchPointSnapshot) {
+      baseSnapshot = source.branchPointSnapshot;
+    } else {
+      // main branch merging into another? Use the target's branchPointSnapshot
+      if (target.branchPointSnapshot) {
+        baseSnapshot = target.branchPointSnapshot;
+      } else {
+        baseSnapshot = new Map();
+      }
+    }
+
+    // Collect all document IDs across base, source, and target
+    const allDocIds = new Set<string>();
+    for (const key of baseSnapshot.keys()) allDocIds.add(key);
+    for (const key of source.documents.keys()) allDocIds.add(key);
+    for (const key of target.documents.keys()) allDocIds.add(key);
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+    const changesToApply: Array<{ id: string; content: object | null }> = []; // null = delete
+
+    for (const docId of allDocIds) {
+      const baseEntry = baseSnapshot.get(docId);
+      const sourceEntry = source.documents.get(docId);
+      const targetEntry = target.documents.get(docId);
+
+      const baseContent = (baseEntry && !baseEntry.deleted) ? baseEntry.content : undefined;
+      const sourceContent = (sourceEntry && !sourceEntry.deleted) ? sourceEntry.content : undefined;
+      const targetContent = (targetEntry && !targetEntry.deleted) ? targetEntry.content : undefined;
+
+      const sourceChanged = !deepEqual(baseContent, sourceContent);
+      const targetChanged = !deepEqual(baseContent, targetContent);
+
+      if (!sourceChanged && !targetChanged) {
+        // No changes - keep target as is
+        if (targetContent !== undefined) {
+          merged[docId] = clone(targetContent);
+        }
+        continue;
+      }
+
+      if (sourceChanged && !targetChanged) {
+        // Only source changed - take source
+        if (sourceContent !== undefined) {
+          merged[docId] = clone(sourceContent);
+          changesToApply.push({ id: docId, content: clone(sourceContent) });
+        } else {
+          // Source deleted
+          changesToApply.push({ id: docId, content: null });
+        }
+        continue;
+      }
+
+      if (!sourceChanged && targetChanged) {
+        // Only target changed - keep target
+        if (targetContent !== undefined) {
+          merged[docId] = clone(targetContent);
+        }
+        continue;
+      }
+
+      // Both changed - need field-level merge
+      if (sourceContent === undefined && targetContent === undefined) {
+        // Both deleted - no conflict
+        changesToApply.push({ id: docId, content: null });
+        continue;
+      }
+
+      if (sourceContent === undefined || targetContent === undefined) {
+        // One deleted, one modified - conflict at document level
+        // For "ours" resolution, keep target
+        if (targetContent !== undefined) {
+          merged[docId] = clone(targetContent);
+        }
+        conflicts.push({
+          documentId: docId,
+          path: '',
+          base: baseContent !== undefined ? clone(baseContent) : undefined,
+          ours: targetContent !== undefined ? clone(targetContent) : undefined,
+          theirs: sourceContent !== undefined ? clone(sourceContent) : undefined,
+        });
+        continue;
+      }
+
+      // Both modified - do field-level three-way merge
+      const baseObj = baseContent ?? {};
+      const sourceObj = sourceContent;
+      const targetObj = targetContent;
+
+      // Collect all leaf paths from all three
+      const allPaths = new Set<string>();
+      for (const p of getLeafPaths(baseObj)) allPaths.add(p);
+      for (const p of getLeafPaths(sourceObj)) allPaths.add(p);
+      for (const p of getLeafPaths(targetObj)) allPaths.add(p);
+
+      const mergedDoc = clone(targetObj);
+      let docConflicts: Conflict[] = [];
+
+      for (const path of allPaths) {
+        const baseVal = getAtPath(baseObj, path);
+        const sourceVal = getAtPath(sourceObj, path);
+        const targetVal = getAtPath(targetObj, path);
+
+        const baseHas = hasAtPath(baseObj, path);
+        const sourceHas = hasAtPath(sourceObj, path);
+        const targetHas = hasAtPath(targetObj, path);
+
+        const sourceFieldChanged = !deepEqual(baseVal, sourceVal) || (baseHas !== sourceHas);
+        const targetFieldChanged = !deepEqual(baseVal, targetVal) || (baseHas !== targetHas);
+
+        if (!sourceFieldChanged) {
+          // Source didn't change this field, keep target's value (already in mergedDoc)
+          continue;
+        }
+
+        if (!targetFieldChanged) {
+          // Only source changed - take source's value
+          if (sourceHas) {
+            setAtPath(mergedDoc, path, clone(sourceVal));
+          } else {
+            deleteAtPath(mergedDoc, path);
+          }
+          continue;
+        }
+
+        // Both changed
+        if (deepEqual(sourceVal, targetVal) && sourceHas === targetHas) {
+          // Both changed to same value - no conflict
+          continue;
+        }
+
+        // Conflict!
+        docConflicts.push({
+          documentId: docId,
+          path,
+          base: baseHas ? clone(baseVal) : undefined,
+          ours: targetHas ? clone(targetVal) : undefined,
+          theirs: sourceHas ? clone(sourceVal) : undefined,
+        });
+        // For merged output, keep "ours" (target) - already in mergedDoc
+      }
+
+      merged[docId] = mergedDoc;
+      conflicts.push(...docConflicts);
+
+      if (docConflicts.length === 0) {
+        changesToApply.push({ id: docId, content: clone(mergedDoc) });
+      }
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      // Apply changes to target branch
+      for (const change of changesToApply) {
+        if (change.content === null) {
+          // Delete
+          const doc = target.documents.get(change.id);
+          if (doc) {
+            doc.deleted = true;
+          }
+        } else {
+          const existing = target.documents.get(change.id);
+          if (existing && !existing.deleted) {
+            // Update
+            const version: Version = {
+              id: generateVersionId(),
+              timestamp: Date.now(),
+              content: clone(change.content),
+            };
+            existing.content = clone(change.content);
+            existing.versions.push(version);
+          } else {
+            // Create (new doc from source or previously deleted)
+            const version: Version = {
+              id: generateVersionId(),
+              timestamp: Date.now(),
+              content: clone(change.content),
+            };
+            target.documents.set(change.id, {
+              content: clone(change.content),
+              versions: [version],
+              deleted: false,
+            });
+          }
+        }
+      }
+    }
+
+    return { merged, conflicts, applied };
+  }
+}
