+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('Document CRUD', () => {
+    it('creates and retrieves a document', () => {
+      store.create('doc1', { title: 'Hello' });
+      expect(store.get('doc1')).toEqual({ title: 'Hello' });
+    });
+
+    it('throws when creating a document with duplicate id', () => {
+      store.create('doc1', { title: 'Hello' });
+      expect(() => store.create('doc1', { title: 'World' })).toThrow();
+    });
+
+    it('throws when getting a non-existent document', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+
+    it('updates a document', () => {
+      store.create('doc1', { title: 'Hello' });
+      store.update('doc1', { title: 'Updated' });
+      expect(store.get('doc1')).toEqual({ title: 'Updated' });
+    });
+
+    it('throws when updating a non-existent document', () => {
+      expect(() => store.update('nonexistent', { title: 'x' })).toThrow();
+    });
+
+    it('deletes a document', () => {
+      store.create('doc1', { title: 'Hello' });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('throws when deleting a non-existent document', () => {
+      expect(() => store.delete('nonexistent')).toThrow();
+    });
+
+    it('deep clones on create - mutation of original does not affect stored', () => {
+      const content = { title: 'Hello', nested: { value: 1 } };
+      store.create('doc1', content);
+      content.nested.value = 999;
+      expect(store.get('doc1')).toEqual({ title: 'Hello', nested: { value: 1 } });
+    });
+
+    it('deep clones on get - mutation of retrieved does not affect stored', () => {
+      store.create('doc1', { title: 'Hello', nested: { value: 1 } });
+      const retrieved = store.get('doc1') as any;
+      retrieved.nested.value = 999;
+      expect(store.get('doc1')).toEqual({ title: 'Hello', nested: { value: 1 } });
+    });
+
+    it('deep clones on update', () => {
+      store.create('doc1', { title: 'Hello' });
+      const content = { title: 'Updated', nested: { value: 1 } };
+      store.update('doc1', content);
+      content.nested.value = 999;
+      expect(store.get('doc1')).toEqual({ title: 'Updated', nested: { value: 1 } });
+    });
+  });
+
+  describe('Version History', () => {
+    it('tracks versions on create', () => {
+      store.create('doc1', { title: 'Hello' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(1);
+      expect(history[0].content).toEqual({ title: 'Hello' });
+      expect(history[0].id).toBeDefined();
+      expect(history[0].timestamp).toBeGreaterThan(0);
+    });
+
+    it('tracks versions on update', () => {
+      store.create('doc1', { title: 'v1' });
+      store.update('doc1', { title: 'v2' });
+      store.update('doc1', { title: 'v3' });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ title: 'v1' });
+      expect(history[1].content).toEqual({ title: 'v2' });
+      expect(history[2].content).toEqual({ title: 'v3' });
+    });
+
+    it('returns versions in chronological order', () => {
+      store.create('doc1', { title: 'v1' });
+      store.update('doc1', { title: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);
+    });
+
+    it('assigns unique version IDs', () => {
+      store.create('doc1', { title: 'v1' });
+      store.update('doc1', { title: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(history[0].id).not.toBe(history[1].id);
+    });
+
+    it('retrieves content at a specific version', () => {
+      store.create('doc1', { title: 'v1' });
+      store.update('doc1', { title: 'v2' });
+      const history = store.getHistory('doc1');
+      expect(store.getVersion('doc1', history[0].id)).toEqual({ title: 'v1' });
+      expect(store.getVersion('doc1', history[1].id)).toEqual({ title: 'v2' });
+    });
+
+    it('throws on getHistory for non-existent document', () => {
+      expect(() => store.getHistory('nonexistent')).toThrow();
+    });
+
+    it('throws on getVersion for non-existent version', () => {
+      store.create('doc1', { title: 'v1' });
+      expect(() => store.getVersion('doc1', 'bad-version')).toThrow();
+    });
+
+    it('throws on getVersion for non-existent document', () => {
+      expect(() => store.getVersion('nonexistent', 'v1')).toThrow();
+    });
+  });
+
+  describe('Branching', () => {
+    it('defaults to main branch', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('lists branches', () => {
+      expect(store.listBranches()).toEqual(['main']);
+    });
+
+    it('creates a branch from current branch', () => {
+      store.createBranch('feature');
+      expect(store.listBranches()).toContain('feature');
+    });
+
+    it('switches branch', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    it('throws when switching to non-existent branch', () => {
+      expect(() => store.switchBranch('nonexistent')).toThrow();
+    });
+
+    it('throws when creating duplicate branch', () => {
+      store.createBranch('feature');
+      expect(() => store.createBranch('feature')).toThrow();
+    });
+
+    it('isolates documents between branches', () => {
+      store.create('doc1', { title: 'main-doc' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc2', { title: 'feature-doc' });
+      store.switchBranch('main');
+      expect(() => store.get('doc2')).toThrow();
+      expect(store.get('doc1')).toEqual({ title: 'main-doc' });
+    });
+
+    it('new branch inherits documents from parent', () => {
+      store.create('doc1', { title: 'Hello' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.get('doc1')).toEqual({ title: 'Hello' });
+    });
+
+    it('changes on branch do not affect parent', () => {
+      store.create('doc1', { title: 'original' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { title: 'changed' });
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ title: 'original' });
+    });
+
+    it('creates a branch from a specific branch', () => {
+      store.create('doc1', { title: 'main-v1' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { title: 'feature-v1' });
+      store.switchBranch('main');
+      store.createBranch('from-feature', 'feature');
+      store.switchBranch('from-feature');
+      expect(store.get('doc1')).toEqual({ title: 'feature-v1' });
+    });
+  });
+
+  describe('Merging', () => {
+    it('merges when only source branch changed a document', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, b: 3 });
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 1, b: 3 });
+      expect(store.get('doc1')).toEqual({ a: 1, b: 3 });
+    });
+
+    it('keeps target changes when only target changed', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('main');
+      store.update('doc1', { a: 1, b: 99 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 1, b: 99 });
+    });
+
+    it('merges non-conflicting changes from both branches', () => {
+      store.create('doc1', { a: 1, b: 2, c: 3 });
+      store.createBranch('feature');
+      // source changes field a
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2, c: 3 });
+      // target changes field b
+      store.switchBranch('main');
+      store.update('doc1', { a: 1, b: 20, c: 3 });
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 3 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 20, c: 3 });
+    });
+
+    it('detects conflicts when both branches change same field differently', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100, b: 2 });
+      store.switchBranch('main');
+      store.update('doc1', { a: 200, b: 2 });
