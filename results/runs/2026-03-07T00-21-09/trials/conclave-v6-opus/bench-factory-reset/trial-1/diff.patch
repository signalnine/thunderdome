+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix [numLights x (numButtons + 1)] over GF(2)
+  const matrix: number[][] = [];
+  for (let r = 0; r < numLights; r++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let c = 0; c < numButtons; c++) {
+      if (buttons[c].includes(r)) {
+        row[c] = 1;
+      }
+    }
+    row[numButtons] = target[r] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotCol: number[] = [];
+  let row = 0;
+  for (let col = 0; col < numButtons && row < numLights; col++) {
+    let pivotRow = -1;
+    for (let r = row; r < numLights; r++) {
+      if (matrix[r][col] === 1) { pivotRow = r; break; }
+    }
+    if (pivotRow === -1) continue;
+    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];
+    for (let r = 0; r < numLights; r++) {
+      if (r !== row && matrix[r][col] === 1) {
+        for (let c = 0; c <= numButtons; c++) matrix[r][c] ^= matrix[row][c];
+      }
+    }
+    pivotCol.push(col);
+    row++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check for inconsistency
+  for (let r = rank; r < numLights; r++) {
+    if (matrix[r][numButtons] === 1) return null;
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let c = 0; c < numButtons; c++) {
+    if (!pivotSet.has(c)) freeVars.push(c);
+  }
+
+  const numFree = freeVars.length;
+
+  // Precompute pivot dependencies on free variables
+  const pivotDeps: number[][] = [];
+  const pivotConstArr: number[] = [];
+  for (let i = 0; i < rank; i++) {
+    const deps: number[] = [];
+    for (let fi = 0; fi < numFree; fi++) {
+      if (matrix[i][freeVars[fi]] === 1) deps.push(fi);
+    }
+    pivotDeps.push(deps);
+    pivotConstArr.push(matrix[i][numButtons]);
+  }
+
+  const computeSolution = (freeAssign: number): number[] => {
+    const solution = new Array(numButtons).fill(0);
+    for (let fi = 0; fi < numFree; fi++) {
+      solution[freeVars[fi]] = (freeAssign >> fi) & 1;
+    }
+    for (let i = 0; i < rank; i++) {
+      let val = pivotConstArr[i];
+      for (const fi of pivotDeps[i]) val ^= (freeAssign >> fi) & 1;
+      solution[pivotCol[i]] = val;
+    }
+    return solution;
+  };
+
+  const countOnes = (solution: number[]): number => {
+    let c = 0;
+    for (let i = 0; i < solution.length; i++) c += solution[i];
+    return c;
+  };
+
+  if (numFree <= 20) {
+    let bestPressed: number[] | null = null;
+    let bestCount = numButtons + 1;
+
+    for (let mask = 0; mask < (1 << numFree); mask++) {
+      const solution = computeSolution(mask);
+      const count = countOnes(solution);
+      if (count < bestCount) {
+        bestCount = count;
+        bestPressed = solutionToPressed(solution);
+      } else if (count === bestCount) {
+        const pressed = solutionToPressed(solution);
+        if (lexSmallerArray(pressed, bestPressed!)) bestPressed = pressed;
+      }
+    }
+    return bestPressed!;
+  }
+
+  // Meet-in-the-middle for > 20 free variables.
+  // Since numFree > 20 implies rank < 20 (rank + numFree = numButtons <= 40),
+  // the number of distinct pivot-signature keys is at most 2^rank < 2^20.
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+
+  // Encode pivot deps as bitmasks for each half
+  const pivotDepMaskA: number[] = [];
+  const pivotDepMaskB: number[] = [];
+  let pivotConstBitmask = 0;
+  for (let i = 0; i < rank; i++) {
+    let mA = 0, mB = 0;
+    for (const fi of pivotDeps[i]) {
+      if (fi < halfA) mA |= (1 << fi);
+      else mB |= (1 << (fi - halfA));
+    }
+    pivotDepMaskA.push(mA);
+    pivotDepMaskB.push(mB);
+    if (pivotConstArr[i]) pivotConstBitmask |= (1 << i);
+  }
+
+  const popcount = (n: number): number => {
+    let c = 0;
+    while (n) { c += n & 1; n >>>= 1; }
+    return c;
+  };
+
+  // keyA encodes which pivot variables would be 1 given halfA assignment
+  // keyA = pivotConst XOR partialA (bitmask over rank pivot rows)
+  const computeKeyA = (freeA: number): number => {
+    let key = pivotConstBitmask;
+    for (let i = 0; i < rank; i++) {
+      if (popcount(freeA & pivotDepMaskA[i]) & 1) key ^= (1 << i);
+    }
+    return key;
+  };
+
+  // Phase 1: enumerate halfA, group by keyA, keep min-cost entry per key
+  const keyMap = new Map<number, { costA: number; freeA: number }>();
+  for (let freeA = 0; freeA < (1 << halfA); freeA++) {
+    const keyA = computeKeyA(freeA);
+    const costA = popcount(freeA);
+    const existing = keyMap.get(keyA);
+    if (!existing || costA < existing.costA) {
+      keyMap.set(keyA, { costA, freeA });
+    }
+  }
+
+  // Phase 2: enumerate halfB, for each try all keyA entries
+  // Total ones = costA + costB + popcount(keyA XOR pivotBitsB)
+  let bestCount2 = numButtons + 1;
+  let bestFreeA = 0;
+  let bestFreeB = 0;
+
+  for (let freeB = 0; freeB < (1 << halfB); freeB++) {
+    let pivotBitsB = 0;
+    for (let i = 0; i < rank; i++) {
+      if (popcount(freeB & pivotDepMaskB[i]) & 1) pivotBitsB |= (1 << i);
+    }
+    const costB = popcount(freeB);
+
+    for (const [keyA, { costA, freeA }] of keyMap) {
+      const total = costA + costB + popcount(keyA ^ pivotBitsB);
+      if (total < bestCount2) {
+        bestCount2 = total;
+        bestFreeA = freeA;
+        bestFreeB = freeB;
+      } else if (total === bestCount2) {
+        const curPressed = solutionToPressed(computeSolution(bestFreeA | (bestFreeB << halfA)));
+        const newPressed = solutionToPressed(computeSolution(freeA | (freeB << halfA)));
+        if (lexSmallerArray(newPressed, curPressed)) {
+          bestFreeA = freeA;
+          bestFreeB = freeB;
+        }
+      }
+    }
+  }
+
+  return solutionToPressed(computeSolution(bestFreeA | (bestFreeB << halfA)));
+}
+
+function solutionToPressed(solution: number[]): number[] {
+  const pressed: number[] = [];
+  for (let c = 0; c < solution.length; c++) {
+    if (solution[c] === 1) pressed.push(c);
+  }
+  return pressed;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  // Build augmented matrix [numCounters x (numButtons + 1)] over GF(p)
+  const matrix: number[][] = [];
+  for (let r = 0; r < numCounters; r++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let c = 0; c < numButtons; c++) {
+      if (buttons[c].includes(r)) row[c] = 1;
+    }
+    row[numButtons] = ((lights[r] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotCol: number[] = [];
+  let row = 0;
+  for (let col = 0; col < numButtons && row < numCounters; col++) {
+    let pivotRow = -1;
+    for (let r = row; r < numCounters; r++) {
+      if (matrix[r][col] !== 0) { pivotRow = r; break; }
+    }
+    if (pivotRow === -1) continue;
+    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];
+
+    const inv = modInverse(matrix[row][col], modulus);
+    for (let c = 0; c <= numButtons; c++) {
+      matrix[row][c] = (matrix[row][c] * inv) % modulus;
+    }
+
+    for (let r = 0; r < numCounters; r++) {
+      if (r !== row && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[r][c] = ((matrix[r][c] - factor * matrix[row][c]) % modulus + modulus) % modulus;
+        }
+      }
+    }
+    pivotCol.push(col);
+    row++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check for inconsistency
+  for (let r = rank; r < numCounters; r++) {
+    if (matrix[r][numButtons] !== 0) return null;
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let c = 0; c < numButtons; c++) {
+    if (!pivotSet.has(c)) freeVars.push(c);
+  }
+
+  const numFree = freeVars.length;
+
+  // Precompute pivot dependencies
+  const pivotDeps: { fi: number; coeff: number }[][] = [];
+  const pivotConstArr: number[] = [];
+  for (let i = 0; i < rank; i++) {
+    const deps: { fi: number; coeff: number }[] = [];
+    for (let fi = 0; fi < numFree; fi++) {
+      if (matrix[i][freeVars[fi]] !== 0) {
+        deps.push({ fi, coeff: matrix[i][freeVars[fi]] });
+      }
+    }
+    pivotDeps.push(deps);
+    pivotConstArr.push(matrix[i][numButtons]);
+  }
+
+  const computeSolution = (freeVals: number[]): number[] => {
+    const solution = new Array(numButtons).fill(0);
+    for (let fi = 0; fi < numFree; fi++) solution[freeVars[fi]] = freeVals[fi];
+    for (let i = 0; i < rank; i++) {
+      let val = pivotConstArr[i];
+      for (const { fi, coeff } of pivotDeps[i]) {
+        val = ((val - coeff * freeVals[fi]) % modulus + modulus) % modulus;
+      }
+      solution[pivotCol[i]] = val;
+    }
+    return solution;
+  };
+
+  const totalPresses = (solution: number[]): number => {
+    let sum = 0;
+    for (let i = 0; i < solution.length; i++) sum += solution[i];
+    return sum;
+  };
+
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  if (numFree === 0 || totalCombinations <= 5_000_000) {
+    // Direct enumeration
+    let bestSolution: number[] | null = null;
+    let bestTotal = Infinity;
+    const freeVals = new Array(numFree).fill(0);
+
+    for (let combo = 0; combo < totalCombinations; combo++) {
+      let temp = combo;
+      for (let i = 0; i < numFree; i++) {
+        freeVals[i] = temp % modulus;
+        temp = Math.floor(temp / modulus);
+      }
+      const solution = computeSolution(freeVals);
+      const total = totalPresses(solution);
+      if (total < bestTotal || (total === bestTotal && lexSmallerArray(solution, bestSolution!))) {
+        bestTotal = total;
+        bestSolution = [...solution];
+      }
+    }
+    return bestSolution!;
+  }
+
+  // Meet-in-the-middle for large search spaces
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+  const sizeA = Math.pow(modulus, halfA);
+  const sizeB = Math.pow(modulus, halfB);
+
+  const encodeKey = (partials: number[]): string => partials.join(',');
+
+  // Phase 1: enumerate halfA, group by pivot partial effects
+  const keyMapC = new Map<string, { costA: number; freeA: number[] }>();
+
+  for (let comboA = 0; comboA < sizeA; comboA++) {
+    const freeValsA = new Array(halfA);
+    let temp = comboA;
+    for (let i = 0; i < halfA; i++) {
+      freeValsA[i] = temp % modulus;
+      temp = Math.floor(temp / modulus);
+    }
+
+    let costA = 0;
+    for (let i = 0; i < halfA; i++) costA += freeValsA[i];
+
+    const partials = new Array(rank);
+    for (let i = 0; i < rank; i++) {
+      let partial = 0;
+      for (const { fi, coeff } of pivotDeps[i]) {
+        if (fi < halfA) partial = (partial + coeff * freeValsA[fi]) % modulus;
+      }
+      partials[i] = partial;
+    }
+
+    const key = encodeKey(partials);
+    const existing = keyMapC.get(key);
+    if (!existing || costA < existing.costA ||
+        (costA === existing.costA && lexSmallerArray(freeValsA, existing.freeA))) {
+      keyMapC.set(key, { costA, freeA: [...freeValsA] });
+    }
+  }
+
+  // Phase 2: enumerate halfB, combine with best halfA for each pivot signature
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  for (let comboB = 0; comboB < sizeB; comboB++) {
+    const freeValsB = new Array(halfB);
+    let temp = comboB;
+    for (let i = 0; i < halfB; i++) {
+      freeValsB[i] = temp % modulus;
+      temp = Math.floor(temp / modulus);
+    }
+
+    let costB = 0;
+    for (let i = 0; i < halfB; i++) costB += freeValsB[i];
+
+    const partialsB = new Array(rank);
+    for (let i = 0; i < rank; i++) {
+      let partial = 0;
+      for (const { fi, coeff } of pivotDeps[i]) {
+        if (fi >= halfA) partial = (partial + coeff * freeValsB[fi - halfA]) % modulus;
+      }
+      partialsB[i] = partial;
+    }
+
+    for (const [keyStr, { costA, freeA }] of keyMapC) {
+      const partialsA = keyStr.split(',').map(Number);
+
+      let pivotCost = 0;
+      for (let i = 0; i < rank; i++) {
+        pivotCost += ((pivotConstArr[i] - partialsA[i] - partialsB[i]) % modulus + modulus * 2) % modulus;
+      }
+
+      const total = costA + costB + pivotCost;
+      if (total < bestTotal) {
+        bestTotal = total;
+        bestSolution = computeSolution([...freeA, ...freeValsB]);
+      } else if (total === bestTotal) {
+        const candidate = computeSolution([...freeA, ...freeValsB]);
+        if (lexSmallerArray(candidate, bestSolution!)) bestSolution = candidate;
+      }
+    }
+  }
+
+  return bestSolution;
+}
+
+function modInverse(a: number, m: number): number {
+  let [old_r, r] = [((a % m) + m) % m, m];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % m) + m) % m;
+}
+
+function lexSmallerArray(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
