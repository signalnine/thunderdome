\n  }\n\n  // Gaussian elimination over GF(2)\n  const pivotCol: number[] = [];\n  let row = 0;\n  for (let col = 0; col < numButtons && row < numLights; col++) {\n    let pivotRow = -1;\n    for (let r = row; r < numLights; r++) {\n      if (matrix[r][col] === 1) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];\n    for (let r = 0; r < numLights; r++) {\n      if (r !== row && matrix[r][col] === 1) {\n        for (let c = 0; c <= numButtons; c++) {\n          matrix[r][c] ^= matrix[row][c];\n        }\n      }\n    }\n    pivotCol.push(col);\n    row++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < numLights; r++) {\n    if (matrix[r][numButtons] === 1) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let c = 0; c < numButtons; c++) {\n    if (!pivotSet.has(c)) {\n      freeVars.push(c);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // For each pivot row i, precompute which free variables affect it\n  // pivotDeps[i] = list of free variable indices (into freeVars array) that have coefficient 1\n  // pivotConst[i] = the constant term (from augmented column)\n  const pivotDeps: number[][] = [];\n  const pivotConst: number[] = [];\n  for (let i = 0; i < rank; i++) {\n    const deps: number[] = [];\n    for (let fi = 0; fi < numFree; fi++) {\n      if (matrix[i][freeVars[fi]] === 1) {\n        deps.push(fi);\n      }\n    }\n    pivotDeps.push(deps);\n    pivotConst.push(matrix[i][numButtons]);\n  }\n\n  // Compute solution from free variable assignment (given as bitmask over freeVars)\n  const computeSolution = (freeAssign: number): number[] => {\n    const solution = new Array(numButtons).fill(0);\n    for (let fi = 0; fi < numFree; fi++) {\n      solution[freeVars[fi]] = (freeAssign >> fi) & 1;\n    }\n    for (let i = 0; i < rank; i++) {\n      let val = pivotConst[i];\n      for (const fi of pivotDeps[i]) {\n        val ^= (freeAssign >> fi) & 1;\n      }\n      solution[pivotCol[i]] = val;\n    }\n    return solution;\n  };\n\n  // Count ones in a solution\n  const countOnes = (solution: number[]): number => {\n    let count = 0;\n    for (let i = 0; i < solution.length; i++) {\n      count += solution[i];\n    }\n    return count;\n  };\n\n  if (numFree <= 20) {\n    // Direct enumeration\n    let bestPressed: number[] | null = null;\n    let bestCount = numButtons + 1;\n\n    for (let mask = 0; mask < (1 << numFree); mask++) {\n      const solution = computeSolution(mask);\n      const count = countOnes(solution);\n      if (count < bestCount) {\n        bestCount = count;\n        bestPressed = solutionToPressed(solution);\n      } else if (count === bestCount) {\n        const pressed = solutionToPressed(solution);\n        if (lexSmallerArray(pressed, bestPressed!)) {\n          bestPressed = pressed;\n        }\n      }\n    }\n\n    return bestPressed!;\n  }\n\n  // Meet-in-the-middle for > 20 free variables\n  // Split free variables into two halves\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n\n  // For each half-A assignment, compute partial contribution to each pivot variable\n  // and partial count of ones (from free vars in A and affected pivot vars)\n  // Key: the partial effect vector (what half-B needs to \"complete\")\n  // We actually need to track: for each pivot row, the partial XOR from halfA free vars\n\n  // The approach: for half A, we enumerate all 2^halfA assignments.\n  // For each, we compute the full effect on the solution (partial, since halfB free vars are 0).\n  // We record: (count_of_ones, solution) grouped by the \"signature\" which is the\n  // set of pivot-row partial XOR values from halfA free vars.\n\n  // Actually, the simplest correct MITM for minimum weight:\n  // For each assignme