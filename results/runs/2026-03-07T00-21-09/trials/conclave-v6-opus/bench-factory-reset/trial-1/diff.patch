      }\n    }\n    if (pivotRow === -1) continue;\n    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];\n    for (let r = 0; r < numLights; r++) {\n      if (r !== row && matrix[r][col] === 1) {\n        for (let c = 0; c <= numButtons; c++) {\n          matrix[r][c] ^= matrix[row][c];\n        }\n      }\n    }\n    pivotCol.push(col);\n    row++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < numLights; r++) {\n    if (matrix[r][numButtons] === 1) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let c = 0; c < numButtons; c++) {\n    if (!pivotSet.has(c)) {\n      freeVars.push(c);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // For each pivot row i, precompute which free variables affect it\n  // pivotDeps[i] = list of free variable indices (into freeVars array) that have coefficient 1\n  // pivotConst[i] = the constant term (from augmented column)\n  const pivotDeps: number[][] = [];\n  const pivotConst: number[] = [];\n  for (let i = 0; i < rank; i++) {\n    const deps: number[] = [];\n    for (let fi = 0; fi < numFree; fi++) {\n      if (matrix[i][freeVars[fi]] === 1) {\n        deps.push(fi);\n      }\n    }\n    pivotDeps.push(deps);\n    pivotConst.push(matrix[i][numButtons]);\n  }\n\n  // Compute solution from free variable assignment (given as bitmask over freeVars)\n  const computeSolution = (freeAssign: number): number[] => {\n    const solution = new Array(numButtons).fill(0);\n    for (let fi = 0; fi < numFree; fi++) {\n      solution[freeVars[fi]] = (freeAssign >> fi) & 1;\n    }\n    for (let i = 0; i < rank; i++) {\n      let val = pivotConst[i];\n      for (const fi of pivotDeps[i]) {\n        val ^= (freeAssign >> fi) & 1;\n      }\n      solution[pivotCol[i]] = val;\n    }\n    return solution;\n  };\n\n  // Count ones in a solution\n  const countOnes = (solution: number[]): number => {\n    let count = 0;\n    for (let i = 0; i < solution.length; i++) {\n      count += solution[i];\n    }\n    return count;\n  };\n\n  if (numFree <= 20) {\n    // Direct enumeration\n    let bestSolution: number[] | null = null;\n    let bestCount = numButtons + 1;\n\n    for (let mask = 0; mask < (1 << numFree); mask++) {\n      const solution = computeSolution(mask);\n      const count = countOnes(solution);\n      if (count < bestCount) {\n        bestCount = count;\n        bestSolution = solution;\n      } else if (count === bestCount) {\n        if (lexSmallerSol(solution, bestSolution!)) {\n          bestSolution = solution;\n        }\n      }\n    }\n\n    return solutionToPressed(bestSolution!);\n  }\n\n  // Meet-in-the-middle for > 20 free variables\n  // Split free variables into two halves\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n\n  // For each half-A assignment, compute partial contribution to each pivot variable\n  // and partial count of ones (from free vars in A and affected pivot vars)\n  // Key: the partial effect vector (what half-B needs to \"complete\")\n  // We actually need to track: for each pivot row, the partial XOR from halfA free vars\n\n  // The approach: for half A, we enumerate all 2^halfA assignments.\n  // For each, we compute the full effect on the solution (partial, since halfB free vars are 0).\n  // We record: (count_of_ones, solution) grouped by the \"signature\" which is the\n  // set of pivot-row partial XOR values from halfA free vars.\n\n  // Actually, the simplest correct MITM for minimum weight:\n  // For each assignment of halfA, compute for each pivot variable:\n  //   partial_val_A[i] = pivotConst[i] XOR (XOR of halfA free vars with deps in pivotDeps[i])\n  // The full pivot value will be: partial_val_A[i] XOR partial_val_B[i]\n  // where partial_val_B[i] = XOR of halfB free vars with deps in pivotDeps[i]\n  //\n  // Total ones = (ones from halfA free vars) + (ones from halfB free vars) +\n  //              sum_over_pivots(partial_val_A[i] XOR partial_val_B[i])\n  //\n  // This isn't easily decomposable into independent halves because the pivot\n  // contributions depend on BOTH halves via XOR.\n\n  // Alternative approach: represent partial_val as a bitmask over pivots.\n  // For half A: compute pivotBitsA = bitmask of which pivot vars would be 1\n  //   if only halfA free vars are set (and halfB are all 0)\n  //   onesA = popcount(freeA bits) + popcount(pivotBitsA)\n  // For half B: compute pivotBitsB = bitmask of which pivot vars change from their\n  //   \"no halfB\" value when halfB vars are set\n  //   Actually: pivotBitsB = XOR contribution from halfB free vars only\n  //\n  // Full pivot bit i = pivotConst[i] XOR partialA[i] XOR partialB[i]\n  // So: pivotBits_full = pivotConst_bitmask XOR pivotBitsA_raw XOR pivotBitsB_raw\n  // where pivotBitsA_raw[i] = XOR of halfA free vars in deps of pivot i\n  //       pivotBitsB_raw[i] = XOR of halfB free vars in deps of pivot i\n  //\n  // Total ones = popcount(freeA_bits) + popcount(freeB_bits) +\n  //              popcount(pivotConst_bitmask XOR pivotBitsA_raw XOR pivotBitsB_raw)\n  //\n  // Let combined = pivotConst_bitmask XOR pivotBitsA_raw\n  // Total ones = popcount(freeA_bits) + popcount(freeB_bits) +\n  //              popcount(combined XOR pivotBitsB_raw)\n  //\n  // For fixed pivotBitsB_raw, we want to minimize:\n  //   popcount(freeA_bits) + popcount(combined XOR pivotBitsB_raw)\n  // = popcount(freeA_bits) + popcount((pivotConst XOR pivotBitsA_raw) XOR pivotBitsB_raw)\n  //\n  // If we define keyA = pivotConst XOR pivotBitsA_raw, then for fixed keyA,\n  // the contribution from A is: popcount(freeA_bits) + popcount(keyA XOR pivotBitsB_raw)\n  //\n  // For a given keyA and pivotBitsB_raw, the pivot contribution is fixed.\n  // So we want to group halfA assignments by keyA, keeping only the best (min freeA popcount, lex smallest).\n  // Then for each halfB assignment