\n    expect(elapsed).toBeLessThan(5000);\n    // Should press buttons 0..19 (minimum presses = 20, lex smallest)\n    expect(result).not.toBeNull();\n    expect(result!.length).toBe(20);\n  });\n\n  test('solveToggle MITM path: 5 lights 40 buttons (35 free vars) within 5 seconds', () => {\n    // 5 lights, 40 buttons. First 5 form identity, rest are duplicates of first 5 cyclically.\n    // This gives 35 free variables, exercising the MITM path.\n    const numLights = 5;\n    const numButtons = 40;\n    const target = new Array(numLights).fill(true);\n    const buttons: number[][] = [];\n    for (let i = 0; i < numButtons; i++) {\n      buttons.push([i % numLights]);\n    }\n    const start = Date.now();\n    const result = solveToggle({ target, buttons });\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).not.toBeNull();\n    expect(result!.length).toBe(5);\n  });","originalFile":"import { describe, test, expect } from 'vitest';\nimport { solveToggle, solveCounter } from './index.js';\n\ndescribe('solveToggle', () => {\n  test('single button toggles single light to on', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  test('no buttons needed when target is all off', () => {\n    const result = solveToggle({\n      target: [false, false],\n      buttons: [[0], [1]],\n    });\n    expect(result).toEqual([]);\n  });\n\n  test('returns null from example in TASK.md (no solution)', () => {\n    // target [T, T, F, T], buttons: {0,1}, {1,2,3}, {0,3}\n    // System is inconsistent as shown in TASK.md\n    const result = solveToggle({\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]],\n    });\n    expect(result).toBeNull();\n  });\n\n  test('selects minimum number of button presses', () => {\n    // Light 0 needs to be on. Button 0 toggles [0], Button 1 toggles [0].\n    // Either button alone works (1 press). Both together cancel out (0 != target).\n    // Minimum is 1 press. Lex smallest is [0].\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  test('two buttons needed', () => {\n    // target: [true, true], buttons: [0], [1]\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0], [1]],\n    });\n    expect(result).toEqual([0, 1]);\n  });\n\n  test('lexicographically smallest among equal-size solutions', () => {\n    // target: [true], buttons: [0], [0], [0]\n    // Any single button works. Lex smallest is [0].\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0], [0], [0]],\n    });\n    expect(result).toEqual([0]);\n  });\n\n  test('handles empty buttons list with non-trivial target', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [],\n    });\n    expect(result).toBeNull();\n  });\n\n  test('handles empty buttons list with all-off target', () => {\n    const result = solveToggle({\n      target: [false, false],\n      buttons: [],\n    });\n    expect(result).toEqual([]);\n  });\n\n  test('free variables: chooses fewer presses over more', () => {\n    // target: [true, false], buttons: [0,1], [0], [1]\n    // Equations: b0 XOR b1 = 1, b0 XOR b2 = 0\n    // From eq2: b2 = b0. Eq1: b0 XOR b1 = 1 => b1 = b0 XOR 1\n    // If b0=0: b1=1, b2=0 => press [1], total=1\n    // If b0=1: b1=0, b2=1 => press [0,2], total=2\n    // Min presses = 1, answer = [1]\n    const result = solveToggle({\n      target: [true, false],\n      buttons: [[0, 1], [0], [1]],\n    });\n    expect(result).toEqual([1]);\n  });\n});\n\ndescribe('solveCounter', () => {\n  test('single button single counter', () => {\n    // counter 0 needs value 3, button 0 increments counter 0, mod 5\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  test('no presses needed when target is all zeros', () => {\n    const result = solveCounter([0, 0], [[0], [1]], 5);\n    expect(result).toEqual([0, 0]);\n  });\n\n  test('returns null when no solution exists', () => {\n    // counter 0 needs value 1, but no buttons affect it\n    const result = solveCounter([1], [[], []], 3);\n    expect(result).toBeNull();\n  });\n\n  test('two independent counters', () => {\n    // counter 0 = 2, counter 1 = 3, mod 5\n    // button 0 affects counter 0, button 1 affects counter 1\n    const result = solveCounter([2, 3], [[0], [1]], 5);\n    expect(result).toEqual([2, 3]);\n  });\n\n  test('button affects multiple counters', () => {\n    // counter 0 = 1, counter 1 = 1, mod 3\n    // button 0 affects [0,1]\n    // pressing once gives [1,1] => done\n    const result = solveCounter([1, 1], [[0, 1]], 3);\n    expect(result).toEqual([1]);\n  });\n\n  test('minimum total presses among solutions', () => {\n    // counter 0 = 1, mod 3. button 0 affects [0], button 1 affects [0]\n    // Solutions: b0=1,b1=0 (total=1), b0=0,b1=1 (total=1), b0=2,b1=2 (total=4)\n    // Tied on total=1, lex smallest = [0, 1] vs [1, 0] => [0, 1]\n    const result = solveCounter([1], [[0], [0]], 3);\n    expect(result).toEqual([0, 1]);\n  });\n\n  test('lexicographically smallest result', () => {\n    // Same as above, verifying [0, 1] is chosen (lex smallest with min total)\n    const result = solveCounter([1], [[0], [0]], 3);\n    expect(result).toEqual([0, 1]);\n  });\n\n  test('handles empty buttons with non-zero target', () => {\n    const result = solveCounter([1], [], 5);\n    expect(result).toBeNull();\n  });\n\n  test('handles empty buttons with zero target', () => {\n    const result = solveCounter([0, 0], [], 5);\n    expect(result).toEqual([]);\n  });\n});\n\ndescribe('performance', () => {\n  test('solveToggle handles 40 buttons and 40 lights within 5 seconds', () => {\n    // Create a system where each button i toggles light i (identity matrix).\n    // All lights should be on. Unique solution: press all buttons.\n    // This has 0 free variables, so it's fast. But tests the matrix size.\n    const n = 40;\n    const target = new Array(n).fill(true);\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i]);\n    }\n    const start = Date.now();\n    const result = solveToggle({ target, buttons });\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(Array.from({ length: n }, (_, i) => i));\n  });\n\n  test('solveToggle handles many free variables within 5 seconds', () => {\n    // 20 lights but 40 buttons. First 20 buttons form identity for lights.\n    // Last 20 buttons each duplicate a light (same as button i-20).\n    // This gives 20 free variables.\n    const numLights = 20;\n    const numButtons = 40;\n    const target = new Array(numLights).fill(true);\n    const buttons: number[][] = [];\n    for (let i = 0; i < numLights; i++) {\n      buttons.push([i]);\n    }\n    for (let i = 0; i < numLights; i++) {\n      buttons.push([i]); // duplicate\n    }\n    const start = Date.now();\n    const result = solveToggle({ target, buttons });\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    // Should press buttons 0..19 (minimum presses = 20, lex smallest)\n    expect(result).not.toBeNull();\n    expect(result!.length).toBe(20);\n  });\n\n  test('solveCounter handles 40 buttons and 40 counters with mod 97 within 5 seconds', () => {\n    // Identity matrix: button i increments counter i. Target all 1s.\n    const n = 40;\n    const lights = new Array(n).fill(1);\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i]);\n    }\n    const start = Date.now();\n    const result = solveCounter(lights, buttons, 97);\n    const elapsed = Date.now() - start;\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(new Array(n).fill(1));\n  });\n\n  test('solveCounter