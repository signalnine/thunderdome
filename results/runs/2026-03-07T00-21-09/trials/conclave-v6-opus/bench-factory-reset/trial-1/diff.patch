    solution[pc] = val;\n   105→    }\n   106→\n   107→    // Count presses\n   108→    const pressed: number[] = [];\n   109→    for (let c = 0; c < numButtons; c++) {\n   110→      if (solution[c] === 1) {\n   111→        pressed.push(c);\n   112→      }\n   113→    }\n   114→\n   115→    const count = pressed.length;\n   116→    if (count < bestCount || (count === bestCount && lexSmaller(pressed, bestSolution!))) {\n   117→      bestCount = count;\n   118→      bestSolution = pressed;\n   119→    }\n   120→  }\n   121→\n   122→  return bestSolution!;\n   123→}\n   124→\n   125→function lexSmaller(a: number[], b: number[]): boolean {\n   126→  const len = Math.min(a.length, b.length);\n   127→  for (let i = 0; i < len; i++) {\n   128→    if (a[i] < b[i]) return true;\n   129→    if (a[i] > b[i]) return false;\n   130→  }\n   131→  return a.length < b.length;\n   132→}\n   133→\n   134→/**\n   135→ * Solve a counter puzzle using Gaussian elimination over GF(p).\n   136→ *\n   137→ * Similar structure to solveToggle but arithmetic is mod p.\n   138→ * Each button can be pressed 0..p-1 times. We solve the system\n   139→ * of linear equations mod p, then enumerate free variables to\n   140→ * find minimum total presses with lex-smallest tiebreaker.\n   141→ */\n   142→export function solveCounter(\n   143→  lights: number[],\n   144→  buttons: number[][],\n   145→  modulus: number\n   146→): number[] | null {\n   147→  const numCounters = lights.length;\n   148→  const numButtons = buttons.length;\n   149→\n   150→  // Build augmented matrix [numCounters x (numButtons + 1)]\n   151→  const matrix: number[][] = [];\n   152→  for (let r = 0; r < numCounters; r++) {\n   153→    const row = new Array(numButtons + 1).fill(0);\n   154→    for (let c = 0; c < numButtons; c++) {\n   155→      if (buttons[c].includes(r)) {\n   156→        row[c] = 1;\n   157→      }\n   158→    }\n   159→    row[numButtons] = lights[r] % modulus;\n   160→    matrix.push(row);\n   161→  }\n   