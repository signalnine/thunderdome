alB[i]\n  // So: pivotBits_full = pivotConst_bitmask XOR pivotBitsA_raw XOR pivotBitsB_raw\n  // where pivotBitsA_raw[i] = XOR of halfA free vars in deps of pivot i\n  //       pivotBitsB_raw[i] = XOR of halfB free vars in deps of pivot i\n  //\n  // Total ones = popcount(freeA_bits) + popcount(freeB_bits) +\n  //              popcount(pivotConst_bitmask XOR pivotBitsA_raw XOR pivotBitsB_raw)\n  //\n  // Let combined = pivotConst_bitmask XOR pivotBitsA_raw\n  // Total ones = popcount(freeA_bits) + popcount(freeB_bits) +\n  //              popcount(combined XOR pivotBitsB_raw)\n  //\n  // For fixed pivotBitsB_raw, we want to minimize:\n  //   popcount(freeA_bits) + popcount(combined XOR pivotBitsB_raw)\n  // = popcount(freeA_bits) + popcount((pivotConst XOR pivotBitsA_raw) XOR pivotBitsB_raw)\n  //\n  // If we define keyA = pivotConst XOR pivotBitsA_raw, then for fixed keyA,\n  // the contribution from A is: popcount(freeA_bits) + popcount(keyA XOR pivotBitsB_raw)\n  //\n  // For a given keyA and pivotBitsB_raw, the pivot contribution is fixed.\n  // So we want to group halfA assignments by keyA, keeping only the best (min freeA popcount, lex smallest).\n  // Then for each halfB assignment, try all keyA values... but that's still O(2^rank * 2^halfB).\n  //\n  // Actually: total = popcount(freeA) + popcount(freeB) + popcount(keyA XOR pivotBitsB_raw)\n  // Rearrange: for fixed pivotBitsB_raw, we want keyA that minimizes:\n  //   popcount(freeA) + popcount(keyA XOR pivotBitsB_raw)\n  //\n  // Since keyA XOR pivotBitsB_raw = keyA XOR pivotBitsB, define target_key = pivotBitsB_raw.\n  // We want to find keyA that minimizes popcount(freeA) + popcount(keyA XOR target_key).\n  //\n  // This is: popcount(freeA) + hamming_distance(keyA, target_key).\n  //\n  // For each halfA assignment, we have (keyA, popcount(freeA)). For each halfB,\n  // we have target_key and popcount(freeB). We want to minimize:\n  //   popcount(freeB) + min over halfA { popcount(freeA) + hamming(keyA, target_key) }\n  //\n  // Since rank <= 40, keyA is up to 40 bits. We can't precompute for all possible\n  // target_key values. But we CAN store all (keyA, costA) pairs from halfA, and\n  // for each halfB assignment, iterate over all stored halfA entries.\n  // That's 2^halfA * 2^halfB = 2^numFree which is what we started with.\n\n  // Better approach: since rank <= 40 but numFree can also be up to 40,\n  // and we need this to be fast... Let's use a different MITM strategy.\n  //\n  // Group by keyA. For each unique keyA value, store minimum costA and best freeA assignment.\n  // There are at most 2^rank distinct keyA values, but rank <= 40.\n  // For each halfB, compute target_key, then we need the keyA closest in Hamming distance\n  // weighted by costA. This is still hard in general.\n  //\n  // Practical approach: since rank can be at most min(numLights, numButtons) = 40,\n  // and numFree = numButtons - rank, if numFree is large then rank is small.\n  // E.g., 40 buttons, 5 lights => rank <= 5, numFree >= 35.\n  // With rank <= 5, keyA has at most 5 bits => 32 possible values.\n  // We store best costA for each of 32 keyA values.\n  // Then for each halfB (2^17 or 2^18 entries), we iterate over 32 keyA values.\n  // Total: 2^18 * 32 ≈ 8M — fast!\n  //\n  // General: 2^halfB * 2^rank operations. halfB ≈ numFree/2, rank = numButtons - numFree.\n  // 2^(numFree/2) * 2^(numButtons - numFree) = 2^(numButtons - numFree/2).\n  // With numButtons=40, numFree=35: 2^(40-17) = 2^23 ≈ 8M — fine.\n  // With numButtons=40, numFree=20: 2^(40-10) = 2^30 ≈ 1B — too slow.\n  // But with numFree=20, direct enumeration (2^20 ≈ 1M) is fine!\n\n  // So the plan:\n  // - numFree <= 20: direct enumeration (already handled above)\n  // - numFree > 20: MITM with keyA grouping. Since numFree > 20 implies rank < 20,\n  //   keyA has < 20 bits, so at most ~1M groups. This is always efficient.\n\n  // Encode pivot deps as bitmasks over free variable indices\n  const pivotDepMaskA: number[] = []; // for halfA free vars (indices 0..halfA-1)\n  const pivotDepMaskB: number[] = []; // for halfB free vars (indices halfA..numFree-1)\n  let pivotConstBitmask = 0;\n  for (let i = 0; i < rank; i++) {\n    let maskA = 0, maskB = 0;\n    for (const fi of pivotDeps[i]) {\n      if (fi < halfA) {\n        maskA |= (1 << fi);\n      } else {\n        maskB |= (1 << (fi - halfA));\n      }\n    }\n    pivotDepMaskA.push(maskA);\n    pivotDepMaskB.push(maskB);\n    if (pivotConst[i]) {\n      pivotConstBitmask |= (1 << i);\n    }\n  }\n\n  const popcount = (n: number): number => {\n    let count = 0;\n    while (n) {\n      count += n & 1;\n      n >>>= 1;\n    }\n    return count;\n  };\n\n  // Compute keyA for a halfA assignment\n  const computeKeyA = (freeA: number): number => {\n    let key = pivotConstBitmask;\n    for (let i = 0; i < rank; i++) {\n      // Count parity of (freeA & pivotDepMaskA[i])\n      if (popcount(freeA & pivotDepMaskA[i]) & 1) {\n        key ^= (1 << i);\n      }\n    }\n    return key;\n  };\n\n  // Phase 1: enumerate halfA, group by keyA\n  // For each keyA, store best (costA, freeA_assignment)\n  // costA = popcount(freeA_bits) (just the free variable ones from A)\n  const keyMap = new Map<number, { costA: number; freeA: number }>();\n\n  for (let freeA = 0; freeA < (1 << halfA); freeA++) {\n    const keyA = computeKeyA(freeA);\n    const costA = popcount(freeA);\n    const existing = keyMap.get(keyA);\n    if (!existing || costA < existing.costA) {\n      keyMap.set(keyA, { costA, freeA });\n    }\n    // For lex-smallest tiebreaker at same cost, we need more careful handling.\n    // We'll do a second pass for the best candidate.\n  }\n\n  // Phase 2: enumerate halfB, for each try all keyA entries\n  let bestCount2 = numButtons + 1;\n  let bestFreeA = 0;\n  let bestFreeB = 0;\n\n  for (let freeB = 0; freeB < (1 << halfB); freeB++) {\n    // Compute pivotBitsB_raw\n    let pivotBitsB = 0;\n    for (let i = 0; i < rank; i++) {\n      if (popcount(freeB & pivotDepMaskB[i]) & 1) {\n        pivotBitsB |= (1 << i);\n      }\n    }\n    const costB = popcount(freeB);\n\n    // For each keyA in the map, total = costA + costB + popcount(keyA XOR pivotBitsB)\n    // But keyA already includes pivotConst, so pivot ones = popcount(keyA XOR pivotBitsB)\n    // Wait, keyA = pivotConst XOR partialA, and full pivot = keyA XOR partialB = keyA XOR pivotBitsB\n    // No: full pivot bit i = pivotConst[i] XOR partialA[i] XOR partialB[i]\n    // keyA was computed as pivotConst XOR partialA. So full = keyA XOR pivotBitsB.\n    // Ones from pivots = popcount(keyA XOR pivotBitsB). Correct.\n\n    for (const [keyA, { costA, freeA }] of keyMap) {\n      const pivotOnes = popcount(keyA ^ pivotBitsB);\n      const total = costA + costB + pivotOnes;\n      if (total < bestCount2) {\n        bestCount2 = total;\n        bestFreeA = freeA;\n        bestFreeB = freeB;\n      } else if (total === bestCount2) {\n        // Lex comparison: reconstruct and compare\n        const freeAssign = bestFreeA | (bestFreeB << halfA);\n        const newFreeAssign = freeA | (freeB << halfA);\n        const curSol = computeSolution(freeAssign);\n        const newSol = computeSolution(newFreeAssign);\n        if (lexSmallerSol(newSol, curSol)) {\n          bestFreeA = freeA;\n          bestFreeB = freeB;\n        }\n      }\n    }\n  }\n\n  const bestFreeAssign = bestFreeA | (bestFreeB << halfA);\n  return solutionToPressed(computeSolution(bestFreeAssign));\n}\n\nfunction solutionToPressed(solution: number[]): number[] {\n  const pressed: number[] = [];\n  for (let c = 0; c < solution.length; c++) {\n    if (solution[c] === 1) {\n      pressed.push(c);\n    }\n  }\n  return pressed;\n}\n\nfunction lexSmallerSol(a: number[], b: number[]): boolean {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [numCounters x (numButtons + 1)]\n  const matrix: number[][] = [];\n  for (let r = 0; r < numCounters; r++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let c = 0; c < numButtons; c++) {\n      if (buttons[c].includes(r)) {\n        row[c] = 1;\n      }\n    }\n    row[numButtons] = ((lights[r] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p)\n  const pivotCol: number[] = [];\n  let row = 0;\n  for (let col = 0; col < numButtons && row < numCounters; col++) {\n    let pivotRow = -1;\n    for (let r = row; r < numCounters; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotRow = r;\n        break;\n      }\n    }\n    if (pivotRow === -1) continue;\n    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];\n\n    const pivotVal = matrix[row][col];\n    const inv = modInverse(pivotVal, modulus);\n    for (let c = 0; c <= numButtons; c++) {\n      matrix[row][c] = (matrix[row][c] * inv) % modulus;\n    }\n\n    for (let r = 0; r < numCounters; r++) {\n      if (r !== row && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let c = 0; c <= numButtons; c++) {\n          matrix[r][c] = ((matrix[r][c] - factor * matrix[row][c]) % modulus + modulus) % modulus;\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    row++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check for inconsistency\n  for (let r = rank; r < numCounters; r++) {\n    if (matrix[r][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let c = 0; c < numButtons; c++) {\n    if (!pivotSet.has(c)) {\n      freeVars.push(c);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // For each pivot row, precompute dependencies on free variables\n  // pivotRow i: solution[pivotCol[i]] = matrix[i][numButtons] - sum(matrix[i][freeVars[j]] * freeVal[j]) mod p\n  const pivotDeps: { fi: number; coeff: number }[][] = [];\n  const pivotConst: number[] = [];\n  for (let i = 0; i < rank; i++) {\n    const deps: { fi: number; coeff: number }[] = [];\n    for (let fi = 0; fi < numFree; fi++) {\n      if (matrix[i][freeVars[fi]] !== 0) {\n        deps.push({ fi, coeff: matrix[i][freeVars[fi]] });\n      }\n    }\n    pivotDeps.push(deps);\n    pivotConst.push(matrix[i][numButtons]);\n  }\n\n  const computeSolution = (freeVals: number[]): number[] => {\n    const solution = new Array(numButtons).fill(0);\n    for (let fi = 0; fi < numFree; fi++) {\n      solution[freeVars[fi]] = freeVals[fi];\n    }\n    for (let i = 0; i < rank; i++) {\n      let val = pivotConst[i];\n      for (const { fi, coeff } of pivotDeps[i]) {\n        val = ((val - coeff * freeVals[fi]) % modulus + modulus) % modulus;\n      }\n      solution[pivotCol[i]] = val;\n    }\n    return solution;\n  };\n\n  const totalPresses = (solution: number[]): number => {\n    let sum = 0;\n    for (let i = 0; i < solution.length; i++) {\n      sum += solution[i];\n    }\n    return sum;\n  };\n\n  // For small number of free variables or small modulus, enumerate directly.\n  // For larger, use meet-in-the-middle.\n  const totalCombinations = Math.pow(modulus, numFree);\n\n  if (numFree === 0 || totalCombinations <= 5_000_000) {\n    // Direct enumeration\n    let bestSolution: number[] | null = null;\n    let bestTotal = Infinity;\n\n    const freeVals = new Array(numFree).fill(0);\n    for (let combo = 0; combo < totalCombinations; combo++) {\n      // Decode combo into freeVals\n      let temp = combo;\n      for (let i = 0; i < numFree; i++) {\n        freeVals[i] = temp % modulus;\n        temp = Math.floor(temp / modulus);\n      }\n\n      const solution = computeSolution(freeVals);\n      const total = totalPresses(solution);\n\n      if (total < bestTotal || (total === bestTotal && lexSmallerArray(solution, bestSolution!))) {\n        bestTotal = total;\n        bestSolution = [...solution];\n      }\n    }\n\n    return bestSolution!;\n  }\n\n  // Meet-in-the-middle for GF(p) with many free variables\n  // Split free variables into two halves\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n  const sizeA = Math.pow(modulus, halfA);\n  const sizeB = Math.pow(modulus, halfB);\n\n  // For each halfA assignment, compute the partial effect on each pivot variable.\n  // pivotPartialA[i] = sum(matrix[i][freeVars[j]] * freeVals[j]) mod p for j in 0..halfA-1\n  // Key = tuple of pivotPartialA values (as a string or encoded number)\n  // Store best (costA, freeValsA) for each key\n\n  // Encode pivot partials as a single key. Since each value is 0..p-1 and rank <= 40,\n  // we need a good hash. Use a string for correctness.\n  const encodeKey = (partials: number[]): string => partials.join(',');\n\n  // Phase 1: enumerate halfA\n  const keyMapC = new Map<string, { costA: number; freeA: number[] }>();\n\n  for (let comboA = 0; comboA < sizeA; comboA++) {\n    const freeValsA = new Array(halfA);\n    let temp = comboA;\n    for (let i = 0; i < halfA; i++) {\n      freeValsA[i] = temp % modulus;\n      temp = Math.floor(temp / modulus);\n    }\n\n    // Compute cost of freeA vars themselves\n    let costA = 0;\n    for (let i = 0; i < halfA; i++) {\n      costA += freeValsA[i];\n    }\n\n    // Compute partial pivot effects from halfA\n    const partials = new Array(rank);\n    for (let i = 0; i < rank; i++) {\n      let partial = 0;\n      for (const { fi, coeff } of pivotDeps[i]) {\n        if (fi < halfA) {\n          partial = (partial + coeff * freeValsA[fi]) % modulus;\n        }\n      }\n      partials[i] = partial;\n    }\n\n    const key = encodeKey(partials);\n    const existing = keyMapC.get(key);\n    if (!existing || costA < existing.costA ||\n        (costA === existing.costA && lexSmallerArray(freeValsA, existing.freeA))) {\n      keyMapC.set(key, { costA, freeA: freeValsA });\n    }\n  }\n\n  // Phase 2: enumerate halfB, for each try all keyA entries\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  for (let comboB = 0; comboB < sizeB; comboB++) {\n    const freeValsB = new Array(halfB);\n    let temp = comboB;\n    for (let i = 0; i < halfB; i++) {\n      freeValsB[i] = temp % modulus;\n      temp = Math.floor(temp / modulus);\n    }\n\n    let costB = 0;\n    for (let i = 0; i < halfB; i++) {\n      costB += freeValsB[i];\n    }\n\n    // Compute partial pivot effects from halfB\n    const partialsB = new Array(rank);\n    for (let i = 0; i < rank; i++) {\n      let partial = 0;\n      for (const { fi, coeff } of pivotDeps[i]) {\n        if (fi >= halfA) {\n          partial = (partial + coeff * freeValsB[fi - halfA]) % modulus;\n        }\n      }\n      partialsB[i] = partial;\n    }\n\n    // For each keyA entry, compute full solution cost\n    for (const [keyStr, { costA, freeA }] of keyMapC) {\n      // Decode keyA partials\n      const partialsA = keyStr.split(',').map(Number);\n\n      // Compute pivot variable values\n      let pivotCost = 0;\n      for (let i = 0; i < rank; i++) {\n        const pivotVal = ((pivotConst[i] - partialsA[i] - partialsB[i]) % modulus + modulus * 2) % modulus;\n        pivotCost += pivotVal;\n      }\n\n      const total = costA + costB + pivotCost;\n      if (total < bestTotal) {\n        bestTotal = total;\n        const fullFreeVals = [...freeA, ...freeValsB];\n        bestSolution = computeSolution(fullFreeVals);\n      } else if (total === bestTotal) {\n        const fullFreeVals = [...freeA, ...freeValsB];\n        const candidate = computeSolution(fullFreeVals);\n        if (lexSmallerArray(candidate, bestSolution!)) {\n          bestSolution = candidate;\n        }\n      }\n    }\n  }\n\n  return bestSolution;\n}\n\nfunction modInverse(a: 