4→  // For each halfA assignment, compute the partial effect on each pivot variable.\n   505→  // pivotPartialA[i] = sum(matrix[i][freeVars[j]] * freeVals[j]) mod p for j in 0..halfA-1\n   506→  // Key = tuple of pivotPartialA values (as a string or encoded number)\n   507→  // Store best (costA, freeValsA) for each key\n   508→\n   509→  // Encode pivot partials as a single key. Since each value is 0..p-1 and rank <= 40,\n   510→  // we need a good hash. Use a string for correctness.\n   511→  const encodeKey = (partials: number[]): string => partials.join(',');\n   512→\n   513→  // Phase 1: enumerate halfA\n   514→  const keyMapC = new Map<string, { costA: number; freeA: number[] }>();\n   515→\n   516→  for (let comboA = 0; comboA < sizeA; comboA++) {\n   517→    const freeValsA = new Array(halfA);\n   518→    let temp = comboA;\n   519→    for (let i = 0; i < halfA; i++) {\n   520→      freeValsA[i] = temp % modulus;\n   521→      temp = Math.floor(temp / modulus);\n   522→    }\n   523→\n   524→    // Compute cost of freeA vars themselves\n   525→    let costA = 0;\n   526→    for (let i = 0; i < halfA; i++) {\n   527→      costA += freeValsA[i];\n   528→    }\n   529→\n   530→    // Compute partial pivot effects from halfA\n   531→    const partials = new Array(rank);\n   532→    for (let i = 0; i < rank; i++) {\n   533→      let partial = 0;\n   534→      for (const { fi, coeff } of pivotDeps[i]) {\n   535→        if (fi < halfA) {\n   536→          partial = (partial + coeff * freeValsA[fi]) % modulus;\n   537→        }\n   538→      }\n   539→      partials[i] = partial;\n   540→    }\n   541→\n   542→    const key = encodeKey(partials);\n   543→    const existing = keyMapC.get(key);\n   544→    if (!existing || costA < existing.costA ||\n   545→        (costA === existing.costA && lexSmallerArray(freeValsA, existing.freeA))) {\n   546→      keyMapC.set(key, { costA, freeA: freeValsA });\n   547→    }\n   548→  }\n   549→\n   550→  // Phase 2: enumerate halfB, for each try all keyA entries\n   551→  let bestSolution: number[] | null = null;\n   552→  let bestTotal = Infinity;\n   553→\n   554→  for (let comboB = 0; comboB < sizeB; comboB++) {\n   555→    const freeValsB = new Array(halfB);\n   556→    let temp = comboB;\n   557→    for (let i = 0; i < halfB; i++) {\n   558→      freeValsB[i] = temp % modulus;\n   559→      temp = Math.floor(temp / modulus);\n   560→    }\n   561→\n   562→    let costB = 0;\n   563→    for (let i = 0; i < halfB; i++) {\n   564→      costB += freeValsB[i];\n   565→    }\n   566→\n   567→    // Compute partial pivot effects from halfB\n   568→    const partialsB = new Array(rank);\n   569→    for (let i = 0; i < rank; i++) {\n   570→      let partial = 0;\n   571→      for (const { fi, coeff } of pivotDeps[i]) {\n   572→        if (fi >= halfA) {\n   573→          partial = (partial + coeff * freeValsB[fi - halfA]) % modulus;\n   574→        }\n   575→      }\n   576→      partialsB[i] = partial;\n   577→    }\n   578→\n   579→    // For each keyA entry, compute full solution cost\n   580→    for (const [keyStr, { costA, freeA }] of keyMapC) {\n   581→      // Decode keyA partials\n   582→      const partialsA = keyStr.split(',').map(Number);\n   583→\n   584→      // Compute pivot variable values\n   585→      let pivotCost = 0;\n   586→      for (let i = 0; i < rank; i++) {\n   587→        const pivotVal = ((pivotConst[i] - partialsA[i] - partialsB[i]) % modulus + modulus * 2) % modulus;\n   588→        pivotCost += pivotVal;\n   589→      }\n   590→\n   591→      const total = costA + costB + pivotCost;\n   592→      if (total < bestTotal) {\n   593→        bestTotal = total;\n   594→        const fullFreeVals = [...freeA, ...freeValsB];\n   595→        bestSolution = computeSolution(fullFreeVals);\n   596→      } else if (total === bestTotal) {\n   597→        const fullFreeVals = [...freeA, ...freeValsB];\n   598→        const candidate = computeSolution(fullFreeVals);\n   599→    