h; c++) {\n   341→    if (solution[c] === 1) {\n   342→      pressed.push(c);\n   343→    }\n   344→  }\n   345→  return pressed;\n   346→}\n   347→\n   348→export function solveCounter(\n   349→  lights: number[],\n   350→  buttons: number[][],\n   351→  modulus: number\n   352→): number[] | null {\n   353→  const numCounters = lights.length;\n   354→  const numButtons = buttons.length;\n   355→\n   356→  // Build augmented matrix [numCounters x (numButtons + 1)]\n   357→  const matrix: number[][] = [];\n   358→  for (let r = 0; r < numCounters; r++) {\n   359→    const row = new Array(numButtons + 1).fill(0);\n   360→    for (let c = 0; c < numButtons; c++) {\n   361→      if (buttons[c].includes(r)) {\n   362→        row[c] = 1;\n   363→      }\n   364→    }\n   365→    row[numButtons] = ((lights[r] % modulus) + modulus) % modulus;\n   366→    matrix.push(row);\n   367→  }\n   368→\n   369→  // Gaussian elimination over GF(p)\n   370→  const pivotCol: number[] = [];\n   371→  let row = 0;\n   372→  for (let col = 0; col < numButtons && row < numCounters; col++) {\n   373→    let pivotRow = -1;\n   374→    for (let r = row; r < numCounters; r++) {\n   375→      if (matrix[r][col] !== 0) {\n   376→        pivotRow = r;\n   377→        break;\n   378→      }\n   379→    }\n   380→    if (pivotRow === -1) continue;\n   381→    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];\n   382→\n   383→    const pivotVal = matrix[row][col];\n   384→    const inv = modInverse(pivotVal, modulus);\n   385→    for (let c = 0; c <= numButtons; c++) {\n   386→      matrix[row][c] = (matrix[row][c] * inv) % modulus;\n   387→    }\n   388→\n   389→    for (let r = 0; r < numCounters; r++) {\n   390→      if (r !== row && matrix[r][col] !== 0) {\n   391→        const factor = matrix[r][col];\n   392→        for (let c = 0; c <= numButtons; c++) {\n   393→          matrix[r][c] = ((matrix[r][c] - factor * matrix[row][c]) % modulus + modulus) % modulus;\n   394→        }\n   395→      }\n   396→    }\n   397→\n   398→    pivotCol.push(col);\n   399→    row++;\n   400→  }\n   401→\n   402→  const rank = pivotCol.length;\n   403→\n   404→  // Check for inconsistency\n   405→  for (let r = rank; r < numCounters; r++) {\n   406→    if (matrix[r][numButtons] !== 0) {\n   407→      return null;\n   408→    }\n   409→  }\n   410→\n   411→  // Identify free variables\n   412→  const pivotSet = new Set(pivotCol);\n   413→  const freeVars: number[] = [];\n   414→  for (let c = 0; c < numButtons; c++) {\n   415→    if (!pivotSet.has(c)) {\n   416→      freeVars.push(c);\n   417→    }\n   418→  }\n   419→\n   420→  const numFree = freeVars.length;\n   421→\n   422→  // For each pivot row, precompute dependencies on free variables\n   423→  // pivotRow i: solution[pivotCol[i]] = matrix[i][numButtons] - sum(matrix[i][freeVars[j]] * freeVal[j]) mod p\n   424→  const pivotDeps: { fi: number; coeff: number }[][] = [];\n   425→  const pivotConst: number[] = [];\n   426→  for (let i = 0; i < rank; i++) {\n   427→    const deps: { fi: number; coeff: number }[] = [];\n   428→    for (let fi = 0; fi < numFree; fi++) {\n   429→      if (matrix[i][freeVars[fi]] !== 0) {\n   430→        deps.push({ fi, coeff: matrix[i][freeVars[fi]] });\n   431→      }\n   432→    }\n   433→    pivotDeps.push(deps);\n   434→    pivotConst.push(matrix[i][numButtons]);\n   435→  }\n   436→\n   437→  const computeSolution = (freeVals: number[]): number[] => {\n   438→    const solution = new Array(numButtons).fill(0);\n   439→    for (let fi = 0; fi < numFree; fi++) {\n   440→      solution[freeVars[fi]] = freeVals[fi];\n   441→    }\n   442→    for (let i = 0; i < rank; i++) {\n   443→      let val = pivotConst[i];\n   444→      for (const { fi, coeff } of pivotDeps[i]) {\n   445→        val = ((val - coeff * freeVals[fi]) % modulus + modulus) % modulus;\n   446→      }\n   447→      solution[pivotCol[i]] = val;\n   448→    }\n   449→    return solution;\n   450→  };\n   451→\n   452→  const totalPresses = (solution: number[]): number => {\n   453→    let sum = 0;\n   454→    for (let i = 0; i < solution.length; i++) {\n   455→      sum += solution[i];\n   456→    }\n   457→    return sum;\n   458→  };\n   459→\n   460→  // For small number of free variables or small modulus, enumerate directly.\n   461→  // For larger, use meet-in-the-middle.\n   462→  const totalCombinations = Math.pow(modulus, numFree);\n   463→\n   464→  if (numFree === 0 || totalCombinations <= 5_000_000) {\n   465→    // Direct enumeration\n   466→    let bestSolution: number[] | null = null;\n   467→    let bestTotal = Infinity;\n   468→\n   469→    const freeVals = new Array(numFree).fill(0);\n   470→    for (let combo = 0; combo < totalCombinations; combo++) {\n   471→      // Decode combo into freeVals\n   472→      let temp = combo;\n   473→      for (let i = 0; i < numFree; i++) {\n   474→        freeVals[i] = temp % modulus;\n   475→        temp = Math.floor(temp / modulus);\n   476→      }\n   477→\n   478→      const solution = computeSolution(freeVals);\n   479→      const total = totalPresses(solution);\n   480→\n   481→      if (total < bestTotal || (total === bestTotal && lexSmallerArray(solution, bestSolution!))) {\n   482→        bestTotal = total;\n   483→        bestSolution = [...solution];\n   484→      }\n   485→    }\n   486→\n   487→    return bestSolution!;\n   488→  }\n   489→\n   490→  // Meet-in-the-middle for GF(p) with many free variables\n   491→  // Split free variables into two halves\n   492→  const halfA = Math.floor(numFree / 2);\n   493→  const halfB = numFree - halfA;\n   494→  const sizeA = Math.pow(modulus, halfA);\n   495→  const sizeB = Math.pow(modulus, halfB);\n   496→\n   497→  // For each halfA assignment, compute the partial effect on each pivot variable.\n   498→  // pivotPartialA[i] = sum(matrix[i][freeVars[j]] * freeVals[j]) mod p for j in 0..halfA-1\n   499→  // Key = tuple of pivotPartialA values (as a string or e