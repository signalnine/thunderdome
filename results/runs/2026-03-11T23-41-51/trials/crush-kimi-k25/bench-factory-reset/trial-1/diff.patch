+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function gaussianEliminationGF2(matrix: number[][], target: number[]): { basis: number[][]; particular: number[] | null } {
+  const n = matrix.length;
+  const m = matrix[0]?.length || 0;
+
+  // Augmented matrix
+  const aug: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    aug.push([...matrix[i], target[i]]);
+  }
+
+  const where: number[] = new Array(m).fill(-1);
+  let row = 0;
+
+  for (let col = 0; col < m && row < n; col++) {
+    // Find pivot
+    let sel = row;
+    for (let i = row; i < n; i++) {
+      if (aug[i][col] === 1) {
+        sel = i;
+        break;
+      }
+    }
+    if (aug[sel][col] === 0) continue;
+
+    // Swap rows
+    [aug[sel], aug[row]] = [aug[row], aug[sel]];
+    where[col] = row;
+
+    // Eliminate
+    for (let i = 0; i < n; i++) {
+      if (i !== row && aug[i][col] === 1) {
+        for (let j = col; j <= m; j++) {
+          aug[i][j] ^= aug[row][j];
+        }
+      }
+    }
+    row++;
+  }
+
+  // Check for inconsistency
+  for (let i = row; i < n; i++) {
+    if (aug[i][m] === 1) {
+      return { basis: [], particular: null };
+    }
+  }
+
+  // Find particular solution
+  const particular: number[] = new Array(m).fill(0);
+  for (let i = 0; i < m; i++) {
+    if (where[i] !== -1) {
+      particular[i] = aug[where[i]][m];
+    }
+  }
+
+  // Find null space basis
+  const basis: number[][] = [];
+  for (let j = 0; j < m; j++) {
+    if (where[j] === -1) {
+      const vec = new Array(m).fill(0);
+      vec[j] = 1;
+      for (let i = 0; i < m; i++) {
+        if (where[i] !== -1) {
+          vec[i] = aug[where[i]][j];
+        }
+      }
+      basis.push(vec);
+    }
+  }
+
+  return { basis, particular };
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const n = machine.target.length;
+  const m = machine.buttons.length;
+
+  if (n === 0) {
+    return [];
+  }
+
+  if (m === 0) {
+    return machine.target.every(t => !t) ? [] : null;
+  }
+
+  // Build matrix: row = light, col = button
+  const matrix: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m).fill(0);
+    matrix.push(row);
+  }
+
+  for (let j = 0; j < m; j++) {
+    for (const lightIdx of machine.buttons[j]) {
+      if (lightIdx >= 0 && lightIdx < n) {
+        matrix[lightIdx][j] = 1;
+      }
+    }
+  }
+
+  const target = machine.target.map(t => (t ? 1 : 0));
+  const { basis, particular } = gaussianEliminationGF2(matrix, target);
+
+  if (particular === null) {
+    return null;
+  }
+
+  if (basis.length === 0) {
+    // Unique solution
+    const result: number[] = [];
+    for (let i = 0; i < m; i++) {
+      if (particular[i] === 1) {
+        result.push(i);
+      }
+    }
+    return result;
+  }
+
+  // At this point, particular is guaranteed to be non-null
+  const particularVec = particular;
+
+  // Use meet-in-the-middle for finding optimal solution
+  // The solution space is: particular + c1*basis1 + c2*basis2 + ...
+  // We split the basis into two halves and generate all combinations for each
+  const k = basis.length;
+  const half1 = Math.floor(k / 2);
+  const half2 = k - half1;
+
+  const basis1 = basis.slice(0, half1);
+  const basis2 = basis.slice(half1);
+
+  // Generate all vectors and their button-press counts for first half
+  // Each entry: [vector, number of basis vectors used, which basis vectors]
+  type Partial = { vec: number[]; count: number; indices: number[] };
+  const partials1: Partial[] = [];
+
+  for (let mask = 0; mask < (1 << half1); mask++) {
+    const vec = new Array(m).fill(0);
+    const indices: number[] = [];
+    let count = 0;
+    for (let i = 0; i < half1; i++) {
+      if ((mask >> i) & 1) {
+        indices.push(i);
+        for (let j = 0; j < m; j++) {
+          vec[j] ^= basis1[i][j];
+        }
+        count++;
+      }
+    }
+    partials1.push({ vec, count, indices });
+  }
+
+  // For each possible partial1, compute the full solution and track the best
+  let bestResult: number[] | null = null;
+  let bestWeight = Infinity;
+
+  for (const p1 of partials1) {
+    // Combine with all possibilities from second half
+    for (let mask = 0; mask < (1 << half2); mask++) {
+      const vec = [...p1.vec];
+      for (let i = 0; i < half2; i++) {
+        if ((mask >> i) & 1) {
+          for (let j = 0; j < m; j++) {
+            vec[j] ^= basis2[i][j];
+          }
+        }
+      }
+
+      // Now add the particular solution
+      const fullVec = new Array(m).fill(0);
+      for (let j = 0; j < m; j++) {
+        fullVec[j] = particularVec[j] ^ vec[j];
+      }
+
+      // Build result (indices where fullVec[j] == 1)
+      const result: number[] = [];
+      for (let j = 0; j < m; j++) {
+        if (fullVec[j] === 1) {
+          result.push(j);
+        }
+      }
+
+      const weight = result.length;
+      if (weight < bestWeight || (weight === bestWeight && lexLess(result, bestResult!))) {
+        bestWeight = weight;
+        bestResult = result;
+      }
+    }
+  }
+
+  return bestResult;
+}
+
+function lexLess(a: number[], b: number[]): boolean {
+  for (let i = 0; i < Math.min(a.length, b.length); i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+// Counter puzzle solver
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+
+  if (n === 0) {
+    return new Array(m).fill(0);
+  }
+
+  if (m === 0) {
+    return lights.every(t => t === 0) ? [] : null;
+  }
+
+  // Build matrix: row = counter, col = button
+  const matrix: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m).fill(0);
+    matrix.push(row);
+  }
+
+  for (let j = 0; j < m; j++) {
+    for (const counterIdx of buttons[j]) {
+      if (counterIdx >= 0 && counterIdx < n) {
+        matrix[counterIdx][j] = (matrix[counterIdx][j] + 1) % modulus;
+      }
+    }
+  }
+
+  const target = [...lights];
+
+  // Gaussian elimination over Z_modulus
+  const { basis, particular } = gaussianEliminationMod(matrix, target, modulus);
+
+  if (particular === null) {
+    return null;
+  }
+
+  if (basis.length === 0) {
+    // Unique solution
+    return particular;
+  }
+
+  // At this point, particular is guaranteed to be non-null
+  const particularVec = particular;
+
+  // Use meet-in-the-middle for finding optimal solution
+  // Any solution is: particular + c1*basis1 + c2*basis2 + ... (mod modulus)
+  // We split the basis and enumerate all combinations
+  const k = basis.length;
+  const half1 = Math.floor(k / 2);
+  const half2 = k - half1;
+
+  const basis1 = basis.slice(0, half1);
+  const basis2 = basis.slice(half1);
+
+  // Generate all partial combinations for first half
+  // Each entry is the vector contribution from basis1
+  type Partial = { vec: number[]; count: number; indices: number[] };
+  const partials1: Partial[] = [];
+
+  function generatePartials1(idx: number, current: number[], coeffs: number[], count: number) {
+    if (idx === half1) {
+      partials1.push({ vec: [...current], count, indices: [...coeffs] });
+      return;
+    }
+    for (let c = 0; c < modulus; c++) {
+      const newCurrent = [...current];
+      for (let j = 0; j < m; j++) {
+        newCurrent[j] = (newCurrent[j] + c * basis1[idx][j]) % modulus;
+      }
+      coeffs.push(c);
+      generatePartials1(idx + 1, newCurrent, coeffs, count + c);
+      coeffs.pop();
+    }
+  }
+
+  generatePartials1(0, new Array(m).fill(0), [], 0);
+
+  // Enumerate all combinations and find the best
+  let bestResult: number[] | null = null;
+  let bestPresses = Infinity;
+
+  function searchSecondHalf(idx: number, p1: Partial, current: number[], coeffs: number[]) {
+    if (idx === half2) {
+      // Combine: fullVec = particular + p1.vec + current
+      const fullVec = new Array(m).fill(0);
+      for (let j = 0; j < m; j++) {
+        fullVec[j] = (particularVec[j] + p1.vec[j] + current[j]) % modulus;
+      }
+
+      const totalPresses = fullVec.reduce((a, b) => a + b, 0);
+      if (totalPresses < bestPresses ||
+          (totalPresses === bestPresses && lexLessArray(fullVec, bestResult!))) {
+        bestPresses = totalPresses;
+        bestResult = fullVec;
+      }
+      return;
+    }
+    for (let c = 0; c < modulus; c++) {
+      const newCurrent = [...current];
+      for (let j = 0; j < m; j++) {
+        newCurrent[j] = (newCurrent[j] + c * basis2[idx][j]) % modulus;
+      }
+      coeffs.push(c);
+      searchSecondHalf(idx + 1, p1, newCurrent, coeffs);
+      coeffs.pop();
+    }
+  }
+
+  for (const p1 of partials1) {
+    searchSecondHalf(0, p1, new Array(m).fill(0), []);
+  }
+
+  return bestResult;
+}
+
+function gaussianEliminationMod(
+  matrix: number[][],
+  target: number[],
+  modulus: number
+): { basis: number[][]; particular: number[] | null } {
+  const n = matrix.length;
+  const m = matrix[0]?.length || 0;
+
+  // Augmented matrix
+  const aug: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    aug.push([...matrix[i], target[i]]);
+  }
+
+  const where: number[] = new Array(m).fill(-1);
+  let row = 0;
+
+  for (let col = 0; col < m && row < n; col++) {
+    // Find pivot
+    let sel = -1;
+    for (let i = row; i < n; i++) {
+      if (aug[i][col] !== 0) {
+        sel = i;
+        break;
+      }
+    }
+    if (sel === -1) continue;
+
+    // Swap rows
+    [aug[sel], aug[row]] = [aug[row], aug[sel]];
+    where[col] = row;
+
+    // Normalize pivot row
+    const inv = modInverse(aug[row][col], modulus);
+    for (let j = col; j <= m; j++) {
+      aug[row][j] = (aug[row][j] * inv) % modulus;
+    }
+
+    // Eliminate
+    for (let i = 0; i < n; i++) {
+      if (i !== row && aug[i][col] !== 0) {
+        const factor = aug[i][col];
+        for (let j = col; j <= m; j++) {
+          aug[i][j] = (aug[i][j] - factor * aug[row][j] + modulus * modulus) % modulus;
+        }
+      }
+    }
+    row++;
+  }
+
+  // Check for inconsistency
+  for (let i = row; i < n; i++) {
+    if (aug[i][m] !== 0) {
+      return { basis: [], particular: null };
+    }
+  }
+
+  // Find particular solution
+  const particular: number[] = new Array(m).fill(0);
+  for (let i = 0; i < m; i++) {
+    if (where[i] !== -1) {
+      particular[i] = aug[where[i]][m];
+    }
+  }
+
+  // Find null space basis
+  const basis: number[][] = [];
+  for (let j = 0; j < m; j++) {
+    if (where[j] === -1) {
+      const vec = new Array(m).fill(0);
+      vec[j] = 1;
+      for (let i = 0; i < m; i++) {
+        if (where[i] !== -1) {
+          vec[i] = (modulus - aug[where[i]][j]) % modulus;
+        }
+      }
+      basis.push(vec);
+    }
+  }
+
+  return { basis, particular };
+}
+
+function modInverse(a: number, m: number): number {
+  // Extended Euclidean algorithm
+  let [old_r, r] = [a, m];
+  let [old_s, s] = [1, 0];
+
+  while (r !== 0) {
+    const quotient = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - quotient * r];
+    [old_s, s] = [s, old_s - quotient * s];
+  }
+
+  return ((old_s % m) + m) % m;
+}
+
+function lexLessArray(a: number[], b: number[]): boolean {
+  for (let i = 0; i < Math.min(a.length, b.length); i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
