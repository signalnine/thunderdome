+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const visitedCells = new Set<string>();
+  const memo = new Set<string>();
+
+  // State: (row, col, dr, dc)
+  const queue: [number, number, number, number][] = [];
+
+  // Find all 'S' on the first row
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      if (!memo.has(`${0},${c},1,0`)) {
+        queue.push([0, c, 1, 0]);
+        visitedCells.add(`${0},${c}`);
+        memo.add(`${0},${c},1,0`);
+      }
+    }
+  }
+
+  let head = 0;
+  while (head < queue.length) {
+    const [r, c, dr, dc] = queue[head++];
+
+    let nr: number, nc: number, ndr: number, ndc: number;
+
+    if (grid[r][c] === '^') {
+      // Split into two
+      // Down-left
+      nr = r + 1;
+      nc = c - 1;
+      ndr = 1;
+      ndc = -1;
+      if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
+        visitedCells.add(`${nr},${nc}`);
+        const state = `${nr},${nc},${ndr},${ndc}`;
+        if (!memo.has(state)) {
+          memo.add(state);
+          queue.push([nr, nc, ndr, ndc]);
+        }
+      }
+
+      // Down-right
+      nr = r + 1;
+      nc = c + 1;
+      ndr = 1;
+      ndc = 1;
+      if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
+        visitedCells.add(`${nr},${nc}`);
+        const state = `${nr},${nc},${ndr},${ndc}`;
+        if (!memo.has(state)) {
+          memo.add(state);
+          queue.push([nr, nc, ndr, ndc]);
+        }
+      }
+    } else {
+      // Continue in current direction
+      nr = r + dr;
+      nc = c + dc;
+      ndr = dr;
+      ndc = dc;
+
+      if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
+        visitedCells.add(`${nr},${nc}`);
+        const state = `${nr},${nc},${ndr},${ndc}`;
+        if (!memo.has(state)) {
+          memo.add(state);
+          queue.push([nr, nc, ndr, ndc]);
+        }
+      }
+    }
+  }
+
+  return visitedCells.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const memo = new Map<string, bigint>();
+
+  function getPaths(r: number, c: number, dr: number, dc: number): bigint {
+    // If out of bounds, it's one path that exited
+    if (r < 0 || r >= rows || c < 0 || c >= cols) {
+      return 1n;
+    }
+
+    const state = `${r},${c},${dr},${dc}`;
+    if (memo.has(state)) return memo.get(state)!;
+
+    let result: bigint;
+    if (grid[r][c] === '^') {
+      result = getPaths(r + 1, c - 1, 1, -1) + getPaths(r + 1, c + 1, 1, 1);
+    } else {
+      result = getPaths(r + dr, c + dc, dr, dc);
+    }
+
+    memo.set(state, result);
+    return result;
+  }
+
+  // Find all 'S' on the first row
+  let totalPaths = 0n;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      totalPaths += getPaths(0, c, 1, 0);
+    }
+  }
+
+  return totalPaths;
+}
