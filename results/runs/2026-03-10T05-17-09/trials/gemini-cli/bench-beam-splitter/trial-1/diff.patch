+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('Beam Splitter', () => {
+  it('Example 1', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('Example 2', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('Absorption at boundaries', () => {
+    const grid = [
+      ['S'],
+    ];
+    expect(countBeamCells(grid)).toBe(1);
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('Multiple sources', () => {
+    const grid = [
+      ['S', '.', 'S'],
+      ['.', '.', '.'],
+    ];
+    // Both 'S' at (0,0) and (0,2) emit beams down to (1,0) and (1,2) respectively.
+    // Visited: (0,0), (0,2), (1,0), (1,2)
+    expect(countBeamCells(grid)).toBe(4);
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('Performance test: 200x200 grid with 50 splitters', () => {
+    const rows = 200;
+    const cols = 200;
+    const grid = Array.from({ length: rows }, () => Array(cols).fill('.'));
+    grid[0][100] = 'S';
+    
+    // Create a chain of 50 splitters
+    for (let i = 1; i <= 50; i++) {
+      grid[i][100 + (i % 2 === 0 ? 0 : 1)] = '^';
+    }
+    
+    const start = Date.now();
+    countBeamCells(grid);
+    countBeamPaths(grid);
+    const end = Date.now();
+    
+    expect(end - start).toBeLessThan(5000);
+  });
+});
