+
+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  it('should return null for the example in TASK.md', () => {
+    const machine = {
+      target: [true, true, false, true],
+      buttons: [
+        [0, 1],
+        [1, 2, 3],
+        [0, 3]
+      ]
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should find the correct buttons for a simple case', () => {
+    const machine = {
+      target: [true, true, false],
+      buttons: [
+        [0, 1],
+        [1],
+        [2]
+      ]
+    };
+    // Button 0: [on, on, off]
+    // Match!
+    // Presses: {0} weight 1.
+    // Buttons {1, 2} would give [off, on, on].
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should handle lexicographical smallest set', () => {
+    // Target: [true]
+    // Button 0: [0]
+    // Button 1: [0]
+    // Both solve it with 1 press. {0} is lexicographically smaller than {1}.
+    const machine = {
+      target: [true],
+      buttons: [[0], [0]]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should solve a simple counter puzzle', () => {
+    const lights = [1, 2];
+    const buttons = [[0, 1], [1]];
+    const modulus = 3;
+    // x0 * [1, 1] + x1 * [0, 1] = [1, 2]
+    // x0 = 1
+    // x0 + x1 = 2 => 1 + x1 = 2 => x1 = 1
+    // Result: [1, 1]
+    expect(solveCounter(lights, buttons, modulus)).toEqual([1, 1]);
+  });
+
+  it('should handle multiple presses', () => {
+    const lights = [2];
+    const buttons = [[0]];
+    const modulus = 5;
+    expect(solveCounter(lights, buttons, modulus)).toEqual([2]);
+  });
+
+  it('should handle minimum total presses', () => {
+    const lights = [1];
+    const buttons = [[0], [0]];
+    const modulus = 3;
+    // Solutions:
+    // [1, 0] -> total 1
+    // [0, 1] -> total 1
+    // [2, 2] -> total 4 (mod 3: 2+2=4=1)
+    // Between [1, 0] and [0, 1], [0, 1] is lexicographically smaller?
+    // Wait, [0, 1] < [1, 0]. Yes.
+    expect(solveCounter(lights, buttons, modulus)).toEqual([0, 1]);
+  });
+});
