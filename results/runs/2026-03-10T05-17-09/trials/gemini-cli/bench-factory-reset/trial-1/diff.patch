+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const M = buttons.length;
+
+  const targetVec = target.reduce((acc, val, i) => acc | (val ? (1n << BigInt(i)) : 0n), 0n);
+  const buttonVecs = buttons.map(b => b.reduce((acc, val) => acc | (1n << BigInt(val)), 0n));
+
+  const M1 = Math.min(M, 20);
+  const M2 = M - M1;
+
+  const map = new Map<bigint, { w: number, x: bigint }>();
+
+  function isBetterX(x1: bigint, x2: bigint, count: number): boolean {
+    for (let i = 0; i < count; i++) {
+      const b1 = (x1 >> BigInt(i)) & 1n;
+      const b2 = (x2 >> BigInt(i)) & 1n;
+      if (b1 !== b2) return b1 === 1n;
+    }
+    return false;
+  }
+
+  let curX1 = 0n;
+  let curY1 = 0n;
+  let curW1 = 0;
+
+  function updateMap(y: bigint, w: number, x: bigint) {
+    const existing = map.get(y);
+    if (!existing) {
+      map.set(y, { w, x });
+    } else if (w < existing.w) {
+      existing.w = w;
+      existing.x = x;
+    } else if (w === existing.w) {
+      if (isBetterX(x, existing.x, M1)) {
+        existing.x = x;
+      }
+    }
+  }
+
+  updateMap(curY1, curW1, curX1);
+  for (let i = 1; i < (1 << M1); i++) {
+    let j = 0;
+    let temp = i;
+    while (!(temp & 1)) { temp >>= 1; j++; }
+    const bit = 1n << BigInt(j);
+    if ((curX1 & bit) === 0n) {
+      curX1 |= bit;
+      curY1 ^= buttonVecs[j];
+      curW1++;
+    } else {
+      curX1 &= ~bit;
+      curY1 ^= buttonVecs[j];
+      curW1--;
+    }
+    updateMap(curY1, curW1, curX1);
+  }
+
+  let bestX: bigint | null = null;
+  let bestW = Infinity;
+
+  let curX2 = 0n;
+  let curY2 = 0n;
+  let curW2 = 0;
+
+  function check(y2: bigint, w2: number, x2: bigint) {
+    const needed = targetVec ^ y2;
+    const match = map.get(needed);
+    if (match) {
+      const totalW = w2 + match.w;
+      const totalX = match.x | (x2 << BigInt(M1));
+      if (bestX === null || totalW < bestW) {
+        bestW = totalW;
+        bestX = totalX;
+      } else if (totalW === bestW) {
+        if (isBetterX(totalX, bestX, M)) {
+          bestX = totalX;
+        }
+      }
+    }
+  }
+
+  check(curY2, curW2, curX2);
+  for (let i = 1; i < (1 << M2); i++) {
+    let j = 0;
+    let temp = i;
+    while (!(temp & 1)) { temp >>= 1; j++; }
+    const bit = 1n << BigInt(j);
+    if ((curX2 & bit) === 0n) {
+      curX2 |= bit;
+      curY2 ^= buttonVecs[M1 + j];
+      curW2++;
+    } else {
+      curX2 &= ~bit;
+      curY2 ^= buttonVecs[M1 + j];
+      curW2--;
+    }
+    check(curY2, curW2, curX2);
+  }
+
+  if (bestX === null) return null;
+  const res: number[] = [];
+  for (let i = 0; i < M; i++) {
+    if ((bestX >> BigInt(i)) & 1n) res.push(i);
+  }
+  return res.sort((a, b) => a - b);
+}
+
+function modInverse(a: number, p: number): number {
+  let b = p - 2;
+  let res = 1;
+  a %= p;
+  while (b > 0) {
+    if (b % 2 === 1) res = (res * a) % p;
+    a = (a * a) % p;
+    b = Math.floor(b / 2);
+  }
+  return res;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const N = lights.length;
+  const M = buttons.length;
+  const P = modulus;
+
+  if (P === 2) {
+    return solveCounterP2(lights, buttons);
+  }
+
+  const A = Array.from({ length: N }, () => new Array(M).fill(0));
+  for (let j = 0; j < M; j++) {
+    for (const i of buttons[j]) {
+      A[i][j] = 1;
+    }
+  }
+
+  const matrix = A.map((row, i) => [...row, lights[i]]);
+  let pivotRow = 0;
+  const pivotCol = new Array(M).fill(-1);
+  const isPivotCol = new Array(M).fill(false);
+
+  for (let col = 0; col < M && pivotRow < N; col++) {
+    let best = pivotRow;
+    while (best < N && matrix[best][col] === 0) best++;
+    if (best === N) continue;
+
+    [matrix[pivotRow], matrix[best]] = [matrix[best], matrix[pivotRow]];
+    const inv = modInverse(matrix[pivotRow][col], P);
+    for (let j = col; j <= M; j++) {
+      matrix[pivotRow][j] = (matrix[pivotRow][j] * inv) % P;
+    }
+
+    for (let i = 0; i < N; i++) {
+      if (i !== pivotRow && matrix[i][col] !== 0) {
+        const factor = matrix[i][col];
+        for (let j = col; j <= M; j++) {
+          matrix[i][j] = (matrix[i][j] - factor * matrix[pivotRow][j] % P + P) % P;
+        }
+      }
+    }
+    pivotCol[pivotRow] = col;
+    isPivotCol[col] = true;
+    pivotRow++;
+  }
+
+  for (let i = pivotRow; i < N; i++) {
+    if (matrix[i][M] !== 0) return null;
+  }
+
+  const x0 = new Array(M).fill(0);
+  for (let i = 0; i < pivotRow; i++) {
+    x0[pivotCol[i]] = matrix[i][M];
+  }
+
+  const basis: number[][] = [];
+  for (let j = 0; j < M; j++) {
+    if (!isPivotCol[j]) {
+      const v = new Array(M).fill(0);
+      v[j] = 1;
+      for (let i = 0; i < pivotRow; i++) {
+        v[pivotCol[i]] = (P - matrix[i][j]) % P;
+      }
+      basis.push(v);
+    }
+  }
+
+  const k = basis.length;
+  let bestX: number[] | null = null;
+  let bestTotal = Infinity;
+
+  const curX = new Int32Array(M);
+  for(let j=0; j<M; j++) curX[j] = x0[j];
+  let curTotal = 0;
+  for(let j=0; j<M; j++) curTotal += curX[j];
+  
+  const coeffs = new Uint32Array(k).fill(0);
+  const flatBasis = new Int32Array(k * M);
+  for(let i=0; i<k; i++) for(let j=0; j<M; j++) flatBasis[i*M + j] = basis[i][j];
+
+  for (;;) {
+    if (curTotal < bestTotal) {
+      bestTotal = curTotal;
+      bestX = Array.from(curX);
+    } else if (curTotal === bestTotal) {
+      if (bestX === null) {
+        bestX = Array.from(curX);
+      } else {
+        for (let i = 0; i < M; i++) {
+          if (curX[i] !== bestX[i]) {
+            if (curX[i] < (bestX[i] as number)) bestX = Array.from(curX);
+            break;
+          }
+        }
+      }
+    }
+
+    let i = k - 1;
+    while (i >= 0) {
+      const offset = i * M;
+      for (let j = 0; j < M; j++) {
+        const diff = flatBasis[offset + j];
+        curX[j] += diff;
+        if (curX[j] >= P) {
+          curX[j] -= P;
+          curTotal += diff - P;
+        } else {
+          curTotal += diff;
+        }
+      }
+      coeffs[i]++;
+      if (coeffs[i] < P) break;
+      coeffs[i] = 0;
+      i--;
+    }
+    if (i < 0) break;
+  }
+
+  return bestX;
+}
+
+function solveCounterP2(lights: number[], buttons: number[] | number[][]): number[] | null {
+  const M = buttons.length;
+  const targetVec = lights.reduce((acc, val, i) => acc | (BigInt(val & 1) << BigInt(i)), 0n);
+  const buttonVecs = (buttons as number[][]).map(b => b.reduce((acc, val) => acc | (1n << BigInt(val)), 0n));
+
+  const M1 = Math.min(M, 20);
+  const M2 = M - M1;
+
+  const map = new Map<bigint, { w: number, x: bigint }>();
+
+  // Part 2: lexicographically smallest array means 0 is better than 1 at index i
+  function isBetterP2(x1: bigint, x2: bigint, count: number): boolean {
+    for (let i = 0; i < count; i++) {
+      const b1 = (x1 >> BigInt(i)) & 1n;
+      const b2 = (x2 >> BigInt(i)) & 1n;
+      if (b1 !== b2) return b1 < b2; // 0 is better than 1
+    }
+    return false;
+  }
+
+  let curX1 = 0n;
+  let curY1 = 0n;
+  let curW1 = 0;
+
+  function updateMap(y: bigint, w: number, x: bigint) {
+    const existing = map.get(y);
+    if (!existing) {
+      map.set(y, { w, x });
+    } else if (w < existing.w) {
+      existing.w = w;
+      existing.x = x;
+    } else if (w === existing.w) {
+      if (isBetterP2(x, existing.x, M1)) {
+        existing.x = x;
+      }
+    }
+  }
+
+  updateMap(curY1, curW1, curX1);
+  for (let i = 1; i < (1 << M1); i++) {
+    let j = 0;
+    let temp = i;
+    while (!(temp & 1)) { temp >>= 1; j++; }
+    const bit = 1n << BigInt(j);
+    if ((curX1 & bit) === 0n) {
+      curX1 |= bit;
+      curY1 ^= buttonVecs[j];
+      curW1++;
+    } else {
+      curX1 &= ~bit;
+      curY1 ^= buttonVecs[j];
+      curW1--;
+    }
+    updateMap(curY1, curW1, curX1);
+  }
+
+  let bestX: bigint | null = null;
+  let bestW = Infinity;
+  let curX2 = 0n;
+  let curY2 = 0n;
+  let curW2 = 0;
+
+  function check(y2: bigint, w2: number, x2: bigint) {
+    const needed = targetVec ^ y2;
+    const match = map.get(needed);
+    if (match) {
+      const totalW = w2 + match.w;
+      const totalX = match.x | (x2 << BigInt(M1));
+      if (bestX === null || totalW < bestW) {
+        bestW = totalW;
+        bestX = totalX;
+      } else if (totalW === bestW) {
+        if (isBetterP2(totalX, bestX, M)) {
+          bestX = totalX;
+        }
+      }
+    }
+  }
+
+  check(curY2, curW2, curX2);
+  for (let i = 1; i < (1 << M2); i++) {
+    let j = 0;
+    let temp = i;
+    while (!(temp & 1)) { temp >>= 1; j++; }
+    const bit = 1n << BigInt(j);
+    if ((curX2 & bit) === 0n) {
+      curX2 |= bit;
+      curY2 ^= buttonVecs[M1 + j];
+      curW2++;
+    } else {
+      curX2 &= ~bit;
+      curY2 ^= buttonVecs[M1 + j];
+      curW2--;
+    }
+    check(curY2, curW2, curX2);
+  }
+
+  if (bestX === null) return null;
+  const res: number[] = new Array(M).fill(0);
+  for (let i = 0; i < M; i++) {
+    if ((bestX >> BigInt(i)) & 1n) res[i] = 1;
+  }
+  return res;
+}
