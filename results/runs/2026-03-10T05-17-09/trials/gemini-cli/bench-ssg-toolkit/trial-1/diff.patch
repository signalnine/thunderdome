+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // Matches <pre><code class="language-xyz">...</code></pre>
+        // Regex needs to handle the case where it has a class
+        const codeBlockRegex = /<pre>\s*<code class="language-([^"]+)">([\s\S]*?)<\/code>\s*<\/pre>/g;
+
+        content = content.replace(codeBlockRegex, (match, lang, inner) => {
+          return `<pre data-language="${lang}"><code class="language-${lang} highlighted">${inner}</code></pre>`;
+        });
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
