+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+        let content = file.content;
+        const assets = new Set<string>();
+
+        // Current manifest if it exists
+        const manifest = (ctx.data.get('asset-manifest') as { assets: string[] }) || { assets: [] };
+        const manifestAssets = new Set(manifest.assets);
+
+        // Regex for relative URLs like "./image.png"
+        // Need to be careful not to match absolute URLs or already processed /assets/
+        const urlRegex = /(src|href)="(\.\/[^"]+)"/g;
+
+        content = content.replace(urlRegex, (match, attr, url) => {
+          const assetName = url.substring(2); // remove "./"
+          assets.add(assetName);
+          return `${attr}="/assets/${assetName}"`;
+        });
+
+        if (assets.size > 0) {
+          assets.forEach(a => manifestAssets.add(a));
+          ctx.data.set('asset-manifest', { assets: Array.from(manifestAssets) });
+        }
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
