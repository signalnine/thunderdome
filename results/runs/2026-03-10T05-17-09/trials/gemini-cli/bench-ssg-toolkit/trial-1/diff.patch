+import { Plugin, BuildContext } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild: (ctx: BuildContext): void => {
+        const filesWithDates = [...ctx.files].sort((a, b) => {
+          const dateA = a.date ? new Date(a.date).getTime() : 0;
+          const dateB = b.date ? new Date(b.date).getTime() : 0;
+          return dateB - dateA;
+        });
+
+        const baseUrl = ctx.config.baseUrl.endsWith('/')
+          ? ctx.config.baseUrl.slice(0, -1)
+          : ctx.config.baseUrl;
+
+        let items = '';
+        for (const file of filesWithDates) {
+          let categories = '';
+          if (file.tags) {
+            for (const tag of file.tags) {
+              categories += `<category>${tag}</category>`;
+            }
+          }
+
+          items += `
+    <item>
+      <title>${file.title}</title>
+      <link>${baseUrl}/${file.slug}.html</link>
+      <guid>${baseUrl}/${file.slug}.html</guid>
+      <description><![CDATA[${file.content}]]></description>
+      ${file.date ? `<pubDate>${new Date(file.date).toUTCString()}</pubDate>` : ''}
+      ${categories}
+    </item>`;
+        }
+
+        const feed = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${ctx.config.title}</title>
+    <link>${baseUrl}</link>
+    <description>${ctx.config.title} RSS Feed</description>${items}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', feed.trim());
+      },
+    },
+  };
+}
