@@ -0,0 +1,59 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+import { marked } from 'marked';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, _ctx: BuildContext): Promise<ContentFile> => {
+        let content = file.content;
+
+        // Simple Footnote implementation
+        const footnotes: Map<string, string> = new Map();
+        const footnoteRegex = /^\[\^([^\]]+)\]:\s*(.*)$/gm;
+        let match;
+        while ((match = footnoteRegex.exec(content)) !== null) {
+          footnotes.set(match[1], match[2]);
+        }
+        content = content.replace(footnoteRegex, '').trim();
+
+        // Replace footnote references [^1]
+        content = content.replace(/\[\^([^\]]+)\]/g, (match, id) => {
+          if (footnotes.has(id)) {
+            // Finding the index of this footnote id among all captured footnotes to use as the display number
+            const keys = Array.from(footnotes.keys());
+            const index = keys.indexOf(id) + 1;
+            return `<sup><a href="#fn-${id}">${index}</a></sup>`;
+          }
+          return match;
+        });
+
+        // Admonition containers :::note, :::warning, :::tip
+        const admonitionRegex = /:::(note|warning|tip)\n([\s\S]*?)\n:::/g;
+        content = content.replace(admonitionRegex, (_match, type, innerContent) => {
+          return `<div class="admonition admonition-${type}">${innerContent}</div>`;
+        });
+
+        // Basic markdown to HTML using marked
+        let htmlContent = await marked.parse(content);
+
+        // Append footnotes section if any
+        if (footnotes.size > 0) {
+          let footnotesHtml = '<section class="footnotes"><ol>';
+          for (const [id, note] of footnotes.entries()) {
+            footnotesHtml += `<li id="fn-${id}">${note}</li>`;
+          }
+          footnotesHtml += '</ol></section>';
+          htmlContent += footnotesHtml;
+        }
+
+        return {
+          ...file,
+          content: htmlContent.trim(),
+        };
+      },
+    },
+  };
+}
