+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires = { ...inputs };
+  const remainingGates = [...gates];
+
+  let changed = true;
+  while (changed && remainingGates.length > 0) {
+    changed = false;
+    for (let i = 0; i < remainingGates.length; i++) {
+      const gate = remainingGates[i];
+      if (gate.in1 in wires && gate.in2 in wires) {
+        const val1 = wires[gate.in1];
+        const val2 = wires[gate.in2];
+        let res: number;
+        switch (gate.op) {
+          case 'AND':
+            res = val1 & val2;
+            break;
+          case 'OR':
+            res = val1 | val2;
+            break;
+          case 'XOR':
+            res = val1 ^ val2;
+            break;
+        }
+        wires[gate.out] = res;
+        remainingGates.splice(i, 1);
+        i--;
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const swapped = new Set<string>();
+
+  // Find max z index to know which is the last carry
+  let maxZ = -1;
+  for (const gate of gates) {
+    if (gate.out.startsWith('z')) {
+      const idx = parseInt(gate.out.slice(1));
+      if (idx > maxZ) maxZ = idx;
+    }
+  }
+
+  const lastZ = `z${maxZ.toString().padStart(2, '0')}`;
+
+  for (const gate of gates) {
+    // 1. z-outputs (except the last one) must come from XOR gates
+    if (gate.out.startsWith('z')) {
+      if (gate.out !== lastZ) {
+        if (gate.op !== 'XOR') {
+          swapped.add(gate.out);
+        }
+      } else {
+        // Last z bit (carry-out) should NOT be from an XOR gate (it's from an OR gate)
+        if (gate.op === 'XOR') {
+          swapped.add(gate.out);
+        }
+      }
+    }
+
+    // 2. XOR gates that don't output to z and don't take x,y as inputs are suspicious
+    if (gate.op === 'XOR' && !gate.out.startsWith('z')) {
+      const isInputGate = (gate.in1.startsWith('x') && gate.in2.startsWith('y')) || 
+                        (gate.in1.startsWith('y') && gate.in2.startsWith('x'));
+      if (!isInputGate) {
+        swapped.add(gate.out);
+      }
+    }
+
+    // 3. XOR gates taking x,y (except x00, y00) must feed into an XOR gate (to produce z)
+    // and an AND gate (to propagate carry)
+    if (gate.op === 'XOR' && 
+        ((gate.in1.startsWith('x') && gate.in2.startsWith('y')) || 
+         (gate.in1.startsWith('y') && gate.in2.startsWith('x')))) {
+      if (gate.in1 !== 'x00' && gate.in1 !== 'y00') {
+        const usedByXor = gates.some(g => (g.in1 === gate.out || g.in2 === gate.out) && g.op === 'XOR');
+        const usedByAnd = gates.some(g => (g.in1 === gate.out || g.in2 === gate.out) && g.op === 'AND');
+        if (!usedByXor || !usedByAnd) {
+          swapped.add(gate.out);
+        }
+      }
+    }
+
+    // 4. AND gates must feed into an OR gate
+    // Exception: x00 AND y00 feeds into the next bit's XOR and AND
+    if (gate.op === 'AND') {
+      const isBit0 = (gate.in1 === 'x00' && gate.in2 === 'y00') || (gate.in1 === 'y00' && gate.in2 === 'x00');
+      if (!isBit0) {
+        const usedByOr = gates.some(g => (g.in1 === gate.out || g.in2 === gate.out) && g.op === 'OR');
+        if (!usedByOr) {
+          swapped.add(gate.out);
+        }
+      } else {
+        // x00 AND y00 should feed into XOR and AND (for z01 and carry propagation)
+        const usedByXor = gates.some(g => (g.in1 === gate.out || g.in2 === gate.out) && g.op === 'XOR');
+        const usedByAnd = gates.some(g => (g.in1 === gate.out || g.in2 === gate.out) && g.op === 'AND');
+        if (!usedByXor || !usedByAnd) {
+          // Note: in a 1-bit adder this might be different, but we have 45 bits
+          swapped.add(gate.out);
+        }
+      }
+    }
+
+    // 5. OR gates (except the last z) must feed into XOR and AND
+    if (gate.op === 'OR' && gate.out !== lastZ) {
+      const usedByXor = gates.some(g => (g.in1 === gate.out || g.in2 === gate.out) && g.op === 'XOR');
+      const usedByAnd = gates.some(g => (g.in1 === gate.out || g.in2 === gate.out) && g.op === 'AND');
+      if (!usedByXor || !usedByAnd) {
+        swapped.add(gate.out);
+      }
+    }
+
+    // 6. z-outputs (except z00 and lastZ) must have one input from xNN XOR yNN
+    if (gate.out.startsWith('z') && gate.out !== 'z00' && gate.out !== lastZ) {
+      if (gate.op === 'XOR') {
+        const bitStr = gate.out.slice(1);
+        const expectedX = `x${bitStr}`;
+        const expectedY = `y${bitStr}`;
+        const inputXor = gates.find(g => 
+          g.op === 'XOR' && 
+          ((g.in1 === expectedX && g.in2 === expectedY) || (g.in1 === expectedY && g.in2 === expectedX))
+        );
+        if (inputXor) {
+          if (gate.in1 !== inputXor.out && gate.in2 !== inputXor.out) {
+            swapped.add(gate.out);
+          }
+        }
+      }
+    }
+  }
+
+  return Array.from(swapped).sort();
+}
