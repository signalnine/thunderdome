+export interface Operation {
+  type: 'insert' | 'delete' | 'init';
+  pos: number;
+  char?: string;
+  version: number;
+  userId?: string;
+}
+
+export function transform(op1: Operation, op2: Operation): Operation {
+  if (op1.type === 'init' || op2.type === 'init') return op1;
+
+  const newOp = { ...op1 };
+
+  if (op1.type === 'insert' && op2.type === 'insert') {
+    if (op1.pos < op2.pos || (op1.pos === op2.pos && op1.userId! < op2.userId!)) {
+      // no change
+    } else {
+      newOp.pos += 1;
+    }
+  } else if (op1.type === 'insert' && op2.type === 'delete') {
+    if (op1.pos <= op2.pos) {
+      // no change
+    } else {
+      newOp.pos -= 1;
+    }
+  } else if (op1.type === 'delete' && op2.type === 'insert') {
+    if (op1.pos < op2.pos) {
+      // no change
+    } else {
+      newOp.pos += 1;
+    }
+  } else if (op1.type === 'delete' && op2.type === 'delete') {
+    if (op1.pos < op2.pos) {
+      // no change
+    } else if (op1.pos > op2.pos) {
+      newOp.pos -= 1;
+    } else {
+      // Both deleting same character. Make op1 a no-op
+      newOp.type = 'init';
+    }
+  }
+
+  return newOp;
+}
+
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    return content.slice(0, op.pos) + (op.char || '') + content.slice(op.pos);
+  } else if (op.type === 'delete') {
+    return content.slice(0, op.pos) + content.slice(op.pos + 1);
+  }
+  return content;
+}
