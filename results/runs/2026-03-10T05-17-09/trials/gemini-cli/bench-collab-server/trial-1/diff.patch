+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { createApp } from './server.js';
+import request from 'supertest';
+import { WebSocket } from 'ws';
+
+import { Express } from 'express';
+
+interface AppResult {
+  app: Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+describe('Document Server', () => {
+  let appInstance: AppResult;
+  let port: number;
+
+  beforeEach(async () => {
+    appInstance = createApp(':memory:') as AppResult;
+    port = await appInstance.start();
+  });
+
+  afterEach(async () => {
+    await appInstance.stop();
+  });
+
+  it('should create and list documents', async () => {
+    const res = await request(appInstance.app)
+      .post('/api/documents')
+      .send({ title: 'Test Doc', content: 'Hello' });
+
+    expect(res.status).toBe(201);
+    expect(res.body.title).toBe('Test Doc');
+    expect(res.body.content).toBe('Hello');
+
+    const listRes = await request(appInstance.app).get('/api/documents');
+    expect(listRes.status).toBe(200);
+    expect(listRes.body.length).toBe(1);
+    expect(listRes.body[0].title).toBe('Test Doc');
+  });
+
+  it('should handle real-time edits via WebSocket', async () => {
+    const createRes = await request(appInstance.app)
+      .post('/api/documents')
+      .send({ title: 'Collab Doc', content: 'abc' });
+    const docId = createRes.body.id;
+
+    const ws = new WebSocket(`ws://localhost:${port}/doc/${docId}`);
+
+    const syncPromise = new Promise<{ content: string; version: number }>((resolve) => {
+      ws.on('message', (data) => {
+        const msg = JSON.parse(data.toString());
+        if (msg.type === 'sync') resolve(msg);
+      });
+    });
+
+    await new Promise<void>((resolve) => {
+      ws.on('open', resolve);
+    });
+
+    const syncMsg = await syncPromise;
+    expect(syncMsg.content).toBe('abc');
+    expect(syncMsg.version).toBe(0);
+
+    const broadcastPromise = new Promise<{ op: { type: string, pos: number, char?: string, version: number } }>((resolve) => {
+      ws.on('message', (data) => {
+        const msg = JSON.parse(data.toString());
+        if (msg.type === 'broadcast') resolve(msg);
+      });
+    });
+
+    // Send an operation: insert 'd' at pos 3
+    ws.send(JSON.stringify({
+      type: 'operation',
+      op: { type: 'insert', pos: 3, char: 'd', version: 0 }
+    }));
+
+    const broadcastMsg = await broadcastPromise;
+    expect(broadcastMsg.op.type).toBe('insert');
+    expect(broadcastMsg.op.pos).toBe(3);
+    expect(broadcastMsg.op.char).toBe('d');
+    expect(broadcastMsg.op.version).toBe(1);
+
+    // Verify via REST
+    const finalDoc = await request(appInstance.app).get(`/api/documents/${docId}`);
+    expect(finalDoc.body.content).toBe('abcd');
+
+    ws.close();
+  });
+
+  it('should resolve concurrent edits', async () => {
+    const createRes = await request(appInstance.app)
+      .post('/api/documents')
+      .send({ title: 'Concurrent Doc', content: 'abc' });
+    const docId = createRes.body.id;
+
+    const ws1 = new WebSocket(`ws://localhost:${port}/doc/${docId}`);
+    const ws2 = new WebSocket(`ws://localhost:${port}/doc/${docId}`);
+
+    const ws1Sync = new Promise(resolve => ws1.on('message', (data) => {
+        if (JSON.parse(data.toString()).type === 'sync') resolve(null);
+    }));
+    const ws2Sync = new Promise(resolve => ws2.on('message', (data) => {
+        if (JSON.parse(data.toString()).type === 'sync') resolve(null);
+    }));
+
+    await Promise.all([
+      new Promise(resolve => ws1.on('open', resolve)),
+      new Promise(resolve => ws2.on('open', resolve)),
+      ws1Sync,
+      ws2Sync
+    ]);
+
+    // Wait for two broadcasts on both
+    let count1 = 0;
+    let count2 = 0;
+    const ws1Done = new Promise<void>(resolve => ws1.on('message', (data) => {
+        if (JSON.parse(data.toString()).type === 'broadcast') {
+          count1++;
+          if (count1 === 2) resolve();
+        }
+    }));
+    const ws2Done = new Promise<void>(resolve => ws2.on('message', (data) => {
+        if (JSON.parse(data.toString()).type === 'broadcast') {
+          count2++;
+          if (count2 === 2) resolve();
+        }
+    }));
+
+    // ws1 inserts 'X' at 0
+    ws1.send(JSON.stringify({
+      type: 'operation',
+      op: { type: 'insert', pos: 0, char: 'X', version: 0, userId: 'user1' }
+    }));
+
+    // ws2 inserts 'Y' at 0
+    ws2.send(JSON.stringify({
+      type: 'operation',
+      op: { type: 'insert', pos: 0, char: 'Y', version: 0, userId: 'user2' }
+    }));
+
+    await Promise.all([ws1Done, ws2Done]);
+
+    // Verify document content
+    const finalDoc = await request(appInstance.app).get(`/api/documents/${docId}`);
+    expect(finalDoc.body.content).toBe('XYabc');
+
+    ws1.close();
+    ws2.close();
+  });
+
+  it('should handle 10 concurrent clients without corruption', async () => {
+    const createRes = await request(appInstance.app)
+      .post('/api/documents')
+      .send({ title: 'Multi Collab', content: '' });
+    const docId = createRes.body.id;
+
+    const numClients = 10;
+    const clients: WebSocket[] = [];
+    const syncPromises: Promise<unknown>[] = [];
+
+    for (let i = 0; i < numClients; i++) {
+      const ws = new WebSocket(`ws://localhost:${port}/doc/${docId}`);
+      clients.push(ws);
+      syncPromises.push(new Promise(resolve => ws.on('message', (data) => {
+        if (JSON.parse(data.toString()).type === 'sync') resolve(null);
+      })));
+    }
+
+    await Promise.all([
+      ...clients.map(ws => new Promise(resolve => ws.on('open', resolve))),
+      ...syncPromises
+    ]);
+
+    const broadcastPromises: Promise<void>[] = [];
+    for (let i = 0; i < numClients; i++) {
+      const ws = clients[i];
+      let count = 0;
+      broadcastPromises.push(new Promise<void>(resolve => ws.on('message', (data) => {
+        if (JSON.parse(data.toString()).type === 'broadcast') {
+          count++;
+          if (count === numClients) resolve();
+        }
+      })));
+    }
+
+    // Each client inserts its index at position 0
+    for (let i = 0; i < numClients; i++) {
+      clients[i].send(JSON.stringify({
+        type: 'operation',
+        op: { type: 'insert', pos: 0, char: i.toString(), version: 0, userId: `user${i}` }
+      }));
+    }
+
+    await Promise.all(broadcastPromises);
+
+    const finalDoc = await request(appInstance.app).get(`/api/documents/${docId}`);
+    expect(finalDoc.body.content.length).toBe(numClients);
+    
+    // Sort the characters of the final content to verify all were preserved
+    const sortedContent = finalDoc.body.content.split('').sort().join('');
+    let expected = '';
+    for (let i = 0; i < numClients; i++) expected += i.toString();
+    expect(sortedContent).toBe(expected);
+
+    clients.forEach(ws => ws.close());
+  });
