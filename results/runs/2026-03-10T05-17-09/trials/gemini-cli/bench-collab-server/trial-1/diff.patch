+import Database from 'better-sqlite3';
+import { readFileSync } from 'fs';
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string;
+  created_at: string;
+}
+
+export class DocumentDB {
+  private db: Database.Database;
+
+  constructor(dbPath: string = ':memory:') {
+    this.db = new Database(dbPath);
+    const schema = readFileSync('schema.sql', 'utf8');
+    this.db.exec(schema);
+  }
+
+  createDocument(id: string, title: string, content: string = ''): Document {
+    const stmt = this.db.prepare(
+      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+    );
+    stmt.run(id, title, content);
+
+    // Initial version
+    this.addVersion(id, 0, content, JSON.stringify({ type: 'init' }));
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): Document | undefined {
+    return this.db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Document | undefined;
+  }
+
+  listDocuments(): Document[] {
+    return this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC').all() as Document[];
+  }
+
+  updateDocumentTitle(id: string, title: string) {
+    this.db.prepare("UPDATE documents SET title = ?, updated_at = datetime('now') WHERE id = ?").run(title, id);
+  }
+
+  updateDocumentContent(id: string, content: string) {
+    this.db.prepare("UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?").run(content, id);
+  }
+
+  applyOperation(id: string, content: string, version: number, operation: string) {
+    const updateContent = this.db.prepare("UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?");
+    const insertVersion = this.db.prepare('INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)');
+    
+    const transaction = this.db.transaction((id, content, version, operation) => {
+      updateContent.run(content, id);
+      insertVersion.run(id, version, content, operation);
+    });
+
+    transaction(id, content, version, operation);
+  }
+
+  deleteDocument(id: string) {
+    this.db.prepare('DELETE FROM documents WHERE id = ?').run(id);
+  }
+
+  addVersion(document_id: string, version: number, content: string, operation: string) {
+    const stmt = this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    );
+    stmt.run(document_id, version, content, operation);
+  }
+
+  getVersions(document_id: string): Version[] {
+    return this.db.prepare('SELECT * FROM versions WHERE document_id = ? ORDER BY version DESC').all(document_id) as Version[];
+  }
+
+  getLatestVersion(document_id: string): number {
+    const res = this.db.prepare('SELECT MAX(version) as max_v FROM versions WHERE document_id = ?').get(document_id) as { max_v: number | null };
+    return res.max_v ?? -1;
+  }
+
+  close() {
+    this.db.close();
+  }
+}
