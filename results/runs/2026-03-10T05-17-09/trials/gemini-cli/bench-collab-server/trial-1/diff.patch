diff --git a/src/server.ts b/src/server.ts
new file mode 100644
index 0000000..493cf5f
--- /dev/null
+++ b/src/server.ts
@@ -0,0 +1,189 @@
+import express from 'express';
+import { createServer } from 'http';
+import { WebSocketServer, WebSocket } from 'ws';
+import { DocumentDB } from './db.js';
+import { Operation, transform, applyOperation } from './ot.js';
+import { randomUUID } from 'crypto';
+
+interface AppResult {
+  app: express.Express;
+  start: (port?: number) => Promise<number>;
+  stop: () => Promise<void>;
+}
+
+export function createApp(dbPath: string = ':memory:'): AppResult {
+  const app = express();
+  const db = new DocumentDB(dbPath);
+  const server = createServer(app);
+  const wss = new WebSocketServer({ noServer: true });
+
+  app.use(express.json());
+
+  // REST API
+  app.get('/api/documents', (req, res) => {
+    res.json(db.listDocuments());
+  });
+
+  app.post('/api/documents', (req, res) => {
+    const { title, content } = req.body;
+    if (!title) return res.status(400).json({ error: 'Title is required' });
+    const id = randomUUID();
+    const doc = db.createDocument(id, title, content || '');
+    res.status(201).json(doc);
+  });
+
+  app.get('/api/documents/:id', (req, res) => {
+    const doc = db.getDocument(req.params.id);
+    if (!doc) return res.status(404).json({ error: 'Document not found' });
+    res.json(doc);
+  });
+
+  app.put('/api/documents/:id', (req, res) => {
+    const doc = db.getDocument(req.params.id);
+    if (!doc) return res.status(404).json({ error: 'Document not found' });
+    const { title } = req.body;
+    if (title) db.updateDocumentTitle(req.params.id, title);
+    res.json(db.getDocument(req.params.id));
+  });
+
+  app.delete('/api/documents/:id', (req, res) => {
+    db.deleteDocument(req.params.id);
+    res.status(204).send();
+  });
+
+  app.get('/api/documents/:id/history', (req, res) => {
+    res.json(db.getVersions(req.params.id));
+  });
+
+  // WebSocket
+  const connections = new Map<string, Set<WebSocket>>();
+
+  server.on('upgrade', (request, socket, head) => {
+    const url = new URL(request.url || '', `http://${request.headers.host}`);
+    const match = url.pathname.match(/^\/doc\/([^/]+)$/);
+    if (match) {
+      const docId = match[1];
+      const doc = db.getDocument(docId);
+      if (doc) {
+        wss.handleUpgrade(request, socket, head, (ws) => {
+          wss.emit('connection', ws, docId);
+        });
+      } else {
+        socket.destroy();
+      }
+    } else {
+      socket.destroy();
+    }
+  });
+
+  wss.on('connection', (ws: WebSocket, docId: string) => {
+    if (!connections.has(docId)) {
+      connections.set(docId, new Set());
+    }
+    const docConnections = connections.get(docId)!;
+    docConnections.add(ws);
+
+    const userId = randomUUID();
+    const doc = db.getDocument(docId)!;
+    const currentVersion = db.getLatestVersion(docId);
+
+    // Send initial state
+    ws.send(JSON.stringify({
+      type: 'sync',
+      docId,
+      content: doc.content,
+      version: currentVersion,
+      title: doc.title,
+      userId
+    }));
+
+    ws.on('message', (data) => {
+      try {
+        const msg = JSON.parse(data.toString());
+        if (msg.type === 'operation') {
+          const incomingOp = msg.op as Operation;
+          if (!incomingOp.userId) incomingOp.userId = userId;
+          handleOperation(docId, ws, incomingOp);
+        }
+      } catch (e) {
+        console.error('Error handling WS message', e);
+        ws.send(JSON.stringify({ type: 'error', message: 'Invalid message format' }));
+      }
+    });
+
+    ws.on('close', () => {
+      docConnections.delete(ws);
+      if (docConnections.size === 0) {
+        connections.delete(docId);
+      }
+    });
+  });
+
+  function handleOperation(docId: string, ws: WebSocket, incomingOp: Operation) {
+    const doc = db.getDocument(docId);
+    if (!doc) return;
+
+    const currentVersion = db.getLatestVersion(docId);
+    let opToApply = { ...incomingOp };
+
+    if (incomingOp.version < currentVersion) {
+      // Transformation needed
+      const history = db.getVersions(docId);
+      // Versions are sorted by version DESC.
+      // We need versions from incomingOp.version + 1 up to currentVersion
+      const opsInBetween = history
+        .filter(v => v.version > incomingOp.version)
+        .sort((a, b) => a.version - b.version);
+
+      for (const v of opsInBetween) {
+        const histOp = JSON.parse(v.operation) as Operation;
+        opToApply = transform(opToApply, histOp);
+      }
+    }
+
+    // Apply transformed operation
+    const newContent = applyOperation(doc.content, opToApply);
+    const newVersion = currentVersion + 1;
+    opToApply.version = newVersion;
+
+    db.applyOperation(docId, newContent, newVersion, JSON.stringify(opToApply));
+
+    // Broadcast to ALL (including sender, so they know their op was accepted and get the final version)
+    const broadcastMsg = JSON.stringify({
+      type: 'broadcast',
+      op: opToApply
+    });
+
+    const docConnections = connections.get(docId);
+    if (docConnections) {
+      for (const client of docConnections) {
+        if (client.readyState === WebSocket.OPEN) {
+          client.send(broadcastMsg);
+        }
+      }
+    }
+  }
+
+  return {
+    app,
+    start: (port: number = 0) => {
+      return new Promise((resolve) => {
+        server.listen(port, () => {
+          const addr = server.address();
+          const actualPort = typeof addr === 'string' ? 0 : addr?.port || 0;
+          resolve(actualPort);
+        });
+      });
+    },
+    stop: async () => {
+      await new Promise<void>((resolve) => {
+        wss.close(() => {
+          server.close(() => {
+            db.close();
+            resolve();
+          });
+        });
+      });
+    }
+  };
+}
