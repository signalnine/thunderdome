+++ b/src/server.ts
@@ -0,0 +1,383 @@
+import express, { Request, Response } from 'express';
+import { createServer } from 'http';
+import { WebSocket, WebSocketServer } from 'ws';
+import Database from 'better-sqlite3';
+import { v4 as uuidv4 } from 'uuid';
+
+interface Document {
+  id: string;
+  title: string;
+  content: string;
+  version: number;
+}
+
+interface Operation {
+  type: 'insert' | 'delete';
+  position: number;
+  text?: string; // for insert
+  length?: number; // for delete
+}
+
+interface ClientOperation {
+  operation: Operation;
+  baseVersion: number;
+}
+
+interface BroadcastOperation {
+  operation: Operation;
+  version: number;
+}
+
+interface CreateAppOptions {
+  dbFile?: string;
+}
+
+export function createApp(options: CreateAppOptions = {}) {
+  const app = express();
+  app.use(express.json());
+
+  const dbFile = options.dbFile || ':memory:';
+  const db = new Database(dbFile);
+
+  // Initialize database tables
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS documents (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      content TEXT NOT NULL,
+      version INTEGER NOT NULL
+    );
+    
+    CREATE TABLE IF NOT EXISTS document_operations (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      document_id TEXT NOT NULL,
+      operation TEXT NOT NULL,
+      version INTEGER NOT NULL,
+      created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
+      FOREIGN KEY (document_id) REFERENCES documents(id)
+    );
+    
+    CREATE INDEX IF NOT EXISTS idx_doc_ops ON document_operations(document_id, version);
+  `);
+
+  // REST API for document management
+  app.get('/documents', async (req: Request, res: Response) => {
+    const stmt = db.prepare('SELECT id, title, version FROM documents');
+    const docs = stmt.all() as { id: string; title: string; version: number }[];
+    res.json(docs);
+  });
+
+  app.post('/documents', (req: Request, res: Response) => {
+    const { title } = req.body;
+    if (!title) {
+      return res.status(400).json({ error: 'Title is required' });
+    }
+    const id = uuidv4();
+    const content = '';
+    const version = 0;
+    const insertDoc = db.prepare(
+      'INSERT INTO documents (id, title, content, version) VALUES (?, ?, ?, ?)'
+    );
+    insertDoc.run(id, title, content, version);
+    res.status(201).json({ id, title, version });
+  });
+
+  app.get('/documents/:id', (req: Request, res: Response) => {
+    const { id } = req.params;
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(id);
+    if (!doc) {
+      return res.status(404).json({ error: 'Document not found' });
+    }
+    res.json(doc);
+  });
+
+  app.put('/documents/:id', (req: Request, res: Response) => {
+    const { id } = req.params;
+    const { title, content } = req.body;
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(id);
+    if (!doc) {
+      return res.status(404).json({ error: 'Document not found' });
+    }
+    const updateDoc = db.prepare(
+      'UPDATE documents SET title = COALESCE(?, title), content = COALESCE(?, content) WHERE id = ?'
+    );
+    updateDoc.run(title, content, id);
+    const updated = db.prepare('SELECT * FROM documents WHERE id = ?').get(id);
+    res.json(updated);
+  });
+
+  app.delete('/documents/:id', (req: Request, res: Response) => {
+    const { id } = req.params;
+    const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get(id);
+    if (!doc) {
+      return res.status(404).json({ error: 'Document not found' });
+    }
+    db.prepare('DELETE FROM document_operations WHERE document_id = ?').run(id);
+    db.prepare('DELETE FROM documents WHERE id = ?').run(id);
+    res.status(204).send();
+  });
+
+  app.get('/documents/:id/versions', (req: Request, res: Response) => {
+    const { id } = req.params;
+    const versions = db.prepare(
+      'SELECT version, created_at FROM document_operations WHERE document_id = ? ORDER BY version'
+    ).all(id) as { version: number; created_at: string }[];
+    res.json(versions);
+  });
+
+  // WebSocket server setup
+  const httpServer = createServer(app);
+  const wss = new WebSocketServer({ server: httpServer, path: '/ws' });
+
+  // In-memory storage for active connections per document
+  const documentClients = new Map<string, Set<WebSocket>>();
+
+  // OT transformation functions
+  function transformInsert(insertOp: Operation, otherOp: Operation): Operation {
+    if (insertOp.type !== 'insert') {
+      throw new Error('Expected insert operation');
+    }
+    let pos = insertOp.position;
+    if (otherOp.type === 'insert') {
+      if (otherOp.position < pos || (otherOp.position === pos && otherOp.text!.length > 0)) {
+        pos += otherOp.text!.length;
+      }
+    } else if (otherOp.type === 'delete') {
+      const deleteEnd = otherOp.position + (otherOp.length || 0);
+      if (otherOp.position < pos) {
+        pos -= Math.min(deleteEnd, pos) - otherOp.position;
+      } else if (otherOp.position >= pos && otherOp.position < pos) {
+        // This case is covered by the first condition? Actually, if delete starts after insert position, no change
+        // But if delete starts before or at insert position and ends after insert position, we adjust
+        const overlap = Math.min(deleteEnd, pos) - otherOp.position;
+        if (overlap > 0) {
+          pos -= overlap;
+        }
+      }
+    }
+    return { ...insertOp, position: pos };
+  }
+
+  function transformDelete(deleteOp: Operation, otherOp: Operation): Operation {
+    if (deleteOp.type !== 'delete') {
+      throw new Error('Expected delete operation');
+    }
+    let pos = deleteOp.position;
+    let len = deleteOp.length || 0;
+    if (otherOp.type === 'insert') {
+      const insertEnd = otherOp.position + (otherOp.text?.length || 0);
+      if (otherOp.position < pos + len) {
+        if (otherOp.position < pos) {
+          // Insertion starts before deletion
+          pos += otherOp.text?.length || 0;
+        } else {
+          // Insertion starts within deletion
+          len += otherOp.text?.length || 0;
+        }
+      }
+    } else if (otherOp.type === 'delete') {
+      const otherEnd = otherOp.position + (otherOp.length || 0);
+      const thisEnd = pos + len;
+      if (otherOp.position < pos) {
+        if (otherEnd <= pos) {
+          // Other deletion ends before this deletion starts
+          pos -= otherOp.length || 0;
+        } else if (otherEnd < thisEnd) {
+          // Other deletion partially overlaps with this deletion
+          pos -= otherOp.length || 0;
+          len -= (otherEnd - pos);
+        } else {
+          // Other deletion completely covers this deletion or extends beyond
+          len = 0;
+        }
+      } else if (otherOp.position < pos + len) {
+        // Other deletion starts within this deletion
+        len -= Math.min(otherOp.length || 0, pos + len - otherOp.position);
+      }
+    }
+    if (len < 0) len = 0;
+    return { ...deleteOp, position: pos, length: len };
+  }
+
+  function transformOperation(operation: Operation, otherOp: Operation): Operation {
+    if (operation.type === 'insert') {
+      return transformInsert(operation, otherOp);
+    } else {
+      return transformDelete(operation, otherOp);
+    }
+  }
+
+  function applyOperation(content: string, operation: Operation): string {
+    if (operation.type === 'insert') {
+      const { position, text } = operation;
+      if (text === undefined) throw new Error('Insert operation requires text');
+      return content.slice(0, position) + text + content.slice(position);
+    } else {
+      const { position, length } = operation;
+      const len = length || 0;
+      return content.slice(0, position) + content.slice(position + len);
+    }
+  }
+
+  wss.on('connection', (ws: WebSocket, req: Request) => {
+    const url = new URL(req.url || '', `http://${req.headers.host}`);
+    const documentId = url.pathname.split('/').pop();
+    if (!documentId) {
+      ws.close(1008, 'Document ID required');
+      return;
+    }
+
+    // Verify document exists
+    const getDoc = db.prepare('SELECT * FROM documents WHERE id = ?');
+    const doc = getDoc.get(documentId) as Document | undefined;
+    if (!doc) {
+      ws.close(1008, 'Document not found');
+      return;
+    }
+
+    // Add client to document's client set
+    if (!documentClients.has(documentId)) {
+      documentClients.set(documentId, new Set());
+    }
+    const clients = documentClients.get(documentId)!;
+    clients.add(ws);
+
+    // Send current state to newly connected client
+    ws.send(JSON.stringify({
+      type: 'init',
+      documentId,
+      content: doc.content,
+      version: doc.version
+    }));
+
+    ws.on('message', (data: WebSocket.Data) => {
+      try {
+        const message = JSON.parse(data.toString());
+        if (message.type === 'operation') {
+          const clientOp = message as ClientOperation;
+          const { operation, baseVersion } = clientOp;
+
+          // Begin transaction
+          const transaction = db.transaction(() => {
+            // Get current document state
+            const currentDoc = db.prepare('SELECT * FROM documents WHERE id = ?').get(documentId) as Document | undefined;
+            if (!currentDoc) {
+              throw new Error('Document not found');
+            }
+
+            // Check if baseVersion matches current version
+            if (baseVersion > currentDoc.version) {
+              throw new Error('Base version too new');
+            }
+
+            // If baseVersion is behind, retrieve and transform against missed operations
+            let transformedOp = { ...operation };
+            if (baseVersion < currentDoc.version) {
+              const missedOpsStmt = db.prepare(
+                                'SELECT operation, version FROM document_operations WHERE document_id = ? AND version > ? AND version <= ? ORDER BY version'
+                              );
+              const missedOps = missedOpsStmt.all(documentId, baseVersion, currentDoc.version) as { operation: string; version: number }[];
+              for (const opRow of missedOps) {
+                const pastOp = JSON.parse(opRow.operation) as Operation;
+                transformedOp = transformOperation(transformedOp, pastOp);
+              }
+            }
+
+            // Apply transformed operation to current content
+            const newContent = applyOperation(currentDoc.content, transformedOp);
+            const newVersion = currentDoc.version + 1;
+
+            // Store operation
+            const insertOp = db.prepare(
+              'INSERT INTO document_operations (document_id, operation, version) VALUES (?, ?, ?)'
+            );
+            insertOp.run(documentId, JSON.stringify(transformedOp), newVersion);
+
+            // Update document
+            const updateDoc = db.prepare(
+              'UPDATE documents SET content = ?, version = ? WHERE id = ?'
+            );
+            updateDoc.run(newContent, newVersion, documentId);
+
+            // Broadcast to other clients
+            const broadcastMsg: BroadcastOperation = {
+              operation: transformedOp,
+              version: newVersion
+            };
+            for (const client of clients) {
+              if (client !== ws && client.readyState === WebSocket.OPEN) {
+                client.send(JSON.stringify({
+                  type: 'operation',
+                  documentId,
+                  ...broadcastMsg
+                }));
+              }
+            }
+
+            return { newContent, newVersion };
+          });
+
+          const result = transaction();
+          // Optionally send acknowledgment to sender
+          if (ws.readyState === WebSocket.OPEN) {
+            ws.send(JSON.stringify({
+              type: 'ack',
+              version: result.newVersion
+            }));
+          }
+        }
+      } catch (err) {
+        if (ws.readyState === WebSocket.OPEN) {
+          ws.send(JSON.stringify({
+            type: 'error',
+            error: err instanceof Error ? err.message : 'Unknown error'
+          }));
+        }
+      }
+    });
+
+    ws.on('close', () => {
+      clients.delete(ws);
+      if (clients.size === 0) {
+        documentClients.delete(documentId);
+      }
+    });
+
+    ws.on('error', (err) => {
+      console.error('WebSocket error:', err);
+    });
+  });
+
+  // Start and stop functions
+  let port: number | null = null;
+  return {
+    app,
+    start: (portNum?: number): Promise<number> => {
+      return new Promise((resolve) => {
+        httpServer.listen(portNum || 0, () => {
+          const addr = httpServer.address();
+          if (addr && typeof addr !== 'string' && addr.port) {
+            port = addr.port;
+            resolve(port);
+          } else {
+            port = 0;
+            resolve(port);
+          }
+        });
+      });
+    },
+    stop: (): Promise<void> => {
+      return new Promise((resolve, reject) => {
+        httpServer.close((err) => {
+          if (err) {
+            reject(err);
+          } else {
+            wss.close(() => {
+              resolve();
+            });
+          }
+        });
+      });
+    }
+  };
+}
