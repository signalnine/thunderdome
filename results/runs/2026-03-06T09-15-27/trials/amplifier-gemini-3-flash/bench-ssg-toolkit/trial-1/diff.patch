@@ -0,0 +1,27 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // Match <pre><code class="language-xxx">...</code></pre>
+        const regex = /<pre><code class="language-([^"]+)">([\s\S]*?)<\/code><\/pre>/g;
+
+        content = content.replace(regex, (match, lang, code) => {
+          const highlightedClass = `language-${lang} highlighted`;
+          return `<pre data-language="${lang}"><code class="${highlightedClass}">${code}</code></pre>`;
+        });
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
