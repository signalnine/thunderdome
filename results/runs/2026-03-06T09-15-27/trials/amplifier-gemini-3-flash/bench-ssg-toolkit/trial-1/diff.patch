@@ -0,0 +1,34 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      afterBuild: (ctx: BuildContext): void => {
+        const searchIndex = ctx.files.map(file => {
+          // Strip HTML tags to get plain text
+          const plainText = file.content
+            .replace(/<[^>]*>/g, ' ')
+            .replace(/\s+/g, ' ')
+            .trim();
+
+          const entry: { title: string; slug: string; content: string; tags?: string[] } = {
+            title: file.title,
+            slug: file.slug,
+            content: plainText,
+          };
+
+          if (file.tags) {
+            entry.tags = file.tags;
+          }
+
+          return entry;
+        });
+
+        ctx.output.set('search-index.json', JSON.stringify(searchIndex, null, 2));
+      },
+    },
+  };
+}
