@@ -0,0 +1,66 @@
+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: async (file: ContentFile, _ctx: BuildContext): Promise<ContentFile> => {
+        let content = file.content;
+
+        // Handle admonitions :::type ... :::
+        const admonitionRegex = /^:::(note|warning|tip)\n([\s\S]*?)\n:::/gm;
+        content = content.replace(admonitionRegex, (_match, type, innerContent) => {
+          return `<div class="admonition admonition-${type}">\n${innerContent}\n</div>`;
+        });
+
+        // Handle footnotes [^1]
+        const footnoteRefRegex = /\[\^(\d+)\]/g;
+        const footnotes: Map<string, string> = new Map();
+        
+        // Find footnote definitions [^1]: content
+        const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.*)$/gm;
+        let match;
+        const definitions: string[] = [];
+        while ((match = footnoteDefRegex.exec(content)) !== null) {
+          footnotes.set(match[1], match[2]);
+          definitions.push(match[0]);
+        }
+
+        // Remove definitions from content
+        for (const def of definitions) {
+          content = content.replace(def, '');
+        }
+
+        // Replace references
+        content = content.replace(footnoteRefRegex, (_match, id) => {
+          if (footnotes.has(id)) {
+            return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+          }
+          return _match;
+        });
+
+        // Convert to HTML using marked
+        let html = await marked.parse(content);
+
+        // Append footnotes section if any
+        if (footnotes.size > 0) {
+          let footnotesHtml = '\n<section class="footnotes">\n<hr>\n<ol>\n';
+          const sortedIds = Array.from(footnotes.keys()).sort((a, b) => parseInt(a) - parseInt(b));
+          for (const id of sortedIds) {
+            footnotesHtml += `<li id="fn-${id}">${footnotes.get(id)}</li>\n`;
+          }
+          footnotesHtml += '</ol>\n</section>';
+          html += footnotesHtml;
+        }
+
+        return {
+          ...file,
+          content: html.trim(),
+        };
+      },
+    },
+  };
+}
