@@ -0,0 +1,34 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+        let content = file.content;
+        const manifest = ctx.data.get('asset-manifest') as { assets: string[] } || { assets: [] };
+        const assetSet = new Set(manifest.assets);
+
+        // Regex to find src="./..." or href="./..."
+        const regex = /(src|href)="(\.\/([^"]+))"/g;
+
+        content = content.replace(regex, (match, attr, fullPath, fileName) => {
+          if (fullPath.startsWith('./')) {
+            assetSet.add(fileName);
+            return `${attr}="/assets/${fileName}"`;
+          }
+          return match;
+        });
+
+        ctx.data.set('asset-manifest', { assets: Array.from(assetSet) });
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
