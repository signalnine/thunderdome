+import { v4 as uuidv4 } from 'uuid';
+import { getDB } from './database.js';
+import { Event, CreateEvent, BatchEvents, EventQuery, QueryParams, Dashboard, CreateDashboard } from './types.js';
+
+export function createEvent(event: CreateEvent, user_id?: string, session_id?: string): Event {
+  const db = getDB();
+  const tenant_id = db.prepare('SELECT tenant_id FROM users WHERE id = ?').get(user_id) as { tenant_id: string };
+
+  const id = uuidv4();
+  const properties = JSON.stringify(event.properties || {});
+  const timestamp = event.timestamp || new Date().toISOString();
+
+  db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  ).run(id, tenant_id, event.name, properties, timestamp, user_id || null, session_id || null);
+
+  return {
+    id,
+    tenant_id: tenant_id.tenant_id,
+    name: event.name,
+    properties,
+    timestamp,
+    user_id,
+    session_id,
+  };
+}
+
+export function createEvents(events: CreateEvent[], user_id?: string, session_id?: string): Event[] {
+  const db = getDB();
+  const tenant_id = db.prepare('SELECT tenant_id FROM users WHERE id = ?').get(user_id) as { tenant_id: string };
+
+  const resultEvents: Event[] = [];
+
+  const insertStmt = db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  );
+
+  db.transaction(() => {
+    for (const event of events) {
+      const id = uuidv4();
+      const properties = JSON.stringify(event.properties || {});
+      const timestamp = event.timestamp || new Date().toISOString();
+
+      insertStmt.run(id, tenant_id.tenant_id, event.name, properties, timestamp, user_id || null, session_id || null);
+
+      resultEvents.push({
+        id,
+        tenant_id: tenant_id.tenant_id,
+        name: event.name,
+        properties,
+        timestamp,
+        user_id,
+        session_id,
+      });
+    }
+  })();
+
+  return resultEvents;
+}
+
+export function getEventById(id: string): Event | null {
+  const db = getDB();
+  return db.prepare('SELECT * FROM events WHERE id = ?').get(id) as Event | null;
+}
+
+export function findEventsByTenant(params: EventQuery & { limit?: number }): Event[] {
+  const db = getDB();
+  let sql = 'SELECT * FROM events WHERE 1=1';
+  const paramsList: any[] = [];
+
+  if (params.name) {
+    sql += ' AND name = ?';
+    paramsList.push(params.name);
+  }
+  if (params.start_time) {
+    sql += ' AND timestamp >= ?';
+    paramsList.push(params.start_time);
+  }
+  if (params.end_time) {
+    sql += ' AND timestamp <= ?';
+    paramsList.push(params.end_time);
+  }
+
+  sql += ' ORDER BY timestamp DESC';
+
+  if (params.limit) {
+    sql += ' LIMIT ?';
+  }
+
+  const stmt = db.prepare(sql);
+  const args = paramsList.length ? paramsList : undefined;
+  return args ? stmt.all(...args) as Event[] : stmt.all() as Event[];
+}
+
+export function countEvents(params: EventQuery): number {
+  const db = getDB();
+  let sql = 'SELECT COUNT(*) as count FROM events WHERE 1=1';
+  const paramsList: any[] = [];
+
+  if (params.name) {
+    sql += ' AND name = ?';
+    paramsList.push(params.name);
+  }
+  if (params.start_time) {
+    sql += ' AND timestamp >= ?';
+    paramsList.push(params.start_time);
+  }
+  if (params.end_time) {
+    sql += ' AND timestamp <= ?';
+    paramsList.push(params.end_time);
+  }
+
+  const stmt = db.prepare(sql);
+  const args = paramsList.length ? paramsList : undefined;
+  const result = args ? stmt.get(...args) as { count: number } : stmt.get() as { count: number };
+
+  return result.count;
+}
+
+export function getTimeseriesData(
+  params: QueryParams,
+  user_id: string,
+  tenant_id: string
+): Record<string, number>[] {
+  const db = getDB();
+
+  const end_time = params.end_time || new Date().toISOString();
+  const start_time = params.start_time || new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString();
+  const group_by = params.group_by || 'hour';
+
+  let sql = 'SELECT ';
+  switch (group_by) {
+    case 'day':
+      sql += `DATE(timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ? AND timestamp >= ? AND timestamp <= ? GROUP BY period ORDER BY period ASC`;
+      const dayStmt = db.prepare(sql);
+      return dayStmt.all(tenant_id, params.name || '%', start_time, end_time) as Record<string, number>[];
+    case 'week':
+      sql += `strftime('%Y-W%W', timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ? AND timestamp >= ? AND timestamp <= ? GROUP BY period ORDER BY period ASC`;
+      const weekStmt = db.prepare(sql);
+      return weekStmt.all(tenant_id, params.name || '%', start_time, end_time) as Record<string, number>[];
+    default:
+      sql += `strftime('%H', timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ? AND name = ? AND timestamp >= ? AND timestamp <= ? GROUP BY period ORDER BY period ASC`;
+      const hourStmt = db.prepare(sql);
+      return hourStmt.all(tenant_id, params.name || '%', start_time, end_time) as Record<string, number>[];
+  }
+}
+
+export function getBreakdownData(
+  params: QueryParams,
+  user_id: string,
+  tenant_id: string
+): Record<string, number>[] {
+  const db = getDB();
+
+  const end_time = params.end_time || new Date().toISOString();
+  const start_time = params.start_time || new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString();
+  const group_by = params.property_name || 'name';
+
+  const sql = `
+    SELECT ${group_by} as label, COUNT(*) as count
+    FROM events
+    WHERE tenant_id = ? AND name = ? AND timestamp >= ? AND timestamp <= ?
+    GROUP BY ${group_by}
+    ORDER BY count DESC
+    LIMIT ?
+  `;
+
+  const limit = params.limit ? parseInt(params.limit as string) : 10;
+  const stmt = db.prepare(sql);
+  return stmt.all(tenant_id, params.name || '%', start_time, end_time, limit) as Record<string, number>[];
+}
