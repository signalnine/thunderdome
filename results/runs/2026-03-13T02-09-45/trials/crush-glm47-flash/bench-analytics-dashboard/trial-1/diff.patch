+import { v4 as uuidv4 } from 'uuid';
+import { getDB } from './database.js';
+import { Dashboard, CreateDashboard, Widget } from './types.js';
+
+export function createDashboard(params: CreateDashboard, user_id: string, tenant_id: string): Dashboard {
+  const db = getDB();
+  const id = uuidv4();
+  const config = JSON.stringify(params.config || {});
+
+  db.prepare(
+    'INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, datetime("now"), datetime("now"))'
+  ).run(id, tenant_id, params.name, user_id, config);
+
+  return {
+    id,
+    tenant_id,
+    name: params.name,
+    owner_id: user_id,
+    config,
+    created_at: new Date().toISOString(),
+    updated_at: new Date().toISOString(),
+  };
+}
+
+export function findDashboardById(id: string, user_id: string, tenant_id: string): Dashboard | null {
+  const db = getDB();
+  const dashboard = db
+    .prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?')
+    .get(id, tenant_id) as Dashboard | undefined;
+
+  if (!dashboard || dashboard.owner_id !== user_id) {
+    return null;
+  }
+
+  return dashboard;
+}
+
+export function findDashboardsByUser(user_id: string, tenant_id: string): Dashboard[] {
+  const db = getDB();
+  return db
+    .prepare('SELECT * FROM dashboards WHERE tenant_id = ? AND owner_id = ? ORDER BY created_at DESC')
+    .all(tenant_id, user_id) as Dashboard[];
+}
+
+export function updateDashboard(
+  id: string,
+  user_id: string,
+  tenant_id: string,
+  name?: string,
+  config?: Record<string, any>
+): Dashboard | null {
+  const dashboard = findDashboardById(id, user_id, tenant_id);
+  if (!dashboard) return null;
+
+  const db = getDB();
+  const updates: string[] = [];
+  const args: any[] = [];
+
+  if (name !== undefined) {
+    updates.push('name = ?');
+    args.push(name);
+  }
+  if (config !== undefined) {
+    updates.push('config = ?');
+    args.push(JSON.stringify(config));
+  }
+
+  if (updates.length === 0) return dashboard;
+
+  updates.push('updated_at = datetime("now")');
+  args.push(id);
+
+  db.prepare(`UPDATE dashboards SET ${updates.join(', ')} WHERE id = ?`).run(...args);
+
+  return findDashboardById(id, user_id, tenant_id);
+}
+
+export function deleteDashboard(id: string, user_id: string, tenant_id: string): boolean {
+  const db = getDB();
+  const result = db
+    .prepare('DELETE FROM dashboards WHERE id = ? AND tenant_id = ? AND owner_id = ?')
+    .run(id, tenant_id, user_id);
+
+  return result.changes > 0;
+}
+
+export function getDashboardWidgets(dashboard_id: string, user_id: string, tenant_id: string): Widget[] {
+  const db = getDB();
+  const widgets = db
+    .prepare('SELECT * FROM widgets WHERE dashboard_id = ?')
+    .all(dashboard_id) as Widget[];
+
+  const dashboard = findDashboardById(dashboard_id, user_id, tenant_id);
+  if (!dashboard) return [];
+
+  return widgets;
+}
+
+export function createWidget(widget: Omit<Widget, 'id'>, user_id: string, tenant_id: string): Widget {
+  const db = getDB();
+  const id = uuidv4();
+
+  db.prepare(
+    'INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)'
+  ).run(id, widget.dashboard_id, widget.type, JSON.stringify(widget.config), widget.position_x, widget.position_y, widget.width, widget.height);
+
+  return { ...widget, id };
+}
+
+export function updateWidget(id: string, user_id: string, tenant_id: string, type?: string, config?: any, position_x?: number, position_y?: number, width?: number, height?: number): Widget | null {
+  const db = getDB();
+  const dashboard = findDashboardById(id, user_id, tenant_id);
+  if (!dashboard) return null;
+
+  const existing = db.prepare('SELECT * FROM widgets WHERE id = ?').get(id) as Widget | undefined;
+  if (!existing) return null;
+
+  const updates: string[] = [];
+  const args: any[] = [];
+
+  if (type !== undefined) updates.push('type = ?'), args.push(type);
+  if (config !== undefined) updates.push('config = ?'), args.push(JSON.stringify(config));
+  if (position_x !== undefined) updates.push('position_x = ?'), args.push(position_x);
+  if (position_y !== undefined) updates.push('position_y = ?'), args.push(position_y);
+  if (width !== undefined) updates.push('width = ?'), args.push(width);
+  if (height !== undefined) updates.push('height = ?'), args.push(height);
+
+  if (updates.length === 0) return existing;
+
+  updates.push('updated_at = datetime("now")');
+  args.push(id);
+
+  db.prepare(`UPDATE widgets SET ${updates.join(', ')} WHERE id = ?`).run(...args);
+
+  return db.prepare('SELECT * FROM widgets WHERE id = ?').get(id) as Widget;
+}
+
+export function deleteWidget(id: string, user_id: string, tenant_id: string): boolean {
+  const db = getDB();
+  const dashboard = findDashboardById(id, user_id, tenant_id);
+  if (!dashboard) return false;
+
+  const result = db
+    .prepare('DELETE FROM widgets WHERE id = ? AND dashboard_id = ?')
+    .run(id, dashboard.id);
+
+  return result.changes > 0;
+}
