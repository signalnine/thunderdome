+  const { format = 'json' } = req.query;
+
+  const dashboards = findDashboardsByUser(req.user.user_id, req.user.tenant_id);
+
+  if (format === 'csv') {
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename=dashboards.csv');
+
+    let csv = 'id,tenant_id,name,owner_id,config,created_at,updated_at\n';
+    dashboards.forEach((dashboard: any) => {
+      csv += dashboard.id + ',';
+      csv += dashboard.tenant_id + ',';
+      csv += dashboard.name + ',';
+      csv += dashboard.owner_id + ',';
+      csv += dashboard.config + ',';
+      csv += dashboard.created_at + ',';
+      csv += dashboard.updated_at + '\n';
+    });
+
+    res.send(csv);
+  } else {
+    res.json(dashboards);
+  }
+});
+
