+
+  const params = {
+    name: name as string,
+    start_time: start_time as string,
+    end_time: end_time as string,
+  };
+
+  const events = findEventsByTenant(params);
+
+  if (format === 'csv') {
+    res.setHeader('Content-Type', 'text/csv');
+    res.setHeader('Content-Disposition', 'attachment; filename=events.csv');
+
+    let csv = 'id,tenant_id,name,properties,timestamp,user_id,session_id\n';
+    events.forEach((event: any) => {
+      csv += event.id + ',';
+      csv += event.tenant_id + ',';
+      csv += event.name + ',';
+      csv += event.properties + ',';
+      csv += event.timestamp + ',';
+      csv += (event.user_id || '') + ',';
+      csv += (event.session_id || '') + '\n';
+    });
+
+    res.send(csv);
+  } else {
+    res.json(events);
+  }
+});
+
+router.get('/count', authenticate, (req: any, res) => {
+  const { name, start_time, end_time } = req.query;
+
+  const params = {
+    name: name as string,
+    start_time: start_time as string,
+    end_time: end_time as string,
+  };
+
+  const count = countEvents(params);
+
+  res.json({ count });
+});
