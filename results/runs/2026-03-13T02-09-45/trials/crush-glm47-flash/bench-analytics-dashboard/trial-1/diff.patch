+import { Router } from 'express';
+import { authenticate, isTenantAdmin } from '../auth.js';
+import { getTimeseriesData, getBreakdownData } from '../event.js';
+
+const router = Router();
+
+router.get('/timeseries', authenticate, (req: any, res) => {
+  const { name, start_time, end_time, group_by = 'hour', limit = 10 } = req.query;
+
+  try {
+    const data = getTimeseriesData(
+      {
+        name: name ? name.join(',') : '%',
+        start_time,
+        end_time,
+      },
+      req.user.user_id,
+      req.user.tenant_id
+    );
+
+    const parsedData = data.map((item) => {
+      if (typeof item.period === 'string') {
+        return {
+          ...item,
+          period: item.period === '%' ? null : item.period,
+        };
+      }
+      return item;
+    });
+
+    res.json(parsedData);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message || 'Invalid query parameters' });
+  }
+});
+
+router.get('/breakdown', authenticate, (req: any, res) => {
+  const { name, start_time, end_time, property_name, limit = 10 } = req.query;
+
+  try {
+    const data = getBreakdownData(
+      {
+        name,
+        start_time,
+        end_time,
+        property_name,
+        limit,
+      },
+      req.user.user_id,
+      req.user.tenant_id
+    );
+
+    res.json(data);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message || 'Invalid query parameters' });
+  }
+});
+
+router.get('/breakdown/:dashboardId', authenticate, (req: any, res) => {
+  const dashboardId = req.params.dashboardId;
+  const { name, start_time, end_time, property_name, limit = 10 } = req.query;
+
+  try {
+    const data = getBreakdownData(
+      {
+        name,
+        start_time,
+        end_time,
+        property_name,
+        limit,
+      },
+      req.user.user_id,
+      req.user.tenant_id
+    );
+
+    res.json(data);
+  } catch (error: any) {
+    res.status(400).json({ error: error.message || 'Invalid query parameters' });
