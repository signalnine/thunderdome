+import { Router } from 'express';
+import { authenticate } from '../auth.js';
+import {
+  createUser,
+  findUserByEmail,
+  findUserById,
+  findUsersByTenant,
+  updateUserRole,
+  deleteUser,
+  getProfile,
+  verifyUserPassword,
+} from '../user.js';
+import { signToken, verifyToken } from '../auth.js';
+
+const router = Router();
+
+router.post('/register', (req: any, res) => {
+  const { email, password, tenant_id, role = 'viewer' } = req.body;
+
+  if (!email || !password || !tenant_id) {
+    return res.status(400).json({ error: 'Email, password, and tenant_id are required' });
+  }
+
+  const existingUser = findUserByEmail(email);
+  if (existingUser) {
+    return res.status(409).json({ error: 'Email already registered' });
+  }
+
+  const user = createUser({ email, password, tenant_id, role });
+
+  const token = signToken({ user_id: user.id, tenant_id: user.tenant_id, role: user.role });
+
+  res.status(201).json({
+    user: {
+      id: user.id,
+      email: user.email,
+      role: user.role,
+    },
+    token,
+  });
+});
+
+router.post('/login', (req: any, res) => {
+  const { email, password, tenant_id } = req.body;
+
+  if (!email || !password || !tenant_id) {
+    return res.status(400).json({ error: 'Email, password, and tenant_id are required' });
+  }
+
+  const user = findUserByEmail(email);
+  if (!user || user.tenant_id !== tenant_id) {
+    return res.status(401).json({ error: 'Invalid credentials' });
+  }
+
+  if (!verifyUserPassword(user, password)) {
+    return res.status(401).json({ error: 'Invalid credentials' });
+  }
+
+  const token = signToken({ user_id: user.id, tenant_id: user.tenant_id, role: user.role });
+
+  res.json({
+    user: {
+      id: user.id,
+      email: user.email,
+      role: user.role,
+    },
+    token,
+  });
+});
+
+router.get('/profile', authenticate, (req: any, res) => {
+  const { user_id, tenant_id } = req.user as any;
+
+  if (tenant_id !== req.query.tenant_id) {
+    return res.status(403).json({ error: 'Tenant ID mismatch' });
+  }
+
+  const profile = getProfile(user_id, tenant_id);
+
+  res.json({
+    id: profile.id,
+    email: profile.email,
+    role: profile.role,
+    created_at: profile.created_at,
+  });
+});
+
+router.get('/', authenticate, (req: any, res) => {
+  const { tenant_id } = req.query;
+
+  const users = findUsersByTenant(tenant_id as string);
+
+  res.json(users);
+});
+
+router.patch('/:id/role', authenticate, async (req: any, res) => {
+  const { id } = req.params;
+  const { role, tenant_id: target_tenant_id } = req.body;
+
+  const { tenant_id: actor_tenant_id, role: actor_role } = req.user as any;
+
+  if (actor_role !== 'admin') {
+    return res.status(403).json({ error: 'Only admins can change user roles' });
+  }
+
+  const user = findUserById(id);
+  if (!user || user.tenant_id !== actor_tenant_id) {
+    return res.status(404).json({ error: 'User not found' });
+  }
+
+  if (user.tenant_id !== target_tenant_id) {
+    return res.status(403).json({ error: 'Cannot modify users from another tenant' });
+  }
+
+  if (!['admin', 'editor', 'viewer'].includes(role)) {
+    return res.status(400).json({ error: 'Invalid role' });
+  }
+
+  const success = updateUserRole(id, actor_tenant_id, role);
+
+  if (success) {
+    res.json({ message: 'Role updated successfully' });
+  } else {
+    res.status(500).json({ error: 'Failed to update role' });
+  }
+});
+
+router.delete('/:id', authenticate, async (req: any, res) => {
+  const { id } = req.params;
+  const { tenant_id: target_tenant_id } = req.body;
+
+  const { tenant_id: actor_tenant_id, role: actor_role } = req.user as any;
+
+  if (actor_role !== 'admin') {
+    return res.status(403).json({ error: 'Only admins can delete users' });
+  }
+
+  const user = findUserById(id);
+  if (!user || user.tenant_id !== actor_tenant_id) {
+    return res.status(404).json({ error: 'User not found' });
+  }
+
+  if (user.tenant_id !== target_tenant_id) {
+    return res.status(403).json({ error: 'Cannot delete users from another tenant' });
+  }
+
+  if (user.id === actor_tenant_id) {
+    return res.status(400).json({ error: 'Cannot delete your own account' });
+  }
+
+  const success = deleteUser(id, actor_tenant_id);
+
+  if (success) {
+    res.json({ message: 'User deleted successfully' });
+  } else {
+    res.status(500).json({ error: 'Failed to delete user' });
+  }
+});
+
+export default router;
