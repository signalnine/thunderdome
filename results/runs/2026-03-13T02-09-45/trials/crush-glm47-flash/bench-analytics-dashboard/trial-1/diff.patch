+import express, { type Express } from 'express';
+import cors from 'cors';
+
+import { initializeDB } from './database.js';
+import userRoutes from './routes/users.js';
+import eventRoutes from './routes/events.js';
+import dashboardRoutes from './routes/dashboards.js';
+import exportRoutes from './routes/exports.js';
+import queryRoutes from './routes/queries.js';
+
+export function createApp(): Express {
+  const app = express();
+
+  app.use(cors());
+  app.use(express.json());
+
+  app.use('/api/auth', userRoutes);
+  app.use('/api/events', eventRoutes);
+  app.use('/api/dashboards', dashboardRoutes);
+  app.use('/api/exports', exportRoutes);
+  app.use('/api/queries', queryRoutes);
+
+  app.get('/api/health', (req, res) => {
+    res.json({ status: 'ok' });
+  });
+
+  app.get('/', (req, res) => {
+    res.json({
+      name: 'Multi-tenant Analytics Dashboard API',
+      version: '1.0.0',
+      endpoints: {
+        auth: {
+          register: 'POST /api/auth/register',
+          login: 'POST /api/auth/login',
+          profile: 'GET /api/auth/profile',
+          users: 'GET /api/auth/users',
+          updateUserRole: 'PATCH /api/auth/:id/role',
+          deleteUser: 'DELETE /api/auth/:id',
+        },
+        events: {
+          create: 'POST /api/events',
+          batch: 'POST /api/events/batch',
+          getByID: 'GET /api/events/:id',
+          list: 'GET /api/events',
+          count: 'GET /api/events/count',
+        },
+        dashboards: {
+          create: 'POST /api/dashboards',
+          list: 'GET /api/dashboards',
+          get: 'GET /api/dashboards/:id',
+          update: 'PATCH /api/dashboards/:id',
+          delete: 'DELETE /api/dashboards/:id',
+          widgets: 'GET /api/dashboards/:id/widgets',
+          addWidget: 'POST /api/dashboards/:id/widgets',
+          updateWidget: 'PATCH /api/dashboards/widgets/:widgetId',
+          deleteWidget: 'DELETE /api/dashboards/widgets/:widgetId',
+        },
+        exports: {
+          events: {
+            json: 'GET /api/exports/events?format=json',
+            csv: 'GET /api/exports/events?format=csv',
+          },
+          count: 'GET /api/exports/count',
+          dashboards: {
+            json: 'GET /api/exports/dashboards?format=json',
+            csv: 'GET /api/exports/dashboards?format=csv',
+          },
+        },
+        queries: {
+          timeseries: 'GET /api/queries/timeseries',
+          breakdown: 'GET /api/queries/breakdown',
+          breakdownByDashboard: 'GET /api/queries/breakdown/:dashboardId',
+        },
+      },
+    });
+  });
+
+  return app;
+}
+
+export default createApp;
