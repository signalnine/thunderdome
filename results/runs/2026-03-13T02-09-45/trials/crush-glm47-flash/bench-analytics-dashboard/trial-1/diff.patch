+import { Router } from 'express';
+import { authenticate, isTenantAdmin } from '../auth.js';
+import {
+  createDashboard,
+  findDashboardById,
+  findDashboardsByUser,
+  updateDashboard,
+  deleteDashboard,
+  getDashboardWidgets,
+  createWidget,
+  updateWidget,
+  deleteWidget,
+} from '../dashboard.js';
+
+const router = Router();
+
+router.post('/', authenticate, (req: any, res) => {
+  const { name = 'New Dashboard', config = {} } = req.body;
+
+  if (!name) {
+    return res.status(400).json({ error: 'Dashboard name is required' });
+  }
+
+  const dashboard = createDashboard({ name, config }, req.user.user_id, req.user.tenant_id);
+
+  res.status(201).json(dashboard);
+});
+
+router.get('/', authenticate, (req: any, res) => {
+  const dashboards = findDashboardsByUser(req.user.user_id, req.user.tenant_id);
+
+  res.json(dashboards);
+});
+
+router.get('/:id', authenticate, (req: any, res) => {
+  const { id } = req.params;
+
+  const dashboard = findDashboardById(id, req.user.user_id, req.user.tenant_id);
+
+  if (!dashboard) {
+    return res.status(404).json({ error: 'Dashboard not found or access denied' });
+  }
+
+  res.json(dashboard);
+});
+
+router.patch('/:id', authenticate, (req: any, res) => {
+  const { id } = req.params;
+  const { name, config } = req.body;
+
+  const dashboard = updateDashboard(id, req.user.user_id, req.user.tenant_id, name, config);
+
+  if (!dashboard) {
+    return res.status(404).json({ error: 'Dashboard not found or access denied' });
+  }
+
+  res.json(dashboard);
+});
+
+router.delete('/:id', authenticate, (req: any, res) => {
+  const { id } = req.params;
+
+  const success = deleteDashboard(id, req.user.user_id, req.user.tenant_id);
+
+  if (success) {
+    res.json({ message: 'Dashboard deleted successfully' });
+  } else {
+    res.status(404).json({ error: 'Dashboard not found or access denied' });
+  }
+});
+
+router.get('/:id/widgets', authenticate, (req: any, res) => {
+  const { id } = req.params;
+
+  const dashboard = findDashboardById(id, req.user.user_id, req.user.tenant_id);
+
+  if (!dashboard) {
+    return res.status(404).json({ error: 'Dashboard not found or access denied' });
+  }
+
+  const widgets = getDashboardWidgets(id, req.user.user_id, req.user.tenant_id);
+
+  res.json(widgets);
+});
+
+router.post('/:id/widgets', authenticate, isTenantAdmin as any, (req: any, res) => {
+  const { id } = req.params;
+  const { type, config = {}, position_x = 0, position_y = 0, width = 1, height = 1 } = req.body;
+
+  const dashboard = findDashboardById(id, req.user.user_id, req.user.tenant_id);
+  if (!dashboard) {
+    return res.status(404).json({ error: 'Dashboard not found or access denied' });
+  }
+
+  const widget = createWidget(
+    { dashboard_id: id, type, config: config || {}, position_x, position_y, width, height },
+    req.user.user_id,
+    req.user.tenant_id
+  );
+
+  res.status(201).json(widget);
+});
+
+router.patch('/widgets/:widgetId', authenticate, isTenantAdmin as any, (req: any, res) => {
+  const { widgetId } = req.params;
+  const { type, config, position_x, position_y, width, height } = req.body;
+
+  const widget = updateWidget(
+    widgetId,
+    req.user.user_id,
+    req.user.tenant_id,
+    (type !== undefined ? { type } : {}) as any
+  );
+  if (type !== undefined) {
+    (widget as any).type = type;
+  }
+  if (config !== undefined) {
+    (widget as any).config = config;
+  }
+  if (position_x !== undefined) {
+    (widget as any).position_x = position_x;
+  }
+  if (position_y !== undefined) {
+    (widget as any).position_y = position_y;
+  }
+  if (width !== undefined) {
+    (widget as any).width = width;
+  }
+  if (height !== undefined) {
+    (widget as any).height = height;
+  }
+
+  if (!widget) {
+    return res.status(404).json({ error: 'Widget not found or access denied' });
+  }
+
+  res.json(widget);
+});
+
+router.delete('/widgets/:widgetId', authenticate, isTenantAdmin as any, (req: any, res) => {
+  const { widgetId } = req.params;
+
+  const success = deleteWidget(widgetId, req.user.user_id, req.user.tenant_id);
+
+  if (success) {
+    res.json({ message: 'Widget deleted successfully' });
+  } else {
+    res.status(404).json({ error: 'Widget not found or access denied' });
+  }
+});
+
+export default router;
