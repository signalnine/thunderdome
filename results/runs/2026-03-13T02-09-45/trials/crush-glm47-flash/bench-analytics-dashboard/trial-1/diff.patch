+import { Router } from 'express';
+import { authenticate, isTenantAdmin } from '../auth.js';
+import { createEvent, createEvents, getEventById, findEventsByTenant, countEvents } from '../event.js';
+
+const router = Router();
+
+router.post('/', authenticate, (req: any, res) => {
+  const { name, properties = {}, timestamp, session_id } = req.body;
+
+  if (!name) {
+    return res.status(400).json({ error: 'Event name is required' });
+  }
+
+  const event = createEvent({ name, properties, timestamp, session_id }, req.user.user_id, req.user.session_id);
+
+  res.status(201).json(event);
+});
+
+router.post('/batch', authenticate, (req: any, res) => {
+  const { events } = req.body;
+
+  if (!events || !Array.isArray(events) || events.length === 0) {
+    return res.status(400).json({ error: 'Events array is required' });
+  }
+
+  const createdEvents = createEvents(
+    events.map((e: any) => ({ name: e.name, properties: e.properties, timestamp: e.timestamp, session_id: req.user.session_id })),
+    req.user.user_id,
+    req.user.session_id
+  );
+
+  res.status(201).json(createdEvents);
+});
+
+router.get('/:id', authenticate, (req: any, res) => {
+  const { id } = req.params;
+
+  const event = getEventById(id);
+
+  if (!event || event.tenant_id !== req.user.tenant_id) {
+    return res.status(404).json({ error: 'Event not found or access denied' });
+  }
+
+  res.json(event);
+});
+
+router.get('/', authenticate, (req: any, res) => {
+  const { name, start_time, end_time, limit } = req.query;
+
+  const params = {
+    name: name as string,
+    start_time: start_time as string,
+    end_time: end_time as string,
+    limit: limit ? parseInt(limit as string) : undefined,
+  };
+
+  const events = findEventsByTenant(params);
+
+  res.json(events);
+});
+
+router.get('/count', authenticate, (req: any, res) => {
+  const { name, start_time, end_time } = req.query;
+
+  const params = {
+    name: name as string,
+    start_time: start_time as string,
+    end_time: end_time as string,
+  };
+
+  const count = countEvents(params);
+
+  res.json({ count });
+});
+
+export default router;
