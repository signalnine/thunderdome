& candidateStart + duration <= options.endTime)) {\n   298→        if (candidateStart + duration <= options.endTime) {\n   299→          return candidateStart;\n   300→        }\n   301→      }\n   302→    }\n   303→\n   304→    return null;\n   305→  }\n   306→\n   307→  function placeEvent(\n   308→    roomId: string,\n   309→    eventId: string,\n   310→    startTime: number,\n   311→    duration: number,\n   312→    state: State\n   313→  ): void {\n   314→    if (!state.has(roomId)) {\n   315→      state.set(roomId, []);\n   316→    }\n   317→    state.get(roomId)!.push({\n   318→      eventId,\n   319→      roomId,\n   320→      startTime,\n   321→      endTime: startTime + duration,\n   322→    });\n   323→  }\n   324→\n   325→  // Use a greedy approach with smart ordering, then try to improve with retries\n   326→  function greedySchedule(eventOrder: string[]): { assignments: Map<string, Assignment>; unscheduled: string[] } {\n   327→    const state: State = new Map();\n   328→    for (const r of rooms) {\n   329→      state.set(r.id, []);\n   330→    }\n   331→    const assignments = new Map<string, Assignment>();\n   332→    const unscheduled: string[] = [];\n   333→\n   334→    for (const eventId of eventOrder) {\n   335→      const event = eventMap.get(eventId)!;\n   336→      const attendees = event.attendees ?? 1;\n   337→      const earliestStart = getEarliestStart(eventId, assignments);\n   338→\n   339→      if (earliestStart === -1) {\n   340→        // Prerequisite not scheduled\n   341→        unscheduled.push(eventId);\n   342→        continue;\n   343→      }\n   344→\n   345→      // Order rooms: preferred first, then by capacity (smallest fitting room first)\n   346→      const validRooms = rooms\n   347→        .filter(r => r.capacity >= attendees)\n   348→        .sort((a, b) => {\n   349→          // Preferred room first\n   350→          if (event.preferredRoom) {\n   351→            if (a.id === event.preferredRoom && b.id !== event.pref