r>();\n  for (const e of events) {\n    color.set(e.id, WHITE);\n  }\n\n  const order: string[] = [];\n\n  function dfs(id: string, path: string[]): void {\n    color.set(id, GRAY);\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const prereq of event.prerequisites) {\n        const prereqColor = color.get(prereq);\n        if (prereqColor === GRAY) {\n          throw new Error(`Cycle detected in prerequisites: ${[...path, id, prereq].join(' -> ')}`);\n        }\n        if (prereqColor === WHITE) {\n          dfs(prereq, [...path, id]);\n        }\n      }\n    }\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id, []);\n    }\n  }\n\n  return order;\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  const gap = options.gap ?? 15;\n\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  // Step 1: Detect cycles and get topological order\n  const topoOrder = detectCyclesAndTopologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Step 2: Compute constraint tightness\n  const validRoomsForEvent = new Map<string, Room[]>();\n  for (const e of events) {\n    const attendees = e.attendees ?? 1;\n    validRoomsForEvent.set(e.id, rooms.filter(r => r.capacity >= attendees));\n  }\n\n  const topoRank = new Map<string, number>();\n  for (let i = 0; i < topoOrder.length; i++) {\n    topoRank.set(topoOrder[i], i);\n  }\n\n  // Compute topo levels (longest path from roots)\n  const topoLevel = new Map<string, number>();\n  function computeLevel(id: string): number {\n    if (topoLevel.has(id)) return topoLevel.get(id)!;\n    const event = eventMap.get(id)!;\n    let maxPrereqLevel = -1;\n    if (event.prerequisites) {\n      for (const prereq of event.prerequisites) {\n        if (eventMap.has(prereq)) {\n          maxPrereqLevel = Math.max(maxPrereqLevel, computeLevel(prereq));\n        }\n      }\n    }\n    const level = maxPrereqLevel + 1;\n    topoLevel.set(id, level);\n    return level;\n  }\n  for (const e of events) {\n    computeLevel(e.id);\n  }\n\n  // Step 3: Build sorted event orderings\n  type RoomSchedule = Assignment[];\n  type State = Map<string, RoomSchedule>;\n\n  function getEarliestStart(eventId: string, assignments: Map<string, Assignment>): number {\n    const event = eventMap.get(eventId)!;\n    let earliest = options.startTime;\n    if (event.prerequisites) {\n      for (const prereq of event.prerequisites) {\n        const prereqAssignment = assignments.get(prereq);\n        if (prereqAssignment) {\n          earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n        } else if (eventMap.has(prereq)) {\n          return -1; // Prerequisite exists but not scheduled\n        }\n      }\n    }\n    return earliest;\n  }\n\n  function findEarliestSlot(\n    roomId: string,\n    duration: number,\n    state: State,\n    earliestStart: number\n  ): number | null {\n    const roomSched = state.get(roomId) || [];\n\n    if (roomSched.length === 0) {\n      if (earliestStart + duration <= options.endTime) {\n        return earliestStart;\n      }\n      return null;\n    }\n\n    const sorted = [...roomSched].sort((a, b) => a.startTime - b.startTime);\n\n    // Try before first event\n    if (earliestStart + duration + gap <= sorted[0].startTime) {\n      if (earliestStart + duration <= options.endTime) {\n        return earliestStart;\n      }\n    }\n\n    // Try between/after events\n    for (let i = 0; i < sorted.length; i++) {\n      const gapStart = sorted[i].endTime + gap;\n      const candidateStart = Math.max(earliestStart, gapStart);\n      if (i < sorted.length - 1) {\n        // Between two events: need gap before next event\n        if (candidateStart + duration + gap <= sorted[i + 1].startTime && candidateStart + duration <= options.endTime) {\n          return candidateStart;\n        }\n      } else {\n        // After last event\n        if (candidateStart + duration <= options.endTime) {\n          return candidateStart;\n        }\n      }\n    }\n\n    return null;\n  }\n\n  function greedySchedule(eventOrder: string[]): { assignments: Map<string, Assignment>; unscheduled: string[] } {\n    const state: State = new Map();\n    for (const r of rooms) {\n      state.set(r.id, []);\n    }\n    const assignments = new Map<string, Assignment>();\n    const unscheduled: string[] = [];\n\n    for (const eventId of eventOrder) {\n      const event = eventMap.get(eventId)!;\n      const attendees = event.attendees ?? 1;\n      const earliestStart = getEarliestStart(eventId, assignments);\n\n      if (earliestStart === -1) {\n        unscheduled.push(eventId);\n        continue;\n      }\n\n      // Order rooms: preferred first, then smallest fitting room\n      const validRooms = rooms\n        .filter(r => r.capacity >= attendees)\n        .sort((a, b) => {\n          if (event.preferredRoom) {\n            if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n            if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n          }\n          return a.capacity - b.capacity;\n        });\n\n      let bestSlot: { roomId: string; startTime: number } | null = null;\n\n      for (const room of validRooms) {\n        const slotStart = findEarliestSlot(room.id, event.duration, state, earliestStart);\n        if (slotStart !== null) {\n          if (!bestSlot) {\n            bestSlot = { roomId: room.id, startTime: slotStart };\n            if (event.preferredRoom === room.id) break;\n          } else if (event.preferredRoom === room.id) {\n            bestSlot = { roomId: room.id, startTime: slotStart };\n            break;\n          }\n        }\n      }\n\n      if (bestSlot) {\n        const assignment: Assignment = {\n          eventId,\n          roomId: bestSlot.roomId,\n          startTime: bestSlot.startTime,\n          endTime: bestSlot.startTime + event.duration,\n        };\n        state.get(bestSlot.roomId)!.push(assignment);\n        assignments.set(eventId, assignment);\n      } else {\n        unscheduled.push(eventId);\n      }\n    }\n\n    return { assignments, unscheduled };\n  }\n\n  // Backtracking scheduler for small inputs\n  function backtrackingSchedule(eventOrder: string[]): { assignments: Map<string, Assignment>; unscheduled: string[] } {\n    let bestAssignments = new Map<string, Assignment>();\n    let bestUnscheduledCount = eventOrder.length;\n\n    function bt(\n      idx: number,\n      state: State,\n      assignments: Map<string, Assignment>,\n      scheduledCount: number,\n      skippedCount: number\n    ): void {\n      if (idx === eventOrder.length) {\n        const unscheduledCount = eventOrder.length - scheduledCount;\n        if (unscheduledCount < bestUnscheduledCount) {\n          bestUnscheduledCount = unscheduledCount;\n          bestAssignments = new Map(assignments);\n        }\n        return;\n      }\n\n      // Pruning: can't beat best even if all remaining are scheduled\n      if (skippedCount >= bestUnscheduledCount) {\n        return;\n      }\n\n      const eventId = eventOrder[idx];\n      const event = eventMap.get(eventId)!;\n      const attendees = event.attendees ?? 1;\n      const earliestStart = getEarliestStart(eventId, assignments);\n\n      if (earliestStart === -1) {\n        bt(idx + 1, state, assignments, scheduledCount, skippedCount + 1);\n        return;\n      }\n\n      const orderedRooms = rooms\n        .filter(r => r.capacity >= attendees)\n        .sort((a, b) => {\n          if (event.preferredRoom) {\n            if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n            if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n          }\n          return a.capacity - b.capacity;\n        });\n\n      for (const room of orderedRooms) {\n        const slotStart = findEarliestSlot(room.id, event.duration, state, earliestStart);\n        if (slotStart !== null) {\n          const assignment: Assignment = {\n            eventId,\n            roomId: room.id,\n            startTime: slotStart,\n            endTime: slotStart + event.duration,\n          };\n          const roomSched = state.get(room.id)!;\n          roomSched.push(assignment);\n          assignments.set(eventId, assignment);\n\n          bt(idx + 1, state, assignments, scheduledCount + 1, skippedCount);\n\n          // Undo\n          roomSched.pop();\n          assignments.delete(eventId);\n\n          if (bestUnscheduledCount === 0) return;\n        }\n      }\n\n      // Also try skipping this event\n      bt(idx + 1, state, assignments, scheduledCount, skippedCount + 1);\n    }\n\n    const initialState: State = new Map();\n    for (const r of rooms) {\n      initialState.set(r.id, []);\n    }\n\n    bt(0, initialState, new Map(), 0, 0);\n\n    const unscheduled = eventOrder.filter(id => !bestAssignments.has(id));\n    return { assignments: bestAssignments, unscheduled };\n  }\n\n  // Sort: topo level first, then constraint tightness\n  const sortedEventIds = events.map(e => e.id).sort((a, b) => {\n    const levelA = topoLevel.get(a)!;\n    const levelB = topoLevel.get(b)!;\n    if (levelA !== levelB) return levelA - levelB;\n\n    const validA = validRoomsForEvent.get(a)!.length;\n    const validB = validRoomsForEvent.get(b)!.length;\n    if (validA !== validB) return validA - validB;\n\n    const durA = eventMap.get(a)!.duration;\n    const durB = eventMap.get(b)!.duration;\n    if (durA !== durB) return durB - durA;\n\n    return topoRank.get(a)! - topoRank.get(b)!;\n  });\n\n  // Try multiple orderings and pick the best\n  let bestResult = greedySchedule(sortedEventIds);\n\n  // Reverse constraint ordering within each level\n  const reversedWithinLevels = events.map(e => e.id).sort((a, b) => {\n    const levelA = topoLevel.get(a)!;\n    const levelB = topoLevel.get(b)!;\n    if (levelA !== levelB) return levelA - levelB;\n    const validA = validRoomsForEvent.get(a)!.length;\n    const validB = validRoomsForEvent.get(b)!.length;\n    if (validA !== validB) return validB - validA;\n    return topoRank.get(a)! - topoRank.get(b)!;\n  });\n\n  const result2 = greedySchedule(reversedWithinLevels);\n  if (result2.unscheduled.length < bestResult.unscheduled.length) {\n    bestResult = result2;\n  }\n\n  // Shortest-duration-first\n  const shortestFirst = events.map(e => e.id).sort((a, b) => {\n    const levelA = topoLevel.get(a)!;\n    const levelB = topoLevel.get(b)!;\n    if (levelA !== levelB) return levelA - levelB;\n    return eventMap.get(a)!.duration - eventMap.get(b)!.duration;\n  });\n\n  const result3 = greedySchedule(shortestFirst);\n  if (result3.unscheduled.length < bestResult.unscheduled.length) {\n    bestResult = result3;\n  }\n\n  // Longest-duration-first\n  const longestFirst = events.map(e => e.id).sort((a, b) => {\n    const levelA = topoLevel.get(a)!;\n    const levelB = topoLevel.get(b)!;\n    if (levelA !== levelB) return levelA - levelB;\n    return eventMap.get(b)!.duration - eventMap.get(a)!.duration;\n  });\n\n  const result4 = greedySchedule(longestFirst);\n  if (result4.unscheduled.length < bestResult.unscheduled.length) {\n    bestResult = result4;\n  }\n\n  // For manageable inputs, use backtracking for optimal solution\n  if (bestResult.unscheduled.length > 0 && events.length <= 20) {\n    const btResult = backtrackingSchedule(sortedEventIds);\n    if (btResult.unscheduled.length < bestResult.unscheduled.length) {\n      bestResult = btResult;\n    }\n  }\n\n  return {\n    assignments: Array.from(bestResult.assignments.values()),\n    unscheduled: bestResult.unscheduled,\n  };\n}\n","structuredPatch":[{"oldStart":420,"oldLines":3,"newStart":420,"newLines":5,"lines":["     unsched