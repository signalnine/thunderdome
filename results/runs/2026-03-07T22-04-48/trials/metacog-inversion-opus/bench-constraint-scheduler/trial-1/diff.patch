t afterLast = sorted[sorted.length - 1].endTime + gap;\n    const candidateStart = Math.max(earliestStart, afterLast);\n    if (candidateStart + duration <= options.endTime) {\n      slots.push(candidateStart);\n    }\n\n    return slots;\n  }\n\n  // Better approach: find the earliest valid start time in a room\n  function findEarliestSlot(\n    roomId: string,\n    duration: number,\n    state: State,\n    earliestStart: number\n  ): number | null {\n    const roomSched = state.get(roomId) || [];\n\n    if (roomSched.length === 0) {\n      if (earliestStart + duration <= options.endTime) {\n        return earliestStart;\n      }\n      return null;\n    }\n\n    const sorted = [...roomSched].sort((a, b) => a.startTime - b.startTime);\n\n    // Try before first event\n    if (earliestStart + duration + gap <= sorted[0].startTime) {\n      if (earliestStart + duration <= options.endTime) {\n        return earliestStart;\n      }\n    }\n\n    // Try between events\n    for (let i = 0; i < sorted.length; i++) {\n      const gapStart = sorted[i].endTime + gap;\n      const candidateStart = Math.max(earliestStart, gapStart);\n      const nextStart = i < sorted.length - 1 ? sorted[i + 1].startTime : options.endTime + gap;\n      if (candidateStart + duration + gap <= nextStart || (i === sorted.length - 1 && candidateStart + duration <= options.endTime)) {\n        if (candidateStart + duration <= options.endTime) {\n          return candidateStart;\n        }\n      }\n    }\n\n    return null;\n  }\n\n  function placeEvent(\n    roomId: string,\n    eventId: string,\n    startTime: number,\n    duration: number,\n    state: State\n  ): void {\n    if (!state.has(roomId)) {\n      state.set(roomId, []);\n    }\n    state.get(roomId)!.push({\n      eventId,\n      roomId,\n      startTime,\n      endTime: startTime + duration,\n    });\n  }\n\n  // Use a greedy approach with smart ordering, then try to improve with retries\n  function greedySchedule(eventOrder: string[])