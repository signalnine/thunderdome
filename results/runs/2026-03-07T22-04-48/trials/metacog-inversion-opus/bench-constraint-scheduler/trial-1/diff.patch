 + duration + gap <= nextStart || (i === sorted.length - 1 && candidateStart + duration <= options.endTime)) {\n        if (candidateStart + duration <= options.endTime) {\n          return candidateStart;\n        }\n      }\n    }\n\n    return null;\n  }\n\n  function placeEvent(\n    roomId: string,\n    eventId: string,\n    startTime: number,\n    duration: number,\n    state: State\n  ): void {\n    if (!state.has(roomId)) {\n      state.set(roomId, []);\n    }\n    state.get(roomId)!.push({\n      eventId,\n      roomId,\n      startTime,\n      endTime: startTime + duration,\n    });\n  }\n\n  // Use a greedy approach with smart ordering, then try to improve with retries\n  function greedySchedule(eventOrder: string[]): { assignments: Map<string, Assignment>; unscheduled: string[] } {\n    const state: State = new Map();\n    for (const r of rooms) {\n      state.set(r.id, []);\n    }\n    const assignments = new Map<string, Assignment>();\n    const unscheduled: string[] = [];\n\n    for (const eventId of eventOrder) {\n      const event = eventMap.get(eventId)!;\n      const attendees = event.attendees ?? 1;\n      const earliestStart = getEarliestStart(eventId, assignments);\n\n      if (earliestStart === -1) {\n        // Prerequisite not scheduled\n        unscheduled.push(eventId);\n        continue;\n      }\n\n      // Order rooms: preferred first, then by capacity (smallest fitting room first)\n      const validRooms = rooms\n        .filter(r => r.capacity >= attendees)\n        .sort((a, b) => {\n          // Preferred room first\n          if (event.preferredRoom) {\n            if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;\n            if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;\n          }\n          // Smallest fitting room first (save larger rooms for larger events)\n          return a.capacity - b.capacity;\n        });\n\n      let placed = false;\n      let bestSlot: { roomId