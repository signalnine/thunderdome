@@ -0,0 +1,67 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: (ctx: BuildContext): void => {
+        // Build tag index from files
+        const tagMap = new Map<string, ContentFile[]>();
+
+        for (const file of ctx.files) {
+          if (file.tags && file.tags.length > 0) {
+            for (const tag of file.tags) {
+              const normalizedTag = tag.toLowerCase();
+              if (!tagMap.has(normalizedTag)) {
+                tagMap.set(normalizedTag, []);
+              }
+              const files = tagMap.get(normalizedTag)!;
+              if (!files.includes(file)) {
+                files.push(file);
+              }
+            }
+          }
+        }
+
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+      afterBuild: (ctx: BuildContext): void => {
+        // Generate tag listing pages
+        const tagMap = ctx.data.get('taxonomy-tags') as
+          | Map<string, ContentFile[]>
+          | undefined;
+
+        if (!tagMap || tagMap.size === 0) {
+          return;
+        }
+
+        for (const [tag, files] of tagMap) {
+          const fileListHtml = files
+            .map(
+              (f) =>
+                `<article><h2><a href="/${f.slug}.html">${f.title}</a></h2></article>`
+            )
+            .join('\n');
+
+          const tagPageHtml = `<!DOCTYPE html>
+<html>
+<head>
+  <meta charset="utf-8">
+  <title>Tag: ${tag} | ${ctx.config.title}</title>
+</head>
+<body>
+  <h1>Tag: ${tag}</h1>
+  <div class="tag-listing">
+    ${fileListHtml}
+  </div>
+</body>
+</html>`;
+
+          ctx.output.set(`tags/${tag}.html`, tagPageHtml);
+        }
+      },
+    },
+  };
+}
