+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+        let content = file.content;
+        const assets: string[] = [];
+
+        // Extract existing assets from manifest if any
+        const existingManifest = ctx.data.get('asset-manifest') as
+          | { assets: string[] }
+          | undefined;
+        if (existingManifest) {
+          assets.push(...existingManifest.assets);
+        }
+
+        // Find and rewrite image src attributes
+        const imgRegex = /<img[^>]+src="([^"]+)"/g;
+        let match;
+        while ((match = imgRegex.exec(file.content)) !== null) {
+          const originalUrl = match[1];
+          if (originalUrl.startsWith('./')) {
+            const assetName = originalUrl.slice(2);
+            if (!assets.includes(assetName)) {
+              assets.push(assetName);
+            }
+            content = content.replace(
+              `src="${originalUrl}"`,
+              `src="/assets/${assetName}"`
+            );
+          }
+        }
+
+        // Find and rewrite link href attributes (for assets like PDFs)
+        const linkRegex = /<a[^>]+href="([^"]+)"/g;
+        while ((match = linkRegex.exec(file.content)) !== null) {
+          const originalUrl = match[1];
+          if (originalUrl.startsWith('./')) {
+            const assetName = originalUrl.slice(2);
+            if (!assets.includes(assetName)) {
+              assets.push(assetName);
+            }
+            content = content.replace(
+              `href="${originalUrl}"`,
+              `href="/assets/${assetName}"`
+            );
+          }
+        }
+
+        // Update manifest in context
+        ctx.data.set('asset-manifest', { assets });
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
diff --git a/src/plugins/markdown-ext.ts b/src/plugins/markdown-ext.ts
