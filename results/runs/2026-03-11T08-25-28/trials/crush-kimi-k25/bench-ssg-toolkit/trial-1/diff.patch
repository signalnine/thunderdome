@@ -0,0 +1,31 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // Process code blocks with language class
+        // Pattern: <pre><code class="language-xxx">...</code></pre>
+        const codeBlockRegex =
+          /<pre><code\s+class="language-([^"]+)">([\s\S]*?)<\/code><\/pre>/g;
+
+        content = content.replace(
+          codeBlockRegex,
+          (_match, language, codeContent) => {
+            return `<pre data-language="${language}"><code class="language-${language} highlighted">${codeContent}</code></pre>`;
+          }
+        );
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
