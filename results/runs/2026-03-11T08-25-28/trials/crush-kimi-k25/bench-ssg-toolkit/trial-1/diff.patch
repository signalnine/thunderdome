+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext): ContentFile => {
+        let content = file.content;
+
+        // Process admonitions first (before markdown conversion)
+        content = processAdmonitions(content);
+
+        // Process footnotes
+        content = processFootnotes(content);
+
+        // Convert basic markdown to HTML
+        content = convertBasicMarkdown(content);
+
+        return {
+          ...file,
+          content,
+        };
+      },
+    },
+  };
+}
+
+function processAdmonitions(content: string): string {
+  // Match :::type\ncontent\n::: pattern
+  const admonitionRegex = /^:::(\w+)\n([\s\S]*?)\n:::$/gm;
+  return content.replace(admonitionRegex, (_match, type, innerContent) => {
+    return `<div class="admonition admonition-${type}">${innerContent}</div>`;
+  });
+}
+
+function processFootnotes(content: string): string {
+  const footnoteRefs: Map<string, string> = new Map();
+
+  // Extract footnote definitions [^1]: content
+  const defRegex = /\[\^(\d+)]:\s*(.+?)(?=\n\[\^|\n*$)/gs;
+  let match;
+  const defs: string[] = [];
+
+  while ((match = defRegex.exec(content)) !== null) {
+    footnoteRefs.set(match[1], match[2].trim());
+    defs.push(match[0]);
+  }
+
+  // Remove footnote definitions from content
+  let processedContent = content;
+  for (const def of defs) {
+    processedContent = processedContent.replace(def, '');
+  }
+
+  // Replace footnote references [^1] with links
+  processedContent = processedContent.replace(/\[\^(\d+)]/g, (_m, num) => {
+    return `<sup><a href="#fn-${num}">${num}</a></sup>`;
+  });
+
+  // Add footnotes section if there are footnotes
+  if (footnoteRefs.size > 0) {
+    const footnotesHtml: string[] = [];
+    footnoteRefs.forEach((text, num) => {
+      footnotesHtml.push(`<li id="fn-${num}">${text}</li>`);
+    });
+    processedContent += `\n<section class="footnotes"><ol>${footnotesHtml.join('')}</ol></section>`;
+  }
+
+  return processedContent.trim();
+}
+
+function convertBasicMarkdown(content: string): string {
+  // Convert headers
+  content = content.replace(/^### (.*$)/gim, '<h3>$1</h3>');
+  content = content.replace(/^## (.*$)/gim, '<h2>$1</h2>');
+  content = content.replace(/^# (.*$)/gim, '<h1>$1</h1>');
+
+  // Convert bold
+  content = content.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
+
+  // Convert italic
+  content = content.replace(/\*(.*?)\*/g, '<em>$1</em>');
+
+  // Convert paragraphs (simple approach - wrap non-tag lines)
+  const lines = content.split('\n');
+  const result: string[] = [];
+  let inParagraph = false;
+
+  for (const line of lines) {
+    const trimmed = line.trim();
+    if (trimmed === '') {
+      if (inParagraph) {
+        result.push('</p>');
+        inParagraph = false;
+      }
+      result.push('');
+    } else if (
+      trimmed.startsWith('<') &&
+      !trimmed.startsWith('<em') &&
+      !trimmed.startsWith('<strong')
+    ) {
+      if (inParagraph) {
+        result.push('</p>');
+        inParagraph = false;
+      }
+      result.push(line);
+    } else {
+      if (!inParagraph) {
+        result.push('<p>');
+        inParagraph = true;
+      }
+      result.push(line);
+    }
+  }
+
+  if (inParagraph) {
+    result.push('</p>');
+  }
+
+  return result.join('\n');
+}
