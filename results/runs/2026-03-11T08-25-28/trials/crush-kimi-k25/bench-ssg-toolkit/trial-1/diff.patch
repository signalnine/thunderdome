@@ -0,0 +1,79 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'],
+    hooks: {
+      afterBuild: (ctx: BuildContext): void => {
+        // Sort files by date (newest first)
+        const sortedFiles = [...ctx.files].sort((a, b) => {
+          if (!a.date) return 1;
+          if (!b.date) return -1;
+          return new Date(b.date).getTime() - new Date(a.date).getTime();
+        });
+
+        // Get taxonomy tags for categories
+        const tagMap = ctx.data.get('taxonomy-tags') as
+          | Map<string, ContentFile[]>
+          | undefined;
+
+        // Build RSS items
+        const items = sortedFiles
+          .map((file) => {
+            const title = escapeXml(file.title);
+            const link = `${ctx.config.baseUrl}/${file.slug}.html`;
+            const description = `<![CDATA[${file.content}]]>`;
+
+            // Find categories for this file
+            const categories: string[] = [];
+            if (tagMap) {
+              for (const [tag, files] of tagMap) {
+                if (files.some((f) => f.slug === file.slug)) {
+                  categories.push(`<category>${escapeXml(tag)}</category>`);
+                }
+              }
+            }
+
+            let pubDate = '';
+            if (file.date) {
+              pubDate = `<pubDate>${new Date(file.date).toUTCString()}</pubDate>`;
+            }
+
+            return `    <item>
+      <title>${title}</title>
+      <link>${link}</link>
+      <guid>${link}</guid>
+      ${pubDate}
+      <description>${description}</description>
+      ${categories.join('\n      ')}
+    </item>`;
+          })
+          .join('\n');
+
+        const feed = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${escapeXml(ctx.config.title)}</title>
+    <link>${ctx.config.baseUrl}</link>
+    <description>RSS feed for ${escapeXml(ctx.config.title)}</description>
+    <language>en</language>
+${items}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', feed);
+      },
+    },
+  };
+}
+
+function escapeXml(str: string): string {
+  return str
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;')
+    .replace(/'/g, '&apos;');
+}
diff --git a/src/plugins/search-index.ts b/src/plugins/search-index.ts
new file mode 100644
index 0000000..3fb5744
--- /dev/null
+++ b/src/plugins/search-index.ts
@@ -0,0 +1,58 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+interface SearchIndexEntry {
+  slug: string;
+  title: string;
+  content: string;
+  tags?: string[];
+}
+
+export function createSearchIndexPlugin(): Plugin {
+  return {
+    name: 'search-index',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'syntax-highlight'],
+    hooks: {
+      afterBuild: (ctx: BuildContext): void => {
+        const index: SearchIndexEntry[] = ctx.files.map((file) => {
+          // Strip HTML tags from content to get plain text
+          const plainText = stripHtml(file.content);
+
+          return {
+            slug: file.slug,
+            title: file.title,
+            content: plainText,
+            tags: file.tags,
+          };
+        });
+
+        ctx.output.set('search-index.json', JSON.stringify(index, null, 2));
+      },
+    },
+  };
+}
+
+function stripHtml(html: string): string {
+  // Remove script and style tags with their content
+  let text = html.replace(/<(script|style)[^>]*>[\s\S]*?<\/\1>/gi, '');
+
+  // Replace common block elements with newlines
+  text = text.replace(/<(\/div|p|h[1-6]|li|br)[^>]*>/gi, '\n');
+
+  // Remove all remaining HTML tags
+  text = text.replace(/<[^>]+>/g, '');
+
+  // Decode common HTML entities
+  text = text
+    .replace(/&nbsp;/g, ' ')
+    .replace(/&amp;/g, '&')
+    .replace(/&lt;/g, '<')
+    .replace(/&gt;/g, '>')
+    .replace(/&quot;/g, '"')
+    .replace(/&#39;/g, "'");
+
+  // Collapse multiple whitespace
+  text = text.replace(/\s+/g, ' ').trim();
+
+  return text;
+}
