+  // Create FTS5 virtual table for full-text search
+  db.exec(`
+    CREATE VIRTUAL TABLE IF NOT EXISTS notes_fts USING fts5(
+      id UNINDEXED,
+      content
+    )
+  `);
+
+  // Create triggers to keep FTS table in sync with notes table
+  db.exec(`
+    CREATE TRIGGER IF NOT EXISTS notes_ai AFTER INSERT ON notes BEGIN
+      INSERT INTO notes_fts(id, content) VALUES (new.id, new.title || ' ' || new.body);
+    END;
+  `);
+  db.exec(`
+    CREATE TRIGGER IF NOT EXISTS notes_ad AFTER DELETE ON notes BEGIN
+      DELETE FROM notes_fts WHERE id = old.id;
+    END;
+  `);
+  db.exec(`
+    CREATE TRIGGER IF NOT EXISTS notes_au AFTER UPDATE OF title, body ON notes BEGIN
+      UPDATE notes_fts SET content = new.title || ' ' || new.body WHERE id = new.id;
+    END;
+  `);
+
+  // Populate FTS table with existing notes (useful when database already has data)
+  const existingNotes = db.prepare('SELECT id, title, body FROM notes').all();
+  const insertFts = db.prepare('INSERT INTO notes_fts(id, content) VALUES (?, ?)');
+  for (const note of existingNotes as { id: number; title: string; body: string }[]) {
+    insertFts.run(note.id, note.title + ' ' + note.body);
+  }
+
   return db;
 }
 
