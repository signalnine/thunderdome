+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0133aJFLBdcw3uFGebrfvgBc","type":"tool_result","content":"     1→/**\n     2→ * Double-entry accounting ledger\n     3→ */\n     4→\n     5→export type AccountType = 'asset' | 'liability' | 'equity' | 'revenue' | 'expense';\n     6→\n     7→export interface Account {\n     8→  name: string;\n     9→  type: AccountType;\n    10→  currency: string;\n    11→}\n    12→\n    13→export interface LineItem {\n    14→  account: string;\n    15→  amount: number;\n    16→}\n    17→\n    18→export interface JournalEntry {\n    19→  id: number;\n    20→  description: string;\n    21→  debits: LineItem[];\n    22→  credits: LineItem[];\n    23→  date: Date;\n    24→}\n    25→\n    26→export interface BalanceEntry {\n    27→  account: string;\n    28→  type: AccountType;\n    29→  debit: number;\n    30→  credit: number;\n    31→}\n    32→\n    33→export interface StatementLine {\n    34→  date: Date;\n    35→  description: string;\n    36→  debit: number;\n    37→  credit: number;\n    38→  balance: number;\n    39→}\n    40→\n    41→export interface ProfitAndLoss {\n    42→  revenue: number;\n    43→  expenses: number;\n    44→  netIncome: number;\n    45→}\n    46→\n    47→export class Ledger {\n    48→  private accounts: Map<string, Account> = new Map();\n    49→  private entries: JournalEntry[] = [];\n    50→  private nextId = 1;\n    51→\n    52→  createAccount(name: string, type: AccountType, currency: string = 'USD'): Account {\n    53→    if (this.accounts.has(name)) {\n    54→      throw new Error(`Account already exists: ${name}`);\n    55→    }\n    56→    const account: Account = { name, type, currency };\n    57→    this.accounts.set(name, account);\n    58→    return account;\n    59→  }\n    60→\n    61→  postEntry(\n    62→    description: string,\n    63→    debits: LineItem[],\n    64→    credits: LineItem[],\n    65→    date?: Date\n    66→  ): JournalEntry {\n    67→    for (const d of debits) {\n    68→      if (!this.accounts.has(d.account)) {\n    69→        throw new Error(`Account not found: ${d.account}`);\n    70→      }\n    71→    }\n    72→    for (const c of credits) {\n    73→      if (!this.accounts.has(c.account)) {\n    74→        throw new Error(`Account not found: ${c.account}`);\n    75→      }\n    76→    }\n    77→\n    78→    const allItems = [...debits, ...credits];\n    79→    const currencies = new Set(allItems.map(item => this.accounts.get(item.account)!.currency));\n    80→    if (currencies.size > 1) {\n    81→      throw new Error(`Currency mismatch: all accounts in an entry must use the same currency`);\n    82→    }\n    83→\n    84→    const totalDebits = debits.reduce((sum, d) => sum + d.amount, 0);\n    85→    const totalCredits = credits.reduce((sum, c) => sum + c.amount, 0);\n    86→    if (totalDebits !== totalCredits) {\n    87→      throw new Error(`Debits (${totalDebits}) must equal credits (${totalCredits})`);\n    88→    }\n    89→\n    90→    for (const d of debits) {\n    91→      if (d.amount <= 0) throw new Error('Amounts must be positive');\n    92→    }\n    93→    for (const c of credits) {\n    94→      if (c.amount <= 0) throw new Error('Amounts must be positive');\n    95→    }\n    96→\n    97→    const entry: JournalEntry = {\n    98→      id: this.nextId++,\n    99→      description,\n   100→      debits: [...debits],\n   101→      credits: [...credits],\n   102→      date: date ?? new Date(),\n   103→    };\n   104→    this.entries.push(entry);\n   105→    return entry;\n   106→  }\n   107→\n   108→  getBalance(accountName: string): number {\n   109→    const account = this.accounts.get(accountName);\n   110→    if (!account) throw new Error(`Account not found: ${accountName}`);\n   111→\n   112→    let balance = 0;\n   113→    for (const entry of this.entries) {\n   114→      for (const d of entry.debits) {\n   115→        if (d.account === accountName) balance += d.amount;\n   116→      }\n   117→      for (const c of entry.credits) {\n   118→        if (c.account === accountName) balance -= c.amount;\n   119→      }\n   120→    }\n   121→\n   122→    // Credit-normal accounts (liability, equity, revenue) should show positive when credits > debits\n   123→    if (account.type === 'liability' || account.type === 'equity' || account.type === 'revenue') {\n   124→      return -balance;\n   125→    }\n   126→    return balance;\n   127→  }\n   128→\n   129→  getTrialBalance(): BalanceEntry[] {\n   130→    const result: BalanceEntry[] = [];\n   131→\n   132→    for (const [name, account] of this.accounts) {\n   133→      let totalDebits = 0;\n   134→      // eslint-disable-next-line prefer-const\n   135→      let totalCredits = 0;\n   136→\n   137→      for (const entry of this.entries) {\n   138→        for (const d of entry.debits) {\n   139→          if (d.account === name) totalDebits += d.amount;\n   140→        }\n   141→        for (const c of entry.credits) {\n   142→          if (c.account === name) totalCredits += c.amount;\n   143→        }\n   144→      }\n   145→\n   146→      result.push({\n   147→        account: name,\n   148→        type: account.type,\n   149→        debit: totalDebits,\n   150→        credit: totalCredits,\n   151→      });\n   152→    }\n   153→\n   154→    return result;\n   155→  }\n   156→\n   157→  getStatement(\n   158→    accountName: string,\n   159→    startDate?: Date,\n   160→    endDate?: Date\n   161→  ): StatementLine[] {\n   162→    const account = this.accounts.get(accountName);\n   163→    if (!account) throw new Error(`Account not found: ${accountName}`);\n   164→\n   165→    const lines: StatementLine[] = [];\n   166→    let runningBalance = 0;\n   167→\n   168→    const sorted = [...this.entries].sort(\n   169→      (a, b) => a.date.getTime() - b.date.getTime()\n   170→    );\n   171→\n   172→    for (const entry of sorted) {\n   173→      if (startDate && entry.date.getTime() < startDate.getTime()) continue;\n   174→      if (endDate && entry.date.getTime() > endDate.getTime()) continue;\n   175→\n   176→      let debit = 0;\n   177→      let credit = 0;\n   178→\n   179→      for (const d of entry.debits) {\n   180→        if (d.account === accountName) debit += d.amount;\n   181→      }\n   182→      for (const c of entry.credits) {\n   183→        if (c.account === accountName) credit += c.amount;\n   184→      }\n   185→\n   186→      if (debit === 0 && credit === 0) continue;\n   187→\n   188→      runningBalance += debit - credit;\n   189→\n   190→      lines.push({\n   191→        date: entry.date,\n   192→        description: entry.description,\n   193→        debit,\n   194→        credit,\n   195→        balance: runningBalance,\n   196→      });\n   197→    }\n   198→\n   199→    return lines;\n   200→  }\n   201→\n   202→  splitEntry(\n   203→    description: string,\n   204→    fromAccount: string,\n   205→    toAccounts: LineItem[],\n   206→    totalAmount: number,\n   207→    date?: Date\n   208→  ): JournalEntry {\n   209→    if (!this.accounts.has(fromAccount)) {\n   210→      throw new Error(`Account not found: ${fromAccount}`);\n   211→    }\n   212→\n   213→    const debits: LineItem[] = [{ account: fromAccount, amount: totalAmount }];\n   214→    const credits: LineItem[] = toAccounts.map(ta => ({\n   215→      account: ta.account,\n   216→      amount: ta.amount,\n   217→    }));\n   218→\n   219→    return this.postEntry(description, debits, credits, date);\n   220→  }\n   221→\n   222→  getAccountsByType(type: AccountType): Account[] {\n   223→    const result: Account[] = [];\n   224→    for (const account of this.accounts.values()) {\n   225→      if (account.type === type) result.push({ ...account });\n   226→    }\n   227→    return result;\n   228→  }\n   229→\n   230→  getProfitAndLoss(startDate?: Date, endDate?: Date): ProfitAndLoss {\n   231→    let revenue = 0;\n   232→    let expenses = 0;\n   233→\n   234→    for (const entry of this.entries) {\n   235→      if (startDate && entry.date < startDate) continue;\n   236→      if (endDate && entry.date > endDate) continue;\n   237→\n   238→      for (const c of entry.credits) {\n   239→        const acct = this.accounts.get(c.account);\n   240→        if (acct?.type === 'revenue') revenue += c.amount;\n   241→      }\n   242→\n   243→      for (const d of entry.debits) {\n   244→        const acct = this.accounts.get(d.account);\n   245→        if (acct?.type === 'expense') expenses += d.amount;\n   246→      }\n   247→    }\n   248→\n   249→    return {\n   250→      revenue,\n   251→      expenses,\n   252→      netIncome: revenue - expenses,\n   253→    };\n   254→  }\n   255→}\n   256→"}]},"parent_tool_use_id":"toolu_01XhYN1cPpQS9V4Ng5VN8XMH","session_id":"2e0d2146-8dc8-4a82-8626-c137ae57e1db","uuid":"f48eed79-edbd-4571-a718-b9dae8028364"}
