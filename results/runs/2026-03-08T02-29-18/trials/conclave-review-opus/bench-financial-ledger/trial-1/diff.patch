te && entry.date.getTime() < startDate.getTime()) continue;\n       if (endDate && entry.date.getTime() > endDate.getTime()) continue;\n \n       let debit = 0;\n@@ -172,7 +185,7 @@ export class Ledger {\n \n       if (debit === 0 && credit === 0) continue;\n \n-      runningBalance += debit + credit;\n+      runningBalance += debit - credit;\n \n       lines.push({\n         date: entry.date,\n@@ -200,7 +213,7 @@ export class Ledger {\n     const debits: LineItem[] = [{ account: fromAccount, amount: totalAmount }];\n     const credits: LineItem[] = toAccounts.map(ta => ({\n       account: ta.account,\n-      amount: totalAmount,\n+      amount: ta.amount,\n     }));\n \n     return this.postEntry(description, debits, credits, date);\n@@ -224,7 +237,7 @@ export class Ledger {\n \n       for (const c of entry.credits) {\n         const acct = this.accounts.get(c.account);\n-        if (acct?.type === 'revenue') revenue -= c.amount;\n+        if (acct?.type === 'revenue') revenue += c.amount;\n       }\n \n       for (const d of entry.debits) {\n@@ -236,7 +249,7 @@ export class Ledger {\n     return {\n       revenue,\n       expenses,\n-      netIncome: revenue + expenses,\n+      netIncome: revenue - expenses,\n     };\n   }\n }","is_error":false}]},"parent_tool_use_id":"toolu_01XhYN1cPpQS9V4Ng5VN8XMH","session_id":"2e0d2146-8dc8-4a82-8626-c137ae57e1db","uuid":"ac954b47-7b9a-4bd8-ba97-fc86b4102d4d"}
