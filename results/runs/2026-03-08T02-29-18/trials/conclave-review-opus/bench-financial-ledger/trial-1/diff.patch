+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xy18iks78UcyTwhRCjAegg","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { Ledger } from '../src/ledger.js';\n     3→\n     4→describe('Ledger', () => {\n     5→  let ledger: Ledger;\n     6→\n     7→  beforeEach(() => {\n     8→    ledger = new Ledger();\n     9→  });\n    10→\n    11→  // ===== Account Creation (5 tests, all pass) =====\n    12→\n    13→  describe('createAccount', () => {\n    14→    it('creates an asset account', () => {\n    15→      const acct = ledger.createAccount('Cash', 'asset');\n    16→      expect(acct.name).toBe('Cash');\n    17→      expect(acct.type).toBe('asset');\n    18→      expect(acct.currency).toBe('USD');\n    19→    });\n    20→\n    21→    it('creates an account with custom currency', () => {\n    22→      const acct = ledger.createAccount('Euro Cash', 'asset', 'EUR');\n    23→      expect(acct.currency).toBe('EUR');\n    24→    });\n    25→\n    26→    it('creates all account types', () => {\n    27→      const types = ['asset', 'liability', 'equity', 'revenue', 'expense'] as const;\n    28→      for (const type of types) {\n    29→        const acct = ledger.createAccount(`${type}-acct`, type);\n    30→        expect(acct.type).toBe(type);\n    31→      }\n    32→    });\n    33→\n    34→    it('returns accounts by type', () => {\n    35→      ledger.createAccount('Cash', 'asset');\n    36→      ledger.createAccount('AR', 'asset');\n    37→      ledger.createAccount('AP', 'liability');\n    38→      const assets = ledger.getAccountsByType('asset');\n    39→      expect(assets).toHaveLength(2);\n    40→      expect(assets.map(a => a.name).sort()).toEqual(['AR', 'Cash']);\n    41→    });\n    42→\n    43→    it('rejects duplicate account names', () => {\n    44→      ledger.createAccount('Cash', 'asset');\n    45→      expect(() => ledger.createAccount('Cash', 'liability')).toThrow();\n    46→    });\n    47→  });\n    48→\n    49→  // ===== Journal Entries (8 tests, 7 pass) =====\n    50→\n    51→  describe('postEntry', () => {\n    52→    beforeEach(() => {\n    53→      ledger.createAccount('Cash', 'asset');\n    54→      ledger.createAccount('Revenue', 'revenue');\n    55→      ledger.createAccount('Expenses', 'expense');\n    56→      ledger.createAccount('AP', 'liability');\n    57→    });\n    58→\n    59→    it('posts a simple entry', () => {\n    60→      const entry = ledger.postEntry(\n    61→        'Sale',\n    62→        [{ account: 'Cash', amount: 100 }],\n    63→        [{ account: 'Revenue', amount: 100 }]\n    64→      );\n    65→      expect(entry.id).toBe(1);\n    66→      expect(entry.description).toBe('Sale');\n    67→    });\n    68→\n    69→    it('posts a compound entry', () => {\n    70→      const entry = ledger.postEntry(\n    71→        'Split payment',\n    72→        [{ account: 'Cash', amount: 50 }, { account: 'Expenses', amount: 50 }],\n    73→        [{ account: 'AP', amount: 100 }]\n    74→      );\n    75→      expect(entry.debits).toHaveLength(2);\n    76→      expect(entry.credits).toHaveLength(1);\n    77→    });\n    78→\n    79→    it('rejects unbalanced entries', () => {\n    80→      expect(() =>\n    81→        ledger.postEntry(\n    82→          'Bad',\n    83→          [{ account: 'Cash', amount: 100 }],\n    84→          [{ account: 'Revenue', amount: 50 }]\n    85→        )\n    86→      ).toThrow(/must equal/i);\n    87→    });\n    88→\n    89→    it('rejects unknown accounts', () => {\n    90→      expect(() =>\n    91→        ledger.postEntry(\n    92→          'Bad',\n    93→          [{ account: 'NonExistent', amount: 100 }],\n    94→          [{ account: 'Revenue', amount: 100 }]\n    95→        )\n    96→      ).toThrow(/not found/i);\n    97→    });\n    98→\n    99→    it('rejects zero or negative amounts', () => {\n   100→      expect(() =>\n   101→        ledger.postEntry(\n   102→          'Bad',\n   103→          [{ account: 'Cash', amount: 0 }],\n   104→          [{ account: 'Revenue', amount: 0 }]\n   105→        )\n   106→      ).toThrow(/positive/i);\n   107→    });\n   108→\n   109→    it('uses current date when not specified', () => {\n   110→      const before = new Date();\n   111→      const entry = ledger.postEntry(\n   112→        'Sale',\n   113→        [{ account: 'Cash', amount: 100 }],\n   114→        [{ account: 'Revenue', amount: 100 }]\n   115→      );\n   116→      const after = new Date();\n   117→      expect(entry.date.getTime()).toBeGreaterThanOrEqual(before.getTime());\n   118→      expect(entry.date.getTime()).toBeLessThanOrEqual(after.getTime());\n   119→    });\n   120→\n   121→    it('uses specified date', () => {\n   122→      const date = new Date('2024-01-15');\n   123→      const entry = ledger.postEntry(\n   124→        'Sale',\n   125→        [{ account: 'Cash', amount: 100 }],\n   126→        [{ account: 'Revenue', amount: 100 }],\n   127→        date\n   128→      );\n   129→      expect(entry.date).toEqual(date);\n   130→    });\n   131→\n   132→    it('rejects entries mixing currencies', () => {\n   133→      ledger.createAccount('Euro Cash', 'asset', 'EUR');\n   134→      expect(() =>\n   135→        ledger.postEntry(\n   136→          'Bad mix',\n   137→          [{ account: 'Cash', amount: 100 }],\n   138→          [{ account: 'Euro Cash', amount: 100 }]\n   139→        )\n   140→      ).toThrow(/currency/i);\n   141→    });\n   142→  });\n   143→\n   144→  // ===== Balances (6 tests, 5 pass) =====\n   145→\n   146→  describe('getBalance', () => {\n   147→    beforeEach(() => {\n   148→      ledger.createAccount('Cash', 'asset');\n   149→      ledger.createAccount('Revenue', 'revenue');\n   150→      ledger.createAccount('AP', 'liability');\n   151→      ledger.createAccount('Expenses', 'expense');\n   152→    });\n   153→\n   154→    it('returns zero for new accounts', () => {\n   155→      expect(ledger.getBalance('Cash')).toBe(0);\n   156→    });\n   157→\n   158→    it('returns correct asset balance', () => {\n   159→      ledger.postEntry(\n   160→        'Sale',\n   161→        [{ account: 'Cash', amount: 100 }],\n   162→        [{ account: 'Revenue', amount: 100 }]\n   163→      );\n   164→      expect(ledger.getBalance('Cash')).toBe(100);\n   165→    });\n   166→\n   167→    it('accumulates multiple entries', () => {\n   168→      ledger.postEntry(\n   169→        'Sale 1',\n   170→        [{ account: 'Cash', amount: 100 }],\n   171→        [{ account: 'Revenue', amount: 100 }]\n   172→      );\n   173→      ledger.postEntry(\n   174→        'Expense',\n   175→        [{ account: 'Expenses', amount: 30 }],\n   176→        [{ account: 'Cash', amount: 30 }]\n   177→      );\n   178→      expect(ledger.getBalance('Cash')).toBe(70);\n   179→    });\n   180→\n   181→    it('throws for unknown account', () => {\n   182→      expect(() => ledger.getBalance('Nonexistent')).toThrow(/not found/i);\n   183→    });\n   184→\n   185→    it('returns correct expense balance', () => {\n   186→      ledger.postEntry(\n   187→        'Rent',\n   188→        [{ account: 'Expenses', amount: 500 }],\n   189→        [{ account: 'Cash', amount: 500 }]\n   190→      );\n   191→      expect(ledger.getBalance('Expenses')).toBe(500);\n   192→    });\n   193→\n   194→    it('returns positive balance for liability with credits', () => {\n   195→      ledger.postEntry(\n   196→        'Loan received',\n   197→        [{ account: 'Cash', amount: 1000 }],\n   198→        [{ account: 'AP', amount: 1000 }]\n   199→      );\n   200→      // Liabilities have credit-normal balance — credited AP should show positive\n   201→      expect(ledger.getBalance('AP')).toBe(1000);\n   202→    });\n   203→  });\n   204→\n   205→  // ===== Trial Balance (4 tests, 3 pass) =====\n   206→\n   207→  describe('getTrialBalance', () => {\n   208→    beforeEach(() => {\n   209→      ledger.createAccount('Cash', 'asset');\n   210→      ledger.createAccount('Revenue', 'revenue');\n   211→      ledger.createAccount('Expenses', 'expense');\n   212→    });\n   213→\n   214→    it('returns empty trial balance', () => {\n   215→      const tb = ledger.getTrialBalance();\n   216→      expect(tb).toHaveLength(3);\n   217→      expect(tb.every(e => e.debit === 0 && e.credit === 0)).toBe(true);\n   218→    });\n   219→\n   220→    it('includes all accounts', () => {\n   221→      const tb = ledger.getTrialBalance();\n   222→      const names = tb.map(e => e.account).sort();\n   223→      expect(names).toEqual(['Cash', 'Expenses', 'Revenue']);\n   224→    });\n   225→\n   226→    it('includes account type', () => {\n   227→      const tb = ledger.getTrialBalance();\n   228→      const cash = tb.find(e => e.account === 'Cash');\n   229→      expect(cash?.type).toBe('asset');\n   230→    });\n   231→\n   232→    it('debits equal credits after entries', () => {\n   233→      ledger.postEntry(\n   234→        'Sale',\n   235→        [{ account: 'Cash', amount: 200 }],\n   236→        [{ account: 'Revenue', amount: 200 }]\n   237→      );\n   238→      ledger.postEntry(\n   239→        'Cost',\n   240→        [{ account: 'Expenses', amount: 50 }],\n   241→        [{ account: 'Cash', amount: 50 }]\n   242→      );\n   243→      const tb = ledger.getTrialBalance();\n   244→      const totalDebits = tb.reduce((s, e) => s + e.debit, 0);\n   245→      const totalCredits = tb.reduce((s, e) => s + e.credit, 0);\n   246→      expect(totalDebits).toBe(totalCredits);\n   247→    });\n   248→  });\n   249→\n   250→  // ===== Statements (6 tests, 4 pass) =====\n   251→\n   252→  describe('getStatement', () => {\n   253→    const jan1 = new Date('2024-01-01');\n   254→    const jan15 = new Date('2024-01-15');\n   255→    const jan31 = new Date('2024-01-31');\n   256→    const feb15 = new Date('2024-02-15');\n   257→\n   258→    beforeEach(() => {\n   259→      ledger.createAccount('Cash', 'asset');\n   260→      ledger.createAccount('Revenue', 'revenue');\n   261→      ledger.createAccount('Expenses', 'expense');\n   262→    });\n   263→\n   264→    it('returns empty statement for no entries', () => {\n   265→      const stmt = ledger.getStatement('Cash');\n   266→      expect(stmt).toHaveLength(0);\n   267→    });\n   268→\n   269→    it('returns entries in date order', () => {\n   270→      ledger.postEntry('Late', [{ account: 'Cash', amount: 50 }], [{ account: 'Revenue', amount: 50 }], jan31);\n   271→      ledger.postEntry('Early', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n   272→      const stmt = ledger.getStatement('Cash');\n   273→      expect(stmt).toHaveLength(2);\n   274→      expect(stmt[0].description).toBe('Early');\n   275→      expect(stmt[1].description).toBe('Late');\n   276→    });\n   277→\n   278→    it('only includes entries for the requested account', () => {\n   279→      ledger.postEntry('Sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n   280→      ledger.postEntry('Cost', [{ account: 'Expenses', amount: 30 }], [{ account: 'Cash', amount: 30 }], jan15);\n   281→      const stmt = ledger.getStatement('Cash');\n   282→      expect(stmt).toHaveLength(2); // Cash appears in both\n   283→      const revenueStmt = ledger.getStatement('Revenue');\n   284→      expect(revenueStmt).toHaveLength(1);\n   285→    });\n   286→\n   287→    it('throws for unknown account', () => {\n   288→      expect(() => ledger.getStatement('Nonexistent')).toThrow(/not found/i);\n   289→    });\n   290→\n   291→    it('shows correct running balance', () => {\n   292→      ledger.postEntry('Sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n   293→      ledger.postEntry('Cost', [{ account: 'Expenses', amount: 30 }], [{ account: 'Cash', amount: 30 }], jan15);\n   294→      const stmt = ledger.getStatement('Cash');\n   295→      expect(stmt[0].balance).toBe(100);  // +100 debit\n   296→      expect(stmt[1].balance).toBe(70);   // -30 credit\n   297→    });\n   298→\n   299→    it('filters by date range inclusively', () => {\n   300→      ledger.postEntry('Jan', [{ account: 'Cash', amount: 100 }], [{ account: 'Revenue', amount: 100 }], jan1);\n   301→      ledger.postEntry('Mid', [{ account: 'Cash', amount: 50 }], [{ account: 'Revenue', amount: 50 }], jan15);\n   302→      ledger.postEntry('Feb', [{ account: 'Cash', amount: 200 }], [{ account: 'Revenue', amount: 200 }], feb15);\n   303→      const stmt = ledger.getStatement('Cash', jan1, jan31);\n   304→      expect(stmt).toHaveLength(2); // Jan 1 and Jan 15, not Feb 15\n   305→      expect(stmt[0].description).toBe('Jan');\n   306→      expect(stmt[1].description).toBe('Mid');\n   307→    });\n   308→  });\n   309→\n   310→  // ===== Split Entries (4 tests, 2 pass) =====\n   311→\n   312→  describe('splitEntry', () => {\n   313→    beforeEach(() => {\n   314→      ledger.createAccount('Cash', 'asset');\n   315→      ledger.createAccount('Rent', 'expense');\n   316→      ledger.createAccount('Utilities', 'expense');\n   317→      ledger.createAccount('Insurance', 'expense');\n   318→    });\n   319→\n   320→    it('creates a basic split entry', () => {\n   321→      // This passes because with one destination, totalAmount === ta.amount by coincidence\n   322→      const entry = ledger.splitEntry(\n   323→        'Office costs',\n   324→        'Cash',\n   325→        [{ account: 'Rent', amount: 1000 }],\n   326→        1000\n   327→      );\n   328→      expect(entry.debits[0].amount).toBe(1000);\n   329→      expect(entry.credits[0].amount).toBe(1000);\n   330→    });\n   331→\n   332→    it('throws for unknown source account', () => {\n   333→      expect(() =>\n   334→        ledger.splitEntry(\n   335→          'Bad',\n   336→          'Nonexistent',\n   337→          [{ account: 'Rent', amount: 100 }],\n   338→          100\n   339→        )\n   340→      ).toThrow(/not found/i);\n   341→    });\n   342→\n   343→    it('creates correct credit amounts for multi-way split', () => {\n   344→      const entry = ledger.splitEntry(\n   345→        'Monthly bills',\n   346→        'Cash',\n   347→        [\n   348→          { account: 'Rent', amount: 800 },\n   349→          { account: 'Utilities', amount: 150 },\n   350→          { account: 'Insurance', amount: 50 },\n   351→        ],\n   352→        1000\n   353→      );\n   354→      expect(entry.credits).toHaveLength(3);\n   355→      expect(entry.credits.find(c => c.account === 'Rent')?.amount).toBe(800);\n   356→      expect(entry.credits.find(c => c.account === 'Utilities')?.amount).toBe(150);\n   357→      expect(entry.credits.find(c => c.account === 'Insurance')?.amount).toBe(50);\n   358→    });\n   359→\n   360→    it('rejects split where amounts dont sum to total', () => {\n   361→      expect(() =>\n   362→        ledger.splitEntry(\n   363→          'Bad split',\n   364→          'Cash',\n   365→          [\n   366→            { account: 'Rent', amount: 600 },\n   367→            { account: 'Utilities', amount: 300 },\n   368→          ],\n   369→          1000  // 600 + 300 = 900 !== 1000\n   370→        )\n   371→      ).toThrow();\n   372→    });\n   373→  });\n   374→\n   375→  // ===== Profit & Loss (7 tests, 5 pass) =====\n   376→\n   377→  describe('getProfitAndLoss', () => {\n   378→    beforeEach(() => {\n   379→      ledger.createAccount('Cash', 'asset');\n   380→      ledger.createAccount('Sales', 'revenue');\n   381→      ledger.createAccount('Consulting', 'revenue');\n   382→      ledger.createAccount('Rent', 'expense');\n   383→      ledger.createAccount('Salaries', 'expense');\n   384→    });\n   385→\n   386→    it('returns zeros with no entries', () => {\n   387→      const pnl = ledger.getProfitAndLoss();\n   388→      expect(pnl.revenue).toBe(0);\n   389→      expect(pnl.expenses).toBe(0);\n   390→      expect(pnl.netIncome).toBe(0);\n   391→    });\n   392→\n   393→    it('calculates expenses correctly', () => {\n   394→      ledger.postEntry('Rent', [{ account: 'Rent', amount: 2000 }], [{ account: 'Cash', amount: 2000 }]);\n   395→      const pnl = ledger.getProfitAndLoss();\n   396→      expect(pnl.expenses).toBe(2000);\n   397→    });\n   398→\n   399→    it('handles date filtering', () => {\n   400→      const jan = new Date('2024-01-15');\n   401→      const feb = new Date('2024-02-15');\n   402→      ledger.postEntry('Jan sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Sales', amount: 100 }], jan);\n   403→      ledger.postEntry('Feb sale', [{ account: 'Cash', amount: 200 }], [{ account: 'Sales', amount: 200 }], feb);\n   404→      const pnl = ledger.getProfitAndLoss(new Date('2024-02-01'), new Date('2024-03-01'));\n   405→      // Only Feb sale should be included\n   406→      expect(Math.abs(pnl.revenue)).toBe(200);\n   407→    });\n   408→\n   409→    it('includes multiple revenue accounts', () => {\n   410→      ledger.postEntry('Sale', [{ account: 'Cash', amount: 100 }], [{ account: 'Sales', amount: 100 }]);\n   411→      ledger.postEntry('Consult', [{ account: 'Cash', amount: 50 }], [{ account: 'Consulting', amount: 50 }]);\n   412→      const pnl = ledger.getProfitAndLoss();\n   413→      // Revenue should be sum of both\n   414→      expect(Math.abs(pnl.revenue)).toBe(150);\n   415→    });\n   416→\n   417→    it('includes multiple expense accounts', () => {\n   418→      ledger.postEntry('Rent', [{ account: 'Rent', amount: 2000 }], [{ account: 'Cash', amount: 2000 }]);\n   419→      ledger.postEntry('Pay', [{ account: 'Salaries', amount: 5000 }], [{ account: 'Cash', amount: 5000 }]);\n   420→      const pnl = ledger.getProfitAndLoss();\n   421→      expect(pnl.expenses).toBe(7000);\n   422→    });\n   423→\n   424→    it('calculates positive revenue from credit entries', () => {\n   425→      ledger.postEntry('Sale', [{ account: 'Cash', amount: 500 }], [{ account: 'Sales', amount: 500 }]);\n   426→      const pnl = ledger.getProfitAndLoss();\n   427→      expect(pnl.revenue).toBe(500);\n   428→    });\n   429→\n   430→    it('calculates correct net income', () => {\n   431→      ledger.postEntry('Sale', [{ account: 'Cash', amount: 1000 }], [{ account: 'Sales', amount: 1000 }]);\n   432→      ledger.postEntry('Rent', [{ account: 'Rent', amount: 400 }], [{ account: 'Cash', amount: 400 }]);\n   433→      const pnl = ledger.getProfitAndLoss();\n   434→      expect(pnl.netIncome).toBe(600);  // 1000 - 400\n   435→    });\n   436→  });\n   437→});\n   438→"}]},"parent_tool_use_id":"toolu_01XhYN1cPpQS9V4Ng5VN8XMH","session_id":"2e0d2146-8dc8-4a82-8626-c137ae57e1db","uuid":"7a1d0665-4a0f-493f-be4c-3f308eb0b763"}
