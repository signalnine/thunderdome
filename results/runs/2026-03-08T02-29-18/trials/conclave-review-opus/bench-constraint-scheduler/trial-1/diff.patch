nment).toHaveProperty('startTime');\n      expect(assignment).toHaveProperty('endTime');\n      expect(typeof assignment.eventId).toBe('string');\n      expect(typeof assignment.roomId).toBe('string');\n      expect(typeof assignment.startTime).toBe('number');\n      expect(typeof assignment.endTime).toBe('number');\n    });\n\n    it('should have endTime equal to startTime + duration', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 45 },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(45);\n    });\n  });\n\n  describe('no room overlap', () => {\n    it('should never have overlapping events in the same room', () => {\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 20 },\n      ];\n      const options: ScheduleOptions = {\n        startTime: 0,\n        endTime: 480,\n        gap: 0,\n      };\n      const events: Event[] = Array.from({ length: 8 }, (_, i) => ({\n        id: `e${i}`,\n        name: `Event ${i}`,\n        duration: 60,\n      }));\n      const result = schedule(events, rooms, options);\n\n      // Check no overlaps within same room\n      const byRoom = new Map<string, typeof result.assignments>();\n      for (const a of result.assignments) {\n        if (!byRoom.has(a.roomId)) byRoom.set(a.roomId, []);\n        byRoom.get(a.roomId)!.push(a);\n      }\n\n      for (const [, roomAssignments] of byRoom) {\n        const sorted = roomAssignments.sort((a, b) => a.startTime - b.startTime);\n        for (let i = 0; i < sorted.length - 1; i++) {\n          expect(sorted[i].endTime).toBeLessThanOrEqual(sorted[i + 1].startTime);\n        }\n      }\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
