+++ b/src/index.ts
@@ -0,0 +1,471 @@
+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+function detectCycle(events: Event[]): void {
+  const eventIds = new Set(events.map(e => e.id));
+  const visited = new Set<string>();
+  const inStack = new Set<string>();
+
+  const adjList = new Map<string, string[]>();
+  for (const event of events) {
+    if (event.prerequisites) {
+      for (const prereq of event.prerequisites) {
+        if (prereq === event.id) {
+          throw new Error(`Cycle detected: event "${event.id}" has itself as a prerequisite`);
+        }
+      }
+      adjList.set(event.id, event.prerequisites.filter(p => eventIds.has(p)));
+    }
+  }
+
+  function dfs(nodeId: string): void {
+    visited.add(nodeId);
+    inStack.add(nodeId);
+
+    const deps = adjList.get(nodeId) || [];
+    for (const dep of deps) {
+      if (inStack.has(dep)) {
+        throw new Error(`Cycle detected in prerequisites involving "${dep}"`);
+      }
+      if (!visited.has(dep)) {
+        dfs(dep);
+      }
+    }
+
+    inStack.delete(nodeId);
+  }
+
+  for (const event of events) {
+    if (!visited.has(event.id)) {
+      dfs(event.id);
+    }
+  }
+}
+
+function topologicalSort(events: Event[]): Event[] {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) eventMap.set(e.id, e);
+
+  const eventIds = new Set(events.map(e => e.id));
+  const inDegree = new Map<string, number>();
+  const adjList = new Map<string, string[]>();
+
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    adjList.set(e.id, []);
+  }
+
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const prereq of e.prerequisites) {
+        if (eventIds.has(prereq)) {
+          adjList.get(prereq)!.push(e.id);
+          inDegree.set(e.id, (inDegree.get(e.id) || 0) + 1);
+        }
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const sorted: Event[] = [];
+  while (queue.length > 0) {
+    const id = queue.shift()!;
+    sorted.push(eventMap.get(id)!);
+    for (const neighbor of adjList.get(id)!) {
+      const newDeg = inDegree.get(neighbor)! - 1;
+      inDegree.set(neighbor, newDeg);
+      if (newDeg === 0) queue.push(neighbor);
+    }
+  }
+
+  return sorted;
+}
+
+/**
+ * Find the earliest time a slot of `duration` minutes can be placed in a room,
+ * starting no earlier than `earliestStart`, ending no later than `endTime`,
+ * with at least `gap` minutes between adjacent slots.
+ */
+function findEarliestSlot(
+  slots: { start: number; end: number }[],
+  duration: number,
+  earliestStart: number,
+  endTime: number,
+  gap: number
+): number | null {
+  let candidateStart = earliestStart;
+  const sorted = [...slots].sort((a, b) => a.start - b.start);
+
+  for (let attempt = 0; attempt <= sorted.length; attempt++) {
+    const candidateEnd = candidateStart + duration;
+    if (candidateEnd > endTime) return null;
+
+    let conflict = false;
+    for (const slot of sorted) {
+      // Two events conflict if they are closer than `gap` minutes apart.
+      // Non-overlapping: candidateEnd + gap <= slot.start OR candidateStart >= slot.end + gap
+      if (candidateEnd + gap > slot.start && candidateStart < slot.end + gap) {
+        candidateStart = slot.end + gap;
+        conflict = true;
+        break;
+      }
+    }
+
+    if (!conflict) {
+      return candidateStart;
+    }
+  }
+
+  return null;
+}
+
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  detectCycle(events);
+
+  const gap = options.gap ?? 15;
+  const { startTime, endTime } = options;
+
+  const sortedEvents = topologicalSort(events);
+  const eventMap = new Map<string, Event>();
+  for (const e of events) eventMap.set(e.id, e);
+
+  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);
+
+  const bestResult = optimizeSchedule(sortedEvents, sortedRooms, eventMap, gap, startTime, endTime);
+
+  return bestResult;
+}
+
+type Strategy = 'prefer-small-room' | 'prefer-large-room' | 'prefer-short-first';
+
+function optimizeSchedule(
+  sortedEvents: Event[],
+  sortedRooms: Room[],
+  eventMap: Map<string, Event>,
+  gap: number,
+  startTime: number,
+  endTime: number
+): ScheduleResult {
+  const strategies: Strategy[] = [
+    'prefer-small-room',
+    'prefer-large-room',
+    'prefer-short-first',
+  ];
+
+  let bestResult: ScheduleResult = { assignments: [], unscheduled: sortedEvents.map(e => e.id) };
+
+  for (const strategy of strategies) {
+    const result = trySchedule(sortedEvents, sortedRooms, eventMap, gap, startTime, endTime, strategy);
+    if (result.assignments.length > bestResult.assignments.length) {
+      bestResult = result;
+    }
+    if (bestResult.unscheduled.length === 0) break;
+  }
+
+  // If we have unscheduled events, try harder with backtracking
+  if (bestResult.unscheduled.length > 0) {
+    const result = tryWithBacktracking(sortedEvents, sortedRooms, eventMap, gap, startTime, endTime);
+    if (result.assignments.length > bestResult.assignments.length) {
+      bestResult = result;
+    }
+  }
+
+  return bestResult;
+}
+
+function trySchedule(
+  sortedEvents: Event[],
+  sortedRooms: Room[],
+  eventMap: Map<string, Event>,
+  gap: number,
+  startTime: number,
+  endTime: number,
+  strategy: Strategy
+): ScheduleResult {
+  const assignments: Assignment[] = [];
+  const unscheduled: string[] = [];
+  const assignmentMap = new Map<string, Assignment>();
+  const roomTimelines = new Map<string, { start: number; end: number }[]>();
+
+  for (const room of sortedRooms) {
+    roomTimelines.set(room.id, []);
+  }
+
+  // For 'prefer-short-first', sort events by duration ascending within topological order
+  let orderedEvents: Event[];
+  if (strategy === 'prefer-short-first') {
+    // Assign topological depth to each event
+    const eventIds = new Set(sortedEvents.map(e => e.id));
+    const depth = new Map<string, number>();
+    for (const e of sortedEvents) {
+      let maxPrereqDepth = -1;
+      if (e.prerequisites) {
+        for (const prereq of e.prerequisites) {
+          if (eventIds.has(prereq) && depth.has(prereq)) {
+            maxPrereqDepth = Math.max(maxPrereqDepth, depth.get(prereq)!);
+          }
+        }
+      }
+      depth.set(e.id, maxPrereqDepth + 1);
+    }
+    orderedEvents = [...sortedEvents].sort((a, b) => {
+      const da = depth.get(a.id)!;
+      const db = depth.get(b.id)!;
+      if (da !== db) return da - db;
+      return a.duration - b.duration;
+    });
+  } else {
+    orderedEvents = [...sortedEvents];
+  }
+
+  for (const event of orderedEvents) {
+    const attendees = event.attendees ?? 1;
+
+    let earliestStart = startTime;
+    let prereqsSatisfied = true;
+
+    if (event.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        if (!eventMap.has(prereqId)) continue;
+        const prereqAssignment = assignmentMap.get(prereqId);
+        if (!prereqAssignment) {
+          prereqsSatisfied = false;
+          break;
+        }
+        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);
+      }
+    }
+
+    if (!prereqsSatisfied) {
+      unscheduled.push(event.id);
+      continue;
+    }
+
+    let candidateRooms: Room[];
+    if (strategy === 'prefer-large-room') {
+      candidateRooms = [...sortedRooms].reverse().filter(r => r.capacity >= attendees);
+    } else {
+      candidateRooms = sortedRooms.filter(r => r.capacity >= attendees);
+    }
+
+    // Try preferred room first
+    if (event.preferredRoom) {
+      const preferredIdx = candidateRooms.findIndex(r => r.id === event.preferredRoom);
+      if (preferredIdx > 0) {
+        const [preferred] = candidateRooms.splice(preferredIdx, 1);
+        candidateRooms.unshift(preferred);
+      }
+    }
+
+    let bestAssignment: Assignment | null = null;
+    let bestStartTime = Infinity;
+
+    for (const room of candidateRooms) {
+      const timeline = roomTimelines.get(room.id)!;
+      const slotStart = findEarliestSlot(timeline, event.duration, earliestStart, endTime, gap);
+
+      if (slotStart !== null) {
+        if (slotStart < bestStartTime) {
+          bestStartTime = slotStart;
+          bestAssignment = {
+            eventId: event.id,
+            roomId: room.id,
+            startTime: slotStart,
+            endTime: slotStart + event.duration,
+          };
+
+          // If preferred room works, use it
+          if (room.id === event.preferredRoom) break;
+        }
+      }
+    }
+
+    if (bestAssignment) {
+      assignments.push(bestAssignment);
+      assignmentMap.set(event.id, bestAssignment);
+      roomTimelines.get(bestAssignment.roomId)!.push({
+        start: bestAssignment.startTime,
+        end: bestAssignment.endTime,
+      });
+    } else {
+      unscheduled.push(event.id);
+    }
+  }
+
+  return { assignments, unscheduled };
+}
+
+function tryWithBacktracking(
+  sortedEvents: Event[],
+  sortedRooms: Room[],
+  eventMap: Map<string, Event>,
+  gap: number,
+  startTime: number,
+  endTime: number
+): ScheduleResult {
+  const eventIds = new Set(sortedEvents.map(e => e.id));
+
+  const prereqMap = new Map<string, string[]>();
+  for (const e of sortedEvents) {
+    const prereqs = (e.prerequisites || []).filter(p => eventIds.has(p));
+    prereqMap.set(e.id, prereqs);
+  }
+
+  const assignments = new Map<string, Assignment>();
+  const roomTimelines = new Map<string, { start: number; end: number }[]>();
+  for (const room of sortedRooms) {
+    roomTimelines.set(room.id, []);
+  }
+
+  let bestAssignments = new Map<string, Assignment>();
+
+  function getEarliestStart(eventId: string): number | null {
+    let earliest = startTime;
+    for (const prereq of prereqMap.get(eventId) || []) {
+      const a = assignments.get(prereq);
+      if (!a) return null;
+      earliest = Math.max(earliest, a.endTime + gap);
+    }
+    return earliest;
+  }
+
+  function solve(remaining: Event[]): void {
+    if (assignments.size > bestAssignments.size) {
+      bestAssignments = new Map(assignments);
+    }
+    if (remaining.length === 0) return;
+    if (assignments.size + remaining.length <= bestAssignments.size) return;
+
+    const schedulable: Event[] = [];
+
+    for (const e of remaining) {
+      const prereqs = prereqMap.get(e.id) || [];
+      const allSatisfied = prereqs.every(p => assignments.has(p));
+      if (allSatisfied) {
+        schedulable.push(e);
+      }
+    }
+
+    if (schedulable.length === 0) return;
+
+    for (const event of schedulable) {
+      const attendees = event.attendees ?? 1;
+      const earliestStart = getEarliestStart(event.id);
+      if (earliestStart === null) continue;
+
+      const candidateRooms = sortedRooms.filter(r => r.capacity >= attendees);
+      if (event.preferredRoom) {
+        const idx = candidateRooms.findIndex(r => r.id === event.preferredRoom);
+        if (idx > 0) {
+          const [preferred] = candidateRooms.splice(idx, 1);
+          candidateRooms.unshift(preferred);
+        }
+      }
+
+      let placed = false;
+      for (const room of candidateRooms) {
+        const timeline = roomTimelines.get(room.id)!;
+        const slotStart = findEarliestSlot(timeline, event.duration, earliestStart, endTime, gap);
+        if (slotStart !== null) {
+          const assignment: Assignment = {
+            eventId: event.id,
+            roomId: room.id,
+            startTime: slotStart,
+            endTime: slotStart + event.duration,
+          };
+
+          assignments.set(event.id, assignment);
+          // Push to end of timeline; pop() restores correctly due to stack-based recursion
+          timeline.push({ start: slotStart, end: slotStart + event.duration });
+
+          const newRemaining = remaining.filter(e => e.id !== event.id);
+          solve(newRemaining);
+
+          assignments.delete(event.id);
+          timeline.pop();
+
+          placed = true;
+
+          if (bestAssignments.size === sortedEvents.length) return;
+        }
+      }
+
+      // Try skipping this event (and its dependents)
+      if (placed) {
+        const newRemaining = remaining.filter(e => e.id !== event.id);
+        const toRemove = new Set<string>([event.id]);
+        let changed = true;
+        while (changed) {
+          changed = false;
+          for (const e of newRemaining) {
+            if (toRemove.has(e.id)) continue;
+            const prereqs = prereqMap.get(e.id) || [];
+            if (prereqs.some(p => toRemove.has(p) && !assignments.has(p))) {
+              toRemove.add(e.id);
+              changed = true;
+            }
+          }
+        }
+        const filteredRemaining = newRemaining.filter(e => !toRemove.has(e.id));
+        if (assignments.size + filteredRemaining.length > bestAssignments.size) {
+          solve(filteredRemaining);
+        }
+      }
+
+      if (bestAssignments.size === sortedEvents.length) return;
+    }
+  }
+
+  // Limit backtracking for large inputs to avoid exponential blowup
+  if (sortedEvents.length <= 20) {
+    solve([...sortedEvents]);
+  }
+
+  if (bestAssignments.size === 0) {
+    return { assignments: [], unscheduled: sortedEvents.map(e => e.id) };
+  }
+
+  const resultAssignments = Array.from(bestAssignments.values());
+  const scheduled = new Set(resultAssignments.map(a => a.eventId));
+  const unscheduled = sortedEvents.filter(e => !scheduled.has(e.id)).map(e => e.id);
+
+  return { assignments: resultAssignments, unscheduled };
+}
