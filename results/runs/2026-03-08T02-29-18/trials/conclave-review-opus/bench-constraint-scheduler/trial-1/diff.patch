26→      ];\n   427→      // Should not throw, just schedule e1 normally since the prereq doesn't exist\n   428→      const result = schedule(events, defaultRooms, defaultOptions);\n   429→      expect(result.assignments).toHaveLength(1);\n   430→    });\n   431→  });\n   432→\n   433→  describe('assignment validation', () => {\n   434→    it('should return correct assignment structure', () => {\n   435→      const events: Event[] = [\n   436→        { id: 'e1', name: 'Event 1', duration: 60 },\n   437→      ];\n   438→      const result = schedule(events, defaultRooms, defaultOptions);\n   439→      const assignment = result.assignments[0];\n   440→      expect(assignment).toHaveProperty('eventId');\n   441→      expect(assignment).toHaveProperty('roomId');\n   442→      expect(assignment).toHaveProperty('startTime');\n   443→      expect(assignment).toHaveProperty('endTime');\n   444→      expect(typeof assignment.eventId).toBe('string');\n   445→      expect(typeof assignment.roomId).toBe('string');\n   446→      expect(typeof assignment.startTime).toBe('number');\n   447→      expect(typeof assignment.endTime).toBe('number');\n   448→    });\n   449→\n   450→    it('should have endTime equal to startTime + duration', () => {\n   451→      const events: Event[] = [\n   452→        { id: 'e1', name: 'Event 1', duration: 45 },\n   453→      ];\n   454→      const result = schedule(events, defaultRooms, defaultOptions);\n   455→      expect(result.assignments[0].endTime - result.assignments[0].startTime).toBe(45);\n   456→    });\n   457→  });\n   458→\n   459→  describe('no room overlap', () => {\n   460→    it('should never have overlapping events in the same room', () => {\n   461→      const rooms: Room[] = [\n   462→        { id: 'room-a', name: 'Room A', capacity: 20 },\n   463→      ];\n   464→      const options: ScheduleOptions = {\n   465→        startTime: 0,\n   466→        endTime: 480,\n   467→        gap: 0,\n   468→      };\n   469→      const events