\n\n    const deps = adjList.get(nodeId) || [];\n    for (const dep of deps) {\n      if (inStack.has(dep)) {\n        throw new Error(`Cycle detected in prerequisites involving \"${dep}\"`);\n      }\n      if (!visited.has(dep)) {\n        dfs(dep);\n      }\n    }\n\n    inStack.delete(nodeId);\n  }\n\n  for (const event of events) {\n    if (!visited.has(event.id)) {\n      dfs(event.id);\n    }\n  }\n}\n\nfunction topologicalSort(events: Event[]): Event[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) eventMap.set(e.id, e);\n\n  const eventIds = new Set(events.map(e => e.id));\n  const inDegree = new Map<string, number>();\n  const adjList = new Map<string, string[]>();\n\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n    adjList.set(e.id, []);\n  }\n\n  for (const e of events) {\n    if (e.prerequisites) {\n      for (const prereq of e.prerequisites) {\n        if (eventIds.has(prereq)) {\n          adjList.get(prereq)!.push(e.id);\n          inDegree.set(e.id, (inDegree.get(e.id) || 0) + 1);\n        }\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const sorted: Event[] = [];\n  while (queue.length > 0) {\n    queue.sort();\n    const id = queue.shift()!;\n    sorted.push(eventMap.get(id)!);\n    for (const neighbor of adjList.get(id)!) {\n      const newDeg = inDegree.get(neighbor)! - 1;\n      inDegree.set(neighbor, newDeg);\n      if (newDeg === 0) queue.push(neighbor);\n    }\n  }\n\n  return sorted;\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  detectCycle(events);\n\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  // Topological sort to respect prerequisites\n  const sortedEvents = topologicalSort(events);\n  const eventMap = new Map<string, Event>();\n  for (const e of events) eventMap.set(e.id, e);\n\n  // Sort rooms by capacity ascending for efficient packing\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Use backtracking with intelligent ordering to maximize scheduled events\n  const bestResult = greedySchedule(sortedEvents, sortedRooms, eventMap, options, gap, startTime, endTime);\n\n  return bestResult;\n}\n\ninterface RoomTimeline {\n  slots: { start: number; end: number }[];\n}\n\nfunction findEarliestSlot(\n  timeline: RoomTimeline,\n  duration: number,\n  earliestStart: number,\n  endTime: number,\n  gap: number\n): number | null {\n  const start = earliestStart;\n  const end = start + duration;\n\n  if (end > endTime) return null;\n\n  // Check against all existing slots in this room\n  // Find a valid start time that doesn't conflict\n  let candidateStart = start;\n\n  // Sort existing slots by start time\n  const sorted = [...timeline.slots].sort((a, b) => a.start - b.start);\n\n  // Try to fit the event\n  for (let attempt = 0; attempt < sorted.length + 1; attempt++) {\n    const candidateEnd = candidateStart + duration;\n    if (candidateEnd > endTime) return null;\n\n    let conflict = false;\n    for (const slot of sorted) {\n      // Check if candidate overlaps with this slot (including gap)\n      if (candidateStart < slot.end + gap && candidateEnd > slot.start - gap) {\n        // Conflict - move candidate to after this slot\n        candidateStart = slot.end + gap;\n        conflict = true;\n        break;\n      }\n    }\n\n    if (!conflict) {\n      if (candidateStart >= earliestStart && candidateStart + duration <= endTime) {\n        return candidateStart;\n      }\n      return null;\n    }\n  }\n\n  return null;\n}\n\nfunction greedySchedule(\n  sortedEvents: Event[],\n  sortedRooms: Room[],\n  eventMap: Map<string, Event>,\n  options: ScheduleOptions,\n  gap: number,\n  startTime: number,\n  endTime: number\n): ScheduleResult {\n  // Build a