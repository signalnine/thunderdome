unscheduled.length > 0) {\n    const result = tryWithBacktracking(sortedEvents, sortedRooms, eventMap, gap, startTime, endTime);\n    if (result.assignments.length > bestResult.assignments.length) {\n      bestResult = result;\n    }\n  }\n\n  return bestResult;\n}\n\nfunction trySchedule(\n  sortedEvents: Event[],\n  sortedRooms: Room[],\n  eventMap: Map<string, Event>,\n  gap: number,\n  startTime: number,\n  endTime: number,\n  dependentCount: Map<string, number>,\n  strategy: string\n): ScheduleResult {\n  const assignments: Assignment[] = [];\n  const unscheduled: string[] = [];\n  const assignmentMap = new Map<string, Assignment>();\n  const roomTimelines = new Map<string, RoomTimeline>();\n\n  for (const room of sortedRooms) {\n    roomTimelines.set(room.id, { slots: [] });\n  }\n\n  // Order events: topological order is primary, then by dependent count (desc), then duration (desc)\n  const orderedEvents = [...sortedEvents].sort((a, b) => {\n    const idxA = sortedEvents.indexOf(a);\n    const idxB = sortedEvents.indexOf(b);\n    if (idxA !== idxB) return idxA - idxB;\n    const depA = dependentCount.get(a.id) || 0;\n    const depB = dependentCount.get(b.id) || 0;\n    if (depA !== depB) return depB - depA;\n    return b.duration - a.duration;\n  });\n\n  for (const event of orderedEvents) {\n    const attendees = event.attendees ?? 1;\n\n    // Find earliest possible start based on prerequisites\n    let earliestStart = startTime;\n    let prereqsSatisfied = true;\n\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (!eventMap.has(prereqId)) continue; // skip unknown prereqs\n        const prereqAssignment = assignmentMap.get(prereqId);\n        if (!prereqAssignment) {\n          // Prerequisite wasn't scheduled - can't schedule this event\n          prereqsSatisfied = false;\n          break;\n        }\n        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);\n      }\n    }\n\n    if (!prereqsSatisfied) {\n      unscheduled.push(event.id);\n      continue;\n    }\n\n    // Get candidate rooms based on strategy\n    let candidateRooms: Room[];\n    if (strategy === 'prefer-large-room') {\n      candidateRooms = [...sortedRooms].reverse().filter(r => r.capacity >= attendees);\n    } else {\n      candidateRooms = sortedRooms.filter(r => r.capacity >= attendees);\n    }\n\n    // Try preferred room first\n    if (event.preferredRoom) {\n      const preferredIdx = candidateRooms.findIndex(r => r.id === event.preferredRoom);\n      if (preferredIdx > 0) {\n        const [preferred] = candidateRooms.splice(preferredIdx, 1);\n        candidateRooms.unshift(preferred);\n      }\n    }\n\n    let bestAssignment: Assignment | null = null;\n    let bestStartTime = Infinity;\n\n    for (const room of candidateRooms) {\n      const timeline = roomTimelines.get(room.id)!;\n      const slotStart = findEarliestSlot(timeline, event.duration, earliestStart, endTime, gap);\n\n      if (slotStart !== null) {\n        if (slotStart < bestStartTime) {\n          bestStartTime = slotStart;\n          bestAssignment = {\n            eventId: event.id,\n            roomId: room.id,\n            startTime: slotStart,\n            endTime: slotStart + event.duration,\n          };\n\n          // If preferred room works, use it immediately\n          if (room.id === event.preferredRoom) break;\n        }\n      }\n    }\n\n    if (bestAssignment) {\n      assignments.push(bestAssignment);\n      assignmentMap.set(event.id, bestAssignment);\n      roomTimelines.get(bestAssignment.roomId)!.slots.push({\n        start: bestAssignment.startTime,\n        end: bestAssignment.endTime,\n      });\n    } else {\n      unscheduled.push(event.id);\n    }\n  }\n\n  return { assignments, unscheduled };\n}\n\nfunction tryWithBacktracking(\n  sortedEvents: Event[],\n  sortedRooms: Room[],\n  eventMap: Map<string, Event>,\n  gap: number,\n  startTime: number,\n  endTime: number\n): ScheduleResult {\n  const eventIds = new Set(sortedEvents.map(e => e.id));\n\n  // Build prerequisite graph\n  const prereqMap = new Map<string, string[]>();\n  const depMap = new Map<string, string[]>();\n  for (const e of sortedEvents) {\n    const prereqs = (e.prerequisites || []).filter(p => eventIds.has(p));\n    prereqMap.set(e.id, prereqs);\n    depMap.set(e.id, []);\n  }\n  for (const e of sortedEvents) {\n    for (const prereq of prereqMap.get(e.id) || []) {\n      depMap.get(prereq)!.push(e.id);\n    }\n  }\n\n  // For backtracking, limit search space\n  const assignments = new Map<string, Assignment>();\n  const roomTimelines = new Map<string, { start: number; end: number }[]>();\n  for (const room of sortedRooms) {\n    roomTimelines.set(room.id, []);\n  }\n\n  let bestAssignments = new Map<string, Assignment>();\n\n  function getEarliestStart(eventId: string): number | null {\n    let earliest = startTime;\n    for (const prereq of prereqMap.get(eventId) || []) {\n      const a = assignments.get(prereq);\n      if (!a) return null; // prerequisite not scheduled\n      earliest = Math.max(earliest, a.endTime + gap);\n    }\n    return earliest;\n  }\n\n  function solve(remaining: Event[]): void {\n    if (assignments.size > bestAssignments.size) {\n      bestAssignments = new Map(assignments);\n    }\n    if (remaining.length === 0) return;\n    if (assignments.size + remaining.length <= bestAssignments.size) return; // pruning\n\n    // Pick next event: one whose prerequisites are all satisfied\n    const schedulable: Event[] = [];\n    const notYetSchedulable: Event[] = [];\n\n    for (const e of remaining) {\n      const prereqs = prereqMap.get(e.id) || [];\n      const allSatisfied = prereqs.every(p => assignments.has(p));\n      if (allSatisfied) {\n        schedulable.push(e);\n      } else {\n        notYetSchedulable.push(e);\n      }\n    }\n\n    if (schedulable.length === 0) {\n      // Can't schedule any more\n      return;\n    }\n\n    // Try scheduling each schedulable event\n    for (const event of schedulable) {\n      const attendees = event.attendees ?? 1;\n      const earliestStart = getEarliestStart(event.id);\n      if (earliestStart === null) continue;\n\n      const candidateRooms = sortedRooms.filter(r => r.capacity >= attendees);\n      if (event.preferredRoom) {\n        const idx = candidateRooms.findIndex(r => r.id === event.preferredRoom);\n        if (idx > 0) {\n          const [preferred] = candidateRooms.splice(idx, 1);\n          candidateRooms.unshift(preferred);\n        }\n      }\n\n      let placed = false;\n      for (const room of candidateRooms) {\n        const timeline = roomTimelines.get(room.id)!;\n        const slotStart = findEarliestSlotArr(timeline, event.duration, earliestStart, endTime, gap);\n        if (slotStart !== null) {\n          const assignment: Assignment = {\n            eventId: event.id,\n            roomId: room.id,\n            startTime: slotStart,\n            endTime: slotStart + event.duration,\n          };\n\n          assignments.set(event.id, assignment);\n          timeline.push({ start: slotStart, end: slotStart + event.duration });\n\n          const newRemaining = remaining.filter(e => e.id !== event.id);\n          solve(newRemaining);\n\n          // Restore\n          assignments.delete(event.id);\n          timeline.pop();\n\n          placed = true;\n\n          if (bestAssignments.size === sortedEvents.length) return; // found perfect solution\n\n          // For preferred room, if it worked, don't try others\n          if (room.id === event.preferredRoom) break;\n        }\n      }\n\n      // Also try skipping this event\n      if (placed) {\n        const newRemaining = remaining.filter(e => e.id !== event.id);\n        // Remove dependents too\n        const toRemove = new Set<string>([event.id]);\n        let changed = true;\n        while (changed) {\n          changed = false;\n          for (const e of newRemaining) {\n            if (toRemove.has(e.id)) continue;\n            const prereqs = prereqMap.get(e.id) || [];\n            if (prereqs.some(p => toRemove.has(p) && !assignments.has(p))) {\n              toRemove.add(e.id);\n              changed = true;\n            }\n          }\n        }\n        const filteredRemaining = newRemaining.filter(e => !toRemove.has(e.id));\n        if (assignments.size + filteredRemaining.length > bestAssignments.size) {\n          solve(filteredRemaining);\n        }\n      }\n\n      if (bestAssignments.size === sortedEvents.length) return;\n    }\n  }\n\n  // Limit backtracking for large inputs\n  if (sortedEvents.length <= 15) {\n    solve([...sortedEvents]);\n  }\n\n  if (bestAssignments.size === 0) {\n    return { assignments: [], unscheduled: sortedEvents.map(e => e.id) };\n  }\n\n  const resultAssignments = Array.from(bestAssignments.values());\n  const scheduled = new Set(resultAssignments.map(a => a.eventId));\n  const unscheduled = sortedEvents.filter(e => !scheduled.has(e.id)).map(e => e.id);\n\n  return { assignments: resultAssignments, unscheduled };\n}\n\nfunction findEarliestSlotArr(\n  slots: { start: number; end: number }[],\n  duration: number,\n  earliestStart: number,\n  endTime: number,\n  gap: number\n): number | null {\n  let candidateStart = earliestStart;\n  const sorted = [...slots].sort((a, b) => a.start - b.start);\n\n  for (let attempt = 0; attempt <= sorted.length; attempt++) {\n    const candidateEnd = candidateStart + duration;\n    if (candidateEnd > endTime) return null;\n\n    let conflict = false;\n    for (const slot of sorted) {\n      if (candidateStart < slot.end + gap && candidateEnd > slot.start - gap) {\n        candidateStart = slot.end + gap;\n        conflict = true;\n        break;\n      }\n    }\n\n    if (!conflict) {\n      return candidateStart;\n    }\n  }\n\n  return null;\n}\n"}}
