unction findEarliestSlot(\n  timeline: RoomTimeline,\n  duration: number,\n  earliestStart: number,\n  endTime: number,\n  gap: number\n): number | null {\n  const start = earliestStart;\n  const end = start + duration;\n\n  if (end > endTime) return null;\n\n  // Check against all existing slots in this room\n  // Find a valid start time that doesn't conflict\n  let candidateStart = start;\n\n  // Sort existing slots by start time\n  const sorted = [...timeline.slots].sort((a, b) => a.start - b.start);\n\n  // Try to fit the event\n  for (let attempt = 0; attempt < sorted.length + 1; attempt++) {\n    const candidateEnd = candidateStart + duration;\n    if (candidateEnd > endTime) return null;\n\n    let conflict = false;\n    for (const slot of sorted) {\n      // Check if candidate overlaps with this slot (including gap)\n      if (candidateStart < slot.end + gap && candidateEnd > slot.start - gap) {\n        // Conflict - move candidate to after this slot\n        candidateStart = slot.end + gap;\n        conflict = true;\n        break;\n      }\n    }\n\n    if (!conflict) {\n      if (candidateStart >= earliestStart && candidateStart + duration <= endTime) {\n        return candidateStart;\n      }\n      return null;\n    }\n  }\n\n  return null;\n}\n\nfunction greedySchedule(\n  sortedEvents: Event[],\n  sortedRooms: Room[],\n  eventMap: Map<string, Event>,\n  options: ScheduleOptions,\n  gap: number,\n  startTime: number,\n  endTime: number\n): ScheduleResult {\n  // Build a dependency graph to know which events depend on which\n  const eventIds = new Set(sortedEvents.map(e => e.id));\n\n  // Count how many events transitively depend on each event\n  // Events with more dependents should be scheduled first (among same topo level)\n  const dependentCount = new Map<string, number>();\n  const reverseDeps = new Map<string, Set<string>>();\n\n  for (const e of sortedEvents) {\n    dependentCount.set(e.id, 0);\n    reverseDeps.set(e.id, new Set());\n  }\n\n  fo