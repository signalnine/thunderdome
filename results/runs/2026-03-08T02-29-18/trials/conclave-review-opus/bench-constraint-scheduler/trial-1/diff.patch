      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toContain('e1');\n    });\n\n    it('should schedule events that fit exactly in the window', () => {\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 600,\n        gap: 0,\n      };\n      const events: Event[] = [\n        { id: 'e1', name: 'Exact Fit', duration: 60 },\n      ];\n      const result = schedule(events, defaultRooms, options);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBe(540);\n      expect(result.assignments[0].endTime).toBe(600);\n    });\n  });\n\n  describe('room gaps', () => {\n    it('should enforce default 15-minute gaps between events in same room', () => {\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);\n    });\n\n    it('should respect custom gap value', () => {\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 1020,\n        gap: 30,\n      };\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const result = schedule(events, rooms, options);\n      expect(result.assignments).toHaveLength(2);\n\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30