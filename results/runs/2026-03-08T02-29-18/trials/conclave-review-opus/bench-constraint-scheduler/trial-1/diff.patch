roomTimelines = new Map<string, RoomTimeline>();\n   283→\n   284→  for (const room of sortedRooms) {\n   285→    roomTimelines.set(room.id, { slots: [] });\n   286→  }\n   287→\n   288→  // Order events: topological order is primary, then by dependent count (desc), then duration (desc)\n   289→  const orderedEvents = [...sortedEvents].sort((a, b) => {\n   290→    const idxA = sortedEvents.indexOf(a);\n   291→    const idxB = sortedEvents.indexOf(b);\n   292→    if (idxA !== idxB) return idxA - idxB;\n   293→    const depA = dependentCount.get(a.id) || 0;\n   294→    const depB = dependentCount.get(b.id) || 0;\n   295→    if (depA !== depB) return depB - depA;\n   296→    return b.duration - a.duration;\n   297→  });\n   298→\n   299→  for (const event of orderedEvents) {\n   300→    const attendees = event.attendees ?? 1;\n   301→\n   302→    // Find earliest possible start based on prerequisites\n   303→    let earliestStart = startTime;\n   304→    let prereqsSatisfied = true;\n   305→\n   306→    if (event.prerequisites) {\n   307→      for (const prereqId of event.prerequisites) {\n   308→        if (!eventMap.has(prereqId)) continue; // skip unknown prereqs\n   309→        const prereqAssignment = assignmentMap.get(prereqId);\n   310→        if (!prereqAssignment) {\n   311→          // Prerequisite wasn't scheduled - can't schedule this event\n   312→          prereqsSatisfied = false;\n   313→          break;\n   314→        }\n   315→        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);\n   316→      }\n   317→    }\n   318→\n   319→    if (!prereqsSatisfied) {\n   320→      unscheduled.push(event.id);\n   321→      continue;\n   322→    }\n   323→\n   324→    // Get candidate rooms based on strategy\n   325→    let candidateRooms: Room[];\n   326→    if (strategy === 'prefer-large-room') {\n   327→      candidateRooms = [...sortedRooms].reverse().filter(r => r.capacity >= attendees);\n   328→    } else {\n   329→      candidateRo