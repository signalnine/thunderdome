 432→\n   433→    for (const e of remaining) {\n   434→      const prereqs = prereqMap.get(e.id) || [];\n   435→      const allSatisfied = prereqs.every(p => assignments.has(p));\n   436→      if (allSatisfied) {\n   437→        schedulable.push(e);\n   438→      } else {\n   439→        notYetSchedulable.push(e);\n   440→      }\n   441→    }\n   442→\n   443→    if (schedulable.length === 0) {\n   444→      // Can't schedule any more\n   445→      return;\n   446→    }\n   447→\n   448→    // Try scheduling each schedulable event\n   449→    for (const event of schedulable) {\n   450→      const attendees = event.attendees ?? 1;\n   451→      const earliestStart = getEarliestStart(event.id);\n   452→      if (earliestStart === null) continue;\n   453→\n   454→      const candidateRooms = sortedRooms.filter(r => r.capacity >= attendees);\n   455→      if (event.preferredRoom) {\n   456→        const idx = candidateRooms.findIndex(r => r.id === event.preferredRoom);\n   457→        if (idx > 0) {\n   458→          const [preferred] = candidateRooms.splice(idx, 1);\n   459→          candidateRooms.unshift(preferred);\n   460→        }\n   461→      }\n   462→\n   463→      let placed = false;\n   464→      for (const room of candidateRooms) {\n   465→        const timeline = roomTimelines.get(room.id)!;\n   466→        const slotStart = findEarliestSlotArr(timeline, event.duration, earliestStart, endTime, gap);\n   467→        if (slotStart !== null) {\n   468→          const assignment: Assignment = {\n   469→            eventId: event.id,\n   470→            roomId: room.id,\n   471→            startTime: slotStart,\n   472→            endTime: slotStart + event.duration,\n   473→          };\n   474→\n   475→          assignments.set(event.id, assignment);\n   476→          timeline.push({ start: slotStart, end: slotStart + event.duration });\n   477→\n   478→          const newRemaining = remaining.filter(e => e.id !== event.id);\n   479→          solve(newRemain