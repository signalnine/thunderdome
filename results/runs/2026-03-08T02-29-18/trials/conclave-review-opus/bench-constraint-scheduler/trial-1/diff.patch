e events that fit exactly in the window', () => {\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 600,\n        gap: 0,\n      };\n      const events: Event[] = [\n        { id: 'e1', name: 'Exact Fit', duration: 60 },\n      ];\n      const result = schedule(events, defaultRooms, options);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBe(540);\n      expect(result.assignments[0].endTime).toBe(600);\n    });\n  });\n\n  describe('room gaps', () => {\n    it('should enforce default 15-minute gaps between events in same room', () => {\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(15);\n    });\n\n    it('should respect custom gap value', () => {\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 1020,\n        gap: 30,\n      };\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const result = schedule(events, rooms, options);\n      expect(result.assignments).toHaveLength(2);\n\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[1].startTime - sorted[0].endTime).toBeGreaterThanOrEqual(30);\n    });\n\n    it('should allow gap of 0', () => {\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 660,\n        gap: 0,\n      };\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60 },\n      ];\n      const result = schedule(events, rooms, options);\n      expect(result.assignments).toHaveLength(2);\n\n      const sorted = result.assignments.sort((a, b) => a.startTime - b.startTime);\n      expect(sorted[0].endTime).toBeLessThanOrEqual(sorted[1].startTime);\n    });\n  });\n\n  describe('prerequisites', () => {\n    it('should schedule prerequisite events before dependent events', () => {\n      const events: Event[] = [\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n        { id: 'e1', name: 'Event 1', duration: 60 },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n\n      const e1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      expect(e1.endTime + 15).toBeLessThanOrEqual(e2.startTime);\n    });\n\n    it('should handle chains of prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e3', name: 'Event 3', duration: 30, prerequisites: ['e2'] },\n        { id: 'e2', name: 'Event 2', duration: 30, prerequisites: ['e1'] },\n        { id: 'e1', name: 'Event 1', duration: 30 },\n      ];\n      const result = schedule(events, defaultRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(3);\n\n      const e1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      const e3 = result.assignments.find(a => a.eventId === 'e3')!;\n      expect(e1.endTime).toBeLessThanOrEqual(e2.startTime);\n      expect(e2.endTime).toBeLessThanOrEqual(e3.startTime);\n    });\n\n    it('should enforce gap between prerequisite and dependent', () => {\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n        { id: 'room-b', name: 'Room B', capacity: 10 },\n      ];\n      const options: ScheduleOptions = {\n        startTime: 540,\n        endTime: 1020,\n        gap: 15,\n      };\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60 },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      ];\n      const result = schedule(events, rooms, options);\n      expect(result.assignments).toHaveLength(2);\n\n      const e1 = result.assignments.find(a => a.eventId === 'e1')!;\n      const e2 = result.assignments.find(a => a.eventId === 'e2')!;\n      expect(e2.startTime).toBeGreaterThanOrEqual(e1.endTime + 15);\n    });\n\n    it('should handle unscheduled prerequisite making dependent unschedulable', () => {\n      const rooms: Room[] = [\n        { id: 'small', name: 'Small Room', capacity: 5 },\n      ];\n      const events: Event[] = [\n        { id: 'e1', name: 'Big Event', duration: 60, attendees: 50 },\n        { id: 'e2', name: 'Small Event', duration: 60, prerequisites: ['e1'] },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.unscheduled).toContain('e1');\n      // e2 depends on e1 which can't be scheduled\n      expect(result.unscheduled).toContain('e2');\n    });\n  });\n\n  describe('prerequisite cycles', () => {\n    it('should throw on self-referencing prerequisites', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw on two-event cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e2'] },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n\n    it('should throw on multi-event cycle', () => {\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, prerequisites: ['e3'] },\n        { id: 'e2', name: 'Event 2', duration: 60, prerequisites: ['e1'] },\n        { id: 'e3', name: 'Event 3', duration: 60, prerequisites: ['e2'] },\n      ];\n      expect(() => schedule(events, defaultRooms, defaultOptions)).toThrow();\n    });\n  });\n\n  describe('preferred room', () => {\n    it('should honor preferred room when possible', () => {\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n        { id: 'room-b', name: 'Room B', capacity: 10 },\n      ];\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, preferredRoom: 'room-b' },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-b');\n    });\n\n    it('should fall back to other rooms when preferred room is not available', () => {\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n        { id: 'room-b', name: 'Room B', capacity: 5 },\n      ];\n      const events: Event[] = [\n        { id: 'e1', name: 'Event 1', duration: 60, attendees: 8, preferredRoom: 'room-b' },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe('room-a');\n    });\n  });\n\n  describe('batch optimization', () => {\n    it('should maximize scheduled events when choices matter', () => {\n      // Create a scenario where greedy placement could fail\n      // One room, tight time window\n      const rooms: Room[] = [\n        { id: 'room-a', name: 'Room A', capacity: 10 },\n      ];\n      const options: ScheduleOptions 