175→        // Conflict - move candidate to after this slot\n   176→        candidateStart = slot.end + gap;\n   177→        conflict = true;\n   178→        break;\n   179→      }\n   180→    }\n   181→\n   182→    if (!conflict) {\n   183→      if (candidateStart >= earliestStart && candidateStart + duration <= endTime) {\n   184→        return candidateStart;\n   185→      }\n   186→      return null;\n   187→    }\n   188→  }\n   189→\n   190→  return null;\n   191→}\n   192→\n   193→function greedySchedule(\n   194→  sortedEvents: Event[],\n   195→  sortedRooms: Room[],\n   196→  eventMap: Map<string, Event>,\n   197→  options: ScheduleOptions,\n   198→  gap: number,\n   199→  startTime: number,\n   200→  endTime: number\n   201→): ScheduleResult {\n   202→  // Build a dependency graph to know which events depend on which\n   203→  const eventIds = new Set(sortedEvents.map(e => e.id));\n   204→\n   205→  // Count how many events transitively depend on each event\n   206→  // Events with more dependents should be scheduled first (among same topo level)\n   207→  const dependentCount = new Map<string, number>();\n   208→  const reverseDeps = new Map<string, Set<string>>();\n   209→\n   210→  for (const e of sortedEvents) {\n   211→    dependentCount.set(e.id, 0);\n   212→    reverseDeps.set(e.id, new Set());\n   213→  }\n   214→\n   215→  for (const e of sortedEvents) {\n   216→    if (e.prerequisites) {\n   217→      for (const prereq of e.prerequisites) {\n   218→        if (eventIds.has(prereq)) {\n   219→          reverseDeps.get(prereq)!.add(e.id);\n   220→        }\n   221→      }\n   222→    }\n   223→  }\n   224→\n   225→  // BFS to count transitive dependents\n   226→  for (const e of sortedEvents) {\n   227→    const visited = new Set<string>();\n   228→    const queue = [e.id];\n   229→    while (queue.length > 0) {\n   230→      const curr = queue.shift()!;\n   231→      for (const dep of reverseDeps.get(curr) || []) {\n   232→        if (!visited.has