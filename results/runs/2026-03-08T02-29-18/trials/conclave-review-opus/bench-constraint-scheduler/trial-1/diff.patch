 Event>,\n  gap: number,\n  startTime: number,\n  endTime: number,\n  dependentCount: Map<string, number>,\n  strategy: string\n): ScheduleResult {\n  const assignments: Assignment[] = [];\n  const unscheduled: string[] = [];\n  const assignmentMap = new Map<string, Assignment>();\n  const roomTimelines = new Map<string, RoomTimeline>();\n\n  for (const room of sortedRooms) {\n    roomTimelines.set(room.id, { slots: [] });\n  }\n\n  // Order events: topological order is primary, then by dependent count (desc), then duration (desc)\n  const orderedEvents = [...sortedEvents].sort((a, b) => {\n    const idxA = sortedEvents.indexOf(a);\n    const idxB = sortedEvents.indexOf(b);\n    if (idxA !== idxB) return idxA - idxB;\n    const depA = dependentCount.get(a.id) || 0;\n    const depB = dependentCount.get(b.id) || 0;\n    if (depA !== depB) return depB - depA;\n    return b.duration - a.duration;\n  });\n\n  for (const event of orderedEvents) {\n    const attendees = event.attendees ?? 1;\n\n    // Find earliest possible start based on prerequisites\n    let earliestStart = startTime;\n    let prereqsSatisfied = true;\n\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (!eventMap.has(prereqId)) continue; // skip unknown prereqs\n        const prereqAssignment = assignmentMap.get(prereqId);\n        if (!prereqAssignment) {\n          // Prerequisite wasn't scheduled - can't schedule this event\n          prereqsSatisfied = false;\n          break;\n        }\n        earliestStart = Math.max(earliestStart, prereqAssignment.endTime + gap);\n      }\n    }\n\n    if (!prereqsSatisfied) {\n      unscheduled.push(event.id);\n      continue;\n    }\n\n    // Get candidate rooms based on strategy\n    let candidateRooms: Room[];\n    if (strategy === 'prefer-large-room') {\n      candidateRooms = [...sortedRooms].reverse().filter(r => r.capacity >= attendees);\n    } else {\n      candidateRooms = sortedRooms.filter(r => r.capacity >= attendees);\n    }\n\n    // Try preferred room first\n    if (event.preferredRoom) {\n      const preferredIdx = candidateRooms.findIndex(r => r.id === event.preferredRoom);\n      if (preferredIdx > 0) {\n        const [preferred] = candidateRooms.splice(preferredIdx, 1);\n        candidateRooms.unshift(preferred);\n      }\n    }\n\n    let bestAssignment: Assignment | null = null;\n    let bestStartTime = Infinity;\n\n    for (const room of candidateRooms) {\n      const timeline = roomTimelines.get(room.id)!;\n      const slotStart = findEarliestSlot(timeline, event.duration, earliestStart, endTime, gap);\n\n      if (slotStart !== null) {\n        if (slotStart < bestStartTime) {\n          bestStartTime = slotStart;\n          bestAssignment = {\n            eventId: event.id,\n            roomId: room.id,\n            startTime: slotStart,\n            endTime: slotStart + event.duration,\n          };\n\n          // If preferred room works, use it immediately\n          if (room.id === event.preferredRoom) break;\n        }\n      }\n    }\n\n    if (bestAssignment) {\n      assignments.push(bestAssignment);\n      assignmentMap.set(event.id, bestAssignment);\n      roomTimelines.get(bestAssignment.roomId)!.slots.push({\n        start: bestAssignment.startTime,\n        end: bestAssignment.endTime,\n      });\n    } else {\n      unscheduled.push(event.id);\n    }\n  }\n\n  return { assignments, unscheduled };\n}\n\nfunction tryWithBacktracking(\n  sortedEvents: Event[],\n  sortedRooms: Room[],\n  eventMap: Map<string, Event>,\n  gap: number,\n  startTime: number,\n  endTime: number\n): ScheduleResult {\n  const eventIds = new Set(sortedEvents.map(e => e.id));\n\n  // Build prerequisite graph\n  const prereqMap = new Map<string, string[]>();\n  const depMap = new Map<string, string[]>();\n  for (const e of sortedEvents) {\n    const prereqs = (e.prerequisites || []).filter(p => eventIds.has(p));\n    prereqMap.set(e.id, prereqs);\n    depMap.set(e.id