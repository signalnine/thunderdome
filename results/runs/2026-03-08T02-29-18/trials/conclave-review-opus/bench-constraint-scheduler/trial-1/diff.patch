 432→\n   433→    for (const e of remaining) {\n   434→      const prereqs = prereqMap.get(e.id) || [];\n   435→      const allSatisfied = prereqs.every(p => assignments.has(p));\n   436→      if (allSatisfied) {\n   437→        schedulable.push(e);\n   438→      } else {\n   439→        notYetSchedulable.push(e);\n   440→      }\n   441→    }\n   442→\n   443→    if (schedulable.length === 0) {\n   444→      // Can't schedule any more\n   445→      return;\n   446→    }\n   447→\n   448→    // Try scheduling each schedulable event\n   449→    for (const event of schedulable) {\n   450→      const attendees = event.attendees ?? 1;\n   451→      const earliestStart = getEarliestStart(event.id);\n   452→      if (earliestStart === null) continue;\n   453→\n   454→      const candidateRooms = sortedRooms.filter(r => r.capacity >= attendees);\n   455→      if (event.preferredRoom) {\n   456→        const idx = candidateRooms.findIndex(r => r.id === event.preferredRoom);\n   457→        if (idx > 0) {\n   458→          const [preferred] = candidateRooms.splice(idx, 1);\n   459→          candidateRooms.unshift(preferred);\n   460→        }\n   461→      }\n   462→\n   463→      let placed = false;\n   464→      for (const room of candidateRooms) {\n   465→        const timeline = roomTimelines.get(room.id)!;\n   466→        const slotStart = findEarliestSlotArr(timeline, event.duration, earliestStart, endTime, gap);\n   467→        if (slotStart !== null) {\n   468→          const assignment: Assignment = {\n   469→            eventId: event.id,\n   470→            roomId: room.id,\n   471→            startTime: slotStart,\n   472→            endTime: slotStart + event.duration,\n   473→          };\n   474→\n   475→          assignments.set(event.id, assignment);\n   476→          timeline.push({ start: slotStart, end: slotStart + event.duration });\n   477→\n   478→          const newRemaining = remaining.filter(e => e.id !== event.id);\n   479→          solve(newRemaining);\n   480→\n   481→          // Restore\n   482→          assignments.delete(event.id);\n   483→          timeline.pop();\n   484→\n   485→          placed = true;\n   486→\n   487→          if (bestAssignments.size === sortedEvents.length) return; // found perfect solution\n   488→\n   489→          // For preferred room, if it worked, don't try others\n   490→          if (room.id === event.preferredRoom) break;\n   491→        }\n   492→      }\n   493→\n   494→      // Also try skipping this event\n   495→      if (placed) {\n   496→        const newRemaining = remaining.filter(e => e.id !== event.id);\n   497→        // Remove dependents too\n   498→        const toRemove = new Set<string>([event.id]);\n   499→        let changed = true;\n   500→        while (changed) {\n   501→          changed = false;\n   502→          for (const e of newRemaining) {\n   503→            if (toRemove.has(e.id)) continue;\n   504→            const prereqs = prereqMap.get(e.id) || [];\n   505→            if (prereqs.some(p => toRemove.has(p) && !assignments.has(p))) {\n   506→              toRemove.add(e.id);\n   507→              changed = true;\n   508→            }\n   509→          }\n   510→        }\n   511→        const filteredRemaining = newRemaining.filter(e => !toRemove.has(e.id));\n   512→        if (assignments.size + filteredRemaining.length > bestAssignments.size) {\n   513→          solve(filteredRemaining);\n   514→        }\n   515→      }\n   516→\n   517→      if (bestAssignments.size === sortedEvents.length) return;\n   518→    }\n   519→  }\n   520→\n   521→  // Limit backtracking for large inputs\n   522→  if (sortedEvents.length <= 15) {\n   523→    solve([...sortedEvents]);\n   524→  }\n   525→\n   526→  if (bestAssignments.size === 0) {\n   527→    return { assignments: [], unscheduled: sortedEvents.map(e => e.id) };\n   528→  }\n   529→\n   530→  const resultAssignments = Array.from(bestAssignments.values());\n   531→  const scheduled = new Set(r