ength(3);\n   309→    expect(report[0].count).toBe(2); // January\n   310→    expect(report[1].count).toBe(1); // February\n   311→    expect(report[2].count).toBe(2); // March\n   312→  });\n   313→\n   314→  it('generates monthly report with correct totals', () => {\n   315→    const report = getMonthlyReport(db, 2024);\n   316→    expect(report[0].total_revenue).toBe(300); // Jan: 100 + 200\n   317→    expect(report[1].total_revenue).toBe(300); // Feb: 300\n   318→    expect(report[2].total_revenue).toBe(550); // Mar: 400 + 150\n   319→  });\n   320→\n   321→  it('returns empty report for year with no invoices', () => {\n   322→    const report = getMonthlyReport(db, 2025);\n   323→    expect(report).toHaveLength(0);\n   324→  });\n   325→\n   326→  it('groups invoices correctly at month boundaries', () => {\n   327→    // Add invoices at exact month boundaries\n   328→    createInvoice(db, {\n   329→      customer_id: 'cust-2',\n   330→      date: '2024-01-31',\n   331→      subtotal: 50, discount_rate: 0, tax_rate: 0, total: 50, status: 'paid',\n   332→    });\n   333→    createInvoice(db, {\n   334→      customer_id: 'cust-2',\n   335→      date: '2024-02-01',\n   336→      subtotal: 75, discount_rate: 0, tax_rate: 0, total: 75, status: 'paid',\n   337→    });\n   338→\n   339→    const report = getMonthlyReport(db, 2024);\n   340→    const jan = report.find(r => r.month === 1)!;\n   341→    const feb = report.find(r => r.month === 2)!;\n   342→\n   343→    // Jan should have 3 invoices (10th, 25th, 31st) = 100 + 200 + 50 = 350\n   344→    expect(jan.count).toBe(3);\n   345→    expect(jan.total_revenue).toBe(350);\n   346→\n   347→    // Feb should have 2 invoices (15th, 1st) = 300 + 75 = 375\n   348→    expect(feb.count).toBe(2);\n   349→    expect(feb.total_revenue).toBe(375);\n   350→  });\n   351→\n   352→  it('reports correct year in summaries', () => {\n   353→    const report = getMonthlyReport(db, 2024);\n   354→    expect(report.every(r => r.year === 