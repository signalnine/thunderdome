// Button 0 affects [0], Button 1 affects [1].\n    // Target: [1, 1]. Modulus 3.\n    // Only solution: (1, 1). Total: 2.\n    const result = solveCounter([1, 1], [[0], [1]], 3);\n    expect(result).toEqual([1, 1]);\n  });\n\n  it('should handle multiple buttons affecting same counter', () => {\n    // Button 0 affects [0, 1], Button 1 affects [1, 2].\n    // Target: [2, 3, 1]. Modulus 5.\n    // x0 affects counters 0 and 1, x1 affects counters 1 and 2.\n    // counter 0 = x0 = 2\n    // counter 1 = x0 + x1 = 3 => x1 = 1\n    // counter 2 = x1 = 1 ✓\n    const result = solveCounter([2, 3, 1], [[0, 1], [1, 2]], 5);\n    expect(result).toEqual([2, 1]);\n  });\n\n  it('should handle larger modulus', () => {\n    // Button 0 affects [0]. Target: [50]. Modulus 97.\n    const result = solveCounter([50], [[0]], 97);\n    expect(result).toEqual([50]);\n  });\n\n  it('should handle no buttons with zero target', () => {\n    const result = solveCounter([0, 0], [], 5);\n    expect(result).toEqual([]);\n  });\n\n  it('should handle no buttons with non-zero target', () => {\n    const result = solveCounter([1], [], 5);\n    expect(result).toBeNull();\n  });\n\n  it('should prefer minimum total even with higher individual values', () => {\n    // Button 0 affects [0], Button 1 affects [0].\n    // Target: counter 0 = 4. Modulus 5.\n    // Solutions: (4,0) total=4, (0,4) total=4, (3,1) total=4, (1,3) total=4, (2,2) total=4\n    // All have total=4. Lex smallest: [0, 4]\n    const result = solveCounter([4], [[0], [0]], 5);\n    expect(result).toEqual([0, 4]);\n  });\n\n  it('should work with modulus 2 (binary case)', () => {\n    // This is essentially the toggle case but with counter interface\n    const result = solveCounter([1, 1, 0], [[0], [1], [2]], 2);\n    expect(result).toEqual([1, 1, 0]);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
