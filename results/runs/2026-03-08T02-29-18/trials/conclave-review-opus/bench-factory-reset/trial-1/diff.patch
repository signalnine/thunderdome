1);\n  const pivotRow: number[] = new Array(cols).fill(-1); // for each column, which row is its pivot\n  let rank = 0;\n\n  for (let col = 0; col < cols; col++) {\n    // Find a pivot row for this column\n    let found = -1;\n    for (let row = rank; row < rows; row++) {\n      if (mat[row][col] === 1) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [mat[rank], mat[found]] = [mat[found], mat[rank]];\n    pivotCol[rank] = col;\n    pivotRow[col] = rank;\n\n    // Eliminate this column from all other rows\n    for (let row = 0; row < rows; row++) {\n      if (row !== rank && mat[row][col] === 1) {\n        for (let c = 0; c <= cols; c++) {\n          mat[row][c] ^= mat[rank][c];\n        }\n      }\n    }\n\n    rank++;\n  }\n\n  // Check for inconsistency: any row with all-zero coefficients but non-zero target\n  for (let row = rank; row < rows; row++) {\n    if (mat[row][cols] === 1) {\n      return null; // no solution\n    }\n  }\n\n  // Now we have reduced row echelon form.\n  // Identify free variables (columns that are not pivot columns).\n  const isFree: boolean[] = new Array(cols).fill(true);\n  for (let r = 0; r < rank; r++) {\n    isFree[pivotCol[r]] = false;\n  }\n\n  const freeVars: number[] = [];\n  for (let c = 0; c < cols; c++) {\n    if (isFree[c]) freeVars.push(c);\n  }\n\n  // Enumerate all 2^freeVars combinations to find solution with minimum presses,\n  // then lexicographically smallest.\n  // freeVars.length can be up to 40 - rank. If rank is close to m, this is small.\n  // But worst case could be large. With m up to 40 and n up to 40, rank <= min(m,n) = 40.\n  // If rank = 0, we'd have 2^40 combinations - too many.\n  // However, if rank = 0 and target has any 1, we already returned null.\n  // If rank = 0 and target is all 0, the only solution is pressing no buttons.\n  // In general, freeVars.length = m - rank. With m=40, rank could be small.\n  // We need a smarter approach for large free variable counts.\n\n  // For large number of free variables, we note:\n  // - Each pivot variable is determined by the free variables.\n  // - For pivot variable at row r with pivot column pivotCol[r]:\n  //   x[pivotCol[r]] = mat[r][cols] XOR (sum of mat[r][freeVar] * x[freeVar]) for each free var\n  // - We want to minimize total number of 1s in the solution.\n  // - This is essentially a minimum weight codeword problem, which is NP-hard in general.\n  // - But with up to 40 free variables, we need a meet-in-the-middle approach.\n\n  if (freeVars.length <= 20) {\n    return solveToggleBruteForce(mat, rank, cols, pivotCol, isFree, freeVars);\n  } else {\n    return solveToggleMeetInMiddle(mat, rank, cols, pivotCol, isFree, freeVars);\n  }\n}\n\nfunction solveToggleBruteForce(\n  mat: number[][],\n  rank: number,\n  cols: number,\n  pivotCol: number[],\n  _isFree: boolean[],\n  freeVars: number[]\n): number[] | null {\n  const numFree = freeVars.length;\n  let bestSolution: number[] | null = null;\n  let bestCount = cols + 1;\n\n  for (let mask = 0; mask < (1 << numFree); mask++) {\n    const solution = new Array(cols).fill(0);\n\n    // Set free variables\n    let freeCount = 0;\n    for (let i = 0; i < numFree; i++) {\n      if (mask & (1 << i)) {\n        solution[freeVars[i]] = 1;\n        freeCount++;\n      }\n    }\n\n    // Early pruning: if free vars already exceed best, skip\n    if (freeCount >= bestCount) continue;\n\n    // Determine pivot variables\n    let totalCount = freeCount;\n    let valid = true;\n    for (let r = rank - 1; r >= 0; r--) {\n      let val = mat[r][cols];\n      for (let i = 0; i < numFree; i++) {\n        if (mask & (1 << i)) {\n          val ^= mat[r][freeVars[i]];\n        }\n      }\n      solution[pivotCol[r]] = val;\n      if (val) {\n        totalCount++;\n        if (totalCount >= bestCount) {\n          valid = false;\n          break;\n        }\n      }\n    }\n\n    if (!valid) continue;\n\n    if (totalCount < bestCount) {\n      bestCount = totalCount;\n      bestSolution = solution.slice();\n    } else if (totalCount === bestCount) {\n      // Lexicographic comparison: compare the sets of pressed buttons\n      const currentIndices = indicesToArray(solution);\n      const bestIndices = indicesToArray(bestSolution!);\n      if (compareLex(currentIndices, bestIndices) < 0) {\n        bestSolution = solution.slice();\n      }\n    }\n  }\n\n  if (bestSolution === null) return null;\n  return indicesToArray(bestSolution);\n}\n\nfunction solveToggleMeetInMiddle(\n  mat: number[][],\n  rank: number,\n  cols: number,\n  pivotCol: number[],\n  _isFree: boolean[],\n  freeVars: number[]\n): number[] | null {\n  // Split free variables into two halves\n  const numFree = freeVars.length;\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n\n  // For each free var assignment, we need to compute the effect on pivot variables.\n  // Precompute: for each free var i, compute the column vector of its effect on pivot vars.\n  // pivotEffect[i][r] = mat[r][freeVars[i]] for each pivot row r\n\n  // For a given free var assignment (mask), the pivot variable at row r is:\n  // x[pivotCol[r]] = mat[r][cols] XOR (xor of mat[r][freeVars[i]] for set bits i in mask)\n\n  // Represent each free var's effect as a bigint bitmask over pivot rows.\n  const freeEffect: bigint[] = new Array(numFree);\n  for (let i = 0; i < numFree; i++) {\n    let bits = 0n;\n    for (let r = 0; r < rank; r++) {\n      if (mat[r][freeVars[i]]) {\n        bits |= 1n << BigInt(r);\n      }\n    }\n    freeEffect[i] = bits;\n  }\n\n  // Base pivot values (when all free vars are 0)\n  let basePivot = 0n;\n  for (let r = 0; r < rank; r++) {\n    if (mat[r][cols]) {\n      basePivot |= 1n << BigInt(r);\n    }\n  }\n\n  // Count bits in a bigint\n  function popcount(n: bigint): number {\n    let count = 0;\n    while (n > 0n) {\n      n &= n - 1n;\n      count++;\n    }\n    return count;\n  }\n\n  // Build a solution from free var mask\n  function buildSolution(freeMask: number): { solution: number[]; count: number } {\n    const solution = new Array(cols).fill(0);\n    let pivotState = basePivot;\n    let freeCount = 0;\n\n    for (let i = 0; i < numFree; i++) {\n      if (freeMask & (1 << i)) {\n        solution[freeVars[i]] = 1;\n        freeCount++;\n        pivotState ^= freeEffect[i];\n      }\n    }\n\n    for (let r = 0; r < rank; r++) {\n      if (pivotState & (1n << BigInt(r))) {\n        solution[pivotCol[r]] = 1;\n      }\n    }\n\n    return { solution, count: freeCount + popcount(pivotState) };\n  }\n\n  // First half: enumerate all 2^half1 assignments\n  // For each, compute the XOR effect on pivot rows (a bigint)\n  // Store in a map: pivotState -> { freeCount, freeMask, totalWeight }\n\n  // For the second half, for each assignment, we compute the pivot state and want to combine.\n  // Combined pivotState = basePivot XOR effect1 XOR effect2\n  // We want to minimize popcount(combinedPivotState) + freeCount1 + freeCount2\n\n  // This is still tricky because the optimization depends on the combined XOR.\n  // Meet-in-the-middle for minimum weight: for each first-half state s1,\n  // the combined pivot state = basePivot XOR s1 XOR s2, and we want to minimize\n  // popcount(basePivot XOR s1 XOR s2) + popcount(mask1) + popcount(mask2).\n\n  // This doesn't factor nicely. Let's use a different approach:\n  // For each total target weight, try to find a solution.\n  // Or just enumerate both halves and combine.\n\n  // With half1 ~ 20 and half2 ~ 20, we have ~1M * ~1M = 10^12 combinations.\n  // That's too many.\n\n  // Alternative: Since rank <= 40, the pivot state is a 40-bit value.\n  // For the first half (2^20 entries), store map from pivotEffect -> best (freeCount, mask).\n  // For the second half, enumerate and look up basePivot XOR s2 to find s1 such that\n  // s1 XOR s2 = target => s1 = basePivot XOR s2 XOR desiredPivot\n  // But we want desiredPivot to have minimum popcount + the free var counts.\n  // We can't enumerate desired pivots.\n\n  // Actually, we want to minimize popcount(basePivot XOR s1 XOR s2) + free1 + free2.\n  // If we fix s1, we want to minimize popcount(P XOR s2) + free2 where P = basePivot XOR s1.\n  // This still requires trying all s2 for each s1.\n\n  // Better: group first half by their pivot XOR effect.\n  // Map: pivotXorEffect -> best (lowest freeCount, then lex smallest mask)\n  // Then for second half, compute s2's effect, and the combined pivot = basePivot XOR s1effect XOR s2effect\n  // Combined weight = popcount(basePivot XOR s1effect XOR s2effect) + free1 + free2\n  // = popcount((basePivot XOR s2effect) XOR s1effect) + free1 + free2\n\n  // For each s2, we want s1effect that minimizes popcount((basePivot XOR s2effect) XOR s1effect) + free1.\n  // This is still a search over all first-half entries.\n\n  // With 2^20 first half entries and 2^20 second half entries, doing a full cross is 2^40.\n  // We need the map approach: for each s2, want s1effect = basePivot XOR s2effect (to zero out pivot state).\n  // That gives total count = free1 + free2 (minimum possible for that s2 if it exists).\n  // But the minimum might use a different s1 that doesn't perfectly cancel.\n\n  // In practice, for this problem, rank is at most min(m, n) = 40, and free vars = m - rank.\n  // If m = 40 and rank = 0, target must be all zeros (otherwise no solution), and the\n  // answer is to press no buttons.\n  // If m = 40 and rank = 20, free vars = 20, which is fine for brute force.\n  // The problematic case is m = 40, rank = 10, free vars = 30.\n  // But with n = 40 lights and 40 buttons, rank is typically close to min(m, n).\n\n  // For the meet-in-the-middle, we use a map approach:\n  // First half: enumerate 2^half1 combinations, for each compute pivotXorEffect and freeCount.\n  //   Store in map: pivotXorEffect -> list of (freeCount, mask)\n  //   Actually store only the best (min freeCount, then lex smallest mask) for each pivotXorEffect.\n\n  // Wait, that loses information. We need to consider that different s1effects paired with different\n  // s2effects yield different final pivot popcounts.\n\n  // The correct MITM approach:\n  // We want to minimize: freeCount1 + freeCount2 + pivotPopcount\n  // where pivotPopcount = popcount(basePivot XOR s1effect XOR s2effect)\n  // = popcount of the final pivot state after both halves applied.\n\n  // This three-way optimization doesn't split cleanly.\n\n  // Practical approach: just iterate. If freeVars <= 25, brute force is ~33M, doable in a few seconds.\n  // For freeVars > 25, we need MITM. But in practice with 40 lights and 40 buttons, this is rare.\n\n  // Let's do a hybrid: if freeVars <= 25, brute force. Otherwise, MITM with heuristic.\n\n  // Actually let me just do brute force up to 25 free vars. Beyond that is extremely unlikely\n  // with the constraints (40 lights, 40 buttons).\n\n  if (numFree <= 25) {\n    // Brute force with pruning\n    let bestSolution: number[] | null = null;\n    let bestCount = cols + 1;\n\n    for (let mask = 0; mask < (1 << numFree); mask++) {\n      const freeCount = popcount(BigInt(mask));\n      if (freeCount >= bestCount) continue;\n\n      let pivotState = basePivot;\n      for (let i = 0; i < numFree; i++) {\n        if (mask & (1 << i)) {\n          pivotState ^= freeEffect[i];\n        }\n      }\n\n      const pivotCount = popcount(pivotState);\n      const totalCount = freeCount + pivotCount;\n\n      if (totalCount < bestCount) {\n        bestCount = totalCount;\n        const { solution } = buildSolution(mask);\n        bestSolution = solution;\n      } else if (totalCount === bestCount) {\n        const { solution } = buildSolution(mask);\n        const currentIndices = indicesToArray(solution);\n        const bestIndices = indicesToArray(bestSolution!);\n        if (compareLex(currentIndices, bestIndices) < 0) {\n          bestSolution = solution;\n        }\n      }\n    }\n\n    if (bestSolution === null) return null;\n    return indicesToArray(bestSolution);\n  }\n\n  // True meet-in-the-middle for > 25 free vars\n  // Build first half map: s1effect -> { minFreeCount, bestMask }\n  // For each s2, look for s1 that gives best result.\n\n  // Group by s1effect, keep only best per effect\n  const firstHalfMap = new Map<bigint, { freeCount: number; mask: number }>();\n\n  for (let mask1 = 0; mask1 < (1 << half1); mask1++) {\n    let effect = 0n;\n    let fc = 0;\n    for (let i = 0; i < half1; i++) {\n      if (mask1 & (1 << i)) {\n        effect ^= freeEffect[i];\n        fc++;\n      }\n    }\n\n    const existing = firstHalfMap.get(effect);\n    if (!existing || fc < existing.freeCount || (fc === existing.freeCount && mask1 < existing.mask)) {\n      firstHalfMap.set(effect, { freeCount: fc, mask: mask1 });\n    }\n  }\n\n  // For exact MITM: for each s2, the ideal s1effect would be basePivot XOR s2effect\n  // (to make pivot state all zeros). But we need to search nearby too.\n  // For a practical approach, enumerate second half, and for each, search the first half map\n  // for exact match (pivot = 0) and nearby matches.\n\n  // Since exact MITM only works for the zero-pivot case, and the general case requires\n  // searching all first-half entries, let's do a different approach:\n  // iterate second half, and for each, iterate ALL first-half entries.\n  // With 2^20 * 2^20 = 2^40 this is too much.\n\n  // Practical solution: since rank <= 40 and n <= 40, the number of distinct pivot effects\n  // for the first half is at most 2^rank (but also at most 2^half1).\n  // We'll iterate second half entries, compute desired = basePivot XOR s2effect,\n  // and look up exact match in the map. If found, total = fc1 + fc2 + 0 (pivots all cancel).\n  // For non-zero pivot, we'd need to check other combinations.\n  // But the minimum weight solution might have non-zero pivots that are compensated.\n\n  // Full solution: for the general case, we note that we want to find the closest entry\n  // in the first half map to (basePivot XOR s2effect). \"Closest\" in Hamming distance.\n  // Finding nearest neighbor in Hamming space of 2^20 points in 40-dim space is hard.\n\n  // Practical compromise: just do brute force up to 2^25 (~33M), and for larger,\n  // use a greedy/heuristic approach.\n\n  // Greedy: try the zero-free-var solution first, then try flipping one free var at a time,\n  // keeping changes that reduce total count. Then try pairs, etc.\n\n  // Actually, let me just do the exact search with the constraint that with 40 lights and\n  // 40 buttons, rank will be at least max(0, m + n - 40) in typical cases, so free vars\n  // won't exceed ~20 in practice. Let's just handle up to 30 with optimized brute force.\n\n  // For truly large free var counts, fall back to: the minimum solution among trying each\n  // individual free var setting. This isn't guaranteed optimal but handles edge cases.\n\n  // Let me implement a practical meet-in-the-middle with the \"try all first-half for each second-half\" approach,\n  // but with the first half being the smaller one (already ensured by half1 <= half2).\n\n  // With half1 = 15 and half2 = 15 (total 30), first half has 32K entries.\n  // For each of 32K second-half entries, check all 32K first-half entries: 1 billion ops.\n  // Still too many.\n\n  // Alternative MITM: store first half indexed by effect in a sorted structure,\n  // and for each second half, compute target effect and do nearest-neighbor lookup.\n  // With rank up to 40, the effect is a 40-bit number. We can use the XOR trick:\n  // for each second half with effect s2 and cost fc2, we want first half with effect s1\n  // minimizing popcount(basePivot XOR s1 XOR s2) + fc1.\n  // Let target = basePivot XOR s2. We want s1 minimizing popcount(target XOR s1) + fc1.\n  // This is: find the entry in the first half map that minimizes Hamming distance to target + fc1.\n\n  // If we group first-half entries by freeCount, for each freeCount level, we have a set of\n  // effects. We search for the minimum popcount(target XOR s1) among those effects.\n  // We'd do this for freeCount = 0, 1, 2, ..., half1 and find the overall minimum.\n\n  // Finding minimum Hamming distance to a target in a set can be done with tries or just linearly.\n  // With 2^half1 entries and 2^half2 queries, linear scan per query gives 2^(half1+half2) = 2^30 ~ 1B.\n  // Might be tight but doable if the inner loop is simple (just XOR and popcount).\n\n  // Let's try this approach with optimized popcount.\n\n  // Actually, for up to 2^30 total iterations with simple operations, this should work within 5 seconds\n  // in optimized JS. Let's try.\n\n  interface HalfEntry {\n    effect: bigint;\n    freeCount: number;\n    mask: number;\n  }\n\n  const firstHalf: HalfEntry[] = [];\n  for (let mask1 = 0; mask1 < (1 << half1); mask1++) {\n    let effect = 0n;\n    let fc = 0;\n    for (let i = 0; i < half1; i++) {\n      if (mask1 & (1 << i)) {\n        effect ^= freeEffect[i];\n        fc++;\n      }\n    }\n    firstHalf.push({ effect, freeCount: fc, mask: mask1 });\n  }\n\n  let bestCount = cols + 1;\n  let bestFreeMask = 0;\n\n  for (let mask2 = 0; mask2 < (1 << half2); mask2++) {\n    let s2effect = 0n;\n    let fc2 = 0;\n    for (let i = 0; i < half2; i++) {\n      if (mask2 & (1 << i)) {\n        s2effect ^= freeEffect[half1 + i];\n        fc2++;\n      }\n    }\n\n    if (fc2 >= bestCount) continue;\n\n    const target = basePivot ^ s2effect;\n\n    for (const entry of firstHalf) {\n      const totalFree = entry.freeCount + fc2;\n      if (totalFree >= bestCount) continue;\n\n      const pivotState = target ^ entry.effect;\n      const pc = popcount(pivotState);\n      const total = totalFree + pc;\n\n      if (total < bestCount) {\n        bestCount = total;\n        bestFreeMask = entry.mask | (mask2 << half1);\n      } else if (total === bestCount) {\n        const newMask = entry.mask | (mask2 << half1);\n        // Compare solutions lexicographically\n        const newSol = buildSolution(newMask);\n        const oldSol = buildSolution(bestFreeMask);\n        if (compareLex(indicesToArray(newSol.solution), indicesToArray(oldSol.solution)) < 0) {\n          bestFreeMask = newMask;\n        }\n      }\n    }\n  }\n\n  if (bestCount > cols) return null;\n  const { solution } = buildSolution(bestFreeMask);\n  return indicesToArray(solution);\n}\n\nfunction indicesToArray(solution: number[]): number[] {\n  const result: number[] = [];\n  for (let i = 0; i < solution.length; i++) {\n    if (solution[i]) result.push(i);\n  }\n  return result;\n}\n\nfunction compareLex(a: number[], b: number[]): number {\n  const len = Math.max(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    const va = i < a.length ? a[i] : Infinity;\n    const vb = i < b.length ? b[i] : Infinity;\n    if (va < vb) return -1;\n    if (va > vb) return 1;\n  }\n  return 0;\n}\n\n/**\n * Solve a counter puzzle over GF(p) using Gaussian elimination.\n * Find minimum total presses, then lexicographically smallest among ties.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const n = lights.length;  // number of counters\n  const m = buttons.length; // number of buttons\n\n  // Build augmented matrix over GF(modulus).\n  // Row i (counter i): sum of x[j] for each button j that affects counter i ≡ lights[i] (mod modulus)\n  // mat[i][j] = 1 if button j affects counter i, 0 otherwise\n  // mat[i][m] = lights[i]\n\n  const mat: number[][] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Array(m + 1).fill(0);\n    row[m] = ((lights[i] % modulus) + modulus) % modulus;\n    mat.push(row);\n  }\n\n  for (let j = 0; j < m; j++) {\n    for (const counterIdx of buttons[j]) {\n      if (counterIdx >= 0 && counterIdx < n) {\n        mat[counterIdx][j] = (mat[counterIdx][j] + 1) % modulus;\n      }\n    }\n  }\n\n  // Gaussian elimination over GF(modulus)\n  const pivotCol: number[] = new Array(n).fill(-1);\n  let rank = 0;\n\n  // Modular inverse using Fermat's little theorem (modulus is prime)\n  function modInverse(a: number, p: number): number {\n    return modPow(a, p - 2, p);\n  }\n\n  function modPow(base: number, exp: number, mod: number): number {\n    let result = 1;\n    base = ((base % mod) + mod) % mod;\n    while (exp > 0) {\n      if (exp & 1) result = (result * base) % mod;\n      exp >>= 1;\n      base = (base * base) % mod;\n    }\n    return result;\n  }\n\n  for (let col = 0; col < m; col++) {\n    // Find pivot row\n    let found = -1;\n    for (let row = rank; row < n; row++) {\n      if (mat[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [mat[rank], mat[found]] = [mat[found], mat[rank]];\n    pivotCol[rank] = col;\n\n    // Scale pivot row so pivot element = 1\n    const inv = modInverse(mat[rank][col], modulus);\n    for (let c = 0; c <= m; c++) {\n      mat[rank][c] = (mat[rank][c] * inv) % modulus;\n    }\n\n    // Eliminate this column from all other rows\n    for (let row = 0; row < n; row++) {\n      if (row !== rank && mat[row][col] !== 0) {\n        const factor = mat[row][col];\n        for (let c = 0; c <= m; c++) {\n          mat[row][c] = (((mat[row][c] - factor * mat[rank][c]) % modulus) + modulus) % modulus;\n        }\n      }\n    }\n\n    rank++;\n  }\n\n  // Check for inconsistency\n  for (let row = rank; row < n; row++) {\n    if (mat[row][m] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const isFree: boolean[] = new Array(m).fill(true);\n  for (let r = 0; r < rank; r++) {\n    isFree[pivotCol[r]] = false;\n  }\n\n  const freeVars: number[] = [];\n  for (let c = 0; c < m; c++) {\n    if (isFree[c]) freeVars.push(c);\n  }\n\n  const numFree = freeVars.length;\n\n  // For each free variable, it can take values 0 to modulus-1.\n  // Total combinations: modulus^numFree.\n  // With modulus up to 97 and numFree potentially large, we need smart enumeration.\n\n  // For each assignment of free variables, pivot variables are determined:\n  // x[pivotCol[r]] = mat[r][m] - sum(mat[r][freeVars[i]] * x[freeVars[i]]) mod modulus\n\n  // We want to minimize total sum of all x[i], then lexicographically smallest.\n\n  // If numFree = 0, just read off the solution.\n  if (numFree === 0) {\n    const solution = new Array(m).fill(0);\n    for (let r = 0; r < rank; r++) {\n      solution[pivotCol[r]] = mat[r][m];\n    }\n    return solution;\n  }\n\n  // For small numFree, enumerate all modulus^numFree combinations.\n  // modulus^numFree: if numFree=1 and modulus=97: 97 combinations (fine)\n  // numFree=2: 9409 (fine)\n  // numFree=3: ~912K (fine)\n  // numFree=4: ~88M (tight but maybe doable)\n  // numFree=5: ~8.6B (too much)\n\n  // For larger cases, use dynamic programming or branch-and-bound.\n\n  // Let's compute the max enumerable size\n  let totalCombinations = 1;\n  let overflow = false;\n  for (let i = 0; i < numFree; i++) {\n    totalCombinations *= modulus;\n    if (totalCombinations > 5_000_000) {\n      overflow = true;\n      break;\n    }\n  }\n\n  if (!overflow) {\n    return solveCounterBruteForce(mat, rank, m, modulus, pivotCol, freeVars);\n  }\n\n  // For larger cases, use branch and bound\n  return solveCounterBranchAndBound(mat, rank, m, modulus, pivotCol, freeVars);\n}\n\nfunction solveCounterBruteForce(\n  mat: number[][],\n  rank: number,\n  m: number,\n  modulus: number,\n  pivotCol: number[],\n  freeVars: number[]\n): number[] | null {\n  const numFree = freeVars.length;\n\n  let bestSolution: number[] | null = null;\n  let bestTotal = Infinity;\n\n  // Enumerate all modulus^numFree combinations using mixed-radix counter\n  const freeValues = new Array(numFree).fill(0);\n\n  // Precompute mat[r][freeVars[i]] for each pivot row r and free var i\n  const matFree: number[][] = [];\n  for (let r = 0; r < rank; r++) {\n    const row: number[] = [];\n    for (let i = 0; i < numFree; i++) {\n      row.push(mat[r][freeVars[i]]);\n    }\n    matFree.push(row);\n  }\n\n  const matRHS: number[] = [];\n  for (let r = 0; r < rank; r++) {\n    matRHS.push(mat[r][m]);\n  }\n\n  const enumerate = (): void => {\n    // Total number of iterations\n    let totalIter = 1;\n    for (let i = 0; i < numFree; i++) totalIter *= modulus;\n\n    for (let iter = 0; iter < totalIter; iter++) {\n      // Compute solution\n      const solution = new Array(m).fill(0);\n      let total = 0;\n\n      // Set free variables\n      for (let i = 0; i < numFree; i++) {\n        solution[freeVars[i]] = freeValues[i];\n        total += freeValues[i];\n      }\n\n      if (total < bestTotal || (total <= bestTotal + rank * (modulus - 1))) {\n        // Compute pivot variables\n        for (let r = 0; r < rank; r++) {\n          let val = matRHS[r];\n          for (let i = 0; i < numFree; i++) {\n            val = (val - matFree[r][i] * freeValues[i] % modulus + modulus * modulus) % modulus;\n          }\n          val = ((val % modulus) + modulus) % modulus;\n          solution[pivotCol[r]] = val;\n          total += val;\n        }\n\n        if (total < bestTotal) {\n          bestTotal = total;\n          bestSolution = solution.slice();\n        } else if (total === bestTotal) {\n          if (compareLexArrays(solution, bestSolution!) < 0) {\n            bestSolution = solution.slice();\n          }\n        }\n      } else {\n        // Even with all pivot vars = 0, we exceed best. Skip if all remaining free values\n        // would only increase the total. We can't easily skip in this scheme.\n      }\n\n      // Increment mixed-radix counter\n      for (let i = numFree - 1; i >= 0; i--) {\n        freeValues[i]++;\n        if (freeValues[i] < modulus) break;\n        freeValues[i] = 0;\n      }\n    }\n  };\n\n  enumerate();\n  return bestSolutio