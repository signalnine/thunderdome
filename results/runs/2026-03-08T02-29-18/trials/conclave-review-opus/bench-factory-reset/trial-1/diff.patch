+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+describe('solveToggle', () => {
+  it('should return empty array when target is all off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0], [1], [2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should return null when no solution exists', () => {
+    // From the example in TASK.md
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should solve a simple single button press', () => {
+    const machine: Machine = {
+      target: [true, false, false],
+      buttons: [[0], [1], [2]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should solve with two button presses', () => {
+    const machine: Machine = {
+      target: [true, true, false],
+      buttons: [[0], [1], [2]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('should find minimum number of presses', () => {
+    // Button 0 toggles [0,1,2], Button 1 toggles [0], Button 2 toggles [1], Button 3 toggles [2]
+    // Target: [true, true, true]
+    // Solution with 1 press: button 0
+    // Solution with 3 presses: buttons 1, 2, 3
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0, 1, 2], [0], [1], [2]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should return lexicographically smallest when tied on count', () => {
+    // Button 0 toggles [0], Button 1 toggles [0]
+    // Target: [true]
+    // Both button 0 alone and button 1 alone work (1 press each)
+    // Lexicographically smallest: [0]
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('should handle overlapping toggles', () => {
+    // Button 0: [0,1], Button 1: [1,2]
+    // Target: [true, false, true]
+    // Press both: light 0 toggled by btn0, light 1 toggled by both (cancels), light 2 toggled by btn1
+    // Result: [true, false, true] ✓
+    const machine: Machine = {
+      target: [true, false, true],
+      buttons: [[0, 1], [1, 2]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('should return null with no buttons and non-zero target', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should handle no buttons with all-off target', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('should handle a larger system', () => {
+    // 5 lights, 5 buttons, each button toggles exactly its own light
+    const machine: Machine = {
+      target: [true, false, true, false, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 2, 4]);
+  });
+
+  it('should handle dependent buttons', () => {
+    // Button 0: [0, 1], Button 1: [0, 2], Button 2: [1, 2]
+    // Target: [true, true, true]
+    // b0 XOR b1 = 1 (light 0), b0 XOR b2 = 1 (light 1), b1 XOR b2 = 1 (light 2)
+    // From equations: b0 XOR b1 = 1, b0 XOR b2 = 1, b1 XOR b2 = 1
+    // b1 = b0 XOR 1, b2 = b0 XOR 1, check: (b0 XOR 1) XOR (b0 XOR 1) = 0 ≠ 1
+    // No solution
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0, 1], [0, 2], [1, 2]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('should handle the case where pressing all buttons gives the target', () => {
+    // Button 0: [0], Button 1: [1], Button 2: [2]
+    // Target: [true, true, true]
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0], [1], [2]],
+    };
+    expect(solveToggle(machine)).toEqual([0, 1, 2]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0], [1], [2]], 5);
+    expect(result).toEqual([0, 0, 0]);
+  });
+
+  it('should solve a simple single button press', () => {
+    // Button 0 affects counter 0. Target: counter 0 = 3. Modulus 5.
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('should handle modular arithmetic', () => {
+    // Button 0 affects counter 0. Target: counter 0 = 0. Modulus 5.
+    // Pressing 0 times gives 0. Pressing 5 times wraps to 0.
+    // Minimum presses: 0.
+    const result = solveCounter([0], [[0]], 5);
+    expect(result).toEqual([0]);
+  });
+
+  it('should return null when no solution exists', () => {
+    // Two counters, one button that affects both.
+    // Button 0 affects [0, 1]. Target: [1, 2]. Modulus 5.
+    // x0 presses: counter 0 = x0, counter 1 = x0.
+    // Need x0 = 1 and x0 = 2. Impossible.
+    const result = solveCounter([1, 2], [[0, 1]], 5);
+    expect(result).toBeNull();
+  });
+
+  it('should find minimum total presses', () => {
+    // Button 0 affects [0], Button 1 affects [0].
+    // Target: counter 0 = 1. Modulus 5.
+    // Solutions: (1,0), (0,1), (2,4), (3,3), (4,2)
+    // Minimum total: 1. Lex smallest: [0, 1] vs [1, 0] -> [0, 1]
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should return lexicographically smallest when tied', () => {
+    // Button 0 affects [0], Button 1 affects [1].
+    // Target: [1, 1]. Modulus 3.
+    // Only solution: (1, 1). Total: 2.
+    const result = solveCounter([1, 1], [[0], [1]], 3);
+    expect(result).toEqual([1, 1]);
+  });
+
+  it('should handle multiple buttons affecting same counter', () => {
+    // Button 0 affects [0, 1], Button 1 affects [1, 2].
+    // Target: [2, 3, 1]. Modulus 5.
+    // x0 affects counters 0 and 1, x1 affects counters 1 and 2.
+    // counter 0 = x0 = 2
+    // counter 1 = x0 + x1 = 3 => x1 = 1
+    // counter 2 = x1 = 1 ✓
+    const result = solveCounter([2, 3, 1], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([2, 1]);
+  });
+
+  it('should handle larger modulus', () => {
+    // Button 0 affects [0]. Target: [50]. Modulus 97.
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+  });
+
+  it('should handle no buttons with zero target', () => {
+    const result = solveCounter([0, 0], [], 5);
+    expect(result).toEqual([]);
+  });
+
+  it('should handle no buttons with non-zero target', () => {
+    const result = solveCounter([1], [], 5);
+    expect(result).toBeNull();
+  });
+
+  it('should prefer minimum total even with higher individual values', () => {
+    // Button 0 affects [0], Button 1 affects [0].
+    // Target: counter 0 = 4. Modulus 5.
+    // Solutions: (4,0) total=4, (0,4) total=4, (3,1) total=4, (1,3) total=4, (2,2) total=4
+    // All have total=4. Lex smallest: [0, 4]
+    const result = solveCounter([4], [[0], [0]], 5);
+    expect(result).toEqual([0, 4]);
+  });
+
+  it('should work with modulus 2 (binary case)', () => {
+    // This is essentially the toggle case but with counter interface
+    const result = solveCounter([1, 1, 0], [[0], [1], [2]], 2);
+    expect(result).toEqual([1, 1, 0]);
+  });
+});
