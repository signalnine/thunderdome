   // Two counters, one button that affects both.\n   146→    // Button 0 affects [0, 1]. Target: [1, 2]. Modulus 5.\n   147→    // x0 presses: counter 0 = x0, counter 1 = x0.\n   148→    // Need x0 = 1 and x0 = 2. Impossible.\n   149→    const result = solveCounter([1, 2], [[0, 1]], 5);\n   150→    expect(result).toBeNull();\n   151→  });\n   152→\n   153→  it('should find minimum total presses', () => {\n   154→    // Button 0 affects [0], Button 1 affects [0].\n   155→    // Target: counter 0 = 1. Modulus 5.\n   156→    // Solutions: (1,0), (0,1), (2,4), (3,3), (4,2)\n   157→    // Minimum total: 1. Lex smallest: [0, 1] vs [1, 0] -> [0, 1]\n   158→    const result = solveCounter([1], [[0], [0]], 5);\n   159→    expect(result).toEqual([0, 1]);\n   160→  });\n   161→\n   162→  it('should return lexicographically smallest when tied', () => {\n   163→    // Button 0 affects [0], Button 1 affects [1].\n   164→    // Target: [1, 1]. Modulus 3.\n   165→    // Only solution: (1, 1). Total: 2.\n   166→    const result = solveCounter([1, 1], [[0], [1]], 3);\n   167→    expect(result).toEqual([1, 1]);\n   168→  });\n   169→\n   170→  it('should handle multiple buttons affecting same counter', () => {\n   171→    // Button 0 affects [0, 1], Button 1 affects [1, 2].\n   172→    // Target: [2, 3, 1]. Modulus 5.\n   173→    // x0 affects counters 0 and 1, x1 affects counters 1 and 2.\n   174→    // counter 0 = x0 = 2\n   175→    // counter 1 = x0 + x1 = 3 => x1 = 1\n   176→    // counter 2 = x1 = 1 ✓\n   177→    const result = solveCounter([2, 3, 1], [[0, 1], [1, 2]], 5);\n   178→    expect(result).toEqual([2, 1]);\n   179→  });\n   180→\n   181→  it('should handle larger modulus', () => {\n   182→    // Button 0 affects [0]. Target: [50]. Modulus 97.\n   183→    const result = solveCounter([50], [[0]], 97);\n   184→    expect(result).toEqual([50]);\n   185→  });\n   186→\n   187→  it('should handle no buttons with zero target', () => {\n   188→    const result = solveCounter([