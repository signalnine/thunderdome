   47→  const pivotCol: number[] = new Array(rows).fill(-1);\n    48→  const pivotRow: number[] = new Array(cols).fill(-1); // for each column, which row is its pivot\n    49→  let rank = 0;\n    50→\n    51→  for (let col = 0; col < cols; col++) {\n    52→    // Find a pivot row for this column\n    53→    let found = -1;\n    54→    for (let row = rank; row < rows; row++) {\n    55→      if (mat[row][col] === 1) {\n    56→        found = row;\n    57→        break;\n    58→      }\n    59→    }\n    60→    if (found === -1) continue;\n    61→\n    62→    // Swap rows\n    63→    [mat[rank], mat[found]] = [mat[found], mat[rank]];\n    64→    pivotCol[rank] = col;\n    65→    pivotRow[col] = rank;\n    66→\n    67→    // Eliminate this column from all other rows\n    68→    for (let row = 0; row < rows; row++) {\n    69→      if (row !== rank && mat[row][col] === 1) {\n    70→        for (let c = 0; c <= cols; c++) {\n    71→          mat[row][c] ^= mat[rank][c];\n    72→        }\n    73→      }\n    74→    }\n    75→\n    76→    rank++;\n    77→  }\n    78→\n    79→  // Check for inconsistency: any row with all-zero coefficients but non-zero target\n    80→  for (let row = rank; row < rows; row++) {\n    81→    if (mat[row][cols] === 1) {\n    82→      return null; // no solution\n    83→    }\n    84→  }\n    85→\n    86→  // Now we have reduced row echelon form.\n    87→  // Identify free variables (columns that are not pivot columns).\n    88→  const isFree: boolean[] = new Array(cols).fill(true);\n    89→  for (let r = 0; r < rank; r++) {\n    90→    isFree[pivotCol[r]] = false;\n    91→  }\n    92→\n    93→  const freeVars: number[] = [];\n    94→  for (let c = 0; c < cols; c++) {\n    95→    if (isFree[c]) freeVars.push(c);\n    96→  }\n    97→\n    98→  // Enumerate all 2^freeVars combinations to find solution with minimum presses,\n    99→  // then lexicographically smallest.\n   100→  // freeVars.length can be up to 40 - rank. If rank is close to m, this is small.\n   101→  // But worst case could be large. With m up to 40 and n up to 40, rank <= min(m,n) = 40.\n   102→  // If rank = 0, we'd have 2^40 combinations - too many.\n   103→  // However, if rank = 0 and target has any 1, we already returned null.\n   104→  // If rank = 0 and target is all 0, the only solution is pressing no buttons.\n   105→  // In general, freeVars.length = m - rank. With m=40, rank could be small.\n   106→  // We need a smarter approach for large free variable counts.\n   107→\n   108→  // For large number of free variables, we note:\n   109→  // - Each pivot variable is determined by the free variables.\n   110→  // - For pivot variable at row r with pivot column pivotCol[r]:\n   111→  //   x[pivotCol[r]] = mat[r][cols] XOR (sum of mat[r][freeVar] * x[freeVar]) for each free var\n   112→  // - We want to minimize total number of 1s in the solution.\n   113→  // - This is essentially a minimum weight codeword problem, which is NP-hard in general.\n   114→  // - But with up to 40 free variables, we need a meet-in-the-middle approach.\n   115→\n   116→  if (freeVars.length <= 20) {\n   117→    return solveToggleBruteForce(mat, rank, cols, pivotCol, isFree, freeVars);\n   118→  } else {\n   119→    return solveToggleMeetInMiddle(mat, rank, cols, pivotCol, isFree, freeVars);\n   120→  }\n   121→}\n   122→\n   123→function solveToggleBruteForce(\n   124→  mat: number[][],\n   125→  rank: number,\n   126→  cols: number,\n   127→  pivotCol: number[],\n   128→  _isFree: boolean[],\n   129→  freeVars: number[]\n   130→): number[] | null {\n   131→  const numFree = freeVars.length;\n   132→  let bestSolution: number[] | null = null;\n   133→  let bestCount = cols + 1;\n   134→\n   135→  for (let mask = 0; mask < (1 << numFree); mask++) {\n   136→    const solution = new Array(cols).fill(0);\n   137→\n   138→    // Set free variables\n   139→    let freeCount = 0;\n   140→    for (let i = 0; i < numFree; i++) {\n   141→      if (mask & (1 << i)) {\n   142→        solution[freeVars[i]] = 1;\n   143→        freeCount++;\n   144→      }\n   145→    }\n   146→\n   147→    // Early pruning: if free vars already exceed best, skip\n   148→    if (freeCount >= bestCount) continue;\n   149→\n   150→    // Determine pivot variables\n   151→    let totalCount = freeCount;\n   152→    let valid = true;\n   153→    for (let r = rank - 1; r >= 0; r--) {\n   154→      let val = mat[r][cols];\n   155→      for (let i = 0; i < numFree; i++) {\n   156→        if (mask & (1 << i)) {\n   157→          val ^= mat[r][freeVars[i]];\n   158→        }\n   159→      }\n   160→      solution[pivotCol[r]] = val;\n   161→      if (val) {\n   162→        totalCount++;\n   163→        if (totalCount >= bestCount) {\n   164→          valid = false;\n   165→          break;\n   166→        }\n   167→      }\n   168→    }\n   169→\n   170→    if (!valid) continue;\n   171→\n   172→    if (totalCount < bestCount) {\n   173→      bestCount = totalCount;\n   174→      bestSolution = solution.slice();\n   175→    } else if (totalCount === bestCount) {\n   176→      // Lexicographic comparison: compare the sets of pressed buttons\n   177→      const currentIndices = indicesToArray(solution);\n   178→      const bestIndices = indicesToArray(bestSolution!);\n   179→      if (compareLex(currentIndices, bestIndices) < 0) {\n   180→        bestSolution = solution.slice();\n   181→      }\n   182→    }\n   183→  }\n   184→\n   185→  if (bestSolution === null) return null;\n   186→  return indicesToArray(bestSolution);\n   187→}\n   188→\n   189→function solveToggleMeetInMiddle(\n   190→  mat: number[][],\n   191→  rank: number,\n   192→  cols: number,\n   193→  pivotCol: number[],\n   194→  _isFree: boolean[],\n   195→  freeVars: number[]\n   196→): number[] | null {\n   197→  // Split free variables into two halves\n   198→  const numFree = freeVars.length;\n   199→  const half1 = Math.floor(numFree / 2);\n   200→  const half2 = numFree - half1;\n   201→\n   202→  // For each free var assignment, we need to compute the effect on pivot variables.\n   203→  // Precompute: for each free var i, compute the column vector of its effect on pivot vars.\n   204→  // pivotEffect[i][r] = mat[r][freeVars[i]] for each pivot row r\n   205→\n   206→  // For a given free var assignment (mask), the pivot variable at row r is:\n   207→  // x[pivotCol[r]] = mat[r][cols] XOR (xor of mat[r][freeVars[i]] for set bits i in mask)\n   208→\n   209→  // Represent each free var's effect as a bigint bitmask over pivot rows.\n   210→  const freeEffect: bigint[] = new Array(numFree);\n   211→  for (let i = 0; i < numFree; i++) {\n   212→    let bits = 0n;\n   213→    for (let r = 0; r < rank; r++) {\n   214→      if (mat[r][freeVars[i]]) {\n   215→        bits |= 1n << BigInt(r);\n   216→      }\n   217→    }\n   218→    freeEffect[i] = bits;\n   219→  }\n   220→\n   221→  // Base pivot values (when all free vars are 0)\n   222→  let basePivot = 0n;\n   223→  for (let r = 0; r < rank; r++) {\n   224→    if (mat[r][cols]) {\n   225→      basePivot |= 1n << BigInt(r);\n   226→    }\n   227→  }\n   228→\n   229→  // Count bits in a bigint\n   230→  function popcount(n: bigint): number {\n   231→    let count = 0;\n   232→    while (n > 0n) {\n   233→      n &= n - 1n;\n   234→      count++;\n   235→    }\n   236→    return count;\n   237→  }\n   238→\n   239→  // Build a solution from free var mask\n   240→  function buildSolution(freeMask: number): { solution: number[]; count: number } {\n   241→    const solution = new Array(cols).fill(0);\n   242→    let pivotState = basePivot;\n   243→    let freeCount = 0;\n   244→\n   245→    for (let i = 0; i < numFree; i++) {\n   246→      if (freeMask & (1 << i)) {\n   247→        solution[freeVars[i]] = 1;\n   248→        freeCount++;\n   249→        pivotState ^= freeEffect[i];\n   250→      }\n   251→    }\n   252→\n   253→    for (let r = 0; r < rank; r++) {\n   254→      if (pivotState & (1n << BigInt(r))) {\n   255→        solution[pivotCol[r]] = 1;\n   256→      }\n   257→    }\n   258→\n   259→    return { solution, count: freeCount + popcount(pivotState) };\n   260→  }\n   261→\n   262→  // First half: enumerate all 2^half1 assignments\n   263→  // For each, compute the XOR effect on pivot rows (a bigint)\n   264→  // Store in a map: pivotState -> { freeCount, freeMask, totalWeight }\n   265→\n   266→  // For the second half, for each assignment, we compute the pivot state and want to combine.\n   267→  // Combined pivotState = basePivot XOR effect1 XOR effect2\n   268→  // We want to minimize popcount(combinedPivotState) + freeCount1 + freeCount2\n   269→\n   270→  // This is still tricky because the optimization depends on the combined XOR.\n   271→  // Meet-in-the-middle for minimum weight: for each first-half state s1,\n   272→  // the combined pivot state = basePivot XOR s1 XOR s2, and we want to minimize\n   273→  // popcount(basePivot XOR s1 XOR s2) + popcount(mask1) + popcount(mask2).\n   274→\n   275→  // This doesn't factor nicely. Let's use a different approach:\n   276→  // For each total target weight, try to find a solution.\n   277→  // Or just enumerate both halves and combine.\n   278→\n   279→  // With half1 ~ 20 and half2 ~ 20, we have ~1M * ~1M = 10^12 combinations.\n   280→  // That's too many.\n   281→\n   282→  // Alternative: Since rank <= 40, the pivot state is a 40-bit value.\n   283→  // For the first half (2^20 entries), store map from pivotEffect -> best (freeCount, mask).\n   284→  // For the second half, enumerate and look up basePivot XOR s2 to find s1 such that\n   285→  // s1 XOR s2 = target => s1 = basePivot XOR s2 XOR desiredPivot\n   286→  // But we want desiredPivot to have minimum popcount + the free var counts.\n   287→  // We can't enumerate desired pivots.\n   288→\n   289→  // Actually, we want to minimize popcount(basePivot XOR s1 XOR s2) + free1 + free2.\n   290→  // If we fix s1, we want to minimize popcount(P XOR s2) + free2 where P = basePivot XOR s1.\n   291→  // This still requires trying all s2 for each s1.\n   292→\n   293→  // Better: group first half by their pivot XOR effect.\n   294→  // Map: pivotXorEffect -> best (lowest freeCount, then lex smallest mask)\n   295→  // Then for second half, compute s2's effect, and the combined pivot = basePivot XOR s1effect XOR s2effect\n   296→  // Combined weight = popcount(basePivot XOR s1effect XOR s2effect) + free1 + free2\n   297→  // = popcount((basePivot XOR s2effect) XOR s1effect) + free1 + free2\n   298→\n   299→  // For each s2, we want s1effect that minimizes popcount((basePivot XOR s2effect) XOR s1effect) + free1.\n   300→  // This is still a search over all first-half entries.\n   301→\n   302→  // With 2^20 first half entries and 2^20 second half entries, doing a full cross is 2^40.\n   303→  // We need the map approach: for each s2, want s1effect = basePivot XOR s2effect (to zero out pivot state).\n   304→  // That gives total count = free1 + free2 (minimum possible for that s2 if it exists).\n   305→  // But the minimum might use a different s1 that doesn't perfectly cancel.\n   306→\n   307→  // In practice, for this problem, rank is at most min(m, n) = 40, and free vars = m - rank.\n   308→  // If m = 40 and rank = 0, target must be all zeros (otherwise no solution), and the\n   309→  // answer is to press no buttons.\n   310→  // If m = 40 and rank = 20, free vars = 20, which is fine for brute force.\n   311→  // The problematic case is m = 40, rank = 10, free vars = 30.\n   312→  // But with n = 40 lights and 40 buttons, rank is typically close to min(m, n).\n   313→\n   314→  // For the meet-in-the-middle, we use a map approach:\n   315→  // First half: enumerate 2^half1 combinations, for each compute pivotXorEffect and freeCount.\n   316→  //   Store in map: pivotXorEffect -> list of (freeCount, mask)\n   317→  //   Actually store only the best (min freeCount, then lex smallest mask) for each pivotXorEffect.\n   318→\n   319→  // Wait, that loses information. We need to consider that different s1effects paired with different\n   320→  // s2effects yield different final pivot popcounts.\n   321→\n   322→  // The correct MITM approach:\n   323→  // We want to minimize: freeCount1 + freeCount2 + pivotPopcount\n   324→  // where pivotPopcount = popcount(basePivot XOR s1effect XOR s2effect)\n   325→  // = popcount of the final pivot state after both halves applied.\n   326→\n   327→  // This three-way optimization doesn't split cleanly.\n   328→\n   329→  // Practical approach: just iterate. If freeVars <= 25, brute force is ~33M, doable in a few seconds.\n   330→  // For freeVars > 25, we need MITM. But in practice with 40 lights and 40 buttons, this is rare.\n   331→\n   332→  // Let's do a hybrid: if freeVars <= 25, brute force. Otherwise, MITM with heuristic.\n   333→\n   334→  // Actually let me just do brute force up to 25 free vars. Beyond that is extremely unlikely\n   335→  // with the constraints (40 lights, 40 buttons).\n   336→\n   337→  if (numFree <= 25) {\n   338→    // Brute force with pruning\n   339→    let bestSolution: number[] | null = null;\n   340→    let bestCount = cols + 1;\n   341→\n   342→    for (let mask = 0; mask < (1 << numFree); mask++) {\n   343→      const freeCount = popcount(BigInt(mask));\n   344→      if (freeCount >= bestCount) continue;\n   345→\n   346→      let pivotState = basePivot;\n   347→      for (let i = 0; i < numFree; i++) {\n   348→        if (mask & (1 << i)) {\n   349→          pivotState ^= freeEffect[i];\n   350→        }\n   351→      }\n   352→\n   353→      const pivotCount = popcount(pivotState);\n   354→      const totalCount = freeCount + pivotCount;\n   355→\n   356→      if (totalCount < bestCount) {\n   357→        bestCount = totalCount;\n   358→        const { solution } = buildSolution(mask);\n   359→        bestSolution = solution;\n   360→      } else if (totalCount === bestCount) {\n   361→        const { solution } = buildSolution(mask);\n   362→        const currentIndices = indicesToArray(solution);\n   363→        const bestIndices = indicesToArray(bestSolution!);\n   364→        if (compareLex(currentIndices, bestIndices) < 0) {\n   365→          bestSolution = solution;\n   366→        }\n   367→      }\n   368→    }\n   369→\n   370→    if (bestSolution === null) return null;\n   371→    return indicesToArray(bestSolution);\n   372→  }\n   373→\n   374→  // True meet-in-the-middle for > 25 free vars\n   375→  // Build first half map: s1effect -> { minFreeCount, bestMask }\n   376→  // For each s2, look for s1 that gives best result.\n   377→\n   378→  // Group by s1effect, keep only best per effect\n   379→  const firstHalfMap = new Map<bigint, { freeCount: number; mask: number }>();\n   380→\n   381→  for (let mask1 = 0; mask1 < (1 << half1); mask1++) {\n   382→    let effect = 0n;\n   383→    let fc = 0;\n   384→    for (let i = 0; i < half1; i++) {\n   385→      if (mask1 & (1 << i)) {\n   386→        effect ^= freeEffect[i];\n   387→        fc++;\n   388→      }\n   389→    }\n   390→\n   391→    const existing = firstHalfMap.get(effect);\n   392→    if (!existing || fc < existing.freeCount || (fc === existing.freeCount && mask1 < existing.mask)) {\n   393→      firstHalfMap.set(effect, { freeCount: fc, mask: mask1 });\n   394→    }\n   395→  }\n   396→\n   397→  // For exact MITM: for each s2, the ideal s1effect would be basePivot XOR s2effect\n   398→  // (to make pivot state all zeros). But we need to search nearby too.\n   399→  // For a practical approach, enumerate second half, and for each, search the first half map\n   400→  // for exact match (pivot = 0) and nearby matches.\n   401→\n   402→  // Since exact MITM only works for the zero-pivot case, and the general case requires\n   403→  // searching all first-half entries, let's do a different approach:\n   404→  // iterate second half, and for each, iterate ALL first-half entries.\n   405→  // With 2^20 * 2^20 = 2^40 this is too much.\n   406→\n   407→  // Practical solution: since rank <= 40 and n <= 40, the number of distinct pivot effects\n   408→  // for the first half is at most 2^rank (but also at most 2^half1).\n   409→  // We'll iterate second half entries, compute desired = basePivot XOR s2effect,\n   410→  // and look up exact match in the map. If found, total = fc1 + fc2 + 0 (pivots all cancel).\n   411→  // For non-zero pivot, we'd need to check other combinations.\n   412→  // But the minimum weight solution might have non-zero pivots that are compensated.\n   413→\n   414→  // Full solution: for the general case, we note that we want to find the closest entry\n   415→  // in the first half map to (basePivot XOR s2effect). \"Closest\" in Hamming distance.\n   416→  // Finding nearest neighbor in Hamming space of 2^20 points in 40-dim space is hard.\n   417→\n   418→  // Practical compromise: just do brute force up to 2^25 (~33M), and for larger,\n   419→  // use a greedy/heuristic approach.\n   420→\n   421→  // Greedy: try the zero-free-var solution first, then try flipping one free var at a time,\n   422→  // keeping changes that reduce total count. Then try pairs, etc.\n   423→\n   424→  // Actually, let me just do the exact search with the constraint that with 40 lights and\n   425→  // 40 buttons, rank will be at least max(0, m + n - 40) in typical cases, so free vars\n   426→  // won't exceed ~20 in practice. Let's just handle up to 30 with optimized brute force.\n   427→\n   428→  // For truly large free var counts, fall back to: the minimum solution among trying each\n   429→  // individual free var setting. This isn't guaranteed optimal but handles edge cases.\n   430→\n   431→  // Let me implement a practical meet-in-the-middle with the \"try all first-half for each second-half\" approach,\n   432→  // but with the first half being the smaller one (already ensured by half1 <= half2).\n   433→\n   434→  // With half1 = 15 and half2 = 15 (total 30), first half has 32K entries.\n   435→  // For each of 32K second-half entries, check all 32K first-half entries: 1 billion ops.\n   436→  // Still too many.\n   437→\n   438→  // Alternative MITM: store first half indexed by effect in a sorted structure,\n   439→  // and for each second half, compute target effect and do nearest-neighbor lookup.\n   440→  // With rank up to 40, the effect is a 40-bit number. We can use the XOR trick:\n   441→  // for each second half with effect s2 and cost fc2, we want first half with effect s1\n   442→  // minimizing popcount(basePivot XOR s1 XOR s2) + fc1.\n   443→  // Let target = basePivot XOR s2. We want s1 minimizing popcount(target XOR s1) + fc1.\n   444→  // This is: find the entry in the first half map that minimizes Hamming distance to target + fc1.\n   445→\n   446→  // If we group first-half entries by freeCount, for each freeCount level, we have a set of\n   447→  // effects. We search for the minimum popcount(target XOR s1) among those effects.\n   448→  // We'd do this for freeCount = 0, 1, 2, ..., half1 and find the overall minimum.\n   449→\n   450→  // Finding minimum Hamming distance to a target in a set can be done with tries or just linearly.\n   451→  // With 2^half1 entries and 2^half2 queries, linear scan per query gives 2^(half1+half2) = 2^30 ~ 1B.\n   452→  // Might be tight but doable if the inner loop is simple (just XOR and popcount).\n   453→\n   454→  // Let's try this approach with optimized popcount.\n   455→\n   456→  // Actually, for up to 2^30 total iterations with simple operations, this should work within 5 seconds\n   457→  // in optimized JS. Let's try.\n   458→\n   459→  interface HalfEntry {\n   460→    effect: bigint;\n   461→    freeCount: number;\n   462→    mask: number;\n   463→  }\n   464→\n   465→  const firstHalf: HalfEntry[] = [];\n   466→  for (let mask1 = 0; mask1 < (1 << half1); mask1++) {\n   467→    let effect = 0n;\n   468→    let fc = 0;\n   469→    for (let i = 0; i < half1; i++) {\n   470→      if (mask1 & (1 << i)) {\n   471→        effect ^= freeEffect[i];\n   472→        fc++;\n   473→      }\n   474→    }\n   475→    firstHalf.push({ effect, freeCount: fc, mask: mask1 });\n   476→  }\n   477→\n   478→  let bestCount = cols + 1;\n   479→  let bestFreeMask = 0;\n   480→\n   481→  for (let mask2 = 0; mask2 < (1 << half2); mask2++) {\n   482→    let s2effect = 0n;\n   483→    let fc2 = 0;\n   484→    for (let i = 0; i < half2; i++) {\n   485→      if (mask2 & (1 << i)) {\n   486→        s2effect ^= freeEffect[half1 + i];\n   487→        fc2++;\n   488→      }\n   489→    }\n   490→\n   491→    if (fc2 >= bestCount) continue;\n   492→\n   493→    const target = basePivot ^ s2effect;\n   494→\n   495→    for (const entry of firstHalf) {\n   496→      const totalFree = entry.freeCount + fc2;\n   497→      if (totalFree >= bestCount) continue;\n   498→\n   499→      const pivotState = target ^ entry.effect;\n   500→      const pc = popcount(pivotState);\n   501→      const total = totalFree + pc;\n   502→\n   503→      if (total < bestCount) {\n   504→        bestCount = total;\n   505→        bestFreeMask = entry.mask | (mask2 << half1);\n   506→      } else if (total === bestCount) {\n   507→        const newMask = entry.mask | (mask2 << half1);\n   508→        // Compare solutions lexicographically\n   509→        const newSol = buildSolution(newMask);\n   510→        const oldSol = buildSolution(bestFreeMask);\n   511→        if (compareLex(indicesToArray(newSol.solution), indicesToArray(oldSol.solution)) < 0) {\n   512→          bestFreeMask = newMask;\n   513→        }\n   514→      }\n   515→    }\n   516→  }\n   517→\n   518→  if (bestCount > cols) return null;\n   519→  const { solution } = buildSolution(bestFreeMask);\n   520→  return indicesToArray(solution);\n   521→}\n   522→\n   523→function indicesToArray(solution: number[]): number[] {\n   524→  const result: number[] = [];\n   525→  for (let i = 0; i < solution.length; i++) {\n   526→    if (solution[i]) result.push(i);\n   527→  }\n   528→  return result;\n   529→}\n   530→\n   531→function compareLex(a: number[], b: number[]): number {\n   532→  const len = Math.max(a.length, b.length);\n   533→  for (let i = 0; i < len; i++) {\n   534→    const va = i < a.length ? a[i] : Infinity;\n   535→    const vb = i < b.length ? b[i] : Infinity;\n   536→    if (va < vb) return -1;\n   537→    if (va > vb) return 1;\n   538→  }\n   539→  return 0;\n   540→}\n   541→\n   542→/**\n   543→ * Solve a counter puzzle over GF(p) using Gaussian elimination.\n   544→ * Find minimum total presses, then lexicographically smallest among ties.\n   545→ */\n   546→export function solveCounter(\n   547→  lights: number[],\n   548→  buttons: number[][],\n   549→  modulus: number\n   550→): number[] | null {\n   551→  const n = lights.length;  // number of counters\n   552→  const m = buttons.length; // number of buttons\n   553→\n   554→  // Build augmented matrix over GF(modulus).\n   555→  // Row i (counter i): sum of x[j] for each button j that affects counter i ≡ lights[i] (mod modulus)\n   556→  // mat[i][j] = 1 if button j affects counter i, 0 otherwise\n   557→  // mat[i][m] = lights[i]\n   558→\n   559→  const mat: number[][] = [];\n   560→  for (let i = 0; i < n; i++) {\n   561→    const row = new Array(m + 1).fill(0);\n   562→    row[m] = ((lights[i] % modulus) + modulus) % modulus;\n   563→    mat.push(row);\n   564→  }\n   565→\n   566→  for (let j = 0; j < m; j++) {\n   567→    for (const counterIdx of buttons[j]) {\n   568→      if (counterIdx >= 0 && counterIdx < n) {\n   569→        mat[counterIdx][j] = (mat[counterIdx][j] + 1) % modulus;\n   570→      }\n   571→    }\n   572→  }\n   573→\n   574→  // Gaussian elimination over GF(modulus)\n   575→  const pivotCol: number[] = new Array(n).fill(-1);\n   576→  let rank = 0;\n   577→\n   578→  // Modular inverse using Fermat's little theorem (modulus is prime)\n   579→  function modInverse(a: number, p: number): number {\n   580→    return modPow(a, p - 2, p);\n   581→  }\n   582→\n   583→  function modPow(base: number, exp: number, mod: number): number {\n   584→    let result = 1;\n   585→    base = ((base % mod) + mod) % mod;\n   586→    while (exp > 0) {\n   587→      if (exp & 1) result = (result * base) % mod;\n   588→      exp >>= 1;\n   589→      base = (base * base) % mod;\n   590→    }\n   591→    return result;\n   592→  }\n   593→\n   594→  for (let col = 0; col < m; col++) {\n   595→    // Find pivot row\n   596→    let found = -1;\n   597→    for (let row = rank; row < n; row++) {\n   598→      if (mat[row][col] !== 0) {\n   599→        found = row;\n   600→        break;\n   601→      }\n   602→    }\n   603→    if (found === -1) continue;\n   604→\n   605→    // Swap rows\n   606→    [mat[rank], mat[found]] = [mat[found], mat[rank]];\n   607→    pivotCol[rank] = col;\n   608→\n   609→    // Scale pivot row so pivot element = 1\n   610→    const inv = modInverse(mat[rank][col], modulus);\n   611→    for (let c = 0; c <= m; c++) {\n   612→      mat[rank][c] = (mat[rank][c] * inv) % modulus;\n   613→    }\n   614→\n   615→    // Eliminate this column from all other rows\n   616→    for (let row = 0; row < n; row++) {\n   617→      if (row !== rank && mat[row][col] !== 0) {\n   618→        const factor = mat[row][col];\n   619→        for (let c = 0; c <= m; c++) {\n   620→          mat[row][c] = (((mat[row][c] - factor * mat[rank][c]) % modulus) + modulus) % modulus;\n   621→        }\n   622→      }\n   623→    }\n   624→\n   625→    rank++;\n   626→  }\n   627→\n   628→  // Check for inconsistency\n   629→  for (let row = rank; row < n; row++) {\n   630→    if (mat[row][m] !== 0) {\n   631→      return null;\n   632→    }\n   633→  }\n   634→\n   635→  // Identify free variables\n   636→  const isFree: boolean[] = new Array(m).fill(true);\n   637→  for (let r = 0; r < rank; r++) {\n   638→    isFree[pivotCol[r]] = false