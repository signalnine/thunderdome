up first-half entries by freeCount, for each freeCount level, we have a set of\n  // effects. We search for the minimum popcount(target XOR s1) among those effects.\n  // We'd do this for freeCount = 0, 1, 2, ..., half1 and find the overall minimum.\n\n  // Finding minimum Hamming distance to a target in a set can be done with tries or just linearly.\n  // With 2^half1 entries and 2^half2 queries, linear scan per query gives 2^(half1+half2) = 2^30 ~ 1B.\n  // Might be tight but doable if the inner loop is simple (just XOR and popcount).\n\n  // Let's try this approach with optimized popcount.\n\n  // Actually, for up to 2^30 total iterations with simple operations, this should work within 5 seconds\n  // in optimized JS. Let's try.\n\n  interface HalfEntry {\n    effect: bigint;\n    freeCount: number;\n    mask: number;\n  }\n\n  const firstHalf: HalfEntry[] = [];\n  for (let mask1 = 0; mask1 < (1 << half1); mask1++) {\n    let effect = 0n;\n    let fc = 0;\n    for (let i = 0; i < half1; i++) {\n      if (mask1 & (1 << i)) {\n        effect ^= freeEffect[i];\n        fc++;\n      }\n    }\n    firstHalf.push({ effect, freeCount: fc, mask: mask1 });\n  }\n\n  let bestCount = cols + 1;\n  let bestFreeMask = 0;\n\n  for (let mask2 = 0; mask2 < (1 << half2); mask2++) {\n    let s2effect = 0n;\n    let fc2 = 0;\n    for (let i = 0; i < half2; i++) {\n      if (mask2 & (1 << i)) {\n        s2effect ^= freeEffect[half1 + i];\n        fc2++;\n      }\n    }\n\n    if (fc2 >= bestCount) continue;\n\n    const target = basePivot ^ s2effect;\n\n    for (const entry of firstHalf) {\n      const totalFree = entry.freeCount + fc2;\n      if (totalFree >= bestCount) continue;\n\n      const pivotState = target ^ entry.effect;\n      const pc = popcount(pivotState);\n      const total = totalFree + pc;\n\n      if (total < bestCount) {\n        bestCount = total;\n        bestFreeMask = entry.mask | (mask2 << half1);\n      } else if (total === bestCount) {\n        const newMask = entry.mask | (mask2 << half1);\n        // Compare solutions lexicographically\n        const newSol = buildSolution(newMask);\n        const oldSol = buildSolution(bestFreeMask);\n        if (compareLex(indicesToArray(newSol.solution), indicesToArray(oldSol.solution)) < 0) {\n          bestFreeMask = newMask;\n        }\n      }\n    }\n  }\n\n  if (bestCount > cols) return null;\n  const { solution } = buildSolution(bestFreeMask);\n  return indicesToArray(solution);\n}\n\nfunction indicesToArray(solution: number[]): number[] {\n  const result: number[] = [];\n  for (let i = 0; i < solution.length; i++) {\n    if (solution[i]) result.push(i);\n  }\n  return result;\n}\n\nfunction compareLex(a: number[], b: number[]): number {\n  const len = Math.max(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    const va = i < a.length ? a[i] : Infinity;\n    const vb = i < b.length ? b[i] : Infinity;\n    if (va < vb) return -1;\n    if (va > vb) return 1;\n  }\n  return 0;\n}\n\n/**\n * Solve a counter puzzle over GF(p) using Gaussian elimination.\n * Find minimum total presses, then lexicographically smallest among ties.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const n = lights.length;  // number of counters\n  const m = buttons.length; // number of buttons\n\n  // Build augmented matrix over GF(modulus).\n  // Row i (counter i): sum of x[j] for each button j that affects counter i ≡ lights[i] (mod modulus)\n  // mat[i][j] = 1 if button j affects counter i, 0 otherwise\n  // mat[i][m] = lights[i]\n\n  const mat: number[][] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Array(m + 1).fill(0);\n    row[m] = ((lights[i] % modulus) + modulus) % modulus;\n    mat.push(row);\n  }\n\n  for (let j = 0; j < m; j++) {\n    for (const counterIdx of buttons[j]) {\n      if (counterIdx >= 0 && counterIdx < n) {\n        mat[counterIdx][j] = (mat[counterIdx][j] + 1) % modulus;\n      }\n    }\n  }\n\n  // Gaussian elimination over GF(modulus)\n  const pivotCol: number[] = new Array(n).fill(-1);\n  let rank = 0;\n\n  // Modular inverse using Fermat's little theorem (modulus is prime)\n  function modInverse(a: number, p: number): number {\n    return modPow(a, p - 2, p);\n  }\n\n  function modPow(base: number, exp: number, mod: number): number {\n    let result = 1;\n    base = ((base % mod) + mod) % mod;\n    while (exp > 0) {\n      if (exp & 1) result = (result * base) % mod;\n      exp >>= 1;\n      base = (base * base) % mod;\n    }\n    return result;\n  }\n\n  for (let col = 0; col < m; col++) {\n    // Find pivot row\n    let found = -1;\n    for (let row = rank; row < n; row++) {\n      if (mat[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    // Swap rows\n    [mat[rank], mat[found]] = [mat[found], mat[rank]];\n    pivotCol[rank] = col;\n\n    // Scale pivot row so pivot element = 1\n    const inv = modInverse(mat[rank][col], modulus);\n    for (let c = 0; c <= m; c++) {\n      mat[rank][c] = (mat[rank][c] * inv) % modulus;\n    }\n\n    // Eliminate this column from all other rows\n    for (let row = 0; row < n; row++) {\n      if (row !== rank && mat[row][col] !== 0) {\n        const factor = mat[row][col];\n        for (let c = 0; c <= m; c++) {\n          mat[row][c] = (((mat[row][c] - factor * mat[rank][c]) % modulus) + modulus) % modulus;\n        }\n      }\n    }\n\n    rank++;\n  }\n\n  // Check for inconsistency\n  for (let row = rank; row < n; row++) {\n    if (mat[row][m] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const isFree: boolean[] = new Array(m).fill(true);\n  for (let r = 0; r < rank; r++) {\n    isFree[pivotCol[r]] = false;\n  }\n\n  const freeVars: number[] = [];\n  for (let c = 0; c < m; c++) {\n    if (isFree[c]) freeVars.push(c);\n  }\n\n  const numFree = freeVars.length;\n\n  // For each free variable, it can take 