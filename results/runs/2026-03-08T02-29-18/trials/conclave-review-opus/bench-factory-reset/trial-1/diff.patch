+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve a toggle puzzle over GF(2) using Gaussian elimination.
+ * Find minimum button presses, then lexicographically smallest among ties.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  // Build augmented matrix over GF(2): mat[light][button] = 1 if button toggles light
+  const mat: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    row[m] = target[i] ? 1 : 0;
+    mat.push(row);
+  }
+
+  for (let j = 0; j < m; j++) {
+    for (const lightIdx of buttons[j]) {
+      if (lightIdx >= 0 && lightIdx < n) {
+        mat[lightIdx][j] ^= 1;
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotCol: number[] = new Array(n).fill(-1);
+  let rank = 0;
+
+  for (let col = 0; col < m; col++) {
+    let found = -1;
+    for (let row = rank; row < n; row++) {
+      if (mat[row][col] === 1) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [mat[rank], mat[found]] = [mat[found], mat[rank]];
+    pivotCol[rank] = col;
+
+    for (let row = 0; row < n; row++) {
+      if (row !== rank && mat[row][col] === 1) {
+        for (let c = 0; c <= m; c++) {
+          mat[row][c] ^= mat[rank][c];
+        }
+      }
+    }
+
+    rank++;
+  }
+
+  // Check for inconsistency
+  for (let row = rank; row < n; row++) {
+    if (mat[row][m] === 1) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const isFree: boolean[] = new Array(m).fill(true);
+  for (let r = 0; r < rank; r++) {
+    isFree[pivotCol[r]] = false;
+  }
+
+  const freeVars: number[] = [];
+  for (let c = 0; c < m; c++) {
+    if (isFree[c]) freeVars.push(c);
+  }
+
+  if (freeVars.length <= 25) {
+    return solveToggleBruteForce(mat, rank, m, pivotCol, freeVars);
+  } else {
+    return solveToggleMeetInMiddle(mat, rank, m, pivotCol, freeVars);
+  }
+}
+
+function solveToggleBruteForce(
+  mat: number[][],
+  rank: number,
+  numButtons: number,
+  pivotCol: number[],
+  freeVars: number[]
+): number[] | null {
+  const numFree = freeVars.length;
+  let bestSolution: number[] | null = null;
+  let bestCount = numButtons + 1;
+
+  for (let mask = 0; mask < (1 << numFree); mask++) {
+    const solution = new Array(numButtons).fill(0);
+
+    let freeCount = 0;
+    for (let i = 0; i < numFree; i++) {
+      if (mask & (1 << i)) {
+        solution[freeVars[i]] = 1;
+        freeCount++;
+      }
+    }
+
+    if (freeCount >= bestCount) continue;
+
+    let totalCount = freeCount;
+    let valid = true;
+    for (let r = rank - 1; r >= 0; r--) {
+      let val = mat[r][numButtons];
+      for (let i = 0; i < numFree; i++) {
+        if (mask & (1 << i)) {
+          val ^= mat[r][freeVars[i]];
+        }
+      }
+      solution[pivotCol[r]] = val;
+      if (val) {
+        totalCount++;
+        if (totalCount >= bestCount) {
+          valid = false;
+          break;
+        }
+      }
+    }
+
+    if (!valid) continue;
+
+    if (totalCount < bestCount) {
+      bestCount = totalCount;
+      bestSolution = solution.slice();
+    } else if (totalCount === bestCount) {
+      const currentIndices = indicesToArray(solution);
+      const bestIndices = indicesToArray(bestSolution!);
+      if (compareLex(currentIndices, bestIndices) < 0) {
+        bestSolution = solution.slice();
+      }
+    }
+  }
+
+  if (bestSolution === null) return null;
+  return indicesToArray(bestSolution);
+}
+
+function solveToggleMeetInMiddle(
+  mat: number[][],
+  rank: number,
+  numButtons: number,
+  pivotCol: number[],
+  freeVars: number[]
+): number[] | null {
+  const numFree = freeVars.length;
+  const half1 = Math.floor(numFree / 2);
+  const half2 = numFree - half1;
+
+  // For each free var, compute its effect on pivot rows as a bitmask
+  const freeEffect: bigint[] = new Array(numFree);
+  for (let i = 0; i < numFree; i++) {
+    let bits = 0n;
+    for (let r = 0; r < rank; r++) {
+      if (mat[r][freeVars[i]]) {
+        bits |= 1n << BigInt(r);
+      }
+    }
+    freeEffect[i] = bits;
+  }
+
+  // Base pivot state (when all free vars are 0)
+  let basePivot = 0n;
+  for (let r = 0; r < rank; r++) {
+    if (mat[r][numButtons]) {
+      basePivot |= 1n << BigInt(r);
+    }
+  }
+
+  function popcount(n: bigint): number {
+    let count = 0;
+    while (n > 0n) {
+      n &= n - 1n;
+      count++;
+    }
+    return count;
+  }
+
+  function buildSolution(freeMask: number): { solution: number[]; count: number } {
+    const solution = new Array(numButtons).fill(0);
+    let pivotState = basePivot;
+    let freeCount = 0;
+
+    for (let i = 0; i < numFree; i++) {
+      if (freeMask & (1 << i)) {
+        solution[freeVars[i]] = 1;
+        freeCount++;
+        pivotState ^= freeEffect[i];
+      }
+    }
+
+    for (let r = 0; r < rank; r++) {
+      if (pivotState & (1n << BigInt(r))) {
+        solution[pivotCol[r]] = 1;
+      }
+    }
+
+    return { solution, count: freeCount + popcount(pivotState) };
+  }
+
+  // Meet-in-the-middle: enumerate both halves and cross-check
+  interface HalfEntry {
+    effect: bigint;
+    freeCount: number;
+    mask: number;
+  }
+
+  const firstHalf: HalfEntry[] = [];
+  for (let mask1 = 0; mask1 < (1 << half1); mask1++) {
+    let effect = 0n;
+    let fc = 0;
+    for (let i = 0; i < half1; i++) {
+      if (mask1 & (1 << i)) {
+        effect ^= freeEffect[i];
+        fc++;
+      }
+    }
+    firstHalf.push({ effect, freeCount: fc, mask: mask1 });
+  }
+
+  let bestCount = numButtons + 1;
+  let bestFreeMask = 0;
+
+  for (let mask2 = 0; mask2 < (1 << half2); mask2++) {
+    let s2effect = 0n;
+    let fc2 = 0;
+    for (let i = 0; i < half2; i++) {
+      if (mask2 & (1 << i)) {
+        s2effect ^= freeEffect[half1 + i];
+        fc2++;
+      }
+    }
+
+    if (fc2 >= bestCount) continue;
+
+    const target = basePivot ^ s2effect;
+
+    for (const entry of firstHalf) {
+      const totalFree = entry.freeCount + fc2;
+      if (totalFree >= bestCount) continue;
+
+      const pivotState = target ^ entry.effect;
+      const pc = popcount(pivotState);
+      const total = totalFree + pc;
+
+      if (total < bestCount) {
+        bestCount = total;
+        bestFreeMask = entry.mask | (mask2 << half1);
+      } else if (total === bestCount) {
+        const newMask = entry.mask | (mask2 << half1);
+        const newSol = buildSolution(newMask);
+        const oldSol = buildSolution(bestFreeMask);
+        if (compareLex(indicesToArray(newSol.solution), indicesToArray(oldSol.solution)) < 0) {
+          bestFreeMask = newMask;
+        }
+      }
+    }
+  }
+
+  if (bestCount > numButtons) return null;
+  const { solution } = buildSolution(bestFreeMask);
+  return indicesToArray(solution);
+}
+
+function indicesToArray(solution: number[]): number[] {
+  const result: number[] = [];
+  for (let i = 0; i < solution.length; i++) {
+    if (solution[i]) result.push(i);
+  }
+  return result;
+}
+
+function compareLex(a: number[], b: number[]): number {
+  const len = Math.max(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    const va = i < a.length ? a[i] : Infinity;
+    const vb = i < b.length ? b[i] : Infinity;
+    if (va < vb) return -1;
+    if (va > vb) return 1;
+  }
+  return 0;
+}
+
+/**
+ * Solve a counter puzzle over GF(p) using Gaussian elimination.
+ * Find minimum total presses, then lexicographically smallest among ties.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+
+  // Build augmented matrix over GF(modulus)
+  const mat: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    row[m] = ((lights[i] % modulus) + modulus) % modulus;
+    mat.push(row);
+  }
+
+  for (let j = 0; j < m; j++) {
+    for (const counterIdx of buttons[j]) {
+      if (counterIdx >= 0 && counterIdx < n) {
+        mat[counterIdx][j] = (mat[counterIdx][j] + 1) % modulus;
+      }
+    }
+  }
+
+  // Gaussian elimination over GF(modulus)
+  const pivotCol: number[] = new Array(n).fill(-1);
+  let rank = 0;
+
+  function modInverse(a: number, p: number): number {
+    return modPow(a, p - 2, p);
+  }
+
+  function modPow(base: number, exp: number, mod: number): number {
+    let result = 1;
+    base = ((base % mod) + mod) % mod;
+    while (exp > 0) {
+      if (exp & 1) result = (result * base) % mod;
+      exp >>= 1;
+      base = (base * base) % mod;
+    }
+    return result;
+  }
+
+  for (let col = 0; col < m; col++) {
+    let found = -1;
+    for (let row = rank; row < n; row++) {
+      if (mat[row][col] !== 0) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [mat[rank], mat[found]] = [mat[found], mat[rank]];
+    pivotCol[rank] = col;
+
+    const inv = modInverse(mat[rank][col], modulus);
+    for (let c = 0; c <= m; c++) {
+      mat[rank][c] = (mat[rank][c] * inv) % modulus;
+    }
+
+    for (let row = 0; row < n; row++) {
+      if (row !== rank && mat[row][col] !== 0) {
+        const factor = mat[row][col];
+        for (let c = 0; c <= m; c++) {
+          mat[row][c] = (((mat[row][c] - factor * mat[rank][c]) % modulus) + modulus) % modulus;
+        }
+      }
+    }
+
+    rank++;
+  }
+
+  // Check for inconsistency
+  for (let row = rank; row < n; row++) {
+    if (mat[row][m] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const isFree: boolean[] = new Array(m).fill(true);
+  for (let r = 0; r < rank; r++) {
+    isFree[pivotCol[r]] = false;
+  }
+
+  const freeVars: number[] = [];
+  for (let c = 0; c < m; c++) {
+    if (isFree[c]) freeVars.push(c);
+  }
+
+  const numFree = freeVars.length;
+
+  // If unique solution, read it off directly
+  if (numFree === 0) {
+    const solution = new Array(m).fill(0);
+    for (let r = 0; r < rank; r++) {
+      solution[pivotCol[r]] = mat[r][m];
+    }
+    return solution;
+  }
+
+  // Determine enumeration strategy based on total combinations
+  let totalCombinations = 1;
+  let overflow = false;
+  for (let i = 0; i < numFree; i++) {
+    totalCombinations *= modulus;
+    if (totalCombinations > 5_000_000) {
+      overflow = true;
+      break;
+    }
+  }
+
+  if (!overflow) {
+    return solveCounterBruteForce(mat, rank, m, modulus, pivotCol, freeVars);
+  }
+
+  return solveCounterBranchAndBound(mat, rank, m, modulus, pivotCol, freeVars);
+}
+
+function computePivotValues(
+  matFree: number[][],
+  matRHS: number[],
+  freeValues: number[],
+  rank: number,
+  numFree: number,
+  modulus: number
+): number[] {
+  const pivotValues: number[] = new Array(rank);
+  for (let r = 0; r < rank; r++) {
+    let val = matRHS[r];
+    for (let i = 0; i < numFree; i++) {
+      val = ((val - (matFree[r][i] * freeValues[i]) % modulus) % modulus + modulus) % modulus;
+    }
+    pivotValues[r] = val;
+  }
+  return pivotValues;
+}
+
+function solveCounterBruteForce(
+  mat: number[][],
+  rank: number,
+  m: number,
+  modulus: number,
+  pivotCol: number[],
+  freeVars: number[]
+): number[] | null {
+  const numFree = freeVars.length;
+
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  const freeValues = new Array(numFree).fill(0);
+
+  const matFree: number[][] = [];
+  for (let r = 0; r < rank; r++) {
+    const row: number[] = [];
+    for (let i = 0; i < numFree; i++) {
+      row.push(mat[r][freeVars[i]]);
+    }
+    matFree.push(row);
+  }
+
+  const matRHS: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    matRHS.push(mat[r][m]);
+  }
+
+  let totalIter = 1;
+  for (let i = 0; i < numFree; i++) totalIter *= modulus;
+
+  for (let iter = 0; iter < totalIter; iter++) {
+    const solution = new Array(m).fill(0);
+    let total = 0;
+
+    for (let i = 0; i < numFree; i++) {
+      solution[freeVars[i]] = freeValues[i];
+      total += freeValues[i];
+    }
+
+    if (total <= bestTotal) {
+      const pivotValues = computePivotValues(matFree, matRHS, freeValues, rank, numFree, modulus);
+      for (let r = 0; r < rank; r++) {
+        solution[pivotCol[r]] = pivotValues[r];
+        total += pivotValues[r];
+      }
+
+      if (total < bestTotal) {
+        bestTotal = total;
+        bestSolution = solution.slice();
+      } else if (total === bestTotal) {
+        if (compareLexArrays(solution, bestSolution!) < 0) {
+          bestSolution = solution.slice();
+        }
+      }
+    }
+
+    // Increment mixed-radix counter
+    for (let i = numFree - 1; i >= 0; i--) {
+      freeValues[i]++;
+      if (freeValues[i] < modulus) break;
+      freeValues[i] = 0;
+    }
+  }
+
+  return bestSolution;
+}
+
+function solveCounterBranchAndBound(
+  mat: number[][],
+  rank: number,
+  m: number,
+  modulus: number,
+  pivotCol: number[],
+  freeVars: number[]
+): number[] | null {
+  const numFree = freeVars.length;
+
+  const matFree: number[][] = [];
+  for (let r = 0; r < rank; r++) {
+    const row: number[] = [];
+    for (let i = 0; i < numFree; i++) {
+      row.push(mat[r][freeVars[i]]);
+    }
+    matFree.push(row);
+  }
+
+  const matRHS: number[] = [];
+  for (let r = 0; r < rank; r++) {
+    matRHS.push(mat[r][m]);
+  }
+
+  // Seed with the all-zeros-for-free-vars solution for initial pruning bound
+  const zeroFree = new Array(numFree).fill(0);
+  const initPivots = computePivotValues(matFree, matRHS, zeroFree, rank, numFree, modulus);
+  const initSolution = new Array(m).fill(0);
+  let bestTotal = 0;
+  for (let r = 0; r < rank; r++) {
+    initSolution[pivotCol[r]] = initPivots[r];
+    bestTotal += initPivots[r];
+  }
+  let bestSolution: number[] | null = initSolution;
+
+  const freeValues = new Array(numFree).fill(0);
+
+  function dfs(idx: number, currentFreeSum: number): void {
+    if (idx === numFree) {
+      const solution = new Array(m).fill(0);
+      let total = currentFreeSum;
+
+      for (let i = 0; i < numFree; i++) {
+        solution[freeVars[i]] = freeValues[i];
+      }
+
+      const pivotValues = computePivotValues(matFree, matRHS, freeValues, rank, numFree, modulus);
+      for (let r = 0; r < rank; r++) {
+        solution[pivotCol[r]] = pivotValues[r];
+        total += pivotValues[r];
+      }
+
+      if (total < bestTotal) {
+        bestTotal = total;
+        bestSolution = solution.slice();
+      } else if (total === bestTotal) {
+        if (compareLexArrays(solution, bestSolution!) < 0) {
+          bestSolution = solution.slice();
+        }
+      }
+      return;
+    }
+
+    if (currentFreeSum > bestTotal) return;
+
+    for (let v = 0; v < modulus; v++) {
+      freeValues[idx] = v;
+      if (currentFreeSum + v <= bestTotal) {
+        dfs(idx + 1, currentFreeSum + v);
+      }
+    }
+    freeValues[idx] = 0;
+  }
+
+  dfs(0, 0);
+  return bestSolution;
+}
+
+function compareLexArrays(a: number[], b: number[]): number {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return -1;
+    if (a[i] > b[i]) return 1;
+  }
+  return 0;
+}
