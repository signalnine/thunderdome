     `);\n   203→      stmt.run(title, body, tags, id);\n   204→\n   205→      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note;\n   206→      res.json({ note });\n   207→    } catch (err) {\n   208→      next(err);\n   209→    }\n   210→  });\n   211→\n   212→  // DELETE /notes/:id - Delete note\n   213→  router.delete('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   214→    try {\n   215→      const id = parseInt(req.params.id);\n   216→      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n   217→\n   218→      if (!existing) {\n   219→        throw new NotFoundError('Note not found');\n   220→      }\n   221→\n   222→      db.prepare('DELETE FROM notes WHERE id = ?').run(id);\n   223→      res.status(204).send();\n   224→    } catch (err) {\n   225→      next(err);\n   226→    }\n   227→  });\n   228→\n   229→  return router;\n   230→}\n   231→"}]},"parent_tool_use_id":null,"session_id":"d3005709-ab89-47ca-8f40-a8619351863a","uuid":"516285f2-6f85-4594-9dc1-ee4d7ebc2b1b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/routes.ts","content":"import { Router, Request, Response, NextFunction } from 'express';\nimport Database from 'better-sqlite3';\nimport { Note, NoteInput, SearchResult, SuggestResult } from './models.js';\nimport { NotFoundError, ValidationError } from './errors.js';\n\nfunction sanitizeFtsQuery(query: string): string {\n  // Preserve quoted phrases\n  const parts: string[] = [];\n  const regex = /\"([^\"]*)\"|(\\S+)/g;\n  let match;\n\n  while ((match = regex.exec(query)) !== null) {\n    if (match[1] !== undefined) {\n      // Quoted phrase — keep quotes\n      parts.push(`\"${match[1]}\"`);\n    } else if (match[2]) {\n      // Single word — strip FTS5 special chars except *\n      const cleaned = match[2].replace(/[^\\w*]/g, '');\n      if (cleaned) {\n        parts.push(cleaned);\n      }\n    }\n  }\n\n  return parts.join(' ') |