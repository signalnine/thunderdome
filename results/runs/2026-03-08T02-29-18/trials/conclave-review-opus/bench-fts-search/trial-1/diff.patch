+function sanitizeFtsQuery(query: string): string {
+  // Preserve quoted phrases, sanitize individual tokens
+  const parts: string[] = [];
+  const regex = /"([^"]*)"|(\S+)/g;
+  let match;
+
+  while ((match = regex.exec(query)) !== null) {
+    if (match[1] !== undefined) {
+      // Quoted phrase — sanitize inner content (strip embedded quotes)
+      const innerCleaned = match[1].replace(/"/g, '');
+      if (innerCleaned.trim()) {
+        parts.push(`"${innerCleaned}"`);
+      }
+    } else if (match[2]) {
+      // Single word — strip FTS5 special chars, disallow lone wildcards
+      const cleaned = match[2].replace(/[^\w]/g, '');
+      if (cleaned) {
+        // Quote FTS5 reserved keywords so they're treated as literals
+        if (FTS5_KEYWORDS.has(cleaned.toLowerCase())) {
+          parts.push(`"${cleaned}"`);
+        } else {
+          parts.push(cleaned);
+        }
+      }
+    }
+  }
+
+  return parts.join(' ') || '""';
+}
