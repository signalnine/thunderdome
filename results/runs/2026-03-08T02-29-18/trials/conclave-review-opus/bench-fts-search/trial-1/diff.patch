+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015yZixWB9sEV8NtZwsemqwQ","type":"tool_result","content":"     1→import { Router, Request, Response, NextFunction } from 'express';\n     2→import Database from 'better-sqlite3';\n     3→import { Note, NoteInput, SearchResult, SuggestResult } from './models.js';\n     4→import { NotFoundError, ValidationError } from './errors.js';\n     5→\n     6→function sanitizeFtsQuery(query: string): string {\n     7→  // Preserve quoted phrases\n     8→  const parts: string[] = [];\n     9→  const regex = /\"([^\"]*)\"|(\\S+)/g;\n    10→  let match;\n    11→\n    12→  while ((match = regex.exec(query)) !== null) {\n    13→    if (match[1] !== undefined) {\n    14→      // Quoted phrase — keep quotes\n    15→      parts.push(`\"${match[1]}\"`);\n    16→    } else if (match[2]) {\n    17→      // Single word — strip FTS5 special chars except *\n    18→      const cleaned = match[2].replace(/[^\\w*]/g, '');\n    19→      if (cleaned) {\n    20→        parts.push(cleaned);\n    21→      }\n    22→    }\n    23→  }\n    24→\n    25→  return parts.join(' ') || '\"\"';\n    26→}\n    27→\n    28→export function createRoutes(db: Database.Database): Router {\n    29→  const router = Router();\n    30→\n    31→  // GET /notes - List all notes (with optional tag filter)\n    32→  router.get('/notes', (req: Request, res: Response, next: NextFunction) => {\n    33→    try {\n    34→      const tag = req.query.tag as string | undefined;\n    35→\n    36→      let notes: Note[];\n    37→      if (tag) {\n    38→        // Use a join with json_each for tag filtering\n    39→        const tagStmt = db.prepare(`\n    40→          SELECT DISTINCT notes.* FROM notes, json_each(notes.tags)\n    41→          WHERE json_each.value = ?\n    42→          ORDER BY created_at DESC\n    43→        `);\n    44→        notes = tagStmt.all(tag) as Note[];\n    45→      } else {\n    46→        const stmt = db.prepare('SELECT * FROM notes ORDER BY created_at DESC');\n    47→        notes = stmt.all() as Note[];\n    48→      }\n    49→\n    50→      res.json({ notes });\n    51→    } catch (err) {\n    52→      next(err);\n    53→    }\n    54→  });\n    55→\n    56→  // GET /notes/search - Full-text search\n    57→  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {\n    58→    try {\n    59→      const q = req.query.q as string | undefined;\n    60→      if (!q || q.trim() === '') {\n    61→        throw new ValidationError('Search query is required');\n    62→      }\n    63→\n    64→      const page = Math.max(1, parseInt(req.query.page as string) || 1);\n    65→      const perPage = 20;\n    66→      const offset = (page - 1) * perPage;\n    67→\n    68→      // Sanitize query for FTS5: strip characters that are FTS5 operators\n    69→      // but preserve quoted phrases\n    70→      const sanitized = sanitizeFtsQuery(q.trim());\n    71→\n    72→      // Count total matching results\n    73→      const countStmt = db.prepare(`\n    74→        SELECT COUNT(*) as total FROM notes_fts WHERE notes_fts MATCH ?\n    75→      `);\n    76→\n    77→      let total = 0;\n    78→      let results: SearchResult[] = [];\n    79→\n    80→      try {\n    81→        total = (countStmt.get(sanitized) as { total: number }).total;\n    82→\n    83→        // Search with BM25 ranking and snippet highlighting\n    84→        const searchStmt = db.prepare(`\n    85→          SELECT\n    86→            notes.id,\n    87→            notes.title,\n    88→            snippet(notes_fts, 1, '<mark>', '</mark>', '...', 32) as snippet,\n    89→            bm25(notes_fts) as rank\n    90→          FROM notes_fts\n    91→          JOIN notes ON notes.id = notes_fts.rowid\n    92→          WHERE notes_fts MATCH ?\n    93→          ORDER BY bm25(notes_fts)\n    94→          LIMIT ? OFFSET ?\n    95→        `);\n    96→\n    97→        results = searchStmt.all(sanitized, perPage, offset) as SearchResult[];\n    98→      } catch {\n    99→        // If FTS query syntax is invalid, return empty results\n   100→        total = 0;\n   101→        results = [];\n   102→      }\n   103→\n   104→      res.json({ results, total, page, perPage });\n   105→    } catch (err) {\n   106→      next(err);\n   107→    }\n   108→  });\n   109→\n   110→  // GET /notes/search/suggest - Autocomplete suggestions\n   111→  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n   112→    try {\n   113→      const q = req.query.q as string | undefined;\n   114→      if (!q || q.trim() === '') {\n   115→        throw new ValidationError('Search query is required');\n   116→      }\n   117→\n   118→      // Use prefix query for autocomplete\n   119→      const prefix = q.trim().replace(/[^\\w\\s]/g, '') + '*';\n   120→\n   121→      let results: SuggestResult[] = [];\n   122→      try {\n   123→        const suggestStmt = db.prepare(`\n   124→          SELECT notes.id, notes.title\n   125→          FROM notes_fts\n   126→          JOIN notes ON notes.id = notes_fts.rowid\n   127→          WHERE notes_fts MATCH ?\n   128→          ORDER BY bm25(notes_fts)\n   129→          LIMIT 5\n   130→        `);\n   131→        results = suggestStmt.all(prefix) as SuggestResult[];\n   132→      } catch {\n   133→        results = [];\n   134→      }\n   135→\n   136→      res.json({ results });\n   137→    } catch (err) {\n   138→      next(err);\n   139→    }\n   140→  });\n   141→\n   142→  // GET /notes/:id - Get single note\n   143→  router.get('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   144→    try {\n   145→      const id = parseInt(req.params.id);\n   146→      const stmt = db.prepare('SELECT * FROM notes WHERE id = ?');\n   147→      const note = stmt.get(id) as Note | undefined;\n   148→\n   149→      if (!note) {\n   150→        throw new NotFoundError('Note not found');\n   151→      }\n   152→\n   153→      res.json({ note });\n   154→    } catch (err) {\n   155→      next(err);\n   156→    }\n   157→  });\n   158→\n   159→  // POST /notes - Create note\n   160→  router.post('/notes', (req: Request, res: Response, next: NextFunction) => {\n   161→    try {\n   162→      const input = req.body as NoteInput;\n   163→\n   164→      if (!input.title || input.title.trim() === '') {\n   165→        throw new ValidationError('Title is required');\n   166→      }\n   167→      if (!input.body || input.body.trim() === '') {\n   168→        throw new ValidationError('Body is required');\n   169→      }\n   170→\n   171→      const tags = input.tags ? JSON.stringify(input.tags) : '[]';\n   172→      const stmt = db.prepare(`\n   173→        INSERT INTO notes (title, body, tags) VALUES (?, ?, ?)\n   174→      `);\n   175→      const result = stmt.run(input.title, input.body, tags);\n   176→\n   177→      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(result.lastInsertRowid) as Note;\n   178→      res.status(201).json({ note });\n   179→    } catch (err) {\n   180→      next(err);\n   181→    }\n   182→  });\n   183→\n   184→  // PUT /notes/:id - Update note\n   185→  router.put('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   186→    try {\n   187→      const id = parseInt(req.params.id);\n   188→      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n   189→\n   190→      if (!existing) {\n   191→        throw new NotFoundError('Note not found');\n   192→      }\n   193→\n   194→      const input = req.body as Partial<NoteInput>;\n   195→      const title = input.title ?? existing.title;\n   196→      const body = input.body ?? existing.body;\n   197→      const tags = input.tags ? JSON.stringify(input.tags) : existing.tags;\n   198→\n   199→      const stmt = db.prepare(`\n   200→        UPDATE notes SET title = ?, body = ?, tags = ?, updated_at = datetime('now')\n   201→        WHERE id = ?\n   202→      `);\n   203→      stmt.run(title, body, tags, id);\n   204→\n   205→      const note = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note;\n   206→      res.json({ note });\n   207→    } catch (err) {\n   208→      next(err);\n   209→    }\n   210→  });\n   211→\n   212→  // DELETE /notes/:id - Delete note\n   213→  router.delete('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   214→    try {\n   215→      const id = parseInt(req.params.id);\n   216→      const existing = db.prepare('SELECT * FROM notes WHERE id = ?').get(id) as Note | undefined;\n   217→\n   218→      if (!existing) {\n   219→        throw new NotFoundError('Note not found');\n   220→      }\n   221→\n   222→      db.prepare('DELETE FROM notes WHERE id = ?').run(id);\n   223→      res.status(204).send();\n   224→    } catch (err) {\n   225→      next(err);\n   226→    }\n   227→  });\n   228→\n   229→  return router;\n   230→}\n   231→"}]},"parent_tool_use_id":"toolu_01PbguX5ZVQR74MfN9QUDE6j","session_id":"d3005709-ab89-47ca-8f40-a8619351863a","uuid":"0144e09b-4807-49a7-bbd3-217f1217c248"}
