earchResult[];\n    98→      } catch {\n    99→        // If FTS query syntax is invalid, return empty results\n   100→        total = 0;\n   101→        results = [];\n   102→      }\n   103→\n   104→      res.json({ results, total, page, perPage });\n   105→    } catch (err) {\n   106→      next(err);\n   107→    }\n   108→  });\n   109→\n   110→  // GET /notes/search/suggest - Autocomplete suggestions\n   111→  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {\n   112→    try {\n   113→      const q = req.query.q as string | undefined;\n   114→      if (!q || q.trim() === '') {\n   115→        throw new ValidationError('Search query is required');\n   116→      }\n   117→\n   118→      // Use prefix query for autocomplete\n   119→      const prefix = q.trim().replace(/[^\\w\\s]/g, '') + '*';\n   120→\n   121→      let results: SuggestResult[] = [];\n   122→      try {\n   123→        const suggestStmt = db.prepare(`\n   124→          SELECT notes.id, notes.title\n   125→          FROM notes_fts\n   126→          JOIN notes ON notes.id = notes_fts.rowid\n   127→          WHERE notes_fts MATCH ?\n   128→          ORDER BY bm25(notes_fts)\n   129→          LIMIT 5\n   130→        `);\n   131→        results = suggestStmt.all(prefix) as SuggestResult[];\n   132→      } catch {\n   133→        results = [];\n   134→      }\n   135→\n   136→      res.json({ results });\n   137→    } catch (err) {\n   138→      next(err);\n   139→    }\n   140→  });\n   141→\n   142→  // GET /notes/:id - Get single note\n   143→  router.get('/notes/:id', (req: Request, res: Response, next: NextFunction) => {\n   144→    try {\n   145→      const id = parseInt(req.params.id);\n   146→      const stmt = db.prepare('SELECT * FROM notes WHERE id = ?');\n   147→      const note = stmt.get(id) as Note | undefined;\n   148→\n   149→      if (!note) {\n   150→        throw new NotFoundError('Note not found');\n   151→      }\n   152→\n   153→      res.js