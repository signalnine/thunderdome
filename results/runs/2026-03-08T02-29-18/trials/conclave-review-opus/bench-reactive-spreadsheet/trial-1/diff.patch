+// --- Cell Reference Utilities ---
+
+function columnToIndex(col: string): number {
+  let index = 0;
+  for (let i = 0; i < col.length; i++) {
+    index = index * 26 + (col.charCodeAt(i) - 64);
+  }
+  return index - 1; // 0-based
+}
+
+function indexToColumn(index: number): string {
+  let col = '';
+  let n = index + 1; // 1-based
+  while (n > 0) {
+    n--;
+    col = String.fromCharCode(65 + (n % 26)) + col;
+    n = Math.floor(n / 26);
+  }
+  return col;
+}
+
+function parseRef(ref: string): { col: number; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: columnToIndex(match[1]), row: parseInt(match[2], 10) - 1 };
+}
+
+function refToString(col: number, row: number): string {
+  return `${indexToColumn(col)}${row + 1}`;
+}
+
+function expandRange(start: string, end: string): string[] {
+  const s = parseRef(start);
+  const e = parseRef(end);
+  const minCol = Math.min(s.col, e.col);
+  const maxCol = Math.max(s.col, e.col);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+  const cells: string[] = [];
+  for (let r = minRow; r <= maxRow; r++) {
+    for (let c = minCol; c <= maxCol; c++) {
+      cells.push(refToString(c, r));
+    }
+  }
+  return cells;
+}
+
+// --- Tokenizer ---
+
+type TokenType =
+  | 'NUMBER'
+  | 'STRING'
+  | 'BOOLEAN'
+  | 'CELL_REF'
+  | 'RANGE'
+  | 'FUNCTION'
+  | 'OPERATOR'
+  | 'COMPARISON'
+  | 'LPAREN'
+  | 'RPAREN'
+  | 'COMMA';
+
+interface Token {
+  type: TokenType;
+  value: string;
+}
+
+function tokenize(formula: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < formula.length) {
+    // Skip whitespace
+    if (formula[i] === ' ' || formula[i] === '\t') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (formula[i] === '"') {
+      let str = '';
+      i++; // skip opening quote
+      while (i < formula.length && formula[i] !== '"') {
+        str += formula[i];
+        i++;
+      }
+      i++; // skip closing quote
+      tokens.push({ type: 'STRING', value: str });
+      continue;
+    }
+
+    // Number
+    if (/\d/.test(formula[i]) || (formula[i] === '.' && i + 1 < formula.length && /\d/.test(formula[i + 1]))) {
+      let num = '';
+      while (i < formula.length && (/\d/.test(formula[i]) || formula[i] === '.')) {
+        num += formula[i];
+        i++;
+      }
+      tokens.push({ type: 'NUMBER', value: num });
+      continue;
+    }
+
+    // Identifiers: cell refs, ranges, functions, booleans
+    if (/[A-Za-z]/.test(formula[i])) {
+      let ident = '';
+      while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+        ident += formula[i];
+        i++;
+      }
+      const upper = ident.toUpperCase();
+
+      // Check for range (IDENT:IDENT)
+      if (i < formula.length && formula[i] === ':') {
+        i++; // skip ':'
+        let ident2 = '';
+        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+          ident2 += formula[i];
+          i++;
+        }
+        tokens.push({ type: 'RANGE', value: `${upper}:${ident2.toUpperCase()}` });
+        continue;
+      }
+
+      // Boolean
+      if (upper === 'TRUE' || upper === 'FALSE') {
+        tokens.push({ type: 'BOOLEAN', value: upper });
+        continue;
+      }
+
+      // Function (followed by '(')
+      if (i < formula.length && formula[i] === '(') {
+        tokens.push({ type: 'FUNCTION', value: upper });
+        continue;
+      }
+
+      // Cell reference
+      if (/^[A-Z]+\d+$/.test(upper)) {
+        tokens.push({ type: 'CELL_REF', value: upper });
+        continue;
+      }
+
+      throw new Error(`Unknown identifier: ${ident}`);
+    }
+
+    // Comparison operators
+    if (formula[i] === '<') {
+      if (i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push({ type: 'COMPARISON', value: '<=' });
+        i += 2;
+        continue;
+      }
+      if (i + 1 < formula.length && formula[i + 1] === '>') {
+        tokens.push({ type: 'COMPARISON', value: '<>' });
+        i += 2;
+        continue;
+      }
+      tokens.push({ type: 'COMPARISON', value: '<' });
+      i++;
+      continue;
+    }
+    if (formula[i] === '>') {
+      if (i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push({ type: 'COMPARISON', value: '>=' });
+        i += 2;
+        continue;
+      }
+      tokens.push({ type: 'COMPARISON', value: '>' });
+      i++;
+      continue;
+    }
+    if (formula[i] === '=') {
+      tokens.push({ type: 'COMPARISON', value: '=' });
+      i++;
+      continue;
+    }
+
+    // Arithmetic operators
+    if ('+-*/'.includes(formula[i])) {
+      tokens.push({ type: 'OPERATOR', value: formula[i] });
+      i++;
+      continue;
+    }
+
+    if (formula[i] === '(') {
+      tokens.push({ type: 'LPAREN', value: '(' });
+      i++;
+      continue;
+    }
+    if (formula[i] === ')') {
+      tokens.push({ type: 'RPAREN', value: ')' });
+      i++;
+      continue;
+    }
+    if (formula[i] === ',') {
+      tokens.push({ type: 'COMMA', value: ',' });
+      i++;
+      continue;
+    }
+
+    throw new Error(`Unexpected character: ${formula[i]}`);
+  }
+
+  return tokens;
+}
+
+// --- AST ---
+
+type ASTNode =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'cell_ref'; ref: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'binary'; op: string; left: ASTNode; right: ASTNode }
+  | { type: 'unary'; op: string; operand: ASTNode }
+  | { type: 'function'; name: string; args: ASTNode[] };
+
+// --- Parser (recursive descent) ---
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    if (this.pos < this.tokens.length) {
+      throw new Error(`Unexpected token: ${this.tokens[this.pos].value}`);
+    }
+    return node;
+  }
+
+  private peek(): Token | undefined {
+    return this.tokens[this.pos];
+  }
+
+  private consume(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  private expect(type: TokenType): Token {
+    const t = this.consume();
+    if (t.type !== type) {
+      throw new Error(`Expected ${type} but got ${t.type}`);
+    }
+    return t;
+  }
+
+  private parseComparison(): ASTNode {
+    let left = this.parseAddSub();
+    while (this.peek()?.type === 'COMPARISON') {
+      const op = this.consume().value;
+      const right = this.parseAddSub();
+      left = { type: 'binary', op, left, right };
+    }
+    return left;
+  }
+
+  private parseAddSub(): ASTNode {
+    let left = this.parseMulDiv();
+    while (this.peek()?.type === 'OPERATOR' && (this.peek()!.value === '+' || this.peek()!.value === '-')) {
+      const op = this.consume().value;
+      const right = this.parseMulDiv();
+      left = { type: 'binary', op, left, right };
+    }
+    return left;
+  }
+
+  private parseMulDiv(): ASTNode {
+    let left = this.parseUnary();
+    while (this.peek()?.type === 'OPERATOR' && (this.peek()!.value === '*' || this.peek()!.value === '/')) {
+      const op = this.consume().value;
+      const right = this.parseUnary();
+      left = { type: 'binary', op, left, right };
+    }
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    if (this.peek()?.type === 'OPERATOR' && (this.peek()!.value === '-' || this.peek()!.value === '+')) {
+      const op = this.consume().value;
+      const operand = this.parseUnary();
+      return { type: 'unary', op, operand };
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const token = this.peek();
+    if (!token) throw new Error('Unexpected end of formula');
+
+    switch (token.type) {
+      case 'NUMBER': {
+        this.consume();
+        return { type: 'number', value: parseFloat(token.value) };
+      }
+      case 'STRING': {
+        this.consume();
+        return { type: 'string', value: token.value };
+      }
+      case 'BOOLEAN': {
+        this.consume();
+        return { type: 'boolean', value: token.value === 'TRUE' };
+      }
+      case 'CELL_REF': {
+        this.consume();
+        return { type: 'cell_ref', ref: token.value };
+      }
+      case 'RANGE': {
+        this.consume();
+        const [start, end] = token.value.split(':');
+        return { type: 'range', start, end };
+      }
+      case 'FUNCTION': {
+        return this.parseFunction();
+      }
+      case 'LPAREN': {
+        this.consume();
+        const expr = this.parseComparison();
+        this.expect('RPAREN');
+        return expr;
+      }
+      default:
+        throw new Error(`Unexpected token: ${token.value}`);
+    }
+  }
+
+  private parseFunction(): ASTNode {
+    const nameToken = this.consume(); // FUNCTION token
+    this.expect('LPAREN');
+    const args: ASTNode[] = [];
+    if (this.peek()?.type !== 'RPAREN') {
+      args.push(this.parseComparison());
+      while (this.peek()?.type === 'COMMA') {
+        this.consume();
+        args.push(this.parseComparison());
+      }
+    }
+    this.expect('RPAREN');
+    return { type: 'function', name: nameToken.value, args };
+  }
+}
+
+function parseFormula(formula: string): ASTNode {
+  const tokens = tokenize(formula);
+  const parser = new Parser(tokens);
+  return parser.parse();
+}
+
+// --- Dependency extraction ---
+
+function extractDependencies(ast: ASTNode): Set<string> {
+  const deps = new Set<string>();
+
+  function walk(node: ASTNode): void {
+    switch (node.type) {
+      case 'cell_ref':
+        deps.add(node.ref);
+        break;
+      case 'range':
+        for (const cell of expandRange(node.start, node.end)) {
+          deps.add(cell);
+        }
+        break;
+      case 'binary':
+        walk(node.left);
+        walk(node.right);
+        break;
+      case 'unary':
+        walk(node.operand);
+        break;
+      case 'function':
+        for (const arg of node.args) {
+          walk(arg);
+        }
+        break;
+      // number, string, boolean have no deps
+    }
+  }
+
+  walk(ast);
+  return deps;
+}
+
+// --- Evaluator ---
+
+type CellValue = string | number | boolean | null;
+
+function evaluate(ast: ASTNode, getCellValue: (ref: string) => CellValue): CellValue {
+  switch (ast.type) {
+    case 'number':
+      return ast.value;
+    case 'string':
+      return ast.value;
+    case 'boolean':
+      return ast.value;
+    case 'cell_ref':
+      return getCellValue(ast.ref);
+    case 'range':
+      throw new Error('Range can only be used as function argument');
+    case 'unary': {
+      const val = evaluate(ast.operand, getCellValue);
+      if (typeof val !== 'number') throw new Error('Unary operator requires numeric operand');
+      return ast.op === '-' ? -val : val;
+    }
+    case 'binary': {
+      const left = evaluate(ast.left, getCellValue);
+      const right = evaluate(ast.right, getCellValue);
+
+      // Comparison operators
+      if (['>', '<', '>=', '<=', '=', '<>'].includes(ast.op)) {
+        const l = left ?? 0;
+        const r = right ?? 0;
+        switch (ast.op) {
+          case '>': return (l as number) > (r as number);
+          case '<': return (l as number) < (r as number);
+          case '>=': return (l as number) >= (r as number);
+          case '<=': return (l as number) <= (r as number);
+          case '=': return l === r;
+          case '<>': return l !== r;
+          default: throw new Error(`Unknown comparison: ${ast.op}`);
+        }
+      }
+
+      // Arithmetic operators
+      const lNum = typeof left === 'number' ? left : (left === null ? 0 : Number(left));
+      const rNum = typeof right === 'number' ? right : (right === null ? 0 : Number(right));
+      switch (ast.op) {
+        case '+': return lNum + rNum;
+        case '-': return lNum - rNum;
+        case '*': return lNum * rNum;
+        case '/':
+          if (rNum === 0) throw new Error('Division by zero');
+          return lNum / rNum;
+        default:
+          throw new Error(`Unknown operator: ${ast.op}`);
+      }
+    }
+    case 'function':
+      return evaluateFunction(ast.name, ast.args, getCellValue);
+  }
+}
+
+function resolveRangeValues(args: ASTNode[], getCellValue: (ref: string) => CellValue): CellValue[] {
+  const values: CellValue[] = [];
+  for (const arg of args) {
+    if (arg.type === 'range') {
+      const cells = expandRange(arg.start, arg.end);
+      for (const cell of cells) {
+        values.push(getCellValue(cell));
+      }
+    } else {
+      values.push(evaluate(arg, getCellValue));
+    }
+  }
+  return values;
+}
+
+function evaluateFunction(name: string, args: ASTNode[], getCellValue: (ref: string) => CellValue): CellValue {
+  switch (name) {
+    case 'SUM': {
+      const values = resolveRangeValues(args, getCellValue);
+      let sum = 0;
+      for (const v of values) {
+        if (typeof v === 'number') sum += v;
+      }
+      return sum;
+    }
+    case 'AVERAGE': {
+      const values = resolveRangeValues(args, getCellValue);
+      let sum = 0;
+      let count = 0;
+      for (const v of values) {
+        if (typeof v === 'number') {
+          sum += v;
+          count++;
+        }
+      }
+      return count === 0 ? 0 : sum / count;
+    }
+    case 'MIN': {
+      const values = resolveRangeValues(args, getCellValue);
+      let min = Infinity;
+      for (const v of values) {
+        if (typeof v === 'number' && v < min) min = v;
+      }
+      return min === Infinity ? 0 : min;
+    }
+    case 'MAX': {
+      const values = resolveRangeValues(args, getCellValue);
+      let max = -Infinity;
+      for (const v of values) {
+        if (typeof v === 'number' && v > max) max = v;
+      }
+      return max === -Infinity ? 0 : max;
+    }
+    case 'COUNT': {
+      const values = resolveRangeValues(args, getCellValue);
+      let count = 0;
+      for (const v of values) {
+        if (typeof v === 'number') count++;
+      }
+      return count;
+    }
+    case 'IF': {
+      if (args.length !== 3) throw new Error('IF requires exactly 3 arguments');
+      const condition = evaluate(args[0], getCellValue);
+      const isTruthy = condition === true || (typeof condition === 'number' && condition !== 0);
+      return isTruthy
+        ? evaluate(args[1], getCellValue)
+        : evaluate(args[2], getCellValue);
+    }
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
+
+// --- Spreadsheet ---
+
+interface CellData {
+  raw: string | number | boolean;
+  formula: ASTNode | null;
+  value: CellValue;
+  dependencies: Set<string>;
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Map from cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+    let formula: ASTNode | null = null;
+    let dependencies = new Set<string>();
+    let computedValue: CellValue;
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaStr = value.substring(1);
+      formula = parseFormula(formulaStr);
+      dependencies = extractDependencies(formula);
+
+      // Check for circular references before updating
+      this.checkCircular(ref, dependencies);
+    }
+
+    // Compute value BEFORE mutating the dependency graph,
+    // so that if evaluation throws, the graph remains consistent.
+    if (formula) {
+      computedValue = evaluate(formula, (r) => this.getInternal(r));
+    } else if (typeof value === 'string') {
+      computedValue = value;
+    } else {
+      computedValue = value;
+    }
+
+    // Remove old dependents tracking
+    const oldCell = this.cells.get(ref);
+    if (oldCell) {
+      for (const dep of oldCell.dependencies) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    // Register new dependents
+    for (const dep of dependencies) {
+      if (!this.dependents.has(dep)) {
+        this.dependents.set(dep, new Set());
+      }
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    this.cells.set(ref, {
+      raw: value,
+      formula,
+      value: computedValue,
+      dependencies,
+    });
+
+    // Reactively update dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = cell.toUpperCase();
+    return this.getInternal(ref);
+  }
+
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    if (typeof value === 'boolean') return value ? 'TRUE' : 'FALSE';
+    return String(value);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  private getInternal(ref: string): CellValue {
+    const cell = this.cells.get(ref);
+    return cell ? cell.value : null;
+  }
+
+  private checkCircular(target: string, newDeps: Set<string>): void {
+    // BFS/DFS: from each dependency, follow transitive dependencies to see if we reach target
+    const visited = new Set<string>();
+    const queue = [...newDeps];
+
+    while (queue.length > 0) {
+      const current = queue.pop()!;
+      if (current === target) {
+        throw new Error(`Circular reference detected involving ${target}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+
+      const cellData = this.cells.get(current);
+      if (cellData) {
+        for (const dep of cellData.dependencies) {
+          queue.push(dep);
+        }
+      }
+    }
+  }
+
+  private propagate(changedCell: string): void {
+    // Topological sort of all transitive dependents, then re-evaluate
+    const order: string[] = [];
+    const visited = new Set<string>();
+
+    const visit = (cell: string): void => {
+      if (visited.has(cell)) return;
+      visited.add(cell);
+      const deps = this.dependents.get(cell);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+      order.push(cell);
+    };
+
+    visit(changedCell);
+    // Reverse to get proper evaluation order (dependencies before dependents)
+    order.reverse();
+
+    // Skip the changed cell itself (already updated), re-evaluate the rest.
+    // Catch per-cell errors so one failure doesn't halt all updates.
+    for (const ref of order) {
+      if (ref === changedCell) continue;
+      const cellData = this.cells.get(ref);
+      if (cellData?.formula) {
+        try {
+          cellData.value = evaluate(cellData.formula, (r) => this.getInternal(r));
+        } catch {
+          cellData.value = null;
+        }
+      }
+    }
+  }
+}
