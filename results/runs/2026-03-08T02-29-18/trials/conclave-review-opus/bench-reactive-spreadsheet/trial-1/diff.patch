formula[i] === ' ' || formula[i] === '\\t') {\n      i++;\n      continue;\n    }\n\n    // String literal\n    if (formula[i] === '\"') {\n      let str = '';\n      i++; // skip opening quote\n      while (i < formula.length && formula[i] !== '\"') {\n        str += formula[i];\n        i++;\n      }\n      i++; // skip closing quote\n      tokens.push({ type: 'STRING', value: str });\n      continue;\n    }\n\n    // Number\n    if (/\\d/.test(formula[i]) || (formula[i] === '.' && i + 1 < formula.length && /\\d/.test(formula[i + 1]))) {\n      let num = '';\n      while (i < formula.length && (/\\d/.test(formula[i]) || formula[i] === '.')) {\n        num += formula[i];\n        i++;\n      }\n      tokens.push({ type: 'NUMBER', value: num });\n      continue;\n    }\n\n    // Identifiers: cell refs, ranges, functions, booleans\n    if (/[A-Za-z]/.test(formula[i])) {\n      let ident = '';\n      while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {\n        ident += formula[i];\n        i++;\n      }\n      const upper = ident.toUpperCase();\n\n      // Check for range (IDENT:IDENT)\n      if (i < formula.length && formula[i] === ':') {\n        i++; // skip ':'\n        let ident2 = '';\n        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {\n          ident2 += formula[i];\n          i++;\n        }\n        tokens.push({ type: 'RANGE', value: `${upper}:${ident2.toUpperCase()}` });\n        continue;\n      }\n\n      // Boolean\n      if (upper === 'TRUE' || upper === 'FALSE') {\n        tokens.push({ type: 'BOOLEAN', value: upper });\n        continue;\n      }\n\n      // Function (followed by '(')\n      if (i < formula.length && formula[i] === '(') {\n        tokens.push({ type: 'FUNCTION', value: upper });\n        continue;\n      }\n\n      // Cell reference\n      if (/^[A-Z]+\\d+$/.test(upper)) {\n        tokens.push({ type: 'CELL_REF', value: upper });\n        continue;\n      }\n\n      throw new Error(`Unknown identifier: 