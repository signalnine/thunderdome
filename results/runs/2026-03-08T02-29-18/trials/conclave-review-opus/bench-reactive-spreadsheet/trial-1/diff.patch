\n  value: CellValue;\n  dependencies: Set<string>;\n}\n\nexport class Spreadsheet {\n  private cells: Map<string, CellData> = new Map();\n  // Map from cell -> set of cells that depend on it\n  private dependents: Map<string, Set<string>> = new Map();\n\n  set(cell: string, value: string | number | boolean): void {\n    const ref = cell.toUpperCase();\n    let formula: ASTNode | null = null;\n    let dependencies = new Set<string>();\n    let computedValue: CellValue;\n\n    if (typeof value === 'string' && value.startsWith('=')) {\n      const formulaStr = value.substring(1);\n      formula = parseFormula(formulaStr);\n      dependencies = extractDependencies(formula);\n\n      // Check for circular references before updating\n      this.checkCircular(ref, dependencies);\n    }\n\n    // Compute value BEFORE mutating the dependency graph,\n    // so that if evaluation throws, the graph remains consistent.\n    if (formula) {\n      computedValue = evaluate(formula, (r) => this.getInternal(r));\n    } else if (typeof value === 'string') {\n      computedValue = value;\n    } else {\n      computedValue = value;\n    }\n\n    // Remove old dependents tracking\n    const oldCell = this.cells.get(ref);\n    if (oldCell) {\n      for (const dep of oldCell.dependencies) {\n        this.dependents.get(dep)?.delete(ref);\n      }\n    }\n\n    // Register new dependents\n    for (const dep of dependencies) {\n      if (!this.dependents.has(dep)) {\n        this.dependents.set(dep, new Set());\n      }\n      this.dependents.get(dep)!.add(ref);\n    }\n\n    this.cells.set(ref, {\n      raw: value,\n      formula,\n      value: computedValue,\n      dependencies,\n    });\n\n    // Reactively update dependents\n    this.propagate(ref);\n  }\n\n  get(cell: string): CellValue {\n    const ref = cell.toUpperCase();\n    return this.getInternal(ref);\n  }\n\n  getDisplay(cell: string): string {\n    const value = this.get(cell);\n    if (value === null) return '';\n    if (typ