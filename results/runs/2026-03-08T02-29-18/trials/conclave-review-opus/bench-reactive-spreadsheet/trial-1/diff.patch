g\n    const oldCell = this.cells.get(ref);\n    if (oldCell) {\n      for (const dep of oldCell.dependencies) {\n        this.dependents.get(dep)?.delete(ref);\n      }\n    }\n\n    // Register new dependents\n    for (const dep of dependencies) {\n      if (!this.dependents.has(dep)) {\n        this.dependents.set(dep, new Set());\n      }\n      this.dependents.get(dep)!.add(ref);\n    }\n\n    // Compute value\n    if (formula) {\n      computedValue = evaluate(formula, (r) => this.getInternal(r));\n    } else if (typeof value === 'string') {\n      computedValue = value;\n    } else {\n      computedValue = value;\n    }\n\n    this.cells.set(ref, {\n      raw: value,\n      formula,\n      value: computedValue,\n      dependencies,\n    });\n\n    // Reactively update dependents\n    this.propagate(ref);\n  }\n\n  get(cell: string): CellValue {\n    const ref = cell.toUpperCase();\n    return this.getInternal(ref);\n  }\n\n  getDisplay(cell: string): string {\n    const value = this.get(cell);\n    if (value === null) return '';\n    if (typeof value === 'boolean') return value ? 'TRUE' : 'FALSE';\n    return String(value);\n  }\n\n  getCells(): Map<string, CellValue> {\n    const result = new Map<string, CellValue>();\n    for (const [ref, data] of this.cells) {\n      result.set(ref, data.value);\n    }\n    return result;\n  }\n\n  private getInternal(ref: string): CellValue {\n    const cell = this.cells.get(ref);\n    return cell ? cell.value : null;\n  }\n\n  private checkCircular(target: string, newDeps: Set<string>): void {\n    // BFS/DFS: from each dependency, follow transitive dependencies to see if we reach target\n    const visited = new Set<string>();\n    const queue = [...newDeps];\n\n    while (queue.length > 0) {\n      const current = queue.pop()!;\n      if (current === target) {\n        throw new Error(`Circular reference detected involving ${target}`);\n      }\n      if (visited.has(current)) continue;\n      visited.add(current);\n\n 