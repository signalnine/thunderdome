uld evaluate division', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 42);\n      sheet.set('A2', 6);\n      sheet.set('A3', '=A1/A2');\n      expect(sheet.get('A3')).toBe(7);\n    });\n\n    it('should handle operator precedence', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 2);\n      sheet.set('A2', 3);\n      sheet.set('A3', 4);\n      sheet.set('B1', '=A1+A2*A3');\n      expect(sheet.get('B1')).toBe(14); // 2 + 3*4 = 14\n    });\n\n    it('should handle parentheses', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 2);\n      sheet.set('A2', 3);\n      sheet.set('B1', '=(A1+A2)*2');\n      expect(sheet.get('B1')).toBe(10);\n    });\n\n    it('should handle unary minus', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=-A1');\n      expect(sheet.get('B1')).toBe(-5);\n    });\n\n    it('should handle number literals in formulas', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+5');\n      expect(sheet.get('B1')).toBe(15);\n    });\n\n    it('should handle references to empty cells as 0', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1+A2');\n      expect(sheet.get('B1')).toBe(10); // A2 is null, treated as 0\n    });\n  });\n\n  describe('comparison operators', () => {\n    it('should evaluate greater than', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 10);\n      sheet.set('B1', '=A1>5');\n      expect(sheet.get('B1')).toBe(true);\n    });\n\n    it('should evaluate less than', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 3);\n      sheet.set('B1', '=A1<5');\n      expect(sheet.get('B1')).toBe(true);\n    });\n\n    it('should evaluate greater than or equal', () => {\n      const sheet = new Spreadsheet();\n      sheet.set('A1', 5);\n      sheet.set('B1', '=A1>=5');\n      expect