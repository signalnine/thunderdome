version: sync1.version,\n    }));\n\n    await ackPromise1;\n\n    // Now client 2 sends its op (also based on version 1)\n    // The server should transform it\n    const ackPromise2 = waitForMessage(ws2, (m) => m.type === 'ack');\n\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      operation: [2, 'Y'],\n      version: sync2.version,\n    }));\n\n    await ackPromise2;\n\n    // Verify the final document state\n    const res = await request(instance.app)\n      .get(`/api/documents/${doc.body.id}`)\n      .expect(200);\n\n    // Both X and Y should be in the result\n    expect(res.body.content).toContain('X');\n    expect(res.body.content).toContain('Y');\n    expect(res.body.content).toContain('a');\n    expect(res.body.content).toContain('b');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should reject invalid operations', async () => {\n    const doc = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Invalid Op Test', content: 'Hello' });\n\n    const { ws } = await connectWs(doc.body.id);\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: 'not-an-array',\n      version: 1,\n    }));\n\n    const error = await waitForMessage(ws, (m) => m.type === 'error');\n    expect(error.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle malformed JSON gracefully', async () => {\n    const doc = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Malformed Test', content: '' });\n\n    const { ws } = await connectWs(doc.body.id);\n\n    ws.send('not valid json {{{');\n\n    const error = await waitForMessage(ws, (m) => m.type === 'error');\n    expect(error.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should reject connection to non-existent document', async () => {\n    return new Promise<void>((resolve, reject) => {\n      const ws = new WebSocket(wsUrl('nonexistent'));\n      const timeout = setTimeout(() => reject(new Error('Timeout')), 5000);\n      ws.on('error', () => {\n        clearTimeout(timeout);\n        resolve();\n      });\n      ws.on('close', () => {\n        clearTimeout(timeout);\n        resolve();\n      });\n      ws.on('open', () => {\n        clearTimeout(timeout);\n        reject(new Error('Should not have connected'));\n      });\n    });\n  });\n\n  it('should handle unknown message type', async () => {\n    const doc = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Unknown Msg Test', content: '' });\n\n    const { ws } = await connectWs(doc.body.id);\n\n    ws.send(JSON.stringify({ type: 'unknown_type' }));\n\n    const error = await waitForMessage(ws, (m) => m.type === 'error');\n    expect(error.message).toContain('Unknown message type');\n\n    ws.close();\n  });\n});\n\ndescribe('Concurrent clients', () => {\n  beforeEach(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterEach(async () => {\n    await instance.stop();\n  });\n\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const doc = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Concurrent Test', content: '' });\n\n    const docId = doc.body.id;\n    const numClients = 10;\n\n    // Connect all clients\n    const clients: { ws: WebSocket; sync: { version: number; clientId: string } }[] = [];\n    for (let i = 0; i < numClients; i++) {\n      const c = await connectWs(docId);\n      clients.push({ ws: c.ws, sync: c.sync });\n    }\n\n    // Each client sequentially sends an insert operation\n    // They each insert their index number as a character\n    for (let i = 0; i < numClients; i++) {\n      const client = clients[i];\n      // Get current document state for this client\n      const res = await request(instance.app).get(`/api/documents/${docId}`);\n      const currentContent = res.body.content;\n\n      // Insert at the end of the current content\n      const op = currentContent.length > 0\n        ? [currentContent.length, String(i)]\n        : [String(i)];\n\n      const ackPromise = waitForMessage(client.ws, (m) => m.type === 'ack');\n\n      // Get the latest version\n      const versionsRes = await request(instance.app).get(`/api/documents/${docId}/versions`);\n      const latestVersion = versionsRes.body.length > 0\n        ? versionsRes.body[versionsRes.body.length - 1].version\n        : 1;\n\n      client.ws.send(JSON.stringify({\n        type: 'operation',\n        operation: op,\n        version: latestVersion,\n      }));\n\n      await ackPromise;\n    }\n\n    // Verify final state\n    const finalRes = await request(instance.app).get(`/api/documents/${docId}`);\n    expect(finalRes.body.content.length).toBe(numClients);\n\n    // All digits 0-9 should be in the content\n    for (let i = 0; i < numClients; i++) {\n      expect(finalRes.body.content).toContain(String(i));\n    }\n\n    // Check versions\n    const versionsRes = await request(instance.app).get(`/api/documents/${docId}/versions`);\n    expect(versionsRes.body.length).toBe(numClients + 1); // initial + 10 ops\n\n    // Clean up\n    for (const client of clients) {\n      client.ws.close();\n    }\n  });\n});\n\ndescribe('Persistence', () => {\n  it('should persist documents across server restarts', async () => {\n    const fs = await import('fs');\n    const os = await import('os');\n    const path = await import('path');\n    const dbPath = path.join(os.tmpdir(), `test-collab-${Date.now()}.db`);\n\n    try {\n      // Start first instance\n      let inst = createApp(dbPath);\n      await inst.start(0);\n\n      await request(inst.app)\n        .post('/api/documents')\n        .send({ title: 'Persistent Doc', content: 'saved content' });\n\n      const docsRes = await request(inst.app).get('/api/documents');\n      const docId = docsRes.body[0].id;\n\n      await inst.stop();\n\n      // Start second instance with same database\n      inst = createApp(dbPath);\n      await inst.start(0);\n\n      const res = await request(inst.app)\n        .get(`/api/documents/${docId}`)\n        .expect(200);\n\n      expect(res.body.title).toBe('Persistent Doc');\n      expect(res.body.content).toBe('saved content');\n\n      await inst.stop();\n    } finally {\n      if (fs.existsSync(dbPath)) fs.unlinkSync(dbPath);\n    }\n  });\n});\n","structuredPatch":[],"originalFile":null}}
