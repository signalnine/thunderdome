+import { describe, it, expect } from 'vitest';
+import { apply, transform, compose, baseLength, targetLength, validateOperation, Operation } from './ot.js';
+
+describe('OT Engine', () => {
+  describe('apply', () => {
+    it('should apply insert at beginning', () => {
+      expect(apply('hello', ['world ', 5])).toBe('world hello');
+    });
+
+    it('should apply insert at end', () => {
+      expect(apply('hello', [5, ' world'])).toBe('hello world');
+    });
+
+    it('should apply insert in middle', () => {
+      expect(apply('helo', [2, 'l', 2])).toBe('hello');
+    });
+
+    it('should apply delete', () => {
+      expect(apply('hello world', [5, -6])).toBe('hello');
+    });
+
+    it('should apply retain only (identity)', () => {
+      expect(apply('hello', [5])).toBe('hello');
+    });
+
+    it('should apply to empty document', () => {
+      expect(apply('', ['hello'])).toBe('hello');
+    });
+
+    it('should apply delete then insert', () => {
+      expect(apply('abc', [-3, 'xyz'])).toBe('xyz');
+    });
+
+    it('should throw on wrong base length', () => {
+      expect(() => apply('hello', [10])).toThrow();
+    });
+  });
+
+  describe('baseLength and targetLength', () => {
+    it('should compute base length correctly', () => {
+      expect(baseLength([3, 'abc', -2])).toBe(5);
+    });
+
+    it('should compute target length correctly', () => {
+      expect(targetLength([3, 'abc', -2])).toBe(6);
+    });
+  });
+
+  describe('transform', () => {
+    it('should handle two inserts at different positions', () => {
+      // Doc: "abc" (length 3)
+      const a: Operation = [1, 'X', 2]; // insert X after position 1: "aXbc"
+      const b: Operation = [2, 'Y', 1]; // insert Y after position 2: "abYc"
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const docA = apply('abc', a);   // "aXbc"
+      const docB = apply('abc', b);   // "abYc"
+      const resultAB = apply(docA, bPrime); // apply b' to doc after a
+      const resultBA = apply(docB, aPrime); // apply a' to doc after b
+      expect(resultAB).toBe(resultBA);
+      // Both inserts should be preserved
+      expect(resultAB).toContain('X');
+      expect(resultAB).toContain('Y');
+    });
+
+    it('should handle two inserts at same position', () => {
+      // Doc: "ab" (length 2)
+      const a: Operation = [1, 'X', 1]; // insert X at position 1
+      const b: Operation = [1, 'Y', 1]; // insert Y at position 1
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const resultAB = apply(apply('ab', a), bPrime);
+      const resultBA = apply(apply('ab', b), aPrime);
+      expect(resultAB).toBe(resultBA);
+      expect(resultAB).toContain('X');
+      expect(resultAB).toContain('Y');
+    });
+
+    it('should handle insert vs delete', () => {
+      // Doc: "abcd" (length 4)
+      const a: Operation = [2, 'X', 2]; // insert X at position 2
+      const b: Operation = [1, -2, 1];  // delete positions 1-2
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const resultAB = apply(apply('abcd', a), bPrime);
+      const resultBA = apply(apply('abcd', b), aPrime);
+      expect(resultAB).toBe(resultBA);
+    });
+
+    it('should handle both deleting same chars', () => {
+      // Doc: "abcd" (length 4)
+      const a: Operation = [1, -2, 1]; // delete "bc"
+      const b: Operation = [1, -2, 1]; // delete "bc"
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const resultAB = apply(apply('abcd', a), bPrime);
+      const resultBA = apply(apply('abcd', b), aPrime);
+      expect(resultAB).toBe(resultBA);
+      expect(resultAB).toBe('ad');
+    });
+
+    it('should throw when base lengths differ', () => {
+      expect(() => transform([3], [5])).toThrow();
+    });
+
+    it('should handle identity operations', () => {
+      const a: Operation = [5]; // retain all
+      const b: Operation = [5]; // retain all
+
+      const [aPrime, bPrime] = transform(a, b);
+      expect(apply(apply('hello', a), bPrime)).toBe('hello');
+      expect(apply(apply('hello', b), aPrime)).toBe('hello');
+    });
+
+    it('should preserve both insertions from concurrent edits', () => {
+      const doc = 'Hello World';
+      // Client A inserts " Beautiful" after "Hello"
+      const a: Operation = [5, ' Beautiful', 6];
+      // Client B inserts " Amazing" at the end
+      const b: Operation = [11, ' Amazing'];
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const resultAB = apply(apply(doc, a), bPrime);
+      const resultBA = apply(apply(doc, b), aPrime);
+      expect(resultAB).toBe(resultBA);
+      expect(resultAB).toContain('Beautiful');
+      expect(resultAB).toContain('Amazing');
+    });
+  });
+
+  describe('compose', () => {
+    it('should compose two operations', () => {
+      const doc = 'hello';
+      const a: Operation = [5, ' world']; // "hello world"
+      const b: Operation = [11, '!'];     // "hello world!"
+
+      const composed = compose(a, b);
+      expect(apply(doc, composed)).toBe('hello world!');
+    });
+
+    it('should throw on mismatched lengths', () => {
+      expect(() => compose([3], [5])).toThrow();
+    });
+  });
+
+  describe('validateOperation', () => {
+    it('should validate a correct operation', () => {
+      expect(validateOperation([3, 'abc', -2], 5)).toBe(true);
+    });
+
+    it('should reject non-array', () => {
+      expect(validateOperation('not an array', 0)).toBe(false);
+    });
+
+    it('should reject wrong base length', () => {
+      expect(validateOperation([3], 5)).toBe(false);
+    });
+
+    it('should reject zero retain', () => {
+      expect(validateOperation([0, 5], 5)).toBe(false);
+    });
+
+    it('should reject empty string insert', () => {
+      expect(validateOperation(['', 5], 5)).toBe(false);
+    });
+
+    it('should reject non-integer numbers', () => {
+      expect(validateOperation([2.5], 2)).toBe(false);
+    });
+  });
+});
