se();\n        server.close((err) => {\n          db.close();\n          if (err) reject(err);\n          else resolve();\n        });\n        // Force close any lingering connections\n        server.closeAllConnections();\n      });\n    },\n  };\n}\n","structuredPatch":[],"originalFile":null}}
