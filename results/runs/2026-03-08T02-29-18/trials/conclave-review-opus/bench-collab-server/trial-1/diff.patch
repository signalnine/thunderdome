     if (typeof content !== 'string') {\n        res.status(400).json({ error: 'content must be a string' });\n        return;\n      }\n      updates.content = content;\n    }\n    const doc = updateDocument(db, req.params.id, updates);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.json(doc);\n  });\n\n  // Partially update a document\n  router.patch('/documents/:id', (req: Request, res: Response) => {\n    const { title, content } = req.body;\n    const updates: { title?: string; content?: string } = {};\n    if (title !== undefined) {\n      if (typeof title !== 'string') {\n        res.status(400).json({ error: 'title must be a string' });\n        return;\n      }\n      updates.title = title;\n    }\n    if (content !== undefined) {\n      if (typeof content !== 'string') {\n        res.status(400).json({ error: 'content must be a string' });\n        return;\n      }\n      updates.content = content;\n    }\n    const doc = updateDocument(db, req.params.id, updates);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.json(doc);\n  });\n\n  // Delete a document\n  router.delete('/documents/:id', (req: Request, res: Response) => {\n    const deleted = deleteDocument(db, req.params.id);\n    if (!deleted) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    res.status(204).send();\n  });\n\n  // Get document version history\n  router.get('/documents/:id/versions', (req: Request, res: Response) => {\n    const doc = getDocument(db, req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versions = getDocumentVersions(db, req.params.id);\n    res.json(versions);\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
