});\n   216→\n   217→    const { ws: ws1, sync: sync1 } = await connectWs(doc.body.id);\n   218→    const { ws: ws2 } = await connectWs(doc.body.id);\n   219→\n   220→    // Client 1 sends an operation\n   221→    const broadcastPromise = waitForMessage(ws2, (m) => m.type === 'operation');\n   222→\n   223→    ws1.send(JSON.stringify({\n   224→      type: 'operation',\n   225→      operation: [2, '!'],\n   226→      version: sync1.version,\n   227→    }));\n   228→\n   229→    const broadcast = await broadcastPromise;\n   230→    expect(broadcast.type).toBe('operation');\n   231→    expect(broadcast.version).toBe(2);\n   232→\n   233→    ws1.close();\n   234→    ws2.close();\n   235→  });\n   236→\n   237→  it('should handle concurrent operations with OT', async () => {\n   238→    const doc = await request(instance.app)\n   239→      .post('/api/documents')\n   240→      .send({ title: 'OT Test', content: 'ab' });\n   241→\n   242→    const { ws: ws1, sync: sync1 } = await connectWs(doc.body.id);\n   243→    const { ws: ws2, sync: sync2 } = await connectWs(doc.body.id);\n   244→\n   245→    // Both clients based on version 1, content \"ab\"\n   246→    // Client 1: insert \"X\" at position 1 → \"aXb\"\n   247→    // Client 2: insert \"Y\" at position 2 → \"abY\"\n   248→    const ackPromise1 = waitForMessage(ws1, (m) => m.type === 'ack');\n   249→\n   250→    ws1.send(JSON.stringify({\n   251→      type: 'operation',\n   252→      operation: [1, 'X', 1],\n   253→      version: sync1.version,\n   254→    }));\n   255→\n   256→    await ackPromise1;\n   257→\n   258→    // Now client 2 sends its op (also based on version 1)\n   259→    // The server should transform it\n   260→    const ackPromise2 = waitForMessage(ws2, (m) => m.type === 'ack');\n   261→\n   262→    ws2.send(JSON.stringify({\n   263→      type: 'operation',\n   264→      operation: [2, 'Y'],\n   265→      version: sync2.version,\n   266→    }));\n   267→\n   268→    await ackPromise2;\n   269→\n   270→    // Verify the final document state\n   271→    const res = await request(instance.app)\n   272→      .get(`/api/documents/${doc.body.id}`)\n   273→      .expect(200);\n   274→\n   275→    // Both X and Y should be in the result\n   276→    expect(res.body.content).toContain('X');\n   277→    expect(res.body.content).toContain('Y');\n   278→    expect(res.body.content).toContain('a');\n   279→    expect(res.body.content).toContain('b');\n   280→\n   281→    ws1.close();\n   282→    ws2.close();\n   283→  });\n   284→\n   285→  it('should reject invalid operations', async () => {\n   286→    const doc = await request(instance.app)\n   287→      .post('/api/documents')\n   288→      .send({ title: 'Invalid Op Test', content: 'Hello' });\n   289→\n   290→    const { ws } = await connectWs(doc.body.id);\n   291→\n   292→    ws.send(JSON.stringify({\n   293→      type: 'operation',\n   294→      operation: 'not-an-array',\n   295→      version: 1,\n   296→    }));\n   297→\n   298→    const error = await waitForMessage(ws, (m) => m.type === 'error');\n   299→    expect(error.type).toBe('error');\n   300→\n   301→    ws.close();\n   302→  });\n   303→\n   304→  it('should handle malformed JSON gracefully', async () => {\n   305→    const doc = await request(instance.app)\n   306→      .post('/api/documents')\n   307→      .send({ title: 'Malformed Test', content: '' });\n   308→\n   309→    const { ws } = await connectWs(doc.body.id);\n   310→\n   311→    ws.send('not valid json {{{');\n   312→\n   313→    const error = await waitForMessage(ws, (m) => m.type === 'error');\n   314→    expect(error.type).toBe('error');\n   315→\n   316→    ws.close();\n   317→  });\n   318→\n   319→  it('should reject connection to non-existent document', async () => {\n   320→    return new Promise<void>((resolve, reject) => {\n   321→      const ws = new WebSocket(wsUrl('nonexistent'));\n   322→      const timeout = setTimeout(() => reject(new Error('Timeout')), 5000);\n   323→      ws.on('error', () => {\n   324→        clearTimeout(timeout);\n   325→        resolve();\n   326→      });\n   327→      ws.on('close', () => {\n   328→        clearTimeout(timeout);\n   329→        resolve();\n   330→      });\n   331→      ws.on('open', () => {\n   332→        clearTimeout(timeout);\n   333→        reject(new Error('Should not have connected'));\n   334→      });\n   335→    });\n   336→  });\n   337→\n   338→  it('should handle unknown message type', async () => {\n   339→    const doc = await request(instance.app)\n   340→      .post('/api/documents')\n   341→      .send({ title: 'Unknown Msg Test', content: '' });\n   342→\n   343→    const { ws } = await connectWs(doc.body.id);\n   344→\n   345→    ws.send(JSON.stringify({ type: 'unknown_type' }));\n   346→\n   347→    const error = await waitForMessage(ws, (m) => m.type === 'error');\n   348→    expect(error.message).toContain('Unknown message type');\n   349→\n   350→    ws.close();\n   351→  });\n   352→});\n   353→\n   354→describe('Concurrent clients', () => {\n   355→  beforeEach(async () => {\n   356→    instance = createApp();\n   357→    port = await instance.start(0);\n   358→  });\n   359→\n   360→  afterEach(async () => {\n   361→    await instance.stop();\n   362→  });\n   363→\n   364→  it('should handle 10 concurrent clients without corruption', async () => {\n   365→    const doc = await request(instance.app)\n   366→      .post('/api/documents')\n   367→      .send({ title: 'Concurrent Test', content: '' });\n   368→\n   369→    const docId = doc.body.id;\n   370→    const numClients = 10;\n   371→\n   372→    // Connect all clients\n   373→    const clients: { ws: WebSocket; sync: { version: number; clientId: string } }[] = [];\n   374→    for (let i = 0; i < numClients; i++) {\n   375→      const c = await connectWs(docId);\n   376→      clients.push({ ws: c.ws, sync: c.sync });\n   377→    }\n   378→\n   379→    // Each client sequentially sends an insert operation\n   380→