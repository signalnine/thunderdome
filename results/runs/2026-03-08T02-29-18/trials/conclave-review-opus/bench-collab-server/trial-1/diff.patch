retain\n        result += doc.slice(pos, pos + c);\n        pos += c;\n      } else {\n        // delete\n        pos += Math.abs(c);\n      }\n    } else {\n      // insert\n      result += c;\n    }\n  }\n\n  return result;\n}\n\n/**\n * Compose two consecutive operations into one.\n * apply(apply(doc, a), b) === apply(doc, compose(a, b))\n */\nexport function compose(a: Operation, b: Operation): Operation {\n  if (targetLength(a) !== baseLength(b)) {\n    throw new Error('Compose: target length of a must equal base length of b');\n  }\n\n  const result: Operation = [];\n  let ia = 0;\n  let ib = 0;\n  let aComp: OpComponent | undefined = a[ia];\n  let bComp: OpComponent | undefined = b[ib];\n\n  function push(c: OpComponent) {\n    if (typeof c === 'number' && c === 0) return;\n    if (result.length > 0) {\n      const last = result[result.length - 1];\n      if (typeof c === 'number' && typeof last === 'number') {\n        if ((c > 0 && last > 0) || (c < 0 && last < 0)) {\n          result[result.length - 1] = last + c;\n          return;\n        }\n      } else if (typeof c === 'string' && typeof last === 'string') {\n        result[result.length - 1] = last + c;\n        return;\n      }\n    }\n    result.push(c);\n  }\n\n  while (aComp !== undefined || bComp !== undefined) {\n    // Delete from A takes priority\n    if (typeof aComp === 'number' && aComp < 0) {\n      push(aComp);\n      ia++;\n      aComp = a[ia];\n      continue;\n    }\n    // Insert from B takes priority\n    if (typeof bComp === 'string') {\n      push(bComp);\n      ib++;\n      bComp = b[ib];\n      continue;\n    }\n\n    if (aComp === undefined || bComp === undefined) {\n      throw new Error('Compose: operation length mismatch');\n    }\n\n    // Both retain\n    if (typeof aComp === 'number' && aComp > 0 && typeof bComp === 'number' && bComp > 0) {\n      const min = Math.min(aComp, bComp);\n      push(min);\n      if (aComp === min) { ia++; aComp = a[ia]; } else { aComp = aComp 