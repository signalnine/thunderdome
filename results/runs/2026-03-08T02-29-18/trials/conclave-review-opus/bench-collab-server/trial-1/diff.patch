ct(201);\n\n    expect(res.body).toMatchObject({\n      title: 'Test Doc',\n      content: 'Hello',\n    });\n    expect(res.body.id).toBeDefined();\n  });\n\n  it('should list documents', async () => {\n    await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Doc 1' });\n    await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Doc 2' });\n\n    const res = await request(instance.app)\n      .get('/api/documents')\n      .expect(200);\n\n    expect(res.body.length).toBe(2);\n  });\n\n  it('should get a document by id', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Test', content: 'content' });\n\n    const res = await request(instance.app)\n      .get(`/api/documents/${created.body.id}`)\n      .expect(200);\n\n    expect(res.body.title).toBe('Test');\n    expect(res.body.content).toBe('content');\n  });\n\n  it('should return 404 for missing document', async () => {\n    await request(instance.app)\n      .get('/api/documents/nonexistent')\n      .expect(404);\n  });\n\n  it('should update a document', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Original' });\n\n    const res = await request(instance.app)\n      .put(`/api/documents/${created.body.id}`)\n      .send({ title: 'Updated', content: 'New content' })\n      .expect(200);\n\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('New content');\n  });\n\n  it('should patch a document', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Original', content: 'content' });\n\n    const res = await request(instance.app)\n      .patch(`/api/documents/${created.body.id}`)\n      .send({ title: 'Patched' })\n      .expect(200);\n\n    expect(res.body.title).toBe('Patched');\n    expect(res.body.content).toBe('content');\n  });\n\n  it('should delete a document', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'To Delete' });\n\n    await request(instance.app)\n      .delete(`/api/documents/${created.body.id}`)\n      .expect(204);\n\n    await request(instance.app)\n      .get(`/api/documents/${created.body.id}`)\n      .expect(404);\n  });\n\n  it('should get version history', async () => {\n    const created = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Versioned', content: 'v1' });\n\n    const res = await request(instance.app)\n      .get(`/api/documents/${created.body.id}/versions`)\n      .expect(200);\n\n    expect(res.body.length).toBe(1);\n    expect(res.body[0].version).toBe(1);\n    expect(res.body[0].content).toBe('v1');\n  });\n\n  it('should reject document creation without title', async () => {\n    await request(instance.app)\n      .post('/api/documents')\n      .send({ content: 'no title' })\n      .expect(400);\n  });\n});\n\ndescribe('WebSocket Collaboration', () => {\n  beforeEach(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterEach(async () => {\n    await instance.stop();\n  });\n\n  it('should send sync message on connection', async () => {\n    const doc = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'WS Test', content: 'Hello' });\n\n    const { ws, sync } = await connectWs(doc.body.id);\n    expect(sync.content).toBe('Hello');\n    expect(sync.version).toBe(1);\n    expect(sync.clientId).toBeDefined();\n    ws.close();\n  });\n\n  it('should apply operations and acknowledge', async () => {\n    const doc = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Op Test', content: 'Hello' });\n\n    const { ws, sync } = await connectWs(doc.body.id);\n\n    // Insert \" World\" at the end\n    const op = [5, ' World'];\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: op,\n      version: sync.version,\n    }));\n\n    const ack = await waitForMessage(ws, (m) => m.type === 'ack');\n    expect(ack.type).toBe('ack');\n    expect(ack.version).toBe(2);\n\n    // Verify via REST\n    const res = await request(instance.app)\n      .get(`/api/documents/${doc.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe('Hello World');\n\n    ws.close();\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const doc = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Broadcast Test', content: 'Hi' });\n\n    const { ws: ws1, sync: sync1 } = await connectWs(doc.body.id);\n    const { ws: ws2 } = await connectWs(doc.body.id);\n\n    // Client 1 sends an operation\n    const broadcastPromise = waitForMessage(ws2, (m) => m.type === 'operation');\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: [2, '!'],\n      version: sync1.version,\n    }));\n\n    const broadcast = await broadcastPromise;\n    expect(broadcast.type).toBe('operation');\n    expect(broadcast.version).toBe(2);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should handle concurrent operations with OT', async () => {\n    const doc = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'OT Test', content: 'ab' });\n\n    const { ws: ws1, sync: sync1 } = await connectWs(doc.body.id);\n    const { ws: ws2, sync: sync2 } = await connectWs(doc.body.id);\n\n    // Both clients based on version 1, content \"ab\"\n    // Client 1: insert \"X\" at position 1 → \"aXb\"\n    // Client 2: insert \"Y\" at position 2 → \"abY\"\n    const ackPromise1 = waitForMessage(ws1, (m) => m.type === 'ack');\n\n    ws1.send(JSON.stringify({\n      type: 'operation',\n      operation: [1, 'X', 1],\n      version: sync1.version,\n    }));\n\n    await ackPromise1;\n\n    // Now client 2 sends its op (also based on version 1)\n    // The server should transform it\n    const ackPromise2 = waitForMessage(ws2, (m) => m.type === 'ack');\n\n    ws2.send(JSON.stringify({\n      type: 'operation',\n      operation: [2, 'Y'],\n      version: sync2.version,\n    }));\n\n    await ackPromise2;\n\n    // Verify the final document state\n    const res = await request(instance.app)\n      .get(`/api/documents/${doc.body.id}`)\n      .expect(200);\n\n    // Both X and Y should be in the result\n    expect(res.body.content).toContain('X');\n    expect(res.body.content).toContain('Y');\n    expect(res.body.content).toContain('a');\n    expect(res.body.content).toContain('b');\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it('should reject invalid operations', async () => {\n    const doc = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Invalid Op Test', content: 'Hello' });\n\n    const { ws } = await connectWs(doc.body.id);\n\n    ws.send(JSON.stringify({\n      type: 'operation',\n      operation: 'not-an-array',\n      version: 1,\n    }));\n\n    const error = await waitForMessage(ws, (m) => m.type === 'error');\n    expect(error.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should handle malformed JSON gracefully', async () => {\n    const doc = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Malformed Test', content: '' });\n\n    const { ws } = await connectWs(doc.body.id);\n\n    ws.send('not valid json {{{');\n\n    const error = await waitForMessage(ws, (m) => m.type === 'error');\n    expect(error.type).toBe('error');\n\n    ws.close();\n  });\n\n  it('should reject connection to non-existent document', async () => {\n    return new Promise<void>((resolve, reject) => {\n      const ws = new WebSocket(wsUrl('nonexistent'));\n      const timeout = setTimeout(() => reject(new Error('Timeout')), 5000);\n      ws.on('error', () => {\n        clearTimeout(timeout);\n        resolve();\n      });\n      ws.on('close', () => {\n        clearTimeout(timeout);\n        resolve();\n      });\n      ws.on('open', () => {\n        clearTimeout(timeout);\n        reject(new Error('Should not have connected'));\n      });\n    });\n  });\n\n  it('should handle unknown message type', async () => {\n    const doc = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Unknown Msg Test', content: '' });\n\n    const { ws } = await connectWs(doc.body.id);\n\n    ws.send(JSON.stringify({ type: 'unknown_type' }));\n\n    const error = await waitForMessage(ws, (m) => m.type === 'error');\n    expect(error.message).toContain('Unknown message type');\n\n    ws.close();\n  });\n});\n\ndescribe('Concurrent clients', () => {\n  beforeEach(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n  });\n\n  afterEach(async () => {\n    await instance.stop();\n  });\n\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const doc = await request(instance.app)\n      .post('/api/documents')\n      .send({ title: 'Concurrent Test', content: '' });\n\n    const docId = doc.body.id;\n    const numClients = 10;\n\n    // Connect all clients\n    const clients: { ws: WebSocket; sync: { version: number; clientId: string } }[] = [];\n    for (let i = 0; i < numClients; i++) {\n      const c = await connectWs(docId);\n      clients.push({ ws: c.ws, sync: c.sync });\n    }\n\n    // Each client sequentially sends an insert operation\n    // They each insert their index number as a character\n    for (let i = 0; i < numClients; i++) {\n      const client = clients[i];\n      // Get current document state for this client\n      const res = await request(instance.app).get(`/api/documents/${docId}`);\n      const currentContent = res.body.content;\n\n      // Insert at the end of the current content\n      const op = currentContent.length > 0\n        ? [currentContent.length, String(i)]\n        : [String(i)];\n\n      const ackPromise = waitForMessage(client.ws, (m) => m.type === 'ack');\n\n      // Get the latest version\n      const versionsRes = await request(instance.app).get(`/api/documents/${docId}/versions`);\n      const latestVersion = versionsRes.body.length > 0\n        ? versionsRes.body[versionsRes.body.length - 1].version\n        : 1;\n\n      client.ws.send(JSON.stringify({\n        type: 'operation',\n        operation: op,\n        version: latestVersion,\n      }));\n\n      await ackPromise;\n    }\n\n    // Verify final state\n    const finalRes = await request(instance.app).get(`/api/documents/${docId}`);\n    expect(finalRes.body.content.length).toBe(numClients);\n\n    // All digits 0-9 should be in the content\n    for (let i = 0; i < numClients; i++) {\n      expect(finalRes.body.content).toContain(String(i));\n    }\n\n    // Check versions\n    const versionsRes = await request(instance.app).get(`/api/documents/${docId}/versions`);\n    expect(versionsRes.body.length).toBe(numClients + 1); // initial + 10 ops\n\n    // Clean up\n    for (const client of clients) {\n      client.ws.close();\n    }\n  });\n});\n\ndescribe('Persistence', () => {\n  it('should persist documents across server restarts', async () => {\n    const fs = await import('fs');\n    const os = await import('os');\n    const path = await import('path');\n    const dbPath = path.join(os.tmpdir(), `test-collab-${Date.now()}.db`);\n\n    try {\n      // Start first instance\n      let inst = createApp(dbPath);\n      await inst.start(0);\n\n      await request(inst.app)\n        .post('/api/documents')\n        .send({ title: 'Persistent Doc', content: 'saved content' });\n\n      const docsRes = await request(inst.app).get('/api/documents');\n      const docId = docsRes.body[0].id;\n\n      await inst.stop();\n\n      // Start second instance with same database\n      inst = createApp(dbPath);\n      await inst.start(0);\n\n      const res = await request(inst.app)\n        .get(`/api/documents/${docId}`)\n 