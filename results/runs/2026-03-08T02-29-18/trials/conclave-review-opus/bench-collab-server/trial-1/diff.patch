+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VNxKGxeF734wjxcZbfsAmE","type":"tool_result","content":"     1→import Database from 'better-sqlite3';\n     2→import { randomUUID } from 'crypto';\n     3→import * as fs from 'fs';\n     4→import * as path from 'path';\n     5→import { fileURLToPath } from 'url';\n     6→\n     7→const __filename = fileURLToPath(import.meta.url);\n     8→const __dirname = path.dirname(__filename);\n     9→\n    10→export interface Document {\n    11→  id: string;\n    12→  title: string;\n    13→  content: string;\n    14→  created_at: string;\n    15→  updated_at: string;\n    16→}\n    17→\n    18→export interface Version {\n    19→  id: number;\n    20→  document_id: string;\n    21→  version: number;\n    22→  content: string;\n    23→  operation: string | null;\n    24→  created_at: string;\n    25→}\n    26→\n    27→export function createDatabase(dbPath?: string): Database.Database {\n    28→  const db = new Database(dbPath || ':memory:');\n    29→  db.pragma('journal_mode = WAL');\n    30→  db.pragma('foreign_keys = ON');\n    31→\n    32→  const schemaPath = path.resolve(__dirname, '..', 'schema.sql');\n    33→  const schema = fs.readFileSync(schemaPath, 'utf-8');\n    34→  db.exec(schema);\n    35→\n    36→  return db;\n    37→}\n    38→\n    39→export function createDocument(db: Database.Database, title: string, content: string = ''): Document {\n    40→  const id = randomUUID();\n    41→  const stmt = db.prepare(\n    42→    'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'\n    43→  );\n    44→  stmt.run(id, title, content);\n    45→\n    46→  // Create initial version\n    47→  db.prepare(\n    48→    'INSERT INTO versions (document_id, version, content, operation) VALUES (?, 1, ?, NULL)'\n    49→  ).run(id, content);\n    50→\n    51→  return getDocument(db, id)!;\n    52→}\n    53→\n    54→export function getDocument(db: Database.Database, id: string): Document | undefined {\n    55→  return db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as Document | undefined;\n    56→}\n    57→\n    58→export function listDocuments(db: Database.Database): Document[] {\n    59→  return db.prepare('SELECT * FROM documents ORDER BY updated_at DESC').all() as Document[];\n    60→}\n    61→\n    62→export function updateDocument(\n    63→  db: Database.Database,\n    64→  id: string,\n    65→  updates: { title?: string; content?: string }\n    66→): Document | undefined {\n    67→  const doc = getDocument(db, id);\n    68→  if (!doc) return undefined;\n    69→\n    70→  const title = updates.title ?? doc.title;\n    71→  const content = updates.content ?? doc.content;\n    72→\n    73→  db.prepare(\n    74→    \"UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?\"\n    75→  ).run(title, content, id);\n    76→\n    77→  return getDocument(db, id);\n    78→}\n    79→\n    80→export function deleteDocument(db: Database.Database, id: string): boolean {\n    81→  const result = db.prepare('DELETE FROM documents WHERE id = ?').run(id);\n    82→  return result.changes > 0;\n    83→}\n    84→\n    85→export function getDocumentVersions(db: Database.Database, documentId: string): Version[] {\n    86→  return db.prepare(\n    87→    'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'\n    88→  ).all(documentId) as Version[];\n    89→}\n    90→\n    91→export function getLatestVersion(db: Database.Database, documentId: string): number {\n    92→  const row = db.prepare(\n    93→    'SELECT MAX(version) as max_version FROM versions WHERE document_id = ?'\n    94→  ).get(documentId) as { max_version: number | null };\n    95→  return row?.max_version ?? 0;\n    96→}\n    97→\n    98→export function addVersion(\n    99→  db: Database.Database,\n   100→  documentId: string,\n   101→  content: string,\n   102→  operation: object | null\n   103→): Version {\n   104→  const nextVersion = getLatestVersion(db, documentId) + 1;\n   105→  const opJson = operation ? JSON.stringify(operation) : null;\n   106→\n   107→  db.prepare(\n   108→    'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'\n   109→  ).run(documentId, nextVersion, content, opJson);\n   110→\n   111→  // Also update the document content\n   112→  db.prepare(\n   113→    \"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"\n   114→  ).run(content, documentId);\n   115→\n   116→  return db.prepare(\n   117→    'SELECT * FROM versions WHERE document_id = ? AND version = ?'\n   118→  ).get(documentId, nextVersion) as Version;\n   119→}\n   120→"}]},"parent_tool_use_id":"toolu_013rkWmSE5uGcwtL379e38kb","session_id":"4d85a3d6-1f98-4d05-b9ee-7f9aefd9ea76","uuid":"a6fcea4c-2535-4034-875f-20e920d52223"}
