+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wnx4b67eH9Ap39qEJkofqs","type":"tool_result","content":"     1→import { WebSocketServer, WebSocket } from 'ws';\n     2→import { IncomingMessage } from 'http';\n     3→import { Server } from 'http';\n     4→import Database from 'better-sqlite3';\n     5→import { randomUUID } from 'crypto';\n     6→import { getDocument, addVersion, getLatestVersion } from './db.js';\n     7→import { Operation, apply, transform, validateOperation } from './ot.js';\n     8→\n     9→interface ClientConnection {\n    10→  ws: WebSocket;\n    11→  clientId: string;\n    12→  docId: string;\n    13→}\n    14→\n    15→interface DocumentState {\n    16→  content: string;\n    17→  version: number;\n    18→  clients: Map<string, ClientConnection>;\n    19→}\n    20→\n    21→export interface WsMessage {\n    22→  type: string;\n    23→  [key: string]: unknown;\n    24→}\n    25→\n    26→export interface OperationMsg {\n    27→  type: 'operation';\n    28→  operation: Operation;\n    29→  version: number;\n    30→  clientId?: string;\n    31→}\n    32→\n    33→export interface SyncMsg {\n    34→  type: 'sync';\n    35→  content: string;\n    36→  version: number;\n    37→  clientId: string;\n    38→}\n    39→\n    40→export interface AckMsg {\n    41→  type: 'ack';\n    42→  version: number;\n    43→}\n    44→\n    45→export interface ErrorMsg {\n    46→  type: 'error';\n    47→  message: string;\n    48→}\n    49→\n    50→export class CollaborationServer {\n    51→  private wss: WebSocketServer;\n    52→  private documents: Map<string, DocumentState> = new Map();\n    53→  private db: Database.Database;\n    54→  // History of operations per document indexed by version they produced\n    55→  // operationHistory[docId][version] = operation that transformed doc from version-1 to version\n    56→  private operationHistory: Map<string, Map<number, Operation>> = new Map();\n    57→\n    58→  constructor(server: Server, db: Database.Database) {\n    59→    this.db = db;\n    60→    this.wss = new WebSocketServer({ noServer: true });\n    61→\n    62→    server.on('upgrade', (request: IncomingMessage, socket, head) => {\n    63→      const url = new URL(request.url || '/', `http://${request.headers.host || 'localhost'}`);\n    64→      const pathMatch = url.pathname.match(/^\\/ws\\/documents\\/([^/]+)$/);\n    65→\n    66→      if (!pathMatch) {\n    67→        socket.destroy();\n    68→        return;\n    69→      }\n    70→\n    71→      const docId = pathMatch[1];\n    72→      const doc = getDocument(this.db, docId);\n    73→      if (!doc) {\n    74→        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n    75→        socket.destroy();\n    76→        return;\n    77→      }\n    78→\n    79→      this.wss.handleUpgrade(request, socket, head, (ws) => {\n    80→        this.handleConnection(ws, docId);\n    81→      });\n    82→    });\n    83→  }\n    84→\n    85→  private getOrLoadDocumentState(docId: string): DocumentState | null {\n    86→    let state = this.documents.get(docId);\n    87→    if (!state) {\n    88→      const doc = getDocument(this.db, docId);\n    89→      if (!doc) return null;\n    90→      const version = getLatestVersion(this.db, docId);\n    91→      state = {\n    92→        content: doc.content,\n    93→        version,\n    94→        clients: new Map(),\n    95→      };\n    96→      this.documents.set(docId, state);\n    97→      this.operationHistory.set(docId, new Map());\n    98→    }\n    99→    return state;\n   100→  }\n   101→\n   102→  private handleConnection(ws: WebSocket, docId: string) {\n   103→    const state = this.getOrLoadDocumentState(docId);\n   104→    if (!state) {\n   105→      ws.close(4004, 'Document not found');\n   106→      return;\n   107→    }\n   108→\n   109→    const clientId = randomUUID();\n   110→    const conn: ClientConnection = { ws, clientId, docId };\n   111→    state.clients.set(clientId, conn);\n   112→\n   113→    // Send sync message with current document state\n   114→    const syncMsg: SyncMsg = {\n   115→      type: 'sync',\n   116→      content: state.content,\n   117→      version: state.version,\n   118→      clientId,\n   119→    };\n   120→    ws.send(JSON.stringify(syncMsg));\n   121→\n   122→    ws.on('message', (data) => {\n   123→      try {\n   124→        const msg = JSON.parse(data.toString()) as WsMessage;\n   125→        this.handleMessage(conn, msg);\n   126→      } catch (err) {\n   127→        const errorMsg: ErrorMsg = {\n   128→          type: 'error',\n   129→          message: err instanceof Error ? err.message : 'Invalid message',\n   130→        };\n   131→        ws.send(JSON.stringify(errorMsg));\n   132→      }\n   133→    });\n   134→\n   135→    ws.on('close', () => {\n   136→      state.clients.delete(clientId);\n   137→      if (state.clients.size === 0) {\n   138→        // Keep state in memory for quick reconnect - could add TTL cleanup\n   139→      }\n   140→    });\n   141→  }\n   142→\n   143→  private handleMessage(conn: ClientConnection, msg: WsMessage) {\n   144→    if (msg.type === 'operation') {\n   145→      this.handleOperation(conn, msg as unknown as OperationMsg);\n   146→    } else {\n   147→      const errorMsg: ErrorMsg = {\n   148→        type: 'error',\n   149→        message: `Unknown message type: ${msg.type}`,\n   150→      };\n   151→      conn.ws.send(JSON.stringify(errorMsg));\n   152→    }\n   153→  }\n   154→\n   155→  private handleOperation(conn: ClientConnection, msg: OperationMsg) {\n   156→    const state = this.documents.get(conn.docId);\n   157→    if (!state) {\n   158→      conn.ws.send(JSON.stringify({ type: 'error', message: 'Document state not found' }));\n   159→      return;\n   160→    }\n   161→\n   162→    const clientVersion = msg.version;\n   163→    let operation = msg.operation;\n   164→\n   165→    // Validate the operation\n   166→    if (!Array.isArray(operation)) {\n   167→      conn.ws.send(JSON.stringify({ type: 'error', message: 'Operation must be an array' }));\n   168→      return;\n   169→    }\n   170→\n   171→    if (typeof clientVersion !== 'number' || clientVersion < 0) {\n   172→      conn.ws.send(JSON.stringify({ type: 'error', message: 'Invalid version number' }));\n   173→      return;\n   174→    }\n   175→\n   176→    if (clientVersion > state.version) {\n   177→      conn.ws.send(JSON.stringify({\n   178→        type: 'error',\n   179→        message: `Client version ${clientVersion} is ahead of server version ${state.version}`,\n   180→      }));\n   181→      return;\n   182→    }\n   183→\n   184→    const history = this.operationHistory.get(conn.docId)!;\n   185→\n   186→    // Transform the operation against all operations that happened since the client's version\n   187→    // The client's op was based on version `clientVersion`, but the server is at `state.version`.\n   188→    // We need to transform against operations [clientVersion+1 .. state.version]\n   189→    try {\n   190→      // First validate the operation against the document length at clientVersion\n   191→      // We need to reconstruct what the doc length was at clientVersion\n   192→      // Since we track the content at each version, we use the operation history\n   193→      // to transform the incoming op so it applies to the current content.\n   194→\n   195→      for (let v = clientVersion + 1; v <= state.version; v++) {\n   196→        const serverOp = history.get(v);\n   197→        if (!serverOp) {\n   198→          conn.ws.send(JSON.stringify({\n   199→            type: 'error',\n   200→            message: `Missing operation history for version ${v}`,\n   201→          }));\n   202→          return;\n   203→        }\n   204→        // Transform: operation (client) vs serverOp (server)\n   205→        // We want the transformed client op (a') to apply after serverOp\n   206→        const [aPrime] = transform(operation, serverOp);\n   207→        operation = aPrime;\n   208→      }\n   209→\n   210→      // Validate the transformed operation against the current document\n   211→      if (!validateOperation(operation, state.content.length)) {\n   212→        conn.ws.send(JSON.stringify({\n   213→          type: 'error',\n   214→          message: `Invalid operation: base length doesn't match document length (${state.content.length})`,\n   215→        }));\n   216→        return;\n   217→      }\n   218→\n   219→      // Apply the operation\n   220→      const newContent = apply(state.content, operation);\n   221→      state.version++;\n   222→      state.content = newContent;\n   223→\n   224→      // Store in history\n   225→      history.set(state.version, operation);\n   226→\n   227→      // Persist to database\n   228→      addVersion(this.db, conn.docId, newContent, operation);\n   229→\n   230→      // Send ack to the sender\n   231→      const ackMsg: AckMsg = { type: 'ack', version: state.version };\n   232→      conn.ws.send(JSON.stringify(ackMsg));\n   233→\n   234→      // Broadcast to other clients\n   235→      const broadcastMsg = {\n   236→        type: 'operation',\n   237→        operation,\n   238→        version: state.version,\n   239→        clientId: conn.clientId,\n   240→      };\n   241→      const broadcastStr = JSON.stringify(broadcastMsg);\n   242→      for (const [cid, client] of state.clients) {\n   243→        if (cid !== conn.clientId && client.ws.readyState === WebSocket.OPEN) {\n   244→          client.ws.send(broadcastStr);\n   245→        }\n   246→      }\n   247→    } catch (err) {\n   248→      conn.ws.send(JSON.stringify({\n   249→        type: 'error',\n   250→        message: err instanceof Error ? err.message : 'Operation transform/apply failed',\n   251→      }));\n   252→    }\n   253→  }\n   254→\n   255→  close() {\n   256→    for (const [, state] of this.documents) {\n   257→      for (const [, client] of state.clients) {\n   258→        client.ws.close(1001, 'Server shutting down');\n   259→      }\n   260→    }\n   261→    this.wss.close();\n   262→  }\n   263→}\n   264→"}]},"parent_tool_use_id":"toolu_013rkWmSE5uGcwtL379e38kb","session_id":"4d85a3d6-1f98-4d05-b9ee-7f9aefd9ea76","uuid":"22dee546-ae10-4cc5-bf2e-6334cb759aa2"}
