_SIZE = 1000;\n  private wss: WebSocketServer;\n  private documents: Map<string, DocumentState> = new Map();\n  private db: Database.Database;\n  // History of operations per document indexed by version they produced\n  // operationHistory[docId][version] = operation that transformed doc from version-1 to version\n  private operationHistory: Map<string, Map<number, Operation>> = new Map();\n\n  constructor(server: Server, db: Database.Database) {\n    this.db = db;\n    this.wss = new WebSocketServer({ noServer: true });\n\n    server.on('upgrade', (request: IncomingMessage, socket, head) => {\n      const url = new URL(request.url || '/', `http://${request.headers.host || 'localhost'}`);\n      const pathMatch = url.pathname.match(/^\\/ws\\/documents\\/([^/]+)$/);\n\n      if (!pathMatch) {\n        socket.destroy();\n        return;\n      }\n\n      const docId = pathMatch[1];\n      const doc = getDocument(this.db, docId);\n      if (!doc) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.handleConnection(ws, docId);\n      });\n    });\n  }\n\n  private getOrLoadDocumentState(docId: string): DocumentState | null {\n    let state = this.documents.get(docId);\n    if (!state) {\n      const doc = getDocument(this.db, docId);\n      if (!doc) return null;\n      const version = getLatestVersion(this.db, docId);\n      state = {\n        content: doc.content,\n        version,\n        clients: new Map(),\n      };\n      this.documents.set(docId, state);\n      this.operationHistory.set(docId, new Map());\n    }\n    return state;\n  }\n\n  private handleConnection(ws: WebSocket, docId: string) {\n    const state = this.getOrLoadDocumentState(docId);\n    if (!state) {\n      ws.close(4004, 'Document not found');\n      return;\n    }\n\n    const clientId = randomUUID();\n    const conn: ClientConnection = { ws, clientId, docId };\n    state.clients.set(clientId, conn);\n\n    // Send sync message with current document state\n    const syncMsg: SyncMsg = {\n      type: 'sync',\n      content: state.content,\n      version: state.version,\n      clientId,\n    };\n    ws.send(JSON.stringify(syncMsg));\n\n    ws.on('message', (data) => {\n      try {\n        const msg = JSON.parse(data.toString()) as WsMessage;\n        this.handleMessage(conn, msg);\n      } catch (err) {\n        const errorMsg: ErrorMsg = {\n          type: 'error',\n          message: err instanceof Error ? err.message : 'Invalid message',\n        };\n        ws.send(JSON.stringify(errorMsg));\n      }\n    });\n\n    ws.on('close', () => {\n      state.clients.delete(clientId);\n      if (state.clients.size === 0) {\n        // Keep state in memory for quick reconnect - could add TTL cleanup\n      }\n    });\n  }\n\n  private handleMessage(conn: ClientConnection, msg: WsMessage) {\n    if (msg.type === 'operation') {\n      this.handleOperation(conn, msg as unknown as OperationMsg);\n    } else {\n      const errorMsg: ErrorMsg = {\n        type: 'error',\n        message: `Unknown message type: ${msg.type}`,\n      };\n      conn.ws.send(JSON.stringify(errorMsg));\n    }\n  }\n\n  private handleOperation(conn: ClientConnection, msg: OperationMsg) {\n    const state = this.documents.get(conn.docId);\n    if (!state) {\n      conn.ws.send(JSON.stringify({ type: 'error', message: 'Document state not found' }));\n      return;\n    }\n\n    const clientVersion = msg.version;\n    let operation = msg.operation;\n\n    // Validate the operation\n    if (!Array.isArray(operation)) {\n      conn.ws.send(JSON.stringify({ type: 'error', message: 'Operation must be an array' }));\n      return;\n    }\n\n    if (typeof clientVersion !== 'number' || clientVersion < 0) {\n      conn.ws.send(JSON.stringify({ type: 'error', message: 'Invalid version number' }));\n      return;\n    }\n\n    if (clientVersion > state.version) {\n      conn.ws.send(JSON.stringify({\n        type: 'error',\n        message: `Client version ${clientVersion} is ahead of server version ${state.version}`,\n      }));\n      return;\n    }\n\n    const history = this.operationHistory.get(conn.docId)!;\n\n    // Transform the operation against all operations that happened since the client's version\n    // The client's op was based on version `clientVersion`, but the server is at `state.version`.\n    // We need to transform against operations [clientVersion+1 .. state.version]\n    try {\n      // First validate the operation against the document length at clientVersion\n      // We need to reconstruct what the doc length was at clientVersion\n      // Since we track the content at each version, we use the operation history\n      // to transform the incoming op so it applies to the current content.\n\n      for (let v = clientVersion + 1; v <= state.version; v++) {\n        const serverOp = history.get(v);\n        if (!serverOp) {\n          conn.ws.send(JSON.stringify({\n            type: 'error',\n            message: `Missing operation history for version ${v}`,\n          }));\n          return;\n        }\n        // Transform: operation (client) vs serverOp (server)\n        // We want the transformed client op (a') to apply after serverOp\n        const [aPrime] = transform(operation, serverOp);\n        operation = aPrime;\n      }\n\n      // Validate the transformed operation against the current document\n      if (!validateOperation(operation, state.content.length)) {\n        conn.ws.send(JSON.stringify({\n          type: 'error',\n          message: `Invalid operation: base length doesn't match document length (${state.content.length})`,\n        }));\n        return;\n      }\n\n      // Apply the operation\n      const newContent = apply(state.content, operation);\n      state.version++;\n      state.content = newContent;\n\n      // Store in history\n      history.set(state.version, operati