@@ -0,0 +1,300 @@
+/**
+ * Operational Transformation (OT) engine for collaborative text editing.
+ *
+ * Operations are arrays of components:
+ * - number > 0: retain N characters
+ * - string: insert the string at the current position
+ * - number < 0: delete |N| characters
+ *
+ * The "base length" is the total characters retained + deleted.
+ * The "target length" is the total characters retained + inserted.
+ */
+
+export type OpComponent = number | string;
+export type Operation = OpComponent[];
+
+export interface OperationMessage {
+  type: 'operation';
+  docId: string;
+  operation: Operation;
+  version: number; // the version this operation is based on
+  clientId?: string;
+}
+
+export function baseLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;       // retain
+      else len += Math.abs(c);    // delete
+    }
+    // insert doesn't consume base characters
+  }
+  return len;
+}
+
+export function targetLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) len += c;       // retain
+      // delete doesn't produce target characters
+    } else {
+      len += c.length;            // insert
+    }
+  }
+  return len;
+}
+
+/**
+ * Apply an operation to a string, producing a new string.
+ */
+export function apply(doc: string, op: Operation): string {
+  if (baseLength(op) !== doc.length) {
+    throw new Error(
+      `Operation base length (${baseLength(op)}) does not match document length (${doc.length})`
+    );
+  }
+
+  let result = '';
+  let pos = 0;
+
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (c > 0) {
+        // retain
+        result += doc.slice(pos, pos + c);
+        pos += c;
+      } else {
+        // delete
+        pos += Math.abs(c);
+      }
+    } else {
+      // insert
+      result += c;
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Compose two consecutive operations into one.
+ * apply(apply(doc, a), b) === apply(doc, compose(a, b))
+ */
+export function compose(a: Operation, b: Operation): Operation {
+  if (targetLength(a) !== baseLength(b)) {
+    throw new Error('Compose: target length of a must equal base length of b');
+  }
+
+  const result: Operation = [];
+  let ia = 0;
+  let ib = 0;
+  let aComp: OpComponent | undefined = a[ia];
+  let bComp: OpComponent | undefined = b[ib];
+
+  function push(c: OpComponent) {
+    if (typeof c === 'number' && c === 0) return;
+    if (result.length > 0) {
+      const last = result[result.length - 1];
+      if (typeof c === 'number' && typeof last === 'number') {
+        if ((c > 0 && last > 0) || (c < 0 && last < 0)) {
+          result[result.length - 1] = last + c;
+          return;
+        }
+      } else if (typeof c === 'string' && typeof last === 'string') {
+        result[result.length - 1] = last + c;
+        return;
+      }
+    }
+    result.push(c);
+  }
+
+  while (aComp !== undefined || bComp !== undefined) {
+    // Delete from A takes priority
+    if (typeof aComp === 'number' && aComp < 0) {
+      push(aComp);
+      ia++;
+      aComp = a[ia];
+      continue;
+    }
+    // Insert from B takes priority
+    if (typeof bComp === 'string') {
+      push(bComp);
+      ib++;
+      bComp = b[ib];
+      continue;
+    }
+
+    if (aComp === undefined || bComp === undefined) {
+      throw new Error('Compose: operation length mismatch');
+    }
+
+    // Both retain
+    if (typeof aComp === 'number' && aComp > 0 && typeof bComp === 'number' && bComp > 0) {
+      const min = Math.min(aComp, bComp);
+      push(min);
+      if (aComp === min) { ia++; aComp = a[ia]; } else { aComp = aComp - min; }
+      if (bComp === min) { ib++; bComp = b[ib]; } else { bComp = bComp - min; }
+    }
+    // A retains, B deletes
+    else if (typeof aComp === 'number' && aComp > 0 && typeof bComp === 'number' && bComp < 0) {
+      const min = Math.min(aComp, -bComp);
+      push(-min);
+      if (aComp === min) { ia++; aComp = a[ia]; } else { aComp = aComp - min; }
+      if (-bComp === min) { ib++; bComp = b[ib]; } else { bComp = bComp + min; }
+    }
+    // A inserts, B retains
+    else if (typeof aComp === 'string' && typeof bComp === 'number' && bComp > 0) {
+      const min = Math.min(aComp.length, bComp);
+      push(aComp.slice(0, min));
+      if (aComp.length === min) { ia++; aComp = a[ia]; } else { aComp = aComp.slice(min); }
+      if (bComp === min) { ib++; bComp = b[ib]; } else { bComp = bComp - min; }
+    }
+    // A inserts, B deletes
+    else if (typeof aComp === 'string' && typeof bComp === 'number' && bComp < 0) {
+      const min = Math.min(aComp.length, -bComp);
+      if (aComp.length === min) { ia++; aComp = a[ia]; } else { aComp = aComp.slice(min); }
+      if (-bComp === min) { ib++; bComp = b[ib]; } else { bComp = bComp + min; }
+    }
+    else {
+      throw new Error(`Compose: unexpected component types: ${typeof aComp}, ${typeof bComp}`);
+    }
+  }
+
+  return result;
+}
+
+/**
+ * Transform two concurrent operations a and b (both based on the same document state)
+ * into a' and b' such that:
+ *   apply(apply(doc, a), b') === apply(apply(doc, b), a')
+ *
+ * Returns [a', b']
+ */
+export function transform(a: Operation, b: Operation): [Operation, Operation] {
+  if (baseLength(a) !== baseLength(b)) {
+    throw new Error(
+      `Transform: operations must have same base length (${baseLength(a)} vs ${baseLength(b)})`
+    );
+  }
+
+  const aPrime: Operation = [];
+  const bPrime: Operation = [];
+  let ia = 0;
+  let ib = 0;
+  let aComp: OpComponent | undefined = a[ia];
+  let bComp: OpComponent | undefined = b[ib];
+
+  function pushA(c: OpComponent) {
+    if (typeof c === 'number' && c === 0) return;
+    if (aPrime.length > 0) {
+      const last = aPrime[aPrime.length - 1];
+      if (typeof c === 'number' && typeof last === 'number' && ((c > 0 && last > 0) || (c < 0 && last < 0))) {
+        aPrime[aPrime.length - 1] = last + c;
+        return;
+      }
+      if (typeof c === 'string' && typeof last === 'string') {
+        aPrime[aPrime.length - 1] = last + c;
+        return;
+      }
+    }
+    aPrime.push(c);
+  }
+
+  function pushB(c: OpComponent) {
+    if (typeof c === 'number' && c === 0) return;
+    if (bPrime.length > 0) {
+      const last = bPrime[bPrime.length - 1];
+      if (typeof c === 'number' && typeof last === 'number' && ((c > 0 && last > 0) || (c < 0 && last < 0))) {
+        bPrime[bPrime.length - 1] = last + c;
+        return;
+      }
+      if (typeof c === 'string' && typeof last === 'string') {
+        bPrime[bPrime.length - 1] = last + c;
+        return;
+      }
+    }
+    bPrime.push(c);
+  }
+
+  while (aComp !== undefined || bComp !== undefined) {
+    // Insert from A
+    if (typeof aComp === 'string') {
+      pushA(aComp);
+      pushB(aComp.length); // B' must retain over A's insert
+      ia++;
+      aComp = a[ia];
+      continue;
+    }
+    // Insert from B
+    if (typeof bComp === 'string') {
+      pushA(bComp.length); // A' must retain over B's insert
+      pushB(bComp);
+      ib++;
+      bComp = b[ib];
+      continue;
+    }
+
+    if (aComp === undefined || bComp === undefined) {
+      throw new Error('Transform: operation length mismatch');
+    }
+
+    // Both retain
+    if (typeof aComp === 'number' && aComp > 0 && typeof bComp === 'number' && bComp > 0) {
+      const min = Math.min(aComp, bComp);
+      pushA(min);
+      pushB(min);
+      if (aComp === min) { ia++; aComp = a[ia]; } else { aComp = aComp - min; }
+      if (bComp === min) { ib++; bComp = b[ib]; } else { bComp = bComp - min; }
+    }
+    // A deletes, B deletes
+    else if (typeof aComp === 'number' && aComp < 0 && typeof bComp === 'number' && bComp < 0) {
+      const min = Math.min(-aComp, -bComp);
+      // Both deleted the same chars, neither needs to do anything
+      if (-aComp === min) { ia++; aComp = a[ia]; } else { aComp = aComp + min; }
+      if (-bComp === min) { ib++; bComp = b[ib]; } else { bComp = bComp + min; }
+    }
+    // A deletes, B retains
+    else if (typeof aComp === 'number' && aComp < 0 && typeof bComp === 'number' && bComp > 0) {
+      const min = Math.min(-aComp, bComp);
+      pushA(-min);
+      // B' doesn't need to retain what A deleted
+      if (-aComp === min) { ia++; aComp = a[ia]; } else { aComp = aComp + min; }
+      if (bComp === min) { ib++; bComp = b[ib]; } else { bComp = bComp - min; }
+    }
+    // A retains, B deletes
+    else if (typeof aComp === 'number' && aComp > 0 && typeof bComp === 'number' && bComp < 0) {
+      const min = Math.min(aComp, -bComp);
+      // A' doesn't need to retain what B deleted
+      pushB(-min);
+      if (aComp === min) { ia++; aComp = a[ia]; } else { aComp = aComp - min; }
+      if (-bComp === min) { ib++; bComp = b[ib]; } else { bComp = bComp + min; }
+    }
+    else {
+      throw new Error(`Transform: unexpected component combination`);
+    }
+  }
+
+  return [aPrime, bPrime];
+}
+
+/**
+ * Validate that an operation is well-formed and matches the expected document length.
+ */
+export function validateOperation(op: unknown, docLength: number): op is Operation {
+  if (!Array.isArray(op)) return false;
+  let base = 0;
+  for (const c of op) {
+    if (typeof c === 'number') {
+      if (!Number.isInteger(c) || c === 0) return false;
+      if (c > 0) base += c;
+      else base += Math.abs(c);
+    } else if (typeof c === 'string') {
+      if (c.length === 0) return false;
+    } else {
+      return false;
+    }
+  }
+  return base === docLength;
+}
