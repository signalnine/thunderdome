\n      expect(() => store.getVersion('nonexistent', 'v1')).toThrow();\n    });\n\n    it('should have unique version ids', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n      const history = store.getHistory('doc1');\n      const ids = history.map(v => v.id);\n      expect(new Set(ids).size).toBe(ids.length);\n    });\n\n    it('should deep clone version content', () => {\n      store.create('doc1', { nested: { x: 1 } });\n      const history = store.getHistory('doc1');\n      (history[0].content as Record<string, Record<string, number>>).nested.x = 999;\n      expect(store.getHistory('doc1')[0].content).toEqual({ nested: { x: 1 } });\n    });\n  });\n\n  describe('Branching', () => {\n    it('should start on main branch', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should create and switch to a branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n    });\n\n    it('should list branches', () => {\n      store.createBranch('feature');\n      store.createBranch('bugfix');\n      expect(store.listBranches()).toContain('main');\n      expect(store.listBranches()).toContain('feature');\n      expect(store.listBranches()).toContain('bugfix');\n    });\n\n    it('should throw when creating duplicate branch', () => {\n      store.createBranch('feature');\n      expect(() => store.createBranch('feature')).toThrow();\n    });\n\n    it('should throw when switching to non-existent branch', () => {\n      expect(() => store.switchBranch('nonexistent')).toThrow();\n    });\n\n    it('should isolate changes between branches', () => {\n      store.create('doc1', { name: 'original' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n\n      store.update('doc1', { name: 'modified' });\n      expect(store.get('doc1')).toEqual({ name: 'modified' });\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'original' });\n    });\n\n    it('should branch from specified branch', () => {\n      store.create('doc1', { name: 'main' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'feature' });\n\n      store.switchBranch('main');\n      store.createBranch('from-feature', 'feature');\n      store.switchBranch('from-feature');\n      expect(store.get('doc1')).toEqual({ name: 'feature' });\n    });\n\n    it('should isolate document creation between branches', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'feature-only' });\n\n      store.switchBranch('main');\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should isolate document deletion between branches', () => {\n      store.create('doc1', { name: 'test' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'test' });\n    });\n\n    it('should throw when branching from non-existent branch', () => {\n      expect(() => store.createBranch('feature', 'nonexistent')).toThrow();\n    });\n  });\n\n  describe('Merging', () => {\n    it('should merge non-conflicting changes from source branch', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 10, b: 2 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 2 });\n      expect(store.get('doc1')).toEqual({ a: 10, b: 2 });\n    });\n\n    it('should handle both sides changing different fields', () => {\n      store.create('doc1', { a: 1, b: 2 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 10, b: 2 });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: 1, b: 20 });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ a: 10, b: 20 });\n      expect(store.get('doc1')).toEqual({ a: 10, b: 20 });\n    });\n\n    it('should detect conflicts when both sides change same field differently', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 100 });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: 200 });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0]).toEqual({\n        documentId: 'doc1',\n        path: 'a',\n        base: 1,\n        ours: 200,\n        theirs: 100,\n      });\n      // merged favors ours\n      expect(result.merged['doc1']).toEqual({ a: 200 });\n      // Branch unchanged\n      expect(store.get('doc1')).toEqual({ a: 200 });\n    });\n\n    it('should not apply merge when there are conflicts', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 100 });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: 200 });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      // Current branch should remain unchanged (a=200 as we set it)\n      expect(store.get('doc1')).toEqual({ a: 200 });\n    });\n\n    it('should not conflict when both sides change to same value', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 42 });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: 42 });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n    });\n\n    it('should merge new documents from source branch', () => {\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.create('doc1', { name: 'new' });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ name: 'new' });\n      expect(store.get('doc1')).toEqual({ name: 'new' });\n    });\n\n    it('should handle independent document changes on different branches', () => {\n      store.create('doc1', { a: 1 });\n      store.create('doc2', { b: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 10 });\n\n      store.switchBranch('main');\n      store.update('doc2', { b: 20 });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(store.get('doc1')).toEqual({ a: 10 });\n      expect(store.get('doc2')).toEqual({ b: 20 });\n    });\n\n    it('should handle nested object merging', () => {\n      store.create('doc1', { config: { theme: 'light', lang: 'en' } });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { config: { theme: 'dark', lang: 'en' } });\n\n      store.switchBranch('main');\n      store.update('doc1', { config: { theme: 'light', lang: 'fr' } });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(result.merged['doc1']).toEqual({ config: { theme: 'dark', lang: 'fr' } });\n    });\n\n    it('should return empty merge result for no-op merge', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.conflicts).toHaveLength(0);\n      expect(Object.keys(result.merged)).toHaveLength(0);\n    });\n\n    it('should handle deeply nested conflicts', () => {\n      store.create('doc1', { a: { b: { c: 1 } } });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: { b: { c: 100 } } });\n\n      store.switchBranch('main');\n      store.update('doc1', { a: { b: { c: 200 } } });\n\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(false);\n      expect(result.conflicts).toHaveLength(1);\n      expect(result.conflicts[0].path).toBe('a.b.c');\n      expect(result.conflicts[0].base).toBe(1);\n      expect(result.conflicts[0].ours).toBe(200);\n      expect(result.conflicts[0].theirs).toBe(100);\n    });\n\n    it('should handle adding new fields on one branch', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.update('doc1', { a: 1, b: 2 });\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(result.merged['doc1']).toEqual({ a: 1, b: 2 });\n    });\n\n    it('should handle deletion on source branch', () => {\n      store.create('doc1', { a: 1 });\n      store.createBranch('feature');\n\n      store.switchBranch('feature');\n      store.delete('doc1');\n\n      store.switchBranch('main');\n      const result = store.merge('feature');\n\n      expect(result.applied).toBe(true);\n      expect(() => store.get('doc1')).toThrow();\n    });\n\n    it('should handle both branches adding different fields', () => {\n      store.create('doc1', { a: 1 });\n   