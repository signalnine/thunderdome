g, unknown>, prefix: string = ''): Map<string, unknown> {\n  const result = new Map<string, unknown>();\n  for (const key of Object.keys(obj)) {\n    const path = prefix ? `${prefix}.${key}` : key;\n    const val = obj[key];\n    if (isPlainObject(val)) {\n      const nested = getNestedPaths(val as Record<string, unknown>, path);\n      for (const [p, v] of nested) {\n        result.set(p, v);\n      }\n    } else {\n      result.set(path, val);\n    }\n  }\n  return result;\n}\n\nfunction allPaths(obj: Record<string, unknown>, prefix: string = ''): Set<string> {\n  const result = new Set<string>();\n  for (const key of Object.keys(obj)) {\n    const path = prefix ? `${prefix}.${key}` : key;\n    result.set(path);\n    const val = obj[key];\n    if (isPlainObject(val)) {\n      for (const p of allPaths(val as Record<string, unknown>, path)) {\n        result.add(p);\n      }\n    }\n  }\n  return result;\n}\n\nfunction getAtPath(obj: Record<string, unknown>, path: string): unknown {\n  const parts = path.split('.');\n  let current: unknown = obj;\n  for (const part of parts) {\n    if (!isPlainObject(current)) return undefined;\n    current = (current as Record<string, unknown>)[part];\n  }\n  return current;\n}\n\nfunction setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const part = parts[i];\n    if (!isPlainObject(current[part])) {\n      current[part] = {};\n    }\n    current = current[part] as Record<string, unknown>;\n  }\n  current[parts[parts.length - 1]] = value;\n}\n\nfunction deleteAtPath(obj: Record<string, unknown>, path: string): void {\n  const parts = path.split('.');\n  let current: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    const part = parts[i];\n    if (!isPlainObject(current[part])) return;\n    current = current[part] as Record<string, unknown>;\n  }\n  delete current[parts[parts.length - 1]];\n}\n\nfunction deepEqual(a: unknown, b: unknown): boolean {\n  if (a === b) return true;\n  if (a === null || b === null) return a === b;\n  if (typeof a !== typeof b) return false;\n  if (typeof a !== 'object') return false;\n  if (Array.isArray(a) !== Array.isArray(b)) return false;\n  if (Array.isArray(a) && Array.isArray(b)) {\n    if (a.length !== b.length) return false;\n    return a.every((val, i) => deepEqual(val, b[i]));\n  }\n  const aObj = a as Record<string, unknown>;\n  const bObj = b as Record<string, unknown>;\n  const aKeys = Object.keys(aObj);\n  const bKeys = Object.keys(bObj);\n  if (aKeys.length !== bKeys.length) return false;\n  return aKeys.every(key => deepEqual(aObj[key], bObj[key]));\n}\n\n// Collect all leaf paths from an object, including through nested objects\nfunction collectLeafPaths(obj: Record<string, unknown>, prefix: string = ''): Set<string> {\n  const result = new Set<string>();\n  for (const key of Object.keys(obj)) {\n    const path = prefix ? `${prefix}.${key}` : key;\n    const val = obj[key];\n    if (isPlainObject(val) && Object.keys(val as Record<string, unknown>).length > 0) {\n      for (const p of collectLeafPaths(val as Record<string, unknown>, path)) {\n        result.add(p);\n      }\n    } else {\n      result.set(path);\n    }\n  }\n  return result;\n}\n\n// Get all field paths (both leaf and intermediate) for diff purposes\nfunction getAllFieldPaths(base: Record<string, unknown>, ours: Record<string, unknown>, theirs: Record<string, unknown>): Set<string> {\n  const paths = new Set<string>();\n  for (const p of collectLeafPaths(base)) paths.add(p);\n  for (const p of collectLeafPaths(ours)) paths.add(p);\n  for (const p of collectLeafPaths(theirs)) paths.add(p);\n  return paths;\n}\n\nfunction threeWayMergeDocument(\n  base: object | null,\n  ours: object | null,\n  theirs: object | null,\n  documentId: string,\n): { merged: object | null; conflicts: Conflict[] } {\n  // Handle cases where document existence differs\n  if (base === null && ours === null && theirs === null) {\n    return { merged: null, conflicts: [] };\n  }\n\n  const baseObj = (base ?? {}) as Record<string, unknown>;\n  const oursObj = (ours ?? {}) as Record<string, unknown>;\n  const theirsObj = (theirs ?? {}) as Record<string, unknown>;\n\n  const conflicts: Conflict[] = [];\n  const merged = clone(oursObj) as Record<string, unknown>;\n\n  const paths = getAllFieldPaths(baseObj, oursObj, theirsObj);\n\n  for (const path of paths) {\n    const baseVal = getAtPath(baseObj, path);\n    const oursVal = getAtPath(oursObj, path);\n    const theirsVal = getAtPath(theirsObj, path);\n\n    const oursChanged = !deepEqual(baseVal, oursVal);\n    const theirsChanged = !deepEqual(baseVal, theirsVal);\n\n    if (!oursChanged && !theirsChanged) {\n      // No change on either side\n      continue;\n    }\n\n    if (oursChanged && !theirsChanged) {\n      // Only ours changed - already in merged (cloned from ours)\n      continue;\n    }\n\n    if (!oursChanged && theirsChanged) {\n      // Only theirs changed - take theirs\n      if (theirsVal === undefined) {\n        deleteAtPath(merged, path);\n      } else if (isPlainObject(theirsVal)) {\n        // Skip intermediate objects; their leaves will be handled\n        continue;\n      } else {\n        setAtPath(merged, path, clone(theirsVal));\n      }\n      continue;\n    }\n\n    // Both changed\n    if (deepEqual(oursVal, theirsVal)) {\n      // Both changed to same value - no conflict\n      continue;\n    }\n\n    // Skip if both values are plain objects - their leaf differences will be caught\n    if (isPlainObject(oursVal) && isPlainObject(theirsVal)) {\n      continue;\n    }\n\n    // Conflict - merged keeps ours value (already there from clone)\n    conflicts.push({\n      documentId,\n      path,\n      base: baseVal === undefined ? undefined : clone(baseVal),\n      ours: oursVal === undefined ? undefined : clone(oursVal),\n      theirs: theirsVal === undefined ? undefined : clone(theirsVal),\n    });\n  }\n\n  // Clean up empty parent objects that resulted from deletion\n  cleanEmptyObjects(merged);\n\n  return { merged, conflicts };\n}\n\nfunction cleanEmptyObjects(obj: Record<string, unknown>): void {\n  for (const key of Object.keys(obj)) {\n    if (isPlainObject(obj[key])) {\n      cleanEmptyObjects(obj[key] as Record<string, unknown>);\n      if (Object.keys(obj[key] as Record<string, unknown>).length === 0) {\n        delete obj[key];\n      }\n    }\n  }\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n      parentBranch: null,\n      branchPointSnapshots: new Map(),\n    });\n  }\n\n  // Document CRUD\n\n  create(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: clone(content),\n    };\n\n    branch.documents.set(id, {\n      content: clone(content),\n      versions: [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return clone(entry.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: clone(content),\n    };\n\n    entry.content = clone(content);\n    entry.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    entry.deleted = true;\n  }\n\n  // Version History\n\n  getHistory(id: string): Version[] {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return entry.versions.map(v => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: clone(v.content),\n    }));\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    const version = entry.versions.find(v => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" not found for document \"${id}\"`);\n    }\n    return clone(version.content);\n  }\n\n  // Branching\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n\n    const sourceBranchName = fromBranch ?? this.currentBranch;\n    const sourceBranch = this.branches.get(sourceBranchName);\n    if (!sourceBranch) {\n      throw new Error(`Branch \"${sourceBranchName}\" not found`);\n    }\n\n    const newBranch: BranchData = {\n      documents: cloneDocumentMap(sourceBranch.documents),\n      parentBranch: sourceBranchName,\n      branchPointSnapshots: new Map(),\n    };\n\n    // Store snapshot of parent at branch point\n    newBranch.branchPointSnapshots.set(sourceBranchName, cloneDocumentMap(sourceBranch.documents));\n\n    // Also store the sn