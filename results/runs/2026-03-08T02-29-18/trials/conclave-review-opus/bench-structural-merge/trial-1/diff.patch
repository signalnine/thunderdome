{\n    60→    result.set(id, cloneDocumentEntry(entry));\n    61→  }\n    62→  return result;\n    63→}\n    64→\n    65→function isPlainObject(val: unknown): val is Record<string, unknown> {\n    66→  return val !== null && typeof val === 'object' && !Array.isArray(val);\n    67→}\n    68→\n    69→\n    70→function getAtPath(obj: Record<string, unknown>, path: string): unknown {\n    71→  const parts = path.split('.');\n    72→  let current: unknown = obj;\n    73→  for (const part of parts) {\n    74→    if (!isPlainObject(current)) return undefined;\n    75→    current = (current as Record<string, unknown>)[part];\n    76→  }\n    77→  return current;\n    78→}\n    79→\n    80→function setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {\n    81→  const parts = path.split('.');\n    82→  let current: Record<string, unknown> = obj;\n    83→  for (let i = 0; i < parts.length - 1; i++) {\n    84→    const part = parts[i];\n    85→    if (!isPlainObject(current[part])) {\n    86→      current[part] = {};\n    87→    }\n    88→    current = current[part] as Record<string, unknown>;\n    89→  }\n    90→  current[parts[parts.length - 1]] = value;\n    91→}\n    92→\n    93→function deleteAtPath(obj: Record<string, unknown>, path: string): void {\n    94→  const parts = path.split('.');\n    95→  let current: Record<string, unknown> = obj;\n    96→  for (let i = 0; i < parts.length - 1; i++) {\n    97→    const part = parts[i];\n    98→    if (!isPlainObject(current[part])) return;\n    99→    current = current[part] as Record<string, unknown>;\n   100→  }\n   101→  delete current[parts[parts.length - 1]];\n   102→}\n   103→\n   104→function deepEqual(a: unknown, b: unknown): boolean {\n   105→  if (a === b) return true;\n   106→  if (a === null || b === null) return a === b;\n   107→  if (typeof a !== typeof b) return false;\n   108→  if (typeof a !== 'object') return false;\n   109→  if (Array.isArray(a) !== Array.isArray(b)) return false;\n   110→  if (Array.isArray(a) && Array.isArray(b)) {\n   111→    if (a.length !== b.length) return false;\n   112→    return a.every((val, i) => deepEqual(val, b[i]));\n   113→  }\n   114→  const aObj = a as Record<string, unknown>;\n   115→  const bObj = b as Record<string, unknown>;\n   116→  const aKeys = Object.keys(aObj);\n   117→  const bKeys = Object.keys(bObj);\n   118→  if (aKeys.length !== bKeys.length) return false;\n   119→  return aKeys.every(key => deepEqual(aObj[key], bObj[key]));\n   120→}\n   121→\n   122→// Collect all leaf paths from an object, including through nested objects\n   123→function collectLeafPaths(obj: Record<string, unknown>, prefix: string = ''): Set<string> {\n   124→  const result = new Set<string>();\n   125→  for (const key of Object.keys(obj)) {\n   126→    const path = prefix ? `${prefix}.${key}` : key;\n   127→    const val = obj[key];\n   128→    if (isPlainObject(val) && Object.keys(val as Record<string, unknown>).length > 0) {\n   129→      for (const p of collectLeafPaths(val as Record<string, unknown>, path)) {\n   130→        result.add(p);\n   131→      }\n   132→    } else {\n   133→      result.add(path);\n   134→    }\n   135→  }\n   136→  return result;\n   137→}\n   138→\n   139→// Get all field paths (both leaf and intermediate) for diff purposes\n   140→function getAllFieldPaths(base: Record<string, unknown>, ours: Record<string, unknown>, theirs: Record<string, unknown>): Set<string> {\n   141→  const paths = new Set<string>();\n   142→  for (const p of collectLeafPaths(base)) paths.add(p);\n   143→  for (const p of collectLeafPaths(ours)) paths.add(p);\n   144→  for (const p of collectLeafPaths(theirs)) paths.add(p);\n   145→  return paths;\n   146→}\n   147→\n   148→function threeWayMergeDocument(\n   149→  base: object | null,\n   150→  ours: object | null,\n   151→  theirs: object | null,\n   152→  documentId: string,\n   153→): { merged: object | null; conflicts: Conflict[] } {\n   154→  // Handle cases where document existence differs\n   155→  if (base === null && ours === null && theirs === null) {\n   156→    return { merged: null, conflicts: [] };\n   157→  }\n   158→\n   159→  const baseObj = (base ?? {}) as Record<string, unknown>;\n   160→  const oursObj = (ours ?? {}) as Record<string, unknown>;\n   161→  const theirsObj = (theirs ?? {}) as Record<string, unknown>;\n   162→\n   163→  const conflicts: Conflict[] = [];\n   164→  const merged = clone(oursObj) as Record<string, unknown>;\n   165→\n   166→  const paths = getAllFieldPaths(baseObj, oursObj, theirsObj);\n   167→\n   168→  for (const path of paths) {\n   169→    const baseVal = getAtPath(baseObj, path);\n   170→    const oursVal = getAtPath(oursObj, path);\n   171→    const theirsVal = getAtPath(theirsObj, path);\n   172→\n   173→    const oursChanged = !deepEqual(baseVal, oursVal);\n   174→    const theirsChanged = !deepEqual(baseVal, theirsVal);\n   175→\n   176→    if (!oursChanged && !theirsChanged) {\n   177→      // No change on either side\n   178→      continue;\n   179→    }\n   180→\n   181→    if (oursChanged && !theirsChanged) {\n   182→      // Only ours changed - already in merged (cloned from ours)\n   183→      continue;\n   184→    }\n   185→\n   186→    if (!oursChanged && theirsChanged) {\n   187→      // Only theirs changed - take theirs\n   188→      if (theirsVal === undefined) {\n   189→        deleteAtPath(merged, path);\n   190→      } else if (isPlainObject(theirsVal)) {\n   191→        // Skip intermediate objects; their leaves will be handled\n   192→        continue;\n   193→      } else {\n   194→        setAtPath(merged, path, clone(theirsVal));\n   195→      }\n   196→      continue;\n   197→    }\n   198→\n   199→    // Both changed\n   200→    if (deepEqual(oursVal, theirsVal)) {\n   201→      // Both changed to same value - no conflict\n   202→      continue;\n   203→    }\n   204→\n   205→    // Skip if both values are plain objects - their leaf differences will be c