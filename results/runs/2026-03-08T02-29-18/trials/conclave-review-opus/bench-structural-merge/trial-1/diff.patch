+function threeWayMergeDocument(
+  base: object | null,
+  ours: object | null,
+  theirs: object | null,
+  documentId: string,
+): { merged: object | null; conflicts: Conflict[] } {
+  if (base === null && ours === null && theirs === null) {
+    return { merged: null, conflicts: [] };
+  }
+
+  const baseObj = (base ?? {}) as Record<string, unknown>;
+  const oursObj = (ours ?? {}) as Record<string, unknown>;
+  const theirsObj = (theirs ?? {}) as Record<string, unknown>;
+
+  const conflicts: Conflict[] = [];
+  const merged = clone(oursObj) as Record<string, unknown>;
+
+  const paths = getAllFieldPaths(baseObj, oursObj, theirsObj);
+
+  for (const path of paths) {
+    const baseVal = getAtPath(baseObj, path);
+    const oursVal = getAtPath(oursObj, path);
+    const theirsVal = getAtPath(theirsObj, path);
+
+    const oursChanged = !deepEqual(baseVal, oursVal);
+    const theirsChanged = !deepEqual(baseVal, theirsVal);
+
+    if (!oursChanged && !theirsChanged) {
+      continue;
+    }
+
+    if (oursChanged && !theirsChanged) {
+      continue;
+    }
+
+    if (!oursChanged && theirsChanged) {
+      if (theirsVal === undefined) {
+        deleteAtPath(merged, path);
+      } else if (isPlainObject(theirsVal)) {
+        continue;
+      } else {
+        setAtPath(merged, path, clone(theirsVal));
+      }
+      continue;
+    }
+
+    // Both changed
+    if (deepEqual(oursVal, theirsVal)) {
+      continue;
+    }
+
+    // Skip if both values are plain objects - their leaf differences will be caught
+    if (isPlainObject(oursVal) && isPlainObject(theirsVal)) {
+      continue;
+    }
+
+    // Conflict - merged keeps ours value (already there from clone)
+    conflicts.push({
+      documentId,
+      path,
+      base: baseVal === undefined ? undefined : clone(baseVal),
+      ours: oursVal === undefined ? undefined : clone(oursVal),
+      theirs: theirsVal === undefined ? undefined : clone(theirsVal),
+    });
+  }
+
+  return { merged, conflicts };
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+  private versionCounter: number = 0;
+
+  constructor() {
+    this.branches.set('main', {
+      documents: new Map(),
+      parentBranch: null,
+      branchPointSnapshots: new Map(),
+    });
+  }
+
+  private generateVersionId(): string {
+    return `v_${++this.versionCounter}_${Date.now()}`;
+  }
+
+  // Document CRUD
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchData();
+    const existing = branch.documents.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: this.generateVersionId(),
+      timestamp: Date.now(),
+      content: clone(content),
+    };
+
+    branch.documents.set(id, {
+      content: clone(content),
+      versions: [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchData();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return clone(entry.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchData();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+
+    const version: Version = {
+      id: this.generateVersionId(),
+      timestamp: Date.now(),
+      content: clone(content),
+    };
+
+    entry.content = clone(content);
+    entry.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchData();
+    const entry = branch.documents.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    entry.deleted = true;
+  }
+
+  // Version History
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchData();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: clone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchData();
+    const entry = branch.documents.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version = entry.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return clone(version.content);
+  }
+
+  // Branching
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+
+    const sourceBranchName = fromBranch ?? this.currentBranch;
+    const sourceBranch = this.branches.get(sourceBranchName);
+    if (!sourceBranch) {
+      throw new Error(`Branch "${sourceBranchName}" not found`);
+    }
+
+    const newBranch: BranchData = {
+      documents: cloneDocumentMap(sourceBranch.documents),
+      parentBranch: sourceBranchName,
+      branchPointSnapshots: new Map(),
+    };
+
+    // Store snapshot of parent at branch point
+    newBranch.branchPointSnapshots.set(sourceBranchName, cloneDocumentMap(sourceBranch.documents));
+
+    // Also store the snapshot on the source branch side
+    sourceBranch.branchPointSnapshots.set(name, cloneDocumentMap(sourceBranch.documents));
+
+    this.branches.set(name, newBranch);
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // Merging
+
+  merge(sourceBranch: string): MergeResult {
+    const targetBranchName = this.currentBranch;
+    const target = this.branches.get(targetBranchName);
+    const source = this.branches.get(sourceBranch);
+
+    if (!target) {
+      throw new Error(`Branch "${targetBranchName}" not found`);
+    }
+    if (!source) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+
+    const baseSnapshot = this.findCommonAncestor(targetBranchName, sourceBranch);
+
+    const allDocIds = new Set<string>();
+    for (const id of baseSnapshot.keys()) allDocIds.add(id);
+    for (const id of target.documents.keys()) allDocIds.add(id);
+    for (const id of source.documents.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+    let hasChanges = false;
+
+    for (const docId of allDocIds) {
+      const baseEntry = baseSnapshot.get(docId);
+      const oursEntry = target.documents.get(docId);
+      const theirsEntry = source.documents.get(docId);
+
+      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;
+      const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : null;
+      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : null;
+
+      const oursChanged = !deepEqual(baseContent, oursContent);
+      const theirsChanged = !deepEqual(baseContent, theirsContent);
+
+      if (!oursChanged && !theirsChanged) {
+        continue;
+      }
+
+      hasChanges = true;
+
+      if (oursChanged && !theirsChanged) {
+        if (oursContent !== null) {
+          merged[docId] = clone(oursContent);
+        }
+        continue;
+      }
+
+      if (!oursChanged && theirsChanged) {
+        if (theirsContent !== null) {
+          merged[docId] = clone(theirsContent);
+        }
+        continue;
+      }
+
+      // Both changed
+      if (deepEqual(oursContent, theirsContent)) {
+        if (oursContent !== null) {
+          merged[docId] = clone(oursContent);
+        }
+        continue;
+      }
+
+      // Handle deletion conflicts
+      if (oursContent === null || theirsContent === null) {
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: baseContent !== null ? clone(baseContent) : undefined,
+          ours: oursContent !== null ? clone(oursContent) : undefined,
+          theirs: theirsContent !== null ? clone(theirsContent) : undefined,
+        });
+        if (oursContent !== null) {
+          merged[docId] = clone(oursContent);
+        }
+        continue;
+      }
+
+      // Both modified the document - structural merge
+      const result = threeWayMergeDocument(baseContent, oursContent, theirsContent, docId);
+      if (result.merged !== null) {
+        merged[docId] = result.merged;
+      }
+      allConflicts.push(...result.conflicts);
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied && hasChanges) {
+      this.applyMerge(target, baseSnapshot, source, allDocIds, merged);
+
+      // Update branch point snapshots after merge to support sequential merges.
+      // Both branches should now see the current merged state as the new common ancestor.
+      const mergedSnapshot = cloneDocumentMap(target.documents);
+      target.branchPointSnapshots.set(sourceBranch, mergedSnapshot);
+      source.branchPointSnapshots.set(targetBranchName, cloneDocumentMap(target.documents));
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+
+  private applyMerge(
+    target: BranchData,
+    baseSnapshot: Map<string, DocumentEntry>,
+    source: BranchData,
+    allDocIds: Set<string>,
+    merged: Record<string, object>,
+  ): void {
+    for (const docId of allDocIds) {
+      const baseEntry = baseSnapshot.get(docId);
+      const oursEntry = target.documents.get(docId);
+      const theirsEntry = source.documents.get(docId);
+
+      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;
+      const oursContent = oursEntry && !oursEntry.deleted ? oursEntry.content : null;
+      const theirsContent = theirsEntry && !theirsEntry.deleted ? theirsEntry.content : null;
+
+      const oursChanged = !deepEqual(baseContent, oursContent);
+      const theirsChanged = !deepEqual(baseContent, theirsContent);
+
+      if (!theirsChanged) continue;
+
+      if (!oursChanged && theirsChanged) {
+        if (theirsContent === null) {
+          if (oursEntry) {
+            oursEntry.deleted = true;
+          }
+        } else if (oursEntry && !oursEntry.deleted) {
+          const version: Version = {
+            id: this.generateVersionId(),
+            timestamp: Date.now(),
+            content: clone(theirsContent),
+          };
+          oursEntry.content = clone(theirsContent);
+          oursEntry.versions.push(version);
+        } else {
+          const version: Version = {
+            id: this.generateVersionId(),
+            timestamp: Date.now(),
+            content: clone(theirsContent),
+          };
+          target.documents.set(docId, {
+            content: clone(theirsContent),
+            versions: [version],
+            deleted: false,
+          });
+        }
+      } else if (oursChanged && theirsChanged) {
+        const mergedContent = merged[docId];
+        if (mergedContent && oursEntry) {
+          const version: Version = {
+            id: this.generateVersionId(),
+            timestamp: Date.now(),
+            content: clone(mergedContent),
+          };
+          oursEntry.content = clone(mergedContent);
+          oursEntry.versions.push(version);
+        }
+      }
+    }
+  }
+
+  private getCurrentBranchData(): BranchData {
+    const branch = this.branches.get(this.currentBranch);
+    if (!branch) {
+      throw new Error(`Branch "${this.currentBranch}" not found`);
+    }
+    return branch;
+  }
+
+  private findCommonAncestor(targetBranch: string, sourceBranch: string): Map<string, DocumentEntry> {
+    const target = this.branches.get(targetBranch)!;
+    const source = this.branches.get(sourceBranch)!;
+
+    // Direct snapshot: target has a snapshot for source
+    const targetSnapshot = target.branchPointSnapshots.get(sourceBranch);
+    if (targetSnapshot) {
+      return targetSnapshot;
+    }
+
+    // Direct snapshot: source has a snapshot for target
+    const sourceSnapshot = source.branchPointSnapshots.get(targetBranch);
+    if (sourceSnapshot) {
+      return sourceSnapshot;
+    }
+
+    // Walk parent chains to find common ancestor for sibling branches
+    const targetAncestors = this.getAncestorChain(targetBranch);
+    const sourceAncestors = this.getAncestorChain(sourceBranch);
+
+    // Find the nearest common ancestor
+    for (const tAncestor of targetAncestors) {
+      if (sourceAncestors.includes(tAncestor)) {
+        // Found common ancestor - use the snapshot the target branch has for it
+        // or the snapshot the source branch has for it
+        const targetAncestorSnapshot = target.branchPointSnapshots.get(tAncestor);
+        if (targetAncestorSnapshot) {
+          return targetAncestorSnapshot;
+        }
+        const sourceAncestorSnapshot = source.branchPointSnapshots.get(tAncestor);
+        if (sourceAncestorSnapshot) {
+          return sourceAncestorSnapshot;
+        }
+        break;
+      }
+    }
+
+    // Fallback: empty base
+    return new Map();
+  }
+
+  private getAncestorChain(branchName: string): string[] {
+    const ancestors: string[] = [];
+    let current = this.branches.get(branchName);
+    while (current?.parentBranch) {
+      ancestors.push(current.parentBranch);
+      current = this.branches.get(current.parentBranch);
+    }
+    return ancestors;
+  }
+}
