+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  base: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  ours: any;
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  theirs: any;
+}
+
+interface DocumentEntry {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+interface BranchData {
+  documents: Map<string, DocumentEntry>;
+  parentBranch: string | null;
+  branchPointSnapshots: Map<string, Map<string, DocumentEntry>>;
+}
+
+function clone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+function cloneDocumentEntry(entry: DocumentEntry): DocumentEntry {
+  return {
+    content: clone(entry.content),
+    versions: entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: clone(v.content),
+    })),
+    deleted: entry.deleted,
+  };
+}
+
+function cloneDocumentMap(map: Map<string, DocumentEntry>): Map<string, DocumentEntry> {
+  const result = new Map<string, DocumentEntry>();
+  for (const [id, entry] of map) {
+    result.set(id, cloneDocumentEntry(entry));
+  }
+  return result;
+}
+
+function isPlainObject(val: unknown): val is Record<string, unknown> {
+  return val !== null && typeof val === 'object' && !Array.isArray(val);
+}
+
+function getAtPath(obj: Record<string, unknown>, path: string): unknown {
+  const parts = path.split('.');
+  let current: unknown = obj;
+  for (const part of parts) {
+    if (!isPlainObject(current)) return undefined;
+    current = (current as Record<string, unknown>)[part];
+  }
+  return current;
+}
+
+function setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {
+  const parts = path.split('.');
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (!isPlainObject(current[part])) {
+      current[part] = {};
+    }
+    current = current[part] as Record<string, unknown>;
+  }
+  current[parts[parts.length - 1]] = value;
+}
+
+function deleteAtPath(obj: Record<string, unknown>, path: string): void {
+  const parts = path.split('.');
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const part = parts[i];
+    if (!isPlainObject(current[part])) return;
+    current = current[part] as Record<string, unknown>;
+  }
+  delete current[parts[parts.length - 1]];
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return a === b;
+  if (typeof a !== typeof b) return false;
+  if (typeof a !== 'object') return false;
+  if (Array.isArray(a) !== Array.isArray(b)) return false;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    return a.every((val, i) => deepEqual(val, b[i]));
+  }
+  const aObj = a as Record<string, unknown>;
+  const bObj = b as Record<string, unknown>;
+  const aKeys = Object.keys(aObj);
+  const bKeys = Object.keys(bObj);
+  if (aKeys.length !== bKeys.length) return false;
+  return aKeys.every(key => deepEqual(aObj[key], bObj[key]));
+}
+
+function collectLeafPaths(obj: Record<string, unknown>, prefix: string = ''): Set<string> {
+  const result = new Set<string>();
+  for (const key of Object.keys(obj)) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    const val = obj[key];
+    if (isPlainObject(val) && Object.keys(val as Record<string, unknown>).length > 0) {
+      for (const p of collectLeafPaths(val as Record<string, unknown>, path)) {
+        result.add(p);
+      }
+    } else {
+      result.add(path);
+    }
+  }
+  return result;
+}
+
+function getAllFieldPaths(base: Record<string, unknown>, ours: Record<string, unknown>, theirs: Record<string, unknown>): Set<string> {
+  const paths = new Set<string>();
+  for (const p of collectLeafPaths(base)) paths.add(p);
+  for (const p of collectLeafPaths(ours)) paths.add(p);
+  for (const p of collectLeafPaths(theirs)) paths.add(p);
+  return paths;
+}
