 path: 'a',\n   283→        base: 1,\n   284→        ours: 200,\n   285→        theirs: 100,\n   286→      });\n   287→      // merged favors ours\n   288→      expect(result.merged['doc1']).toEqual({ a: 200 });\n   289→      // Branch unchanged\n   290→      expect(store.get('doc1')).toEqual({ a: 200 });\n   291→    });\n   292→\n   293→    it('should not apply merge when there are conflicts', () => {\n   294→      store.create('doc1', { a: 1 });\n   295→      store.createBranch('feature');\n   296→\n   297→      store.switchBranch('feature');\n   298→      store.update('doc1', { a: 100 });\n   299→\n   300→      store.switchBranch('main');\n   301→      store.update('doc1', { a: 200 });\n   302→\n   303→      const result = store.merge('feature');\n   304→\n   305→      expect(result.applied).toBe(false);\n   306→      // Current branch should remain unchanged (a=200 as we set it)\n   307→      expect(store.get('doc1')).toEqual({ a: 200 });\n   308→    });\n   309→\n   310→    it('should not conflict when both sides change to same value', () => {\n   311→      store.create('doc1', { a: 1 });\n   312→      store.createBranch('feature');\n   313→\n   314→      store.switchBranch('feature');\n   315→      store.update('doc1', { a: 42 });\n   316→\n   317→      store.switchBranch('main');\n   318→      store.update('doc1', { a: 42 });\n   319→\n   320→      const result = store.merge('feature');\n   321→\n   322→      expect(result.applied).toBe(true);\n   323→      expect(result.conflicts).toHaveLength(0);\n   324→    });\n   325→\n   326→    it('should merge new documents from source branch', () => {\n   327→      store.createBranch('feature');\n   328→\n   329→      store.switchBranch('feature');\n   330→      store.create('doc1', { name: 'new' });\n   331→\n   332→      store.switchBranch('main');\n   333→      const result = store.merge('feature');\n   334→\n   335→      expect(result.applied).toBe(true);\n   336→      expect(result.merged['doc1']).toEqual({ name: 'new' });\n   337→      expect(store.get('doc1')).toEqual({ name: 'new' });\n   338→    });\n   339→\n   340→    it('should handle independent document changes on different branches', () => {\n   341→      store.create('doc1', { a: 1 });\n   342→      store.create('doc2', { b: 1 });\n   343→      store.createBranch('feature');\n   344→\n   345→      store.switchBranch('feature');\n   346→      store.update('doc1', { a: 10 });\n   347→\n   348→      store.switchBranch('main');\n   349→      store.update('doc2', { b: 20 });\n   350→\n   351→      const result = store.merge('feature');\n   352→\n   353→      expect(result.applied).toBe(true);\n   354→      expect(result.conflicts).toHaveLength(0);\n   355→      expect(store.get('doc1')).toEqual({ a: 10 });\n   356→      expect(store.get('doc2')).toEqual({ b: 20 });\n   357→    });\n   358→\n   359→    it('should handle nested object merging', () => {\n   360→      store.create('doc1', { config: { theme: 'light', lang: 'en' } });\n   361→      store.createBranch('feature');\n   362→\n   363→      store.switchBranch('feature');\n   364→      store.update('doc1', { config: { theme: 'dark', lang: 'en' } });\n   365→\n   366→      store.switchBranch('main');\n   367→      store.update('doc1', { config: { theme: 'light', lang: 'fr' } });\n   368→\n   369→      const result = store.merge('feature');\n   370→\n   371→      expect(result.applied).toBe(true);\n   372→      expect(result.conflicts).toHaveLength(0);\n   373→      expect(result.merged['doc1']).toEqual({ config: { theme: 'dark', lang: 'fr' } });\n   374→    });\n   375→\n   376→    it('should return empty merge result for no-op merge', () => {\n   377→      store.create('doc1', { a: 1 });\n   378→      store.createBranch('feature');\n   379→\n   380→      const result = store.merge('feature');\n   381→\n   382→      expect(result.applied).toBe(true);\n   383→      expect(result.conflicts).toHaveLength(0);\n   384→      expect(Object.keys(result.merged)).toHaveLength(0);\n   385→    });\n   386→\n   387→    it('should handle deeply nested conflicts', () => {\n   388→      store.create('doc1', { a: { b: { c: 1 } } });\n   389→      store.createBranch('feature');\n   390→\n   391→      store.switchBranch('feature');\n   392→      store.update('doc1', { a: { b: { c: 100 } } });\n   393→\n   394→      store.switchBranch('main');\n   395→      store.update('doc1', { a: { b: { c: 200 } } });\n   396→\n   397→      const result = store.merge('feature');\n   398→\n   399→      expect(result.applied).toBe(false);\n   400→      expect(result.conflicts).toHaveLength(1);\n   401→      expect(result.conflicts[0].path).toBe('a.b.c');\n   402→      expect(result.conflicts[0].base).toBe(1);\n   403→      expect(result.conflicts[0].ours).toBe(200);\n   404→      expect(result.conflicts[0].theirs).toBe(100);\n   405→    });\n   406→\n   407→    it('should handle adding new fields on one branch', () => {\n   408→      store.create('doc1', { a: 1 });\n   409→      store.createBranch('feature');\n   410→\n   411→      store.switchBranch('feature');\n   412→      store.update('doc1', { a: 1, b: 2 });\n   413→\n   414→      store.switchBranch('main');\n   415→      const result = store.merge('feature');\n   416→\n   417→      expect(result.applied).toBe(true);\n   418→      expect(result.merged['doc1']).toEqual({ a: 1, b: 2 });\n   419→    });\n   420→\n   421→    it('should handle deletion on source branch', () => {\n   422→      store.create('doc1', { a: 1 });\n   423→      store.createBranch('feature');\n   424→\n   425→      store.switchBranch('feature');\n   426→      store.delete('doc1');\n   427→\n   428→      store.switchBranch('main');\n   429→      const result = store.merge('feature');\n   430→\n   431→      expect(result.applied).toBe(true);\n   432→      expect(() => store.get('doc1')).toThrow();\n   433→    });\n   434→\n   435→    it('should handle both branches adding different fields', () => {\n   436→      store.create('doc1', { a: 1 });\n   437→      store.createBranch('feature');\n   438→\n   439→      store.switchBranch('feature');\n   440→      store.update('doc1', { a: 1, b: 2 });\n   441→\n   442→      store.switchBranch('main');\n   443→      store.update('doc1', { a: 1, c: 3 });\n   444→\n   445→      const result = store.merge('feature');\n   446→\n   447→      expect(result.applied).toBe(true);\n   448→      expect(result.merged['doc1']).toEqual({ a: 1, b: 2, c: 3 });\n   449→    });\n   450→\n   451→    it('should handle removing a field on one branch', () => {\n   452→      store.create('doc1', { a: 1, b: 2 });\n   453→      store.createBranch('feature');\n   454→\n   455→      store.switchBranch('feature');\n   456→      store.update('doc1', { a: 1 }); // removed b\n   457→\n   458→      store.switchBranch('main');\n   459→      const result = store.merge('feature');\n   460→\n   461→      expect(result.applied).toBe(true);\n   462→      expect(result.merged['doc1']).toEqual({ a: 1 });\n   463→    });\n   464→\n   465→    it('should throw when merging non-existent branch', () => {\n   466→      expect(() => store.merge('nonexistent')).toThrow();\n   467→    });\n   468→\n   469→    it('should handle array values', () => {\n   470→      store.create('doc1', { tags: ['a', 'b'] });\n   471→      store.createBranch('feature');\n   472→\n   473→      store.switchBranch('feature');\n   474→      store.update('doc1', { tags: ['a', 'b', 'c'] });\n   475→\n   476→      store.switchBranch('main');\n   477→      const result = store.merge('feature');\n   478→\n   479→      expect(result.applied).toBe(true);\n   480→      expect(result.merged['doc1']).toEqual({ tags: ['a', 'b', 'c'] });\n   481→    });\n   482→\n   483→    it('should conflict on array values changed differently', () => {\n   484→      store.create('doc1', { tags: ['a'] });\n   485→      store.createBranch('feature');\n   486→\n   487→      store.switchBranch('feature');\n   488→      store.update('doc1', { tags: ['a', 'b'] });\n   489→\n   490→      store.switchBranch('main');\n   491→      store.update('doc1', { tags: ['a', 'c'] });\n   492→\n   493→      const result = store.merge('feature');\n   494→\n   495→      expect(result.applied).toBe(false);\n   496→      expect(result.conflicts).toHaveLength(1);\n   497→      expect(result.conflicts[0].path).toBe('tags');\n   498→    });\n   499→\n   500→    it('should create a version entry after successful merge', () => {\n   501→      store.create('doc1', { a: 1, b: 2 });\n   502→      store.createBranch('feature');\n   503→\n   504→      store.switchBranch('feature');\n   505→      store.update('doc1', { a: 10, b: 2 });\n   506→\n   507→      store.switchBranch('main');\n   508→      const beforeCount = store.getHistory('doc1').length;\n   509→      store.merge('feature');\n   510→      const afterCount = store.getHistory('doc1').length;\n   511→\n   512→      expect(afterCount).toBe(beforeCount + 1);\n   513→    });\n   514→\n   515→    it('should handle multiple documents in a merge', () => {\n   516→      store.create('doc1', { a: 1 });\n   517→      store.create('doc2', { b: 1 });\n   518→      store.create('doc3', { c: 1 });\n   519→      store.createBranch('feature');\n   520→\n   521→      store.switchBranch('feature');\n   522→      store.update('doc1', { a: 10 });\n   523→      store.update('doc2', { b: 10 });\n   524→      // doc3 unchanged\n   525→\n   526→      store.switchBranch('main');\n   527→      // doc1, doc2, doc3 unchanged on main\n   528→\n   529→      const result = store.merge('feature');\n   530→\n   531→      expect(result.applied).toBe(true);\n   532→      expect(store.get('doc1')).toEqual({ a: 10 });\n   533→      expect(store.get('doc2')).toEqual({ b: 10 });\n   534→      expect(store.get('doc3')).toEqual({ c: 1 });\n   535→    });\n   536→\n   537→    it('should handle merge with mixed conflicts and clean merges', () => {\n   538→      store.create('doc1', { a: 1 });\n   539→      store.create('doc2', { x: