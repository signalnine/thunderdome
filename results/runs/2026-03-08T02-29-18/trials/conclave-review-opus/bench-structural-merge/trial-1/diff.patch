ate('doc1', { name: 'test' });\n    48→      store.delete('doc1');\n    49→      expect(() => store.delete('doc1')).toThrow();\n    50→    });\n    51→\n    52→    it('should deep clone on create', () => {\n    53→      const content = { nested: { value: 1 } };\n    54→      store.create('doc1', content);\n    55→      content.nested.value = 999;\n    56→      expect(store.get('doc1')).toEqual({ nested: { value: 1 } });\n    57→    });\n    58→\n    59→    it('should deep clone on get', () => {\n    60→      store.create('doc1', { nested: { value: 1 } });\n    61→      const result = store.get('doc1') as Record<string, Record<string, number>>;\n    62→      result.nested.value = 999;\n    63→      expect(store.get('doc1')).toEqual({ nested: { value: 1 } });\n    64→    });\n    65→\n    66→    it('should deep clone on update', () => {\n    67→      store.create('doc1', { value: 1 });\n    68→      const content = { value: 2, nested: { x: 1 } };\n    69→      store.update('doc1', content);\n    70→      content.nested.x = 999;\n    71→      expect(store.get('doc1')).toEqual({ value: 2, nested: { x: 1 } });\n    72→    });\n    73→\n    74→    it('should throw when updating a deleted document', () => {\n    75→      store.create('doc1', { name: 'test' });\n    76→      store.delete('doc1');\n    77→      expect(() => store.update('doc1', { name: 'v2' })).toThrow();\n    78→    });\n    79→\n    80→    it('should allow creating a document after it was deleted', () => {\n    81→      store.create('doc1', { name: 'v1' });\n    82→      store.delete('doc1');\n    83→      store.create('doc1', { name: 'v2' });\n    84→      expect(store.get('doc1')).toEqual({ name: 'v2' });\n    85→    });\n    86→  });\n    87→\n    88→  describe('Version History', () => {\n    89→    it('should track versions on create', () => {\n    90→      store.create('doc1', { name: 'v1' });\n    91→      const history = store.getHistory('doc1');\n    92→      expect(history).toHaveLength(1);\n    93→      expect(history[0].content).toEqual({ name: 'v1' });\n    94→    });\n    95→\n    96→    it('should track versions on update', () => {\n    97→      store.create('doc1', { name: 'v1' });\n    98→      store.update('doc1', { name: 'v2' });\n    99→      store.update('doc1', { name: 'v3' });\n   100→      const history = store.getHistory('doc1');\n   101→      expect(history).toHaveLength(3);\n   102→      expect(history[0].content).toEqual({ name: 'v1' });\n   103→      expect(history[1].content).toEqual({ name: 'v2' });\n   104→      expect(history[2].content).toEqual({ name: 'v3' });\n   105→    });\n   106→\n   107→    it('should return versions in chronological order', () => {\n   108→      store.create('doc1', { v: 1 });\n   109→      store.update('doc1', { v: 2 });\n   110→      store.update('doc1', { v: 3 });\n   111→      const history = store.getHistory('doc1');\n   112→      for (let i = 1; i < history.length; i++) {\n   113→        expect(history[i].timestamp).toBeGreaterThanOrEqual(history[i - 1].timestamp);\n   114→      }\n   115→    });\n   116→\n   117→    it('should get a specific version', () => {\n   118→      store.create('doc1', { v: 1 });\n   119→      store.update('doc1', { v: 2 });\n   120→      const history = store.getHistory('doc1');\n   121→      const v1Content = store.getVersion('doc1', history[0].id);\n   122→      expect(v1Content).toEqual({ v: 1 });\n   123→    });\n   124→\n   125→    it('should throw for non-existent version', () => {\n   126→      store.create('doc1', { v: 1 });\n   127→      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();\n   128→    });\n   129→\n   130→    it('should throw getHistory for non-existent document', () => {\n   131→      expect(() => store.getHistory('nonexistent')).toThrow();\n   132→    });\n   133→\n   134→    it('should throw getVersion for non-existent document', () => {\n   135→      expect(() => store.getVersion('nonexistent', 'v1')).toThrow();\n   136→    });\n   137→\n   138→    it('should have unique version ids', () => {\n   139→      store.create('doc1', { v: 1 });\n   140→      store.update('doc1', { v: 2 });\n   141→      store.update('doc1', { v: 3 });\n   142→      const history = store.getHistory('doc1');\n   143→      const ids = history.map(v => v.id);\n   144→      expect(new Set(ids).size).toBe(ids.length);\n   145→    });\n   146→\n   147→    it('should deep clone version content', () => {\n   148→      store.create('doc1', { nested: { x: 1 } });\n   149→      const history = store.getHistory('doc1');\n   150→      (history[0].content as Record<string, Record<string, number>>).nested.x = 999;\n   151→      expect(store.getHistory('doc1')[0].content).toEqual({ nested: { x: 1 } });\n   152→    });\n   153→  });\n   154→\n   155→  describe('Branching', () => {\n   156→    it('should start on main branch', () => {\n   157→      expect(store.getBranch()).toBe('main');\n   158→    });\n   159→\n   160→    it('should create and switch to a branch', () => {\n   161→      store.createBranch('feature');\n   162→      store.switchBranch('feature');\n   163→      expect(store.getBranch()).toBe('feature');\n   164→    });\n   165→\n   166→    it('should list branches', () => {\n   167→      store.createBranch('feature');\n   168→      store.createBranch('bugfix');\n   169→      expect(store.listBranches()).toContain('main');\n   170→      expect(store.listBranches()).toContain('feature');\n   171→      expect(store.listBranches()).toContain('bugfix');\n   172→    });\n   173→\n   174→    it('should throw when creating duplicate branch', () => {\n   175→      store.createBranch('feature');\n   176→      expect(() => store.createBranch('feature')).toThrow();\n   177→    });\n   178→\n   179→    it('should throw when switching to non-existent branch', () => {\n   180→      expect(() => store.switchBranch('nonexistent')).toThrow();\n   181→    });\n   182→\n   183→    it('should isolate changes between branches', () => {\n   184→      store.create('doc1', { name: 'original' });\n   185→      store.createBranch('feature');\n   186→      store.switchBranch('feature');\n   187→\n   188→      store.update('doc1', { name: 'modified' });\n   189→      expect(store.get('doc1')).toEqual({ name: 'modified' });\n   190→\n   191→      store.switchBranch('main');\n   192→      expect(store.get('doc1')).toEqual({ name: 'original' });\n   193→    });\n   194→\n   195→    it('should branch from specified branch', () => {\n   196→      store.create('doc1', { name: 'main' });\n   197→      store.createBranch('feature');\n   198→      store.switchBranch('feature');\n   199→      store.update('doc1', { name: 'feature' });\n   200→\n   201→      store.switchBranch('main');\n   202→      store.createBranch('from-feature', 'feature');\n   203→      store.switchBranch('from-feature');\n   204→      expect(store.get('doc1')).toEqual({ name: 'feature' });\n   205→    });\n   206→\n   207→    it('should isolate document creation between branches', () => {\n   208→      store.createBranch('feature');\n   209→      store.switchBranch('feature');\n   210→      store.create('doc1', { name: 'feature-only' });\n   211→\n   212→      store.switchBranch('main');\n   213→      expect(() => store.get('doc1')).toThrow();\n   214→    });\n   215→\n   216→    it('should isolate document deletion between branches', () => {\n   217→      store.create('doc1', { name: 'test' });\n   218→      store.createBranch('feature');\n   219→      store.switchBranch('feature');\n   220→      store.delete('doc1');\n   221→\n   222→      store.switchBranch('main');\n   223→      expect(store.get('doc1')).toEqual({ name: 'test' });\n   224→    });\n   225→\n   226→    it('should throw when branching from non-existent branch', () => {\n   227→      expect(() => store.createBranch('feature', 'nonexistent')).toThrow();\n   228→    });\n   229→  });\n   230→\n   231→  describe('Merging', () => {\n   232→    it('should merge non-conflicting changes from