ne(theirsVal),\n    });\n  }\n\n  // Clean up empty parent objects that resulted from deletion\n  cleanEmptyObjects(merged);\n\n  return { merged, conflicts };\n}\n\nfunction cleanEmptyObjects(obj: Record<string, unknown>): void {\n  for (const key of Object.keys(obj)) {\n    if (isPlainObject(obj[key])) {\n      cleanEmptyObjects(obj[key] as Record<string, unknown>);\n      if (Object.keys(obj[key] as Record<string, unknown>).length === 0) {\n        delete obj[key];\n      }\n    }\n  }\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = 'main';\n\n  constructor() {\n    this.branches.set('main', {\n      documents: new Map(),\n      parentBranch: null,\n      branchPointSnapshots: new Map(),\n    });\n  }\n\n  // Document CRUD\n\n  create(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: clone(content),\n    };\n\n    branch.documents.set(id, {\n      content: clone(content),\n      versions: [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n    return clone(entry.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getCurrentBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" not found`);\n    }\n\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: clone(content),\n    };\n\n    entry.content