+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LqmbCU5wftfAYM1aXFVSGk","type":"tool_result","content":"     1→import { Request, Response, NextFunction } from \"express\";\n     2→import jwt from \"jsonwebtoken\";\n     3→\n     4→const JWT_SECRET = process.env.JWT_SECRET || \"analytics-dashboard-secret\";\n     5→\n     6→export interface AuthPayload {\n     7→  userId: string;\n     8→  tenantId: string;\n     9→  role: string;\n    10→  email: string;\n    11→}\n    12→\n    13→export interface AuthRequest extends Request {\n    14→  user?: AuthPayload;\n    15→}\n    16→\n    17→export function signToken(payload: AuthPayload): string {\n    18→  return jwt.sign(payload, JWT_SECRET, { expiresIn: \"24h\" });\n    19→}\n    20→\n    21→export function verifyToken(token: string): AuthPayload {\n    22→  return jwt.verify(token, JWT_SECRET) as AuthPayload;\n    23→}\n    24→\n    25→export function authenticate(\n    26→  req: AuthRequest,\n    27→  res: Response,\n    28→  next: NextFunction\n    29→): void {\n    30→  const authHeader = req.headers.authorization;\n    31→  if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n    32→    res.status(401).json({ error: \"Authentication required\" });\n    33→    return;\n    34→  }\n    35→\n    36→  const token = authHeader.slice(7);\n    37→  try {\n    38→    const payload = verifyToken(token);\n    39→    req.user = payload;\n    40→    next();\n    41→  } catch {\n    42→    res.status(401).json({ error: \"Invalid or expired token\" });\n    43→  }\n    44→}\n    45→"}]},"parent_tool_use_id":"toolu_01NpzdRi7BEm3BXPjZeRa3sm","session_id":"258ebd09-1e5b-43b8-9837-f8074adae159","uuid":"ccdeb355-d246-4b7d-aeec-429f8a4ea3f2"}
