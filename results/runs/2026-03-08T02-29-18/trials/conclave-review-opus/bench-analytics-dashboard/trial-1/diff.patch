+import { Router, Response } from "express";
+import { getDb } from "../db.js";
+import { AuthRequest, authenticate } from "../auth.js";
+
+const router = Router();
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = "id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map((e) => {
+    const props = e.properties.replace(/"/g, '""');
+    return `${e.id},${e.name},"${props}",${e.timestamp},${e.user_id || ""},${e.session_id || ""}`;
+  });
+  return [header, ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: DashboardRow[]): string {
+  const header = "id,name,owner_id,config,created_at,updated_at";
+  const rows = dashboards.map((d) => {
+    const config = d.config.replace(/"/g, '""');
+    return `${d.id},${d.name},${d.owner_id},"${config}",${d.created_at},${d.updated_at}`;
+  });
+  return [header, ...rows].join("\n");
+}
+
+// Export events as JSON
+router.get("/events/json", authenticate, (req: AuthRequest, res: Response) => {
+  const db = getDb();
+  const { eventName, startDate, endDate } = req.query;
+
+  let query = "SELECT * FROM events WHERE tenant_id = ?";
+  const params: unknown[] = [req.user!.tenantId];
+
+  if (eventName) {
+    query += " AND name = ?";
+    params.push(eventName);
+  }
+  if (startDate) {
+    query += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+  if (endDate) {
+    query += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  query += " ORDER BY timestamp DESC";
+
+  const events = db.prepare(query).all(...params) as EventRow[];
+  const mapped = events.map((e) => ({
+    id: e.id,
+    name: e.name,
+    properties: JSON.parse(e.properties),
+    timestamp: e.timestamp,
+    userId: e.user_id,
+    sessionId: e.session_id,
+  }));
+
+  res.json({ events: mapped });
+});
+
+// Export events as CSV
+router.get("/events/csv", authenticate, (req: AuthRequest, res: Response) => {
+  const db = getDb();
+  const { eventName, startDate, endDate } = req.query;
+
+  let query = "SELECT * FROM events WHERE tenant_id = ?";
+  const params: unknown[] = [req.user!.tenantId];
+
+  if (eventName) {
+    query += " AND name = ?";
+    params.push(eventName);
+  }
+  if (startDate) {
+    query += " AND timestamp >= ?";
+    params.push(startDate);
+  }
+  if (endDate) {
+    query += " AND timestamp <= ?";
+    params.push(endDate);
+  }
+
+  query += " ORDER BY timestamp DESC";
+
+  const events = db.prepare(query).all(...params) as EventRow[];
+  const csv = eventsToCsv(events);
+
+  res.setHeader("Content-Type", "text/csv");
+  res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+  res.send(csv);
+});
+
+// Export dashboards as JSON
+router.get("/dashboards/json", authenticate, (req: AuthRequest, res: Response) => {
+  const db = getDb();
+  const dashboards = db
+    .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+    .all(req.user!.tenantId) as DashboardRow[];
+
+  const mapped = dashboards.map((d) => ({
+    id: d.id,
+    name: d.name,
+    ownerId: d.owner_id,
+    config: JSON.parse(d.config),
+    createdAt: d.created_at,
+    updatedAt: d.updated_at,
+  }));
+
+  res.json({ dashboards: mapped });
+});
+
+// Export dashboards as CSV
+router.get("/dashboards/csv", authenticate, (req: AuthRequest, res: Response) => {
+  const db = getDb();
+  const dashboards = db
+    .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+    .all(req.user!.tenantId) as DashboardRow[];
+
+  const csv = dashboardsToCsv(dashboards);
+
+  res.setHeader("Content-Type", "text/csv");
+  res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+  res.send(csv);
+});
+
+export default router;
