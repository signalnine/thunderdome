+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M3qhmmL2GbGbpytgWapf9i","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import { getDb } from \"../db.js\";\n     3→import { AuthRequest, authenticate } from \"../auth.js\";\n     4→\n     5→const router = Router();\n     6→\n     7→interface EventRow {\n     8→  id: string;\n     9→  tenant_id: string;\n    10→  name: string;\n    11→  properties: string;\n    12→  timestamp: string;\n    13→  user_id: string | null;\n    14→  session_id: string | null;\n    15→}\n    16→\n    17→interface DashboardRow {\n    18→  id: string;\n    19→  tenant_id: string;\n    20→  name: string;\n    21→  owner_id: string;\n    22→  config: string;\n    23→  created_at: string;\n    24→  updated_at: string;\n    25→}\n    26→\n    27→function eventsToCsv(events: EventRow[]): string {\n    28→  const header = \"id,name,properties,timestamp,user_id,session_id\";\n    29→  const rows = events.map((e) => {\n    30→    const props = e.properties.replace(/\"/g, '\"\"');\n    31→    return `${e.id},${e.name},\"${props}\",${e.timestamp},${e.user_id || \"\"},${e.session_id || \"\"}`;\n    32→  });\n    33→  return [header, ...rows].join(\"\\n\");\n    34→}\n    35→\n    36→function dashboardsToCsv(dashboards: DashboardRow[]): string {\n    37→  const header = \"id,name,owner_id,config,created_at,updated_at\";\n    38→  const rows = dashboards.map((d) => {\n    39→    const config = d.config.replace(/\"/g, '\"\"');\n    40→    return `${d.id},${d.name},${d.owner_id},\"${config}\",${d.created_at},${d.updated_at}`;\n    41→  });\n    42→  return [header, ...rows].join(\"\\n\");\n    43→}\n    44→\n    45→// Export events as JSON\n    46→router.get(\"/events/json\", authenticate, (req: AuthRequest, res: Response) => {\n    47→  const db = getDb();\n    48→  const { eventName, startDate, endDate } = req.query;\n    49→\n    50→  let query = \"SELECT * FROM events WHERE tenant_id = ?\";\n    51→  const params: unknown[] = [req.user!.tenantId];\n    52→\n    53→  if (eventName) {\n    54→    query += \" AND name = ?\";\n    55→    params.push(eventName);\n    56→  }\n    57→  if (startDate) {\n    58→    query += \" AND timestamp >= ?\";\n    59→    params.push(startDate);\n    60→  }\n    61→  if (endDate) {\n    62→    query += \" AND timestamp <= ?\";\n    63→    params.push(endDate);\n    64→  }\n    65→\n    66→  query += \" ORDER BY timestamp DESC\";\n    67→\n    68→  const events = db.prepare(query).all(...params) as EventRow[];\n    69→  const mapped = events.map((e) => ({\n    70→    id: e.id,\n    71→    name: e.name,\n    72→    properties: JSON.parse(e.properties),\n    73→    timestamp: e.timestamp,\n    74→    userId: e.user_id,\n    75→    sessionId: e.session_id,\n    76→  }));\n    77→\n    78→  res.json({ events: mapped });\n    79→});\n    80→\n    81→// Export events as CSV\n    82→router.get(\"/events/csv\", authenticate, (req: AuthRequest, res: Response) => {\n    83→  const db = getDb();\n    84→  const { eventName, startDate, endDate } = req.query;\n    85→\n    86→  let query = \"SELECT * FROM events WHERE tenant_id = ?\";\n    87→  const params: unknown[] = [req.user!.tenantId];\n    88→\n    89→  if (eventName) {\n    90→    query += \" AND name = ?\";\n    91→    params.push(eventName);\n    92→  }\n    93→  if (startDate) {\n    94→    query += \" AND timestamp >= ?\";\n    95→    params.push(startDate);\n    96→  }\n    97→  if (endDate) {\n    98→    query += \" AND timestamp <= ?\";\n    99→    params.push(endDate);\n   100→  }\n   101→\n   102→  query += \" ORDER BY timestamp DESC\";\n   103→\n   104→  const events = db.prepare(query).all(...params) as EventRow[];\n   105→  const csv = eventsToCsv(events);\n   106→\n   107→  res.setHeader(\"Content-Type\", \"text/csv\");\n   108→  res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n   109→  res.send(csv);\n   110→});\n   111→\n   112→// Export dashboards as JSON\n   113→router.get(\"/dashboards/json\", authenticate, (req: AuthRequest, res: Response) => {\n   114→  const db = getDb();\n   115→  const dashboards = db\n   116→    .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n   117→    .all(req.user!.tenantId) as DashboardRow[];\n   118→\n   119→  const mapped = dashboards.map((d) => ({\n   120→    id: d.id,\n   121→    name: d.name,\n   122→    ownerId: d.owner_id,\n   123→    config: JSON.parse(d.config),\n   124→    createdAt: d.created_at,\n   125→    updatedAt: d.updated_at,\n   126→  }));\n   127→\n   128→  res.json({ dashboards: mapped });\n   129→});\n   130→\n   131→// Export dashboards as CSV\n   132→router.get(\"/dashboards/csv\", authenticate, (req: AuthRequest, res: Response) => {\n   133→  const db = getDb();\n   134→  const dashboards = db\n   135→    .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n   136→    .all(req.user!.tenantId) as DashboardRow[];\n   137→\n   138→  const csv = dashboardsToCsv(dashboards);\n   139→\n   140→  res.setHeader(\"Content-Type\", \"text/csv\");\n   141→  res.setHeader(\"Content-Disposition\", \"attachment; filename=dashboards.csv\");\n   142→  res.send(csv);\n   143→});\n   144→\n   145→export default router;\n   146→"}]},"parent_tool_use_id":"toolu_01NpzdRi7BEm3BXPjZeRa3sm","session_id":"258ebd09-1e5b-43b8-9837-f8074adae159","uuid":"81a06541-0444-44b8-9f2b-f829ec02a38e"}
