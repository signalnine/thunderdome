+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import request from "supertest";
+import { createApp } from "./app.js";
+import { resetDb } from "./db.js";
+import type { Express } from "express";
+
+let app: Express;
+
+beforeEach(() => {
+  resetDb();
+  app = createApp();
+});
+
+afterEach(() => {
+  resetDb();
+});
+
+async function registerUser(
+  overrides: Partial<{ email: string; password: string; tenantId: string; role: string }> = {}
+) {
+  const data = {
+    email: overrides.email || "test@example.com",
+    password: overrides.password || "password123",
+    tenantId: overrides.tenantId || "tenant1",
+    role: overrides.role || "admin",
+  };
+  const res = await request(app).post("/auth/register").send(data);
+  return res;
+}
+
+async function getToken(
+  overrides: Partial<{ email: string; password: string; tenantId: string; role: string }> = {}
+): Promise<string> {
+  const res = await registerUser(overrides);
+  return res.body.token;
+}
+
+describe("Health", () => {
+  it("returns ok", async () => {
+    const res = await request(app).get("/health");
+    expect(res.status).toBe(200);
+    expect(res.body.status).toBe("ok");
+  });
+});
+
+describe("Auth", () => {
+  it("registers a new user", async () => {
+    const res = await registerUser();
+    expect(res.status).toBe(201);
+    expect(res.body.email).toBe("test@example.com");
+    expect(res.body.token).toBeDefined();
+    expect(res.body.tenantId).toBe("tenant1");
+  });
+
+  it("rejects duplicate email", async () => {
+    await registerUser();
+    const res = await registerUser();
+    expect(res.status).toBe(409);
+  });
+
+  it("login with valid credentials", async () => {
+    await registerUser();
+    const res = await request(app)
+      .post("/auth/login")
+      .send({ email: "test@example.com", password: "password123" });
+    expect(res.status).toBe(200);
+    expect(res.body.token).toBeDefined();
+  });
+
+  it("login with invalid credentials returns 401", async () => {
+    await registerUser();
+    const res = await request(app)
+      .post("/auth/login")
+      .send({ email: "test@example.com", password: "wrongpassword" });
+    expect(res.status).toBe(401);
+  });
+
+  it("get profile", async () => {
+    const token = await getToken();
+    const res = await request(app)
+      .get("/auth/me")
+      .set("Authorization", `Bearer ${token}`);
+    expect(res.status).toBe(200);
+    expect(res.body.email).toBe("test@example.com");
+    expect(res.body.tenantId).toBe("tenant1");
+  });
+
+  it("rejects unauthenticated profile request", async () => {
+    const res = await request(app).get("/auth/me");
+    expect(res.status).toBe(401);
+  });
+
+  it("admin can change user role", async () => {
+    const adminToken = await getToken({ email: "admin@test.com", role: "admin" });
+    const viewerRes = await registerUser({ email: "viewer@test.com", role: "viewer" });
+    const viewerId = viewerRes.body.id;
+
+    const res = await request(app)
+      .put(`/auth/users/${viewerId}/role`)
+      .set("Authorization", `Bearer ${adminToken}`)
+      .send({ role: "editor" });
+    expect(res.status).toBe(200);
+    expect(res.body.role).toBe("editor");
+  });
+
+  it("non-admin cannot change user role", async () => {
+    const viewerToken = await getToken({ email: "viewer@test.com", role: "viewer" });
+    const otherRes = await registerUser({ email: "other@test.com", role: "viewer" });
+    const otherId = otherRes.body.id;
+
+    const res = await request(app)
+      .put(`/auth/users/${otherId}/role`)
+      .set("Authorization", `Bearer ${viewerToken}`)
+      .send({ role: "editor" });
+    expect(res.status).toBe(403);
+  });
+
+  it("cannot change role of user in different tenant", async () => {
+    const adminToken = await getToken({ email: "admin@test.com", role: "admin", tenantId: "tenant1" });
+    const otherRes = await registerUser({ email: "other@test.com", role: "viewer", tenantId: "tenant2" });
+    const otherId = otherRes.body.id;
+
+    const res = await request(app)
+      .put(`/auth/users/${otherId}/role`)
+      .set("Authorization", `Bearer ${adminToken}`)
+      .send({ role: "editor" });
+    expect(res.status).toBe(403);
+  });
+});
+
+describe("Events", () => {
+  it("ingest single event", async () => {
+    const token = await getToken();
+    const res = await request(app)
+      .post("/events")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ name: "page_view", properties: { url: "/home" } });
+    expect(res.status).toBe(201);
+    expect(res.body.name).toBe("page_view");
+  });
+
+  it("reject unauthenticated event", async () => {
+    const res = await request(app)
+      .post("/events")
+      .send({ name: "page_view" });
+    expect(res.status).toBe(401);
+  });
+
+  it("ingest batch events", async () => {
+    const token = await getToken();
+    const res = await request(app)
+      .post("/events/batch")
+      .set("Authorization", `Bearer ${token}`)
+      .send({
+        events: [
+          { name: "page_view", properties: { url: "/home" } },
+          { name: "click", properties: { button: "signup" } },
+          { name: "page_view", properties: { url: "/about" } },
+        ],
+      });
+    expect(res.status).toBe(201);
+    expect(res.body.ingested).toBe(3);
+  });
+
+  it("reject batch with no events", async () => {
+    const token = await getToken();
+    const res = await request(app)
+      .post("/events/batch")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ events: [] });
+    expect(res.status).toBe(400);
+  });
+});
+
+describe("Query Engine", () => {
+  let token: string;
+
+  beforeEach(async () => {
+    token = await getToken();
+    // Insert test events
+    await request(app)
+      .post("/events/batch")
+      .set("Authorization", `Bearer ${token}`)
+      .send({
+        events: [
+          { name: "page_view", properties: { url: "/home" }, timestamp: "2024-01-15T10:00:00Z" },
+          { name: "page_view", properties: { url: "/about" }, timestamp: "2024-01-15T11:00:00Z" },
+          { name: "page_view", properties: { url: "/home" }, timestamp: "2024-01-16T10:00:00Z" },
+          { name: "click", properties: { button: "signup" }, timestamp: "2024-01-16T12:00:00Z" },
+          { name: "click", properties: { button: "login" }, timestamp: "2024-01-16T13:00:00Z" },
+        ],
+      });
+  });
+
+  it("count all events", async () => {
+    const res = await request(app)
+      .post("/query/count")
+      .set("Authorization", `Bearer ${token}`)
+      .send({});
+    expect(res.status).toBe(200);
+    expect(res.body.count).toBe(5);
+  });
+
+  it("count filtered events", async () => {
+    const res = await request(app)
+      .post("/query/count")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ filter: { eventName: "page_view" } });
+    expect(res.status).toBe(200);
+    expect(res.body.count).toBe(3);
+  });
+
+  it("timeseries query", async () => {
+    const res = await request(app)
+      .post("/query/timeseries")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ filter: { eventName: "page_view" }, interval: "day" });
+    expect(res.status).toBe(200);
+    expect(res.body.timeseries.length).toBe(2);
+  });
+
+  it("breakdown query", async () => {
+    const res = await request(app)
+      .post("/query/breakdown")
+      .set("Authorization", `Bearer ${token}`)
+      .send({ filter: { eventName: "page_view" }, property: "url" });
+    expect(res.status).toBe(200);
+    expect(res.body.breakdown.length).toBe(2);
+    expect(res.body.breakdown[0].value).toBe("/home");
+    expect(res.body.breakdown[0].count).toBe(2);
+  });
+
+  it("tenant isolation in queries", async () => {
+    const otherToken = await getToken({ email: "other@example.com", tenantId: "tenant2" });
+    const res = await request(app)
+      .post("/query/count")
+      .set("Authorization", `Bearer ${otherToken}`)
+      .send({});
+    expect(res.status).toBe(200);
+    expect(res.body.count).toBe(0);
+  });
+});
+
+describe("Dashboards", () => {
+  let token: string;
+
+  beforeEach(async () => {
+    token = await getToken();
+  });
+
+  it("create dashboard", async () => {
+    const res = await request(app)
+      .post("/dashboards")
