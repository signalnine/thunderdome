+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AiGjoP4qerv7GF5SDrV1t2","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import { v4 as uuidv4 } from \"uuid\";\n     3→import { getDb } from \"../db.js\";\n     4→import { AuthRequest, authenticate } from \"../auth.js\";\n     5→\n     6→const router = Router();\n     7→\n     8→// Create dashboard\n     9→router.post(\"/\", authenticate, (req: AuthRequest, res: Response) => {\n    10→  const { name, config } = req.body;\n    11→\n    12→  if (!name) {\n    13→    res.status(400).json({ error: \"Dashboard name is required\" });\n    14→    return;\n    15→  }\n    16→\n    17→  const db = getDb();\n    18→  const id = uuidv4();\n    19→  const now = new Date().toISOString();\n    20→  const dashConfig = config ? JSON.stringify(config) : \"{}\";\n    21→\n    22→  db.prepare(\n    23→    \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    24→  ).run(id, req.user!.tenantId, name, req.user!.userId, dashConfig, now, now);\n    25→\n    26→  res.status(201).json({\n    27→    id,\n    28→    name,\n    29→    tenantId: req.user!.tenantId,\n    30→    ownerId: req.user!.userId,\n    31→    config: config || {},\n    32→    createdAt: now,\n    33→    updatedAt: now,\n    34→  });\n    35→});\n    36→\n    37→// List dashboards for tenant\n    38→router.get(\"/\", authenticate, (req: AuthRequest, res: Response) => {\n    39→  const db = getDb();\n    40→  const dashboards = db\n    41→    .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n    42→    .all(req.user!.tenantId) as Array<{\n    43→    id: string;\n    44→    tenant_id: string;\n    45→    name: string;\n    46→    owner_id: string;\n    47→    config: string;\n    48→    created_at: string;\n    49→    updated_at: string;\n    50→  }>;\n    51→\n    52→  res.json({\n    53→    dashboards: dashboards.map((d) => ({\n    54→      id: d.id,\n    55→      name: d.name,\n    56→      tenantId: d.tenant_id,\n    57→      ownerId: d.owner_id,\n    58→      config: JSON.parse(d.config),\n    59→      createdAt: d.created_at,\n    60→      updatedAt: d.updated_at,\n    61→    })),\n    62→  });\n    63→});\n    64→\n    65→// Get single dashboard\n    66→router.get(\"/:id\", authenticate, (req: AuthRequest, res: Response) => {\n    67→  const db = getDb();\n    68→  const dashboard = db\n    69→    .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n    70→    .get(req.params.id, req.user!.tenantId) as {\n    71→    id: string;\n    72→    tenant_id: string;\n    73→    name: string;\n    74→    owner_id: string;\n    75→    config: string;\n    76→    created_at: string;\n    77→    updated_at: string;\n    78→  } | undefined;\n    79→\n    80→  if (!dashboard) {\n    81→    res.status(404).json({ error: \"Dashboard not found\" });\n    82→    return;\n    83→  }\n    84→\n    85→  res.json({\n    86→    id: dashboard.id,\n    87→    name: dashboard.name,\n    88→    tenantId: dashboard.tenant_id,\n    89→    ownerId: dashboard.owner_id,\n    90→    config: JSON.parse(dashboard.config),\n    91→    createdAt: dashboard.created_at,\n    92→    updatedAt: dashboard.updated_at,\n    93→  });\n    94→});\n    95→\n    96→// Update dashboard\n    97→router.put(\"/:id\", authenticate, (req: AuthRequest, res: Response) => {\n    98→  const { name, config } = req.body;\n    99→\n   100→  const db = getDb();\n   101→  const existing = db\n   102→    .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n   103→    .get(req.params.id, req.user!.tenantId) as { id: string } | undefined;\n   104→\n   105→  if (!existing) {\n   106→    res.status(404).json({ error: \"Dashboard not found\" });\n   107→    return;\n   108→  }\n   109→\n   110→  const now = new Date().toISOString();\n   111→  const updates: string[] = [\"updated_at = ?\"];\n   112→  const params: unknown[] = [now];\n   113→\n   114→  if (name !== undefined) {\n   115→    updates.push(\"name = ?\");\n   116→    params.push(name);\n   117→  }\n   118→  if (config !== undefined) {\n   119→    updates.push(\"config = ?\");\n   120→    params.push(JSON.stringify(config));\n   121→  }\n   122→\n   123→  params.push(req.params.id);\n   124→  db.prepare(`UPDATE dashboards SET ${updates.join(\", \")} WHERE id = ?`).run(...params);\n   125→\n   126→  const updated = db.prepare(\"SELECT * FROM dashboards WHERE id = ?\").get(req.params.id) as {\n   127→    id: string;\n   128→    tenant_id: string;\n   129→    name: string;\n   130→    owner_id: string;\n   131→    config: string;\n   132→    created_at: string;\n   133→    updated_at: string;\n   134→  };\n   135→\n   136→  res.json({\n   137→    id: updated.id,\n   138→    name: updated.name,\n   139→    tenantId: updated.tenant_id,\n   140→    ownerId: updated.owner_id,\n   141→    config: JSON.parse(updated.config),\n   142→    createdAt: updated.created_at,\n   143→    updatedAt: updated.updated_at,\n   144→  });\n   145→});\n   146→\n   147→// Delete dashboard\n   148→router.delete(\"/:id\", authenticate, (req: AuthRequest, res: Response) => {\n   149→  const db = getDb();\n   150→  const existing = db\n   151→    .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n   152→    .get(req.params.id, req.user!.tenantId) as { id: string } | undefined;\n   153→\n   154→  if (!existing) {\n   155→    res.status(404).json({ error: \"Dashboard not found\" });\n   156→    return;\n   157→  }\n   158→\n   159→  db.prepare(\"DELETE FROM dashboards WHERE id = ?\").run(req.params.id);\n   160→  res.status(204).send();\n   161→});\n   162→\n   163→export default router;\n   164→"}]},"parent_tool_use_id":"toolu_01NpzdRi7BEm3BXPjZeRa3sm","session_id":"258ebd09-1e5b-43b8-9837-f8074adae159","uuid":"b0b5aab7-e2c4-4d1f-bff1-3aed2b50d7fb"}
