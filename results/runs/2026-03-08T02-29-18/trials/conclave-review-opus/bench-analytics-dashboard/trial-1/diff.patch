ereClause(req.user!.tenantId, filter);\n\n  let dateFormat: string;\n  switch (interval) {\n    case \"hour\":\n      dateFormat = \"%Y-%m-%dT%H:00:00\";\n      break;\n    case \"month\":\n      dateFormat = \"%Y-%m-01\";\n      break;\n    case \"day\":\n    default:\n      dateFormat = \"%Y-%m-%d\";\n      break;\n  }\n\n  const rows = db\n    .prepare(\n      `SELECT strftime('${dateFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE ${where} GROUP BY bucket ORDER BY bucket`\n    )\n    .all(...params) as Array<{ bucket: string; count: number }>;\n\n  res.json({ timeseries: rows });\n});\n\n// Breakdown query\nrouter.post(\"/breakdown\", authenticate, (req: AuthRequest, res: Response) => {\n  const { filter, property } = req.body as { filter?: QueryFilter; property: string };\n\n  if (!property) {\n    res.status(400).json({ error: \"property field is required for breakdown queries\" });\n    return;\n  }\n\n  const db = getDb();\n  const { where, params } = buildWhereClause(req.user!.tenantId, filter);\n\n  const rows = db\n    .prepare(\n      `SELECT json_extract(properties, '$.' || ?) as prop_value, COUNT(*) as count FROM events WHERE ${where} AND json_extract(properties, '$.' || ?) IS NOT NULL GROUP BY prop_value ORDER BY count DESC`\n    )\n    .all(property, ...params, property) as Array<{ prop_value: string; count: number }>;\n\n  res.json({ breakdown: rows.map((r) => ({ value: r.prop_value, count: r.count })) });\n});\n\nexport default router;\n","structuredPatch":[],"originalFile":null}}
