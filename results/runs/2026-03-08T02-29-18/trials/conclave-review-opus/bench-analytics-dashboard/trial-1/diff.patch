+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014h3YC3ZJ7y65F94NXaMrZ3","type":"tool_result","content":"     1→import { Router, Response } from \"express\";\n     2→import crypto from \"node:crypto\";\n     3→import { v4 as uuidv4 } from \"uuid\";\n     4→import { getDb } from \"../db.js\";\n     5→import { AuthRequest, authenticate, signToken } from \"../auth.js\";\n     6→\n     7→const router = Router();\n     8→\n     9→function hashPassword(password: string): string {\n    10→  return crypto.createHash(\"sha256\").update(password).digest(\"hex\");\n    11→}\n    12→\n    13→// Register\n    14→router.post(\"/register\", (req: AuthRequest, res: Response) => {\n    15→  const { email, password, tenantId, role } = req.body;\n    16→\n    17→  if (!email || !password || !tenantId) {\n    18→    res.status(400).json({ error: \"email, password, and tenantId are required\" });\n    19→    return;\n    20→  }\n    21→\n    22→  const userRole = role && [\"admin\", \"viewer\", \"editor\"].includes(role) ? role : \"viewer\";\n    23→  const id = uuidv4();\n    24→  const passwordHash = hashPassword(password);\n    25→\n    26→  const db = getDb();\n    27→  try {\n    28→    db.prepare(\n    29→      \"INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)\"\n    30→    ).run(id, email, passwordHash, tenantId, userRole);\n    31→\n    32→    const token = signToken({ userId: id, tenantId, role: userRole, email });\n    33→    res.status(201).json({ id, email, tenantId, role: userRole, token });\n    34→  } catch (err: unknown) {\n    35→    const message = err instanceof Error ? err.message : \"Unknown error\";\n    36→    if (message.includes(\"UNIQUE constraint\")) {\n    37→      res.status(409).json({ error: \"Email already registered\" });\n    38→    } else {\n    39→      res.status(500).json({ error: message });\n    40→    }\n    41→  }\n    42→});\n    43→\n    44→// Login\n    45→router.post(\"/login\", (req: AuthRequest, res: Response) => {\n    46→  const { email, password } = req.body;\n    47→\n    48→  if (!email || !password) {\n    49→    res.status(400).json({ error: \"email and password are required\" });\n    50→    return;\n    51→  }\n    52→\n    53→  const db = getDb();\n    54→  const user = db\n    55→    .prepare(\"SELECT * FROM users WHERE email = ?\")\n    56→    .get(email) as { id: string; email: string; password_hash: string; tenant_id: string; role: string } | undefined;\n    57→\n    58→  if (!user || user.password_hash !== hashPassword(password)) {\n    59→    res.status(401).json({ error: \"Invalid credentials\" });\n    60→    return;\n    61→  }\n    62→\n    63→  const token = signToken({\n    64→    userId: user.id,\n    65→    tenantId: user.tenant_id,\n    66→    role: user.role,\n    67→    email: user.email,\n    68→  });\n    69→\n    70→  res.json({ token, user: { id: user.id, email: user.email, tenantId: user.tenant_id, role: user.role } });\n    71→});\n    72→\n    73→// Get profile\n    74→router.get(\"/me\", authenticate, (req: AuthRequest, res: Response) => {\n    75→  const db = getDb();\n    76→  const user = db\n    77→    .prepare(\"SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?\")\n    78→    .get(req.user!.userId) as { id: string; email: string; tenant_id: string; role: string; created_at: string } | undefined;\n    79→\n    80→  if (!user) {\n    81→    res.status(404).json({ error: \"User not found\" });\n    82→    return;\n    83→  }\n    84→\n    85→  res.json({\n    86→    id: user.id,\n    87→    email: user.email,\n    88→    tenantId: user.tenant_id,\n    89→    role: user.role,\n    90→    createdAt: user.created_at,\n    91→  });\n    92→});\n    93→\n    94→// Admin: change user role\n    95→router.put(\"/users/:userId/role\", authenticate, (req: AuthRequest, res: Response) => {\n    96→  if (req.user!.role !== \"admin\") {\n    97→    res.status(403).json({ error: \"Admin access required\" });\n    98→    return;\n    99→  }\n   100→\n   101→  const { role } = req.body;\n   102→  if (!role || ![\"admin\", \"viewer\", \"editor\"].includes(role)) {\n   103→    res.status(400).json({ error: \"Valid role required (admin, viewer, editor)\" });\n   104→    return;\n   105→  }\n   106→\n   107→  const db = getDb();\n   108→  const targetUser = db\n   109→    .prepare(\"SELECT id, tenant_id FROM users WHERE id = ?\")\n   110→    .get(req.params.userId) as { id: string; tenant_id: string } | undefined;\n   111→\n   112→  if (!targetUser) {\n   113→    res.status(404).json({ error: \"User not found\" });\n   114→    return;\n   115→  }\n   116→\n   117→  if (targetUser.tenant_id !== req.user!.tenantId) {\n   118→    res.status(403).json({ error: \"Cannot modify users outside your tenant\" });\n   119→    return;\n   120→  }\n   121→\n   122→  db.prepare(\"UPDATE users SET role = ? WHERE id = ?\").run(role, req.params.userId);\n   123→  res.json({ id: req.params.userId, role });\n   124→});\n   125→\n   126→export default router;\n   127→"}]},"parent_tool_use_id":"toolu_01NpzdRi7BEm3BXPjZeRa3sm","session_id":"258ebd09-1e5b-43b8-9837-f8074adae159","uuid":"f7f82caa-293b-4acc-8a3d-257567e90c65"}
