('should remove a review', () => {\n    const review = reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 4,\n      comment: 'Nice',\n    });\n    const removed = reviews.removeReview(review.id);\n    expect(removed).toBe(true);\n    expect(reviews.getReviews('plugin-a')).toHaveLength(0);\n  });\n\n  it('should return false when removing nonexistent review', () => {\n    expect(reviews.removeReview(999)).toBe(false);\n  });\n\n  it('should get reviews by user', () => {\n    reviews.addReview({\n      pluginName: 'p1',\n      pluginVersion: '1.0.0',\n      userId: 'alice',\n      rating: 5,\n      comment: 'Great',\n    });\n    reviews.addReview({\n      pluginName: 'p2',\n      pluginVersion: '1.0.0',\n      userId: 'alice',\n      rating: 4,\n      comment: 'Good',\n    });\n    reviews.addReview({\n      pluginName: 'p1',\n      pluginVersion: '1.0.0',\n      userId: 'bob',\n      rating: 3,\n      comment: 'Okay',\n    });\n\n    const aliceReviews = reviews.getReviewsByUser('alice');\n    expect(aliceReviews).toHaveLength(2);\n    expect(aliceReviews.every((r) => r.userId === 'alice')).toBe(true);\n  });\n\n  it('should get review count for a plugin', () => {\n    reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'Nice',\n    });\n    reviews.addReview({\n      pluginName: 'plugin-a',\n      pluginVersion: '2.0.0',\n      userId: 'user2',\n      rating: 4,\n      comment: 'Good',\n    });\n    expect(reviews.getReviewCount('plugin-a')).toBe(2);\n    expect(reviews.getReviewCount('nonexistent')).toBe(0);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
