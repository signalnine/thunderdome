ver.satisfies('2.0.0', '^1.0.0')).toBe(false);\n    expect(resolver.satisfies('1.2.3', '~1.2.0')).toBe(true);\n    expect(resolver.satisfies('1.3.0', '~1.2.0')).toBe(false);\n  });\n\n  it('should find max satisfying version', () => {\n    expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0')).toBe('1.5.0');\n    expect(resolver.maxSatisfying(['1.0.0', '2.0.0'], '^3.0.0')).toBeNull();\n  });\n\n  it('should validate ranges', () => {\n    expect(resolver.validRange('^1.0.0')).toBe(true);\n    expect(resolver.validRange('~2.0.0')).toBe(true);\n    expect(resolver.validRange('>=1.0.0 <3.0.0')).toBe(true);\n    expect(resolver.validRange('not-a-range')).toBe(false);\n  });\n\n  it('should handle exact version ranges', () => {\n    const result = resolver.resolve(\n      [{ name: 'foo', range: '1.2.3' }],\n      { foo: ['1.2.3', '1.3.0'] }\n    );\n    expect(result[0].version).toBe('1.2.3');\n  });\n\n  it('should handle wildcard range', () => {\n    const result = resolver.resolve(\n      [{ name: 'foo', range: '*' }],\n      { foo: ['1.0.0', '2.0.0', '3.0.0'] }\n    );\n    expect(result[0].version).toBe('3.0.0');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1749,"cache_read_input_tokens":28858,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1749},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"de02cfdf-443c-4834-9e30-cb87edfae800","uuid":"48d900f5-48f2-422e-a6ce-e54d5379b38f"}
