ree.dependencies).toHaveLength(2);\n    48→      expect(tree.dependencies[0].name).toBe('child1');\n    49→      expect(tree.dependencies[1].name).toBe('child2');\n    50→      expect(tree.dependencies[1].dependencies).toHaveLength(1);\n    51→      expect(tree.dependencies[1].dependencies[0].name).toBe('grandchild');\n    52→    });\n    53→\n    54→    it('should throw for unknown plugin', () => {\n    55→      expect(() => deps.buildTree('nonexistent', registry)).toThrow(\n    56→        'not found'\n    57→      );\n    58→    });\n    59→  });\n    60→\n    61→  describe('detectCycles', () => {\n    62→    it('should return null when no cycles', () => {\n    63→      registry.register(makeManifest('a', { b: '^1.0.0' }));\n    64→      registry.register(makeManifest('b'));\n    65→      expect(deps.detectCycles('a', registry)).toBeNull();\n    66→    });\n    67→\n    68→    it('should detect a direct cycle', () => {\n    69→      registry.register(makeManifest('a', { b: '^1.0.0' }));\n    70→      registry.register(makeManifest('b', { a: '^1.0.0' }));\n    71→      const cycles = deps.detectCycles('a', registry);\n    72→      expect(cycles).not.toBeNull();\n    73→      expect(cycles!.length).toBeGreaterThan(0);\n    74→    });\n    75→\n    76→    it('should detect an indirect cycle', () => {\n    77→      registry.register(makeManifest('a', { b: '^1.0.0' }));\n    78→      registry.register(makeManifest('b', { c: '^1.0.0' }));\n    79→      registry.register(makeManifest('c', { a: '^1.0.0' }));\n    80→      const cycles = deps.detectCycles('a', registry);\n    81→      expect(cycles).not.toBeNull();\n    82→      expect(cycles!.length).toBeGreaterThan(0);\n    83→    });\n    84→  });\n    85→\n    86→  describe('hasCircularDependency', () => {\n    87→    it('should return false when no cycles', () => {\n    88→      registry.register(makeManifest('a', { b: '^1.0.0' }));\n    89→      registry.register(makeManifest('b'));\n    90→      expect(deps.hasCircularDependency('a', registry)).toBe(false);\n    91→    });\n    92→\n    93→    it('should return true when cycles exist', () => {\n    94→      registry.register(makeManifest('a', { b: '^1.0.0' }));\n    95→      registry.register(makeManifest('b', { a: '^1.0.0' }));\n    96→      expect(deps.hasCircularDependency('a', registry)).toBe(true);\n    97→    });\n    98→  });\n    99→\n   100→  describe('topologicalSort', () => {\n   101→    it('should sort a single node', () => {\n   102→      registry.register(makeManifest('a'));\n   103→      const sorted = deps.topologicalSort('a', registry);\n   104→      expect(sorted).toEqual(['a']);\n   105→    });\n   106→\n   107→    it('should sort dependencies before dependents', () => {\n   108→      registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));\n   109→      registry.register(makeManifest('b', { c: '^1.0.0' }));\n   110→      registry.register(makeManifest('c'));\n   111→\n   112→      const sorted = deps.topologicalSort('a', registry);\n   113→      expect(sorted.indexOf('c')).toBeLessThan(sorted.indexOf('b'));\n   114→      expect(sorted.indexOf('b')).toBeLessThan(sorted.indexOf('a'));\n   115→    });\n   116→\n   117→    it('should throw on circular dependency', () => {\n   118→      registry.register(makeManifest('a', { b: '^1.0.0' }));\n   119→      registry.register(makeManifest('b', { a: '^1.0.0' }));\n   120→      expect(() => deps.topologicalSort('a', registry)).toThrow('Circular');\n   121→    });\n   122→  });\n   123→\n   124→  describe('flattenDependencies', () => {\n   125→    it('should return empty array for no dependencies', () => {\n   126→      registry.register(makeManifest('a'));\n   127→      expect(deps.flattenDependencies('a', registry)).toEqual([]);\n   128→    });\n   129→\n   130→    it('should flatten all transitive dependencies', () => {\n   131→      registry.register(makeManifest('a', { b: '^1.0.0', c: '^1.0.0' }));\n   132→      registry.register(makeManifest('b', { d: 