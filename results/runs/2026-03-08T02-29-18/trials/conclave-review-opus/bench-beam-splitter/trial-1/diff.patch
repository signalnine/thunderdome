+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function nextPos(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':       return [row + 1, col];
+    case 'down-left':  return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function findSource(grid: string[][]): [number, number] | null {
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[0][col] === 'S') return [0, col];
+  }
+  return null;
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  if (rows === 0) return 0;
+  const cols = grid[0].length;
+
+  const src = findSource(grid);
+  if (!src) return 0;
+
+  const visited = new Set<string>();
+  const beams: Beam[] = [{ row: src[0], col: src[1], dir: 'down' }];
+  const seen = new Set<string>();
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const { row, col, dir } = beam;
+
+    if (!inBounds(row, col, rows, cols)) continue;
+
+    const key = `${row},${col},${dir}`;
+    if (seen.has(key)) continue;
+    seen.add(key);
+
+    visited.add(`${row},${col}`);
+
+    const cell = grid[row][col];
+
+    if (cell === '^') {
+      const [lr, lc] = nextPos(row, col, 'down-left');
+      const [rr, rc] = nextPos(row, col, 'down-right');
+      beams.push({ row: lr, col: lc, dir: 'down-left' });
+      beams.push({ row: rr, col: rc, dir: 'down-right' });
+    } else {
+      const [nr, nc] = nextPos(row, col, dir);
+      beams.push({ row: nr, col: nc, dir });
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  if (rows === 0) return 0n;
+  const cols = grid[0].length;
+
+  const src = findSource(grid);
+  if (!src) return 0n;
+
+  let totalPaths = 0n;
+
+  // Group beams by row for efficient processing
+  // Use Map<string, bigint> keyed by "col,dir" for merging identical states
+  const beamsByRow: Map<string, bigint>[] = Array.from({ length: rows }, () => new Map());
+
+  const makeKey = (col: number, dir: Direction): string => `${col},${dir}`;
+
+  const addBeam = (r: number, col: number, dir: Direction, count: bigint): void => {
+    if (inBounds(r, col, rows, cols)) {
+      const k = makeKey(col, dir);
+      beamsByRow[r].set(k, (beamsByRow[r].get(k) ?? 0n) + count);
+    } else {
+      totalPaths += count;
+    }
+  };
+
+  addBeam(src[0], src[1], 'down', 1n);
+
+  for (let r = 0; r < rows; r++) {
+    for (const [key, count] of beamsByRow[r]) {
+      const commaIdx = key.indexOf(',');
+      const col = parseInt(key.substring(0, commaIdx));
+      const dir = key.substring(commaIdx + 1) as Direction;
+
+      if (grid[r][col] === '^') {
+        const [lr, lc] = nextPos(r, col, 'down-left');
+        addBeam(lr, lc, 'down-left', count);
+        const [rr, rc] = nextPos(r, col, 'down-right');
+        addBeam(rr, rc, 'down-right', count);
+      } else {
+        const [nr, nc] = nextPos(r, col, dir);
+        addBeam(nr, nc, dir, count);
+      }
+    }
+  }
+
+  return totalPaths;
+}
