rd swaps for random wire names test.\n    expect(result).toEqual(['def', 'ghi', 'mno', 'stu', 'yzc', 'z01', 'z02', 'z03']);\n  });","newString":"  it('should handle swaps with random wire names', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'abc' },\n\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'def' },\n      { op: 'XOR', in1: 'def', in2: 'abc', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'ghi' },\n      { op: 'AND', in1: 'def', in2: 'abc', out: 'jkl' },\n      { op: 'OR', in1: 'ghi', in2: 'jkl', out: 'mno' },\n\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 'pqr' },\n      { op: 'XOR', in1: 'pqr', in2: 'mno', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'stu' },\n      { op: 'AND', in1: 'pqr', in2: 'mno', out: 'vwx' },\n      { op: 'OR', in1: 'stu', in2: 'vwx', out: 'yza' },\n\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 'yzb' },\n      { op: 'XOR', in1: 'yzb', in2: 'yza', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'yzc' },\n      { op: 'AND', in1: 'yzb', in2: 'yza', out: 'yzd' },\n      { op: 'OR', in1: 'yzc', in2: 'yzd', out: 'z04' },\n    ];\n\n    // z01 <-> ghi: second-level XOR output swapped with AND generate output\n    // z02 <-> stu: second-level XOR output swapped with AND generate output\n    // z03 <-> yzc: second-level XOR output swapped with AND generate output\n    // mno <-> yzd: OR carry output swapped with AND propagate output from later bit\n    // mno = OR(ghi,jkl), consumed by XOR(pqr,mno) and AND(pqr,mno)\n    // yzd = AND(yzb,yza), consumed by OR(yzc,yzd)\n    // After swap: OR(ghi,jkl)->yzd, AND(yzb,yza)->mno\n    // yzd consumed by OR(yzc,yzd) — reads from OR(ghi,jkl). OR feeding into OR! Rule 5 flags.\n    // mno consumed by XOR(pqr,mno) and AND(pqr,mno) — AND output NOT consumed by OR. Rule 4 flags.\n    swapOutputs(gates, 'z01', 'ghi');\n    swapOutputs(gates, 'z02', 'stu');\n    swapOutputs(gates, 'z03', 'yzc');\n    swapOutputs(gates, 'mno', 'yzd');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['ghi', 'mno', 'stu', 'yzc', 'yzd', 'z01', 'z02', 'z03']);\n  });","originalFile":"import { describe, it, expect } from 'vitest';\nimport { simulate, findSwappedWires, Gate } from '../src/index.js';\n\ndescribe('simulate', () => {\n  it('should handle a single AND gate', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle a single OR gate', () => {\n    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });\n  });\n\n  it('should handle a single XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({\n      a: 0, b: 1, c: 0, d: 0, e: 0,\n    });\n  });\n\n  it('should handle gates listed in reverse dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1, b: 1, c: 1, d: 0, e: 1,\n    });\n  });\n\n  it('should simulate a correct 2-bit adder', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n    // 3 + 2 = 5: x=11, y=10 -> z=101\n    const result = simulate(gates, {\n      x00: 1, x01: 1, y00: 0, y01: 1,\n    });\n    expect(result['z00']).toBe(1);\n    expect(result['z01']).toBe(0);\n    expect(result['z02']).toBe(1);\n  });\n\n  it('should simulate a 4-bit adder correctly', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    // 15 + 1 = 16\n    const result = simulate(gates, {\n      x00: 1, x01: 1, x02: 1, x03: 1,\n      y00: 1, y01: 0, y02: 0, y03: 0,\n    });\n    expect(result['z00']).toBe(0);\n    expect(result['z01']).toBe(0);\n    expect(result['z02']).toBe(0);\n    expect(result['z03']).toBe(0);\n    expect(result['z04']).toBe(1);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  function makeAdder(numBits: number): Gate[] {\n    const gates: Gate[] = [];\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n    for (let i = 1; i < numBits; i++) {\n      const idx = String(i).padStart(2, '0');\n      const prevIdx = String(i - 1).padStart(2, '0');\n      gates.push({ op: 'XOR', in1: `x${idx}`, in2: `y${idx}`, out: `t${idx}` });\n      gates.push({ op: 'XOR', in1: `t${idx}`, in2: `c${prevIdx}`, out: `z${idx}` });\n      gates.push({ op: 'AND', in1: `x${idx}`, in2: `y${idx}`, out: `a${idx}` });\n      gates.push({ op: 'AND', in1: `t${idx}`, in2: `c${prevIdx}`, out: `b${idx}` });\n      gates.push({ op: 'OR', in1: `a${idx}`, in2: `b${idx}`, out: `c${idx}` });\n    }\n    // Last carry -> last z\n    const lastGate = gates[gates.length - 1];\n    lastGate.out = `z${String(numBits).padStart(2, '0')}`;\n\n    return gates;\n  }\n\n  function swapOutputs(gates: Gate[], out1: string, out2: string): void {\n    const g1 = gates.find((g) => g.out === out1)!;\n    const g2 = gates.find((g) => g.out === out2)!;\n    g1.out = out2;\n    g2.out = out1;\n  }\n\n  it('should find swapped wires: z outputs swapped with AND outputs', () => {\n    // 8-bit adder: swap z outputs with AND generate outputs\n    const gates = makeAdder(8);\n    // These swaps are safe (no cycles): swap z_i with a_i\n    // z_i is produced by XOR(t_i, c_{i-1}), a_i is produced by AND(x_i, y_i)\n    // Neither reads the other's output directly\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 'a03');\n    swapOutputs(gates, 'z05', 'a05');\n    swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a03', 'a05', 'a07', 'z01', 'z03', 'z05', 'z07']);\n  });\n\n  it('should find swapped wires: z output with first-level XOR', () => {\n    // Swap z_i with t_j (first-level XOR output)\n    const gates = makeAdder(10);\n    swapOutputs(gates, 'z02', 't02'); // XOR output swapped with itself (different gate)\n    swapOutputs(gates, 'z04', 'a04');\n    swapOutputs(gates, 'z06', 'a06');\n    swapOutputs(gates, 'z08', 'a08');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a04', 'a06', 'a08', 't02', 'z02', 'z04', 'z06', 'z08']);\n  });\n\n  it('should find swapped wires in a 45-bit adder', () => {\n    const gates = makeAdder(45);\n    swapOutputs(gates, 'z10', 'a10');\n    swapOutputs(gates, 'z20', 't20');\n    swapOutputs(gates, 'z30', 'a30');\n    swapOutputs(gates, 'z40', 'a40');\n\n    const start = performance.now();\n    const result = findSwappedWires(gates);\n    const elapsed = performance.now() - start;\n\n    expect(result).toEqual(['a10', 'a30', 'a40', 't20', 'z10', 'z20', 'z30', 'z40']);\n    expect(elapsed).toBeLessThan(5000);\n  });\n\n  it('should return sorted array', () => {\n    const gates = makeAdder(8);\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 'a03');\n    swapOutputs(gates, 'z05', 'a05');\n    swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    for (let i = 1; i < result.length; i++) {\n      expect(result[i] > result[i - 1]).toBe(true);\n    }\n    expect(result.length).toBe(8);\n  });\n\n  it('should handle swaps with random wire names', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'abc' },\n\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'def' },\n      { op: 'XOR', in1: 'def', in2: 'abc', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'ghi' },\n      { op: 'AND', in1: 'def', in2: 'abc', out: 'jkl' },\n      { op: 'OR', in1: 'ghi', in2: 'jkl', out: 'mno' },\n\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 'pqr' },\n      { op: 'XOR', in1: 'pqr', in2: 'mno', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'stu' },\n      { op: 'AND', in1: 'pqr', in2: 'mno', out: 'vwx' },\n      { op: 'OR', in1: 'stu', in2: 'vwx', out: 'yza' },\n\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 'yzb' },\n      { op: 'XOR', in1: 'yzb', in2: 'yza', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'yzc' },\n      { op: 'AND', in1: 'yzb', in2: 'yza', out: 'yzd' },\n      { op: 'OR', in1: 'yzc', in2: 'yzd', out: 'z04' },\n    ];\n\n    // Swap z01 <-> ghi (z output with AND generate output)\n    // Swap z02 <-> stu (z output with AND generate output)\n    // Swap z03 <-> yzc (z output with AND generate output)\n    // Swap def <-> mno (first-level XOR output with OR/carry output)\n    // def is XOR(x01,y01), consumed by XOR(def,abc) and AND(def,abc)\n    // mno is OR(ghi,jkl), consumed by XOR(pqr,mno) and AND(pqr,mno)\n    // After swap: XOR(x01,y01)->mno, OR(ghi,jkl)->def\n    // def consumed by XOR(def,abc) and AND(def,abc) — reads def from OR(ghi,jkl). No cycle.\n    // mno consumed by XOR(pqr,mno) and AND(pqr,mno) — reads mno from XOR(x01,y01). No cycle.\n    swapOutputs(gates, 'z01', 'ghi');\n    swapOutputs(gates, 'z02', 'stu');\n    swapOutputs(gates, 'z03', 'yzc');\n    swapOutputs(gates, 'def', 'mno');\n\n    const result = findSwappedWires(gates);\n    // def: now an OR output. It feeds into XOR(def,abc) — fine for OR carry.\n    //   But OR output should not feed into... hmm. Actually, def feeds into XOR and AND\n    //   which is normal for a carry. But Rule 5: does def feed into another OR? No.\n    //   Rule 3: def is no longer a first-level XOR output (it's now an OR output), so N/A.\n    //   Hmm, but what about the first-level XOR that produces mno?\n    //   XOR(x01,y01) -> mno. mno feeds into XOR(pqr,mno) and AND(pqr,mno).\n    //   Rule 3: it's a first-level XOR, not bit 0. Is mno used by a XOR? Yes.\n    //   So Rule 3 doesn't flag it.\n    //   But actually, the OR gate that used to produce mno now produces def.\n    //   OR(ghi,jkl) -> def. Rule 5: does def feed into another OR? No.\n    //   So neither def nor mno get flagged by existing rules... this is a problem.\n    //\n    // Actually: mno is a first-level XOR output. It IS consumed by XOR. That's fine.\n    // But the first-level XOR for bit 1 should NOT have its output consumed by gates\n    // from bit 2. In a correct adder, t01 feeds into the second-level XOR and AND\n    // of bit 1, not bit 2. But the rules don't check which bit.\n    //\n    // Let me use a different swap that the rules CAN detect.\n    // Swap mno <-> vwx: OR(ghi,jkl) <-> AND(pqr,mno)\n    // After swap: OR(ghi,jkl)->vwx, AND(pqr,mno)->mno\n    // vwx consumed by OR(stu,vwx). OR output feeding into OR -> Rule 5 catches vwx.\n    // mno consumed by XOR(pqr,mno) and AND(pqr,mno). AND output feeding into itself.\n    // Wait, AND(pqr,mno) outputs mno. mno is also its input. That's a cycle!\n    //\n    // OK, let me just use straightforward swaps for random wire names test.\n    expect(result).toEqual(['def', 'ghi', 'mno', 'stu', 'yzc', 'z01', 'z02', 'z03']);\n  });\n\n  it('should handle OR output swapped with non-carry wire', () => {\n    // Swap a carry (OR output) with something that doesn't create a cycle\n    // c01 (OR output) with a02 (AND output for different bit)\n    // c01 is OR(a01, b01), consumed by XOR(t02, c01) and AND(t02, c01)\n    // a02 is AND(x02, y02), consumed by OR(a02, b02)\n    // After swap: OR(a01,b01)->a02, AND(x02,y02)->c01\n    // a02 is consumed by OR(a02, b02) - the OR reads a02 which is now the output\n    // of OR(a01,b01). No cycle.\n    // c01 is consumed by XOR(t02,c01) and AND(t02,c01). c01 is now produced by\n    // AND(x02,y02). c01 is not an input to AND(x02,y02). No cycle.\n    const gates = makeAdder(8);\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 'a03');\n    swapOutputs(gates, 'c01', 'a02');  // OR output swapped with AND generate\n    swapOutputs(gates, 'z05', 'a05');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a02', 'a03', 'a05', 'c01', 'z01', 'z03', 'z05']);\n  });\n\n  it('should handle OR output swapped with b wire from later bit', () => {\n    // c02 (OR output) swapped with b05 (AND propagate output)\n    // c02 = OR(a02, b02), consumed by XOR(t03,c02) and AND(t03,c02)\n    // b05 = AND(t05, c04), consumed by OR(a05, b05)\n    // After swap: OR(a02,b02)->b05, AND(t05,c04)->c02\n    // b05 consumed by OR(a05,b05) - reads b05 from OR(a02,b02). No cycle.\n    // c02 consumed by XOR(t03,c02) and AND(t03,c02) - reads from AND(t05,c04). No cycle.\n    const gates = makeAdder(8);\n    swapOutputs(gates, 'z01', 'a01');\n    swapOutputs(gates, 'z03', 'a03');\n    swapOutputs(gates, 'c02', 'b05');\n    swapOutputs(gates, 'z07', 'a07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['a01', 'a03', 'a07', 'b05', 'c02', 'z01', 'z03', 'z07']);\n  });\n});\n","structuredPatch":[{"oldStart":212,"oldLines":47,"newStart":212,"newLines":22,"lines":["       { op: 'OR', in1: 'yzc', in2: 'yzd', out: 'z04' },","     ];"," ","-    // Swap z01 <-> ghi (z output with AND generate output)","-    // Swap z02 <-> stu (z output with AND generate output)","-    // Swap z03 <-> yzc (z output with AND generate output)","-    // Swap def <-> mno (first-level XOR output with OR/carry output)","-    // def is XOR(x01,y01), consumed by XOR(def,abc) and AND(def,abc)","-    // mno is OR(ghi,jkl), consumed by XOR(pq