@@ -0,0 +1,175 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let changed = true;
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      if (wires[gate.in1] !== undefined && wires[gate.in2] !== undefined) {
+        const a = wires[gate.in1];
+        const b = wires[gate.in2];
+        switch (gate.op) {
+          case 'AND':
+            wires[gate.out] = a & b;
+            break;
+          case 'OR':
+            wires[gate.out] = a | b;
+            break;
+          case 'XOR':
+            wires[gate.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Determine the number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2, g.out]) {
+      const m = w.match(/^[xy](\d+)$/);
+      if (m) {
+        const bit = parseInt(m[1], 10);
+        if (bit > maxBit) maxBit = bit;
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+
+  const swapped: Set<string> = new Set();
+
+  // Strategy: Walk the expected ripple-carry adder structure bit by bit.
+  // For each bit, identify which gates should exist and what their outputs
+  // should be. When we find a mismatch, we identify the swap.
+
+  // For a ripple-carry adder:
+  // Bit 0 (half adder):
+  //   x00 XOR y00 -> z00
+  //   x00 AND y00 -> c00
+  //
+  // Bit i (full adder), for i >= 1:
+  //   x_i XOR y_i -> t_i       (partial sum / XOR of inputs)
+  //   t_i XOR c_{i-1} -> z_i   (final sum)
+  //   x_i AND y_i -> a_i       (generate)
+  //   t_i AND c_{i-1} -> b_i   (propagate)
+  //   a_i OR b_i -> c_i        (carry out)
+  //
+  // Bit N (final): c_{N-1} -> z_N
+
+  // We need to trace the structure, detecting where outputs don't match
+  // what we expect and recording swaps.
+
+  // Helper to check if wire is an input wire
+  function isInputWire(w: string): boolean {
+    return /^[xy]\d+$/.test(w);
+  }
+
+  // Check structural rules and collect bad wires
+  // Rule 1: z-wires (except the last z) must be produced by XOR gates
+  // Rule 2: XOR gates with non-x/y inputs must output to z-wires
+  // Rule 3: XOR gates with x/y inputs (except x00/y00) must feed into another XOR and an AND
+  // Rule 4: AND gates (except x00 AND y00) must feed into an OR gate
+  // Rule 5: OR gates must not output to z-wires (except last z)
+
+  const lastZ = `z${String(numBits).padStart(2, '0')}`;
+
+  for (const g of gates) {
+    // Rule 1: z outputs (except last) must come from XOR
+    if (g.out.startsWith('z') && g.out !== lastZ && g.op !== 'XOR') {
+      swapped.add(g.out);
+    }
+
+    // Rule 2: XOR gate with non-input wires must output to z
+    if (g.op === 'XOR') {
+      const in1IsInput = isInputWire(g.in1);
+      const in2IsInput = isInputWire(g.in2);
+
+      if (!in1IsInput && !in2IsInput) {
+        // This is a "second level" XOR (t_i XOR c_{i-1} -> z_i)
+        // Its output must be a z wire
+        if (!g.out.startsWith('z')) {
+          swapped.add(g.out);
+        }
+      }
+    }
+
+    // Rule 3: XOR gate with x/y inputs (first level XOR) - except bit 0 -
+    // must have its output used by another XOR gate and an AND gate
+    if (g.op === 'XOR') {
+      const in1IsInput = isInputWire(g.in1);
+      const in2IsInput = isInputWire(g.in2);
+
+      if (in1IsInput && in2IsInput) {
+        // First-level XOR: x_i XOR y_i -> t_i
+        // Skip bit 0 (x00 XOR y00 -> z00)
+        const isZeroBit =
+          (g.in1 === 'x00' || g.in1 === 'y00') &&
+          (g.in2 === 'x00' || g.in2 === 'y00');
+
+        if (!isZeroBit) {
+          // t_i should be used as input to another XOR and an AND
+          const usedByXor = gates.some(
+            (g2) =>
+              g2.op === 'XOR' &&
+              (g2.in1 === g.out || g2.in2 === g.out)
+          );
+          if (!usedByXor) {
+            swapped.add(g.out);
+          }
+        }
+      }
+    }
+
+    // Rule 4: AND gate output (except x00 AND y00) must feed into an OR gate
+    if (g.op === 'AND') {
+      const isZeroBit =
+        (g.in1 === 'x00' || g.in1 === 'y00') &&
+        (g.in2 === 'x00' || g.in2 === 'y00');
+
+      if (!isZeroBit) {
+        const usedByOr = gates.some(
+          (g2) =>
+            g2.op === 'OR' &&
+            (g2.in1 === g.out || g2.in2 === g.out)
+        );
+        if (!usedByOr) {
+          swapped.add(g.out);
+        }
+      }
+    }
+
+    // Rule 5: OR gate outputs must not feed into other OR gates.
+    // In a correct adder, OR outputs are carries that feed into XOR and AND
+    // of the next bit, never into another OR gate.
+    if (g.op === 'OR') {
+      const feedsIntoOr = gates.some(
+        (g2) =>
+          g2.op === 'OR' &&
+          (g2.in1 === g.out || g2.in2 === g.out)
+      );
+      if (feedsIntoOr) {
+        swapped.add(g.out);
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
