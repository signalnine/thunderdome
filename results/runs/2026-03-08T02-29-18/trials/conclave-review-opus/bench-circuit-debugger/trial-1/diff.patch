ppedWires(gates);\n    // Verify sorted\n    for (let i = 1; i < result.length; i++) {\n      expect(result[i] > result[i - 1]).toBe(true);\n    }\n    expect(result.length).toBe(8);\n  });\n\n  it('should handle swaps with random wire names', () => {\n    // Build a 4-bit adder with random internal wire names\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'abc' }, // c00 = abc\n\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'def' }, // t01 = def\n      { op: 'XOR', in1: 'def', in2: 'abc', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'ghi' }, // a01 = ghi\n      { op: 'AND', in1: 'def', in2: 'abc', out: 'jkl' }, // b01 = jkl\n      { op: 'OR', in1: 'ghi', in2: 'jkl', out: 'mno' },  // c01 = mno\n\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 'pqr' }, // t02 = pqr\n      { op: 'XOR', in1: 'pqr', in2: 'mno', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'stu' }, // a02 = stu\n      { op: 'AND', in1: 'pqr', in2: 'mno', out: 'vwx' }, // b02 = vwx\n      { op: 'OR', in1: 'stu', in2: 'vwx', out: 'yza' },  // c02 = yza\n\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 'yzb' }, // t03 = yzb\n      { op: 'XOR', in1: 'yzb', in2: 'yza', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'yzc' }, // a03 = yzc\n      { op: 'AND', in1: 'yzb', in2: 'yza', out: 'yzd' }, // b03 = yzd\n      { op: 'OR', in1: 'yzc', in2: 'yzd', out: 'z04' },  // c03 -> z04\n    ];\n\n    // Swap z01 <-> ghi (z output with an AND output)\n    // and swap z03 <-> pqr (z output with a first-level XOR output)\n    // and swap jkl <-> mno (AND output with OR/carry output)\n    // and swap stu <-> z02 (AND output with z output)\n    swapOutputs(gates, 'z01', 'ghi');\n    swapOutputs(gates, 'z03', 'pqr');\n    swapOutputs(gates, 'jkl', 'mno');\n    swapOutputs(gates, 'stu', 'z02');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(['ghi', 'jkl