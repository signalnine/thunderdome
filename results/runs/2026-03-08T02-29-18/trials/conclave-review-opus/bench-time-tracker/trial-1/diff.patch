+import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
+import { dirname } from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string; // ISO 8601
+  stop: string | null; // ISO 8601, null if still running
+}
+
+export interface TimeSummary {
+  [task: string]: number; // milliseconds
+}
+
+export interface TimeTrackerOptions {
+  filePath: string;
+}
+
+function isTimeEntry(item: unknown): item is TimeEntry {
+  if (typeof item !== "object" || item === null) return false;
+  const obj = item as Record<string, unknown>;
+  return (
+    typeof obj.task === "string" &&
+    typeof obj.start === "string" &&
+    (obj.stop === null || typeof obj.stop === "string")
+  );
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[];
+  private readonly filePath: string;
+
+  constructor(options: TimeTrackerOptions) {
+    this.filePath = options.filePath;
+    this.entries = this.load();
+  }
+
+  private load(): TimeEntry[] {
+    try {
+      const data = readFileSync(this.filePath, "utf-8");
+      const parsed: unknown = JSON.parse(data);
+      if (!Array.isArray(parsed)) {
+        return [];
+      }
+      return parsed.filter(isTimeEntry);
+    } catch {
+      return [];
+    }
+  }
+
+  private save(): void {
+    const dir = dirname(this.filePath);
+    mkdirSync(dir, { recursive: true });
+    writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+
+  private getRunningEntry(): TimeEntry | undefined {
+    return this.entries.find((e) => e.stop === null);
+  }
+
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name must not be empty");
+    }
+
+    const now = new Date().toISOString();
+
+    // Stop any currently running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = now;
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: now,
+      stop: null,
+    };
+
+    this.entries.push(entry);
+    this.save();
+    return { ...entry };
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return { ...running };
+  }
+
+  getEntries(options?: { from?: Date; to?: Date }): TimeEntry[] {
+    if (!options) {
+      return this.entries.map((e) => ({ ...e }));
+    }
+
+    return this.entries
+      .filter((entry) => {
+        const start = new Date(entry.start);
+        if (options.from && start < options.from) {
+          return false;
+        }
+        if (options.to && start > options.to) {
+          return false;
+        }
+        return true;
+      })
+      .map((e) => ({ ...e }));
+  }
+
+  getSummary(options?: { from?: Date; to?: Date }): TimeSummary {
+    const entries = this.getEntries(options);
+    const summary: TimeSummary = {};
+
+    for (const entry of entries) {
+      const start = new Date(entry.start).getTime();
+      const stop = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = Math.max(0, stop - start);
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  isRunning(): boolean {
+    return this.getRunningEntry() !== undefined;
+  }
+
+  currentTask(): string | null {
+    const running = this.getRunningEntry();
+    return running ? running.task : null;
+  }
+}
