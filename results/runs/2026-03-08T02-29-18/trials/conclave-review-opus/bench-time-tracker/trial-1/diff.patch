 entry;\n  }\n\n  stop(): TimeEntry {\n    const running = this.getRunningEntry();\n    if (!running) {\n      throw new Error(\"No timer is currently running\");\n    }\n\n    running.stop = new Date().toISOString();\n    this.save();\n    return running;\n  }\n\n  getEntries(options?: { from?: Date; to?: Date }): TimeEntry[] {\n    if (!options) {\n      return [...this.entries];\n    }\n\n    return this.entries.filter((entry) => {\n      const start = new Date(entry.start);\n      if (options.from && start < options.from) {\n        return false;\n      }\n      if (options.to && start > options.to) {\n        return false;\n      }\n      return true;\n    });\n  }\n\n  getSummary(options?: { from?: Date; to?: Date }): TimeSummary {\n    const entries = this.getEntries(options);\n    const summary: TimeSummary = {};\n\n    for (const entry of entries) {\n      const start = new Date(entry.start).getTime();\n      const stop = entry.stop\n        ? new Date(entry.stop).getTime()\n        : Date.now();\n      const duration = stop - start;\n\n      if (summary[entry.task] === undefined) {\n        summary[entry.task] = 0;\n      }\n      summary[entry.task] += duration;\n    }\n\n    return summary;\n  }\n\n  isRunning(): boolean {\n    return this.getRunningEntry() !== undefined;\n  }\n\n  currentTask(): string | null {\n    const running = this.getRunningEntry();\n    return running ? running.task : null;\n  }\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":230,"cache_read_input_tokens":20230,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":230},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"22f6fbde-cc42-470a-8506-fcd165641c4c","uuid":"f4ed9897-5a7e-4138-a4f5-d15fa37a576d"}
