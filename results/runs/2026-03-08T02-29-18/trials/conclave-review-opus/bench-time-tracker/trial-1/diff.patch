\n      tracker.start(\"task2\");\n      tracker.stop();\n\n      const summary = tracker.getSummary({ from: afterFirst });\n      expect(summary[\"task1\"]).toBeUndefined();\n      expect(summary[\"task2\"]).toBeGreaterThanOrEqual(0);\n    });\n  });\n\n  describe(\"isRunning / currentTask\", () => {\n    it(\"should report no running task initially\", () => {\n      const tracker = new TimeTracker({ filePath });\n      expect(tracker.isRunning()).toBe(false);\n      expect(tracker.currentTask()).toBeNull();\n    });\n\n    it(\"should report running task after start\", () => {\n      const tracker = new TimeTracker({ filePath });\n      tracker.start(\"coding\");\n      expect(tracker.isRunning()).toBe(true);\n      expect(tracker.currentTask()).toBe(\"coding\");\n    });\n\n    it(\"should report no running task after stop\", () => {\n      const tracker = new TimeTracker({ filePath });\n      tracker.start(\"coding\");\n      tracker.stop();\n      expect(tracker.isRunning()).toBe(false);\n      expect(tracker.currentTask()).toBeNull();\n    });\n  });\n\n  describe(\"graceful handling of corrupt data\", () => {\n    it(\"should start fresh if file contains invalid JSON\", () => {\n      mkdirSync(filePath.replace(/\\/[^/]+$/, \"\"), { recursive: true });\n      writeFileSync(filePath, \"not json\", \"utf-8\");\n\n      const tracker = new TimeTracker({ filePath });\n      expect(tracker.getEntries()).toHaveLength(0);\n    });\n\n    it(\"should start fresh if file contains non-array JSON\", () => {\n      mkdirSync(filePath.replace(/\\/[^/]+$/, \"\"), { recursive: true });\n      writeFileSync(filePath, '{\"foo\": \"bar\"}', \"utf-8\");\n\n      const tracker = new TimeTracker({ filePath });\n      expect(tracker.getEntries()).toHaveLength(0);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":238,"oldLines":15,"newStart":238,"newLines":16,"lines":["       const tracker = new TimeTracker({ filePath });","       tracker.start(\"task1\");","       tracker.sto