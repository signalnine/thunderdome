;\n\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(2);\n      expect(entries[0].task).toBe(\"task1\");\n      expect(entries[0].stop).not.toBeNull();\n      expect(entries[1].task).toBe(\"task2\");\n      expect(entries[1].stop).toBeNull();\n    });\n\n    it(\"should support unicode task names\", () => {\n      const tracker = new TimeTracker({ filePath });\n      const entry = tracker.start(\"写代码 🚀\");\n      expect(entry.task).toBe(\"写代码 🚀\");\n    });\n\n    it(\"should support emoji-only task names\", () => {\n      const tracker = new TimeTracker({ filePath });\n      const entry = tracker.start(\"🎯🔥💻\");\n      expect(entry.task).toBe(\"🎯🔥💻\");\n    });\n  });\n\n  describe(\"stop\", () => {\n    it(\"should stop the currently running timer\", () => {\n      const tracker = new TimeTracker({ filePath });\n      tracker.start(\"coding\");\n      const stopped = tracker.stop();\n      expect(stopped.task).toBe(\"coding\");\n      expect(stopped.stop).not.toBeNull();\n    });\n\n    it(\"should throw if no timer is running\", () => {\n      const tracker = new TimeTracker({ filePath });\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n\n    it(\"should throw if timer was already stopped\", () => {\n      const tracker = new TimeTracker({ filePath });\n      tracker.start(\"coding\");\n      tracker.stop();\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n  });\n\n  describe(\"persistence\", () => {\n    it(\"should create the file and parent directories automatically\", () => {\n      const nested = join(tmpdir(), `tracker-test-${Date.now()}`, \"a\", \"b\", \"data.json\");\n      const tracker = new TimeTracker({ filePath: nested });\n      tracker.start(\"coding\");\n      expect(existsSync(nested)).toBe(true);\n\n      // Clean up\n      const root = join(tmpdir(), nested.split(\"/\").find((s) => s.startsWith(\"tracker-test\"))!);\n      rmSync(root, { recursive: true });\n    });\n\n    it(\"should persist entries between instances\", () => {\n      const tracker1 = new TimeTracker({ filePath });\n      tracker1.start(\"coding\");\n      tracker1.stop();\n\n      const tracker2 = new TimeTracker({ filePath });\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe(\"coding\");\n      expect(entries[0].stop).not.toBeNull();\n    });\n\n    it(\"should persist unicode task names correctly\", () => {\n      const tracker1 = new TimeTracker({ filePath });\n      tracker1.start(\"café ☕ コーディング\");\n      tracker1.stop();\n\n      const tracker2 = new TimeTracker({ filePath });\n      const entries = tracker2.getEntries();\n      expect(entries[0].task).toBe(\"café ☕ コーディング\");\n    });\n\n    it(\"should save data as valid JSON\", () => {\n      const tracker = new TimeTracker({ filePath });\n      tracker.start(\"coding\");\n      tracker.stop();\n\n      const raw = readFileSync(filePath, \"utf-8\");\n      const parsed = JSON.parse(raw);\n      expect(Array.isArray(parsed)).toBe(true);\n      expect(parsed).toHaveLength(1);\n    });\n  });\n\n  describe(\"getEntries\", () => {\n    it(\"should return all entries when no filter is specified\", () => {\n      const tracker = new TimeTracker({ filePath });\n      tracker.start(\"task1\");\n      tracker.start(\"task2\");\n      tracker.stop();\n\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(2);\n    });\n\n    it(\"should filter by date range\", () => {\n      const tracker = new TimeTracker({ filePath });\n\n      tracker.start(\"task1\");\n      tracker.stop();\n\n      const afterFirst = new Date();\n\n      // Small delay to ensure timestamps differ\n      tracker.start(\"task2\");\n      tracker.stop();\n\n      const entries = tracker.getEntries({ from: afterFirst });\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe(\"task2\");\