+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Hjg72jZ5UjV1kXqeFheM62","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KAddpApyybgokTBwAaeszJ","name":"Write","input":{"file_path":"/workspace/src/app.test.ts","content":"import { describe, it, expect, beforeEach } from 'vitest';\nimport request from 'supertest';\nimport { createApp } from './app.js';\nimport type { Express } from 'express';\n\nlet app: Express;\n\nbeforeEach(() => {\n  app = createApp();\n});\n\n// Helper functions\nasync function registerUser(username: string, password: string) {\n  const res = await request(app)\n    .post('/auth/register')\n    .send({ username, password });\n  return res;\n}\n\nasync function loginUser(username: string, password: string) {\n  const res = await request(app)\n    .post('/auth/login')\n    .send({ username, password });\n  return res;\n}\n\nasync function createUserAndLogin(username: string, password = 'pass123') {\n  await registerUser(username, password);\n  const loginRes = await loginUser(username, password);\n  return { token: loginRes.body.token, userId: loginRes.body.userId };\n}\n\ndescribe('Auth', () => {\n  it('should register a new user', async () => {\n    const res = await registerUser('alice', 'pass123');\n    expect(res.status).toBe(201);\n    expect(res.body.username).toBe('alice');\n    expect(res.body.id).toBeDefined();\n    expect(res.body.password).toBeUndefined();\n  });\n\n  it('should reject duplicate username', async () => {\n    await registerUser('alice', 'pass123');\n    const res = await registerUser('alice', 'pass456');\n    expect(res.status).toBe(409);\n  });\n\n  it('should reject registration with missing fields', async () => {\n    const res = await registerUser('', 'pass');\n    expect(res.status).toBe(400);\n  });\n\n  it('should login with valid credentials', async () => {\n    await registerUser('alice', 'pass123');\n    const res = await loginUser('alice', 'pass123');\n    expect(res.status).toBe(200);\n    expect(res.body.token).toBeDefined();\n    expect(res.body.userId).toBeDefined();\n  });\n\n  it('should reject login with invalid credentials', async () => {\n    await registerUser('alice', 'pass123');\n    const res = await loginUser('alice', 'wrong');\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject unauthenticated requests', async () => {\n    const res = await request(app).get('/folders/1');\n    expect(res.status).toBe(401);\n  });\n\n  it('should reject invalid token', async () => {\n    const res = await request(app)\n      .get('/folders/1')\n      .set('Authorization', 'Bearer invalidtoken');\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe('Folders', () => {\n  let alice: { token: string; userId: string };\n\n  beforeEach(async () => {\n    alice = await createUserAndLogin('alice');\n  });\n\n  it('should create a folder', async () => {\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'My Folder' });\n\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe('My Folder');\n    expect(res.body.ownerId).toBe(alice.userId);\n    expect(res.body.parentId).toBeNull();\n  });\n\n  it('should create a nested folder', async () => {\n    const parent = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Parent' });\n\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Child', parentId: parent.body.id });\n\n    expect(child.status).toBe(201);\n    expect(child.body.parentId).toBe(parent.body.id);\n  });\n\n  it('should reject folder with nonexistent parent', async () => {\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Orphan', parentId: '99999' });\n\n    expect(res.status).toBe(404);\n  });\n\n  it('should get a folder with children and documents', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Root' });\n\n    await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'SubFolder', parentId: folder.body.id });\n\n    await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc1', content: 'Hello', folderId: folder.body.id });\n\n    const res = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Root');\n    expect(res.body.children).toHaveLength(1);\n    expect(res.body.documents).toHaveLength(1);\n  });\n\n  it('should update a folder', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Original' });\n\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Renamed' });\n\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe('Renamed');\n  });\n\n  it('should delete a folder and its contents', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'ToDelete' });\n\n    await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc', content: 'Content', folderId: folder.body.id });\n\n    const del = await request(app)\n      .delete(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(del.status).toBe(204);\n\n    const get = await request(app)\n      .get(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(get.status).toBe(404);\n  });\n\n  it('should reject creating folder without name', async () => {\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({});\n\n    expect(res.status).toBe(400);\n  });\n\n  it('should return 404 for nonexistent folder', async () => {\n    const res = await request(app)\n      .get('/folders/99999')\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(res.status).toBe(404);\n  });\n\n  it('should prevent setting folder as its own parent', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Self' });\n\n    const res = await request(app)\n      .put(`/folders/${folder.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ parentId: folder.body.id });\n\n    expect(res.status).toBe(400);\n  });\n});\n\ndescribe('Documents', () => {\n  let alice: { token: string; userId: string };\n  let folderId: string;\n\n  beforeEach(async () => {\n    alice = await createUserAndLogin('alice');\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Docs Folder' });\n    folderId = folder.body.id;\n  });\n\n  it('should create a document', async () => {\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'My Doc', content: 'Hello World', folderId });\n\n    expect(res.status).toBe(201);\n    expect(res.body.title).toBe('My Doc');\n    expect(res.body.content).toBe('Hello World');\n    expect(res.body.ownerId).toBe(alice.userId);\n  });\n\n  it('should get a document', async () => {\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'My Doc', content: 'Hello', folderId });\n\n    const res = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('My Doc');\n  });\n\n  it('should update a document', async () => {\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Original', content: 'Old', folderId });\n\n    const res = await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Updated', content: 'New' });\n\n    expect(res.status).toBe(200);\n    expect(res.body.title).toBe('Updated');\n    expect(res.body.content).toBe('New');\n    expect(res.body.updatedAt).not.toBe(doc.body.updatedAt);\n  });\n\n  it('should delete a document', async () => {\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'ToDelete', content: 'Bye', folderId });\n\n    const del = await request(app)\n      .delete(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(del.status).toBe(204);\n\n    const get = await request(app)\n      .get(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(get.status).toBe(404);\n  });\n\n  it('should reject document in nonexistent folder', async () => {\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc', content: 'Text', folderId: '99999' });\n\n    expect(res.status).toBe(404);\n  });\n\n  it('should reject document creation with missing fields', async () => {\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc' });\n\n    expect(res.status).toBe(400);\n  });\n\n  it('should return 404 for nonexistent document', async () => {\n    const res = await request(app)\n      .get('/documents/99999')\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(res.status).toBe(404);\n  });\n});\n\ndescribe('Sharing & Permissions', () => {\n  let alice: { token: string; userId: string };\n  let bob: { token: string; userId: string };\n  let folderId: string;\n  let docId: string;\n\n  beforeEach(async () => {\n    alice = await createUserAndLogin('alice');\n    bob = await createUserAndLogin('bob');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Shared Folder' });\n    folderId = folder.body.id;\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Shared Doc', content: 'Secret', folderId });\n    docId = doc.body.id;\n  });\n\n  it('should deny access to non-shared resources', async () => {\n    const res = await request(app)\n      .get(`/documents/${docId}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n\n    expect(res.status).toBe(403);\n  });\n\n  it('should share a document with viewer role', async () => {\n    const share = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: bob.userId,\n        role: 'viewer',\n      });\n\n    expect(share.status).toBe(201);\n\n    // Bob can now read\n    const read = await request(app)\n      .get(`/documents/${docId}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n\n    expect(read.status).toBe(200);\n\n    // But Bob cannot edit\n    const edit = await request(app)\n      .put(`/documents/${docId}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ title: 'Hacked' });\n\n    expect(edit.status).toBe(403);\n  });\n\n  it('should share a document with editor role', async () => {\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: bob.userId,\n        role: 'editor',\n      });\n\n    // Bob can read and edit\n    const edit = await request(app)\n      .put(`/documents/${docId}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ title: 'Updated by Bob' });\n\n    expect(edit.status).toBe(200);\n    expect(edit.body.title).toBe('Updated by Bob');\n\n    // But Bob cannot delete (needs owner)\n    const del = await request(app)\n      .delete(`/documents/${docId}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n\n    expect(del.status).toBe(403);\n  });\n\n  it('should share a folder and grant access to documents within', async () => {\n    // Share folder with Bob as viewer\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folderId,\n        userId: bob.userId,\n        role: 'viewer',\n      });\n\n    // Bob should be able to read the document in the folder\n    const read = await request(app)\n      .get(`/documents/${docId}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n\n    expect(read.status).toBe(200);\n  });\n\n  it('should use most permissive role when multiple paths exist', async () => {\n    // Share folder with viewer\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folderId,\n        userId: bob.userId,\n        role: 'viewer',\n      });\n\n    // Share document directly with editor\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: bob.userId,\n        role: 'editor',\n      });\n\n    // Bob should have editor access (most permissive)\n    const edit = await request(app)\n      .put(`/documents/${docId}`)\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ title: 'Edited' });\n\n    expect(edit.status).toBe(200);\n  });\n\n  it('should allow editors to share with others', async () => {\n    const carol = await createUserAndLogin('carol');\n\n    // Share with Bob as editor\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: bob.userId,\n        role: 'editor',\n      });\n\n    // Bob shares with Carol as viewer\n    const share = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: carol.userId,\n        role: 'viewer',\n      });\n\n    expect(share.status).toBe(201);\n\n    // Carol can read\n    const read = await request(app)\n      .get(`/documents/${docId}`)\n      .set('Authorization', `Bearer ${carol.token}`);\n\n    expect(read.status).toBe(200);\n  });\n\n  it('should prevent non-owners from granting owner role', async () => {\n    const carol = await createUserAndLogin('carol');\n\n    // Share with Bob as editor\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: bob.userId,\n        role: 'editor',\n      });\n\n    // Bob tries to share as owner\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: carol.userId,\n        role: 'owner',\n      });\n\n    expect(res.status).toBe(403);\n  });\n\n  it('should prevent viewers from sharing', async () => {\n    const carol = await createUserAndLogin('carol');\n\n    // Share with Bob as viewer\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: bob.userId,\n        role: 'viewer',\n      });\n\n    // Bob tries to share with Carol\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: carol.userId,\n        role: 'viewer',\n      });\n\n    expect(res.status).toBe(403);\n  });\n\n  it('should update existing share', async () => {\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: bob.userId,\n        role: 'viewer',\n      });\n\n    // Update to editor\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: bob.userId,\n        role: 'editor',\n      });\n\n    expect(res.status).toBe(200);\n    expect(res.body.role).toBe('editor');\n  });\n\n  it('should reject share with invalid role', async () => {\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: bob.userId,\n        role: 'superadmin',\n      });\n\n    expect(res.status).toBe(400);\n  });\n\n  it('should reject share with nonexistent user', async () => {\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: '99999',\n        role: 'viewer',\n      });\n\n    expect(res.status).toBe(404);\n  });\n\n  it('should reject share with missing fields', async () => {\n    const res = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ resourceType: 'document' });\n\n    expect(res.status).toBe(400);\n  });\n\n  it('should inherit permissions from parent folder to child folder', async () => {\n    // Create child folder inside shared folder\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Child', parentId: folderId });\n\n    // Share parent folder with Bob as viewer\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'folder',\n        resourceId: folderId,\n        userId: bob.userId,\n        role: 'viewer',\n      });\n\n    // Bob can read child folder\n    const res = await request(app)\n      .get(`/folders/${child.body.id}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n\n    expect(res.status).toBe(200);\n  });\n\n  it('should deny access to unshared folder', async () => {\n    const res = await request(app)\n      .get(`/folders/${folderId}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n\n    expect(res.status).toBe(403);\n  });\n\n  it('should allow owner to delete share', async () => {\n    const share = await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: docId,\n        userId: bob.userId,\n        role: 'viewer',\n      });\n\n    const del = await request(app)\n      .delete(`/share/${share.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(del.status).toBe(204);\n\n    // Bob can no longer access\n    const read = await request(app)\n      .get(`/documents/${docId}`)\n      .set('Authorization', `Bearer ${bob.token}`);\n\n    expect(read.status).toBe(403);\n  });\n});\n\ndescribe('Activity Log', () => {\n  let alice: { token: string; userId: string };\n\n  beforeEach(async () => {\n    alice = await createUserAndLogin('alice');\n  });\n\n  it('should track document creation', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Folder' });\n\n    await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc', content: 'Text', folderId: folder.body.id });\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(res.status).toBe(200);\n    expect(res.body.length).toBeGreaterThan(0);\n\n    const docCreated = res.body.find(\n      (e: { action: string }) => e.action === 'document_created',\n    );\n    expect(docCreated).toBeDefined();\n    expect(docCreated.userId).toBe(alice.userId);\n  });\n\n  it('should track document updates', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Folder' });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc', content: 'Old', folderId: folder.body.id });\n\n    await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ content: 'New' });\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    const docUpdated = res.body.find(\n      (e: { action: string }) => e.action === 'document_updated',\n    );\n    expect(docUpdated).toBeDefined();\n  });\n\n  it('should track sharing events', async () => {\n    const bob = await createUserAndLogin('bob');\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Folder' });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc', content: 'Text', folderId: folder.body.id });\n\n    await request(app)\n      .post('/share')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({\n        resourceType: 'document',\n        resourceId: doc.body.id,\n        userId: bob.userId,\n        role: 'viewer',\n      });\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    const shareEvent = res.body.find(\n      (e: { action: string }) => e.action === 'share_created',\n    );\n    expect(shareEvent).toBeDefined();\n  });\n\n  it('should filter activity by resourceType', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Folder' });\n\n    await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc', content: 'Text', folderId: folder.body.id });\n\n    const res = await request(app)\n      .get('/activity?resourceType=document')\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(res.status).toBe(200);\n    for (const entry of res.body) {\n      expect(entry.resourceType).toBe('document');\n    }\n  });\n\n  it('should filter activity by resourceId', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Folder' });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc', content: 'Text', folderId: folder.body.id });\n\n    const res = await request(app)\n      .get(`/activity?resourceId=${doc.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(res.status).toBe(200);\n    for (const entry of res.body) {\n      expect(entry.resourceId).toBe(doc.body.id);\n    }\n  });\n\n  it('should track document deletion', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Folder' });\n\n    const doc = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc', content: 'Text', folderId: folder.body.id });\n\n    await request(app)\n      .delete(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    const deleteEvent = res.body.find(\n      (e: { action: string }) => e.action === 'document_deleted',\n    );\n    expect(deleteEvent).toBeDefined();\n  });\n\n  it('should return entries sorted by most recent first', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Folder' });\n\n    await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc1', content: 'Text', folderId: folder.body.id });\n\n    await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc2', content: 'Text', folderId: folder.body.id });\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(res.body.length).toBeGreaterThanOrEqual(2);\n    for (let i = 0; i < res.body.length - 1; i++) {\n      expect(res.body[i].timestamp >= res.body[i + 1].timestamp).toBe(true);\n    }\n  });\n\n  it('activity entries should have required fields', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Folder' });\n\n    await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Doc', content: 'Text', folderId: folder.body.id });\n\n    const res = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    for (const entry of res.body) {\n      expect(entry.action).toBeDefined();\n      expect(entry.userId).toBeDefined();\n      expect(entry.resourceType).toBeDefined();\n      expect(entry.resourceId).toBeDefined();\n      expect(entry.timestamp).toBeDefined();\n    }\n  });\n});\n\ndescribe('Edge Cases', () => {\n  it('should handle document creation with empty content', async () => {\n    const alice = await createUserAndLogin('alice');\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Folder' });\n\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Empty Doc', content: '', folderId: folder.body.id });\n\n    expect(res.status).toBe(201);\n    expect(res.body.content).toBe('');\n  });\n\n  it('should handle cascading folder deletion', async () => {\n    const alice = await createUserAndLogin('alice');\n\n    const root = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Root' });\n\n    const child = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Child', parentId: root.body.id });\n\n    await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ title: 'Deep Doc', content: 'Text', folderId: child.body.id });\n\n    // Delete root should cascade\n    const del = await request(app)\n      .delete(`/folders/${root.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(del.status).toBe(204);\n\n    // Child folder should be gone too\n    const getChild = await request(app)\n      .get(`/folders/${child.body.id}`)\n      .set('Authorization', `Bearer ${alice.token}`);\n\n    expect(getChild.status).toBe(404);\n  });\n\n  it('should not allow creating subfolder without permission on parent', async () => {\n    const alice = await createUserAndLogin('alice');\n    const bob = await createUserAndLogin('bob');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Alice Folder' });\n\n    // Bob tries to create a subfolder in Alice's folder\n    const res = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ name: 'Bob Sub', parentId: folder.body.id });\n\n    expect(res.status).toBe(403);\n  });\n\n  it('should not allow creating document without permission on folder', async () => {\n    const alice = await createUserAndLogin('alice');\n    const bob = await createUserAndLogin('bob');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${alice.token}`)\n      .send({ name: 'Alice Folder' });\n\n    const res = await request(app)\n      .post('/documents')\n      .set('Authorization', `Bearer ${bob.token}`)\n      .send({ title: 'Doc', content: 'Text', folderId: folder.body.id });\n\n    expect(res.status).toBe(403);\n  });\n\n  it('owner shares document with another user as owner', async () => {\n    const alice = await createUserAndLogin('alice');\n    const bob = await createUserAndLogin('bob');\n\n    const folder = await reques