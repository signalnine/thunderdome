+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RAC3oqQ3paZPYzbbCNifvU","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import { Store, generateId } from '../store.js';\n     3→import { AuthRequest, authMiddleware } from '../middleware.js';\n     4→import { hasPermission } from '../permissions.js';\n     5→import { Role } from '../types.js';\n     6→\n     7→const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];\n     8→\n     9→export function shareRoutes(store: Store): Router {\n    10→  const router = Router();\n    11→  router.use(authMiddleware(store));\n    12→\n    13→  // Share a resource\n    14→  router.post('/', (req: AuthRequest, res: Response) => {\n    15→    const { resourceType, resourceId, userId: targetUserId, role } = req.body;\n    16→    const currentUserId = req.userId!;\n    17→\n    18→    if (!resourceType || !resourceId || !targetUserId || !role) {\n    19→      res.status(400).json({ error: 'resourceType, resourceId, userId, and role are required' });\n    20→      return;\n    21→    }\n    22→\n    23→    if (!VALID_ROLES.includes(role)) {\n    24→      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });\n    25→      return;\n    26→    }\n    27→\n    28→    if (resourceType !== 'folder' && resourceType !== 'document') {\n    29→      res.status(400).json({ error: 'resourceType must be folder or document' });\n    30→      return;\n    31→    }\n    32→\n    33→    // Check resource exists\n    34→    if (resourceType === 'folder') {\n    35→      if (!store.folders.has(resourceId)) {\n    36→        res.status(404).json({ error: 'Folder not found' });\n    37→        return;\n    38→      }\n    39→    } else {\n    40→      if (!store.documents.has(resourceId)) {\n    41→        res.status(404).json({ error: 'Document not found' });\n    42→        return;\n    43→      }\n    44→    }\n    45→\n    46→    // Check target user exists\n    47→    if (!store.users.has(targetUserId)) {\n    48→      res.status(404).json({ error: 'Target user not found' });\n    49→      return;\n    50→    }\n    51→\n    52→    // Editors can share, owners can share - need at least editor\n    53→    if (!hasPermission(store, currentUserId, resourceType, resourceId, 'editor')) {\n    54→      res.status(403).json({ error: 'Insufficient permissions to share' });\n    55→      return;\n    56→    }\n    57→\n    58→    // Only owners can grant owner role\n    59→    if (role === 'owner' && !hasPermission(store, currentUserId, resourceType, resourceId, 'owner')) {\n    60→      res.status(403).json({ error: 'Only owners can grant owner role' });\n    61→      return;\n    62→    }\n    63→\n    64→    // Check if share already exists and update it\n    65→    const existingShare = store.shares.find(\n    66→      (s) =>\n    67→        s.resourceType === resourceType &&\n    68→        s.resourceId === resourceId &&\n    69→        s.userId === targetUserId,\n    70→    );\n    71→\n    72→    if (existingShare) {\n    73→      existingShare.role = role;\n    74→      store.activity.push({\n    75→        id: generateId(store),\n    76→        action: 'share_updated',\n    77→        userId: currentUserId,\n    78→        resourceType,\n    79→        resourceId,\n    80→        timestamp: new Date().toISOString(),\n    81→        details: `Updated ${targetUserId} role to ${role}`,\n    82→      });\n    83→      res.json(existingShare);\n    84→      return;\n    85→    }\n    86→\n    87→    const share = {\n    88→      id: generateId(store),\n    89→      resourceType,\n    90→      resourceId,\n    91→      userId: targetUserId,\n    92→      role,\n    93→    };\n    94→    store.shares.push(share);\n    95→\n    96→    store.activity.push({\n    97→      id: generateId(store),\n    98→      action: 'share_created',\n    99→      userId: currentUserId,\n   100→      resourceType,\n   101→      resourceId,\n   102→      timestamp: new Date().toISOString(),\n   103→      details: `Shared with ${targetUserId} as ${role}`,\n   104→    });\n   105→\n   106→    res.status(201).json(share);\n   107→  });\n   108→\n   109→  // Remove a share\n   110→  router.delete('/:shareId', (req: AuthRequest, res: Response) => {\n   111→    const shareIndex = store.shares.findIndex((s) => s.id === req.params.shareId);\n   112→    if (shareIndex === -1) {\n   113→      res.status(404).json({ error: 'Share not found' });\n   114→      return;\n   115→    }\n   116→\n   117→    const share = store.shares[shareIndex];\n   118→\n   119→    // Need owner permission to remove shares\n   120→    if (!hasPermission(store, req.userId!, share.resourceType, share.resourceId, 'owner')) {\n   121→      res.status(403).json({ error: 'Only owners can remove shares' });\n   122→      return;\n   123→    }\n   124→\n   125→    store.shares.splice(shareIndex, 1);\n   126→    res.status(204).send();\n   127→  });\n   128→\n   129→  return router;\n   130→}\n   131→"}]},"parent_tool_use_id":"toolu_01UL1u9gzupPbyBP6USzfduL","session_id":"3911a068-6837-46ec-81ae-795bfc04c614","uuid":"48a85457-76ec-4305-af8e-5d49df06596d"}
