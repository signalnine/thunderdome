+import { Router, Response } from 'express';
+import { Store } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+
+export function activityRoutes(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Get activity log
+  router.get('/', (req: AuthRequest, res: Response) => {
+    const { resourceType, resourceId } = req.query;
+
+    let entries = [...store.activity];
+
+    if (resourceType && typeof resourceType === 'string') {
+      entries = entries.filter((e) => e.resourceType === resourceType);
+    }
+
+    if (resourceId && typeof resourceId === 'string') {
+      entries = entries.filter((e) => e.resourceId === resourceId);
+    }
+
+    // Sort by timestamp descending (most recent first)
+    entries.sort((a, b) => b.timestamp.localeCompare(a.timestamp));
+
+    res.json(entries);
+  });
+
+  return router;
+}
