+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018igevcUmgDDiZE8gQ9mAfj","type":"tool_result","content":"     1→import { Store } from './store.js';\n     2→import { Role } from './types.js';\n     3→\n     4→const ROLE_LEVEL: Record<Role, number> = {\n     5→  viewer: 1,\n     6→  editor: 2,\n     7→  owner: 3,\n     8→};\n     9→\n    10→export function getEffectiveRole(\n    11→  store: Store,\n    12→  userId: string,\n    13→  resourceType: 'folder' | 'document',\n    14→  resourceId: string,\n    15→): Role | null {\n    16→  let bestRole: Role | null = null;\n    17→\n    18→  // Check direct shares on this resource\n    19→  for (const share of store.shares) {\n    20→    if (\n    21→      share.userId === userId &&\n    22→      share.resourceType === resourceType &&\n    23→      share.resourceId === resourceId\n    24→    ) {\n    25→      if (!bestRole || ROLE_LEVEL[share.role] > ROLE_LEVEL[bestRole]) {\n    26→        bestRole = share.role;\n    27→      }\n    28→    }\n    29→  }\n    30→\n    31→  // Check ownership\n    32→  if (resourceType === 'folder') {\n    33→    const folder = store.folders.get(resourceId);\n    34→    if (folder && folder.ownerId === userId) {\n    35→      return 'owner';\n    36→    }\n    37→  } else {\n    38→    const doc = store.documents.get(resourceId);\n    39→    if (doc && doc.ownerId === userId) {\n    40→      return 'owner';\n    41→    }\n    42→  }\n    43→\n    44→  // If resource is a document, also check permissions on its parent folder\n    45→  if (resourceType === 'document') {\n    46→    const doc = store.documents.get(resourceId);\n    47→    if (doc) {\n    48→      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);\n    49→      if (folderRole && (!bestRole || ROLE_LEVEL[folderRole] > ROLE_LEVEL[bestRole])) {\n    50→        bestRole = folderRole;\n    51→      }\n    52→    }\n    53→  }\n    54→\n    55→  // If resource is a folder, check parent folder permissions (inherited)\n    56→  if (resourceType === 'folder') {\n    57→    const folder = store.folders.get(resourceId);\n    58→    if (folder && folder.parentId) {\n    59→      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);\n    60→      if (parentRole && (!bestRole || ROLE_LEVEL[parentRole] > ROLE_LEVEL[bestRole])) {\n    61→        bestRole = parentRole;\n    62→      }\n    63→    }\n    64→  }\n    65→\n    66→  return bestRole;\n    67→}\n    68→\n    69→export function hasPermission(\n    70→  store: Store,\n    71→  userId: string,\n    72→  resourceType: 'folder' | 'document',\n    73→  resourceId: string,\n    74→  requiredRole: Role,\n    75→): boolean {\n    76→  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);\n    77→  if (!effectiveRole) return false;\n    78→  return ROLE_LEVEL[effectiveRole] >= ROLE_LEVEL[requiredRole];\n    79→}\n    80→"}]},"parent_tool_use_id":"toolu_01UL1u9gzupPbyBP6USzfduL","session_id":"3911a068-6837-46ec-81ae-795bfc04c614","uuid":"4e6c7d42-a44a-4477-9b43-105c26d9ad2c"}
