+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_0181NSNzPrMX4vsFSpP86Z9s","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Pef5m5i5sYohcDKabUFpjY","name":"Write","input":{"file_path":"/workspace/src/routes/share.ts","content":"import { Router, Response } from 'express';\nimport { Store, generateId } from '../store.js';\nimport { AuthRequest, authMiddleware } from '../middleware.js';\nimport { hasPermission } from '../permissions.js';\nimport { Role } from '../types.js';\n\nconst VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];\n\nexport function shareRoutes(store: Store): Router {\n  const router = Router();\n  router.use(authMiddleware(store));\n\n  // Share a resource\n  router.post('/', (req: AuthRequest, res: Response) => {\n    const { resourceType, resourceId, userId: targetUserId, role } = req.body;\n    const currentUserId = req.userId!;\n\n    if (!resourceType || !resourceId || !targetUserId || !role) {\n      res.status(400).json({ error: 'resourceType, resourceId, userId, and role are required' });\n      return;\n    }\n\n    if (!VALID_ROLES.includes(role)) {\n      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });\n      return;\n    }\n\n    if (resourceType !== 'folder' && resourceType !== 'document') {\n      res.status(400).json({ error: 'resourceType must be folder or document' });\n      return;\n    }\n\n    // Check resource exists\n    if (resourceType === 'folder') {\n      if (!store.folders.has(resourceId)) {\n        res.status(404).json({ error: 'Folder not found' });\n        return;\n      }\n    } else {\n      if (!store.documents.has(resourceId)) {\n        res.status(404).json({ error: 'Document not found' });\n        return;\n      }\n    }\n\n    // Check target user exists\n    if (!store.users.has(targetUserId)) {\n      res.status(404).json({ error: 'Target user not found' });\n      return;\n    }\n\n    // Editors can share, owners can share - need at least editor\n    if (!hasPermission(store, currentUserId, resourceType, resourceId, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions to share' });\n      return;\n    }\n\n    // Only owners can grant owner role\n    if (role === 'owner' && !hasPermission(store, currentUserId, resourceType, resourceId, 'owner')) {\n      res.status(403).json({ error: 'Only owners can grant owner role' });\n      return;\n    }\n\n    // Check if share already exists and update it\n    const existingShare = store.shares.find(\n      (s) =>\n        s.resourceType === resourceType &&\n        s.resourceId === resourceId &&\n        s.userId === targetUserId,\n    );\n\n    if (existingShare) {\n      existingShare.role = role;\n      store.activity.push({\n        id: generateId(store),\n        action: 'share_updated',\n        userId: currentUserId,\n        resourceType,\n        resourceId,\n        timestamp: new Date().toISOString(),\n        details: `Updated ${targetUserId} role to ${role}`,\n      });\n      res.json(existingShare);\n      return;\n    }\n\n    const share = {\n      id: generateId(store),\n      resourceType,\n      resourceId,\n      userId: targetUserId,\n      role,\n    };\n    store.shares.push(share);\n\n    store.activity.push({\n      id: generateId(store),\n      action: 'share_created',\n      userId: currentUserId,\n      resourceType,\n      resourceId,\n      timestamp: new Date().toISOString(),\n      details: `Shared with ${targetUserId} as ${role}`,\n    });\n\n    res.status(201).json(share);\n  });\n\n  // Remove a share\n  router.delete('/:shareId', (req: AuthRequest, res: Response) => {\n    const shareIndex = store.shares.findIndex((s) => s.id === req.params.shareId);\n    if (shareIndex === -1) {\n      res.status(404).json({ error: 'Share not found' });\n      return;\n    }\n\n    const share = store.shares[shareIndex];\n\n    // Need owner permission to remove shares\n    if (!hasPermission(store, req.userId!, share.resourceType, share.resourceId, 'owner')) {\n      res.status(403).json({ error: 'Only owners can remove shares' });\n      return;\n    }\n\n    store.shares.splice(shareIndex, 1);\n    res.status(204).send();\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1265,"cache_read_input_tokens":25354,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1265},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3911a068-6837-46ec-81ae-795bfc04c614","uuid":"40b12c54-ee2c-4735-9406-1a91f80e2950"}
