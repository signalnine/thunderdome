+
+export function createApp() {
+  const app = express();
+  const store = createStore();
+
+  app.use(express.json());
+
+  app.use('/auth', authRoutes(store));
+  app.use('/folders', folderRoutes(store));
+  app.use('/documents', documentRoutes(store));
+  app.use('/share', shareRoutes(store));
