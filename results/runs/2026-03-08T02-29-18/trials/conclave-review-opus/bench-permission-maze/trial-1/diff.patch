@@ -0,0 +1,141 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+export function documentRoutes(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Create document
+  router.post('/', (req: AuthRequest, res: Response) => {
+    const { title, content, folderId } = req.body;
+    const userId = req.userId!;
+
+    if (!title || content === undefined || !folderId) {
+      res.status(400).json({ error: 'Title, content, and folderId are required' });
+      return;
+    }
+
+    const folder = store.folders.get(folderId);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    // Need at least editor permission on folder to create document
+    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+
+    const id = generateId(store);
+    const now = new Date().toISOString();
+    const doc = {
+      id,
+      title,
+      content,
+      folderId,
+      ownerId: userId,
+      createdAt: now,
+      updatedAt: now,
+    };
+    store.documents.set(id, doc);
+
+    store.activity.push({
+      id: generateId(store),
+      action: 'document_created',
+      userId,
+      resourceType: 'document',
+      resourceId: id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/:id', (req: AuthRequest, res: Response) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, req.userId!, 'document', doc.id, 'viewer')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/:id', (req: AuthRequest, res: Response) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, req.userId!, 'document', doc.id, 'editor')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const { title, content } = req.body;
+
+    if (title !== undefined) {
+      doc.title = title;
+    }
+    if (content !== undefined) {
+      doc.content = content;
+    }
+    doc.updatedAt = new Date().toISOString();
+
+    store.activity.push({
+      id: generateId(store),
+      action: 'document_updated',
+      userId: req.userId!,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', (req: AuthRequest, res: Response) => {
+    const doc = store.documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    if (!hasPermission(store, req.userId!, 'document', doc.id, 'owner')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    // Remove shares for this document
+    store.shares = store.shares.filter(
+      (s) => !(s.resourceType === 'document' && s.resourceId === doc.id),
+    );
+
+    store.documents.delete(doc.id);
+
+    store.activity.push({
+      id: generateId(store),
+      action: 'document_deleted',
+      userId: req.userId!,
+      resourceType: 'document',
+      resourceId: doc.id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(204).send();
+  });
+
+  return router;
+}
