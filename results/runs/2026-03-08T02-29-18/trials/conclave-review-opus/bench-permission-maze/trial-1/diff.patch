@@ -0,0 +1,79 @@
+import { Store } from './store.js';
+import { Role } from './types.js';
+
+const ROLE_LEVEL: Record<Role, number> = {
+  viewer: 1,
+  editor: 2,
+  owner: 3,
+};
+
+export function getEffectiveRole(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+): Role | null {
+  let bestRole: Role | null = null;
+
+  // Check direct shares on this resource
+  for (const share of store.shares) {
+    if (
+      share.userId === userId &&
+      share.resourceType === resourceType &&
+      share.resourceId === resourceId
+    ) {
+      if (!bestRole || ROLE_LEVEL[share.role] > ROLE_LEVEL[bestRole]) {
+        bestRole = share.role;
+      }
+    }
+  }
+
+  // Check ownership
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.ownerId === userId) {
+      return 'owner';
+    }
+  } else {
+    const doc = store.documents.get(resourceId);
+    if (doc && doc.ownerId === userId) {
+      return 'owner';
+    }
+  }
+
+  // If resource is a document, also check permissions on its parent folder
+  if (resourceType === 'document') {
+    const doc = store.documents.get(resourceId);
+    if (doc) {
+      const folderRole = getEffectiveRole(store, userId, 'folder', doc.folderId);
+      if (folderRole && (!bestRole || ROLE_LEVEL[folderRole] > ROLE_LEVEL[bestRole])) {
+        bestRole = folderRole;
+      }
+    }
+  }
+
+  // If resource is a folder, check parent folder permissions (inherited)
+  if (resourceType === 'folder') {
+    const folder = store.folders.get(resourceId);
+    if (folder && folder.parentId) {
+      const parentRole = getEffectiveRole(store, userId, 'folder', folder.parentId);
+      if (parentRole && (!bestRole || ROLE_LEVEL[parentRole] > ROLE_LEVEL[bestRole])) {
+        bestRole = parentRole;
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+export function hasPermission(
+  store: Store,
+  userId: string,
+  resourceType: 'folder' | 'document',
+  resourceId: string,
+  requiredRole: Role,
+): boolean {
+  const effectiveRole = getEffectiveRole(store, userId, resourceType, resourceId);
+  if (!effectiveRole) return false;
+  return ROLE_LEVEL[effectiveRole] >= ROLE_LEVEL[requiredRole];
+}
