+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LARrj9upbdHSyNWBoQXqde","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import { Store, generateId } from '../store.js';\n     3→import { AuthRequest, authMiddleware } from '../middleware.js';\n     4→import { hasPermission } from '../permissions.js';\n     5→\n     6→export function documentRoutes(store: Store): Router {\n     7→  const router = Router();\n     8→  router.use(authMiddleware(store));\n     9→\n    10→  // Create document\n    11→  router.post('/', (req: AuthRequest, res: Response) => {\n    12→    const { title, content, folderId } = req.body;\n    13→    const userId = req.userId!;\n    14→\n    15→    if (!title || content === undefined || !folderId) {\n    16→      res.status(400).json({ error: 'Title, content, and folderId are required' });\n    17→      return;\n    18→    }\n    19→\n    20→    const folder = store.folders.get(folderId);\n    21→    if (!folder) {\n    22→      res.status(404).json({ error: 'Folder not found' });\n    23→      return;\n    24→    }\n    25→\n    26→    // Need at least editor permission on folder to create document\n    27→    if (!hasPermission(store, userId, 'folder', folderId, 'editor')) {\n    28→      res.status(403).json({ error: 'Insufficient permissions on folder' });\n    29→      return;\n    30→    }\n    31→\n    32→    const id = generateId(store);\n    33→    const now = new Date().toISOString();\n    34→    const doc = {\n    35→      id,\n    36→      title,\n    37→      content,\n    38→      folderId,\n    39→      ownerId: userId,\n    40→      createdAt: now,\n    41→      updatedAt: now,\n    42→    };\n    43→    store.documents.set(id, doc);\n    44→\n    45→    store.activity.push({\n    46→      id: generateId(store),\n    47→      action: 'document_created',\n    48→      userId,\n    49→      resourceType: 'document',\n    50→      resourceId: id,\n    51→      timestamp: new Date().toISOString(),\n    52→    });\n    53→\n    54→    res.status(201).json(doc);\n    55→  });\n    56→\n    57→  // Get document\n    58→  router.get('/:id', (req: AuthRequest, res: Response) => {\n    59→    const doc = store.documents.get(req.params.id);\n    60→    if (!doc) {\n    61→      res.status(404).json({ error: 'Document not found' });\n    62→      return;\n    63→    }\n    64→\n    65→    if (!hasPermission(store, req.userId!, 'document', doc.id, 'viewer')) {\n    66→      res.status(403).json({ error: 'Access denied' });\n    67→      return;\n    68→    }\n    69→\n    70→    res.json(doc);\n    71→  });\n    72→\n    73→  // Update document\n    74→  router.put('/:id', (req: AuthRequest, res: Response) => {\n    75→    const doc = store.documents.get(req.params.id);\n    76→    if (!doc) {\n    77→      res.status(404).json({ error: 'Document not found' });\n    78→      return;\n    79→    }\n    80→\n    81→    if (!hasPermission(store, req.userId!, 'document', doc.id, 'editor')) {\n    82→      res.status(403).json({ error: 'Access denied' });\n    83→      return;\n    84→    }\n    85→\n    86→    const { title, content } = req.body;\n    87→\n    88→    if (title !== undefined) {\n    89→      doc.title = title;\n    90→    }\n    91→    if (content !== undefined) {\n    92→      doc.content = content;\n    93→    }\n    94→    doc.updatedAt = new Date().toISOString();\n    95→\n    96→    store.activity.push({\n    97→      id: generateId(store),\n    98→      action: 'document_updated',\n    99→      userId: req.userId!,\n   100→      resourceType: 'document',\n   101→      resourceId: doc.id,\n   102→      timestamp: new Date().toISOString(),\n   103→    });\n   104→\n   105→    res.json(doc);\n   106→  });\n   107→\n   108→  // Delete document\n   109→  router.delete('/:id', (req: AuthRequest, res: Response) => {\n   110→    const doc = store.documents.get(req.params.id);\n   111→    if (!doc) {\n   112→      res.status(404).json({ error: 'Document not found' });\n   113→      return;\n   114→    }\n   115→\n   116→    if (!hasPermission(store, req.userId!, 'document', doc.id, 'owner')) {\n   117→      res.status(403).json({ error: 'Access denied' });\n   118→      return;\n   119→    }\n   120→\n   121→    // Remove shares for this document\n   122→    store.shares = store.shares.filter(\n   123→      (s) => !(s.resourceType === 'document' && s.resourceId === doc.id),\n   124→    );\n   125→\n   126→    store.documents.delete(doc.id);\n   127→\n   128→    store.activity.push({\n   129→      id: generateId(store),\n   130→      action: 'document_deleted',\n   131→      userId: req.userId!,\n   132→      resourceType: 'document',\n   133→      resourceId: doc.id,\n   134→      timestamp: new Date().toISOString(),\n   135→    });\n   136→\n   137→    res.status(204).send();\n   138→  });\n   139→\n   140→  return router;\n   141→}\n   142→"}]},"parent_tool_use_id":"toolu_01UL1u9gzupPbyBP6USzfduL","session_id":"3911a068-6837-46ec-81ae-795bfc04c614","uuid":"a1eed9c3-3976-4f3e-b5d2-44e258448c60"}
