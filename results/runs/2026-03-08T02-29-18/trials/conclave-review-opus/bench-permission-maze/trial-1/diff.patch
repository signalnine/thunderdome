 title: string; createdAt: string; updatedAt: string }[] = [];\n    for (const doc of store.documents.values()) {\n      if (doc.folderId === folder.id) {\n        documents.push({ id: doc.id, title: doc.title, createdAt: doc.createdAt, updatedAt: doc.updatedAt });\n      }\n    }\n\n    res.json({ ...folder, children, documents });\n  });\n\n  // Update folder\n  router.put('/:id', (req: AuthRequest, res: Response) => {\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, req.userId!, 'folder', folder.id, 'editor')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n\n    const { name, parentId } = req.body;\n\n    if (name !== undefined) {\n      folder.name = name;\n    }\n\n    if (parentId !== undefined) {\n      if (parentId !== null) {\n        const parent = store.folders.get(parentId);\n        if (!parent) {\n          res.status(404).json({ error: 'Parent folder not found' });\n          return;\n        }\n        // Prevent circular reference\n        if (parentId === folder.id) {\n          res.status(400).json({ error: 'Folder cannot be its own parent' });\n          return;\n        }\n      }\n      folder.parentId = parentId;\n    }\n\n    store.activity.push({\n      id: generateId(store),\n      action: 'folder_updated',\n      userId: req.userId!,\n      resourceType: 'folder',\n      resourceId: folder.id,\n      timestamp: new Date().toISOString(),\n    });\n\n    res.json(folder);\n  });\n\n  // Delete folder\n  router.delete('/:id', (req: AuthRequest, res: Response) => {\n    const folder = store.folders.get(req.params.id);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    if (!hasPermission(store, req.userId!, 'folder', folder.id, 'owner')) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    