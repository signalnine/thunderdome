+import { Router, Response } from 'express';
+import { Store, generateId } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+
+export function folderRoutes(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Create folder
+  router.post('/', (req: AuthRequest, res: Response) => {
+    const { name, parentId } = req.body;
+    const userId = req.userId!;
+
+    if (!name) {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+
+    if (parentId !== undefined && parentId !== null) {
+      const parent = store.folders.get(parentId);
+      if (!parent) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      // Need at least editor on parent to create subfolder
+      if (!hasPermission(store, userId, 'folder', parentId, 'editor')) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+
+    const id = generateId(store);
+    const folder = {
+      id,
+      name,
+      parentId: parentId || null,
+      ownerId: userId,
+      createdAt: new Date().toISOString(),
+    };
+    store.folders.set(id, folder);
+
+    store.activity.push({
+      id: generateId(store),
+      action: 'folder_created',
+      userId,
+      resourceType: 'folder',
+      resourceId: id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(201).json(folder);
+  });
+
+  // Get folder
+  router.get('/:id', (req: AuthRequest, res: Response) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, req.userId!, 'folder', folder.id, 'viewer')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    // Get children folders
+    const children: typeof folder[] = [];
+    for (const f of store.folders.values()) {
+      if (f.parentId === folder.id) {
+        children.push(f);
+      }
+    }
+
+    // Get documents in folder
+    const documents: { id: string; title: string; createdAt: string; updatedAt: string }[] = [];
+    for (const doc of store.documents.values()) {
+      if (doc.folderId === folder.id) {
+        documents.push({ id: doc.id, title: doc.title, createdAt: doc.createdAt, updatedAt: doc.updatedAt });
+      }
+    }
+
+    res.json({ ...folder, children, documents });
+  });
+
+  // Update folder
+  router.put('/:id', (req: AuthRequest, res: Response) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, req.userId!, 'folder', folder.id, 'editor')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    const { name, parentId } = req.body;
+
+    if (name !== undefined) {
+      folder.name = name;
+    }
+
+    if (parentId !== undefined) {
+      if (parentId !== null) {
+        const parent = store.folders.get(parentId);
+        if (!parent) {
+          res.status(404).json({ error: 'Parent folder not found' });
+          return;
+        }
+        // Prevent circular reference by walking up the ancestor chain
+        let current: string | null = parentId;
+        const visited = new Set<string>();
+        while (current) {
+          if (current === folder.id) {
+            res.status(400).json({ error: 'Cannot create circular folder hierarchy' });
+            return;
+          }
+          if (visited.has(current)) break;
+          visited.add(current);
+          const ancestor = store.folders.get(current);
+          current = ancestor?.parentId ?? null;
+        }
+      }
+      folder.parentId = parentId;
+    }
+
+    store.activity.push({
+      id: generateId(store),
+      action: 'folder_updated',
+      userId: req.userId!,
+      resourceType: 'folder',
+      resourceId: folder.id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.json(folder);
+  });
+
+  // Delete folder
+  router.delete('/:id', (req: AuthRequest, res: Response) => {
+    const folder = store.folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+
+    if (!hasPermission(store, req.userId!, 'folder', folder.id, 'owner')) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+
+    // Collect all folder IDs to delete (root + descendants)
+    const deletedFolderIds = new Set<string>([folder.id]);
+    const deletedDocIds = new Set<string>();
+
+    const collectChildren = (folderId: string) => {
+      for (const [childId, child] of store.folders) {
+        if (child.parentId === folderId) {
+          deletedFolderIds.add(childId);
+          collectChildren(childId);
+        }
+      }
+    };
+    collectChildren(folder.id);
+
+    // Collect all documents in deleted folders
+    for (const [docId, doc] of store.documents) {
+      if (deletedFolderIds.has(doc.folderId)) {
+        deletedDocIds.add(docId);
+      }
+    }
+
+    // Delete documents
+    for (const docId of deletedDocIds) {
+      store.documents.delete(docId);
+    }
+
+    // Delete child folders
+    for (const folderId of deletedFolderIds) {
+      store.folders.delete(folderId);
+    }
+
+    // Remove all shares for deleted resources
+    store.shares = store.shares.filter(
+      (s) =>
+        !(
+          (s.resourceType === 'folder' && deletedFolderIds.has(s.resourceId)) ||
+          (s.resourceType === 'document' && deletedDocIds.has(s.resourceId))
+        ),
+    );
+
+    store.activity.push({
+      id: generateId(store),
+      action: 'folder_deleted',
+      userId: req.userId!,
+      resourceType: 'folder',
+      resourceId: folder.id,
+      timestamp: new Date().toISOString(),
+    });
+
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/routes/share.ts b/src/routes/share.ts
new file mode 100644
index 0000000..0497a44
--- /dev/null
+++ b/src/routes/share.ts
@@ -0,0 +1,130 @@
+import { Router, Response } from 'express';
+import { Store, generateId } from '../store.js';
+import { AuthRequest, authMiddleware } from '../middleware.js';
+import { hasPermission } from '../permissions.js';
+import { Role } from '../types.js';
+
+const VALID_ROLES: Role[] = ['viewer', 'editor', 'owner'];
+
+export function shareRoutes(store: Store): Router {
+  const router = Router();
+  router.use(authMiddleware(store));
+
+  // Share a resource
+  router.post('/', (req: AuthRequest, res: Response) => {
+    const { resourceType, resourceId, userId: targetUserId, role } = req.body;
+    const currentUserId = req.userId!;
+
+    if (!resourceType || !resourceId || !targetUserId || !role) {
+      res.status(400).json({ error: 'resourceType, resourceId, userId, and role are required' });
+      return;
+    }
+
+    if (!VALID_ROLES.includes(role)) {
+      res.status(400).json({ error: 'Invalid role. Must be viewer, editor, or owner' });
+      return;
+    }
+
+    if (resourceType !== 'folder' && resourceType !== 'document') {
+      res.status(400).json({ error: 'resourceType must be folder or document' });
+      return;
+    }
+
+    // Check resource exists
+    if (resourceType === 'folder') {
+      if (!store.folders.has(resourceId)) {
+        res.status(404).json({ error: 'Folder not found' });
+        return;
+      }
+    } else {
+      if (!store.documents.has(resourceId)) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+    }
+
+    // Check target user exists
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Editors can share, owners can share - need at least editor
+    if (!hasPermission(store, currentUserId, resourceType, resourceId, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions to share' });
+      return;
+    }
+
+    // Only owners can grant owner role
+    if (role === 'owner' && !hasPermission(store, currentUserId, resourceType, resourceId, 'owner')) {
+      res.status(403).json({ error: 'Only owners can grant owner role' });
+      return;
+    }
+
+    // Check if share already exists and update it
+    const existingShare = store.shares.find(
+      (s) =>
+        s.resourceType === resourceType &&
+        s.resourceId === resourceId &&
+        s.userId === targetUserId,
+    );
+
+    if (existingShare) {
+      existingShare.role = role;
+      store.activity.push({
+        id: generateId(store),
+        action: 'share_updated',
+        userId: currentUserId,
+        resourceType,
+        resourceId,
+        timestamp: new Date().toISOString(),
+        details: `Updated ${targetUserId} role to ${role}`,
+      });
+      res.json(existingShare);
+      return;
+    }
+
+    const share = {
+      id: generateId(store),
+      resourceType,
+      resourceId,
+      userId: targetUserId,
+      role,
+    };
+    store.shares.push(share);
+
+    store.activity.push({
+      id: generateId(store),
+      action: 'share_created',
+      userId: currentUserId,
+      resourceType,
+      resourceId,
+      timestamp: new Date().toISOString(),
+      details: `Shared with ${targetUserId} as ${role}`,
+    });
+
+    res.status(201).json(share);
+  });
+
+  // Remove a share
+  router.delete('/:shareId', (req: AuthRequest, res: Response) => {
+    const shareIndex = store.shares.findIndex((s) => s.id === req.params.shareId);
+    if (shareIndex === -1) {
+      res.status(404).json({ error: 'Share not found' });
+      return;
+    }
+
+    const share = store.shares[shareIndex];
+
+    // Need owner permission to remove shares
+    if (!hasPermission(store, req.userId!, share.resourceType, share.resourceId, 'owner')) {
+      res.status(403).json({ error: 'Only owners can remove shares' });
+      return;
+    }
+
+    store.shares.splice(shareIndex, 1);
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/store.ts b/src/store.ts
new file mode 100644
index 0000000..d10952d
--- /dev/null
+++ b/src/store.ts
@@ -0,0 +1,31 @@
+import { User, Folder, Document, Share, ActivityEntry } from './types.js';
+
+export interface Store {
+  users: Map<string, User>;
+  tokens: Map<string, string>; // token -> userId
+  folders: Map<string, Folder>;
+  documents: Map<string, Document>;
+  shares: Share[];
+  activity: ActivityEntry[];
+  nextId: number;
+}
+
+export function createStore(): Store {
+  return {
+    users: new Map(),
+    tokens: new Map(),
+    folders: new Map(),
+    documents: new Map(),
+    shares: [],
+    activity: [],
+    nextId: 1,
+  };
+}
+
+export function generateId(store: Store): string {
+  return String(store.nextId++);
+}
+
+export function generateToken(): string {
+  return Math.random().toString(36).substring(2) + Date.now().toString(36);
+}
