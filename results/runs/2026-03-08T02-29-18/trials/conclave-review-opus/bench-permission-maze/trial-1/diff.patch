+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NYt8FbALcqbZATYeLQVen4","type":"tool_result","content":"     1→import { Router, Response } from 'express';\n     2→import { Store, generateId } from '../store.js';\n     3→import { AuthRequest, authMiddleware } from '../middleware.js';\n     4→import { hasPermission } from '../permissions.js';\n     5→\n     6→export function folderRoutes(store: Store): Router {\n     7→  const router = Router();\n     8→  router.use(authMiddleware(store));\n     9→\n    10→  // Create folder\n    11→  router.post('/', (req: AuthRequest, res: Response) => {\n    12→    const { name, parentId } = req.body;\n    13→    const userId = req.userId!;\n    14→\n    15→    if (!name) {\n    16→      res.status(400).json({ error: 'Folder name is required' });\n    17→      return;\n    18→    }\n    19→\n    20→    if (parentId !== undefined && parentId !== null) {\n    21→      const parent = store.folders.get(parentId);\n    22→      if (!parent) {\n    23→        res.status(404).json({ error: 'Parent folder not found' });\n    24→        return;\n    25→      }\n    26→      // Need at least editor on parent to create subfolder\n    27→      if (!hasPermission(store, userId, 'folder', parentId, 'editor')) {\n    28→        res.status(403).json({ error: 'Insufficient permissions on parent folder' });\n    29→        return;\n    30→      }\n    31→    }\n    32→\n    33→    const id = generateId(store);\n    34→    const folder = {\n    35→      id,\n    36→      name,\n    37→      parentId: parentId || null,\n    38→      ownerId: userId,\n    39→      createdAt: new Date().toISOString(),\n    40→    };\n    41→    store.folders.set(id, folder);\n    42→\n    43→    store.activity.push({\n    44→      id: generateId(store),\n    45→      action: 'folder_created',\n    46→      userId,\n    47→      resourceType: 'folder',\n    48→      resourceId: id,\n    49→      timestamp: new Date().toISOString(),\n    50→    });\n    51→\n    52→    res.status(201).json(folder);\n    53→  });\n    54→\n    55→  // Get folder\n    56→  router.get('/:id', (req: AuthRequest, res: Response) => {\n    57→    const folder = store.folders.get(req.params.id);\n    58→    if (!folder) {\n    59→      res.status(404).json({ error: 'Folder not found' });\n    60→      return;\n    61→    }\n    62→\n    63→    if (!hasPermission(store, req.userId!, 'folder', folder.id, 'viewer')) {\n    64→      res.status(403).json({ error: 'Access denied' });\n    65→      return;\n    66→    }\n    67→\n    68→    // Get children folders\n    69→    const children: typeof folder[] = [];\n    70→    for (const f of store.folders.values()) {\n    71→      if (f.parentId === folder.id) {\n    72→        children.push(f);\n    73→      }\n    74→    }\n    75→\n    76→    // Get documents in folder\n    77→    const documents: { id: string; title: string; createdAt: string; updatedAt: string }[] = [];\n    78→    for (const doc of store.documents.values()) {\n    79→      if (doc.folderId === folder.id) {\n    80→        documents.push({ id: doc.id, title: doc.title, createdAt: doc.createdAt, updatedAt: doc.updatedAt });\n    81→      }\n    82→    }\n    83→\n    84→    res.json({ ...folder, children, documents });\n    85→  });\n    86→\n    87→  // Update folder\n    88→  router.put('/:id', (req: AuthRequest, res: Response) => {\n    89→    const folder = store.folders.get(req.params.id);\n    90→    if (!folder) {\n    91→      res.status(404).json({ error: 'Folder not found' });\n    92→      return;\n    93→    }\n    94→\n    95→    if (!hasPermission(store, req.userId!, 'folder', folder.id, 'editor')) {\n    96→      res.status(403).json({ error: 'Access denied' });\n    97→      return;\n    98→    }\n    99→\n   100→    const { name, parentId } = req.body;\n   101→\n   102→    if (name !== undefined) {\n   103→      folder.name = name;\n   104→    }\n   105→\n   106→    if (parentId !== undefined) {\n   107→      if (parentId !== null) {\n   108→        const parent = store.folders.get(parentId);\n   109→        if (!parent) {\n   110→          res.status(404).json({ error: 'Parent folder not found' });\n   111→          return;\n   112→        }\n   113→        // Prevent circular reference\n   114→        if (parentId === folder.id) {\n   115→          res.status(400).json({ error: 'Folder cannot be its own parent' });\n   116→          return;\n   117→        }\n   118→      }\n   119→      folder.parentId = parentId;\n   120→    }\n   121→\n   122→    store.activity.push({\n   123→      id: generateId(store),\n   124→      action: 'folder_updated',\n   125→      userId: req.userId!,\n   126→      resourceType: 'folder',\n   127→      resourceId: folder.id,\n   128→      timestamp: new Date().toISOString(),\n   129→    });\n   130→\n   131→    res.json(folder);\n   132→  });\n   133→\n   134→  // Delete folder\n   135→  router.delete('/:id', (req: AuthRequest, res: Response) => {\n   136→    const folder = store.folders.get(req.params.id);\n   137→    if (!folder) {\n   138→      res.status(404).json({ error: 'Folder not found' });\n   139→      return;\n   140→    }\n   141→\n   142→    if (!hasPermission(store, req.userId!, 'folder', folder.id, 'owner')) {\n   143→      res.status(403).json({ error: 'Access denied' });\n   144→      return;\n   145→    }\n   146→\n   147→    // Delete all documents in this folder\n   148→    for (const [docId, doc] of store.documents) {\n   149→      if (doc.folderId === folder.id) {\n   150→        store.documents.delete(docId);\n   151→      }\n   152→    }\n   153→\n   154→    // Delete child folders recursively\n   155→    const deleteChildren = (folderId: string) => {\n   156→      for (const [childId, child] of store.folders) {\n   157→        if (child.parentId === folderId) {\n   158→          // Delete documents in child folder\n   159→          for (const [docId, doc] of store.documents) {\n   160→            if (doc.folderId === childId) {\n   161→              store.documents.delete(docId);\n   162→            }\n   163→          }\n   164→          deleteChildren(childId);\n   165→          store.folders.delete(childId);\n   166→        }\n   167→      }\n   168→    };\n   169→    deleteChildren(folder.id);\n   170→\n   171→    // Remove shares for this folder\n   172→    store.shares = store.shares.filter(\n   173→      (s) => !(s.resourceType === 'folder' && s.resourceId === folder.id),\n   174→    );\n   175→\n   176→    store.folders.delete(folder.id);\n   177→\n   178→    store.activity.push({\n   179→      id: generateId(store),\n   180→      action: 'folder_deleted',\n   181→      userId: req.userId!,\n   182→      resourceType: 'folder',\n   183→      resourceId: folder.id,\n   184→      timestamp: new Date().toISOString(),\n   185→    });\n   186→\n   187→    res.status(204).send();\n   188→  });\n   189→\n   190→  return router;\n   191→}\n   192→"}]},"parent_tool_use_id":"toolu_01UL1u9gzupPbyBP6USzfduL","session_id":"3911a068-6837-46ec-81ae-795bfc04c614","uuid":"a9c0959c-dfb1-4ab8-b3dd-40accf4fc723"}
