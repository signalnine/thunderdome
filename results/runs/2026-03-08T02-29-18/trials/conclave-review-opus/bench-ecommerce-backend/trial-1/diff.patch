diff --git a/src/analytics/index.ts b/src/analytics/index.ts
new file mode 100644
index 0000000..5f5ad8c
--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,125 @@
+import { EventBus } from '../bus.js';
+import {
+  AnalyticsService,
+  Events,
+  PaymentProcessedEvent,
+  PaymentStatus,
+  OrderCreatedEvent,
+} from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let totalRevenue = 0;
+  const uniqueCarts = new Set<string>();
+  let orderCount = 0;
+  const productCounts = new Map<string, number>();
+
+  // Track cart creations from cart:updated events (first time a cartId is seen)
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    const event = payload as { cartId: string };
+    uniqueCarts.add(event.cartId);
+    increment(Events.CART_UPDATED);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    orderCount++;
+    increment(Events.ORDER_CREATED);
+
+    // We need cart items to track product counts - listen from bus log
+    // The order event has cartId, but we track products via cart events
+    // For product ranking, we'll track from cart updated events associated with orders
+    // Actually, we need to get items from the bus log's cart events
+    const log = bus.getLog();
+    // Find the most recent cart:updated event for this cartId
+    for (let i = log.length - 1; i >= 0; i--) {
+      if (log[i].event === Events.CART_UPDATED) {
+        const cartEvent = log[i].payload as { cartId: string; items: Array<{ productId: string; quantity: number }> };
+        if (cartEvent.cartId === event.cartId) {
+          for (const item of cartEvent.items) {
+            productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);
+          }
+          break;
+        }
+      }
+    }
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as PaymentProcessedEvent;
+    increment(Events.PAYMENT_PROCESSED);
+
+    function findOrderTotal(orderId: string): number {
+      const log = bus.getLog();
+      for (let i = log.length - 1; i >= 0; i--) {
+        if (log[i].event === Events.ORDER_CREATED) {
+          const orderEvent = log[i].payload as OrderCreatedEvent;
+          if (orderEvent.orderId === orderId) {
+            return orderEvent.total;
+          }
+        }
+      }
+      return 0;
+    }
+
+    if (event.status === PaymentStatus.SUCCESS) {
+      totalRevenue += findOrderTotal(event.orderId);
+    } else if (event.status === PaymentStatus.FAILED && event.error === 'Refunded') {
+      totalRevenue -= findOrderTotal(event.orderId);
+    }
+  });
+
+  bus.on(Events.PRODUCT_CREATED, () => {
+    increment(Events.PRODUCT_CREATED);
+  });
+
+  bus.on(Events.INVENTORY_UPDATED, () => {
+    increment(Events.INVENTORY_UPDATED);
+  });
+
+  bus.on(Events.LOW_STOCK_ALERT, () => {
+    increment(Events.LOW_STOCK_ALERT);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, () => {
+    increment(Events.ORDER_STATUS_CHANGED);
+  });
+
+  bus.on(Events.NOTIFICATION_SENT, () => {
+    increment(Events.NOTIFICATION_SENT);
+  });
+
+  bus.on(Events.PRICE_CALCULATED, () => {
+    increment(Events.PRICE_CALCULATED);
+  });
+
+  bus.on(Events.ANALYTICS_EVENT, () => {
+    increment(Events.ANALYTICS_EVENT);
+  });
+
+  function increment(eventType: string): void {
+    eventCounts.set(eventType, (eventCounts.get(eventType) ?? 0) + 1);
+  }
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) ?? 0;
+    },
+
+    getRevenue(): number {
+      return totalRevenue;
+    },
+
+    getConversionRate(): number {
+      if (uniqueCarts.size === 0) return 0;
+      return orderCount / uniqueCarts.size;
+    },
+
+    getTopProducts(limit: number) {
+      return Array.from(productCounts.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
diff --git a/src/cart/index.ts b/src/cart/index.ts
new file mode 100644
index 0000000..d1d13a4
--- /dev/null
+++ b/src/cart/index.ts
@@ -0,0 +1,72 @@
+import { EventBus } from '../bus.js';
+import { CartService, Events, CartUpdatedEvent } from '../types.js';
+
+export function createCartService(bus: EventBus): CartService {
+  const carts = new Map<string, { id: string; userId: string; items: Array<{ productId: string; quantity: number }> }>();
+  let nextId = 1;
+
+  function emitCartUpdated(cart: { id: string; userId: string; items: Array<{ productId: string; quantity: number }> }): void {
+    const event: CartUpdatedEvent = {
+      cartId: cart.id,
+      userId: cart.userId,
+      items: cart.items.map(i => ({ ...i })),
+    };
+    bus.emit(Events.CART_UPDATED, event);
+  }
+
+  return {
+    createCart(userId: string): string {
+      const id = `cart_${nextId++}`;
+      const cart = { id, userId, items: [] as Array<{ productId: string; quantity: number }> };
+      carts.set(id, cart);
+      emitCartUpdated(cart);
+      return id;
+    },
+
+    addItem(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      const existing = cart.items.find(i => i.productId === productId);
+      if (existing) {
+        existing.quantity += quantity;
+      } else {
+        cart.items.push({ productId, quantity });
+      }
+      emitCartUpdated(cart);
+    },
+
+    removeItem(cartId: string, productId: string): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items = cart.items.filter(i => i.productId !== productId);
+      emitCartUpdated(cart);
+    },
+
+    getCart(cartId: string) {
+      const cart = carts.get(cartId);
+      if (!cart) return null;
+      return {
+        id: cart.id,
+        userId: cart.userId,
+        items: cart.items.map(i => ({ ...i })),
+      };
+    },
+
+    clearCart(cartId: string): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items = [];
+      emitCartUpdated(cart);
+    },
+
+    updateQuantity(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      const existing = cart.items.find(i => i.productId === productId);
+      if (existing) {
+        existing.quantity = quantity;
+        emitCartUpdated(cart);
+      }
+    },
+  };
+}
