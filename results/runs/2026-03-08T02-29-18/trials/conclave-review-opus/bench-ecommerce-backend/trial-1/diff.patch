ventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert', async () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.setLowStockThreshold('p1', 5);\n    inventory.setStock('p1', 3);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.LOW_STOCK_ALERT)).toBe(true);\n  });\n});\n\ndescribe('CartService', () => {\n  it('should create a cart and add items', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    const c = cart.getCart(cartId);\n    expect(c).toBeTruthy();\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('should consolidate items for the same product', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.addItem(cartId, 'p1', 3);\n    const c = cart.getCart(cartId);\n    expect(c!.items).toHaveLength(1);\n    expect(c!.items[0].quantity).toBe(5);\n  });\n\n  it('should remove items', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.removeItem(cartId, 'p1');\n    expect(cart.getCart(cartId)!.items).toHaveLength(0);\n  });\n\n  it('should update quantity', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.updateQuantity(cartId, 'p1', 7);\n    expect(cart.getCart(cartId)!.items[0].quantity).toBe(7);\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, 'p1', 2);\n    cart.clearCart(cartId);\n    expect(cart.getCart(cartId)!.items).toHaveLength(0);\n  });\n\n  it('should return null for unknown cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('unknown')).toBeNull();\n  });\n});\n\ndescribe('PricingService', () => {\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([\n      { productId: 'p1', quantity: 2, price: 10 },\n    ]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // 10% of 90\n    expect(result.total).toBe(99);\n  });\n\n  it('should track prices from product created events', async () => {\n    const pricing = createPricingService(bus);\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    // Need to wait for async bus emit\n    await new Promise(resolve => setTimeout(resolve, 10));\n    expect(pricing.getPrice(id)).toBe(9.99);\n  });\n\n  it('should ignore invalid discount codes', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'INVALID'\n    );\n    expect(result.discount).toBe(0);\n    expect(result.total).toBe(110);\n  });\n});\n\ndescribe('OrderService', () => {\n  it('should create and retrieve an order', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    const order = orders.getOrder(id);\n    expect(order).toBeTruthy();\n    expect(order!.status).toBe(OrderStatus.PENDING);\n    expect(order!.total).toBe(99.99);\n  });\n\n  it('should update order status with previous status', async () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 99.99);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n\n    const log = bus.getLog();\n    const statusEvent = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(statusEvent).toBeTruthy();\n    const payload = statusEvent!.payload as { orderId: string; status: string; previousStatus: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n    expect(payload.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should list orders for a user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 10);\n    orders.createOrder('user1', 'cart2', 20);\n    orders.createOrder('user2', 'cart3', 30);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n    expect(orders.listOrders('user2')).toHaveLength(1);\n  });\n\n  it('should return null for unknown order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('unknown')).toBeNull();\n  });\n\n  it('should progress through status lifecycle', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    orders.updateStatus(id, OrderStatus.SHIPPED);\n    orders.updateStatus(id, OrderStatus.DELIVERED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.DELIVERED);\n  });\n\n  it('should support cancellation', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(id, OrderStatus.CANCELLED);\n    expect(orders.getOrder(id)!.status).toBe(OrderStatus.CANCELLED);\n  });\n});\n\ndescribe('PaymentService', () => {\n  it('should process payment successfully', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeTruthy();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeTruthy();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 99.99);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 99.99);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should fail to refund non-existent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('nonexistent');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit PAYMENT_PROCESSED event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 99.99);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('NotificationService', () => {\n  it('should deliver notifications to subscribed users on order events', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n\n    // Wait for async events\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    const userNotifs = notifications.getNotifications('user1');\n    expect(userNotifs.length).toBeGreaterThan(0);\n    expect(userNotifs.some(n => n.type === 'order_created')).toBe(true);\n  });\n\n  it('should notify on order status changes', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    const userNotifs = notifications.getNotifications('user1');\n    expect(userNotifs.some(n => n.type === 'order_status')).toBe(true);\n  });\n\n  it('should notify on payment events', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    notifications.subscribe('user1');\n    const orderId = orders.createOrder('user1', 'cart1', 50);\n    await payment.processPayment(orderId, 50);\n\n    const userNotifs = notifications.getNotifications('user1');\n    expect(userNotifs.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('should not notify unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    const orders = createOrderService(bus);\n\n    orders.createOrder('user1', 'cart1', 50);\n\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  it('should count events', async () => {\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.createProduct('Gizmo', 14.99, 'toys');\n\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n\n    orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment('order_1', 100);\n\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not count revenue from failed payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus, { simulateFailure: true });\n\n    orders.createOrder('user1', 'cart1', 100);\n    await payment.processPayment('order_1', 100);\n\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cartSvc = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const cart1 = cartSvc.createCart('user1');\n    cartSvc.addItem(cart1, 'p1', 1);\n    const cart2 = cartSvc.createCart('user2');\n    cartSvc.addItem(cart2, 'p2', 1);\n\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    orders.createOrder('user1', cart1, 50);\n\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should rank top products', async () => {\n    const analytics = createAnalyticsService(bus);\n    const cartSvc = createCartService(bus);\n    const orders = createOrderService(bus);\n\n    const cart1 = cartSvc.createCart('user1');\n    cartSvc.addItem(cart1, 'p1', 5);\n    cartSvc.addItem(cart1, 'p2', 2);\n\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    orders.createOrder('user1', cart1, 50);\n\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    const top = analytics.getTopProducts(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(2);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n});\n\ndescribe('Integration: Full Order Flow', () => {\n  it('should handle a complete order lifecycle', async () => {\n    // Create all services\n    const analytics = createAnalyticsService(bus);\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cartSvc = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products\n    const p1 = catalog.createProduct('Widget', 10, 'gadgets');\n    const p2 = catalog.createProduct('Gizmo', 20, 'gadgets');\n\n    // Wait for product creation events\n    await new Promise(resolve => setTimeout(resolve, 10));\n\n    // Set inventory\n    inventory.setStock(p1, 100);\n    inventory.setStock(p2, 50);\n\n    // Create cart and add items\n    const cartId = cartSvc.createCart('user1');\n    cartSvc.addItem(cartId, p1, 2);\n    cartSvc.addItem(cartId, p2, 1);\n\n    // Calculate price\n    const cart = cartSvc.getCart(cartId)!;\n    const priceItems = cart.items.map(i => ({\n      productId: i.productId,\n      quantity: i.quantity,\n      price: pricing.getPrice(i.productId),\n    }));\n    const total = pricing.calculateTotal(priceItems);\n    expect(total.subtotal).toBe(40); // 2*10 + 1*20\n    expect(total.tax).toBe(4);\n    expect(total.total).toBe(44);\n\n    // Reserve inventory\n    expect(inventory.reserve(p1, 2)).toBe(true);\n    expect(inventory.reserve(p2, 1)).toBe(true);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, total.total);\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const payResult = await payment.processPayment(orderId, total.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    expect(orders.getOrder(orderId)!.status).toBe(OrderStatus.DELIVERED);\n\n    // Check notifications\n    await new Promise(resolve => setTimeout(resolve, 10));\n    const userNotifs = notifications.getNotifications('user1');\n    expect(userNotifs.length).toBeGreaterThan(0);\n\n    // Check analytics\n    expect(analytics.getRevenue()).toBe(44);\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
