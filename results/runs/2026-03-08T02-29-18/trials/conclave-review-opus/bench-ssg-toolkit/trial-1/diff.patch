+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,60 @@
+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        if (!content) {
+          return { ...file, content: '' };
+        }
+
+        // Extract footnote definitions before markdown processing
+        const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+        const footnotes: Map<string, string> = new Map();
+        let match: RegExpExecArray | null;
+
+        while ((match = footnoteDefRegex.exec(content)) !== null) {
+          footnotes.set(match[1], match[2]);
+        }
+
+        // Remove footnote definitions from content
+        content = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '').trim();
+
+        // Process admonition containers before markdown parsing
+        // Replace :::type ... ::: with placeholder divs
+        content = content.replace(
+          /^:::(\w+)\n([\s\S]*?)^:::/gm,
+          (_match, type: string, inner: string) => {
+            return `<div class="admonition admonition-${type}">\n${inner.trim()}\n</div>`;
+          }
+        );
+
+        // Replace inline footnote references [^1] with superscript links
+        content = content.replace(
+          /\[\^(\d+)\]/g,
+          (_match, num: string) => `<sup><a href="#fn-${num}">${num}</a></sup>`
+        );
+
+        // Convert markdown to HTML using marked (synchronous)
+        const html = marked.parse(content, { async: false }) as string;
+
+        // Build footnotes section if any footnotes exist
+        let result = html;
+        if (footnotes.size > 0) {
+          const items = Array.from(footnotes.entries())
+            .map(([num, text]) => `<li id="fn-${num}">${text}</li>`)
+            .join('\n');
+          result += `\n<section class="footnotes">\n<ol>\n${items}\n</ol>\n</section>`;
+        }
+
+        return { ...file, content: result };
+      },
+    },
+  };
+}
