new Date('2025-01-01T00:05:00Z')); // due\n    48→    expect(third).toHaveLength(1);\n    49→  });\n    50→\n    51→  it('should support hourly schedule', () => {\n    52→    q.addSchedule('0 * * * *', 'hourly');\n    53→\n    54→    const created = q.tick(new Date('2025-01-01T01:00:00Z'));\n    55→    expect(created).toHaveLength(1);\n    56→\n    57→    // Not at the top of the hour\n    58→    const none = q.tick(new Date('2025-01-01T01:30:00Z'));\n    59→    expect(none).toHaveLength(0);\n    60→  });\n    61→\n    62→  it('should support daily at midnight schedule', () => {\n    63→    q.addSchedule('0 0 * * *', 'daily');\n    64→\n    65→    const created = q.tick(new Date('2025-01-02T00:00:00Z'));\n    66→    expect(created).toHaveLength(1);\n    67→\n    68→    // Not midnight\n    69→    const none = q.tick(new Date('2025-01-02T12:00:00Z'));\n    70→    expect(none).toHaveLength(0);\n    71→  });\n    72→\n    73→  it('should respect custom queue and priority in schedules', () => {\n    74→    q.addSchedule('*/1 * * * *', 'data', { queue: 'reports', priority: 2 });\n    75→\n    76→    const tasks = q.tick(new Date());\n    77→    expect(tasks[0].queue).toBe('reports');\n    78→    expect(tasks[0].priority).toBe(2);\n    79→  });\n    80→\n    81→  it('should not create tasks after schedule is removed', () => {\n    82→    const s = q.addSchedule('*/1 * * * *', 'data');\n    83→    q.tick(new Date('2025-01-01T00:00:00Z'));\n    84→\n    85→    q.removeSchedule(s.id);\n    86→    const created = q.tick(new Date('2025-01-01T00:02:00Z'));\n    87→    expect(created).toHaveLength(0);\n    88→  });\n    89→\n    90→  it('should throw on invalid cron expression', () => {\n    91→    expect(() => q.addSchedule('invalid', 'data')).toThrow();\n    92→    expect(() => q.addSchedule('* *', 'data')).toThrow();\n    93→  });\n    94→\n    95→  it('recurring tasks should be subject to normal queue rules', () => {\n    96→    q.setConcurrency('default', 1);\n    97→    q.