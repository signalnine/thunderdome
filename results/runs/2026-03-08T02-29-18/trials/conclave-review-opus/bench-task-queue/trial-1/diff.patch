--- /dev/null
+++ b/tests/phase05-retry.test.ts
@@ -0,0 +1,114 @@
+import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 5: Retry with Backoff', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('should complete a task', () => {
+    const task = q.add('data');
+    q.next();
+    q.complete(task.id);
+    expect(task.status).toBe('completed');
+  });
+
+  it('should fail a task and retry it', () => {
+    const task = q.add('data', { maxRetries: 3, backoffDelay: 1000 });
+    q.next(); // attempt 1
+    q.fail(task.id, 'error');
+
+    expect(task.status).toBe('pending');
+    expect(task.attempt).toBe(1);
+
+    // Should not be available yet (1000ms backoff)
+    expect(q.next()).toBeNull();
+
+    vi.advanceTimersByTime(1000);
+    const retried = q.next();
+    expect(retried?.id).toBe(task.id);
+    expect(retried?.attempt).toBe(2);
+  });
+
+  it('should use exponential backoff', () => {
+    const task = q.add('data', { maxRetries: 3, backoffDelay: 1000 });
+
+    // Attempt 1
+    q.next();
+    q.fail(task.id, 'err');
+    // backoff: 1000 * 2^0 = 1000ms
+
+    vi.advanceTimersByTime(999);
+    expect(q.next()).toBeNull();
+    vi.advanceTimersByTime(1);
+    q.next(); // attempt 2
+
+    q.fail(task.id, 'err');
+    // backoff: 1000 * 2^1 = 2000ms
+
+    vi.advanceTimersByTime(1999);
+    expect(q.next()).toBeNull();
+    vi.advanceTimersByTime(1);
+    q.next(); // attempt 3
+
+    q.fail(task.id, 'err');
+    // All retries exhausted
+    expect(task.status).toBe('failed');
+  });
+
+  it('should keep original queue and priority on retry', () => {
+    const task = q.add('data', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 100 });
+    q.next('myq');
+    q.fail(task.id, 'err');
+
+    expect(task.queue).toBe('myq');
+    expect(task.priority).toBe(2);
+  });
+
+  it('should track attempt count', () => {
+    const task = q.add('data', { maxRetries: 2, backoffDelay: 100 });
+
+    q.next();
+    expect(task.attempt).toBe(1);
+
+    q.fail(task.id, 'err');
+    vi.advanceTimersByTime(100);
+
+    q.next();
+    expect(task.attempt).toBe(2);
+  });
+
+  it('should default to 3 max retries', () => {
+    const task = q.add('data');
+    expect(task.maxRetries).toBe(3);
+  });
+
+  it('should default to 1000ms backoff delay', () => {
+    const task = q.add('data');
+    expect(task.backoffDelay).toBe(1000);
+  });
+
+  it('should store the error message', () => {
+    const task = q.add('data');
+    q.next();
+    q.fail(task.id, 'Something went wrong');
+    expect(task.error).toBe('Something went wrong');
+  });
+
+  it('should throw when completing a non-processing task', () => {
+    const task = q.add('data');
+    expect(() => q.complete(task.id)).toThrow();
+  });
+
+  it('should throw when failing a non-processing task', () => {
+    const task = q.add('data');
+    expect(() => q.fail(task.id)).toThrow();
+  });
+});
