s = options.dependencies ?? [];\n    48→    for (const depId of dependencies) {\n    49→      const depTask = this.tasks.get(depId);\n    50→      if (!depTask) {\n    51→        throw new Error(`Dependency task not found: ${depId}`);\n    52→      }\n    53→    }\n    54→\n    55→    const now = new Date();\n    56→    let availableAt = now;\n    57→\n    58→    if (options.processAt) {\n    59→      availableAt = options.processAt;\n    60→    } else if (options.delay && options.delay > 0) {\n    61→      availableAt = new Date(now.getTime() + options.delay);\n    62→    }\n    63→\n    64→    const task: Task<T> = {\n    65→      id: randomUUID(),\n    66→      payload,\n    67→      status: 'pending',\n    68→      queue,\n    69→      priority,\n    70→      createdAt: now,\n    71→      availableAt,\n    72→      attempt: 0,\n    73→      maxRetries: options.maxRetries ?? 3,\n    74→      backoffDelay: options.backoffDelay ?? 1000,\n    75→      progress: 0,\n    76→      dependencies: [...dependencies],\n    77→      resolvedDependencies: new Set<string>(),\n    78→    };\n    79→\n    80→    // Check resolved dependencies on creation\n    81→    for (const depId of task.dependencies) {\n    82→      const depTask = this.tasks.get(depId);\n    83→      if (depTask && depTask.status === 'completed') {\n    84→        task.resolvedDependencies.add(depId);\n    85→      }\n    86→    }\n    87→\n    88→    this.tasks.set(task.id, task as Task);\n    89→    return task;\n    90→  }\n    91→\n    92→  get(taskId: string): Task | null {\n    93→    return this.tasks.get(taskId) ?? null;\n    94→  }\n    95→\n    96→  next(queueName?: string): Task | null {\n    97→    const queue = queueName ?? DEFAULT_QUEUE;\n    98→    const now = new Date();\n    99→\n   100→    // Check concurrency limit\n   101→    const limit = this.concurrencyLimits.get(queue);\n   102→    if (limit !== undefined) {\n   103→      const activeCount = this.getActiveCount(queue);\n   104→      if (activeCount >= limit) {\n   105→        return null;\n   106→      }\n   107→    }\n   108→\n   109→    // Find eligible tasks: pending, in this queue, available (time), unblocked (deps)\n   110→    const candidates: Task[] = [];\n   111→    for (const task of this.tasks.values()) {\n   112→      if (task.queue !== queue) continue;\n   113→      if (task.status !== 'pending') continue;\n   114→      if (task.availableAt > now) continue;\n   115→      if (!this.areDependenciesMet(task)) continue;\n   116→      candidates.push(task);\n   117→    }\n   118→\n   119→    if (candidates.length === 0) return null;\n   120→\n   121→    // Sort: priority (ascending = higher priority first), then availableAt, then createdAt\n   122→    candidates.sort((a, b) => {\n   123→      if (a.priority !== b.priority) return a.priority - b.priority;\n   124→      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n   125→        return a.availableAt.getTime() - b.availableAt.getTime();\n   126→      }\n   127→      return a.createdAt.getTime() - b.createdAt.getTime();\n   128→    });\n   129→\n   130→    const chosen = candidates[0];\n   131→    chosen.status = 'processing';\n   132→    chosen.attempt += 1;\n   133→    return chosen;\n   134→  }\n   135→\n   136→  size(queueName?: string): number {\n   137→    const queue = queueName ?? DEFAULT_QUEUE;\n   138→    let count = 0;\n   139→    for (const task of this.tasks.values()) {\n   140→      if (task.queue === queue && task.status === 'pending') {\n   141→        count++;\n   142→      }\n   143→    }\n   144→    return count;\n   145→  }\n   146→\n   147→  // --- Phase 2: Named Queues ---\n   148→\n   149→  getQueues(): string[] {\n   150→    const queues = new Set<string>();\n   151→    for (const task of this.tasks.values()) {\n   152→      queues.add(task.queue);\n   153→    }\n   154→    return Array.from(queues);\n   155→  }\n   156→\n   157→  // --- Phase 5: Complete/Fail ---\n   158→\n   159→  complete(taskId: str