@@ -0,0 +1,79 @@
+import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('should reject new tasks after shutdown', async () => {
+    await q.shutdown();
+    expect(() => q.add('data')).toThrow(/shutting down/);
+  });
+
+  it('should complete immediately if no tasks are processing', async () => {
+    const summary = await q.shutdown();
+    expect(summary.completed).toBe(0);
+    expect(summary.forceCancelled).toBe(0);
+    expect(summary.duration).toBeGreaterThanOrEqual(0);
+  });
+
+  it('should wait for processing tasks to complete', async () => {
+    const task = q.add('data');
+    q.next();
+
+    // Complete the task asynchronously
+    setTimeout(() => {
+      q.complete(task.id);
+    }, 50);
+
+    const summary = await q.shutdown({ timeout: 5000 });
+    expect(summary.completed).toBe(1);
+    expect(summary.forceCancelled).toBe(0);
+  });
+
+  it('should force-cancel tasks that exceed the timeout', async () => {
+    q.add('slow-task');
+    q.next();
+
+    // Don't complete the task — it will be force-cancelled
+    const summary = await q.shutdown({ timeout: 50 });
+    expect(summary.forceCancelled).toBe(1);
+  });
+
+  it('should run shutdown callbacks', async () => {
+    let called = false;
+    q.onShutdown(() => {
+      called = true;
+    });
+
+    await q.shutdown();
+    expect(called).toBe(true);
+  });
+
+  it('should return the same result for multiple shutdown calls', async () => {
+    const p1 = q.shutdown();
+    const p2 = q.shutdown();
+
+    const [r1, r2] = await Promise.all([p1, p2]);
+    expect(r1).toBe(r2);
+  });
+
+  it('should report duration in the summary', async () => {
+    const summary = await q.shutdown();
+    expect(typeof summary.duration).toBe('number');
+  });
+
+  it('should expose isShuttingDown flag', async () => {
+    expect(q.isShuttingDown).toBe(false);
+    const promise = q.shutdown();
+    expect(q.isShuttingDown).toBe(true);
+    await promise;
+  });
+});
