+    const task = q.add('data', { queue: 'emails' });
+    expect(task.queue).toBe('emails');
+  });
+
+  it('should use the default queue when no name is specified', () => {
+    const task = q.add('data');
+    expect(task.queue).toBe('default');
+  });
+
+  it('should keep named queues independent', () => {
+    q.add('email-task', { queue: 'emails' });
+    q.add('sms-task', { queue: 'sms' });
+
+    const emailTask = q.next('emails');
+    expect(emailTask?.payload).toBe('email-task');
+
+    const smsTask = q.next('sms');
+    expect(smsTask?.payload).toBe('sms-task');
+  });
+
+  it('should return null from empty or non-existent queue', () => {
+    expect(q.next('nonexistent')).toBeNull();
+  });
+
+  it('should list all queue names', () => {
+    q.add('a', { queue: 'q1' });
+    q.add('b', { queue: 'q2' });
+    q.add('c'); // default
+
+    const queues = q.getQueues();
+    expect(queues).toContain('q1');
+    expect(queues).toContain('q2');
+    expect(queues).toContain('default');
