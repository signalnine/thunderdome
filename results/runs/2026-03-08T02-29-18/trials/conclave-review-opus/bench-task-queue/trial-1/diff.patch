+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 7: Task Dependencies', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  it('should block a task until its dependencies complete', () => {
+    const dep = q.add('dep');
+    const task = q.add('main', { dependencies: [dep.id] });
+
+    // dep is pending, so only dep should be available
+    const next = q.next();
+    expect(next?.id).toBe(dep.id);
+
+    // task is blocked
+    expect(q.next()).toBeNull();
+
+    // Complete the dependency
+    q.complete(dep.id);
+
+    // Now task should be available
+    const nextTask = q.next();
+    expect(nextTask?.id).toBe(task.id);
+  });
+
+  it('should handle multiple dependencies', () => {
+    const dep1 = q.add('dep1');
+    const dep2 = q.add('dep2');
+    const task = q.add('main', { dependencies: [dep1.id, dep2.id] });
+
+    q.next(); // dep1
+    q.complete(dep1.id);
+
+    // Still blocked on dep2
+    const next = q.next();
+    expect(next?.id).toBe(dep2.id);
+    expect(q.next()).toBeNull();
+
+    q.complete(dep2.id);
+
+    // Now unblocked
+    const final = q.next();
+    expect(final?.id).toBe(task.id);
+  });
+
+  it('should throw when depending on a non-existent task', () => {
+    expect(() => q.add('data', { dependencies: ['nonexistent'] })).toThrow();
+  });
+
+  it('should leave dependents blocked when a dependency fails', () => {
+    const dep = q.add('dep', { maxRetries: 1 });
+    q.add('main', { dependencies: [dep.id] });
+
+    q.next();
+    q.fail(dep.id, 'error');
+
+    // main should remain blocked
+    expect(q.next()).toBeNull();
+  });
+
+  it('should allow inspecting dependency status', () => {
+    const dep1 = q.add('dep1');
+    const dep2 = q.add('dep2');
+    const task = q.add('main', { dependencies: [dep1.id, dep2.id] });
+
+    let status = q.getDependencyStatus(task.id);
+    expect(status?.total).toBe(2);
+    expect(status?.resolved).toHaveLength(0);
+    expect(status?.pending).toHaveLength(2);
+
+    q.next();
+    q.complete(dep1.id);
+
+    status = q.getDependencyStatus(task.id);
+    expect(status?.resolved).toContain(dep1.id);
+    expect(status?.pending).toContain(dep2.id);
+  });
+
+  it('should return null for dependency status of unknown task', () => {
+    expect(q.getDependencyStatus('unknown')).toBeNull();
+  });
+
+  it('should handle tasks with already-completed dependencies', () => {
+    const dep = q.add('dep');
+    q.next();
+    q.complete(dep.id);
+
+    const task = q.add('main', { dependencies: [dep.id] });
+
+    // Should be immediately available since dep is already completed
+    const next = q.next();
+    expect(next?.id).toBe(task.id);
+  });
+});
