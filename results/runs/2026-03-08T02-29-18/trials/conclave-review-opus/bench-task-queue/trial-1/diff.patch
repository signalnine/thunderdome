+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013wVEGA8GBtFgsdW9bLwvRU","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 6: Dead Letter Queue', () => {\n     5→  let q: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    q = new TaskQueue();\n     9→    vi.useFakeTimers();\n    10→  });\n    11→\n    12→  afterEach(() => {\n    13→    vi.useRealTimers();\n    14→  });\n    15→\n    16→  it('should move a task to DLQ after exhausting retries', () => {\n    17→    const task = q.add('data', { maxRetries: 1, backoffDelay: 100 });\n    18→\n    19→    q.next();\n    20→    q.fail(task.id, 'error 1');\n    21→    // maxRetries=1, attempt was 1, so it's exhausted\n    22→\n    23→    expect(task.status).toBe('failed');\n    24→    const dlq = q.getDeadLetterQueue();\n    25→    expect(dlq).toHaveLength(1);\n    26→    expect(dlq[0].task.id).toBe(task.id);\n    27→    expect(dlq[0].lastError).toBe('error 1');\n    28→    expect(dlq[0].failCount).toBe(1);\n    29→  });\n    30→\n    31→  it('should retain error info in DLQ entries', () => {\n    32→    const task = q.add('data', { maxRetries: 1, backoffDelay: 100 });\n    33→    q.next();\n    34→    q.fail(task.id, 'the error message');\n    35→\n    36→    const dlq = q.getDeadLetterQueue();\n    37→    expect(dlq[0].lastError).toBe('the error message');\n    38→    expect(dlq[0].failedAt).toBeInstanceOf(Date);\n    39→  });\n    40→\n    41→  it('should redrive a task from DLQ back to the queue', () => {\n    42→    const task = q.add('data', { maxRetries: 1, backoffDelay: 100 });\n    43→    q.next();\n    44→    q.fail(task.id, 'error');\n    45→\n    46→    expect(q.getDeadLetterQueue()).toHaveLength(1);\n    47→\n    48→    const redriven = q.redriveTask(task.id);\n    49→    expect(redriven).toBeDefined();\n    50→    expect(redriven!.status).toBe('pending');\n    51→    expect(redriven!.attempt).toBe(0);\n    52→\n    53→    expect(q.getDeadLetterQueue()).toHaveLength(0);\n    54→\n    55→    // Task should be available for processing again\n    56→    const next = q.next();\n    57→    expect(next?.id).toBe(task.id);\n    58→  });\n    59→\n    60→  it('should clear all DLQ entries for a queue', () => {\n    61→    const t1 = q.add('t1', { maxRetries: 1 });\n    62→    const t2 = q.add('t2', { maxRetries: 1 });\n    63→\n    64→    q.next();\n    65→    q.fail(t1.id, 'err');\n    66→    q.next();\n    67→    q.fail(t2.id, 'err');\n    68→\n    69→    expect(q.getDeadLetterQueue()).toHaveLength(2);\n    70→    q.clearDeadLetterQueue();\n    71→    expect(q.getDeadLetterQueue()).toHaveLength(0);\n    72→  });\n    73→\n    74→  it('should have independent DLQs per queue', () => {\n    75→    const t1 = q.add('t1', { queue: 'q1', maxRetries: 1 });\n    76→    const t2 = q.add('t2', { queue: 'q2', maxRetries: 1 });\n    77→\n    78→    q.next('q1');\n    79→    q.fail(t1.id, 'err');\n    80→    q.next('q2');\n    81→    q.fail(t2.id, 'err');\n    82→\n    83→    expect(q.getDeadLetterQueue('q1')).toHaveLength(1);\n    84→    expect(q.getDeadLetterQueue('q2')).toHaveLength(1);\n    85→\n    86→    q.clearDeadLetterQueue('q1');\n    87→    expect(q.getDeadLetterQueue('q1')).toHaveLength(0);\n    88→    expect(q.getDeadLetterQueue('q2')).toHaveLength(1);\n    89→  });\n    90→\n    91→  it('should return null when redriving non-existent task', () => {\n    92→    expect(q.redriveTask('nonexistent')).toBeNull();\n    93→  });\n    94→});\n    95→"}]},"parent_tool_use_id":"toolu_01X7HDmPZ9XYrwKCX7SoCxNT","session_id":"bbf996d8-eb78-4498-a67c-80ac6eebe0fd","uuid":"11d04cda-5a76-4da9-990b-f0d3ee01ed40"}
