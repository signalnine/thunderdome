areFn): void {\n    let stack = this.middlewareStacks.get(queueName);\n    if (!stack) {\n      stack = [];\n      this.middlewareStacks.set(queueName, stack);\n    }\n    stack.push(middleware);\n  }\n\n  registerHandler(queueName: string, handler: HandlerFn): void {\n    this.handlers.set(queueName, handler);\n  }\n\n  async process(queueName?: string): Promise<Task | null> {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const task = this.next(queue);\n    if (!task) return null;\n\n    const middlewares = this.middlewareStacks.get(queue) ?? [];\n    const handler = this.handlers.get(queue);\n\n    try {\n      await this.runMiddlewareChain(task, middlewares, 0, handler);\n      if (task.status === 'processing') {\n        this.complete(task.id);\n      }\n    } catch (err) {\n      if (task.status === 'processing') {\n        this.fail(task.id, err instanceof Error ? err.message : String(err));\n      }\n    }\n\n    return task;\n  }\n\n  private async runMiddlewareChain(\n    task: Task,\n    middlewares: MiddlewareFn[],\n    index: number,\n    handler?: HandlerFn\n  ): Promise<void> {\n    if (index < middlewares.length) {\n      let nextCalled = false;\n      await middlewares[index](task, async () => {\n        nextCalled = true;\n        await this.runMiddlewareChain(task, middlewares, index + 1, handler);\n      });\n      if (!nextCalled) {\n        // Middleware didn't call next — skip processing\n        return;\n      }\n    } else if (handler) {\n      await handler(task);\n    }\n  }\n\n  // --- Phase 12: Graceful Shutdown ---\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  async shutdown(options: ShutdownOptions = {}): Promise<ShutdownSummary> {\n    if (this.shutdownState.promise) {\n      return this.shutdownState.promise;\n    }\n\n    this.shutdownState.initiated = true;\n    this.shutdownState.promise = this.doShutdown(options);\n    return this.shutdownState.promise;\n  }\n\n  private async doShutdown(options: ShutdownOptions): Promise<ShutdownSummary> {\n    const startTime = Date.now();\n    const timeout = options.timeout ?? 30000;\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Wait for processing tasks\n    let completed = 0;\n    let forceCancelled = 0;\n\n    const processingTasks = Array.from(this.tasks.values()).filter(\n      (t) => t.status === 'processing'\n    );\n\n    if (processingTasks.length > 0) {\n      const deadline = Date.now() + timeout;\n\n      // Poll until all processing tasks finish or timeout\n      await new Promise<void>((resolve) => {\n        const check = () => {\n          const stillProcessing = processingTasks.filter((t) => t.status === 'processing');\n          if (stillProcessing.length === 0 || Date.now() >= deadline) {\n            resolve();\n            return;\n          }\n          setTimeout(check, 10);\n        };\n        check();\n      });\n    }\n\n    // Count completed and force-cancel remaining\n    for (const task of processingTasks) {\n      if (task.status === 'processing') {\n        task.status = 'cancelled';\n        forceCancelled++;\n      } else if (task.status === 'completed') {\n        completed++;\n      }\n    }\n\n    const duration = Date.now() - startTime;\n\n    return { completed, forceCancelled, duration };\n  }\n}\n\n// Helper to validate cron expression synchronously\nfunction await_validate(expression: string): { shouldRun: boolean } {\n  // Just parse to validate; parseCron will throw if invalid\n  const { parseCron } = require('./cron.js');\n  parseCron(expression);\n  return { shouldRun: false };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":727,"cache_read_input_tokens":25675,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":727},"output_tokens":1,"service_tier":"standard