+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EUiF6KFbeRvZ2ajtXGoDqH","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 7: Task Dependencies', () => {\n     5→  let q: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    q = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should block a task until its dependencies complete', () => {\n    12→    const dep = q.add('dep');\n    13→    const task = q.add('main', { dependencies: [dep.id] });\n    14→\n    15→    // dep is pending, so only dep should be available\n    16→    const next = q.next();\n    17→    expect(next?.id).toBe(dep.id);\n    18→\n    19→    // task is blocked\n    20→    expect(q.next()).toBeNull();\n    21→\n    22→    // Complete the dependency\n    23→    q.complete(dep.id);\n    24→\n    25→    // Now task should be available\n    26→    const nextTask = q.next();\n    27→    expect(nextTask?.id).toBe(task.id);\n    28→  });\n    29→\n    30→  it('should handle multiple dependencies', () => {\n    31→    const dep1 = q.add('dep1');\n    32→    const dep2 = q.add('dep2');\n    33→    const task = q.add('main', { dependencies: [dep1.id, dep2.id] });\n    34→\n    35→    q.next(); // dep1\n    36→    q.complete(dep1.id);\n    37→\n    38→    // Still blocked on dep2\n    39→    const next = q.next();\n    40→    expect(next?.id).toBe(dep2.id);\n    41→    expect(q.next()).toBeNull();\n    42→\n    43→    q.complete(dep2.id);\n    44→\n    45→    // Now unblocked\n    46→    const final = q.next();\n    47→    expect(final?.id).toBe(task.id);\n    48→  });\n    49→\n    50→  it('should throw when depending on a non-existent task', () => {\n    51→    expect(() => q.add('data', { dependencies: ['nonexistent'] })).toThrow();\n    52→  });\n    53→\n    54→  it('should leave dependents blocked when a dependency fails', () => {\n    55→    const dep = q.add('dep', { maxRetries: 1 });\n    56→    q.add('main', { dependencies: [dep.id] });\n    57→\n    58→    q.next();\n    59→    q.fail(dep.id, 'error');\n    60→\n    61→    // main should remain blocked\n    62→    expect(q.next()).toBeNull();\n    63→  });\n    64→\n    65→  it('should allow inspecting dependency status', () => {\n    66→    const dep1 = q.add('dep1');\n    67→    const dep2 = q.add('dep2');\n    68→    const task = q.add('main', { dependencies: [dep1.id, dep2.id] });\n    69→\n    70→    let status = q.getDependencyStatus(task.id);\n    71→    expect(status?.total).toBe(2);\n    72→    expect(status?.resolved).toHaveLength(0);\n    73→    expect(status?.pending).toHaveLength(2);\n    74→\n    75→    q.next();\n    76→    q.complete(dep1.id);\n    77→\n    78→    status = q.getDependencyStatus(task.id);\n    79→    expect(status?.resolved).toContain(dep1.id);\n    80→    expect(status?.pending).toContain(dep2.id);\n    81→  });\n    82→\n    83→  it('should return null for dependency status of unknown task', () => {\n    84→    expect(q.getDependencyStatus('unknown')).toBeNull();\n    85→  });\n    86→\n    87→  it('should handle tasks with already-completed dependencies', () => {\n    88→    const dep = q.add('dep');\n    89→    q.next();\n    90→    q.complete(dep.id);\n    91→\n    92→    const task = q.add('main', { dependencies: [dep.id] });\n    93→\n    94→    // Should be immediately available since dep is already completed\n    95→    const next = q.next();\n    96→    expect(next?.id).toBe(task.id);\n    97→  });\n    98→});\n    99→"}]},"parent_tool_use_id":"toolu_01X7HDmPZ9XYrwKCX7SoCxNT","session_id":"bbf996d8-eb78-4498-a67c-80ac6eebe0fd","uuid":"9db98b7f-53db-4fff-82cc-ca648273a64c"}
