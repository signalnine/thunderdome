+export function parseCron(expression: string): { minute: number | null; hour: number | null; interval: number | null } {
+  const parts = expression.trim().split(/\s+/);
+  if (parts.length !== 5) {
+    throw new Error(`Invalid cron expression: ${expression}`);
+  }
+
+  const [minutePart, hourPart] = parts;
+
+  // */N * * * * — every N minutes
+  const intervalMatch = minutePart.match(/^\*\/(\d+)$/);
+  if (intervalMatch) {
+    const n = parseInt(intervalMatch[1], 10);
+    if (n <= 0 || n > 59) {
+      throw new Error(`Invalid interval in cron expression: ${expression}`);
+    }
+    return { minute: null, hour: null, interval: n };
+  }
+
+  // 0 * * * * — every hour on the hour
+  if (minutePart === '0' && hourPart === '*') {
+    return { minute: 0, hour: null, interval: null };
+  }
+
+  // 0 0 * * * — every day at midnight
+  if (minutePart === '0' && hourPart === '0') {
+    return { minute: 0, hour: 0, interval: null };
+  }
+
+  throw new Error(`Unsupported cron expression: ${expression}`);
+}
+
+export function shouldRun(expression: string, now: Date, lastRun?: Date): boolean {
+  const parsed = parseCron(expression);
+
+  if (parsed.interval !== null) {
+    // Every N minutes
+    if (!lastRun) return true;
+    const elapsed = now.getTime() - lastRun.getTime();
+    return elapsed >= parsed.interval * 60 * 1000;
+  }
+
+  if (parsed.hour === null) {
+    // Every hour on the hour (minute === 0)
+    if (now.getMinutes() !== 0) return false;
+    if (!lastRun) return true;
+    // Don't run more than once per hour
+    return now.getTime() - lastRun.getTime() >= 60 * 60 * 1000;
+  }
+
+  // Every day at midnight (hour === 0, minute === 0)
+  if (now.getHours() !== 0 || now.getMinutes() !== 0) return false;
+  if (!lastRun) return true;
+  return now.getTime() - lastRun.getTime() >= 24 * 60 * 60 * 1000;
+}
