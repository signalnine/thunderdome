+import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 4: Delayed and Scheduled Tasks', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('should delay a task by milliseconds', () => {
+    q.add('delayed', { delay: 5000 });
+    expect(q.next()).toBeNull();
+
+    vi.advanceTimersByTime(5000);
+    expect(q.next()?.payload).toBe('delayed');
+  });
+
+  it('should schedule a task for a specific future time', () => {
+    const future = new Date(Date.now() + 10000);
+    q.add('scheduled', { processAt: future });
+    expect(q.next()).toBeNull();
+
+    vi.advanceTimersByTime(10000);
+    expect(q.next()?.payload).toBe('scheduled');
+  });
+
+  it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {
+    q.add('delayed', { delay: 5000 });
+    q.add('immediate');
+
+    expect(q.next()?.payload).toBe('immediate');
+    expect(q.next()).toBeNull();
+  });
+
+  it('should order by availability time when multiple delayed tasks are available', () => {
+    q.add('later', { delay: 3000 });
+    q.add('sooner', { delay: 1000 });
+
+    vi.advanceTimersByTime(3000);
+    expect(q.next()?.payload).toBe('sooner');
+    expect(q.next()?.payload).toBe('later');
+  });
+
+  it('should show availableAt on the task object', () => {
+    const task = q.add('data', { delay: 5000 });
+    expect(task.availableAt).toBeInstanceOf(Date);
+    expect(task.availableAt.getTime()).toBeGreaterThan(task.createdAt.getTime());
+  });
+
+  it('should work with named queues', () => {
+    q.add('delayed-q1', { queue: 'q1', delay: 2000 });
+    q.add('immediate-q1', { queue: 'q1' });
+
+    expect(q.next('q1')?.payload).toBe('immediate-q1');
+    expect(q.next('q1')).toBeNull();
+
+    vi.advanceTimersByTime(2000);
+    expect(q.next('q1')?.payload).toBe('delayed-q1');
+  });
+
+  it('should respect priority among available delayed tasks', () => {
+    q.add('low-priority', { delay: 1000, priority: 10 });
+    q.add('high-priority', { delay: 1000, priority: 1 });
+
+    vi.advanceTimersByTime(1000);
+    expect(q.next()?.payload).toBe('high-priority');
+    expect(q.next()?.payload).toBe('low-priority');
+  });
+});
