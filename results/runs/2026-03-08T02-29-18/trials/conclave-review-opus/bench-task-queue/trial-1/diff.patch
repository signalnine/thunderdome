finish or timeout\n    // Re-check the full task list each iteration to catch any tasks\n    // that transitioned to processing after shutdown was initiated\n    const getProcessingTasks = () =>\n      Array.from(this.tasks.values()).filter((t) => t.status === 'processing');\n\n    let processingTasks = getProcessingTasks();\n    if (processingTasks.length > 0) {\n      await new Promise<void>((resolve) => {\n        const check = () => {\n          processingTasks = getProcessingTasks();\n          if (processingTasks.length === 0 || Date.now() >= deadline) {\n            resolve();\n            return;\n          }\n          setTimeout(check, 10);\n        };\n        check();\n      });\n    }\n\n    // Force-cancel any still-processing tasks\n    let completed = 0;\n    let forceCancelled = 0;\n    processingTasks = getProcessingTasks();\n\n    for (const task of processingTasks) {\n      task.status = 'cancelled';\n      forceCancelled++;\n    }\n\n    // Count tasks that completed during the shutdown window\n    for (const task of this.tasks.values()) {\n      if (task.status === 'completed') {\n        completed++;\n      }\n    }\n\n    const duration = Date.now() - startTime;\n\n    return { completed, forceCancelled, duration };\n  }\n}\n","structuredPatch":[{"oldStart":539,"oldLines":18,"newStart":539,"newLines":22,"lines":[" ","     const deadline = Date.now() + timeout;"," ","-    // Poll until all processing tasks finish or timeout","-    // Re-check the full task list each iteration to catch any tasks","-    // that transitioned to processing after shutdown was initiated","-    const getProcessingTasks = () =>","-      Array.from(this.tasks.values()).filter((t) => t.status === 'processing');","+    // Track tasks that were processing at shutdown start","+    const initiallyProcessing = new Set(","+      Array.from(this.tasks.values())","+        .filter((t) => t.status === 'processing')","+        .map((t) => t.id)","+    );"," ","-    let processing