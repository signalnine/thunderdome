@@ -0,0 +1,94 @@
+import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+    vi.useFakeTimers();
+  });
+
+  afterEach(() => {
+    vi.useRealTimers();
+  });
+
+  it('should move a task to DLQ after exhausting retries', () => {
+    const task = q.add('data', { maxRetries: 1, backoffDelay: 100 });
+
+    q.next();
+    q.fail(task.id, 'error 1');
+    // maxRetries=1, attempt was 1, so it's exhausted
+
+    expect(task.status).toBe('failed');
+    const dlq = q.getDeadLetterQueue();
+    expect(dlq).toHaveLength(1);
+    expect(dlq[0].task.id).toBe(task.id);
+    expect(dlq[0].lastError).toBe('error 1');
+    expect(dlq[0].failCount).toBe(1);
+  });
+
+  it('should retain error info in DLQ entries', () => {
+    const task = q.add('data', { maxRetries: 1, backoffDelay: 100 });
+    q.next();
+    q.fail(task.id, 'the error message');
+
+    const dlq = q.getDeadLetterQueue();
+    expect(dlq[0].lastError).toBe('the error message');
+    expect(dlq[0].failedAt).toBeInstanceOf(Date);
+  });
+
+  it('should redrive a task from DLQ back to the queue', () => {
+    const task = q.add('data', { maxRetries: 1, backoffDelay: 100 });
+    q.next();
+    q.fail(task.id, 'error');
+
+    expect(q.getDeadLetterQueue()).toHaveLength(1);
+
+    const redriven = q.redriveTask(task.id);
+    expect(redriven).toBeDefined();
+    expect(redriven!.status).toBe('pending');
+    expect(redriven!.attempt).toBe(0);
+
+    expect(q.getDeadLetterQueue()).toHaveLength(0);
+
+    // Task should be available for processing again
+    const next = q.next();
+    expect(next?.id).toBe(task.id);
+  });
+
+  it('should clear all DLQ entries for a queue', () => {
+    const t1 = q.add('t1', { maxRetries: 1 });
+    const t2 = q.add('t2', { maxRetries: 1 });
+
+    q.next();
+    q.fail(t1.id, 'err');
+    q.next();
+    q.fail(t2.id, 'err');
+
+    expect(q.getDeadLetterQueue()).toHaveLength(2);
+    q.clearDeadLetterQueue();
+    expect(q.getDeadLetterQueue()).toHaveLength(0);
+  });
+
+  it('should have independent DLQs per queue', () => {
+    const t1 = q.add('t1', { queue: 'q1', maxRetries: 1 });
+    const t2 = q.add('t2', { queue: 'q2', maxRetries: 1 });
+
+    q.next('q1');
+    q.fail(t1.id, 'err');
+    q.next('q2');
+    q.fail(t2.id, 'err');
+
+    expect(q.getDeadLetterQueue('q1')).toHaveLength(1);
+    expect(q.getDeadLetterQueue('q2')).toHaveLength(1);
+
+    q.clearDeadLetterQueue('q1');
+    expect(q.getDeadLetterQueue('q1')).toHaveLength(0);
+    expect(q.getDeadLetterQueue('q2')).toHaveLength(1);
+  });
+
+  it('should return null when redriving non-existent task', () => {
+    expect(q.redriveTask('nonexistent')).toBeNull();
+  });
+});
