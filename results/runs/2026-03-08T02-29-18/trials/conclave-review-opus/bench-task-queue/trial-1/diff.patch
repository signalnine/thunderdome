.next();\n    expect(next?.id).toBe(task.id);\n  });\n\n  it('should clear all DLQ entries for a queue', () => {\n    const t1 = q.add('t1', { maxRetries: 1 });\n    const t2 = q.add('t2', { maxRetries: 1 });\n\n    q.next();\n    q.fail(t1.id, 'err');\n    q.next();\n    q.fail(t2.id, 'err');\n\n    expect(q.getDeadLetterQueue()).toHaveLength(2);\n    q.clearDeadLetterQueue();\n    expect(q.getDeadLetterQueue()).toHaveLength(0);\n  });\n\n  it('should have independent DLQs per queue', () => {\n    const t1 = q.add('t1', { queue: 'q1', maxRetries: 1 });\n    const t2 = q.add('t2', { queue: 'q2', maxRetries: 1 });\n\n    q.next('q1');\n    q.fail(t1.id, 'err');\n    q.next('q2');\n    q.fail(t2.id, 'err');\n\n    expect(q.getDeadLetterQueue('q1')).toHaveLength(1);\n    expect(q.getDeadLetterQueue('q2')).toHaveLength(1);\n\n    q.clearDeadLetterQueue('q1');\n    expect(q.getDeadLetterQueue('q1')).toHaveLength(0);\n    expect(q.getDeadLetterQueue('q2')).toHaveLength(1);\n  });\n\n  it('should return null when redriving non-existent task', () => {\n    expect(q.redriveTask('nonexistent')).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1193,"cache_read_input_tokens":49029,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1193},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"bbf996d8-eb78-4498-a67c-80ac6eebe0fd","uuid":"2f2637cd-962c-4c2b-bc53-ae3950743048"}
