nriched: true };\n    57→      await next();\n    58→    });\n    59→\n    60→    let received: unknown = null;\n    61→    q.registerHandler('default', async (task) => {\n    62→      received = (task as Record<string, unknown>).metadata;\n    63→    });\n    64→\n    65→    q.add('data');\n    66→    await q.process();\n    67→\n    68→    expect(received).toEqual({ enriched: true });\n    69→  });\n    70→\n    71→  it('should mark task as failed if middleware throws', async () => {\n    72→    q.use('default', async () => {\n    73→      throw new Error('middleware error');\n    74→    });\n    75→\n    76→    const task = q.add('data', { maxRetries: 0 });\n    77→    await q.process();\n    78→\n    79→    expect(task.status).toBe('failed');\n    80→    expect(task.error).toBe('middleware error');\n    81→  });\n    82→\n    83→  it('should mark task as failed if handler throws', async () => {\n    84→    q.registerHandler('default', async () => {\n    85→      throw new Error('handler error');\n    86→    });\n    87→\n    88→    const task = q.add('data', { maxRetries: 0 });\n    89→    await q.process();\n    90→\n    91→    expect(task.status).toBe('failed');\n    92→    expect(task.error).toBe('handler error');\n    93→  });\n    94→\n    95→  it('should complete task after successful processing', async () => {\n    96→    q.registerHandler('default', async () => {\n    97→      // successful processing\n    98→    });\n    99→\n   100→    const task = q.add('data');\n   101→    await q.process();\n   102→\n   103→    expect(task.status).toBe('completed');\n   104→  });\n   105→\n   106→  it('should return null when no tasks are available', async () => {\n   107→    const result = await q.process();\n   108→    expect(result).toBeNull();\n   109→  });\n   110→\n   111→  it('should have independent middleware per queue', async () => {\n   112→    const q1Order: string[] = [];\n   113→    const q2Order: string[] = [];\n   114→\n   115→    q.use('q1', async (