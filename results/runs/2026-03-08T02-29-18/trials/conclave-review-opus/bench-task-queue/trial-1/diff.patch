-import { describe, it, expect, beforeEach } from 'vitest';
-import { TaskQueue } from '../src/index.js';
-
-describe('Phase 2: Named Queues', () => {
-  let queue: TaskQueue;
-
-  beforeEach(() => {
-    queue = new TaskQueue();
