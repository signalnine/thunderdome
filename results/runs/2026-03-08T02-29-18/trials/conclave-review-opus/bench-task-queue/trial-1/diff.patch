etConcurrency('default')).toBe(5);\n    expect(q.getActiveCount('default')).toBe(0);\n\n    q.add('t1');\n    q.next();\n    expect(q.getActiveCount('default')).toBe(1);\n  });\n\n  it('should respect priority within concurrency limits', () => {\n    q.setConcurrency('default', 1);\n\n    q.add('low', { priority: 10 });\n    q.add('high', { priority: 1 });\n\n    const first = q.next();\n    expect(first?.payload).toBe('high');\n  });\n\n  it('should apply concurrency per queue', () => {\n    q.setConcurrency('q1', 1);\n    q.setConcurrency('q2', 1);\n\n    q.add('q1-t1', { queue: 'q1' });\n    q.add('q1-t2', { queue: 'q1' });\n    q.add('q2-t1', { queue: 'q2' });\n\n    expect(q.next('q1')).toBeDefined();\n    expect(q.next('q1')).toBeNull(); // at limit\n\n    // q2 is independent\n    expect(q.next('q2')).toBeDefined();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":996,"cache_read_input_tokens":51412,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":996},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"bbf996d8-eb78-4498-a67c-80ac6eebe0fd","uuid":"74d38668-3de1-4442-8c92-cd59d40887f9"}
