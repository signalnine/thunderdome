+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014b9btr71o6oA9kq4G8mF6x","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 1: Basic FIFO Queue', () => {\n     5→  let q: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    q = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should add a task and return a task object', () => {\n    12→    const task = q.add({ message: 'hello' });\n    13→    expect(task).toBeDefined();\n    14→    expect(task.id).toBeDefined();\n    15→    expect(task.payload).toEqual({ message: 'hello' });\n    16→    expect(task.status).toBe('pending');\n    17→    expect(task.createdAt).toBeInstanceOf(Date);\n    18→  });\n    19→\n    20→  it('should generate unique IDs for each task', () => {\n    21→    const t1 = q.add('task1');\n    22→    const t2 = q.add('task2');\n    23→    expect(t1.id).not.toBe(t2.id);\n    24→  });\n    25→\n    26→  it('should retrieve tasks in FIFO order', () => {\n    27→    q.add('first');\n    28→    q.add('second');\n    29→    q.add('third');\n    30→\n    31→    const t1 = q.next();\n    32→    expect(t1?.payload).toBe('first');\n    33→\n    34→    const t2 = q.next();\n    35→    expect(t2?.payload).toBe('second');\n    36→\n    37→    const t3 = q.next();\n    38→    expect(t3?.payload).toBe('third');\n    39→  });\n    40→\n    41→  it('should transition task to processing state on next()', () => {\n    42→    q.add('task');\n    43→    const task = q.next();\n    44→    expect(task?.status).toBe('processing');\n    45→  });\n    46→\n    47→  it('should return null when no tasks are available', () => {\n    48→    expect(q.next()).toBeNull();\n    49→  });\n    50→\n    51→  it('should not return already processing tasks', () => {\n    52→    q.add('only-one');\n    53→    q.next();\n    54→    expect(q.next()).toBeNull();\n    55→  }