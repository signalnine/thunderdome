+    q.add('a', { queue: 'q1' });
+    q.add('b', { queue: 'q1' });
+    q.add('c', { queue: 'q2' });
+
+    expect(q.size('q1')).toBe(2);
+    expect(q.size('q2')).toBe(1);
+    expect(q.size()).toBe(0); // default queue is empty
+  });
+
+  it('should not mix tasks between queues on next()', () => {
+    q.add('q1-task', { queue: 'q1' });
+    expect(q.next('q2')).toBeNull();
+    expect(q.next('q1')?.payload).toBe('q1-task');
+  });
+});
