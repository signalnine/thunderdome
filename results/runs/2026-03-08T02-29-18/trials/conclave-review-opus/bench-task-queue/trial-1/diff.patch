etry', () => {\n    const task = q.add('data', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 100 });\n    q.next('myq');\n    q.fail(task.id, 'err');\n\n    expect(task.queue).toBe('myq');\n    expect(task.priority).toBe(2);\n  });\n\n  it('should track attempt count', () => {\n    const task = q.add('data', { maxRetries: 2, backoffDelay: 100 });\n\n    q.next();\n    expect(task.attempt).toBe(1);\n\n    q.fail(task.id, 'err');\n    vi.advanceTimersByTime(100);\n\n    q.next();\n    expect(task.attempt).toBe(2);\n  });\n\n  it('should default to 3 max retries', () => {\n    const task = q.add('data');\n    expect(task.maxRetries).toBe(3);\n  });\n\n  it('should default to 1000ms backoff delay', () => {\n    const task = q.add('data');\n    expect(task.backoffDelay).toBe(1000);\n  });\n\n  it('should store the error message', () => {\n    const task = q.add('data');\n    q.next();\n    q.fail(task.id, 'Something went wrong');\n    expect(task.error).toBe('Something went wrong');\n  });\n\n  it('should throw when completing a non-processing task', () => {\n    const task = q.add('data');\n    expect(() => q.complete(task.id)).toThrow();\n  });\n\n  it('should throw when failing a non-processing task', () => {\n    const task = q.add('data');\n    expect(() => q.fail(task.id)).toThrow();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":915,"cache_read_input_tokens":48114,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":915},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"bbf996d8-eb78-4498-a67c-80ac6eebe0fd","uuid":"aa263237-b432-403b-888a-139283bbf2fc"}
