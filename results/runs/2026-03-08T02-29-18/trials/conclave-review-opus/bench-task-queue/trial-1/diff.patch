+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016WiCQygxgYcnWnuXMDDTbH","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, vi } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 9: Progress Tracking and Cancellation', () => {\n     5→  let q: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    q = new TaskQueue();\n     9→  });\n    10→\n    11→  describe('Progress', () => {\n    12→    it('should report progress on a processing task', () => {\n    13→      const task = q.add('data');\n    14→      q.next();\n    15→\n    16→      q.reportProgress(task.id, 50, 'halfway');\n    17→      expect(task.progress).toBe(50);\n    18→      expect(task.progressMessage).toBe('halfway');\n    19→    });\n    20→\n    21→    it('should validate progress range', () => {\n    22→      const task = q.add('data');\n    23→      q.next();\n    24→\n    25→      expect(() => q.reportProgress(task.id, -1)).toThrow();\n    26→      expect(() => q.reportProgress(task.id, 101)).toThrow();\n    27→    });\n    28→\n    29→    it('should not allow progress on non-processing tasks', () => {\n    30→      const task = q.add('data');\n    31→      expect(() => q.reportProgress(task.id, 50)).toThrow();\n    32→    });\n    33→\n    34→    it('should support progress subscriptions', () => {\n    35→      const task = q.add('data');\n    36→      q.next();\n    37→\n    38→      const updates: Array<{ progress: number; message?: string }> = [];\n    39→      q.onProgress(task.id, (progress, message) => {\n    40→        updates.push({ progress, message });\n    41→      });\n    42→\n    43→      q.reportProgress(task.id, 25, 'quarter');\n    44→      q.reportProgress(task.id, 75, 'three quarters');\n    45→\n    46→      expect(updates).toHaveLength(2);\n    47→      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n    48→      expect(updates[1]).toEqual({ progress: 75, message: 'three quarters' });\n    49→    });\n    50→\n    51→    it('should support unsubscribing from progress', () => {\n    52→      const task = q.add('data');\n    53→      q.next();\n    54→\n    55→      const updates: number[] = [];\n    56→      const unsub = q.onProgress(task.id, (progress) => {\n    57→        updates.push(progress);\n    58→      });\n    59→\n    60→      q.reportProgress(task.id, 25);\n    61→      unsub();\n    62→      q.reportProgress(task.id, 50);\n    63→\n    64→      expect(updates).toHaveLength(1);\n    65→      expect(updates[0]).toBe(25);\n    66→    });\n    67→\n    68→    it('should set progress to 100 on completion', () => {\n    69→      const task = q.add('data');\n    70→      q.next();\n    71→      q.complete(task.id);\n    72→      expect(task.progress).toBe(100);\n    73→    });\n    74→  });\n    75→\n    76→  describe('Cancellation', () => {\n    77→    it('should cancel a pending task', () => {\n    78→      const task = q.add('data');\n    79→      const result = q.cancel(task.id);\n    80→\n    81→      expect(result).toBe(true);\n    82→      expect(task.status).toBe('cancelled');\n    83→      expect(q.next()).toBeNull();\n    84→    });\n    85→\n    86→    it('should cancel a processing task', () => {\n    87→      const task = q.add('data');\n    88→      q.next();\n    89→      const result = q.cancel(task.id);\n    90→\n    91→      expect(result).toBe(true);\n    92→      expect(task.status).toBe('cancelled');\n    93→    });\n    94→\n    95→    it('should not cancel a completed task', () => {\n    96→      const task = q.add('data');\n    97→      q.next();\n    98→      q.complete(task.id);\n    99→\n   100→      expect(q.cancel(task.id)).toBe(false);\n   101→    });\n   102→\n   103→    it('should not retry a cancelled task', () => {\n   104→      vi.useFakeTimers();\n   105→      const task = q.add('data', { maxRetries: 3, backoffDelay: 100 });\n   106→      q.next();\n   107→\n   108→