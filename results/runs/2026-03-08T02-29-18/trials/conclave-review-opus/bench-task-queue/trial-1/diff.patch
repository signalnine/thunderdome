 still validate.\n    const depSet = new Set(dependencies);\n    for (const depId of dependencies) {\n      const visited = new Set<string>();\n      const stack = [depId];\n      while (stack.length > 0) {\n        const current = stack.pop()!;\n        if (visited.has(current)) continue;\n        visited.add(current);\n        const task = this.tasks.get(current);\n        if (task) {\n          for (const transitiveDep of task.dependencies) {\n            if (depSet.has(transitiveDep) && transitiveDep !== depId) {\n              // This is fine — one dep depends on another dep. Not a cycle.\n            }\n            stack.push(transitiveDep);\n          }\n        }\n      }\n    }\n    // With our \"deps must exist at creation\" constraint, cycles are\n    // structurally impossible. This validation ensures the invariant holds.\n  }\n\n  private areDependenciesMet(task: Task): boolean {\n    if (task.dependencies.length === 0) return true;\n    for (const depId of task.dependencies) {\n      if (!task.resolvedDependencies.has(depId)) return false;\n    }\n    return true;\n  }\n\n  private resolveDependents(completedTaskId: string): void {\n    for (const task of this.tasks.values()) {\n      if (task.dependencies.includes(completedTaskId)) {\n        task.resolvedDependencies.add(completedTaskId);\n      }\n    }\n  }\n\n  getDependencyStatus(taskId: string): { total: number; resolved: string[]; pending: string[] } | null {\n    const task = this.tasks.get(taskId);\n    if (!task) return null;\n    const resolved = Array.from(task.resolvedDependencies);\n    const pending = task.dependencies.filter((d) => !task.resolvedDependencies.has(d));\n    return { total: task.dependencies.length, resolved, pending };\n  }\n\n  // --- Phase 8: Concurrency Control ---\n\n  setConcurrency(queueName: string, limit: number): void {\n    if (limit < 1 || !Number.isInteger(limit)) {\n      throw new Error(`Invalid concurrency limit: ${limit}`);\n    }\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  getConcurrency(queueName?: string): number | undefined {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    return this.concurrencyLimits.get(queue);\n  }\n\n  getActiveCount(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queue && task.status === 'processing') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // --- Phase 9: Progress and Cancellation ---\n\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n    }\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress value: ${progress}. Must be between 0 and 100.`);\n    }\n    task.progress = progress;\n    task.progressMessage = message;\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  onProgress(taskId: string, callback: ProgressCallback): () => void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    let listeners = this.progressListeners.get(taskId);\n    if (!listeners) {\n      listeners = new Set();\n      this.progressListeners.set(taskId, listeners);\n    }\n    listeners.add(callback);\n\n    // Return unsubscribe function\n    return () => {\n      listeners!.delete(callback);\n      if (listeners!.size === 0) {\n        this.progressListeners.delete(taskId);\n      }\n    };\n  }\n\n  cancel(taskId: string): boolean {\n    const task = this.tasks.get(taskId);\n    if (!task) return false;\n    if (task.status !== 'pending' && task.status !== 'processing') return false;\n\n    task.status = 'cancelled';\n\n    // Clean up progress listeners\n    this.progressListeners.delete(taskId);\n\n    return true;\n  }\n\n  // --- Phase 10: Recurring Tasks ---\n\n  addSchedule(cronExpression: string, payload: unknown, options: ScheduleOptions = {}): Schedule {\n    if (this.shutdownState.initiated) {\n      throw new Error('Queue system is shutting down; cannot add schedules');\n    }\n\n    // Validate the cron expression\n    parseCron(cronExpression);\n\n    const schedule: Schedule = {\n      id: options.id ?? randomUUID(),\n      cronExpression,\n      payload,\n      queue: options.queue ?? DEFAULT_QUEUE,\n      priority: options.priority ?? 5,\n    };\n\n    this.schedules.set(schedule.id, schedule);\n    return schedule;\n  }\n\n  removeSchedule(scheduleId: string): boolean {\n    return this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): Schedule[] {\n    return Array.from(this.schedules.values());\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const created: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (shouldRun(schedule.cronExpression, currentTime, schedule.lastRun)) {\n        const task = this.add(schedule.payload, {\n          queue: schedule.queue,\n          priority: schedule.priority,\n        });\n        schedule.lastRun = currentTime;\n        created.push(task);\n      }\n    }\n\n    return created;\n  }\n\n  // --- Phase 11: Middleware ---\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    let stack = this.middlewareStacks.get(queueName);\n    if (!stack) {\n      stack = [];\n      this.middlewareStacks.set(queueName, stack);\n    }\n    stack.push(middleware);\n  }\n\n  registerHandler(queueName: string, handler: HandlerFn): void {\n    this.handlers.set(queueName, handler);\n  }\n\n  async process(queueName?: string): Promise<Task | null> {\n    const queue = queueName ?? DEF