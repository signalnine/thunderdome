d of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      const taskId = randomUUID(); // pre-generate to use in detection\n      this.detectCircularDeps(taskId, dependencies);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n\n    if (options.processAt) {\n      availableAt = options.processAt;\n    } else if (options.delay && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      queue,\n      priority,\n      createdAt: now,\n      availableAt,\n      attempt: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoffDelay: options.backoffDelay ?? 1000,\n      progress: 0,\n      dependencies: [...dependencies],\n      resolvedDependencies: new Set<string>(),\n    };\n\n    // Check resolved dependencies on creation\n    for (const depId of task.dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (depTask && depTask.status === 'completed') {\n        task.resolvedDependencies.add(depId);\n      }\n    }\n\n    this.tasks.set(task.id, task as Task);\n    return task;\n  }\n\n  get(taskId: string): Task | null {\n    return this.tasks.get(taskId) ?? null;\n  }\n\n  next(queueName?: string): Task | null {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const now = new Date();\n\n    // Check concurrency limit\n    const limit = this.concurrencyLimits.get(queue);\n    if (limit !== undefined) {\n      const activeCount = this.getActiveCount(queue);\n      if (activeCount >= limit) {\n        return null;\n      }\n    }\n\n    // Find eligible tasks: pending, in this queue, available (time), unblocked (deps)\n    const candidates: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.queue !== queue) continue;\n      if (task.status !== 'pending') continue;\n      if (task.availableAt > now) continue;\n      if (!this.areDependenciesMet(task)) continue;\n      candidates.push(task);\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Sort: priority (ascending = higher priority first), then availableAt, then createdAt\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n        return a.availableAt.getTime() - b.availableAt.getTime();\n      }\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const chosen = candidates[0];\n    chosen.status = 'processing';\n    chosen.attempt += 1;\n    return chosen;\n  }\n\n  size(queueName?: string): number {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queue && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // --- Phase 2: Named Queues ---\n\n  getQueues(): string[] {\n    const queues = new Set<string>();\n    for (const task of this.tasks.values()) {\n      queues.add(task.queue);\n    }\n    return Array.from(queues);\n  }\n\n  // --- Phase 5: Complete/Fail ---\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Unblock dependents\n    this.resolveDependents(taskId);\n  }\n\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error;\n\n    if (task.attempt < task.maxRetries) {\n      // Re-queue with backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempt - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n    } else {\n      // Exhausted retries — move to DLQ\n      task.status = 'failed';\n      this.addToDeadLetterQueue(task, error);\n    }\n  }\n\n  // --- Phase 6: Dead Letter Queue ---\n\n  private addToDeadLetterQueue(task: Task, error?: string): void {\n    const dlq = this.deadLetterQueues.get(task.queue) ?? [];\n    dlq.push({\n      task,\n      failedAt: new Date(),\n      failCount: task.attempt,\n      lastError: error,\n    });\n    this.deadLetterQueues.set(task.queue, dlq);\n  }\n\n  getDeadLetterQueue(queueName?: string): DeadLetterEntry[] {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    return [...(this.deadLetterQueues.get(queue) ?? [])];\n  }\n\n  redriveTask(taskId: string): Task | null {\n    for (const [queueName, dlq] of this.deadLetterQueues.entries()) {\n      const index = dlq.findIndex((e) => e.task.id === taskId);\n      if (index !== -1) {\n        const entry = dlq.splice(index, 1)[0];\n        const task = entry.task;\n        task.status = 'pending';\n        task.attempt = 0;\n        task.progress = 0;\n        task.error = undefined;\n        task.availableAt = new Date();\n        this.deadLetterQueues.set(queueName, dlq);\n        return task;\n      }\n    }\n    return null;\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const queue = queueName ?? DEFAULT_QUEUE;\n    const dlq = this.deadLetterQueues.get(queue);\n    if (dlq) {\n      // Remove tasks from main store too\n      for (const entry of dlq) {\n        this.tasks.delete(entry.task.id);\n      }\n      this.deadLetterQueues.set(queue, []);\n    }\n  }\n\n  // --- Phase 7: Task Dependencies ---\n\n  private areDependenciesMet(task: Task): boolean {\n    if (task.dependencies.length === 0) return true;\n    for (const depId of task.dependencies) {\n      if (!task.resolvedDependencies.has(depId)) return false;\n    }\n    return true;\n  }\n\n  private resolveDependents(completedTaskId: string): void {\n    for (const task of this.tasks.values()) {\n      if (task.dependencies.includes(completedTaskId)) {\n        task.resolvedDependencies.add(completedTaskId);\n      }\n    }\n  }\n\n  private detectCircularDeps(newTaskId: string, dependencies: string[]): void {\n    // BFS/DFS: check if any dependency (transitively) already depends on tasks\n    // that would create a cycle back to newTaskId. Since newTaskId doesn't exist yet,\n    // we check if any of the deps transitively depend on each other in a way\n    // that would form a loop. Actually, since the new task doesn't exist yet,\n    // we can't have a cycle unless one of our dependencies (transitively) depends\n    // on us — but we don't exist yet. So circular deps would only happen if\n    // the dependencies themselves form a cycle... but those are existing tasks.\n    // Actually the real concern is: if task A depends on B, and we try to add\n    // B depending on A -> cycle. So we need to check: do any of our dependencies\n    // (transitively through their *dependents*) lead back to us?\n    // Since we don't exist yet, this can only happen if called in a chain.\n    // Let's just verify none of the dependency tasks are (transitively) waiting on\n    // something that would create a cycle. The key scenario:\n    // - Task A exists (pending, depends on nothing)\n    // - Task B is added with dep on A\n    // - Task C is added with dep on B\n    // - Task D is added with dep on C AND A tries to depend on D -> cycle\n    // But since D doesn't exist yet and A already exists, there's no issue.\n    // The real circular case: A depends on B, now try to add B depending on A.\n    // So we check: for each dep, walk its dep chain; if we find any dep that\n    // is also in our dependencies, that's a potential cycle.\n    // Actually simplest: check if any of our deps (transitively) depend on\n    // any other of our deps, or more accurately, if there's any path from\n    // a dependency back to any other dependency in the chain.\n    //\n    // The real check: we want to ensure that no existing task that depends on\n    // what will become `newTaskId` is in the transitive dependency chain of newTaskId.\n    // But newTaskId doesn't exist yet, so nothing depends on it yet.\n    // Circular dependencies primarily matter when: A -> B -> C -> A.\n    // At task C creation time, C depends on B, B depends on A. Then if someone\n    // tries to make A depend on C, that's the cycle. So when adding A with dep on C:\n    // Walk C's deps: C->B->A. If A is what we're adding... but A doesn't exist yet.\n    //\n    // The simplest practical approach: just validate the existing dependency graph\n    // doesn't have cycles. Since we're adding edges FROM newTask TO dependencies,\n    // we need to check if any of the dependencies (transitively) would reach\n    // tasks that already depend on this new task. But nothing depends on newTask yet\n    // since it doesn't exist. So the only case where this matters is if\n    // dependencies themselves form a cycle among themselves, which shouldn't happen\n    // if previous additions were validated.\n    //\n    // For now, the important case: if task A exists, and task B depends on A,\n    // then adding a task with ID of A depending on B would be a cycle.\n    // But we can't add a task with an existing ID. So we're fine?\n    //\n    // Wait — re-reading the requirement: \"Circular dependencies (direct or indirect)\n    // must be detected and rejected at task-creation time.\" This means if task A\n    // exists with deps on B (which doesn't exist yet), and then B is created with\n    // deps on A, that's a cycle. But the requirement also says \"Depending on a\n    // non-existent