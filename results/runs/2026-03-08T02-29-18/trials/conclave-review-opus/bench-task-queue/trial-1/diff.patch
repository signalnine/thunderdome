+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PQNjkmX9FfzagV1W8Tr6Ep","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 8: Concurrency Control', () => {\n     5→  let q: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    q = new TaskQueue();\n     9→  });\n    10→\n    11→  it('should limit concurrent processing tasks', () => {\n    12→    q.setConcurrency('default', 2);\n    13→\n    14→    q.add('t1');\n    15→    q.add('t2');\n    16→    q.add('t3');\n    17→\n    18→    const t1 = q.next();\n    19→    const t2 = q.next();\n    20→    expect(t1).toBeDefined();\n    21→    expect(t2).toBeDefined();\n    22→\n    23→    // Third should be null — at limit\n    24→    expect(q.next()).toBeNull();\n    25→  });\n    26→\n    27→  it('should free slot on task completion', () => {\n    28→    q.setConcurrency('default', 1);\n    29→\n    30→    q.add('t1');\n    31→    q.add('t2');\n    32→\n    33→    const t1 = q.next();\n    34→    expect(t1).toBeDefined();\n    35→    expect(q.next()).toBeNull();\n    36→\n    37→    q.complete(t1!.id);\n    38→    const t2 = q.next();\n    39→    expect(t2).toBeDefined();\n    40→    expect(t2?.payload).toBe('t2');\n    41→  });\n    42→\n    43→  it('should free slot on task failure', () => {\n    44→    q.setConcurrency('default', 1);\n    45→\n    46→    q.add('t1', { maxRetries: 0 });\n    47→    q.add('t2');\n    48→\n    49→    const t1 = q.next();\n    50→    expect(t1).toBeDefined();\n    51→    expect(q.next()).toBeNull();\n    52→\n    53→    q.fail(t1!.id, 'err');\n    54→    const t2 = q.next();\n    55→    expect(t2?.payload).toBe('t2');\n    56→  });\n    57→\n    58→  it('should default to unlimited concurrency', () => {\n    59→    expect(q.getConcurrency('default')).toBeUndefined();\n    60→\n    61→    // Add and retrieve many tasks\n    62→    for (let i = 0; i < 100; i++) {\n    63→      q.add(`t${i}`);\n    64→    }\n    65→    for (let i = 0; i < 100; i++) {\n    66→      expect(q.next()).toBeDefined();\n    67→    }\n    68→  });\n    69→\n    70→  it('should query concurrency limit and active count', () => {\n    71→    q.setConcurrency('default', 5);\n    72→    expect(q.getConcurrency('default')).toBe(5);\n    73→    expect(q.getActiveCount('default')).toBe(0);\n    74→\n    75→    q.add('t1');\n    76→    q.next();\n    77→    expect(q.getActiveCount('default')).toBe(1);\n    78→  });\n    79→\n    80→  it('should respect priority within concurrency limits', () => {\n    81→    q.setConcurrency('default', 1);\n    82→\n    83→    q.add('low', { priority: 10 });\n    84→    q.add('high', { priority: 1 });\n    85→\n    86→    const first = q.next();\n    87→    expect(first?.payload).toBe('high');\n    88→  });\n    89→\n    90→  it('should apply concurrency per queue', () => {\n    91→    q.setConcurrency('q1', 1);\n    92→    q.setConcurrency('q2', 1);\n    93→\n    94→    q.add('q1-t1', { queue: 'q1' });\n    95→    q.add('q1-t2', { queue: 'q1' });\n    96→    q.add('q2-t1', { queue: 'q2' });\n    97→\n    98→    expect(q.next('q1')).toBeDefined();\n    99→    expect(q.next('q1')).toBeNull(); // at limit\n   100→\n   101→    // q2 is independent\n   102→    expect(q.next('q2')).toBeDefined();\n   103→  });\n   104→});\n   105→"}]},"parent_tool_use_id":"toolu_01X7HDmPZ9XYrwKCX7SoCxNT","session_id":"bbf996d8-eb78-4498-a67c-80ac6eebe0fd","uuid":"a1a5bb46-fe82-44f5-bdf5-1ad21365a1fe"}
