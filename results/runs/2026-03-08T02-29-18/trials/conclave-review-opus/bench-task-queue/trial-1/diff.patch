new file mode 100644
index 0000000..e703108
--- /dev/null
+++ b/tests/phase11-middleware.test.ts
@@ -0,0 +1,153 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  it('should run middleware in order before handler', async () => {
+    const order: string[] = [];
+
+    q.use('default', async (_task, next) => {
+      order.push('mw1-before');
+      await next();
+      order.push('mw1-after');
+    });
+
+    q.use('default', async (_task, next) => {
+      order.push('mw2-before');
+      await next();
+      order.push('mw2-after');
+    });
+
+    q.registerHandler('default', async () => {
+      order.push('handler');
+    });
+
+    q.add('data');
+    await q.process();
+
+    expect(order).toEqual(['mw1-before', 'mw2-before', 'handler', 'mw2-after', 'mw1-after']);
+  });
+
+  it('should skip processing if middleware does not call next', async () => {
+    const handlerCalled: boolean[] = [];
+
+    q.use('default', async () => {
+      // Don't call next — skip
+    });
+
+    q.registerHandler('default', async () => {
+      handlerCalled.push(true);
+    });
+
+    q.add('data');
+    const task = await q.process();
+
+    expect(task).toBeDefined();
+    expect(handlerCalled).toHaveLength(0);
+    // Task should NOT be auto-completed when middleware skips next()
+    expect(task?.status).toBe('processing');
+  });
+
+  it('should allow middleware to modify the task', async () => {
+    q.use('default', async (task, next) => {
+      (task as Record<string, unknown>).metadata = { enriched: true };
+      await next();
+    });
+
+    let received: unknown = null;
+    q.registerHandler('default', async (task) => {
+      received = (task as Record<string, unknown>).metadata;
+    });
+
+    q.add('data');
+    await q.process();
+
+    expect(received).toEqual({ enriched: true });
+  });
+
+  it('should mark task as failed if middleware throws', async () => {
+    q.use('default', async () => {
+      throw new Error('middleware error');
+    });
+
+    const task = q.add('data', { maxRetries: 0 });
+    await q.process();
+
+    expect(task.status).toBe('failed');
+    expect(task.error).toBe('middleware error');
+  });
+
+  it('should mark task as failed if handler throws', async () => {
+    q.registerHandler('default', async () => {
+      throw new Error('handler error');
+    });
+
+    const task = q.add('data', { maxRetries: 0 });
+    await q.process();
+
+    expect(task.status).toBe('failed');
+    expect(task.error).toBe('handler error');
+  });
+
+  it('should complete task after successful processing', async () => {
+    q.registerHandler('default', async () => {
+      // successful processing
+    });
+
+    const task = q.add('data');
+    await q.process();
+
+    expect(task.status).toBe('completed');
+  });
+
+  it('should return null when no tasks are available', async () => {
+    const result = await q.process();
+    expect(result).toBeNull();
+  });
+
+  it('should have independent middleware per queue', async () => {
+    const q1Order: string[] = [];
+    const q2Order: string[] = [];
+
+    q.use('q1', async (_task, next) => {
+      q1Order.push('q1-mw');
+      await next();
+    });
+
+    q.use('q2', async (_task, next) => {
+      q2Order.push('q2-mw');
+      await next();
+    });
+
+    q.registerHandler('q1', async () => { q1Order.push('q1-handler'); });
+    q.registerHandler('q2', async () => { q2Order.push('q2-handler'); });
+
+    q.add('data', { queue: 'q1' });
+    q.add('data', { queue: 'q2' });
+
+    await q.process('q1');
+    await q.process('q2');
+
+    expect(q1Order).toEqual(['q1-mw', 'q1-handler']);
+    expect(q2Order).toEqual(['q2-mw', 'q2-handler']);
+  });
+
+  it('should process without handler (middleware only)', async () => {
+    let called = false;
+    q.use('default', async (_task, next) => {
+      called = true;
+      await next();
+    });
+
+    q.add('data');
+    const task = await q.process();
+
+    expect(called).toBe(true);
+    expect(task?.status).toBe('completed');
+  });
+});
