+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JBbBiTXC6PPqvbpvUFz3ez","type":"tool_result","content":"     1→export function parseCron(expression: string): { minute: number | null; hour: number | null; interval: number | null } {\n     2→  const parts = expression.trim().split(/\\s+/);\n     3→  if (parts.length !== 5) {\n     4→    throw new Error(`Invalid cron expression: ${expression}`);\n     5→  }\n     6→\n     7→  const [minutePart, hourPart] = parts;\n     8→\n     9→  // */N * * * * — every N minutes\n    10→  const intervalMatch = minutePart.match(/^\\*\\/(\\d+)$/);\n    11→  if (intervalMatch) {\n    12→    const n = parseInt(intervalMatch[1], 10);\n    13→    if (n <= 0 || n > 59) {\n    14→      throw new Error(`Invalid interval in cron expression: ${expression}`);\n    15→    }\n    16→    return { minute: null, hour: null, interval: n };\n    17→  }\n    18→\n    19→  // 0 * * * * — every hour on the hour\n    20→  if (minutePart === '0' && hourPart === '*') {\n    21→    return { minute: 0, hour: null, interval: null };\n    22→  }\n    23→\n    24→  // 0 0 * * * — every day at midnight\n    25→  if (minutePart === '0' && hourPart === '0') {\n    26→    return { minute: 0, hour: 0, interval: null };\n    27→  }\n    28→\n    29→  throw new Error(`Unsupported cron expression: ${expression}`);\n    30→}\n    31→\n    32→export function shouldRun(expression: string, now: Date, lastRun?: Date): boolean {\n    33→  const parsed = parseCron(expression);\n    34→\n    35→  if (parsed.interval !== null) {\n    36→    // Every N minutes\n    37→    if (!lastRun) return true;\n    38→    const elapsed = now.getTime() - lastRun.getTime();\n    39→    return elapsed >= parsed.interval * 60 * 1000;\n    40→  }\n    41→\n    42→  if (parsed.hour === null) {\n    43→    // Every hour on the hour (minute === 0)\n    44→    if (now.getMinutes() !== 0) return false;\n    45→    if (!lastRun) return true;\n    46→    // Don't run more than once per hour\n    47→    return now.getTime() - lastRun.getTime() >= 60 * 60 * 1000;\n    48→  }\n    49→\n    50→  // Every day at midnight (hour === 0, minute === 0)\n    51→  if (now.getHours() !== 0 || now.getMinutes() !== 0) return false;\n    52→  if (!lastRun) return true;\n    53→  return now.getTime() - lastRun.getTime() >= 24 * 60 * 60 * 1000;\n    54→}\n    55→"}]},"parent_tool_use_id":"toolu_01X7HDmPZ9XYrwKCX7SoCxNT","session_id":"bbf996d8-eb78-4498-a67c-80ac6eebe0fd","uuid":"d39c51e2-6f76-486a-93e4-eb0200baf157"}
