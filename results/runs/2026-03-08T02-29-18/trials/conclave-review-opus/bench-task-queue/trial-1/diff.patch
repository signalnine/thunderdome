+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018xrEFD2zQjtNRAHjADDsr9","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 5: Retry with Backoff', () => {\n     5→  let q: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    q = new TaskQueue();\n     9→    vi.useFakeTimers();\n    10→  });\n    11→\n    12→  afterEach(() => {\n    13→    vi.useRealTimers();\n    14→  });\n    15→\n    16→  it('should complete a task', () => {\n    17→    const task = q.add('data');\n    18→    q.next();\n    19→    q.complete(task.id);\n    20→    expect(task.status).toBe('completed');\n    21→  });\n    22→\n    23→  it('should fail a task and retry it', () => {\n    24→    const task = q.add('data', { maxRetries: 3, backoffDelay: 1000 });\n    25→    q.next(); // attempt 1\n    26→    q.fail(task.id, 'error');\n    27→\n    28→    expect(task.status).toBe('pending');\n    29→    expect(task.attempt).toBe(1);\n    30→\n    31→    // Should not be available yet (1000ms backoff)\n    32→    expect(q.next()).toBeNull();\n    33→\n    34→    vi.advanceTimersByTime(1000);\n    35→    const retried = q.next();\n    36→    expect(retried?.id).toBe(task.id);\n    37→    expect(retried?.attempt).toBe(2);\n    38→  });\n    39→\n    40→  it('should use exponential backoff', () => {\n    41→    const task = q.add('data', { maxRetries: 3, backoffDelay: 1000 });\n    42→\n    43→    // Attempt 1\n    44→    q.next();\n    45→    q.fail(task.id, 'err');\n    46→    // backoff: 1000 * 2^0 = 1000ms\n    47→\n    48→    vi.advanceTimersByTime(999);\n    49→    expect(q.next()).toBeNull();\n    50→    vi.advanceTimersByTime(1);\n    51→    q.next(); // attempt 2\n    52→\n    53→    q.fail(task.id, 'err');\n    54→    // backoff: 1000 * 2^1 = 2000ms\n    55→\n    56→    vi.advanceTimersByTime(1999);\n    57→    expect(q.next()).toBeNull();\n    58→    vi.advanceTimersByTime(1);\n    59→    q.next(); // attempt 3\n    60→\n    61→    q.fail(task.id, 'err');\n    62→    // All retries exhausted\n    63→    expect(task.status).toBe('failed');\n    64→  });\n    65→\n    66→  it('should keep original queue and priority on retry', () => {\n    67→    const task = q.add('data', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 100 });\n    68→    q.next('myq');\n    69→    q.fail(task.id, 'err');\n    70→\n    71→    expect(task.queue).toBe('myq');\n    72→    expect(task.priority).toBe(2);\n    73→  });\n    74→\n    75→  it('should track attempt count', () => {\n    76→    const task = q.add('data', { maxRetries: 2, backoffDelay: 100 });\n    77→\n    78→    q.next();\n    79→    expect(task.attempt).toBe(1);\n    80→\n    81→    q.fail(task.id, 'err');\n    82→    vi.advanceTimersByTime(100);\n    83→\n    84→    q.next();\n    85→    expect(task.attempt).toBe(2);\n    86→  });\n    87→\n    88→  it('should default to 3 max retries', () => {\n    89→    const task = q.add('data');\n    90→    expect(task.maxRetries).toBe(3);\n    91→  });\n    92→\n    93→  it('should default to 1000ms backoff delay', () => {\n    94→    const task = q.add('data');\n    95→    expect(task.backoffDelay).toBe(1000);\n    96→  });\n    97→\n    98→  it('should store the error message', () => {\n    99→    const task = q.add('data');\n   100→    q.next();\n   101→    q.fail(task.id, 'Something went wrong');\n   102→    expect(task.error).toBe('Something went wrong');\n   103→  });\n   104→\n   105→  it('should throw when completing a non-processing task', () => {\n   106→    const task = q.add('data');\n   107→    expect(() => q.complete(task.id)).toThrow();\n   108→  });\n   109→\n   110→  it('should throw when failing a non-processing task', () => {\n   111→    const task = q.add('data');\n   112→    expect(() => q.fail(task.id)).toThrow();\n   113→  });\n   114→});\n   115→"}]},"parent_tool_