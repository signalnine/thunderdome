+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  it('should limit concurrent processing tasks', () => {
+    q.setConcurrency('default', 2);
+
+    q.add('t1');
+    q.add('t2');
+    q.add('t3');
+
+    const t1 = q.next();
+    const t2 = q.next();
+    expect(t1).toBeDefined();
+    expect(t2).toBeDefined();
+
+    // Third should be null — at limit
+    expect(q.next()).toBeNull();
+  });
+
+  it('should free slot on task completion', () => {
+    q.setConcurrency('default', 1);
+
+    q.add('t1');
+    q.add('t2');
+
+    const t1 = q.next();
+    expect(t1).toBeDefined();
+    expect(q.next()).toBeNull();
+
+    q.complete(t1!.id);
+    const t2 = q.next();
+    expect(t2).toBeDefined();
+    expect(t2?.payload).toBe('t2');
+  });
+
+  it('should free slot on task failure', () => {
+    q.setConcurrency('default', 1);
+
+    q.add('t1', { maxRetries: 0 });
+    q.add('t2');
+
+    const t1 = q.next();
+    expect(t1).toBeDefined();
+    expect(q.next()).toBeNull();
+
+    q.fail(t1!.id, 'err');
+    const t2 = q.next();
+    expect(t2?.payload).toBe('t2');
+  });
+
+  it('should default to unlimited concurrency', () => {
+    expect(q.getConcurrency('default')).toBeUndefined();
+
+    // Add and retrieve many tasks
+    for (let i = 0; i < 100; i++) {
+      q.add(`t${i}`);
+    }
+    for (let i = 0; i < 100; i++) {
+      expect(q.next()).toBeDefined();
+    }
+  });
+
+  it('should query concurrency limit and active count', () => {
+    q.setConcurrency('default', 5);
+    expect(q.getConcurrency('default')).toBe(5);
+    expect(q.getActiveCount('default')).toBe(0);
+
+    q.add('t1');
+    q.next();
+    expect(q.getActiveCount('default')).toBe(1);
+  });
+
+  it('should respect priority within concurrency limits', () => {
+    q.setConcurrency('default', 1);
+
+    q.add('low', { priority: 10 });
+    q.add('high', { priority: 1 });
+
+    const first = q.next();
+    expect(first?.payload).toBe('high');
+  });
+
+  it('should apply concurrency per queue', () => {
+    q.setConcurrency('q1', 1);
+    q.setConcurrency('q2', 1);
+
+    q.add('q1-t1', { queue: 'q1' });
+    q.add('q1-t2', { queue: 'q1' });
+    q.add('q2-t1', { queue: 'q2' });
+
+    expect(q.next('q1')).toBeDefined();
+    expect(q.next('q1')).toBeNull(); // at limit
+
+    // q2 is independent
+    expect(q.next('q2')).toBeDefined();
+  });
+});
