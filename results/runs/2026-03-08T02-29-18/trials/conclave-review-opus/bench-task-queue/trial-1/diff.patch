+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../src/index.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let q: TaskQueue;
+
+  beforeEach(() => {
+    q = new TaskQueue();
+  });
+
+  it('should add a task and return a task object', () => {
+    const task = q.add({ message: 'hello' });
+    expect(task).toBeDefined();
+    expect(task.id).toBeDefined();
+    expect(task.payload).toEqual({ message: 'hello' });
+    expect(task.status).toBe('pending');
+    expect(task.createdAt).toBeInstanceOf(Date);
+  });
+
+  it('should generate unique IDs for each task', () => {
+    const t1 = q.add('task1');
+    const t2 = q.add('task2');
+    expect(t1.id).not.toBe(t2.id);
+  });
+
+  it('should retrieve tasks in FIFO order', () => {
+    q.add('first');
+    q.add('second');
+    q.add('third');
+
+    const t1 = q.next();
+    expect(t1?.payload).toBe('first');
+
+    const t2 = q.next();
+    expect(t2?.payload).toBe('second');
+
+    const t3 = q.next();
+    expect(t3?.payload).toBe('third');
+  });
+
+  it('should transition task to processing state on next()', () => {
+    q.add('task');
+    const task = q.next();
+    expect(task?.status).toBe('processing');
+  });
+
+  it('should return null when no tasks are available', () => {
+    expect(q.next()).toBeNull();
+  });
+
+  it('should not return already processing tasks', () => {
+    q.add('only-one');
+    q.next();
+    expect(q.next()).toBeNull();
+  });
+
+  it('should track the size of pending tasks', () => {
+    expect(q.size()).toBe(0);
+    q.add('a');
+    q.add('b');
+    expect(q.size()).toBe(2);
+    q.next();
+    expect(q.size()).toBe(1);
+  });
+
+  it('should get a task by ID', () => {
+    const added = q.add('data');
+    const found = q.get(added.id);
+    expect(found).toBe(added);
+  });
+
+  it('should return null for unknown task ID', () => {
+    expect(q.get('nonexistent')).toBeNull();
+  });
+});
