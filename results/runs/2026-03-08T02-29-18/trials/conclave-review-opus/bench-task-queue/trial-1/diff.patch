+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TfrRQ7ruRec148gRDk1vMh","type":"tool_result","content":"     1→import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';\n     2→import { TaskQueue } from '../src/index.js';\n     3→\n     4→describe('Phase 4: Delayed and Scheduled Tasks', () => {\n     5→  let q: TaskQueue;\n     6→\n     7→  beforeEach(() => {\n     8→    q = new TaskQueue();\n     9→    vi.useFakeTimers();\n    10→  });\n    11→\n    12→  afterEach(() => {\n    13→    vi.useRealTimers();\n    14→  });\n    15→\n    16→  it('should delay a task by milliseconds', () => {\n    17→    q.add('delayed', { delay: 5000 });\n    18→    expect(q.next()).toBeNull();\n    19→\n    20→    vi.advanceTimersByTime(5000);\n    21→    expect(q.next()?.payload).toBe('delayed');\n    22→  });\n    23→\n    24→  it('should schedule a task for a specific future time', () => {\n    25→    const future = new Date(Date.now() + 10000);\n    26→    q.add('scheduled', { processAt: future });\n    27→    expect(q.next()).toBeNull();\n    28→\n    29→    vi.advanceTimersByTime(10000);\n    30→    expect(q.next()?.payload).toBe('scheduled');\n    31→  });\n    32→\n    33→  it('should prefer non-delayed tasks over not-yet-available delayed tasks', () => {\n    34→    q.add('delayed', { delay: 5000 });\n    35→    q.add('immediate');\n    36→\n    37→    expect(q.next()?.payload).toBe('immediate');\n    38→    expect(q.next()).toBeNull();\n    39→  });\n    40→\n    41→  it('should order by availability time when multiple delayed tasks are available', () => {\n    42→    q.add('later', { delay: 3000 });\n    43→    q.add('sooner', { delay: 1000 });\n    44→\n    45→    vi.advanceTimersByTime(3000);\n    46→    expect(q.next()?.payload).toBe('sooner');\n    47→    expect(q.next()?.payload).toBe('later');\n    48→  });\n    49→\n    50→  it('should show availableAt on the task object', () => {\n    51→    const task = q.add('data', { delay: 5000 });\n    52→    expect(task.availableAt).toBeInstanceOf(Date);\n    53→    expect(task.availableAt.getTime()).toBeGreaterThan(task.createdAt.getTime());\n    54→  });\n    55→\n    56→  it('should work with named queues', () => {\n    57→    q.add('delayed-q1', { queue: 'q1', delay: 2000 });\n    58→    q.add('immediate-q1', { queue: 'q1' });\n    59→\n    60→    expect(q.next('q1')?.payload).toBe('immediate-q1');\n    61→    expect(q.next('q1')).toBeNull();\n    62→\n    63→    vi.advanceTimersByTime(2000);\n    64→    expect(q.next('q1')?.payload).toBe('delayed-q1');\n    65→  });\n    66→\n    67→  it('should respect priority among available delayed tasks', () => {\n    68→    q.add('low-priority', { delay: 1000, priority: 10 });\n    69→    q.add('high-priority', { delay: 1000, priority: 1 });\n    70→\n    71→    vi.advanceTimersByTime(1000);\n    72→    expect(q.next()?.payload).toBe('high-priority');\n    73→    expect(q.next()?.payload).toBe('low-priority');\n    74→  });\n    75→});\n    76→"}]},"parent_tool_use_id":"toolu_01X7HDmPZ9XYrwKCX7SoCxNT","session_id":"bbf996d8-eb78-4498-a67c-80ac6eebe0fd","uuid":"548ce9ea-5504-4bb5-9db4-ef2cd501c897"}
