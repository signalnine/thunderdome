 get a task by ID', () => {\n    const added = q.add('data');\n    const found = q.get(added.id);\n    expect(found).toBe(added);\n  });\n\n  it('should return null for unknown task ID', () => {\n    expect(q.get('nonexistent')).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":429,"cache_read_input_tokens":45372,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":429},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"bbf996d8-eb78-4498-a67c-80ac6eebe0fd","uuid":"1cd6713e-66d5-4319-9109-2aac72afea69"}
