          g.in1 !== xi &&\n          g.in2 !== xi &&\n          g.in1 !== yi &&\n          g.in2 !== yi\n      );\n      if (xorUsingCarry) {\n        // The other input should be partialSum but isn't — partialSum is swapped\n        const otherInput =\n          xorUsingCarry.in1 === carry\n            ? xorUsingCarry.in2\n            : xorUsingCarry.in1;\n        swap(partialSum, otherInput);\n        partialSum = otherInput;\n        xorWithCarry = xorUsingCarry;\n      } else {\n        // Try to find an XOR gate that uses partialSum\n        const xorUsingPartial = mutableGates.find(\n          (g) =>\n            g.op === 'XOR' &&\n            (g.in1 === partialSum || g.in2 === partialSum) &&\n            g.in1 !== xi &&\n            g.in2 !== xi &&\n            g.in1 !== yi &&\n            g.in2 !== yi\n        );\n        if (xorUsingPartial) {\n          const otherInput =\n            xorUsingPartial.in1 === partialSum\n              ? xorUsingPartial.in2\n              : xorUsingPartial.in1;\n          swap(carry, otherInput);\n          carry = otherInput;\n          xorWithCarry = xorUsingPartial;\n        } else {\n          continue;\n        }\n      }\n    }\n\n    // Check that the XOR with carry outputs to zi\n    if (xorWithCarry.out !== zi) {\n      swap(xorWithCarry.out, zi);\n    }\n\n    // Step 3: Find xi AND yi -> generate\n    const andXY = findGate(mutableGates, 'AND', xi, yi);\n    if (!andXY) continue;\n    const generate = andXY.out;\n\n    // Step 4: Find partialSum AND carry -> propagate\n    const andPC = findGate(mutableGates, 'AND', partialSum, carry);\n    if (!andPC) continue;\n    const propagate = andPC.out;\n\n    // Step 5: Find generate OR propagate -> carryOut\n    const orGate = findGate(mutableGates, 'OR', generate, propagate);\n    if (!orGate) {\n      // One of generate or propagate might be swapped\n      // Try finding an OR gate using generate\n      const orUsingGen = mutableGates.find(\n        (g) =>\n          