+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from './index.js';
+
+describe('simulate', () => {
+  it('should handle a single AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should handle a single OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+  });
+
+  it('should handle a single XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });
+  });
+
+  it('should handle chained gates in dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, c: 1, d: 0, e: 1,
+    });
+    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({
+      a: 0, b: 1, c: 0, d: 0, e: 0,
+    });
+  });
+
+  it('should handle gates listed out of order', () => {
+    // Gates listed in reverse dependency order
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, c: 1, d: 0, e: 1,
+    });
+  });
+
+  it('should simulate a correct 2-bit adder', () => {
+    // Build a 2-bit adder: x(1:0) + y(1:0) = z(2:0)
+    const gates: Gate[] = [
+      // Bit 0 half adder
+      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },
+      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },
+      // Bit 1 full adder
+      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },
+      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },
+      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },
+      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },
+      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },
+    ];
+
+    // 0 + 0 = 0
+    let result = simulate(gates, { x00: 0, x01: 0, y00: 0, y01: 0 });
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(0);
+    expect(result.z02).toBe(0);
+
+    // 1 + 1 = 2 (binary 10)
+    result = simulate(gates, { x00: 1, x01: 0, y00: 1, y01: 0 });
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(0);
+
+    // 3 + 3 = 6 (binary 110)
+    result = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });
+    expect(result.z00).toBe(0);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(1);
+
+    // 2 + 1 = 3 (binary 011)
+    result = simulate(gates, { x00: 0, x01: 1, y00: 1, y01: 0 });
+    expect(result.z00).toBe(1);
+    expect(result.z01).toBe(1);
+    expect(result.z02).toBe(0);
+  });
+});
+
+describe('findSwappedWires', () => {
+  function makeAdder(numBits: number): Gate[] {
+    const gates: Gate[] = [];
+    // Bit 0: half adder
+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+    for (let i = 1; i < numBits; i++) {
+      const pad = i.toString().padStart(2, '0');
+      const xi = `x${pad}`;
+      const yi = `y${pad}`;
+      const zi = `z${pad}`;
+      const ti = `t${pad}`;
+      const ai = `a${pad}`;
+      const bi = `b${pad}`;
+      const ci = `c${pad}`;
+      const prevC = `c${(i - 1).toString().padStart(2, '0')}`;
+
+      gates.push({ op: 'XOR', in1: xi, in2: yi, out: ti });
+      gates.push({ op: 'XOR', in1: ti, in2: prevC, out: zi });
+      gates.push({ op: 'AND', in1: xi, in2: yi, out: ai });
+      gates.push({ op: 'AND', in1: ti, in2: prevC, out: bi });
+      gates.push({ op: 'OR', in1: ai, in2: bi, out: ci });
+    }
+
+    // Final carry
+    const lastC = `c${(numBits - 1).toString().padStart(2, '0')}`;
+    const zFinal = `z${numBits.toString().padStart(2, '0')}`;
+    // The last carry IS the final output bit - no extra gate needed
+    // In a real circuit, the carry wire would be named zFinal
+    // We rename the last carry output to zFinal
+    const lastGate = gates.find((g) => g.out === lastC);
+    if (lastGate) {
+      lastGate.out = zFinal;
+    }
+
+    return gates;
+  }
+
+  function swapOutputs(gates: Gate[], wire1: string, wire2: string): void {
+    const g1 = gates.find((g) => g.out === wire1);
+    const g2 = gates.find((g) => g.out === wire2);
+    if (g1 && g2) {
+      g1.out = wire2;
+      g2.out = wire1;
+    }
+  }
+
+  it('should find 4 pairs of swapped wires in a small adder', () => {
+    const gates = makeAdder(8);
+
+    // Swap 4 pairs
+    swapOutputs(gates, 'z01', 'a01');
+    swapOutputs(gates, 't03', 'b05');
+    swapOutputs(gates, 'z06', 'c06');
+    swapOutputs(gates, 'a07', 'z08');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a01', 'a07', 'b05', 'c06', 't03', 'z01', 'z06', 'z08'].sort()
+    );
+  });
+
+  it('should find 4 pairs of swapped wires in a larger adder', () => {
+    const gates = makeAdder(20);
+
+    swapOutputs(gates, 'z02', 't02');
+    swapOutputs(gates, 'a10', 'z10');
+    swapOutputs(gates, 'z15', 'c14');
+    swapOutputs(gates, 't18', 'z18');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a10', 'c14', 't02', 't18', 'z02', 'z10', 'z15', 'z18'].sort()
+    );
+  });
+
+  it('should handle a 45-bit adder within time constraints', () => {
+    const gates = makeAdder(45);
+
+    swapOutputs(gates, 'z05', 'a05');
+    swapOutputs(gates, 'b15', 't15');
+    swapOutputs(gates, 'c25', 'z26');
+    swapOutputs(gates, 'z44', 'a44');
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).toEqual(
+      ['a05', 'a44', 'b15', 'c25', 't15', 'z05', 'z26', 'z44'].sort()
+    );
+  });
+
+  it('should handle swaps involving z00', () => {
+    const gates = makeAdder(8);
+
+    swapOutputs(gates, 'z00', 'a01');
+    swapOutputs(gates, 't03', 'b03');
+    swapOutputs(gates, 'z05', 'c05');
+    swapOutputs(gates, 'a07', 'z08');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a01', 'a07', 'b03', 'c05', 't03', 'z00', 'z05', 'z08'].sort()
+    );
+  });
+
+  it('should handle swaps involving the final carry bit', () => {
+    const gates = makeAdder(8);
+
+    swapOutputs(gates, 'z01', 'a01');
+    swapOutputs(gates, 't03', 'b05');
+    swapOutputs(gates, 'z06', 'a06');
+    swapOutputs(gates, 'b07', 'z08');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual(
+      ['a01', 'a06', 'b05', 'b07', 't03', 'z01', 'z06', 'z08'].sort()
+    );
+  });
+});
