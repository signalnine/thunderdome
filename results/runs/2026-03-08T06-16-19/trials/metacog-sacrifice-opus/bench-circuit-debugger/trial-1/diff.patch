 findSwappedWires(gates: Gate[]): string[] {\n  // Determine the number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2, g.out]) {\n      const m = w.match(/^[xy](\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n  const numBits = maxBit + 1;\n\n  const swapped: Set<string> = new Set();\n\n  // We'll work with a mutable copy so we can fix swaps as we find them\n  const mutableGates = gates.map((g) => ({ ...g }));\n\n  function swap(wire1: string, wire2: string): void {\n    swapped.add(wire1);\n    swapped.add(wire2);\n    // Fix the gates so subsequent analysis works on corrected circuit\n    for (const g of mutableGates) {\n      if (g.out === wire1) {\n        g.out = wire2;\n      } else if (g.out === wire2) {\n        g.out = wire1;\n      }\n    }\n  }\n\n  // For bit 0 (half adder):\n  // x00 XOR y00 -> z00\n  // x00 AND y00 -> carry0\n  const xorBit0 = findGate(mutableGates, 'XOR', 'x00', 'y00');\n  const andBit0 = findGate(mutableGates, 'AND', 'x00', 'y00');\n\n  if (!xorBit0 || !andBit0) {\n    return [];\n  }\n\n  // Check if bit 0 XOR outputs to z00\n  if (xorBit0.out !== 'z00') {\n    // z00 is swapped with whatever xorBit0 currently outputs\n    swap(xorBit0.out, 'z00');\n  }\n\n  let carry = andBit0.out;\n\n  // For each subsequent bit (full adder):\n  for (let i = 1; i < numBits; i++) {\n    const xi = `x${i.toString().padStart(2, '0')}`;\n    const yi = `y${i.toString().padStart(2, '0')}`;\n    const zi = `z${i.toString().padStart(2, '0')}`;\n\n    // Step 1: Find xi XOR yi -> partial_sum\n    const xorXY = findGate(mutableGates, 'XOR', xi, yi);\n    if (!xorXY) continue;\n\n    let partialSum = xorXY.out;\n\n    // Step 2: Find partialSum XOR carry -> zi\n    let xorWithCarry = findGate(mutableGates, 'XOR', partialSum, carry);\n\n    if (!xorWithCarry) {\n      // The partial sum or carry might be swapped.\n      // Try to find an XOR gate that uses carry\n      const xorUsingCarry = mutableGates.find(\n        (g) =>\n          g.op === 'XOR' &&\n          (g.in1 === carry || g.in2 === carry) &&\n          g.in1 !== xi &&\n          g.in2 !== xi &&\n          g.in1 !== yi &&\n          g.in2 !== yi\n      );\n      if (xorUsingCarry) {\n        // The other input should be partialSum but isn't — partialSum is swapped\n        const otherInput =\n          xorUsingCarry.in1 === carry\n            ? xorUsingCarry.in2\n            : xorUsingCarry.in1;\n        swap(partialSum, otherInput);\n        partialSum = otherInput;\n        xorWithCarry = xorUsingCarry;\n      } else {\n        // Try to find an XOR gate that uses partialSum\n        const xorUsingPartial = mutableGates.find(\n          (g) =>\n            g.op === 'XOR' &&\n            (g.in1 === partialSum || g.in2 === partialSum) &&\n            g.in1 !== xi &&\n            g.in2 !== xi &&\n            g.in1 !== yi &&\n            g.in2 !== yi\n        );\n        if (xorUsingPartial) {\n          const otherInput =\n            xorUsingPartial.in1 === partialSum\n              ? xorUsingPartial.in2\n              : xorUsingPartial.in1;\n          swap(carry, otherInput);\n          carry = otherInput;\n          xorWithCarry = xorUsingPartial;\n        } else {\n          continue;\n        }\n      }\n    }\n\n    // Check that the XOR with carry outputs to zi\n    if (xorWithCarry.out !== zi) {\n      swap(xorWithCarry.out, zi);\n    }\n\n    // Step 3: Find xi AND yi -> generate\n    const andXY = findGate(mutableGates, 'AND', xi, yi);\n    if (!andXY) continue;\n    const generate = andXY.out;\n\n    // Step 4: Find partialSum AND carry -> propagate\n    const andPC = findGate(mutableGates, 'AND', partialSum, carry);\n    if (!andPC) continue;\n    const propagate = andPC.out;\n\n    // Step 5: Find generate OR propagate -> carryOut\n    const orGate = findGate(mutableGates, 'OR', generate, propagate);\n    if (!orGate) {\n      // One of generate or propagate might be swapped\n      // Try finding an OR gate using generate\n      const orUsingGen = mutableGates.find(\n        (g) =>\n          g.op === 'OR' &&\n          (g.in1 === generate || g.in2 === generate)\n      );\n      if (orUsingGen) {\n        const otherInput =\n          orUsingGen.in1 === generate ? orUsingGen.in2 : orUsingGen.in1;\n        swap(propagate, otherInput);\n        carry = orUsingGen.out;\n      } else {\n        const orUsingProp = mutableGates.find(\n          (g) =>\n            g.op === 'OR' &&\n            (g.in1 === propagate || g.in2 === propagate)\n        );\n        if (orUsingProp) {\n          const otherInput =\n            orUsingProp.in1 === propagate\n              ? orUsingProp.in2\n              : orUsingProp.in1;\n          swap(generate, otherInput);\n          carry = orUsingProp.out;\n        } else {\n          continue;\n        }\n      }\n    } else {\n      carry = orGate.out;\n    }\n\n    // The carry for the last bit should be z{numBits}\n    // Check if the carry-out of the last stage is the final z output\n    if (i === numBits - 1) {\n      const zFinal = `z${(numBits).toString().padStart(2, '0')}`;\n      if (carry !== zFinal) {\n        swap(carry, zFinal);\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":55,"oldLines":10,"newStart":55,"newLines":6,"lines":["   );"," }"," ","-function findGateByOutput(gates: Gate[], out: string): Gate | undefined {","-  return gates.find((g) => g.out === out);","-}","-"," export function findSwappedWires(gates: Gate[]): string[] {","   // Determine the number of input bits","   let maxBit = 0;"]}],"userModified":false,"replaceAll":false}}
