+  formula: string | null; // non-null if it's a formula (starts with '=')
+  value: CellValue;
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // dependents: cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+  // dependencies: cell -> set of cells it depends on
+  private dependencies: Map<string, Set<string>> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = cell.toUpperCase();
+
+    if (typeof value === 'string' && value.startsWith('=')) {
+      const formulaStr = value.substring(1);
+      const deps = this.extractDependencies(formulaStr);
+
+      // Check for circular references before committing
+      this.checkCircular(ref, deps);
+
+      // Remove old dependency edges
+      this.removeDependencyEdges(ref);
+
+      // Store new dependencies
+      this.dependencies.set(ref, deps);
+      for (const dep of deps) {
+        if (!this.dependents.has(dep)) {
+          this.dependents.set(dep, new Set());
+        }
+        this.dependents.get(dep)!.add(ref);
+      }
+
+      const computed = this.evaluateFormula(formulaStr);
+      this.cells.set(ref, { raw: value, formula: formulaStr, value: computed });
+    } else {
+      // Remove old dependency edges
+      this.removeDependencyEdges(ref);
+      this.dependencies.delete(ref);
+
+      this.cells.set(ref, { raw: value, formula: null, value: value });
+    }
+
+    // Propagate changes to dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = cell.toUpperCase();
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.value;
+  }
+
+  getDisplay(cell: string): string {
+    const val = this.get(cell);
+    if (val === null) return '';
+    return String(val);
+  }
+
+  getCells(): Map<string, CellValue> {
+    const result = new Map<string, CellValue>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.value);
+    }
+    return result;
+  }
+
+  private removeDependencyEdges(ref: string): void {
+    const oldDeps = this.dependencies.get(ref);
+    if (oldDeps) {
+      for (const dep of oldDeps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+  }
+
+  private checkCircular(ref: string, deps: Set<string>): void {
+    // BFS/DFS from each dependency to see if we can reach ref
+    const visited = new Set<string>();
+    const stack = [...deps];
+    while (stack.length > 0) {
+      const current = stack.pop()!;
+      if (current === ref) {
+        throw new Error(`Circular reference detected involving ${ref}`);
+      }
+      if (visited.has(current)) continue;
+      visited.add(current);
+      const currentDeps = this.dependencies.get(current);
+      if (currentDeps) {
+        for (const d of currentDeps) {
+          stack.push(d);
+        }
+      }
+    }
+  }
+
+  private propagate(changed: string): void {
+    // Topological order of all transitive dependents
+    const order = this.getEvalOrder(changed);
+    for (const ref of order) {
+      const data = this.cells.get(ref);
+      if (data && data.formula !== null) {
+        data.value = this.evaluateFormula(data.formula);
+      }
+    }
+  }
+
+  private getEvalOrder(start: string): string[] {
+    // BFS to find all transitive dependents, then topological sort
+    const allDependents = new Set<string>();
+    const queue = [start];
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const deps = this.dependents.get(current);
+      if (deps) {
+        for (const d of deps) {
+          if (!allDependents.has(d)) {
+            allDependents.add(d);
+            queue.push(d);
+          }
+        }
+      }
+    }
+
+    // Topological sort using Kahn's algorithm within the subgraph
+    // In-degree only counts edges from OTHER nodes within allDependents
+    const inDegree = new Map<string, number>();
+    for (const node of allDependents) {
+      inDegree.set(node, 0);
+    }
+    for (const node of allDependents) {
+      const nodeDeps = this.dependencies.get(node);
+      if (nodeDeps) {
+        let count = 0;
+        for (const dep of nodeDeps) {
+          if (allDependents.has(dep)) {
+            count++;
+          }
+        }
+        inDegree.set(node, count);
+      }
+    }
+
+    const sorted: string[] = [];
+    const ready: string[] = [];
+    for (const [node, deg] of inDegree) {
+      if (deg === 0) ready.push(node);
+    }
+    while (ready.length > 0) {
+      const node = ready.shift()!;
+      sorted.push(node);
+      const nodeDependents = this.dependents.get(node);
+      if (nodeDependents) {
+        for (const dep of nodeDependents) {
+          if (allDependents.has(dep)) {
+            inDegree.set(dep, inDegree.get(dep)! - 1);
+            if (inDegree.get(dep) === 0) {
+              ready.push(dep);
+            }
+          }
+        }
+      }
+    }
+
+    return sorted;
+  }
+
+  // --- Formula Parsing & Evaluation ---
+
+  private extractDependencies(formula: string): Set<string> {
+    const deps = new Set<string>();
+    const rangePattern = /([A-Z]+\d+):([A-Z]+\d+)/gi;
+
+    // First expand ranges
+    let match: RegExpExecArray | null;
+    while ((match = rangePattern.exec(formula)) !== null) {
+      const cells = this.expandRange(match[1].toUpperCase(), match[2].toUpperCase());
+      for (const c of cells) {
+        deps.add(c);
+      }
+    }
+
+    // Then individual cell refs (not already in ranges)
+    const singlePattern = /[A-Z]+\d+/gi;
+    while ((match = singlePattern.exec(formula)) !== null) {
+      deps.add(match[0].toUpperCase());
+    }
+
+    return deps;
+  }
+
+  private expandRange(start: string, end: string): string[] {
+    const { col: startCol, row: startRow } = this.parseRef(start);
+    const { col: endCol, row: endRow } = this.parseRef(end);
+    const cells: string[] = [];
+    const minCol = Math.min(startCol, endCol);
+    const maxCol = Math.max(startCol, endCol);
+    const minRow = Math.min(startRow, endRow);
+    const maxRow = Math.max(startRow, endRow);
+    for (let c = minCol; c <= maxCol; c++) {
+      for (let r = minRow; r <= maxRow; r++) {
+        cells.push(this.colToLetters(c) + r);
+      }
+    }
+    return cells;
+  }
+
+  private parseRef(ref: string): { col: number; row: number } {
+    const match = ref.match(/^([A-Z]+)(\d+)$/);
+    if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+    return { col: this.lettersToCol(match[1]), row: parseInt(match[2], 10) };
+  }
+
+  private lettersToCol(letters: string): number {
+    let col = 0;
+    for (let i = 0; i < letters.length; i++) {
+      col = col * 26 + (letters.charCodeAt(i) - 64);
+    }
+    return col;
+  }
+
+  private colToLetters(col: number): string {
+    let result = '';
+    while (col > 0) {
+      const remainder = (col - 1) % 26;
+      result = String.fromCharCode(65 + remainder) + result;
+      col = Math.floor((col - 1) / 26);
+    }
+    return result;
+  }
+
+  private evaluateFormula(formula: string): CellValue {
+    const tokens = this.tokenize(formula);
+    const ctx = { tokens, pos: 0 };
+    const result = this.parseExpression(ctx);
+    return result;
+  }
+
+  // Tokenizer
+  private tokenize(formula: string): string[] {
+    const tokens: string[] = [];
+    let i = 0;
+    while (i < formula.length) {
+      // Skip whitespace
+      if (formula[i] === ' ' || formula[i] === '\t') {
+        i++;
+        continue;
+      }
+      // String literal
+      if (formula[i] === '"') {
+        let str = '';
+        i++; // skip opening quote
+        while (i < formula.length && formula[i] !== '"') {
+          str += formula[i];
+          i++;
+        }
+        i++; // skip closing quote
+        tokens.push(`"${str}"`);
+        continue;
+      }
+      // Number
+      if (/\d/.test(formula[i]) || (formula[i] === '.' && i + 1 < formula.length && /\d/.test(formula[i + 1]))) {
+        let num = '';
+        while (i < formula.length && (/\d/.test(formula[i]) || formula[i] === '.')) {
+          num += formula[i];
+          i++;
+        }
+        tokens.push(num);
+        continue;
+      }
+      // Cell ref or function name or boolean
+      if (/[A-Za-z]/.test(formula[i])) {
+        let word = '';
+        while (i < formula.length && /[A-Za-z0-9]/.test(formula[i])) {
+          word += formula[i];
+          i++;
+        }
+        tokens.push(word);
+        continue;
+      }
+      // Operators: >=, <=, <>, +, -, *, /, (, ), ,, :, =, <, >
+      if (formula[i] === '<' && i + 1 < formula.length && formula[i + 1] === '>') {
+        tokens.push('<>');
+        i += 2;
+        continue;
+      }
+      if (formula[i] === '<' && i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push('<=');
+        i += 2;
+        continue;
+      }
+      if (formula[i] === '>' && i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push('>=');
+        i += 2;
+        continue;
+      }
+      tokens.push(formula[i]);
+      i++;
+    }
+    return tokens;
+  }
+
+  // Recursive descent parser
+  private parseExpression(ctx: { tokens: string[]; pos: number }): CellValue {
+    return this.parseComparison(ctx);
+  }
+
+  private parseComparison(ctx: { tokens: string[]; pos: number }): CellValue {
+    let left = this.parseAddSub(ctx);
+    while (ctx.pos < ctx.tokens.length) {
+      const op = ctx.tokens[ctx.pos];
+      if (['>', '<', '>=', '<=', '=', '<>'].includes(op)) {
+        ctx.pos++;
+        const right = this.parseAddSub(ctx);
+        left = this.applyComparison(op, left, right);
+      } else {
+        break;
+      }
+    }
+    return left;
+  }
+
+  private applyComparison(op: string, left: CellValue, right: CellValue): boolean {
+    const l = typeof left === 'number' ? left : 0;
+    const r = typeof right === 'number' ? right : 0;
+    switch (op) {
+      case '>': return l > r;
+      case '<': return l < r;
+      case '>=': return l >= r;
+      case '<=': return l <= r;
+      case '=': return left === right;
+      case '<>': return left !== right;
+      default: return false;
+    }
+  }
+
+  private parseAddSub(ctx: { tokens: string[]; pos: number }): CellValue {
+    let left = this.parseMulDiv(ctx);
+    while (ctx.pos < ctx.tokens.length) {
+      const op = ctx.tokens[ctx.pos];
+      if (op === '+' || op === '-') {
+        ctx.pos++;
+        const right = this.parseMulDiv(ctx);
+        const l = typeof left === 'number' ? left : 0;
+        const r = typeof right === 'number' ? right : 0;
+        left = op === '+' ? l + r : l - r;
+      } else {
+        break;
+      }
+    }
+    return left;
+  }
+
+  private parseMulDiv(ctx: { tokens: string[]; pos: number }): CellValue {
+    let left = this.parseUnary(ctx);
+    while (ctx.pos < ctx.tokens.length) {
+      const op = ctx.tokens[ctx.pos];
+      if (op === '*' || op === '/') {
+        ctx.pos++;
+        const right = this.parseUnary(ctx);
+        const l = typeof left === 'number' ? left : 0;
+        const r = typeof right === 'number' ? right : 0;
+        left = op === '*' ? l * r : (r !== 0 ? l / r : 0);
+      } else {
+        break;
+      }
+    }
+    return left;
+  }
+
+  private parseUnary(ctx: { tokens: string[]; pos: number }): CellValue {
+    if (ctx.pos < ctx.tokens.length && ctx.tokens[ctx.pos] === '-') {
+      ctx.pos++;
+      const val = this.parsePrimary(ctx);
+      return typeof val === 'number' ? -val : 0;
+    }
+    if (ctx.pos < ctx.tokens.length && ctx.tokens[ctx.pos] === '+') {
+      ctx.pos++;
+      return this.parsePrimary(ctx);
+    }
+    return this.parsePrimary(ctx);
+  }
+
+  private parsePrimary(ctx: { tokens: string[]; pos: number }): CellValue {
+    if (ctx.pos >= ctx.tokens.length) return 0;
+
+    const token = ctx.tokens[ctx.pos];
+
+    // Parenthesized expression
+    if (token === '(') {
+      ctx.pos++;
+      const val = this.parseExpression(ctx);
+      if (ctx.pos < ctx.tokens.length && ctx.tokens[ctx.pos] === ')') {
+        ctx.pos++;
+      }
+      return val;
+    }
+
+    // String literal
+    if (token.startsWith('"') && token.endsWith('"')) {
+      ctx.pos++;
+      return token.slice(1, -1);
+    }
+
+    // Number
+    if (/^\d+(\.\d+)?$/.test(token)) {
+      ctx.pos++;
+      return parseFloat(token);
+    }
+
+    // Boolean
+    if (token.toUpperCase() === 'TRUE') {
+      ctx.pos++;
+      return true;
+    }
+    if (token.toUpperCase() === 'FALSE') {
+      ctx.pos++;
+      return false;
+    }
+
+    // Function call or cell reference
+    if (/^[A-Za-z]+\d*$/.test(token)) {
+      const upper = token.toUpperCase();
+      // Check if it's a function (next token is '(')
+      if (ctx.pos + 1 < ctx.tokens.length && ctx.tokens[ctx.pos + 1] === '(') {
+        return this.parseFunction(ctx);
+      }
+
+      // Cell reference
+      if (/^[A-Z]+\d+$/.test(upper)) {
+        ctx.pos++;
+        const cellData = this.cells.get(upper);
+        return cellData ? cellData.value : 0;
+      }
+
+      // Unknown identifier
+      ctx.pos++;
+      return 0;
+    }
+
+    // Skip unknown tokens
+    ctx.pos++;
+    return 0;
+  }
+
+  private parseFunction(ctx: { tokens: string[]; pos: number }): CellValue {
+    const funcName = ctx.tokens[ctx.pos].toUpperCase();
+    ctx.pos++; // skip function name
+    ctx.pos++; // skip '('
+
+    if (funcName === 'IF') {
+      return this.parseIfFunction(ctx);
+    }
+
+    // For aggregate functions, collect range values
+    const values = this.parseRangeArg(ctx);
+
+    if (ctx.pos < ctx.tokens.length && ctx.tokens[ctx.pos] === ')') {
+      ctx.pos++;
+    }
+
+    const nums = values.filter((v): v is number => typeof v === 'number');
+
+    switch (funcName) {
+      case 'SUM':
+        return nums.reduce((a, b) => a + b, 0);
+      case 'AVERAGE':
+        return nums.length > 0 ? nums.reduce((a, b) => a + b, 0) / nums.length : 0;
+      case 'MIN':
+        return nums.length > 0 ? Math.min(...nums) : 0;
+      case 'MAX':
+        return nums.length > 0 ? Math.max(...nums) : 0;
+      case 'COUNT':
+        return nums.length;
+      default:
+        return 0;
+    }
+  }
+
+  private parseIfFunction(ctx: { tokens: string[]; pos: number }): CellValue {
+    // Parse condition
+    const condition = this.parseExpression(ctx);
+
+    // Skip comma
+    if (ctx.pos < ctx.tokens.length && ctx.tokens[ctx.pos] === ',') {
+      ctx.pos++;
+    }
+
+    // Parse true value
+    const trueVal = this.parseExpression(ctx);
+
+    // Skip comma
+    if (ctx.pos < ctx.tokens.length && ctx.tokens[ctx.pos] === ',') {
+      ctx.pos++;
+    }
+
+    // Parse false value
+    const falseVal = this.parseExpression(ctx);
+
+    // Skip closing paren
+    if (ctx.pos < ctx.tokens.length && ctx.tokens[ctx.pos] === ')') {
+      ctx.pos++;
+    }
+
+    // Evaluate condition
+    const isTruthy = condition === true || (typeof condition === 'number' && condition !== 0) || (typeof condition === 'string' && condition !== '');
+
+    return isTruthy ? trueVal : falseVal;
+  }
+
+  private parseRangeArg(ctx: { tokens: string[]; pos: number }): CellValue[] {
+    // Check if this is a range expression: CELLREF : CELLREF
+    if (ctx.pos + 2 < ctx.tokens.length &&
+        /^[A-Z]+\d+$/i.test(ctx.tokens[ctx.pos]) &&
+        ctx.tokens[ctx.pos + 1] === ':' &&
+        /^[A-Z]+\d+$/i.test(ctx.tokens[ctx.pos + 2])) {
+      const startRef = ctx.tokens[ctx.pos].toUpperCase();
+      ctx.pos++; // skip start ref
+      ctx.pos++; // skip ':'
+      const endRef = ctx.tokens[ctx.pos].toUpperCase();
+      ctx.pos++; // skip end ref
+
+      const refs = this.expandRange(startRef, endRef);
+      return refs.map(ref => {
+        const data = this.cells.get(ref);
+        return data ? data.value : null;
+      });
+    }
+
+    // Single expression argument (or comma-separated)
+    const values: CellValue[] = [];
+    while (ctx.pos < ctx.tokens.length && ctx.tokens[ctx.pos] !== ')') {
+      values.push(this.parseExpression(ctx));
+      if (ctx.pos < ctx.tokens.length && ctx.tokens[ctx.pos] === ',') {
+        ctx.pos++;
+      }
+    }
+    return values;
+  }
+}
