egree.set(dep, inDegree.get(dep)! - 1);\n            if (inDegree.get(dep) === 0) {\n              ready.push(dep);\n            }\n          }\n        }\n      }\n    }\n\n    return sorted;\n  }\n\n  // --- Formula Parsing & Evaluation ---\n\n  private extractDependencies(formula: string): Set<string> {\n    const deps = new Set<string>();\n    const rangePattern = /([A-Z]+\\d+):([A-Z]+\\d+)/gi;\n\n    // First expand ranges\n    let match: RegExpExecArray | null;\n    const rangeRefs = new Set<string>();\n    while ((match = rangePattern.exec(formula)) !== null) {\n      const cells = this.expandRange(match[1].toUpperCase(), match[2].toUpperCase());\n      for (const c of cells) {\n        rangeRefs.add(c);\n        deps.add(c);\n      }\n    }\n\n    // Then individual cell refs (not already in ranges)\n    const singlePattern = /[A-Z]+\\d+/gi;\n    while ((match = singlePattern.exec(formula)) !== null) {\n      deps.add(match[0].toUpperCase());\n    }\n\n    return deps;\n  }\n\n  private expandRange(start: string, end: string): string[] {\n    const { col: startCol, row: startRow } = this.parseRef(start);\n    const { col: endCol, row: endRow } = this.parseRef(end);\n    const cells: string[] = [];\n    const minCol = Math.min(startCol, endCol);\n    const maxCol = Math.max(startCol, endCol);\n    const minRow = Math.min(startRow, endRow);\n    const maxRow = Math.max(startRow, endRow);\n    for (let c = minCol; c <= maxCol; c++) {\n      for (let r = minRow; r <= maxRow; r++) {\n        cells.push(this.colToLetters(c) + r);\n      }\n    }\n    return cells;\n  }\n\n  private parseRef(ref: string): { col: number; row: number } {\n    const match = ref.match(/^([A-Z]+)(\\d+)$/);\n    if (!match) throw new Error(`Invalid cell reference: ${ref}`);\n    return { col: this.lettersToCol(match[1]), row: parseInt(match[2], 10) };\n  }\n\n  private lettersToCol(letters: string): number {\n    let col = 0;\n    for (let i = 0; i < letters.length; i++) {\n      col = c