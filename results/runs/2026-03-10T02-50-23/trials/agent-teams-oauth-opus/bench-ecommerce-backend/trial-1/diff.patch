diff --git a/src/analytics/index.ts b/src/analytics/index.ts
new file mode 100644
index 0000000..1f54373
--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,120 @@
+import { EventBus } from '../bus.js';
+import {
+  Events,
+  PaymentStatus,
+  type AnalyticsService,
+  type CartUpdatedEvent,
+  type OrderCreatedEvent,
+  type PaymentProcessedEvent,
+} from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let totalRevenue = 0;
+  const uniqueCartIds = new Set<string>();
+  let orderCount = 0;
+  const productOrderQuantities = new Map<string, number>();
+
+  // cartId -> items snapshot, used to look up products when an order is created
+  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();
+
+  // orderId -> total, used to look up revenue when a payment succeeds
+  const orderTotals = new Map<string, number>();
+
+  function incrementEventCount(eventType: string): void {
+    eventCounts.set(eventType, (eventCounts.get(eventType) ?? 0) + 1);
+  }
+
+  // --- Event listeners ---
+
+  bus.on(Events.PRODUCT_CREATED, () => {
+    incrementEventCount(Events.PRODUCT_CREATED);
+  });
+
+  bus.on(Events.INVENTORY_UPDATED, () => {
+    incrementEventCount(Events.INVENTORY_UPDATED);
+  });
+
+  bus.on(Events.LOW_STOCK_ALERT, () => {
+    incrementEventCount(Events.LOW_STOCK_ALERT);
+  });
+
+  bus.on(Events.CART_UPDATED, (payload) => {
+    const event = payload as CartUpdatedEvent;
+    incrementEventCount(Events.CART_UPDATED);
+    uniqueCartIds.add(event.cartId);
+    cartItems.set(event.cartId, event.items);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload) => {
+    const event = payload as OrderCreatedEvent;
+    incrementEventCount(Events.ORDER_CREATED);
+    orderCount++;
+    orderTotals.set(event.orderId, event.total);
+
+    // Look up the cart items to track product order quantities
+    const items = cartItems.get(event.cartId);
+    if (items) {
+      for (const item of items) {
+        productOrderQuantities.set(
+          item.productId,
+          (productOrderQuantities.get(item.productId) ?? 0) + item.quantity,
+        );
+      }
+    }
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload) => {
+    const event = payload as PaymentProcessedEvent;
+    incrementEventCount(Events.PAYMENT_PROCESSED);
+
+    if (event.status === PaymentStatus.SUCCESS) {
+      const total = orderTotals.get(event.orderId);
+      if (total !== undefined) {
+        totalRevenue += total;
+      }
+    }
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, () => {
+    incrementEventCount(Events.ORDER_STATUS_CHANGED);
+  });
+
+  bus.on(Events.NOTIFICATION_SENT, () => {
+    incrementEventCount(Events.NOTIFICATION_SENT);
+  });
+
+  bus.on(Events.PRICE_CALCULATED, () => {
+    incrementEventCount(Events.PRICE_CALCULATED);
+  });
+
+  bus.on(Events.ANALYTICS_EVENT, () => {
+    incrementEventCount(Events.ANALYTICS_EVENT);
+  });
+
+  // --- Public API ---
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) ?? 0;
+    },
+
+    getRevenue(): number {
+      return totalRevenue;
+    },
+
+    getConversionRate(): number {
+      if (uniqueCartIds.size === 0) {
+        return 0;
+      }
+      return orderCount / uniqueCartIds.size;
+    },
+
+    getTopProducts(limit: number): Array<{ productId: string; count: number }> {
+      return Array.from(productOrderQuantities.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
diff --git a/src/cart/index.ts b/src/cart/index.ts
new file mode 100644
index 0000000..ae85fa3
--- /dev/null
+++ b/src/cart/index.ts
@@ -0,0 +1,90 @@
+import { randomUUID } from 'crypto';
+import { EventBus } from '../bus.js';
+import { CartService, CartUpdatedEvent, Events } from '../types.js';
+
+interface CartItem {
+  productId: string;
+  quantity: number;
+}
+
+interface Cart {
+  id: string;
+  userId: string;
+  items: CartItem[];
+}
+
+export function createCartService(bus: EventBus): CartService {
+  const carts = new Map<string, Cart>();
+
+  function emitCartUpdated(cart: Cart): void {
+    const payload: CartUpdatedEvent = {
+      cartId: cart.id,
+      userId: cart.userId,
+      items: cart.items.map((item) => ({ productId: item.productId, quantity: item.quantity })),
+    };
+    void bus.emit(Events.CART_UPDATED, payload);
+  }
+
+  return {
+    createCart(userId: string): string {
+      const cartId = randomUUID();
+      carts.set(cartId, { id: cartId, userId, items: [] });
+      return cartId;
+    },
+
+    addItem(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+
+      const existing = cart.items.find((item) => item.productId === productId);
+      if (existing) {
+        existing.quantity += quantity;
+      } else {
+        cart.items.push({ productId, quantity });
+      }
+
+      emitCartUpdated(cart);
+    },
+
+    removeItem(cartId: string, productId: string): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+
+      cart.items = cart.items.filter((item) => item.productId !== productId);
+
+      emitCartUpdated(cart);
+    },
+
+    getCart(cartId: string): { id: string; userId: string; items: CartItem[] } | null {
+      const cart = carts.get(cartId);
+      if (!cart) return null;
+
+      return {
+        id: cart.id,
+        userId: cart.userId,
+        items: cart.items.map((item) => ({ productId: item.productId, quantity: item.quantity })),
+      };
+    },
+
+    clearCart(cartId: string): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+
+      cart.items = [];
+
+      emitCartUpdated(cart);
+    },
+
+    updateQuantity(cartId: string, productId: string, quantity: number): void {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+
+      const existing = cart.items.find((item) => item.productId === productId);
+      if (existing) {
+        existing.quantity = quantity;
+      }
+
+      emitCartUpdated(cart);
+    },
+  };
+}
diff --git a/src/catalog/index.ts b/src/catalog/index.ts
new file mode 100644
index 0000000..687286b
--- /dev/null
+++ b/src/catalog/index.ts
@@ -0,0 +1,68 @@
+import { EventBus } from '../bus.js';
+import { Events, type CatalogService, type ProductCreatedEvent } from '../types.js';
+
+interface Product {
+  id: string;
+  name: string;
+  price: number;
+  category: string;
+}
+
+export function createCatalogService(bus: EventBus): CatalogService {
+  const products = new Map<string, Product>();
+  let counter = 0;
+
+  function nextId(): string {
+    counter += 1;
+    return `product-${counter}`;
+  }
+
+  return {
+    createProduct(name: string, price: number, category: string): string {
+      const id = nextId();
+      const product: Product = { id, name, price, category };
+      products.set(id, product);
+
+      const payload: ProductCreatedEvent = { productId: id, name, price, category };
+      void bus.emit(Events.PRODUCT_CREATED, payload);
+
+      return id;
+    },
+
+    getProduct(productId: string): Product | null {
+      return products.get(productId) ?? null;
+    },
+
+    listProducts(category?: string): Product[] {
+      const all = Array.from(products.values());
+      if (category === undefined) {
+        return all;
+      }
+      return all.filter((p) => p.category === category);
+    },
+
+    searchProducts(query: string): Product[] {
+      const lower = query.toLowerCase();
+      return Array.from(products.values()).filter((p) =>
+        p.name.toLowerCase().includes(lower),
+      );
+    },
+
+    updateProduct(
+      productId: string,
+      updates: Partial<{ name: string; price: number; category: string }>,
+    ): void {
+      const product = products.get(productId);
+      if (!product) {
+        return;
+      }
+      if (updates.name !== undefined) product.name = updates.name;
+      if (updates.price !== undefined) product.price = updates.price;
+      if (updates.category !== undefined) product.category = updates.category;
+    },
+
+    removeProduct(productId: string): boolean {
+      return products.delete(productId);
+    },
+  };
+}
