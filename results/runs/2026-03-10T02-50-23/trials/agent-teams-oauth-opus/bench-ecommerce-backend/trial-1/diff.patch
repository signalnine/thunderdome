@@ -0,0 +1,68 @@
+import { EventBus } from '../bus.js';
+import {
+  Events,
+  PaymentStatus,
+  type PaymentProcessedEvent,
+  type PaymentService,
+} from '../types.js';
+
+export function createPaymentService(
+  bus: EventBus,
+  options?: { simulateFailure?: boolean; simulateTimeout?: boolean },
+): PaymentService {
+  const transactions = new Map<
+    string,
+    { orderId: string; amount: number; status: PaymentStatus }
+  >();
+
+  return {
+    async processPayment(
+      orderId: string,
+      amount: number,
+    ): Promise<{
+      status: PaymentStatus;
+      transactionId?: string;
+      error?: string;
+    }> {
+      let result: {
+        status: PaymentStatus;
+        transactionId?: string;
+        error?: string;
+      };
+
+      if (options?.simulateTimeout) {
+        result = { status: PaymentStatus.TIMEOUT, error: 'Payment timed out' };
+      } else if (options?.simulateFailure) {
+        result = { status: PaymentStatus.FAILED, error: 'Payment failed' };
+      } else {
+        const transactionId = crypto.randomUUID();
+        transactions.set(transactionId, {
+          orderId,
+          amount,
+          status: PaymentStatus.SUCCESS,
+        });
+        result = { status: PaymentStatus.SUCCESS, transactionId };
+      }
+
+      const eventPayload: PaymentProcessedEvent = {
+        orderId,
+        status: result.status,
+        transactionId: result.transactionId,
+        error: result.error,
+      };
+
+      await bus.emit(Events.PAYMENT_PROCESSED, eventPayload);
+
+      return result;
+    },
+
+    async refund(transactionId: string): Promise<boolean> {
+      const transaction = transactions.get(transactionId);
+      if (!transaction || transaction.status !== PaymentStatus.SUCCESS) {
+        return false;
+      }
+      transactions.delete(transactionId);
+      return true;
+    },
+  };
+}
