riority ?? TaskQueue.DEFAULT_PRIORITY;\n\n    // Phase 3: Validate priority\n    if (!Number.isInteger(priority) || priority < 1 || priority > 10) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Phase 7: Validate dependencies\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      if (!this.tasks.has(depId)) {\n        throw new Error(`Dependency task '${depId}' does not exist`);\n      }\n    }\n\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      this.detectCycles(dependencies);\n    }\n\n    // Phase 4: Calculate availability time\n    let availableAt = new Date();\n    if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    } else if (options.runAt != null) {\n      availableAt = new Date(options.runAt.getTime());\n    }\n\n    const task: Task = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      createdAt: new Date(),\n      priority,\n      queue: queueName,\n      availableAt,\n      attempts: 0,\n      maxRetries: options.maxRetries ?? TaskQueue.DEFAULT_MAX_RETRIES,\n      backoffDelay: options.backoffDelay ?? TaskQueue.DEFAULT_BACKOFF_DELAY,\n      dependencies: [...dependencies],\n      progress: 0,\n      progressMessage: undefined,\n      error: undefined,\n      failCount: 0,\n    };\n\n    this.tasks.set(task.id, task);\n    this.taskInsertOrder.set(task.id, this._insertOrder++);\n    this.ensureQueue(queueName);\n\n    return this.copyTask(task);\n  }\n\n  getNextTask(queueName?: string): Task | null {\n    const task = this._dequeueTask(queueName ?? TaskQueue.DEFAULT_QUEUE);\n    return task ? this.copyTask(task) : null;\n  }\n\n  getTaskCount(queueName?: string): number {\n    const queue = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queue && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  getTask(taskId: string): Task | null {\n    const task = this.tasks.get(taskId);\n    return task ? this.copyTask(task) : null;\n  }\n\n  // Phase 2: List all queue names\n  getQueues(): string[] {\n    const names = new Set<string>();\n    for (const task of this.tasks.values()) {\n      names.add(task.queue);\n    }\n    for (const name of this.queueData.keys()) {\n      names.add(name);\n    }\n    return [...names];\n  }\n\n  // ─── Internal dequeue (returns real reference) ────────────────────────────\n\n  private _dequeueTask(queueName: string): Task | null {\n    const queueInfo = this.queueData.get(queueName);\n\n    // Phase 8: Check concurrency limit\n    if (queueInfo && queueInfo.concurrencyLimit > 0) {\n      if (queueInfo.activeCount >= queueInfo.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = Date.now();\n    const eligible: Task[] = [];\n\n    for (const task of this.tasks.values()) {\n      if (task.queue !== queueName) continue;\n      if (task.status !== 'pending') continue;\n      if (task.availableAt.getTime() > now) continue;\n      if (!this.areDependenciesResolved(task)) continue;\n      eligible.push(task);\n    }\n\n    if (eligible.length === 0) return null;\n\n    // Sort: priority (asc), availableAt (asc), insertion order (asc = FIFO)\n    eligible.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const aAt = a.availableAt.getTime();\n      const bAt = b.availableAt.getTime();\n      if (aAt !== bAt) return aAt - bAt;\n      return (this.taskInsertOrder.get(a.id) ?? 0) - (this.taskInsertOrder.get(b.id) ?? 0);\n    });\n\n    const task = eligible[0];\n    task.status = 'processing';\n    task.attempts++;\n\n    // Track concurrency\n    const qi = this.ensureQueue(queueName);\n    qi.activeCount++;\n\n    return task;\n  }\n\n  private areDependenciesResolved(task: Task): bool