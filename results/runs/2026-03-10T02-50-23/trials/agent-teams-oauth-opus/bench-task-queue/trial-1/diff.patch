tq.getDeadLetterTasks();\\n    expect(dlqTasks).toHaveLength(1);\\n    expect(dlqTasks[0].id).toBe(task.id);\\n  });\\n\\n  it('getDeadLetterTasks returns DLQ tasks for a queue', () => {\\n    const task1 = tq.addTask({ action: 'fail1' });\\n    const task2 = tq.addTask({ action: 'fail2' });\\n\\n    exhaustRetries(task1.id);\\n    exhaustRetries(task2.id);\\n\\n    const dlqTasks = tq.getDeadLetterTasks();\\n    expect(dlqTasks).toHaveLength(2);\\n    const ids = dlqTasks.map(t => t.id);\\n    expect(ids).toContain(task1.id);\\n    expect(ids).toContain(task2.id);\\n  });\\n\\n  it('dead-lettered tasks retain error info', () => {\\n    const task = tq.addTask({ action: 'doomed' });\\n\\n    exhaustRetries(task.id, 'catastrophic failure');\\n\\n    const dlqTasks = tq.getDeadLetterTasks();\\n    expect(dlqTasks).toHaveLength(1);\\n    expect(dlqTasks[0].error).toBe('catastrophic failure');\\n  });\\n\\n  it('dead-lettered tasks retain failCount', () => {\\n    const task = tq.addTask({ action: 'doomed' });\\n\\n    exhaustRetries(task.id);\\n\\n    const dlqTasks = tq.getDeadLetterTasks();\\n    expect(dlqTasks).toHaveLength(1);\\n    // 4 total failures (attempt 1 + 3 retries)\\n    expect(dlqTasks[0].failCount).toBe(4);\\n  });\\n\\n  it('retryDeadLetterTask moves task back to original queue', () => {\\n    const task = tq.addTask({ action: 'retry-me' }, { queue: 'emails' });\\n\\n    exhaustRetries(task.id);\\n\\n    const dlqBefore = tq.getDeadLetterTasks('emails');\\n    expect(dlqBefore).toHaveLength(1);\\n\\n    const retried = tq.retryDeadLetterTask(task.id);\\n    expect(retried.status).toBe('pending');\\n    expect(retried.queue).toBe('emails');\\n    expect(retried.attempts).toBe(0);\\n    expect(retried.error).toBeUndefined();\\n\\n    // DLQ should be empty now\\n    const dlqAfter = tq.getDeadLetterTasks('emails');\\n    expect(dlqAfter).toHaveLength(0);\\n\\n    // Task should be available in original queue\\n    vi.advanceTimersByTime(1);\\n    const next = tq.getNextTask('emails');\\n    expect(next).not.toBeNull();\\n    expect(next!.id).toBe(task.id);\\n  });\\n\\n  it('clearDeadLetterQueue removes all DLQ tasks', () => {\\n    const task1 = tq.addTask({ action: 'fail1' });\\n    const task2 = tq.addTask({ action: 'fail2' });\\n\\n    exhaustRetries(task1.id);\\n    exhaustRetries(task2.id);\\n\\n    expect(tq.getDeadLetterTasks()).toHaveLength(2);\\n\\n    tq.clearDeadLetterQueue();\\n\\n    expect(tq.getDeadLetterTasks()).toHaveLength(0);\\n\\n    // Tasks should also be removed from the main store\\n    expect(tq.getTask(task1.id)).toBeNull();\\n    expect(tq.getTask(task2.id)).toBeNull();\\n  });\\n\\n  it('each named queue has independent DLQ', () => {\\n    const emailTask = tq.addTask({ action: 'email-fail' }, { queue: 'emails' });\\n    const smsTask = tq.addTask({ action: 'sms-fail' }, { queue: 'sms' });\\n\\n    // Exhaust retries for email task\\n    for (let i = 0; i < 4; i++) {\\n      vi.advanceTimersByTime(10000);\\n      const next = tq.getNextTask('emails');\\n      expect(next).not.toBeNull();\\n      expect(next!.id).toBe(emailTask.id);\\n      tq.fail(next!.id, 'email error');\\n    }\\n\\n    // Exhaust retries for sms task\\n    for (let i = 0; i < 4; i++) {\\n      vi.advanceTimersByTime(10000);\\n      const next = tq.getNextTask('sms');\\n      expect(next).not.toBeNull();\\n      expect(next!.id).toBe(smsTask.id);\\n      tq.fail(next!.id, 'sms error');\\n    }\\n\\n    const emailDlq = tq.getDeadLetterTasks('emails');\\n    const smsDlq = tq.getDeadLetterTasks('sms');\\n    const defaultDlq = tq.getDeadLetterTasks();\\n\\n    expect(emailDlq).toHaveLength(1);\\n    expect(emailDlq[0].id).toBe(emailTask.id);\\n\\n    expect(smsDlq).toHaveLength(1);\\n    expect(smsDlq[0].id).toBe(smsTask.id);\\n\\n    expect(defaultDlq).toHaveLength(0);\\n  });\\n});\\n\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_in