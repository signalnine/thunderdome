 id: string;\\n    19→  payload: unknown;\\n    20→  status: TaskStatus;\\n    21→  createdAt: Date;\\n    22→  priority: number;\\n    23→  queue: string;\\n    24→  availableAt: Date;\\n    25→  attempts: number;\\n    26→  maxRetries: number;\\n    27→  backoffDelay: number;\\n    28→  dependencies: string[];\\n    29→  progress: number;\\n    30→  progressMessage?: string;\\n    31→  error?: string;\\n    32→  failCount: number;\\n    33→}\\n    34→\\n    35→export interface ScheduleOptions {\\n    36→  id?: string;\\n    37→  cron: string;\\n    38→  queue?: string;\\n    39→  payload: unknown;\\n    40→  taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'runAt' | 'dependencies'>;\\n    41→}\\n    42→\\n    43→export interface Schedule {\\n    44→  id: string;\\n    45→  cron: string;\\n    46→  queue: string;\\n    47→  payload: unknown;\\n    48→  taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'runAt' | 'dependencies'>;\\n    49→  lastRun?: Date;\\n    50→}\\n    51→\\n    52→export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void> | void;\\n    53→export type HandlerFn = (task: Task) => Promise<void> | void;\\n    54→export type ProgressCallback = (progress: number, message?: string) => void;\\n    55→\\n    56→export interface ShutdownSummary {\\n    57→  completed: number;\\n    58→  forceCancelled: number;\\n    59→  duration: number;\\n    60→}\\n    61→\\n    62→interface QueueData {\\n    63→  concurrencyLimit: number; // 0 = unlimited\\n    64→  activeCount: number;\\n    65→  middleware: MiddlewareFn[];\\n    66→  handler?: HandlerFn;\\n    67→}\\n    68→\\n    69→// ─── TaskQueue ───────────────────────────────────────────────────────────────\\n    70→\\n    71→export class TaskQueue {\\n    72→  private tasks = new Map<string, Task>();\\n    73→  private queueData = new Map<string, QueueData>();\\n    74→  private dlqIds = new Map<string, Set<string>>(); // queue → set of task IDs in DLQ\\n    75→  private schedules = new Map<string, Schedule>();\\n    76→  private progressListeners = new Map<string, Set<ProgressCallback>>();\\n    77→  private _isShutdown = false;\\n    78→  private _shutdownPromise: Promise<ShutdownSummary> | null = null;\\n    79→  private shutdownCallbacks: (() => void | Promise<void>)[] = [];\\n    80→  private _shutdownWaiter: (() => void) | null = null;\\n    81→  private _insertOrder = 0;\\n    82→  private taskInsertOrder = new Map<string, number>();\\n    83→\\n    84→  static readonly DEFAULT_QUEUE = 'default';\\n    85→  static readonly DEFAULT_PRIORITY = 5;\\n    86→  static readonly DEFAULT_MAX_RETRIES = 3;\\n    87→  static readonly DEFAULT_BACKOFF_DELAY = 1000;\\n    88→\\n    89→  // ─── Internal helpers ────────────────────────────────────────────────────\\n    90→\\n    91→  private ensureQueue(name: string): QueueData {\\n    92→    if (!this.queueData.has(name)) {\\n    93→      this.queueData.set(name, {\\n    94→        concurrencyLimit: 0,\\n    95→        activeCount: 0,\\n    96→        middleware: [],\\n    97→      });\\n    98→    }\\n    99→    return this.queueData.get(name)!;\\n   100→  }\\n   101→\\n   102→  private notifyShutdownWaiter(): void {\\n   103→    if (this._shutdownWaiter) {\\n   104→      this._shutdownWaiter();\\n   105→    }\\n   106→  }\\n   107→\\n   108→  // ─── Phase 1 & 2: Add and retrieve tasks ─────────────────────────────────\\n   109→\\n   110→  addTask(payload: unknown, options: TaskOptions = {}): Task {\\n   111→    if (this._isShutdown) {\\n   112→      throw new Error('Cannot add tasks: queue system is shut down');\\n   113→    }\\n   114→\\n   115→    const queueName = options.queue ?? TaskQueue.DEFAULT_QUEUE;\\n   116→    const priority = options.priority ?? TaskQueue.DEFAULT_PRIORITY;\\n   117→\\n   118→    // Phase 3: Validate priority\\n   119→    if (!Number.isInteger(priority) || priority < 1 || priority > 10) {\\n   120→      throw new Error(`Invalid priority: ${priority}. Must be an integer