, afterEach, vi } from 'vitest';\\n     2→import { TaskQueue } from '../src/index.js';\\n     3→\\n     4→describe('Phase 6 - Dead Letter Queue', () => {\\n     5→  let tq: TaskQueue;\\n     6→\\n     7→  beforeEach(() => {\\n     8→    vi.useFakeTimers();\\n     9→    tq = new TaskQueue();\\n    10→  });\\n    11→\\n    12→  afterEach(() => {\\n    13→    vi.useRealTimers();\\n    14→  });\\n    15→\\n    16→  /**\\n    17→   * Helper: exhaust all retries for a task so it ends up in the DLQ.\\n    18→   * With default maxRetries=3 and backoffDelay=1000:\\n    19→   *   attempt 1 fails -> pending (delay 1000)\\n    20→   *   attempt 2 fails -> pending (delay 2000)\\n    21→   *   attempt 3 fails -> pending (delay 4000)\\n    22→   *   attempt 4 fails -> failed + DLQ\\n    23→   */\\n    24→  function exhaustRetries(taskId: string, errorMsg = 'persistent error'): void {\\n    25→    // We need 4 fail cycles: attempts 1-3 retry, attempt 4 goes to DLQ\\n    26→    for (let i = 0; i < 4; i++) {\\n    27→      // Advance time generously to make the task available\\n    28→      vi.advanceTimersByTime(10000);\\n    29→      const next = tq.getNextTask();\\n    30→      expect(next).not.toBeNull();\\n    31→      expect(next!.id).toBe(taskId);\\n    32→      tq.fail(next!.id, errorMsg);\\n    33→    }\\n    34→  }\\n    35→\\n    36→  it('task moved to DLQ after exhausting retries', () => {\\n    37→    const task = tq.addTask({ action: 'doomed' });\\n    38→\\n    39→    exhaustRetries(task.id);\\n    40→\\n    41→    const updated = tq.getTask(task.id);\\n    42→    expect(updated!.status).toBe('failed');\\n    43→\\n    44→    const dlqTasks = tq.getDeadLetterTasks();\\n    45→    expect(dlqTasks).toHaveLength(1);\\n    46→    expect(dlqTasks[0].id).toBe(task.id);\\n    47→  });\\n    48→\\n    49→  it('getDeadLetterTasks returns DLQ tasks for a queue', () => {\\n    50→    const task1 = tq.addTask({ action: 'fail1' });\\n    51→    const task2 = tq.addTask({ action: 'f