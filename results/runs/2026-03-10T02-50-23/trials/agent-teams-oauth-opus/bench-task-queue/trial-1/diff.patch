":\"ac73a490a71cac7dc\",\"slug\":\"dreamy-petting-quill\",\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01Fqzgis5UyKSmCVafAnn44S\",\"type\":\"tool_result\",\"content\":\"     1→import { randomUUID } from 'node:crypto';\\n     2→\\n     3→// ─── Types ───────────────────────────────────────────────────────────────────\\n     4→\\n     5→export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';\\n     6→\\n     7→export interface TaskOptions {\\n     8→  queue?: string;\\n     9→  priority?: number;\\n    10→  delay?: number;\\n    11→  runAt?: Date;\\n    12→  maxRetries?: number;\\n    13→  backoffDelay?: number;\\n    14→  dependencies?: string[];\\n    15→}\\n    16→\\n    17→export interface Task {\\n    18→  id: string;\\n    19→  payload: unknown;\\n    20→  status: TaskStatus;\\n    21→  createdAt: Date;\\n    22→  priority: number;\\n    23→  queue: string;\\n    24→  availableAt: Date;\\n    25→  attempts: number;\\n    26→  maxRetries: number;\\n    27→  backoffDelay: number;\\n    28→  dependencies: string[];\\n    29→  progress: number;\\n    30→  progressMessage?: string;\\n    31→  error?: string;\\n    32→  failCount: number;\\n    33→}\\n    34→\\n    35→export interface ScheduleOptions {\\n    36→  id?: string;\\n    37→  cron: string;\\n    38→  queue?: string;\\n    39→  payload: unknown;\\n    40→  taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'runAt' | 'dependencies'>;\\n    41→}\\n    42→\\n    43→export interface Schedule {\\n    44→  id: string;\\n    45→  cron: string;\\n    46→  queue: string;\\n    47→  payload: unknown;\\n    48→  taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'runAt' | 'dependencies'>;\\n    49→  lastRun?: Date;\\n    50→}\\n    51→\\n    52→export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void> | void;\\n    53→export type HandlerFn = (task: Task) => Promise<void> | void;\\n    54→export type ProgressCallback = (progress: number, message?: string) => void;\\n    55→\\n    56→export interface ShutdownSummary {\\n    57→  completed: number;\\n    58→  forceCancelled: number;\\n    59→  duration: number;\\n    60→}\\n    61→\\n    62→interface QueueData {\\n    63→  concurrencyLimit: number; // 0 = unlimited\\n    64→  activeCount: number;\\n    65→  middleware: MiddlewareFn[];\\n    66→  handler?: HandlerFn;\\n    67→}\\n    68→\\n    69→// ─── TaskQueue ───────────────────────────────────────────────────────────────\\n    70→\\n    71→export class TaskQueue {\\n    72→  private tasks = new Map<string, Task>();\\n    73→  private queueData = new Map<string, QueueData>();\\n    74→  private dlqIds = new Map<string, Set<string>>(); // queue → set of task IDs in DLQ\\n    75→  private schedules = new Map<string, Schedule>();\\n    76→  private progressListeners = new Map<string, Set<ProgressCallback>>();\\n    77→  private _isShutdown = false;\\n    78→  private _shutdownPromise: Promise<ShutdownSummary> | null = null;\\n    79→  private shutdownCallbacks: (() => void | Promise<void>)[] = [];\\n    80→  private _shutdownWaiter: (() => void) | null = null;\\n    81→  private _insertOrder = 0;\\n    82→  private taskInsertOrder = new Map<string, number>();\\n    83→\\n    84→  static readonly DEFAULT_QUEUE = 'default';\\n    85→  static readonly DEFAULT_PRIORITY = 5;\\n    86→  static readonly DEFAULT_MAX_RETRIES = 3;\\n    87→  static readonly DEFAULT_BACKOFF_DELAY = 1000;\\n    88→\\n    89→  // ─── Internal helpers ────────────────────────────────────────────────────\\n    90→\\n    91→  private ensureQueue(name: string): QueueData {\\n    92→    if (!this.queueData.has(name)) {\\n    93→      this.queueData.set(name, {\\n    94→        concurrencyLimit: 0,\\n    95→        activeCount: 0,\\n    96→        middleware: [],\\n    97→      });\\n    98→    }\\n    99→    return this.queueData.get(name)!;\\n   100→  }\\n   101→\\n   102→  private notifyShutdownWaiter(): void {\\n   103→    if (this._shutdownWaiter) {\\n   104→      this._shutdownWaiter();\\n   105→    }\\n   106→  }\\n   107→\\n   108→  // ─── Phase 1 & 2: Add and retrieve tasks ─────────────────────────────────\\n   109→\\n   110→  addTask(payload: unknown, options: TaskOptions = {}): Task {\\n   111→    if (this._isShutdown) {\\n   112→      throw new Error('Cannot add tasks: queue system is shut down');\\n   113→    }\\n   114→\\n   115→    const queueName = options.queue ?? TaskQueue.DEFAULT_QUEUE;\\n   116→    const priority = options.priority ?? TaskQueue.DEFAULT_PRIORITY;\\n   117→\\n   118→    // Phase 3: Validate priority\\n   119→    if (!Number.isInteger(priority) || priority < 1 || priority > 10) {\\n   120→      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\\n   121→    }\\n   122→\\n   123→    // Phase 7: Validate dependencies\\n   124→    const dependencies = options.dependencies ?? [];\\n   125→    for (const depId of dependencies) {\\n   126→      if (!this.tasks.has(depId)) {\\n   127→        throw new Error(`Dependency task '${depId}' does not exist`);\\n   128→      }\\n   129→    }\\n   130→\\n   131→    // Circular dependency detection\\n   132→    if (dependencies.length > 0) {\\n   133→      this.detectCycles(dependencies);\\n   134→    }\\n   135→\\n   136→    // Phase 4: Calculate availability time\\n   137→    let availableAt = new Date();\\n   138→    if (options.delay != null && options.delay > 0) {\\n   139→      availableAt = new Date(Date.now() + options.delay);\\n   140→    } else if (options.runAt != null) {\\n   141→      availableAt = new Date(options.runAt.getTime());\\n   142→    }\\n   143→\\n   144→    const task: Task = {\\n   145→      id: randomUUID(),\\n   146→      payload,\\n   147→      status: 'pending',\\n   148→      createdAt: new Date(),\\n   149→      priority,\\n   150→      queue: queueName,\\n   151→      availableAt,\\n   152→      attempts: 0,\\n   153→      maxRetries: options.maxRetries ?? TaskQueue.DEFAULT_MAX_RETRIES,\\n   154→      backoffDelay: options.backoffDelay ?? TaskQueue.DEFAULT_BACKOFF_DELAY,\\n   155→      dependencies: [...dependencies],\\n   156→      progress: 0,\\n   157→      progressMessage: undefined,\\n   158→      error: undefined,\\n   159→      failCount: 0,\\n   160→    };\\n   161→\\n   162→    this.tasks.set(task.id, task);\\n   163→    this.taskInsertOrder.set(task.id, this._insertOrder++);\\n   164→    this.ensureQueue(queueName);\\n   165→\\n   166→    return this.copyTask(task);\\n   167→  }\\n   168→\\n   169→  getNextTask(queueName?: string): Task | null {\\n   170→    const task = this._dequeueTask(queueName ?? TaskQueue.DEFAULT_QUEUE);\\n   171→    return task ? this.copyTask(task) : null;\\n   172→  }\\n   173→\\n   174→  getTaskCount(queueName?: string): number {\\n   175→    const queue = queueName ?? TaskQueue.DEFAULT_QUEUE;\\n   176→    let count = 0;\\n   177→    for (const task of this.tasks.values()) {\\n   178→      if (task.queue === queue && task.status === 'pending') {\\n   179→        count++;\\n   180→      }\\n   181→    }\\n   182→    return count;\\n   183→  }\\n   184→\\n   185→  getTask(taskId: string): Task | null {\\n   186→    const task = this.tasks.get(taskId);\\n   187→    return task ? this.copyTask(task) : null;\\n   188→  }\\n   189→\\n   190→  // Phase 2: List all queue names\\n   191→  getQueues(): string[] {\\n   192→    const names = new Set<string>();\\n   193→    for (const task of this.tasks.values()) {\\n   194→      names.add(task.queue);\\n   195→    }\\n   196→    for (const name of this.queueData.keys()) {\\n   197→      names.add(name);\\n   198→    }\\n   199→    return [...names];\\n   200→  }\\n   201→\\n   202→  // ─── Internal dequeue (returns real reference) ────────────────────────────\\n   203→\\n   204→  private _dequeueTask(queueName: string): Task | null {\\n   205→    const queueInfo = this.queueData.get(queueName);\\n   206→\\n   207→    // Phase 8: Check concurrency limit\\n   208→    if (queueInfo && queueInfo.concurrencyLimit > 0) {\\n   209→      if (queueInfo.activeCount >= queueInfo.concurrencyLimit) {\\n   210→        return null;\\n   211→      }\\n   212→    }\\n   213→\\n   214→    const now = Date.now();\\n   215→    const eligible: Task[] = [];\\n   216→\\n   217→    for (const task of this.tasks.values()) {\\n   218→      if (task.queue !== queueName) continue;\\n   219→      if (task.status !== 'pending') continue;\\n   220→      if (task.availableAt.getTime() > now) continue;\\n   221→      if (!this.areDependenciesResolved(task)) continue;\\n   222→      eligible.push(task);\\n   223→    }\\n   224→\\n   225→    if (eligible.length === 0) return null;\\n   226→\\n   227→    // Sort: priority (asc), availableAt (asc), insertion order (asc = FIFO)\\n   228→    eligible.sort((a, b) => {\\n   229→      if (a.priority !== b.priority) return a.priority - b.priority;\\n   230→      const aAt = a.availableAt.getTime();\\n   231→      const bAt = b.availableAt.getTime();\\n   232→      if (aAt !== bAt) return aAt - bAt;\\n   233→      return (this.taskInsertOrder.get(a.id) ?? 0) - (this.taskInsertOrder.get(b.id) ?? 0);\\n   234→    });\\n   235→\\n   236→    const task = eligible[0];\\n   237→    task.status = 'processing';\\n   238→    task.attempts++;\\n   239→\\n   240→    // Track concurrency\\n   241→    const qi = this.ensureQueue(queueName);\\n   242→    qi.activeCount++;\\n   243→\\n   244→    return task;\\n   245→  }\\n   246→\\n   247→  private areDependenciesResolved(task: Task): boolean {\\n   248→    for (const depId of task.dependencies) {\\n   249→      const dep = this.tasks.get(depId);\\n   250→      if (!dep || dep.status !== 'completed') return false;\\n   251→    }\\n   252→    return true;\\n   253→  }\\n   254→\\n   255→  private detectCycles(dependencies: string[]): void {\\n   256→    const visited = new Set<string>();\\n   257→    const visiting = new Set<string>();\\n   258→\\n   259→    const dfs = (taskId: string): void => {\\n   260→      if (visiting.has(taskId)) {\\n   261→        throw new Error('Circular dependency detected');\\n   262→      }\\n   263→      if (visited.has(taskId)) return;\\n   264→\\n   265→      visiting.add(taskId);\\n   266→      const task = this.tasks.get(taskId);\\n   267→      if (task) {\\n   268→        for (const depId of task.dependencies) {\\n   269→          dfs(depId);\\n   270→        }\\n   271→      }\\n   272→      visiting.delete(taskId);\\n   273→      visited.add(taskId);\\n   274→    };\\n   275→\\n   276→    for (const depId of dependencies) {\\n   277→      dfs(depId);\\n   278→    }\\n   279→  }\\n   280→\\n   281→  private copyTask(task: Task): Task {\\n   282→    return { ...task, dependencies: [...task.dependencies] };\\n   283→  }\\n   284→\\n   285→  // ─── Phase 5: Complete / Fail ─────────────────────────────────────────────\\n   286→\\n   287→  complete(taskId: string): void {\\n   288→    const task = this.tasks.get(taskId);\\n   289→    if (!task) throw new Error(`Task '${taskId}' not found`);\\n   290→    if (task.status !== 'processing') {\\n   291→      throw new Error(`Cannot complete task with status '${task.status}'`);\\n   292→    }\\n   293→\\n   294→    task.status = 'completed';\\n   295→    task.progress = 100;\\n   296→\\n   297→    // Free concurrency slot\\n   298→    const qi = this.queueData.get(task.queue);\\n   299→    if (qi) qi.activeCount = Math.max(0, qi.activeCount - 1);\\n   300→\\n   301→    this.notifyShutdownWaiter();\\n   302→  }\\n   303→\\n   304→  fail(taskId: string, error?: string | Error): void {\\n   305→    const task = this.tasks.get(taskId);\\n   306→    if (!task) throw new Error(`Task '${taskId}' not found`);\\n   307→    if (task.status !== 'processing') {\\n   308→      throw new Error(`Cannot fail task with status '${task.status}'`);\\n   309→    }\\n   310→\\n   311→    const errorMessage = error instanceof Error ? error.message : (error ?? 'Task failed');\\n   312→    task.error = errorMessage;\\n   313→    task.failCount++;\\n   314→\\n   315→    // Free concurrency slot\\n   316→    const qi = this.queueData.get(task.queue);\\n   317→    if (qi) qi.activeCount = Math.max(0, qi.activeCount - 1);\\n   318→\\n   319→    // Check retries: attempts includes this try, maxRetries is the number of retries\\n   320→    // With maxRetries=3: attempt 1 fails → 0 retries used (< 3), retry\\n   321→    //                    attempt 2 fails → 1 retry used (< 3), retry\\n   322→    //                    attempt 3 fails → 2 retries used (< 3), retry\\n   323→    //                    attempt 4 fails → 3 retries used (= 3), DLQ\\n   324→    const retriesUsed = task.attempts - 1;\\n   325→    if (retriesUsed < task.maxRetries) {\\n   326→      // Retry with exponential backoff\\n   327→      const delay = task.backoffDelay * Math.pow(2, retriesUsed);\\n   328→      task.status = 'pending';\\n   329→      task.availableAt = new Date(Date.now() + delay);\\n   330→      task.progress = 0;\\n   331→      task.progressMessage = undefined;\\n   332→    } else {\\n   333→      // No more retries → failed + DLQ\\n   334→      task.status = 'failed';\\n   335→      this.addToDeadLetterQueue(task);\\n   336→    }\\n   337→\\n   338→    this.notifyShutdownWaiter();\\n   339→  }\\n   340→\\n   341→  // ─── Phase 6: Dead Letter Queue ──────────────────────────────────────────\\n   342→\\n   343→  private addToDeadLetterQueue(task: Task): void {\\n   344→    if (!this.dlqIds.has(task.queue)) {\\n   345→      this.dlqIds.set(task.queue, new Set());\\n   346→    }\\n   347→    this.dlqIds.get(task.queue)!.add(task.id);\\n   348→  }\\n   349→\\n   350→  getDeadLetterTasks(queueName?: string): Task[] {\\n   351→    const queue = queueName ?? TaskQueue.DEFAULT_QUEUE;\\n   352→    const ids = this.dlqIds.get(queue);\\n   353→    if (!ids || ids.size === 0) return [];\\n   354→    const result: Task[] = [];\\n   355→    for (const id of ids) {\\n   356→      const task = this.tasks.get(id);\\n   357→      if (task) result.push(this.copyTask(task));\\n   358→    }\\n   359→    return result;\\n   360→  }\\n   361→\\n   362→  retryDeadLetterTask(taskId: string): Task {\\n   363→    // Find the task in any DLQ\\n   364→    for (const [_queueName, ids] of this.dlqIds) {\\n   365→      if (ids.has(taskId)) {\\n   366→        const task = this.tasks.get(taskId);\\n   367→        if (!task) throw new Error(`Task '${taskId}' not found`);\\n   368→\\n   369→        ids.delete(taskId);\\n   370→\\n   371→        // Reset for fresh retry\\n   372→        task.status = 'pending';\\n   373→        task.attempts = 0;\\n   374→        task.error = undefined;\\n   375→        task.progress = 0;\\n   376→        task.progressMessage = undefined;\\n   377→        task.availableAt = new Date();\\n   378→\\n   379→        return this.copyTask(task);\\n   380→      }\\n   381→    }\\n   382→    throw new Error(`Task '${taskId}' not found in any dead letter queue`);\\n   383→  }\\n   384→\\n   385→  clearDeadLetterQueue(queueName?: string): void {\\n   386→    const queue = queueName ?? TaskQueue.DEFAULT_QUEUE;\\n   387→    const ids = this.dlqIds.get(queue);\\n   388→    if (ids) {\\n   389→      for (const id of ids) {\\n   390→        this.tasks.delete(id);\\n   391→        this.taskInsertOrder.delete(id);\\n   392→      }\\n   393→      ids.clear();\\n   394→    }\\n   395→  }\\n   396→\\n   397→  // ─── Phase 7: Dependency status ───────────────────────────────────────────\\n   398→\\n   399→  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } {\\n   400→    const task = this.tasks.get(taskId);\\n   401→    if (!task) throw new Error(`Task '${taskId}' not found`);\\n   402→\\n   403→    const resolved: string[] = [];\\n   404→    const pending: string[] = [];\\n   405→\\n   406→    for (const depId of task.dependencies) {\\n   407→      const dep = this.tasks.get(depId);\\n   408→      if (dep && dep.status === 'completed') {\\n   409→        resolved.push(depId);\\n   410→      } else {\\n   411→        pending.push(depId);\\n   412→      }\\n   413→    }\\n   414→\\n   415→    return { dependencies: [...task.dependencies], resolved, pending };\\n   416→  }\\n   417→\\n   418→  // ─── Phase 8: Concurrency control ────────────────────────────────────────\\n   419→\\n   420→  setConcurrency(queueName: string, limit: number): void {\\n   421→    const qi = this.ensureQueue(queueName);\\n   422→    qi.concurrencyLimit = limit;\\n   423→  }\\n   424→\\n   425→  getConcurrency(queueName?: string): { limit: number; active: number } {\\n   426→    const queue = queueName ?? TaskQueue.DEFAULT_QUEUE;\\n   427→    const qi = this.ensureQueue(queue);\\n   428→    return { limit: qi.concurrencyLimit, active: qi.activeCount };\\n   429→  }\\n   430→\\n   431→  // ─── Phase 9: Progress & Cancellation ─────────────────────────────────────\\n   432→\\n   433→  updateProgress(taskId: string, progress: number, message?: string): void {\\n   434→    const task = this.tasks.get(taskId);\\n   435→    if (!task) throw new Error(`Task '${taskId}' not found`);\\n   436→    if (task.status !== 'processing') {\\n   437→      throw new Error(`Cannot update progress on task with status '${task.status}'`);\\n   438→    }\\n   439→\\n   440→    task.progress = Math.max(0, Math.min(100, progress));\\n   441→    if (message !== undefined) {\\n   442→      task.progressMessage = message;\\n   443→    }\\n   444→\\n   445→    // Notify listeners\\n   446→    const listeners = this.progressListeners.get(taskId);\\n   447→    if (listeners) {\\n   448→      for (const callback of listeners) {\\n   449→        try { callback(task.progress, task.progressMessage); } catch (_e) { /* ignore */ }\\n   450→      }\\n   451→    }\\n   452→  }\\n   453→\\n   454→  getProgress(taskId: string): { percentage: number; message?: string } {\\n   455→    const task 