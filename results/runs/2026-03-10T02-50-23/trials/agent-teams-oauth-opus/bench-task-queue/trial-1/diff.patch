> Promise<void>) => Promise<void> | void;\nexport type HandlerFn = (task: Task) => Promise<void> | void;\nexport type ProgressCallback = (progress: number, message?: string) => void;\n\nexport interface ShutdownSummary {\n  completed: number;\n  forceCancelled: number;\n  duration: number;\n}\n\ninterface QueueData {\n  concurrencyLimit: number; // 0 = unlimited\n  activeCount: number;\n  middleware: MiddlewareFn[];\n  handler?: HandlerFn;\n}\n\n// ─── TaskQueue ───────────────────────────────────────────────────────────────\n\nexport class TaskQueue {\n  private tasks = new Map<string, Task>();\n  private queueData = new Map<string, QueueData>();\n  private dlqIds = new Map<string, Set<string>>(); // queue → set of task IDs in DLQ\n  private schedules = new Map<string, Schedule>();\n  private progressListeners = new Map<string, Set<ProgressCallback>>();\n  private _isShutdown = false;\n  private _shutdownPromise: Promise<ShutdownSummary> | null = null;\n  private shutdownCallbacks: (() => void | Promise<void>)[] = [];\n  private _shutdownWaiter: (() => void) | null = null;\n  private _insertOrder = 0;\n  private taskInsertOrder = new Map<string, number>();\n\n  static readonly DEFAULT_QUEUE = 'default';\n  static readonly DEFAULT_PRIORITY = 5;\n  static readonly DEFAULT_MAX_RETRIES = 3;\n  static readonly DEFAULT_BACKOFF_DELAY = 1000;\n\n  // ─── Internal helpers ────────────────────────────────────────────────────\n\n  private ensureQueue(name: string): QueueData {\n    if (!this.queueData.has(name)) {\n      this.queueData.set(name, {\n        concurrencyLimit: 0,\n        activeCount: 0,\n        middleware: [],\n      });\n    }\n    return this.queueData.get(name)!;\n  }\n\n  private notifyShutdownWaiter(): void {\n    if (this._shutdownWaiter) {\n      this._shutdownWaiter();\n    }\n  }\n\n  // ─── Phase 1 & 2: Add and retrieve tasks ─────────────────────────────────\n\n  addTask(payload: unknown, options: TaskOptions = {}): Task {\n    if (this._isShutdown) {\n      throw new Error('Cannot add tasks: queue system is shut down');\n    }\n\n    const queueName = options.queue ?? TaskQueue.DEFAULT_QUEUE;\n    const priority = options.priority ?? TaskQueue.DEFAULT_PRIORITY;\n\n    // Phase 3: Validate priority\n    if (!Number.isInteger(priority) || priority < 1 || priority > 10) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Phase 7: Validate dependencies\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      if (!this.tasks.has(depId)) {\n        throw new Error(`Dependency task '${depId}' does not exist`);\n      }\n    }\n\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      this.detectCycles(dependencies);\n    }\n\n    // Phase 4: Calculate availability time\n    let availableAt = new Date();\n    if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(Date.now() + options.delay);\n    } else if (options.runAt != null) {\n      availableAt = new Date(options.runAt.getTime());\n    }\n\n    const task: Task = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      createdAt: new Date(),\n      priority,\n      queue: queueName,\n      availableAt,\n      attempts: 0,\n      maxRetries: options.maxRetries ?? TaskQueue.DEFAULT_MAX_RETRIES,\n      backoffDelay: options.backoffDelay ?? TaskQueue.DEFAULT_BACKOFF_DELAY,\n      dependencies: [...dependencies],\n      progress: 0,\n      progressMessage: undefined,\n      error: undefined,\n      failCount: 0,\n    };\n\n    this.tasks.set(task.id, task);\n    this.taskInsertOrder.set(task.id, this._insertOrder++);\n    this.ensureQueue(queueName);\n\n    return this.copyTask(task);\n  }\n\n  getNextTask(queueName?: string): Task | null {\n    const task = this._dequeueTask(queueName ?? TaskQueue.DEFAULT_QUEUE);\n    return task ? this.copyTask(task) : null;\n  }\n\n  getTaskCount(queueName?: string): number {\n    const queue = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queue && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  getTask(taskId: string): Task | null {\n    const task = this.tasks.get(taskId);\n    return task ? this.copyTask(task) : null;\n  }\n\n  // Phase 2: List all queue names\n  getQueues(): string[] {\n    const names = new Set<string>();\n    for (const task of this.tasks.values()) {\n      names.add(task.queue);\n    }\n    for (const name of this.queueData.keys()) {\n      names.add(name);\n    }\n    return [...names];\n  }\n\n  // ─── Internal dequeue (returns real reference) ────────────────────────────\n\n  private _dequeueTask(queueName: string): Task | null {\n    const queueInfo = this.queueData.get(queueName);\n\n    // Phase 8: Check concurrency limit\n    if (queueInfo && queueInfo.concurrencyLimit > 0) {\n      if (queueInfo.activeCount >= queueInfo.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = Date.now();\n    const eligible: Task[] = [];\n\n    for (const task of this.tasks.values()) {\n      if (task.queue !== queueName) continue;\n      if (task.status !== 'pending') continue;\n      if (task.availableAt.getTime() > now) continue;\n      if (!this.areDependenciesResolved(task)) continue;\n      eligible.push(task);\n    }\n\n    if (eligible.length === 0) return null;\n\n    // Sort: priority (asc), availableAt (asc), insertion order (asc = FIFO)\n    eligible.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      const aAt = a.availableAt.getTime();\n      const bAt = b.availableAt.getTime();\n      if (aAt !== bAt) return aAt - bAt;\n      return (this.taskInsertOrder.get(a.id) ?? 0) - (this.taskInsertOrder.get(b.id) ?? 0);\n    });\n\n    const task = eligible[0];\n    task.status = 'processing';\n    task.attempts++;\n\n    // Track concurrency\n    const qi = this.ensureQueue(queueName);\n    qi.activeCount++;\n\n    return task;\n  }\n\n  private areDependenciesResolved(task: Task): boolean {\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (!dep || dep.status !== 'completed') return false;\n    }\n    return true;\n  }\n\n  private detectCycles(dependencies: string[]): void {\n    const visited = new Set<string>();\n    const visiting = new Set<string>();\n\n    const dfs = (taskId: string): void => {\n      if (visiting.has(taskId)) {\n        throw new Error('Circular dependency detected');\n      }\n      if (visited.has(taskId)) return;\n\n      visiting.add(taskId);\n      const task = this.tasks.get(taskId);\n      if (task) {\n        for (const depId of task.dependencies) {\n          dfs(depId);\n        }\n      }\n      visiting.delete(taskId);\n      visited.add(taskId);\n    };\n\n    for (const depId of dependencies) {\n      dfs(depId);\n    }\n  }\n\n  private copyTask(task: Task): Task {\n    return { ...task, dependencies: [...task.dependencies] };\n  }\n\n  // ─── Phase 5: Complete / Fail ─────────────────────────────────────────────\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task with status '${task.status}'`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Free concurrency slot\n    const qi = this.queueData.get(task.queue);\n    if (qi) qi.activeCount = Math.max(0, qi.activeCount - 1);\n\n    this.notifyShutdownWaiter();\n  }\n\n  fail(taskId: string, error?: string | Error): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task with status '${task.status}'`);\n    }\n\n    const errorMessage = error instanceof Error ? error.message : (error ?? 'Task failed');\n    task.error = errorMessage;\n    task.failCount++;\n\n    // Free concurrency slot\n    const qi = this.queueData.get(task.queue);\n    if (qi) qi.activeCount = Math.max(0, qi.activeCount - 1);\n\n    // Check retries: attempts includes this try, maxRetries is the number of retries\n    // With maxRetries=3: attempt 1 fails → 0 retries used (< 3), retry\n    //                    attempt 2 fails → 1 retry used (< 3), retry\n    //                    attempt 3 fails → 2 retries used (< 3), retry\n    //                    attempt 4 fails → 3 retries used (= 3), DLQ\n    const retriesUsed = task.attempts - 1;\n    if (retriesUsed < task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, retriesUsed);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.progress = 0;\n      task.progressMessage = undefined;\n    } else {\n      // No more retries → failed + DLQ\n      task.status = 'failed';\n      this.addToDeadLetterQueue(task);\n    }\n\n    this.notifyShutdownWaiter();\n  }\n\n  // ─── Phase 6: Dead Letter Queue ──────────────────────────────────────────\n\n  private addToDeadLetterQueue(task: Task): void {\n    if (!this.dlqIds.has(task.queue)) {\n      this.dlqIds.set(task.queue, new Set());\n    }\n    this.dlqIds.get(task.queue)!.add(task.id);\n  }\n\n  getDeadLetterTasks(queueName?: string): Task[] {\n    const queue = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    const ids = this.dlqIds.get(queue);\n    if (!ids || ids.size === 0) return [];\n    const result: Task[] = [];\n    for (const id of ids) {\n      const task = this.tasks.get(id);\n      if (task) result.push(this.copyTask(task));\n    }\n    return result;\n  }\n\n  retryDeadLetterTask(taskId: string): Task {\n    // Find the task in any DLQ\n    for (const [_queueName, ids] of this.dlqIds) {\n      if (ids.has(taskId)) {\n        const task = this.tasks.get(taskId);\n        if (!task) throw new Error(`Task '${taskId}' not found`);\n\n        ids.delete(taskId);\n\n        // Reset for fresh retry\n        task.status = 'pending';\n        task.attempts = 0;\n        task.error = undefined;\n        task.progress = 0;\n        task.progressMessage = undefined;\n        task.availableAt = new Date();\n\n        return this.copyTask(task);\n      }\n    }\n    throw new Error(`Task '${taskId}' not found in any dead letter queue`);\n  }\n\n  clearDeadLetterQueue(queueName?: string): void {\n    const queue = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    const ids = this.dlqIds.get(queue);\n    if (ids) {\n      for (const id of ids) {\n        this.tasks.delete(id);\n        this.taskInsertOrder.delete(id);\n      }\n      ids.clear();\n    }\n  }\n\n  // ─── Phase 7: Dependency status ───────────────────────────────────────────\n\n  getDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; pending: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n\n    const resolved: string[] = [];\n    const pending: string[] = [];\n\n    for (const depId of task.dependencies) {\n      const dep = this.tasks.get(depId);\n      if (dep && dep.status === 'completed') {\n        resolved.push(depId);\n      } else {\n        pending.push(depId);\n      }\n    }\n\n    return { dependencies: [...task.dependencies], resolved, pending };\n  }\n\n  // ─── Phase 8: Concurrency control ────────────────────────────────────────\n\n  setConcurrency(queueName: string, limit: number): void {\n    const qi = this.ensureQueue(queueName);\n    qi.concurrencyLimit = limit;\n  }\n\n  getConcurrency(queueName?: string): { limit: number; active: number } {\n    const queue = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    const qi = this.ensureQueue(queue);\n    return { limit: qi.concurrencyLimit, active: qi.activeCount };\n  }\n\n  // ─── Phase 9: Progress & Cancellation ─────────────────────────────────────\n\n  updateProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot update progress on task with status '${task.status}'`);\n    }\n\n    task.progress = Math.max(0, Math.min(100, progress));\n    if (message !== undefined) {\n      task.progressMessage = message;\n    }\n\n    // Notify listeners\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const callback of listeners) {\n        try { callback(task.progress, task.progressMessage); } catch (_e) { /* ignore */ }\n      }\n    }\n  }\n\n  getProgress(taskId: string): { percentage: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n    return { percentage: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, callback: ProgressCallback): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(callback);\n\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(callback);\n      }\n    };\n  }\n\n  cancel(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task '${taskId}' not found`);\n\n    if (task.status !== 'pending' && task.status !== 'processing') {\n      throw new Error(`Cannot cancel task with status '${task.status}'`);\n    }\n\n    const wasProcessing = task.status === 'processing';\n    task.status = 'cancelled';\n\n    if (wasProcessing) {\n      // Free concurrency slot\n      const qi = this.queueData.get(task.queue);\n      if (qi) qi.activeCount = Math.max(0, qi.activeCount - 1);\n    }\n\n    this.notifyShutdownWaiter();\n  }\n\n  // ─── Phase 10: Recurring Tasks (Cron) ─────────────────────────────────────\n\n  addSchedule(options: ScheduleOptions): Schedule {\n    const id = options.id ?? randomUUID();\n\n    // Validate cron expression\n    this.parseCron(options.cron);\n\n    const schedule: Schedule = {\n      id,\n      cron: options.cron,\n      queue: options.queue ?? TaskQueue.DEFAULT_QUEUE,\n      payload: options.payload,\n      taskOptions: options.taskOptions,\n    };\n\n    this.schedules.set(id, schedule);\n    return { ...schedule };\n  }\n\n  removeSchedule(scheduleId: string): boolean {\n    return this.schedules.delete(scheduleId);\n  }\n\n  getSchedules(): Schedule[] {\n    return [...this.schedules.values()].map(s => ({ ...s }));\n  }\n\n  tick(now?: Date): Task[] {\n    const currentTime = now ?? new Date();\n    const created: Task[] = [];\n\n    for (const schedule of this.schedules.values()) {\n      if (this.shouldRunSchedule(schedule, currentTime)) {\n        const task = this.addTask(\n          typeof schedule.payload === 'object' && schedule.payload !== null\n            ? JSON.parse(JSON.stringify(schedule.payload))\n            : schedule.payload,\n          {\n            queue: schedule.queue,\n            ...(schedule.taskOptions ?? {}),\n          }\n        );\n        created.push(task);\n        schedule.lastRun = new Date(currentTime.getTime());\n      }\n    }\n\n    return created;\n  }\n\n  private parseCron(expression: string): { minute: string; hour: string; dayOfMonth: string; month: string; dayOfWeek: string } {\n    const parts = expression.trim().split(/\\s+/);\n    if (parts.length !== 5) {\n      throw new Error(`Invalid cron expression: ${expression}`);\n    }\n    return {\n      minute: parts[0],\n      hour: parts[1],\n      dayOfMonth: parts[2],\n      month: parts[3],\n      dayOfWeek: parts[4],\n    };\n  }\n\n  private cronFieldMatches(field: string, value: number): boolean {\n    if (field === '*') return true;\n    if (field.startsWith('*/')) {\n      const interval = parseInt(field.slice(2), 10);\n      if (isNaN(interval) || interval <= 0) return false;\n      return value % interval === 0;\n    }\n    const num = parseInt(field, 10);\n    return !isNaN(num) && value === num;\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const cron = this.parseCron(schedule.cron);\n\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n\n    if (!this.cronFieldMatches(cron.minute, currentMinute)) return false;\n    if (!this.cronFieldMatches(cron.hour, currentHour)) return false;\n\n    // Check if already run for this time slot\n    if (schedule.lastRun) {\n      const lastSlot = new Date(schedule.lastRun);\n      lastSlot.setSeconds(0, 0);\n      const currentSlot = new Date(now);\n      currentSlot.setSeconds(0, 0);\n\n      if (lastSlot.getTime() >= currentSlot.getTime()) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  // ─── Phase 11: Middleware Pipeline ────────────────────────────────────────\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    const qi = this.ensureQueue(queueName);\n    qi.middleware.push(middleware);\n  }\n\n  process(queueName: string, handler: HandlerFn): void {\n    const qi = this.ensureQueue(queueName);\n    qi.handler = handler;\n  }\n\n  async processNext(queueName?: string): Promise<Task | null> {\n    const queue = queueName ?? TaskQueue.DEFAULT_QUEUE;\n    const task = this._dequeueTask(queue);\n    if (!task) return null;\n\n    const qi = this.queueData.get(queue);\n    const middleware = qi?.middleware ?? [];\n    const handler = qi?.handler;\n\n    try {\n      // Build and execute middleware chain\n      let index = 0;\n\n      const runNext = async (): Promise<void> => {\n        if (index < middleware.length) {\n          const mw = middleware[index++];\n          await mw(task, async () => {\n            await runNext();\n          });\n        } else if (handler) {\n          await handler(task);\n        }\n      };\n\n      await runNext();\n\n      // Auto-complete if still processing\n      if (task.status === 'processing') {\n        this.complete(task.id);\n      }\n    } catch (err) {\n      // Auto-fail if still processing\n      if (task.status === 'processing') {\n        this.fail(task.id, err instanceof Error ? err : new Error(String(err)));\n      }\n    }\n\n    return this.copyTask(task);\n  }\n\n  // ─── Phase 12: Graceful Shutdown ──────────────────────────────────────────\n\n  onShutdown(callback: () => void | Promise<void>): void {\n    this.shutdownCallbacks.push(callback);\n  }\n\n  get isShutdownActive(): boolean {\n    return this._isShutdown;\n  }\n\n  async shutdown(options?: { timeout?: number }): Promise<ShutdownSummary> {\n    if (this._shutdownPromise) {\n      return this._shutdownPromise;\n    }\n\n    this._isShutdown = true;\n    this._shutdownPromise = this._doShutdown(options?.timeout ?? 30000);\n    return this._shutdownPromise;\n  }\n\n  private async _doShutdown(timeout: number): Promise<ShutdownSummary> {\n    const startTime = Date.now();\n\n    // Run shutdown callbacks\n    for (const callback of this.shutdownCallbacks) {\n      try { await callback(); } catch (_e) { /* ignore */ }\n    }\n\n    // Snapshot currently processing tasks\n    const processingTaskIds: string[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        processingTaskIds.push(task.id);\n      }\n    }\n\n    if (processingTaskIds.length === 0) {\n      return { completed: 0, forceCancelled: 0, duration: Date.now() - startTime };\n    }\n\n    // Wait for processing tasks to finish (with timeout)\n    const allDone = await this._waitForProcessingTasks(processingTaskIds, timeout);\n\n    let completed = 0;\n    let forceCancelled = 0;\n\n    for (const id of processingTaskIds) {\n      const task = this.tasks.get(id);\n      if (task && task.status === 'processing') {\n        // Force cancel\n        task.status = 'cancelled';\n        const qi = this.queueData.get(task.queue);\n        if (qi) qi.activeCount = Math.max(0, qi.activeCount - 1);\n        forceCancelled++;\n      } else {\n        completed++;\n      }\n    }\n\n    return { completed, forceCancelled, duration: Date.now() - startTime };\n  }\n\n  private _waitForProcessingTasks(taskIds: string[], timeout: number): Promise<boolean> {\n    return new Promise<boolean>((resolve) => {\n      // Check immediately\n      if (this._allTasksDone(taskIds)) {\n        resolve(true);\n        return;\n      }\n\n      const timer = setTimeout(() => {\n        this._shutdownWaiter = null;\n        resolve(false);\n      }, timeout);\n\n      this._shutdownWaiter = () => {\n        if (this._allTasksDone(taskIds)) {\n          clearTimeout(timer);\n          this._shutdownWaiter = null;\n          resolve(true);\n        }\n      };\n    });\n  }\n\n  private _allTasksDone(taskIds: string[]): boolean {\n    for (const id of taskIds) {\n      const task = this.tasks.get(id);\n      if (task && task.status === 'processing') return false;\n    }\n    return true;\n  }\n}\n","structuredPatch":[{"oldStart":684,"oldLines":7,"newStart":684,"newLines":7,"lines":["     }"," ","     // Wait for processing tasks to finish (with timeout)","-    const allDone = await this._waitForProcessingTasks(processingTaskIds, timeout);","+    await this._waitForProcessingTasks(processingTaskIds, timeout);"," ","     let completed = 0;","     let forceCancelled = 0;"]}],"userModified":false,"replaceAll":false},"sourceToolAssistantUUID":"2a25c728-4b26-429c-9582-0d179cebf8d4"}
