s can target each task independently,\\n    // then verify clearing one queue's DLQ works\\n    const task1 = tq.addTask({ action: 'fail1' });\\n    const task2 = tq.addTask({ action: 'fail2' }, { queue: 'other' });\\n\\n    exhaustRetries(task1.id, 'default');\\n    exhaustRetries(task2.id, 'other');\\n\\n    expect(tq.getDeadLetterTasks('default')).toHaveLength(1);\\n    expect(tq.getDeadLetterTasks('other')).toHaveLength(1);\\n\\n    tq.clearDeadLetterQueue('default');\\n\\n    expect(tq.getDeadLetterTasks('default')).toHaveLength(0);\\n    expect(tq.getTask(task1.id)).toBeNull();\\n\\n    // Other queue's DLQ should be unaffected\\n    expect(tq.getDeadLetterTasks('other')).toHaveLength(1);\\n    expect(tq.getTask(task2.id)).not.toBeNull();\\n\\n    // Now clear the other DLQ too\\n    tq.clearDeadLetterQueue('other');\\n    expect(tq.getDeadLetterTasks('other')).toHaveLength(0);\\n    expect(tq.getTask(task2.id)).toBeNull();\\n  });\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":2094,\"cache_read_input_tokens\":36017,\"output_tokens\":1389,\"server_tool_use\":{\"web_search_requests\":0,\"web_fetch_requests\":0},\"service_tier\":\"standard\",\"cache_creation\":{\"ephemeral_1h_input_tokens\":0,\"ephemeral_5m_input_tokens\":2094},\"inference_geo\":\"\",\"iterations\":[],\"speed\":\"standard\"}},\"requestId\":\"req_011CYtfuKfonJr8k9vfq9P8C\",\"type\":\"assistant\",\"uuid\":\"8afd2058-e8fb-4b1b-a396-4b3450f17554\",\"timestamp\":\"2026-03-10T03:15:00.929Z\"}\n{\"parentUuid\":\"8afd2058-e8fb-4b1b-a396-4b3450f17554\",\"isSidechain\":true,\"userType\":\"external\",\"cwd\":\"/workspace\",\"sessionId\":\"7b80494b-48a1-4415-b468-129889149fd5\",\"version\":\"2.1.63\",\"gitBranch\":\"HEAD\",\"agentId\":\"ac73a490a71cac7dc\",\"slug\":\"dreamy-petting-quill\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"PostToolUse\",\"hookName\":\"PostToolUse: