d).toBe(dep.id);\\n\\n    // Now task is blocked because dep is processing (not completed)\\n    const next2 = tq.getNextTask();\\n    expect(next2).toBeNull();\\n  });\\n\\n  it('task becomes available when all dependencies complete', () => {\\n    const dep = tq.addTask({ action: 'dep' });\\n    const task = tq.addTask({ action: 'dependent' }, { dependencies: [dep.id] });\\n\\n    // Dequeue and complete the dependency\\n    const dequeuedDep = tq.getNextTask()!;\\n    expect(dequeuedDep.id).toBe(dep.id);\\n    tq.complete(dequeuedDep.id);\\n\\n    // Now the dependent task should be available\\n    const next = tq.getNextTask();\\n    expect(next).not.toBeNull();\\n    expect(next!.id).toBe(task.id);\\n  });\\n\\n  it('depending on non-existent task throws error', () => {\\n    expect(() => {\\n      tq.addTask({ action: 'main' }, { dependencies: ['non-existent-id'] });\\n    }).toThrow(\\\"Dependency task 'non-existent-id' does not exist\\\");\\n  });\\n\\n  it('circular dependencies are detected and rejected (self-reference scenario)', () => {\\n    // Since tasks can only depend on already-existing tasks, true cycles\\n    // are structurally impossible. However, we can verify that the dependency\\n    // chain resolution works correctly:\\n    // A -> B -> C (chain of dependencies works fine)\\n    const taskA = tq.addTask({ action: 'A' });\\n    const taskB = tq.addTask({ action: 'B' }, { dependencies: [taskA.id] });\\n    const taskC = tq.addTask({ action: 'C' }, { dependencies: [taskB.id] });\\n\\n    // taskC depends on taskB which depends on taskA\\n    expect(taskC.dependencies).toEqual([taskB.id]);\\n\\n    // A non-existent (self-referencing) task ID cannot be used as dependency\\n    // because the task doesn't exist yet when addTask is called\\n    expect(() => {\\n      tq.addTask({ action: 'self' }, { dependencies: ['will-not-exist'] });\\n    }).toThrow(\\\"Dependency task 'will-not-exist' does not exist\\\");\\n  });\\n\\n  it('failed dependency does NOT auto-fail dependents (they remain blocked)', () => {\\n    const dep = tq.addTask({ action: 'dep' }, { maxRetries: 0 });\\n    const task = tq.addTask({ action: 'dependent' }, { dependencies: [dep.id] });\\n\\n    // Process and fail the dependency (maxRetries=0, so first fail after attempt 1 goes to DLQ)\\n    const dequeuedDep = tq.getNextTask()!;\\n    tq.fail(dequeuedDep.id, 'dep failed');\\n\\n    // The dependent task should still be blocked (not auto-failed)\\n    const updated = tq.getTask(task.id);\\n    expect(updated!.status).toBe('pending');\\n\\n    // And it should not be dequeue-able since its dependency is not completed\\n    const next = tq.getNextTask();\\n    expect(next).toBeNull();\\n  });\\n\\n  it('getDependencyStatus returns correct status', () => {\\n    const dep1 = tq.addTask({ action: 'dep1' });\\n    const dep2 = tq.addTask({ action: 'dep2' });\\n    const task = tq.addTask({ action: 'main' }, { dependencies: [dep1.id, dep2.id] });\\n\\n    // Initially both pending\\n    let status = tq.getDependencyStatus(task.id);\\n    expect(status.dependencies).toEqual([dep1.id, dep2.id]);\\n    expect(status.resolved).toEqual([]);\\n    expect(status.pending).toEqual([dep1.id, dep2.id]);\\n\\n    // Complete dep1\\n    const d1 = tq.getNextTask()!;\\n    expect(d1.id).toBe(dep1.id);\\n    tq.complete(d1.id);\\n\\n    status = tq.getDependencyStatus(task.id);\\n    expect(status.resolved).toEqual([dep1.id]);\\n    expect(status.pending).toEqual([dep2.id]);\\n\\n    // Complete dep2\\n    const d2 = tq.getNextTask()!;\\n    expect(d2.id).toBe(dep2.id);\\n    tq.complete(d2.id);\\n\\n    status = tq.getDependencyStatus(task.id);\\n    expect(status.resolved).toEqual([dep1.id, dep2.id]);\\n    expect(status.pending).toEqual([]);\\n  });\\n\\n  it('multiple dependencies all must complete', () => {\\n    const dep1 = tq.addTask({ action: 'dep1' });\\n    const dep2 = tq.addTask({ action: 'dep2' });\\n    const dep3 = tq.addTask({ action: 'dep3' });\\n    const task = tq.addTask(\\n      { action: 'main' },\\n      { dependencies: [dep1.id, dep2.id, dep3.id] }\\n    );\\n\\n    // Complete dep1 only\\n    const d1 = tq.getNextTask()!;\\n    tq.complete(d1.id);\\n\\n    // Task should still be blocked\\n    // dep2 and dep3 are still pending (available to dequeue), but task itself is blocked\\n    const d2 = tq.getNextTask()!;\\n    expect([dep2.id, dep3.id]).toContain(d2.id);\\n    tq.complete(d2.id);\\n\\n    // Still one dependency not completed\\n    // The remaining dep should be next, not the dependent task\\n    const d3 = tq.getNextTask()!;\\n    expect([dep2.id, dep3.id]).toContain(d3.id);\\n\\n    // Task is still blocked (d3 is processing, not completed)\\n    const shouldBeNull = tq.getNextTask();\\n    expect(shouldBeNull).toBeNull();\\n\\n    // Complete last dependency\\n    tq.complete(d3.id);\\n\\n    // Now the dependent task should be available\\n    const finalTask = tq.getNextTask();\\n    expect(finalTask).not.toBeNull();\\n    expect(finalTask!.id).toBe(task.id);\\n  });\\n});\\n\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":103,\"cache_read_input_tokens\":22560,\"cache_creation\":{\"ephemeral_5m_input_tokens\":103,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":2,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"}},\"requestId\":\"req_011CYtfkqNjbmKzAJTnbk7ch\",\"type\":\"assistant\",\"uuid\":\"8ceaba11-84b1-410d-9558-37ae30a99c60\",\"timestamp\":\"2026-03-10T03:13:50.123Z\"}\n{\"parentUuid\":\"8ceaba11-84b1-410d-9558-37ae30a99c60\",\"isSidechain\":true,\"userType\":\"external\",\"cwd\":\"/workspace\",\"sessionId\":\"7b80494b-48a1-4415-b468-129889149fd5\",\"version\":\"2.1.63\",\"gitBranch\":\"HEAD\",\"agentId\":\"ac73a490a71cac7dc\",\"slug\":\"dreamy-petting-quill\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"PostToolUse\",\"hookName\":\