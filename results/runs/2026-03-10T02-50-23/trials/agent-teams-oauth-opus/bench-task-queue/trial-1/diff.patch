ot', () => {\\n    tq.setConcurrency('default', 1);\\n\\n    tq.addTask({ action: 'task1' });\\n    tq.addTask({ action: 'task2' });\\n\\n    const t1 = tq.getNextTask()!;\\n    expect(t1).not.toBeNull();\\n\\n    // Concurrency limit reached\\n    expect(tq.getNextTask()).toBeNull();\\n\\n    // Complete the task to free the slot\\n    tq.complete(t1.id);\\n\\n    const concurrency = tq.getConcurrency();\\n    expect(concurrency.active).toBe(0);\\n\\n    // Now another task can be dequeued\\n    const t2 = tq.getNextTask();\\n    expect(t2).not.toBeNull();\\n  });\\n\\n  it('failing a task frees a concurrency slot', () => {\\n    tq.setConcurrency('default', 1);\\n\\n    tq.addTask({ action: 'task1' });\\n    tq.addTask({ action: 'task2' });\\n\\n    const t1 = tq.getNextTask()!;\\n    expect(t1).not.toBeNull();\\n\\n    // Concurrency limit reached\\n    expect(tq.getNextTask()).toBeNull();\\n\\n    // Fail the task to free the slot\\n    tq.fail(t1.id, 'error');\\n\\n    const concurrency = tq.getConcurrency();\\n    expect(concurrency.active).toBe(0);\\n\\n    // Now another task can be dequeued\\n    const t2 = tq.getNextTask();\\n    expect(t2).not.toBeNull();\\n  });\\n\\n  it('getConcurrency returns limit and active count', () => {\\n    tq.setConcurrency('default', 3);\\n\\n    tq.addTask({ action: 'task1' });\\n    tq.addTask({ action: 'task2' });\\n    tq.addTask({ action: 'task3' });\\n\\n    expect(tq.getConcurrency()).toEqual({ limit: 3, active: 0 });\\n\\n    const t1 = tq.getNextTask()!;\\n    expect(tq.getConcurrency()).toEqual({ limit: 3, active: 1 });\\n\\n    const t2 = tq.getNextTask()!;\\n    expect(tq.getConcurrency()).toEqual({ limit: 3, active: 2 });\\n\\n    tq.complete(t1.id);\\n    expect(tq.getConcurrency()).toEqual({ limit: 3, active: 1 });\\n\\n    tq.complete(t2.id);\\n    expect(tq.getConcurrency()).toEqual({ limit: 3, active: 0 });\\n  });\\n\\n  it('concurrency interacts correctly with priority ordering', () => {\\n    tq.setConcurrency('default', 2);\\n\\n    // Add tasks with different priorities (lower number = higher priority)\\n    const low = tq.addTask({ action: 'low-priority' }, { priority: 8 });\\n    const high = tq.addTask({ action: 'high-priority' }, { priority: 1 });\\n    const mid = tq.addTask({ action: 'mid-priority' }, { priority: 5 });\\n\\n    // First dequeue should get highest priority (priority 1)\\n    const first = tq.getNextTask()!;\\n    expect(first.id).toBe(high.id);\\n    expect(first.priority).toBe(1);\\n\\n    // Second dequeue should get next highest (priority 5)\\n    const second = tq.getNextTask()!;\\n    expect(second.id).toBe(mid.id);\\n    expect(second.priority).toBe(5);\\n\\n    // Third dequeue should be blocked by concurrency\\n    const third = tq.getNextTask();\\n    expect(third).toBeNull();\\n\\n    // Complete one task, now lowest priority should come through\\n    tq.complete(first.id);\\n\\n    const fourth = tq.getNextTask()!;\\n    expect(fourth.id).toBe(low.id);\\n    expect(fourth.priority).toBe(8);\\n  });\\n});\\n\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":103,\"cache_read_input_tokens\":22560,\"output_tokens\":7186,\"server_tool_use\":{\"web_search_requests\":0,\"web_fetch_requests\":0},\"service_tier\":\"standard\",\"cache_creation\":{\"ephemeral_1h_input_tokens\":0,\"ephemeral_5m_input_tokens\":103},\"inference_geo\":\"\",\"iterations\":[],\"speed\":\"standard\"}},\"requestId\":\"req_011CYtfkqNjbmKzAJTnbk7ch\",\"type\":\"assistant\",\"uuid\":\"206e784d-a97a-4bcf-92f6-a8ad965182a0\",\"timestamp\":\"2026-03-10T03:14:04.549Z\"}\n{\"parentUuid\":\"206e784d-a97a-4bcf-92f6-a8ad965182a0\",\"isSidechain\":true,\"userType\":\"external\",\"cwd\":\"/workspace\",\"sessionId\":\"7b80494b-48a1-4415-b468-129889149fd5\",\"version\":\"2.1.63\",\"gitBranch\":\"HEAD\",\"agentId\":\"ac73a490a71cac7dc\",\"slug\":\"dreamy-petting-quill\",\"type\":\"p