  // Counter 0: x0 ≡ 1 (mod 3)\n    // Counter 1: x0 ≡ 2 (mod 3)\n    // Same button, different targets: impossible\n    const result = solveCounter([1, 2], [[0, 1]], 3);\n    // x0 affects both counters. x0=1 gives counter0=1, counter1=1 (need 2). No solution.\n    expect(result).toBeNull();\n  });\n});\n\ndescribe('edge cases', () => {","originalFile":"import { describe, it, expect } from 'vitest';\nimport { solveToggle, solveCounter, Machine } from './index.js';\n\n// Helper to verify a toggle solution\nfunction verifyToggle(machine: Machine, buttons: number[]): boolean {\n  const state = new Array(machine.target.length).fill(false);\n  for (const b of buttons) {\n    for (const light of machine.buttons[b]) {\n      state[light] = !state[light];\n    }\n  }\n  return state.every((s, i) => s === machine.target[i]);\n}\n\n// Helper to verify a counter solution\nfunction verifyCounter(lights: number[], buttons: number[][], modulus: number, presses: number[]): boolean {\n  const state = new Array(lights.length).fill(0);\n  for (let i = 0; i < buttons.length; i++) {\n    for (const counter of buttons[i]) {\n      state[counter] = (state[counter] + presses[i]) % modulus;\n    }\n  }\n  return state.every((s, i) => s === lights[i]);\n}\n\ndescribe('solveToggle', () => {\n  it('should return empty array when target is all off', () => {\n    const result = solveToggle({\n      target: [false, false, false],\n      buttons: [[0, 1], [1, 2], [0, 2]]\n    });\n    expect(result).toEqual([]);\n  });\n\n  it('should return null when no solution exists', () => {\n    // From the example in the spec\n    const result = solveToggle({\n      target: [true, true, false, true],\n      buttons: [[0, 1], [1, 2, 3], [0, 3]]\n    });\n    expect(result).toBeNull();\n  });\n\n  it('should solve simple single-button case', () => {\n    const result = solveToggle({\n      target: [true],\n      buttons: [[0]]\n    });\n    expect(result).toEqual([0]);\n  });\n\n  it('should solve two independent lights', () => {\n    const result = solveToggle({\n      target: [true, true],\n      buttons: [[0], [1]]\n    });\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('should find minimum presses', () => {\n    // Light 0 can be toggled by button 0 alone or buttons 1+2\n    // Target: light 0 on\n    const result = solveToggle({\n      target: [true, false],\n      buttons: [[0], [0, 1], [1]]\n    });\n    // Button 0 alone works (1 press). Buttons 1+2 also work (2 presses).\n    expect(result).toEqual([0]);\n  });\n\n  it('should handle overlapping buttons', () => {\n    const machine: Machine = {\n      target: [true, false, true],\n      buttons: [[0, 1], [1, 2]]\n    };\n    // Button 0: [on, on, off]\n    // Button 1: [off, on, on]\n    // Both: [on, off, on] ✓\n    const result = solveToggle(machine);\n    expect(result).toEqual([0, 1]);\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should return lex smallest when tied', () => {\n    // Two possible 1-button solutions\n    const machine: Machine = {\n      target: [true],\n      buttons: [[0], [0]] // both toggle light 0\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]); // lex smaller than [1]\n  });\n\n  it('should handle no buttons', () => {\n    expect(solveToggle({ target: [], buttons: [] })).toEqual([]);\n    expect(solveToggle({ target: [false], buttons: [] })).toEqual([]);\n    expect(solveToggle({ target: [true], buttons: [] })).toBeNull();\n  });\n\n  it('should handle larger puzzle', () => {\n    const machine: Machine = {\n      target: [true, true, true, true, true],\n      buttons: [\n        [0],    // button 0\n        [1],    // button 1\n        [2],    // button 2\n        [3],    // button 3\n        [4],    // button 4\n      ]\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0, 1, 2, 3, 4]);\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should handle puzzle with multiple solutions', () => {\n    const machine: Machine = {\n      target: [true, true, false],\n      buttons: [[0], [1], [0, 1], [2]]\n    };\n    // Button 0+1 works (2 presses), or button 2 alone (but 2 toggles light 2 which should be off)\n    // Actually: press 0 and 1: light 0 on, light 1 on, light 2 off. ✓ (2 presses)\n    // Press 2: light 0 on, light 1 on, light 2 off. Wait, button 2 toggles [0,1], gives [on, on, off]. ✓ (1 press)\n    const result = solveToggle(machine);\n    expect(result).toEqual([2]); // 1 press is better than 2\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('should handle redundant buttons', () => {\n    // Button 2 = Button 0 XOR Button 1\n    const machine: Machine = {\n      target: [true, false],\n      buttons: [[0], [1], [0, 1]]\n    };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]);\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n});\n\ndescribe('solveCounter', () => {\n  it('should return all zeros when target is all zeros', () => {\n    const result = solveCounter([0, 0], [[0], [1]], 3);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('should solve simple single-button case', () => {\n    const result = solveCounter([1], [[0]], 5);\n    expect(result).toEqual([1]);\n  });\n\n  it('should solve with modular wrapping', () => {\n    // Counter 0 needs value 3 (mod 5)\n    // Button 0 increments counter 0\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('should return null when no solution exists', () => {\n    // Counter 0 needs value 1, but no button affects it\n    const result = solveCounter([1, 0], [[], [1]], 3);\n    // Button 0 affects nothing, Button 1 affects counter 1\n    // Counter 0 can never be 1\n    expect(result).toBeNull();\n  });\n\n  it('should find minimum total presses', () => {\n    // Two counters, each needs value 1 (mod 5)\n    // Button 0 increments both counters\n    // Button 1 increments counter 0 only\n    // Button 2 increments counter 1 only\n    // Solution: press button 0 once (total = 1) vs buttons 1+2 (total = 2)\n    const result = solveCounter([1, 1], [[0, 1], [0], [1]], 5);\n    expect(result).toEqual([1, 0, 0]);\n  });\n\n  it('should handle mod 2 case', () => {\n    const result = solveCounter([1, 1], [[0], [1]], 2);\n    expect(result).toEqual([1, 1]);\n  });\n\n  it('should handle multiple solutions with lex tiebreaking', () => {\n    // Counter 0 needs value 1 (mod 3)\n    // Button 0 and Button 1 both increment counter 0\n    // Solutions: [1, 0] (total=1) and [0, 1] (total=1)\n    // Lex smallest: [0, 1]\n    const result = solveCounter([1], [[0], [0]], 3);\n    expect(result).toEqual([0, 1]);\n  });\n\n  it('should verify solution correctness', () => {\n    const lights = [2, 3];\n    const buttons = [[0, 1], [1]];\n    const modulus = 5;\n    const result = solveCounter(lights, buttons, modulus);\n    expect(result).not.toBeNull();\n    expect(verifyCounter(lights, buttons, modulus, result!)).toBe(true);\n  });\n\n  it('should handle no buttons with all zeros target', () => {\n    const result = solveCounter([0, 0], [], 3);\n    expect(result).toEqual([]);\n  });\n\n  it('should handle larger modulus', () => {\n    // With mod 97, test that the solver works\n    const result = solveCounter([50], [[0]], 97);\n    expect(result).toEqual([50]);\n  });\n\n  it('should handle system with free variables', () => {\n    // 1 counter, 3 buttons all affecting counter 0, mod 5\n    // x0 + x1 + x2 ≡ 2 (mod 5)\n    // Min total: 2 (e.g., [0, 0, 2] or [0, 2, 0] or [2, 0, 0])\n    // Lex smallest with total 2: [0, 0, 2]\n    const result = solveCounter([2], [[0], [0], [0]], 5);\n    expect(result).not.toBeNull();\n    expect(verifyCounter([2], [[0], [0], [0]], 5, result!)).toBe(true);\n    const total = result!.reduce((a, b) => a + b, 0);\n    expect(total).toBe(2);\n    expect(result).toEqual([0, 0, 2]);\n  });\n\n  it('should handle larger puzzle', () => {\n    const lights = [1, 2, 3];\n    const buttons = [[0, 1], [1, 2], [0, 2]];\n    const modulus = 7;\n    const result = solveCounter(lights, buttons, modulus);\n    expect(result).not.toBeNull();\n    expect(verifyCounter(lights, buttons, modulus, result!)).toBe(true);\n  });\n});\n\ndescribe('performance', () => {\n  it('toggle: 20 buttons 20 lights', () => {\n    const n = 20;\n    const buttons: number[][] = [];\n    const target: boolean[] = [];\n    for (let i = 0; i < n; i++) {\n      // Each button toggles light i and (i+1)%n\n      buttons.push([i, (i + 1) % n]);\n      target.push(i % 2 === 0);\n    }\n    const machine: Machine = { target, buttons };\n    const result = solveToggle(machine);\n    if (result !== null) {\n      expect(verifyToggle(machine, result)).toBe(true);\n    }\n  });\n\n  it('toggle: 30 buttons with many free vars', () => {\n    // Many buttons all toggle light 0 -> creates many free variables\n    const buttons: number[][] = [];\n    for (let i = 0; i < 30; i++) buttons.push([0]);\n    const machine: Machine = { target: [true], buttons };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]); // lex smallest 1-press solution\n  });\n\n  it('counter: 10 buttons 10 counters mod 7', () => {\n    const n = 10;\n    const mod = 7;\n    const lights: number[] = [];\n    const buttons: number[][] = [];\n    for (let i = 0; i < n; i++) {\n      buttons.push([i, (i + 1) % n]);\n      lights.push((i + 1) % mod);\n    }\n    const result = solveCounter(lights, buttons, mod);\n    if (result !== null) {\n      expect(verifyCounter(lights, buttons, mod, result)).toBe(true);\n    }\n  });\n\n  it('toggle: 35 buttons triggering meet-in-middle', () => {\n    // 35 buttons all toggle light 0 -> 34 free vars, triggers meet-in-middle\n    const buttons: number[][] = [];\n    for (let i = 0; i < 35; i++) buttons.push([0]);\n    const machine: Machine = { target: [true], buttons };\n    const result = solveToggle(machine);\n    expect(result).toEqual([0]); // lex smallest single-press solution\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('toggle: 40 buttons with 2 lights', () => {\n    const buttons: number[][] = [];\n    for (let i = 0; i < 20; i++) buttons.push([0]);\n    for (let i = 0; i < 20; i++) buttons.push([1]);\n    const machine: Machine = { target: [true, true], buttons };\n    const result = solveToggle(machine);\n    // Min presses = 2 (one from each group). Lex smallest: button 0 and button 20.\n    expect(result).toEqual([0, 20]);\n    expect(verifyToggle(machine, result!)).toBe(true);\n  });\n\n  it('counter: small free vars with large modulus', () => {\n    // 3 buttons, 1 counter, mod 97\n    // x0 + x1 + x2 ≡ 5 (mod 97)\n    const result = solveCounter([5], [[0], [0], [0]], 97);\n    expect(result).not.toBeNull();\n    expect(verifyCounter([5], [[0], [0], [0]], 97, result!)).toBe(true);\n    const total = result!.reduce((a, b) => a + b, 0);\n    expect(total).toBe(5);\n  });\n});\n\ndescribe('edge cases', () => {\n  it('toggle: single light single button - on', () => {\n    expect(solveToggle({ target: [true], buttons: [[0]] })).toEqual([0]);\n  });\n\n  it('toggle: single light single button - off', () => {\n    expect(solveToggle({ target: [false], buttons: [[0]] })).toEqual([]);\n  });\n\n  it('counter: zero-dimensional', () => {\n    expect(solveCounter([], [], 2)).toEqual([]);\n  });\n\n  it('counter: buttons that affect no counters', () => {\n    const result = solveCounter([0], [[], []], 3);\n    expect(result).toEqual([0, 0]);\n  });\n\n  it('toggle: many buttons same light', () => {\n    // 10 buttons all toggle light 0, target on\n    // Min: 1 press. Lex smallest: button 0.\n    const buttons = Array.from({ length: 10 }, () => [0]);\n    const result = solveToggle({ target: [true], buttons });\n    expect(result).toEqual([0]);\n  });\n\n  it('counter: identity matrix', () => {\n    // Each button affects exactly one counter. Direct solution.\n    const n = 5;\n    const mod = 7;\n    const lights = [1, 2, 3, 4, 5];\n    const buttons = Array.from({ length: n }, (_, i) => [i]);\n    const result = solveCounter(lights, buttons, mod);\n    expect(result).toEqual([1, 2, 3, 4, 5]);\n  });\n});\n","structuredPatch":[{"oldStart":304,"oldLines":6,"newStart":304,"newLines":49,"lines":["   });"," });"," ","+describe('counter tricky cases', () => {","+  it('should prefer lower value earlier in result (lex)', () => {","+    // 2 buttons, 1 counter, mod 5: x0 + x1 ≡ 3 (mod 5)","+    // Total 3: [0,3], [1,2], [2,1], [3,0]","+    // Lex smallest: [0, 3]","+    const result = solveCounter([3], [[0], [0]], 5);","+    expect(result).toEqual([0, 3]);","+  });","+","+  it('should handle when wrapping gives lower total', () => {","+    // 1 button, 1 counter, mod 5: x0 ≡ 4 (mod 5)","+    // x0 = 4. Total = 4.","+    const result = solveCounter([4], [[0]], 5);","+    expect(result).toEqual([4]);","+  });","+","+  it('should handle underdetermined system with optimization', () => {","+    // 3 buttons, 2 counters, mod 7","+    // Counter 0: x0 + x2 ≡ 3 (mod 7)","+    // Counter 1: x1 + x2 ≡ 5 (mod 7)","+    // Free var: x2. For x2=0: x0=3, x1=5, total=8","+    // For x2=3: x0=0, x1=2, total=5","+    // For x2=5: x0=5(=3-5+7), x1=0, total=10","+    // Minimum total should be 5 at [0, 2, 3]","+    const result = solveCounter([3, 5], [[0], [1], [0, 1]], 7);","+    expect(result).not.toBeNull();","+    expect(verifyCounter([3, 5], [[0], [1], [0, 1]], 7, result!)).toBe(true);","+    const total = result!.reduce((a, b) => a + b, 0);","+    expect(total).toBe(5);","+    expect(result).toEqual([0, 2, 3]);","+  });","+","+  it('counter: inconsistent system', () => {","+    // Two counters that can never both be satisfied","+    // Counter 0: x0 ≡ 1 (mod 3)","+    // Counter 1: x0 ≡ 2 (mod 3)","+    // Same button, different targets: impossible","+    const result = solveCounter([1, 2], [[0, 1]], 3);","+    // x