+  const entries = Array.from(h1Map.values());
+  let bestW = m + 1;
+  let bestSol = 0n;
+
+  for (let mask2 = 0; mask2 < (1 << h2); mask2++) {
+    let sol2 = 0n, w2 = 0;
+    const mb2 = BigInt(mask2);
+    for (let fi = 0; fi < h2; fi++) {
+      if ((mask2 >> fi) & 1) { sol2 |= 1n << BigInt(freeVars[h1 + fi]); w2++; }
+    }
+    let sig2 = 0n;
+    for (let k = 0; k < nP; k++) {
+      if (popcount64(mb2 & (pivotDeps[k] >> BigInt(h1))) & 1) sig2 |= 1n << BigInt(k);
+    }
