R p2_mask.\n  // We want popcount(target_mask XOR p1_mask) + w1 minimized.\n  // For each stored (p1_mask, w1, solution1), compute popcount(target_mask XOR p1_mask) + w1.\n  //\n  // Since there are at most 2^20 stored entries and 2^20 second-half entries,\n  // and for each second-half we'd need to scan all first-half entries,\n  // this is 2^40 operations. Too slow.\n  //\n  // Better approach: group first-half entries by p1_mask. For each unique p1_mask,\n  // keep only the best (w1, solution). Then for each second-half entry,\n  // iterate over all unique p1_masks and find the best total.\n  //\n  // The number of unique p1_masks is at most 2^(half1), but in practice much smaller\n  // because only some pivots depend on half1 free vars.\n  //\n  // Let me try yet another approach: if numFree > 25, we can try to reduce the problem\n  // by choosing a different pivoting strategy that minimizes free variables.\n  // Actually, Gaussian elimination already finds the rank, and free vars = m - rank.\n  // The rank is at most n (number of lights), so free vars >= m - n.\n  // With m = 40 and n = 40, free vars could be 0. The worst case for free vars\n  // is when rank is small, e.g., m=40, rank=0 (no equations constrain the buttons,\n  // which would mean all target is false).\n  //\n  // In practice, for the given constraints, let me just handle the general case.\n  // I'll implement a meet-in-the-middle approach that works when signatures are manageable.\n\n  // Split deps for each pivot into half1 and half2\n  const numPivots = pivotCol.length;\n\n  // Build p1 deps mask and p2 deps mask for each pivot\n  // pivotDeps[k] is a bitmask over freeVars indices (0..numFree-1)\n  // Half1: indices 0..half1-1, Half2: indices half1..numFree-1\n\n  const pivotConstMask = buildPivotConstMask(pivotConst, numPivots);\n\n  // First half enumeration\n  type HalfResult = { w: number; sol: bigint; p1Mask: bigint };\n  const half1Map = new Map<string, HalfResult>(); // p1Mask -> best result\n\n  const total1 = 1 << half1;\n  for (let mask = 0; mask < total1; mask++) {\n    let sol = 0n;\n    let w = 0;\n    const maskBig = BigInt(mask);\n\n    // Set free variables for first half\n    for (let fi = 0; fi < half1; fi++) {\n      if ((mask >> fi) & 1) {\n        sol |= 1n << BigInt(freeVars[fi]);\n        w++;\n      }\n    }\n\n    // Compute p1_mask: parity contribution from half1 free vars to each pivot\n    let p1Mask = 0n;\n    for (let k = 0; k < numPivots; k++) {\n      // Extract bits 0..half1-1 from pivotDeps[k]\n      const half1Deps = pivotDeps[k] & ((1n << BigInt(half1)) - 1n);\n      let bits = maskBig & half1Deps;\n      let parity = 0;\n      while (bits > 0n) {\n        parity ^= 1;\n        bits &= bits - 1n;\n      }\n      if (parity) {\n        p1Mask |= 1n << BigInt(k);\n      }\n    }\n\n    const key = p1Mask.toString(36);\n    const existing = half1Map.get(key);\n    if (!existing || w < existing.w || (w === existing.w && compareLex(sol, existing.sol, m) < 0)) {\n      half1Map.set(key, { w, sol, p1Mask });\n    }\n  }\n\n  // Second half enumeration\n  let bestWeight = m + 1;\n  let bestSolution = -1n;\n\n  const total2 = 1 << half2;\n  for (let mask2 = 0; mask2 < total2; mask2++) {\n    let sol2 = 0n;\n    let w2 = 0;\n    const maskBig2 = BigInt(mask2);\n\n    // Set free variables for second half\n    for (let fi = 0; fi < half2; fi++) {\n      if ((mask2 >> fi) & 1) {\n        sol2 |= 1n << BigInt(freeVars[half1 + fi]);\n        w2++;\n      }\n    }\n\n    // Compute p2_mask\n    let p2Mask = 0n;\n    for (let k = 0; k < numPivots; k++) {\n      const half2Deps = pivotDeps[k] >> BigInt(half1);\n      let bits = maskBig2 & half2Deps;\n      let parity = 0;\n      while (bits > 0n) {\n        parity ^= 1;\n        bits &= bits - 1n;\n      }\n      if (parity) {\n        p2Mask |= 1n << BigInt(k);\n      }\n    }\n\n    // For each first-half entry, compute total weight\n    for (const [, entry] of half1Map) {\n      //