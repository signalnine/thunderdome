+        const k = aff[i];
+        pivotPartial[k] = (saved[i] + (pCoeffs[k][idx] * v) % modulus) % modulus;
+      }
+
+      // Add costs of pivots determined at this index
+      let addedCost = 0;
+      for (const k of pivotsAtIdx[idx]) {
+        addedCost += ((pConst[k] - pivotPartial[k]) % modulus + modulus) % modulus;
+      }
+
+      const newTotal = runningTotal + v + addedCost;
+      if (newTotal <= bestTotal) {
+        search(idx + 1, newTotal);
+      }
+    }
+
+    // Restore affected partial sums
+    for (let i = 0; i < aff.length; i++) pivotPartial[aff[i]] = saved[i];
+    freeVals[idx] = 0;
+  };
+
+  search(0, baseCost);
+  return bestResult;
+}
+
+function computeInverses(p: number): number[] {
+  const inv = new Array(p).fill(0);
+  if (p <= 1) return inv;
+  inv[1] = 1;
+  for (let i = 2; i < p; i++) {
+    inv[i] = (p - ((Math.floor(p / i) * inv[p % i]) % p)) % p;
+  }
+  return inv;
+}
+
+function counterResult(
+  fv: number[], fvIdx: number[], pCols: number[],
+  pC: number[], pCoeffs: number[][],
+  nF: number, nP: number, m: number, mod: number
+): number[] {
+  const r = new Array(m).fill(0);
+  for (let fi = 0; fi < nF; fi++) r[fvIdx[fi]] = fv[fi];
+  for (let k = 0; k < nP; k++) {
+    let val = pC[k];
+    for (let fi = 0; fi < nF; fi++) {
+      val = ((val - (pCoeffs[k][fi] * fv[fi]) % mod) % mod + mod) % mod;
+    }
+    r[pCols[k]] = val;
+  }
+  return r;
+}
+
+function lexCmp(a: number[], b: number[]): number {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return -1;
+    if (a[i] > b[i]) return 1;
+  }
+  return 0;
+}
