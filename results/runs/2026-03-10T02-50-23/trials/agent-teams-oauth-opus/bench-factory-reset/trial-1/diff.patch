\n    34→  // Then do Gaussian elimination to reduce.\n    35→\n    36→  // Build matrix: rows = lights, cols = buttons\n    37→  // row[i] has bit j set if button j affects light i\n    38→  // augmented bit = target[i]\n    39→\n    40→  // Use BigInt for bitmasks since m can be up to 40\n    41→  const rows: bigint[] = new Array(n);\n    42→  const targetBits: number[] = new Array(n);\n    43→\n    44→  for (let i = 0; i < n; i++) {\n    45→    let row = 0n;\n    46→    for (let j = 0; j < m; j++) {\n    47→      if (buttons[j].includes(i)) {\n    48→        row |= 1n << BigInt(j);\n    49→      }\n    50→    }\n    51→    rows[i] = row;\n    52→    targetBits[i] = target[i] ? 1 : 0;\n    53→  }\n    54→\n    55→  // Gaussian elimination over GF(2)\n    56→  // We'll track pivot columns and reduce the system\n    57→  const pivotRow: number[] = []; // pivotRow[col] = row index that has pivot at this column\n    58→  const pivotCol: number[] = []; // ordered list of pivot columns\n    59→  const usedRow = new Set<number>();\n    60→\n    61→  for (let col = 0; col < m; col++) {\n    62→    // Find a row with a 1 in this column that hasn't been used as pivot\n    63→    let found = -1;\n    64→    for (let row = 0; row < n; row++) {\n    65→      if (!usedRow.has(row) && ((rows[row] >> BigInt(col)) & 1n) === 1n) {\n    66→        found = row;\n    67→        break;\n    68→      }\n    69→    }\n    70→    if (found === -1) continue; // free variable\n    71→\n    72→    usedRow.add(found);\n    73→    pivotCol.push(col);\n    74→    pivotRow.push(found);\n    75→\n    76→    // Eliminate this column from all other rows\n    77→    for (let row = 0; row < n; row++) {\n    78→      if (row !== found && ((rows[row] >> BigInt(col)) & 1n) === 1n) {\n    79→        rows[row] ^= rows[found];\n    80→        targetBits[row] ^= targetBits[found];\n    81→      }\n    82→    }\n    83→  }\n    84→\n    85→  // Check consistency: any row that's all zeros but target is 1 means no solution\n    86→  for (let row = 0; row < n; row++) {\n    87→    if (rows[row] === 0n && targetBits[row] === 1) {\n    88→      return null;\n    89→    }\n    90→  }\n    91→\n    92→  // Now we have a reduced system. Pivot columns are determined by free variables.\n    93→  // Free variables are columns not in pivotCol.\n    94→  const pivotColSet = new Set(pivotCol);\n    95→  const freeVars: number[] = [];\n    96→  for (let col = 0; col < m; col++) {\n    97→    if (!pivotColSet.has(col)) {\n    98→      freeVars.push(col);\n    99→    }\n   100→  }\n   101→\n   102→  // For each assignment of free variables, compute the determined variables\n   103→  // and find the solution with minimum weight, then lex smallest.\n   104→  // Number of free variables can be up to 40, so we can't enumerate all 2^40.\n   105→  // But in practice, with up to 40 buttons and 40 lights, the number of free\n   106→  // variables should be manageable... actually it could be up to 40.\n   107→\n   108→  // We need a smarter approach. Let's think about this as an optimization problem.\n   109→  // After GE, each pivot variable is determined by the free variables:\n   110→  //   x_pivot = target_pivot XOR (sum of coefficients * free vars)\n   111→  // We want to minimize the total number of 1s across all variables.\n   112→\n   113→  // Build the dependency: for each pivot variable, express it in terms of free vars.\n   114→  // pivotCol[k] is determined by pivotRow[k]:\n   115→  //   x_{pivotCol[k]} = targetBits[pivotRow[k]] XOR (XOR of x_j for j in freeVars where row has bit j)\n   116→\n   117→  // Create a mapping: for each pivot, the set of free variables it depends on\n   118→  const pivotDeps: bigint[] = new Array(pivotCol.length); // bitmask over freeVars indices\n   119→  const pivotConst: number[] = new Array(pivotCol.length);\n   120→\n   121→  for (let k = 0; k < pivotCol.length; k++) {\n   122→    const row = pivotRow[k];\n   123→    let deps = 0n;\n   124→    for (let fi = 0; fi < freeVars.length; fi++) {\n   125→      if ((rows[row] >> BigInt(freeVars[fi]) & 1n) === 1n) {\n   126→        deps |= 1n << BigInt(fi);\n   127→      }\n   128→    }\n   129→    pivotDeps[k] = deps;\n   130→    pivotConst[k] = targetBits[row];\n   131→  }\n   132→\n   133→  const numFree = freeVars.length;\n   134→\n   135→  // If numFree <= 20, we can enumerate all 2^numFree combinations.\n   136→  // For larger, we need a different approach.\n   137→  // With up to 40 buttons and 40 lights, free vars could be up to 40.\n   138→  // But 2^20 = ~1M which is fine. For > 20, we use meet-in-the-middle.\n   139→\n   140→  if (numFree <= 22) {\n   141→    return solveByEnumeration(numFree, freeVars, pivotCol, pivotDeps, pivotConst, m);\n   142→  } else {\n   143→    return solveByMeetInMiddle(numFree, freeVars, pivotCol, pivotDeps, pivotConst, m);\n   144→  }\n   145→}\n   146→\n   147→function solveByEnumeration(\n   148→  numFree: number,\n   149→  freeVars: number[],\n   150→  pivotCol: number[],\n   151→  pivotDeps: bigint[],\n   152→  pivotConst: number[],\n   153→  m: number\n   154→): number[] | null {\n   155→  let bestWeight = m + 1;\n   156→  let bestSolution: bigint = -1n;\n   157→\n   158→  const total = 1 << numFree;\n   159→  for (let mask = 0; mask < total; mask++) {\n   160→    let solution = 0n;\n   161→    let weight = 0;\n   162→    const maskBig = BigInt(mask);\n   163→\n   164→    // Set free variables\n   165→    for (let fi = 0; fi < numFree; fi++) {\n   166→      if ((mask >> fi) & 1) {\n   167→        solution |= 1n << BigInt(freeVars[fi]);\n   168→        weight++;\n   169→      }\n   170→    }\n   171→\n   172→    // Compute pivot variables\n   173→    for (let k = 0; k < pivotCol.length; k++) {\n   174→      // Count bits in (maskBig & pivotDeps[k])\n   175→      let depBits = maskBig & pivotDeps[k];\n   176→      let parity = pivotConst[k];\n   177→      while (depBits > 0n) {\n   178→        parity ^= 1;\n   179→        depBits &= depBits - 1n;\n   180→      }\n   181→      if (parity) {\n   182→        solution |= 1n << BigInt(pivotCol[k]);\n   183→        weight++;\n   184→      }\n   185→    }\n   186→\n   187→    if (weight < bestWeight || (weight === bestWeight && compareLex(solution, bestSolution, m) < 0)) {\n   188→      bestWeight = weight;\n   189→      bestSolution = solution;\n   190→    }\n   191→  }\n   192→\n   193→  if (bestSolution === -1n) return null;\n   194→\n   195→  const result: number[] = [];\n   196→  for (let i = 0; i < m; i++) {\n   197→    if ((bestSolution >> BigInt(i) & 1n) === 1n) {\n   198→      result.push(i);\n   199→    }\n   200→  }\n   201→  return result;\n   202→}\n   203→\n   204→function compareLex(a: bigint, b: bigint, m: number): number {\n   205→  // Compare two solutions lexicographically by their button index sets.\n   206→  // The lex smallest set is determined by comparing from the smallest index.\n   207→  // Actually, for sets: {0,2} < {1} because we compare element by element.\n   208→  // A set with a smaller first element is lex smaller. If same first, compare second, etc.\n   209→  // Equivalently, compare the bitmasks: extract bits from LSB.\n   210→  // The set with fewer elements when both have same first element... it's complex.\n   211→  //\n   212→  // Lex comparison of sorted arrays: compare element by element.\n   213→  // {0, 2} vs {1}: 0 < 1, so {0,2} is smaller.\n   214→  // {0, 2} vs {0, 1}: 0==0, then 2 > 1, so {0,1} is smaller.\n   215→  // {0} vs {0, 1}: 0==0, then {0} has no more elements, so {0} is smaller.\n   216→  //\n   217→  // Given bitmasks, compare from LSB:\n   218→  // Find the lowest bit where they differ.\n   219→  const diff = a ^ b;\n   220→  if (diff === 0n) return 0;\n   221→  // Lowest differing bit\n   222→  const lowestDiff = diff & (-diff);\n   223→  // If a has this bit set but b doesn't: a has an extra element at this position\n   224→  // If it's in a but not b:\n   225→  //   - If a has more 1s below this position... no, the bits below are the same.\n   226→  //   All bits below lowestDiff are the same in a and b.\n   227→  //   At lowestDiff: one has it, the other doesn't.\n   228→  //   The one that has the smaller set at this point depends:\n   229→  //   - If a has it (and b doesn't): a includes this button index but b doesn't.\n   230→  //     For lex comparison of sets: having an extra element earlier...\n   231→  //     Wait, we need to be more careful.\n   232→  //\n   233→  //   Actually, lex comparison of sorted arrays:\n   234→  //   Let's think about it as: build the sorted arrays and compare.\n   235→  //   Since bits are from position 0 upward, the sorted array is just the set bits in order.\n   236→  //\n   237→  //   At the lowest differing bit position p:\n   238→  //   - All elements below p are the same in both sets (since lower bits are identical)\n   239→  //   - One set has p, the other doesn't\n   240→  //   - If a has p and b doesn't: a's next element is p.\n   241→  //     b's next element is either > p or b has no more elements at this position.\n   242→  //     If b has a next element > p: a is lex smaller (p < b's next element)\n   243→  //     If b has no more elements: a is lex larger (longer set)\n   244→  //   - If b has p and a doesn't: symmetric\n   245→  //\n   246→  //   Hmm wait, this is tricky. Let me reconsider.\n   247→  //\n   248→  //   Actually the problem says \"fewest button presses first, then lex smallest set of indices.\"\n   249→  //   Since we already handle fewest first, for lex tiebreaking among same-size sets:\n   250→  //\n   251→  //   For same-size sets, lex smallest means: the set whose sorted representation is\n   252→  //   lex smallest. For same-size sets, the lowest differing bit determines it:\n   253→  //   the set that has the bit set is lex smaller (because it has the smaller index).\n   254→  //   Wait no - if a has bit p set and b doesn't, and they're same size,\n   255→  //   then b must have some higher bit set instead. So a has p and b has something > p\n   256→  //   at the same position in the sorted array. So a is lex smaller.\n   257→  //\n   258→  //   But for DIFFERENT size sets (which shouldn't happen since we filter by weight first):\n   259→  //   it's more complex. Since we already filter by weight, let's just handle same-size.\n   260→\n   261→  if ((a & lowestDiff) !== 0n) {\n   262→    // a has this bit, b doesn't.\n   263→    // For same-weight solutions: a has a smaller element here, so a is lex smaller.\n   264→    return -1;\n   265→  } else {\n   266→    return 1;\n   267→  }\n   268→}\n   269→\n   270→function solveByMeetInMiddle(\n   271→  numFree: number,\n   272→  freeVars: number[],\n   273→  pivotCol: number[],\n   274→  pivotDeps: bigint[],\n   275→  pivotConst: number[],\n   276→  m: number\n   277→): number[] | null {\n   278→  // Split free variables into two halves\n   279→  const half1 = Math.floor(numFree / 2);\n   280→  const half2 = numFree - half1;\n   281→\n   282→  // For each assignment of the first half, compute the contribution to each pivot\n   283→  // variable. Store a map from the \"pivot effect\" signature to the best (weight, solution).\n   284→\n   285→  // The pivot variable value is: pivotConst[k] XOR popcount(freeMask & pivotDeps[k])\n   286→  // We want to find combinations of first-half and second-half free var assignments\n   287→  // that together give the right pivot values.\n   288→\n   289→  // Actually, for meet-in-the-middle, we need to decompose the problem.\n   290→  // Each pivot depends on some free vars from half1 and some from half2.\n   291→  // pivot_val[k] = pivotConst[k] XOR parity(half1_free & deps1[k]) XOR parity(half2_free & deps2[k])\n   292→  // We want pivot_val[k] to be whatever it needs to be.\n   293→  //\n   294→  // Actually, the total weight = (free vars set in half1) + (free vars set in half2) + (pivot vars that are 1)\n   295→  // And each pivot var depends on both halves. So we can't cleanly separate.\n   296→  //\n   297→  // Alternative approach: use ILP or a smarter algorithm.\n   298→  // But for the constraint (up to 40 buttons, 40 lights), the number of free variables\n   299→  // is m - rank(A) which could be large.\n   300→  //\n   301→  // Let me reconsider. With 40 lights and 40 buttons, rank can be at most 40,\n   302→  // so free vars can be 0 to 40. For 40 free vars this is 2^40 which is too much\n   303→  // even for meet-in-the-middle on one criterion.\n   304→  //\n   305→  // For meet-in-the-middle:\n   306→  // Split free vars into two halves of ~20 each.\n   307→  // For each half1 assignment, compute:\n   308→  //   - partial parity for each pivot (from half1 free vars)\n   309→  //   - weight contribution from half1 free vars\n   310→  //   - partial weight from pivots (not fully determined yet since they depend on half2 too)\n   311→  //\n   312→  // The issue is that pivot values depend on BOTH halves, so we can't compute pivot weight\n   313→  // independently per half.\n   314→  //\n   315→  // Key insight: Each pivot's value is pivotConst[k] XOR parity(half1_bits & deps1[k]) XOR parity(half2_bits & deps2[k])\n   316→  // Let's define for each pivot k:\n   317→  //   p1[k] = parity(half1_bits & deps1[k])  -- contribution from first half\n   318→  //   p2[k] = parity(half2_bits & deps2[k])  -- contribution from second half\n   319→  //   pivot_val[k] = pivotConst[k] XOR p1[k] XOR p2[k]\n   320→  //   pivot weight contribution = sum of pivot_val[k] for all k\n   321→  //\n   322→  // So total weight = w1(free) + w2(free) + sum_k(pivotConst[k] XOR p1[k] XOR p2[k])\n   323→  // where w1, w2 are the popcount of the free variable assignments in each half.\n   324→  //\n   325→  // The pivot signature from half1 can be represented as a bitmask of p1[k] values.\n   326→  // There are at most 40 pivots, so this is a 40-bit signature.\n   327→  // For each half1 assignment, we compute (signature, w1 + partial_pivot_weight).\n   328→  //\n   329→  // Wait, the pivot weight depends on both halves. Let me think more carefully.\n   330→  //\n   331→  // For a given (p1_signature, p2_signature):\n   332→  //   pivot_val[k] = pivotConst[k] XOR p1[k] XOR p2[k]\n   333→  //   total pivot weight = sum_k (pivotConst[k] XOR p1[k] XOR p2[k])\n   334→  //\n   335→  // We can precompute for each p1_signature:\n   336→  //   For each possible p2_signature, the total pivot weight.\n   337→  //   But that's 2^(num_pivots) * 2^(num_pivots) combinations for the signature space.\n   338→  //\n   339→  // Better: for a given p1, the total weight is:\n   340→  //   w1 + w2 + popcount(pivotConstMask XOR p1_mask XOR p2_mask)\n   341→  //   where pivotConstMask is the bitmask of pivotConst values.\n   342→  //\n   343→  // So: total = w1 + w2 + popcount(combined_mask XOR p2_mask)\n   344→  //   where combined_mask = pivotConstMask XOR p1_mask\n   345→  //\n   346→  // For the first half: compute (combined_mask, w1) for each half1 assignment.\n   347→  // For the second half: compute (p2_mask, w2) for each half2 assignment.\n   348→  // We want to minimize w1 + w2 + popcount(combined_mask XOR p2_mask).\n   349→  //\n   350→  // Group first-half results by combined_mask. For each combined_mask value,\n   351→  // keep the best (smallest w1, lex smallest solution).\n   352→  //\n   353→  // Then for each second-half assignment (p2_mask, w2), and for each first-half\n   354→  // combined_mask, compute total = w1 + w2 + popcount(combined_mask XOR p2_mask).\n   355→  //\n   356→  // But iterating over all combined_mask values for each second-half is still potentially\n   357→  // 2^(numPivots) * 2^(half2), which could be huge.\n   358→  //\n   359→  // However, there are only 2^(half1) distinct combined_mask values (at most ~2^20).\n   360→  // And 2^(half2) is also ~2^20. So worst case ~2^40 comparisons, still too many.\n   361→  //\n   362→  // Alternative: for each fixed combined_mask, we want p2_mask to minimize\n   363→  // popcount(combined_mask XOR p2_mask) + w2.\n   364→  //\n   365→  // Hmm, this is essentially a min-weight codeword problem which is NP-hard in general.\n   366→  // But with the structure we have, let me try a different approach.\n   367→  //\n   368→  // Actually, for practical cases the number of free variables tends to be small.\n   369→  // Let me just handle up to ~25 by enumeration (2^25 ≈ 33M, borderline for 5 seconds)\n   370→  // and use meet-in-the-middle for larger cases.\n   371→  //\n   372→  // For meet-in-the-middle with the pivot complication, let me try:\n   373→  // Enumerate first half (2^20), store results grouped by p1_signature (bitmask of pivot parities).\n   374→  // Enumerate second half (2^20), and for each, iterate over possible p1_signatures.\n   375→  // But with up to 40 pivots, there are potentially 2^40 signatures...\n   376→  //\n   377→  // Actually, the p1_signature only has bits for pivots that actually depend on half1 free vars.\n   378→  // Similarly for p2. In practice, many pivots may not depend on any free vars at all\n   379→  // (they're just pivotConst). Let me think about the maximum possible distinct signatures.\n   380→  // Each half1 assignment generates a signature based on parities of subsets of half1 free vars.\n   381→  // The signature space is at most 2^(half1) but also at most 2^(numPivots).\n   382→  //\n   383→  // Actually, the number of DISTINCT p1_signatures is at most 2^(rank of the deps1 matrix),\n   384→  // which is at most min(half1, numPivots). And similarly for p2.\n   385→  //\n   386→  // Let me just implement this: for each second-half assignment, compute the p2_mask,\n   387→  // then we need to find a first-half assignment with combined_mask = pivotConstMask XOR p1_mask\n   388→  // such that popcount(combined_mask XOR p2_mask) + w1 is minimized.\n   389→  // Equivalently, find p1_mask such that popcount(pivotConstMask XOR p1_mask XOR p2_mask) + w1 is min.\n   390→  // Let target_mask = pivotConstMask XOR p2_mask.\n   391→  // We want popcount(target_mask XOR p1_mask) + w1 minimized.\n   392→  // For each stored (p1_mask, w1, solution1), compute popcount(target_mask XOR p1_mask) + w1.\n   393→  //\n   394→  // Since there are at most 2^20 stored entries and 2^20 second-half entries,\n   395→  // and for each second-half we'd need to scan all first-half entries,\n   396→  // this is 2^40 operations. Too slow.\n   397→  //\n   398→  // Better approach: group first-half entries by p1_mask. For each unique p1_mask,\n   399→  // keep only the best (w1, solution). Then for each second-half entry,\n   400→  // iterate over all unique p1_masks and find the best total.\n   401→  //\n   402→  // The number of unique p1_masks is at most 2^(half1), but in practice much smaller\n   403→  // because only some pivots depend on half1 free vars.\n   404→  //\n   405→  // Let me try yet another approach: if numFree > 25, we can try to reduce the problem\n   406→  // by choosing a different pivoting strategy that minimizes free variables.\n   407→  // Actually, Gaussian elimination already finds the rank, and free vars = m - rank.\n   408→  // The rank is at most n (number of lights), so free vars >= m - n.\n   409→  // With m = 40 and n = 40, free vars could be 0. The worst case for free vars\n   410→  // is when rank is small, e.g., m=40, rank=0 (no equations constrain the buttons,\n   411→  // which would mean all target is false).\n   412→  //\n   413→  // In practice, for the given constraints, let me just handle the general case.\n   414→  // I'll implement a meet-in-the-middle approach that works when signatures are manageable.\n   415→\n   416→  // Split deps for each pivot into half1 and half2\n   417→  const numPivots = pivotCol.length;\n   418→\n   419→  // Build p1 deps mask and p2 deps mask for each pivot\n   420→  // pivotDeps[k] is a bitmask over freeVars indices (0..numFree-1)\n   421→  // Half1: indices 0..half1-1, Half2: indices half1..numFree-1\n   422→\n   423→  const pivotConstMask = buildPivotConstMask(pivotConst, numPivots);\n   424→\n   425→  // First half enumeration\n   426→  type HalfResult = { w: number; sol: bigint; p1Mask: bigint };\n   427→  const half1Map = new Map<string, HalfResult>(); // p1Mask -> best result\n   428→\n   429→  const total1 = 1 << half1;\n   430→  for (let mask = 0; mask < total1; mask++) {\n   431→    let sol = 0n;\n   432→    let w = 0;\n   433→    const maskBig = BigInt(mask);\n   434→\n   435→    // Set free variables for first half\n   436→    for (let fi = 0; fi < half1; fi++) {\n   437→      if ((mask >> fi) & 1) {\n   438→        sol |= 1n << BigInt(freeVars[fi]);\n   439→        w++;\n   440→      }\n   441→    }\n   442→\n   443→    // Compute p1_mask: parity contribution from half1 free vars to each pivot\n   444→    let p1Mask = 0n;\n   445→    for (let k = 0; k < numPivots; k++) {\n   446→      // Extract bits 0..half1-1 from pivotDeps[k]\n   447→      const half1Deps = pivotDeps[k] & ((1n << BigInt(half1)) - 1n);\n   448→      let bits = maskBig & half1Deps;\n   449→      let parity = 0;\n   450→      while (bits > 0n) {\n   451→        parity ^= 1;\n   452→        bits &= bits - 1n;\n   453→      }\n   454→      if (parity) {\n   455→        p1Mask |= 1n << BigInt(k);\n   456→      }\n   457→    }\n   458→\n   459→    const key = p1Mask.toString(36);\n   460→    const existing = half1Map.get(key);\n   461→    if (!existing || w < existing.w || (w === existing.w && compareLex(sol, existing.sol, m) < 0)) {\n   462→      half1Map.set(key, { w, sol, p1Mask });\n   463→    }\n   464→  }\n   465→\n   466→  // Second half enumeration\n   467→  let bestWeight = m + 1;\n   468→  let bestSolution = -1n;\n   469→\n   470→  const total2 = 1 << half2;\n   471→  for (let mask2 = 0; mask2 < total2; mask2++) {\n   472→    let sol2 = 0n;\n   473→    let w2 = 0;\n   474→    const maskBig2 = BigInt(mask2);\n   475→\n   476→    // Set free variables for second half\n   477→    for (let fi = 0; fi < half2; fi++) {\n   478→      if ((mask2 >> fi) & 1) {\n   479→        sol2 |= 1n << BigInt(freeVars[half1 + fi]);\n   480→        w2++;\n   481→      }\n   482→    }\n   483→\n   484→    // Compute p2_mask\n   485→    let p2Mask = 0n;\n   486→    for (let k = 0; k < numPivots; k++) {\n   487→      const half2Deps = pivotDeps[k] >> BigInt(half1);\n   488→      let bits = maskBig2 & half2Deps;\n   489→      let parity = 0;\n   490→      while (bits > 0n) {\n   491→        parity ^= 1;\n   492→        bits &= bits - 1n;\n   493→      }\n   494→      if (parity) {\n   495→        p2Mask |= 1n << BigInt(k);\n   496→      }\n   497→    }\n   498→\n   499→    // For each first-half entry, compute total weight\n   500→    for (const [, entry] of half1Map) {\n   501→      // Pivot values: pivotConst[k] XOR p1[k] XOR p2[k]\n   502→      const pivotValMask = pivotConstMask ^ entry.p1Mask ^ p2Mask;\n   503→      // Count pivot vars that are 1\n   504→      let pvBits = pivotValMask;\n   505→      let pivotWeight = 0;\n   506→      while (pvBits > 0n) {\n   507→        pivotWeight++;\n   508→        pvBits &= pvBits - 1n;\n   509→      }\n   510→\n   511→      const totalWeight = entry.w + w2 + pivotWeight;\n   512→\n   513→      if (totalWeight < bestWeight) {\n   514→        // Compute full solution\n   515→        let fullSol = entry.sol | sol2;\n   516→        // Add pivot variables\n   517→        for (let k = 0; k < numPivots; k++) {\n   518→          if ((pivotValMask >> BigInt(k) & 1n) === 1n) {\n   519→            fullSol |= 1n << BigInt(pivotCol[k]);\n   520→          }\n   521→        }\n   522→        bestWeight = totalWeight;\n   523→        bestSolution = fullSol;\n   524→      } else if (totalWeight === bestWeight) {\n   525→        let fullSol = entry.sol | sol2;\n   526→        for (let k = 0; k < numPivots; k++) {\n   527→          if ((pivotValMask >> BigInt(k) & 1n) === 1n) {\n   528→            fullSol |= 1n << BigInt(pivotCol[k]);\n   529→          }\n   530→        }\n   531→        if (compareLex(fullSol, bestSolution, m) < 0) {\n   532→          bestSolution = fullSol;\n   533→        }\n   534→      }\n   535→    }\n   536→  }\n   537→\n   538→  if (bestSolution === -1n) return null;\n   539→\n   540→  const result: number[] = [];\n   541→  for (let i = 0; i < m; i++) {\n   542→    if ((bestSolution >> BigInt(i) & 1n) === 1n) {\n   543→      result.push(i);\n   544→    }\n   545→  }\n   546→  return result;\n   547→}\n   548→\n   549→function buildPivotConstMask(pivotConst: number[], numPivots: number): bigint {\n   550→  let mask = 0n;\n   551→  for (let k = 0; k < numPivots; k++) {\n   552→    if (pivotConst[k]) {\n   553→      mask |= 1n << BigInt(k);\n   554→    }\n   555→  }\n   556→  return mask;\n   557→}\n   558→\n   559→/**\n   560→ * Solve counter puzzle using Gaussian elimination over GF(p) where p = modulus.\n   561→ *\n   562→ * Each button increments a set of counters by 1. Pressing button i x_i times\n   563→ * increments each counter in buttons[i] by x_i (mod modulus).\n   564→ * We need: for each counter j, sum of x_i for all buttons i affecting counter j ≡ lights[j] (mod modulus).\n   565→ */\n   566→export function solveCounter(\n   567→  lights: number[],\n   568→  buttons: number[][],\n   569→  modulus: number\n   570→): number[] | null {\n   571→  const n = lights.length; // number of counters\n   572→  const m = buttons.length; // number of buttons\n   573→\n   574→  // Build matrix A where A[i][j] = 1 if button j affects counter i, else 0\n   575→  // Augmented with the target vector\n   576→  // Solve A * x ≡ lights (mod modulus)\n   577→\n   578→  // Rows = counters, Cols = buttons + 1 (augmented)\n   579→  const matrix: number[][] = [];\n   580→  for (let i = 0; i < n; i++) {\n   581→    const row = new Array(m + 1).fill(0);\n   582→    for (let j = 0; j < m; j++) {\n   583→      if (buttons[j].includes(i)) {\n   584→        row[j] = 1;\n   585→      }\n   586→    }\n   587→    row[m] = lights[i] % modulus;\n   588→    if (row[m] < 0) row[m] += modulus;\n   589→    matrix.push(row);\n   590→  }\n   591→\n   592→  // Gaussian elimination over GF(modulus)\n   593→  // Since modulus is prime, every non-zero element has a multiplicative inverse\n   594→  const inv = computeInverses(modulus);\n   595→\n   596→  const pivotCols: number[] = [];\n   597→  const pivotRows: number[] = [];\n   598→  let currentRow = 0;\n   599→\n   600→  for (let col = 0; col < m && currentRow < n; col++) {\n   601→    // Find pivot\n   602→    let pivotIdx = -1;\n   603→    for (let row = currentRow; row < n; row++) {\n   604→      if (matrix[row][col] !== 0) {\n   605→        pivotIdx = row;\n   606→        break;\n   607→      }\n   608→    }\n   609→    if (pivotIdx === -1) continue;\n   610→\n   611→    // Swap rows\n   612→    [matrix[currentRow], matrix[pivotIdx]] = [matrix[pivotIdx], matrix[currentRow]];\n   613→\n   614→    // Scale pivot row so that the pivot element becomes 1\n   615→    const scale = inv[matrix[currentRow][col]];\n   616→    for (let j = col; j <= m; j++) {\n   617→      matrix[currentRow][j] = (matrix[currentRow][j] * scale) % modulus;\n   618→    }\n   619→\n   620→    // Eliminate column from all other rows\n   621→    for (let row = 0; row < n; row++) {\n   622→      if (row !== currentRow && matrix[row][col] !== 0) {\n   623→        const factor = matrix[row][col];\n   624→        for (let j = col; j <= m; j++) {\n   625→          matrix[row][j] = (matrix[row][j] - factor * matrix[currentRow][j] % modulus + modulus * modulus) % modulus;\n   626→        }\n   627→      }\n   628→    }\n   629→\n   630→    pivotCols.push(col);\n   631→    pivotRows.push(currentRow);\n   632→    currentRow++;\n   633→  }\n   634→\n   635→  // Check consistency\n   636→  for (let row = currentRow; row < n; row++) {\n   637→    if (matrix[row][m] !== 0) {\n   638→      return null; // inconsistent system\n   639→    }\n   640→  }\n   641→\n   642→  // Identify free variables\n   643→  const pivotColSet = new Set(pivotCols);\n   644→  const freeVarsList: number[] = [];\n   645→  for (let col = 0; col < m; col++) {\n   646→    if (!pivotColSet.has(col)) {\n   647→      freeVarsList.push(col);\n   648→    }\n   649→  }\n   650→\n   651→  const numFree = freeVarsList.length;\n   652→\n   653→  // For each pivot variable, express it in terms of free variables:\n   654→  // x_{pivotCol[k]} = matrix[pivotRows[k]][m] - sum(matrix[pivotRows[k]][fv] * x_fv) (mod modulus)\n   655→\n   656→  // We need to find the assignment of free variables (each 0..modulus-1)\n   657→  // that minimizes total presses, then is lex smallest.\n   658→\n   659→  // Total presses = sum of all x_i (where each x_i in 0..modulus-1)\n   660→\n   661→  // For small numFree or small modulus, we can enumerate.\n   662→  // Total combinations: modulus^numFree. With modulus up to 97 and numFree potentially large,\n   663→  // this can be huge.\n   664→\n   665→  // For the case numFree = 0: solution is determined\n   666→  if (numFree === 0) {\n   667→    const result = new Array(m).fill(0);\n   668→    for (let k = 0; k < pivotCols.length; k++) {\n   669→      result[pivotCols[k]] = matrix[pivotRows[k]][m];\n   670→    }\n   671→    return result;\n   672→  }\n   673→\n   674→  // Get pivot dependencies on free variables\n   675→  const pivotFreeCoeffs: number[][] = []; // [pivotIdx][freeVarIdx] = coefficient\n   676→  const pivotConstVals: number[] = [];\n   677→\n   678→  for (let k = 0; k < pivotCols.length; k++) {\n   679→    const coeffs: number[] = [];\n   680→    for (let fi = 0; fi < numFree; fi++) {\n   681→      coeffs.push(matrix[pivotRows[k]][freeVarsList[fi]]);\n   682→    }\n   683→    pivotFreeCoeffs.push(coeffs);\n   684→    pivotConstVals.push(matrix[pivotRows[k]][m]);\n   685→  }\n   686→\n   687→  // For small search spaces, enumerate\n   688→  const searchSpace = Math.pow(modulus, numFree);\n   689→\n   690→  if (searchSpace <= 5_000_000) {\n   691→    return solveCounterByEnumeration(\n   692→      m, modulus, numFree, freeVarsList, pivotCols,\n   693→      pivotFreeCoeffs, pivotConstVals, inv\n   694→    );\n   695→  }\n   696→\n   697→  // For larger search spaces, use meet-in-the-middle\n   698→  return solveCounterByMeetInMiddle(\n   699→    m, modulus, numFree, freeVarsList, pivotCols,\n   700→    pivotFreeCoeffs, pivotConstVals, inv\n   701→  );\n   702→}\n   703→\n   704→function computeInverses(modulus: number): number[] {\n   705→  const inv = new Array(modulus).fill(0);\n   706→  inv[1] = 1;\n   707→  for (let i = 2; i < modulus; i++) {\n   708→    inv[i] = (modulus - Math.floor(modulus / i) * inv[modulus % i] % modulus + modulus) % modulus;\n   709→  }\n   710→  return inv;\n   711→}\n   712→\n   713→function solveCounterByEnumeration(\n   714→  m: number,\n   715→  modulus: number,\n   716→  numFree: number,\n   717→  freeVarsList: number[],\n   718→  pivotCols: number[],\n   719→  pivotFreeCoeffs: number[][],\n   720→  pivotConstVals: number[],\n   721→  _inv: number[]\n   722→): number[] | null {\n   723→  let bestTotal = Infinity;\n   724→  let bestResult: number[] | null = null;\n   725→\n   726→  const freeVals = new Array(numFree).fill(0);\n   727→\n   728→  const enumerate = (idx: number, currentTotal: number): void => {\n   729→    if (idx === numFree) {\n   730→      // Compute pivot variable values\n   731→      let total = currentTotal;\n   732→      const result = new Array(m).fill(0);\n   733→\n   734→      // Set free variables\n   735→      for (let fi = 0; fi < numFree; fi++) {\n   736→        result[freeVarsList[fi]] = freeVals[fi];\n   737→      }\n   738→\n   739→      // Compute pivot variables\n   740→      for (let k = 0; k < pivotCols.length; k++) {\n   741→        let val = pivotConstVals[k];\n   742→        for (let fi = 0; fi < numFree; fi++) {\n   743→          val = (val - pivotFreeCoeffs[k][fi] * freeVals[fi] % modulus + modulus * modulus) % modulus;\n   744→        }\n   745→        val = val % modulus;\n   746→        result[pivotCols[k]] = val;\n   747→        total += val;\n   748→      }\n   749→\n   750→      if (total < bestTotal || (total === bestTotal && lexCompareArrays(result, bestResult!) < 0)) {\n   751→        bestTotal = total;\n   752→        bestResult = [...result];\n   753→      }\n   754→      return;\n   755→    }\n   756→\n   757→    for (let v = 0; v < modulus; v++) {\n   758→      freeVals[idx] = v;\n   759→      // Pruning: if current total already >= best, skip\n   760→      if (currentTotal + v >= bestTotal) {\n   761→        // Even with 0 for remaining free vars, we still have pivot vars to add\n   762→        // So this pruning is only valid if we know pivot vars will be non-negative\n   763→        // They're always 0..modulus-1, so minimum is 0.\n   764→        // But we can't prune because pivot vars could compensate.\n   765→        // Actually, if currentTotal + v alone exceeds bestTotal, we can prune\n   766→        // since all remaining values are >= 0 and pivot values >= 0.\n   767→        // But v alone might not exceed it. Let me just prune if obvious:\n   768→        if (currentTotal + v > bestTotal) {\n   769→          continue;\n   770→        }\n   771→      }\n   772→      enumerate(idx + 1, currentTotal + v);\n   773→    }\n   774→  };\n   775→\n   776→  enumerate(0, 0);\n   777→  return bestResult;\n   778→}\n   779→\n   780→function lexCompareArrays(a: number[], b: number[]): number {\n   781→  for (let i = 0; i < a.length; i++) {\n   782→    if (a[i] < b[i]) return -1;\n   783→    if (a[i] > b[i]) return 1;\n   784→  }\n   785→  return 0;\n   786→}\n   787→\n   788→function solveCounterByMeetInMiddle(\n   789→  m: number,\n   790→  modulus: number,\n   791→  numFree: number,\n   792→  freeVarsList: number[],\n   793→  pivotCols: number[],\n   794→  pivotFreeCoeffs: number[][],\n   795→  pivotConstVals: number[],\n   796→  _inv: number[]\n   797→): number[] | null {\n   798→  // Split free variables into two halves\n   799→  const half1 = Math.floor(numFree / 2);\n   800→  const half2 = numFree - half1;\n   801→  const numPivots = pivotCols.length;\n   802→\n   803→  // For each half1 assignment, compute:\n   804→  //   - contribution to each pivot: sum(coeff[k][fi] * val[fi]) for fi in half1\n   805→  //   - free var total for half1\n   806→  //   - signature: array of partial pivot contributions mod modulus\n   807→  // Store in a map: signature -> best (total, solution partial)\n   808→\n   809→  // The signature is the tuple of partial pivot contributions (each mod modulus).\n   810→  // With numPivots up to 40 and modulus up to 97, the number of distinct signatures\n   811→  // can be large. But for half1 ~ 3-4 variables with modulus up to 97,\n   812→  // we have at most 97^4 ≈ 89M entries. That's too many.\n   813→  // But we only have modulus^half1 actual entries, which should be bounded.\n   814→\n   815→  type HalfEntry = {\n   816→    w: number;\n   817→    partialSol: number[]; // values for the half's free variables\n   818→    pivotContribs: number[]; // partial pivot contributions\n   819→  };\n   820→\n   821→  const half1Map = new Map<string, HalfEntry>();\n   822→  const freeVals1 = new Array(half1).fill(0);\n   823→\n   824→  const buildHalf1 = (idx: number, w: number, contribs: number[]): void => {\n   825→    if (idx === half1) {\n   826→      const key = contribs.join(',');\n   827→      const existing = half1Map.get(key);\n   828→      const partialSol = [...freeVals1];\n   829→      if (!existing || w < existing.w ||\n   830→          (w === existing.w && lexComparePartial(partialSol, existing.partialSol, freeVarsList, 0, half1, m) < 0)) {\n   831→        half1Map.set(key, { w, partialSol, pivotContribs: [...contribs] });\n   832→      }\n   833→      return;\n   834→    }\n   835→\n   836→    for (let v = 0; v < modulus; v++) {\n   837→      freeVals1[idx] = v;\n   838→      const newContribs = [...contribs];\n   839→      for (let k = 0; k < numPivots; k++) {\n   840→        newContribs[k] = (newContribs[k] + pivotFreeCoeffs[k][idx] * v) % modulus;\n   841→      }\n   842→      buildHalf1(idx + 1, w + v, newContribs);\n   843→    }\n   844→  };\n   845→\n   846→  buildHalf1(0, 0, new Array(numPivots).fill(0));\n   847→\n   848→  // For each half2 assignment, compute contributions and look up complementary half1\n   849→  let bestTotal = Infinity;\n   850→  let bestResult: number[] | null = null;\n   851→\n   852→  const freeVals2 = new Array(half2).fill(0);\n   853→\n   854→  const searchHalf2 = (idx: number, w2: number, contribs2: number[]): void => {\n   855→    if (idx === half2) {\n   856→      // We need the total pivot contribution (from half1 + half2) to determine pivot values.\n   857→      // pivot_val[k] = (pivotConstVals[k] - totalContrib[k]) mod modulus\n   858→      // We want totalContrib[k] = contribs1[k] + contribs2[k] (mod modulus)\n   859→      // pivot_val[k] = (pivotConstVals[k] - contribs1[k] - contribs2[k]) mod modulus\n   860→      // total = w1 + w2 + sum(pivot_val[k])\n   861→      // We want to minimize this over all matching half1 entries.\n   862→\n   863→      // For each half1 entry in the map, compute the total.\n   864→      // This is O(|half1Map|) per half2 entry, which could be expensive.\n   865→      // But half1Map has at most modulus^half1 entries, and we iterate modulus^half2 times.\n   866→      // Total: modulus^numFree, same as brute force. Not helpful!\n   867→\n   868→      // Better: we need to be smarter about the lookup.\n   869→      // For a given half2 contribs, the needed half1 contribs is determined if we fix the\n   870→      // pivot values. But we DON'T know the pivot values in advance because we're optimizing.\n   871→\n   872→      // Let's just iterate over all half1 entries since half1Map is bounded by modulus^half1.\n   873→      // If half1 ≈ half2 ≈ numFree/2, and modulus^