+    let pi = -1;
+    for (let row = curRow; row < n; row++) {
+      if (matrix[row][col] !== 0) { pi = row; break; }
+    }
+    if (pi === -1) continue;
+    [matrix[curRow], matrix[pi]] = [matrix[pi], matrix[curRow]];
+    const sc = inv[matrix[curRow][col]];
