XOR p2_mask) + w2.\n  //\n  // Hmm, this is essentially a min-weight codeword problem which is NP-hard in general.\n  // But with the structure we have, let me try a different approach.\n  //\n  // Actually, for practical cases the number of free variables tends to be small.\n  // Let me just handle up to ~25 by enumeration (2^25 ≈ 33M, borderline for 5 seconds)\n  // and use meet-in-the-middle for larger cases.\n  //\n  // For meet-in-the-middle with the pivot complication, let me try:\n  // Enumerate first half (2^20), store results grouped by p1_signature (bitmask of pivot parities).\n  // Enumerate second half (2^20), and for each, iterate over possible p1_signatures.\n  // But with up to 40 pivots, there are potentially 2^40 signatures...\n  //\n  // Actually, the p1_signature only has bits for pivots that actually depend on half1 free vars.\n  // Similarly for p2. In practice, many pivots may not depend on any free vars at all\n  // (they're just pivotConst). Let me think about the maximum possible distinct signatures.\n  // Each half1 assignment generates a signature based on parities of subsets of half1 free vars.\n  // The signature space is at most 2^(half1) but also at most 2^(numPivots).\n  //\n  // Actually, the number of DISTINCT p1_signatures is at most 2^(rank of the deps1 matrix),\n  // which is at most min(half1, numPivots). And similarly for p2.\n  //\n  // Let me just implement this: for each second-half assignment, compute the p2_mask,\n  // then we need to find a first-half assignment with combined_mask = pivotConstMask XOR p1_mask\n  // such that popcount(combined_mask XOR p2_mask) + w1 is minimized.\n  // Equivalently, find p1_mask such that popcount(pivotConstMask XOR p1_mask XOR p2_mask) + w1 is min.\n  // Let target_mask = pivotConstMask XOR p2_mask.\n  // We want popcount(target_mask XOR p1_mask) + w1 minimized.\n  // For each stored (p1_mask, w1, solution1), compute popcount(target_mask XOR p1_mask) + w1.\n  //\n  // Since there are at most 2^20 stored entries and 2^20 second-half entries,\n  // and for each second-half we'd need to scan all first-half entries,\n  // this is 2^40 operations. Too slow.\n  //\n  // Better approach: group first-half entries by p1_mask. For each unique p1_mask,\n  // keep only the best (w1, solution). Then for each second-half entry,\n  // iterate over all unique p1_masks and find the best total.\n  //\n  // The number of unique p1_masks is at most 2^(half1), but in practice much smaller\n  // because only some pivots depend on half1 free vars.\n  //\n  // Let me try yet another approach: if numFree > 25, we can try to reduce the problem\n  // by choosing a different pivoting strategy that minimizes free variables.\n  // Actually, Gaussian elimination already finds the rank, and free vars = m - rank.\n  // The rank is at most n (number of lights), so free vars >= m - n.\n  // With m = 40 and n = 40, free vars could be 0. The worst case for free vars\n  // is when rank is small, e.g., m=40, rank=0 (no equations constrain the buttons,\n  // which would mean all target is false).\n  //\n  // In practice, for the given constraints, let me just handle the general case.\n  // I'll implement a meet-in-the-middle approach that works when signatures are manageable.\n\n  // Split deps for each pivot into half1 and half2\n  const numPivots = pivotCol.length;\n\n  // Build p1 deps mask and p2 deps mask for each pivot\n  // pivotDeps[k] is a bitmask over freeVars indices (0..numFree-1)\n  // Half1: indices 0..half1-1, Half2: indices half1..numFree-1\n\n  const pivotConstMask = buildPivotConstMask(pivotConst, numPivots);\n\n  // First half enumeration\n  type HalfResult = { w: number; sol: bigint; p1Mask: bigint };\n  const half1Map = new Map<string, HalfResult>(); // p1Mask -> best result\n\n  const total1 = 1 << half1;\n  for (let mask = 0; mask < total1; mask++) {\n    let sol = 0n;\n    let w = 0;\n    const maskBig = BigInt(mask);\n\n    // Set free variables for first half\n    for (let fi = 0; fi < half1; fi++) {\n      if ((mask >> fi) & 1) {\n        sol |= 1n << BigInt(freeVars[fi]);\n        w++;\n      }\n    }\n\n    // Compute p1_mask: parity contribution from half1 free vars to each pivot\n    let p1Mask = 0n;\n    for (let k = 0; k < numPivots; k++) {\n      // Extract bits 0..half1-1 from pivotDeps[k]\n      const half1Deps = pivotDeps[k] & ((1n << BigInt(half1)) - 1n);\n      let bits = maskBig & half1Deps;\n      let parity = 0;\n      while (bits > 0n) {\n        parity ^= 1;\n        bits &= bits - 1n;\n      }\n      if (parity) {\n        p1Mask |= 1n << BigInt(k);\n      }\n    }\n\n    const key = p1Mask.toString(36);\n    const existing = half1Map.get(key);\n    if (!existing || w < existing.w || (w === existing.w && compareLex(sol, existing.sol, m) < 0)) {\n      half1Map.set(key, { w, sol, p1Mask });\n    }\n  }\n\n  // Second half enumeration\n  let bestWeight = m + 1;\n  let bestSolution = -1n;\n\n  const total2 = 1 << half2;\n  for (let mask2 = 0; mask2 < total2; mask2++) {\n    let sol2 = 0n;\n    let w2 = 0;\n    const maskBig2 = BigInt(mask2);\n\n    // Set free variables for second half\n    for (let fi = 0; fi < half2; fi++) {\n      if ((mask2 >> fi) & 1) {\n        sol2 |= 1n << BigInt(freeVars[half1 + fi]);\n        w2++;\n      }\n    }\n\n    // Compute p2_mask\n    let p2Mask = 0n;\n    for (let k = 0; k < numPivots; k++) {\n      const half2Deps = pivotDeps[k] >> BigInt(half1);\n      let bits = maskBig2 & half2Deps;\n      let parity = 0;\n      while (bits > 0n) {\n        parity ^= 1;\n        bits &= bits - 1n;\n      }\n      if (parity) {\n        p2Mask |= 1n << BigInt(k);\n      }\n    }\n\n    // For each first-half entry, compute total weight\n    for (const [, entry] of half1Map) {\n      // Pivot values: pivotConst[k] XOR p1[k] XOR p2[k]\n      const pivotValMask = pivotConstMask ^ entry.p1Mask ^ p2Mask;\n      // Count pivot vars that are 1\n      let pvBits = pivotValMask;\n      let pivotWeight = 0;\n      while (pvBits > 0n) {\n        pivotWeight++;\n        pvBits &= pvBits - 1n;\n      }\n\n      const totalWeight = entry.w + w2 + pivotWeight;\n\n      if (totalWeight < bestWeight) {\n        // Compute full solution\n        let fullSol = entry.sol | sol2;\n        // Add pivot variables\n        for (let k = 0; k < numPivots; k++) {\n          if ((pivotValMask >> BigInt(k) & 1n) === 1n) {\n            fullSol |= 1n << BigInt(pivotCol[k]);\n          }\n        }\n        bestWeight = totalWeight;\n        bestSolution = fullSol;\n      } else if (totalWeight === bestWeight) {\n        let fullSol = entry.sol | sol2;\n        for (let k = 0; k < numPivots; k++) {\n          if ((pivotValMask >> BigInt(k) & 1n) === 1n) {\n            fullSol |= 1n << BigInt(pivotCol[k]);\n          }\n        }\n        if (compareLex(fullSol, bestSolution, m) < 0) {\n          bestSolution = fullSol;\n        }\n      }\n    }\n  }\n\n  if (bestSolution === -1n) return null;\n\n  const result: number[] = [];\n  for (let i = 0; i < m; i++) {\n    if ((bestSolution >> BigInt(i) & 1n) === 1n) {\n      result.push(i);\n    }\n  }\n  return result;\n}\n\nfunction buildPivotConstMask(pivotConst: number[], numPivots: number): bigint {\n  let mask = 0n;\n  for (let k = 0; k < numPivots; k++) {\n    if (pivotConst[k]) {\n      mask |= 1n << BigInt(k);\n    }\n  }\n  return mask;\n}\n\n/**\n * Solve counter puzzle using Gaussian elimination over GF(p) where p = modulus.\n *\n * Each button increments a set of counters by 1. Pressing button i x_i times\n * increments each counter in buttons[i] by x_i (mod modulus).\n * We need: for each counter j, sum of x_i for all buttons i affecting counter j ≡ lights[j] (mod modulus).\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const n = lights.length; // number of counters\n  const m = buttons.length; // number of buttons\n\n  // Build matrix A where A[i][j] = 1 if button j affects counter i, else 0\n  // Augmented with the target vector\n  // Solve A * x ≡ lights (mod modulus)\n\n  // Rows = counters, Cols = buttons + 1 (augmented)\n  const matrix: number[][] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Array(m + 1).fill(0);\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[m] = lights[i] % modulus;\n    if (row[m] < 0) row[m] += modulus;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(modulus)\n  // Since modulus is prime, every non-zero element has a multiplicative inverse\n  const inv = computeInverses(modulus);\n\n  const pivotCols: number[] = [];\n  const pivotRows: number[] = [];\n  let currentRow = 0;\n\n  for (let col = 0; col < m && currentRow < n; col++) {\n    // Find pivot\n    let pivotIdx = -1;\n    for (let row = currentRow; row < n; row++) {\n      if (matrix[row][col] !== 0) {\n        pivotIdx = row;\n        break;\n      }\n    }\n    if (pivotIdx === -1) continue;\n\n    // Swap rows\n    [matrix[currentRow], matrix[pivotIdx]] = [matrix[pivotIdx], matrix[currentRow]];\n\n    // Scale pivot row so that the pivot element becomes 1\n    const scale = inv[matrix[currentRow][col]];\n    for (let j = col; j <= m; j++) {\n      matrix[currentRow][j] = (matrix[currentRow][j] * scale) % modulus;\n    }\n\n    // Eliminate column from all other rows\n    for (let row = 0; row < n; row++) {\n      if (row !== currentRow && matrix[row][col] !== 0) {\n        const factor = matrix[row][col];\n        for (let j = col; j <= m; j++) {\n          matrix[row][j] = (matrix[row][j] - factor * matrix[currentRow][j] % modulus + modulus * modulus) % modulus;\n        }\n      }\n    }\n\n    pivotCols.push(col);\n    pivotRows.push(currentRow);\n    currentRow++;\n  }\n\n  // Check consistency\n  for (let row = currentRow; row < n; row++) {\n    if (matrix[row][m] !== 0) {\n      return null; // inconsistent system\n    }\n  }\n\n  // Identify free variables\n  const pivotColSet = new Set(pivotCols);\n  const freeVarsList: number[] = [];\n  for (let col = 0; col < m; col++) {\n    if (!pivotColSet.has(col)) {\n      freeVarsList.push(col);\n    }\n  }\n\n  const numFree = freeVarsList.length;\n\n  // For each pivot variable, express it in terms of free variables:\n  // x_{pivotCol[k]} = matrix[pivotRows[k]][m] - sum(matrix[pivotRows[k]][fv] * x_fv) (mod modulus)\n\n  // We need to find the assignment of free variables (each 0..modulus-1)\n  // that minimizes total presses, then is lex smallest.\n\n  // Total presses = sum of all x_i (where each x_i in 0..modulus-1)\n\n  // For small numFree or small modulus, we can enumerate.\n  // Total combinations: modulus^numFree. With modulus up to 97 and numFree potentially large,\n  // this can be huge.\n\n  // For the case numFree = 0: solution is determined\n  if (numFree === 0) {\n    const result = new Array(m).fill(0);\n    for (let k = 0; k < pivotCols.length; k++) {\n      result[pivotCols[k]] = matrix[pivotRows[k]][m];\n    }\n    return result;\n  }\n\n  // Get pivot dependencies on free variables\n  const pivotFreeCoeffs: number[][] = []; // [pivotIdx][freeVarIdx] = coefficient\n  const pivotConstVals: number[] = [];\n\n  for (let k = 0; k < pivotCols.length; k++) {\n    const coeffs: number[] = [];\n    for (let fi = 0; fi < numFree; fi++) {\n      coeffs.push(matrix[pivotRows[k]][freeVarsList[fi]]);\n    }\n    pivotFreeCoeffs.push(coeffs);\n    pivotConstVals.push(matrix[pivotRows[k]][m]);\n  }\n\n  // For small search spaces, enumerate\n  const searchSpace = Math.pow(modulus, numFree);\n\n  if (searchSpace <= 5_000_000) {\n    return solveCounterByEnumeration(\n      m, modulus, numFree, freeVarsList, pivotCols,\n      pivotFreeCoeffs, pivotConstVals, inv\n    );\n  }\n\n  // For larger search spaces, use meet-in-the-middle\n  return solveCounterByMeetInMiddle(\n    m, modulus, numFree, freeVarsList, pivotCols,\n    pivotFreeCoeffs, pivotConstVals, inv\n  );\n}\n\nfunction computeInverses(modulus: number): number[] {\n  const inv = new Array(modulus).fill(0);\n  inv[1] = 1;\n  for (let i = 2; i < modulus; i++) {\n    inv[i] = (modulus - Math.floor(modulus / i) * inv[modulus % i] % modulus + modulus) % modulus;\n  }\n  return inv;\n}\n\nfunction solveCounterByEnumeration(\n  m: number,\n  modulus: number,\n  numFree: number,\n  freeVarsList: number[],\n  pivotCols: number[],\n  pivotFreeCoeffs: number[][],\n  pivotConstVals: number[],\n  _inv: number[]\n): number[] | null {\n  let bestTotal = Infinity;\n  let bestResult: number[] | null = null;\n\n  const freeVals = new Array(numFree).fill(0);\n\n  const enumerate = (idx: number, currentTotal: number): void => {\n    if (idx === numFree) {\n      // Compute pivot variable values\n      let total = currentTotal;\n      const result = new Array(m).fill(0);\n\n      // Set free variables\n      for (let fi = 0; fi < numFree; fi++) {\n        result[freeVarsList[fi]] = freeVals[fi];\n      }\n\n      // Compute pivot variables\n      for (let k = 0; k < pivotCols.length; k++) {\n        let val = pivotConstVals[k];\n        for (let fi = 0; fi < numFree; fi++) {\n          val = (val - pivotFreeCoeffs[k][fi] * freeVals[fi] % modulus + modulus * modulus) % modulus;\n        }\n        val = val % modulus;\n        result[pivotCols[k]] = val;\n        total += val;\n      }\n\n      if (total < bestTotal || (total === bestTotal && lexCompareArrays(result, bestResult!) < 0)) {\n        bestTotal = total;\n        bestResult = [...result];\n      }\n      return;\n    }\n\n    for (let v = 0; v < modulus; v++) {\n      freeVals[idx] = v;\n      // Pruning: if current total already >= best, skip\n      if (currentTotal + v >= bestTotal) {\n        // Even with 0 for remaining free vars, we still have pivot vars to add\n        // So this pruning is only valid if we know pivot vars will be non-negative\n        // They're always 0..modulus-1, so minimum is 0.\n        // But we can't prune because pivot vars could compensate.\n        // Actually, if currentTotal + v alone exceeds bestTotal, we can prune\n        // since all remaining values are >= 0 and pivot values >= 0.\n        // But v alone might not exceed it. Let me just prune if obvious:\n        if (currentTotal + v > bestTotal) {\n          continue;\n        }\n      }\n      enumerate(idx + 1, currentTotal + v);\n    }\n  };\n\n  enumerate(0, 0);\n  return bestResult;\n}\n\nfunction lexCompareArrays(a: number[], b: number[]): number {\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] < b[i]) return -1;\n    if (a[i] > b[i]) return 1;\n  }\n  return 0;\n}\n\nfunction solveCounterByMeetInMiddle(\n  m: number,\n  modulus: number,\n  numFree: number,\n  freeVarsList: number[],\n  pivotCols: number[],\n  pivotFreeCoeffs: number[][],\n  pivotConstVals: number[],\n  _inv: number[]\n): number[] | null {\n  // Split free variables into two halves\n  const half1 = Math.floor(numFree / 2);\n  const half2 = numFree - half1;\n  const numPivots = pivotCols.length;\n\n  // For each half1 assignment, compute:\n  //   - contribution to each pivot: sum(coeff[k][fi] * val[fi]) for fi in half1\n  //   - free var total for half1\n  //   - signature: array of partial pivot contributions mod modulus\n  // Store in a map: signature -> best (total, solution partial)\n\n  // The signature is the tuple of partial pivot contributions (each mod modulus).\n  // With numPivots up to 40 and modulus up to 97, the number of distinct signatures\n  // can be large. But for half1 ~ 3-4 variables with modulus up to 97,\n  // we have at most 97^4 ≈ 89M entries. That's too many.\n  // But we only have modulus^half1 actual entries, which should be bounded.\n\n  type HalfEntry = {\n    w: number;\n    partialSol: number[]; // values for the half's free variables\n    pivotContribs: number[]; // partial pivot contributions\n  };\n\n  const half1Map = new Map<string, HalfEntry>();\n  const freeVals1 = new Array(half1).fill(0);\n\n  const buildHalf1 = (idx: number, w: number, contribs: number[]): void => {\n    if (idx === half1) {\n      const key = contribs.join(',');\n      const existing = half1Map.get(key);\n      const partialSol = [...freeVals1];\n      if (!existing || w < existing.w ||\n          (w === existing.w && lexComparePartial(partialSol, existing.partialSol, freeVarsList, 0, half1, m) < 0)) {\n        half1Map.set(key, { w, partialSol, pivotContribs: [...contribs] });\n      }\n      return;\n    }\n\n    for (let v = 0; v < modulus; v++) {\n      freeVals1[idx] = v;\n      const newContribs = [...contribs];\n      for (let k = 0; k < numPivots; k++) {\n        newContribs[k] = (newContribs[k] + pivotFreeCoeffs[k][idx] * v) % modulus;\n      }\n      buildHalf1(idx + 1, w + v, newContribs);\n    }\n  };\n\n  buildHalf1(0, 0, new Array(numPivots).fill(0));\n\n  // For each half2 assignment, compute contributions and look up complementary half1\n  let bestTotal = Infinity;\n  let bestResult: number[] | null = null;\n\n  const freeVals2 = new Array(half2).fill(0);\n\n  const searchHalf2 = (idx: number, w2: number, contribs2: number[]): void => {\n    if (idx === half2) {\n      // We need the total pivot contribution (from half1 + half2) to determine pivot values.\n      // pivot_val[k] = (pivotConstVals[k] - totalContrib[k]) mod modulus\n      // We want totalContrib[k] = contribs1[k] + contribs2[k] (mod modulus)\n      // pivot_val[k] = (pivotConstVals[k] - contribs1[k] - contribs2[k]) mod modulus\n      // total = w1 + w2 + sum(pivot_val[k])\n      // We want to minimize this over all matching half1 entries.\n\n      // For each half1 entry in the map, compute the total.\n      // This is O(|half1Map|) per half2 entry, which could be expensive.\n      // But half1Map has at most modulus^half1 entries, and we iterate modulus^half2 times.\n      // Total: modulus^numFree, same as brute force. Not helpful!\n\n      // Better: