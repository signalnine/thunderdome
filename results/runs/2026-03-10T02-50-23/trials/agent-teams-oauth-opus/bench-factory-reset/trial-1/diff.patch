 >= bestTotal) break; // prune\n        }\n\n        if (total < bestTotal) {\n          const result = buildFullResult(m, numFree, freeVarsList, pivotCols, pivotConstVals,\n            pivotFreeCoeffs, entry.partialSol, freeVals2, half1, modulus);\n          bestTotal = total;\n          bestResult = result;\n        } else if (total === bestTotal) {\n          const result = buildFullResult(m, numFree, freeVarsList, pivotCols, pivotConstVals,\n            pivotFreeCoeffs, entry.partialSol, freeVals2, half1, modulus);\n          if (bestResult === null || lexCompareArrays(result, bestResult) < 0) {\n            bestResult = result;\n          }\n        }\n      }\n      return;\n    }\n\n    for (let v = 0; v < modulus; v++) {\n      freeVals2[idx] = v;\n      const newContribs = [...contribs2];\n      for (let k = 0; k < numPivots; k++) {\n        newContribs[k] = (newContribs[k] + pivotFreeCoeffs[k][half1 + idx] * v) % modulus;\n      }\n      searchHalf2(idx + 1, w2 + v, newContribs);\n    }\n  };\n\n  searchHalf2(0, 0, new Array(numPivots).fill(0));\n\n  return bestResult;\n}\n\nfunction buildFullResult(\n  m: number,\n  numFree: number,\n  freeVarsList: number[],\n  pivotCols: number[],\n  pivotConstVals: number[],\n  pivotFreeCoeffs: number[][],\n  partialSol1: number[],\n  partialSol2: number[],\n  half1: number,\n  modulus: number\n): number[] {\n  const result = new Array(m).fill(0);\n  const allFreeVals: number[] = [...partialSol1, ...partialSol2];\n\n  for (let fi = 0; fi < numFree; fi++) {\n    result[freeVarsList[fi]] = allFreeVals[fi];\n  }\n\n  for (let k = 0; k < pivotCols.length; k++) {\n    let val = pivotConstVals[k];\n    for (let fi = 0; fi < numFree; fi++) {\n      val = (val - pivotFreeCoeffs[k][fi] * allFreeVals[fi] % modulus + modulus * modulus) % modulus;\n    }\n    val = val % modulus;\n    result[pivotCols[k]] = val;\n  }\n\n  return result;\n}\n\nfunction lexComparePartial(\n  a: number[], b: number[],\n  freeVarsList: number[],\n  of