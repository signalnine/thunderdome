rn null;\n  }\n\n  // Identify free variables and build pivot dependencies\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < m; col++) {\n    if (!pivotColSet.has(col)) freeVars.push(col);\n  }\n  const numFree = freeVars.length;\n  const pivotDeps: bigint[] = [];\n  const pivotConst: number[] = [];\n  for (let k = 0; k < pivotCol.length; k++) {\n    const r = pivotRow[k];\n    let deps = 0n;\n    for (let fi = 0; fi < numFree; fi++) {\n      if (((rows[r] >> BigInt(freeVars[fi])) & 1n) === 1n) deps |= 1n << BigInt(fi);\n    }\n    pivotDeps.push(deps);\n    pivotConst.push(tBits[r]);\n  }\n\n  if (numFree <= 22) {\n    return toggleEnumerate(numFree, freeVars, pivotCol, pivotDeps, pivotConst, m);\n  }\n  return toggleMeetInMiddle(numFree, freeVars, pivotCol, pivotDeps, pivotConst, m);\n}\n\nfunction popcount64(x: bigint): number {\n  let c = 0;\n  while (x > 0n) { c++; x &= x - 1n; }\n  return c;\n}\n\nfunction compareLexBig(a: bigint, b: bigint): number {\n  const diff = a ^ b;\n  if (diff === 0n) return 0;\n  return (a & (diff & (-diff))) !== 0n ? -1 : 1;\n}\n\nfunction bitsToArray(bits: bigint, m: number): number[] {\n  const r: number[] = [];\n  for (let i = 0; i < m; i++) {\n    if (((bits >> BigInt(i)) & 1n) === 1n) r.push(i);\n  }\n  return r;\n}\n\nfunction evalSolution(\n  freeMask: bigint, numFree: number, freeVars: number[],\n  pivotCol: number[], pivotDeps: bigint[], pivotConst: number[]\n): [bigint, number] {\n  let sol = 0n;\n  let w = 0;\n  for (let fi = 0; fi < numFree; fi++) {\n    if (((freeMask >> BigInt(fi)) & 1n) === 1n) {\n      sol |= 1n << BigInt(freeVars[fi]);\n      w++;\n    }\n  }\n  for (let k = 0; k < pivotCol.length; k++) {\n    if (pivotConst[k] ^ (popcount64(freeMask & pivotDeps[k]) & 1)) {\n      sol |= 1n << BigInt(pivotCol[k]);\n      w++;\n    }\n  }\n  return [sol, w];\n}\n\nfunction toggleEnumerate(\n  numFree: number, freeVars: number[], pivotCol: number[],\n  pivotDeps: bigint[], pivotConst: number[], m: number\n): number[] {\n  let bestW = m + 1;\n  let bestSol = 0n;\n  for (let mask = 0; mask < (1 << numFree); mask++) {\n    const [sol, w] = evalSolution(BigInt(mask), numFree, freeVars, pivotCol, pivotDeps, pivotConst);\n    if (w < bestW || (w === bestW && compareLexBig(sol, bestSol) < 0)) {\n      bestW = w; bestSol = sol;\n    }\n  }\n  return bitsToArray(bestSol, m);\n}\n\nfunction toggleMeetInMiddle(\n  numFree: number, freeVars: number[], pivotCol: number[],\n  pivotDeps: bigint[], pivotConst: number[], m: number\n): number[] {\n  const h1 = Math.floor(numFree / 2);\n  const h2 = numFree - h1;\n  const nP = pivotCol.length;\n\n  let pcMask = 0n;\n  for (let k = 0; k < nP; k++) if (pivotConst[k]) pcMask |= 1n << BigInt(k);\n\n  const h1Mask = (1n << BigInt(h1)) - 1n;\n\n  interface HE { w: number; sol: bigint; sig: bigint }\n  const h1Map = new Map<string, HE>();\n\n  for (let mask = 0; mask < (1 << h1); mask++) {\n    let sol = 0n, w = 0;\n    const mb = BigInt(mask);\n    for (let fi = 0; fi < h1; fi++) {\n      if ((mask >> fi) & 1) { sol |= 1n << BigInt(freeVars[fi]); w++; }\n    }\n    let sig = 0n;\n    for (let k = 0; k < nP; k++) {\n      if (popcount64(mb & (pivotDeps[k] & h1Mask)) & 1) sig |= 1n << BigInt(k);\n    }\n    const key = sig.toString(36);\n    const ex = h1Map.get(key);\n    if (!ex || w < ex.w || (w === ex.w && compareLexBig(sol, ex.sol) < 0)) {\n      h1Map.set(key, { w, sol, sig });\n    }\n  }\n\n  const entries = Array.from(h1Map.values());\n  let bestW = m + 1;\n  let bestSol = 0n;\n\n  for (let mask2 = 0; mask2 < (1 << h2); mask2++) {\n    let sol2 = 0n, w2 = 0;\n    const mb2 = BigInt(mask2);\n    for (let fi = 0; fi < h2; fi++) {\n      if ((mask2 >> fi) & 1) { sol2 |= 1n << BigInt(freeVars[h1 + fi]); w2++; }\n    }\n    let sig2 = 0n;\n    for (let k = 0; k < nP; k++) {\n      if (popcount64(mb2 & (pivotDeps[k] >> BigInt(h1))) & 1) sig2 |= 1n << BigInt(k);\n    }\n\n    for (const e of entries) 