+
+describe('ReviewService', () => {
+  let reviews: ReviewService;
+
+  beforeEach(() => {
+    reviews = createReviewService();
+  });
+
+  describe('addReview', () => {
+    it('should add a review with auto-generated fields', () => {
+      const review = reviews.addReview({
+        pluginName: 'test-plugin',
+        pluginVersion: '1.0.0',
+        userId: 'user1',
+        rating: 5,
+        comment: 'Great plugin!',
+      });
+      expect(review.id).toBeDefined();
+      expect(review.flagged).toBe(false);
+      expect(review.createdAt).toBeDefined();
+      expect(review.rating).toBe(5);
+    });
+  });
+
+  describe('getReviews', () => {
+    it('should get reviews for a plugin', () => {
+      reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'ok' });
+      reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u2', rating: 4, comment: 'good' });
+      reviews.addReview({ pluginName: 'b', pluginVersion: '1.0.0', userId: 'u1', rating: 3, comment: 'meh' });
+      const result = reviews.getReviews('a');
+      expect(result).toHaveLength(2);
+    });
+  });
+
+  describe('getAverageRating', () => {
+    it('should compute average excluding flagged reviews', () => {
+      const r1 = reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'ok' });
+      reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'ok' });
+      const r3 = reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u3', rating: 1, comment: 'bad' });
+
+      // Average of 5, 3, 1 = 3
+      expect(reviews.getAverageRating('a')).toBe(3);
+
+      // Flag the 1-star review
+      reviews.flagReview(r3.id);
+      // Average of 5, 3 = 4
+      expect(reviews.getAverageRating('a')).toBe(4);
+
+      // Flag all remaining reviews
+      reviews.flagReview(r1.id);
+      reviews.flagReview(reviews.getReviews('a')[1].id);
+      // No unflagged reviews -> 0
+      expect(reviews.getAverageRating('a')).toBe(0);
+    });
+
+    it('should return 0 for plugin with no reviews', () => {
+      expect(reviews.getAverageRating('nonexistent')).toBe(0);
+    });
+  });
+
+  describe('flagReview', () => {
+    it('should flag a review', () => {
+      const review = reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'ok' });
+      reviews.flagReview(review.id);
+      const flagged = reviews.getFlaggedReviews();
+      expect(flagged).toHaveLength(1);
+      expect(flagged[0].id).toBe(review.id);
+      expect(flagged[0].flagged).toBe(true);
+    });
+  });
+
+  describe('removeReview', () => {
+    it('should remove a review', () => {
+      const review = reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'ok' });
+      expect(reviews.removeReview(review.id)).toBe(true);
+      expect(reviews.getReviews('a')).toHaveLength(0);
+    });
+
+    it('should return false for non-existent review', () => {
+      expect(reviews.removeReview(999)).toBe(false);
+    });
+  });
+
+  describe('getReviewsByUser', () => {
+    it('should return reviews by a specific user', () => {
+      reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: 'ok' });
+      reviews.addReview({ pluginName: 'b', pluginVersion: '1.0.0', userId: 'user1', rating: 4, comment: 'ok' });
+      reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'user2', rating: 3, comment: 'ok' });
+      const result = reviews.getReviewsByUser('user1');
+      expect(result).toHaveLength(2);
+    });
+  });
+
+  describe('getReviewCount', () => {
+    it('should count all reviews including flagged', () => {
+      const r1 = reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'ok' });
+      reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'ok' });
+      reviews.flagReview(r1.id);
+      expect(reviews.getReviewCount('a')).toBe(2);
+    });
+  });
+});
