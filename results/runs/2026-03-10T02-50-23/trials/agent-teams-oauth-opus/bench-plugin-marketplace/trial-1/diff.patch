index 0000000..080e806
--- /dev/null
+++ b/src/deps/index.ts
@@ -0,0 +1,142 @@
+import type { DepsService, DependencyNode, RegistryService } from '../types.js';
+
+export function createDepsService(): DepsService {
+  function buildTree(name: string, registry: RegistryService): DependencyNode {
+    const visited = new Set<string>();
+
+    function build(pluginName: string): DependencyNode {
+      const manifest = registry.get(pluginName);
+
+      if (!manifest) {
+        return { name: pluginName, version: 'unknown', dependencies: [] };
+      }
+
+      if (visited.has(pluginName)) {
+        return { name: pluginName, version: manifest.version, dependencies: [] };
+      }
+
+      visited.add(pluginName);
+
+      const children: DependencyNode[] = [];
+      for (const depName of Object.keys(manifest.dependencies)) {
+        children.push(build(depName));
+      }
+
+      return {
+        name: pluginName,
+        version: manifest.version,
+        dependencies: children,
+      };
+    }
+
+    return build(name);
+  }
+
+  function detectCycles(name: string, registry: RegistryService): string[][] | null {
+    const cycles: string[][] = [];
+    const visited = new Set<string>();
+    const path: string[] = [];
+    const pathSet = new Set<string>();
+
+    function dfs(pluginName: string): void {
+      if (pathSet.has(pluginName)) {
+        // Found a cycle: extract the cycle from path
+        const cycleStart = path.indexOf(pluginName);
+        const cycle = path.slice(cycleStart).concat(pluginName);
+        cycles.push(cycle);
+        return;
+      }
+
+      if (visited.has(pluginName)) {
+        return;
+      }
+
+      const manifest = registry.get(pluginName);
+      if (!manifest) {
+        return;
+      }
+
+      path.push(pluginName);
+      pathSet.add(pluginName);
+
+      for (const depName of Object.keys(manifest.dependencies)) {
+        dfs(depName);
+      }
+
+      path.pop();
+      pathSet.delete(pluginName);
+      visited.add(pluginName);
+    }
+
+    dfs(name);
+
+    return cycles.length > 0 ? cycles : null;
+  }
+
+  function topologicalSort(name: string, registry: RegistryService): string[] {
+    const cycles = detectCycles(name, registry);
+    if (cycles) {
+      throw new Error(
+        `Circular dependencies detected: ${cycles.map((c) => c.join(' -> ')).join('; ')}`
+      );
+    }
+
+    const result: string[] = [];
+    const visited = new Set<string>();
+
+    function visit(pluginName: string): void {
+      if (visited.has(pluginName)) {
+        return;
+      }
+
+      visited.add(pluginName);
+
+      const manifest = registry.get(pluginName);
+      if (manifest) {
+        for (const depName of Object.keys(manifest.dependencies)) {
+          visit(depName);
+        }
+      }
+
+      result.push(pluginName);
+    }
+
+    visit(name);
+
+    return result;
+  }
+
+  function flattenDependencies(name: string, registry: RegistryService): string[] {
+    const visited = new Set<string>();
+
+    function collect(pluginName: string): void {
+      const manifest = registry.get(pluginName);
+      if (!manifest) {
+        return;
+      }
+
+      for (const depName of Object.keys(manifest.dependencies)) {
+        if (!visited.has(depName)) {
+          visited.add(depName);
+          collect(depName);
+        }
+      }
+    }
+
+    collect(name);
+
+    return Array.from(visited);
+  }
+
+  function hasCircularDependency(name: string, registry: RegistryService): boolean {
+    return detectCycles(name, registry) !== null;
+  }
+
+  return {
+    buildTree,
+    detectCycles,
+    topologicalSort,
+    flattenDependencies,
+    hasCircularDependency,
+  };
+}
