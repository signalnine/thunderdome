 plugin without name', async () => {\n      await expect(marketplace.installPlugin(makeManifest({ name: '' }))).rejects.toThrow('name');\n    });\n\n    it('should reject plugin without version', async () => {\n      await expect(marketplace.installPlugin(makeManifest({ version: '' }))).rejects.toThrow('version');\n    });\n\n    it('should reject plugin without entryPoint', async () => {\n      await expect(marketplace.installPlugin(makeManifest({ entryPoint: '' }))).rejects.toThrow('entryPoint');\n    });\n\n    it('should resolve dependencies during install', async () => {\n      // Register a dependency first\n      marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.0.0' }));\n      marketplace.registry.register(makeManifest({ name: 'dep-a', version: '1.2.0' }));\n\n      const result = await marketplace.installPlugin(\n        makeManifest({\n          name: 'my-plugin',\n          dependencies: { 'dep-a': '^1.0.0' },\n        }),\n      );\n      expect(result.resolvedDependencies).toHaveLength(1);\n      expect(result.resolvedDependencies[0].name).toBe('dep-a');\n      expect(result.resolvedDependencies[0].version).toBe('1.2.0');\n    });\n\n    it('should reject circular dependencies', async () => {\n      // Create a cycle: a depends on test-plugin\n      marketplace.registry.register(makeManifest({ name: 'dep-cycle', dependencies: { 'cyclic-plugin': '^1.0.0' } }));\n\n      await expect(\n        marketplace.installPlugin(\n          makeManifest({\n            name: 'cyclic-plugin',\n            dependencies: { 'dep-cycle': '^1.0.0' },\n          }),\n        ),\n      ).rejects.toThrow(/[Cc]ircular/);\n    });\n\n    it('should register the plugin in the catalog', async () => {\n      await marketplace.installPlugin(makeManifest({ name: 'registered-plugin' }));\n      const found = marketplace.registry.get('registered-plugin');\n      expect(found).not.toBeNull();\n      expect(found?.name).toBe('registered-plugin');\n    });\n\n    it('should handle plugin execution failure gracefully', async () => {\n      const result = await marketplace.installPlugin(\n        makeManifest({ entryPoint: 'throw new Error(\"init failed\")' }),\n      );\n      expect(result.executionResult.success).toBe(false);\n      expect(result.executionResult.error).toContain('init failed');\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"7965129d-bcba-43e4-8e42-1afb91135160"}
