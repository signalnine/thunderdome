index 0000000..e44dd35
--- /dev/null
+++ b/src/registry/index.ts
@@ -0,0 +1,180 @@
+import Database from 'better-sqlite3';
+import semver from 'semver';
+import type { PluginManifest, RegistryService } from '../types.js';
+
+export function createRegistry(): RegistryService {
+  const db = new Database(':memory:');
+
+  db.pragma('journal_mode = WAL');
+
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS plugins (
+      name TEXT NOT NULL,
+      version TEXT NOT NULL,
+      description TEXT NOT NULL,
+      author TEXT NOT NULL,
+      dependencies TEXT NOT NULL,
+      entryPoint TEXT NOT NULL,
+      permissions TEXT NOT NULL,
+      PRIMARY KEY (name, version)
+    )
+  `);
+
+  const insertStmt = db.prepare(`
+    INSERT OR REPLACE INTO plugins (name, version, description, author, dependencies, entryPoint, permissions)
+    VALUES (@name, @version, @description, @author, @dependencies, @entryPoint, @permissions)
+  `);
+
+  const getByNameStmt = db.prepare(`
+    SELECT * FROM plugins WHERE name = ?
+  `);
+
+  const getByNameVersionStmt = db.prepare(`
+    SELECT * FROM plugins WHERE name = ? AND version = ?
+  `);
+
+  const listAllStmt = db.prepare(`
+    SELECT * FROM plugins
+  `);
+
+  const searchStmt = db.prepare(`
+    SELECT * FROM plugins
+    WHERE name LIKE ? OR description LIKE ? OR author LIKE ?
+  `);
+
+  const removeStmt = db.prepare(`
+    DELETE FROM plugins WHERE name = ? AND version = ?
+  `);
+
+  const listVersionsStmt = db.prepare(`
+    SELECT version FROM plugins WHERE name = ?
+  `);
+
+  const updateStmt = db.prepare(`
+    UPDATE plugins
+    SET description = @description,
+        author = @author,
+        dependencies = @dependencies,
+        entryPoint = @entryPoint,
+        permissions = @permissions
+    WHERE name = @name AND version = @version
+  `);
+
+  function rowToManifest(row: Record<string, unknown>): PluginManifest {
+    return {
+      name: row.name as string,
+      version: row.version as string,
+      description: row.description as string,
+      author: row.author as string,
+      dependencies: JSON.parse(row.dependencies as string) as Record<string, string>,
+      entryPoint: row.entryPoint as string,
+      permissions: JSON.parse(row.permissions as string) as string[],
+    };
+  }
+
+  function manifestToRow(manifest: PluginManifest): Record<string, string> {
+    return {
+      name: manifest.name,
+      version: manifest.version,
+      description: manifest.description,
+      author: manifest.author,
+      dependencies: JSON.stringify(manifest.dependencies),
+      entryPoint: manifest.entryPoint,
+      permissions: JSON.stringify(manifest.permissions),
+    };
+  }
+
+  function pickLatest(rows: Record<string, unknown>[]): PluginManifest | null {
+    if (rows.length === 0) return null;
+    let best = rows[0];
+    for (let i = 1; i < rows.length; i++) {
+      if (semver.gt(rows[i].version as string, best.version as string)) {
+        best = rows[i];
+      }
+    }
+    return rowToManifest(best);
+  }
+
+  const registry: RegistryService = {
+    register(manifest: PluginManifest): void {
+      insertStmt.run(manifestToRow(manifest));
+    },
+
+    get(name: string): PluginManifest | null {
+      const rows = getByNameStmt.all(name) as Record<string, unknown>[];
+      return pickLatest(rows);
+    },
+
+    getVersion(name: string, version: string): PluginManifest | null {
+      const row = getByNameVersionStmt.get(name, version) as Record<string, unknown> | undefined;
+      return row ? rowToManifest(row) : null;
+    },
+
+    list(): PluginManifest[] {
+      const rows = listAllStmt.all() as Record<string, unknown>[];
+      const byName = new Map<string, Record<string, unknown>[]>();
+      for (const row of rows) {
+        const name = row.name as string;
+        let group = byName.get(name);
+        if (!group) {
+          group = [];
+          byName.set(name, group);
+        }
+        group.push(row);
+      }
+      const result: PluginManifest[] = [];
+      for (const group of byName.values()) {
+        const latest = pickLatest(group);
+        if (latest) result.push(latest);
+      }
+      return result;
+    },
+
+    search(query: string): PluginManifest[] {
+      const pattern = `%${query}%`;
+      const rows = searchStmt.all(pattern, pattern, pattern) as Record<string, unknown>[];
+      const byName = new Map<string, Record<string, unknown>[]>();
+      for (const row of rows) {
+        const name = row.name as string;
+        let group = byName.get(name);
+        if (!group) {
+          group = [];
+          byName.set(name, group);
+        }
+        group.push(row);
+      }
+      const result: PluginManifest[] = [];
+      for (const group of byName.values()) {
+        const latest = pickLatest(group);
+        if (latest) result.push(latest);
+      }
+      return result;
+    },
+
+    remove(name: string, version: string): boolean {
+      const result = removeStmt.run(name, version);
+      return result.changes > 0;
+    },
+
+    listVersions(name: string): string[] {
+      const rows = listVersionsStmt.all(name) as Array<{ version: string }>;
+      return rows.map((r) => r.version);
+    },
+
+    update(name: string, version: string, updates: Partial<PluginManifest>): void {
+      const existing = getByNameVersionStmt.get(name, version) as Record<string, unknown> | undefined;
+      if (!existing) return;
+
+      const current = rowToManifest(existing);
+      const updated: PluginManifest = {
+        ...current,
+        ...updates,
+        name,
+        version,
+      };
+      updateStmt.run(manifestToRow(updated));
+    },
+  };
+
+  return registry;
+}
