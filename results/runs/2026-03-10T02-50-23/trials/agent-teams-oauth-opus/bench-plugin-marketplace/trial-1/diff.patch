+++ b/src/runner/index.ts
@@ -0,0 +1,78 @@
+import vm from 'node:vm';
+import type { RunnerService, SandboxResult } from '../types.js';
+
+const DEFAULT_TIMEOUT_MS = 5000;
+
+function executeInSandbox(
+  code: string,
+  timeoutMs: number,
+  context?: Record<string, unknown>,
+): SandboxResult {
+  const memBefore = process.memoryUsage().heapUsed;
+  const startTime = performance.now();
+
+  try {
+    const sandbox: Record<string, unknown> = { ...context };
+    const vmContext = vm.createContext(sandbox);
+
+    const script = new vm.Script(code);
+    const scriptResult = script.runInContext(vmContext, { timeout: timeoutMs });
+
+    const duration = performance.now() - startTime;
+    const memAfter = process.memoryUsage().heapUsed;
+    const memoryUsed = Math.max(0, memAfter - memBefore);
+
+    const output = sandbox.result !== undefined ? sandbox.result : scriptResult;
+
+    return {
+      success: true,
+      output,
+      duration,
+      memoryUsed,
+    };
+  } catch (err: unknown) {
+    const duration = performance.now() - startTime;
+    const memAfter = process.memoryUsage().heapUsed;
+    const memoryUsed = Math.max(0, memAfter - memBefore);
+
+    let errorMessage: string;
+    const errObj = err as { message?: string };
+    if (
+      typeof errObj.message === 'string' &&
+      errObj.message.includes('Script execution timed out')
+    ) {
+      errorMessage = 'Script execution timed out';
+    } else if (typeof errObj.message === 'string') {
+      errorMessage = errObj.message;
+    } else {
+      errorMessage = String(err);
+    }
+
+    return {
+      success: false,
+      output: undefined,
+      duration,
+      memoryUsed,
+      error: errorMessage,
+    };
+  }
+}
+
+export function createRunner(): RunnerService {
+  return {
+    async execute(
+      code: string,
+      context?: Record<string, unknown>,
+    ): Promise<SandboxResult> {
+      return executeInSandbox(code, DEFAULT_TIMEOUT_MS, context);
+    },
+
+    async executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context?: Record<string, unknown>,
+    ): Promise<SandboxResult> {
+      return executeInSandbox(code, timeoutMs, context);
+    },
+  };
+}
