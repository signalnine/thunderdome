e.startsWith('y')) {\n    51→        const num = parseInt(wire.slice(1), 10);\n    52→        if (num > maxBit) maxBit = num;\n    53→      }\n    54→    }\n    55→  }\n    56→  const numBits = maxBit + 1;\n    57→\n    58→  // Build lookup structures\n    59→  const gateByOutput = new Map<string, Gate>();\n    60→  for (const gate of gates) {\n    61→    gateByOutput.set(gate.out, gate);\n    62→  }\n    63→\n    64→  // Helper: find a gate with given op and inputs (order-independent)\n    65→  function findGate(\n    66→    op: Gate['op'],\n    67→    in1: string,\n    68→    in2: string,\n    69→  ): Gate | undefined {\n    70→    for (const gate of gates) {\n    71→      if (gate.op !== op) continue;\n    72→      if (\n    73→        (gate.in1 === in1 && gate.in2 === in2) ||\n    74→        (gate.in1 === in2 && gate.in2 === in1)\n    75→      ) {\n    76→        return gate;\n    77→      }\n    78→    }\n    79→    return undefined;\n    80→  }\n    81→\n    82→  // Helper: find a gate with given op that has `wire` as one of its inputs\n    83→  function findGateWithInput(\n    84→    op: Gate['op'],\n    85→    wire: string,\n    86→  ): Gate | undefined {\n    87→    for (const gate of gates) {\n    88→      if (gate.op !== op) continue;\n    89→      if (gate.in1 === wire || gate.in2 === wire) {\n    90→        return gate;\n    91→      }\n    92→    }\n    93→    return undefined;\n    94→  }\n    95→\n    96→  // Helper: get the other input of a gate given one input\n    97→  function otherInput(gate: Gate, knownInput: string): string {\n    98→    return gate.in1 === knownInput ? gate.in2 : gate.in1;\n    99→  }\n   100→\n   101→  const swapped = new Set<string>();\n   102→\n   103→  // For a correct ripple-carry adder, each bit position i has a known structure.\n   104→  // We walk through the adder bit by bit, tracking the carry wire, and detect\n   105→  // structural violations that indicate swaps.\n   106→\n   107→  // Bit 0 is special: z00 = x00 X