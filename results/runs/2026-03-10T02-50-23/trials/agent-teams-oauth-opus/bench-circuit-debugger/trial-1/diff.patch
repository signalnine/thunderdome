+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+  let changed = true;
+
+  while (remaining.length > 0 && changed) {
+    changed = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      const v1 = wires[gate.in1];
+      const v2 = wires[gate.in2];
+      if (v1 !== undefined && v2 !== undefined) {
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = v1 & v2;
+            break;
+          case 'OR':
+            result = v1 | v2;
+            break;
+          case 'XOR':
+            result = v1 ^ v2;
+            break;
+        }
+        wires[gate.out] = result;
+        remaining.splice(i, 1);
+        changed = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Determine the number of input bits
+  let maxBit = 0;
+  for (const gate of gates) {
+    for (const wire of [gate.in1, gate.in2, gate.out]) {
+      if (wire.startsWith('x') || wire.startsWith('y')) {
+        const num = parseInt(wire.slice(1), 10);
+        if (num > maxBit) maxBit = num;
+      }
+    }
+  }
+  const numBits = maxBit + 1;
+
+  // Build lookup structures
+  const gateByOutput = new Map<string, Gate>();
+  for (const gate of gates) {
+    gateByOutput.set(gate.out, gate);
+  }
+
+  // Helper: find a gate with given op and inputs (order-independent)
+  function findGate(
+    op: Gate['op'],
+    in1: string,
+    in2: string,
+  ): Gate | undefined {
+    for (const gate of gates) {
+      if (gate.op !== op) continue;
+      if (
+        (gate.in1 === in1 && gate.in2 === in2) ||
+        (gate.in1 === in2 && gate.in2 === in1)
+      ) {
+        return gate;
+      }
+    }
+    return undefined;
+  }
+
+  // Helper: find a gate with given op that has `wire` as one of its inputs
+  function findGateWithInput(
+    op: Gate['op'],
+    wire: string,
+  ): Gate | undefined {
+    for (const gate of gates) {
+      if (gate.op !== op) continue;
+      if (gate.in1 === wire || gate.in2 === wire) {
+        return gate;
+      }
+    }
+    return undefined;
+  }
+
+  // Helper: get the other input of a gate given one input
+  function otherInput(gate: Gate, knownInput: string): string {
+    return gate.in1 === knownInput ? gate.in2 : gate.in1;
+  }
+
+  const swapped = new Set<string>();
+
+  // For a correct ripple-carry adder, each bit position i has a known structure.
+  // We walk through the adder bit by bit, tracking the carry wire, and detect
+  // structural violations that indicate swaps.
+
+  // Bit 0 is special: z00 = x00 XOR y00, c00 = x00 AND y00
+  // For bit i >= 1:
