.padStart(2, '0')}`;\n  const yWire = (i: number) => `y${i.toString().padStart(2, '0')}`;\n  const zWire = (i: number) => `z${i.toString().padStart(2, '0')}`;\n\n  // Track carry wire for each bit\n  let carry = '';\n\n  for (let i = 0; i < numBits; i++) {\n    const xi = xWire(i);\n    const yi = yWire(i);\n    const zi = zWire(i);\n\n    if (i === 0) {\n      // Bit 0: z00 = x00 XOR y00\n      const xorGate = findGate('XOR', xi, yi);\n      if (!xorGate) continue;\n\n      if (xorGate.out !== zi) {\n        // z00 output is swapped with something else\n        swapped.add(xorGate.out);\n        swapped.add(zi);\n        // Swap them in the circuit\n        swapOutputs(xorGate.out, zi);\n      }\n\n      // c00 = x00 AND y00\n      const andGate = findGate('AND', xi, yi);\n      if (andGate) {\n        carry = andGate.out;\n      }\n    } else {\n      // Bit i: t_i = x_i XOR y_i\n      const xorXY = findGate('XOR', xi, yi);\n      if (!xorXY) continue;\n      let t = xorXY.out;\n\n      // z_i = t_i XOR carry\n      // First check: t should not be a z wire (unless it IS z_i, which would be wrong structure)\n      // If t starts with 'z', it's swapped\n      if (t.startsWith('z') && t !== zi) {\n        // t_i's output is swapped - it shouldn't be a z wire\n        // We need to find what zi's gate actually outputs\n        const zGate = gateByOutput.get(zi);\n        if (zGate) {\n          swapped.add(t);\n          swapped.add(zi);\n          swapOutputs(t, zi);\n          t = xorXY.out; // After swap\n        }\n      }\n\n      // Now find the gate that XORs t with carry to produce z_i\n      let xorTC = findGate('XOR', t, carry);\n\n      if (!xorTC) {\n        // The XOR gate using t as input exists but may have wrong output\n        // Or the XOR gate using carry exists but t was swapped\n        const xorWithT = findGateWithInput('XOR', t);\n        if (xorWithT && xorWithT !== xorXY) {\n          // This gate should use carry as the other input\n          const other = otherInput(xorWithT, t);\n          if (other !== carry) {\n            // carry is wrong - the previous carry output was swapped\n            // Actually, \"other\" is what the circuit thinks is carry\n            // Let's check: maybe t is wrong (xorXY.out was swapped)\n            // Try the other way: find XOR gate with carry\n            const xorWithCarry = findGateWithInput('XOR', carry);\n            if (\n              xorWithCarry &&\n              xorWithCarry !== xorXY &&\n              xorWithCarry.op === 'XOR'\n            ) {\n              // carry is used in an XOR with something else\n              // That something else should be t, but it's not\n              // So t and that something else might be swapped\n              const otherT = otherInput(xorWithCarry, carry);\n              if (otherT !== t) {\n                // t (xorXY.out) is swapped with otherT\n                swapped.add(t);\n                swapped.add(otherT);\n                swapOutputs(t, otherT);\n                t = xorXY.out;\n                xorTC = xorWithCarry;\n              }\n            } else {\n              // carry is not used in any other XOR - carry itself might be swapped\n              swapped.add(carry);\n              swapped.add(other);\n              swapOutputs(carry, other);\n              carry = other;\n              xorTC = xorWithT;\n            }\n          } else {\n            xorTC = xorWithT;\n          }\n        } else {\n          // No XOR gate with t at all (other than xorXY)\n          // Try finding XOR with carry\n          const xorWithCarry = findGateWithInput('XOR', carry);\n          if (xorWithCarry && xorWithCarry !== xorXY) {\n            const otherT = otherInput(xorWithCarry, carry);\n            swapped.add(t);\n            swapped.add(otherT);\n            swapOutputs(t, otherT);\n            t = xorXY.out;\n            xorTC = xorWithCarry;\n          }\n        }\n      }\n\n      if (xorTC) {\n        // C