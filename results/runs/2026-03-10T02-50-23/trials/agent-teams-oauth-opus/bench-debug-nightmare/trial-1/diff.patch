rs.get(event) ?? [];\n    existing.push(handler);\n    globalHandlers.set(event, existing);\n  }\n\n  off(event: string, handler: EventHandler): void {\n    const existing = globalHandlers.get(event);\n    if (!existing) return;\n    globalHandlers.set(\n      event,\n      existing.filter((h) => h !== handler)\n    );\n  }\n\n  async emit(event: string, data: unknown): Promise<void> {\n    const handlers = globalHandlers.get(event) ?? [];\n    for (const handler of handlers) {\n      await handler(data);\n    }\n  }\n\n  clear(): void {\n    globalHandlers.clear();\n  }\n}\n","numLines":33,"startLine":1,"totalLines":33}},"sourceToolAssistantUUID":"47f71d53-366e-4801-867b-265a714ef255"}
