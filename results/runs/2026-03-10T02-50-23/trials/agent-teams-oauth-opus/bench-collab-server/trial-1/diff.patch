index 0000000..95b0a65
--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,139 @@
+import { Operation } from './types.js';
+
+/**
+ * Transform operation A against operation B using Operational Transformation.
+ * Returns a new operation A' such that applying B then A' yields the same
+ * document state as applying A then B'.
+ */
+export function transformOperation(opA: Operation, opB: Operation): Operation {
+  const a = { ...opA };
+
+  if (a.type === 'insert' && opB.type === 'insert') {
+    // Both inserting: if A's position is after B's insertion point,
+    // shift A right by B's inserted length
+    if (a.position > opB.position) {
+      a.position += (opB.content?.length ?? 0);
+    } else if (a.position === opB.position) {
+      // Tie-break: compare content lexicographically for determinism
+      if ((a.content ?? '') > (opB.content ?? '')) {
+        a.position += (opB.content?.length ?? 0);
+      }
+    }
+  } else if (a.type === 'insert' && opB.type === 'delete') {
+    // A inserts, B deletes
+    const delEnd = opB.position + (opB.length ?? 0);
+    if (a.position >= delEnd) {
+      a.position -= (opB.length ?? 0);
+    } else if (a.position > opB.position) {
+      // Insert falls within deleted range; move to start of deletion
+      a.position = opB.position;
+    }
+  } else if (a.type === 'delete' && opB.type === 'insert') {
+    // A deletes, B inserts
+    const insertPos = opB.position;
+    const insertLen = opB.content?.length ?? 0;
+    const delEnd = a.position + (a.length ?? 0);
+
+    if (a.position >= insertPos) {
+      a.position += insertLen;
+    } else if (delEnd > insertPos) {
+      // The deletion range spans the insertion point.
+      // Split is complex; simplify: increase delete length to cover inserted content is wrong.
+      // Instead, just shift end of deletion range.
+      a.length = (a.length ?? 0) + insertLen;
+    }
+  } else if (a.type === 'delete' && opB.type === 'delete') {
+    // Both deleting
+    const aEnd = a.position + (a.length ?? 0);
+    const bEnd = opB.position + (opB.length ?? 0);
+
+    if (a.position >= bEnd) {
+      // A is entirely after B's deletion
+      a.position -= (opB.length ?? 0);
+    } else if (aEnd <= opB.position) {
+      // A is entirely before B's deletion - no change needed
+    } else {
+      // Overlapping deletions
+      const overlapStart = Math.max(a.position, opB.position);
+      const overlapEnd = Math.min(aEnd, bEnd);
+      const overlapLen = Math.max(0, overlapEnd - overlapStart);
+
+      // Reduce A's length by the overlap (already deleted by B)
+      a.length = (a.length ?? 0) - overlapLen;
+      // Move position if B's deletion starts before A
+      if (opB.position < a.position) {
+        a.position -= Math.min(a.position - opB.position, opB.length ?? 0);
+      }
+    }
+  }
+
+  return a;
+}
+
+/**
+ * Transform an operation against a sequence of operations.
+ * Used to bring a client operation up to the current server version.
+ */
+export function transformAgainstAll(op: Operation, serverOps: Operation[]): Operation {
+  let transformed = { ...op };
+  for (const serverOp of serverOps) {
+    transformed = transformOperation(transformed, serverOp);
+  }
+  return transformed;
+}
+
+/**
+ * Apply an operation to a document content string.
+ * Returns the new content.
+ */
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    return content.slice(0, pos) + (op.content ?? '') + content.slice(pos);
+  } else if (op.type === 'delete') {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    const len = Math.min(op.length ?? 0, content.length - pos);
+    if (len <= 0) return content;
+    return content.slice(0, pos) + content.slice(pos + len);
+  }
+  return content;
+}
+
+/**
+ * Validate that an operation is well-formed and safe to apply to
+ * a document of the given length.
+ */
+export function validateOperation(op: Operation, docLength: number): string | null {
+  if (!op || typeof op !== 'object') {
+    return 'Operation must be an object';
+  }
+  if (op.type !== 'insert' && op.type !== 'delete') {
+    return 'Operation type must be "insert" or "delete"';
+  }
+  if (typeof op.position !== 'number' || op.position < 0 || !Number.isFinite(op.position)) {
+    return 'Operation position must be a non-negative number';
+  }
+  if (typeof op.version !== 'number' || op.version < 0 || !Number.isFinite(op.version)) {
+    return 'Operation version must be a non-negative number';
+  }
+  if (op.type === 'insert') {
+    if (typeof op.content !== 'string' || op.content.length === 0) {
+      return 'Insert operation must have non-empty content string';
+    }
+    if (op.position > docLength) {
+      return `Insert position ${op.position} is past end of document (length ${docLength})`;
+    }
+  }
+  if (op.type === 'delete') {
+    if (typeof op.length !== 'number' || op.length <= 0 || !Number.isFinite(op.length)) {
+      return 'Delete operation must have a positive length';
+    }
+    if (op.position > docLength) {
+      return `Delete position ${op.position} is past end of document (length ${docLength})`;
+    }
+    if (op.position + op.length > docLength) {
+      return `Delete range extends past end of document`;
+    }
+  }
+  return null;
+}
