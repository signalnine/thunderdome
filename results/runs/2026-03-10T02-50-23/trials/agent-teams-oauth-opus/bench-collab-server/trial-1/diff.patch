+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export type OperationType = 'insert' | 'delete';
+
+export interface Operation {
+  type: OperationType;
+  position: number;
+  content?: string;  // for insert
+  length?: number;   // for delete
+  version: number;   // base version this op was created against
+}
+
+export interface WsMessage {
+  type: 'operation' | 'sync' | 'ack' | 'error' | 'cursor';
+  documentId?: string;
+  operation?: Operation;
+  content?: string;
+  version?: number;
+  title?: string;
+  message?: string;
+  clientId?: string;
+}
