dated = await getRes.json();\n    // Should have A, X, C, D (B deleted, X inserted)\n    expect(updated.content).toBe('AXCD');\n\n    ws1.close();\n    ws2.close();\n  });\n});\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"0a61b9d0-505c-4f9f-bc9a-aabb2cfa73c3"}
