+import { WebSocketServer, WebSocket } from 'ws';
+import { IncomingMessage, Server as HttpServer } from 'http';
+import { Duplex } from 'stream';
+import { randomUUID } from 'crypto';
+import { DocumentDatabase } from './database.js';
+import { Operation, WsMessage } from './types.js';
+import { applyOperation, transformAgainstAll, validateOperation } from './ot.js';
+
+interface ClientConnection {
+  ws: WebSocket;
+  clientId: string;
+  documentId: string;
+}
+
+interface DocumentState {
+  version: number;
+  content: string;
+  operations: Operation[]; // history of server-applied operations for OT
+}
+
+export class CollaborationServer {
+  private wss: WebSocketServer;
+  private clients: Map<string, ClientConnection> = new Map();
+  private documentStates: Map<string, DocumentState> = new Map();
+  private db: DocumentDatabase;
+
+  constructor(server: HttpServer, db: DocumentDatabase) {
+    this.db = db;
+    this.wss = new WebSocketServer({ noServer: true });
+
+    server.on('upgrade', (request: IncomingMessage, socket: Duplex, head: Buffer) => {
+      const url = new URL(request.url ?? '/', `http://${request.headers.host ?? 'localhost'}`);
+      const pathMatch = url.pathname.match(/^\/ws\/documents\/([^/]+)$/);
+
+      if (!pathMatch) {
+        socket.destroy();
+        return;
+      }
+
+      const documentId = pathMatch[1];
+      const doc = this.db.getDocument(documentId);
+
+      if (!doc) {
+        socket.write('HTTP/1.1 404 Not Found\r\n\r\n');
+        socket.destroy();
+        return;
+      }
+
+      this.wss.handleUpgrade(request, socket, head, (ws) => {
+        this.handleConnection(ws, documentId);
+      });
+    });
+  }
+
+  private getDocumentState(documentId: string): DocumentState {
+    if (!this.documentStates.has(documentId)) {
+      const doc = this.db.getDocument(documentId);
+      if (!doc) throw new Error(`Document ${documentId} not found`);
+      const version = this.db.getLatestVersion(documentId);
+      this.documentStates.set(documentId, {
+        version,
+        content: doc.content,
+        operations: [],
+      });
+    }
+    return this.documentStates.get(documentId)!;
+  }
+
+  private handleConnection(ws: WebSocket, documentId: string): void {
+    const clientId = randomUUID();
+    const conn: ClientConnection = { ws, clientId, documentId };
+    this.clients.set(clientId, conn);
+
+    const state = this.getDocumentState(documentId);
+
+    // Send sync message with current document state
+    const syncMsg: WsMessage = {
+      type: 'sync',
+      documentId,
+      content: state.content,
+      version: state.version,
+      clientId,
+    };
+    ws.send(JSON.stringify(syncMsg));
+
+    ws.on('message', (data) => {
+      try {
+        const msg = JSON.parse(data.toString()) as WsMessage;
+        this.handleMessage(clientId, msg);
+      } catch {
+        const errorMsg: WsMessage = {
+          type: 'error',
+          message: 'Invalid message format',
+        };
+        ws.send(JSON.stringify(errorMsg));
+      }
+    });
+
+    ws.on('close', () => {
+      this.clients.delete(clientId);
+    });
+
+    ws.on('error', () => {
+      this.clients.delete(clientId);
+    });
+  }
+
+  private handleMessage(clientId: string, msg: WsMessage): void {
+    const conn = this.clients.get(clientId);
+    if (!conn) return;
+
+    if (msg.type === 'operation' && msg.operation) {
+      this.handleOperation(conn, msg.operation);
+    }
+  }
+
+  private handleOperation(conn: ClientConnection, op: Operation): void {
+    const state = this.getDocumentState(conn.documentId);
+
+    // Validate version
+    if (op.version < 0 || op.version > state.version) {
+      const errorMsg: WsMessage = {
+        type: 'error',
+        message: `Invalid version ${op.version}. Current version is ${state.version}`,
+      };
+      conn.ws.send(JSON.stringify(errorMsg));
+      return;
+    }
+
+    // Transform against concurrent operations
+    const concurrentOps = state.operations.slice(op.version);
+    let transformed: Operation;
+    try {
+      transformed = transformAgainstAll(op, concurrentOps);
+    } catch {
+      const errorMsg: WsMessage = {
+        type: 'error',
+        message: 'Failed to transform operation',
+      };
+      conn.ws.send(JSON.stringify(errorMsg));
+      return;
+    }
+
+    // Validate the transformed operation against current document state
+    const validationError = validateOperation(transformed, state.content.length);
+    if (validationError) {
+      const errorMsg: WsMessage = {
+        type: 'error',
+        message: validationError,
+      };
+      conn.ws.send(JSON.stringify(errorMsg));
+      return;
+    }
+
+    // Apply the transformed operation
+    const newContent = applyOperation(state.content, transformed);
+    state.version++;
+    state.content = newContent;
+    transformed.version = state.version;
+    state.operations.push(transformed);
+
+    // Persist to database
+    this.db.updateDocumentContent(conn.documentId, newContent);
+    this.db.addVersion(
+      conn.documentId,
+      state.version,
+      newContent,
+      JSON.stringify(transformed)
+    );
+
+    // Send ack to the originating client
+    const ackMsg: WsMessage = {
+      type: 'ack',
+      version: state.version,
+    };
+    conn.ws.send(JSON.stringify(ackMsg));
+
+    // Broadcast the transformed operation to all other clients on this document
+    const broadcastMsg: WsMessage = {
+      type: 'operation',
+      operation: transformed,
+      version: state.version,
+      clientId: conn.clientId,
+    };
+    const broadcastStr = JSON.stringify(broadcastMsg);
+
+    for (const [id, client] of this.clients) {
+      if (id !== conn.clientId && client.documentId === conn.documentId) {
+        if (client.ws.readyState === WebSocket.OPEN) {
+          client.ws.send(broadcastStr);
+        }
+      }
+    }
+  }
+
+  closeAll(): void {
+    for (const [, conn] of this.clients) {
+      conn.ws.close();
+    }
+    this.clients.clear();
+    this.documentStates.clear();
+    this.wss.close();
+  }
+
+  getConnectedClients(documentId: string): number {
+    let count = 0;
+    for (const [, conn] of this.clients) {
+      if (conn.documentId === documentId) count++;
+    }
+    return count;
+  }
+}
