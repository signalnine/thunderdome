t {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\nexport interface ScheduleResult {\n  assignments: Assignment[];\n  unscheduled: string[];\n}\n\nfunction detectCycle(events: Event[]): void {\n  const eventIds = new Set(events.map(e => e.id));\n  const visited = new Set<string>();\n  const inStack = new Set<string>();\n  const adjMap = new Map<string, string[]>();\n\n  for (const event of events) {\n    if (event.prerequisites) {\n      for (const pre of event.prerequisites) {\n        if (pre === event.id) {\n          throw new Error(`Cycle detected: event \"${event.id}\" has a self-reference`);\n        }\n      }\n      adjMap.set(event.id, event.prerequisites.filter(p => eventIds.has(p)));\n    }\n  }\n\n  function dfs(id: string): void {\n    visited.add(id);\n    inStack.add(id);\n    const deps = adjMap.get(id) || [];\n    for (const dep of deps) {\n      if (inStack.has(dep)) {\n        throw new Error(`Cycle detected in prerequisites involving event \"${dep}\"`);\n      }\n      if (!visited.has(dep)) {\n        dfs(dep);\n      }\n    }\n    inStack.delete(id);\n  }\n\n  for (const event of events) {\n    if (!visited.has(event.id)) {\n      dfs(event.id);\n    }\n  }\n}\n\nfunction topologicalSort(events: Event[]): Event[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) eventMap.set(e.id, e);\n  const eventIds = new Set(events.map(e => e.id));\n\n  const inDegree = new Map<string, number>();\n  const dependents = new Map<string, string[]>();\n\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n    dependents.set(e.id, []);\n  }\n\n  for (const e of events) {\n    if (e.prerequisites) {\n      let count = 0;\n      for (const pre of e.prerequisites) {\n        if (eventIds.has(pre)) {\n          count++;\n          dependents.get(pre)!.push(e.id);\n        }\n      }\n      inDegree.set(e.id, count);\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const sorted: Event[] = [];\n  while (queue.length > 0) {\n    queue.sort();\n    const id = queue.shift()!;\n    sorted.push(eventMap.get(id)!);\n    for (const dep of dependents.get(id)!) {\n      const newDeg = inDegree.get(dep)! - 1;\n      inDegree.set(dep, newDeg);\n      if (newDeg === 0) queue.push(dep);\n    }\n  }\n\n  return sorted;\n}\n\nfunction getEarliestStartAfterPrereqs(\n  event: Event,\n  assignments: Map<string, Assignment>,\n  gap: number,\n  windowStart: number\n): number {\n  let earliest = windowStart;\n  if (event.prerequisites) {\n    for (const preId of event.prerequisites) {\n      const preAssignment = assignments.get(preId);\n      if (preAssignment) {\n        earliest = Math.max(earliest, preAssignment.endTime + gap);\n      }\n    }\n  }\n  return earliest;\n}\n\nfunction getEarliestSlotInRoom(\n  roomAssignments: Assignment[],\n  duration: number,\n  earliestStart: number,\n  windowEnd: number,\n  gap: number\n): number | null {\n  // Try to find the earliest slot in this room\n  // roomAssignments are sorted by startTime\n\n  if (roomAssignments.length === 0) {\n    if (earliestStart + duration <= windowEnd) {\n      return earliestStart;\n    }\n    return null;\n  }\n\n  // Try before first event\n  const firstEvent = roomAssignments[0];\n  if (earliestStart + duration + gap <= firstEvent.startTime) {\n    return earliestStart;\n  }\n\n  // Try between events\n  for (let i = 0; i < roomAssignments.length; i++) {\n    const slotStart = Math.max(earliestStart, roomAssignments[i].endTime + gap);\n    const nextStart = i + 1 < roomAssignments.length ? roomAssignments[i + 1].startTime : windowEnd + gap;\n    if (slotStart + duration + (i + 1 < roomAssignments.length ? gap : 0) <= nextStart) {\n      if (slotStart + duration <= windowEnd) {\n        return slotStart;\n      }\n    }\n  }\n\n  return null;\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  detectCycle(events);\n\n  const gap = options.gap ?? 15;\n  const { startTime: windowStart, endTime: windowEnd } = options;\n\n  const sorted = topologicalSort(events);\n  const eventMap = new Map<string, Event>();\n  for (const e of events) eventMap.set(e.id, e);\n\n  // Sort rooms by capacity ascending for better packing\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Track assignments per room (sorted by start time)\n  const roomSchedules = new Map<string, Assignment[]>();\n  for (const room of rooms) roomSchedules.set(room.id, []);\n\n  const assignments = new Map<string, Assignment>();\n  const unscheduled: string[] = [];\n\n  // Check if all prerequisites are scheduled\n  function prereqsScheduled(event: Event): boolean {\n    if (!event.prerequisites) return true;\n    const eventIds = new Set(events.map(e => e.id));\n    for (const preId of event.prerequisites) {\n      if (eventIds.has(preId) && !assignments.has(preId)) return false;\n    }\n    return true;\n  }\n\n  // Try to place an event, returning the best assignment or null\n  function tryPlace(event: Event): Assignment | null {\n    if (!prereqsScheduled(event)) return null;\n\n    const attendees = event.attendees ?? 1;\n    const earliestFromPrereqs = getEarliestStartAfterPrereqs(event, assignments, gap, windowStart);\n\n    if (earliestFromPrereqs + event.duration > windowEnd) return null;\n\n    // Filter rooms by capacity\n    const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);\n    if (eligibleRooms.length === 0) return null;\n\n    // Try preferred room first if specified\n    let bestAssignment: Assignment | null = null;\n    let bestStart = Infinity;\n    let isPreferred = false;\n\n    const tryRoom = (room: Room, preferred: boolean) => {\n      const roomAsgn = roomSchedules.get(room.id)!;\n      const slotStart = getEarliestSlotInRoom(roomAsgn, event.duration, earliestFromPrereqs, windowEnd, gap);\n      if (slotStart !== null) {\n        // Prefer: preferred room, then earliest start, then smallest capacity\n        if (\n          bestAssignment === null ||\n          (preferred && !isPreferred) ||\n          (preferred === isPreferred && slotStart < bestStart) ||\n          (preferred === isPreferred && slotStart === bestStart && room.capacity < (rooms.find(r => r.id === bestAssignment!.roomId)?.capacity ?? Infinity))\n        ) {\n          bestAssignment = {\n            eventId: event.id,\n            roomId: room.id,\n            startTime: slotStart,\n            endTime: slotStart + event.duration,\n          };\n          bestStart = slotStart;\n          isPreferred = preferred;\n        }\n      }\n    };\n\n    if (event.preferredRoom) {\n      const prefRoom = eligibleRooms.find(r => r.id === event.preferredRoom);\n      if (prefRoom) tryRoom(prefRoom, true);\n    }\n\n    for (const room of eligibleRooms) {\n      tryRoom(room, false);\n    }\n\n    return bestAssignment;\n  }\n\n  // Greedy assignment in topological order\n  for (const event of sorted) {\n    const assignment = tryPlace(event);\n    if (assignment) {\n      assignments.set(event.id, assignment);\n      const roomAsgn = roomSchedules.get(assignment.roomId)!;\n      roomAsgn.push(assignment);\n      roomAsgn.sort((a, b) => a.startTime - b.startTime);\n    } else {\n      unscheduled.push(event.id);\n    }\n  }\n\n  // Handle events not in topological sort (prereqs not in event list - should still be sorted)\n  const scheduledIds = new Set([...assignments.keys(), ...unscheduled]);\n  for (const event of events) {\n    if (!scheduledIds.has(event.id)) {\n      unscheduled.push(event.id);\n    }\n  }\n\n  // Backtracking optimization: try to schedule unscheduled events by rearranging\n  // Try multiple passes to improve the schedule\n  let improved = true;\n  while (improved && unscheduled.length > 0) {\n    improved = false;\n    for (let i = unscheduled.length - 1; i >= 0; i--) {\n      const eventId = unscheduled[i];\n      const event = eventMap.get(eventId)!;\n      if (!prereqsScheduled(event)) continue;\n\n      const assignment = tryPlace(event);\n      if (assignment) {\n        assignments.set(event.id, assignment);\n        const roomAsgn = roomSchedules.get(assignment.roomId)!;\n        roomAsgn.push(assignment);\n        roomAsgn.sort((a, b) => a.startTime - b.startTime);\n        unscheduled.splice(i, 1);\n        improved = true;\n      }\n    }\n  }\n\n  return {\n    assignments: Array.from(assignments.values()),\n    unscheduled,\n  };\n}\n","numLines":305,"startLine":1,"totalLines":305}},"sourceToolAssistantUUID":"25f83b2c-31b7-4cf7-b6a3-cf5a18ed1a40"}
