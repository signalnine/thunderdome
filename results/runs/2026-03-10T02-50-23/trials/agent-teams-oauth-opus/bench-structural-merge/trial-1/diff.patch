index 0000000..9c0f470
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,241 @@
+import type { Version, MergeResult, Conflict, DocumentState } from './types.js';
+import { deepClone, threeWayMerge } from './merge.js';
+
+export type { Version, MergeResult, Conflict };
+
+type BranchData = Map<string, DocumentState>;
+
+let versionCounter = 0;
+function generateVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+  // Track the snapshot of the parent branch at the time of branching
+  private branchPoints: Map<string, BranchData> = new Map();
+
+  constructor() {
+    this.branches.set('main', new Map());
+    // main's branch point is an empty state
+    this.branchPoints.set('main', new Map());
+  }
+
+  // ---- CRUD ----
+
+  create(id: string, content: object): void {
+    const branch = this.getCurrentBranchData();
+    const existing = branch.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    branch.set(id, {
+      content: deepClone(content),
+      deleted: false,
+      versions: existing ? [...existing.versions, version] : [version],
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    doc.content = deepClone(content);
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    doc.deleted = true;
+    doc.content = {};
+  }
+
+  // ---- Version History ----
+
+  getHistory(id: string): Version[] {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return doc.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getCurrentBranchData();
+    const doc = branch.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version = doc.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // ---- Branching ----
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch "${sourceName}" not found`);
+    }
+    const newBranch = this.cloneBranchData(source);
+    this.branches.set(name, newBranch);
+    // Record the branch point (snapshot of source at time of branching)
+    this.branchPoints.set(name, this.cloneBranchData(source));
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // ---- Merging ----
+
+  merge(sourceBranch: string): MergeResult {
+    const source = this.branches.get(sourceBranch);
+    if (!source) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+    const target = this.getCurrentBranchData();
+
+    // Find common ancestor: the branch point of the source branch
+    const base = this.branchPoints.get(sourceBranch);
+    if (!base) {
+      throw new Error(`No branch point found for "${sourceBranch}"`);
+    }
+
+    // Collect all document IDs across base, source, and target
+    const allIds = new Set<string>();
+    for (const id of base.keys()) allIds.add(id);
+    for (const id of source.keys()) allIds.add(id);
+    for (const id of target.keys()) allIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    for (const docId of allIds) {
+      const baseDoc = base.get(docId);
+      const oursDoc = target.get(docId);
+      const theirsDoc = source.get(docId);
+
+      const baseContent = baseDoc && !baseDoc.deleted ? baseDoc.content : undefined;
+      const oursContent = oursDoc && !oursDoc.deleted ? oursDoc.content : undefined;
+      const theirsContent = theirsDoc && !theirsDoc.deleted ? theirsDoc.content : undefined;
+
+      // Skip documents with no changes
+      const baseExists = baseContent !== undefined;
+      const oursExists = oursContent !== undefined;
+      const theirsExists = theirsContent !== undefined;
+
+      // Check if anything changed
+      const oursChanged = baseExists !== oursExists ||
+        (baseContent !== undefined && oursContent !== undefined && JSON.stringify(baseContent) !== JSON.stringify(oursContent));
+      const theirsChanged = baseExists !== theirsExists ||
+        (baseContent !== undefined && theirsContent !== undefined && JSON.stringify(baseContent) !== JSON.stringify(theirsContent));
+
+      if (!oursChanged && !theirsChanged) {
+        continue; // No changes on either side
+      }
+
+      const result = threeWayMerge(docId, baseContent, oursContent, theirsContent);
+      merged[docId] = result.merged;
+      allConflicts.push(...result.conflicts);
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge
+      for (const [docId, content] of Object.entries(merged)) {
+        const existingDoc = target.get(docId);
+        const version: Version = {
+          id: generateVersionId(),
+          timestamp: Date.now(),
+          content: deepClone(content),
+        };
+        if (existingDoc) {
+          existingDoc.content = deepClone(content);
+          existingDoc.deleted = false;
+          existingDoc.versions.push(version);
+        } else {
+          target.set(docId, {
+            content: deepClone(content),
+            deleted: false,
+            versions: [version],
+          });
+        }
+      }
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+
+  // ---- Private Helpers ----
+
+  private getCurrentBranchData(): BranchData {
+    return this.branches.get(this.currentBranch)!;
+  }
+
+  private cloneBranchData(data: BranchData): BranchData {
+    const clone: BranchData = new Map();
+    for (const [id, doc] of data) {
+      clone.set(id, {
+        content: deepClone(doc.content),
+        deleted: doc.deleted,
+        versions: doc.versions.map(v => ({
+          id: v.id,
+          timestamp: v.timestamp,
+          content: deepClone(v.content),
+        })),
+      });
+    }
+    return clone;
+  }
+}
