+++ b/src/merge.ts
@@ -0,0 +1,228 @@
+import type { Conflict } from './types.js';
+
+function isObject(val: unknown): val is Record<string, unknown> {
+  return val !== null && typeof val === 'object' && !Array.isArray(val);
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return false;
+  if (typeof a !== typeof b) return false;
+
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    for (let i = 0; i < a.length; i++) {
+      if (!deepEqual(a[i], b[i])) return false;
+    }
+    return true;
+  }
+
+  if (isObject(a) && isObject(b)) {
+    const keysA = Object.keys(a);
+    const keysB = Object.keys(b);
+    if (keysA.length !== keysB.length) return false;
+    for (const key of keysA) {
+      if (!Object.prototype.hasOwnProperty.call(b, key)) return false;
+      if (!deepEqual(a[key], b[key])) return false;
+    }
+    return true;
+  }
+
+  return false;
+}
+
+export function deepClone<T>(obj: T): T {
+  if (obj === null || typeof obj !== 'object') return obj;
+  if (Array.isArray(obj)) return obj.map(item => deepClone(item)) as T;
+  const result: Record<string, unknown> = {};
+  for (const key of Object.keys(obj as Record<string, unknown>)) {
+    result[key] = deepClone((obj as Record<string, unknown>)[key]);
+  }
+  return result as T;
+}
+
+function getAllPaths(obj: unknown, prefix: string = ''): Set<string> {
+  const paths = new Set<string>();
+  if (!isObject(obj)) return paths;
+  for (const key of Object.keys(obj)) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    paths.add(path);
+    if (isObject(obj[key])) {
+      for (const sub of getAllPaths(obj[key], path)) {
+        paths.add(sub);
+      }
+    }
+  }
+  return paths;
+}
+
+function getAtPath(obj: unknown, path: string): unknown {
+  const parts = path.split('.');
+  let cur: unknown = obj;
+  for (const part of parts) {
+    if (!isObject(cur)) return undefined;
+    cur = cur[part];
+  }
+  return cur;
+}
+
+function setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {
+  const parts = path.split('.');
+  let cur: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (!isObject(cur[parts[i]])) {
+      cur[parts[i]] = {};
+    }
+    cur = cur[parts[i]] as Record<string, unknown>;
+  }
+  cur[parts[parts.length - 1]] = value;
+}
+
+function deleteAtPath(obj: Record<string, unknown>, path: string): void {
+  const parts = path.split('.');
+  let cur: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (!isObject(cur[parts[i]])) return;
+    cur = cur[parts[i]] as Record<string, unknown>;
+  }
+  delete cur[parts[parts.length - 1]];
+}
+
+function hasAtPath(obj: unknown, path: string): boolean {
+  const parts = path.split('.');
+  let cur: unknown = obj;
+  for (let i = 0; i < parts.length; i++) {
+    if (!isObject(cur)) return false;
+    if (!Object.prototype.hasOwnProperty.call(cur, parts[i])) return false;
+    cur = cur[parts[i]];
+  }
+  return true;
+}
+
+// Collect only leaf-level paths (paths where the value is not a plain object, or the key itself if it's a leaf)
+function getLeafPaths(obj: unknown, prefix: string = ''): Set<string> {
+  const paths = new Set<string>();
+  if (!isObject(obj)) return paths;
+  for (const key of Object.keys(obj)) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    if (isObject(obj[key]) && Object.keys(obj[key] as object).length > 0) {
+      for (const sub of getLeafPaths(obj[key], path)) {
+        paths.add(sub);
+      }
+    } else {
+      paths.add(path);
+    }
+  }
+  return paths;
+}
+
+export interface ThreeWayResult {
+  merged: object;
+  conflicts: Conflict[];
+}
+
+export function threeWayMerge(
+  documentId: string,
+  base: object | undefined,
+  ours: object | undefined,
+  theirs: object | undefined
+): ThreeWayResult {
+  const conflicts: Conflict[] = [];
+
+  // Both sides deleted
+  if (ours === undefined && theirs === undefined) {
+    return { merged: {}, conflicts };
+  }
+
+  // Only one side deleted
+  if (ours === undefined) {
+    // We deleted, they may have modified
+    // Treat as ours wins for merged view
+    return { merged: deepClone(theirs!), conflicts };
+  }
+  if (theirs === undefined) {
+    // They deleted, we may have modified
+    return { merged: deepClone(ours), conflicts };
+  }
+
+  const baseObj = base ?? {};
+
+  // Collect all paths across all three versions
+  const allPaths = new Set<string>();
+  for (const p of getLeafPaths(baseObj)) allPaths.add(p);
+  for (const p of getLeafPaths(ours)) allPaths.add(p);
+  for (const p of getLeafPaths(theirs)) allPaths.add(p);
+
+  // Also add parent-level paths for structural changes (e.g., object replaced with scalar)
+  for (const p of getAllPaths(baseObj)) allPaths.add(p);
+  for (const p of getAllPaths(ours)) allPaths.add(p);
+  for (const p of getAllPaths(theirs)) allPaths.add(p);
+
+  // Filter to only leaf-level paths for merge decisions
+  // A path is a leaf if none of the other paths have it as a prefix
+  const sortedPaths = Array.from(allPaths).sort();
+  const leafPaths: string[] = [];
+  for (let i = 0; i < sortedPaths.length; i++) {
+    const path = sortedPaths[i];
+    const next = sortedPaths[i + 1];
+    if (next && next.startsWith(path + '.')) {
+      continue; // skip non-leaf
+    }
+    leafPaths.push(path);
+  }
+
+  const merged: Record<string, unknown> = deepClone(ours) as Record<string, unknown>;
+
+  for (const path of leafPaths) {
+    const baseVal = getAtPath(baseObj, path);
+    const oursVal = getAtPath(ours, path);
+    const theirsVal = getAtPath(theirs, path);
+    const baseHas = hasAtPath(baseObj, path);
+    const oursHas = hasAtPath(ours, path);
+    const theirsHas = hasAtPath(theirs, path);
+
+    const baseEff = baseHas ? baseVal : undefined;
+    const oursEff = oursHas ? oursVal : undefined;
+    const theirsEff = theirsHas ? theirsVal : undefined;
+
+    const oursChanged = baseHas !== oursHas || !deepEqual(baseEff, oursEff);
+    const theirsChanged = baseHas !== theirsHas || !deepEqual(baseEff, theirsEff);
+
+    if (!oursChanged && !theirsChanged) {
+      // No change
+      continue;
+    }
+
+    if (oursChanged && !theirsChanged) {
+      // Only ours changed - already in merged
+      continue;
+    }
+
+    if (!oursChanged && theirsChanged) {
+      // Only theirs changed - apply theirs
+      if (theirsHas) {
+        setAtPath(merged, path, deepClone(theirsVal));
+      } else {
+        deleteAtPath(merged, path);
+      }
+      continue;
+    }
+
+    // Both changed
+    if (deepEqual(oursEff, theirsEff) && oursHas === theirsHas) {
+      // Same change - no conflict
+      continue;
+    }
+
+    // Conflict! merged keeps ours value (already there)
+    conflicts.push({
+      documentId,
+      path,
+      base: baseHas ? deepClone(baseVal) : undefined,
+      ours: oursHas ? deepClone(oursVal) : undefined,
+      theirs: theirsHas ? deepClone(theirsVal) : undefined,
+    });
+  }
+
+  return { merged: merged as object, conflicts };
+}
