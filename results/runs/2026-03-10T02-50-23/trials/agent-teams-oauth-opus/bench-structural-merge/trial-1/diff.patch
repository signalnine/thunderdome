+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from './index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('CRUD operations', () => {
+    it('creates and retrieves a document', () => {
+      store.create('doc1', { name: 'test' });
+      expect(store.get('doc1')).toEqual({ name: 'test' });
+    });
+
+    it('throws on duplicate create', () => {
+      store.create('doc1', { a: 1 });
+      expect(() => store.create('doc1', { a: 2 })).toThrow();
+    });
+
+    it('throws on get of nonexistent document', () => {
+      expect(() => store.get('nope')).toThrow();
+    });
+
+    it('updates a document', () => {
+      store.create('doc1', { a: 1 });
+      store.update('doc1', { a: 2, b: 3 });
+      expect(store.get('doc1')).toEqual({ a: 2, b: 3 });
+    });
+
+    it('throws on update of nonexistent document', () => {
+      expect(() => store.update('nope', { a: 1 })).toThrow();
+    });
+
+    it('deletes a document', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('throws on delete of nonexistent document', () => {
+      expect(() => store.delete('nope')).toThrow();
+    });
+
+    it('throws on delete of already deleted document', () => {
+      store.create('doc1', { a: 1 });
+      store.delete('doc1');
+      expect(() => store.delete('doc1')).toThrow();
+    });
+
+    it('deep clones on create so mutations dont affect store', () => {
+      const obj = { nested: { value: 1 } };
+      store.create('doc1', obj);
+      obj.nested.value = 999;
+      expect(store.get('doc1')).toEqual({ nested: { value: 1 } });
+    });
+
+    it('deep clones on get so mutations dont affect store', () => {
+      store.create('doc1', { nested: { value: 1 } });
+      const retrieved = store.get('doc1') as any;
+      retrieved.nested.value = 999;
+      expect(store.get('doc1')).toEqual({ nested: { value: 1 } });
+    });
+  });
+
+  describe('Version History', () => {
+    it('tracks versions on create', () => {
+      store.create('doc1', { a: 1 });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(1);
+      expect(history[0].content).toEqual({ a: 1 });
+    });
+
+    it('tracks versions on update', () => {
+      store.create('doc1', { a: 1 });
+      store.update('doc1', { a: 2 });
+      store.update('doc1', { a: 3 });
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ a: 1 });
+      expect(history[1].content).toEqual({ a: 2 });
+      expect(history[2].content).toEqual({ a: 3 });
+    });
+
+    it('returns versions in chronological order', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      const history = store.getHistory('doc1');
+      expect(history[0].timestamp).toBeLessThanOrEqual(history[1].timestamp);
+    });
+
+    it('getVersion returns specific version content', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      const history = store.getHistory('doc1');
+      expect(store.getVersion('doc1', history[0].id)).toEqual({ v: 1 });
+      expect(store.getVersion('doc1', history[1].id)).toEqual({ v: 2 });
+    });
+
+    it('throws on getHistory for unknown doc', () => {
+      expect(() => store.getHistory('nope')).toThrow();
+    });
+
+    it('throws on getVersion for unknown version', () => {
+      store.create('doc1', { a: 1 });
+      expect(() => store.getVersion('doc1', 'bad-version')).toThrow();
+    });
+
+    it('each version has a unique id', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      const history = store.getHistory('doc1');
+      expect(history[0].id).not.toBe(history[1].id);
+    });
+  });
+
+  describe('Branching', () => {
+    it('default branch is main', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('creates and switches branches', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+    });
+
+    it('lists branches', () => {
+      store.createBranch('dev');
+      store.createBranch('feature');
+      const branches = store.listBranches();
+      expect(branches).toContain('main');
+      expect(branches).toContain('dev');
+      expect(branches).toContain('feature');
+    });
+
+    it('branches are isolated', () => {
+      store.create('doc1', { value: 'main' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { value: 'feature' });
+
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ value: 'main' });
+
+      store.switchBranch('feature');
+      expect(store.get('doc1')).toEqual({ value: 'feature' });
+    });
+
+    it('new docs on branch not visible on main', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc-feature', { x: 1 });
+
+      store.switchBranch('main');
+      expect(() => store.get('doc-feature')).toThrow();
+    });
+
+    it('createBranch from specific branch', () => {
+      store.create('doc1', { from: 'main' });
+      store.createBranch('dev');
+      store.switchBranch('dev');
+      store.update('doc1', { from: 'dev' });
+
+      // Create a branch from dev while on main
+      store.switchBranch('main');
+      store.createBranch('feature', 'dev');
+      store.switchBranch('feature');
+      expect(store.get('doc1')).toEqual({ from: 'dev' });
+    });
+
+    it('throws on duplicate branch name', () => {
+      store.createBranch('feature');
+      expect(() => store.createBranch('feature')).toThrow();
+    });
+
+    it('throws on switch to nonexistent branch', () => {
+      expect(() => store.switchBranch('nope')).toThrow();
+    });
+  });
+
+  describe('Merging', () => {
+    it('merges non-conflicting changes', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      // Change on feature branch
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2 });
+
+      // Change different field on main
+      store.switchBranch('main');
+      store.update('doc1', { a: 1, b: 20 });
+
+      // Merge feature into main
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 20 });
+
+      // Verify main has merged content
+      expect(store.get('doc1')).toEqual({ a: 10, b: 20 });
+    });
+
+    it('detects conflicts on same field different values', () => {
+      store.create('doc1', { x: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { x: 'feature-value' });
+
+      store.switchBranch('main');
+      store.update('doc1', { x: 'main-value' });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0].documentId).toBe('doc1');
+      expect(result.conflicts[0].path).toBe('x');
+      expect(result.conflicts[0].base).toBe(1);
+      expect(result.conflicts[0].ours).toBe('main-value');
+      expect(result.conflicts[0].theirs).toBe('feature-value');
+
+      // Main should be unchanged
+      expect(store.get('doc1')).toEqual({ x: 'main-value' });
+    });
+
+    it('no conflict when both sides make the same change', () => {
+      store.create('doc1', { x: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { x: 42 });
+
+      store.switchBranch('main');
+      store.update('doc1', { x: 42 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it('handles new documents on source branch', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('new-doc', { hello: 'world' });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['new-doc']).toEqual({ hello: 'world' });
+      expect(store.get('new-doc')).toEqual({ hello: 'world' });
+    });
+
+    it('handles deep nested merge', () => {
+      store.create('doc1', { a: { b: { c: 1, d: 2 } } });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: { b: { c: 10, d: 2 } } });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: { b: { c: 1, d: 20 } } });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ a: { b: { c: 10, d: 20 } } });
+    });
+
+    it('merged field shows ours on conflict', () => {
+      store.create('doc1', { x: 0 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { x: 'theirs' });
+
+      store.switchBranch('main');
+      store.update('doc1', { x: 'ours' });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      // merged should favor ours
+      expect(result.merged['doc1']).toEqual({ x: 'ours' });
+    });
+
+    it('independent documents merge cleanly', () => {
+      store.create('doc1', { a: 1 });
+      store.create('doc2', { b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10 });
+
+      store.switchBranch('main');
+      store.update('doc2', { b: 20 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(store.get('doc1')).toEqual({ a: 10 });
+      expect(store.get('doc2')).toEqual({ b: 20 });
+    });
+
+    it('fast-forward merge with no changes', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(Object.keys(result.merged)).toHaveLength(0);
+    });
+
+    it('handles field additions on one side', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, newField: 'added' });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 1, newField: 'added' });
+    });
+
+    it('handles field deletion on one side', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1 }); // removed b
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 1 });
+    });
+
+    it('merge creates a new version', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10 });
+
+      store.switchBranch('main');
+      const historyBefore = store.getHistory('doc1');
+      store.merge('feature');
+      const historyAfter = store.getHistory('doc1');
+      expect(historyAfter.length).toBe(historyBefore.length + 1);
+    });
+  });
+});
