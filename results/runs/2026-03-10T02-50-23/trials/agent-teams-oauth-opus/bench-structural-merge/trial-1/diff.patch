+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: any;
+  ours: any;
+  theirs: any;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface DocumentState {
+  content: object;
+  deleted: boolean;
+  versions: Version[];
+}
