@@ -0,0 +1,196 @@
+import { Router, Response } from "express";
+import { v4 as uuidv4 } from "uuid";
+import Database from "better-sqlite3";
+import { AuthRequest, Dashboard } from "../types.js";
+import { authenticate } from "../auth.js";
+
+export function createDashboardRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Create dashboard
+  router.post("/", authenticate, (req: AuthRequest, res: Response): void => {
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenant_id;
+    const ownerId = req.user!.id;
+    const dashConfig = config ? JSON.stringify(config) : "{}";
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, ownerId, dashConfig, now, now);
+
+    res.status(201).json({
+      id,
+      tenant_id: tenantId,
+      name,
+      owner_id: ownerId,
+      config: config || {},
+      created_at: now,
+      updated_at: now,
+    });
+  });
+
+  // List dashboards for tenant
+  router.get("/", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenant_id;
+
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenantId) as Dashboard[];
+
+    const parsed = dashboards.map((d) => ({
+      ...d,
+      config: typeof d.config === "string" ? JSON.parse(d.config) : d.config,
+    }));
+
+    res.json({ dashboards: parsed });
+  });
+
+  // Get single dashboard
+  router.get("/:id", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenant_id;
+    const { id } = req.params;
+
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(id, tenantId) as Dashboard | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db
+      .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+      .all(id);
+
+    const parsedWidgets = widgets.map((w) => {
+      const widget = w as Record<string, unknown>;
+      return {
+        ...widget,
+        config:
+          typeof widget.config === "string"
+            ? JSON.parse(widget.config as string)
+            : widget.config,
+      };
+    });
+
+    res.json({
+      ...dashboard,
+      config:
+        typeof dashboard.config === "string"
+          ? JSON.parse(dashboard.config)
+          : dashboard.config,
+      widgets: parsedWidgets,
+    });
+  });
+
+  // Update dashboard
+  router.put("/:id", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenant_id;
+    const { id } = req.params;
+    const { name, config } = req.body;
+
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(id, tenantId) as Dashboard | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const updatedName = name || existing.name;
+    const updatedConfig = config ? JSON.stringify(config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?"
+    ).run(updatedName, updatedConfig, now, id);
+
+    res.json({
+      id,
+      tenant_id: tenantId,
+      name: updatedName,
+      config: config || (typeof existing.config === "string" ? JSON.parse(existing.config) : existing.config),
+      owner_id: existing.owner_id,
+      updated_at: now,
+    });
+  });
+
+  // Delete dashboard
+  router.delete("/:id", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenant_id;
+    const { id } = req.params;
+
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(id, tenantId) as Dashboard | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM dashboards WHERE id = ?").run(id);
+
+    res.status(204).send();
+  });
+
+  // Add widget to dashboard
+  router.post("/:id/widgets", authenticate, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenant_id;
+    const { id: dashboardId } = req.params;
+    const { type, config, position_x, position_y, width, height } = req.body;
+
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(dashboardId, tenantId) as Dashboard | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    if (!type || !["counter", "timeseries", "breakdown", "funnel"].includes(type)) {
+      res.status(400).json({ error: "Valid widget type is required (counter, timeseries, breakdown, funnel)" });
+      return;
+    }
+
+    const widgetId = uuidv4();
+    const widgetConfig = config ? JSON.stringify(config) : "{}";
+
+    db.prepare(
+      "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+    ).run(
+      widgetId,
+      dashboardId,
+      type,
+      widgetConfig,
+      position_x || 0,
+      position_y || 0,
+      width || 1,
+      height || 1
+    );
+
+    res.status(201).json({
+      id: widgetId,
+      dashboard_id: dashboardId,
+      type,
+      config: config || {},
+      position_x: position_x || 0,
+      position_y: position_y || 0,
+      width: width || 1,
+      height: height || 1,
+    });
+  });
+
+  return router;
+}
