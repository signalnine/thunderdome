+{"parentUuid":"d00cc1a7-93d6-4c0e-97f9-c796c07b8655","isSidechain":false,"userType":"external","cwd":"/workspace","sessionId":"1005da56-073f-4dbb-a56e-e5580670accf","version":"2.1.63","gitBranch":"HEAD","slug":"recursive-sparking-cat","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015d4zkejYNnPEFnYuRidje5","type":"tool_result","content":"File created successfully at: /workspace/src/routes/export.ts"}]},"uuid":"fd80ac7a-14d7-4c6d-acb7-405482238b11","timestamp":"2026-03-10T03:21:54.442Z","toolUseResult":{"type":"create","filePath":"/workspace/src/routes/export.ts","content":"import { Router, Response } from \"express\";\nimport Database from \"better-sqlite3\";\nimport { AuthRequest, Dashboard } from \"../types.js\";\nimport { authenticate } from \"../auth.js\";\n\nfunction toCsv(rows: Record<string, unknown>[]): string {\n  if (rows.length === 0) return \"\";\n\n  const headers = Object.keys(rows[0]);\n  const lines = [headers.join(\",\")];\n\n  for (const row of rows) {\n    const values = headers.map((h) => {\n      const val = row[h];\n      if (val === null || val === undefined) return \"\";\n      const str = String(val);\n      if (str.includes(\",\") || str.includes('\"') || str.includes(\"\\n\")) {\n        return `\"${str.replace(/\"/g, '\"\"')}\"`;\n      }\n      return str;\n    });\n    lines.push(values.join(\",\"));\n  }\n\n  return lines.join(\"\\n\");\n}\n\nexport function createExportRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // Export events as JSON\n  router.get(\"/events/json\", authenticate, (req: AuthRequest, res: Response): void => {\n    const tenantId = req.user!.tenant_id;\n    const { name, start, end } = req.query;\n\n    let query = \"SELECT * FROM events WHERE tenant_id = ?\";\n    const params: string[] = [tenantId];\n\n    if (name) {\n      query += \" AND name = ?\";\n      params.push(name as string);\n    }\n\n    if (start) {\n      query += \" AND timestamp >= ?\";\n      params.push(start as string);\n    }\n\n    if (end) {\n      query += \" AND timestamp <= ?\";\n      params.push(end as string);\n    }\n\n    query += \" ORDER BY timestamp DESC\";\n\n    const events = db.prepare(query).all(...params) as Record<string, unknown>[];\n\n    const parsed = events.map((e) => ({\n      ...e,\n      properties:\n        typeof e.properties === \"string\"\n          ? JSON.parse(e.properties as string)\n          : e.properties,\n    }));\n\n    res.setHeader(\"Content-Type\", \"application/json\");\n    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.json\");\n    res.json({ events: parsed });\n  });\n\n  // Export events as CSV\n  router.get(\"/events/csv\", authenticate, (req: AuthRequest, res: Response): void => {\n    const tenantId = req.user!.tenant_id;\n    const { name, start, end } = req.query;\n\n    let query = \"SELECT * FROM events WHERE tenant_id = ?\";\n    const params: string[] = [tenantId];\n\n    if (name) {\n      query += \" AND name = ?\";\n      params.push(name as string);\n    }\n\n    if (start) {\n      query += \" AND timestamp >= ?\";\n      params.push(start as string);\n    }\n\n    if (end) {\n      query += \" AND timestamp <= ?\";\n      params.push(end as string);\n    }\n\n    query += \" ORDER BY timestamp DESC\";\n\n    const events = db.prepare(query).all(...params) as Record<string, unknown>[];\n\n    res.setHeader(\"Content-Type\", \"text/csv\");\n    res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n    res.send(toCsv(events));\n  });\n\n  // Export dashboard as JSON\n  router.get(\n    \"/dashboards/:id/json\",\n    authenticate,\n    (req: AuthRequest, res: Response): void => {\n      const tenantId = req.user!.tenant_id;\n      const { id } = req.params;\n\n      const dashboard = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n        .get(id, tenantId) as Dashboard | undefined;\n\n      if (!dashboard) {\n        res.status(404).json({ error: \"Dashboard not found\" });\n        return;\n      }\n\n      const widgets = db\n        .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n        .all(id) as Record<string, unknown>[];\n\n      const parsedWidgets = widgets.map((w) => ({\n        ...w,\n        config:\n          typeof w.config === \"string\"\n            ? JSON.parse(w.config as string)\n            : w.config,\n      }));\n\n      res.setHeader(\"Content-Type\", \"application/json\");\n      res.setHeader(\n        \"Content-Disposition\",\n        `attachment; filename=dashboard-${id}.json`\n      );\n      res.json({\n        ...dashboard,\n        config:\n          typeof dashboard.config === \"string\"\n            ? JSON.parse(dashboard.config)\n            : dashboard.config,\n        widgets: parsedWidgets,\n      });\n    }\n  );\n\n  // Export dashboard as CSV\n  router.get(\n    \"/dashboards/:id/csv\",\n    authenticate,\n    (req: AuthRequest, res: Response): void => {\n      const tenantId = req.user!.tenant_id;\n      const { id } = req.params;\n\n      const dashboard = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n        .get(id, tenantId) as Dashboard | undefined;\n\n      if (!dashboard) {\n        res.status(404).json({ error: \"Dashboard not found\" });\n        return;\n      }\n\n      const widgets = db\n        .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n        .all(id) as Record<string, unknown>[];\n\n      const rows = [\n        {\n          type: \"dashboard\",\n          id: dashboard.id,\n          name: dashboard.name,\n          owner_id: dashboard.owner_id,\n          config: dashboard.config,\n          created_at: dashboard.created_at,\n          updated_at: dashboard.updated_at,\n        },\n        ...widgets.map((w) => ({\n          type: \"widget\",\n          id: w.id as string,\n          name: w.type as string,\n          owner_id: \"\",\n          con