+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function findSource(grid: string[][]): [number, number] {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  throw new Error('No source found');
+}
+
+function step(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down': return [row + 1, col];
+    case 'down-left': return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function inBounds(row: number, col: number, rows: number, cols: number): boolean {
+  return row >= 0 && row < rows && col >= 0 && col < cols;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  const visited = new Set<string>();
+  visited.add(`${sr},${sc}`);
+
+  const beams: Beam[] = [{ row: sr, col: sc, dir: 'down' }];
+
+  // Track visited (cell, direction) to avoid re-processing identical beams
+  const seen = new Set<string>();
+  seen.add(`${sr},${sc},down`);
+
+  while (beams.length > 0) {
+    const beam = beams.pop()!;
+    const [nr, nc] = step(beam.row, beam.col, beam.dir);
+
+    if (!inBounds(nr, nc, rows, cols)) continue;
+
+    visited.add(`${nr},${nc}`);
+
+    if (grid[nr][nc] === '^') {
+      // Split into two diagonal beams
+      for (const dir of ['down-left', 'down-right'] as Direction[]) {
+        const key = `${nr},${nc},${dir}`;
+        if (!seen.has(key)) {
+          seen.add(key);
+          beams.push({ row: nr, col: nc, dir });
+        }
+      }
+    } else {
+      // Continue in same direction
+      const key = `${nr},${nc},${beam.dir}`;
+      if (!seen.has(key)) {
+        seen.add(key);
+        beams.push({ row: nr, col: nc, dir: beam.dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  // Use memoization: for each (cell, direction), count the number of paths
+  // from that state to grid exit.
+  const rows = grid.length;
+  const cols = grid[0].length;
+  const [sr, sc] = findSource(grid);
+
+  const memo = new Map<string, bigint>();
+
+  function countFrom(row: number, col: number, dir: Direction): bigint {
+    const key = `${row},${col},${dir}`;
+    if (memo.has(key)) return memo.get(key)!;
+
+    const [nr, nc] = step(row, col, dir);
+
+    if (!inBounds(nr, nc, rows, cols)) {
+      // Beam exits the grid — this is one complete path
+      memo.set(key, 1n);
+      return 1n;
+    }
+
+    let result: bigint;
+    if (grid[nr][nc] === '^') {
+      // Splitter: beam splits into down-left and down-right
+      result = countFrom(nr, nc, 'down-left') + countFrom(nr, nc, 'down-right');
+    } else {
+      // Continue in same direction
+      result = countFrom(nr, nc, dir);
+    }
+
+    memo.set(key, result);
+    return result;
+  }
+
+  return countFrom(sr, sc, 'down');
+}
