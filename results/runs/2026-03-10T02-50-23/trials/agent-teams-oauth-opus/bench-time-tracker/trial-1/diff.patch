@@ -0,0 +1,123 @@
+import fs from "node:fs";
+import path from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string;
+  stop: string | null;
+}
+
+interface StorageData {
+  entries: TimeEntry[];
+}
+
+export interface TimeSummary {
+  [task: string]: number;
+}
+
+export interface QueryOptions {
+  from?: Date;
+  to?: Date;
+}
+
+export class TimeTracker {
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = path.resolve(filePath);
+  }
+
+  private load(): StorageData {
+    try {
+      const raw = fs.readFileSync(this.filePath, "utf-8");
+      return JSON.parse(raw) as StorageData;
+    } catch {
+      return { entries: [] };
+    }
+  }
+
+  private save(data: StorageData): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    fs.writeFileSync(this.filePath, JSON.stringify(data, null, 2), "utf-8");
+  }
+
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    const data = this.load();
+    const now = new Date().toISOString();
+
+    // Stop any currently running timer
+    for (const entry of data.entries) {
+      if (entry.stop === null) {
+        entry.stop = now;
+      }
+    }
+
+    const newEntry: TimeEntry = {
+      task,
+      start: now,
+      stop: null,
+    };
+
+    data.entries.push(newEntry);
+    this.save(data);
+    return newEntry;
+  }
+
+  stop(): TimeEntry {
+    const data = this.load();
+
+    const running = data.entries.find((e) => e.stop === null);
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save(data);
+    return running;
+  }
+
+  getEntries(options?: QueryOptions): TimeEntry[] {
+    const data = this.load();
+    let entries = data.entries;
+
+    if (options) {
+      entries = entries.filter((entry) => {
+        const entryStart = new Date(entry.start);
+        if (options.from && entryStart < options.from) {
+          return false;
+        }
+        if (options.to && entryStart > options.to) {
+          return false;
+        }
+        return true;
+      });
+    }
+
+    return entries;
+  }
+
+  getSummary(options?: QueryOptions): TimeSummary {
+    const entries = this.getEntries(options);
+    const summary: TimeSummary = {};
+
+    for (const entry of entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop
+        ? new Date(entry.stop).getTime()
+        : Date.now();
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+}
