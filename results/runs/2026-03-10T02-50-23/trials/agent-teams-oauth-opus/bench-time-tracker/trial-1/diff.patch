+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import fs from "node:fs";
+import os from "node:os";
+import path from "node:path";
+import { TimeTracker } from "./tracker.js";
+
+let tmpDir: string;
+let filePath: string;
+
+beforeEach(() => {
+  tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), "tracker-test-"));
+  filePath = path.join(tmpDir, "data.json");
+});
+
+afterEach(() => {
+  fs.rmSync(tmpDir, { recursive: true, force: true });
+});
+
+describe("TimeTracker", () => {
+  describe("start", () => {
+    it("should start a timer and persist it", () => {
+      const tracker = new TimeTracker(filePath);
+      const entry = tracker.start("coding");
+      expect(entry.task).toBe("coding");
+      expect(entry.start).toBeTruthy();
+      expect(entry.stop).toBeNull();
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+    });
+
+    it("should throw on empty task name", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should auto-stop previous timer when starting a new one", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].stop).not.toBeNull();
+      expect(entries[1].stop).toBeNull();
+    });
+  });
+
+  describe("stop", () => {
+    it("should stop the running timer", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("coding");
+      const stopped = tracker.stop();
+      expect(stopped.task).toBe("coding");
+      expect(stopped.stop).not.toBeNull();
+    });
+
+    it("should throw when no timer is running", () => {
+      const tracker = new TimeTracker(filePath);
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("a");
+      tracker.start("b");
+      tracker.stop();
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter by date range", () => {
+      const tracker = new TimeTracker(filePath);
+
+      // Manually create entries with known dates
+      const data = {
+        entries: [
+          { task: "old", start: "2024-01-01T00:00:00.000Z", stop: "2024-01-01T01:00:00.000Z" },
+          { task: "mid", start: "2024-06-15T00:00:00.000Z", stop: "2024-06-15T01:00:00.000Z" },
+          { task: "new", start: "2025-01-01T00:00:00.000Z", stop: "2025-01-01T01:00:00.000Z" },
+        ],
+      };
+      fs.writeFileSync(filePath, JSON.stringify(data), "utf-8");
+
+      const filtered = tracker.getEntries({
+        from: new Date("2024-03-01"),
+        to: new Date("2024-12-31"),
+      });
+      expect(filtered).toHaveLength(1);
+      expect(filtered[0].task).toBe("mid");
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations per task", () => {
+      const data = {
+        entries: [
+          { task: "coding", start: "2024-01-01T00:00:00.000Z", stop: "2024-01-01T01:00:00.000Z" },
+          { task: "coding", start: "2024-01-02T00:00:00.000Z", stop: "2024-01-02T02:00:00.000Z" },
+          { task: "review", start: "2024-01-03T00:00:00.000Z", stop: "2024-01-03T00:30:00.000Z" },
+        ],
+      };
+      fs.writeFileSync(filePath, JSON.stringify(data), "utf-8");
+
+      const tracker = new TimeTracker(filePath);
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBe(3 * 60 * 60 * 1000); // 3 hours
+      expect(summary["review"]).toBe(30 * 60 * 1000); // 30 min
+    });
+
+    it("should use current time for running entries", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("active");
+
+      const summary = tracker.getSummary();
+      expect(summary["active"]).toBeGreaterThanOrEqual(0);
+      expect("active" in summary).toBe(true);
+    });
+  });
+
+  describe("persistence", () => {
+    it("should create parent directories", () => {
+      const deepPath = path.join(tmpDir, "a", "b", "c", "data.json");
+      const tracker = new TimeTracker(deepPath);
+      tracker.start("test");
+
+      expect(fs.existsSync(deepPath)).toBe(true);
+    });
+
+    it("should persist across instances", () => {
+      const t1 = new TimeTracker(filePath);
+      t1.start("task1");
+      t1.stop();
+
+      const t2 = new TimeTracker(filePath);
+      const entries = t2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("task1");
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle emoji task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("🚀 deployment");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("🚀 deployment");
+    });
+
+    it("should handle unicode task names", () => {
+      const tracker = new TimeTracker(filePath);
+      tracker.start("日本語タスク");
+      tracker.stop();
+
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("日本語タスク");
+    });
+  });
+});
