pare(`\n    SELECT COALESCE(SUM(total), 0) as total, COUNT(*) as count\n    FROM invoices\n    WHERE date >= ? AND date <= ?\n  `);\n\n  const result = stmt.get(start, end) as { total: number; count: number };\n  return {\n    total: Math.round(result.total * 100) / 100,\n    count: result.count,\n  };\n}\n","numLines":96,"startLine":1,"totalLines":96}},"sourceToolAssistantUUID":"433cf306-e80a-4117-a400-a92bc91e5515"}
