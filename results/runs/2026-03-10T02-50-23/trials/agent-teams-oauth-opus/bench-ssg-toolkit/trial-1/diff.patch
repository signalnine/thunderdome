g,\n    files: [],\n    output: new Map(),\n    assets: new Map(),\n    data: new Map(),\n  };\n}\n\nfunction makeFile(overrides: Partial<ContentFile> = {}): ContentFile {\n  return {\n    slug: 'test',\n    title: 'Test',\n    content: '',\n    metadata: {},\n    ...overrides,\n  };\n}\n\ndescribe('asset-pipeline plugin', () => {\n  const plugin = createAssetPipelinePlugin();\n\n  it('rewrites relative image URLs to /assets/ path', async () => {\n    const file = makeFile({ content: '<img src=\"./image.png\" alt=\"test\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('src=\"/assets/image.png\"');\n    expect(result.content).not.toContain('src=\"./image.png\"');\n  });\n\n  it('rewrites relative link URLs to /assets/ path', async () => {\n    const file = makeFile({ content: '<a href=\"./doc.pdf\">Download</a>' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('href=\"/assets/doc.pdf\"');\n    expect(result.content).not.toContain('href=\"./doc.pdf\"');\n  });\n\n  it('leaves absolute URLs unchanged', async () => {\n    const file = makeFile({ content: '<img src=\"https://cdn.example.com/image.png\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toContain('src=\"https://cdn.example.com/image.png\"');\n  });\n\n  it('generates asset manifest in ctx.data', async () => {\n    const file = makeFile({ content: '<img src=\"./photo.jpg\">' });\n    const ctx = makeCtx();\n    await plugin.hooks.transformContent!(file, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest).toBeDefined();\n    expect(manifest.assets).toContain('photo.jpg');\n  });\n\n  it('handles files with no asset references', async () => {\n    const file = makeFile({ content: '<p>No assets here</p>' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toBe('<p>No assets here</p>');\n  });\n\n  it('handles multiple assets in one file', async () => {\n    const file = makeFile({\n      content: '<img src=\"./a.png\"><img src=\"./b.jpg\"><a href=\"./c.pdf\">link</a>',\n    });\n    const ctx = makeCtx();\n    await plugin.hooks.transformContent!(file, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest.assets).toContain('a.png');\n    expect(manifest.assets).toContain('b.jpg');\n    expect(manifest.assets).toContain('c.pdf');\n  });\n\n  it('asset manifest includes all discovered assets', async () => {\n    const ctx = makeCtx();\n    const file1 = makeFile({ content: '<img src=\"./one.png\">' });\n    const file2 = makeFile({ content: '<img src=\"./two.png\">' });\n    await plugin.hooks.transformContent!(file1, ctx);\n    await plugin.hooks.transformContent!(file2, ctx);\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] };\n    expect(manifest.assets).toHaveLength(2);\n    expect(manifest.assets).toContain('one.png');\n    expect(manifest.assets).toContain('two.png');\n  });\n\n  it('does not double-process already-rewritten URLs', async () => {\n    const file = makeFile({ content: '<img src=\"/assets/image.png\">' });\n    const ctx = makeCtx();\n    const result = await plugin.hooks.transformContent!(file, ctx);\n    expect(result.content).toBe('<img src=\"/assets/image.png\">');\n    const manifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;\n    expect(!manifest || manifest.assets.length === 0).toBe(true);\n  });\n});\n","numLines":108,"startLine":1,"totalLines":108}},"sourceToolAssistantUUID":"fbc8ccfc-a957-49fb-9a97-0d649d552f2a"}
