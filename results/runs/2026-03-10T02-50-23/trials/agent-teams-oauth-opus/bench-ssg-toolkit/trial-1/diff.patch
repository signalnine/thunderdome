@@ -0,0 +1,47 @@
+import { marked } from 'marked';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Extract footnote definitions
+        const footnotes = new Map<string, string>();
+        content = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, (_match, id: string, text: string) => {
+          footnotes.set(id, text);
+          return '';
+        });
+
+        // Process admonition containers before markdown parsing
+        content = content.replace(/^:::(note|warning|tip)\n([\s\S]*?)\n:::$/gm, (_match, type: string, inner: string) => {
+          return `<div class="admonition admonition-${type}">\n${inner}\n</div>`;
+        });
+
+        // Convert markdown to HTML
+        content = marked.parse(content) as string;
+
+        // Replace inline footnote references
+        content = content.replace(/\[\^(\d+)\]/g, (_match, id: string) => {
+          return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+        });
+
+        // Append footnotes section
+        if (footnotes.size > 0) {
+          let section = '<section class="footnotes"><ol>';
+          for (const [id, text] of footnotes) {
+            section += `<li id="fn-${id}">${text}</li>`;
+          }
+          section += '</ol></section>';
+          content += section;
+        }
+
+        return { ...file, content };
+      },
+    },
+  };
+}
