a: {},\n    ...overrides,\n  };\n}\n\ndescribe('search-index plugin', () => {\n  const plugin = createSearchIndexPlugin();\n\n  it('generates search-index.json in ctx.output', async () => {\n    const files = [makeFile({ slug: 'post-1', title: 'Post 1', content: '<p>Hello</p>' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    expect(ctx.output.has('search-index.json')).toBe(true);\n  });\n\n  it('index entries have title, slug, and plain text content', async () => {\n    const files = [makeFile({ slug: 'my-post', title: 'My Post', content: '<p>Some text here</p>' })];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].slug).toBe('my-post');\n    expect(index[0].title).toBe('My Post');\n    expect(index[0].content).toBe('Some text here');\n  });\n\n  it('HTML tags stripped from indexed content', async () => {\n    const files = [\n      makeFile({\n        slug: 'post',\n        title: 'Post',\n        content: '<h1>Title</h1><p>This is <strong>bold</strong> text.</p>',\n      }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].content).not.toContain('<');\n    expect(index[0].content).not.toContain('>');\n    expect(index[0].content).toContain('bold');\n    expect(index[0].content).toContain('text');\n  });\n\n  it('code blocks included in searchable text', async () => {\n    const files = [\n      makeFile({\n        slug: 'post',\n        title: 'Code Post',\n        content: '<p>Example:</p><pre><code class=\"language-js\">const x = 1;</code></pre>',\n      }),\n    ];\n    const ctx = makeCtx(files);\n    await plugin.hooks.afterBuild!(ctx);\n    const index = JSON.parse(ctx.output.get('search-index.json')!);\n    expect(index[0].content).toContain('const x = 1;');\n  });\n\n  it('handles empt