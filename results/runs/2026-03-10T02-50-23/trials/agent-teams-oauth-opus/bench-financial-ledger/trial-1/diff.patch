mount: 100 }]\n    95→        )\n    96→      ).toThrow(/not found/i);\n    97→    });\n    98→\n    99→    it('rejects zero or negative amounts', () => {\n   100→      expect(() =>\n   101→        ledger.postEntry(\n   102→          'Bad',\n   103→          [{ account: 'Cash', amount: 0 }],\n   104→          [{ account: 'Revenue', amount: 0 }]\n   105→        )\n   106→      ).toThrow(/positive/i);\n   107→    });\n   108→\n   109→    it('uses current date when not specified', () => {\n   110→      const before = new Date();\n   111→      const entry = ledger.postEntry(\n   112→        'Sale',\n   113→        [{ account: 'Cash', amount: 100 }],\n   114→        [{ account: 'Revenue', amount: 100 }]\n   115→      );\n   116→      const after = new Date();\n   117→      expect(entry.date.getTime()).toBeGreaterThanOrEqual(before.getTime());\n   118→      expect(entry.date.getTime()).toBeLessThanOrEqual(after.getTime());\n   119→    });\n   120→\n   121→    it('uses specified date', () => {\n   122→      const date = new Date('2024-01-15');\n   123→      const entry = ledger.postEntry(\n   124→        'Sale',\n   125→        [{ account: 'Cash', amount: 100 }],\n   126→        [{ account: 'Revenue', amount: 100 }],\n   127→        date\n   128→      );\n   129→      expect(entry.date).toEqual(date);\n   130→    });\n   131→\n   132→    it('rejects entries mixing currencies', () => {\n   133→      ledger.createAccount('Euro Cash', 'asset', 'EUR');\n   134→      expect(() =>\n   135→        ledger.postEntry(\n   136→          'Bad mix',\n   137→          [{ account: 'Cash', amount: 100 }],\n   138→          [{ account: 'Euro Cash', amount: 100 }]\n   139→        )\n   140→      ).toThrow(/currency/i);\n   141→    });\n   142→  });\n   143→\n   144→  // ===== Balances (6 tests, 5 pass) =====\n   145→\n   146→  describe('getBalance', () => {\n   147→    beforeEach(() => {\n   148→      ledger.createAccount('Cash', 'asset');\n   149→      ledger.createAccount('Revenue', 'reve