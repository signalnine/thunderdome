@@ -0,0 +1,126 @@
+// Direction encoding: 0 = down, 1 = down-left, 2 = down-right
+type Dir = 0 | 1 | 2;
+
+const DR = [1, 1, 1] as const;   // row delta: always +1
+const DC = [0, -1, 1] as const;  // col delta: 0, -1, +1
+
+function findSource(grid: string[][]): [number, number] {
+  const row = 0;
+  for (let col = 0; col < grid[0].length; col++) {
+    if (grid[row][col] === 'S') return [row, col];
+  }
+  // S might not be on row 0 in edge cases; search all rows
+  for (let r = 0; r < grid.length; r++) {
+    for (let c = 0; c < grid[r].length; c++) {
+      if (grid[r][c] === 'S') return [r, c];
+    }
+  }
+  throw new Error('No source S found in grid');
+}
+
+function inBounds(grid: string[][], r: number, c: number): boolean {
+  return r >= 0 && r < grid.length && c >= 0 && c < grid[0].length;
+}
+
+function stateKey(r: number, c: number, d: Dir): number {
+  // Encode state as a single number for fast set lookup
+  // Assumes grid dimensions < 10000
+  return (r * 10000 + c) * 3 + d;
+}
+
+export function countBeamCells(grid: string[][]): number {
+  if (grid.length === 0 || grid[0].length === 0) return 0;
+
+  const [sr, sc] = findSource(grid);
+  const visitedCells = new Set<number>(); // encoded as r * cols + c
+  const visitedStates = new Set<number>();
+  const cols = grid[0].length;
+
+  // BFS queue: [row, col, direction]
+  const queue: [number, number, Dir][] = [[sr, sc, 0]];
+  visitedStates.add(stateKey(sr, sc, 0));
+
+  while (queue.length > 0) {
+    const [r, c, d] = queue.shift()!;
+    visitedCells.add(r * cols + c);
+
+    const cell = grid[r][c];
+
+    if (cell === '^') {
+      // Split into down-left and down-right
+      const dirs: Dir[] = [1, 2];
+      for (const nd of dirs) {
+        const nr = r + DR[nd];
+        const nc = c + DC[nd];
+        if (inBounds(grid, nr, nc)) {
+          const sk = stateKey(nr, nc, nd);
+          if (!visitedStates.has(sk)) {
+            visitedStates.add(sk);
+            queue.push([nr, nc, nd]);
+          }
+        }
+      }
+    } else {
+      // Continue in current direction (S and . are pass-through)
+      const nr = r + DR[d];
+      const nc = c + DC[d];
+      if (inBounds(grid, nr, nc)) {
+        const sk = stateKey(nr, nc, d);
+        if (!visitedStates.has(sk)) {
+          visitedStates.add(sk);
+          queue.push([nr, nc, d]);
+        }
+      }
+    }
+  }
+
+  return visitedCells.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  if (grid.length === 0 || grid[0].length === 0) return 0n;
+
+  const [sr, sc] = findSource(grid);
+  const memo = new Map<number, bigint>();
+
+  function dp(r: number, c: number, d: Dir): bigint {
+    const sk = stateKey(r, c, d);
+    const cached = memo.get(sk);
+    if (cached !== undefined) return cached;
+
+    const cell = grid[r][c];
+    let result: bigint;
+
+    if (cell === '^') {
+      // Split into down-left and down-right
+      let paths = 0n;
+      const dirs: Dir[] = [1, 2];
+      for (const nd of dirs) {
+        const nr = r + DR[nd];
+        const nc = c + DC[nd];
+        if (inBounds(grid, nr, nc)) {
+          paths += dp(nr, nc, nd);
+        } else {
+          // Beam exits the grid — counts as 1 path
+          paths += 1n;
+        }
+      }
+      result = paths;
+    } else {
+      // Continue in current direction
+      const nr = r + DR[d];
+      const nc = c + DC[d];
+      if (inBounds(grid, nr, nc)) {
+        result = dp(nr, nc, d);
+      } else {
+        // Beam exits the grid — counts as 1 path
+        result = 1n;
+      }
+    }
+
+    memo.set(sk, result);
+    return result;
+  }
+
+  return dp(sr, sc, 0);
+}
