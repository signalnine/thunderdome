+++ b/src/index.test.ts
@@ -0,0 +1,120 @@
+import { describe, it, expect } from 'vitest';
+import { countBeamCells, countBeamPaths } from './index.js';
+
+describe('countBeamCells', () => {
+  it('example 1: single splitter', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it('example 2: two splitters', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it('no splitters: straight down', () => {
+    const grid = [
+      ['S'],
+      ['.'],
+      ['.'],
+    ];
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it('source only', () => {
+    const grid = [['S']];
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it('beam exits sideways', () => {
+    const grid = [
+      ['S', '.'],
+      ['^', '.'],
+    ];
+    // S at (0,0), dir=down -> (1,0) is '^', splits to (2,-1) OOB and (2,1) OOB
+    // Visited: (0,0), (1,0)
+    expect(countBeamCells(grid)).toBe(2);
+  });
+});
+
+describe('countBeamPaths', () => {
+  it('example 1: single splitter -> 2 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('example 2: two splitters -> 4 paths', () => {
+    const grid = [
+      ['.', 'S', '.', '.', '.'],
+      ['.', '^', '.', '.', '.'],
+      ['^', '.', '^', '.', '.'],
+      ['.', '.', '.', '.', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it('no splitters: 1 path', () => {
+    const grid = [
+      ['S'],
+      ['.'],
+      ['.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('source only: 1 path (exits immediately)', () => {
+    const grid = [['S']];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it('beam exits sideways: 2 paths', () => {
+    const grid = [
+      ['S', '.'],
+      ['^', '.'],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it('handles large grid with many splitters', () => {
+    // Create a grid that has splitters in a chain
+    // 10 rows, beam hits splitter at each row -> 2^9 paths
+    const cols = 21;
+    const rows = 10;
+    const grid: string[][] = [];
+    for (let r = 0; r < rows; r++) {
+      grid.push(new Array(cols).fill('.'));
+    }
+    grid[0][10] = 'S';
+    // Place splitters such that the beam always hits one
+    // Row 1: splitter at col 10
+    grid[1][10] = '^';
+    // Row 2: splitters at col 9 and 11
+    grid[2][9] = '^';
+    grid[2][11] = '^';
+    // etc. - this gets complex, let's just test a simpler case
+    // With 1 splitter at row 1, each branch goes diagonal,
+    // no more splitters -> 2 paths
+    // Reset
+    for (let r = 0; r < rows; r++) {
+      grid[r] = new Array(cols).fill('.');
+    }
+    grid[0][10] = 'S';
+    grid[1][10] = '^';
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+});
