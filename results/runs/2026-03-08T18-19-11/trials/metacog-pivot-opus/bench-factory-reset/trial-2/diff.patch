[1, 0];\n  while (r !== 0) {\n    const q = Math.floor(old_r / r);\n    [old_r, r] = [r, old_r - q * r];\n    [old_s, s] = [s, old_s - q * s];\n  }\n  return mod(old_s, p);\n}\n\n// ── Core solver: Ax ≡ b (mod p) ────────────────────────────────────────────\n\ninterface LinearSystem {\n  /** Number of variables (buttons) */\n  numVars: number;\n  /** Number of equations (lights/counters) */\n  numEqs: number;\n  /** Augmented matrix [A | b], size numEqs × (numVars+1) */\n  matrix: number[][];\n  /** The prime modulus */\n  p: number;\n}\n\n/**\n * Gaussian elimination on the augmented matrix (in-place).\n * Returns the array of pivot columns (one per pivot row).\n */\nfunction gaussianElimination(sys: LinearSystem): number[] {\n  const { numEqs, numVars, matrix, p } = sys;\n  const pivotCols: number[] = [];\n  let pivotRow = 0;\n\n  for (let col = 0; col < numVars && pivotRow < numEqs; col++) {\n    // Find a row with non-zero entry in this column\n    let found = -1;\n    for (let row = pivotRow; row < numEqs; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue; // free variable\n\n    // Swap rows\n    if (found !== pivotRow) {\n      [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];\n    }\n\n    // Scale pivot row so leading entry = 1\n    const inv = modInverse(matrix[pivotRow][col], p);\n    for (let j = col; j <= numVars; j++) {\n      matrix[pivotRow][j] = mod(matrix[pivotRow][j] * inv, p);\n    }\n\n    // Eliminate this column in all other rows\n    for (let row = 0; row < numEqs; row++) {\n      if (row === pivotRow || matrix[row][col] === 0) continue;\n      const factor = matrix[row][col];\n      for (let j = col; j <= numVars; j++) {\n        matrix[row][j] = mod(matrix[row][j] - factor * matrix[pivotRow][j], p);\n      }\n    }\n\n    pivotCols.push(col);\n    pivotRow++;\n  }\n\n  return pivotCols;\n}\n\n/**\n * After Gaussian elimination, check consistency (no row like 0 0 … 0 | c with c≠0).\n */\nfunction isConsistent(sys: LinearSystem, numPivots: number): boolean {\n  const { numEqs, numVars, matrix } = sys;\n  for (let row = numPivots; row < numEqs; row++) {\n    if (matrix[row][numVars] !== 0) return false;\n  }\n  return true;\n}\n\n/**\n * Solve the linear system and return the optimal solution vector, or null.\n *\n * \"Optimal\" means: minimum sum of entries, breaking ties by lexicographic order.\n *\n * Strategy: identify free variables and enumerate all possible assignments\n * (each in 0..p-1). For each assignment, back-substitute to get the full\n * solution, compute cost, and keep the best.\n *\n * With up to 40 variables and potentially many free variables, full enumeration\n * could be expensive. However, in practice the number of free variables is\n * small. If it is too large, we use a smarter approach.\n */\nfunction solveSystem(sys: LinearSystem): number[] | null {\n  const { numVars, matrix, p } = sys;\n  const pivotCols = gaussianElimination(sys);\n  const numPivots = pivotCols.length;\n\n  if (!isConsistent(sys, numPivots)) return null;\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCols);\n  const freeVars: number[] = [];\n  for (let j = 0; j < numVars; j++) {\n    if (!pivotSet.has(j)) freeVars.push(j);\n  }\n\n  // Map pivot column → pivot row\n  const pivotColToRow = new Map<number, number>();\n  for (let i = 0; i < pivotCols.length; i++) {\n    pivotColToRow.set(pivotCols[i], i);\n  }\n\n  const numFree = freeVars.length;\n\n  // If enumeration is feasible (p^numFree ≤ threshold), enumerate\n  const maxEnum = 1_000_000; // ~10^6 should complete well within 5 seconds\n  const totalCombinations = Math.pow(p, numFree);\n\n  if (totalCombinations <= maxEnum) {\n    return enumerateFreeSolutions(sys, pivotCols, pivotColToRow, freeVars, p, numVars, matrix);\n  }\n\n  // Fallback for large search spaces: use a greedy/heuristic approach\n  // Try to minimize by setting free variables to minimize total cost\n  return heuristicSolve(sys, pivotCols, pivotColToRow, freeVars, p, numVars, matrix);\n}\n\n/**\n * Enumerate all assignments to free variables, compute the resulting full\n * solution, and return the optimal one.\n */\nfunction enumerateFreeSolutions(\n  _sys: LinearSystem,\n  pivotCols: number[],\n  pivotColToRow: Map<number, number>,\n  freeVars: number[],\n  p: number,\n  numVars: number,\n  matrix: number[][]\n): number[] | null {\n  const numFree = freeVars.length;\n  const totalCombinations = Math.pow(p, numFree);\n\n  let bestSolution: number[] | null = null;\n  let bestCost = Infinity;\n\n  // Assignment vector for free variables\n  const freeAssign = new Array(numFree).fill(0);\n\n  for (let idx = 0; idx < totalCombinations; idx++) {\n    // Decode idx into freeAssign (mixed radix, base p)\n    if (idx > 0) {\n      let carry = idx;\n      for (let k = numFree - 1; k >= 0; k--) {\n        freeAssign[k] = carry % p;\n        carry = Math.floor(carry / p);\n      }\n    }\n\n    // Build solution\n    const sol = new Array(numVars).fill(0);\n\n    // Set free variables\n    for (let k = 0; k < numFree; k++) {\n      sol[freeVars[k]] = freeAssign[k];\n    }\n\n    // Back-substitute for pivot variables\n    // Row i has pivot at pivotCols[i]:\n    //   x[pivotCols[i]] + sum(matrix[i][j]*x[j] for non-pivot j) = matrix[i][numVars]\n    //   => x[pivotCols[i]] = matrix[i][numVars] - sum(matrix[i][j]*x[j] for non-pivot j)\n    let valid = true;\n    for (let i = pivotCols.length - 1; i >= 0; i--) {\n      const pc = pivotCols[i];\n      let val = matrix[i][numVars];\n      for (let j = pc + 1; j < numVars; j++) {\n        if (j === pc) continue;\n        val = mod(val - matrix[i][j] * sol[j], p);\n      }\n      sol[pc] = mod(val, p);\n    }\n\n    if (!valid) continue;\n\n    // Compute cost (sum of presses)\n    let cost = 0;\n    for (let j = 0; j < numVars; j++) cost += sol[j];\n\n    if (cost < bestCost || (cost === bestCost