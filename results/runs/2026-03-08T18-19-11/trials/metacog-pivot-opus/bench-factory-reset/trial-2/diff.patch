+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+// ── Helper: verify a toggle solution against the target ─────────────────────
+function verifyToggle(
+  target: boolean[],
+  buttons: number[][],
+  pressed: number[]
+): boolean {
+  const state = new Array(target.length).fill(false);
+  for (const b of pressed) {
+    for (const idx of buttons[b]) {
+      state[idx] = !state[idx];
+    }
+  }
+  return state.every((v, i) => v === target[i]);
+}
+
+// ── Helper: verify a counter solution against the target ────────────────────
+function verifyCounter(
+  target: number[],
+  buttons: number[][],
+  presses: number[],
+  modulus: number
+): boolean {
+  const state = new Array(target.length).fill(0);
+  for (let b = 0; b < presses.length; b++) {
+    for (const idx of buttons[b]) {
+      state[idx] = (state[idx] + presses[b]) % modulus;
+    }
+  }
+  return state.every((v, i) => v === target[i]);
+}
+
+describe('solveToggle', () => {
+  it('returns null when no solution exists (TASK.md example)', () => {
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('returns empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('solves a simple single-button case', () => {
+    const result = solveToggle({
+      target: [true, true, false],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    });
+    expect(result).toEqual([0]);
+    expect(verifyToggle([true, true, false], [[0, 1], [1, 2], [0, 2]], result!)).toBe(true);
+  });
+
+  it('solves a two-button case', () => {
+    const result = solveToggle({
+      target: [true, true, true, true],
+      buttons: [[0, 1], [2, 3]],
+    });
+    expect(result).toEqual([0, 1]);
+    expect(verifyToggle([true, true, true, true], [[0, 1], [2, 3]], result!)).toBe(true);
+  });
+
+  it('prefers fewer button presses', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('returns lexicographically smallest among tied solutions', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('handles identity-like buttons (each button toggles one light)', () => {
+    const result = solveToggle({
+      target: [true, false, true, false, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    });
+    expect(result).toEqual([0, 2, 4]);
+  });
+
+  it('handles overlapping buttons correctly', () => {
+    // button 0: {0, 1, 2}, button 1: {1, 2, 3}, button 2: {2, 3, 4}
+    // press 0 and 2: {0, on}, {1, on}, {2, on XOR on = off}, {3, on}, {4, on}
+    // = [T, T, F, T, T]
+    const target: boolean[] = [true, true, false, true, true];
+    const buttons = [[0, 1, 2], [1, 2, 3], [2, 3, 4]];
+    const result = solveToggle({ target, buttons });
+    expect(result).not.toBeNull();
+    expect(verifyToggle(target, buttons, result!)).toBe(true);
+  });
+
+  it('handles empty target (0 lights)', () => {
+    const result = solveToggle({
+      target: [],
+      buttons: [],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('handles buttons with no effect (empty button)', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [[], [0]],
+    });
+    expect(result).toEqual([1]);
+  });
+
+  it('handles more buttons than lights', () => {
+    const target: boolean[] = [true, true];
+    const buttons = [[0], [1], [0, 1], [0], [1]];
+    const result = solveToggle({ target, buttons });
+    expect(result).not.toBeNull();
+    // Should press fewest buttons. Pressing 2 (which toggles both) gives [T, T] with 1 press.
+    expect(result!.length).toBeLessThanOrEqual(2);
+    expect(verifyToggle(target, buttons, result!)).toBe(true);
+  });
+
+  it('handles more lights than buttons', () => {
+    // 4 lights, 2 buttons
+    const target: boolean[] = [true, true, true, true];
+    const buttons = [[0, 1, 2, 3]]; // only one button
+    const result = solveToggle({ target, buttons });
+    expect(result).toEqual([0]);
+    expect(verifyToggle(target, buttons, result!)).toBe(true);
+  });
+
+  it('returns null when a specific light cannot be reached', () => {
+    // Light 2 is never toggled by any button
+    const result = solveToggle({
+      target: [false, false, true],
+      buttons: [[0], [1]],
+    });
+    expect(result).toBeNull();
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns all zeros when target is all zero', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 3);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('solves a simple single-button case', () => {
+    const result = solveCounter([2, 2], [[0, 1]], 3);
+    expect(result).toEqual([2]);
+    expect(verifyCounter([2, 2], [[0, 1]], result!, 3)).toBe(true);
+  });
+
+  it('solves a two-button case', () => {
+    const result = solveCounter([1, 2], [[0], [1]], 5);
+    expect(result).toEqual([1, 2]);
+    expect(verifyCounter([1, 2], [[0], [1]], result!, 5)).toBe(true);
+  });
+
+  it('returns null when no solution exists', () => {
+    const result = solveCounter([1, 0], [[0, 1]], 2);
+    expect(result).toBeNull();
+  });
+
+  it('minimizes total presses', () => {
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('works with wrapping modulus', () => {
+    const result = solveCounter([0], [[0]], 3);
+    expect(result).toEqual([0]);
+  });
+
+  it('handles larger modulus', () => {
+    // Button 0: {0}, target: [50] mod 97
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+    expect(verifyCounter([50], [[0]], result!, 97)).toBe(true);
+  });
+
+  it('handles multiple buttons affecting same counter', () => {
+    // Button 0: {0}, Button 1: {0}
+    // target: [3] mod 7
+    // b0 + b1 ≡ 3 (mod 7)
+    // min sum solutions: (0,3)=3, (1,2)=3, (2,1)=3, (3,0)=3
+    // lex smallest with sum 3: [0, 3]
+    const result = solveCounter([3], [[0], [0]], 7);
+    expect(result).not.toBeNull();
+    expect(verifyCounter([3], [[0], [0]], result!, 7)).toBe(true);
+    const totalPresses = result!.reduce((a, b) => a + b, 0);
+    expect(totalPresses).toBe(3);
+    expect(result).toEqual([0, 3]);
+  });
+
+  it('handles identity-like buttons', () => {
+    const result = solveCounter([1, 2, 3], [[0], [1], [2]], 5);
+    expect(result).toEqual([1, 2, 3]);
+  });
+
+  it('returns null when counter cannot be reached', () => {
+    // Counter 1 not affected by any button, target[1] = 1
+    const result = solveCounter([0, 1], [[0]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('handles empty inputs', () => {
+    const result = solveCounter([], [], 2);
+    expect(result).toEqual([]);
+  });
+
+  it('works with modulus 2 (same as toggle but different API)', () => {
+    // Equivalent to toggle problem
+    const result = solveCounter([1, 1, 0], [[0, 1], [1, 2], [0, 2]], 2);
+    expect(result).not.toBeNull();
+    expect(verifyCounter([1, 1, 0], [[0, 1], [1, 2], [0, 2]], result!, 2)).toBe(true);
+  });
+});
