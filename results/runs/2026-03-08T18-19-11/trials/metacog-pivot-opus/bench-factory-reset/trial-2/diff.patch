esult;\n   421→}\n   422→"}]},"parent_tool_use_id":null,"session_id":"1294bb6f-e9b6-41bc-af37-9ace45910b28","uuid":"d2b9124d-0aa3-4129-a487-a4e5a026e91e","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/index.ts","content":"/**\n * Factory Reset — Toggle & Counter puzzle solvers\n *\n * Both puzzles reduce to solving a system of linear equations over a finite\n * field GF(p).  Toggle is the special case p = 2; Counter uses an arbitrary\n * prime p.\n *\n * We build the augmented matrix  [A | b]  where A[i][j] = 1 iff button j\n * affects light/counter i, and b[i] is the target value for light/counter i.\n * Gaussian elimination gives us the row-echelon form; back-substitution with\n * enumeration over free variables yields the optimal (min presses, then lex\n * smallest) solution.\n */\n\n// ── GF(p) arithmetic helpers ────────────────────────────────────────────────\n\nfunction mod(a: number, p: number): number {\n  return ((a % p) + p) % p;\n}\n\nfunction modInverse(a: number, p: number): number {\n  // Extended Euclidean algorithm – p is always prime so inverse exists for a≠0\n  let [old_r, r] = [a, p];\n  let [old_s, s] = [1, 0];\n  while (r !== 0) {\n    const q = Math.floor(old_r / r);\n    [old_r, r] = [r, old_r - q * r];\n    [old_s, s] = [s, old_s - q * s];\n  }\n  return mod(old_s, p);\n}\n\n// ── Core solver: Ax ≡ b (mod p) ────────────────────────────────────────────\n\ninterface LinearSystem {\n  /** Number of variables (buttons) */\n  numVars: number;\n  /** Number of equations (lights/counters) */\n  numEqs: number;\n  /** Augmented matrix [A | b], size numEqs × (numVars+1) */\n  matrix: number[][];\n  /** The prime modulus */\n  p: number;\n}\n\n/**\n * Gaussian elimination on the augmented matrix (in-place).\n * Returns the array of pivot columns (one per pivot row).\n */\nfunction gaussianElimination(sys: LinearSystem): number[] {\n  const { numEqs, numVars, matrix, p } = sys;\n  const pivotCols: number[] = [];\n  let pivotRow = 0;\n\n  for (let col = 0; col < numVars && pivotRow < numEqs; col++) {\n    // Find a row with non-zero entry in this column\n    let found = -1;\n    for (let row = pivotRow; row < numEqs; row++) {\n      if (matrix[row][col] !== 0) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue; // free variable\n\n    // Swap rows\n    if (found !== pivotRow) {\n      [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];\n    }\n\n    // Scale pivot row so leading entry = 1\n    const inv = modInverse(matrix[pivotRow][col], p);\n    for (let j = col; j <= numVars; j++) {\n      matrix[pivotRow][j] = mod(matrix[pivotRow][j] * inv, p);\n    }\n\n    // Eliminate this column in all other rows\n    for (let row = 0; row < numEqs; row++) {\n      if (row === pivotRow || matrix[row][col] === 0) continue;\n      const factor = matrix[row][col];\n      for (let j = col; j <= numVars; j++) {\n        matrix[row][j] = mod(matrix[row][j] - factor * matrix[pivotRow][j], p);\n      }\n    }\n\n    pivotCols.push(col);\n    pivotRow++;\n  }\n\n  return pivotCols;\n}\n\n/**\n * After Gaussian elimination, check consistency (no row like 0 0 … 0 | c with c≠0).\n */\nfunction isConsistent(sys: LinearSystem, numPivots: number): boolean {\n  const { numEqs, numVars, matrix } = sys;\n  for (let row = numPivots; row < numEqs; row++) {\n    if (matrix[row][numVars] !== 0) return false;\n  }\n  return true;\n}\n\n/**\n * Solve the linear system and return the optimal solution vector, or null.\n *\n * \"Optimal\" means: minimum sum of entries, breaking ties by lexicographic order.\n *\n * Strategy: identify free variables and enumerate all possible assignments\n * (each in 0..p-1). For each assignment, back-substitute to get the full\n * solution, compute cost, and keep the best.\n *\n * With up to 40 variables and potentially many free variables, full enumeration\n * could be expensive. However, in practice the number of free variables is\n * small. If it is too large, we use a smarter approach.\n */\nfunction solveSystem(sys: LinearSystem): number[] | null {\n  const { numVars, matrix, p } = sys;\n  const pivotCols = gaussianElimination(sys);\n  const numPivots = pivotCols.length;\n\n  if (!isConsistent(sys, numPivots)) return null;\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCols);\n  const freeVars: number[] = [];\n  for (let j = 0; j < numVars; j++) {\n    if (!pivotSet.has(j)) freeVars.push(j);\n  }\n\n  // Map pivot column → pivot row\n  const pivotColToRow = new Map<number, number>();\n  for (let i = 0; i < pivotCols.length; i++) {\n    pivotColToRow.set(pivotCols[i], i);\n  }\n\n  const numFree = freeVars.length;\n\n  // If enumeration is feasible (p^numFree ≤ threshold), enumerate\n  const maxEnum = 1_000_000; // ~10^6 should complete well within 5 seconds\n  const totalCombinations = Math.pow(p, numFree);\n\n  if (totalCombinations <= maxEnum) {\n    return enumerateFreeSolutions(sys, pivotCols, pivotColToRow, freeVars, p, numVars, matrix);\n  }\n\n  // Fallback for large search spaces: use a greedy/heuristic approach\n  // Try to minimize by setting free variables to minimize total cost\n  return heuristicSolve(sys, pivotCols, pivotColToRow, freeVars, p, numVars, matrix);\n}\n\n/**\n * Enumerate all assignments to free variables, compute the resulting full\n * solution, and return the optimal one.\n */\nfunction enumerateFreeSolutions(\n  _sys: LinearSystem,\n  pivotCols: number[],\n  pivotColToRow: Map<number, number>,\n  freeVars: number[],\n  p: number,\n  numVars: number,\n  matrix: number[][]\n): number[] | null {\n  const numFree = freeVars.length;\n  const totalCombinations = Math.pow(p, numFree);\n\n  let bestSolution: number[] | null = null;\n  let bestCost = Infinity;\n\n  // Assignment vector for free variables\n  const freeAssign = new Array(numFree).fill(0);\n\n  for (let idx = 0; idx < totalCombinations; idx++) {\n    // Decode idx into freeAssign (mixed radix, base p)\n    if (idx > 0) {\n      let carry = idx;\n      for (let k = numFree - 1; k >= 0; k--) {\n        freeAssign[k] = carry % p;\n        carry = Math.floor(carry / p);\n      }\n    }\n\n    // Build solution\n    const sol = new Array(numVars).fill(0);\n\n    // Set free variables\n    for (let k = 0; k < numFree; k++) {\n      sol[freeVars[k]] = freeAssign[k];\n    }\n\n    // Back-substitute for pivot variables\n    // Row i has pivot at pivotCols[i]:\n    //   x[pivotCols[i]] + sum(matrix[i][j]*x[j] for non-pivot j) = matrix[i][numVars]\n    //   => x[pivotCols[i]] = matrix[i][numVars] - sum(matrix[i][j]*x[j] for non-pivot j)\n    for (let i = pivotCols.length - 1; i >= 0; i--) {\n      const pc = pivotCols[i];\n      let val = matrix[i][numVars];\n      for (let j = pc + 1; j < numVars; j++) {\n        if (j === pc) continue;\n        val = mod(val - matrix[i][j] * sol[j], p);\n      }\n      sol[pc] = mod(val, p);\n    }\n\n    // Compute cost (sum of presses)\n    let cost = 0;\n    for (let j = 0; j < numVars; j++) cost += sol[j];\n\n    if (cost < bestCost || (cost === bestCost && lexSmaller(sol, bestSolution!, numVars))) {\n      bestCost = cost;\n      bestSolution = sol.slice();\n    }\n  }\n\n  return bestSolution;\n}\n\n/**\n * Heuristic solver for when there are too many free variables to enumerate.\n * For each free variable, try all p values and pick the one that locally\n * minimizes cost. This is greedy and may not find the global optimum,\n * but for well-structured puzzles it works.\n *\n * As a refinement, we also try setting all free vars to 0 as a baseline,\n * and try each free variable independently set to each value with others at 0.\n */\nfunction heuristicSolve(\n  _sys: LinearSystem,\n  pivotCols: number[],\n  _pivotColToRow: Map<number, number>,\n  freeVars: number[],\n  p: number,\n  numVars: number,\n  matrix: number[][]\n): number[] | null {\n  const numFree = freeVars.length;\n\n  // Compute the particular solution (all free vars = 0)\n  const particularSol = computeSolution(pivotCols, freeVars, new Array(numFree).fill(0), p, numVars, matrix);\n\n  // For each pivot variable, compute how it depends on each free variable\n  // pivotVal[i] = matrix[i][numVars] - sum over free vars: matrix[i][freeVars[k]] * freeAssign[k]\n  // So x[pivotCols[i]] = particularSol[pivotCols[i]] - sum_k (matrix[i][freeVars[k]] * freeAssign[k])\n\n  // The \"null-space vectors\": for each free variable k, the vector that gets added\n  // when we increase freeVar k by 1\n  const nullVecs: number[][] = [];\n  for (let k = 0; k < numFree; k++) {\n    const vec = new Array(numVars).fill(0);\n    vec[freeVars[k]] = 1;\n    for (let i = 0; i < pivotCols.length; i++) {\n      vec[pivotCols[i]] = mod(-matrix[i][freeVars[k]], p);\n    }\n    nullVecs.push(vec);\n  }\n\n  let bestSol = particularSol;\n  let bestCost = sumArray(particularSol);\n\n  // Greedy: iteratively try adjusting each free variable\n  const currentFreeAssign = new Array(numFree).fill(0);\n  let improved = true;\n\n  while (improved) {\n    improved = false;\n    for (let k = 0; k < numFree; k++) {\n      let bestVal = currentFreeAssign[k];\n      let bestLocalCost = bestCost;\n      let bestLocalSol = bestSol;\n\n      for (let v = 0; v < p; v++) {\n        if (v === currentFreeAssign[k]) continue;\n        const delta = mod(v - currentFreeAssign[k], p);\n        const newSol = bestSol.slice();\n        for (let j = 0; j < numVars; j++) {\n          newSol[j] = mod(newSol[j] + delta * nullVecs[k][j], p);\n        }\n        const cost = sumArray(newSol);\n        if (cost < bestLocalCost || (cost === bestLocalCost && lexSmaller(newSol, bestLocalSol, numVars))) {\n          bestLocalCost = cost;\n          bestLocalSol = newSol;\n          bestVal = v;\n        }\n      }\n\n      if (bestVal !== currentFreeAssign[k]) {\n        currentFreeAssign[k] = bestVal;\n        bestSol = bestLocalSol;\n        bestCost = bestLocalCost;\n        improved = true;\n      }\n    }\n  }\n\n  return bestSol;\n}\n\nfunction computeSolution(\n  pivotCols: number[],\n  freeVars: number[],\n  freeAssign: number[],\n  p: number,\n  numVars: number,\n  matrix: number[][]\n): number[] {\n  const sol = new Array(numVars).fill(0);\n  for (let k = 0; k < freeVars.length; k++) {\n    sol[freeVars[k]] = freeAssign[k];\n  }\n  for (let i = pivotCols.length - 1; i >= 0; i--) {\n    const pc = pivotCols[i];\n    let val = matrix[i][numVars];\n    for (let j = pc + 1; j < numVars; j++) {\n      val = mod(val - matrix[i][j] * sol[j], p);\n    }\n    sol[pc] = mod(val, p);\n  }\n  return sol;\n}\n\nfunction sumArray(arr: number[]): number {\n  let s = 0;\n  for (const v of arr) s += v;\n  return s;\n}\n\nfunction lexSmaller(a: number[], b: number[], n: number): boolean {\n  for (let i = 0; i < n; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\n// ── Public API ──────────────────────────────────────────────────────────────\n\nexport interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve the toggle puzzle (GF(2) linear system).\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | b] where A is numLights × numButtons\n  // A[i][j] = 1 if button j toggles light i, else 0\n  // b[i] = target[i] ? 1 : 0\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n\n  const sys: LinearSystem = {\n    numVars: numButtons,\n    numEqs: numLights,\n    matrix,\n    p: 2,\n  };\n\n  const result = solveSystem(sys);\n  if (result === null) return null;\n\n  // Convert from press-count vector to sorted array of pressed button indices\n  const pressed: number[] = [];\n  for (let j = 0; j < numButtons; j++) {\n    if (result[j] === 1) pressed.push(j);\n  }\n  return pressed;\n}\n\n/**\n * Solve the counter puzzle (GF(p) linear system).\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | b] where A is numCounters × numButtons\n  // A[i][j] = 1 if button j affects counter i, else 0\n  // b[i] = lights[i]\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = mod(lights[i], modulus);\n    matrix.push(row);\n  }\n\n  const sys: LinearSystem = {\n    numVars: numButtons,\n    numEqs: numCounters,\n    matrix,\n    p: modulus,\n  };\n\n  const result = solveSystem(sys);\n  if (result === null) return null;\n\n  return result;\n}\n","numLines":422,"startLine":1,"totalLines":422}}}
