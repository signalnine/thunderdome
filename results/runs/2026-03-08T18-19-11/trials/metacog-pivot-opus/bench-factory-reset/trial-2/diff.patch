; k < numFree; k++) {\n      let bestVal = currentFreeAssign[k];\n      let bestLocalCost = bestCost;\n      let bestLocalSol = bestSol;\n\n      for (let v = 0; v < p; v++) {\n        if (v === currentFreeAssign[k]) continue;\n        const delta = mod(v - currentFreeAssign[k], p);\n        const newSol = bestSol.slice();\n        for (let j = 0; j < numVars; j++) {\n          newSol[j] = mod(newSol[j] + delta * nullVecs[k][j], p);\n        }\n        const cost = sumArray(newSol);\n        if (cost < bestLocalCost || (cost === bestLocalCost && lexSmaller(newSol, bestLocalSol, numVars))) {\n          bestLocalCost = cost;\n          bestLocalSol = newSol;\n          bestVal = v;\n        }\n      }\n\n      if (bestVal !== currentFreeAssign[k]) {\n        currentFreeAssign[k] = bestVal;\n        bestSol = bestLocalSol;\n        bestCost = bestLocalCost;\n        improved = true;\n      }\n    }\n  }\n\n  return bestSol;\n}\n\nfunction computeSolution(\n  pivotCols: number[],\n  freeVars: number[],\n  freeAssign: number[],\n  p: number,\n  numVars: number,\n  matrix: number[][]\n): number[] {\n  const sol = new Array(numVars).fill(0);\n  for (let k = 0; k < freeVars.length; k++) {\n    sol[freeVars[k]] = freeAssign[k];\n  }\n  for (let i = pivotCols.length - 1; i >= 0; i--) {\n    const pc = pivotCols[i];\n    let val = matrix[i][numVars];\n    for (let j = pc + 1; j < numVars; j++) {\n      val = mod(val - matrix[i][j] * sol[j], p);\n    }\n    sol[pc] = mod(val, p);\n  }\n  return sol;\n}\n\nfunction sumArray(arr: number[]): number {\n  let s = 0;\n  for (const v of arr) s += v;\n  return s;\n}\n\nfunction lexSmaller(a: number[], b: number[], n: number): boolean {\n  for (let i = 0; i < n; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\n// ── Public API ──────────────────────────────────────────────────────────────\n\nexport interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n/**\n * Sol