+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  it('returns empty array when target is all off', () => {
+    expect(solveToggle({ target: [false, false], buttons: [[0], [1]] })).toEqual([]);
+  });
+
+  it('returns null when no solution exists', () => {
+    // From the example in the spec
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('solves simple single button', () => {
+    expect(solveToggle({ target: [true], buttons: [[0]] })).toEqual([0]);
+  });
+
+  it('solves two buttons independently', () => {
+    expect(solveToggle({
+      target: [true, true],
+      buttons: [[0], [1]],
+    })).toEqual([0, 1]);
+  });
+
+  it('returns minimum button presses', () => {
+    // Button 0 toggles light 0, Button 1 toggles lights 0 and 1, Button 2 toggles light 1
+    // Target: [true, true]
+    // Button 1 alone: [true, true] ✓ — 1 press
+    // Buttons 0, 2: [true, true] ✓ — 2 presses
+    // Should return [1]
+    expect(solveToggle({
+      target: [true, true],
+      buttons: [[0], [0, 1], [1]],
+    })).toEqual([1]);
+  });
+
+  it('returns lexicographically smallest when tied on press count', () => {
+    // Button 0 toggles [0], Button 1 toggles [0]
+    // Both press just one button, target [true]
+    // Should return [0] (lex smallest)
+    expect(solveToggle({
+      target: [true],
+      buttons: [[0], [0]],
+    })).toEqual([0]);
+  });
+
+  it('handles no buttons with all-off target', () => {
+    expect(solveToggle({ target: [false, false], buttons: [] })).toEqual([]);
+  });
+
+  it('handles no buttons with non-zero target', () => {
+    expect(solveToggle({ target: [true], buttons: [] })).toBeNull();
+  });
+
+  it('solves overlapping buttons', () => {
+    // 3 lights, 3 buttons
+    // B0: [0,1], B1: [1,2], B2: [0,2]
+    // Target: [true, false, true]
+    // Press B2: [on, off, on] → [true, false, true] ✓
+    expect(solveToggle({
+      target: [true, false, true],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    })).toEqual([2]);
+  });
+
+  it('handles redundant buttons', () => {
+    // B0 and B1 both toggle [0]
+    // Target [false]: just press nothing
+    expect(solveToggle({
+      target: [false],
+      buttons: [[0], [0]],
+    })).toEqual([]);
+  });
+
+  it('handles larger system', () => {
+    // 5 lights, 5 buttons where each button toggles one light
+    const result = solveToggle({
+      target: [true, false, true, false, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    });
+    expect(result).toEqual([0, 2, 4]);
+  });
+
+  it('verifies solution correctness', () => {
+    const machine = {
+      target: [true, false, true],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).not.toBeNull();
+
+    // Verify: simulate
+    const lights = [false, false, false];
+    for (const btnIdx of result!) {
+      for (const lightIdx of machine.buttons[btnIdx]) {
+        lights[lightIdx] = !lights[lightIdx];
+      }
+    }
+    expect(lights).toEqual(machine.target);
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns array of zeros when target is all zeros', () => {
+    expect(solveCounter([0, 0], [[0], [1]], 5)).toEqual([0, 0]);
+  });
+
+  it('returns null when no solution exists', () => {
+    // 1 counter, no buttons, target is 3
+    expect(solveCounter([3], [], 5)).toBeNull();
+  });
+
+  it('solves simple single button', () => {
+    // 1 counter, 1 button affecting it, target 3, mod 5
+    // Press 3 times
+    expect(solveCounter([3], [[0]], 5)).toEqual([3]);
+  });
+
+  it('solves with modular arithmetic', () => {
+    // 1 counter, 1 button, target 0, mod 5 → press 0 times
+    expect(solveCounter([0], [[0]], 5)).toEqual([0]);
+  });
+
+  it('handles no buttons with zero target', () => {
+    expect(solveCounter([0], [], 5)).toEqual([]);
+  });
+
+  it('solves two independent counters', () => {
+    // Counter 0 → target 2, Counter 1 → target 3, mod 5
+    // Button 0 affects counter 0, Button 1 affects counter 1
+    expect(solveCounter([2, 3], [[0], [1]], 5)).toEqual([2, 3]);
+  });
+
+  it('returns minimum total presses', () => {
+    // 1 counter, 2 buttons both affecting counter 0, target 1, mod 5
+    // Button 0: press 1 (total 1), Button 1: press 0 → [1, 0]
+    // Button 0: press 0, Button 1: press 1 → [0, 1]
+    // Both total 1, lex smallest is [0, 1]
+    // Actually: system is x0 + x1 ≡ 1 (mod 5)
+    // Solutions: (0,1), (1,0), (2,4), (3,3), (4,2)
+    // Min total: (0,1) and (1,0) both = 1
+    // Lex smallest: [0, 1]
+    expect(solveCounter([1], [[0], [0]], 5)).toEqual([0, 1]);
+  });
+
+  it('solves overlapping buttons', () => {
+    // 2 counters, 2 buttons
+    // B0: affects [0, 1], B1: affects [1]
+    // Target: [2, 3], mod 5
+    // x0 ≡ 2 (counter 0), x0 + x1 ≡ 3 (counter 1)
+    // → x0 = 2, x1 = 1
+    expect(solveCounter([2, 3], [[0, 1], [1]], 5)).toEqual([2, 1]);
+  });
+
+  it('handles impossible case with modular constraints', () => {
+    // 2 counters, 1 button affecting both
+    // B0: affects [0, 1]
+    // Target: [1, 2], mod 3
+    // x0 ≡ 1, x0 ≡ 2 → contradiction
+    expect(solveCounter([1, 2], [[0, 1]], 3)).toBeNull();
+  });
+
+  it('verifies solution correctness', () => {
+    const lights = [3, 1, 4];
+    const buttons = [[0, 1], [1, 2], [0, 2]];
+    const modulus = 5;
+    const result = solveCounter(lights, buttons, modulus);
+    expect(result).not.toBeNull();
+
+    // Verify
+    const counters = [0, 0, 0];
+    for (let b = 0; b < buttons.length; b++) {
+      for (const idx of buttons[b]) {
+        counters[idx] = (counters[idx] + result![b]) % modulus;
+      }
+    }
+    expect(counters).toEqual(lights);
+  });
+
+  it('handles larger modulus', () => {
+    // Simple case with mod 97
+    expect(solveCounter([50], [[0]], 97)).toEqual([50]);
+  });
+
+  it('prefers lexicographically smallest among minimum total', () => {
+    // 1 counter, 2 buttons, target 0, mod 3
+    // Trivially, [0, 0] works
+    expect(solveCounter([0], [[0], [0]], 3)).toEqual([0, 0]);
+  });
+});
