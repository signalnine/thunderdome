+interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function popcount(x: bigint): number {
+  let count = 0;
+  while (x > 0n) {
+    x &= x - 1n;
+    count++;
+  }
+  return count;
+}
+
+function solutionToArray(sol: bigint, numButtons: number): number[] {
+  const result: number[] = [];
+  for (let i = 0; i < numButtons; i++) {
+    if ((sol >> BigInt(i)) & 1n) {
+      result.push(i);
+    }
+  }
+  return result;
+}
+
+function compareBitmaskSolutions(a: bigint, b: bigint, numButtons: number): number {
+  const pa = popcount(a);
+  const pb = popcount(b);
+  if (pa !== pb) return pa - pb;
+  // Same popcount: lexicographic comparison of sorted index arrays.
+  // Scan bits from LSB. If a has bit i and b doesn't, a's array includes index i
+  // where b's array has some larger index at that position → a is lex smaller.
+  for (let i = 0; i < numButtons; i++) {
+    const ba = Number((a >> BigInt(i)) & 1n);
+    const bb = Number((b >> BigInt(i)) & 1n);
+    if (ba !== bb) {
+      // ba=1, bb=0 → a is lex smaller → return -1 (which is bb - ba)
+      // ba=0, bb=1 → b is lex smaller → return 1 (which is bb - ba)
+      return bb - ba;
+    }
+  }
+  return 0;
+}
+
+/**
+ * Solve toggle puzzle using Gaussian elimination over GF(2).
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return target.every((t) => !t) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(2) using BigInt bitmasks
+  // Each row: bits 0..numButtons-1 are coefficients, bit numButtons is the target
+  const rows: bigint[] = [];
+  for (let i = 0; i < numLights; i++) {
+    let row = 0n;
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row |= 1n << BigInt(j);
+      }
+    }
+    if (target[i]) {
+      row |= 1n << BigInt(numButtons);
+    }
+    rows.push(row);
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotCol: number[] = [];
+  let rank = 0;
+
+  for (let col = 0; col < numButtons; col++) {
+    let found = -1;
+    for (let row = rank; row < numLights; row++) {
+      if ((rows[row] >> BigInt(col)) & 1n) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [rows[rank], rows[found]] = [rows[found], rows[rank]];
+    pivotCol.push(col);
+
+    for (let row = 0; row < numLights; row++) {
+      if (row !== rank && (rows[row] >> BigInt(col)) & 1n) {
+        rows[row] ^= rows[rank];
+      }
+    }
+    rank++;
+  }
+
+  // Check consistency
+  for (let row = rank; row < numLights; row++) {
+    if ((rows[row] >> BigInt(numButtons)) & 1n) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotColSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotColSet.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // Compute solution from free variable assignment (bitmask over free vars)
+  const computeSolution = (freeAssign: bigint): bigint => {
+    let solution = 0n;
+    for (let i = 0; i < numFree; i++) {
+      if ((freeAssign >> BigInt(i)) & 1n) {
+        solution |= 1n << BigInt(freeVars[i]);
+      }
+    }
+    for (let r = 0; r < rank; r++) {
+      const col = pivotCol[r];
+      let val = (rows[r] >> BigInt(numButtons)) & 1n;
+      for (let i = 0; i < numFree; i++) {
+        if ((freeAssign >> BigInt(i)) & 1n) {
+          val ^= (rows[r] >> BigInt(freeVars[i])) & 1n;
+        }
+      }
+      if (val) {
+        solution |= 1n << BigInt(col);
+      }
+    }
+    return solution;
+  };
+
+  if (numFree === 0) {
+    const result: number[] = [];
+    for (let r = 0; r < rank; r++) {
+      if ((rows[r] >> BigInt(numButtons)) & 1n) {
+        result.push(pivotCol[r]);
+      }
+    }
+    result.sort((a, b) => a - b);
+    return result;
+  }
+
+  const isBetter = (a: bigint, b: bigint): boolean =>
+    compareBitmaskSolutions(a, b, numButtons) < 0;
+
+  if (numFree <= 24) {
+    // Direct enumeration (up to 2^24 = ~16M)
+    let bestSol = computeSolution(0n);
+    const total = 1n << BigInt(numFree);
+    for (let mask = 1n; mask < total; mask++) {
+      const sol = computeSolution(mask);
+      if (isBetter(sol, bestSol)) {
+        bestSol = sol;
+      }
+    }
+    return solutionToArray(bestSol, numButtons);
+  }
+
+  // For numFree > 24, use greedy local search with null space vectors
+  const nullVecs: bigint[] = [];
+  for (let i = 0; i < numFree; i++) {
+    let vec = 1n << BigInt(freeVars[i]);
+    for (let r = 0; r < rank; r++) {
+      if ((rows[r] >> BigInt(freeVars[i])) & 1n) {
+        vec |= 1n << BigInt(pivotCol[r]);
+      }
+    }
+    nullVecs.push(vec);
+  }
+
+  const particular = computeSolution(0n);
+  let bestSol = particular;
+  let current = particular;
+
+  // Greedy: toggle one null vector at a time until no improvement
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (let i = 0; i < numFree; i++) {
+      const candidate = current ^ nullVecs[i];
+      if (isBetter(candidate, bestSol)) {
+        current = candidate;
+        bestSol = candidate;
+        improved = true;
+      }
+    }
+  }
+
+  // Also try all pairs from current best
+  for (let i = 0; i < numFree; i++) {
+    for (let j = i + 1; j < numFree; j++) {
+      const candidate = current ^ nullVecs[i] ^ nullVecs[j];
+      if (isBetter(candidate, bestSol)) {
+        bestSol = candidate;
+      }
+    }
+  }
+
+  return solutionToArray(bestSol, numButtons);
+}
+
+/**
+ * Solve counter puzzle using Gaussian elimination over GF(p).
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return lights.every((v) => v === 0) ? [] : null;
+  }
+
+  const mod = (a: number, m: number): number => ((a % m) + m) % m;
+
+  const modPow = (base: number, exp: number, m: number): number => {
+    let result = 1;
+    base = mod(base, m);
+    while (exp > 0) {
+      if (exp & 1) result = mod(result * base, m);
+      exp >>= 1;
+      base = mod(base * base, m);
+    }
+    return result;
+  };
+
+  const modInverse = (a: number, m: number): number => modPow(mod(a, m), m - 2, m);
+
+  // Build augmented matrix
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = mod(lights[i], modulus);
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(modulus)
+  const pivotCol: number[] = [];
+  let rank = 0;
+
+  for (let col = 0; col < numButtons; col++) {
+    let found = -1;
+    for (let row = rank; row < numCounters; row++) {
+      if (matrix[row][col] !== 0) {
+        found = row;
+        break;
+      }
+    }
+    if (found === -1) continue;
+
+    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];
+
+    const inv = modInverse(matrix[rank][col], modulus);
+    for (let j = 0; j <= numButtons; j++) {
+      matrix[rank][j] = mod(matrix[rank][j] * inv, modulus);
+    }
+
+    for (let row = 0; row < numCounters; row++) {
+      if (row !== rank && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let j = 0; j <= numButtons; j++) {
+          matrix[row][j] = mod(matrix[row][j] - factor * matrix[rank][j], modulus);
+        }
+      }
+    }
+
+    pivotCol.push(col);
+    rank++;
+  }
+
+  // Check consistency
+  for (let row = rank; row < numCounters; row++) {
+    if (matrix[row][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotColSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotColSet.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  const computeSolution = (freeAssign: number[]): number[] => {
+    const solution = new Array(numButtons).fill(0);
+    for (let i = 0; i < numFree; i++) {
+      solution[freeVars[i]] = freeAssign[i];
+    }
+    for (let r = 0; r < rank; r++) {
+      const col = pivotCol[r];
+      let val = matrix[r][numButtons];
+      for (let i = 0; i < numFree; i++) {
+        val = mod(val - matrix[r][freeVars[i]] * freeAssign[i], modulus);
+      }
+      solution[col] = mod(val, modulus);
+    }
+    return solution;
+  };
+
+  const totalPresses = (sol: number[]): number => sol.reduce((a, b) => a + b, 0);
+
+  const isBetterCounter = (a: number[], b: number[]): boolean => {
+    const ta = totalPresses(a);
+    const tb = totalPresses(b);
+    if (ta !== tb) return ta < tb;
+    for (let i = 0; i < a.length; i++) {
+      if (a[i] !== b[i]) return a[i] < b[i];
+    }
+    return false;
+  };
+
+  if (numFree === 0) {
+    return computeSolution([]);
+  }
+
+  // Check if direct enumeration is feasible
+  const totalCombinations = Math.pow(modulus, numFree);
+
+  if (totalCombinations <= 15_000_000) {
+    let bestSol: number[] | null = null;
+    const freeAssign = new Array(numFree).fill(0);
+
+    // Odometer enumeration
+    for (;;) {
+      const sol = computeSolution(freeAssign);
+      if (bestSol === null || isBetterCounter(sol, bestSol)) {
+        bestSol = sol.slice();
+      }
+
+      // Increment
+      let carry = true;
+      for (let i = numFree - 1; i >= 0 && carry; i--) {
+        freeAssign[i]++;
+        if (freeAssign[i] >= modulus) {
+          freeAssign[i] = 0;
+        } else {
+          carry = false;
+        }
+      }
+      if (carry) break;
+    }
+
+    return bestSol;
+  }
+
+  // For large search spaces, use coordinate descent optimization
+  const particular = computeSolution(new Array(numFree).fill(0));
+  let bestSol = particular.slice();
+  const currentFreeAssign = new Array(numFree).fill(0);
+
+  let improved = true;
+  while (improved) {
+    improved = false;
+    for (let i = 0; i < numFree; i++) {
+      let bestV = currentFreeAssign[i];
+      let bestVSol = bestSol;
+      for (let v = 0; v < modulus; v++) {
+        if (v === currentFreeAssign[i]) continue;
+        currentFreeAssign[i] = v;
+        const sol = computeSolution(currentFreeAssign);
+        if (isBetterCounter(sol, bestVSol)) {
+          bestVSol = sol.slice();
+          bestV = v;
+        }
+      }
+      currentFreeAssign[i] = bestV;
+      if (isBetterCounter(bestVSol, bestSol)) {
+        bestSol = bestVSol;
+        improved = true;
+      }
+    }
+  }
+
+  return bestSol;
+}
