--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,495 @@
+// Deep clone using structured clone (or JSON round-trip as fallback)
+function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+// Generate a unique version ID
+let versionCounter = 0;
+function generateVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocEntry {
+  content: object;
+  versions: Version[];
+  deleted: boolean;
+}
+
+// Per-branch state: a map of document ID -> DocEntry
+type BranchState = Map<string, DocEntry>;
+
+function cloneDocEntry(entry: DocEntry): DocEntry {
+  return {
+    content: deepClone(entry.content),
+    versions: entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+    deleted: entry.deleted,
+  };
+}
+
+function cloneBranchState(state: BranchState): BranchState {
+  const cloned: BranchState = new Map();
+  for (const [id, entry] of state) {
+    cloned.set(id, cloneDocEntry(entry));
+  }
+  return cloned;
+}
+
+// Collect all leaf paths and their values from a plain object
+function collectPaths(obj: object, prefix: string = ''): Map<string, unknown> {
+  const result = new Map<string, unknown>();
+  for (const [key, value] of Object.entries(obj)) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    if (value !== null && typeof value === 'object' && !Array.isArray(value)) {
+      const nested = collectPaths(value as object, path);
+      if (nested.size === 0) {
+        // empty object - store as leaf
+        result.set(path, value);
+      } else {
+        for (const [np, nv] of nested) {
+          result.set(np, nv);
+        }
+      }
+    } else {
+      result.set(path, value);
+    }
+  }
+  return result;
+}
+
+// Set a value at a dot-separated path in an object
+function setAtPath(obj: Record<string, unknown>, path: string, value: unknown): void {
+  const parts = path.split('.');
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (!(parts[i] in current) || typeof current[parts[i]] !== 'object' || current[parts[i]] === null || Array.isArray(current[parts[i]])) {
+      current[parts[i]] = {};
+    }
+    current = current[parts[i]] as Record<string, unknown>;
+  }
+  current[parts[parts.length - 1]] = value;
+}
+
+// Delete a key at a dot-separated path
+function deleteAtPath(obj: Record<string, unknown>, path: string): void {
+  const parts = path.split('.');
+  let current: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (!(parts[i] in current) || typeof current[parts[i]] !== 'object' || current[parts[i]] === null) {
+      return;
+    }
+    current = current[parts[i]] as Record<string, unknown>;
+  }
+  delete current[parts[parts.length - 1]];
+}
+
+// Compare two values for deep equality
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return a === b;
+  if (typeof a !== typeof b) return false;
+  if (typeof a !== 'object') return a === b;
+  if (Array.isArray(a) !== Array.isArray(b)) return false;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    return a.every((v, i) => deepEqual(v, b[i]));
+  }
+  const aObj = a as Record<string, unknown>;
+  const bObj = b as Record<string, unknown>;
+  const aKeys = Object.keys(aObj);
+  const bKeys = Object.keys(bObj);
+  if (aKeys.length !== bKeys.length) return false;
+  return aKeys.every(key => key in bObj && deepEqual(aObj[key], bObj[key]));
+}
+
+// Three-way merge of two objects against a base
+function threeWayMerge(
+  base: object | null,
+  ours: object | null,
+  theirs: object | null,
+  documentId: string,
+): { merged: object; conflicts: Conflict[] } {
+  const basePaths = base ? collectPaths(base) : new Map<string, unknown>();
+  const oursPaths = ours ? collectPaths(ours) : new Map<string, unknown>();
+  const theirsPaths = theirs ? collectPaths(theirs) : new Map<string, unknown>();
+
+  const allPaths = new Set<string>();
+  for (const p of basePaths.keys()) allPaths.add(p);
+  for (const p of oursPaths.keys()) allPaths.add(p);
+  for (const p of theirsPaths.keys()) allPaths.add(p);
+
+  const conflicts: Conflict[] = [];
+  const merged: Record<string, unknown> = {};
+
+  // Start from ours as the baseline for merged result
+  if (ours) {
+    Object.assign(merged, deepClone(ours));
+  }
+
+  for (const path of allPaths) {
+    const baseVal = basePaths.has(path) ? basePaths.get(path) : undefined;
+    const oursVal = oursPaths.has(path) ? oursPaths.get(path) : undefined;
+    const theirsVal = theirsPaths.has(path) ? theirsPaths.get(path) : undefined;
+
+    const baseHas = basePaths.has(path);
+    const oursHas = oursPaths.has(path);
+    const theirsHas = theirsPaths.has(path);
+
+    const oursChanged = baseHas !== oursHas || !deepEqual(baseVal, oursVal);
+    const theirsChanged = baseHas !== theirsHas || !deepEqual(baseVal, theirsVal);
+
+    if (!oursChanged && !theirsChanged) {
+      // No changes — keep as is (already in merged from ours)
+      continue;
+    }
+
+    if (oursChanged && !theirsChanged) {
+      // Only ours changed — already in merged from ours copy
+      continue;
+    }
+
+    if (!oursChanged && theirsChanged) {
+      // Only theirs changed — apply theirs
+      if (theirsHas) {
+        setAtPath(merged, path, deepClone(theirsVal));
+      } else {
+        deleteAtPath(merged, path);
+      }
+      continue;
+    }
+
+    // Both changed
+    if (deepEqual(oursVal, theirsVal) && oursHas === theirsHas) {
+      // Both changed to same value — no conflict, keep ours (already in merged)
+      continue;
+    }
+
+    // Conflict — keep ours in merged (as specified), record conflict
+    conflicts.push({
+      documentId,
+      path,
+      base: baseHas ? deepClone(baseVal) : undefined,
+      ours: oursHas ? deepClone(oursVal) : undefined,
+      theirs: theirsHas ? deepClone(theirsVal) : undefined,
+    });
+  }
+
+  return { merged, conflicts };
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = 'main';
+  // Track the snapshot of each branch at its creation point (the ancestor state)
+  // Key: branch name, Value: the branch state snapshot at creation time
+  private branchAncestors: Map<string, BranchState> = new Map();
+  // Track parent branch for each branch
+  private branchParents: Map<string, string> = new Map();
+
+  constructor() {
+    this.branches.set('main', new Map());
+  }
+
+  private getCurrentState(): BranchState {
+    return this.branches.get(this.currentBranch)!;
+  }
+
+  // Document CRUD
+
+  create(id: string, content: object): void {
+    const state = this.getCurrentState();
+    const existing = state.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    state.set(id, {
+      content: deepClone(content),
+      versions: existing && existing.deleted ? [...existing.versions, version] : [version],
+      deleted: false,
+    });
+  }
+
+  get(id: string): object {
+    const state = this.getCurrentState();
+    const entry = state.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return deepClone(entry.content);
+  }
+
+  update(id: string, content: object): void {
+    const state = this.getCurrentState();
+    const entry = state.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+
+    entry.content = deepClone(content);
+    entry.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const state = this.getCurrentState();
+    const entry = state.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    entry.deleted = true;
+  }
+
+  // Version history
+
+  getHistory(id: string): Version[] {
+    const state = this.getCurrentState();
+    const entry = state.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const state = this.getCurrentState();
+    const entry = state.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version = entry.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // Branching
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceBranchName = fromBranch ?? this.currentBranch;
+    const sourceState = this.branches.get(sourceBranchName);
+    if (!sourceState) {
+      throw new Error(`Branch "${sourceBranchName}" not found`);
+    }
+    // Clone the source branch state as the new branch's starting state
+    this.branches.set(name, cloneBranchState(sourceState));
+    // Store the ancestor snapshot (the state at branch creation time)
+    this.branchAncestors.set(name, cloneBranchState(sourceState));
+    this.branchParents.set(name, sourceBranchName);
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  // Merging
+
+  merge(sourceBranch: string): MergeResult {
+    const sourceState = this.branches.get(sourceBranch);
+    if (!sourceState) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+    const targetState = this.getCurrentState();
+
+    // Find common ancestor: use the ancestor snapshot of the source branch
+    // (the state at the point the source branch was created from the target)
+    const ancestor = this.findCommonAncestor(sourceBranch, this.currentBranch);
+
+    // Collect all document IDs across ancestor, source, and target
+    const allDocIds = new Set<string>();
+    if (ancestor) {
+      for (const id of ancestor.keys()) allDocIds.add(id);
+    }
+    for (const id of sourceState.keys()) allDocIds.add(id);
+    for (const id of targetState.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const allConflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const ancestorEntry = ancestor?.get(docId);
+      const sourceEntry = sourceState.get(docId);
+      const targetEntry = targetState.get(docId);
+
+      const ancestorContent = ancestorEntry && !ancestorEntry.deleted ? ancestorEntry.content : null;
+      const sourceContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : null;
+      const targetContent = targetEntry && !targetEntry.deleted ? targetEntry.content : null;
+
+      // Check if either side changed this document
+      const sourceChanged = !deepEqual(ancestorContent, sourceContent);
+      const targetChanged = !deepEqual(ancestorContent, targetContent);
+
+      if (!sourceChanged && !targetChanged) {
+        // No changes on either side for this doc
+        if (targetContent !== null) {
+          merged[docId] = deepClone(targetContent);
+        }
+        continue;
+      }
+
+      if (sourceChanged && !targetChanged) {
+        // Only source changed
+        if (sourceContent !== null) {
+          merged[docId] = deepClone(sourceContent);
+        }
+        // If source deleted it, don't include in merged
+        continue;
+      }
+
+      if (!sourceChanged && targetChanged) {
+        // Only target changed — keep target as-is
+        if (targetContent !== null) {
+          merged[docId] = deepClone(targetContent);
+        }
+        continue;
+      }
+
+      // Both changed — need three-way merge
+      // Handle case where one side deleted and other modified
+      if (sourceContent === null && targetContent === null) {
+        // Both deleted — no conflict
+        continue;
+      }
+
+      if (sourceContent === null || targetContent === null) {
+        // One deleted, one modified — that's a conflict on the whole document
+        // For merged, favor ours (target)
+        if (targetContent !== null) {
+          merged[docId] = deepClone(targetContent);
+        }
+        allConflicts.push({
+          documentId: docId,
+          path: '',
+          base: ancestorContent !== null ? deepClone(ancestorContent) : undefined,
+          ours: targetContent !== null ? deepClone(targetContent) : undefined,
+          theirs: sourceContent !== null ? deepClone(sourceContent) : undefined,
+        });
+        continue;
+      }
+
+      // Both modified — do structural three-way merge
+      const { merged: mergedContent, conflicts } = threeWayMerge(
+        ancestorContent,
+        targetContent,
+        sourceContent,
+        docId,
+      );
+      merged[docId] = mergedContent;
+      allConflicts.push(...conflicts);
+    }
+
+    const applied = allConflicts.length === 0;
+
+    if (applied) {
+      // Apply the merge to the current branch
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const existing = targetState.get(docId);
+          const mergedContent = merged[docId];
+          if (existing && !existing.deleted) {
+            // Check if content actually changed
+            if (!deepEqual(existing.content, mergedContent)) {
+              const version: Version = {
+                id: generateVersionId(),
+                timestamp: Date.now(),
+                content: deepClone(mergedContent),
+              };
+              existing.content = deepClone(mergedContent);
+              existing.versions.push(version);
+            }
+          } else {
+            // Document was added from source branch
+            const sourceEntry = sourceState.get(docId);
+            if (sourceEntry) {
+              targetState.set(docId, cloneDocEntry(sourceEntry));
+            }
+          }
+        } else {
+          // Document was deleted in the merge result
+          const existing = targetState.get(docId);
+          if (existing && !existing.deleted) {
+            existing.deleted = true;
+          }
+        }
+      }
+
+      // Update the ancestor snapshot for the source branch to the current state
+      // so subsequent merges use the right base
+      this.branchAncestors.set(sourceBranch, cloneBranchState(targetState));
+    }
+
+    return { merged, conflicts: allConflicts, applied };
+  }
+
+  private findCommonAncestor(sourceBranch: string, targetBranch: string): BranchState | null {
+    // The common ancestor is the state at the point the source branch was created
+    // If source was created from target, use source's ancestor
+    // If target was created from source, use target's ancestor
+    const sourceParent = this.branchParents.get(sourceBranch);
+    const targetParent = this.branchParents.get(targetBranch);
+
+    if (sourceParent === targetBranch) {
+      return this.branchAncestors.get(sourceBranch) ?? null;
+    }
+    if (targetParent === sourceBranch) {
+      return this.branchAncestors.get(targetBranch) ?? null;
+    }
+
+    // For more complex scenarios, try to find the ancestor through the chain
+    // For now, use the source branch's ancestor if available
+    return this.branchAncestors.get(sourceBranch) ?? null;
+  }
+}
