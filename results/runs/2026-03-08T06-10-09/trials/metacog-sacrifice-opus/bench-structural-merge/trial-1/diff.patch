t bKeys = Object.keys(bObj);\n  if (aKeys.length !== bKeys.length) return false;\n  return aKeys.every(key => key in bObj && deepEqual(aObj[key], bObj[key]));\n}\n\n// Three-way merge of two objects against a base\nfunction threeWayMerge(\n  base: object | null,\n  ours: object | null,\n  theirs: object | null,\n  documentId: string,\n): { merged: object; conflicts: Conflict[] } {\n  const basePaths = base ? collectPaths(base) : new Map<string, unknown>();\n  const oursPaths = ours ? collectPaths(ours) : new Map<string, unknown>();\n  const theirsPaths = theirs ? collectPaths(theirs) : new Map<string, unknown>();\n\n  const allPaths = new Set<string>();\n  for (const p of basePaths.keys()) allPaths.add(p);\n  for (const p of oursPaths.keys()) allPaths.add(p);\n  for (const p of theirsPaths.keys()) allPaths.add(p);\n\n  const conflicts: Conflict[] = [];\n  const merged: Record<string, unknown> = {};\n\n  // Start from ours as the baseline for merged result\n  if (ours) {\n    Object.assign(merged, deepClone(ours));\n  }\n\n  for (const path of allPaths) {\n    const baseVal = basePaths.has(path) ? basePaths.get(path) : undefined;\n    const oursVal = oursPaths.has(path) ? oursPaths.get(path) : undefined;\n    const theirsVal = theirsPaths.has(path) ? theirsPaths.get(path) : undefined;\n\n    const baseHas = basePaths.has(path);\n    const oursHas = oursPaths.has(path);\n    const theirsHas = theirsPaths.has(path);\n\n    const oursChanged = baseHas !== oursHas || !deepEqual(baseVal, oursVal);\n    const theirsChanged = baseHas !== theirsHas || !deepEqual(baseVal, theirsVal);\n\n    if (!oursChanged && !theirsChanged) {\n      // No changes — keep as is (already in merged from ours)\n      continue;\n    }\n\n    if (oursChanged && !theirsChanged) {\n      // Only ours changed — already in merged from ours copy\n      continue;\n    }\n\n    if (!oursChanged && theirsChanged) {\n      // Only theirs changed — apply theirs\n      if (theirsHas) {\n        setAtPath(mer