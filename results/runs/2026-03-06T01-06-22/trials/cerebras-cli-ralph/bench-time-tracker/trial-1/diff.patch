+import { describe, it, expect, beforeEach, afterEach } from 'vitest';
+import { TimeTracker } from './tracker.js';
+import { promises as fs } from 'fs';
+import { join } from 'path';
+
+// Use a temporary file for persistence
+const tempFile = join(process.cwd(), 'temp-tracker-data.json');
+
+afterEach(async () => {
+  // cleanup file
+  try {
+    await fs.unlink(tempFile);
+  } catch (e) { /* ignore */ }
+});
+
+describe('TimeTracker', () => {
+  let tracker: TimeTracker;
+
+  beforeEach(() => {
+    tracker = new TimeTracker({ filePath: tempFile });
+  });
+
+  it('starts and stops a timer', async () => {
+    await tracker.start('Task A');
+    // simulate some delay
+    await new Promise((r) => setTimeout(r, 10));
+    await tracker.stop();
+    const entries = tracker.getEntries();
+    expect(entries).toHaveLength(1);
+    const e = entries[0];
+    expect(e.task).toBe('Task A');
+    expect(e.start).toBeDefined();
+    expect(e.end).toBeDefined();
+    expect(new Date(e.end!).getTime()).toBeGreaterThan(new Date(e.start).getTime());
+  });
+
+  it('auto-stops previous timer when starting new one', async () => {
+    await tracker.start('First');
+    await new Promise((r) => setTimeout(r, 5));
+    await tracker.start('Second'); // should stop first automatically
+    const entries = tracker.getEntries();
+    expect(entries).toHaveLength(2);
+    const first = entries[0];
+    const second = entries[1];
+    expect(first.task).toBe('First');
+    expect(first.end).toBeDefined();
+    expect(second.task).toBe('Second');
+    expect(second.end).toBeUndefined();
+  });
+
+  it('throws on empty task name', async () => {
+  
+    await expect(tracker.start('')).rejects.toThrow('Task name must not be empty');
+  });
+
+  it('throws on stop when no timer running', async () => {
+    await expect(tracker.stop()).rejects.toThrow('No timer is currently running');
+  });
+
+  it('persists entries to file and reloads', async () => {
+    await tracker.start('Persist');
+    await new Promise((r) => setTimeout(r, 5));
+    await tracker.stop();
+    const before = tracker.getEntries();
+    // create new instance reading same file
+    const tracker2 = new TimeTracker({ filePath: tempFile });
+    // give it time to load async constructor (load is async fire-and-forget). Wait a tick.
+    await new Promise((r) => setTimeout(r, 20));
+    const after = tracker2.getEntries();
+    expect(after).toEqual(before);
+  });
+
+  it('provides summary including running timer', async () => {
+    await tracker.start('Running');
+    await new Promise((r) => setTimeout(r, 10));
+    const summary = tracker.getSummary();
+    expect(summary['Running']).toBeGreaterThan(0);
+    // stop and check summary unchanged for completed period
+    await tracker.stop();
+    const summary2 = tracker.getSummary();
+    expect(summary2['Running']).toBeGreaterThanOrEqual(summary['Running']);
+  });
+});
