async () => {\n    // @ts-expect-error testing runtime error\n    await expect(tracker.start('')).rejects.toThrow('Task name must not be empty');\n  });\n\n  it('throws on stop when no timer running', async () => {\n    await expect(tracker.stop()).rejects.toThrow('No timer is currently running');\n  });\n\n  it('persists entries to file and reloads', async () => {\n    await tracker.start('Persist');\n    await new Promise((r) => setTimeout(r, 5));\n    await tracker.stop();\n    const before = tracker.getEntries();\n    // create new instance reading same file\n    const tracker2 = new TimeTracker({ filePath: tempFile });\n    // give it time to load async constructor (load is async fire-and-forget). Wait a tick.\n    await new Promise((r) => setTimeout(r, 20));\n    const after = tracker2.getEntries();\n    expect(after).toEqual(before);\n  });\n\n  it('provides summary including running timer', async () => {\n    await tracker.start('Running');\n    await new Promise((r) => setTimeout(r, 10));\n    const summary = tracker.getSummary();\n    expect(summary['Running']).toBeGreaterThan(0);\n    // stop and check summary unchanged for completed period\n    await tracker.stop();\n    const summary2 = tracker.getSummary();\n    expect(summary2['Running']).toBeGreaterThanOrEqual(summary['Running']);\n  });\n});\n"},"output":"Wrote file successfully.","title":"src/tracker.test.ts","metadata":{"diagnostics":{},"filepath":"/workspace/src/tracker.test.ts","exists":false,"truncated":false},"time":{"start":1772759219793,"end":1772759219805}}}}
