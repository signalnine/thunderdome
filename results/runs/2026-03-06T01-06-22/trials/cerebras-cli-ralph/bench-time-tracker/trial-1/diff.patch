+// Time Tracker implementation
+
+import { promises as fs } from "fs";
+import { join, dirname } from "path";
+
+export interface TimeEntry {
+  /** Task name */
+  task: string;
+  /** ISO string of start time */
+  start: string;
+  /** ISO string of end time, if stopped */
+  end?: string;
+}
+
+export interface TrackerOptions {
+  /** Path to JSON file used for persistence. */
+  filePath?: string;
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private runningEntry: TimeEntry | null = null;
+  private filePath: string;
+
+  constructor(options: TrackerOptions = {}) {
+    // Resolve file path relative to cwd if not absolute
+    this.filePath = options.filePath ?? join(process.cwd(), "time-tracker-data.json");
+    // Load existing data (ignore errors if file does not exist)
+    this.load().catch(() => {
+      // start with empty entries
+    });
+  }
+
+  /** Start a timer for a given task name */
+  async start(taskName: string): Promise<void> {
+    if (!taskName) {
+      throw new Error("Task name must not be empty");
+    }
+    // If a timer is already running, stop it automatically
+    if (this.runningEntry) {
+      await this.stop();
+    }
+    const now = new Date().toISOString();
+    this.runningEntry = { task: taskName, start: now };
+    // Add to entries list (will be finalized when stopped)
+    this.entries.push(this.runningEntry);
+    await this.save();
+  }
+
+  /** Stop the currently running timer */
+  async stop(): Promise<void> {
+    if (!this.runningEntry) {
+      throw new Error("No timer is currently running");
+    }
+    const now = new Date().toISOString();
+    this.runningEntry.end = now;
+    this.runningEntry = null;
+    await this.save();
+  }
+
+  /** Get all entries, optionally filtered by date range */
+  getEntries(filter?: { from?: Date; to?: Date }): TimeEntry[] {
+    let result = this.entries.slice(); // copy
+    if (filter) {
+      const { from, to } = filter;
+      result = result.filter((e) => {
+        const start = new Date(e.start);
+        const afterFrom = !from || start >= from;
+        const beforeTo = !to || start <= to;
+        return afterFrom && beforeTo;
+      });
+    }
+    return result;
+  }
+
+  /** Summarize total time per task in milliseconds */
+  getSummary(): Record<string, number> {
+    const now = Date.now();
+    const summary: Record<string, number> = {};
+    for (const entry of this.entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.end ? new Date(entry.end).getTime() : now;
+      const delta = end - start;
+      summary[entry.task] = (summary[entry.task] ?? 0) + delta;
+    }
+    return summary;
+  }
+
+  /** Load entries from the JSON file */
+  private async load(): Promise<void> {
+    try {
+      const data = await fs.readFile(this.filePath, "utf-8");
+      const parsed: TimeEntry[] = JSON.parse(data);
+      // Validate structure loosely
+      if (Array.isArray(parsed)) {
+        this.entries = parsed;
+        // Determine if any entry is still running (no end)
+        this.runningEntry = this.entries.find((e) => !e.end) ?? null;
+      }
+    } catch (err: unknown) {
+      // If file not found, start with empty data
+      if ((err as { code?: string }).code !== "ENOENT") {
+        // rethrow unexpected errors
+        throw err;
+      }
+    }
+  }
+
+  /** Save entries to the JSON file, ensuring directory exists */
+  private async save(): Promise<void> {
+    const dir = dirname(this.filePath);
+    await fs.mkdir(dir, { recursive: true });
+    const data = JSON.stringify(this.entries, null, 2);
+    await fs.writeFile(this.filePath, data, "utf-8");
+  }
+}
