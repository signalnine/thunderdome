+import { describe, it, expect, beforeEach } from 'vitest';
+import { createReviewService } from './index.js';
+import type { ReviewService } from '../types.js';
+
+describe('ReviewService', () => {
+  let reviews: ReviewService;
+
+  beforeEach(() => {
+    reviews = createReviewService();
+  });
+
+  describe('addReview', () => {
+    it('should add a review and return it with id and metadata', () => {
+      const review = reviews.addReview({
+        pluginName: 'test-plugin',
+        pluginVersion: '1.0.0',
+        userId: 'user1',
+        rating: 5,
+        comment: 'Great plugin!',
+      });
+      expect(review.id).toBeDefined();
+      expect(review.flagged).toBe(false);
+      expect(review.createdAt).toBeDefined();
+      expect(review.rating).toBe(5);
+      expect(review.comment).toBe('Great plugin!');
+    });
+
+    it('should throw for invalid rating below 1', () => {
+      expect(() =>
+        reviews.addReview({
+          pluginName: 'test-plugin',
+          pluginVersion: '1.0.0',
+          userId: 'user1',
+          rating: 0,
+          comment: 'Bad',
+        })
+      ).toThrow();
+    });
+
+    it('should throw for invalid rating above 5', () => {
+      expect(() =>
+        reviews.addReview({
+          pluginName: 'test-plugin',
+          pluginVersion: '1.0.0',
+          userId: 'user1',
+          rating: 6,
+          comment: 'Too high',
+        })
+      ).toThrow();
+    });
+
+    it('should throw for non-integer rating', () => {
+      expect(() =>
+        reviews.addReview({
+          pluginName: 'test-plugin',
+          pluginVersion: '1.0.0',
+          userId: 'user1',
+          rating: 3.5,
+          comment: 'Fractional',
+        })
+      ).toThrow();
+    });
+  });
+
+  describe('getReviews', () => {
+    it('should return all reviews for a plugin', () => {
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'b' });
+      reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: 'c' });
+      const result = reviews.getReviews('p1');
+      expect(result).toHaveLength(2);
+    });
+
+    it('should return empty array for non-existent plugin', () => {
+      expect(reviews.getReviews('nonexistent')).toEqual([]);
+    });
+  });
+
+  describe('getAverageRating', () => {
+    it('should compute average excluding flagged reviews', () => {
+      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'b' });
+      reviews.flagReview(r1.id);
+      const avg = reviews.getAverageRating('p1');
+      expect(avg).toBe(3);
+    });
+
+    it('should return 0 when no unflagged reviews exist', () => {
+      const r = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });
+      reviews.flagReview(r.id);
+      expect(reviews.getAverageRating('p1')).toBe(0);
+    });
+
+    it('should return 0 for non-existent plugin', () => {
+      expect(reviews.getAverageRating('nonexistent')).toBe(0);
+    });
+  });
+
+  describe('flagReview', () => {
+    it('should flag a review', () => {
+      const r = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });
+      reviews.flagReview(r.id);
+      const flagged = reviews.getFlaggedReviews();
+      expect(flagged).toHaveLength(1);
+      expect(flagged[0].flagged).toBe(true);
+    });
+  });
+
+  describe('getFlaggedReviews', () => {
+    it('should return only flagged reviews', () => {
+      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'b' });
+      reviews.flagReview(r1.id);
+      const flagged = reviews.getFlaggedReviews();
+      expect(flagged).toHaveLength(1);
+      expect(flagged[0].id).toBe(r1.id);
+    });
+  });
+
+  describe('removeReview', () => {
+    it('should remove a review and return true', () => {
+      const r = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });
+      expect(reviews.removeReview(r.id)).toBe(true);
+      expect(reviews.getReviews('p1')).toHaveLength(0);
+    });
+
+    it('should return false for non-existent review', () => {
+      expect(reviews.removeReview(999)).toBe(false);
+    });
+  });
+
+  describe('getReviewsByUser', () => {
+    it('should return all reviews by a user', () => {
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: 'a' });
+      reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'user1', rating: 4, comment: 'b' });
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user2', rating: 3, comment: 'c' });
+      const result = reviews.getReviewsByUser('user1');
+      expect(result).toHaveLength(2);
+    });
+  });
+
+  describe('getReviewCount', () => {
+    it('should return count of non-flagged reviews', () => {
+      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });
+      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'b' });
+      reviews.flagReview(r1.id);
+      expect(reviews.getReviewCount('p1')).toBe(1);
+    });
+
+    it('should return 0 for non-existent plugin', () => {
+      expect(reviews.getReviewCount('nonexistent')).toBe(0);
+    });
+  });
+});
