@@ -0,0 +1,87 @@
+import { describe, it, expect } from 'vitest';
+import { createResolver } from './index.js';
+
+describe('ResolverService', () => {
+  const resolver = createResolver();
+
+  describe('resolve', () => {
+    it('should resolve constraints to best matching versions', () => {
+      const constraints = [
+        { name: 'lodash', range: '^4.0.0' },
+        { name: 'express', range: '^5.0.0' },
+      ];
+      const available = {
+        lodash: ['3.10.0', '4.0.0', '4.17.0', '4.17.21'],
+        express: ['4.18.0', '5.0.0', '5.1.0'],
+      };
+      const resolved = resolver.resolve(constraints, available);
+      expect(resolved).toHaveLength(2);
+      expect(resolved[0]).toEqual({ name: 'lodash', version: '4.17.21', satisfies: '^4.0.0' });
+      expect(resolved[1]).toEqual({ name: 'express', version: '5.1.0', satisfies: '^5.0.0' });
+    });
+
+    it('should throw when no versions available for a name', () => {
+      expect(() =>
+        resolver.resolve([{ name: 'missing', range: '^1.0.0' }], {})
+      ).toThrow(/no versions available/);
+    });
+
+    it('should throw when no version satisfies the range', () => {
+      expect(() =>
+        resolver.resolve(
+          [{ name: 'lodash', range: '^5.0.0' }],
+          { lodash: ['4.0.0', '4.17.0'] }
+        )
+      ).toThrow(/no version satisfies/);
+    });
+
+    it('should resolve exact versions', () => {
+      const resolved = resolver.resolve(
+        [{ name: 'pkg', range: '1.0.0' }],
+        { pkg: ['1.0.0', '2.0.0'] }
+      );
+      expect(resolved[0].version).toBe('1.0.0');
+    });
+
+    it('should resolve tilde ranges', () => {
+      const resolved = resolver.resolve(
+        [{ name: 'pkg', range: '~1.2.0' }],
+        { pkg: ['1.1.0', '1.2.0', '1.2.5', '1.3.0'] }
+      );
+      expect(resolved[0].version).toBe('1.2.5');
+    });
+  });
+
+  describe('satisfies', () => {
+    it('should return true for matching version', () => {
+      expect(resolver.satisfies('4.17.21', '^4.0.0')).toBe(true);
+    });
+
+    it('should return false for non-matching version', () => {
+      expect(resolver.satisfies('3.0.0', '^4.0.0')).toBe(false);
+    });
+  });
+
+  describe('maxSatisfying', () => {
+    it('should return the highest satisfying version', () => {
+      expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0')).toBe('1.5.0');
+    });
+
+    it('should return null when no version satisfies', () => {
+      expect(resolver.maxSatisfying(['1.0.0', '1.5.0'], '^2.0.0')).toBeNull();
+    });
+  });
+
+  describe('validRange', () => {
+    it('should return true for valid ranges', () => {
+      expect(resolver.validRange('^1.0.0')).toBe(true);
+      expect(resolver.validRange('~1.0.0')).toBe(true);
+      expect(resolver.validRange('>=1.0.0')).toBe(true);
+      expect(resolver.validRange('1.0.0 - 2.0.0')).toBe(true);
+    });
+
+    it('should return false for invalid ranges', () => {
+      expect(resolver.validRange('not-a-range')).toBe(false);
+    });
+  });
+});
