+++ b/src/deps/index.ts
@@ -0,0 +1,127 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+function buildTree(name: string, registry: RegistryService): DependencyNode {
+  const manifest = registry.get(name);
+
+  if (!manifest) {
+    return { name, version: 'unknown', dependencies: [] };
+  }
+
+  const childNodes: DependencyNode[] = [];
+  for (const depName of Object.keys(manifest.dependencies)) {
+    childNodes.push(buildTree(depName, registry));
+  }
+
+  return {
+    name: manifest.name,
+    version: manifest.version,
+    dependencies: childNodes,
+  };
+}
+
+const WHITE = 0;
+const GRAY = 1;
+const BLACK = 2;
+
+function detectCycles(name: string, registry: RegistryService): string[][] | null {
+  const color = new Map<string, number>();
+  const parent = new Map<string, string | null>();
+  const cycles: string[][] = [];
+
+  function getDeps(pluginName: string): string[] {
+    const manifest = registry.get(pluginName);
+    if (!manifest) return [];
+    return Object.keys(manifest.dependencies);
+  }
+
+  function dfs(node: string): void {
+    color.set(node, GRAY);
+
+    for (const dep of getDeps(node)) {
+      const depColor = color.get(dep) ?? WHITE;
+
+      if (depColor === GRAY) {
+        // Found a cycle — reconstruct it
+        const cycle: string[] = [dep];
+        let current: string | null | undefined = node;
+        while (current !== undefined && current !== null && current !== dep) {
+          cycle.push(current);
+          current = parent.get(current);
+        }
+        cycle.push(dep);
+        cycle.reverse();
+        cycles.push(cycle);
+      } else if (depColor === WHITE) {
+        parent.set(dep, node);
+        dfs(dep);
+      }
+    }
+
+    color.set(node, BLACK);
+  }
+
+  parent.set(name, null);
+  dfs(name);
+
+  return cycles.length > 0 ? cycles : null;
+}
+
+function topologicalSort(name: string, registry: RegistryService): string[] {
+  const cycles = detectCycles(name, registry);
+  if (cycles) {
+    throw new Error(`Circular dependency detected: ${cycles[0].join(' -> ')}`);
+  }
+
+  const result: string[] = [];
+  const visited = new Set<string>();
+
+  function visit(node: string): void {
+    if (visited.has(node)) return;
+    visited.add(node);
+
+    const manifest = registry.get(node);
+    if (manifest) {
+      for (const dep of Object.keys(manifest.dependencies)) {
+        visit(dep);
+      }
+    }
+
+    result.push(node);
+  }
+
+  visit(name);
+  return result;
+}
+
+function flattenDependencies(name: string, registry: RegistryService): string[] {
+  const visited = new Set<string>();
+
+  function collect(node: string): void {
+    const manifest = registry.get(node);
+    if (!manifest) return;
+
+    for (const dep of Object.keys(manifest.dependencies)) {
+      if (!visited.has(dep)) {
+        visited.add(dep);
+        collect(dep);
+      }
+    }
+  }
+
+  collect(name);
+  return [...visited];
+}
+
+function hasCircularDependency(name: string, registry: RegistryService): boolean {
+  return detectCycles(name, registry) !== null;
+}
+
+export function createDepsService(): DepsService {
+  return {
+    buildTree,
+    detectCycles,
+    topologicalSort,
+    flattenDependencies,
+    hasCircularDependency,
+  };
+}
