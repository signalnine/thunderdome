gin and register it', async () => {\n      const marketplace = createMarketplace();\n      const manifest = makeManifest();\n      await marketplace.installPlugin(manifest);\n      const registered = marketplace.registry.get('test-plugin');\n      expect(registered).not.toBeNull();\n      expect(registered?.name).toBe('test-plugin');\n    });\n\n    it('should resolve dependencies during install', async () => {\n      const marketplace = createMarketplace();\n      // Register a dependency first\n      marketplace.registry.register(makeManifest({\n        name: 'dep-plugin',\n        version: '1.0.0',\n      }));\n      marketplace.registry.register(makeManifest({\n        name: 'dep-plugin',\n        version: '1.5.0',\n      }));\n\n      const manifest = makeManifest({\n        dependencies: { 'dep-plugin': '^1.0.0' },\n        entryPoint: '42',\n      });\n      const result = await marketplace.installPlugin(manifest);\n      expect(result.resolvedDependencies).toHaveLength(1);\n      expect(result.resolvedDependencies[0].name).toBe('dep-plugin');\n      expect(result.resolvedDependencies[0].version).toBe('1.5.0');\n    });\n\n    it('should reject plugins with circular dependencies', async () => {\n      const marketplace = createMarketplace();\n      // Create a cycle: a -> b -> a\n      marketplace.registry.register(makeManifest({\n        name: 'b',\n        version: '1.0.0',\n        dependencies: { 'a': '^1.0.0' },\n      }));\n\n      const manifest = makeManifest({\n        name: 'a',\n        version: '1.0.0',\n        dependencies: { 'b': '^1.0.0' },\n      });\n\n      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(/[Cc]ircular/);\n    });\n\n    it('should reject plugin without name', async () => {\n      const marketplace = createMarketplace();\n      const manifest = makeManifest({ name: '' });\n      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(/name/);\n    });\n\n    it('should reject plugin without version', async () => {\n      const marketplace = createMarketplace();\n      const manifest = makeManifest({ version: '' });\n      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(/version/);\n    });\n\n    it('should reject plugin without entryPoint', async () => {\n      const marketplace = createMarketplace();\n      const manifest = makeManifest({ entryPoint: '' });\n      await expect(marketplace.installPlugin(manifest)).rejects.toThrow(/entryPoint/);\n    });\n\n    it('should handle plugin code that fails', async () => {\n      const marketplace = createMarketplace();\n      const manifest = makeManifest({\n        entryPoint: 'throw new Error(\"plugin init failed\")',\n      });\n      const result = await marketplace.installPlugin(manifest);\n      expect(result.executionResult.success).toBe(false);\n      expect(result.executionResult.error).toContain('plugin init failed');\n    });\n\n    it('should execute plugin entry point in sandbox', async () => {\n      const marketplace = createMarketplace();\n      const manifest = makeManifest({\n        entryPoint: '({ status: \"initialized\", value: 100 })',\n      });\n      const result = await marketplace.installPlugin(manifest);\n      expect(result.executionResult.success).toBe(true);\n      expect(result.executionResult.output).toEqual({ status: 'initialized', value: 100 });\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"15df2f74-192b-43b7-a9e3-2fbf701ea909"}
