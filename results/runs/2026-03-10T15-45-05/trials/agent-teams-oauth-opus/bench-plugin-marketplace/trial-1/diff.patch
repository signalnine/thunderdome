ing: 5, comment: 'a' });\n      reviews.flagReview(r.id);\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n      expect(flagged[0].flagged).toBe(true);\n    });\n  });\n\n  describe('getFlaggedReviews', () => {\n    it('should return only flagged reviews', () => {\n      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: 'b' });\n      reviews.flagReview(r1.id);\n      const flagged = reviews.getFlaggedReviews();\n      expect(flagged).toHaveLength(1);\n      expect(flagged[0].id).toBe(r1.id);\n    });\n  });\n\n  describe('removeReview', () => {\n    it('should remove a review and return true', () => {\n      const r = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });\n      expect(reviews.removeReview(r.id)).toBe(true);\n      expect(reviews.getReviews('p1')).toHaveLength(0);\n    });\n\n    it('should return false for non-existent review', () => {\n      expect(reviews.removeReview(999)).toBe(false);\n    });\n  });\n\n  describe('getReviewsByUser', () => {\n    it('should return all reviews by a user', () => {\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user1', rating: 5, comment: 'a' });\n      reviews.addReview({ pluginName: 'p2', pluginVersion: '1.0.0', userId: 'user1', rating: 4, comment: 'b' });\n      reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'user2', rating: 3, comment: 'c' });\n      const result = reviews.getReviewsByUser('user1');\n      expect(result).toHaveLength(2);\n    });\n  });\n\n  describe('getReviewCount', () => {\n    it('should return count of non-flagged reviews', () => {\n      const r1 = reviews.addReview({ pluginName: 'p1', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: 'a' });\n      reviews.addReview({ 