+export interface Event {
+  id: string;
+  name: string;
+  duration: number;
+  attendees?: number;
+  prerequisites?: string[];
+  preferredRoom?: string;
+}
+
+export interface Room {
+  id: string;
+  name: string;
+  capacity: number;
+}
+
+export interface ScheduleOptions {
+  startTime: number;
+  endTime: number;
+  gap?: number;
+}
+
+export interface Assignment {
+  eventId: string;
+  roomId: string;
+  startTime: number;
+  endTime: number;
+}
+
+export interface ScheduleResult {
+  assignments: Assignment[];
+  unscheduled: string[];
+}
+
+function detectCycles(events: Event[]): void {
+  const eventIds = new Set(events.map(e => e.id));
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  const adj = new Map<string, string[]>();
+
+  for (const e of events) {
+    color.set(e.id, WHITE);
+    adj.set(e.id, []);
+  }
+
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const p of e.prerequisites) {
+        if (p === e.id) {
+          throw new Error(`Cycle detected: event "${e.id}" lists itself as prerequisite`);
+        }
+        if (eventIds.has(p)) {
+          adj.get(p)!.push(e.id);
+        }
+      }
+    }
+  }
+
+  function dfs(node: string): void {
+    color.set(node, GRAY);
+    for (const neighbor of adj.get(node) || []) {
+      const c = color.get(neighbor);
+      if (c === GRAY) throw new Error("Cycle detected in prerequisites");
+      if (c === WHITE) dfs(neighbor);
+    }
+    color.set(node, BLACK);
+  }
+
+  for (const e of events) {
+    if (color.get(e.id) === WHITE) dfs(e.id);
+  }
+}
+
+type EventComparator = (a: Event, b: Event) => number;
+
+function topologicalSort(
+  events: Event[],
+  eventMap: Map<string, Event>,
+  compare: EventComparator,
+): string[] {
+  const eventIds = new Set(events.map(e => e.id));
+  const inDegree = new Map<string, number>();
+  const adj = new Map<string, string[]>();
+
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    adj.set(e.id, []);
+  }
+
+  for (const e of events) {
+    if (e.prerequisites) {
+      for (const p of e.prerequisites) {
+        if (eventIds.has(p)) {
+          adj.get(p)!.push(e.id);
+          inDegree.set(e.id, inDegree.get(e.id)! + 1);
+        }
+      }
+    }
+  }
+
+  const available: Event[] = [];
+  for (const e of events) {
+    if (inDegree.get(e.id)! === 0) available.push(e);
+  }
+  available.sort(compare);
+
+  const result: string[] = [];
+  while (available.length > 0) {
+    const event = available.shift()!;
+    result.push(event.id);
+    for (const neighbor of adj.get(event.id)!) {
+      const newDeg = inDegree.get(neighbor)! - 1;
+      inDegree.set(neighbor, newDeg);
+      if (newDeg === 0) {
+        const ne = eventMap.get(neighbor)!;
+        let lo = 0,
+          hi = available.length;
+        while (lo < hi) {
+          const mid = (lo + hi) >> 1;
+          if (compare(ne, available[mid]) <= 0) hi = mid;
+          else lo = mid + 1;
+        }
+        available.splice(lo, 0, ne);
+      }
+    }
+  }
+
+  return result;
+}
+
+function findEarliestSlot(
+  timeline: [number, number][],
+  earliestStart: number,
+  duration: number,
+  gap: number,
+  windowEnd: number,
+): number | null {
+  let candidate = earliestStart;
+
+  for (const [slotStart, slotEnd] of timeline) {
+    if (candidate + duration + gap <= slotStart) {
+      break;
+    }
+    candidate = Math.max(candidate, slotEnd + gap);
+  }
+
+  if (candidate + duration <= windowEnd) {
+    return candidate;
+  }
+  return null;
+}
+
+function insertSorted(
+  timeline: [number, number][],
+  interval: [number, number],
+): void {
+  let lo = 0,
+    hi = timeline.length;
+  while (lo < hi) {
+    const mid = (lo + hi) >> 1;
+    if (timeline[mid][0] < interval[0]) lo = mid + 1;
+    else hi = mid;
+  }
+  timeline.splice(lo, 0, interval);
+}
+
+function greedySchedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions,
+  order: string[],
+  eventMap: Map<string, Event>,
+  validRoomsMap: Map<string, Room[]>,
+  gap: number,
+  honorPreferences: boolean,
+): ScheduleResult {
+  const { startTime, endTime } = options;
+
+  const roomTimelines = new Map<string, [number, number][]>();
+  for (const room of rooms) {
+    roomTimelines.set(room.id, []);
+  }
+
+  const assignments = new Map<string, Assignment>();
+
+  for (const eventId of order) {
+    const event = eventMap.get(eventId)!;
+
+    let earliestStart = startTime;
+    let prereqUnsatisfied = false;
+
+    if (event.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        if (eventMap.has(prereqId)) {
+          const prereqAssignment = assignments.get(prereqId);
+          if (!prereqAssignment) {
+            prereqUnsatisfied = true;
+            break;
+          }
+          earliestStart = Math.max(
+            earliestStart,
+            prereqAssignment.endTime + gap,
+          );
+        }
+      }
+    }
+
+    if (prereqUnsatisfied) continue;
+    if (earliestStart + event.duration > endTime) continue;
+
+    const validRooms = validRoomsMap.get(eventId)!;
+    if (validRooms.length === 0) continue;
+
+    let bestAssignment: Assignment | null = null;
+    let bestCapacity = Infinity;
+    let usedPreferred = false;
+
+    if (honorPreferences && event.preferredRoom) {
+      const prefRoom = validRooms.find((r) => r.id === event.preferredRoom);
+      if (prefRoom) {
+        const timeline = roomTimelines.get(prefRoom.id)!;
+        const slot = findEarliestSlot(
+          timeline,
+          earliestStart,
+          event.duration,
+          gap,
+          endTime,
+        );
+        if (slot !== null) {
+          bestAssignment = {
+            eventId,
+            roomId: prefRoom.id,
+            startTime: slot,
+            endTime: slot + event.duration,
+          };
+          bestCapacity = prefRoom.capacity;
+          usedPreferred = true;
+        }
+      }
+    }
+
+    if (!usedPreferred) {
+      for (const room of validRooms) {
+        const timeline = roomTimelines.get(room.id)!;
+        const slot = findEarliestSlot(
+          timeline,
+          earliestStart,
+          event.duration,
+          gap,
+          endTime,
+        );
+        if (slot !== null) {
+          if (
+            !bestAssignment ||
+            room.capacity < bestCapacity ||
+            (room.capacity === bestCapacity &&
+              slot < bestAssignment.startTime)
+          ) {
+            bestAssignment = {
+              eventId,
+              roomId: room.id,
+              startTime: slot,
+              endTime: slot + event.duration,
+            };
+            bestCapacity = room.capacity;
+          }
+        }
+      }
+    }
+
+    if (bestAssignment) {
+      assignments.set(eventId, bestAssignment);
+      insertSorted(roomTimelines.get(bestAssignment.roomId)!, [
+        bestAssignment.startTime,
+        bestAssignment.endTime,
+      ]);
+    }
+  }
+
+  const result: ScheduleResult = { assignments: [], unscheduled: [] };
+  for (const event of events) {
+    const a = assignments.get(event.id);
+    if (a) result.assignments.push(a);
+    else result.unscheduled.push(event.id);
+  }
+  return result;
+}
+
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions,
+): ScheduleResult {
+  if (events.length === 0) return { assignments: [], unscheduled: [] };
+  if (rooms.length === 0)
+    return { assignments: [], unscheduled: events.map((e) => e.id) };
+
+  const gap = options.gap ?? 15;
+
+  detectCycles(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const event of events) eventMap.set(event.id, event);
+
+  const validRoomsMap = new Map<string, Room[]>();
+  for (const event of events) {
+    const attendees = event.attendees ?? 1;
+    validRoomsMap.set(
+      event.id,
+      rooms.filter((r) => r.capacity >= attendees),
+    );
+  }
+
+  const strategies: EventComparator[] = [
+    // Most constrained first (fewest valid rooms), then shortest duration
+    (a, b) => {
+      const ar = validRoomsMap.get(a.id)!.length;
+      const br = validRoomsMap.get(b.id)!.length;
+      if (ar !== br) return ar - br;
+      return a.duration - b.duration;
+    },
+    // Most constrained first, then longest duration
+    (a, b) => {
+      const ar = validRoomsMap.get(a.id)!.length;
+      const br = validRoomsMap.get(b.id)!.length;
+      if (ar !== br) return ar - br;
+      return b.duration - a.duration;
+    },
+    // Shortest duration first, then most constrained
+    (a, b) => {
+      if (a.duration !== b.duration) return a.duration - b.duration;
+      const ar = validRoomsMap.get(a.id)!.length;
+      const br = validRoomsMap.get(b.id)!.length;
+      return ar - br;
+    },
+    // Most attendees first (largest events first to fill big rooms)
+    (a, b) => {
+      const aa = a.attendees ?? 1;
+      const ba = b.attendees ?? 1;
+      if (aa !== ba) return ba - aa;
+      const ar = validRoomsMap.get(a.id)!.length;
+      const br = validRoomsMap.get(b.id)!.length;
+      return ar - br;
+    },
+  ];
+
+  let bestResult: ScheduleResult | null = null;
+
+  for (const strategy of strategies) {
+    const order = topologicalSort(events, eventMap, strategy);
+
+    for (const honorPref of [true, false]) {
+      const result = greedySchedule(
+        events,
+        rooms,
+        options,
+        order,
+        eventMap,
+        validRoomsMap,
+        gap,
+        honorPref,
+      );
+      if (
+        !bestResult ||
+        result.assignments.length > bestResult.assignments.length
+      ) {
+        bestResult = result;
+      }
+      if (bestResult.unscheduled.length === 0) return bestResult;
+    }
+  }
+
+  return bestResult!;
+}
