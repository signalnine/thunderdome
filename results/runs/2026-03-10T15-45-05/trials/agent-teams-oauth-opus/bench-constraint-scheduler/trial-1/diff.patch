  const room = roomMap.get(a.roomId)!;\n\n    // Room capacity\n    expect((event.attendees ?? 1) <= room.capacity).toBe(true);\n\n    // Time window\n    expect(a.startTime).toBeGreaterThanOrEqual(options.startTime);\n    expect(a.endTime).toBeLessThanOrEqual(options.endTime);\n\n    // Duration\n    expect(a.endTime - a.startTime).toBe(event.duration);\n\n    // Prerequisites\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (eventMap.has(prereqId)) {\n          const prereqAssign = assignMap.get(prereqId);\n          expect(prereqAssign).toBeDefined();\n          expect(prereqAssign!.endTime + gap).toBeLessThanOrEqual(\n            a.startTime,\n          );\n        }\n      }\n    }\n  }\n\n  // Room gaps: no overlapping events in same room\n  const roomEvents = new Map<string, typeof result.assignments>();\n  for (const a of result.assignments) {\n    if (!roomEvents.has(a.roomId)) roomEvents.set(a.roomId, []);\n    roomEvents.get(a.roomId)!.push(a);\n  }\n  for (const [_roomId, assigns] of roomEvents) {\n    assigns.sort((a, b) => a.startTime - b.startTime);\n    for (let i = 0; i < assigns.length - 1; i++) {\n      expect(assigns[i].endTime + gap).toBeLessThanOrEqual(\n        assigns[i + 1].startTime,\n      );\n    }\n  }\n}\n\ndescribe(\"schedule\", () => {\n  it(\"schedules a single event\", () => {\n    const events: Event[] = [\n      { id: \"e1\", name: \"Meeting\", duration: 60 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n    expect(result.unscheduled).toHaveLength(0);\n    expect(result.assignments[0].eventId).toBe(\"e1\");\n    assertValid(result, events, rooms, defaultOptions);\n  });\n\n  it(\"respects room capacity\", () => {\n    const events: Event[] = [\n      { id: \"e1\", name: \"Big Event\", duration: 60, attendees: 50 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(1);\n    expect(result.assignments[0].roomId).toBe(\"r3\"); // only r3 fits 50\n    assertValid(result, events, rooms, defaultOptions);\n  });\n\n  it(\"marks event as unscheduled when no room fits\", () => {\n    const events: Event[] = [\n      { id: \"e1\", name: \"Huge Event\", duration: 60, attendees: 200 },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignments).toHaveLength(0);\n    expect(result.unscheduled).toEqual([\"e1\"]);\n  });\n\n  it(\"respects time window\", () => {\n    const opts: ScheduleOptions = { startTime: 540, endTime: 600, gap: 0 };\n    const events: Event[] = [\n      { id: \"e1\", name: \"Long Event\", duration: 120 },\n    ];\n    const result = schedule(events, rooms, opts);\n    expect(result.unscheduled).toEqual([\"e1\"]);\n  });\n\n  it(\"respects room gaps\", () => {\n    const opts: ScheduleOptions = { startTime: 0, endTime: 200, gap: 30 };\n    const singleRoom: Room[] = [{ id: \"r1\", name: \"Room\", capacity: 100 }];\n    const events: Event[] = [\n      { id: \"e1\", name: \"First\", duration: 60 },\n      { id: \"e2\", name: \"Second\", duration: 60 },\n    ];\n    const result = schedule(events, singleRoom, opts);\n    expect(result.assignments).toHaveLength(2);\n    assertValid(result, events, singleRoom, opts);\n    const a1 = result.assignments.find((a) => a.eventId === \"e1\")!;\n    const a2 = result.assignments.find((a) => a.eventId === \"e2\")!;\n    if (a1.roomId === a2.roomId) {\n      const [first, second] =\n        a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n      expect(second.startTime - first.endTime).toBeGreaterThanOrEqual(30);\n    }\n  });\n\n  it(\"handles prerequisites\", () => {\n    const events: Event[] = [\n      { id: \"e1\", name: \"Setup\", duration: 60 },\n      { id: \"e2\", name: \"Main\", duration: 60, prerequisites: [\"e1\"] },\n    ];\n    const result = schedule(events, rooms, defaultOptions);\n    expect(result.assignment