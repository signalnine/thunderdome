+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import fs from "node:fs";
+import path from "node:path";
+import os from "node:os";
+import { TimeTracker } from "./tracker.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "tracker-test-"));
+  return path.join(dir, "data.json");
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    try {
+      fs.rmSync(path.dirname(filePath), { recursive: true, force: true });
+    } catch {
+      // ignore
+    }
+  });
+
+  it("should start and stop a timer", () => {
+    const tracker = new TimeTracker(filePath);
+    const entry = tracker.start("coding");
+    expect(entry.task).toBe("coding");
+    expect(entry.stop).toBeNull();
+
+    const stopped = tracker.stop();
+    expect(stopped.task).toBe("coding");
+    expect(stopped.stop).not.toBeNull();
+  });
+
+  it("should throw on empty task name", () => {
+    const tracker = new TimeTracker(filePath);
+    expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+    expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+  });
+
+  it("should throw when stopping with no running timer", () => {
+    const tracker = new TimeTracker(filePath);
+    expect(() => tracker.stop()).toThrow("No timer is currently running");
+  });
+
+  it("should auto-stop previous timer when starting new one", () => {
+    const tracker = new TimeTracker(filePath);
+    tracker.start("task1");
+    tracker.start("task2");
+
+    const entries = tracker.getEntries();
+    expect(entries).toHaveLength(2);
+    expect(entries[0].task).toBe("task1");
+    expect(entries[0].stop).not.toBeNull();
+    expect(entries[1].task).toBe("task2");
+    expect(entries[1].stop).toBeNull();
+  });
+
+  it("should persist data to disk", () => {
+    const tracker1 = new TimeTracker(filePath);
+    tracker1.start("persisted-task");
+    tracker1.stop();
+
+    const tracker2 = new TimeTracker(filePath);
+    const entries = tracker2.getEntries();
+    expect(entries).toHaveLength(1);
+    expect(entries[0].task).toBe("persisted-task");
+  });
+
+  it("should create parent directories automatically", () => {
+    const nested = path.join(os.tmpdir(), "tracker-test-nested", "a", "b", "data.json");
+    try {
+      const tracker = new TimeTracker(nested);
+      tracker.start("nested-task");
+      tracker.stop();
+      expect(fs.existsSync(nested)).toBe(true);
+    } finally {
+      fs.rmSync(path.join(os.tmpdir(), "tracker-test-nested"), { recursive: true, force: true });
+    }
+  });
+
+  it("should filter entries by date range", () => {
+    const tracker = new TimeTracker(filePath);
+
+    // Manually write entries with known dates
+    const data = {
+      entries: [
+        { task: "old", start: "2024-01-01T00:00:00.000Z", stop: "2024-01-01T01:00:00.000Z" },
+        { task: "mid", start: "2024-06-15T00:00:00.000Z", stop: "2024-06-15T01:00:00.000Z" },
+        { task: "new", start: "2025-01-01T00:00:00.000Z", stop: "2025-01-01T01:00:00.000Z" },
+      ],
+    };
+    fs.writeFileSync(filePath, JSON.stringify(data), "utf-8");
+
+    const tracker2 = new TimeTracker(filePath);
+
+    const filtered = tracker2.getEntries(
+      new Date("2024-03-01T00:00:00.000Z"),
+      new Date("2024-12-31T23:59:59.999Z")
+    );
+    expect(filtered).toHaveLength(1);
+    expect(filtered[0].task).toBe("mid");
+  });
+
+  it("should summarize time per task", () => {
+    const data = {
+      entries: [
+        { task: "coding", start: "2024-01-01T00:00:00.000Z", stop: "2024-01-01T01:00:00.000Z" },
+        { task: "coding", start: "2024-01-01T02:00:00.000Z", stop: "2024-01-01T03:00:00.000Z" },
+        { task: "review", start: "2024-01-01T03:00:00.000Z", stop: "2024-01-01T03:30:00.000Z" },
+      ],
+    };
+    fs.writeFileSync(filePath, JSON.stringify(data), "utf-8");
+
+    const tracker = new TimeTracker(filePath);
+    const summary = tracker.summary();
+
+    expect(summary["coding"]).toBe(2 * 60 * 60 * 1000); // 2 hours
+    expect(summary["review"]).toBe(30 * 60 * 1000); // 30 minutes
+  });
+
+  it("should use current time for running tasks in summary", () => {
+    const tracker = new TimeTracker(filePath);
+    tracker.start("running-task");
+
+    const summary = tracker.summary();
+    expect(summary["running-task"]).toBeGreaterThan(0);
+  });
+
+  it("should support unicode and emoji task names", () => {
+    const tracker = new TimeTracker(filePath);
+
+    tracker.start("日本語タスク");
+    tracker.stop();
+
+    tracker.start("🚀 deployment");
+    tracker.stop();
+
+    tracker.start("café ☕ break");
+    tracker.stop();
+
+    const entries = tracker.getEntries();
+    expect(entries).toHaveLength(3);
+    expect(entries[0].task).toBe("日本語タスク");
+    expect(entries[1].task).toBe("🚀 deployment");
+    expect(entries[2].task).toBe("café ☕ break");
+
+    // Verify persistence with unicode
+    const tracker2 = new TimeTracker(filePath);
+    const entries2 = tracker2.getEntries();
+    expect(entries2[0].task).toBe("日本語タスク");
+    expect(entries2[1].task).toBe("🚀 deployment");
+  });
+
+  it("should report running status correctly", () => {
+    const tracker = new TimeTracker(filePath);
+    expect(tracker.isRunning()).toBe(false);
+    expect(tracker.currentTask()).toBeNull();
+
+    tracker.start("active");
+    expect(tracker.isRunning()).toBe(true);
+    expect(tracker.currentTask()).toBe("active");
+
+    tracker.stop();
+    expect(tracker.isRunning()).toBe(false);
+    expect(tracker.currentTask()).toBeNull();
+  });
+});
