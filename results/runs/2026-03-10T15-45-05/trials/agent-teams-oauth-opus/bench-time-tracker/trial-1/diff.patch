@@ -0,0 +1,114 @@
+import fs from "node:fs";
+import path from "node:path";
+import type { TimeEntry, TrackerData, TimeSummary } from "./types.js";
+
+export class TimeTracker {
+  private filePath: string;
+  private data: TrackerData;
+
+  constructor(filePath: string) {
+    this.filePath = path.resolve(filePath);
+    this.data = this.load();
+  }
+
+  private load(): TrackerData {
+    try {
+      const raw = fs.readFileSync(this.filePath, "utf-8");
+      const parsed = JSON.parse(raw) as TrackerData;
+      if (!Array.isArray(parsed.entries)) {
+        return { entries: [] };
+      }
+      return parsed;
+    } catch {
+      return { entries: [] };
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    fs.writeFileSync(this.filePath, JSON.stringify(this.data, null, 2), "utf-8");
+  }
+
+  private getRunningEntry(): TimeEntry | undefined {
+    return this.data.entries.find((e) => e.stop === null);
+  }
+
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Auto-stop any running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    };
+
+    this.data.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    if (!from && !to) {
+      return [...this.data.entries];
+    }
+
+    return this.data.entries.filter((entry) => {
+      const startTime = new Date(entry.start).getTime();
+      if (from && startTime < from.getTime()) {
+        return false;
+      }
+      if (to && startTime > to.getTime()) {
+        return false;
+      }
+      return true;
+    });
+  }
+
+  isRunning(): boolean {
+    return this.getRunningEntry() !== undefined;
+  }
+
+  currentTask(): string | null {
+    const running = this.getRunningEntry();
+    return running ? running.task : null;
+  }
+
+  summary(from?: Date, to?: Date): TimeSummary {
+    const entries = this.getEntries(from, to);
+    const result: TimeSummary = {};
+    const now = Date.now();
+
+    for (const entry of entries) {
+      const startMs = new Date(entry.start).getTime();
+      const stopMs = entry.stop ? new Date(entry.stop).getTime() : now;
+      const duration = stopMs - startMs;
+
+      if (result[entry.task] === undefined) {
+        result[entry.task] = 0;
+      }
+      result[entry.task] += duration;
+    }
+
+    return result;
+  }
+}
