+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 8: Concurrency Control', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should limit concurrent processing', () => {
+    tq.setConcurrency('default', 2);
+
+    tq.addTask('a');
+    tq.addTask('b');
+    tq.addTask('c');
+
+    const t1 = tq.getNextTask();
+    const t2 = tq.getNextTask();
+
+    expect(t1).not.toBeNull();
+    expect(t2).not.toBeNull();
+
+    // Third should be null (at limit)
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should free slot on complete', () => {
+    tq.setConcurrency('default', 1);
+    tq.addTask('a');
+    tq.addTask('b');
+
+    const t1 = tq.getNextTask()!;
+    expect(tq.getNextTask()).toBeNull();
+
+    tq.completeTask(t1.id);
+    expect(tq.getNextTask()).not.toBeNull();
+  });
+
+  it('should free slot on fail', () => {
+    tq.setConcurrency('default', 1);
+    tq.addTask('a', { maxRetries: 1, baseDelay: 0 });
+    tq.addTask('b');
+
+    const t1 = tq.getNextTask()!;
+    expect(tq.getNextTask()).toBeNull();
+
+    tq.failTask(t1.id, 'err');
+    // t1 went to DLQ, slot freed, can get b
+    expect(tq.getNextTask()?.payload).toBe('b');
+  });
+
+  it('should default to no limit (unlimited)', () => {
+    const info = tq.getConcurrency('default');
+    expect(info.limit).toBe(0);
+  });
+
+  it('should query concurrency info', () => {
+    tq.setConcurrency('default', 5);
+    tq.addTask('a');
+    tq.addTask('b');
+    tq.getNextTask();
+
+    const info = tq.getConcurrency('default');
+    expect(info.limit).toBe(5);
+    expect(info.active).toBe(1);
+  });
+
+  it('should work correctly with priority', () => {
+    tq.setConcurrency('default', 1);
+    tq.addTask('low', { priority: 10 });
+    tq.addTask('high', { priority: 1 });
+
+    const first = tq.getNextTask()!;
+    expect(first.payload).toBe('high');
+    expect(tq.getNextTask()).toBeNull(); // at limit
+
+    tq.completeTask(first.id);
+    const second = tq.getNextTask()!;
+    expect(second.payload).toBe('low');
+  });
+});
