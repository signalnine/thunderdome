+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 6: Dead Letter Queue', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should move tasks to DLQ after exhausting retries', () => {
+    const task = tq.addTask('data', { maxRetries: 1, baseDelay: 0 });
+    tq.getNextTask();
+    tq.failTask(task.id, 'final');
+
+    const dlq = tq.getDeadLetterTasks();
+    expect(dlq).toHaveLength(1);
+    expect(dlq[0].id).toBe(task.id);
+    expect(dlq[0].status).toBe('failed');
+    expect(dlq[0].error).toBe('final');
+  });
+
+  it('should retain error info in DLQ', () => {
+    const task = tq.addTask('data', { maxRetries: 1, baseDelay: 0 });
+    tq.getNextTask();
+    tq.failTask(task.id, 'something went wrong');
+
+    const dlq = tq.getDeadLetterTasks();
+    expect(dlq[0].error).toBe('something went wrong');
+    expect(dlq[0].retryCount).toBe(1);
+  });
+
+  it('should retry DLQ tasks back to original queue', () => {
+    const task = tq.addTask('data', {
+      queueName: 'emails',
+      maxRetries: 1,
+      baseDelay: 0,
+    });
+    tq.getNextTask('emails');
+    tq.failTask(task.id, 'err');
+
+    expect(tq.getDeadLetterTasks('emails')).toHaveLength(1);
+
+    const retried = tq.retryDeadLetterTask(task.id);
+    expect(retried.status).toBe('pending');
+    expect(retried.retryCount).toBe(0);
+    expect(retried.queueName).toBe('emails');
+
+    expect(tq.getDeadLetterTasks('emails')).toHaveLength(0);
+    expect(tq.getQueueSize('emails')).toBe(1);
+  });
+
+  it('should clear DLQ for a queue', () => {
+    const t1 = tq.addTask('a', { maxRetries: 1, baseDelay: 0 });
+    const t2 = tq.addTask('b', { maxRetries: 1, baseDelay: 0 });
+
+    tq.getNextTask();
+    tq.failTask(t1.id, 'err');
+    tq.getNextTask();
+    tq.failTask(t2.id, 'err');
+
+    expect(tq.getDeadLetterTasks()).toHaveLength(2);
+    tq.clearDeadLetterQueue();
+    expect(tq.getDeadLetterTasks()).toHaveLength(0);
+  });
+
+  it('should have separate DLQ per named queue', () => {
+    const t1 = tq.addTask('a', { queueName: 'q1', maxRetries: 1, baseDelay: 0 });
+    const t2 = tq.addTask('b', { queueName: 'q2', maxRetries: 1, baseDelay: 0 });
+
+    tq.getNextTask('q1');
+    tq.failTask(t1.id, 'err');
+
+    tq.getNextTask('q2');
+    tq.failTask(t2.id, 'err');
+
+    expect(tq.getDeadLetterTasks('q1')).toHaveLength(1);
+    expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);
+
+    tq.clearDeadLetterQueue('q1');
+    expect(tq.getDeadLetterTasks('q1')).toHaveLength(0);
+    expect(tq.getDeadLetterTasks('q2')).toHaveLength(1);
+  });
+});
