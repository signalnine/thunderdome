@@ -0,0 +1,80 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 12: Graceful Shutdown', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should reject new tasks after shutdown', async () => {
+    await tq.shutdown();
+    expect(() => tq.addTask('data')).toThrow(/shutting down/i);
+  });
+
+  it('should return immediately if no processing tasks', async () => {
+    tq.addTask('pending-task');
+    const result = await tq.shutdown();
+    expect(result.completed).toBe(0);
+    expect(result.forceCancelled).toBe(0);
+    expect(result.duration).toBeLessThan(1000);
+  });
+
+  it('should wait for processing tasks to complete', async () => {
+    const task = tq.addTask('data');
+    tq.getNextTask();
+
+    // Complete the task after a delay
+    setTimeout(() => {
+      tq.completeTask(task.id);
+    }, 50);
+
+    const result = await tq.shutdown({ timeout: 5000 });
+    expect(result.completed).toBe(1);
+    expect(result.forceCancelled).toBe(0);
+  });
+
+  it('should force cancel on timeout', async () => {
+    const task = tq.addTask('data');
+    tq.getNextTask();
+
+    // Don't complete the task
+    const result = await tq.shutdown({ timeout: 50 });
+    expect(result.forceCancelled).toBe(1);
+    expect(tq.getTask(task.id)?.status).toBe('cancelled');
+  });
+
+  it('should run shutdown callbacks', async () => {
+    let callbackRan = false;
+    tq.onShutdown(() => {
+      callbackRan = true;
+    });
+
+    await tq.shutdown();
+    expect(callbackRan).toBe(true);
+  });
+
+  it('should return shutdown summary', async () => {
+    const t1 = tq.addTask('a');
+    tq.addTask('b');
+    tq.getNextTask();
+    tq.getNextTask();
+
+    // Complete one, leave one
+    tq.completeTask(t1.id);
+
+    const result = await tq.shutdown({ timeout: 50 });
+    expect(result.completed + result.forceCancelled).toBe(1); // t2 is the only one still processing
+    expect(typeof result.duration).toBe('number');
+  });
+
+  it('should be safe to call shutdown multiple times', async () => {
+    const r1 = tq.shutdown();
+    const r2 = tq.shutdown();
+
+    const [result1, result2] = await Promise.all([r1, r2]);
+    expect(result1).toBeDefined();
+    expect(result2).toBeDefined();
+  });
+});
