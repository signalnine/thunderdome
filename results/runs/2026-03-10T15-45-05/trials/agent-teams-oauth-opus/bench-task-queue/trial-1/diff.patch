+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 7: Task Dependencies', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should block tasks until dependencies complete', () => {
+    const dep = tq.addTask('dependency');
+    const task = tq.addTask('dependent', { dependencies: [dep.id] });
+
+    // dep is available, dependent is blocked
+    const next = tq.getNextTask();
+    expect(next?.id).toBe(dep.id);
+
+    // dependent still blocked (dep is processing, not completed)
+    expect(tq.getNextTask()).toBeNull();
+
+    // Complete the dependency
+    tq.completeTask(dep.id);
+
+    // Now dependent is available
+    const nextTask = tq.getNextTask();
+    expect(nextTask?.id).toBe(task.id);
+  });
+
+  it('should support multiple dependencies', () => {
+    const dep1 = tq.addTask('dep1');
+    const dep2 = tq.addTask('dep2');
+    const task = tq.addTask('dependent', { dependencies: [dep1.id, dep2.id] });
+
+    const d1 = tq.getNextTask()!;
+    const d2 = tq.getNextTask()!;
+    expect(tq.getNextTask()).toBeNull();
+
+    tq.completeTask(d1.id);
+    expect(tq.getNextTask()).toBeNull(); // dep2 still processing
+
+    tq.completeTask(d2.id);
+    const ready = tq.getNextTask();
+    expect(ready?.id).toBe(task.id);
+  });
+
+  it('should throw when depending on non-existent task', () => {
+    expect(() => {
+      tq.addTask('data', { dependencies: ['nonexistent-id'] });
+    }).toThrow();
+  });
+
+  it('should not auto-fail dependents when dependency fails', () => {
+    const dep = tq.addTask('dep', { maxRetries: 1, baseDelay: 0 });
+    const task = tq.addTask('dependent', { dependencies: [dep.id] });
+
+    tq.getNextTask();
+    tq.failTask(dep.id, 'err');
+
+    // dep is now failed, dependent is still pending (not auto-failed)
+    const updated = tq.getTask(task.id)!;
+    expect(updated.status).toBe('pending');
+  });
+
+  it('should query dependency status', () => {
+    const dep1 = tq.addTask('dep1');
+    const dep2 = tq.addTask('dep2');
+    const task = tq.addTask('dependent', { dependencies: [dep1.id, dep2.id] });
+
+    const deps = tq.getTaskDependencies(task.id);
+    expect(deps).toHaveLength(2);
+    expect(deps[0]).toEqual({ taskId: dep1.id, status: 'pending' });
+    expect(deps[1]).toEqual({ taskId: dep2.id, status: 'pending' });
+  });
+
+  it('should work with priorities and dependencies', () => {
+    const dep = tq.addTask('dep');
+    const highPri = tq.addTask('high', { priority: 1, dependencies: [dep.id] });
+    tq.addTask('low', { priority: 10 });
+
+    // lowPri is returned first because highPri is blocked
+    const next = tq.getNextTask();
+    expect(next?.payload).toBe('dep');
+
+    const next2 = tq.getNextTask();
+    expect(next2?.payload).toBe('low');
+
+    tq.completeTask(next!.id);
+    const next3 = tq.getNextTask();
+    expect(next3?.id).toBe(highPri.id);
+  });
+});
