     expect(updates).toHaveLength(2);\n      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n      expect(updates[1]).toEqual({ progress: 75, message: 'three quarters' });\n    });\n\n    it('should support unsubscribe', () => {\n      const task = tq.addTask('data');\n      tq.getNextTask();\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.updateProgress(task.id, 10);\n      unsub();\n      tq.updateProgress(task.id, 50);\n\n      expect(updates).toEqual([10]);\n    });\n\n    it('should throw when updating progress on non-processing task', () => {\n      const task = tq.addTask('data');\n      expect(() => tq.updateProgress(task.id, 50)).toThrow();\n    });\n  });\n\n  describe('Cancellation', () => {\n    it('should cancel pending tasks', () => {\n      const task = tq.addTask('data');\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n      expect(tq.getQueueSize()).toBe(0);\n    });\n\n    it('should cancel processing tasks', () => {\n      const task = tq.addTask('data');\n      tq.getNextTask();\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should not allow cancelling completed tasks', () => {\n      const task = tq.addTask('data');\n      tq.getNextTask();\n      tq.completeTask(task.id);\n\n      expect(() => tq.cancelTask(task.id)).toThrow();\n    });\n\n    it('should remove cancelled pending tasks from queue', () => {\n      tq.addTask('a');\n      const b = tq.addTask('b');\n      tq.addTask('c');\n\n      tq.cancelTask(b.id);\n\n      expect(tq.getQueueSize()).toBe(2);\n      expect(tq.getNextTask()?.payload).toBe('a');\n      expect(tq.getNextTask()?.payload).toBe('c');\n    });\n\n    it('cancelled tasks should never be retried', () => {\n      const task = tq.addTask('data', { maxRetries: 3 });\n      tq.getNextTask();\n      tq.cancelTask(task.id);\n\n      // Should not be in pending queue\n      expect(tq.getQueueSize()).toBe(0);\n      expect(tq.getTask(task.id)?.status).toBe('cancelled');\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"d8818bb8-22d1-4abe-9626-e26b77382874"}
