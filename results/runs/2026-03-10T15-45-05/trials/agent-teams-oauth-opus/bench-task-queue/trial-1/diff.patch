+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 2: Named Queues', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should support named queues', () => {
+    tq.addTask('email', { queueName: 'emails' });
+    tq.addTask('sms', { queueName: 'sms' });
+
+    expect(tq.getNextTask('emails')?.payload).toBe('email');
+    expect(tq.getNextTask('sms')?.payload).toBe('sms');
+  });
+
+  it('should use default queue when no name specified', () => {
+    tq.addTask('default-task');
+    expect(tq.getNextTask()?.payload).toBe('default-task');
+  });
+
+  it('should keep queues independent', () => {
+    tq.addTask('a', { queueName: 'q1' });
+    tq.addTask('b', { queueName: 'q2' });
+
+    expect(tq.getNextTask('q1')?.payload).toBe('a');
+    expect(tq.getNextTask('q1')).toBeNull();
+
+    expect(tq.getNextTask('q2')?.payload).toBe('b');
+    expect(tq.getNextTask('q2')).toBeNull();
+  });
+
+  it('should list queue names', () => {
+    tq.addTask('a', { queueName: 'emails' });
+    tq.addTask('b', { queueName: 'notifications' });
+    tq.addTask('c');
+
+    const names = tq.getQueueNames();
+    expect(names).toContain('emails');
+    expect(names).toContain('notifications');
+    expect(names).toContain('default');
+  });
+
+  it('should track size per queue', () => {
+    tq.addTask('a', { queueName: 'q1' });
+    tq.addTask('b', { queueName: 'q1' });
+    tq.addTask('c', { queueName: 'q2' });
+
+    expect(tq.getQueueSize('q1')).toBe(2);
+    expect(tq.getQueueSize('q2')).toBe(1);
+    expect(tq.getQueueSize()).toBe(0);
+  });
+});
