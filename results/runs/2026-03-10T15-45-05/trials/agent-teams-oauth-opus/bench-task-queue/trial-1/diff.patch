+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 10: Recurring Tasks', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should create recurring tasks on tick', () => {
+    tq.addRecurringTask('*/5 * * * *', { type: 'cleanup' });
+
+    // Tick at a time divisible by 5 minutes
+    tq.tick(new Date('2024-01-01T00:05:00'));
+
+    expect(tq.getQueueSize()).toBe(1);
+    const task = tq.getNextTask()!;
+    expect(task.payload).toEqual({ type: 'cleanup' });
+  });
+
+  it('should not create tasks when cron does not match', () => {
+    tq.addRecurringTask('0 0 * * *', { type: 'daily' });
+
+    tq.tick(new Date('2024-01-01T12:30:00'));
+    expect(tq.getQueueSize()).toBe(0);
+  });
+
+  it('should support every hour', () => {
+    tq.addRecurringTask('0 * * * *', { type: 'hourly' });
+
+    tq.tick(new Date('2024-01-01T03:00:00'));
+    expect(tq.getQueueSize()).toBe(1);
+
+    tq.tick(new Date('2024-01-01T03:30:00'));
+    expect(tq.getQueueSize()).toBe(1); // No new task
+  });
+
+  it('should support every day at midnight', () => {
+    tq.addRecurringTask('0 0 * * *', { type: 'daily' });
+
+    tq.tick(new Date('2024-01-01T00:00:00'));
+    expect(tq.getQueueSize()).toBe(1);
+  });
+
+  it('should remove recurring task schedules', () => {
+    const id = tq.addRecurringTask('*/5 * * * *', { type: 'cleanup' });
+    tq.removeRecurringTask(id);
+
+    tq.tick(new Date('2024-01-01T00:05:00'));
+    expect(tq.getQueueSize()).toBe(0);
+  });
+
+  it('should list recurring tasks', () => {
+    tq.addRecurringTask('*/5 * * * *', { type: 'cleanup' });
+    tq.addRecurringTask('0 * * * *', { type: 'hourly' });
+
+    const schedules = tq.getRecurringTasks();
+    expect(schedules).toHaveLength(2);
+    expect(schedules[0].cron).toBe('*/5 * * * *');
+    expect(schedules[1].cron).toBe('0 * * * *');
+  });
+
+  it('should not duplicate tasks for same minute', () => {
+    tq.addRecurringTask('*/5 * * * *', { type: 'cleanup' });
+
+    const time = new Date('2024-01-01T00:05:00');
+    tq.tick(time);
+    tq.tick(time);
+
+    expect(tq.getQueueSize()).toBe(1);
+  });
+
+  it('should use specified queue name', () => {
+    tq.addRecurringTask('*/5 * * * *', { type: 'job' }, { queueName: 'jobs' });
+
+    tq.tick(new Date('2024-01-01T00:05:00'));
+    expect(tq.getQueueSize('jobs')).toBe(1);
+    expect(tq.getQueueSize()).toBe(0);
+  });
+
+  it('should apply priority from options', () => {
+    tq.addRecurringTask('*/5 * * * *', { type: 'urgent' }, { priority: 1 });
+    tq.addTask('normal', { priority: 5 });
+
+    tq.tick(new Date('2024-01-01T00:05:00'));
+
+    const next = tq.getNextTask()!;
+    expect(next.payload).toEqual({ type: 'urgent' });
+  });
+
+  it('should throw when removing non-existent schedule', () => {
+    expect(() => tq.removeRecurringTask('nonexistent')).toThrow();
+  });
+});
