priority\n    if (!Number.isInteger(priority) || priority < 1 || priority > 10) {\n      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);\n    }\n\n    // Phase 7: Validate dependencies\n    if (options?.dependencies) {\n      for (const depId of options.dependencies) {\n        if (!this.tasks.has(depId)) {\n          throw new Error(`Dependency task '${depId}' does not exist`);\n        }\n      }\n      this.detectCircularDependencies(options.dependencies);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n\n    // Phase 4: Delayed tasks\n    if (options?.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    } else if (options?.processAt) {\n      availableAt = new Date(options.processAt.getTime());\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      priority,\n      createdAt: now,\n      updatedAt: now,\n      availableAt,\n      queueName,\n      retryCount: 0,\n      maxRetries: options?.maxRetries ?? 3,\n      baseDelay: options?.baseDelay ?? 1000,\n      dependencies: options?.dependencies ? [...options.dependencies] : [],\n      progress: 0,\n    };\n\n    this.tasks.set(task.id, task as Task);\n    const queue = this.getQueue(queueName);\n    this.insertPending(queue, task.id);\n\n    return task;\n  }\n\n  getNextTask(queueName: string = 'default'): Task | null {\n    const queue = this.getQueue(queueName);\n\n    // Phase 8: Concurrency control\n    if (queue.concurrencyLimit > 0 && queue.processing.size >= queue.concurrencyLimit) {\n      return null;\n    }\n\n    const now = new Date();\n\n    for (let i = 0; i < queue.pending.length; i++) {\n      const taskId = queue.pending[i];\n      const task = this.tasks.get(taskId)!;\n\n      // Phase 4: Skip tasks not yet available\n      if (task.availableAt.getTime() > now.getTime()) continue;\n\n      // Phase 7: Skip tasks with unmet depend