+export { TaskQueue } from './task-queue.js';
+export type {
+  Task,
+  TaskOptions,
+  TaskStatus,
+  QueueState,
+  Schedule,
+  Middleware,
+  ProcessHandler,
+  ProgressCallback,
+  ShutdownOptions,
+  ShutdownResult,
+} from './types.js';
diff --git a/src/task-queue.ts b/src/task-queue.ts
new file mode 100644
index 0000000..5724c91
--- /dev/null
+++ b/src/task-queue.ts
@@ -0,0 +1,627 @@
+import { randomUUID } from 'node:crypto';
+import { parseCron, cronMatches, type CronFields } from './cron.js';
+import type {
+  Task,
+  TaskOptions,
+  TaskStatus,
+  QueueState,
+  Schedule,
+  Middleware,
+  ProcessHandler,
+  ProgressCallback,
+  ShutdownOptions,
+  ShutdownResult,
+} from './types.js';
+
+export class TaskQueue {
+  private tasks = new Map<string, Task>();
+  private queues = new Map<string, QueueState>();
+  private schedules = new Map<string, Schedule & { parsed: CronFields }>();
+  private progressSubscribers = new Map<string, Set<ProgressCallback>>();
+  private shuttingDown = false;
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+
+  // ─── Queue management ──────────────────────────────────────────
+
+  private getQueue(name: string = 'default'): QueueState {
+    let queue = this.queues.get(name);
+    if (!queue) {
+      queue = {
+        pending: [],
+        processing: new Set(),
+        deadLetter: [],
+        concurrencyLimit: 0,
+        middlewares: [],
+        handler: undefined,
+      };
+      this.queues.set(name, queue);
+    }
+    return queue;
+  }
+
+  // ─── Phase 1: Basic queue ──────────────────────────────────────
+
+  addTask<T>(payload: T, options?: TaskOptions): Task<T> {
+    if (this.shuttingDown) {
+      throw new Error('Queue is shutting down, cannot add tasks');
+    }
+
+    const queueName = options?.queueName ?? 'default';
+    const priority = options?.priority ?? 5;
+
+    // Phase 3: Validate priority
+    if (!Number.isInteger(priority) || priority < 1 || priority > 10) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Phase 7: Validate dependencies
+    if (options?.dependencies) {
+      for (const depId of options.dependencies) {
+        if (!this.tasks.has(depId)) {
+          throw new Error(`Dependency task '${depId}' does not exist`);
+        }
+      }
+      this.detectCircularDependencies(options.dependencies);
+    }
+
+    const now = new Date();
+    let availableAt = now;
+
+    // Phase 4: Delayed tasks
+    if (options?.delay != null && options.delay > 0) {
+      availableAt = new Date(now.getTime() + options.delay);
+    } else if (options?.processAt) {
+      availableAt = new Date(options.processAt.getTime());
+    }
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      payload,
+      status: 'pending',
+      priority,
+      createdAt: now,
+      updatedAt: now,
+      availableAt,
+      queueName,
+      retryCount: 0,
+      maxRetries: options?.maxRetries ?? 3,
+      baseDelay: options?.baseDelay ?? 1000,
+      dependencies: options?.dependencies ? [...options.dependencies] : [],
+      progress: 0,
+    };
+
+    this.tasks.set(task.id, task as Task);
+    const queue = this.getQueue(queueName);
+    this.insertPending(queue, task.id);
+
+    return task;
+  }
+
+  getNextTask(queueName: string = 'default'): Task | null {
+    const queue = this.getQueue(queueName);
+
+    // Phase 8: Concurrency control
+    if (queue.concurrencyLimit > 0 && queue.processing.size >= queue.concurrencyLimit) {
+      return null;
+    }
+
+    const now = new Date();
+
+    for (let i = 0; i < queue.pending.length; i++) {
+      const taskId = queue.pending[i];
+      const task = this.tasks.get(taskId)!;
+
+      // Phase 4: Skip tasks not yet available
+      if (task.availableAt.getTime() > now.getTime()) continue;
+
+      // Phase 7: Skip tasks with unmet dependencies
+      if (!this.areDependenciesMet(task)) continue;
+
+      // Found eligible task
+      queue.pending.splice(i, 1);
+      task.status = 'processing';
+      task.updatedAt = new Date();
+      queue.processing.add(taskId);
+
+      return task;
+    }
+
+    return null;
+  }
+
+  getQueueSize(queueName: string = 'default'): number {
+    const queue = this.getQueue(queueName);
+    return queue.pending.length;
+  }
+
+  // ─── Phase 2: Named queues ────────────────────────────────────
+
+  getQueueNames(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // ─── Phase 5: Complete / Fail ─────────────────────────────────
+
+  completeTask(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task '${taskId}' not found`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task '${taskId}' is not in processing state (current: ${task.status})`);
+    }
+
+    task.status = 'completed';
+    task.updatedAt = new Date();
+
+    const queue = this.getQueue(task.queueName);
+    queue.processing.delete(taskId);
+
+    this.resolveShutdownIfDone();
+  }
+
+  failTask(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task '${taskId}' not found`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task '${taskId}' is not in processing state (current: ${task.status})`);
+    }
+
+    const queue = this.getQueue(task.queueName);
+    queue.processing.delete(taskId);
+
+    task.retryCount++;
+    task.error = error;
+    task.updatedAt = new Date();
+
+    if (task.retryCount < task.maxRetries) {
+      // Retry with exponential backoff
+      const delay = task.baseDelay * Math.pow(2, task.retryCount - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.progress = 0;
+      task.progressMessage = undefined;
+      this.insertPending(queue, taskId);
+    } else {
+      // Phase 6: Move to dead letter queue
+      task.status = 'failed';
+      queue.deadLetter.push(taskId);
+    }
+
+    this.resolveShutdownIfDone();
+  }
+
+  // ─── Phase 6: Dead letter queue ───────────────────────────────
+
+  getDeadLetterTasks(queueName: string = 'default'): Task[] {
+    const queue = this.getQueue(queueName);
+    return queue.deadLetter.map(id => this.tasks.get(id)!);
+  }
+
+  retryDeadLetterTask(taskId: string): Task {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task '${taskId}' not found`);
+    }
+    if (task.status !== 'failed') {
+      throw new Error(`Task '${taskId}' is not in the dead letter queue`);
+    }
+
+    const queue = this.getQueue(task.queueName);
+    const dlqIndex = queue.deadLetter.indexOf(taskId);
+    if (dlqIndex === -1) {
+      throw new Error(`Task '${taskId}' is not in the dead letter queue`);
+    }
+
+    queue.deadLetter.splice(dlqIndex, 1);
+    task.status = 'pending';
+    task.retryCount = 0;
+    task.error = undefined;
+    task.availableAt = new Date();
+    task.updatedAt = new Date();
+    task.progress = 0;
+    task.progressMessage = undefined;
+    this.insertPending(queue, taskId);
+
+    return task;
+  }
+
+  clearDeadLetterQueue(queueName: string = 'default'): void {
+    const queue = this.getQueue(queueName);
+    queue.deadLetter.length = 0;
+  }
+
+  // ─── Phase 7: Dependencies ────────────────────────────────────
+
+  getTaskDependencies(taskId: string): Array<{ taskId: string; status: TaskStatus }> {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task '${taskId}' not found`);
+    }
+    return task.dependencies.map(depId => {
+      const dep = this.tasks.get(depId)!;
+      return { taskId: depId, status: dep.status };
+    });
+  }
+
+  private areDependenciesMet(task: Task): boolean {
+    for (const depId of task.dependencies) {
+      const dep = this.tasks.get(depId);
+      if (!dep || dep.status !== 'completed') return false;
+    }
+    return true;
+  }
+
+  private detectCircularDependencies(dependencies: string[]): void {
+    // Build a set of all transitive dependencies
+    const visited = new Set<string>();
+    const stack = [...dependencies];
+
+    while (stack.length > 0) {
+      const depId = stack.pop()!;
+      if (visited.has(depId)) continue;
+      visited.add(depId);
+
+      const dep = this.tasks.get(depId);
+      if (dep) {
+        for (const transDepId of dep.dependencies) {
+          if (visited.has(transDepId)) continue;
+          stack.push(transDepId);
+        }
+      }
+    }
+
+    // Check if any dependency transitively depends on any other dependency
+    // Since we're adding a new task, cycles can only happen if dependencies form a cycle among themselves
+    // But since all deps already exist and were validated on creation, no new cycle can form
+    // This check is a safeguard
+    for (const depId of dependencies) {
+      if (dependencies.includes(depId) && this.hasTransitiveDep(depId, new Set(dependencies.filter(d => d !== depId)))) {
+        throw new Error('Circular dependency detected');
+      }
+    }
+  }
+
+  private hasTransitiveDep(taskId: string, targetIds: Set<string>, visited = new Set<string>()): boolean {
+    if (visited.has(taskId)) return false;
+    visited.add(taskId);
+
+    const task = this.tasks.get(taskId);
+    if (!task) return false;
+
+    for (const depId of task.dependencies) {
+      if (targetIds.has(depId)) return true;
+      if (this.hasTransitiveDep(depId, targetIds, visited)) return true;
+    }
+    return false;
+  }
+
+  // ─── Phase 8: Concurrency control ────────────────────────────
+
+  setConcurrency(queueName: string, limit: number): void {
+    const queue = this.getQueue(queueName);
+    queue.concurrencyLimit = limit;
+  }
+
+  getConcurrency(queueName: string = 'default'): { limit: number; active: number } {
+    const queue = this.getQueue(queueName);
+    return {
+      limit: queue.concurrencyLimit,
+      active: queue.processing.size,
+    };
+  }
+
+  // ─── Phase 9: Progress & cancellation ─────────────────────────
+
+  updateProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task '${taskId}' not found`);
+    }
+    if (task.status !== 'processing') {
+      throw new Error(`Task '${taskId}' is not in processing state`);
+    }
+
+    task.progress = Math.max(0, Math.min(100, progress));
+    task.progressMessage = message;
+    task.updatedAt = new Date();
+
+    const subscribers = this.progressSubscribers.get(taskId);
+    if (subscribers) {
+      for (const cb of subscribers) {
+        cb(task.progress, task.progressMessage);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task '${taskId}' not found`);
+    }
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, callback: ProgressCallback): () => void {
+    if (!this.progressSubscribers.has(taskId)) {
+      this.progressSubscribers.set(taskId, new Set());
+    }
+    this.progressSubscribers.get(taskId)!.add(callback);
+
+    return () => {
+      const subs = this.progressSubscribers.get(taskId);
+      if (subs) {
+        subs.delete(callback);
+        if (subs.size === 0) {
+          this.progressSubscribers.delete(taskId);
+        }
+      }
+    };
+  }
+
+  cancelTask(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) {
+      throw new Error(`Task '${taskId}' not found`);
+    }
+
+    if (task.status === 'pending') {
+      const queue = this.getQueue(task.queueName);
+      const idx = queue.pending.indexOf(taskId);
+      if (idx !== -1) {
+        queue.pending.splice(idx, 1);
+      }
+      task.status = 'cancelled';
+      task.updatedAt = new Date();
+    } else if (task.status === 'processing') {
+      const queue = this.getQueue(task.queueName);
+      queue.processing.delete(taskId);
+      task.status = 'cancelled';
+      task.updatedAt = new Date();
+      this.resolveShutdownIfDone();
+    } else {
+      throw new Error(`Cannot cancel task in '${task.status}' state`);
+    }
+  }
+
+  // ─── Phase 10: Recurring tasks ────────────────────────────────
+
+  addRecurringTask(
+    cron: string,
+    payload: unknown,
+    options?: Omit<TaskOptions, 'delay' | 'processAt' | 'dependencies'>,
+  ): string {
+    const parsed = parseCron(cron);
+    const id = randomUUID();
+    this.schedules.set(id, {
+      id,
+      cron,
+      payload,
+      options,
+      parsed,
+    });
+    return id;
+  }
+
+  removeRecurringTask(scheduleId: string): void {
+    if (!this.schedules.has(scheduleId)) {
+      throw new Error(`Schedule '${scheduleId}' not found`);
+    }
+    this.schedules.delete(scheduleId);
+  }
+
+  getRecurringTasks(): Schedule[] {
+    return Array.from(this.schedules.values()).map(({ parsed: _parsed, ...schedule }) => schedule);
+  }
+
+  tick(now?: Date): void {
+    const currentTime = now ?? new Date();
+
+    for (const [, schedule] of this.schedules) {
+      if (cronMatches(schedule.parsed, currentTime)) {
+        // Avoid duplicate creation for same minute
+        if (
+          schedule.lastRun &&
+          schedule.lastRun.getFullYear() === currentTime.getFullYear() &&
+          schedule.lastRun.getMonth() === currentTime.getMonth() &&
+          schedule.lastRun.getDate() === currentTime.getDate() &&
+          schedule.lastRun.getHours() === currentTime.getHours() &&
+          schedule.lastRun.getMinutes() === currentTime.getMinutes()
+        ) {
+          continue;
+        }
+
+        schedule.lastRun = currentTime;
+        this.addTask(
+          typeof schedule.payload === 'object' && schedule.payload !== null
+            ? { ...schedule.payload as Record<string, unknown> }
+            : schedule.payload,
+          schedule.options,
+        );
+      }
+    }
+  }
+
+  // ─── Phase 11: Middleware ─────────────────────────────────────
+
+  use(queueName: string, middleware: Middleware): void {
+    const queue = this.getQueue(queueName);
+    queue.middlewares.push(middleware);
+  }
+
+  process(queueName: string, handler: ProcessHandler): void {
+    const queue = this.getQueue(queueName);
+    queue.handler = handler;
+  }
+
+  async processNext(queueName: string = 'default'): Promise<Task | null> {
+    const task = this.getNextTask(queueName);
+    if (!task) return null;
+
+    const queue = this.getQueue(queueName);
+
+    try {
+      let handlerCalled = false;
+      const middlewares = [...queue.middlewares];
+      const handler = queue.handler;
+
+      let index = 0;
+
+      const next = async (): Promise<void> => {
+        if (index < middlewares.length) {
+          const mw = middlewares[index++];
+          await mw(task, next);
+        } else if (handler) {
+          handlerCalled = true;
+          await handler(task);
+        }
+      };
+
+      await next();
+
+      // Auto-complete if task is still processing
+      if (task.status === 'processing') {
+        if (handlerCalled || middlewares.length > 0) {
+          this.completeTask(task.id);
+        }
+      }
+    } catch (err) {
+      if (task.status === 'processing') {
+        this.failTask(task.id, err instanceof Error ? err.message : String(err));
+      }
+    }
+
+    return task;
+  }
+
+  // ─── Phase 12: Graceful shutdown ──────────────────────────────
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(options?: ShutdownOptions): Promise<ShutdownResult> {
+    const timeout = options?.timeout ?? 30000;
+    const startTime = Date.now();
+
+    this.shuttingDown = true;
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Count processing tasks
+    let totalProcessing = 0;
+    for (const [, queue] of this.queues) {
+      totalProcessing += queue.processing.size;
+    }
+
+    // If no processing tasks, return immediately
+    if (totalProcessing === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        duration: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete
+    return new Promise<ShutdownResult>(resolve => {
+      let completed = 0;
+      let forceCancelled = 0;
+
+      const initialProcessing = new Set<string>();
+      for (const [, queue] of this.queues) {
+        for (const taskId of queue.processing) {
+          initialProcessing.add(taskId);
+        }
+      }
+
+      const checkDone = () => {
+        // Count remaining processing tasks from our initial set
+        let remaining = 0;
+        for (const taskId of initialProcessing) {
+          const task = this.tasks.get(taskId);
+          if (task && task.status === 'processing') {
+            remaining++;
+          }
+        }
+
+        completed = initialProcessing.size - remaining;
+
+        if (remaining === 0) {
+          clearInterval(timer);
+          resolve({
+            completed,
+            forceCancelled: 0,
+            duration: Date.now() - startTime,
+          });
+          return;
+        }
+
+        if (Date.now() - startTime >= timeout) {
+          clearInterval(timer);
+          // Force cancel remaining
+          for (const taskId of initialProcessing) {
+            const task = this.tasks.get(taskId);
+            if (task && task.status === 'processing') {
+              const queue = this.getQueue(task.queueName);
+              queue.processing.delete(taskId);
+              task.status = 'cancelled';
+              task.updatedAt = new Date();
+              forceCancelled++;
+            }
+          }
+          completed = initialProcessing.size - forceCancelled;
+          resolve({
+            completed,
+            forceCancelled,
+            duration: Date.now() - startTime,
+          });
+        }
+      };
+
+      const timer = setInterval(checkDone, 10);
+      checkDone();
+    });
+  }
+
+  // ─── Utility ──────────────────────────────────────────────────
+
+  getTask(taskId: string): Task | undefined {
+    return this.tasks.get(taskId);
+  }
+
+  // ─── Private helpers ──────────────────────────────────────────
+
+  private insertPending(queue: QueueState, taskId: string): void {
+    const task = this.tasks.get(taskId)!;
+    let insertIndex = queue.pending.length;
+
+    for (let i = 0; i < queue.pending.length; i++) {
+      const other = this.tasks.get(queue.pending[i])!;
+      if (this.compareTasks(task, other) < 0) {
+        insertIndex = i;
+        break;
+      }
+    }
+
+    queue.pending.splice(insertIndex, 0, taskId);
+  }
+
+  private compareTasks(a: Task, b: Task): number {
+    if (a.priority !== b.priority) return a.priority - b.priority;
+    if (a.availableAt.getTime() !== b.availableAt.getTime()) {
+      return a.availableAt.getTime() - b.availableAt.getTime();
+    }
+    return a.createdAt.getTime() - b.createdAt.getTime();
+  }
+
+  private resolveShutdownIfDone(): void {
+    // This is used to trigger checks in the shutdown polling loop
+    // The polling loop in shutdown() handles the actual resolution
+  }
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..cade877
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,62 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface TaskOptions {
+  queueName?: string;
+  priority?: number;
+  delay?: number;
+  processAt?: Date;
+  maxRetries?: number;
+  baseDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  priority: number;
+  createdAt: Date;
+  updatedAt: Date;
+  availableAt: Date;
+  queueName: string;
+  retryCount: number;
+  maxRetries: number;
+  baseDelay: number;
+  error?: string;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+}
+
+export type Middleware = (task: Task, next: () => Promise<void>) => Promise<void>;
+
+export type ProcessHandler = (task: Task) => Promise<void>;
+
+export type ProgressCallback = (progress: number, message?: string) => void;
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  payload: unknown;
+  options?: Omit<TaskOptions, 'delay' | 'processAt' | 'dependencies'>;
+  lastRun?: Date;
+}
+
+export interface ShutdownOptions {
+  timeout?: number;
+}
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+export interface QueueState {
+  pending: string[];
+  processing: Set<string>;
+  deadLetter: string[];
+  concurrencyLimit: number;
+  middlewares: Middleware[];
+  handler?: ProcessHandler;
+}
