+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 4: Delayed Tasks', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should not return delayed tasks before they are available', () => {
+    tq.addTask('delayed', { delay: 60000 });
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should return delayed tasks after they become available', async () => {
+    tq.addTask('delayed', { delay: 50 });
+    expect(tq.getNextTask()).toBeNull();
+
+    await new Promise(r => setTimeout(r, 60));
+    expect(tq.getNextTask()?.payload).toBe('delayed');
+  });
+
+  it('should support processAt', () => {
+    const futureTime = new Date(Date.now() + 60000);
+    const task = tq.addTask('scheduled', { processAt: futureTime });
+    expect(task.availableAt.getTime()).toBe(futureTime.getTime());
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should set availableAt on delayed tasks', () => {
+    const before = Date.now();
+    const task = tq.addTask('delayed', { delay: 5000 });
+    expect(task.availableAt.getTime()).toBeGreaterThanOrEqual(before + 5000);
+  });
+
+  it('should prefer non-delayed over unavailable delayed tasks', () => {
+    tq.addTask('delayed', { delay: 60000 });
+    tq.addTask('immediate');
+
+    expect(tq.getNextTask()?.payload).toBe('immediate');
+  });
+
+  it('should order delayed tasks by availability time', async () => {
+    tq.addTask('later', { delay: 100 });
+    tq.addTask('sooner', { delay: 30 });
+
+    await new Promise(r => setTimeout(r, 120));
+
+    expect(tq.getNextTask()?.payload).toBe('sooner');
+    expect(tq.getNextTask()?.payload).toBe('later');
+  });
+
+  it('should combine delay with priority', async () => {
+    tq.addTask('delayed-high', { delay: 30, priority: 1 });
+    tq.addTask('immediate-low', { priority: 10 });
+
+    // Delayed task not yet available
+    expect(tq.getNextTask()?.payload).toBe('immediate-low');
+
+    // Add another immediate task
+    tq.addTask('immediate-medium', { priority: 5 });
+
+    await new Promise(r => setTimeout(r, 50));
+
+    // Now delayed-high is available and has higher priority
+    expect(tq.getNextTask()?.payload).toBe('delayed-high');
+    expect(tq.getNextTask()?.payload).toBe('immediate-medium');
+  });
+});
