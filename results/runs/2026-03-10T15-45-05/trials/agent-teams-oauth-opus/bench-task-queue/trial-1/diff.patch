+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 11: Middleware Pipeline', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should run middleware in order', async () => {
+    const order: number[] = [];
+
+    tq.use('default', async (_task, next) => {
+      order.push(1);
+      await next();
+      order.push(4);
+    });
+
+    tq.use('default', async (_task, next) => {
+      order.push(2);
+      await next();
+      order.push(3);
+    });
+
+    tq.process('default', async () => {
+      order.push(99);
+    });
+
+    tq.addTask('data');
+    await tq.processNext();
+
+    expect(order).toEqual([1, 2, 99, 3, 4]);
+  });
+
+  it('should allow middleware to modify task payload', async () => {
+    tq.use('default', async (task, next) => {
+      (task.payload as Record<string, unknown>).modified = true;
+      await next();
+    });
+
+    let receivedPayload: unknown;
+    tq.process('default', async (task) => {
+      receivedPayload = task.payload;
+    });
+
+    tq.addTask({ original: true });
+    await tq.processNext();
+
+    expect(receivedPayload).toEqual({ original: true, modified: true });
+  });
+
+  it('should skip processing when middleware does not call next', async () => {
+    let handlerCalled = false;
+
+    tq.use('default', async () => {
+      // Deliberately not calling next
+    });
+
+    tq.process('default', async () => {
+      handlerCalled = true;
+    });
+
+    tq.addTask('data');
+    await tq.processNext();
+
+    expect(handlerCalled).toBe(false);
+  });
+
+  it('should fail task when middleware throws', async () => {
+    tq.use('default', async () => {
+      throw new Error('middleware error');
+    });
+
+    tq.process('default', async () => {
+      // Should not reach here
+    });
+
+    const task = tq.addTask('data', { maxRetries: 1, baseDelay: 0 });
+    await tq.processNext();
+
+    const updated = tq.getTask(task.id)!;
+    expect(updated.error).toBe('middleware error');
+  });
+
+  it('should have independent middleware per queue', async () => {
+    const q1Calls: string[] = [];
+    const q2Calls: string[] = [];
+
+    tq.use('q1', async (_task, next) => {
+      q1Calls.push('mw');
+      await next();
+    });
+
+    tq.use('q2', async (_task, next) => {
+      q2Calls.push('mw');
+      await next();
+    });
+
+    tq.process('q1', async () => { q1Calls.push('handler'); });
+    tq.process('q2', async () => { q2Calls.push('handler'); });
+
+    tq.addTask('a', { queueName: 'q1' });
+    tq.addTask('b', { queueName: 'q2' });
+
+    await tq.processNext('q1');
+    await tq.processNext('q2');
+
+    expect(q1Calls).toEqual(['mw', 'handler']);
+    expect(q2Calls).toEqual(['mw', 'handler']);
+  });
+
+  it('should return null when no tasks available', async () => {
+    tq.process('default', async () => {});
+    const result = await tq.processNext();
+    expect(result).toBeNull();
+  });
+
+  it('should auto-complete on successful processing', async () => {
+    tq.process('default', async () => {});
+
+    const task = tq.addTask('data');
+    await tq.processNext();
+
+    expect(tq.getTask(task.id)?.status).toBe('completed');
+  });
+
+  it('should work without handler (middleware only)', async () => {
+    let called = false;
+    tq.use('default', async (_task, next) => {
+      called = true;
+      await next();
+    });
+
+    const task = tq.addTask('data');
+    await tq.processNext();
+
+    expect(called).toBe(true);
+    expect(tq.getTask(task.id)?.status).toBe('completed');
+  });
+});
