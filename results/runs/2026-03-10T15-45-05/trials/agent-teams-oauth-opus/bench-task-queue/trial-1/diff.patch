+import { describe, it, expect, beforeEach } from 'vitest';
+import { TaskQueue } from '../index.js';
+
+describe('Phase 1: Basic FIFO Queue', () => {
+  let tq: TaskQueue;
+
+  beforeEach(() => {
+    tq = new TaskQueue();
+  });
+
+  it('should add a task and return a task object', () => {
+    const task = tq.addTask({ message: 'hello' });
+
+    expect(task.id).toBeDefined();
+    expect(typeof task.id).toBe('string');
+    expect(task.payload).toEqual({ message: 'hello' });
+    expect(task.status).toBe('pending');
+    expect(task.createdAt).toBeInstanceOf(Date);
+    expect(task.updatedAt).toBeInstanceOf(Date);
+  });
+
+  it('should generate unique IDs', () => {
+    const t1 = tq.addTask('a');
+    const t2 = tq.addTask('b');
+    expect(t1.id).not.toBe(t2.id);
+  });
+
+  it('should retrieve tasks in FIFO order', () => {
+    tq.addTask('first');
+    tq.addTask('second');
+    tq.addTask('third');
+
+    expect(tq.getNextTask()?.payload).toBe('first');
+    expect(tq.getNextTask()?.payload).toBe('second');
+    expect(tq.getNextTask()?.payload).toBe('third');
+  });
+
+  it('should set task status to processing when retrieved', () => {
+    tq.addTask('data');
+    const task = tq.getNextTask();
+    expect(task?.status).toBe('processing');
+  });
+
+  it('should return null when queue is empty', () => {
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should return null after all tasks are consumed', () => {
+    tq.addTask('only');
+    tq.getNextTask();
+    expect(tq.getNextTask()).toBeNull();
+  });
+
+  it('should track queue size', () => {
+    expect(tq.getQueueSize()).toBe(0);
+    tq.addTask('a');
+    tq.addTask('b');
+    expect(tq.getQueueSize()).toBe(2);
+    tq.getNextTask();
+    expect(tq.getQueueSize()).toBe(1);
+  });
+
+  it('should look up tasks by ID', () => {
+    const task = tq.addTask('data');
+    const found = tq.getTask(task.id);
+    expect(found).toBeDefined();
+    expect(found?.payload).toBe('data');
+  });
+});
