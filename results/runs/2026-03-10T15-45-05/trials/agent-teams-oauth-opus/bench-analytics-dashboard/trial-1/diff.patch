+{"parentUuid":"7bb8a26d-e9ce-4581-83ab-3b4fbfa5f154","isSidechain":false,"userType":"external","cwd":"/workspace","sessionId":"f88581fd-70e9-46c2-803b-6fb972e9fc66","version":"2.1.63","gitBranch":"HEAD","slug":"wise-frolicking-truffle","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NYiKNwrh9Rzn9KDK69w7jZ","type":"tool_result","content":"File created successfully at: /workspace/src/routes/events.ts"}]},"uuid":"9d838d7c-1d18-46c9-9690-29dac263e7df","timestamp":"2026-03-10T16:11:49.402Z","toolUseResult":{"type":"create","filePath":"/workspace/src/routes/events.ts","content":"import { Router, Response } from \"express\";\nimport Database from \"better-sqlite3\";\nimport { v4 as uuidv4 } from \"uuid\";\nimport { AuthRequest, authenticate } from \"../auth.js\";\n\nexport function createEventRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // Ingest single event\n  router.post(\"/\", authenticate, (req: AuthRequest, res: Response) => {\n    const { name, properties, timestamp, sessionId } = req.body;\n\n    if (!name) {\n      res.status(400).json({ error: \"Event name is required\" });\n      return;\n    }\n\n    const id = uuidv4();\n    const tenantId = req.user!.tenantId;\n    const userId = req.user!.id;\n    const props = JSON.stringify(properties || {});\n    const ts = timestamp || new Date().toISOString();\n\n    db.prepare(\n      \"INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    ).run(id, tenantId, name, props, ts, userId, sessionId || null);\n\n    res.status(201).json({ id, name, tenantId, timestamp: ts });\n  });\n\n  // Ingest batch\n  router.post(\"/batch\", authenticate, (req: AuthRequest, res: Response) => {\n    const { events } = req.body;\n\n    if (!Array.isArray(events) || events.length === 0) {\n      res.status(400).json({ error: \"events array is required and must not be empty\" });\n      return;\n    }\n\n    const tenantId = req.user!.tenantId;\n    const userId = req.user!.id;\n\n    const insert = db.prepare(\n      \"INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)\"\n    );\n\n    const insertMany = db.transaction((items: typeof events) => {\n      const results: { id: string; name: string }[] = [];\n      for (const event of items) {\n        if (!event.name) continue;\n        const id = uuidv4();\n        const props = JSON.stringify(event.properties || {});\n        const ts = event.timestamp || new Date().toISOString();\n        insert.run(id, tenantId, event.name, props, ts, userId, event.sessionId || null);\n        results.push({ id, name: event.name });\n      }\n      return results;\n    });\n\n    const results = insertMany(events);\n    res.status(201).json({ inserted: results.length, events: results });\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"7bb8a26d-e9ce-4581-83ab-3b4fbfa5f154"}
