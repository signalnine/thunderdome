+{"parentUuid":"dea55471-dca2-4282-8f2b-25ae57632de7","isSidechain":false,"userType":"external","cwd":"/workspace","sessionId":"f88581fd-70e9-46c2-803b-6fb972e9fc66","version":"2.1.63","gitBranch":"HEAD","slug":"wise-frolicking-truffle","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NG55fPuG8Y84brqe7HAkp6","type":"tool_result","content":"File created successfully at: /workspace/src/routes/query.ts"}]},"uuid":"be1d5c12-98c4-46bb-8433-cde7dc5590d2","timestamp":"2026-03-10T16:11:49.417Z","toolUseResult":{"type":"create","filePath":"/workspace/src/routes/query.ts","content":"import { Router, Response } from \"express\";\nimport Database from \"better-sqlite3\";\nimport { AuthRequest, authenticate } from \"../auth.js\";\n\nexport function createQueryRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // Count events\n  router.post(\"/count\", authenticate, (req: AuthRequest, res: Response) => {\n    const { eventName, startDate, endDate } = req.body;\n    const tenantId = req.user!.tenantId;\n\n    let sql = \"SELECT COUNT(*) as count FROM events WHERE tenant_id = ?\";\n    const params: (string)[] = [tenantId];\n\n    if (eventName) {\n      sql += \" AND name = ?\";\n      params.push(eventName);\n    }\n    if (startDate) {\n      sql += \" AND timestamp >= ?\";\n      params.push(startDate);\n    }\n    if (endDate) {\n      sql += \" AND timestamp <= ?\";\n      params.push(endDate);\n    }\n\n    const result = db.prepare(sql).get(...params) as { count: number };\n    res.json({ count: result.count });\n  });\n\n  // Timeseries\n  router.post(\"/timeseries\", authenticate, (req: AuthRequest, res: Response) => {\n    const { eventName, interval, startDate, endDate } = req.body;\n    const tenantId = req.user!.tenantId;\n    const bucket = interval || \"day\";\n\n    let dateFormat: string;\n    switch (bucket) {\n      case \"hour\":\n        dateFormat = \"%Y-%m-%dT%H:00:00\";\n        break;\n      case \"month\":\n        dateFormat = \"%Y-%m-01\";\n        break;\n      case \"day\":\n      default:\n        dateFormat = \"%Y-%m-%d\";\n        break;\n    }\n\n    let sql = `SELECT strftime('${dateFormat}', timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: string[] = [tenantId];\n\n    if (eventName) {\n      sql += \" AND name = ?\";\n      params.push(eventName);\n    }\n    if (startDate) {\n      sql += \" AND timestamp >= ?\";\n      params.push(startDate);\n    }\n    if (endDate) {\n      sql += \" AND timestamp <= ?\";\n      params.push(endDate);\n    }\n\n    sql += \" GROUP BY period ORDER BY period ASC\";\n\n    const results = db.prepare(sql).all(...params) as { period: string; count: number }[];\n    res.json({ interval: bucket, data: results });\n  });\n\n  // Breakdown\n  router.post(\"/breakdown\", authenticate, (req: AuthRequest, res: Response) => {\n    const { eventName, property, startDate, endDate } = req.body;\n    const tenantId = req.user!.tenantId;\n\n    if (!property) {\n      res.status(400).json({ error: \"property is required for breakdown queries\" });\n      return;\n    }\n\n    let sql = `SELECT json_extract(properties, '$.' || ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;\n    const params: string[] = [property, tenantId];\n\n    if (eventName) {\n      sql += \" AND name = ?\";\n      params.push(eventName);\n    }\n    if (startDate) {\n      sql += \" AND timestamp >= ?\";\n      params.push(startDate);\n    }\n    if (endDate) {\n      sql += \" AND timestamp <= ?\";\n      params.push(endDate);\n    }\n\n    sql += \" GROUP BY value ORDER BY count DESC\";\n\n    const results = db.prepare(sql).all(...params) as { value: string; count: number }[];\n    res.json({ property, data: results });\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"dea55471-dca2-4282-8f2b-25ae57632de7"}
