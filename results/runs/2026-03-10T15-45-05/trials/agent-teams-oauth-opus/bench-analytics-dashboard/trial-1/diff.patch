+    if (!name) {
+      res.status(400).json({ error: "Event name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.id;
+    const props = JSON.stringify(properties || {});
+    const ts = timestamp || new Date().toISOString();
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, props, ts, userId, sessionId || null);
+
+    res.status(201).json({ id, name, tenantId, timestamp: ts });
+  });
+
+  // Ingest batch
+  router.post("/batch", authenticate, (req: AuthRequest, res: Response) => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty" });
+      return;
+    }
+
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.id;
+
+    const insert = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const insertMany = db.transaction((items: typeof events) => {
+      const results: { id: string; name: string }[] = [];
+      for (const event of items) {
+        if (!event.name) continue;
+        const id = uuidv4();
+        const props = JSON.stringify(event.properties || {});
+        const ts = event.timestamp || new Date().toISOString();
+        insert.run(id, tenantId, event.name, props, ts, userId, event.sessionId || null);
+        results.push({ id, name: event.name });
+      }
+      return results;
+    });
+
+    const results = insertMany(events);
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  return router;
+}
diff --git a/src/routes/export.ts b/src/routes/export.ts
new file mode 100644
index 0000000..85042c3
--- /dev/null
+++ b/src/routes/export.ts
@@ -0,0 +1,157 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthRequest, authenticate } from "../auth.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function escapeCsv(value: string): string {
+  if (value.includes(",") || value.includes('"') || value.includes("\n")) {
+    return `"${value.replace(/"/g, '""')}"`;
+  }
+  return value;
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Export events as JSON
+  router.get("/events/json", authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    const events = db.prepare(
+      "SELECT id, tenant_id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ? ORDER BY timestamp DESC"
+    ).all(tenantId) as EventRow[];
+
+    const formatted = events.map((e) => ({
+      id: e.id,
+      name: e.name,
+      properties: JSON.parse(e.properties),
+      timestamp: e.timestamp,
+      userId: e.user_id,
+      sessionId: e.session_id,
+    }));
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", "attachment; filename=events.json");
+    res.json(formatted);
+  });
+
+  // Export events as CSV
+  router.get("/events/csv", authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    const events = db.prepare(
+      "SELECT id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ? ORDER BY timestamp DESC"
+    ).all(tenantId) as EventRow[];
+
+    const header = "id,name,properties,timestamp,user_id,session_id";
+    const rows = events.map(
+      (e) =>
+        `${escapeCsv(e.id)},${escapeCsv(e.name)},${escapeCsv(e.properties)},${escapeCsv(e.timestamp)},${escapeCsv(e.user_id || "")},${escapeCsv(e.session_id || "")}`
+    );
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+    res.send([header, ...rows].join("\n"));
+  });
+
+  // Export dashboard as JSON
+  router.get("/dashboards/:id/json", authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboard = db.prepare(
+      "SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db.prepare(
+      "SELECT id, dashboard_id, type, config, position_x, position_y, width, height FROM widgets WHERE dashboard_id = ?"
+    ).all(dashboard.id) as WidgetRow[];
+
+    res.setHeader("Content-Type", "application/json");
+    res.setHeader("Content-Disposition", `attachment; filename=dashboard-${dashboard.id}.json`);
+    res.json({
+      id: dashboard.id,
+      name: dashboard.name,
+      tenantId: dashboard.tenant_id,
+      ownerId: dashboard.owner_id,
+      config: JSON.parse(dashboard.config),
+      createdAt: dashboard.created_at,
+      updatedAt: dashboard.updated_at,
+      widgets: widgets.map((w) => ({
+        id: w.id,
+        type: w.type,
+        config: JSON.parse(w.config),
+        positionX: w.position_x,
+        positionY: w.position_y,
+        width: w.width,
+        height: w.height,
+      })),
+    });
+  });
+
+  // Export dashboard as CSV
+  router.get("/dashboards/:id/csv", authenticate, (req: AuthRequest, res: Response) => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboard = db.prepare(
+      "SELECT id, tenant_id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE id = ? AND tenant_id = ?"
+    ).get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db.prepare(
+      "SELECT id, dashboard_id, type, config, position_x, position_y, width, height FROM widgets WHERE dashboard_id = ?"
+    ).all(dashboard.id) as WidgetRow[];
+
+    const header = "widget_id,type,config,position_x,position_y,width,height";
+    const rows = widgets.map(
+      (w) =>
+        `${escapeCsv(w.id)},${escapeCsv(w.type)},${escapeCsv(w.config)},${w.position_x},${w.position_y},${w.width},${w.height}`
+    );
+
+    const dashboardInfo = `# Dashboard: ${dashboard.name}\n# ID: ${dashboard.id}\n# Created: ${dashboard.created_at}\n`;
+
+    res.setHeader("Content-Type", "text/csv");
+    res.setHeader("Content-Disposition", `attachment; filename=dashboard-${dashboard.id}.csv`);
+    res.send(dashboardInfo + [header, ...rows].join("\n"));
+  });
+
+  return router;
+}
