annel>\n</rss>`;\n\n        ctx.output.set('feed.xml', feed);\n      },\n    },\n  };\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"6f32c546-2510-4b16-8c8d-6c72caca9747"}
