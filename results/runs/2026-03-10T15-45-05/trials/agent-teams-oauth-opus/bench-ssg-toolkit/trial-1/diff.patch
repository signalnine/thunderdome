this.plugins) {\n      visit(plugin.name);\n    }\n    return sorted;\n  }\n\n  async build(files: ContentFile[]): Promise<BuildContext> {\n    const ctx: BuildContext = {\n      config: this.config,\n      files: [...files],\n      output: new Map(),\n      assets: new Map(),\n      data: new Map(),\n    };\n\n    const orderedPlugins = this.resolvePluginOrder();\n\n    // beforeBuild hooks\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.beforeBuild) {\n        await plugin.hooks.beforeBuild(ctx);\n      }\n    }\n\n    // transformContent hooks (applied to each file in plugin order)\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.transformContent) {\n        const transformed: ContentFile[] = [];\n        for (const file of ctx.files) {\n          transformed.push(await plugin.hooks.transformContent(file, ctx));\n        }\n        ctx.files = transformed;\n      }\n    }\n\n    // Render templates\n    for (const file of ctx.files) {\n      const templateName = file.template || 'default';\n      const template = this.templates.get(templateName);\n      if (template) {\n        const rendered = template.render(file.content, {\n          title: file.title,\n          slug: file.slug,\n          date: file.date,\n          tags: file.tags,\n          ...file.metadata,\n          siteTitle: this.config.title,\n          baseUrl: this.config.baseUrl,\n        });\n        ctx.output.set(`${file.slug}.html`, rendered);\n      } else {\n        ctx.output.set(`${file.slug}.html`, file.content);\n      }\n    }\n\n    // afterBuild hooks\n    for (const plugin of orderedPlugins) {\n      if (plugin.hooks.afterBuild) {\n        await plugin.hooks.afterBuild(ctx);\n      }\n    }\n\n    return ctx;\n  }\n\n  getPlugins(): Plugin[] {\n    return [...this.plugins];\n  }\n\n  getTemplates(): Map<string, Template> {\n    return new Map(this.templates);\n  }\n}\n","numLines":117,"startLine":1,"totalLines":117}},"sourceToolAssistantUUID":"