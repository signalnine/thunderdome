se markdown to HTML (synchronous usage)\n        content = marked.parse(content, { async: false }) as string;\n\n        // Append footnote section if any footnotes exist\n        if (footnotes.size > 0) {\n          const items = Array.from(footnotes.entries())\n            .map(([id, text]) => `<li id=\"fn-${id}\">${text}</li>`)\n            .join('\\n');\n          content += `\\n<section class=\"footnotes\">\\n<ol>\\n${items}\\n</ol>\\n</section>`;\n        }\n\n        return { ...file, content };\n      },\n    },\n  };\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"fc8cfacb-8bb5-44b5-b56c-f8b0a723eb37"}
