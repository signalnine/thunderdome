+type Dir = 0 | 1 | 2; // 0=down, 1=down-left, 2=down-right
+const COL_OFFSET = [0, -1, 1];
+
+function simulate(grid: string[][]): { visited: Set<string>; paths: bigint } {
+  const rows = grid.length;
+  const cols = rows > 0 ? grid[0].length : 0;
+
+  if (rows === 0 || cols === 0) {
+    return { visited: new Set(), paths: 0n };
+  }
+
+  // Find source on top row
+  let sourceCol = -1;
+  for (let c = 0; c < cols; c++) {
+    if (grid[0][c] === 'S') {
+      sourceCol = c;
+      break;
+    }
+  }
+
+  if (sourceCol === -1) {
+    return { visited: new Set(), paths: 0n };
+  }
+
+  const visited = new Set<string>();
+  let totalPaths = 0n;
+
+  // Beams at current row: key = col * 3 + dir, value = path count
+  let beams = new Map<number, bigint>();
+  beams.set(sourceCol * 3, 1n); // dir 0 = down
+
+  for (let row = 0; row < rows && beams.size > 0; row++) {
+    const nextBeams = new Map<number, bigint>();
+
+    for (const [key, count] of beams) {
+      const dir = (key % 3) as Dir;
+      const col = (key - dir) / 3;
+
+      visited.add(`${row},${col}`);
+
+      const cell = grid[row][col];
+
+      if (cell === '^') {
+        // Splitter: emit down-left (dir=1) and down-right (dir=2)
+        for (const newDir of [1, 2] as const) {
+          const newCol = col + COL_OFFSET[newDir];
+          const newRow = row + 1;
+          if (newRow >= rows || newCol < 0 || newCol >= cols) {
+            totalPaths += count;
+          } else {
+            const nk = newCol * 3 + newDir;
+            nextBeams.set(nk, (nextBeams.get(nk) ?? 0n) + count);
+          }
+        }
+      } else {
+        // Continue in current direction
+        const newCol = col + COL_OFFSET[dir];
+        const newRow = row + 1;
+        if (newRow >= rows || newCol < 0 || newCol >= cols) {
+          totalPaths += count;
+        } else {
+          const nk = newCol * 3 + dir;
+          nextBeams.set(nk, (nextBeams.get(nk) ?? 0n) + count);
+        }
+      }
+    }
+
+    beams = nextBeams;
+  }
+
+  return { visited, paths: totalPaths };
+}
+
+export function countBeamCells(grid: string[][]): number {
+  return simulate(grid).visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  return simulate(grid).paths;
+}
