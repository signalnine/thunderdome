+function sanitizeFtsQuery(query: string): string | null {
+  const q = query.trim();
+  if (!q) return null;
+
+  // Phrase query: starts and ends with double quotes
+  if (q.startsWith('"') && q.endsWith('"') && q.length > 2) {
+    const phrase = q.slice(1, -1).replace(/"/g, '');
