+  const cleaned = q.replace(/[^\w\s]/g, ' ').trim();
+  if (!cleaned) return null;
+
+  const words = cleaned.split(/\s+/).filter(w => w.length > 0);
+  if (words.length === 0) return null;
+
+  return words.map(w => `"${w}"`).join(' ');
+}
+
+function sanitizeFtsPrefixQuery(query: string): string | null {
+  const q = query.trim();
+  if (!q) return null;
+
+  const cleaned = q.replace(/[^\w\s]/g, '').trim();
+  if (!cleaned) return null;
+
+  const words = cleaned.split(/\s+/).filter(w => w.length > 0);
+  if (words.length === 0) return null;
+
+  // Prefix match on the last word, exact match on prior words
+  if (words.length === 1) {
+    return `${words[0]}*`;
+  }
+
+  const complete = words.slice(0, -1).map(w => `"${w}"`).join(' ');
+  const last = words[words.length - 1];
+  return `${complete} ${last}*`;
+}
