+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  // Build augmented matrix [A|b] over GF(2)
+  // mat[i][j] = 1 if button j toggles light i; mat[i][m] = target[i]
+  const mat: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    row[m] = target[i] ? 1 : 0;
+    mat.push(row);
+  }
+  for (let j = 0; j < m; j++) {
+    for (const li of buttons[j]) {
+      if (li >= 0 && li < n) mat[li][j] ^= 1;
+    }
+  }
+
+  // RREF over GF(2)
+  const pivotCols: number[] = [];
+  let curRow = 0;
+  for (let col = 0; col < m && curRow < n; col++) {
+    let pr = -1;
+    for (let r = curRow; r < n; r++) {
+      if (mat[r][col]) { pr = r; break; }
+    }
+    if (pr === -1) continue;
+    if (pr !== curRow) {
+      const tmp = mat[curRow]; mat[curRow] = mat[pr]; mat[pr] = tmp;
+    }
+    for (let r = 0; r < n; r++) {
+      if (r !== curRow && mat[r][col]) {
+        const rowR = mat[r], rowP = mat[curRow];
+        for (let c = col; c <= m; c++) rowR[c] ^= rowP[c];
+      }
+    }
+    pivotCols.push(col);
+    curRow++;
+  }
+
+  const rank = pivotCols.length;
+  for (let r = rank; r < n; r++) {
+    if (mat[r][m]) return null;
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+  const numFree = freeVars.length;
+
+  // Precompute: for each pivot row, bitmask of affecting free vars + rhs
+  const pCoeffs = new Array<number>(rank);
+  const pRhs = new Uint8Array(rank);
+  for (let i = 0; i < rank; i++) {
+    let mask = 0;
+    for (let k = 0; k < numFree; k++) {
+      if (mat[i][freeVars[k]]) mask |= (1 << k);
+    }
+    pCoeffs[i] = mask;
+    pRhs[i] = mat[i][m];
+  }
+
+  let bestWeight = m + 1;
+  let bestIndices: number[] = [];
+
+  const totalCombs = 1 << numFree;
+  for (let mask = 0; mask < totalCombs; mask++) {
+    let weight = popcount32(mask);
+    if (weight >= bestWeight) continue;
+
+    let skip = false;
+    const pivotVals = new Uint8Array(rank);
+    for (let i = 0; i < rank; i++) {
+      const v = pRhs[i] ^ (popcount32(pCoeffs[i] & mask) & 1);
+      pivotVals[i] = v;
+      weight += v;
+      if (weight >= bestWeight) { skip = true; break; }
+    }
+    if (skip) continue;
+
+    const indices: number[] = [];
+    for (let k = 0; k < numFree; k++) {
+      if ((mask >> k) & 1) indices.push(freeVars[k]);
+    }
+    for (let i = 0; i < rank; i++) {
+      if (pivotVals[i]) indices.push(pivotCols[i]);
+    }
+    indices.sort((a, b) => a - b);
+
+    if (weight < bestWeight || isLexSmaller(indices, bestIndices)) {
+      bestWeight = weight;
+      bestIndices = indices;
+    }
+  }
+
+  return bestIndices;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+  const p = modulus;
+
+  // Build augmented matrix [A|b] over GF(p)
+  const mat: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    row[m] = ((lights[i] % p) + p) % p;
+    mat.push(row);
+  }
+  for (let j = 0; j < m; j++) {
+    for (const li of buttons[j]) {
+      if (li >= 0 && li < n) mat[li][j] = (mat[li][j] + 1) % p;
+    }
+  }
+
+  function modPow(base: number, exp: number): number {
+    let result = 1;
+    base = ((base % p) + p) % p;
+    while (exp > 0) {
+      if (exp & 1) result = (result * base) % p;
+      exp >>>= 1;
+      base = (base * base) % p;
+    }
+    return result;
+  }
+
+  function modInv(a: number): number {
+    return modPow(a, p - 2);
+  }
+
+  // RREF over GF(p)
+  const pivotCols: number[] = [];
+  let curRow = 0;
+  for (let col = 0; col < m && curRow < n; col++) {
+    let pr = -1;
+    for (let r = curRow; r < n; r++) {
+      if (mat[r][col] !== 0) { pr = r; break; }
+    }
+    if (pr === -1) continue;
+    if (pr !== curRow) {
+      const tmp = mat[curRow]; mat[curRow] = mat[pr]; mat[pr] = tmp;
+    }
+    const inv = modInv(mat[curRow][col]);
+    for (let c = col; c <= m; c++) mat[curRow][c] = (mat[curRow][c] * inv) % p;
+    for (let r = 0; r < n; r++) {
+      if (r !== curRow && mat[r][col] !== 0) {
+        const factor = mat[r][col];
+        for (let c = col; c <= m; c++) {
+          mat[r][c] = ((mat[r][c] - factor * mat[curRow][c]) % p + p) % p;
+        }
+      }
+    }
+    pivotCols.push(col);
+    curRow++;
+  }
+
+  const rank = pivotCols.length;
+  for (let r = rank; r < n; r++) {
+    if (mat[r][m] !== 0) return null;
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+  const numFree = freeVars.length;
+
+  // Precompute coefficients for pivot rows
+  const pCoeffs: number[][] = [];
+  const pRhsArr: number[] = [];
+  for (let i = 0; i < rank; i++) {
+    const coeffs: number[] = [];
+    for (let k = 0; k < numFree; k++) {
+      coeffs.push(mat[i][freeVars[k]]);
+    }
+    pCoeffs.push(coeffs);
+    pRhsArr.push(mat[i][m]);
+  }
+
+  let bestSum = Infinity;
+  let bestSolution: number[] | null = null;
+
+  const freeVals = new Array(numFree).fill(0);
+  const totalCombs = numFree === 0 ? 1 : Math.pow(p, numFree);
+
+  for (let iter = 0; iter < totalCombs; iter++) {
+    const sol = new Array(m).fill(0);
+    let sum = 0;
+
+    for (let k = 0; k < numFree; k++) {
+      sol[freeVars[k]] = freeVals[k];
+      sum += freeVals[k];
+    }
+
+    let skip = false;
+    for (let i = 0; i < rank; i++) {
+      let val = pRhsArr[i];
+      for (let k = 0; k < numFree; k++) {
+        val -= pCoeffs[i][k] * freeVals[k];
+      }
+      const pv = ((val % p) + p) % p;
+      sol[pivotCols[i]] = pv;
+      sum += pv;
+      if (sum > bestSum) { skip = true; break; }
+    }
+
+    if (!skip && (sum < bestSum || (sum === bestSum && isArrayLexSmaller(sol, bestSolution!)))) {
+      bestSum = sum;
+      bestSolution = sol.slice();
+    }
+
+    // Increment freeVals (base-p counter)
+    for (let k = 0; k < numFree; k++) {
+      freeVals[k]++;
+      if (freeVals[k] < p) break;
+      freeVals[k] = 0;
+    }
+  }
+
+  return bestSolution;
+}
+
+function popcount32(x: number): number {
+  x = x - ((x >>> 1) & 0x55555555);
+  x = (x & 0x33333333) + ((x >>> 2) & 0x33333333);
+  return (((x + (x >>> 4)) & 0x0F0F0F0F) * 0x01010101) >>> 24;
+}
+
+function isLexSmaller(a: number[], b: number[]): boolean {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return a.length < b.length;
+}
+
+function isArrayLexSmaller(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
