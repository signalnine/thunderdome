 error };\n    },\n\n    async refund(transactionId: string): Promise<boolean> {\n      const tx = transactions.get(transactionId);\n      if (!tx || tx.status !== PaymentStatus.SUCCESS) return false;\n      tx.status = PaymentStatus.FAILED;\n\n      const event: PaymentProcessedEvent = {\n        orderId: tx.orderId,\n        status: PaymentStatus.FAILED,\n        transactionId,\n        error: 'Refunded',\n      };\n      await bus.emit(Events.PAYMENT_PROCESSED, event);\n\n      return true;\n    },\n  };\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"cf22c384-3880-4ff1-acdd-b3fb0aaae39f"}
