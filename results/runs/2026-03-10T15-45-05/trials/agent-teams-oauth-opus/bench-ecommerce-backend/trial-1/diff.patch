diff --git a/src/analytics/index.ts b/src/analytics/index.ts
new file mode 100644
index 0000000..df6323e
--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,97 @@
+import { EventBus } from '../bus.js';
+import {
+  AnalyticsService,
+  Events,
+  OrderCreatedEvent,
+  PaymentProcessedEvent,
+  PaymentStatus,
+} from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let revenue = 0;
+  const uniqueCarts = new Set<string>();
+  let orderCount = 0;
+  const productCounts = new Map<string, number>();
+
+  function trackEvent(eventType: string): void {
+    eventCounts.set(eventType, (eventCounts.get(eventType) ?? 0) + 1);
+  }
+
+  bus.on(Events.PRODUCT_CREATED, () => { trackEvent(Events.PRODUCT_CREATED); });
+  bus.on(Events.INVENTORY_UPDATED, () => { trackEvent(Events.INVENTORY_UPDATED); });
+  bus.on(Events.LOW_STOCK_ALERT, () => { trackEvent(Events.LOW_STOCK_ALERT); });
+  bus.on(Events.CART_UPDATED, () => { trackEvent(Events.CART_UPDATED); });
+  bus.on(Events.PRICE_CALCULATED, () => { trackEvent(Events.PRICE_CALCULATED); });
+  bus.on(Events.NOTIFICATION_SENT, () => { trackEvent(Events.NOTIFICATION_SENT); });
+  bus.on(Events.ANALYTICS_EVENT, () => { trackEvent(Events.ANALYTICS_EVENT); });
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    trackEvent(Events.ORDER_CREATED);
+    const event = payload as OrderCreatedEvent;
+    orderCount++;
+    uniqueCarts.add(event.cartId);
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, () => { trackEvent(Events.ORDER_STATUS_CHANGED); });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    trackEvent(Events.PAYMENT_PROCESSED);
+    const event = payload as PaymentProcessedEvent;
+    if (event.status === PaymentStatus.SUCCESS) {
+      // Get amount from the event log since PaymentProcessedEvent doesn't carry amount
+      const log = bus.getLog();
+      for (let i = log.length - 1; i >= 0; i--) {
+        const entry = log[i];
+        if (entry.event === Events.ORDER_CREATED) {
+          const orderEvent = entry.payload as OrderCreatedEvent;
+          if (orderEvent.orderId === event.orderId) {
+            revenue += orderEvent.total;
+            break;
+          }
+        }
+      }
+    }
+  });
+
+  // Track product quantities from order creation events via cart data in event log
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    const log = bus.getLog();
+    // Find the most recent cart update for this cart to get items
+    for (let i = log.length - 1; i >= 0; i--) {
+      const entry = log[i];
+      if (entry.event === Events.CART_UPDATED) {
+        const cartEvent = entry.payload as { cartId: string; items: Array<{ productId: string; quantity: number }> };
+        if (cartEvent.cartId === event.cartId) {
+          for (const item of cartEvent.items) {
+            productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);
+          }
+          break;
+        }
+      }
+    }
+  });
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) ?? 0;
+    },
+
+    getRevenue(): number {
+      return revenue;
+    },
+
+    getConversionRate(): number {
+      if (uniqueCarts.size === 0) return 0;
+      return orderCount / uniqueCarts.size;
+    },
+
+    getTopProducts(limit: number) {
+      return [...productCounts.entries()]
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
