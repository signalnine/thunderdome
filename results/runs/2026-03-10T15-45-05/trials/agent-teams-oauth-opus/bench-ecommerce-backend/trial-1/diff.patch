ent(orderId, totals.total);\n    expect(payResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    orders.updateStatus(orderId, OrderStatus.SHIPPED);\n    orders.updateStatus(orderId, OrderStatus.DELIVERED);\n\n    // Wait for async events to settle\n    await new Promise(r => setTimeout(r, 50));\n\n    // Verify notifications\n    const notes = notif.getNotifications('alice');\n    expect(notes.length).toBeGreaterThanOrEqual(4); // created + payment + status changes\n\n    // Verify analytics\n    expect(analytics.getRevenue()).toBe(totals.total);\n    expect(analytics.getEventCount(Events.ORDER_CREATED)).toBe(1);\n    expect(analytics.getEventCount(Events.PAYMENT_PROCESSED)).toBe(1);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":216,"cache_read_input_tokens":32887,"output_tokens":5974,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":216},"inference_geo":"","iterations":[],"speed":"standard"}},"requestId":"req_011CYuhgv7NF7ZFvsR3L6tyc","type":"assistant","uuid":"d75e6ee2-e108-45b3-b007-363470522434","timestamp":"2026-03-10T16:19:43.839Z"}
