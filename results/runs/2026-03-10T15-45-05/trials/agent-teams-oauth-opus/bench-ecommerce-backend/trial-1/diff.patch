ents.PRICE_CALCULATED, result as unknown as PriceCalculatedEvent);\n\n      return result;\n    },\n\n    addDiscountCode(code: string, percentage: number): void {\n      discountCodes.set(code, percentage);\n    },\n\n    getPrice(productId: string): number {\n      return prices.get(productId) ?? 0;\n    },\n  };\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"9c37d406-7014-44d8-a6b4-eb6a6ad04842"}
