@@ -0,0 +1,152 @@
+import type { Token } from './types.js';
+
+const FUNCTIONS = new Set(['SUM', 'AVERAGE', 'MIN', 'MAX', 'COUNT', 'IF']);
+
+export function tokenize(formula: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+
+  while (i < formula.length) {
+    const ch = formula[i];
+
+    // Skip whitespace
+    if (ch === ' ' || ch === '\t') {
+      i++;
+      continue;
+    }
+
+    // String literal
+    if (ch === '"') {
+      let str = '';
+      i++;
+      while (i < formula.length && formula[i] !== '"') {
+        str += formula[i];
+        i++;
+      }
+      if (i >= formula.length) {
+        throw new Error('Unterminated string literal');
+      }
+      i++; // skip closing quote
+      tokens.push({ type: 'string', value: str });
+      continue;
+    }
+
+    // Number
+    if ((ch >= '0' && ch <= '9') || (ch === '.' && i + 1 < formula.length && formula[i + 1] >= '0' && formula[i + 1] <= '9')) {
+      let num = '';
+      while (i < formula.length && ((formula[i] >= '0' && formula[i] <= '9') || formula[i] === '.')) {
+        num += formula[i];
+        i++;
+      }
+      tokens.push({ type: 'number', value: parseFloat(num) });
+      continue;
+    }
+
+    // Identifiers: cell references, functions, booleans
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+      let ident = '';
+      while (i < formula.length && ((formula[i] >= 'A' && formula[i] <= 'Z') || (formula[i] >= 'a' && formula[i] <= 'z') || (formula[i] >= '0' && formula[i] <= '9'))) {
+        ident += formula[i];
+        i++;
+      }
+
+      const upper = ident.toUpperCase();
+
+      // Boolean
+      if (upper === 'TRUE') {
+        tokens.push({ type: 'boolean', value: true });
+        continue;
+      }
+      if (upper === 'FALSE') {
+        tokens.push({ type: 'boolean', value: false });
+        continue;
+      }
+
+      // Function
+      if (FUNCTIONS.has(upper)) {
+        tokens.push({ type: 'func', name: upper });
+        continue;
+      }
+
+      // Check for range (CELL:CELL)
+      const cellRef = upper;
+      if (i < formula.length && formula[i] === ':') {
+        // Peek ahead for a cell reference
+        let j = i + 1;
+        let ident2 = '';
+        while (j < formula.length && ((formula[j] >= 'A' && formula[j] <= 'Z') || (formula[j] >= 'a' && formula[j] <= 'z') || (formula[j] >= '0' && formula[j] <= '9'))) {
+          ident2 += formula[j];
+          j++;
+        }
+        if (ident2.length > 0) {
+          tokens.push({ type: 'range', from: cellRef, to: ident2.toUpperCase() });
+          i = j;
+          continue;
+        }
+      }
+
+      // Cell reference
+      tokens.push({ type: 'cell', ref: cellRef });
+      continue;
+    }
+
+    // Comparison operators
+    if (ch === '<') {
+      if (i + 1 < formula.length && formula[i + 1] === '>') {
+        tokens.push({ type: 'op', value: '<>' });
+        i += 2;
+        continue;
+      }
+      if (i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push({ type: 'op', value: '<=' });
+        i += 2;
+        continue;
+      }
+      tokens.push({ type: 'op', value: '<' });
+      i++;
+      continue;
+    }
+
+    if (ch === '>') {
+      if (i + 1 < formula.length && formula[i + 1] === '=') {
+        tokens.push({ type: 'op', value: '>=' });
+        i += 2;
+        continue;
+      }
+      tokens.push({ type: 'op', value: '>' });
+      i++;
+      continue;
+    }
+
+    if (ch === '=') {
+      tokens.push({ type: 'op', value: '=' });
+      i++;
+      continue;
+    }
+
+    // Arithmetic operators
+    if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {
+      tokens.push({ type: 'op', value: ch });
+      i++;
+      continue;
+    }
+
+    // Parentheses
+    if (ch === '(' || ch === ')') {
+      tokens.push({ type: 'paren', value: ch });
+      i++;
+      continue;
+    }
+
+    // Comma
+    if (ch === ',') {
+      tokens.push({ type: 'comma' });
+      i++;
+      continue;
+    }
+
+    throw new Error(`Unexpected character: ${ch}`);
+  }
+
+  return tokens;
+}
