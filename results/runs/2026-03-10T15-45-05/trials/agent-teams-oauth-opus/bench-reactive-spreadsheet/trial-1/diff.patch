+++ b/src/index.ts
@@ -0,0 +1,187 @@
+import type { CellValue, CellData } from './types.js';
+import { normalizeRef } from './cellref.js';
+import { tokenize } from './tokenizer.js';
+import { parse, collectRefs, evaluate } from './parser.js';
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  // Map from cell -> set of cells that depend on it
+  private dependents: Map<string, Set<string>> = new Map();
+
+  /**
+   * Set a cell's value. Can be a raw value or a formula string starting with '='.
+   */
+  set(cell: string, value: string | number | boolean): void {
+    const ref = normalizeRef(cell);
+
+    // Remove old dependency tracking
+    const existing = this.cells.get(ref);
+    if (existing) {
+      for (const dep of existing.dependsOn) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    // Determine if this is a formula
+    const isFormula = typeof value === 'string' && value.startsWith('=');
+
+    let dependsOn = new Set<string>();
+    let computed: CellValue = null;
+
+    if (isFormula) {
+      const formulaStr = (value as string).substring(1);
+      const tokens = tokenize(formulaStr);
+      const ast = parse(tokens);
+      dependsOn = collectRefs(ast);
+
+      // Check for circular references before committing
+      this.checkCircular(ref, dependsOn);
+
+      // Register dependencies
+      for (const dep of dependsOn) {
+        if (!this.dependents.has(dep)) {
+          this.dependents.set(dep, new Set());
+        }
+        this.dependents.get(dep)!.add(ref);
+      }
+
+      // Store cell data
+      this.cells.set(ref, {
+        raw: value,
+        computed: null,
+        formula: true,
+        dependsOn,
+      });
+
+      // Evaluate
+      computed = this.evaluateCell(ref);
+      this.cells.get(ref)!.computed = computed;
+    } else {
+      this.cells.set(ref, {
+        raw: value,
+        computed: typeof value === 'string' ? value : value,
+        formula: false,
+        dependsOn,
+      });
+    }
+
+    // Propagate changes to dependents
+    this.propagate(ref);
+  }
+
+  /**
+   * Get a cell's computed value. Returns null for empty cells.
+   */
+  get(cell: string): CellValue {
+    const ref = normalizeRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computed;
+  }
+
+  /**
+   * Get the display string for a cell's computed value.
+   */
+  getDisplay(cell: string): string {
+    const value = this.get(cell);
+    if (value === null) return '';
+    return String(value);
+  }
+
+  /**
+   * Get all non-empty cells as a Map from cell reference to computed value.
+   */
+  getCells(): Map<string, any> {
+    const result = new Map<string, any>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computed);
+    }
+    return result;
+  }
+
+  /**
+   * Evaluate a formula cell and return its computed value.
+   */
+  private evaluateCell(ref: string): CellValue {
+    const data = this.cells.get(ref);
+    if (!data || !data.formula) return data?.computed ?? null;
+
+    const formulaStr = (data.raw as string).substring(1);
+    const tokens = tokenize(formulaStr);
+    const ast = parse(tokens);
+
+    return evaluate(ast, (cellRef: string) => {
+      const depData = this.cells.get(cellRef);
+      if (!depData) return null;
+      return depData.computed;
+    });
+  }
+
+  /**
+   * Propagate changes from a cell to all its dependents (topological order).
+   */
+  private propagate(ref: string): void {
+    // Get all affected cells in topological order
+    const order = this.topologicalSort(ref);
+
+    for (const cellRef of order) {
+      if (cellRef === ref) continue; // already computed
+      const data = this.cells.get(cellRef);
+      if (data && data.formula) {
+        data.computed = this.evaluateCell(cellRef);
+      }
+    }
+  }
+
+  /**
+   * Topological sort of all cells reachable from the given cell via dependents.
+   */
+  private topologicalSort(startRef: string): string[] {
+    const visited = new Set<string>();
+    const order: string[] = [];
+
+    const visit = (ref: string): void => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      const deps = this.dependents.get(ref);
+      if (deps) {
+        for (const dep of deps) {
+          visit(dep);
+        }
+      }
+      order.push(ref);
+    };
+
+    visit(startRef);
+    return order.reverse();
+  }
+
+  /**
+   * Check if setting the given cell with the given dependencies would create a cycle.
+   */
+  private checkCircular(ref: string, newDeps: Set<string>): void {
+    // DFS from each dependency to see if we can reach ref
+    const visited = new Set<string>();
+
+    const hasCycle = (current: string): boolean => {
+      if (current === ref) return true;
+      if (visited.has(current)) return false;
+      visited.add(current);
+
+      const cellData = this.cells.get(current);
+      if (cellData) {
+        for (const dep of cellData.dependsOn) {
+          if (hasCycle(dep)) return true;
+        }
+      }
+      return false;
+    };
+
+    for (const dep of newDeps) {
+      visited.clear();
+      if (hasCycle(dep)) {
+        throw new Error(`Circular reference detected: setting ${ref} would create a cycle`);
+      }
+    }
+  }
+}
