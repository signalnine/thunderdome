--- /dev/null
+++ b/src/parser.ts
@@ -0,0 +1,288 @@
+import type { Token, CellValue } from './types.js';
+import { expandRange } from './cellref.js';
+
+// AST node types
+export type ASTNode =
+  | { kind: 'number'; value: number }
+  | { kind: 'string'; value: string }
+  | { kind: 'boolean'; value: boolean }
+  | { kind: 'cell'; ref: string }
+  | { kind: 'range'; cells: string[] }
+  | { kind: 'binop'; op: string; left: ASTNode; right: ASTNode }
+  | { kind: 'unary'; op: string; operand: ASTNode }
+  | { kind: 'call'; name: string; args: ASTNode[] };
+
+/**
+ * Parse a token stream into an AST.
+ */
+export function parse(tokens: Token[]): ASTNode {
+  let pos = 0;
+
+  function peek(): Token | undefined {
+    return tokens[pos];
+  }
+
+  function advance(): Token {
+    return tokens[pos++];
+  }
+
+  function expect(type: string, value?: string): Token {
+    const tok = advance();
+    if (!tok || tok.type !== type || (value !== undefined && (tok as any).value !== value)) {
+      throw new Error(`Expected ${type}${value ? ` '${value}'` : ''} but got ${tok ? `${tok.type}` : 'end of input'}`);
+    }
+    return tok;
+  }
+
+  // Expression: comparison
+  function parseExpression(): ASTNode {
+    return parseComparison();
+  }
+
+  function parseComparison(): ASTNode {
+    let left = parseAddSub();
+    while (peek() && peek()!.type === 'op' && ['>', '<', '>=', '<=', '=', '<>'].includes((peek() as any).value)) {
+      const op = (advance() as { type: 'op'; value: string }).value;
+      const right = parseAddSub();
+      left = { kind: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  function parseAddSub(): ASTNode {
+    let left = parseMulDiv();
+    while (peek() && peek()!.type === 'op' && ((peek() as any).value === '+' || (peek() as any).value === '-')) {
+      const op = (advance() as { type: 'op'; value: string }).value;
+      const right = parseMulDiv();
+      left = { kind: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  function parseMulDiv(): ASTNode {
+    let left = parseUnary();
+    while (peek() && peek()!.type === 'op' && ((peek() as any).value === '*' || (peek() as any).value === '/')) {
+      const op = (advance() as { type: 'op'; value: string }).value;
+      const right = parseUnary();
+      left = { kind: 'binop', op, left, right };
+    }
+    return left;
+  }
+
+  function parseUnary(): ASTNode {
+    if (peek() && peek()!.type === 'op' && (peek() as any).value === '-') {
+      advance();
+      const operand = parseUnary();
+      return { kind: 'unary', op: '-', operand };
+    }
+    if (peek() && peek()!.type === 'op' && (peek() as any).value === '+') {
+      advance();
+      return parseUnary();
+    }
+    return parsePrimary();
+  }
+
+  function parsePrimary(): ASTNode {
+    const tok = peek();
+    if (!tok) throw new Error('Unexpected end of expression');
+
+    if (tok.type === 'number') {
+      advance();
+      return { kind: 'number', value: tok.value };
+    }
+
+    if (tok.type === 'string') {
+      advance();
+      return { kind: 'string', value: tok.value };
+    }
+
+    if (tok.type === 'boolean') {
+      advance();
+      return { kind: 'boolean', value: tok.value };
+    }
+
+    if (tok.type === 'cell') {
+      advance();
+      return { kind: 'cell', ref: tok.ref };
+    }
+
+    if (tok.type === 'range') {
+      advance();
+      return { kind: 'range', cells: expandRange(tok.from, tok.to) };
+    }
+
+    if (tok.type === 'func') {
+      const name = tok.name;
+      advance();
+      expect('paren', '(');
+      const args: ASTNode[] = [];
+      if (peek() && !(peek()!.type === 'paren' && (peek() as any).value === ')')) {
+        args.push(parseExpression());
+        while (peek() && peek()!.type === 'comma') {
+          advance();
+          args.push(parseExpression());
+        }
+      }
+      expect('paren', ')');
+      return { kind: 'call', name, args };
+    }
+
+    if (tok.type === 'paren' && tok.value === '(') {
+      advance();
+      const expr = parseExpression();
+      expect('paren', ')');
+      return expr;
+    }
+
+    throw new Error(`Unexpected token: ${tok.type}`);
+  }
+
+  const ast = parseExpression();
+  if (pos < tokens.length) {
+    throw new Error(`Unexpected token after expression: ${tokens[pos].type}`);
+  }
+  return ast;
+}
+
+/**
+ * Collect all cell references from an AST node.
+ */
+export function collectRefs(node: ASTNode): Set<string> {
+  const refs = new Set<string>();
+
+  function walk(n: ASTNode): void {
+    switch (n.kind) {
+      case 'cell':
+        refs.add(n.ref);
+        break;
+      case 'range':
+        for (const c of n.cells) refs.add(c);
+        break;
+      case 'binop':
+        walk(n.left);
+        walk(n.right);
+        break;
+      case 'unary':
+        walk(n.operand);
+        break;
+      case 'call':
+        for (const arg of n.args) walk(arg);
+        break;
+    }
+  }
+
+  walk(node);
+  return refs;
+}
+
+/**
+ * Evaluate an AST node given a cell value resolver.
+ */
+export function evaluate(node: ASTNode, getCell: (ref: string) => CellValue): CellValue {
+  switch (node.kind) {
+    case 'number':
+      return node.value;
+    case 'string':
+      return node.value;
+    case 'boolean':
+      return node.value;
+    case 'cell':
+      return getCell(node.ref);
+    case 'range':
+      // Ranges shouldn't appear standalone; they're handled inside function calls
+      throw new Error('Range used outside of a function');
+    case 'unary': {
+      const val = evaluate(node.operand, getCell);
+      if (node.op === '-') return -(val as number);
+      return val;
+    }
+    case 'binop': {
+      const left = evaluate(node.left, getCell);
+      const right = evaluate(node.right, getCell);
+      return evalBinop(node.op, left, right);
+    }
+    case 'call':
+      return evalCall(node.name, node.args, getCell);
+  }
+}
+
+function evalBinop(op: string, left: CellValue, right: CellValue): CellValue {
+  switch (op) {
+    case '+': return (left as number) + (right as number);
+    case '-': return (left as number) - (right as number);
+    case '*': return (left as number) * (right as number);
+    case '/': return (left as number) / (right as number);
+    case '>': return (left as number) > (right as number);
+    case '<': return (left as number) < (right as number);
+    case '>=': return (left as number) >= (right as number);
+    case '<=': return (left as number) <= (right as number);
+    case '=': return left === right;
+    case '<>': return left !== right;
+    default: throw new Error(`Unknown operator: ${op}`);
+  }
+}
+
+function resolveRangeValues(node: ASTNode, getCell: (ref: string) => CellValue): CellValue[] {
+  if (node.kind === 'range') {
+    return node.cells.map(c => getCell(c));
+  }
+  // Single value
+  return [evaluate(node, getCell)];
+}
+
+function evalCall(name: string, args: ASTNode[], getCell: (ref: string) => CellValue): CellValue {
+  switch (name) {
+    case 'SUM': {
+      const values = resolveRangeValues(args[0], getCell);
+      let sum = 0;
+      for (const v of values) {
+        if (typeof v === 'number') sum += v;
+      }
+      return sum;
+    }
+    case 'AVERAGE': {
+      const values = resolveRangeValues(args[0], getCell);
+      let sum = 0;
+      let count = 0;
+      for (const v of values) {
+        if (typeof v === 'number') { sum += v; count++; }
+      }
+      return count === 0 ? 0 : sum / count;
+    }
+    case 'MIN': {
+      const values = resolveRangeValues(args[0], getCell);
+      let min = Infinity;
+      for (const v of values) {
+        if (typeof v === 'number' && v < min) min = v;
+      }
+      return min === Infinity ? 0 : min;
+    }
+    case 'MAX': {
+      const values = resolveRangeValues(args[0], getCell);
+      let max = -Infinity;
+      for (const v of values) {
+        if (typeof v === 'number' && v > max) max = v;
+      }
+      return max === -Infinity ? 0 : max;
+    }
+    case 'COUNT': {
+      const values = resolveRangeValues(args[0], getCell);
+      let count = 0;
+      for (const v of values) {
+        if (typeof v === 'number') count++;
+      }
+      return count;
+    }
+    case 'IF': {
+      if (args.length < 3) throw new Error('IF requires 3 arguments');
+      const cond = evaluate(args[0], getCell);
+      if (cond && cond !== 0) {
+        return evaluate(args[1], getCell);
+      } else {
+        return evaluate(args[2], getCell);
+      }
+    }
+    default:
+      throw new Error(`Unknown function: ${name}`);
+  }
+}
