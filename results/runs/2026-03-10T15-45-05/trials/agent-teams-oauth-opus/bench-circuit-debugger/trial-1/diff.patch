+
+describe('findSwappedWires', () => {
+  // Build a correct N-bit ripple-carry adder
+  function buildAdder(n: number): Gate[] {
+    const gates: Gate[] = [];
+    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+    for (let i = 1; i < n; i++) {
+      const p = String(i).padStart(2, '0');
+      const pp = String(i - 1).padStart(2, '0');
+      const zn = String(n).padStart(2, '0');
+      gates.push({ op: 'XOR', in1: `x${p}`, in2: `y${p}`, out: `t${p}` });
+      gates.push({ op: 'XOR', in1: `t${p}`, in2: `c${pp}`, out: `z${p}` });
+      gates.push({ op: 'AND', in1: `x${p}`, in2: `y${p}`, out: `a${p}` });
+      gates.push({
+        op: 'AND',
+        in1: `t${p}`,
+        in2: `c${pp}`,
+        out: `b${p}`,
+      });
+      gates.push({
+        op: 'OR',
+        in1: `a${p}`,
+        in2: `b${p}`,
+        out: i === n - 1 ? `z${zn}` : `c${p}`,
+      });
+    }
+    return gates;
+  }
+
+  // Swap two gate outputs by wire name
+  function swapWires(gates: Gate[], w1: string, w2: string): Gate[] {
+    return gates.map((g) => {
+      if (g.out === w1) return { ...g, out: w2 };
+      if (g.out === w2) return { ...g, out: w1 };
+      return { ...g };
+    });
+  }
+
+  // Verify adder correctness with random inputs
+  function verifyAdder(gates: Gate[], n: number): boolean {
+    for (let trial = 0; trial < 10; trial++) {
+      const x = Math.floor(Math.random() * (1 << n));
+      const y = Math.floor(Math.random() * (1 << n));
+      const inputs: Record<string, number> = {};
+      for (let i = 0; i < n; i++) {
+        const p = String(i).padStart(2, '0');
+        inputs[`x${p}`] = (x >> i) & 1;
+        inputs[`y${p}`] = (y >> i) & 1;
+      }
+      const result = simulate(gates, inputs);
+      let z = 0;
+      for (let i = 0; i <= n; i++) {
+        const p = String(i).padStart(2, '0');
+        z |= (result[`z${p}`] ?? 0) << i;
+      }
+      if (z !== x + y) return false;
+    }
+    return true;
+  }
