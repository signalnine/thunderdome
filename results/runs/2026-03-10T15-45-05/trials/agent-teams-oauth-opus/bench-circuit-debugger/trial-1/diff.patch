ut;\n\n  // Bits 1..N-1: full adders\n  for (let i = 1; i < N; i++) {\n    const p = String(i).padStart(2, '0');\n    const xi = 'x' + p,\n      yi = 'y' + p,\n      zi = 'z' + p;\n\n    let partial = find('XOR', xi, yi)!.out;\n    let sumXor = find('XOR', partial, carry);\n\n    if (!sumXor) {\n      // partial or carry has a wrong name due to a swap\n      const zGate = byOut.get(zi);\n\n      if (zGate && zGate.op === 'XOR') {\n        // z_i correctly comes from XOR but with unexpected inputs\n        const ins = [zGate.in1, zGate.in2];\n\n        if (ins.includes(carry) && !ins.includes(partial)) {\n          const real = ins[0] === carry ? ins[1] : ins[0];\n          doSwap(partial, real);\n          partial = real;\n        } else if (ins.includes(partial) && !ins.includes(carry)) {\n          const real = ins[0] === partial ? ins[1] : ins[0];\n          doSwap(carry, real);\n          carry = real;\n        } else if (!ins.includes(partial) && !ins.includes(carry)) {\n          // Both wrong - assign based on structure\n          doSwap(partial, ins[0]);\n          partial = ins[0];\n          doSwap(carry, ins[1]);\n          carry = ins[1];\n        }\n        sumXor = find('XOR', partial, carry);\n      } else {\n        // z_i is not produced by XOR - z_i itself is swapped\n        // Find the actual sum XOR gate\n        let found = false;\n        for (const c of usedBy.get(partial) || []) {\n          if (c.op === 'XOR') {\n            const other = c.in1 === partial ? c.in2 : c.in1;\n            if (other === carry) {\n              doSwap(c.out, zi);\n              sumXor = find('XOR', partial, carry);\n              found = true;\n              break;\n            }\n          }\n        }\n        if (!found) {\n          for (const c of usedBy.get(carry) || []) {\n            if (c.op === 'XOR') {\n              const other = c.in1 === carry ? c.in2 : c.in1;\n              if (other === partial) {\n                doSwap(c.out, zi);\n            