+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+
+  // Build dependency graph for topological processing
+  const dependents = new Map<string, Gate[]>();
+  const pending = new Map<Gate, number>();
+  const ready: Gate[] = [];
+
+  for (const g of gates) {
+    const n =
+      (wires[g.in1] === undefined ? 1 : 0) +
+      (wires[g.in2] === undefined ? 1 : 0);
+    if (n === 0) {
+      ready.push(g);
+      continue;
+    }
+    pending.set(g, n);
+    for (const w of [g.in1, g.in2]) {
+      if (wires[w] === undefined) {
+        let arr = dependents.get(w);
+        if (!arr) {
+          arr = [];
+          dependents.set(w, arr);
+        }
+        arr.push(g);
+      }
+    }
+  }
+
+  while (ready.length > 0) {
+    const g = ready.pop()!;
+    const a = wires[g.in1],
+      b = wires[g.in2];
+    wires[g.out] = g.op === 'AND' ? a & b : g.op === 'OR' ? a | b : a ^ b;
+
+    const deps = dependents.get(g.out);
+    if (deps) {
+      for (const d of deps) {
+        const r = pending.get(d)! - 1;
+        if (r === 0) {
+          ready.push(d);
+          pending.delete(d);
+        } else {
+          pending.set(d, r);
+        }
+      }
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Try rules-based structural analysis first (fast, handles most cases)
+  const rulesResult = findByRules(gates);
+  if (rulesResult.length === 8) return rulesResult.sort();
+
+  // Fall back to bit-by-bit tracing
+  return findByTracing(gates);
+}
+
+function findByRules(gates: Gate[]): string[] {
+  const bad = new Set<string>();
+
+  // Build wire usage index and gate-by-output index
+  const usedBy = new Map<string, Gate[]>();
+  const byOut = new Map<string, Gate>();
+  let maxZ = 0;
+
+  for (const g of gates) {
+    byOut.set(g.out, g);
+    for (const w of [g.in1, g.in2]) {
+      let arr = usedBy.get(w);
+      if (!arr) {
+        arr = [];
+        usedBy.set(w, arr);
+      }
+      arr.push(g);
+    }
+    const m = g.out.match(/^z(\d+)$/);
+    if (m) maxZ = Math.max(maxZ, parseInt(m[1]));
+  }
+
+  const lastZ = 'z' + String(maxZ).padStart(2, '0');
+  const isXY = (w: string) => w[0] === 'x' || w[0] === 'y';
+  const feedsInto = (wire: string, op: string) =>
+    (usedBy.get(wire) || []).some((g) => g.op === op);
+
+  for (const g of gates) {
+    // Rule 1: z outputs (except last) must come from XOR gates
+    if (g.out[0] === 'z' && g.out !== lastZ && g.op !== 'XOR') {
+      bad.add(g.out);
+    }
+
+    // Rule 2: XOR gates with non-x/y inputs must output to z
+    if (
+      g.op === 'XOR' &&
+      !isXY(g.in1) &&
+      !isXY(g.in2) &&
+      g.out[0] !== 'z'
+    ) {
+      bad.add(g.out);
+    }
+
+    // Rule 3: XOR gates with x/y inputs
+    if (g.op === 'XOR' && (isXY(g.in1) || isXY(g.in2))) {
+      const isBitZero =
+        new Set([g.in1, g.in2]).has('x00') &&
+        new Set([g.in1, g.in2]).has('y00');
+      if (isBitZero) {
+        // Bit 0 XOR must output z00
+        if (g.out !== 'z00') bad.add(g.out);
+      } else {
+        // Other bits: partial sum must feed into another XOR
+        if (!feedsInto(g.out, 'XOR')) bad.add(g.out);
+      }
+    }
+
+    // Rule 4: AND gates (except bit-0 AND) must feed into OR
+    if (g.op === 'AND') {
+      const ins = new Set([g.in1, g.in2]);
+      if (!(ins.has('x00') && ins.has('y00'))) {
+        if (!feedsInto(g.out, 'OR')) bad.add(g.out);
+      }
+    }
+
+    // Rule 5: last z must come from OR (for circuits with more than 1 bit)
+    if (g.out === lastZ && maxZ > 0 && g.op !== 'OR') {
+      bad.add(g.out);
+    }
+  }
+
+  return [...bad];
+}
+
+function findByTracing(gates: Gate[]): string[] {
