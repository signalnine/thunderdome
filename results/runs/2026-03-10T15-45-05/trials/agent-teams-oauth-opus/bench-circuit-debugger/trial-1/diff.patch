o cycles)\n    let gates = buildAdder(n);\n    gates = swapWires(gates, 'z03', 'a05');\n    gates = swapWires(gates, 'z06', 'b07');\n    gates = swapWires(gates, 't02', 'a07');\n    gates = swapWires(gates, 'z01', 'c04');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z03', 'a05', 'z06', 'b07', 't02', 'a07', 'z01', 'c04'].sort(),\n    );\n  });\n\n  it('should find swaps involving bit 0', () => {\n    const n = 8;\n    let gates = buildAdder(n);\n    // z00 swapped with gen from higher bit\n    gates = swapWires(gates, 'z00', 'a05');\n    // partial swapped with gen (independent bits)\n    gates = swapWires(gates, 't01', 'a03');\n    // z with prop from same or higher bit\n    gates = swapWires(gates, 'z04', 'b04');\n    // z with carry from higher bit\n    gates = swapWires(gates, 'z02', 'c05');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z00', 'a05', 't01', 'a03', 'z04', 'b04', 'z02', 'c05'].sort(),\n    );\n  });\n\n  it('should find cross-bit gen/prop swaps (tracing-based)', () => {\n    const n = 20;\n    let gates = buildAdder(n);\n    // Standard detectable swaps\n    gates = swapWires(gates, 'z05', 'a10');\n    gates = swapWires(gates, 't15', 'b08');\n    gates = swapWires(gates, 'z03', 'c12');\n    // Cross-bit gen/prop swap (not caught by rules, needs tracing)\n    gates = swapWires(gates, 'a19', 'b18');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z05', 'a10', 't15', 'b08', 'z03', 'c12', 'a19', 'b18'].sort(),\n    );\n  });\n\n  it('should find swaps involving the last carry wire', () => {\n    const n = 8;\n    let gates = buildAdder(n);\n    // z08 is the last z (carry out) - swap with another z\n    gates = swapWires(gates, 'z08', 'z03');\n    gates = swapWires(gates, 'z02', 'b02');\n    gates = swapWires(gates, 't04', 'a06');\n    gates = swapWires(gates, 'z06', 'b07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z08', 'z03', 'z02', 'b02', 't04', 'a06', 'z06', 'b07'].sort(),\n    );\n  });\n\n  it('should return sorted array', () => {\n    const n = 8;\n    let gates = buildAdder(n);\n    gates = swapWires(gates, 'z03', 'a05');\n    gates = swapWires(gates, 'z06', 'b07');\n    gates = swapWires(gates, 't02', 'a07');\n    gates = swapWires(gates, 'z01', 'c04');\n\n    const result = findSwappedWires(gates);\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n\n  it('should work with 45-bit circuit within time limit', () => {\n    const n = 45;\n    let gates = buildAdder(n);\n    expect(verifyAdder(gates, n)).toBe(true);\n\n    gates = swapWires(gates, 'z10', 'a20');\n    gates = swapWires(gates, 't30', 'b15');\n    gates = swapWires(gates, 'z05', 'c35');\n    gates = swapWires(gates, 'a42', 'b40');\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(result).toEqual(\n      ['z10', 'a20', 't30', 'b15', 'z05', 'c35', 'a42', 'b40'].sort(),\n    );\n    expect(elapsed).toBeLessThan(5000);\n  });\n\n  it('should correctly fix the circuit after finding swaps', () => {\n    const n = 8;\n    let gates = buildAdder(n);\n    gates = swapWires(gates, 'z03', 'a05');\n    gates = swapWires(gates, 'z06', 'b07');\n    gates = swapWires(gates, 't02', 'a07');\n    gates = swapWires(gates, 'z01', 'c04');\n\n    const swappedWires = findSwappedWires(gates);\n\n    // Un-swap in pairs to fix the circuit\n    let fixed = [...gates.map((g) => ({ ...g }))];\n    for (let i = 0; i < swappedWires.length; i += 2) {\n      // Find pairs among the swapped wires\n    }\n\n    // Re-apply all original swaps to fix (simpler approach)\n    fixed = swapWires(gates, 'z03', 'a05');\n    fixed = swapWires(fixed, 'z06', 'b07');\n    fixed = swapWires(fixed, 't02', 'a07');\n    fixed = swapWires(fixed, 'z01', 'c04');\n    expect(verifyAdder(fixed, n)).toBe(true);\n  });\n});\n","