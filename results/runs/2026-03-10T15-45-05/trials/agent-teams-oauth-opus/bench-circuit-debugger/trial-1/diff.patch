+  function rebuild() {
+    byOut = new Map();
+    byKey = new Map();
+    usedBy = new Map();
+    for (const g of gs) {
+      byOut.set(g.out, g);
+      const k =
+        g.op +
+        ':' +
+        (g.in1 < g.in2 ? g.in1 + ',' + g.in2 : g.in2 + ',' + g.in1);
+      byKey.set(k, g);
+      for (const w of [g.in1, g.in2]) {
+        let arr = usedBy.get(w);
+        if (!arr) {
+          arr = [];
+          usedBy.set(w, arr);
+        }
+        arr.push(g);
+      }
+    }
+  }
+
+  function find(op: string, a: string, b: string): G | undefined {
+    return byKey.get(
+      op + ':' + (a < b ? a + ',' + b : b + ',' + a),
+    );
+  }
+
+  function doSwap(w1: string, w2: string) {
+    const g1 = byOut.get(w1)!;
+    const g2 = byOut.get(w2)!;
+    g1.out = w2;
+    g2.out = w1;
+    swapped.push(w1, w2);
+    rebuild();
+  }
+
+  rebuild();
+
+  // Find number of input bits
+  let N = 0;
+  for (const g of gs) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^x(\d+)$/);
+      if (m) N = Math.max(N, parseInt(m[1]) + 1);
+    }
+  }
