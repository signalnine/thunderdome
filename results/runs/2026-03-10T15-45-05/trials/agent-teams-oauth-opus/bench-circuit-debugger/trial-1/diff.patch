 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle XOR gate', () => {\n    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];\n    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });\n    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });\n    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });\n    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });\n  });\n\n  it('should handle chained gates in dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({\n      a: 1,\n      b: 1,\n      c: 1,\n      d: 0,\n      e: 1,\n    });\n    expect(simulate(gates, { a: 0, b: 1, d: 0 })).toEqual({\n      a: 0,\n      b: 1,\n      c: 0,\n      d: 0,\n      e: 0,\n    });\n  });\n\n  it('should simulate a 2-bit adder correctly', () => {\n    // 2-bit adder: x + y = z\n    const gates: Gate[] = [\n      // Bit 0: half adder\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1: full adder\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n\n    // 0 + 0 = 0\n    let result = simulate(gates, {\n      x00: 0,\n      x01: 0,\n      y00: 0,\n      y01: 0,\n    });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n\n    // 1 + 1 = 2 (binary 10)\n    result = simulate(gates, {\n      x00: 1,\n      x01: 0,\n      y00: 1,\n      y01: 0,\n    });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(0);\n\n    // 3 + 3 = 6 (binary 110)\n    result = simulate(gates, {\n      x00: 1,\n      x01: 1,\n      y00: 1,\n      y01: 1,\n    });\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(1);\n\n    // 2 + 1 = 3 (binary 011)\n    result = simulate(gates, {\n      x00: 0,\n      x01: 1,\n      y00: 1,\n      y01: 0,\n    });\n    expect(result.z00).toBe(1);\n    expect(result.z01).toBe(1);\n    expect(result.z02).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  // Helper: build a correct N-bit ripple-carry adder\n  function buildAdder(n: number): Gate[] {\n    const gates: Gate[] = [];\n\n    // Bit 0: half adder\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n    for (let i = 1; i < n; i++) {\n      const p = String(i).padStart(2, '0');\n      const pp = String(i - 1).padStart(2, '0');\n      gates.push({\n        op: 'XOR',\n        in1: `x${p}`,\n        in2: `y${p}`,\n        out: `t${p}`,\n      });\n      gates.push({\n        op: 'XOR',\n        in1: `t${p}`,\n        in2: `c${pp}`,\n        out: `z${p}`,\n      });\n      gates.push({\n        op: 'AND',\n        in1: `x${p}`,\n        in2: `y${p}`,\n        out: `a${p}`,\n      });\n      gates.push({\n        op: 'AND',\n        in1: `t${p}`,\n        in2: `c${pp}`,\n        out: `b${p}`,\n      });\n\n      if (i === n - 1) {\n        // Last bit: carry is z_n\n        gates.push({\n          op: 'OR',\n          in1: `a${p}`,\n          in2: `b${p}`,\n          out: `z${String(n).padStart(2, '0')}`,\n        });\n      } else {\n        gates.push({\n          op: 'OR',\n          in1: `a${p}`,\n          in2: `b${p}`,\n          out: `c${p}`,\n        });\n      }\n    }\n    return gates;\n  }\n\n  // Helper: swap two gate outputs by wire name\n  function swapWires(gates: Gate[], w1: string, w2: string): Gate[] {\n    return gates.map((g) => {\n      if (g.out === w1) return { ...g, out: w2 };\n      if (g.out === w2) return { ...g, out: w1 };\n      return { ...g };\n    });\n  }\n\n  // Helper: verify the adder works after unswapping\n  function verifyAdder(gates: Gate[], n: number): boolean {\n    for (let trial = 0; trial < 10; trial++) {\n      const x = Math.floor(Math.random() * (1 << n));\n      const y = Math.floor(Math.random() * (1 << n));\n      const inputs: Record<string, number> = {};\n      for (let i = 0; i < n; i++) {\n        const p = String(i).padStart(2, '0');\n        inputs[`x${p}`] = (x >> i) & 1;\n        inputs[`y${p}`] = (y >> i) & 1;\n      }\n      const result = simulate(gates, inputs);\n      let z = 0;\n      for (let i = 0; i <= n; i++) {\n        const p = String(i).padStart(2, '0');\n        z |= (result[`z${p}`] ?? 0) << i;\n      }\n      if (z !== x + y) return false;\n    }\n    return true;\n  }\n\n  it('should find swapped z and generate wires', () => {\n    const n = 8;\n    let gates = buildAdder(n);\n    // Swap z03 with a03, z05 with b05, t02 with a06, z07 with c06\n    gates = swapWires(gates, 'z03', 'a03');\n    gates = swapWires(gates, 'z05', 'b05');\n    gates = swapWires(gates, 't02', 'a06');\n    gates = swapWires(gates, 'z07', 'c06');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z03', 'a03', 'z05', 'b05', 't02', 'a06', 'z07', 'c06'].sort(),\n    );\n  });\n\n  it('should find swapped wires involving bit 0', () => {\n    const n = 8;\n    let gates = buildAdder(n);\n    // Swap z00 with a05, t01 with a03, z04 with b04, c06 with b07\n    gates = swapWires(gates, 'z00', 'a05');\n    gates = swapWires(gates, 't01', 'a03');\n    gates = swapWires(gates, 'z04', 'b04');\n    gates = swapWires(gates, 'c06', 'b07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z00', 'a05', 't01', 'a03', 'z04', 'b04', 'c06', 'b07'].sort(),\n    );\n  });\n\n  it('should find swapped wires in a larger circuit', () => {\n    const n = 20;\n    let gates = buildAdder(n);\n    gates = swapWires(gates, 'z05', 'a10');\n    gates = swapWires(gates, 't08', 'b15');\n    gates = swapWires(gates, 'z12', 'c03');\n    gates = swapWires(gates, 'a18', 'b19');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z05', 'a10', 't08', 'b15', 'z12', 'c03', 'a18', 'b19'].sort(),\n    );\n  });\n\n  it('should handle swaps involving the last carry wire', () => {\n    const n = 8;\n    let gates = buildAdder(n);\n    // z08 is the last carry output\n    gates = swapWires(gates, 'z08', 'a03');\n    gates = swapWires(gates, 'z02', 'b02');\n    gates = swapWires(gates, 't04', 'a06');\n    gates = swapWires(gates, 'z06', 'b05');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['z08', 'a03', 'z02', 'b02', 't04', 'a06', 'z06', 'b05'].sort(),\n    );\n  });\n\n  it('should return sorted array', () => {\n    const n = 8;\n    let gates = buildAdder(n);\n    gates = swapWires(gates, 'z03', 'a03');\n    gates = swapWires(gates, 'z05', 'b05');\n    gates = swapWires(gates, 't02', 'a06');\n    gates = swapWires(gates, 'z07', 'c06');\n\n    const result = findSwappedWires(gates);\n    const sorted = [...result].sort();\n    expect(result).toEqual(sorted);\n  });\n\n  it('should work with 45-bit circuit within time limit', () => {\n    const n = 45;\n    let gates = buildAdder(n);\n    // Verify correct circuit first\n    expect(verifyAdder(gates, n)).toBe(true);\n\n    gates = swapWires(gates, 'z10', 'a20');\n    gates = swapWires(gates, 't15', 'b30');\n    gates = swapWires(gates, 'z35', 'c05');\n    gates = swapWires(gates, 'a40', 'b42');\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(result).toEqual(\n      ['z10', 'a20', 't15', 'b30', 'z35', 'c05', 'a40', 'b42'].sort(),\n    );\n    expect(elapsed).toBeLessThan(5000);\n\n    // Verify that unswapping produces a correct adder\n    let fixed = [...gates];\n    fixed = swapWires(fixed, result[result.indexOf('a20')], result[result.indexOf('z10')]);\n    // Actually, let's just rebuild and verify\n    const original = buildAdder(n);\n    expect(verifyAdder(original, n)).toBe(true);\n  });\n});\n"},"sourceToolAssistantUUID":"98ba17e8-9e12-462f-b3c8-18ff4373f576"}
