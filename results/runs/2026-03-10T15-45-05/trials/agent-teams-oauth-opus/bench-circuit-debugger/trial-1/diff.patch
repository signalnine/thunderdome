+    let prop = propGate ? propGate.out : '';
+
+    let orGate = prop ? find('OR', gen, prop) : undefined;
+
+    if (!orGate && prop) {
+      // gen or prop is swapped - determine which using next-bit validation
+      const withProp = (usedBy.get(prop) || []).find(
+        (g) => g.op === 'OR',
+      );
+      const withGen = (usedBy.get(gen) || []).find(
+        (g) => g.op === 'OR',
+      );
+
+      // The correct OR gate's output should connect to the next bit's XOR
+      let propValid = false;
+      let genValid = false;
+
+      if (i + 1 < N) {
+        const nextP = String(i + 1).padStart(2, '0');
+        const nextPartial = find('XOR', 'x' + nextP, 'y' + nextP)?.out;
+        if (nextPartial) {
+          if (withProp) {
+            propValid = !!find('XOR', nextPartial, withProp.out);
+          }
+          if (withGen) {
+            genValid = !!find('XOR', nextPartial, withGen.out);
+          }
+        }
+      } else {
+        // Last bit: carry should be the last z
+        const lastZ = 'z' + String(N).padStart(2, '0');
+        if (withProp) propValid = withProp.out === lastZ;
+        if (withGen) genValid = withGen.out === lastZ;
+      }
+
+      if (propValid && !genValid && withProp) {
+        // prop is correct, gen is wrong
+        const real =
+          withProp.in1 === prop ? withProp.in2 : withProp.in1;
+        doSwap(gen, real);
+        gen = real;
+        orGate = find('OR', gen, prop);
+      } else if (genValid && !propValid && withGen) {
+        // gen is correct, prop is wrong
+        const real =
+          withGen.in1 === gen ? withGen.in2 : withGen.in1;
+        doSwap(prop, real);
+        prop = real;
+        orGate = find('OR', gen, prop);
+      } else {
+        // Fallback: try whichever OR gate exists
+        if (withProp) {
+          const real =
+            withProp.in1 === prop ? withProp.in2 : withProp.in1;
+          doSwap(gen, real);
+          gen = real;
+          orGate = find('OR', gen, prop);
+        } else if (withGen) {
+          const real =
+            withGen.in1 === gen ? withGen.in2 : withGen.in1;
+          doSwap(prop, real);
+          prop = real;
+          orGate = find('OR', gen, prop);
+        }
+      }
+    }
+
+    if (orGate) carry = orGate.out;
+  }
+
+  // Check last z wire (final carry)
+  const lastZ = 'z' + String(N).padStart(2, '0');
+  if (carry !== lastZ && byOut.has(carry) && byOut.has(lastZ)) {
+    doSwap(carry, lastZ);
+  }
+
+  return swapped.sort();
+}
