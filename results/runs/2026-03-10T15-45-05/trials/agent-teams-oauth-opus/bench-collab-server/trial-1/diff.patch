nst newVersion = currentVersion + 1;\n\n    this.db.prepare(\n      \"UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?\"\n    ).run(content, id);\n\n    this.db.prepare(\n      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'\n    ).run(id, newVersion, content, operation ?? null);\n\n    return newVersion;\n  }\n\n  getLatestVersion(id: string): number {\n    const result = this.db.prepare(\n      'SELECT COALESCE(MAX(version), 0) as version FROM versions WHERE document_id = ?'\n    ).get(id) as { version: number } | undefined;\n    return result?.version ?? 0;\n  }\n\n  getVersionHistory(id: string): Version[] {\n    const stmt = this.db.prepare(\n      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'\n    );\n    return stmt.all(id) as Version[];\n  }\n\n  getVersion(documentId: string, version: number): Version | undefined {\n    const stmt = this.db.prepare(\n      'SELECT * FROM versions WHERE document_id = ? AND version = ?'\n    );\n    return stmt.get(documentId, version) as Version | undefined;\n  }\n\n  getOperationsSinceVersion(documentId: string, sinceVersion: number): Version[] {\n    const stmt = this.db.prepare(\n      'SELECT * FROM versions WHERE document_id = ? AND version > ? ORDER BY version ASC'\n    );\n    return stmt.all(documentId, sinceVersion) as Version[];\n  }\n\n  close(): void {\n    this.db.close();\n  }\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"21eae1de-ee78-4c1f-93eb-0551ce85314b"}
