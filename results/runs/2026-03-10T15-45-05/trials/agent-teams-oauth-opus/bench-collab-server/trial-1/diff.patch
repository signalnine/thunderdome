@@ -0,0 +1,123 @@
+import { Operation } from './types.js';
+
+/**
+ * Operational Transform engine.
+ *
+ * Transforms operation A against operation B such that
+ * applying B then A' (transformed) yields the same result
+ * as applying A then B' (transformed).
+ */
+
+/**
+ * Transform operationA against operationB.
+ * Returns the transformed version of operationA that should be applied
+ * after operationB has already been applied.
+ */
+export function transformOperation(opA: Operation, opB: Operation): Operation {
+  const a = { ...opA };
+
+  if (a.type === 'insert' && opB.type === 'insert') {
+    // Both inserts
+    if (a.position > opB.position || (a.position === opB.position && a.type === 'insert' && opB.type === 'insert')) {
+      // If A's position is at or after B's insert, shift A forward by B's inserted length
+      if (a.position > opB.position) {
+        a.position += (opB.text?.length ?? 0);
+      }
+      // If same position, B goes first (tie-breaking), so shift A
+      else if (a.position === opB.position) {
+        a.position += (opB.text?.length ?? 0);
+      }
+    }
+  } else if (a.type === 'insert' && opB.type === 'delete') {
+    const deleteLen = opB.length ?? opB.text?.length ?? 0;
+    if (a.position > opB.position) {
+      // Shift insert position back by the number of deleted characters
+      a.position = Math.max(opB.position, a.position - deleteLen);
+    }
+  } else if (a.type === 'delete' && opB.type === 'insert') {
+    const deleteLen = a.length ?? a.text?.length ?? 0;
+    const insertLen = opB.text?.length ?? 0;
+    if (a.position >= opB.position) {
+      // Shift delete position forward by inserted text length
+      a.position += insertLen;
+    } else if (a.position + deleteLen > opB.position) {
+      // The delete range spans the insert point - split is complex,
+      // but for simplicity we keep the delete as-is shifted
+      // The delete straddles the insert. We don't change position but length stays same.
+    }
+  } else if (a.type === 'delete' && opB.type === 'delete') {
+    const aLen = a.length ?? a.text?.length ?? 0;
+    const bLen = opB.length ?? opB.text?.length ?? 0;
+
+    if (a.position >= opB.position + bLen) {
+      // A is entirely after B's deletion range
+      a.position -= bLen;
+    } else if (a.position + aLen <= opB.position) {
+      // A is entirely before B's deletion range - no change needed
+    } else {
+      // Overlapping deletes
+      const aEnd = a.position + aLen;
+      const bEnd = opB.position + bLen;
+
+      // The portion of A's delete that wasn't already deleted by B
+      const overlapStart = Math.max(a.position, opB.position);
+      const overlapEnd = Math.min(aEnd, bEnd);
+      const overlapLen = Math.max(0, overlapEnd - overlapStart);
+
+      a.position = Math.min(a.position, opB.position);
+      const newLen = aLen - overlapLen;
+
+      if (a.position >= opB.position) {
+        a.position = opB.position;
+      }
+      // Adjust position: if A starts after B, shift back
+      if (opA.position > opB.position) {
+        a.position = opB.position;
+      }
+
+      if (a.text !== undefined) {
+        // Reconstruct text if possible - just set length
+        a.text = undefined;
+      }
+      a.length = newLen;
+
+      if (newLen <= 0) {
+        // Nothing left to delete
+        a.length = 0;
+      }
+    }
+  }
+
+  return a;
+}
+
+/**
+ * Apply an operation to a document string.
+ * Returns the new document content.
+ */
+export function applyOperation(content: string, op: Operation): string {
+  if (op.type === 'insert') {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    const text = op.text ?? '';
+    return content.slice(0, pos) + text + content.slice(pos);
+  } else if (op.type === 'delete') {
+    const pos = Math.min(Math.max(0, op.position), content.length);
+    const len = op.length ?? op.text?.length ?? 0;
+    if (len <= 0) return content;
+    const end = Math.min(pos + len, content.length);
+    return content.slice(0, pos) + content.slice(end);
+  }
+  return content;
+}
+
+/**
+ * Transform an operation against all operations that have been applied
+ * between the operation's base version and the current version.
+ */
+export function transformAgainstHistory(op: Operation, history: Operation[]): Operation {
+  let transformed = { ...op };
+  for (const pastOp of history) {
+    transformed = transformOperation(transformed, pastOp);
+  }
+  return transformed;
+}
