@@ -0,0 +1,60 @@
+import express from 'express';
+import { createServer, Server } from 'http';
+import { DocumentDB } from './db.js';
+import { createRouter } from './routes.js';
+import { CollaborationServer } from './websocket.js';
+
+export interface AppInstance {
+  app: express.Express;
+  server: Server;
+  db: DocumentDB;
+  collaboration: CollaborationServer;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = new DocumentDB(dbPath ?? ':memory:');
+  const app = express();
+  app.use(express.json());
+
+  const router = createRouter(db);
+  app.use('/api', router);
+  // Also mount at root for convenience
+  app.use(router);
+
+  const server = createServer(app);
+  const collaboration = new CollaborationServer(server, db);
+
+  const instance: AppInstance = {
+    app,
+    server,
+    db,
+    collaboration,
+
+    async start(port?: number): Promise<number> {
+      return new Promise((resolve) => {
+        server.listen(port ?? 0, () => {
+          const addr = server.address();
+          const actualPort = typeof addr === 'object' && addr ? addr.port : 0;
+          resolve(actualPort);
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      return new Promise((resolve, reject) => {
+        collaboration.closeAll();
+        server.close((err) => {
+          db.close();
+          if (err) reject(err);
+          else resolve();
+        });
+      });
+    },
+  };
+
+  return instance;
+}
+
+export default createApp;
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
