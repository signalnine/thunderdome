support /docId directly\n        documentId = pathParts[0];\n      }\n\n      if (!documentId) {\n        socket.write('HTTP/1.1 400 Bad Request\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      // Check if document exists\n      const doc = this.db.getDocument(documentId);\n      if (!doc) {\n        socket.write('HTTP/1.1 404 Not Found\\r\\n\\r\\n');\n        socket.destroy();\n        return;\n      }\n\n      this.wss.handleUpgrade(request, socket, head, (ws) => {\n        this.wss.emit('connection', ws, request, documentId);\n      });\n    });\n\n    this.wss.on('connection', (ws: WebSocket, _request: IncomingMessage, documentId: string) => {\n      this.handleConnection(ws, documentId);\n    });\n  }\n\n  private handleConnection(ws: WebSocket, documentId: string): void {\n    const clientId = crypto.randomUUID();\n    const client: Client = { id: clientId, ws, documentId };\n\n    this.clients.set(clientId, client);\n\n    if (!this.documentClients.has(documentId)) {\n      this.documentClients.set(documentId, new Set());\n    }\n    this.documentClients.get(documentId)!.add(clientId);\n\n    // Initialize operation history for this document if needed\n    if (!this.operationHistory.has(documentId)) {\n      this.operationHistory.set(documentId, []);\n    }\n\n    // Send current document state to the new client\n    const doc = this.db.getDocument(documentId);\n    if (doc) {\n      const version = this.db.getLatestVersion(documentId);\n      const syncMessage: WSMessage = {\n        type: 'sync',\n        documentId,\n        content: doc.content,\n        version,\n        clientId,\n      };\n      ws.send(JSON.stringify(syncMessage));\n    }\n\n    ws.on('message', (data) => {\n      try {\n        const message = JSON.parse(data.toString()) as WSMessage;\n        this.handleMessage(client, message);\n      } catch (err) {\n        const errorMsg: WSMessage = {\n          type: 'error',\n          message: 'Invalid message format: ' + (err instanceof Error ? err.message : String(err)),\n        };\n        ws.send(JSON.stringify(errorMsg));\n      }\n    });\n\n    ws.on('close', () => {\n      this.clients.delete(clientId);\n      const docClients = this.documentClients.get(documentId);\n      if (docClients) {\n        docClients.delete(clientId);\n        if (docClients.size === 0) {\n          this.documentClients.delete(documentId);\n          // Keep operation history in case clients reconnect\n        }\n      }\n    });\n\n    ws.on('error', () => {\n      this.clients.delete(clientId);\n      const docClients = this.documentClients.get(documentId);\n      if (docClients) {\n        docClients.delete(clientId);\n      }\n    });\n  }\n\n  private handleMessage(client: Client, message: WSMessage): void {\n    if (message.type === 'operation') {\n      this.handleOperation(client, message);\n    }\n  }\n\n  private handleOperation(client: Client, message: WSMessage): void {\n    const { documentId } = client;\n    const operation = message.operation;\n\n    if (!operation) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: 'Operation is required',\n      }));\n      return;\n    }\n\n    // Validate operation\n    if (!this.validateOperation(operation)) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: 'Invalid operation: must have type (insert/delete), position (>= 0), and text (for insert) or length (for delete)',\n      }));\n      return;\n    }\n\n    const doc = this.db.getDocument(documentId);\n    if (!doc) {\n      client.ws.send(JSON.stringify({\n        type: 'error',\n        message: 'Document not found',\n      }));\n      return;\n    }\n\n    const currentVersion = this.db.getLatestVersion(documentId);\n    const opVersion = operation.version ?? 0;\n    let transformedOp = { ...operation };\n\n    // Transform against any operations that happened after the operation's base version\n    if (opVersion < currentVersion) {\n      const missedVersions = this.db.getOperationsSinceVersion(documentId, opVersion);\n      for (const v of missedVersions) {\n        if (v.operation) {\n          try {\n            const pastOp = JSON.parse(v.operation) as Operation;\n            transformedOp = transformOperation(transformedOp, pastOp);\n          } catch {\n            // Skip invalid stored operations\n          }\n        }\n      }\n    }\n\n    // Apply the (possibly transformed) operation\n    const newContent = applyOperation(doc.content, transformedOp);\n\n    // Store in DB\n    const newVersion = this.db.updateDocumentContent(\n      documentId,\n      newContent,\n      JSON.stringify(transformedOp)\n    );\n\n    // Track in in-memory history too\n    const history = this.operationHistory.get(documentId) ?? [];\n    history.push({ ...transformedOp, version: newVersion });\n    this.operationHistory.set(documentId, history);\n\n    // Send ack to the sender\n    const ack: WSMessage = {\n      type: 'ack',\n      version: newVersion,\n      documentId,\n    };\n    client.ws.send(JSON.stringify(ack));\n\n    // Broadcast to other clients\n    const docClients = this.documentClients.get(documentId);\n    if (docClients) {\n      const broadcastMsg: WSMessage = {\n        type: 'operation',\n        documentId,\n        operation: { ...transformedOp, version: newVersion },\n        version: newVersion,\n        clientId: client.id,\n      };\n      const broadcastStr = JSON.stringify(broadcastMsg);\n\n      for (const cid of docClients) {\n        if (cid !== client.id) {\n          const c = this.clients.get(cid);\n          if (c && c.ws.readyState === WebSocket.OPEN) {\n            c.ws.send(broadcastStr);\n          }\n        }\n      }\n    }\n  }\n\n  private validateOperation(op: Operation): boolean {\n    if (!op || typeof op !== 'object') return false;\n    if (op.type !== 'insert' && op.type !== 'delete') return false;\n    if (typeof op.position !== 'number' || op.position < 0) return false;\n    if (!Number.isInteger(op.position)) return false;\n\n    if (op.type === 'insert') {\n      if (typeof op.text !== 'string' || op.text.length === 0) return false;\n    } else if (op.type === 'delete') {\n      const len = op.length ?? op.text?.length;\n      if (len === undefined || len <= 0) return false;\n    }\n\n    return true;\n  }\n\n  closeAll(): void {\n    for (const [, client] of this.clients) {\n      client.ws.close();\n    }\n    this.clients.clear();\n    this.documentClients.clear();\n    this.wss.close();\n  }\n}\n"},"sourceToolAssistantUUID":"77be22ea-0b54-4672-bb9a-605a9eed830c"}
