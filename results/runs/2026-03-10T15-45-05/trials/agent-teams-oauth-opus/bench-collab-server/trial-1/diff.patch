// Nothing left to delete\n        a.length = 0;\n      }\n    }\n  }\n\n  return a;\n}\n\n/**\n * Apply an operation to a document string.\n * Returns the new document content.\n */\nexport function applyOperation(content: string, op: Operation): string {\n  if (op.type === 'insert') {\n    const pos = Math.min(Math.max(0, op.position), content.length);\n    const text = op.text ?? '';\n    return content.slice(0, pos) + text + content.slice(pos);\n  } else if (op.type === 'delete') {\n    const pos = Math.min(Math.max(0, op.position), content.length);\n    const len = op.length ?? op.text?.length ?? 0;\n    if (len <= 0) return content;\n    const end = Math.min(pos + len, content.length);\n    return content.slice(0, pos) + content.slice(end);\n  }\n  return content;\n}\n\n/**\n * Transform an operation against all operations that have been applied\n * between the operation's base version and the current version.\n */\nexport function transformAgainstHistory(op: Operation, history: Operation[]): Operation {\n  let transformed = { ...op };\n  for (const pastOp of history) {\n    transformed = transformOperation(transformed, pastOp);\n  }\n  return transformed;\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"47af6345-518c-428f-862b-3de4f8839999"}
