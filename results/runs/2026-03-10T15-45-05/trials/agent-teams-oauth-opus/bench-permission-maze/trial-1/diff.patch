er ${aliceToken}`)\n        .send({ name: 'Parent' });\n\n      // Share parent with bob\n      await request(app)\n        .post(`/folders/${parent.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'viewer' });\n\n      const child = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Child', parentId: parent.body.id });\n\n      // Bob can read child folder through parent access\n      const get = await request(app)\n        .get(`/folders/${child.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(get.status).toBe(200);\n    });\n\n    it('most permissive role wins across multiple paths', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      const doc = await request(app)\n        .post(`/folders/${folder.body.id}/documents`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'text' });\n\n      // Share folder with bob as viewer\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'viewer' });\n\n      // Share doc directly with bob as editor\n      await request(app)\n        .post(`/documents/${doc.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'editor' });\n\n      // Bob should be able to edit (editor wins over viewer)\n      const update = await request(app)\n        .put(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ content: 'updated' });\n\n      expect(update.status).toBe(200);\n    });\n  });\n\n  describe('Validation', () => {\n    it('rejects sharing with non-existent user', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      const share = await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: 'nonexistent', role: 'viewer' });\n\n      expect(share.status).toBe(404);\n    });\n\n    it('rejects invalid role', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      const share = await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'admin' });\n\n      expect(share.status).toBe(400);\n    });\n\n    it('rejects sharing non-existent folder', async () => {\n      const share = await request(app)\n        .post('/folders/nonexistent/share')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'viewer' });\n\n      expect(share.status).toBe(404);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"ef6b898d-f40a-42ae-8c53-004dacbc0ac8"}
