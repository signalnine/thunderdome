+
+async function registerAndLogin(app: Express, username: string, password = 'pass') {
+  await request(app).post('/auth/register').send({ username, password });
+  const res = await request(app).post('/auth/login').send({ username, password });
+  return { token: res.body.token as string, userId: res.body.userId as string };
+}
+
+describe('Sharing & Permissions', () => {
+  let app: Express;
+  let aliceToken: string;
+  let aliceId: string;
+  let bobToken: string;
+  let bobId: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    const alice = await registerAndLogin(app, 'alice');
+    aliceToken = alice.token;
+    aliceId = alice.userId;
+    const bob = await registerAndLogin(app, 'bob');
+    bobToken = bob.token;
+    bobId = bob.userId;
+  });
+
+  describe('Folder sharing', () => {
+    it('owner can share folder as viewer', async () => {
+      const folder = await request(app)
+        .post('/folders')
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ name: 'Shared' });
+
+      const share = await request(app)
+        .post(`/folders/${folder.body.id}/share`)
+        .set('Authorization', `Bearer ${aliceToken}`)
+        .send({ targetUserId: bobId, role: 'viewer' });
+
+      expect(share.status).toBe(201);
+
+      // Bob can now read the folder
+      const get = await request(app)
+        .get(`/folders/${folder.body.id}`)
+        .set('Authorization', `Bearer ${bobToken}`);
+
