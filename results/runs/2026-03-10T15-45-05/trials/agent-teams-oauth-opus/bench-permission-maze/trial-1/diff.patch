+import { describe, it, expect, beforeEach } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../src/app.js';
+import type { Express } from 'express';
+
+async function registerAndLogin(app: Express, username: string, password = 'pass') {
+  await request(app).post('/auth/register').send({ username, password });
+  const res = await request(app).post('/auth/login').send({ username, password });
+  return { token: res.body.token as string, userId: res.body.userId as string };
+}
+
+describe('Activity Log', () => {
+  let app: Express;
+  let token: string;
+
+  beforeEach(async () => {
+    app = createApp();
+    const auth = await registerAndLogin(app, 'alice');
+    token = auth.token;
+  });
+
+  it('should start empty', async () => {
+    const res = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(res.status).toBe(200);
+    expect(res.body).toEqual([]);
+  });
+
+  it('should log document creation', async () => {
+    const folder = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Folder' });
+
+    await request(app)
+      .post(`/folders/${folder.body.id}/documents`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Doc', content: 'text' });
+
+    const log = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(log.body.length).toBe(1);
+    expect(log.body[0].action).toBe('document_created');
+    expect(log.body[0].resourceType).toBe('document');
+    expect(log.body[0]).toHaveProperty('timestamp');
+  });
+
+  it('should log document updates', async () => {
+    const folder = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Folder' });
+
+    const doc = await request(app)
+      .post(`/folders/${folder.body.id}/documents`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Doc', content: 'text' });
+
+    await request(app)
+      .put(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ content: 'updated' });
+
+    const log = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(log.body.length).toBe(2);
+    expect(log.body[1].action).toBe('document_updated');
+  });
+
+  it('should log document deletion', async () => {
+    const folder = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Folder' });
+
+    const doc = await request(app)
+      .post(`/folders/${folder.body.id}/documents`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ title: 'Doc', content: 'text' });
+
+    await request(app)
+      .delete(`/documents/${doc.body.id}`)
+      .set('Authorization', `Bearer ${token}`);
+
+    const log = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(log.body.length).toBe(2);
+    expect(log.body[1].action).toBe('document_deleted');
+  });
+
+  it('should log sharing events', async () => {
+    const bob = await registerAndLogin(app, 'bob');
+
+    const folder = await request(app)
+      .post('/folders')
+      .set('Authorization', `Bearer ${token}`)
+      .send({ name: 'Folder' });
+
+    await request(app)
+      .post(`/folders/${folder.body.id}/share`)
+      .set('Authorization', `Bearer ${token}`)
+      .send({ targetUserId: bob.userId, role: 'viewer' });
+
+    const log = await request(app)
+      .get('/activity')
+      .set('Authorization', `Bearer ${token}`);
+
+    expect(log.body.length).toBe(1);
+    expect(log.body[0].action).toBe('shared');
+    expect(log.body[0].resourceType).toBe('folder');
+  });
+
+  it('should require auth', async () => {
+    const res = await request(app).get('/activity');
+    expect(res.status).toBe(401);
+  });
+});
