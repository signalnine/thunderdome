bId, role: 'viewer' });\n\n      expect(share.status).toBe(201);\n\n      // Bob can now read the folder\n      const get = await request(app)\n        .get(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(get.status).toBe(200);\n    });\n\n    it('viewer cannot modify folder', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared' });\n\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'viewer' });\n\n      const update = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Renamed' });\n\n      expect(update.status).toBe(403);\n    });\n\n    it('editor can modify folder', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared' });\n\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'editor' });\n\n      const update = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ name: 'Renamed' });\n\n      expect(update.status).toBe(200);\n      expect(update.body.name).toBe('Renamed');\n    });\n\n    it('viewer cannot delete folder', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared' });\n\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'editor' });\n\n      const del = await request(app)\n        .delete(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(del.status).toBe(403);\n    });\n\n    it('viewer cannot share', async () => {\n      const charlie = await registerAndLogin(app, 'charlie');\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared' });\n\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'viewer' });\n\n      const share = await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ targetUserId: charlie.userId, role: 'viewer' });\n\n      expect(share.status).toBe(403);\n    });\n\n    it('editor can share with viewer/editor', async () => {\n      const charlie = await registerAndLogin(app, 'charlie');\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared' });\n\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'editor' });\n\n      const share = await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ targetUserId: charlie.userId, role: 'viewer' });\n\n      expect(share.status).toBe(201);\n    });\n\n    it('editor cannot assign owner role', async () => {\n      const charlie = await registerAndLogin(app, 'charlie');\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Shared' });\n\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'editor' });\n\n      const share = await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${bobToken}`)\n        .send({ targetUserId: charlie.userId, role: 'owner' });\n\n      expect(share.status).toBe(403);\n    });\n  });\n\n  describe('Document sharing', () => {\n    it('owner can share document', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      const doc = await request(app)\n        .post(`/folders/${folder.body.id}/documents`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'text' });\n\n      const share = await request(app)\n        .post(`/documents/${doc.body.id}/share`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ targetUserId: bobId, role: 'viewer' });\n\n      expect(share.status).toBe(201);\n\n      // Bob can read the doc\n      const get = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(get.status).toBe(200);\n    });\n\n    it('user without access cannot read document', async () => {\n      const folder = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ name: 'Folder' });\n\n      const doc = await request(app)\n        .post(`/folders/${folder.body.id}/documents`)\n        .set('Authorization', `Bearer ${aliceToken}`)\n        .send({ title: 'Doc', content: 'secret' });\n\n      const get = await request(app)\n        .get(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${bobToken}`);\n\n      expect(get.status).toBe(403);\n    });\n  });\n\n  describe('Permission inheritance', () => {\n    it('folder viewer