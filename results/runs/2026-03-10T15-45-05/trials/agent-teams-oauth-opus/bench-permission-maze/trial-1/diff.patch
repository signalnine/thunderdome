new file mode 100644
index 0000000..73456d3
--- /dev/null
+++ b/src/store.ts
@@ -0,0 +1,104 @@
+import crypto from 'node:crypto';
+import { User, Folder, Document, Permission, ActivityEntry, Role } from './types.js';
+
+const ROLE_LEVEL: Record<Role, number> = { viewer: 1, editor: 2, owner: 3 };
+
+export class Store {
+  users = new Map<string, User>();
+  tokens = new Map<string, string>(); // token -> userId
+  folders = new Map<string, Folder>();
+  documents = new Map<string, Document>();
+  permissions: Permission[] = [];
+  activity: ActivityEntry[] = [];
+
+  genId(): string {
+    return crypto.randomUUID();
+  }
+
+  // ---------- users ----------
+  findUserByUsername(username: string): User | undefined {
+    for (const u of this.users.values()) {
+      if (u.username === username) return u;
+    }
+    return undefined;
+  }
+
+  getUserByToken(token: string): User | undefined {
+    const userId = this.tokens.get(token);
+    if (!userId) return undefined;
+    return this.users.get(userId);
+  }
+
+  // ---------- permissions ----------
+  private directRoles(userId: string, resourceType: 'folder' | 'document', resourceId: string): Role[] {
+    return this.permissions
+      .filter(p => p.userId === userId && p.resourceType === resourceType && p.resourceId === resourceId)
+      .map(p => p.role);
+  }
+
+  private bestRole(roles: Role[]): Role | null {
+    if (roles.length === 0) return null;
+    let best = roles[0];
+    for (let i = 1; i < roles.length; i++) {
+      if (ROLE_LEVEL[roles[i]] > ROLE_LEVEL[best]) best = roles[i];
+    }
+    return best;
+  }
+
+  getFolderRole(userId: string, folderId: string): Role | null {
+    const folder = this.folders.get(folderId);
+    if (!folder) return null;
+
+    const roles: Role[] = [];
+
+    if (folder.ownerId === userId) roles.push('owner');
+    roles.push(...this.directRoles(userId, 'folder', folderId));
+
+    // inherit from parent
+    if (folder.parentId) {
+      const parentRole = this.getFolderRole(userId, folder.parentId);
+      if (parentRole) roles.push(parentRole);
+    }
+
+    return this.bestRole(roles);
+  }
+
+  getDocumentRole(userId: string, docId: string): Role | null {
+    const doc = this.documents.get(docId);
+    if (!doc) return null;
+
+    const roles: Role[] = [];
+
+    if (doc.ownerId === userId) roles.push('owner');
+    roles.push(...this.directRoles(userId, 'document', docId));
+
+    // inherit from folder
+    const folderRole = this.getFolderRole(userId, doc.folderId);
+    if (folderRole) roles.push(folderRole);
+
+    return this.bestRole(roles);
+  }
+
+  getEffectiveRole(userId: string, resourceType: 'folder' | 'document', resourceId: string): Role | null {
+    if (resourceType === 'folder') return this.getFolderRole(userId, resourceId);
+    return this.getDocumentRole(userId, resourceId);
+  }
+
+  hasAtLeast(userId: string, resourceType: 'folder' | 'document', resourceId: string, minRole: Role): boolean {
+    const role = this.getEffectiveRole(userId, resourceType, resourceId);
+    if (!role) return false;
+    return ROLE_LEVEL[role] >= ROLE_LEVEL[minRole];
+  }
+
+  // ---------- activity ----------
+  logActivity(action: string, userId: string, resourceType: 'folder' | 'document', resourceId: string): void {
+    this.activity.push({
+      id: this.genId(),
+      action,
+      userId,
+      resourceType,
+      resourceId,
+      timestamp: new Date().toISOString(),
+    });
+  }
+}
