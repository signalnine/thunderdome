+{"parentUuid":"c069ec0a-ecd4-4551-91a3-c72dfd9bd581","isSidechain":false,"userType":"external","cwd":"/workspace","sessionId":"9272d212-7307-4f71-88ce-a26d5ca00721","version":"2.1.63","gitBranch":"HEAD","slug":"cheeky-waddling-yao","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014C4i59TpdQwPHapMSePopK","type":"tool_result","content":"File created successfully at: /workspace/src/routes/folders.ts"}]},"uuid":"6c2e83b8-3e97-46de-939b-d57298ac0d10","timestamp":"2026-03-10T16:40:22.945Z","toolUseResult":{"type":"create","filePath":"/workspace/src/routes/folders.ts","content":"import { Router, Response } from 'express';\nimport { Store } from '../store.js';\nimport { AuthRequest } from '../middleware.js';\n\nexport function createFolderRoutes(store: Store): Router {\n  const router = Router();\n\n  // Create folder\n  router.post('/', (req, res: Response): void => {\n    const { userId } = req as AuthRequest;\n    const { name, parentId } = req.body;\n\n    if (!name) {\n      res.status(400).json({ error: 'Folder name is required' });\n      return;\n    }\n\n    if (parentId) {\n      const parent = store.folders.get(parentId);\n      if (!parent) {\n        res.status(404).json({ error: 'Parent folder not found' });\n        return;\n      }\n      if (!store.hasAtLeast(userId, 'folder', parentId, 'editor')) {\n        res.status(403).json({ error: 'Insufficient permissions on parent folder' });\n        return;\n      }\n    }\n\n    const id = store.genId();\n    const folder = {\n      id,\n      name,\n      parentId: parentId || null,\n      ownerId: userId,\n      createdAt: new Date().toISOString(),\n    };\n    store.folders.set(id, folder);\n    res.status(201).json(folder);\n  });\n\n  // Get folder\n  router.get('/:id', (req, res: Response): void => {\n    const { userId } = req as AuthRequest;\n    const folder = store.folders.get(req.params.id);\n\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    if (!store.hasAtLeast(userId, 'folder', folder.id, 'viewer')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    res.json(folder);\n  });\n\n  // Update folder\n  router.put('/:id', (req, res: Response): void => {\n    const { userId } = req as AuthRequest;\n    const folder = store.folders.get(req.params.id);\n\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    if (!store.hasAtLeast(userId, 'folder', folder.id, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions' });\n      return;\n    }\n\n    if (req.body.name) folder.name = req.body.name;\n    res.json(folder);\n  });\n\n  // Delete folder\n  router.delete('/:id', (req, res: Response): void => {\n    const { userId } = req as AuthRequest;\n    const folder = store.folders.get(req.params.id);\n\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    if (!store.hasAtLeast(userId, 'folder', folder.id, 'owner')) {\n      res.status(403).json({ error: 'Only owners can delete folders' });\n      return;\n    }\n\n    store.folders.delete(folder.id);\n    // Clean up child folders, documents, and permissions\n    for (const [fId, f] of store.folders) {\n      if (f.parentId === folder.id) store.folders.delete(fId);\n    }\n    for (const [dId, d] of store.documents) {\n      if (d.folderId === folder.id) store.documents.delete(dId);\n    }\n    store.permissions = store.permissions.filter(\n      p => !(p.resourceType === 'folder' && p.resourceId === folder.id)\n    );\n\n    res.status(204).send();\n  });\n\n  // Create document inside folder\n  router.post('/:folderId/documents', (req, res: Response): void => {\n    const { userId } = req as AuthRequest;\n    const { folderId } = req.params;\n    const { title, content } = req.body;\n\n    const folder = store.folders.get(folderId);\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n    if (!store.hasAtLeast(userId, 'folder', folderId, 'editor')) {\n      res.status(403).json({ error: 'Insufficient permissions on folder' });\n      return;\n    }\n    if (!title) {\n      res.status(400).json({ error: 'Document title is required' });\n      return;\n    }\n\n    const id = store.genId();\n    const now = new Date().toISOString();\n    const doc = {\n      id,\n      title,\n      content: content || '',\n      folderId,\n      ownerId: userId,\n      createdAt: now,\n      updatedAt: now,\n    };\n    store.documents.set(id, doc);\n    store.logActivity('document_created', userId, 'document', id);\n    res.status(201).json(doc);\n  });\n\n  // Share folder\n  router.post('/:id/share', (req, res: Response): void => {\n    const { userId } = req as AuthRequest;\n    const folder = store.folders.get(req.params.id);\n\n    if (!folder) {\n      res.status(404).json({ error: 'Folder not found' });\n      return;\n    }\n\n    const { targetUserId, role } = req.body;\n    if (!targetUserId || !role) {\n      res.status(400).json({ error: 'targetUserId and role are required' });\n      return;\n    }\n    if (!['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'Invalid role' });\n      return;\n    }\n    if (!store.users.has(targetUserId)) {\n      res.status(404).json({ error: 'Target user not found' });\n      return;\n    }\n\n    // Check sharer's permission\n    const sharerRole = store.getEffectiveRole(userId, 'folder', folder.id);\n    if (!sharerRole || (sharerRole === 'viewer')) {\n      res.status(403).json({ error: 'Insufficient permissions to share' });\n      return;\n    }\n    // Only owners can assign owner role\n    if (role === 'owner' && sharerRole !== 'owner') {\n      res.status(403).json({ error: 'Only owners can assign owner role' });\n      return;\n    }\n\n    const permId = store.genId();\n    const perm = {\n      id: permId,\n      resourceType: 'folder' as const,\n      resourceId: folder.id,\n      userId: targetUserId,\n      role,\n    };\n    store.permissions.push(perm);\n    store.logActivity('shared', userId, 'folder', folder.id);\n    res.status(201).json(perm);\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"c069ec0a-ecd4-4551-91a3-c72dfd9bd581"}
