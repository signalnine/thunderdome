diff --git a/src/app.ts b/src/app.ts
new file mode 100644
index 0000000..6988e6e
--- /dev/null
+++ b/src/app.ts
@@ -0,0 +1,25 @@
+import express from 'express';
+import { Store } from './store.js';
+import { authMiddleware } from './middleware.js';
+import { createAuthRoutes } from './routes/auth.js';
+import { createFolderRoutes } from './routes/folders.js';
+import { createDocumentRoutes } from './routes/documents.js';
+import { createActivityRoutes } from './routes/activity.js';
+
+export function createApp() {
+  const app = express();
+  const store = new Store();
+
+  app.use(express.json());
+
+  // Public routes
+  app.use('/auth', createAuthRoutes(store));
+
+  // Protected routes
+  const auth = authMiddleware(store);
+  app.use('/folders', auth, createFolderRoutes(store));
+  app.use('/documents', auth, createDocumentRoutes(store));
+  app.use('/activity', auth, createActivityRoutes(store));
+
+  return app;
+}
diff --git a/src/middleware.ts b/src/middleware.ts
new file mode 100644
index 0000000..dedba97
--- /dev/null
+++ b/src/middleware.ts
@@ -0,0 +1,20 @@
+import { Request, Response, NextFunction } from 'express';
+import { Store } from './store.js';
+
+export function authMiddleware(store: Store) {
+  return (req: Request, res: Response, next: NextFunction): void => {
+    const header = req.headers.authorization;
+    if (!header || !header.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+    const token = header.slice(7);
+    const user = store.getUserByToken(token);
+    if (!user) {
+      res.status(401).json({ error: 'Invalid token' });
+      return;
+    }
+    res.locals.userId = user.id;
+    next();
+  };
+}
