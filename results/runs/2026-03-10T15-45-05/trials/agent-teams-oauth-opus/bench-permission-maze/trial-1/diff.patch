ctivity')\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(log.body.length).toBe(1);\n    expect(log.body[0].action).toBe('document_created');\n    expect(log.body[0].resourceType).toBe('document');\n    expect(log.body[0]).toHaveProperty('timestamp');\n  });\n\n  it('should log document updates', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Folder' });\n\n    const doc = await request(app)\n      .post(`/folders/${folder.body.id}/documents`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Doc', content: 'text' });\n\n    await request(app)\n      .put(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ content: 'updated' });\n\n    const log = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(log.body.length).toBe(2);\n    expect(log.body[1].action).toBe('document_updated');\n  });\n\n  it('should log document deletion', async () => {\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Folder' });\n\n    const doc = await request(app)\n      .post(`/folders/${folder.body.id}/documents`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ title: 'Doc', content: 'text' });\n\n    await request(app)\n      .delete(`/documents/${doc.body.id}`)\n      .set('Authorization', `Bearer ${token}`);\n\n    const log = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(log.body.length).toBe(2);\n    expect(log.body[1].action).toBe('document_deleted');\n  });\n\n  it('should log sharing events', async () => {\n    const bob = await registerAndLogin(app, 'bob');\n\n    const folder = await request(app)\n      .post('/folders')\n      .set('Authorization', `Bearer ${token}`)\n      .send({ name: 'Folder' });\n\n    await request(app)\n      .post(`/folders/${folder.body.id}/share`)\n      .set('Authorization', `Bearer ${token}`)\n      .send({ targetUserId: bob.userId, role: 'viewer' });\n\n    const log = await request(app)\n      .get('/activity')\n      .set('Authorization', `Bearer ${token}`);\n\n    expect(log.body.length).toBe(1);\n    expect(log.body[0].action).toBe('shared');\n    expect(log.body[0].resourceType).toBe('folder');\n  });\n\n  it('should require auth', async () => {\n    const res = await request(app).get('/activity');\n    expect(res.status).toBe(401);\n  });\n});\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"d066cb61-199c-4c38-a420-9233cbaa1cfd"}
