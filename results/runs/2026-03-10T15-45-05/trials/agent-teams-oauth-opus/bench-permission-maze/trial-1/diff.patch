      if (ROLE_LEVEL[roles[i]] > ROLE_LEVEL[best]) best = roles[i];\n    }\n    return best;\n  }\n\n  getFolderRole(userId: string, folderId: string): Role | null {\n    const folder = this.folders.get(folderId);\n    if (!folder) return null;\n\n    const roles: Role[] = [];\n\n    if (folder.ownerId === userId) roles.push('owner');\n    roles.push(...this.directRoles(userId, 'folder', folderId));\n\n    // inherit from parent\n    if (folder.parentId) {\n      const parentRole = this.getFolderRole(userId, folder.parentId);\n      if (parentRole) roles.push(parentRole);\n    }\n\n    return this.bestRole(roles);\n  }\n\n  getDocumentRole(userId: string, docId: string): Role | null {\n    const doc = this.documents.get(docId);\n    if (!doc) return null;\n\n    const roles: Role[] = [];\n\n    if (doc.ownerId === userId) roles.push('owner');\n    roles.push(...this.directRoles(userId, 'document', docId));\n\n    // inherit from folder\n    const folderRole = this.getFolderRole(userId, doc.folderId);\n    if (folderRole) roles.push(folderRole);\n\n    return this.bestRole(roles);\n  }\n\n  getEffectiveRole(userId: string, resourceType: 'folder' | 'document', resourceId: string): Role | null {\n    if (resourceType === 'folder') return this.getFolderRole(userId, resourceId);\n    return this.getDocumentRole(userId, resourceId);\n  }\n\n  hasAtLeast(userId: string, resourceType: 'folder' | 'document', resourceId: string, minRole: Role): boolean {\n    const role = this.getEffectiveRole(userId, resourceType, resourceId);\n    if (!role) return false;\n    return ROLE_LEVEL[role] >= ROLE_LEVEL[minRole];\n  }\n\n  // ---------- activity ----------\n  logActivity(action: string, userId: string, resourceType: 'folder' | 'document', resourceId: string): void {\n    this.activity.push({\n      id: this.genId(),\n      action,\n      userId,\n      resourceType,\n      resourceId,\n      timestamp: new Date().toISOString(),\n    });\n  }\n}\n","structuredPatch":[],"originalFile":null},"sourceToolAssistantUUID":"38d85789-f632-4047-a8e8-bf5a370e85dc"}
