+}
diff --git a/src/routes/auth.ts b/src/routes/auth.ts
new file mode 100644
index 0000000..f182b6e
--- /dev/null
+++ b/src/routes/auth.ts
@@ -0,0 +1,41 @@
+import { Router, Request, Response } from 'express';
+import crypto from 'node:crypto';
+import { Store } from '../store.js';
+
+export function createAuthRoutes(store: Store): Router {
+  const router = Router();
+
+  router.post('/register', (req: Request, res: Response): void => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+    if (store.findUserByUsername(username)) {
+      res.status(409).json({ error: 'Username already exists' });
+      return;
+    }
+    const id = store.genId();
+    const user = { id, username, password };
+    store.users.set(id, user);
+    res.status(201).json({ id, username });
+  });
+
+  router.post('/login', (req: Request, res: Response): void => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+    const user = store.findUserByUsername(username);
+    if (!user || user.password !== password) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+    const token = crypto.randomUUID();
+    store.tokens.set(token, user.id);
+    res.json({ token, userId: user.id });
+  });
+
+  return router;
+}
diff --git a/src/routes/documents.ts b/src/routes/documents.ts
new file mode 100644
index 0000000..cf9202a
--- /dev/null
+++ b/src/routes/documents.ts
@@ -0,0 +1,117 @@
+import { Router, Request, Response } from 'express';
+import { Store } from '../store.js';
+
+export function createDocumentRoutes(store: Store): Router {
+  const router = Router();
+
+  // Get document
+  router.get('/:id', (req: Request, res: Response): void => {
+    const userId: string = res.locals.userId;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!store.hasAtLeast(userId, 'document', doc.id, 'viewer')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/:id', (req: Request, res: Response): void => {
+    const userId: string = res.locals.userId;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!store.hasAtLeast(userId, 'document', doc.id, 'editor')) {
+      res.status(403).json({ error: 'Insufficient permissions' });
+      return;
+    }
+
+    if (req.body.title !== undefined) doc.title = req.body.title;
+    if (req.body.content !== undefined) doc.content = req.body.content;
+    doc.updatedAt = new Date().toISOString();
+
+    store.logActivity('document_updated', userId, 'document', doc.id);
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/:id', (req: Request, res: Response): void => {
+    const userId: string = res.locals.userId;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!store.hasAtLeast(userId, 'document', doc.id, 'owner')) {
+      res.status(403).json({ error: 'Only owners can delete documents' });
+      return;
+    }
+
+    store.documents.delete(doc.id);
+    store.permissions = store.permissions.filter(
+      p => !(p.resourceType === 'document' && p.resourceId === doc.id)
+    );
+    store.logActivity('document_deleted', userId, 'document', doc.id);
+    res.status(204).send();
+  });
+
+  // Share document
+  router.post('/:id/share', (req: Request, res: Response): void => {
+    const userId: string = res.locals.userId;
+    const doc = store.documents.get(req.params.id);
+
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+
+    const { targetUserId, role } = req.body;
+    if (!targetUserId || !role) {
+      res.status(400).json({ error: 'targetUserId and role are required' });
+      return;
+    }
+    if (!['viewer', 'editor', 'owner'].includes(role)) {
+      res.status(400).json({ error: 'Invalid role' });
+      return;
+    }
+    if (!store.users.has(targetUserId)) {
+      res.status(404).json({ error: 'Target user not found' });
+      return;
+    }
+
+    // Check sharer's permission
+    const sharerRole = store.getEffectiveRole(userId, 'document', doc.id);
+    if (!sharerRole || sharerRole === 'viewer') {
+      res.status(403).json({ error: 'Insufficient permissions to share' });
+      return;
+    }
+    if (role === 'owner' && sharerRole !== 'owner') {
+      res.status(403).json({ error: 'Only owners can assign owner role' });
+      return;
+    }
+
+    const permId = store.genId();
+    const perm = {
+      id: permId,
+      resourceType: 'document' as const,
+      resourceId: doc.id,
+      userId: targetUserId,
+      role,
+    };
+    store.permissions.push(perm);
+    store.logActivity('shared', userId, 'document', doc.id);
+    res.status(201).json(perm);
+  });
+
+  return router;
+}
