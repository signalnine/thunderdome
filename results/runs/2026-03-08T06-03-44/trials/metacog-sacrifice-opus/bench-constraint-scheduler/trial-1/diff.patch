result.assignments.find((a) => a.eventId === \"e2\")!;\n      const [first, second] =\n        a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n      expect(second.startTime).toBeGreaterThanOrEqual(first.endTime);\n    });\n  });\n\n  describe(\"prerequisites\", () => {\n    it(\"schedules prerequisite before dependent event\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Intro\", duration: 60 },\n        { id: \"e2\", name: \"Advanced\", duration: 60, prerequisites: [\"e1\"] },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n\n      const a1 = result.assignments.find((a) => a.eventId === \"e1\")!;\n      const a2 = result.assignments.find((a) => a.eventId === \"e2\")!;\n      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n    });\n\n    it(\"handles chain of prerequisites\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Part 1\", duration: 30 },\n        { id: \"e2\", name: \"Part 2\", duration: 30, prerequisites: [\"e1\"] },\n        { id: \"e3\", name: \"Part 3\", duration: 30, prerequisites: [\"e2\"] },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(3);\n\n      const a1 = result.assignments.find((a) => a.eventId === \"e1\")!;\n      const a2 = result.assignments.find((a) => a.eventId === \"e2\")!;\n      const a3 = result.assignments.find((a) => a.eventId === \"e3\")!;\n      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n    });\n\n    it(\"handles multiple prerequisites\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Prereq 1\", duration: 30 },\n        { id: \"e2\", name: \"Prereq 2\", duration: 30 },\n        {\n          id: \"e3\",\n          name: \"Depends on both\",\n          duration: 30,\n          prerequisites: [\"e1\", \"e2\"],\n        },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(3);\n\n      const a1 = result.assignments.find((a) => a.eventId === \"e1\")!;\n      const a2 = result.assignments.find((a) => a.eventId === \"e2\")!;\n      const a3 = result.assignments.find((a) => a.eventId === \"e3\")!;\n      expect(a3.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);\n      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);\n    });\n\n    it(\"throws on self-referencing prerequisite\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Self Ref\", duration: 60, prerequisites: [\"e1\"] },\n      ];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n\n    it(\"throws on prerequisite cycle (A -> B -> A)\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"A\", duration: 60, prerequisites: [\"e2\"] },\n        { id: \"e2\", name: \"B\", duration: 60, prerequisites: [\"e1\"] },\n      ];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n\n    it(\"throws on longer cycle (A -> B -> C -> A)\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"A\", duration: 60, prerequisites: [\"e3\"] },\n        { id: \"e2\", name: \"B\", duration: 60, prerequisites: [\"e1\"] },\n        { id: \"e3\", name: \"C\", duration: 60, prerequisites: [\"e2\"] },\n      ];\n      expect(() => schedule(events, rooms, defaultOptions)).toThrow();\n    });\n\n    it(\"ignores prerequisites referencing non-existent events\", () => {\n      const events: Event[] = [\n        {\n          id: \"e1\",\n          name: \"Event\",\n          duration: 60,\n          prerequisites: [\"nonexistent\"],\n        },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n    });\n\n    it(\"respects gap between prerequisite events\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Prereq\", duration: 60 },\n        { id: \"e2\", name: \"Dependent\", duration: 60, prerequisites: [\"e1\"] },\n      ];\n      const opts: ScheduleOptions = {\n        startTime: 540,\n        endTime: 1020,\n        gap: 30,\n      };\n      const result = schedule(events, rooms, opts);\n      expect(result.assignments).toHaveLength(2);\n\n      const a1 = result.assignments.find((a) => a.eventId === \"e1\")!;\n      const a2 = result.assignments.find((a) => a.eventId === \"e2\")!;\n      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime + 30);\n    });\n  });\n\n  describe(\"preferred room\", () => {\n    it(\"honors preferred room when possible\", () => {\n      const events: Event[] = [\n        {\n          id: \"e1\",\n          name: \"Event 1\",\n          duration: 60,\n          attendees: 5,\n          preferredRoom: \"r2\",\n        },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe(\"r2\");\n    });\n\n    it(\"uses alternate room when preferred room has insufficient capacity\", () => {\n      const events: Event[] = [\n        {\n          id: \"e1\",\n          name: \"Big Event\",\n          duration: 60,\n          attendees: 15,\n          preferredRoom: \"r1\", // capacity 10\n        },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).not.toBe(\"r1\");\n    });\n\n    it(\"uses alternate room when preferred room is full\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Event 1\", duration: 420, preferredRoom: \"r1\" },\n        { id: \"e2\", name: \"Event 2\", duration: 60, preferredRoom: \"r1\" },\n      ];\n      const singleSmallRoom: Room[] = [\n        { id: \"r1\", name: \"Room 1\", capacity: 10 },\n        { id: \"r2\", name: \"Room 2\", capacity: 10 },\n      ];\n      // e1 takes 420 min (7h) starting at 540. With gap, r1 can't hold another event in 8h window.\n      const opts: ScheduleOptions = {\n        startTime: 540,\n        endTime: 1020, // 8 hours\n        gap: 15,\n      };\n      const result = schedule(events, singleSmallRoom, opts);\n      expect(result.assignments).toHaveLength(2);\n      // At least one should not be in r1 since r1 can't hold both\n    });\n  });\n\n  describe(\"unscheduled events\", () => {\n    it(\"lists events that cannot fit in unscheduled\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Long 1\", duration: 240 },\n        { id: \"e2\", name: \"Long 2\", duration: 240 },\n        { id: \"e3\", name: \"Long 3\", duration: 240 },\n      ];\n      const singleRoom: Room[] = [{ id: \"r1\", name: \"Room\", capacity: 10 }];\n      const opts: ScheduleOptions = {\n        startTime: 540,\n        endTime: 1020, // 8h = 480 min, can fit 2 x 240 with no gap but need gap\n        gap: 0,\n      };\n      // With gap=0: 240 + 240 = 480, fits exactly. Third doesn't fit.\n      const result = schedule(events, singleRoom, opts);\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(1);\n    });\n\n    it(\"marks prerequisite-dependent events as unscheduled when prereq can't be scheduled\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Too Big\", duration: 60, attendees: 100 },\n        { id: \"e2\", name: \"Depends\", duration: 60, prerequisites: [\"e1\"] },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      // e1 can't be scheduled (too many attendees), so e2 also can't\n      expect(result.unscheduled).toContain(\"e1\");\n      // e2 may or may not be unscheduled depending on whether prereq constraint\n      // blocks it when prereq doesn't exist in scheduled set\n    });\n  });\n\n  describe(\"batch optimization\", () => {\n    it(\"maximizes number of events scheduled\", () => {\n      // Create a scenario where naive ordering would fail:\n      // 3 events, 1 room, tight window. A big event and two small ones.\n      // The big event fills the room, but two small ones would be more total.\n      const events: Event[] = [\n        { id: \"big\", name: \"Big Event\", duration: 400 },\n        { id: \"s1\", name: \"Small 1\", duration: 180 },\n        { id: \"s2\", name: \"Small 2\", duration: 180 },\n      ];\n      const singleRoom: Room[] = [{ id: \"r1\", name: \"Room\", capacity: 10 }];\n      const opts: ScheduleOptions = {\n        startTime: 0,\n        endTime: 480,\n        gap: 15,\n      };\n      // Window: 480 min\n      // Big event: 400 min -> leaves 80 min (not enough for 180)\n      // Two small events: 180 + 15 + 180 = 375 min -> both fit!\n      const result = schedule(events, singleRoom, opts);\n      expect(result.assignments.length).toBeGreaterThanOrEqual(2);\n      // Ideally both small events are scheduled\n      const scheduledIds = result.assignments.map((a) => a.eventId);\n      if (scheduledIds.includes(\"big\")) {\n        // If big is scheduled, only 1 event total\n        expect(result.assignments).toHaveLength(1);\n      } else {\n        // Both small events should be scheduled\n        expect(scheduledIds).toContain(\"s1\");\n        expect(scheduledIds).toContain(\"s2\");\n      }\n    });\n\n    it(\"handles many events across multiple rooms\", () => {\n      const events: Event[] = Array.from({ length: 20 }, (_, i) => ({\n        id: `e${i}`,\n        name: `Event ${i}`,\n        duration: 30,\n        attendees: 5,\n      }));\n      const result = schedule(events, rooms, defaultOptions);\n      // 8 hours = 480 min, with 30 min events and 15 min gap:\n      // Per room: floor(480 / 45) = 10 events, plus potentially one more if remainder >= 30\n      // 480 / 45 = 10.67, so 10 full cycles = 450 min, 30 left = 1 more event = 11 per room\n      // Actually: 10 * 30 + 10 * 15 = 450, leaving 30 min for 1 more = 11 events\n      // But gap is only between events, not after last: 11 * 30 + 10 * 15 = 330 + 150 = 480, exactly!\n      // 3 rooms * 11 = 33, but we only have 20 events\n      expect(result.assignments).toHaveLength(20);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n  });\n\n  describe(\"edge cases\", () => {\n    it(\"handles events with exact time window fit\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Exact Fit\", duration: 480 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].startTime).toBe(540);\n      expect(result.assignments[0].endTime).toBe(1020);\n    });\n\n    it(\"handles zero-gap prerequisite timing\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"First\", duration: 60 },\n        { id: \"e2\", name: \"Second\", duration: 60, prerequisites: [\"e1\"] },\n      ];\n      const opts: ScheduleOptions = {\n        startTime: 540,\n        endTime: 1020,\n        gap: 0,\n      };\n      const result = schedule(events, rooms, opts);\n      expect(result.assignments).toHaveLength(2);\n\n      const a1 = result.assignments.find((a) => a.eventId === \"e1\")!;\n      const a2 = result.assignments.find((a) => a.eventId === \"e2\")!;\n      expect(a2.startTime).toBeGreaterThanOrEqual(a1.endTime);\n    });\n\n    it(\"handles events with no prerequisites field\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"No prereqs\", duration: 60 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n    });\n\n    it(\"handles events with empty prerequisites array\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Empty prereqs\", duration: 60, prerequisites: [] },\n      ];\n      const result = schedule(