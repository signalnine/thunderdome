+      const a3 = result.assignments.find((a) => a.eventId === "e3")!;
+      expect(a3.startTime).toBeGreaterThanOrEqual(a1.endTime + 15);
+      expect(a3.startTime).toBeGreaterThanOrEqual(a2.endTime + 15);
+    });
+
+    it("throws on self-referencing prerequisite", () => {
