indIndex(\n    (s) => s.start === start && s.end === end,\n  );\n  if (idx !== -1) {\n    timeline.slots.splice(idx, 1);\n  }\n}\n\n/**\n * Main scheduling function.\n *\n * Strategy (informed by \"the sacrifice\" of naive greediness):\n * 1. Detect cycles in prerequisites (throw on cycle).\n * 2. Topologically sort events respecting prerequisites.\n * 3. Within each topological \"level\", sort by most constrained first:\n *    - Fewest valid rooms (capacity-filtered)\n *    - Longest duration\n *    - Most attendees\n * 4. For each event, try preferred room first, then other rooms.\n * 5. Use backtracking to maximize the total number of scheduled events.\n */\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n): ScheduleResult {\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  // Validate and detect cycles\n  detectCycles(events);\n\n  if (events.length === 0 || rooms.length === 0) {\n    return {\n      assignments: [],\n      unscheduled: events.map((e) => e.id),\n    };\n  }\n\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const eventIds = new Set(events.map((e) => e.id));\n\n  // Compute valid rooms for each event (capacity check)\n  const validRooms = new Map<string, Room[]>();\n  for (const e of events) {\n    const attendees = e.attendees ?? 1;\n    const capable = rooms.filter((r) => r.capacity >= attendees);\n    // Sort: preferred room first, then by capacity ascending (tighter fit first)\n    capable.sort((a, b) => {\n      if (e.preferredRoom === a.id && e.preferredRoom !== b.id) return -1;\n      if (e.preferredRoom === b.id && e.preferredRoom !== a.id) return 1;\n      return a.capacity - b.capacity;\n    });\n    validRooms.set(e.id, capable);\n  }\n\n  // Compute depths and topological order\n  const depths = computeDepths(events);\n  const topoSorted = topologicalSort(events);\n\n  // Sort events: topological depth first, then by constraint level\n  const sortedEvents = [...topoSorted].sort((a, b) => {\n    const depthA = depths.get(a.id) ?? 0;\n    const depthB = depths.get(b.id) ?? 0;\n    if (depthA !== depthB) return depthA - depthB;\n\n    // Most constrained first: fewer valid rooms = higher priority\n    const roomsA = validRooms.get(a.id)?.length ?? 0;\n    const roomsB = validRooms.get(b.id)?.length ?? 0;\n    if (roomsA !== roomsB) return roomsA - roomsB;\n\n    // Longer duration = harder to place\n    if (a.duration !== b.duration) return b.duration - a.duration;\n\n    // More attendees = harder to place\n    const attA = a.attendees ?? 1;\n    const attB = b.attendees ?? 1;\n    return attB - attA;\n  });\n\n  // Initialize room timelines\n  const timelines = new Map<string, RoomTimeline>();\n  for (const r of rooms) {\n    timelines.set(r.id, { roomId: r.id, capacity: r.capacity, slots: [] });\n  }\n\n  // Track assignments\n  const assignments = new Map<\n    string,\n    { roomId: string; startTime: number; endTime: number }\n  >();\n\n  /**\n   * Get the earliest possible start time for an event considering prerequisites.\n   */\n  function getEarliestStart(event: Event): number {\n    let earliest = startTime;\n    const prereqs = (event.prerequisites ?? []).filter((p) => eventIds.has(p));\n    for (const pId of prereqs) {\n      const pAssignment = assignments.get(pId);\n      if (!pAssignment) return -1; // prerequisite not yet scheduled\n      earliest = Math.max(earliest, pAssignment.endTime + gap);\n    }\n    return earliest;\n  }\n\n  /**\n   * Try to place a single event. Returns true if placed successfully.\n   */\n  function tryPlace(event: Event): boolean {\n    const earliest = getEarliestStart(event);\n    if (earliest < 0) return false;\n\n    const rooms = validRooms.get(event.id) ?? [];\n\n    for (const room of rooms) {\n      const timeline = timelines.get(room.id)!;\n      const slotStart = findEarliestSlot(\n        timeline,\n        event.duration,\n        earliest,\n        endTime,\n        gap,\n      );\n      if (slotStart !== null) {\n        const slotEnd = slotStart + event.duration;\n        insertSlot(timeline, slotStart, slotEnd);\n        assignments.set(event.id, {\n          roomId: room.id,\n          startTime: slotStart,\n          endTime: slotEnd,\n        });\n        return true;\n      }\n    }\n\n    return false;\n  }\n\n  /**\n   * Unplace an event (for backtracking).\n   */\n  function unplace(event: Event): void {\n    const a = assignments.get(event.id);\n    if (!a) return;\n    const timeline = timelines.get(a.roomId)!;\n    removeSlot(timeline, a.startTime, a.endTime);\n    assignments.delete(event.id);\n  }\n\n  // Phase 1: Try to place all events in constraint-priority order\n  const unscheduledEvents: Event[] = [];\n  for (const event of sortedEvents) {\n    if (!tryPlace(event)) {\n      unscheduledEvents.push(event);\n    }\n  }\n\n  // Phase 2: Try removing each scheduled event and see if more unscheduled\n  // events can be placed in the freed space (net gain > 0).\n  if (unscheduledEvents.length > 0) {\n    let improved = true;\n\n    while (improved) {\n      improved = false;\n\n      // Try direct placement of any unscheduled events first\n      for (let i = unscheduledEvents.length - 1; i >= 0; i--) {\n        if (tryPlace(unscheduledEvents[i])) {\n          unscheduledEvents.splice(i, 1);\n          improved = true;\n        }\n      }\n\n      if (unscheduledEvents.length === 0) break;\n\n      // Try removing each currently scheduled event to see if we get a net gain\n      const currentlyScheduled = sortedEvents.filter((e) =>\n        assignments.has(e.id),\n      );\n\n      for (const candidate of currentlyScheduled) {\n        // Find events that depend on the candidate (directly or transitively)\n        const dependsOnCandidate = findAllDependents(candidate.id, sortedEvents, eventIds);\n\n        // Save state of candidate and its dependents\n        const savedStates: Array<{\n          event: Event;\n          assignment: { roomId: string; startTime: number; endTime: number };\n        }> = [];\n\n        const candAssignment = assignments.get(candidate.id);\n        if (!candAssignment) continue;\n        savedStates.push({ event: candidate, assignment: { ...candAssignment } });\n\n        for (const depId of dependsOnCandidate) {\n          const depA = assignments.get(depId);\n          if (depA) {\n            const depEvent = eventMap.get(depId)!;\n            savedStates.push({ event: depEvent, assignment: { ...depA } });\n          }\n        }\n\n        // Remove candidate and all its dependents\n        const removedCount = savedStates.length;\n        for (const { event: ev } of savedStates) {\n          unplace(ev);\n        }\n\n        // Collect removed dependent events that were previously scheduled\n        const removedDependentEvents = savedStates\n          .filter((s) => s.event.id !== candidate.id)\n          .map((s) => s.event);\n\n        // Try to place all currently unscheduled events + removed dependents\n        const toPlace = [...unscheduledEvents, ...removedDependentEvents];\n\n        // Sort toPlace by constraint level\n        toPlace.sort((a, b) => {\n          const depthA = depths.get(a.id) ?? 0;\n          const depthB = depths.get(b.id) ?? 0;\n          if (depthA !== depthB) return depthA - depthB;\n          const roomsA = validRooms.get(a.id)?.length ?? 0;\n          const roomsB = validRooms.get(b.id)?.length ?? 0;\n          if (roomsA !== roomsB) return roomsA - roomsB;\n          return b.duration - a.duration;\n        });\n\n        const newlyPlaced: Event[] = [];\n        const stillUnplaced: Event[] = [];\n\n        for (const ev of toPlace) {\n          if (tryPlace(ev)) {\n            newlyPlaced.push(ev);\n          } else {\n            stillUnplaced.push(ev);\n          }\n        }\n\n        // Net gain: newlyPlaced.length - removedCount\n        if (newlyPlaced.length > removedCount) {\n          // Keep the new arrangement\n          // Update unscheduledEvents: the original unscheduled minus those placed,\n          // plus the candidate (and dependents that couldn't be placed)\n          unscheduledEvents.length = 0;\n          unscheduledEvents.push(...stillUnplaced);\n          if (!assignments.has(candidate.id)) {\n            unscheduledEvents.push(candidate);\n          }\n          improved = true;\n          break; // restart the outer loop\n        } else {\n          // Revert: unplace all newly placed, restore saved states\n          for (const ev of newlyPlaced) {\n            unplace(ev);\n          }\n          for (const { event: ev, assignment: a } of savedStates) {\n            const tl = timelines.get(a.roomId)!;\n            insertSlot(tl, a.startTime, a.endTime);\n            assignments.set(ev.id, { ...a });\n          }\n        }\n      }\n    }\n  }\n\n  // Build result\n  const resultAssignments: Assignment[] = [];\n  for (const event of events) {\n    const a = assignments.get(event.id);\n    if (a) {\n      resultAssignments.push({\n        eventId: event.id,\n        roomId: a.roomId,\n        startTime: a.startTime,\n        endTime: a.endTime,\n      });\n    }\n  }\n\n  const scheduledIds = new Set(resultAssignments.map((a) => a.eventId));\n  const unscheduled = events\n    .filter((e) => !scheduledIds.has(e.id))\n    .map((e) => e.id);\n\n  return {\n    assignments: resultAssignments,\n    unscheduled,\n  };\n}\n","structuredPatch":[{"oldStart":230,"oldLines":6,"newStart":230,"newLines":33,"lines":[" }"," "," /**","+ * Find all events that transitively depend on a given event.","+ */","+function findAllDependents(","+  eventId: string,","+  events: Event[],","+  eventIds: Set<string>,","+): string[] {","+  const dependents: string[] = [];","+  const visited = new Set<string>();","+","+  function collect(id: string): void {","+    for (const e of events) {","+     