+import type {
+  Event,
+  Room,
+  ScheduleOptions,
+  Assignment,
+  ScheduleResult,
+} from "./types.js";
+
+/**
+ * Detect cycles in the prerequisite graph using DFS.
+ * Throws if any cycle (including self-references) is found.
+ */
+function detectCycles(events: Event[]): void {
+  const eventIds = new Set(events.map((e) => e.id));
+
+  // Check for self-references first
+  for (const event of events) {
+    if (event.prerequisites?.includes(event.id)) {
+      throw new Error(
+        `Cycle detected: event "${event.id}" lists itself as a prerequisite`,
+      );
+    }
+  }
+
+  const WHITE = 0,
+    GRAY = 1,
+    BLACK = 2;
+  const color = new Map<string, number>();
+  for (const e of events) {
+    color.set(e.id, WHITE);
+  }
+
+  const adjList = new Map<string, string[]>();
+  for (const e of events) {
+    const prereqs = (e.prerequisites ?? []).filter((p) => eventIds.has(p));
+    adjList.set(e.id, prereqs);
+  }
+
+  function dfs(nodeId: string): void {
+    color.set(nodeId, GRAY);
+    for (const dep of adjList.get(nodeId) ?? []) {
+      const depColor = color.get(dep);
+      if (depColor === GRAY) {
+        throw new Error(`Cycle detected in prerequisites involving "${dep}"`);
+      }
+      if (depColor === WHITE) {
+        dfs(dep);
+      }
+    }
+    color.set(nodeId, BLACK);
+  }
+
+  for (const e of events) {
+    if (color.get(e.id) === WHITE) {
+      dfs(e.id);
+    }
+  }
+}
+
+/**
+ * Topological sort (Kahn's algorithm). Returns events in an order
+ * respecting prerequisites. Assumes no cycles.
+ */
+function topologicalSort(events: Event[]): Event[] {
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  const eventIds = new Set(events.map((e) => e.id));
+  const inDegree = new Map<string, number>();
+  const dependents = new Map<string, string[]>();
+
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    dependents.set(e.id, []);
+  }
+
+  for (const e of events) {
+    const prereqs = (e.prerequisites ?? []).filter((p) => eventIds.has(p));
+    inDegree.set(e.id, prereqs.length);
+    for (const p of prereqs) {
+      dependents.get(p)!.push(e.id);
+    }
+  }
+
+  const queue: string[] = [];
+  for (const e of events) {
+    if (inDegree.get(e.id) === 0) {
+      queue.push(e.id);
+    }
+  }
+
+  const sorted: Event[] = [];
+  while (queue.length > 0) {
+    const id = queue.shift()!;
+    sorted.push(eventMap.get(id)!);
+    for (const dep of dependents.get(id)!) {
+      const newDeg = inDegree.get(dep)! - 1;
+      inDegree.set(dep, newDeg);
+      if (newDeg === 0) {
+        queue.push(dep);
+      }
+    }
+  }
+
+  return sorted;
+}
+
+/**
+ * Compute the "depth" of each event in the prerequisite DAG.
+ * Events with no prerequisites have depth 0.
+ */
+function computeDepths(events: Event[]): Map<string, number> {
+  const eventIds = new Set(events.map((e) => e.id));
+  const depths = new Map<string, number>();
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  function getDepth(id: string): number {
+    if (depths.has(id)) return depths.get(id)!;
+    const event = eventMap.get(id);
+    if (!event) return 0;
+    const prereqs = (event.prerequisites ?? []).filter((p) => eventIds.has(p));
+    if (prereqs.length === 0) {
+      depths.set(id, 0);
+      return 0;
+    }
+    const d = 1 + Math.max(...prereqs.map(getDepth));
+    depths.set(id, d);
+    return d;
+  }
+
+  for (const e of events) {
+    getDepth(e.id);
+  }
+
+  return depths;
+}
+
+interface RoomTimeline {
+  roomId: string;
+  capacity: number;
+  /** Sorted list of scheduled intervals */
+  slots: Array<{ start: number; end: number }>;
+}
+
+/**
+ * Find the earliest start time for an event in a given room, respecting:
+ * - The time window
+ * - The gap constraint
+ * - The earliest possible start (from prerequisites)
+ */
+function findEarliestSlot(
+  timeline: RoomTimeline,
+  duration: number,
+  earliestStart: number,
+  endTime: number,
+  gap: number,
+): number | null {
+  const eventEnd = earliestStart + duration;
+  if (eventEnd > endTime) return null;
+
+  if (timeline.slots.length === 0) {
+    return earliestStart;
+  }
+
+  // Try before the first slot
+  const firstSlot = timeline.slots[0];
+  if (
+    earliestStart + duration + gap <= firstSlot.start ||
+    earliestStart + duration <= firstSlot.start // no gap needed after the new event if it ends exactly at first slot start... actually gap is needed
+  ) {
+    // We need: newEnd + gap <= firstSlot.start
+    if (earliestStart + duration + gap <= firstSlot.start) {
+      return earliestStart;
+    }
+  }
+
+  // Try between slots
+  for (let i = 0; i < timeline.slots.length; i++) {
+    const slotEnd = timeline.slots[i].end;
+    const gapStart = slotEnd + gap;
+    const candidateStart = Math.max(earliestStart, gapStart);
+    const candidateEnd = candidateStart + duration;
+
+    if (i + 1 < timeline.slots.length) {
+      const nextSlotStart = timeline.slots[i + 1].start;
+      if (candidateEnd + gap <= nextSlotStart && candidateEnd <= endTime) {
+        return candidateStart;
+      }
+    } else {
+      // After the last slot
+      if (candidateEnd <= endTime) {
+        return candidateStart;
+      }
+    }
+  }
+
+  return null;
+}
+
+/**
+ * Insert a slot into the timeline, maintaining sorted order.
+ */
+function insertSlot(
+  timeline: RoomTimeline,
+  start: number,
+  end: number,
+): void {
+  let i = 0;
+  while (i < timeline.slots.length && timeline.slots[i].start < start) {
+    i++;
+  }
+  timeline.slots.splice(i, 0, { start, end });
+}
+
+/**
+ * Remove a slot from the timeline.
+ */
+function removeSlot(timeline: RoomTimeline, start: number, end: number): void {
+  const idx = timeline.slots.findIndex(
+    (s) => s.start === start && s.end === end,
+  );
+  if (idx !== -1) {
+    timeline.slots.splice(idx, 1);
+  }
+}
+
+/**
+ * Find all events that transitively depend on a given event.
+ */
+function findAllDependents(
+  eventId: string,
+  events: Event[],
+  eventIds: Set<string>,
+): string[] {
+  const dependents: string[] = [];
+  const visited = new Set<string>();
+
+  function collect(id: string): void {
+    for (const e of events) {
+      if (visited.has(e.id)) continue;
+      const prereqs = (e.prerequisites ?? []).filter((p) => eventIds.has(p));
+      if (prereqs.includes(id)) {
+        visited.add(e.id);
+        dependents.push(e.id);
+        collect(e.id);
+      }
+    }
+  }
+
+  collect(eventId);
+  return dependents;
+}
+
+/**
+ * Main scheduling function.
+ *
+ * Strategy (informed by "the sacrifice" of naive greediness):
+ * 1. Detect cycles in prerequisites (throw on cycle).
+ * 2. Topologically sort events respecting prerequisites.
+ * 3. Within each topological "level", sort by most constrained first:
+ *    - Fewest valid rooms (capacity-filtered)
+ *    - Longest duration
+ *    - Most attendees
+ * 4. For each event, try preferred room first, then other rooms.
+ * 5. Use backtracking to maximize the total number of scheduled events.
+ */
+export function schedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions,
+): ScheduleResult {
+  const gap = options.gap ?? 15;
+  const { startTime, endTime } = options;
+
+  // Validate and detect cycles
+  detectCycles(events);
+
+  if (events.length === 0 || rooms.length === 0) {
+    return {
+      assignments: [],
+      unscheduled: events.map((e) => e.id),
+    };
+  }
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  const eventIds = new Set(events.map((e) => e.id));
+
+  // Compute valid rooms for each event (capacity check)
+  const validRooms = new Map<string, Room[]>();
+  for (const e of events) {
+    const attendees = e.attendees ?? 1;
+    const capable = rooms.filter((r) => r.capacity >= attendees);
+    // Sort: preferred room first, then by capacity ascending (tighter fit first)
