ent, try preferred room first, then other rooms.\n * 5. Use backtracking to maximize the total number of scheduled events.\n */","originalFile":"import type {\n  Event,\n  Room,\n  ScheduleOptions,\n  Assignment,\n  ScheduleResult,\n} from \"./types.js\";\n\n/**\n * Detect cycles in the prerequisite graph using DFS.\n * Throws if any cycle (including self-references) is found.\n */\nfunction detectCycles(events: Event[]): void {\n  const eventIds = new Set(events.map((e) => e.id));\n\n  // Check for self-references first\n  for (const event of events) {\n    if (event.prerequisites?.includes(event.id)) {\n      throw new Error(\n        `Cycle detected: event \"${event.id}\" lists itself as a prerequisite`,\n      );\n    }\n  }\n\n  const WHITE = 0,\n    GRAY = 1,\n    BLACK = 2;\n  const color = new Map<string, number>();\n  for (const e of events) {\n    color.set(e.id, WHITE);\n  }\n\n  const adjList = new Map<string, string[]>();\n  for (const e of events) {\n    const prereqs = (e.prerequisites ?? []).filter((p) => eventIds.has(p));\n    adjList.set(e.id, prereqs);\n  }\n\n  function dfs(nodeId: string): void {\n    color.set(nodeId, GRAY);\n    for (const dep of adjList.get(nodeId) ?? []) {\n      const depColor = color.get(dep);\n      if (depColor === GRAY) {\n        throw new Error(`Cycle detected in prerequisites involving \"${dep}\"`);\n      }\n      if (depColor === WHITE) {\n        dfs(dep);\n      }\n    }\n    color.set(nodeId, BLACK);\n  }\n\n  for (const e of events) {\n    if (color.get(e.id) === WHITE) {\n      dfs(e.id);\n    }\n  }\n}\n\n/**\n * Topological sort (Kahn's algorithm). Returns events in an order\n * respecting prerequisites. Assumes no cycles.\n */\nfunction topologicalSort(events: Event[]): Event[] {\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  const eventIds = new Set(events.map((e) => e.id));\n  const inDegree = new Map<string, number>();\n  const dependents = new Map<string, string[]>();\n\n  for (const e of events) {\n    inDegree.set(e.id, 0);\n    dependents.set(e.id, []);\n  }\n\n  for (const e of events) {\n    const prereqs = (e.prerequisites ?? []).filter((p) => eventIds.has(p));\n    inDegree.set(e.id, prereqs.length);\n    for (const p of prereqs) {\n      dependents.get(p)!.push(e.id);\n    }\n  }\n\n  const queue: string[] = [];\n  for (const e of events) {\n    if (inDegree.get(e.id) === 0) {\n      queue.push(e.id);\n    }\n  }\n\n  const sorted: Event[] = [];\n  while (queue.length > 0) {\n    const id = queue.shift()!;\n    sorted.push(eventMap.get(id)!);\n    for (const dep of dependents.get(id)!) {\n      const newDeg = inDegree.get(dep)! - 1;\n      inDegree.set(dep, newDeg);\n      if (newDeg === 0) {\n        queue.push(dep);\n      }\n    }\n  }\n\n  return sorted;\n}\n\n/**\n * Compute the \"depth\" of each event in the prerequisite DAG.\n * Events with no prerequisites have depth 0.\n */\nfunction computeDepths(events: Event[]): Map<string, number> {\n  const eventIds = new Set(events.map((e) => e.id));\n  const depths = new Map<string, number>();\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  function getDepth(id: string): number {\n    if (depths.has(id)) return depths.get(id)!;\n    const event = eventMap.get(id);\n    if (!event) return 0;\n    const prereqs = (event.prerequisites ?? []).filter((p) => eventIds.has(p));\n    if (prereqs.length === 0) {\n      depths.set(id, 0);\n      return 0;\n    }\n    const d = 1 + Math.max(...prereqs.map(getDepth));\n    depths.set(id, d);\n    return d;\n  }\n\n  for (const e of events) {\n    getDepth(e.id);\n  }\n\n  return depths;\n}\n\ninterface RoomTimeline {\n  roomId: string;\n  capacity: number;\n  /** Sorted list of scheduled intervals */\n  slots: Array<{ start: number; end: number }>;\n}\n\n/**\n * Find the earliest start time for an event in a given room, respecting:\n * - The