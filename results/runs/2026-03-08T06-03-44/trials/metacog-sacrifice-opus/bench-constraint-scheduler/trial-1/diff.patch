eLength(2);\n      expect(result.unscheduled).toHaveLength(0);\n\n      const a1 = result.assignments.find((a) => a.eventId === \"e1\")!;\n      const a2 = result.assignments.find((a) => a.eventId === \"e2\")!;\n      const [first, second] =\n        a1.startTime < a2.startTime ? [a1, a2] : [a2, a1];\n      expect(second.startTime).toBeGreaterThanOrEqual(first.endTime + 15);\n    });\n\n    it(\"schedules events in parallel across rooms\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Event 1\", duration: 60 },\n        { id: \"e2\", name: \"Event 2\", duration: 60 },\n      ];\n      const result = schedule(events, rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(2);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it(\"returns empty assignments for no events\", () => {\n      const result = schedule([], rooms, defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toHaveLength(0);\n    });\n\n    it(\"puts all events in unscheduled when no rooms available\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Event 1\", duration: 60 },\n      ];\n      const result = schedule(events, [], defaultOptions);\n      expect(result.assignments).toHaveLength(0);\n      expect(result.unscheduled).toEqual([\"e1\"]);\n    });\n  });\n\n  describe(\"capacity constraints\", () => {\n    it(\"respects room capacity\", () => {\n      const events: Event[] = [\n        { id: \"e1\", name: \"Big Event\", duration: 60, attendees: 30 },\n      ];\n      const smallRooms: Room[] = [\n        { id: \"r1\", name: \"Small\", capacity: 10 },\n        { id: \"r2\", name: \"Big\", capacity: 50 },\n      ];\n      const result = schedule(events, smallRooms, defaultOptions);\n      expect(result.assignments).toHaveLength(1);\n      expect(result.assignments[0].roomId).toBe(\"r2\");\n    });\n\n    it(\"marks event as unscheduled when no room has enough capacity