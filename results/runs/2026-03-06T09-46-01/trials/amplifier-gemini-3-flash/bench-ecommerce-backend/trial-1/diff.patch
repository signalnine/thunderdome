+import { EventBus } from '../bus.js';
+import { NotificationService, Events, OrderCreatedEvent, OrderStatusChangedEvent, PaymentProcessedEvent } from '../types.js';
+
+export function createNotificationService(bus: EventBus): NotificationService {
+  const notifications = new Map<string, Array<{ type: string; message: string; timestamp: number }>>();
+  const orderUserMap = new Map<string, string>();
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    orderUserMap.set(event.orderId, event.userId);
+  });
+
+  const getUserIdFromLog = (orderId: string): string | undefined => {
+    const log = bus.getLog();
+    for (const entry of log) {
+      if (entry.event === Events.ORDER_CREATED) {
+        const payload = entry.payload as OrderCreatedEvent;
+        if (payload.orderId === orderId) {
+          orderUserMap.set(orderId, payload.userId);
+          return payload.userId;
+        }
+      }
+    }
+    return undefined;
+  };
+
+  bus.on(Events.ORDER_STATUS_CHANGED, (payload: unknown) => {
+    const event = payload as OrderStatusChangedEvent;
+    const userId = orderUserMap.get(event.orderId) || getUserIdFromLog(event.orderId);
+    if (userId) {
+      const userNotifications = notifications.get(userId) || [];
+      userNotifications.push({
+        type: 'order_status',
+        message: `Order ${event.orderId} status changed from ${event.previousStatus} to ${event.status}`,
+        timestamp: Date.now()
+      });
+      notifications.set(userId, userNotifications);
+    }
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as PaymentProcessedEvent;
+    const userId = orderUserMap.get(event.orderId) || getUserIdFromLog(event.orderId);
+    if (userId) {
+      const userNotifications = notifications.get(userId) || [];
+      userNotifications.push({
+        type: 'payment',
+        message: `Payment for order ${event.orderId} ${event.status}${event.error ? ': ' + event.error : ''}`,
+        timestamp: Date.now()
+      });
+      notifications.set(userId, userNotifications);
+    }
+  });
+
+  return {
+    subscribe(userId: string): void {
+      if (!notifications.has(userId)) {
+        notifications.set(userId, []);
+      }
+    },
+
+    getNotifications(userId: string) {
+      return notifications.get(userId) || [];
+    }
+  };
+}
