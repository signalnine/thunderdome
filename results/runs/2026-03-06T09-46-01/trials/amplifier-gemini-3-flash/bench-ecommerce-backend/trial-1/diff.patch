diff --git a/src/analytics/index.ts b/src/analytics/index.ts
new file mode 100644
index 0000000..e901511
--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,113 @@
+import { EventBus } from '../bus.js';
+import { AnalyticsService, Events, PaymentProcessedEvent, OrderCreatedEvent, CartUpdatedEvent, PaymentStatus } from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let totalRevenue = 0;
+  const uniqueCarts = new Set<string>();
+  let totalOrders = 0;
+  const productOrderQuantities = new Map<string, number>();
+  const cartItemsMap = new Map<string, Array<{ productId: string; quantity: number }>>();
+  const orderTotals = new Map<string, number>();
+
+  const incrementEventCount = (eventType: string) => {
+    eventCounts.set(eventType, (eventCounts.get(eventType) || 0) + 1);
+  };
+
+  const getOrderTotalFromLog = (orderId: string): number => {
+    const log = bus.getLog();
+    for (const entry of log) {
+      if (entry.event === Events.ORDER_CREATED) {
+        const payload = entry.payload as OrderCreatedEvent;
+        if (payload.orderId === orderId) {
+          return payload.total;
+        }
+      }
+    }
+    return 0;
+  };
+
+  const getCartItemsFromLog = (cartId: string): Array<{ productId: string; quantity: number }> => {
+    const log = bus.getLog();
+    // Search backwards for the latest state of this cart
+    for (let i = log.length - 1; i >= 0; i--) {
+      const entry = log[i];
+      if (entry.event === Events.CART_UPDATED) {
+        const payload = entry.payload as CartUpdatedEvent;
+        if (payload.cartId === cartId) {
+          return payload.items;
+        }
+      }
+    }
+    return [];
+  };
+
+  bus.on(Events.PRODUCT_CREATED, () => incrementEventCount(Events.PRODUCT_CREATED));
+  bus.on(Events.INVENTORY_UPDATED, () => incrementEventCount(Events.INVENTORY_UPDATED));
+  bus.on(Events.LOW_STOCK_ALERT, () => incrementEventCount(Events.LOW_STOCK_ALERT));
+  
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    incrementEventCount(Events.CART_UPDATED);
+    const event = payload as CartUpdatedEvent;
+    uniqueCarts.add(event.cartId);
+    cartItemsMap.set(event.cartId, event.items);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    incrementEventCount(Events.ORDER_CREATED);
+    const event = payload as OrderCreatedEvent;
+    totalOrders++;
+    orderTotals.set(event.orderId, event.total);
+    
+    let items = cartItemsMap.get(event.cartId);
+    if (!items) {
+      items = getCartItemsFromLog(event.cartId);
+    }
+
+    if (items) {
+      for (const item of items) {
+        const current = productOrderQuantities.get(item.productId) || 0;
+        productOrderQuantities.set(item.productId, current + item.quantity);
+      }
+    }
+  });
+
+  bus.on(Events.ORDER_STATUS_CHANGED, () => incrementEventCount(Events.ORDER_STATUS_CHANGED));
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    incrementEventCount(Events.PAYMENT_PROCESSED);
+    const event = payload as PaymentProcessedEvent;
+    if (event.status === PaymentStatus.SUCCESS) {
+      let amount = orderTotals.get(event.orderId);
+      if (amount === undefined) {
+        amount = getOrderTotalFromLog(event.orderId);
+      }
+      totalRevenue += amount;
+    }
+  });
+
+  bus.on(Events.NOTIFICATION_SENT, () => incrementEventCount(Events.NOTIFICATION_SENT));
+  bus.on(Events.ANALYTICS_EVENT, () => incrementEventCount(Events.ANALYTICS_EVENT));
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) || 0;
+    },
+
+    getRevenue(): number {
+      return totalRevenue;
+    },
+
+    getConversionRate(): number {
+      if (uniqueCarts.size === 0) return 0;
+      return totalOrders / uniqueCarts.size;
+    },
+
+    getTopProducts(limit: number) {
+      return Array.from(productOrderQuantities.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    }
+  };
+}
