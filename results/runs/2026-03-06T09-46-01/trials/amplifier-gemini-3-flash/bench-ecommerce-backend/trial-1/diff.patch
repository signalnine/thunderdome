+import { EventBus } from '../bus.js';
+import { PaymentService, PaymentStatus, Events, PaymentProcessedEvent } from '../types.js';
+
+export interface PaymentOptions {
+  simulationMode?: PaymentStatus;
+  delay?: number;
+}
+
+export function createPaymentService(bus: EventBus, options: PaymentOptions = {}): PaymentService {
+  const transactions = new Map<string, { orderId: string; amount: number; status: PaymentStatus }>();
+
+  return {
+    async processPayment(orderId: string, amount: number) {
+      const mode = options.simulationMode || PaymentStatus.SUCCESS;
+      const delay = options.delay || 0;
+
+      if (delay > 0) {
+        await new Promise(resolve => setTimeout(resolve, delay));
+      }
+
+      const status: PaymentStatus = mode;
+      let transactionId: string | undefined;
+      let error: string | undefined;
+
+      if (status === PaymentStatus.SUCCESS) {
+        transactionId = `tx_${Math.random().toString(36).substr(2, 9)}`;
+        transactions.set(transactionId, { orderId, amount, status });
+      } else if (status === PaymentStatus.FAILED) {
+        error = 'Payment failed simulation';
+      } else if (status === PaymentStatus.TIMEOUT) {
+        error = 'Payment timed out simulation';
+      }
+
+      await bus.emit(Events.PAYMENT_PROCESSED, {
+        orderId,
+        status,
+        transactionId,
+        error
+      } as PaymentProcessedEvent);
+
+      return { status, transactionId, error };
+    },
+
+    async refund(transactionId: string): Promise<boolean> {
+      const tx = transactions.get(transactionId);
+      if (tx && tx.status === PaymentStatus.SUCCESS) {
+        // Simple refund implementation: just mark as refunded or similar? 
+        // The interface doesn't specify a refunded status, so we just return true.
+        // In a real system, we might emit a refund event.
+        transactions.delete(transactionId);
+        return true;
+      }
+      return false;
+    }
+  };
+}
