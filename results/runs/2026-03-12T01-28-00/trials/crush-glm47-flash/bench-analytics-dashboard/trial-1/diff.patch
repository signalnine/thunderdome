+import { authMiddleware, AuthRequest } from '../middleware/auth.middleware.js';
+import { buildWhereClause, EventFilter } from '../filters.js';
+
+const router = Router();
+
+router.post('/', authMiddleware, async (req: AuthRequest, res) => {
+  const { tenantId } = req.params;
+  const { user } = req;
+
+  if (!user || (tenantId && user.tenantId !== tenantId)) {
+    return res.status(401).json({ error: 'Unauthorized' });
+  }
+
+  const { name, properties = {}, timestamp } = req.body;
+
+  if (!name) {
+    return res.status(400).json({ error: 'Event name is required' });
+  }
+
+  const tenant_id = tenantId || user?.tenantId;
+  const user_id = user?.userId;
+
+  const event = eventQueries.create({
+    user_id,
+    tenant_id,
+    name,
+    properties,
+    timestamp
+  });
+
+  res.status(201).json({ event: { id: event.id, tenant_id: event.tenant_id, name: event.name, properties: event.properties, timestamp: event.timestamp } });
+});
+
+router.post('/batch', authMiddleware, async (req: AuthRequest, res) => {
+  const { tenantId } = req.params;
+  const { user } = req;
+
+  if (!user || (tenantId && user.tenantId !== tenantId)) {
+    return res.status(401).json({ error: 'Unauthorized' });
+  }
+
+  const { events } = req.body;
+
+  if (!Array.isArray(events) || events.length === 0) {
+    return res.status(400).json({ error: 'Events must be a non-empty array' });
+  }
+
+  const tenant_id = tenantId || user?.tenantId;
+  const user_id = user?.userId;
+
+  const eventsList = events.map(event => ({
+    user_id,
+    tenant_id,
+    name: event.name,
+    properties: event.properties || {},
+    timestamp: event.timestamp
+  }));
+
+  const createdEvents = eventQueries.batchCreate(eventsList);
+
+  res.status(201).json({ 
+    events: createdEvents.map(e => ({ 
+      id: e.id, 
+      tenant_id: e.tenant_id, 
+      name: e.name, 
+      properties: e.properties, 
+      timestamp: e.timestamp 
+    })) 
+  });
+});
+
+router.get('/', authMiddleware, (req: AuthRequest, res) => {
+  const { tenantId } = req.params;
+  const { user } = req;
+
+  if (!user || (tenantId && user.tenantId !== tenantId)) {
+    return res.status(401).json({ error: 'Unauthorized' });
+  }
+
+  const { name, timestampFrom, timestampTo, property, propertyValue } = req.query;
+
+  const whereInfo = buildWhereClause({
+    name: name as string,
+    timestampFrom: timestampFrom as string,
+    timestampTo: timestampTo as string,
+    property: property as string,
+    propertyValue: propertyValue as string
+  });
+
+  const tenant_id = tenantId || user?.tenantId;
+  const userId = user?.userId;
+
+  const userIdFilter = tenant_id === userId ? userId : undefined;
+
+  const events = eventQueries.findByTenant(tenant_id, userIdFilter);
+
+  let filteredEvents = events;
+
+  if (whereInfo.where !== '1=1') {
+    const stmt = db.prepare(`
+      SELECT * FROM events WHERE ${whereInfo.where}
+    `);
+    filteredEvents = stmt.all(...whereInfo.params) as any[];
+  }
+
+  res.json({ events: filteredEvents.map(e => ({
+    id: e.id,
+    tenant_id: e.tenant_id,
+    name: e.name,
+    properties: e.properties,
+    timestamp: e.timestamp,
+    user_id: e.user_id
+  })) });
+});
+
+router.delete('/:id', authMiddleware, (_req: AuthRequest, res) => {
+  res.json({ success: true });
+});
+
+export default router;
