+export interface EventFilter {
+  name?: string;
+  timestampFrom?: string;
+  timestampTo?: string;
+  property?: string;
+  propertyValue?: string;
+}
+
+export const buildWhereClause = (filter: EventFilter) => {
+  const conditions: string[] = ['1=1'];
+  const params: string[] = [];
+
+  if (filter.name) {
+    conditions.push('name = ?');
+    params.push(filter.name);
+  }
+
+  if (filter.timestampFrom) {
+    conditions.push('timestamp >= ?');
+    params.push(filter.timestampFrom);
+  }
+
+  if (filter.timestampTo) {
+    conditions.push('timestamp <= ?');
+    params.push(filter.timestampTo);
+  }
+
+  if (filter.property && filter.propertyValue) {
+    conditions.push(`json_extract(properties, '$.${filter.property}') = ?`);
+    params.push(filter.propertyValue);
+  }
+
+  return { where: conditions.join(' AND '), params };
+};
