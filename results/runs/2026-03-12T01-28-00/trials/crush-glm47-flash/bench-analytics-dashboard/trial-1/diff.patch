@@ -0,0 +1,52 @@
+import { Request, Response, NextFunction } from 'express';
+import { auth, JWTPayload } from './auth.js';
+
+export interface AuthRequest extends Request {
+  user?: JWTPayload;
+}
+
+export const authMiddleware = (req: AuthRequest, res: Response, next: NextFunction) => {
+  const authHeader = req.headers.authorization;
+
+  if (!authHeader || !authHeader.startsWith('Bearer ')) {
+    return res.status(401).json({ error: 'Bearer token missing or invalid format' });
+  }
+
+  const token = authHeader.substring(7);
+
+  const payload = auth.verifyToken(token);
+
+  if (!payload) {
+    return res.status(401).json({ error: 'Invalid or expired token' });
+  }
+
+  req.user = payload;
+  next();
+};
+
+export const optionalAuth = async (req: AuthRequest, res: Response, next: NextFunction) => {
+  const authHeader = req.headers.authorization;
+
+  if (authHeader && authHeader.startsWith('Bearer ')) {
+    const token = authHeader.substring(7);
+    const payload = auth.verifyToken(token);
+
+    if (payload) {
+      req.user = payload;
+    }
+  }
+
+  next();
+};
+
+export const requireTenantIsolation = (req: AuthRequest, res: Response, next: NextFunction) => {
+  if (!req.params.tenantId) {
+    return res.status(401).json({ error: 'Authorization required' });
+  }
+
+  if (req.user?.tenantId !== req.params.tenantId) {
+    return res.status(403).json({ error: 'Tenant isolation violation' });
+  }
+
+  next();
+};
