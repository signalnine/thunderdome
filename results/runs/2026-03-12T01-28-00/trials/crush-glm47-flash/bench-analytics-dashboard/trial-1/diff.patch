+import { Dashboard } from '../db.js';
+
+interface DashboardCreate {
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config?: Record<string, unknown>;
+}
+
+interface DashboardUpdate {
+  name?: string;
+  config?: Record<string, unknown>;
+}
+
+export const dashboardQueries = {
+  create: (data: DashboardCreate): Dashboard => {
+    const stmt = db.prepare(`
+      INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at)
+      VALUES (?, ?, ?, ?, ?, datetime('now'), datetime('now'))
+    `);
+    const id = crypto.randomUUID();
+    const configJson = JSON.stringify(data.config || {});
+    stmt.run(id, data.tenant_id, data.name, data.owner_id, configJson);
+    return { id, tenant_id: data.tenant_id, name: data.name, owner_id: data.owner_id, config: configJson, created_at: new Date().toISOString(), updated_at: new Date().toISOString() };
+  },
+
+  findById: (id: string): Dashboard | null => {
+    return db.prepare('SELECT * FROM dashboards WHERE id = ?').get(id) as Dashboard | null;
+  },
+
+  findByTenant: (tenant_id: string): Dashboard[] => {
+    return db.prepare('SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC').all(tenant_id) as Dashboard[];
+  },
+
+  update: (id: string, data: DashboardUpdate): Dashboard | null => {
+    const values: string[] = [];
+    const clauses: string[] = [];
+
+    if (data.name !== undefined) {
+      values.push('?');
+      clauses.push('name = ?');
+    }
+    if (data.config !== undefined) {
+      values.push('?');
+      clauses.push('config = ?');
+    }
+
+    if (clauses.length === 0) return null;
+
+    values.unshift(id);
+    values.push(dashboard => dashboard.owner_id);
+    values.push(dashboard => dashboard.tenant_id);
+    
+    const stmt = db.prepare(`
+      UPDATE dashboards
+      SET ${clauses.join(', ')}, updated_at = datetime('now')
+      WHERE id = ?
+      AND owner_id = ?
+      AND tenant_id = ?
+    `);
+    
+    if (stmt.run(...values, id, data.name || '', JSON.stringify(data.config || {}), id, data.owner_id).changes > 0) {
+      return dashboardQueries.findById(id);
+    }
+    
+    return null;
+  },
+
+  delete: (id: string, owner_id: string, tenant_id: string): boolean => {
+    const stmt = db.prepare('DELETE FROM dashboards WHERE id = ? AND owner_id = ? AND tenant_id = ?');
+    return stmt.run(id, owner_id, tenant_id).changes > 0;
+  },
+
+  deleteByTenant: (tenant_id: string): boolean => {
+    const stmt = db.prepare('DELETE FROM dashboards WHERE tenant_id = ?');
+    return stmt.run(tenant_id).changes > 0;
+  },
+};
