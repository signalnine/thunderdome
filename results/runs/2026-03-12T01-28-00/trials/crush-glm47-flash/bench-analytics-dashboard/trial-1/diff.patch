+import jwt from 'jsonwebtoken';
+
+const JWT_SECRET = process.env.JWT_SECRET || 'your-secret-key-change-this-in-production';
+const TOKEN_LIFETIME = '7d';
+
+export interface JWTPayload {
+  userId: string;
+  tenantId: string;
+  role: 'admin' | 'viewer' | 'editor';
+  email: string;
+}
+
+export const auth = {
+  signToken: (payload: JWTPayload): string => {
+    return jwt.sign(payload, JWT_SECRET, { expiresIn: TOKEN_LIFETIME });
+  },
+
+  verifyToken: (token: string): JWTPayload | null => {
+    try {
+      return jwt.verify(token, JWT_SECRET) as JWTPayload;
+    } catch (err) {
+      return null;
+    }
+  },
+
+  generateRefreshToken: (userId: string, tenantId: string, role: 'admin' | 'viewer' | 'editor', email: string): string => {
+    return auth.signToken({ userId, tenantId, role, email });
+  },
+
+  generateAccessToken: (userId: string, tenantId: string, role: 'admin' | 'viewer' | 'editor', email: string): string => {
+    return auth.signToken({ userId, tenantId, role, email });
+  },
+};
