+import { db } from '../db.js';
+
+interface EventCreate {
+  user_id?: string;
+  _tenant_id?: string;
+  name: string;
+  properties: Record<string, any>;
+  timestamp?: string;
+}
+
+export const eventQueries = {
+  create: (data: EventCreate): { id: string; tenant_id: string; name: string; properties: string; timestamp: string; user_id: string } => {
+    const stmt = db.prepare(`
+      INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id)
+      VALUES (?, ?, ?, ?, ?, ?)
+    `);
+    const id = crypto.randomUUID();
+    const propertiesJson = JSON.stringify(data.properties);
+    const timestamp = data.timestamp || new Date().toISOString();
+    const tenant_id = data._tenant_id || data.tenant_id;
+    const user_id = data.user_id;
+    stmt.run(id, tenant_id, data.name, propertiesJson, timestamp, user_id);
+    return { id, tenant_id, name: data.name, properties: propertiesJson, timestamp, user_id };
+  },
+
+  db,
+};
+
+export const batchCreate = async (events: EventCreate[]): Promise<{ id: string; tenant_id: string; name: string; properties: string; timestamp: string; user_id: string }[]> => {
+  const stmt = eventQueries.db.prepare(`
+    INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id)
+    VALUES (?, ?, ?, ?, ?, ?)
+  `);
+
+  const insertMany = eventQueries.db.transaction((events: EventCreate[]) => {
+    const results: { id: string; tenant_id: string; name: string; properties: string; timestamp: string; user_id: string }[] = [];
+    for (const event of events) {
+      const id = crypto.randomUUID();
+      const tenant_id = event._tenant_id || event.tenant_id;
+      const user_id = event.user_id;
+      const name = event.name;
+      const propertiesJson = JSON.stringify(event.properties || {});
+      const timestamp = event.timestamp || new Date().toISOString();
+      stmt.run(id, tenant_id, name, propertiesJson, timestamp, user_id);
+      results.push({ id, tenant_id, name, properties: propertiesJson, timestamp, user_id });
+    }
+    return results;
+  });
+
+  return insertMany(events);
+};
