+import { Router } from 'express';
+import { authMiddleware, AuthRequest } from '../middleware/auth.middleware.js';
+import { eventQueries } from '../models/event.model.js';
+import { buildWhereClause, EventFilter } from '../filters.js';
+
+const router = Router();
+
+router.get('/stats', authMiddleware, async (req: AuthRequest, res) => {
+  const { tenantId } = req.params;
+  const { user } = req;
+
+  if (!user || (tenantId && user.tenantId !== tenantId)) {
+    return res.status(401).json({ error: 'Unauthorized' });
+  }
+
+  const tenant_id = tenantId || user?.tenantId;
+  const userId = tenant_id === user?.userId ? user?.userId : undefined;
+
+  const whereInfo = buildWhereClause({
+    property: 'name',
+    propertyValue: req.query.name as string
+  });
+
+  let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+  const params: any[] = [tenant_id];
+
+  if (userId) {
+    query += ' AND user_id = ?';
+    params.push(userId);
+  }
+
+  if (whereInfo.where !== '1=1') {
+    query += ` AND ${whereInfo.where}`;
+  }
+
+  const stmt = eventQueries['db'].prepare(query);
+  const result = stmt.get(...(params as any[]));
+
+  res.json({ count: result?.count || 0 });
+});
+
+router.get('/timeseries', authMiddleware, (req: AuthRequest, res) => {
+  const { tenantId } = req.params;
+  const { user } = req;
+
+  if (!user || (tenantId && user.tenantId !== tenantId)) {
+    return res.status(401).json({ error: 'Unauthorized' });
+  }
+
+  const { tenant_id, userId } = req.query as Record<string, string | undefined>;
+  const { name, interval = 'day', timestampFrom, timestampTo } = req.query as Record<string, string | undefined>;
+
+  const bucketStart = new Date(timestampFrom || new Date().toISOString());
+  bucketStart.setHours(0, 0, 0, 0);
+
+  const bucketEnd = new Date(timestampTo || new Date().toISOString());
+  bucketEnd.setHours(23, 59, 59, 999);
+
+  let dateTrunc = 'day';
+  if (interval === 'hour') dateTrunc = 'hour';
+  else if (interval === 'minute') dateTrunc = 'minute';
+
+  const groupByClause = `to_char(date_trunc('${dateTrunc}', timestamp), ${dateTrunc === 'minute' ? "'YYYY-MM-DD HH24:MI'" : "'YYYY-MM-DD'")}`;
+  const tenant_id_val = tenantId || user?.tenantId;
+  let query = `
+    SELECT ${groupByClause} as timestamp, COUNT(*) as count
+    FROM events 
+    WHERE tenant_id = ?
+    AND timestamp >= ?
+    AND timestamp <= ?
+  `;
+  const params: string[] = [tenant_id_val, bucketStart.toISOString().replace('.000Z', ''), bucketEnd.toISOString().replace('.000Z', '')];
+
+  if (userId) {
+    query += ' AND user_id = ?';
+    params.push(userId);
+  }
+
+  if (name) {
+    query += ' AND name = ?';
+    params.push(name);
+  }
+
+  query += ` GROUP BY ${groupByClause} ORDER BY timestamp ASC`;
+
+  const stmt = eventQueries['db'].prepare(query);
+  const results = stmt.all(...params);
+
+  const timeseries = results.map((row: { [key: string]: any }) => ({
+    timestamp: row.timestamp,
+    count: row.count
+  }));
+
+  res.json({ timeseries });
+});
+
+router.get('/breakdown', authMiddleware, (req: AuthRequest, res) => {
+  const { tenantId } = req.params;
+  const { user } = req;
+
+  if (!user || (tenantId && user.tenantId !== tenantId)) {
+    return res.status(401).json({ error: 'Unauthorized' });
+  }
+
+  const { name, breakdownProperty, timestampFrom, timestampTo } = req.query as Record<string, string | undefined>;
+  const { tenant_id, userId } = req.query as Record<string, string | undefined>;
+
+  const bucketStart = timestampFrom ? new Date(timestampFrom) : new Date();
+  const bucketEnd = timestampTo ? new Date(timestampTo) : new Date();
+
+  const query = `
+    SELECT 
+      json_extract(properties, '$.${breakdownProperty}') as value,
+      COUNT(*) as count
+    FROM events 
+    WHERE tenant_id = ?
+    AND name = ?
+    AND timestamp >= ?
+    AND timestamp <= ?
+  `;
+  const params: string[] = [tenant_id, name, bucketStart.toISOString().replace('.000Z', ''), bucketEnd.toISOString().replace('.000Z', '')];
+
+  if (userId) {
+    query += ' AND user_id = ?';
+    params.push(userId);
+  }
+
+  query += ' GROUP BY value ORDER BY count DESC';
+
+  const stmt = eventQueries['db'].prepare(query);
+  const results = stmt.all(...params);
+
+  const breakdown = results.map((row: { [key: string]: any }) => ({
+    value: row.value || 'null',
+    count: row.count
+  }));
+
+  res.json({ breakdown });
+});
+
+export default router;
