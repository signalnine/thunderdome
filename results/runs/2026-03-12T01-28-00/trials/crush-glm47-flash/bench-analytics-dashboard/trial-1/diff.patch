+router.get('/', authMiddleware, (req: AuthRequest, res) => {
+  if (!req.user) {
+    return res.status(401).json({ error: 'Unauthorized' });
+  }
+
+  const dashboards = dashboardQueries.findByTenant(req.user.tenantId);
+
+  res.json({ dashboards: dashboards.map(d => ({ id: d.id, name: d.name, config: d.config })) });
+});
+
+router.get('/:dashboardId', authMiddleware, (req: AuthRequest, res) => {
+  if (!req.user) {
+    return res.status(401).json({ error: 'Unauthorized' });
+  }
+
+  const dashboard = dashboardQueries.findById(req.params.dashboardId);
+
+  if (!dashboard || dashboard.tenant_id !== req.user.tenantId) {
+    return res.status(404).json({ error: 'Dashboard not found' });
+  }
+
+  res.json({ dashboard: { id: dashboard.id, name: dashboard.name, config: dashboard.config, owner_id: dashboard.owner_id } });
+});
+
+router.put('/:dashboardId', authMiddleware, (req: AuthRequest, res) => {
+  if (!req.user) {
+    return res.status(401).json({ error: 'Unauthorized' });
+  }
+
+  const dashboard = dashboardQueries.findById(req.params.dashboardId);
+
+  if (!dashboard || dashboard.tenant_id !== req.user.tenantId || dashboard.owner_id !== req.user.userId) {
+    return res.status(403).json({ error: 'Permission denied' });
+  }
+
+  const { name, config } = req.body;
+
+  const updated = dashboardQueries.update(req.params.dashboardId, { name, config });
+
+  if (!updated) {
+    return res.status(404).json({ error: 'Dashboard not found' });
+  }
+
+  res.json({ dashboard: { id: updated.id, name: updated.name, config: updated.config } });
+});
+
+router.delete('/:dashboardId', authMiddleware, (req: AuthRequest, res) => {
+  if (!req.user) {
+    return res.status(401).json({ error: 'Unauthorized' });
+  }
+
+  const dashboard = dashboardQueries.findById(req.params.dashboardId);
+
+  if (!dashboard || dashboard.tenant_id !== req.user.tenantId || dashboard.owner_id !== req.user.userId) {
+    return res.status(403).json({ error: 'Permission denied' });
+  }
+
+  const deleted = dashboardQueries.delete(req.params.dashboardId, req.user.userId, req.user.tenantId);
+
+  if (!deleted) {
+    return res.status(404).json({ error: 'Dashboard not found' });
+  }
+
+  res.json({ success: true });
+});
