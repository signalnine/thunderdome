+import { User } from '../db.js';
+
+interface UserCreate {
+  email: string;
+  password: string;
+  tenant_id: string;
+  role?: 'admin' | 'viewer' | 'editor';
+}
+
+interface UserUpdate {
+  role?: 'admin' | 'viewer' | 'editor';
+}
+
+interface UserSelect {
+  id: string;
+  tenant_id: string;
+  email: string;
+}
+
+export const userQueries = {
+  create: (data: UserCreate): User => {
+    const stmt = db.prepare(`
+      INSERT INTO users (id, email, password_hash, tenant_id, role)
+      VALUES (?, ?, ?, ?, ?)
+    `);
+    const id = crypto.randomUUID();
+    stmt.run(id, data.email, data.password, data.tenant_id, data.role || 'viewer');
+    return { id, email: data.email, password_hash: data.password, tenant_id: data.tenant_id, role: data.role || 'viewer', created_at: new Date().toISOString() };
+  },
+
+  findByEmail: (email: string): User | null => {
+    return db.prepare('SELECT * FROM users WHERE email = ?').get(email) as User | null;
+  },
+
+  findById: (id: string): User | null => {
+    return db.prepare('SELECT * FROM users WHERE id = ?').get(id) as User | null;
+  },
+
+  findByTenant: (tenant_id: string): User[] => {
+    return db.prepare('SELECT * FROM users WHERE tenant_id = ?').all(tenant_id) as User[];
+  },
+
+  findByTenantAndRole: (tenant_id: string, role: 'admin' | 'viewer' | 'editor'): User[] => {
+    return db.prepare('SELECT * FROM users WHERE tenant_id = ? AND role = ?').all(tenant_id, role) as User[];
+  },
+
+  updateRole: (id: string, role: 'admin' | 'viewer' | 'editor'): boolean => {
+    const stmt = db.prepare('UPDATE users SET role = ? WHERE id = ?');
+    return stmt.run(role, id).changes > 0;
+  },
+
+  update: (id: string, data: UserUpdate): boolean => {
+    const values: string[] = [];
+    const clauses: string[] = [];
+
+    if (data.role !== undefined) {
+      values.push('?');
+      clauses.push("role = ?");
+    }
+
+    if (clauses.length === 0) return true;
+
+    values.unshift(id);
+    const stmt = db.prepare(`UPDATE users SET ${clauses.join(', ')} WHERE id = ?`);
+    return stmt.run(...values, id).changes > 0;
+  },
+
+  delete: (id: string): boolean => {
+    const stmt = db.prepare('DELETE FROM users WHERE id = ?');
+    return stmt.run(id).changes > 0;
+  },
+};
