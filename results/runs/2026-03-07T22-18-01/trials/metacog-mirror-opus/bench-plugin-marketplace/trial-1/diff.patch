+import { describe, it, expect, beforeEach } from 'vitest';
+import { createMarketplace, type Marketplace } from '../src/index.js';
+import type { PluginManifest } from '../src/types.js';
+
+function makeManifest(overrides: Partial<PluginManifest> = {}): PluginManifest {
+  return {
+    name: 'test-plugin',
+    version: '1.0.0',
+    description: 'A test plugin',
+    author: 'tester',
+    dependencies: {},
+    entryPoint: '1 + 1',
+    permissions: [],
+    ...overrides,
+  };
+}
+
+describe('Marketplace Integration', () => {
+  let marketplace: Marketplace;
+
+  beforeEach(() => {
+    marketplace = createMarketplace();
+  });
+
+  it('should install a simple plugin with no dependencies', async () => {
+    const manifest = makeManifest({ entryPoint: '42' });
+    const result = await marketplace.installPlugin(manifest);
+
+    expect(result.resolvedDependencies).toEqual([]);
+    expect(result.executionResult.success).toBe(true);
+    expect(result.executionResult.output).toBe(42);
+  });
+
+  it('should register the plugin during install', async () => {
+    const manifest = makeManifest();
+    await marketplace.installPlugin(manifest);
+
+    const registered = marketplace.registry.get('test-plugin');
+    expect(registered).not.toBeNull();
+    expect(registered!.version).toBe('1.0.0');
+  });
+
+  it('should resolve dependencies during install', async () => {
+    // First register the dependency
+    marketplace.registry.register(
+      makeManifest({
+        name: 'dep-plugin',
+        version: '1.0.0',
+        entryPoint: '"dep"',
+      })
+    );
+    marketplace.registry.register(
+      makeManifest({
+        name: 'dep-plugin',
+        version: '1.2.0',
+        entryPoint: '"dep"',
+      })
+    );
+
+    const manifest = makeManifest({
+      name: 'main-plugin',
+      dependencies: { 'dep-plugin': '^1.0.0' },
+      entryPoint: '"main"',
+    });
+
+    const result = await marketplace.installPlugin(manifest);
+    expect(result.resolvedDependencies).toHaveLength(1);
+    expect(result.resolvedDependencies[0].name).toBe('dep-plugin');
+    expect(result.resolvedDependencies[0].version).toBe('1.2.0');
+  });
+
+  it('should reject plugins with circular dependencies', async () => {
+    // Register A depending on B
+    marketplace.registry.register(
+      makeManifest({
+        name: 'a',
+        version: '1.0.0',
+        dependencies: { b: '^1.0.0' },
+      })
+    );
+    // Register B depending on A
+    marketplace.registry.register(
+      makeManifest({
+        name: 'b',
+        version: '1.0.0',
+        dependencies: { a: '^1.0.0' },
+      })
+    );
+
+    // Now try to install C which depends on A (which cycles with B)
+    const manifest = makeManifest({
+      name: 'c',
+      version: '1.0.0',
+      dependencies: { a: '^1.0.0' },
+      entryPoint: '"c"',
+    });
+
+    await expect(marketplace.installPlugin(manifest)).rejects.toThrow(
+      /[Cc]ircular/
+    );
+  });
+
+  it('should reject manifest without name', async () => {
