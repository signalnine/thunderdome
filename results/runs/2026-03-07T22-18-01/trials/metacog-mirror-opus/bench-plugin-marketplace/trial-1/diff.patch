@@ -0,0 +1,67 @@
+import vm from 'node:vm';
+import type { SandboxResult, RunnerService } from '../types.js';
+
+const DEFAULT_TIMEOUT = 5000;
+
+export function createRunner(): RunnerService {
+  async function runInSandbox(
+    code: string,
+    timeoutMs: number,
+    context: Record<string, unknown> = {}
+  ): Promise<SandboxResult> {
+    const start = performance.now();
+    const memBefore = process.memoryUsage().heapUsed;
+
+    try {
+      const sandbox: Record<string, unknown> = { ...context };
+      vm.createContext(sandbox);
+
+      const script = new vm.Script(code);
+      const output = script.runInContext(sandbox, { timeout: timeoutMs });
+
+      const duration = performance.now() - start;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - memBefore);
+
+      return {
+        success: true,
+        output,
+        duration,
+        memoryUsed,
+      };
+    } catch (err: unknown) {
+      const duration = performance.now() - start;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - memBefore);
+      // vm errors from a different realm are not instanceof Error, but have .message
+      const errObj = err as Record<string, unknown>;
+      const errorMessage =
+        typeof errObj === 'object' && errObj !== null && typeof errObj.message === 'string'
+          ? errObj.message
+          : String(err);
+
+      return {
+        success: false,
+        output: null,
+        duration,
+        memoryUsed,
+        error: errorMessage,
+      };
+    }
+  }
+
+  return {
+    async execute(
+      code: string,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return runInSandbox(code, DEFAULT_TIMEOUT, context);
+    },
+
+    async executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return runInSandbox(code, timeoutMs, context);
+    },
+  };
+}
