sion: '1.0.0',\n      userId: 'user2',\n      rating: 3,\n      comment: 'OK',\n    });\n    const badReview = reviews.addReview({\n      pluginName: 'my-plugin',\n      pluginVersion: '1.0.0',\n      userId: 'troll',\n      rating: 1,\n      comment: 'Spam!',\n    });\n\n    // Before flagging: average of 5, 3, 1 = 3\n    expect(reviews.getAverageRating('my-plugin')).toBe(3);\n\n    // Flag the troll review\n    reviews.flagReview(badReview.id);\n\n    // After flagging: average of 5, 3 = 4\n    expect(reviews.getAverageRating('my-plugin')).toBe(4);\n  });\n\n  it('should return 0 for average when no reviews exist', () => {\n    expect(reviews.getAverageRating('nonexistent')).toBe(0);\n  });\n\n  it('should flag a review', () => {\n    const review = reviews.addReview({\n      pluginName: 'test',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 1,\n      comment: 'Spam',\n    });\n\n    reviews.flagReview(review.id);\n    const flagged = reviews.getFlaggedReviews();\n    expect(flagged).toHaveLength(1);\n    expect(flagged[0].id).toBe(review.id);\n    expect(flagged[0].flagged).toBe(true);\n  });\n\n  it('should remove a review', () => {\n    const review = reviews.addReview({\n      pluginName: 'test',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 4,\n      comment: 'Good',\n    });\n\n    expect(reviews.removeReview(review.id)).toBe(true);\n    expect(reviews.getReviews('test')).toHaveLength(0);\n  });\n\n  it('should return false when removing nonexistent review', () => {\n    expect(reviews.removeReview(999)).toBe(false);\n  });\n\n  it('should get reviews by user', () => {\n    reviews.addReview({\n      pluginName: 'a',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 5,\n      comment: 'A',\n    });\n    reviews.addReview({\n      pluginName: 'b',\n      pluginVersion: '1.0.0',\n      userId: 'user1',\n      rating: 4,\n      comment: 'B',\n    });\n    reviews.addReview({\n      pluginName: '