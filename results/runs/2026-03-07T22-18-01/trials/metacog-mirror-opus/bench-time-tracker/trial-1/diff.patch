+++ b/src/tracker.ts
@@ -0,0 +1,123 @@
+import * as fs from "node:fs";
+import * as path from "node:path";
+import type { TimeEntry, TimeSummary, TimeTrackerOptions } from "./types.js";
+
+export class TimeTracker {
+  private readonly filePath: string;
+  private entries: TimeEntry[];
+
+  constructor(options: TimeTrackerOptions) {
+    this.filePath = path.resolve(options.filePath);
+    this.entries = this.load();
+  }
+
+  /**
+   * Start a new timer. If another timer is running, it is stopped first.
+   */
+  start(task: string): TimeEntry {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name cannot be empty");
+    }
+
+    // Stop any currently running timer
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    const entry: TimeEntry = {
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    };
+
+    this.entries.push(entry);
+    this.save();
+    return entry;
+  }
+
+  /**
+   * Stop the currently running timer.
+   */
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return running;
+  }
+
+  /**
+   * Get all entries, optionally filtered by date range.
+   */
+  getEntries(options?: { from?: Date; to?: Date }): TimeEntry[] {
+    if (!options) {
+      return [...this.entries];
+    }
+
+    return this.entries.filter((entry) => {
+      const startTime = new Date(entry.start).getTime();
+
+      if (options.from && startTime < options.from.getTime()) {
+        return false;
+      }
+
+      if (options.to && startTime > options.to.getTime()) {
+        return false;
+      }
+
+      return true;
+    });
+  }
+
+  /**
+   * Get total time per task in milliseconds.
+   * Running tasks use the current time for duration calculation.
+   */
+  getSummary(): TimeSummary {
+    const summary: TimeSummary = {};
+    const now = new Date();
+
+    for (const entry of this.entries) {
+      const start = new Date(entry.start).getTime();
+      const end = entry.stop ? new Date(entry.stop).getTime() : now.getTime();
+      const duration = end - start;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  /**
+   * Get the currently running entry, or null if none.
+   */
+  getRunningEntry(): TimeEntry | null {
+    return this.entries.find((e) => e.stop === null) ?? null;
+  }
+
+  private load(): TimeEntry[] {
+    try {
+      const data = fs.readFileSync(this.filePath, "utf-8");
+      const parsed: unknown = JSON.parse(data);
+      if (!Array.isArray(parsed)) {
+        return [];
+      }
+      return parsed as TimeEntry[];
+    } catch {
+      return [];
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    fs.writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+}
