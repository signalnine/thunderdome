fbfe5611-087b-4ec6-aef2-08052b2b701b","uuid":"d0618af9-7e72-4965-ab45-f6decb8f9a1a","tool_use_result":{"type":"text","file":{"filePath":"/workspace/tests/tracker.test.ts","content":"import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\nimport * as fs from \"node:fs\";\nimport * as path from \"node:path\";\nimport * as os from \"node:os\";\nimport { TimeTracker } from \"../src/index.js\";\n\nfunction tmpFile(): string {\n  const dir = fs.mkdtempSync(path.join(os.tmpdir(), \"timetracker-\"));\n  return path.join(dir, \"data.json\");\n}\n\nfunction cleanup(filePath: string): void {\n  try {\n    fs.rmSync(path.dirname(filePath), { recursive: true, force: true });\n  } catch {\n    // ignore\n  }\n}\n\ndescribe(\"TimeTracker\", () => {\n  let filePath: string;\n\n  beforeEach(() => {\n    filePath = tmpFile();\n  });\n\n  afterEach(() => {\n    cleanup(filePath);\n  });\n\n  describe(\"start\", () => {\n    it(\"should start a timer\", () => {\n      const tracker = new TimeTracker({ filePath });\n      const entry = tracker.start(\"coding\");\n\n      expect(entry.task).toBe(\"coding\");\n      expect(entry.start).toBeTruthy();\n      expect(entry.stop).toBeNull();\n    });\n\n    it(\"should throw on empty task name\", () => {\n      const tracker = new TimeTracker({ filePath });\n      expect(() => tracker.start(\"\")).toThrow(\"Task name cannot be empty\");\n    });\n\n    it(\"should throw on whitespace-only task name\", () => {\n      const tracker = new TimeTracker({ filePath });\n      expect(() => tracker.start(\"   \")).toThrow(\"Task name cannot be empty\");\n    });\n\n    it(\"should auto-stop previous timer when starting a new one\", () => {\n      const tracker = new TimeTracker({ filePath });\n      tracker.start(\"task1\");\n      tracker.start(\"task2\");\n\n      const entries = tracker.getEntries();\n      expect(entries).toHaveLength(2);\n      expect(entries[0].stop).not.toBeNull();\n      expect(entries[1].stop).toBeNull();\n    });\n\n    it(\"should support unicode and emoji task names\", () => {\n      const tracker = new TimeTracker({ filePath });\n      tracker.start(\"コーディング 🚀\");\n      const entry = tracker.stop();\n      expect(entry.task).toBe(\"コーディング 🚀\");\n\n      // Verify persistence\n      const tracker2 = new TimeTracker({ filePath });\n      const entries = tracker2.getEntries();\n      expect(entries[0].task).toBe(\"コーディング 🚀\");\n    });\n  });\n\n  describe(\"stop\", () => {\n    it(\"should stop a running timer\", () => {\n      const tracker = new TimeTracker({ filePath });\n      tracker.start(\"coding\");\n      const stopped = tracker.stop();\n\n      expect(stopped.task).toBe(\"coding\");\n      expect(stopped.stop).toBeTruthy();\n    });\n\n    it(\"should throw when no timer is running\", () => {\n      const tracker = new TimeTracker({ filePath });\n      expect(() => tracker.stop()).toThrow(\"No timer is currently running\");\n    });\n  });\n\n  describe(\"persistence\", () => {\n    it(\"should persist entries to disk\", () => {\n      const tracker1 = new TimeTracker({ filePath });\n      tracker1.start(\"task1\");\n      tracker1.stop();\n\n      const tracker2 = new TimeTracker({ filePath });\n      const entries = tracker2.getEntries();\n      expect(entries).toHaveLength(1);\n      expect(entries[0].task).toBe(\"task1\");\n    });\n\n    it(\"should create parent directories if they don't exist\", () => {\n      const deepPath = path.join(os.tmpdir(), \"tt-test\", \"deep\", \"nested\", \"data.json\");\n      try {\n        const tracker = new TimeTracker({ filePath: deepPath });\n        tracker.start(\"task\");\n        tracker.stop();\n\n        expect(fs.existsSync(deepPath)).toBe(true);\n      } finally {\n        fs.rmSync(path.join(os.tmpdir(), \"tt-test\"), { recursive: true, force: true });\n      }\n    });\n\n    it(\"should handle missing file gracefully on load\", () => {\n      const tracker = new TimeTracker({ filePath: \"/tmp/nonexistent-