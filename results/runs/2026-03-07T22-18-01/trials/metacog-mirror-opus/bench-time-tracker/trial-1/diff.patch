+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import * as fs from "node:fs";
+import * as path from "node:path";
+import * as os from "node:os";
+import { TimeTracker } from "../src/index.js";
+
+function tmpFile(): string {
+  const dir = fs.mkdtempSync(path.join(os.tmpdir(), "timetracker-"));
+  return path.join(dir, "data.json");
+}
+
+function cleanup(filePath: string): void {
+  try {
+    fs.rmSync(path.dirname(filePath), { recursive: true, force: true });
+  } catch {
+    // ignore
+  }
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+  });
+
+  afterEach(() => {
+    cleanup(filePath);
+  });
+
+  describe("start", () => {
+    it("should start a timer", () => {
+      const tracker = new TimeTracker({ filePath });
+      const entry = tracker.start("coding");
+
+      expect(entry.task).toBe("coding");
+      expect(entry.start).toBeTruthy();
+      expect(entry.stop).toBeNull();
+    });
+
+    it("should throw on empty task name", () => {
+      const tracker = new TimeTracker({ filePath });
+      expect(() => tracker.start("")).toThrow("Task name cannot be empty");
+    });
+
+    it("should throw on whitespace-only task name", () => {
+      const tracker = new TimeTracker({ filePath });
+      expect(() => tracker.start("   ")).toThrow("Task name cannot be empty");
+    });
+
+    it("should auto-stop previous timer when starting a new one", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("task1");
+      tracker.start("task2");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].stop).not.toBeNull();
+      expect(entries[1].stop).toBeNull();
+    });
+
+    it("should support unicode and emoji task names", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("コーディング 🚀");
+      const entry = tracker.stop();
+      expect(entry.task).toBe("コーディング 🚀");
+
+      // Verify persistence
+      const tracker2 = new TimeTracker({ filePath });
+      const entries = tracker2.getEntries();
+      expect(entries[0].task).toBe("コーディング 🚀");
+    });
+  });
+
+  describe("stop", () => {
+    it("should stop a running timer", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("coding");
+      const stopped = tracker.stop();
+
+      expect(stopped.task).toBe("coding");
+      expect(stopped.stop).toBeTruthy();
+    });
+
+    it("should throw when no timer is running", () => {
+      const tracker = new TimeTracker({ filePath });
+      expect(() => tracker.stop()).toThrow("No timer is currently running");
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to disk", () => {
+      const tracker1 = new TimeTracker({ filePath });
+      tracker1.start("task1");
+      tracker1.stop();
+
+      const tracker2 = new TimeTracker({ filePath });
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("task1");
+    });
+
+    it("should create parent directories if they don't exist", () => {
+      const deepPath = path.join(os.tmpdir(), "tt-test", "deep", "nested", "data.json");
+      try {
+        const tracker = new TimeTracker({ filePath: deepPath });
+        tracker.start("task");
+        tracker.stop();
+
+        expect(fs.existsSync(deepPath)).toBe(true);
+      } finally {
+        fs.rmSync(path.join(os.tmpdir(), "tt-test"), { recursive: true, force: true });
+      }
+    });
+
+    it("should handle missing file gracefully on load", () => {
+      const tracker = new TimeTracker({ filePath: "/tmp/nonexistent-tt/data.json" });
+      expect(tracker.getEntries()).toEqual([]);
+    });
+  });
+
+  describe("getEntries", () => {
+    it("should return all entries", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("task1");
+      tracker.stop();
+      tracker.start("task2");
+      tracker.stop();
+
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter by date range", () => {
+      const tracker = new TimeTracker({ filePath });
+
+      // Create entries at different times
+      tracker.start("old-task");
+      tracker.stop();
+
+      const afterFirst = new Date();
+
+      tracker.start("new-task");
+      tracker.stop();
+
+      const entries = tracker.getEntries({ from: afterFirst });
+      expect(entries.length).toBeGreaterThanOrEqual(1);
+      expect(entries[entries.length - 1].task).toBe("new-task");
+    });
+
+    it("should filter with to date", () => {
+      const tracker = new TimeTracker({ filePath });
+
+      tracker.start("task1");
+      tracker.stop();
+
+      // Use a date far in the past so it definitely excludes the entry
+      const pastDate = new Date("2000-01-01T00:00:00Z");
+      const entries = tracker.getEntries({ to: pastDate });
+      expect(entries).toHaveLength(0);
+    });
+  });
+
+  describe("getSummary", () => {
+    it("should sum durations per task", () => {
+      const tracker = new TimeTracker({ filePath });
+
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("review");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      // Durations may be 0ms when start/stop happen in same millisecond
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(summary["review"]).toBeGreaterThanOrEqual(0);
+      expect("coding" in summary).toBe(true);
+      expect("review" in summary).toBe(true);
+    });
+
+    it("should include running tasks using current time", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("running-task");
+
+      const summary = tracker.getSummary();
+      // Running tasks should appear in summary
+      expect("running-task" in summary).toBe(true);
+      expect(summary["running-task"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("getRunningEntry", () => {
+    it("should return null when nothing is running", () => {
+      const tracker = new TimeTracker({ filePath });
+      expect(tracker.getRunningEntry()).toBeNull();
+    });
+
+    it("should return the running entry", () => {
+      const tracker = new TimeTracker({ filePath });
+      tracker.start("active");
+      const running = tracker.getRunningEntry();
+      expect(running).not.toBeNull();
+      expect(running!.task).toBe("active");
+    });
   });
 });
