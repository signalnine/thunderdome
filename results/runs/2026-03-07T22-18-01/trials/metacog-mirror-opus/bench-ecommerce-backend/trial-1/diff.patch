) => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    expect(catalog.listProducts()).toHaveLength(2);\n  });\n\n  it('should list products by category', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('A', 1, 'cat1');\n    catalog.createProduct('B', 2, 'cat2');\n    catalog.createProduct('C', 3, 'cat1');\n    expect(catalog.listProducts('cat1')).toHaveLength(2);\n  });\n\n  it('should search products by name', () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Blue Widget', 1, 'gadgets');\n    catalog.createProduct('Red Gizmo', 2, 'gadgets');\n    const results = catalog.searchProducts('widget');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('Blue Widget');\n  });\n\n  it('should update a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    catalog.updateProduct(id, { price: 14.99 });\n    expect(catalog.getProduct(id)?.price).toBe(14.99);\n  });\n\n  it('should remove a product', () => {\n    const catalog = createCatalogService(bus);\n    const id = catalog.createProduct('Widget', 9.99, 'gadgets');\n    expect(catalog.removeProduct(id)).toBe(true);\n    expect(catalog.getProduct(id)).toBeNull();\n  });\n\n  it('should emit product:created event', async () => {\n    const catalog = createCatalogService(bus);\n    catalog.createProduct('Widget', 9.99, 'gadgets');\n    // wait for async event\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PRODUCT_CREATED)).toBe(true);\n  });\n});\n\ndescribe('InventoryService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should set and get stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 100);\n    expect(inventory.getStock('p1')).toBe(100);\n  });\n\n  it('should return 0 for unknown product stock', () => {\n    const inventory = createInventoryService(bus);\n    expect(inventory.getStock('unknown')).toBe(0);\n  });\n\n  it('should reserve stock successfully', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    expect(inventory.reserve('p1', 5)).toBe(true);\n    expect(inventory.getStock('p1')).toBe(5);\n  });\n\n  it('should fail to reserve when insufficient stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 3);\n    expect(inventory.reserve('p1', 5)).toBe(false);\n  });\n\n  it('should release reserved stock', () => {\n    const inventory = createInventoryService(bus);\n    inventory.setStock('p1', 10);\n    inventory.reserve('p1', 5);\n    inventory.release('p1', 3);\n    expect(inventory.getStock('p1')).toBe(8);\n  });\n\n  it('should emit low stock alert when threshold is met', async () => {\n    const inventory = createInventoryService(bus);\n    let alertFired = false;\n    bus.on(Events.LOW_STOCK_ALERT, () => { alertFired = true; });\n    inventory.setStock('p1', 5);\n    inventory.setLowStockThreshold('p1', 10);\n    await new Promise(r => setTimeout(r, 10));\n    expect(alertFired).toBe(true);\n  });\n});\n\ndescribe('CartService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create a cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    expect(id).toBeDefined();\n  });\n\n  it('should add items to cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(1);\n    expect(c?.items[0]).toEqual({ productId: 'p1', quantity: 2 });\n  });\n\n  it('should consolidate same product items', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.addItem(id, 'p1', 3);\n    const c = cart.getCart(id);\n    expect(c?.items).toHaveLength(1);\n    expect(c?.items[0].quantity).toBe(5);\n  });\n\n  it('should remove items from cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.removeItem(id, 'p1');\n    expect(cart.getCart(id)?.items).toHaveLength(0);\n  });\n\n  it('should update item quantity', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.updateQuantity(id, 'p1', 10);\n    expect(cart.getCart(id)?.items[0].quantity).toBe(10);\n  });\n\n  it('should clear cart', () => {\n    const cart = createCartService(bus);\n    const id = cart.createCart('user1');\n    cart.addItem(id, 'p1', 2);\n    cart.clearCart(id);\n    expect(cart.getCart(id)?.items).toHaveLength(0);\n  });\n\n  it('should return null for non-existent cart', () => {\n    const cart = createCartService(bus);\n    expect(cart.getCart('fake')).toBeNull();\n  });\n});\n\ndescribe('PricingService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should calculate total with tax', () => {\n    const pricing = createPricingService(bus);\n    const result = pricing.calculateTotal([{ productId: 'p1', quantity: 2, price: 10 }]);\n    expect(result.subtotal).toBe(20);\n    expect(result.discount).toBe(0);\n    expect(result.tax).toBe(2);\n    expect(result.total).toBe(22);\n  });\n\n  it('should apply discount code', () => {\n    const pricing = createPricingService(bus);\n    pricing.addDiscountCode('SAVE10', 10);\n    const result = pricing.calculateTotal(\n      [{ productId: 'p1', quantity: 1, price: 100 }],\n      'SAVE10'\n    );\n    expect(result.subtotal).toBe(100);\n    expect(result.discount).toBe(10);\n    expect(result.tax).toBe(9); // 10% of (100-10)\n    expect(result.total).toBe(99);\n  });\n\n  it('should track prices from product:created events', async () => {\n    const pricing = createPricingService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'Widget', price: 25, category: 'gadgets' });\n    expect(pricing.getPrice('p1')).toBe(25);\n  });\n\n  it('should return 0 for unknown product price', () => {\n    const pricing = createPricingService(bus);\n    expect(pricing.getPrice('unknown')).toBe(0);\n  });\n});\n\ndescribe('OrderService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should create an order', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    expect(id).toBeDefined();\n  });\n\n  it('should get order by id', () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    const order = orders.getOrder(id);\n    expect(order).toEqual({ id, userId: 'user1', status: OrderStatus.PENDING, total: 100 });\n  });\n\n  it('should update order status', async () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    expect(orders.getOrder(id)?.status).toBe(OrderStatus.CONFIRMED);\n  });\n\n  it('should emit order:status_changed with previousStatus', async () => {\n    const orders = createOrderService(bus);\n    const id = orders.createOrder('user1', 'cart1', 100);\n    await new Promise(r => setTimeout(r, 10));\n    orders.updateStatus(id, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n    const log = bus.getLog();\n    const statusEvent = log.find(e => e.event === Events.ORDER_STATUS_CHANGED);\n    expect(statusEvent).toBeDefined();\n    const payload = statusEvent?.payload as { previousStatus: string };\n    expect(payload.previousStatus).toBe(OrderStatus.PENDING);\n  });\n\n  it('should list orders by user', () => {\n    const orders = createOrderService(bus);\n    orders.createOrder('user1', 'cart1', 100);\n    orders.createOrder('user1', 'cart2', 200);\n    orders.createOrder('user2', 'cart3', 50);\n    expect(orders.listOrders('user1')).toHaveLength(2);\n  });\n\n  it('should return null for non-existent order', () => {\n    const orders = createOrderService(bus);\n    expect(orders.getOrder('fake')).toBeNull();\n  });\n});\n\ndescribe('PaymentService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should process payment successfully', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.SUCCESS);\n    expect(result.transactionId).toBeDefined();\n  });\n\n  it('should simulate payment failure', async () => {\n    const payment = createPaymentService(bus, { simulateFailure: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.FAILED);\n    expect(result.error).toBeDefined();\n  });\n\n  it('should simulate payment timeout', async () => {\n    const payment = createPaymentService(bus, { simulateTimeout: true });\n    const result = await payment.processPayment('order1', 100);\n    expect(result.status).toBe(PaymentStatus.TIMEOUT);\n  });\n\n  it('should refund a successful payment', async () => {\n    const payment = createPaymentService(bus);\n    const result = await payment.processPayment('order1', 100);\n    const refunded = await payment.refund(result.transactionId!);\n    expect(refunded).toBe(true);\n  });\n\n  it('should fail to refund non-existent transaction', async () => {\n    const payment = createPaymentService(bus);\n    const refunded = await payment.refund('fake-txn');\n    expect(refunded).toBe(false);\n  });\n\n  it('should emit payment:processed event', async () => {\n    const payment = createPaymentService(bus);\n    await payment.processPayment('order1', 100);\n    const log = bus.getLog();\n    expect(log.some(e => e.event === Events.PAYMENT_PROCESSED)).toBe(true);\n  });\n});\n\ndescribe('NotificationService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should subscribe user and receive order notifications', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    // Simulate order created event\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(1);\n    expect(notifs[0].type).toBe('order_created');\n  });\n\n  it('should not notify unsubscribed users', async () => {\n    const notifications = createNotificationService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    expect(notifications.getNotifications('user1')).toHaveLength(0);\n  });\n\n  it('should notify on payment events', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    // First create order mapping\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'txn1' });\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'payment')).toBe(true);\n  });\n\n  it('should notify on order status changes', async () => {\n    const notifications = createNotificationService(bus);\n    notifications.subscribe('user1');\n\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'user1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.ORDER_STATUS_CHANGED, { orderId: 'o1', status: OrderStatus.CONFIRMED, previousStatus: OrderStatus.PENDING });\n\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.some(n => n.type === 'order_status')).toBe(true);\n  });\n});\n\ndescribe('AnalyticsService', () => {\n  let bus: EventBus;\n\n  beforeEach(() => {\n    bus = new EventBus();\n  });\n\n  it('should count events', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p1', name: 'W', price: 10, category: 'c' });\n    await bus.emit(Events.PRODUCT_CREATED, { productId: 'p2', name: 'X', price: 20, category: 'c' });\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n  });\n\n  it('should track revenue from successful payments', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.SUCCESS, transactionId: 'txn1' });\n    expect(analytics.getRevenue()).toBe(100);\n  });\n\n  it('should not count failed payments as revenue', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    await bus.emit(Events.PAYMENT_PROCESSED, { orderId: 'o1', status: PaymentStatus.FAILED, error: 'fail' });\n    expect(analytics.getRevenue()).toBe(0);\n  });\n\n  it('should calculate conversion rate', async () => {\n    const analytics = createAnalyticsService(bus);\n    // 2 carts, 1 order => 50% conversion\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c1', userId: 'u1', items: [] });\n    await bus.emit(Events.CART_UPDATED, { cartId: 'c2', userId: 'u2', items: [] });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n    expect(analytics.getConversionRate()).toBe(0.5);\n  });\n\n  it('should return 0 conversion rate with no carts', () => {\n    const analytics = createAnalyticsService(bus);\n    expect(analytics.getConversionRate()).toBe(0);\n  });\n\n  it('should track top products', async () => {\n    const analytics = createAnalyticsService(bus);\n    await bus.emit(Events.CART_UPDATED, {\n      cartId: 'c1', userId: 'u1',\n      items: [{ productId: 'p1', quantity: 5 }, { productId: 'p2', quantity: 2 }]\n    });\n    await bus.emit(Events.ORDER_CREATED, { orderId: 'o1', userId: 'u1', cartId: 'c1', total: 100 });\n\n    const top = analytics.getTopProducts(2);\n    expect(top[0].productId).toBe('p1');\n    expect(top[0].count).toBe(5);\n    expect(top[1].productId).toBe('p2');\n    expect(top[1].count).toBe(2);\n  });\n});\n\ndescribe('Integration: Full E-Commerce Flow', () => {\n  it('should handle a complete purchase flow', async () => {\n    const bus = new EventBus();\n\n    // Create all services\n    const catalog = createCatalogService(bus);\n    const inventory = createInventoryService(bus);\n    const cart = createCartService(bus);\n    const pricing = createPricingService(bus);\n    const orders = createOrderService(bus);\n    const payment = createPaymentService(bus);\n    const notifications = createNotificationService(bus);\n    const analytics = createAnalyticsService(bus);\n\n    // Subscribe user for notifications\n    notifications.subscribe('user1');\n\n    // Create products (emits product:created, pricing listens)\n    const p1 = catalog.createProduct('Laptop', 999.99, 'electronics');\n    const p2 = catalog.createProduct('Mouse', 29.99, 'electronics');\n\n    // Wait for events to propagate\n    await new Promise(r => setTimeout(r, 10));\n\n    // Set inventory\n    inventory.setStock(p1, 50);\n    inventory.setStock(p2, 200);\n\n    // Pricing should know about product prices\n    expect(pricing.getPrice(p1)).toBe(999.99);\n    expect(pricing.getPrice(p2)).toBe(29.99);\n\n    // Create a cart and add items\n    const cartId = cart.createCart('user1');\n    cart.addItem(cartId, p1, 1);\n    cart.addItem(cartId, p2, 2);\n\n    // Calculate total\n    const cartData = cart.getCart(cartId)!;\n    const items = cartData.items.map(item => ({\n      productId: item.productId,\n      quantity: item.quantity,\n      price: pricing.getPrice(item.productId),\n    }));\n\n    pricing.addDiscountCode('WELCOME10', 10);\n    const total = pricing.calculateTotal(items, 'WELCOME10');\n\n    // Verify discount: subtotal=1059.97, discount=105.997, tax=95.3973, total=1049.37\n    expect(total.subtotal).toBe(1059.97);\n    expect(total.discount).toBeCloseTo(106, 0);\n\n    // Reserve inventory\n    expect(inventory.reserve(p1, 1)).toBe(true);\n    expect(inventory.reserve(p2, 2)).toBe(true);\n\n    // Create order\n    const orderId = orders.createOrder('user1', cartId, total.total);\n    await new Promise(r => setTimeout(r, 10));\n\n    expect(orders.getOrder(orderId)?.status).toBe(OrderStatus.PENDING);\n\n    // Process payment\n    const paymentResult = await payment.processPayment(orderId, total.total);\n    expect(paymentResult.status).toBe(PaymentStatus.SUCCESS);\n\n    // Update order status\n    orders.updateStatus(orderId, OrderStatus.CONFIRMED);\n    await new Promise(r => setTimeout(r, 10));\n\n    // Verify notifications\n    const notifs = notifications.getNotifications('user1');\n    expect(notifs.length).toBeGreaterThanOrEqual(2); // order_created + payment + status change\n\n    // Verify analytics\n    expect(analytics.getEventCount(Events.PRODUCT_CREATED)).toBe(2);\n    expect(analytics.getRevenue()).toBeGreaterThan(0);\n    expect(analytics.getConversionRate()).toBeGreaterThan(0);\n\n    // Verify top products\n    const topProducts = analytics.getTopProducts(5);\n    expect(topProducts.length).toBeGreaterThanOrEqual(1);\n\n    // Ignore unused vars for lint\n    void catalog;\n  });\n});\n","structuredPatch":[],"originalFile":null}}
