+++ b/src/routes/events.ts
@@ -0,0 +1,133 @@
+import { Router } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { authMiddleware, AuthRequest } from "../auth.js";
+import { AppError } from "../errors.js";
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // POST /api/events - single event ingestion
+  router.post("/events", authMiddleware, (req: AuthRequest, res, next) => {
+    try {
+      const { name, properties, timestamp, session_id } = req.body as {
+        name?: string;
+        properties?: Record<string, unknown>;
+        timestamp?: string;
+        session_id?: string;
+      };
+
+      if (!name) {
+        throw new AppError(400, "Event name is required", "VALIDATION_ERROR");
+      }
+
+      const id = uuidv4();
+      const tenantId = req.user!.tid;
+      const userId = req.user!.sub;
+      const eventTimestamp = timestamp || new Date().toISOString();
+      const eventProperties = JSON.stringify(properties || {});
+
+      db.prepare(
+        "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+      ).run(id, tenantId, name, eventProperties, eventTimestamp, userId, session_id || null);
+
+      res.status(201).json({
+        event: {
+          id,
+          tenant_id: tenantId,
+          name,
+          properties: properties || {},
+          timestamp: eventTimestamp,
+          user_id: userId,
+          session_id: session_id || null,
+        },
+      });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // POST /api/events/batch - batch event ingestion
+  router.post("/events/batch", authMiddleware, (req: AuthRequest, res, next) => {
+    try {
+      const { events } = req.body as {
+        events?: Array<{
+          name: string;
+          properties?: Record<string, unknown>;
+          timestamp?: string;
+          session_id?: string;
+        }>;
+      };
+
+      if (!events || !Array.isArray(events) || events.length === 0) {
+        throw new AppError(400, "events array is required and must not be empty", "VALIDATION_ERROR");
+      }
+
+      const tenantId = req.user!.tid;
+      const userId = req.user!.sub;
+
+      const insertStmt = db.prepare(
+        "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+      );
+
+      const insertMany = db.transaction(
+        (
+          items: Array<{
+            name: string;
+            properties?: Record<string, unknown>;
+            timestamp?: string;
+            session_id?: string;
+          }>
+        ) => {
+          const results: Array<{
+            id: string;
+            tenant_id: string;
+            name: string;
+            properties: Record<string, unknown>;
+            timestamp: string;
+            user_id: string;
+            session_id: string | null;
+          }> = [];
+
+          for (const event of items) {
+            if (!event.name) continue;
+
+            const id = uuidv4();
+            const eventTimestamp = event.timestamp || new Date().toISOString();
+            const eventProperties = JSON.stringify(event.properties || {});
+
+            insertStmt.run(
+              id,
+              tenantId,
+              event.name,
+              eventProperties,
+              eventTimestamp,
+              userId,
+              event.session_id || null
+            );
+
+            results.push({
+              id,
+              tenant_id: tenantId,
+              name: event.name,
+              properties: event.properties || {},
+              timestamp: eventTimestamp,
+              user_id: userId,
+              session_id: event.session_id || null,
+            });
+          }
+
+          return results;
+        }
+      );
+
+      const results = insertMany(events);
+
+      res.status(201).json({ events: results, count: results.length });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  return router;
+}
diff --git a/src/routes/export.ts b/src/routes/export.ts
new file mode 100644
index 0000000..31422c0
--- /dev/null
+++ b/src/routes/export.ts
@@ -0,0 +1,210 @@
+import { Router } from "express";
+import Database from "better-sqlite3";
+import { authMiddleware, AuthRequest } from "../auth.js";
+import { AppError } from "../errors.js";
+
+interface EventRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string;
+  timestamp: string;
+  user_id: string | null;
+  session_id: string | null;
+}
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+function escapeCsvField(field: string): string {
+  if (field.includes(",") || field.includes('"') || field.includes("\n")) {
+    return `"${field.replace(/"/g, '""')}"`;
+  }
+  return field;
+}
+
+function eventsToCsv(events: EventRow[]): string {
+  const header = "id,tenant_id,name,properties,timestamp,user_id,session_id";
+  const rows = events.map(
+    (e) =>
+      [
+        escapeCsvField(e.id),
+        escapeCsvField(e.tenant_id),
+        escapeCsvField(e.name),
+        escapeCsvField(e.properties),
+        escapeCsvField(e.timestamp),
+        escapeCsvField(e.user_id || ""),
+        escapeCsvField(e.session_id || ""),
+      ].join(",")
+  );
+  return [header, ...rows].join("\n");
+}
+
+function dashboardsToCsv(dashboards: Array<DashboardRow & { widgets?: WidgetRow[] }>): string {
+  const header = "id,tenant_id,name,owner_id,config,created_at,updated_at";
+  const rows = dashboards.map(
+    (d) =>
+      [
+        escapeCsvField(d.id),
+        escapeCsvField(d.tenant_id),
+        escapeCsvField(d.name),
+        escapeCsvField(d.owner_id),
+        escapeCsvField(d.config),
+        escapeCsvField(d.created_at),
+        escapeCsvField(d.updated_at),
+      ].join(",")
+  );
+  return [header, ...rows].join("\n");
+}
+
+export function createExportRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // GET /api/export/events
+  router.get("/export/events", authMiddleware, (req: AuthRequest, res, next) => {
+    try {
+      const tenantId = req.user!.tid;
+      const format = (req.query.format as string) || "json";
+      const eventName = req.query.event_name as string | undefined;
+      const startDate = req.query.start_date as string | undefined;
+      const endDate = req.query.end_date as string | undefined;
+
+      let sql = "SELECT * FROM events WHERE tenant_id = ?";
+      const params: unknown[] = [tenantId];
+
+      if (eventName) {
+        sql += " AND name = ?";
+        params.push(eventName);
+      }
+      if (startDate) {
+        sql += " AND timestamp >= ?";
+        params.push(startDate);
+      }
+      if (endDate) {
+        sql += " AND timestamp <= ?";
+        params.push(endDate);
+      }
+
+      sql += " ORDER BY timestamp DESC";
+
+      const events = db.prepare(sql).all(...params) as EventRow[];
+
+      if (format === "csv") {
+        res.setHeader("Content-Type", "text/csv");
+        res.setHeader("Content-Disposition", "attachment; filename=events.csv");
+        res.send(eventsToCsv(events));
+      } else {
+        res.json({
+          events: events.map((e) => ({
+            ...e,
+            properties: JSON.parse(e.properties),
+          })),
+          count: events.length,
+        });
+      }
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // GET /api/export/dashboards
+  router.get("/export/dashboards", authMiddleware, (req: AuthRequest, res, next) => {
+    try {
+      const tenantId = req.user!.tid;
+      const format = (req.query.format as string) || "json";
+
+      const dashboards = db
+        .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+        .all(tenantId) as DashboardRow[];
+
+      const dashboardsWithWidgets = dashboards.map((d) => {
+        const widgets = db
+          .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+          .all(d.id) as WidgetRow[];
+        return { ...d, widgets };
+      });
+
+      if (format === "csv") {
+        res.setHeader("Content-Type", "text/csv");
+        res.setHeader("Content-Disposition", "attachment; filename=dashboards.csv");
+        res.send(dashboardsToCsv(dashboardsWithWidgets));
+      } else {
+        res.json({
+          dashboards: dashboardsWithWidgets.map((d) => ({
+            ...d,
+            config: JSON.parse(d.config),
+            widgets: d.widgets.map((w) => ({
+              ...w,
+              config: JSON.parse(w.config),
+            })),
+          })),
+          count: dashboards.length,
+        });
+      }
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // GET /api/export/dashboards/:id
+  router.get("/export/dashboards/:id", authMiddleware, (req: AuthRequest, res, next) => {
+    try {
+      const tenantId = req.user!.tid;
+      const format = (req.query.format as string) || "json";
+
+      const dashboard = db
+        .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+        .get(req.params.id, tenantId) as DashboardRow | undefined;
+
+      if (!dashboard) {
+        throw new AppError(404, "Dashboard not found", "NOT_FOUND");
+      }
+
+      const widgets = db
+        .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+        .all(dashboard.id) as WidgetRow[];
+
+      if (format === "csv") {
+        res.setHeader("Content-Type", "text/csv");
+        res.setHeader(
+          "Content-Disposition",
+          `attachment; filename=dashboard-${dashboard.id}.csv`
+        );
+        res.send(dashboardsToCsv([{ ...dashboard, widgets }]));
+      } else {
+        res.json({
+          dashboard: {
+            ...dashboard,
+            config: JSON.parse(dashboard.config),
+            widgets: widgets.map((w) => ({
+              ...w,
+              config: JSON.parse(w.config),
+            })),
+          },
+        });
+      }
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  return router;
+}
diff --git a/src/routes/queries.ts b/src/routes/queries.ts
new file mode 100644
index 0000000..7bb453b
--- /dev/null
+++ b/src/routes/queries.ts
@@ -0,0 +1,153 @@
+import { Router } from "express";
+import Database from "better-sqlite3";
+import { authMiddleware, AuthRequest } from "../auth.js";
+import { AppError } from "../errors.js";
+
+export function createQueryRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // POST /api/queries/count
+  router.post("/queries/count", authMiddleware, (req: AuthRequest, res, next) => {
+    try {
+      const { event_name, start_date, end_date, filters } = req.body as {
+        event_name?: string;
+        start_date?: string;
+        end_date?: string;
+        filters?: Record<string, string>;
+      };
+
+      const tenantId = req.user!.tid;
+      let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+      const params: unknown[] = [tenantId];
+
+      if (event_name) {
+        sql += " AND name = ?";
+        params.push(event_name);
+      }
+
+      if (start_date) {
+        sql += " AND timestamp >= ?";
+        params.push(start_date);
+      }
+
+      if (end_date) {
+        sql += " AND timestamp <= ?";
+        params.push(end_date);
+      }
+
+      if (filters) {
+        for (const [key, value] of Object.entries(filters)) {
+          sql += " AND json_extract(properties, ?) = ?";
+          params.push(`$.${key}`, value);
+        }
+      }
+
+      const result = db.prepare(sql).get(...params) as { count: number };
+
+      res.json({ count: result.count });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // POST /api/queries/timeseries
+  router.post("/queries/timeseries", authMiddleware, (req: AuthRequest, res, next) => {
+    try {
+      const { event_name, start_date, end_date, interval, filters } = req.body as {
+        event_name?: string;
+        start_date?: string;
+        end_date?: string;
+        interval?: string;
+        filters?: Record<string, string>;
+      };
+
+      if (!start_date || !end_date) {
+        throw new AppError(400, "start_date and end_date are required", "VALIDATION_ERROR");
+      }
+
+      const tenantId = req.user!.tid;
+      const bucket = interval === "hour" ? "%Y-%m-%dT%H:00:00" :
+                     interval === "month" ? "%Y-%m" :
+                     "%Y-%m-%d";
+
+      let sql = `SELECT strftime('${bucket}', timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+      const params: unknown[] = [tenantId];
+
+      if (event_name) {
+        sql += " AND name = ?";
+        params.push(event_name);
+      }
+
+      sql += " AND timestamp >= ? AND timestamp <= ?";
+      params.push(start_date, end_date);
+
+      if (filters) {
+        for (const [key, value] of Object.entries(filters)) {
+          sql += " AND json_extract(properties, ?) = ?";
+          params.push(`$.${key}`, value);
+        }
+      }
+
+      sql += " GROUP BY period ORDER BY period ASC";
+
+      const results = db.prepare(sql).all(...params) as Array<{ period: string; count: number }>;
+
+      res.json({ timeseries: results });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // POST /api/queries/breakdown
+  router.post("/queries/breakdown", authMiddleware, (req: AuthRequest, res, next) => {
+    try {
+      const { event_name, property, start_date, end_date, filters } = req.body as {
+        event_name?: string;
+        property?: string;
+        start_date?: string;
+        end_date?: string;
+        filters?: Record<string, string>;
+      };
+
+      if (!property) {
+        throw new AppError(400, "property is required for breakdown queries", "VALIDATION_ERROR");
+      }
+
+      const tenantId = req.user!.tid;
+      let sql = `SELECT json_extract(properties, ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+      const params: unknown[] = [`$.${property}`, tenantId];
+
+      if (event_name) {
+        sql += " AND name = ?";
+        params.push(event_name);
+      }
+
+      if (start_date) {
+        sql += " AND timestamp >= ?";
+        params.push(start_date);
+      }
+
+      if (end_date) {
+        sql += " AND timestamp <= ?";
+        params.push(end_date);
+      }
+
+      if (filters) {
+        for (const [key, value] of Object.entries(filters)) {
+          sql += " AND json_extract(properties, ?) = ?";
+          params.push(`$.${key}`, value);
+        }
+      }
+
+      sql += " GROUP BY value ORDER BY count DESC";
+
+      const results = db.prepare(sql).all(...params) as Array<{ value: string | null; count: number }>;
+
+      res.json({ breakdown: results });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  return router;
+}
