+++ b/src/routes/users.ts
@@ -0,0 +1,155 @@
+import { Router } from "express";
+import Database from "better-sqlite3";
+import { createHash, randomBytes } from "crypto";
+import { v4 as uuidv4 } from "uuid";
+import { signToken, authMiddleware, requireRole, AuthRequest } from "../auth.js";
+import { AppError } from "../errors.js";
+
+function hashPassword(password: string, salt: string): string {
+  return createHash("sha256").update(password + salt).digest("hex");
+}
+
+function createSaltedHash(password: string): { hash: string; salt: string } {
+  const salt = randomBytes(16).toString("hex");
+  const hash = hashPassword(password, salt);
+  return { hash: salt + ":" + hash, salt };
+}
+
+function verifyPassword(password: string, storedHash: string): boolean {
+  const [salt, hash] = storedHash.split(":");
+  if (!salt || !hash) return false;
+  const computed = hashPassword(password, salt);
+  return computed === hash;
+}
+
+export function createUserRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // POST /api/auth/register
+  router.post("/auth/register", (req, res, next) => {
+    try {
+      const { email, password, tenant_id, role } = req.body as {
+        email?: string;
+        password?: string;
+        tenant_id?: string;
+        role?: string;
+      };
+
+      if (!email || !password || !tenant_id) {
+        throw new AppError(400, "email, password, and tenant_id are required", "VALIDATION_ERROR");
+      }
+
+      const existing = db.prepare("SELECT id FROM users WHERE email = ?").get(email);
+      if (existing) {
+        throw new AppError(409, "Email already registered", "CONFLICT");
+      }
+
+      const id = uuidv4();
+      const { hash } = createSaltedHash(password);
+      const userRole = role && ["admin", "viewer", "editor"].includes(role) ? role : "viewer";
+
+      db.prepare(
+        "INSERT INTO users (id, email, password_hash, tenant_id, role) VALUES (?, ?, ?, ?, ?)"
+      ).run(id, email, hash, tenant_id, userRole);
+
+      const token = signToken({ sub: id, tid: tenant_id, role: userRole });
+
+      res.status(201).json({
+        user: { id, email, tenant_id, role: userRole },
+        token,
+      });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // POST /api/auth/login
+  router.post("/auth/login", (req, res, next) => {
+    try {
+      const { email, password } = req.body as {
+        email?: string;
+        password?: string;
+      };
+
+      if (!email || !password) {
+        throw new AppError(400, "email and password are required", "VALIDATION_ERROR");
+      }
+
+      const user = db
+        .prepare("SELECT id, email, password_hash, tenant_id, role FROM users WHERE email = ?")
+        .get(email) as
+        | { id: string; email: string; password_hash: string; tenant_id: string; role: string }
+        | undefined;
+
+      if (!user || !verifyPassword(password, user.password_hash)) {
+        throw new AppError(401, "Invalid email or password", "UNAUTHORIZED");
+      }
+
+      const token = signToken({ sub: user.id, tid: user.tenant_id, role: user.role });
+
+      res.json({
+        user: { id: user.id, email: user.email, tenant_id: user.tenant_id, role: user.role },
+        token,
+      });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // GET /api/users/me
+  router.get("/users/me", authMiddleware, (req: AuthRequest, res, next) => {
+    try {
+      const user = db
+        .prepare("SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?")
+        .get(req.user!.sub) as
+        | { id: string; email: string; tenant_id: string; role: string; created_at: string }
+        | undefined;
+
+      if (!user) {
+        throw new AppError(404, "User not found", "NOT_FOUND");
+      }
+
+      res.json({ user });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // PUT /api/users/:id/role  (admin only)
+  router.put(
+    "/users/:id/role",
+    authMiddleware,
+    requireRole("admin"),
+    (req: AuthRequest, res, next) => {
+      try {
+        const { id } = req.params;
+        const { role } = req.body as { role?: string };
+
+        if (!role || !["admin", "viewer", "editor"].includes(role)) {
+          throw new AppError(400, "Valid role is required (admin, viewer, editor)", "VALIDATION_ERROR");
+        }
+
+        // Can only manage users in same tenant
+        const target = db
+          .prepare("SELECT id, tenant_id FROM users WHERE id = ?")
+          .get(id) as { id: string; tenant_id: string } | undefined;
+
+        if (!target) {
+          throw new AppError(404, "User not found", "NOT_FOUND");
+        }
+
+        if (target.tenant_id !== req.user!.tid) {
+          throw new AppError(403, "Cannot modify users outside your tenant", "FORBIDDEN");
+        }
+
+        db.prepare("UPDATE users SET role = ? WHERE id = ?").run(role, id);
+
+        res.json({ id, role });
+      } catch (err) {
+        next(err);
+      }
+    }
+  );
+
+  return router;
+}
