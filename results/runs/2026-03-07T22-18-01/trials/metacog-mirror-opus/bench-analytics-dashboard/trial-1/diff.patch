+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01UbLxdLC2Zqqoqf6srz819v","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01CuQ9zfUmRYVQ3Kum34FCLX","name":"Write","input":{"file_path":"/workspace/src/routes/dashboards.ts","content":"import { Router } from \"express\";\nimport Database from \"better-sqlite3\";\nimport { v4 as uuidv4 } from \"uuid\";\nimport { authMiddleware, AuthRequest } from \"../auth.js\";\nimport { AppError } from \"../errors.js\";\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\ninterface WidgetRow {\n  id: string;\n  dashboard_id: string;\n  type: string;\n  config: string;\n  position_x: number;\n  position_y: number;\n  width: number;\n  height: number;\n}\n\nexport function createDashboardRoutes(db: Database.Database): Router {\n  const router = Router();\n\n  // POST /api/dashboards\n  router.post(\"/dashboards\", authMiddleware, (req: AuthRequest, res, next) => {\n    try {\n      const { name, config, widgets } = req.body as {\n        name?: string;\n        config?: Record<string, unknown>;\n        widgets?: Array<{\n          type: string;\n          config?: Record<string, unknown>;\n          position_x?: number;\n          position_y?: number;\n          width?: number;\n          height?: number;\n        }>;\n      };\n\n      if (!name) {\n        throw new AppError(400, \"Dashboard name is required\", \"VALIDATION_ERROR\");\n      }\n\n      const id = uuidv4();\n      const tenantId = req.user!.tid;\n      const ownerId = req.user!.sub;\n\n      db.prepare(\n        \"INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)\"\n      ).run(id, tenantId, name, ownerId, JSON.stringify(config || {}));\n\n      if (widgets && Array.isArray(widgets)) {\n        const insertWidget = db.prepare(\n          \"INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)\"\n        );\n        for (const widget of widgets) {\n          insertWidget.run(\n            uuidv4(),\n            id,\n            widget.type,\n            JSON.stringify(widget.config || {}),\n            widget.position_x ?? 0,\n            widget.position_y ?? 0,\n            widget.width ?? 1,\n            widget.height ?? 1\n          );\n        }\n      }\n\n      const dashboard = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ?\")\n        .get(id) as DashboardRow;\n\n      const dashboardWidgets = db\n        .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n        .all(id) as WidgetRow[];\n\n      res.status(201).json({\n        dashboard: {\n          ...dashboard,\n          config: JSON.parse(dashboard.config),\n          widgets: dashboardWidgets.map((w) => ({\n            ...w,\n            config: JSON.parse(w.config),\n          })),\n        },\n      });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /api/dashboards\n  router.get(\"/dashboards\", authMiddleware, (req: AuthRequest, res, next) => {\n    try {\n      const tenantId = req.user!.tid;\n      const dashboards = db\n        .prepare(\"SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC\")\n        .all(tenantId) as DashboardRow[];\n\n      res.json({\n        dashboards: dashboards.map((d) => ({\n          ...d,\n          config: JSON.parse(d.config),\n        })),\n      });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // GET /api/dashboards/:id\n  router.get(\"/dashboards/:id\", authMiddleware, (req: AuthRequest, res, next) => {\n    try {\n      const tenantId = req.user!.tid;\n      const dashboard = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n        .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n      if (!dashboard) {\n        throw new AppError(404, \"Dashboard not found\", \"NOT_FOUND\");\n      }\n\n      const widgets = db\n        .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n        .all(dashboard.id) as WidgetRow[];\n\n      res.json({\n        dashboard: {\n          ...dashboard,\n          config: JSON.parse(dashboard.config),\n          widgets: widgets.map((w) => ({\n            ...w,\n            config: JSON.parse(w.config),\n          })),\n        },\n      });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // PUT /api/dashboards/:id\n  router.put(\"/dashboards/:id\", authMiddleware, (req: AuthRequest, res, next) => {\n    try {\n      const tenantId = req.user!.tid;\n      const { name, config } = req.body as {\n        name?: string;\n        config?: Record<string, unknown>;\n      };\n\n      const existing = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n        .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n      if (!existing) {\n        throw new AppError(404, \"Dashboard not found\", \"NOT_FOUND\");\n      }\n\n      const updates: string[] = [];\n      const params: unknown[] = [];\n\n      if (name !== undefined) {\n        updates.push(\"name = ?\");\n        params.push(name);\n      }\n      if (config !== undefined) {\n        updates.push(\"config = ?\");\n        params.push(JSON.stringify(config));\n      }\n\n      if (updates.length > 0) {\n        updates.push(\"updated_at = datetime('now')\");\n        params.push(req.params.id, tenantId);\n        db.prepare(\n          `UPDATE dashboards SET ${updates.join(\", \")} WHERE id = ? AND tenant_id = ?`\n        ).run(...params);\n      }\n\n      const dashboard = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ?\")\n        .get(req.params.id) as DashboardRow;\n\n      const widgets = db\n        .prepare(\"SELECT * FROM widgets WHERE dashboard_id = ?\")\n        .all(dashboard.id) as WidgetRow[];\n\n      res.json({\n        dashboard: {\n          ...dashboard,\n          config: JSON.parse(dashboard.config),\n          widgets: widgets.map((w) => ({\n            ...w,\n            config: JSON.parse(w.config),\n          })),\n        },\n      });\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  // DELETE /api/dashboards/:id\n  router.delete(\"/dashboards/:id\", authMiddleware, (req: AuthRequest, res, next) => {\n    try {\n      const tenantId = req.user!.tid;\n\n      const existing = db\n        .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n        .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n      if (!existing) {\n        throw new AppError(404, \"Dashboard not found\", \"NOT_FOUND\");\n      }\n\n      db.prepare(\"DELETE FROM dashboards WHERE id = ? AND tenant_id = ?\").run(\n        req.params.id,\n        tenantId\n      );\n\n      res.status(204).send();\n    } catch (err) {\n      next(err);\n    }\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":446,"cache_read_input_tokens":23817,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":446},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1fb4fdcc-8069-4737-8760-f20582e0e81e","uuid":"e4c75d4a-2e6d-4492-ba99-564bf34230db"}
