gth(2);\n    expect(res.body.count).toBe(2);\n  });\n\n  it(\"should export events as CSV\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events?format=csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"id,tenant_id,name,properties,timestamp,user_id,session_id\");\n  });\n\n  it(\"should export dashboards as JSON\", async () => {\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"My Dashboard\" });\n\n    const res = await request(app)\n      .get(\"/api/export/dashboards?format=json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.dashboards).toHaveLength(1);\n  });\n\n  it(\"should export dashboards as CSV\", async () => {\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"My Dashboard\" });\n\n    const res = await request(app)\n      .get(\"/api/export/dashboards?format=csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n  });\n\n  it(\"should enforce tenant isolation on exports\", async () => {\n    const reg2 = await request(app)\n      .post(\"/api/auth/register\")\n      .send({ email: \"other@example.com\", password: \"password123\", tenant_id: \"t2\" });\n\n    const res = await request(app)\n      .get(\"/api/export/events?format=json\")\n      .set(\"Authorization\", `Bearer ${reg2.body.token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events).toHaveLength(0);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
