+import { describe, it, expect } from 'vitest';
+import { simulate, findSwappedWires, Gate } from './index.js';
+
+describe('simulate', () => {
+  it('should handle basic AND gate', () => {
+    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 1 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 0 });
+  });
+
+  it('should handle basic OR gate', () => {
+    const gates: Gate[] = [{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 0, b: 1 })).toEqual({ a: 0, b: 1, c: 1 });
+    expect(simulate(gates, { a: 0, b: 0 })).toEqual({ a: 0, b: 0, c: 0 });
+  });
+
+  it('should handle basic XOR gate', () => {
+    const gates: Gate[] = [{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }];
+    expect(simulate(gates, { a: 1, b: 1 })).toEqual({ a: 1, b: 1, c: 0 });
+    expect(simulate(gates, { a: 1, b: 0 })).toEqual({ a: 1, b: 0, c: 1 });
+  });
+
+  it('should handle chained gates in dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    expect(simulate(gates, { a: 1, b: 1, d: 0 })).toEqual({
+      a: 1, b: 1, c: 1, d: 0, e: 1,
+    });
+  });
+
+  it('should simulate a correct 4-bit adder (0+0)', () => {
+    const gates = make4BitAdder();
+    const inputs: Record<string, number> = {};
+    for (let i = 0; i < 4; i++) {
+      inputs[`x${pad(i)}`] = 0;
+      inputs[`y${pad(i)}`] = 0;
+    }
+    const result = simulate(gates, inputs);
+    for (let i = 0; i <= 4; i++) {
+      expect(result[`z${pad(i)}`]).toBe(0);
+    }
+  });
+
+  it('should simulate a correct 4-bit adder (5+3=8)', () => {
+    const gates = make4BitAdder();
+    const inputs: Record<string, number> = {
+      x00: 1, x01: 0, x02: 1, x03: 0,
+      y00: 1, y01: 1, y02: 0, y03: 0,
+    };
+    const result = simulate(gates, inputs);
+    expect(result['z00']).toBe(0);
+    expect(result['z01']).toBe(0);
+    expect(result['z02']).toBe(0);
+    expect(result['z03']).toBe(1);
+    expect(result['z04']).toBe(0);
+  });
+
+  it('should simulate a correct 4-bit adder (15+15=30)', () => {
+    const gates = make4BitAdder();
+    const inputs: Record<string, number> = {
+      x00: 1, x01: 1, x02: 1, x03: 1,
+      y00: 1, y01: 1, y02: 1, y03: 1,
+    };
+    const result = simulate(gates, inputs);
+    expect(result['z00']).toBe(0);
+    expect(result['z01']).toBe(1);
+    expect(result['z02']).toBe(1);
+    expect(result['z03']).toBe(1);
+    expect(result['z04']).toBe(1);
+  });
+
+  it('should handle gates given out of dependency order', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    const result = simulate(gates, { a: 1, b: 1, d: 0 });
+    expect(result).toEqual({ a: 1, b: 1, c: 1, d: 0, e: 1 });
+  });
+});
+
+describe('findSwappedWires', () => {
+  it('should find swapped z-output with internal wire', () => {
+    // Swap z01 <-> c01: the sum output of bit 1 is swapped with carry of bit 1
+    // This is safe because z01 is only consumed externally, and c01 feeds into bit 2
+    const gates = make8BitAdder();
+    swapGateOutputs(gates, 'z01', 'c01');
+    // Swap z03 <-> a03
+    swapGateOutputs(gates, 'z03', 'a03');
+    // Swap z05 <-> c05
+    swapGateOutputs(gates, 'z05', 'c05');
+    // Swap z07 <-> b07
+    swapGateOutputs(gates, 'z07', 'b07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual([
+      'a03', 'b07', 'c01', 'c05', 'z01', 'z03', 'z05', 'z07',
+    ]);
+  });
+
+  it('should find swaps among carry-chain and z wires', () => {
+    // Swap c01 <-> z02, c03 <-> z04, c05 <-> z06, a07 <-> z07
+    const gates = make8BitAdder();
+    swapGateOutputs(gates, 'c01', 'z02');
+    swapGateOutputs(gates, 'c03', 'z04');
+    swapGateOutputs(gates, 'c05', 'z06');
+    swapGateOutputs(gates, 'a07', 'z07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual([
+      'a07', 'c01', 'c03', 'c05', 'z02', 'z04', 'z06', 'z07',
+    ]);
+  });
+
+  it('should find swaps where carry gets a z-name', () => {
+    // Swap c02 <-> z03: carry of bit 2 gets z03 name
+    // And some other swaps
+    const gates = make8BitAdder();
+    swapGateOutputs(gates, 'c02', 'z03');
+    swapGateOutputs(gates, 'c04', 'z05');
+    swapGateOutputs(gates, 't06', 'z06');
+    swapGateOutputs(gates, 'a07', 'z07');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual([
+      'a07', 'c02', 'c04', 't06', 'z03', 'z05', 'z06', 'z07',
+    ]);
+  });
+
+  it('should find swaps involving partial sums', () => {
+    // Swap t01 <-> z01 (partial sum and final sum of same bit)
+    // Swap t03 <-> z03
+    // Swap a05 <-> c04 (generate of bit 5 and carry of bit 4)
+    // Swap b06 <-> c05 (propagate of bit 6 and carry of bit 5)
+    const gates = make8BitAdder();
+    swapGateOutputs(gates, 't01', 'z01');
+    swapGateOutputs(gates, 't03', 'z03');
+    swapGateOutputs(gates, 'a05', 'c04');
+    swapGateOutputs(gates, 'b06', 'c05');
+
+    const result = findSwappedWires(gates);
+    expect(result).toEqual([
+      'a05', 'b06', 'c04', 'c05', 't01', 't03', 'z01', 'z03',
+    ]);
+  });
+});
+
+  it('should handle random wire names (like real puzzle)', () => {
+    // Create an 8-bit adder with random wire names for internal wires
+    const gates = makeNBitAdderRandomNames(8);
+    function findByOp(op: Gate['op'], x: string, y: string): Gate {
+      return gates.find(
+        (g) => g.op === op && ((g.in1 === x && g.in2 === y) || (g.in1 === y && g.in2 === x)),
+      )!;
+    }
+
+    const t1 = findByOp('XOR', 'x01', 'y01').out;
+    const t3 = findByOp('XOR', 'x03', 'y03').out;
+    const a5 = findByOp('AND', 'x05', 'y05').out;
+    const a7 = findByOp('AND', 'x07', 'y07').out;
+
+    swapGateOutputs(gates, 'z01', t1);
+    swapGateOutputs(gates, 'z03', t3);
+    swapGateOutputs(gates, a5, 'z05');
+    swapGateOutputs(gates, a7, 'z07');
+
+    const result = findSwappedWires(gates);
+    const expected = [t1, 'z01', t3, 'z03', a5, 'z05', a7, 'z07'].sort();
+    expect(result).toEqual(expected);
+  });
+
+  it('should handle a 45-bit adder within time limit', () => {
+    const gates = makeNBitAdderRandomNames(45);
+    // Find some wires to swap
+    const t5Gate = gates.find(
+      (g) => g.op === 'XOR' && ((g.in1 === 'x05' && g.in2 === 'y05') || (g.in1 === 'y05' && g.in2 === 'x05')),
+    )!;
+    const a10Gate = gates.find(
+      (g) => g.op === 'AND' && ((g.in1 === 'x10' && g.in2 === 'y10') || (g.in1 === 'y10' && g.in2 === 'x10')),
+    )!;
+    const t20Gate = gates.find(
+      (g) => g.op === 'XOR' && ((g.in1 === 'x20' && g.in2 === 'y20') || (g.in1 === 'y20' && g.in2 === 'x20')),
+    )!;
+    const a30Gate = gates.find(
+      (g) => g.op === 'AND' && ((g.in1 === 'x30' && g.in2 === 'y30') || (g.in1 === 'y30' && g.in2 === 'x30')),
+    )!;
+
+    swapGateOutputs(gates, 'z05', t5Gate.out);
+    swapGateOutputs(gates, 'z10', a10Gate.out);
+    swapGateOutputs(gates, 'z20', t20Gate.out);
+    swapGateOutputs(gates, 'z30', a30Gate.out);
+
+    const start = Date.now();
+    const result = findSwappedWires(gates);
+    const elapsed = Date.now() - start;
+
+    expect(result.length).toBe(8);
+    expect(elapsed).toBeLessThan(5000);
+  });
+
+// Helper: create a correct N-bit ripple-carry adder
+function makeNBitAdder(n: number): Gate[] {
+  const gates: Gate[] = [];
+
+  // Bit 0: half adder
+  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });
+
+  for (let i = 1; i < n; i++) {
+    const p = pad(i);
+    const pp = pad(i - 1);
+    gates.push({ op: 'XOR', in1: `x${p}`, in2: `y${p}`, out: `t${p}` });
+    gates.push({ op: 'XOR', in1: `t${p}`, in2: `c${pp}`, out: `z${p}` });
+    gates.push({ op: 'AND', in1: `x${p}`, in2: `y${p}`, out: `a${p}` });
+    gates.push({ op: 'AND', in1: `t${p}`, in2: `c${pp}`, out: `b${p}` });
+    gates.push({ op: 'OR', in1: `a${p}`, in2: `b${p}`, out: `c${p}` });
+  }
+
+  // Final carry
+  const last = pad(n - 1);
+  gates.push({ op: 'OR', in1: `c${last}`, in2: `c${last}`, out: `z${pad(n)}` });
+
+  return gates;
+}
+
+function make4BitAdder(): Gate[] {
+  return makeNBitAdder(4);
+}
+
+function make8BitAdder(): Gate[] {
+  return makeNBitAdder(8);
+}
+
+function pad(n: number): string {
+  return n.toString().padStart(2, '0');
+}
+
+function makeNBitAdderRandomNames(n: number): Gate[] {
+  const gates: Gate[] = [];
+  let wireCounter = 0;
+  function nextWire(): string {
+    const id = wireCounter++;
+    const a = String.fromCharCode(97 + (id % 26));
+    const b = String.fromCharCode(97 + (Math.floor(id / 26) % 26));
+    const c = String.fromCharCode(97 + (Math.floor(id / 676) % 26));
+    return `${c}${b}${a}`;
+  }
+
+  // Bit 0: half adder
+  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });
+  const carry0 = nextWire();
+  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: carry0 });
+
+  let prevCarry = carry0;
+
+  for (let i = 1; i < n; i++) {
+    const p = pad(i);
+    const t = nextWire();
+    const a = nextWire();
+    const b = nextWire();
+    const c = nextWire();
+
+    gates.push({ op: 'XOR', in1: `x${p}`, in2: `y${p}`, out: t });
+    gates.push({ op: 'XOR', in1: t, in2: prevCarry, out: `z${p}` });
+    gates.push({ op: 'AND', in1: `x${p}`, in2: `y${p}`, out: a });
+    gates.push({ op: 'AND', in1: t, in2: prevCarry, out: b });
+    gates.push({ op: 'OR', in1: a, in2: b, out: c });
+
+    prevCarry = c;
+  }
+
+  // Final carry
+  gates.push({ op: 'OR', in1: prevCarry, in2: prevCarry, out: `z${pad(n)}` });
+
+  return gates;
+}
+
+function swapGateOutputs(gates: Gate[], w1: string, w2: string): void {
+  const g1 = gates.find((g) => g.out === w1);
+  const g2 = gates.find((g) => g.out === w2);
+  if (g1 && g2) {
+    g1.out = w2;
+    g2.out = w1;
+  }
+}
