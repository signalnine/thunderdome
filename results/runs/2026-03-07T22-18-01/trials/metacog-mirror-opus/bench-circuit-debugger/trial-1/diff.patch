n        // So we need to find the XOR gate for bit zBit.\n        if (zBit > 0 && zBit < numBits) {\n          const xBit = `x${pad(zBit)}`;\n          const yBit = `y${pad(zBit)}`;\n          // The sum XOR for this z-bit uses t_zBit (which = XOR(x_zBit, y_zBit).out)\n          // and carry_{zBit-1} as inputs.\n          const xorForBit = fg('XOR', xBit, yBit);\n          if (xorForBit) {\n            const tForBit = xorForBit.out;\n            // Find the non-primary XOR that uses tForBit\n            const sumXorForBit = mg.find(\n              (g) =>\n                g.op === 'XOR' &&\n                g !== xorForBit &&\n                (g.in1 === tForBit || g.in2 === tForBit),\n            );\n            if (sumXorForBit && sumXorForBit.out !== carry) {\n              // sumXorForBit.out should be z_K but it's something else\n              // carry (= z_K) and sumXorForBit.out need to be swapped\n              doSwap(carry, sumXorForBit.out);\n              carry = orGate.out; // re-read after swap\n              foundSwapThisPass = true;\n              break;\n            }\n          }\n        }\n      }\n    }\n\n    if (!foundSwapThisPass) break;\n  }\n\n  return [...swapped].sort();\n}\n"}}
