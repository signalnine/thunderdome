index 0000000..64cdf5f
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,221 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  while (remaining.length > 0) {
+    let progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const gate = remaining[i];
+      const v1 = wires[gate.in1];
+      const v2 = wires[gate.in2];
+      if (v1 === undefined || v2 === undefined) continue;
+
+      let result: number;
+      switch (gate.op) {
+        case 'AND':
+          result = v1 & v2;
+          break;
+        case 'OR':
+          result = v1 | v2;
+          break;
+        case 'XOR':
+          result = v1 ^ v2;
+          break;
+      }
+      wires[gate.out] = result;
+      remaining.splice(i, 1);
+      progress = true;
+    }
+    if (!progress) break;
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  let numBits = 0;
+  for (const g of gates) {
+    for (const wire of [g.in1, g.in2]) {
+      const m = wire.match(/^x(\d+)$/);
+      if (m) {
+        const n = parseInt(m[1], 10);
+        if (n + 1 > numBits) numBits = n + 1;
+      }
+    }
+  }
+
+  function pad(n: number): string {
+    return n.toString().padStart(2, '0');
+  }
+
+  const mg = gates.map((g) => ({ ...g }));
+  const swapped = new Set<string>();
+
+  function fg(op: Gate['op'], a: string, b: string): Gate | undefined {
+    return mg.find(
+      (g) =>
+        g.op === op &&
+        ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a)),
+    );
+  }
+
+  function doSwap(w1: string, w2: string): void {
+    const g1 = mg.find((g) => g.out === w1);
+    const g2 = mg.find((g) => g.out === w2);
+    if (g1 && g2) {
+      g1.out = w2;
+      g2.out = w1;
+      swapped.add(w1);
+      swapped.add(w2);
+    }
+  }
+
+  function other(g: Gate, w: string): string {
+    return g.in1 === w ? g.in2 : g.in1;
+  }
+
+  // Trace the expected ripple-carry adder pattern bit by bit.
+  // After each swap detected, restart from bit 0 so all subsequent
+  // carry chain computations use corrected wire names.
+  let maxPasses = 8;
+  while (maxPasses-- > 0 && swapped.size < 8) {
+    let foundSwap = false;
+    let carry = '';
+
+    for (let bit = 0; bit < numBits; bit++) {
+      const x = `x${pad(bit)}`;
+      const y = `y${pad(bit)}`;
+      const z = `z${pad(bit)}`;
+
+      const xorXY = fg('XOR', x, y);
+      if (!xorXY) continue;
+
+      if (bit === 0) {
+        // Half adder: XOR(x00, y00) should output z00
+        if (xorXY.out !== z) {
+          doSwap(xorXY.out, z);
+          foundSwap = true;
+          break;
+        }
+        const andXY = fg('AND', x, y);
+        if (andXY) carry = andXY.out;
+        continue;
+      }
+
+      // Full adder for bit > 0
+      const t = xorXY.out;
+
+      // Find the sum gate: XOR(t, carry) -> z
+      const sumGate = fg('XOR', t, carry);
+
+      if (!sumGate) {
+        // Either t or carry was swapped with something else
+        const xorCarry = mg.find(
+          (g) =>
+            g.op === 'XOR' &&
+            g !== xorXY &&
+            (g.in1 === carry || g.in2 === carry),
+        );
+
+        if (xorCarry) {
+          // carry is right, t is wrong
+          doSwap(t, other(xorCarry, carry));
+          foundSwap = true;
+          break;
+        }
+
+        const xorT = mg.find(
+          (g) =>
+            g.op === 'XOR' &&
+            g !== xorXY &&
+            (g.in1 === t || g.in2 === t),
+        );
+        if (xorT) {
+          // t is right, carry is wrong
+          doSwap(carry, other(xorT, t));
+          foundSwap = true;
+          break;
+        }
+
+        continue;
+      }
+
+      // Sum gate output should be z
+      if (sumGate.out !== z) {
+        doSwap(sumGate.out, z);
+        foundSwap = true;
+        break;
+      }
+
+      // Carry chain: AND(x,y) -> a, AND(t,carry) -> b, OR(a,b) -> carry_out
+      const andXY = fg('AND', x, y);
+      if (!andXY) continue;
+
+      const propGate = fg('AND', t, carry);
+      if (!propGate) continue;
+
+      const orGate = fg('OR', andXY.out, propGate.out);
+
+      if (!orGate) {
+        const orWithA = mg.find(
+          (g) => g.op === 'OR' && (g.in1 === andXY.out || g.in2 === andXY.out),
+        );
+        if (orWithA) {
+          doSwap(propGate.out, other(orWithA, andXY.out));
+          foundSwap = true;
+          break;
+        }
+
+        const orWithB = mg.find(
+          (g) => g.op === 'OR' && (g.in1 === propGate.out || g.in2 === propGate.out),
+        );
+        if (orWithB) {
+          doSwap(andXY.out, other(orWithB, propGate.out));
+          foundSwap = true;
+          break;
+        }
+
+        continue;
+      }
+
+      carry = orGate.out;
+
+      // Carry should never be a z-wire (except the final z_{numBits})
+      if (carry.startsWith('z') && carry !== `z${pad(numBits)}`) {
+        const zBit = parseInt(carry.slice(1), 10);
+        if (zBit > 0 && zBit < numBits) {
+          const xorForBit = fg('XOR', `x${pad(zBit)}`, `y${pad(zBit)}`);
+          if (xorForBit) {
+            const tForBit = xorForBit.out;
+            const sumXorForBit = mg.find(
+              (g) =>
+                g.op === 'XOR' &&
+                g !== xorForBit &&
+                (g.in1 === tForBit || g.in2 === tForBit),
+            );
+            if (sumXorForBit && sumXorForBit.out !== carry) {
+              doSwap(carry, sumXorForBit.out);
+              carry = orGate.out;
+              foundSwap = true;
+              break;
+            }
+          }
+        }
+      }
+    }
+
+    if (!foundSwap) break;
+  }
+
+  return [...swapped].sort();
+}
