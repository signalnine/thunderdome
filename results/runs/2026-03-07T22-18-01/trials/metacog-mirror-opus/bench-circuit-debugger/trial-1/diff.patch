<string>();\n\n  function fg(op: Gate['op'], a: string, b: string): Gate | undefined {\n    return mg.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a)),\n    );\n  }\n\n  function doSwap(w1: string, w2: string): void {\n    const g1 = mg.find((g) => g.out === w1);\n    const g2 = mg.find((g) => g.out === w2);\n    if (g1 && g2) {\n      g1.out = w2;\n      g2.out = w1;\n      swapped.add(w1);\n      swapped.add(w2);\n    }\n  }\n\n  function other(g: Gate, w: string): string {\n    return g.in1 === w ? g.in2 : g.in1;\n  }\n\n  // Mirror approach: trace the expected ripple-carry adder pattern\n  // bit by bit. After each swap detected, restart from bit 0 so all\n  // subsequent carry chain computations use corrected wire names.\n  //\n  // Expected structure per bit:\n  //   Bit 0 (half adder):\n  //     XOR(x00, y00) -> z00\n  //     AND(x00, y00) -> carry_0\n  //   Bit i > 0 (full adder):\n  //     XOR(xi, yi) -> t_i           (partial sum)\n  //     XOR(t_i, carry_{i-1}) -> zi  (final sum)\n  //     AND(xi, yi) -> a_i           (generate carry)\n  //     AND(t_i, carry_{i-1}) -> b_i (propagate carry)\n  //     OR(a_i, b_i) -> carry_i      (carry out)\n\n  let maxPasses = 8; // at most 4 swaps, each needing a restart\n  while (maxPasses-- > 0 && swapped.size < 8) {\n    let foundSwapThisPass = false;\n    let carry = '';\n\n    for (let bit = 0; bit < numBits; bit++) {\n      const x = `x${pad(bit)}`;\n      const y = `y${pad(bit)}`;\n      const z = `z${pad(bit)}`;\n\n      const xorXY = fg('XOR', x, y);\n      if (!xorXY) continue;\n\n      if (bit === 0) {\n        if (xorXY.out !== z) {\n          doSwap(xorXY.out, z);\n          foundSwapThisPass = true;\n          break; // restart\n        }\n        const andXY = fg('AND', x, y);\n        if (andXY) carry = andXY.out;\n        continue;\n      }\n\n      // Full adder\n      const t = xorXY.out;\n\n      // Find XOR(t, carry) -> z\n      let sumGate = fg('XOR', t, carry);\n\n      if (!sumGate) {\n        // Either t or carry is wrong (was swapped with something)\n        // Try to find an XOR that uses carry (excluding xorXY)\n        const xorCarry = mg.find(\n          (g) =>\n            g.op === 'XOR' &&\n            g !== xorXY &&\n            (g.in1 === carry || g.in2 === carry),\n        );\n\n        if (xorCarry) {\n          // carry is correct, t is wrong => swap t with the actual other input\n          doSwap(t, other(xorCarry, carry));\n          foundSwapThisPass = true;\n          break;\n        }\n\n        // Try to find an XOR that uses t (excluding xorXY)\n        const xorT = mg.find(\n          (g) =>\n            g.op === 'XOR' &&\n            g !== xorXY &&\n            (g.in1 === t || g.in2 === t),\n        );\n        if (xorT) {\n          // t is correct, carry is wrong => swap carry with actual other input\n          doSwap(carry, other(xorT, t));\n          foundSwapThisPass = true;\n          break;\n        }\n\n        // Neither found - skip this bit\n        continue;\n      }\n\n      // sumGate.out should be z\n      if (sumGate.out !== z) {\n        doSwap(sumGate.out, z);\n        foundSwapThisPass = true;\n        break;\n      }\n\n      // Now check the carry chain for this bit\n      const andXY = fg('AND', x, y);\n      if (!andXY) continue;\n\n      const propGate = fg('AND', t, carry);\n      if (!propGate) continue;\n\n      let orGate = fg('OR', andXY.out, propGate.out);\n\n      if (!orGate) {\n        // One of andXY.out or propGate.out is wrong\n        const orWithA = mg.find(\n          (g) => g.op === 'OR' && (g.in1 === andXY.out || g.in2 === andXY.out),\n        );\n        if (orWithA) {\n          doSwap(propGate.out, other(orWithA, andXY.out));\n          foundSwapThisPass = true;\n          break;\n        }\n\n        const orWithB = mg.find(\n          (g) => g.op === 'OR' && (g.in1 === propGate.out || g.in2 === propGate.out),\n        );\n  