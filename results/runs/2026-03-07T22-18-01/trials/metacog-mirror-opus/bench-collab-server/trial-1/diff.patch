+import express from 'express';
+import { createServer, Server as HttpServer } from 'http';
+import { WebSocketServer, WebSocket } from 'ws';
+import { URL } from 'url';
+import { createDatabase, DocumentStore } from './database.js';
+import { createRouter } from './routes.js';
+import { CollaborationManager } from './collaboration.js';
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const db = createDatabase(dbPath ?? ':memory:');
+  const store = new DocumentStore(db);
+  const collaboration = new CollaborationManager(store);
+
+  const app = express();
+  app.use(express.json());
+
+  // Mount REST routes
+  const router = createRouter(store);
+  app.use('/api', router);
+
+  // Also mount at root for flexibility
+  app.use('/', router);
+
+  let httpServer: HttpServer | null = null;
+  let wss: WebSocketServer | null = null;
+
+  return {
+    app,
+
+    async start(port?: number): Promise<number> {
+      return new Promise((resolve, reject) => {
+        httpServer = createServer(app);
+
+        wss = new WebSocketServer({ server: httpServer });
+
+        wss.on('connection', (ws: WebSocket, req) => {
+          // Extract document ID from the URL path
+          // Expected paths: /ws/:docId or /documents/:docId/ws or /:docId
+          const url = new URL(req.url ?? '/', `http://localhost`);
+          const pathname = url.pathname;
+
+          let docId: string | null = null;
+
+          // Try various path patterns
+          const wsMatch = pathname.match(/^\/ws\/([^/]+)$/);
+          const docWsMatch = pathname.match(/^\/documents\/([^/]+)\/ws$/);
+          const apiDocWsMatch = pathname.match(/^\/api\/documents\/([^/]+)\/ws$/);
+          const directMatch = pathname.match(/^\/([^/]+)$/);
+
+          if (wsMatch) {
+            docId = wsMatch[1];
+          } else if (docWsMatch) {
+            docId = docWsMatch[1];
+          } else if (apiDocWsMatch) {
+            docId = apiDocWsMatch[1];
+          } else if (directMatch && directMatch[1] !== 'ws') {
+            docId = directMatch[1];
+          }
+
+          if (!docId) {
+            ws.close(4000, 'Document ID required in WebSocket path');
+            return;
+          }
+
+          collaboration.handleConnection(ws, docId);
+        });
+
+        httpServer.on('error', reject);
+
+        httpServer.listen(port ?? 0, () => {
+          const addr = httpServer!.address();
+          if (addr && typeof addr === 'object') {
+            resolve(addr.port);
+          } else {
+            resolve(0);
+          }
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      collaboration.disconnectAll();
+
+      if (wss) {
+        // Terminate all WebSocket connections
+        for (const client of wss.clients) {
+          try {
+            client.terminate();
+          } catch {
+            // ignore
+          }
+        }
+        await new Promise<void>((resolve) => {
+          wss!.close(() => resolve());
+        });
+        wss = null;
+      }
+
+      if (httpServer) {
+        await new Promise<void>((resolve, reject) => {
+          httpServer!.close((err) => {
+            if (err) reject(err);
+            else resolve();
+          });
+        });
+        httpServer = null;
+      }
+
+      try {
+        store.close();
+      } catch {
+        // db might already be closed
+      }
+    },
+  };
+}
+
+export default createApp;
