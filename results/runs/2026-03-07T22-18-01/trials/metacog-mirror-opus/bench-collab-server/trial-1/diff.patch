--- /dev/null
+++ b/src/collaboration.ts
@@ -0,0 +1,248 @@
+import { WebSocket } from 'ws';
+import { DocumentStore } from './database.js';
+import {
+  Operation,
+  OperationMessage,
+  ServerMessage,
+  apply,
+  transform,
+  validate,
+} from './ot.js';
+import { randomUUID } from 'crypto';
+
+interface ConnectedClient {
+  ws: WebSocket;
+  clientId: string;
+  documentId: string;
+}
+
+interface DocumentState {
+  version: number;
+  content: string;
+  // Map from version number to the operation that produced that version.
+  // history.get(v) is the operation that transforms version (v-1) to version v.
+  history: Map<number, Operation>;
+}
+
+export class CollaborationManager {
+  private clients: Map<string, ConnectedClient> = new Map();
+  private documents: Map<string, DocumentState> = new Map();
+
+  constructor(private store: DocumentStore) {}
+
+  private getDocumentState(docId: string): DocumentState | null {
+    // Check in-memory cache first
+    let state = this.documents.get(docId);
+    if (state) return state;
+
+    // Load from database
+    const doc = this.store.getDocument(docId);
+    if (!doc) return null;
+
+    const latestVersion = this.store.getLatestVersion(docId);
+    state = {
+      version: latestVersion,
+      content: doc.content,
+      history: new Map(),
+    };
+
+    // Load operation history from database
+    const versions = this.store.getVersions(docId);
+    for (const v of versions) {
+      if (v.operation) {
+        try {
+          state.history.set(v.version, JSON.parse(v.operation));
+        } catch {
+          // Skip malformed operations
+        }
+      }
+    }
+
+    this.documents.set(docId, state);
+    return state;
+  }
+
+  handleConnection(ws: WebSocket, docId: string): void {
+    const clientId = randomUUID();
+
+    // Validate document exists
+    const state = this.getDocumentState(docId);
+    if (!state) {
+      this.sendMessage(ws, { type: 'error', message: 'Document not found' });
+      ws.close(4004, 'Document not found');
+      return;
+    }
+
+    const client: ConnectedClient = { ws, clientId, documentId: docId };
+    this.clients.set(clientId, client);
+    this.store.addConnection(clientId, docId);
+
+    // Send sync message with current state
+    this.sendMessage(ws, {
+      type: 'sync',
+      docId,
+      content: state.content,
+      version: state.version,
+    });
+
+    ws.on('message', (data) => {
+      try {
+        const raw = data.toString();
+        let message: unknown;
+        try {
+          message = JSON.parse(raw);
+        } catch {
+          this.sendMessage(ws, { type: 'error', message: 'Invalid JSON' });
+          return;
+        }
+
+        const msg = message as Record<string, unknown>;
+        if (!msg || typeof msg !== 'object' || msg.type !== 'operation') {
+          this.sendMessage(ws, { type: 'error', message: 'Unknown message type' });
+          return;
+        }
+
+        this.handleOperation(client, msg as unknown as OperationMessage);
+      } catch (err) {
+        const errMsg = err instanceof Error ? err.message : 'Unknown error';
+        this.sendMessage(ws, { type: 'error', message: errMsg });
+      }
+    });
+
+    ws.on('close', () => {
+      this.clients.delete(clientId);
+      this.store.removeConnection(clientId);
+    });
+
+    ws.on('error', () => {
+      this.clients.delete(clientId);
+      this.store.removeConnection(clientId);
+    });
+  }
+
+  private handleOperation(client: ConnectedClient, message: OperationMessage): void {
+    const { documentId } = client;
+    const state = this.getDocumentState(documentId);
+    if (!state) {
+      this.sendMessage(client.ws, { type: 'error', message: 'Document not found' });
+      return;
+    }
+
+    const { operation, version: clientVersion } = message;
+
+    // Validate version
+    if (typeof clientVersion !== 'number' || clientVersion < 0 || clientVersion > state.version) {
+      this.sendMessage(client.ws, {
+        type: 'error',
+        message: `Invalid version: ${clientVersion}. Current version: ${state.version}`,
+      });
+      return;
+    }
+
+    // Validate operation format
+    if (!Array.isArray(operation)) {
+      this.sendMessage(client.ws, { type: 'error', message: 'Operation must be an array' });
+      return;
+    }
+
+    // Transform against all operations that happened since the client's version.
+    // The client's operation was based on version `clientVersion`,
+    // but the server is now at version `state.version`.
+    // We need to transform the client op against all ops from clientVersion+1 to state.version.
+    let transformedOp = operation;
+
+    for (let v = clientVersion + 1; v <= state.version; v++) {
+      const serverOp = state.history.get(v);
+      if (serverOp) {
+        const [clientPrime] = transform(transformedOp, serverOp, true);
+        transformedOp = clientPrime;
+      }
+    }
+
+    // Validate the transformed operation against current document
+    const validationError = validate(transformedOp, state.content.length);
+    if (validationError) {
+      this.sendMessage(client.ws, { type: 'error', message: validationError });
+      return;
+    }
+
+    // Apply the transformed operation
+    let newContent: string;
+    try {
+      newContent = apply(state.content, transformedOp);
+    } catch (err) {
+      const errMsg = err instanceof Error ? err.message : 'Failed to apply operation';
+      this.sendMessage(client.ws, { type: 'error', message: errMsg });
+      return;
+    }
+
+    // Update state
+    const newVersion = state.version + 1;
+    state.content = newContent;
+    state.version = newVersion;
+    state.history.set(newVersion, transformedOp);
+
+    // Persist to database
+    this.store.updateContent(documentId, newContent);
+    this.store.addVersion(documentId, newVersion, newContent, JSON.stringify(transformedOp));
+
+    // Send ack to the sender
+    this.sendMessage(client.ws, { type: 'ack', version: newVersion });
+
+    // Broadcast the transformed operation to other clients on the same document
+    const broadcastMsg: OperationMessage = {
+      type: 'operation',
+      docId: documentId,
+      operation: transformedOp,
+      version: newVersion,
+      clientId: client.clientId,
+    };
+
+    for (const [id, otherClient] of this.clients) {
+      if (id !== client.clientId && otherClient.documentId === documentId) {
+        if (otherClient.ws.readyState === WebSocket.OPEN) {
+          this.sendMessage(otherClient.ws, broadcastMsg);
+        }
+      }
+    }
+  }
+
+  private sendMessage(ws: WebSocket, msg: ServerMessage | OperationMessage): void {
+    if (ws.readyState === WebSocket.OPEN) {
+      ws.send(JSON.stringify(msg));
+    }
+  }
+
+  /**
+   * Disconnect all clients. Used during shutdown.
+   */
+  disconnectAll(): void {
+    for (const [, client] of this.clients) {
+      try {
+        client.ws.close(1001, 'Server shutting down');
+      } catch {
+        // ignore
+      }
+    }
+    this.clients.clear();
+    this.documents.clear();
+  }
+
+  /**
+   * Invalidate cached document state (e.g., after a REST update).
+   */
+  invalidateDocument(docId: string): void {
+    this.documents.delete(docId);
+  }
+
+  /**
+   * Get the number of connected clients for a document.
+   */
+  getClientCount(docId: string): number {
+    let count = 0;
+    for (const [, client] of this.clients) {
+      if (client.documentId === docId) count++;
+    }
+    return count;
+  }
+}
