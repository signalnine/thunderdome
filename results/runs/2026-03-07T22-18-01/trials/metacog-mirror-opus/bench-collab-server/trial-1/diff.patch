h (err) {\n      res.status(500).json({ error: 'Failed to update document' });\n    }\n  });\n\n  // Patch a document (partial update)\n  router.patch('/documents/:id', (req: Request, res: Response) => {\n    try {\n      const { title, content } = req.body;\n      const doc = store.updateDocument(req.params.id, { title, content });\n      if (!doc) {\n        res.status(404).json({ error: 'Document not found' });\n        return;\n      }\n      res.json(doc);\n    } catch (err) {\n      res.status(500).json({ error: 'Failed to update document' });\n    }\n  });\n\n  // Delete a document\n  router.delete('/documents/:id', (req: Request, res: Response) => {\n    try {\n      const deleted = store.deleteDocument(req.params.id);\n      if (!deleted) {\n        res.status(404).json({ error: 'Document not found' });\n        return;\n      }\n      res.status(204).send();\n    } catch (err) {\n      res.status(500).json({ error: 'Failed to delete document' });\n    }\n  });\n\n  // Get document version history\n  router.get('/documents/:id/versions', (req: Request, res: Response) => {\n    try {\n      const doc = store.getDocument(req.params.id);\n      if (!doc) {\n        res.status(404).json({ error: 'Document not found' });\n        return;\n      }\n      const versions = store.getVersions(req.params.id);\n      res.json(versions);\n    } catch (err) {\n      res.status(500).json({ error: 'Failed to get versions' });\n    }\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":278,"cache_read_input_tokens":26813,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":278},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"25c5b16f-714c-40ac-8941-e9894b5d88ac","uuid":"2ea51d8c-0a45-4e38-a477-062ada0dc39d"}
