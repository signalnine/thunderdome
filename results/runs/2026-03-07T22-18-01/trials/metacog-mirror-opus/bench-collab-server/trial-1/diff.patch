+++ b/src/database.ts
@@ -0,0 +1,138 @@
+import Database from 'better-sqlite3';
+import { randomUUID } from 'crypto';
+
+export interface DocumentRow {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface VersionRow {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDatabase(dbPath: string = ':memory:'): Database.Database {
+  const db = new Database(dbPath);
+  db.pragma('journal_mode = WAL');
+  db.pragma('foreign_keys = ON');
+
+  db.exec(`
+    CREATE TABLE IF NOT EXISTS documents (
+      id TEXT PRIMARY KEY,
+      title TEXT NOT NULL,
+      content TEXT NOT NULL DEFAULT '',
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+
+    CREATE TABLE IF NOT EXISTS versions (
+      id INTEGER PRIMARY KEY AUTOINCREMENT,
+      document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+      version INTEGER NOT NULL,
+      content TEXT NOT NULL,
+      operation TEXT,
+      created_at TEXT NOT NULL DEFAULT (datetime('now')),
+      UNIQUE(document_id, version)
+    );
+
+    CREATE TABLE IF NOT EXISTS active_connections (
+      id TEXT PRIMARY KEY,
+      document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+      connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+    );
+  `);
+
+  return db;
+}
+
+export class DocumentStore {
+  constructor(private db: Database.Database) {}
+
+  createDocument(title: string, content: string = ''): DocumentRow {
+    const id = randomUUID();
+    const stmt = this.db.prepare(
+      'INSERT INTO documents (id, title, content) VALUES (?, ?, ?)'
+    );
+    stmt.run(id, title, content);
+
+    // Store initial version (version 0 = initial state)
+    this.db.prepare(
+      'INSERT INTO versions (document_id, version, content) VALUES (?, 0, ?)'
+    ).run(id, content);
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): DocumentRow | undefined {
+    return this.db.prepare('SELECT * FROM documents WHERE id = ?').get(id) as DocumentRow | undefined;
+  }
+
+  listDocuments(): DocumentRow[] {
+    return this.db.prepare('SELECT * FROM documents ORDER BY updated_at DESC').all() as DocumentRow[];
+  }
+
+  updateDocument(id: string, updates: { title?: string; content?: string }): DocumentRow | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+
+    this.db.prepare(
+      "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+    ).run(title, content, id);
+
+    return this.getDocument(id);
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.db.prepare('DELETE FROM documents WHERE id = ?').run(id);
+    return result.changes > 0;
+  }
+
+  getVersions(documentId: string): VersionRow[] {
+    return this.db.prepare(
+      'SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC'
+    ).all(documentId) as VersionRow[];
+  }
+
+  getLatestVersion(documentId: string): number {
+    const row = this.db.prepare(
+      'SELECT COALESCE(MAX(version), 0) as max_version FROM versions WHERE document_id = ?'
+    ).get(documentId) as { max_version: number } | undefined;
+    return row?.max_version ?? 0;
+  }
+
+  addVersion(documentId: string, version: number, content: string, operation?: string): void {
+    this.db.prepare(
+      'INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)'
+    ).run(documentId, version, content, operation ?? null);
+  }
+
+  updateContent(id: string, content: string): void {
+    this.db.prepare(
+      "UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?"
+    ).run(content, id);
+  }
+
+  addConnection(id: string, documentId: string): void {
+    this.db.prepare(
+      'INSERT OR REPLACE INTO active_connections (id, document_id) VALUES (?, ?)'
+    ).run(id, documentId);
+  }
+
+  removeConnection(id: string): void {
+    this.db.prepare('DELETE FROM active_connections WHERE id = ?').run(id);
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
