+import { Router, Request, Response } from 'express';
+import { DocumentStore } from './database.js';
+
+export function createRouter(store: DocumentStore): Router {
+  const router = Router();
+
+  // Create a document
+  router.post('/documents', (req: Request, res: Response) => {
+    try {
+      const { title, content } = req.body;
+      if (!title || typeof title !== 'string') {
+        res.status(400).json({ error: 'Title is required and must be a string' });
+        return;
+      }
+      const doc = store.createDocument(title, content ?? '');
+      res.status(201).json(doc);
+    } catch (err) {
+      res.status(500).json({ error: 'Failed to create document' });
+    }
+  });
+
+  // List all documents
+  router.get('/documents', (_req: Request, res: Response) => {
+    try {
+      const docs = store.listDocuments();
+      res.json(docs);
+    } catch (err) {
+      res.status(500).json({ error: 'Failed to list documents' });
+    }
+  });
+
+  // Get a document by ID
+  router.get('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const doc = store.getDocument(req.params.id);
+      if (!doc) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      res.json(doc);
+    } catch (err) {
+      res.status(500).json({ error: 'Failed to get document' });
+    }
+  });
+
+  // Update a document
+  router.put('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const { title, content } = req.body;
+      const doc = store.updateDocument(req.params.id, { title, content });
+      if (!doc) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      res.json(doc);
+    } catch (err) {
+      res.status(500).json({ error: 'Failed to update document' });
+    }
+  });
+
+  // Patch a document (partial update)
+  router.patch('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const { title, content } = req.body;
+      const doc = store.updateDocument(req.params.id, { title, content });
+      if (!doc) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      res.json(doc);
+    } catch (err) {
+      res.status(500).json({ error: 'Failed to update document' });
+    }
+  });
+
+  // Delete a document
+  router.delete('/documents/:id', (req: Request, res: Response) => {
+    try {
+      const deleted = store.deleteDocument(req.params.id);
+      if (!deleted) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      res.status(204).send();
+    } catch (err) {
+      res.status(500).json({ error: 'Failed to delete document' });
+    }
+  });
+
+  // Get document version history
+  router.get('/documents/:id/versions', (req: Request, res: Response) => {
+    try {
+      const doc = store.getDocument(req.params.id);
+      if (!doc) {
+        res.status(404).json({ error: 'Document not found' });
+        return;
+      }
+      const versions = store.getVersions(req.params.id);
+      res.json(versions);
+    } catch (err) {
+      res.status(500).json({ error: 'Failed to get versions' });
+    }
+  });
+
+  return router;
+}
