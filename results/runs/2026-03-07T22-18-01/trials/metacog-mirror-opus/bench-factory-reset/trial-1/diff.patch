ber,\n   111→  numFree: number,\n   112→  rank: number\n   113→): number[] {\n   114→  let bestIndices: number[] | null = null;\n   115→  let bestCount = m + 1;\n   116→\n   117→  const total = 1 << numFree;\n   118→\n   119→  for (let mask = 0; mask < total; mask++) {\n   120→    // Count free variable presses\n   121→    let count = popcount(mask);\n   122→\n   123→    // Early termination: if free vars alone exceed best, skip\n   124→    if (count >= bestCount) continue;\n   125→\n   126→    // Compute pivot variables\n   127→    const pressed: number[] = [];\n   128→\n   129→    // Add free variable indices that are pressed\n   130→    for (let j = 0; j < numFree; j++) {\n   131→      if ((mask >> j) & 1) {\n   132→        pressed.push(freeVars[j]);\n   133→        // count already includes this\n   134→      }\n   135→    }\n   136→\n   137→    // Compute each pivot variable\n   138→    let exceeded = false;\n   139→    for (let i = 0; i < rank; i++) {\n   140→      let val = pivotRHS[i];\n   141→      for (const fj of pivotFreeCoeffs[i]) {\n   142→        val ^= (mask >> fj) & 1;\n   143→      }\n   144→      if (val === 1) {\n   145→        pressed.push(pivotCols[i]);\n   146→        count++;\n   147→        if (count > bestCount) { exceeded = true; break; }\n   148→      }\n   149→    }\n   150→\n   151→    if (exceeded || count > bestCount) continue;\n   152→\n   153→    pressed.sort((a, b) => a - b);\n   154→    if (count < bestCount || compareLex(pressed, bestIndices!) < 0) {\n   155→      bestIndices = pressed;\n   156→      bestCount = count;\n   157→    }\n   158→  }\n   159→\n   160→  return bestIndices!;\n   161→}\n   162→\n   163→function solveToggleMITM(\n   164→  pivotCols: number[],\n   165→  freeVars: number[],\n   166→  pivotFreeCoeffs: number[][],\n   167→  pivotRHS: number[],\n   168→  m: number,\n   169→  numFree: number,\n   170→  rank: number\n   171→): number[] {\n   172→  const halfA = Math.floor(numFree / 2);\n   173→  const halfB = num