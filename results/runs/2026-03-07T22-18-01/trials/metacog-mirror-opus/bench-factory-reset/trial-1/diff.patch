if (numFree <= 25) {\n    // Direct enumeration\n    return solveToggleDirect(pivotCols, freeVars, pivotFreeCoeffs, pivotRHS, m, numFree, rank);\n  } else {\n    // Meet-in-the-middle\n    return solveToggleMITM(pivotCols, freeVars, pivotFreeCoeffs, pivotRHS, m, numFree, rank);\n  }\n}\n\nfunction solveToggleDirect(\n  pivotCols: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotRHS: number[],\n  m: number,\n  numFree: number,\n  rank: number\n): number[] {\n  let bestIndices: number[] | null = null;\n  let bestCount = m + 1;\n\n  const total = 1 << numFree;\n\n  for (let mask = 0; mask < total; mask++) {\n    // Count free variable presses\n    let count = popcount(mask);\n\n    // Early termination: if free vars alone exceed best, skip\n    if (count >= bestCount) continue;\n\n    // Compute pivot variables\n    const pressed: number[] = [];\n\n    // Add free variable indices that are pressed\n    for (let j = 0; j < numFree; j++) {\n      if ((mask >> j) & 1) {\n        pressed.push(freeVars[j]);\n        // count already includes this\n      }\n    }\n\n    // Compute each pivot variable\n    for (let i = 0; i < rank; i++) {\n      let val = pivotRHS[i];\n      for (const fj of pivotFreeCoeffs[i]) {\n        val ^= (mask >> fj) & 1;\n      }\n      if (val === 1) {\n        pressed.push(pivotCols[i]);\n        count++;\n        if (count >= bestCount) break;\n      }\n    }\n\n    if (count >= bestCount) {\n      if (count > bestCount) continue;\n      // Same count - check lex ordering\n      pressed.sort((a, b) => a - b);\n      if (compareLex(pressed, bestIndices!) < 0) {\n        bestIndices = pressed;\n        bestCount = count;\n      }\n    } else {\n      pressed.sort((a, b) => a - b);\n      bestIndices = pressed;\n      bestCount = count;\n    }\n  }\n\n  return bestIndices!;\n}\n\nfunction solveToggleMITM(\n  pivotCols: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotRHS: number[],\n  m: number,\n  numFree: number,\n  rank: number\n): number[] {\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n\n  const sizeA = 1 << halfA;\n  const sizeB = 1 << halfB;\n\n  // For each first-half assignment, compute signature and group by (signature, count).\n  // Keep only the lex-smallest freePressed for each (signature, count) pair.\n  type HalfEntry = { count: number; freePressed: number[] };\n\n  // sigMap: signature -> array of entries sorted by count, keeping best per count\n  const sigMapA = new Map<number, HalfEntry[]>();\n\n  for (let maskA = 0; maskA < sizeA; maskA++) {\n    const freePressed: number[] = [];\n    for (let j = 0; j < halfA; j++) {\n      if ((maskA >> j) & 1) {\n        freePressed.push(freeVars[j]);\n      }\n    }\n\n    let sig = 0;\n    for (let i = 0; i < rank; i++) {\n      let bit = 0;\n      for (const fj of pivotFreeCoeffs[i]) {\n        if (fj < halfA) {\n          bit ^= (maskA >> fj) & 1;\n        }\n      }\n      sig |= (bit << i);\n    }\n\n    const count = freePressed.length;\n\n    if (!sigMapA.has(sig)) {\n      sigMapA.set(sig, []);\n    }\n\n    const entries = sigMapA.get(sig)!;\n    // Check if we already have an entry with this count\n    const existing = entries.find(e => e.count === count);\n    if (existing) {\n      if (compareLex(freePressed, existing.freePressed) < 0) {\n        existing.freePressed = freePressed;\n      }\n    } else {\n      entries.push({ count, freePressed });\n    }\n  }\n\n  // Sort each signature's entries by count\n  for (const [, entries] of sigMapA) {\n    entries.sort((a, b) => a.count - b.count);\n  }\n\n  // Precompute pivotRHSBits\n  let pivotRHSBits = 0;\n  for (let i = 0; i < rank; i++) {\n    pivotRHSBits |= (pivotRHS[i] << i);\n  }\n\n  let bestIndices: number[] | null = null;\n  let bestCount = m + 1;\n\n  for (let maskB = 0; maskB < sizeB; maskB++) {\n    const freePressedB: number[] = [];\n    let countB = 0;\n\n    for (let j = 0; j < halfB; j++) {\n      if (