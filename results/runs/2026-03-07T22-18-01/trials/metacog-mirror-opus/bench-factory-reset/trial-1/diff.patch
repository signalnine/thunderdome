+describe('solveCounter', () => {
+  it('should return all zeros when target is all zero', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should solve a simple single-button case', () => {
+    // Button 0 increments counter 0. Target: counter 0 = 3 mod 5.
+    // Press 3 times.
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('should return null when no solution exists', () => {
+    // Button 0 increments both counters. Target: [1, 2] mod 3.
+    // Any number of presses of button 0 gives [k, k] mod 3.
+    // Can't get [1, 2] from that.
+    const result = solveCounter([1, 2], [[0, 1]], 3);
+    expect(result).toBeNull();
+  });
+
+  it('should find minimum total presses', () => {
+    // Button 0: increments [0], Button 1: increments [0]
+    // Target: [3] mod 5. Options: (3,0), (0,3), (2,1), (1,2), (4,4)
+    // Minimum sum is 3, achieved by (3,0) and (0,3).
+    // Lex-smallest is [0,3].
+    const result = solveCounter([3], [[0], [0]], 5);
+    expect(result).toEqual([0, 3]);
+  });
+
+  it('should handle modular arithmetic', () => {
+    // Button 0: increments [0]. Target: [0] mod 5.
+    // Press 0 times (sum=0) or 5 times (but max is p-1=4, which gives 4 mod 5 = 4 ≠ 0).
+    // Answer: [0]
+    const result = solveCounter([0], [[0]], 5);
+    expect(result).toEqual([0]);
+  });
+
+  it('should solve a two-button two-counter case', () => {
+    // Button 0: [0], Button 1: [1]
+    // Target: [2, 3] mod 5
+    // Solution: press button 0 twice, button 1 three times
+    const result = solveCounter([2, 3], [[0], [1]], 5);
+    expect(result).toEqual([2, 3]);
+  });
+
+  it('should handle no buttons', () => {
+    const result = solveCounter([1], [], 3);
+    expect(result).toBeNull();
+  });
+
+  it('should handle no buttons with zero target', () => {
+    const result = solveCounter([0, 0], [], 3);
+    expect(result).toEqual([]);
+  });
+
+  it('should verify counter result', () => {
+    const lights = [2, 1, 3];
+    const buttons = [[0, 1], [1, 2], [0, 2]];
+    const modulus = 5;
+    const result = solveCounter(lights, buttons, modulus);
+
+    if (result !== null) {
+      // Verify solution
+      const counters = new Array(lights.length).fill(0);
+      for (let i = 0; i < result.length; i++) {
+        for (const idx of buttons[i]) {
+          counters[idx] = (counters[idx] + result[i]) % modulus;
+        }
+      }
+      expect(counters).toEqual(lights);
+    }
+  });
+
+  it('should handle prime modulus correctly', () => {
+    // Simple case with mod 7
+    const result = solveCounter([6], [[0]], 7);
+    expect(result).toEqual([6]);
+  });
+
+  it('should return lex-smallest when tied on sum', () => {
+    // Two buttons both toggle counter 0. mod 5, target 1.
+    // Options: (1,0) sum=1, (0,1) sum=1.
+    // Lex smallest: [0,1]
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should handle multiple counters with shared buttons', () => {
+    // Button 0: [0, 1, 2]
+    // Button 1: [0]
+    // Button 2: [1]
+    // Button 3: [2]
+    // Target: [3, 2, 1] mod 5
+    // One solution: button 0 pressed 1 time -> [1,1,1], then button 1 pressed 2 -> [3,1,1],
+    // button 2 pressed 1 -> [3,2,1], button 3 pressed 0 -> [3,2,1]. Sum = 1+2+1+0 = 4
+    const result = solveCounter([3, 2, 1], [[0, 1, 2], [0], [1], [2]], 5);
+    if (result !== null) {
+      const counters = [0, 0, 0];
+      for (let i = 0; i < result.length; i++) {
+        for (const idx of [[0, 1, 2], [0], [1], [2]][i]) {
+          counters[idx] = (counters[idx] + result[i]) % 5;
+        }
+      }
+      expect(counters).toEqual([3, 2, 1]);
+    }
+  });
+});
