// Compute solution and cost\n    let sum = 0;\n    const sol = new Array(m).fill(0);\n\n    for (let j = 0; j < numFree; j++) {\n      sol[freeVars[j]] = freeVals[j];\n      sum += freeVals[j];\n    }\n\n    if (sum <= bestSum) {\n      // Compute pivot values\n      let valid = true;\n      for (let i = 0; i < rank; i++) {\n        let val = pivotRHS[i];\n        for (let j = 0; j < numFree; j++) {\n          val = val - pivotFreeCoeffs[i][j] * freeVals[j];\n        }\n        val = ((val % p) + p) % p;\n        sol[pivotCols[i]] = val;\n        sum += val;\n        if (sum > bestSum) { valid = false; break; }\n      }\n\n      if (valid && (sum < bestSum || (sum === bestSum && isLexSmaller(sol, bestSolution!, m)))) {\n        bestSum = sum;\n        bestSolution = sol.slice();\n      }\n    }\n\n    // Increment odometer\n    done = true;\n    for (let i = 0; i < numFree; i++) {\n      freeVals[i]++;\n      if (freeVals[i] >= p) {\n        freeVals[i] = 0;\n      } else {\n        done = false;\n        break;\n      }\n    }\n  }\n\n  return bestSolution!;\n}\n\nfunction solveCounterOptimize(\n  pivotCols: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotRHS: number[],\n  m: number,\n  p: number,\n  numFree: number,\n  rank: number\n): number[] {\n  // For large free variable spaces, use coordinate descent + random restarts\n  const computeSolAndCost = (fv: number[]): [number[], number] => {\n    const sol = new Array(m).fill(0);\n    let sum = 0;\n    for (let j = 0; j < numFree; j++) {\n      sol[freeVars[j]] = fv[j];\n      sum += fv[j];\n    }\n    for (let i = 0; i < rank; i++) {\n      let val = pivotRHS[i];\n      for (let j = 0; j < numFree; j++) {\n        val -= pivotFreeCoeffs[i][j] * fv[j];\n      }\n      val = ((val % p) + p) % p;\n      sol[pivotCols[i]] = val;\n      sum += val;\n    }\n    return [sol, sum];\n  };\n\n  let bestSolution: number[] | null = null;\n  let bestSum = Infinity;\n\n  // Try multiple starting point