xSmaller(sol, bestSolForFi, m)) {\n        bestValForFi = v;\n        bestSolForFi = sol.slice();\n      }\n    }\n\n    fv[fi] = bestValForFi;\n    bestSolution = bestSolForFi;\n  }\n\n  return bestSolution!;","originalFile":"export interface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// --- GF(2) Toggle Solver ---\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const n = target.length;  // number of lights\n  const m = buttons.length; // number of buttons\n\n  if (m === 0) {\n    return target.every(t => !t) ? [] : null;\n  }\n\n  // Build augmented matrix over GF(2): rows=lights, cols=buttons+1\n  // matrix[i][j] = 1 if button j toggles light i\n  // matrix[i][m] = target[i]\n  const mat: Uint8Array[] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Uint8Array(m + 1);\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[m] = target[i] ? 1 : 0;\n    mat.push(row);\n  }\n\n  // Gaussian elimination to RREF over GF(2)\n  const pivotCols: number[] = [];\n  let curRow = 0;\n\n  for (let col = 0; col < m && curRow < n; col++) {\n    // Find pivot\n    let pr = -1;\n    for (let r = curRow; r < n; r++) {\n      if (mat[r][col] === 1) { pr = r; break; }\n    }\n    if (pr === -1) continue;\n\n    // Swap\n    [mat[curRow], mat[pr]] = [mat[pr], mat[curRow]];\n\n    // Eliminate all other rows with a 1 in this column\n    for (let r = 0; r < n; r++) {\n      if (r !== curRow && mat[r][col] === 1) {\n        for (let c = col; c <= m; c++) {\n          mat[r][c] ^= mat[curRow][c];\n        }\n      }\n    }\n\n    pivotCols.push(col);\n    curRow++;\n  }\n\n  const rank = pivotCols.length;\n\n  // Check consistency\n  for (let r = rank; r < n; r++) {\n    if (mat[r][m] !== 0) return null;\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCols);\n  const freeVars: number[] = [];\n  for (let j = 0; j <