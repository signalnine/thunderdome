t r = 0; r < n; r++) {\n      if (r !== curRow && mat[r][col] === 1) {\n        for (let c = col; c <= m; c++) {\n          mat[r][c] ^= mat[curRow][c];\n        }\n      }\n    }\n\n    pivotCols.push(col);\n    curRow++;\n  }\n\n  const rank = pivotCols.length;\n\n  // Check consistency\n  for (let r = rank; r < n; r++) {\n    if (mat[r][m] !== 0) return null;\n  }\n\n  // Identify free variables\n  const pivotSet = new Set(pivotCols);\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotSet.has(j)) freeVars.push(j);\n  }\n\n  const numFree = freeVars.length;\n\n  // For each free variable assignment, compute pivot variables and total cost.\n  // We want minimum number of button presses, then lex-smallest index set.\n  //\n  // After RREF, for pivot row i with pivot in column pivotCols[i]:\n  //   x[pivotCols[i]] = mat[i][m] XOR (sum of mat[i][freeVar_j] * freeVal_j)\n  //\n  // Precompute: for each pivot row, which free variables contribute\n  const pivotFreeCoeffs: number[][] = []; // pivotFreeCoeffs[i] = list of free var indices with coeff 1\n  const pivotRHS: number[] = [];\n  for (let i = 0; i < rank; i++) {\n    const coeffs: number[] = [];\n    for (let j = 0; j < numFree; j++) {\n      if (mat[i][freeVars[j]] === 1) {\n        coeffs.push(j);\n      }\n    }\n    pivotFreeCoeffs.push(coeffs);\n    pivotRHS.push(mat[i][m]);\n  }\n\n  if (numFree <= 25) {\n    // Direct enumeration\n    return solveToggleDirect(pivotCols, freeVars, pivotFreeCoeffs, pivotRHS, m, numFree, rank);\n  } else {\n    // Meet-in-the-middle\n    return solveToggleMITM(pivotCols, freeVars, pivotFreeCoeffs, pivotRHS, m, numFree, rank);\n  }\n}\n\nfunction solveToggleDirect(\n  pivotCols: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotRHS: number[],\n  m: number,\n  numFree: number,\n  rank: number\n): number[] {\n  let bestIndices: number[] | null = null;\n  let bestCount = m + 1;\n\n  const total = 1 << numFree;\n\n  for (let mask = 0; mask < total; mask++) {\n    // Count free variable presses\n    let count = popcount(mask);\n\n    // Early termination: if free vars alone exceed best, skip\n    if (count >= bestCount) continue;\n\n    // Compute pivot variables\n    const pressed: number[] = [];\n\n    // Add free variable indices that are pressed\n    for (let j = 0; j < numFree; j++) {\n      if ((mask >> j) & 1) {\n        pressed.push(freeVars[j]);\n        // count already includes this\n      }\n    }\n\n    // Compute each pivot variable\n    for (let i = 0; i < rank; i++) {\n      let val = pivotRHS[i];\n      for (const fj of pivotFreeCoeffs[i]) {\n        val ^= (mask >> fj) & 1;\n      }\n      if (val === 1) {\n        pressed.push(pivotCols[i]);\n        count++;\n        if (count >= bestCount) break;\n      }\n    }\n\n    if (count >= bestCount) {\n      if (count > bestCount) continue;\n      // Same count - check lex ordering\n      pressed.sort((a, b) => a - b);\n      if (compareLex(pressed, bestIndices!) < 0) {\n        bestIndices = pressed;\n        bestCount = count;\n      }\n    } else {\n      pressed.sort((a, b) => a - b);\n      bestIndices = pressed;\n      bestCount = count;\n    }\n  }\n\n  return bestIndices!;\n}\n\nfunction solveToggleMITM(\n  pivotCols: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotRHS: number[],\n  m: number,\n  numFree: number,\n  rank: number\n): number[] {\n  // Split free variables into two halves\n  const halfA = Math.floor(numFree / 2);\n  const halfB = numFree - halfA;\n\n  // For the first half: compute a \"signature\" for each assignment\n  // The signature captures the XOR contribution of first-half free vars to each pivot row\n  // Signature: for each pivot row i, the XOR of mat[i][freeVars[j]] * freeVal_j for j in first half\n  // This is a bit vector of length rank.\n\n  // For each first-half assignment, compute:\n  // - number of free vars pressed in first half\n  // - signature (effect on each pivot row)\n  // - which free var indices are pressed\n\n  // Group by signature. For each signature, keep the assignment with min presses,\n  // then lex-smallest.\n\n  // Then for each second-half assignment:\n  // - Compute its signature contribution\n  // - The full pivot values are: pivotRHS[i] XOR sigA[i] XOR sigB[i]\n  // - Total count = freeCountA + freeCountB + popcount(pivotValues)\n  // - Look up best first-half for the complementary signature\n\n  const sizeA = 1 << halfA;\n  const sizeB = 1 << halfB;\n\n  // For each first-half mask, compute signature as a number (bitfield of rank bits)\n  // and the count of pressed free vars\n  type HalfEntry = { mask: number; count: number; freePressed: number[] };\n\n  // Group by signature\n  const sigMapA = new Map<number, HalfEntry[]>();\n\n  for (let maskA = 0; maskA < sizeA; maskA++) {\n    let sig = 0;\n    const freePressed: number[] = [];\n\n    for (let j = 0; j < halfA; j++) {\n      if ((maskA >> j) & 1) {\n        freePressed.push(freeVars[j]);\n      }\n    }\n\n    // Compute signature\n    for (let i = 0; i < rank; i++) {\n      let bit = 0;\n      for (const fj of pivotFreeCoeffs[i]) {\n        if (fj < halfA) {\n          bit ^= (maskA >> fj) & 1;\n        }\n      }\n      sig |= (bit << i);\n    }\n\n    const entry: HalfEntry = { mask: maskA, count: freePressed.length, freePressed };\n\n    if (!sigMapA.has(sig)) {\n      sigMapA.set(sig, []);\n    }\n    sigMapA.get(sig)!.push(entry);\n  }\n\n  // Sort entries within each signature by count then lex for efficient processing\n  for (const [, entries] of sigMapA) {\n    entries.sort((a, b) => {\n      if (a.count !== b.count) return a.count - b.count;\n      return compareLex(a.freePressed, b.freePressed);\n    });\n  }\n\n  // Now enumerate second half\n  let bestIndices: number[] | null = null;\n  let bestCount = m + 1;\n\n  for (let maskB = 0; maskB < sizeB; maskB++) {\n    const freePressedB: number[] = [];\n    let countB = 0;\n\n    for (let j = 0; j < halfB; j++) {\n      if ((maskB >> j) & 1) {\n        freePressedB.push(freeVars[halfA + j]);\n        countB++;\n      }\n    }\n\n    // Compute B's signature contribution\n    let sigB = 0;\n    for (let i = 0; i < rank; i++) {\n      let bit = 0;\n      for (const fj of pivotFreeCoeffs[i]) {\n        if (fj >= halfA) {\n          bit ^= (maskB >> (fj - halfA)) & 1;\n        }\n      }\n      sigB |= (bit << i);\n    }\n\n    // For each possible A signature, the full pivot values are:\n    // pivotRHS[i] XOR sigA_bit_i XOR sigB_bit_i\n    // The number of pivots pressed = popcount(pivotRHSBits XOR sigA XOR sigB)\n    // where pivotRHSBits is the bitfield of pivotRHS values\n\n    // We want to find the sigA that minimizes:\n    // countA + countB + popcount(pivotRHSBits XOR sigA XOR sigB)\n    // = countA + popcount(pivotRHSBits XOR sigB XOR sigA) + countB\n\n    // Let target = pivotRHSBits XOR sigB\n    // We want sigA that minimizes countA + popcount(target XOR sigA)\n\n    let pivotRHSBits = 0;\n    for (let i = 0; i < rank; i++) {\n      pivotRHSBits |= (pivotRHS[i] << i);\n    }\n\n    const target = pivotRHSBits ^ sigB;\n\n    // Try all signatures in the map\n    for (const [sigA, entries] of sigMapA) {\n      const pivotCount = popcount(target ^ sigA);\n\n      for (const entryA of entries) {\n        const totalCount = entryA.count + countB + pivotCount;\n\n        if (totalCount > bestCount) continue;\n\n        // Build full pressed list\n        const pressed: number[] = [...entryA.freePressed, ...freePressedB];\n\n        // Add pivot indices\n        const fullSig = target ^ sigA;\n        for (let i = 0; i < rank; i++) {\n          if ((fullSig >> i) & 1) {\n            pressed.push(pivotCols[i]);\n          }\n        }\n        pressed.sort((a, b) => a - b);\n\n        if (totalCount < bestCount || compareLex(pressed, bestIndices!) < 0) {\n          bestCount = totalCount;\n          bestIndices = pressed;\n        }\n      }\n    }\n  }\n\n  return bestIndices!;\n}\n\nfunction popcount(x: number): number {\n  let count = 0;\n  while (x) {\n    count += x & 1;\n    x >>= 1;\n  }\n  return count;\n}\n\nfunction compareLex(a: number[], b: number[]): number {\n  const len = Math.min(a.length, b.length);\n  for (let i = 0; i < len; i++) {\n    if (a[i] < b[i]) return -1;\n    if (a[i] > b[i]) return 1;\n  }\n  return a.length - b.length;\n}\n\n// --- GF(p) Counter Solver ---\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const n = lights.length;  // number of counters/lights\n  const m = buttons.length; // number of buttons\n\n  if (m === 0) {\n    return lights.every(l => l % modulus === 0) ? [] : null;\n  }\n\n  // Build augmented matrix over GF(p): rows=lights, cols=buttons+1\n  const mat: number[][] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Array(m + 1).fill(0);\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[m] = ((lights[i] % modulus) + modulus) % modulus;\n    mat.push(row);\n  }\n\n  // Gaussian elimination to RREF over GF(p)\n  const pivotCols: number[] = [];\n  let curRow = 0;\n\n  for (let col = 0; col < m && curRow < n; col++) {\n    let pr = -1;\n    for (let r = curRow; r < n; r++) {\n      if (mat[r][col] !== 0) { pr = r; break; }\n    }\n    if (pr === -1) continue;\n\n    [mat[curRow], mat[pr]] = [mat[pr], mat[curRow]];\n\n    // Normalize\n    const inv = modInverse(mat[curRow][col], modulus);\n    for (let c = col; c <= m; c++) {\n      mat[curRow][c] = (mat[curRow][c] * inv) % modulus;\n    }\n\n    // Eliminate\n    for (let r = 0; r < n; r++) {\n      if (r !== curRow && mat[r][col] !== 0) {\n        const factor = mat[r][col];\n        for (let c = col; c <= m; c++) {\n          mat[r][c] = (((mat[r][c] - factor * mat[curRow][c]) % modulus) + modulus) % modulus;\n        }\n      }\n    }\n\n    pivotCols.push(col);\n    curRow++;\n  }\n\n  const rank = pivotCols.length;\n\n  // Check consistency\n  for (let r = rank; r < n; r++) {\n    if (mat[r][m] !== 0) return null;\n  }\n\n  // Free variables\n  const pivotSet = new Set(pivotCols);\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotSet.has(j)) freeVars.push(j);\n  }\n\n  const numFree = freeVars.length;\n\n  // Precompute pivot row coefficients for free variables\n  const pivotFreeCoeffs: number[][] = [];\n  const pivotRHSVals: number[] = [];\n  for (let i = 0; i < rank; i++) {\n    const coeffs: number[] = new Array(numFree);\n    for (let j = 0; j < numFree; j++) {\n      coeffs[j] = mat[i][freeVars[j]];\n    }\n    pivotFreeCoeffs.push(coeffs);\n    pivotRHSVals.push(mat[i][m]);\n  }\n\n  // Check feasibility of enumeration\n  let totalCombinations = 1;\n  let feasible = true;\n  for (let i = 0; i < numFree; i++) {\n    totalCombinations *= modulus;\n    if (totalCombinations > 10_000_000) {\n      feasible = false;\n      break;\n    }\n  }\n\n  if (numFree === 0) {\n    // Unique solution\n    const solution = new Array(m).fill(0);\n    for (let i = 0; i < rank; i++) {\n      solution[pivotCols[i]] = pivotRHSVals[i];\n    }\n    return solution;\n  }\n\n  if (feasible) {\n    return solveCounterEnum(pivotCols, freeVars, pivotFreeCoeffs, pivotRHSVals, m, modulus, numFree, rank);\n  } else {\n    return solveCounterOptimize(pivotCols, freeVars, pivotFreeCoeffs, pivotRHSVals, m, modulus, numFree, rank);\n  }\n}\n\nfunction solveCounterEnum(\n  pivotCols: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotRHS: number[],\n  m: number,\n  p: number,\n  numFree: number,\n  rank: number\n): number[] {\n  let bestSolution: number[] | null = null;\n  let bestSum = Infinity;\n\n  const freeVals = new Array(numFree).fill(0);\n\n  while (true) {\n    // Compute solution and cost\n    let sum = 0;\n    const sol = new Array(m).fill(0);\n\n    for (let j = 0; j < numFree; j++) {\n      sol[freeVars[j]] = freeVals[j];\n      sum += freeVals[j];\n    }\n\n    if (sum < bestSum) {\n      // Compute pivot values\n      let valid = true;\n      for (let i = 0; i < rank; i++) {\n        let val = pivotRHS[i];\n        for (let j = 0; j < numFree; j++) {\n          val = val - pivotFreeCoeffs[i][j] * freeVals[j];\n        }\n        val = ((val % p) + p) % p;\n        sol[pivotCols[i]] = val;\n        sum += val;\n        if (sum >= bestSum) { valid = false; break; }\n      }\n\n      if (valid && (sum < bestSum || (sum === bestSum && isLexSmaller(sol, bestSolution!, m)))) {\n        bestSum = sum;\n        bestSolution = sol.slice();\n      }\n    } else if (sum === bestSum) {\n      // Still might tie after adding pivot values\n      for (let i = 0; i < rank; i++) {\n        let val = pivotRHS[i];\n        for (let j = 0; j < numFree; j++) {\n          val = val - pivotFreeCoeffs[i][j] * freeVals[j];\n        }\n        val = ((val % p) + p) % p;\n        sol[pivotCols[i]] = val;\n        sum += val;\n      }\n\n      if (sum < bestSum || (sum === bestSum && isLexSmaller(sol, bestSolution!, m))) {\n        bestSum = sum;\n        bestSolution = sol.slice();\n      }\n    }\n    // If sum > bestSum from free vars alone, skip (already handled by continuing)\n\n    // Increment odometer\n    let carry = true;\n    for (let i = 0; i < numFree && carry; i++) {\n      freeVals[i]++;\n      if (freeVals[i] >= p) {\n        freeVals[i] = 0;\n      } else {\n        carry = false;\n      }\n    }\n    if (carry) break;\n  }\n\n  return bestSolution!;\n}\n\nfunction solveCounterOptimize(\n  pivotCols: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotRHS: number[],\n  m: number,\n  p: number,\n  numFree: number,\n  rank: number\n): number[] {\n  // For large free variable spaces, use coordinate descent + random restarts\n  const computeSolAndCost = (fv: number[]): [number[], number] => {\n    const sol = new Array(m).fill(0);\n    l