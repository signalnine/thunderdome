+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from '../src/index.js';
+
+describe('solveToggle', () => {
+  it('should return empty array when target is all off', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should return null when no solution exists', () => {
+    // From the problem description example
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should solve a simple single-button case', () => {
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should solve a two-button case', () => {
+    // Target: [true, false, true]
+    // Button 0: toggles [0]
+    // Button 1: toggles [2]
+    // Solution: press 0 and 1
+    const result = solveToggle({
+      target: [true, false, true],
+      buttons: [[0], [2]],
+    });
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should find minimum presses', () => {
+    // Target: [true, true]
+    // Button 0: toggles [0, 1] -> achieves target with 1 press
+    // Button 1: toggles [0]
+    // Button 2: toggles [1]
+    // Both {0} and {1,2} work; {0} is minimum
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should return lex-smallest when tied on press count', () => {
+    // Target: [true]
+    // Button 0: toggles [0]
+    // Button 1: toggles [0]
+    // Both {0} and {1} work with 1 press. {0} is lex-smaller.
+    const result = solveToggle({
+      target: [true],
+      buttons: [[0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle no buttons needed', () => {
+    const result = solveToggle({
+      target: [false, false],
+      buttons: [[0, 1]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should handle no buttons available', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should handle no buttons available with all off target', () => {
+    const result = solveToggle({
+      target: [false],
+      buttons: [],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should handle larger case', () => {
+    // 5 lights, 5 buttons
+    // Each button toggles one light
+    // Target: all on
+    const result = solveToggle({
+      target: [true, true, true, true, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    });
+    expect(result).toEqual([0, 1, 2, 3, 4]);
+  });
+
+  it('should handle overlapping buttons correctly', () => {
