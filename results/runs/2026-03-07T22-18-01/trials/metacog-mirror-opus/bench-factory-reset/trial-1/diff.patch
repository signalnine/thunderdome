 boolean[];\n  buttons: number[][];\n}\n\n/**\n * Solve toggle puzzle over GF(2) using Gaussian elimination.\n * Find minimum button presses, then lexicographically smallest.\n */\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix over GF(2)\n  // Each row corresponds to a light\n  // Each column corresponds to a button, plus one augmented column for the target\n  // matrix[light][button] = 1 if button toggles that light\n  // We work with the transpose: rows=lights, cols=buttons, augmented with target\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = target[i] ? 1 : 0;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(2)\n  const pivotCol: number[] = []; // pivotCol[row] = column index of pivot in that row\n  const pivotRow: number[] = new Array(numButtons).fill(-1); // pivotRow[col] = row where this col is a pivot\n  let row = 0;\n  for (let col = 0; col < numButtons && row < numLights; col++) {\n    // Find pivot row\n    let pivotR = -1;\n    for (let r = row; r < numLights; r++) {\n      if (matrix[r][col] === 1) {\n        pivotR = r;\n        break;\n      }\n    }\n    if (pivotR === -1) continue; // Free variable\n\n    // Swap rows\n    [matrix[row], matrix[pivotR]] = [matrix[pivotR], matrix[row]];\n\n    // Eliminate all other rows\n    for (let r = 0; r < numLights; r++) {\n      if (r !== row && matrix[r][col] === 1) {\n        for (let c = col; c <= numButtons; c++) {\n          matrix[r][c] ^= matrix[row][c];\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = row;\n    row++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check consistency: any row with all-zero coefficients but non-zero target\n  for (let r = rank; r < numLights; r++) {\n    if (matrix[r][numButtons] !== 0) {\n      return null; // No solution\n    }\n  }\n\n  // Identify free variables (columns not in pivotCol)\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (!pivotColSet.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Enumerate all 2^numFree assignments to free variables\n  // For each, compute forced variables and count total presses\n  let bestSolution: number[] | null = null;\n  let bestCount = numButtons + 1;\n\n  const totalCombinations = 1 << numFree;\n\n  for (let mask = 0; mask < totalCombinations; mask++) {\n    const solution = new Array(numButtons).fill(0);\n\n    // Set free variables\n    for (let i = 0; i < numFree; i++) {\n      solution[freeVars[i]] = (mask >> i) & 1;\n    }\n\n    // Compute pivot variables via back-substitution\n    // Since we did full elimination (reduced row echelon form),\n    // each pivot row has exactly one pivot variable\n    let valid = true;\n    for (let i = rank - 1; i >= 0; i--) {\n      const pc = pivotCol[i];\n      let val = matrix[i][numButtons];\n      for (let c = 0; c < numButtons; c++) {\n        if (c !== pc && matrix[i][c] === 1) {\n          val ^= solution[c];\n        }\n      }\n      solution[pc] = val;\n    }\n\n    if (!valid) continue;\n\n    // Count presses\n    let count = 0;\n    for (let i = 0; i < numButtons; i++) {\n      count += solution[i];\n    }\n\n    // Check if this is better\n    if (count < bestCount || (count === bestCount && isLexSmaller(solution, bestSolution!, numButtons))) {\n      bestCount = count;\n      bestSolution = solution.slice();\n    }\n  }\n\n  if (bestSolution === null) return null;\n\n  // Convert to sorted array of pressed button indices\n  const result: number[] = [];\n  for (let i = 0; i < numButtons; i++) {\n    if (bestSolution[i] === 1) {\n      result.push(i);\n    }\n  }\n  return result;\n}\n\nfunction isLexSmaller(a: number[], b: number[], n: number): boolean {\n  // Compare as sets of pressed indices (sorted ascending)\n  // This is comparing the resulting index arrays lexicographically\n  for (let i = 0; i < n; i++) {\n    if (a[i] !== b[i]) {\n      // First difference: if a has a 0 where b has 1, a's index set comes later\n      // Actually we need to compare the resulting index arrays\n      // Let's think: lex smallest set of indices\n      // [0,1] < [0,2] < [1,2] etc.\n      // As bit vectors: a=0b0011 represents {0,1}, b=0b0101 represents {0,2}\n      // We want to compare the resulting sorted index arrays lexicographically\n      // Easier: just compare the solution arrays as the indices of pressed buttons\n      // Actually, for same count, we want lex smallest index array.\n      // Index array is sorted ascending. So [0,2] < [0,3] < [1,2] etc.\n      // As bit vectors from index 0: comparing bit vectors from low to high index\n      // isn't the same as comparing index arrays.\n      // Let's just build the index arrays and compare.\n      break;\n    }\n  }\n\n  const aIndices: number[] = [];\n  const bIndices: number[] = [];\n  for (let i = 0; i < n; i++) {\n    if (a[i]) aIndices.push(i);\n    if (b[i]) bIndices.push(i);\n  }\n  for (let i = 0; i < Math.min(aIndices.length, bIndices.length); i++) {\n    if (aIndices[i] < bIndices[i]) return true;\n    if (aIndices[i] > bIndices[i]) return false;\n  }\n  return aIndices.length < bIndices.length;\n}\n\n\n/**\n * Solve counter puzzle over GF(p) using Gaussian elimination.\n * Find minimum total presses, then lexicographically smallest result array.\n */\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numLights = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix over GF(p)\n  // matrix[light][button] = 1 if button affects that light, 0 otherwise\n  // augmented column = target value for that light\n  const matrix: number[][] = [];\n  for (let i = 0; i < numLights; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p)\n  const pivotCol: number[] = [];\n  const pivotRow: number[] = new Array(numButtons).fill(-1);\n  let row = 0;\n\n  for (let col = 0; col < numButtons && row < numLights; col++) {\n    // Find pivot row\n    let pivotR = -1;\n    for (let r = row; r < numLights; r++) {\n      if (matrix[r][col] !== 0) {\n        pivotR = r;\n        break;\n      }\n    }\n    if (pivotR === -1) continue;\n\n    // Swap rows\n    [matrix[row], matrix[pivotR]] = [matrix[pivotR], matrix[row]];\n\n    // Normalize pivot row: multiply by inverse of pivot element\n    const pivotVal = matrix[row][col];\n    const inv = modInverse(pivotVal, modulus);\n    for (let c = col; c <= numButtons; c++) {\n      matrix[row][c] = (matrix[row][c] * inv) % modulus;\n    }\n\n    // Eliminate all other rows\n    for (let r = 0; r < numLights; r++) {\n      if (r !== row && matrix[r][col] !== 0) {\n        const factor = matrix[r][col];\n        for (let c = col; c <= numButtons; c++) {\n          matrix[r][c] = (((matrix[r][c] - factor * matrix[row][c]) % modulus) + modulus) % modulus;\n        }\n      }\n    }\n\n    pivotCol.push(col);\n    pivotRow[col] = row;\n    row++;\n  }\n\n  const rank = pivotCol.length;\n\n  // Check consistency\n  for (let r = rank; r < numLights; r++) {\n    if (matrix[r][numButtons] !== 0) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const pivotColSet = new Set(pivotCol);\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (!pivotColSet.has(col)) {\n      freeVars.push(col);\n    }\n  }\n\n  const numFree = freeVars.length;\n\n  // Enumerate all p^numFree assignments to free variables\n  // This is feasible for small numFree. For large numFree with large p, we need optimization.\n  // With up to 40 buttons and 40 lights, numFree could be up to 40 in degenerate cases.\n  // But with modulus up to 97, p^numFree could be huge.\n  // We need a smarter approach for many free variables.\n\n  // For practical cases, if numFree is small (<=~6 with p=97, that's 97^6 ≈ 8e11, too much)\n  // We need a different strategy for large numFree.\n\n  // Strategy: For each free variable independently, try all p values.\n  // Since we want minimum sum, and each pivot variable is a linear function of free vars,\n  // we can compute the optimal assignment more cleverly.\n\n  // However, for correctness and given the constraints (40 buttons, 40 lights),\n  // let's handle it with enumeration when feasible, and greedy/optimization otherwise.\n\n  // Actually, let's think about this differently:\n  // With the minimum total presses objective, we want to minimize sum of all button presses.\n  // Each pivot variable is determined: pivot_i = rhs_i - sum(matrix[i][freeVar_j] * freeVar_j) mod p\n  // Total sum = sum of pivot values + sum of free values\n  // This is a function of the free variable values that we want to minimize over GF(p).\n\n  // For a brute-force approach, limit to manageable sizes:\n  const maxEnumeration = 5_000_000; // Max combinations to try\n  let totalCombinations = 1;\n  let feasible = true;\n  for (let i = 0; i < numFree; i++) {\n    totalCombinations *= modulus;\n    if (totalCombinations > maxEnumeration) {\n      feasible = false;\n      break;\n    }\n  }\n\n  if (feasible) {\n    return solveCounterBruteForce(matrix, pivotCol, freeVars, numButtons, modulus, rank);\n  } else {\n    // For large free variable spaces, use a smarter approach\n    return solveCounterSmart(matrix, pivotCol, freeVars, numButtons, modulus, rank);\n  }\n}\n\nfunction solveCounterBruteForce(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  modulus: number,\n  rank: number\n): number[] | null {\n  const numFree = freeVars.length;\n  let bestSolution: number[] | null = null;\n  let bestSum = Infinity;\n\n  // Enumerate all p^numFree combinations\n  const freeValues = new Array(numFree).fill(0);\n\n  const enumerate = (): void => {\n    while (true) {\n      const solution = new Array(numButtons).fill(0);\n\n      // Set free variables\n      for (let i = 0; i < numFree; i++) {\n        solution[freeVars[i]] = freeValues[i];\n      }\n\n      // Compute pivot variables\n      for (let i = 0; i < rank; i++) {\n        const pc = pivotCol[i];\n        let val = matrix[i][numButtons];\n        for (let j = 0; j < numFree; j++) {\n          val = (((val - matrix[i][freeVars[j]] * freeValues[j]) % modulus) + modulus) % modulus;\n        }\n        // Also subtract contributions from other pivot variables that appear after this one\n        // But since we did full elimination (RREF), each row only has 1 in its pivot column\n        // and the other pivot columns are 0. So we only need to account for free variables.\n        solution[pc] = val % modulus;\n      }\n\n      // Compute sum\n      let sum = 0;\n      for (let i = 0; i < numButtons; i++) {\n        sum += solution[i];\n      }\n\n      if (sum < bestSum || (sum === bestSum && isLexSmallerArray(solution, bestSolution!, numButtons))) {\n        bestSum = sum;\n        bestSolution = solution.slice();\n      }\n\n      // Increment freeValues (odometer style)\n      let carry = true;\n      for (let i = 0; i < numFree && carry; i++) {\n        freeValues[i]++;\n        if (freeValues[i] >= modulus) {\n          freeValues[i] = 0;\n        } else {\n          carry = false;\n        }\n      }\n      if (carry) break; // All combinations exhausted\n    }\n  };\n\n  enumerate();\n  return bestSolution;\n}\n\nfunction solveCounterSmart(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  numButtons: number,\n  modulus: number,\n  rank: number\n): number[] | null {\n  // When we have too many free variables to enumerate, we need a smarter approach.\n  //\n  // Each pivot variable p_i = rhs_i - sum_j(coeff_ij * f_j) mod p\n  // Total cost = sum_i(p_i) + sum_j(f_j)\n  //\n  // We want to minimize total cost. Each free variable f_j affects:\n  // - Its own contribution: f_j\n  // - Pivot variable contributions: -coeff_ij * f_j for each pivot i where coeff_ij != 0\n  //\n  // For each free variable independently (if the cost function were separable, which it is\n  // since total = sum of independent terms mod p), we could optimize each independently.\n  // But actually mod p makes values wrap, so a pivot variable's contribution depends on\n  // the combination of all free variables affecting it.\n  //\n  // However, we can still analyze: for each free variable f_j, if we fix all others,\n  // the optimal value of f_j can be computed. This suggests an iterative coordinate descent.\n  //\n  // Alternative: since modulus is prime, think of this as optimization over Z_p^k.\n  // This is hard in general, but we can try coordinate descent or random search.\n\n  // Start with all free variables = 0\n  const freeValues = new Array(freeVars.length).fill(0);\n\n  // Coordinate descent: iterate over free variables, for each try all p values\n  let improved = true;\n  while (improved) {\n    improved = false;\n    for (let fi = 0; fi < freeVars.length; fi++) {\n      let bestVal = freeValues[fi];\n      let bestCost = computeCost(matrix, pivotCol, freeVars, freeValues, numButtons, modulus, rank);\n\n      for (let v = 0; v < modulus; v++) {\n        if (v === freeValues[fi]) continue;\n        freeValues[fi] = v;\n        const cost = computeCost(matrix, pivotCol, freeVars, freeValues, numButtons, modulus, rank);\n        if (cost < bestCost || (cost === bestCost && v < bestVal)) {\n          bestCost = cost;\n          bestVal = v;\n        }\n      }\n      if (bestVal !== freeValues[fi]) {\n        // revert to check if improvement\n        const oldVal = freeValues[fi];\n        freeValues[fi] = bestVal;\n        if (bestVal !== oldVal) improved = true;\n      }\n    }\n  }\n\n  // Now try to find lexicographically smallest with same cost\n  const targetCost = computeCost(matrix, pivotCol, freeVars, freeValues, numButtons, modulus, rank);\n\n  // Greedily set each button press to smallest possible value\n  // by iterating through free variables in order and trying smallest values\n  for (let fi = 0; fi < freeVars.length; fi++) {\n    for (let v = 0; v < modulus; v++) {\n      freeValues[fi] = v;\n      const cost = computeCost(matrix, pivotCol, freeVars, freeValues, numButtons, modulus, rank);\n      if (cost === targetCost) {\n        break; // Use smallest value that achieves target cost\n      }\n    }\n  }\n\n  // Build solution\n  const solution = new Array(numButtons).fill(0);\n  for (let i = 0; i < freeVars.length; i++) {\n    solution[freeVars[i]] = freeValues[i];\n  }\n  for (let i = 0; i < rank; i++) {\n    const pc = pivotCol[i];\n    let val = matrix[i][numButtons];\n    for (let j = 0; j < freeVars.length; j++) {\n      val = (((val - matrix[i][freeVars[j]] * freeValues[j]) % modulus) + modulus) % modulus;\n    }\n    solution[pc] = val % modulus;\n  }\n\n  return solution;\n}\n\nfunction computeCost(\n  matrix: number[][],\n  pivotCol: number[],\n  freeVars: number[],\n  freeValues: number[],\n  numButtons: number,\n  modulus: number,\n  rank: number\n): number {\n  let sum = 0;\n  for (let i = 0; i < freeVars.length; i++) {\n    sum += freeValues[i];\n  }\n  for (let i = 0; i < rank; i++) {\n    let val = matrix[i][numButtons];\n    for (let j = 0; j < freeVars.length; j++) {\n      val = (((val - matrix[i][freeVars[j]] * freeValues[j]) % modulus) + modulus) % modulus;\n