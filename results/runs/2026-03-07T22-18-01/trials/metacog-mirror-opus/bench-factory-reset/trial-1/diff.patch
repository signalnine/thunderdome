+describe('stress tests', () => {
+  it('should handle 20 buttons and 20 lights toggle puzzle', () => {
+    const n = 20;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      const btn: number[] = [];
+      for (let j = 0; j < n; j++) {
+        if ((i + j) % 3 === 0 || i === j) btn.push(j);
+      }
+      buttons.push(btn);
+    }
+    const target = new Array(n).fill(true);
+    const result = solveToggle({ target, buttons });
+
+    if (result !== null) {
+      // Verify
+      const lights = new Array(n).fill(false);
+      for (const btnIdx of result) {
+        for (const lightIdx of buttons[btnIdx]) {
+          lights[lightIdx] = !lights[lightIdx];
+        }
+      }
+      expect(lights).toEqual(target);
+    }
+  });
+
+  it('should handle 40x40 toggle puzzle with unique solution', () => {
+    // Identity-like: each button toggles exactly one light
+    const n = 40;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+    }
+    const target = new Array(n).fill(false).map((_, i) => i % 2 === 0);
+    const result = solveToggle({ target, buttons });
+
+    expect(result).not.toBeNull();
+    const expected = [];
+    for (let i = 0; i < n; i++) {
+      if (i % 2 === 0) expected.push(i);
+    }
+    expect(result).toEqual(expected);
+  });
+
+  it('should handle 20 buttons 20 counters with mod 7', () => {
+    const n = 20;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]); // Each button increments one counter
+    }
+    const lights = new Array(n).fill(0).map((_, i) => (i * 3) % 7);
+    const result = solveCounter(lights, buttons, 7);
+
+    expect(result).not.toBeNull();
+    if (result !== null) {
+      expect(result).toEqual(lights); // Should be exactly the target values
+    }
+  });
+
+  it('should handle counter puzzle with overlapping buttons', () => {
+    const buttons = [[0, 1, 2], [1, 2, 3], [2, 3, 4], [0, 4]];
+    const lights = [1, 2, 3, 4, 0];
+    const modulus = 5;
+    const result = solveCounter(lights, buttons, modulus);
+
+    if (result !== null) {
+      const counters = new Array(5).fill(0);
+      for (let i = 0; i < result.length; i++) {
+        for (const idx of buttons[i]) {
+          counters[idx] = (counters[idx] + result[i]) % modulus;
+        }
+      }
+      expect(counters).toEqual(lights);
+    }
+  });
+
+  it('should handle counter puzzle with free variables and mod 97', () => {
+    // 10 counters, 15 buttons -> up to 5 free variables with mod 97
+    const nCounters = 10;
+    const nButtons = 15;
+    const buttons: number[][] = [];
+    for (let i = 0; i < nButtons; i++) {
+      const btn: number[] = [];
+      for (let j = 0; j < nCounters; j++) {
+        if ((i * 3 + j * 7) % 5 < 2) btn.push(j);
+      }
+      if (btn.length === 0) btn.push(i % nCounters);
+      buttons.push(btn);
+    }
+    const lights = new Array(nCounters).fill(0).map((_, i) => (i * 13 + 7) % 97);
+    const start = Date.now();
+    const result = solveCounter(lights, buttons, 97);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    if (result !== null) {
+      const counters = new Array(nCounters).fill(0);
+      for (let i = 0; i < result.length; i++) {
+        for (const idx of buttons[i]) {
+          counters[idx] = (counters[idx] + result[i]) % 97;
+        }
+      }
+      expect(counters).toEqual(lights);
+    }
+  });
+
+  it('should complete 40x40 counter puzzle within time limit', () => {
+    const n = 40;
+    const buttons: number[][] = [];
+    for (let i = 0; i < n; i++) {
+      buttons.push([i]);
+    }
+    const lights = new Array(n).fill(0).map((_, i) => i % 97);
+    const start = Date.now();
+    const result = solveCounter(lights, buttons, 97);
+    const elapsed = Date.now() - start;
+
+    expect(elapsed).toBeLessThan(5000);
+    expect(result).not.toBeNull();
+  });
