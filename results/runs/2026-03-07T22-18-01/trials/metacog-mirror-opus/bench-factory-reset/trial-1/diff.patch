ns\n\n  if (m === 0) {\n    return lights.every(l => l % modulus === 0) ? [] : null;\n  }\n\n  // Build augmented matrix over GF(p): rows=lights, cols=buttons+1\n  const mat: number[][] = [];\n  for (let i = 0; i < n; i++) {\n    const row = new Array(m + 1).fill(0);\n    for (let j = 0; j < m; j++) {\n      if (buttons[j].includes(i)) {\n        row[j] = 1;\n      }\n    }\n    row[m] = ((lights[i] % modulus) + modulus) % modulus;\n    mat.push(row);\n  }\n\n  // Gaussian elimination to RREF over GF(p)\n  const pivotCols: number[] = [];\n  let curRow = 0;\n\n  for (let col = 0; col < m && curRow < n; col++) {\n    let pr = -1;\n    for (let r = curRow; r < n; r++) {\n      if (mat[r][col] !== 0) { pr = r; break; }\n    }\n    if (pr === -1) continue;\n\n    [mat[curRow], mat[pr]] = [mat[pr], mat[curRow]];\n\n    // Normalize\n    const inv = modInverse(mat[curRow][col], modulus);\n    for (let c = col; c <= m; c++) {\n      mat[curRow][c] = (mat[curRow][c] * inv) % modulus;\n    }\n\n    // Eliminate\n    for (let r = 0; r < n; r++) {\n      if (r !== curRow && mat[r][col] !== 0) {\n        const factor = mat[r][col];\n        for (let c = col; c <= m; c++) {\n          mat[r][c] = (((mat[r][c] - factor * mat[curRow][c]) % modulus) + modulus) % modulus;\n        }\n      }\n    }\n\n    pivotCols.push(col);\n    curRow++;\n  }\n\n  const rank = pivotCols.length;\n\n  // Check consistency\n  for (let r = rank; r < n; r++) {\n    if (mat[r][m] !== 0) return null;\n  }\n\n  // Free variables\n  const pivotSet = new Set(pivotCols);\n  const freeVars: number[] = [];\n  for (let j = 0; j < m; j++) {\n    if (!pivotSet.has(j)) freeVars.push(j);\n  }\n\n  const numFree = freeVars.length;\n\n  // Precompute pivot row coefficients for free variables\n  const pivotFreeCoeffs: number[][] = [];\n  const pivotRHSVals: number[] = [];\n  for (let i = 0; i < rank; i++) {\n    const coeffs: number[] = new Array(numFree);\n    for (let j = 0; j < numFree; j++) {\n      coeffs[j] = mat[i][freeVars[j]];\n    }\n    pivotFreeCoeffs.push(coeffs);\n    pivotRHSVals.push(mat[i][m]);\n  }\n\n  // Check feasibility of enumeration\n  let totalCombinations = 1;\n  let feasible = true;\n  for (let i = 0; i < numFree; i++) {\n    totalCombinations *= modulus;\n    if (totalCombinations > 10_000_000) {\n      feasible = false;\n      break;\n    }\n  }\n\n  if (numFree === 0) {\n    // Unique solution\n    const solution = new Array(m).fill(0);\n    for (let i = 0; i < rank; i++) {\n      solution[pivotCols[i]] = pivotRHSVals[i];\n    }\n    return solution;\n  }\n\n  if (feasible) {\n    return solveCounterEnum(pivotCols, freeVars, pivotFreeCoeffs, pivotRHSVals, m, modulus, numFree, rank);\n  } else {\n    return solveCounterOptimize(pivotCols, freeVars, pivotFreeCoeffs, pivotRHSVals, m, modulus, numFree, rank);\n  }\n}\n\nfunction solveCounterEnum(\n  pivotCols: number[],\n  freeVars: number[],\n  pivotFreeCoeffs: number[][],\n  pivotRHS: number[],\n  m: number,\n  p: number,\n  numFree: number,\n  rank: number\n): number[] {\n  let bestSolution: number[] | null = null;\n  let bestSum = Infinity;\n\n  const freeVals = new Array(numFree).fill(0);\n\n  while (true) {\n    // Compute solution and cost\n    let sum = 0;\n    const sol = new Array(m).fill(0);\n\n    for (let j = 0; j < numFree; j++) {\n      sol[freeVars[j]] = freeVals[j];\n      sum += freeVals[j];\n    }\n\n    if (sum < bestSum) {\n      // Compute pivot values\n      let valid = true;\n      for (let i = 0; i < rank; i++) {\n        let val = pivotRHS[i];\n        for (let j = 0; j < numFree; j++) {\n          val = val - pivotFreeCoeffs[i][j] * freeVals[j];\n        }\n        val = ((val % p) + p) % p;\n        sol[pivotCols[i]] = val;\n        sum += val;\n        if (sum >= bestSum) { valid = false; break; }\n      }\n\n      if (valid && (sum < bestSum || (sum === bestSum && isLexSmaller(sol, bestSolution!, m)))) {\n        bestSum = sum;\n        bestSolution = sol.slice();\n      }\