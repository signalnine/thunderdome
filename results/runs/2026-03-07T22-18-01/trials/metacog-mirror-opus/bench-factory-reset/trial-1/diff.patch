+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+// --- GF(2) Toggle Solver ---
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;  // number of lights
+  const m = buttons.length; // number of buttons
+
+  if (m === 0) {
+    return target.every(t => !t) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(2): rows=lights, cols=buttons+1
+  // matrix[i][j] = 1 if button j toggles light i
+  // matrix[i][m] = target[i]
+  const mat: Uint8Array[] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Uint8Array(m + 1);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[m] = target[i] ? 1 : 0;
+    mat.push(row);
+  }
+
+  // Gaussian elimination to RREF over GF(2)
+  const pivotCols: number[] = [];
+  let curRow = 0;
+
+  for (let col = 0; col < m && curRow < n; col++) {
+    // Find pivot
+    let pr = -1;
+    for (let r = curRow; r < n; r++) {
+      if (mat[r][col] === 1) { pr = r; break; }
+    }
+    if (pr === -1) continue;
+
+    // Swap
+    [mat[curRow], mat[pr]] = [mat[pr], mat[curRow]];
+
+    // Eliminate all other rows with a 1 in this column
+    for (let r = 0; r < n; r++) {
+      if (r !== curRow && mat[r][col] === 1) {
+        for (let c = col; c <= m; c++) {
+          mat[r][c] ^= mat[curRow][c];
+        }
+      }
+    }
+
+    pivotCols.push(col);
+    curRow++;
+  }
+
+  const rank = pivotCols.length;
+
+  // Check consistency
+  for (let r = rank; r < n; r++) {
+    if (mat[r][m] !== 0) return null;
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+
+  const numFree = freeVars.length;
+
+  // For each free variable assignment, compute pivot variables and total cost.
+  // We want minimum number of button presses, then lex-smallest index set.
+  //
+  // After RREF, for pivot row i with pivot in column pivotCols[i]:
+  //   x[pivotCols[i]] = mat[i][m] XOR (sum of mat[i][freeVar_j] * freeVal_j)
+  //
+  // Precompute: for each pivot row, which free variables contribute
+  const pivotFreeCoeffs: number[][] = []; // pivotFreeCoeffs[i] = list of free var indices with coeff 1
+  const pivotRHS: number[] = [];
+  for (let i = 0; i < rank; i++) {
+    const coeffs: number[] = [];
+    for (let j = 0; j < numFree; j++) {
+      if (mat[i][freeVars[j]] === 1) {
+        coeffs.push(j);
+      }
+    }
+    pivotFreeCoeffs.push(coeffs);
+    pivotRHS.push(mat[i][m]);
+  }
+
+  if (numFree <= 25) {
+    // Direct enumeration
+    return solveToggleDirect(pivotCols, freeVars, pivotFreeCoeffs, pivotRHS, m, numFree, rank);
+  } else {
+    // Meet-in-the-middle
+    return solveToggleMITM(pivotCols, freeVars, pivotFreeCoeffs, pivotRHS, m, numFree, rank);
+  }
+}
+
+function solveToggleDirect(
+  pivotCols: number[],
+  freeVars: number[],
+  pivotFreeCoeffs: number[][],
+  pivotRHS: number[],
+  m: number,
+  numFree: number,
+  rank: number
+): number[] {
+  let bestIndices: number[] | null = null;
+  let bestCount = m + 1;
+
+  const total = 1 << numFree;
+
+  for (let mask = 0; mask < total; mask++) {
+    // Count free variable presses
+    let count = popcount(mask);
+
+    // Early termination: if free vars alone exceed best, skip
+    if (count >= bestCount) continue;
+
+    // Compute pivot variables
+    const pressed: number[] = [];
+
+    // Add free variable indices that are pressed
+    for (let j = 0; j < numFree; j++) {
+      if ((mask >> j) & 1) {
+        pressed.push(freeVars[j]);
+        // count already includes this
+      }
+    }
+
+    // Compute each pivot variable
+    let exceeded = false;
+    for (let i = 0; i < rank; i++) {
+      let val = pivotRHS[i];
+      for (const fj of pivotFreeCoeffs[i]) {
+        val ^= (mask >> fj) & 1;
+      }
+      if (val === 1) {
+        pressed.push(pivotCols[i]);
+        count++;
+        if (count > bestCount) { exceeded = true; break; }
+      }
+    }
+
+    if (exceeded || count > bestCount) continue;
+
+    pressed.sort((a, b) => a - b);
+    if (count < bestCount || compareLex(pressed, bestIndices!) < 0) {
+      bestIndices = pressed;
+      bestCount = count;
+    }
+  }
+
+  return bestIndices!;
+}
+
+function solveToggleMITM(
+  pivotCols: number[],
+  freeVars: number[],
+  pivotFreeCoeffs: number[][],
+  pivotRHS: number[],
+  m: number,
+  numFree: number,
+  rank: number
+): number[] {
+  const halfA = Math.floor(numFree / 2);
+  const halfB = numFree - halfA;
+
+  const sizeA = 1 << halfA;
+  const sizeB = 1 << halfB;
+
+  // For each first-half assignment, compute signature and group by (signature, count).
+  // Keep only the lex-smallest freePressed for each (signature, count) pair.
+  type HalfEntry = { count: number; freePressed: number[] };
+
+  // sigMap: signature -> array of entries sorted by count, keeping best per count
+  const sigMapA = new Map<number, HalfEntry[]>();
+
+  for (let maskA = 0; maskA < sizeA; maskA++) {
+    const freePressed: number[] = [];
+    for (let j = 0; j < halfA; j++) {
+      if ((maskA >> j) & 1) {
+        freePressed.push(freeVars[j]);
+      }
+    }
+
+    let sig = 0;
+    for (let i = 0; i < rank; i++) {
+      let bit = 0;
+      for (const fj of pivotFreeCoeffs[i]) {
+        if (fj < halfA) {
+          bit ^= (maskA >> fj) & 1;
+        }
+      }
+      sig |= (bit << i);
+    }
+
+    const count = freePressed.length;
+
+    if (!sigMapA.has(sig)) {
+      sigMapA.set(sig, []);
+    }
+
+    const entries = sigMapA.get(sig)!;
+    // Check if we already have an entry with this count
+    const existing = entries.find(e => e.count === count);
+    if (existing) {
+      if (compareLex(freePressed, existing.freePressed) < 0) {
+        existing.freePressed = freePressed;
+      }
+    } else {
+      entries.push({ count, freePressed });
+    }
+  }
+
+  // Sort each signature's entries by count
+  for (const [, entries] of sigMapA) {
+    entries.sort((a, b) => a.count - b.count);
+  }
+
+  // Precompute pivotRHSBits
+  let pivotRHSBits = 0;
+  for (let i = 0; i < rank; i++) {
+    pivotRHSBits |= (pivotRHS[i] << i);
+  }
+
+  let bestIndices: number[] | null = null;
+  let bestCount = m + 1;
+
+  for (let maskB = 0; maskB < sizeB; maskB++) {
+    const freePressedB: number[] = [];
+    let countB = 0;
+
+    for (let j = 0; j < halfB; j++) {
+      if ((maskB >> j) & 1) {
+        freePressedB.push(freeVars[halfA + j]);
+        countB++;
+      }
+    }
+
+    if (countB >= bestCount) continue;
+
+    let sigB = 0;
+    for (let i = 0; i < rank; i++) {
+      let bit = 0;
+      for (const fj of pivotFreeCoeffs[i]) {
+        if (fj >= halfA) {
+          bit ^= (maskB >> (fj - halfA)) & 1;
+        }
+      }
+      sigB |= (bit << i);
+    }
+
+    const target = pivotRHSBits ^ sigB;
+
+    for (const [sigA, entries] of sigMapA) {
+      const pivotCount = popcount(target ^ sigA);
+
+      for (const entryA of entries) {
+        const totalCount = entryA.count + countB + pivotCount;
+
+        if (totalCount > bestCount) break; // entries sorted by count, so further entries worse
+
+        const pressed: number[] = [...entryA.freePressed, ...freePressedB];
+        const fullSig = target ^ sigA;
+        for (let i = 0; i < rank; i++) {
+          if ((fullSig >> i) & 1) {
+            pressed.push(pivotCols[i]);
+          }
+        }
+        pressed.sort((a, b) => a - b);
+
+        if (totalCount < bestCount || compareLex(pressed, bestIndices!) < 0) {
+          bestCount = totalCount;
+          bestIndices = pressed;
+        }
+      }
+    }
+  }
+
+  return bestIndices!;
+}
+
+function popcount(x: number): number {
+  let count = 0;
+  while (x) {
+    count += x & 1;
+    x >>= 1;
+  }
+  return count;
+}
+
+function compareLex(a: number[], b: number[]): number {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] < b[i]) return -1;
+    if (a[i] > b[i]) return 1;
+  }
+  return a.length - b.length;
+}
+
+// --- GF(p) Counter Solver ---
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;  // number of counters/lights
+  const m = buttons.length; // number of buttons
+
+  if (m === 0) {
+    return lights.every(l => l % modulus === 0) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(p): rows=lights, cols=buttons+1
+  const mat: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m + 1).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[m] = ((lights[i] % modulus) + modulus) % modulus;
+    mat.push(row);
+  }
+
+  // Gaussian elimination to RREF over GF(p)
+  const pivotCols: number[] = [];
+  let curRow = 0;
+
+  for (let col = 0; col < m && curRow < n; col++) {
+    let pr = -1;
+    for (let r = curRow; r < n; r++) {
+      if (mat[r][col] !== 0) { pr = r; break; }
+    }
+    if (pr === -1) continue;
+
+    [mat[curRow], mat[pr]] = [mat[pr], mat[curRow]];
+
+    // Normalize
+    const inv = modInverse(mat[curRow][col], modulus);
+    for (let c = col; c <= m; c++) {
+      mat[curRow][c] = (mat[curRow][c] * inv) % modulus;
+    }
+
+    // Eliminate
+    for (let r = 0; r < n; r++) {
+      if (r !== curRow && mat[r][col] !== 0) {
+        const factor = mat[r][col];
+        for (let c = col; c <= m; c++) {
+          mat[r][c] = (((mat[r][c] - factor * mat[curRow][c]) % modulus) + modulus) % modulus;
+        }
+      }
+    }
+
+    pivotCols.push(col);
+    curRow++;
+  }
+
+  const rank = pivotCols.length;
+
+  // Check consistency
+  for (let r = rank; r < n; r++) {
+    if (mat[r][m] !== 0) return null;
+  }
+
+  // Free variables
+  const pivotSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let j = 0; j < m; j++) {
+    if (!pivotSet.has(j)) freeVars.push(j);
+  }
+
+  const numFree = freeVars.length;
+
+  // Precompute pivot row coefficients for free variables
+  const pivotFreeCoeffs: number[][] = [];
+  const pivotRHSVals: number[] = [];
+  for (let i = 0; i < rank; i++) {
+    const coeffs: number[] = new Array(numFree);
+    for (let j = 0; j < numFree; j++) {
+      coeffs[j] = mat[i][freeVars[j]];
+    }
+    pivotFreeCoeffs.push(coeffs);
+    pivotRHSVals.push(mat[i][m]);
+  }
+
+  // Check feasibility of enumeration
+  let totalCombinations = 1;
+  let feasible = true;
+  for (let i = 0; i < numFree; i++) {
+    totalCombinations *= modulus;
+    if (totalCombinations > 100_000_000) {
+      feasible = false;
+      break;
+    }
+  }
+
+  if (numFree === 0) {
+    // Unique solution
+    const solution = new Array(m).fill(0);
+    for (let i = 0; i < rank; i++) {
+      solution[pivotCols[i]] = pivotRHSVals[i];
+    }
+    return solution;
+  }
+
+  if (feasible) {
+    return solveCounterEnum(pivotCols, freeVars, pivotFreeCoeffs, pivotRHSVals, m, modulus, numFree, rank);
+  } else {
+    return solveCounterOptimize(pivotCols, freeVars, pivotFreeCoeffs, pivotRHSVals, m, modulus, numFree, rank);
+  }
+}
+
+function solveCounterEnum(
+  pivotCols: number[],
+  freeVars: number[],
+  pivotFreeCoeffs: number[][],
+  pivotRHS: number[],
+  m: number,
+  p: number,
+  numFree: number,
+  rank: number
+): number[] {
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+
+  const freeVals = new Array(numFree).fill(0);
+  let done = false;
+
+  while (!done) {
+    // Compute solution and cost
+    let sum = 0;
+    const sol = new Array(m).fill(0);
+
+    for (let j = 0; j < numFree; j++) {
+      sol[freeVars[j]] = freeVals[j];
+      sum += freeVals[j];
+    }
+
+    if (sum <= bestSum) {
+      // Compute pivot values
+      let valid = true;
+      for (let i = 0; i < rank; i++) {
+        let val = pivotRHS[i];
+        for (let j = 0; j < numFree; j++) {
+          val = val - pivotFreeCoeffs[i][j] * freeVals[j];
+        }
+        val = ((val % p) + p) % p;
+        sol[pivotCols[i]] = val;
+        sum += val;
+        if (sum > bestSum) { valid = false; break; }
+      }
+
+      if (valid && (sum < bestSum || (sum === bestSum && isLexSmaller(sol, bestSolution!, m)))) {
+        bestSum = sum;
+        bestSolution = sol.slice();
+      }
+    }
+
+    // Increment odometer
+    done = true;
+    for (let i = 0; i < numFree; i++) {
+      freeVals[i]++;
+      if (freeVals[i] >= p) {
+        freeVals[i] = 0;
+      } else {
+        done = false;
+        break;
+      }
+    }
+  }
+
+  return bestSolution!;
+}
+
+function solveCounterOptimize(
+  pivotCols: number[],
+  freeVars: number[],
+  pivotFreeCoeffs: number[][],
+  pivotRHS: number[],
+  m: number,
+  p: number,
+  numFree: number,
+  rank: number
+): number[] {
+  // For large free variable spaces, use coordinate descent + random restarts
+  const computeSolAndCost = (fv: number[]): [number[], number] => {
+    const sol = new Array(m).fill(0);
+    let sum = 0;
+    for (let j = 0; j < numFree; j++) {
+      sol[freeVars[j]] = fv[j];
+      sum += fv[j];
+    }
+    for (let i = 0; i < rank; i++) {
+      let val = pivotRHS[i];
+      for (let j = 0; j < numFree; j++) {
+        val -= pivotFreeCoeffs[i][j] * fv[j];
+      }
+      val = ((val % p) + p) % p;
+      sol[pivotCols[i]] = val;
+      sum += val;
+    }
+    return [sol, sum];
+  };
+
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+
+  // Try multiple starting points
+  const startingPoints: number[][] = [new Array(numFree).fill(0)];
+
+  // Add some random starting points
+  for (let trial = 0; trial < 50; trial++) {
+    const fv = new Array(numFree);
+    for (let j = 0; j < numFree; j++) {
+      fv[j] = Math.floor(Math.random() * p);
+    }
+    startingPoints.push(fv);
+  }
+
+  for (const startFV of startingPoints) {
+    const fv = startFV.slice();
+
+    // Coordinate descent
+    let improved = true;
+    while (improved) {
+      improved = false;
+      for (let fi = 0; fi < numFree; fi++) {
+        const savedVal = fv[fi];
+        const [, currentCost] = computeSolAndCost(fv);
+        let bestVal = savedVal;
+        let bestCost = currentCost;
+
+        for (let v = 0; v < p; v++) {
+          if (v === savedVal) continue;
+          fv[fi] = v;
+          const [, cost] = computeSolAndCost(fv);
+          if (cost < bestCost) {
+            bestCost = cost;
+            bestVal = v;
+          }
+        }
+
+        fv[fi] = bestVal;
+        if (bestCost < currentCost) improved = true;
+      }
+    }
+
+    const [sol, sum] = computeSolAndCost(fv);
+    if (sum < bestSum || (sum === bestSum && isLexSmaller(sol, bestSolution!, m))) {
+      bestSum = sum;
+      bestSolution = sol.slice();
+    }
+  }
+
+  // Try to make lex-smallest with same cost via greedy
+  // For each free variable in order, try to set to smallest value
+  // that maintains the best cost
+  const fv = new Array(numFree).fill(0);
+  for (let j = 0; j < numFree; j++) {
+    fv[j] = bestSolution![freeVars[j]];
+  }
+
+  for (let fi = 0; fi < numFree; fi++) {
+    const savedVal = fv[fi];
+    let bestValForFi = savedVal;
+    let bestSolForFi = bestSolution!;
+
+    for (let v = 0; v < p; v++) {
+      fv[fi] = v;
+      const [sol, sum] = computeSolAndCost(fv);
+      if (sum === bestSum && isLexSmaller(sol, bestSolForFi, m)) {
+        bestValForFi = v;
+        bestSolForFi = sol.slice();
+      }
+    }
+
+    fv[fi] = bestValForFi;
+    bestSolution = bestSolForFi;
+  }
+
+  return bestSolution!;
+}
+
+function isLexSmaller(a: number[], b: number[], n: number): boolean {
+  for (let i = 0; i < n; i++) {
+    if (a[i] < b[i]) return true;
+    if (a[i] > b[i]) return false;
+  }
+  return false;
+}
+
+function modInverse(a: number, m: number): number {
+  let [old_r, r] = [a, m];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % m) + m) % m;
+}
