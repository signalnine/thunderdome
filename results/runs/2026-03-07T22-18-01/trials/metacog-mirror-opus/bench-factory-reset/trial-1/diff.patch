aller(a: number[], b: number[], n: number): boolean {\n  for (let i = 0; i < n; i++) {\n    if (a[i] < b[i]) return true;\n    if (a[i] > b[i]) return false;\n  }\n  return false;\n}\n\nfunction isEqual(a: number[], b: number[], n: number): boolean {\n  for (let i = 0; i < n; i++) {\n    if (a[i] !== b[i]) return false;\n  }\n  return true;\n}\n\nfunction modInverse(a: number, m: number): number {\n  let [old_r, r] = [a, m];\n  let [old_s, s] = [1, 0];\n  while (r !== 0) {\n    const q = Math.floor(old_r / r);\n    [old_r, r] = [r, old_r - q * r];\n    [old_s, s] = [s, old_s - q * s];\n  }\n  return ((old_s % m) + m) % m;\n}\n","structuredPatch":[{"oldStart":135,"oldLines":6,"newStart":135,"newLines":7,"lines":["     }"," ","     // Compute each pivot variable","+    let exceeded = false;","     for (let i = 0; i < rank; i++) {","       let val = pivotRHS[i];","       for (const fj of pivotFreeCoeffs[i]) {"]},{"oldStart":143,"oldLines":20,"newStart":144,"newLines":14,"lines":["       if (val === 1) {","         pressed.push(pivotCols[i]);","         count++;","-        if (count >= bestCount) break;","+        if (count > bestCount) { exceeded = true; break; }","       }","     }"," ","-    if (count >= bestCount) {","-      if (count > bestCount) continue;","-      // Same count - check lex ordering","-      pressed.sort((a, b) => a - b);","-      if (compareLex(pressed, bestIndices!) < 0) {","-        bestIndices = pressed;","-        bestCount = count;","-      }","-    } else {","-      pressed.sort((a, b) => a - b);","+    if (exceeded || count > bestCount) continue;","+","+    pressed.sort((a, b) => a - b);","+    if (count < bestCount || compareLex(pressed, bestIndices!) < 0) {","       bestIndices = pressed;","       bestCount = count;","     }"]}],"userModified":false,"replaceAll":false}}
