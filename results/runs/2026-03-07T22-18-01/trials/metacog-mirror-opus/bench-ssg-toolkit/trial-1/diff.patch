+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, ctx: BuildContext): ContentFile => {
+        let content = file.content;
+        const discoveredAssets: string[] = [];
+
+        // Rewrite relative src="./..." URLs to /assets/...
+        content = content.replace(
+          /src="\.\/([^"]+)"/g,
+          (_match, filename) => {
+            discoveredAssets.push(filename);
+            return `src="/assets/${filename}"`;
+          }
+        );
+
+        // Rewrite relative href="./..." URLs to /assets/...
+        content = content.replace(
+          /href="\.\/([^"]+)"/g,
+          (_match, filename) => {
+            discoveredAssets.push(filename);
+            return `href="/assets/${filename}"`;
+          }
+        );
+
+        // Update the asset manifest in ctx.data
+        const existingManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        const allAssets = existingManifest ? [...existingManifest.assets, ...discoveredAssets] : [...discoveredAssets];
+        ctx.data.set('asset-manifest', { assets: allAssets });
+
+        return { ...file, content };
+      },
+    },
+  };
+}
