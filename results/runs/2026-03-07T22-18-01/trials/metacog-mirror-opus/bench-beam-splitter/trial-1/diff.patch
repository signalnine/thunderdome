xponential blowup in cell counting.\n  const seen = new Set<number>();\n  const encodeBeam = (r: number, c: number, d: Dir) => (r * cols + c) * 3 + d;\n\n  const queue: Beam[] = [{ row: source[0], col: source[1], dir: Dir.Down }];\n  seen.add(encodeBeam(source[0], source[1], Dir.Down));\n\n  while (queue.length > 0) {\n    const beam = queue.pop()!;\n    const [nr, nc] = advance(beam.row, beam.col, beam.dir);\n\n    if (!inBounds(nr, nc, rows, cols)) continue;\n\n    visited.add(encode(nr, nc));\n\n    const cell = grid[nr][nc];\n    if (cell === \"^\") {\n      // Splitter: spawn two diagonal beams\n      const leftKey = encodeBeam(nr, nc, Dir.DownLeft);\n      if (!seen.has(leftKey)) {\n        seen.add(leftKey);\n        queue.push({ row: nr, col: nc, dir: Dir.DownLeft });\n      }\n      const rightKey = encodeBeam(nr, nc, Dir.DownRight);\n      if (!seen.has(rightKey)) {\n        seen.add(rightKey);\n        queue.push({ row: nr, col: nc, dir: Dir.DownRight });\n      }\n    } else {\n      // Continue in same direction\n      const key = encodeBeam(nr, nc, beam.dir);\n      if (!seen.has(key)) {\n        seen.add(key);\n        queue.push({ row: nr, col: nc, dir: beam.dir });\n      }\n    }\n  }\n\n  return visited.size;\n}\n\nexport function countBeamPaths(grid: string[][]): bigint {\n  if (grid.length === 0 || grid[0].length === 0) return 0n;\n\n  const rows = grid.length;\n  const cols = grid[0].length;\n  const source = findSource(grid);\n  if (!source) return 0n;\n\n  // For path counting, we can't deduplicate beams the same way because\n  // multiple paths may converge to the same (row, col, dir) state with\n  // different path counts. Instead, we accumulate path counts per state\n  // and process each state once all contributions are collected.\n  //\n  // Since beams only move downward (row increases), we can process\n  // row by row, accumulating path counts.\n\n  const encodeState = (r: number, c: number, d: Dir) => (r * cols + c) * 3 + d;\n\n  // Map from encoded state to path count\n  const pathCounts = new Map<number, bigint>();\n\n  // Initialize: beam starts at source going down\n  pathCounts.set(encodeState(source[0], source[1], Dir.Down), 1n);\n\n  let totalPaths = 0n;\n\n  // Process row by row since all beams move downward\n  for (let row = 0; row < rows; row++) {\n    for (let col = 0; col < cols; col++) {\n      for (let dir = 0; dir <= 2; dir++) {\n        const key = encodeState(row, col, dir as Dir);\n        const count = pathCounts.get(key);\n        if (count === undefined || count === 0n) continue;\n\n        const [nr, nc] = advance(row, col, dir as Dir);\n\n        if (!inBounds(nr, nc, rows, cols)) {\n          // Beam exits the grid — these are completed paths\n          totalPaths += count;\n          continue;\n        }\n\n        const cell = grid[nr][nc];\n        if (cell === \"^\") {\n          // Splitter: each incoming path produces two outgoing paths\n          const leftKey = encodeState(nr, nc, Dir.DownLeft);\n          pathCounts.set(leftKey, (pathCounts.get(leftKey) ?? 0n) + count);\n\n          const rightKey = encodeState(nr, nc, Dir.DownRight);\n          pathCounts.set(rightKey, (pathCounts.get(rightKey) ?? 0n) + count);\n        } else {\n          // Continue in same direction\n          const nextKey = encodeState(nr, nc, dir as Dir);\n          pathCounts.set(nextKey, (pathCounts.get(nextKey) ?? 0n) + count);\n        }\n      }\n    }\n  }\n\n  return totalPaths;\n}\n","structuredPatch":[{"oldStart":11,"oldLines":13,"newStart":11,"newLines":6,"lines":["   dir: Dir;"," }"," ","-interface BeamWithCount {","-  row: number;","-  col: number;","-  dir: Dir;","-  paths: bigint;","-}","-"," function findSource(grid: string[][]): [number, number] | null {","   for (let col = 0; col < grid[0].length; col++) {","     if (grid[0][col] === \"S\") {"]}],"userModified":false,"replaceAll":false}}
