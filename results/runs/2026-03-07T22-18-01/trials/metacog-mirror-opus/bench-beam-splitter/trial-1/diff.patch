+import { describe, it, expect } from "vitest";
+import { countBeamCells, countBeamPaths } from "./index.js";
+
+describe("countBeamCells", () => {
+  it("returns 0 for empty grid", () => {
+    expect(countBeamCells([])).toBe(0);
+  });
+
+  it("returns 0 for grid with no source", () => {
+    const grid = [
+      [".", ".", "."],
+      [".", ".", "."],
+    ];
+    expect(countBeamCells(grid)).toBe(0);
+  });
+
+  it("handles beam going straight down with no splitters", () => {
+    const grid = [
+      [".", "S", "."],
+      [".", ".", "."],
+      [".", ".", "."],
+    ];
+    // Beam: (0,1), (1,1), (2,1) — then exits
+    expect(countBeamCells(grid)).toBe(3);
+  });
+
+  it("example 1: single splitter", () => {
+    const grid = [
+      [".", "S", ".", ".", "."],
+      [".", ".", ".", ".", "."],
+      [".", "^", ".", ".", "."],
+      [".", ".", ".", ".", "."],
+    ];
+    // Visited: (0,1), (1,1), (2,1), (3,0), (3,2) = 5
+    expect(countBeamCells(grid)).toBe(5);
+  });
+
+  it("example 2: two splitters on row 2", () => {
+    const grid = [
+      [".", "S", ".", ".", "."],
+      [".", "^", ".", ".", "."],
+      ["^", ".", "^", ".", "."],
+      [".", ".", ".", ".", "."],
+    ];
+    // Visited: (0,1), (1,1), (2,0), (2,2), (3,1), (3,3) = 6
+    expect(countBeamCells(grid)).toBe(6);
+  });
+
+  it("source on single row grid", () => {
+    const grid = [[".", "S", "."]];
+    // Only the source cell is visited, beam immediately exits
+    expect(countBeamCells(grid)).toBe(1);
+  });
+
+  it("beam absorbed at left boundary", () => {
+    const grid = [
+      ["S", "."],
+      ["^", "."],
+      [".", "."],
+    ];
+    // (0,0) source, (1,0) splitter hit
+    // down-left goes to (2,-1) — absorbed
+    // down-right goes to (2,1) — visited
+    // Visited: (0,0), (1,0), (2,1) = 3
+    expect(countBeamCells(grid)).toBe(3);
+  });
+});
+
+describe("countBeamPaths", () => {
+  it("returns 0n for empty grid", () => {
+    expect(countBeamPaths([])).toBe(0n);
+  });
+
+  it("returns 0n for grid with no source", () => {
+    const grid = [
+      [".", ".", "."],
+      [".", ".", "."],
+    ];
+    expect(countBeamPaths(grid)).toBe(0n);
+  });
+
+  it("single path straight down", () => {
+    const grid = [
+      [".", "S", "."],
+      [".", ".", "."],
+      [".", ".", "."],
+    ];
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it("example 1: single splitter gives 2 paths", () => {
+    const grid = [
+      [".", "S", ".", ".", "."],
+      [".", ".", ".", ".", "."],
+      [".", "^", ".", ".", "."],
+      [".", ".", ".", ".", "."],
+    ];
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it("example 2: two splitters gives 4 paths", () => {
+    const grid = [
+      [".", "S", ".", ".", "."],
+      [".", "^", ".", ".", "."],
+      ["^", ".", "^", ".", "."],
+      [".", ".", ".", ".", "."],
+    ];
+    // 4 paths total (including the one absorbed at col -1)
+    expect(countBeamPaths(grid)).toBe(4n);
+  });
+
+  it("source on single row — 1 path exiting downward", () => {
+    const grid = [[".", "S", "."]];
+    // Beam exits immediately going down from row 0
+    expect(countBeamPaths(grid)).toBe(1n);
+  });
+
+  it("beam absorbed at boundary counts as a path", () => {
+    const grid = [
+      ["S", "."],
+      ["^", "."],
+      [".", "."],
+    ];
+    // 2 paths: one exits left (absorbed), one exits bottom-right area
+    expect(countBeamPaths(grid)).toBe(2n);
+  });
+
+  it("handles large path counts with many splitters", () => {
+    // Build a grid where every other row has a splitter in column where
+    // the beam passes, creating exponential branching
+    // Simple chain: source -> splitter -> splitter -> ...
+    // With 3 splitters in a line: 2^3 = 8 paths
+    const grid = [
+      [".", ".", "S", ".", "."],
+      [".", ".", "^", ".", "."],
+      [".", "^", ".", "^", "."],
+      ["^", ".", ".", ".", "^"],
+      [".", ".", ".", ".", "."],
+    ];
+    // From S(0,2) down to (1,2) splitter
+    // Split: (2,1) and (2,3) — both are splitters
+    // (2,1) splits to (3,0) and (3,2) — (3,0) is splitter
+    // (2,3) splits to (3,2) and (3,4) — (3,4) is splitter
+    // (3,0) splitter: (4,-1) absorbed, (4,1)
+    // (3,2): not a splitter, continues... (3,2) direction depends on how it got there
+    //   from (2,1) going down-left: (3,2) is reached via down-right from (2,1) ? No...
+    //   (2,1) splitter: down-left = (3,0), down-right = (3,2)
+    //   (2,3) splitter: down-left = (3,2), down-right = (3,4)
+    // (3,0) is '^': splits to (4,-1) absorbed and (4,1)
+    // (3,2) reached by two beams (from (2,1) down-right and (2,3) down-left)
+    //   not a splitter, continues in respective directions:
+    //   from (2,1) down-right: continues to (4,3)
+    //   from (2,3) down-left: continues to (4,1)
+    // (3,4) is '^': splits to (4,3) and (4,5) absorbed
+    // Total paths: from (3,0) splitter: 2 paths
+    //              from (3,2) via two beams: 2 paths (each continues to exit)
+    //              from (3,4) splitter: 2 paths
+    //              Total = 2 + 2 + 2 = 6... but let me recount with counts:
+    // Start: 1 path at (0,2)
+    // (1,2) splitter: 1 path splits to 1+1
+    // (2,1) gets 1 path, (2,3) gets 1 path — both splitters
+    // (2,1) splits: (3,0) gets 1, (3,2) gets 1
+    // (2,3) splits: (3,2) gets 1, (3,4) gets 1
+    // (3,0) splitter: exits (4,-1) = 1 path, (4,1) = 1 path
+    // (3,2) has 2 paths (1 down-right + 1 down-left)
+    //   down-right beam from (2,1): continues to (4,3) = 1 path
+    //   down-left beam from (2,3): continues to (4,1) = 1 path
+    // (3,4) splitter: (4,3) = 1 path, exits (4,5) = 1 path
+    // Total = 1 + 1 + 1 + 1 + 1 + 1 = 6? No...
+    // All paths exit at row 4: (4,-1), (4,1), (4,3), (4,1), (4,3), (4,5)
+    // Total = 6 paths
+    // Hmm, but (4,-1) is out of bounds on cols too if cols=5? col=-1 is out of bounds.
+    // Still counts as an exit. And (4,5) is out of bounds. col 5 >= cols(5).
+    // Row 4 is the last row (index 4), and from row 4 the beams would try to go to row 5 which is out of bounds.
+    // Wait - row 4 IS in bounds (0-4 = 5 rows). So beams at row 4 try to advance to row 5.
+    // Actually (4,-1) is out of bounds because col=-1. So the beam from (3,0) going down-left
+    // EXITS at step (4,-1) which is out of bounds. This path is counted.
+    // And (4,5) is out of bounds because col=5 >= 5. Also counted.
+    // For beams that land in row 4 in valid columns, they advance to row 5 (out of bounds) and exit.
+    // Total: 6 paths
+    expect(countBeamPaths(grid)).toBe(6n);
+  });
+});
