(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    // Circular dependency detection\n    if (dependencies.length > 0) {\n      this.detectCircularDependencies(dependencies);\n    }\n\n    const now = new Date();\n    let availableAt = now;\n\n    if (options.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    const hasUnresolvedDeps = dependencies.some(depId => {\n      const dep = this.tasks.get(depId);\n      return dep && dep.status !== 'completed';\n    });\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: hasUnresolvedDeps ? 'blocked' : 'pending',\n      priority,\n      queue: queueName,\n      createdAt: now,\n      updatedAt: now,\n      availableAt,\n      attempts: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoffDelay: options.backoffDelay ?? 1000,\n      dependencies,\n      progress: 0,\n    };\n\n    this.tasks.set(task.id, task as Task);\n    this.ensureQueueState(queueName);\n\n    return task;\n  }\n\n  next(queueName: string = DEFAULT_QUEUE): Task | null {\n    const state = this.queueStates.get(queueName);\n\n    // Check concurrency limit\n    if (state && state.concurrencyLimit > 0) {\n      if (state.activeCount >= state.concurrencyLimit) {\n        return null;\n      }\n    }\n\n    const now = new Date();\n    const candidates: Task[] = [];\n\n    for (const task of this.tasks.values()) {\n      if (\n        task.queue === queueName &&\n        task.status === 'pending' &&\n        task.availableAt <= now\n      ) {\n        candidates.push(task);\n      }\n    }\n\n    if (candidates.length === 0) return null;\n\n    // Sort: priority ascending (1 is highest), then availableAt, then createdAt\n    candidates.sort((a, b) => {\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      if (a.availableAt.getTime() !== b.availableAt.getTime()) {\n        return a.availableAt.getTime() - b.availableAt.getTime();\n      }\n      return a.createdAt.getTime() - b.createdAt.getTime();\n    });\n\n    const task = candidates[0];\n    task.status = 'processing';\n    task.updatedAt = new Date();\n    task.attempts += 1;\n\n    if (state) {\n      state.activeCount += 1;\n    }\n\n    return task;\n  }\n\n  size(queueName: string = DEFAULT_QUEUE): number {\n    let count = 0;\n    for (const task of this.tasks.values()) {\n      if (task.queue === queueName && task.status === 'pending') {\n        count++;\n      }\n    }\n    return count;\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 2: Named Queues\n  // ──────────────────────────────────────────────\n\n  listQueues(): string[] {\n    return Array.from(this.queueStates.keys());\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 5: Complete / Fail with Retry\n  // ──────────────────────────────────────────────\n\n  complete(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    task.status = 'completed';\n    task.updatedAt = new Date();\n    task.progress = 100;\n\n    // Free concurrency slot\n    const state = this.queueStates.get(task.queue);\n    if (state) {\n      state.activeCount = Math.max(0, state.activeCount - 1);\n    }\n\n    // Unblock dependent tasks\n    this.checkDependents(taskId);\n  }\n\n  fail(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    // Free concurrency slot\n    const state = this.queueStates.get(task.queue);\n    if (state) {\n      state.activeCount = Math.max(0, state.activeCount - 1);\n    }\n\n    task.error = error;\n\n    if (task.attempts < task.maxRetries) {\n      // Retry with exponential backoff\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.status = 'pending';\n      task.availableAt = new Date(Date.now() + delay);\n      task.updatedAt = new Date();\n      task.progress = 0;\n    } else {\n      // No more retries - move to dead letter queue\n      task.status = 'failed';\n      task.updatedAt = new Date();\n      this.moveToDLQ(task);\n    }\n  }\n\n  // ──────────────────────────────────────────────\n  // Phase 6: Dead Letter Queue\n  // ──────────────────────────────────────────────\n\n  private moveToDLQ(task: Task): void {\n    const dlqKey = task.queue;\n    if (!this.deadLetterQueues.has(dlqKey)) {\n      this.deadLetterQueues.set(dlqKey, []);\n    }\n    this.deadLetterQueues.get(dlqKey)!.push(task);\n  }\n\n  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {\n    return this.deadLetterQueues.get(queueName) ?? [];\n  }\n\n  retryDeadLetterTask(taskId: string): Task {\n    for (const [queueName, dlqTasks] of this.deadLetterQueues.entries()) {\n      const idx = dlqTasks.findIndex(t => t.id === taskId);\n      if (idx !== -1) {\n        const task = dlqTasks.splice(idx, 1)[0];\n        task.status = 'pending';\n        task.attempts = 0;\n        task.error = undefined;\n        task.availableAt = new Date();\n        task.updatedAt = new Date();\n        task.progress = 0;\n        // task stays in this.tasks map already\n        // Ensure queue state exists\n        this.ensureQueueState(queueName);\n        return task;\n      }\n    }\n    throw new Error(`Dead letter task not found: ${taskId}`);\n  }\n\n  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {\n    const dlqTasks = this.deadLetterQueues.get(queueName);\n    if (dlqTasks) {\n      // Remove tasks from the main map too\n      for (const task of dlqTasks) {\n       