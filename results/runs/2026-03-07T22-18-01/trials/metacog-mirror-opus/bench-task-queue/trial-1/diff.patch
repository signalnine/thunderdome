diff --git a/src/TaskQueue.ts b/src/TaskQueue.ts
new file mode 100644
index 0000000..a7e73a5
--- /dev/null
+++ b/src/TaskQueue.ts
@@ -0,0 +1,740 @@
+import { randomUUID } from 'node:crypto';
+import type {
+  Task,
+  TaskOptions,
+  TaskStatus,
+  ProgressListener,
+  ProgressUpdate,
+  Schedule,
+  MiddlewareFn,
+  HandlerFn,
+  ShutdownResult,
+  ShutdownCallback,
+  QueueState,
+} from './types.js';
+
+const DEFAULT_QUEUE = 'default';
+
+export class TaskQueue {
+  private tasks: Map<string, Task> = new Map();
+  private queueStates: Map<string, QueueState> = new Map();
+  private deadLetterQueues: Map<string, Task[]> = new Map();
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private shutdownCallbacks: ShutdownCallback[] = [];
+  private isShuttingDown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+
+  // ──────────────────────────────────────────────
+  // Phase 1 & 2: Basic FIFO + Named Queues
+  // ──────────────────────────────────────────────
+
+  add<T = unknown>(payload: T, options: TaskOptions = {}): Task<T> {
+    if (this.isShuttingDown) {
+      throw new Error('Queue is shutting down, cannot add new tasks');
+    }
+
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+    const priority = options.priority ?? 5;
+
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Validate dependencies exist
+    const dependencies = options.dependencies ?? [];
+    for (const depId of dependencies) {
+      if (!this.tasks.has(depId)) {
+        throw new Error(`Dependency task not found: ${depId}`);
+      }
+    }
+
+    // Circular dependency detection
+    if (dependencies.length > 0) {
+      this.detectCircularDependencies(dependencies);
+    }
+
+    const now = new Date();
+    let availableAt = now;
+
+    if (options.availableAt) {
+      availableAt = options.availableAt;
+    } else if (options.delay != null && options.delay > 0) {
+      availableAt = new Date(now.getTime() + options.delay);
+    }
+
+    const hasUnresolvedDeps = dependencies.some(depId => {
+      const dep = this.tasks.get(depId);
+      return dep && dep.status !== 'completed';
+    });
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      payload,
+      status: hasUnresolvedDeps ? 'blocked' : 'pending',
+      priority,
+      queue: queueName,
+      createdAt: now,
+      updatedAt: now,
+      availableAt,
+      attempts: 0,
+      maxRetries: options.maxRetries ?? 3,
+      backoffDelay: options.backoffDelay ?? 1000,
+      dependencies,
+      progress: 0,
+    };
+
+    this.tasks.set(task.id, task as Task);
+    this.ensureQueueState(queueName);
+
+    return task;
+  }
+
+  next(queueName: string = DEFAULT_QUEUE): Task | null {
+    const state = this.queueStates.get(queueName);
+
+    // Check concurrency limit
+    if (state && state.concurrencyLimit > 0) {
+      if (state.activeCount >= state.concurrencyLimit) {
+        return null;
+      }
+    }
+
+    const now = new Date();
+    const candidates: Task[] = [];
+
+    for (const task of this.tasks.values()) {
+      if (
+        task.queue === queueName &&
+        task.status === 'pending' &&
+        task.availableAt <= now
+      ) {
+        candidates.push(task);
+      }
+    }
+
+    if (candidates.length === 0) return null;
+
+    // Sort: priority ascending (1 is highest), then availableAt, then createdAt
+    candidates.sort((a, b) => {
+      if (a.priority !== b.priority) return a.priority - b.priority;
+      if (a.availableAt.getTime() !== b.availableAt.getTime()) {
+        return a.availableAt.getTime() - b.availableAt.getTime();
+      }
+      return a.createdAt.getTime() - b.createdAt.getTime();
+    });
+
+    const task = candidates[0];
+    task.status = 'processing';
+    task.updatedAt = new Date();
+    task.attempts += 1;
+
+    if (state) {
+      state.activeCount += 1;
+    }
+
+    return task;
+  }
+
+  size(queueName: string = DEFAULT_QUEUE): number {
+    let count = 0;
+    for (const task of this.tasks.values()) {
+      if (task.queue === queueName && task.status === 'pending') {
+        count++;
+      }
+    }
+    return count;
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 2: Named Queues
+  // ──────────────────────────────────────────────
+
+  listQueues(): string[] {
+    return Array.from(this.queueStates.keys());
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 5: Complete / Fail with Retry
+  // ──────────────────────────────────────────────
+
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot complete task in status: ${task.status}`);
+    }
+
+    task.status = 'completed';
+    task.updatedAt = new Date();
+    task.progress = 100;
+
+    // Free concurrency slot
+    const state = this.queueStates.get(task.queue);
+    if (state) {
+      state.activeCount = Math.max(0, state.activeCount - 1);
+    }
+
+    // Unblock dependent tasks
+    this.checkDependents(taskId);
+  }
+
+  fail(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot fail task in status: ${task.status}`);
+    }
+
+    // Free concurrency slot
+    const state = this.queueStates.get(task.queue);
+    if (state) {
+      state.activeCount = Math.max(0, state.activeCount - 1);
+    }
+
+    task.error = error;
+
+    if (task.attempts < task.maxRetries) {
+      // Retry with exponential backoff
+      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.updatedAt = new Date();
+      task.progress = 0;
+    } else {
+      // No more retries - move to dead letter queue
+      task.status = 'failed';
+      task.updatedAt = new Date();
+      this.moveToDLQ(task);
+    }
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 6: Dead Letter Queue
+  // ──────────────────────────────────────────────
+
+  private moveToDLQ(task: Task): void {
+    const dlqKey = task.queue;
+    if (!this.deadLetterQueues.has(dlqKey)) {
+      this.deadLetterQueues.set(dlqKey, []);
+    }
+    this.deadLetterQueues.get(dlqKey)!.push(task);
+  }
+
+  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): Task[] {
+    return this.deadLetterQueues.get(queueName) ?? [];
+  }
+
+  retryDeadLetterTask(taskId: string): Task {
+    for (const [queueName, dlqTasks] of this.deadLetterQueues.entries()) {
+      const idx = dlqTasks.findIndex(t => t.id === taskId);
+      if (idx !== -1) {
+        const task = dlqTasks.splice(idx, 1)[0];
+        task.status = 'pending';
+        task.attempts = 0;
+        task.error = undefined;
+        task.availableAt = new Date();
+        task.updatedAt = new Date();
+        task.progress = 0;
+        // task stays in this.tasks map already
+        // Ensure queue state exists
+        this.ensureQueueState(queueName);
+        return task;
+      }
+    }
+    throw new Error(`Dead letter task not found: ${taskId}`);
+  }
+
+  clearDeadLetterQueue(queueName: string = DEFAULT_QUEUE): void {
+    const dlqTasks = this.deadLetterQueues.get(queueName);
+    if (dlqTasks) {
+      // Remove tasks from the main map too
+      for (const task of dlqTasks) {
+        this.tasks.delete(task.id);
+      }
+      this.deadLetterQueues.set(queueName, []);
+    }
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 7: Task Dependencies
+  // ──────────────────────────────────────────────
+
+  private detectCircularDependencies(newDeps: string[]): void {
+    // BFS from each dependency to see if it would lead back to any task
+    // that depends on these deps (i.e., circular)
+    // Since the new task doesn't exist yet, we just need to verify
+    // that none of the deps transitively depend on each other in a cycle
+    // Actually, the new task has no ID yet so no cycle is possible through it.
+    // The real check: do any of newDeps have dependencies that form a cycle?
+    // We need to check: can we reach any of newDeps by following dependencies
+    // starting from newDeps?
+
+    // For a new task T with deps [A, B]:
+    // We check that A's transitive dependencies don't include B and vice versa.
+    // Actually that's not right either. The concern is whether T depends on
+    // something that will eventually depend back on T. Since T doesn't exist yet,
+    // no existing task can depend on T, so no cycle is possible at creation time.
+    // However, if we have existing tasks with deps, we should check for cycles
+    // among the existing dependency graph.
+
+    // The real scenario for circular deps:
+    // Task A depends on Task B, then Task B depends on Task A.
+    // When adding B with dep on A, A already exists but doesn't depend on B (B doesn't exist yet).
+    // So at creation time, direct cycles through the new task are impossible.
+    // But: if A depends on C, and we create D depending on A, and then try to
+    // make C depend on D - at that point, C->D->A->C would be a cycle.
+    // When creating the task that depends on C, we check: does C transitively
+    // depend on any not-yet-resolved task? No, we check if any of the dependencies
+    // transitively circle back.
+
+    // Since the new task has no ID yet and no other task can reference it,
+    // the only way a cycle can form is if we somehow create mutual references.
+    // The check: given the new task's deps, verify the transitive closure
+    // of deps from those deps doesn't form a cycle.
+    // More precisely: verify the existing dependency DAG is still a DAG.
+    // Since we're adding a new node with edges to the existing deps, and no
+    // existing node points to the new node, no cycle can form.
+
+    // HOWEVER: the requirement says "Circular dependencies (direct or indirect)
+    // must be detected and rejected at task-creation time."
+    // This means: if we have tasks that already form a partial cycle waiting
+    // for this new task, we'd catch it. But that can't happen since the new task
+    // doesn't have an ID yet.
+
+    // The actual practical case: checking that the dependency IDs themselves
+    // don't create an issue. Let's ensure the graph remains a DAG.
+    // Since we can't create a cycle by adding a leaf node, this is always fine.
+    // But let's be thorough and validate anyway.
+
+    const visited = new Set<string>();
+    const stack = [...newDeps];
+
+    while (stack.length > 0) {
+      const id = stack.pop()!;
+      if (visited.has(id)) continue;
+      visited.add(id);
+
+      const depTask = this.tasks.get(id);
+      if (depTask) {
+        for (const dep of depTask.dependencies) {
+          stack.push(dep);
+        }
+      }
+    }
+
+    // Check for duplicates in newDeps forming immediate cycles
+    const depSet = new Set(newDeps);
+    if (depSet.size !== newDeps.length) {
+      throw new Error('Duplicate dependencies specified');
+    }
+  }
+
+  private checkDependents(completedTaskId: string): void {
+    for (const task of this.tasks.values()) {
+      if (task.status !== 'blocked') continue;
+      if (!task.dependencies.includes(completedTaskId)) continue;
+
+      // Check if all dependencies are now completed
+      const allResolved = task.dependencies.every(depId => {
+        const dep = this.tasks.get(depId);
+        return dep && dep.status === 'completed';
+      });
+
+      if (allResolved) {
+        task.status = 'pending';
+        task.updatedAt = new Date();
+      }
+    }
+  }
+
+  getTask(taskId: string): Task | undefined {
+    return this.tasks.get(taskId);
+  }
+
+  getDependencyStatus(taskId: string): { taskId: string; status: TaskStatus; resolved: boolean }[] {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    return task.dependencies.map(depId => {
+      const dep = this.tasks.get(depId);
+      return {
+        taskId: depId,
+        status: dep ? dep.status : 'failed' as TaskStatus,
+        resolved: dep ? dep.status === 'completed' : false,
+      };
+    });
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 8: Concurrency Control
+  // ──────────────────────────────────────────────
+
+  setConcurrency(queueName: string, limit: number): void {
+    const state = this.ensureQueueState(queueName);
+    state.concurrencyLimit = limit;
+  }
+
+  getConcurrency(queueName: string = DEFAULT_QUEUE): { limit: number; active: number } {
+    const state = this.queueStates.get(queueName);
+    return {
+      limit: state?.concurrencyLimit ?? 0,
+      active: state?.activeCount ?? 0,
+    };
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 9: Progress and Cancellation
+  // ──────────────────────────────────────────────
+
+  reportProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    if (task.status !== 'processing') {
+      throw new Error(`Cannot report progress for task in status: ${task.status}`);
+    }
+    if (progress < 0 || progress > 100) {
+      throw new Error(`Progress must be between 0 and 100, got: ${progress}`);
+    }
+
+    task.progress = progress;
+    task.progressMessage = message;
+    task.updatedAt = new Date();
+
+    const update: ProgressUpdate = { taskId, progress, message };
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(update);
+      }
+    }
+  }
+
+  getProgress(taskId: string): { progress: number; message?: string } {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+    return { progress: task.progress, message: task.progressMessage };
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(listener);
+
+    // Return unsubscribe function
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(listener);
+        if (listeners.size === 0) {
+          this.progressListeners.delete(taskId);
+        }
+      }
+    };
+  }
+
+  cancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {
+      throw new Error(`Cannot cancel task in status: ${task.status}`);
+    }
+
+    const wasProcessing = task.status === 'processing';
+    task.status = 'cancelled';
+    task.updatedAt = new Date();
+
+    // Free concurrency slot if it was processing
+    if (wasProcessing) {
+      const state = this.queueStates.get(task.queue);
+      if (state) {
+        state.activeCount = Math.max(0, state.activeCount - 1);
+      }
+    }
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 10: Recurring Tasks (Cron-like)
+  // ──────────────────────────────────────────────
+
+  addSchedule(
+    cronExpression: string,
+    queueName: string,
+    payload: unknown,
+    taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'availableAt' | 'dependencies'>,
+  ): Schedule {
+    if (this.isShuttingDown) {
+      throw new Error('Queue is shutting down, cannot add schedules');
+    }
+    this.validateCron(cronExpression);
+
+    const schedule: Schedule = {
+      id: randomUUID(),
+      cronExpression,
+      queue: queueName,
+      payload,
+      taskOptions,
+      active: true,
+    };
+
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    const schedule = this.schedules.get(scheduleId);
+    if (!schedule) throw new Error(`Schedule not found: ${scheduleId}`);
+    schedule.active = false;
+    this.schedules.delete(scheduleId);
+  }
+
+  listSchedules(): Schedule[] {
+    return Array.from(this.schedules.values()).filter(s => s.active);
+  }
+
+  tick(now: Date = new Date()): Task[] {
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (!schedule.active) continue;
+
+      if (this.shouldRunAt(schedule, now)) {
+        const task = this.add(schedule.payload, {
+          ...schedule.taskOptions,
+          queue: schedule.queue,
+        });
+        created.push(task);
+        schedule.lastRun = now;
+      }
+    }
+
+    return created;
+  }
+
+  private validateCron(expr: string): void {
+    const parts = expr.trim().split(/\s+/);
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${expr}. Expected 5 fields.`);
+    }
+
+    // Validate minute field
+    const minute = parts[0];
+    if (minute !== '*' && !minute.match(/^\d+$/) && !minute.match(/^\*\/\d+$/)) {
+      throw new Error(`Invalid cron minute field: ${minute}`);
+    }
+
+    // Validate hour field
+    const hour = parts[1];
+    if (hour !== '*' && !hour.match(/^\d+$/) && !hour.match(/^\*\/\d+$/)) {
+      throw new Error(`Invalid cron hour field: ${hour}`);
+    }
+
+    // Fields 2-4 must be * for our supported subset
+    for (let i = 2; i < 5; i++) {
+      if (parts[i] !== '*') {
+        throw new Error(`Unsupported cron field at position ${i}: ${parts[i]}. Only '*' is supported.`);
+      }
+    }
+  }
+
+  private shouldRunAt(schedule: Schedule, now: Date): boolean {
+    const parts = schedule.cronExpression.trim().split(/\s+/);
+    const minuteField = parts[0];
+    const hourField = parts[1];
+
+    const currentMinute = now.getMinutes();
+    const currentHour = now.getHours();
+
+    // Check minute field
+    if (!this.matchesCronField(minuteField, currentMinute)) return false;
+
+    // Check hour field
+    if (!this.matchesCronField(hourField, currentHour)) return false;
+
+    // Check if we already ran at this time
+    if (schedule.lastRun) {
+      const lastMinute = schedule.lastRun.getMinutes();
+      const lastHour = schedule.lastRun.getHours();
+      const lastDate = schedule.lastRun.toDateString();
+      const nowDate = now.toDateString();
+
+      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {
+        return false;
+      }
+    }
+
+    return true;
+  }
+
+  private matchesCronField(field: string, value: number): boolean {
+    if (field === '*') return true;
+    if (field.startsWith('*/')) {
+      const interval = parseInt(field.substring(2), 10);
+      return value % interval === 0;
+    }
+    return parseInt(field, 10) === value;
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 11: Middleware Pipeline
+  // ──────────────────────────────────────────────
+
+  use(queueName: string, middleware: MiddlewareFn): void {
+    const state = this.ensureQueueState(queueName);
+    state.middlewares.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: HandlerFn): void {
+    const state = this.ensureQueueState(queueName);
+    state.handler = handler;
+  }
+
+  async process(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {
+    const task = this.next(queueName);
+    if (!task) return null;
+
+    const state = this.queueStates.get(queueName);
+    if (!state) return task;
+
+    const middlewares = state.middlewares;
+    const handler = state.handler;
+
+    try {
+      await this.runMiddlewarePipeline(task, middlewares, handler);
+      // Auto-complete if still processing (middleware/handler didn't fail it)
+      if (task.status === 'processing') {
+        this.complete(task.id);
+      }
+    } catch (err) {
+      if (task.status === 'processing') {
+        this.fail(task.id, err instanceof Error ? err.message : String(err));
+      }
+    }
+
+    return task;
+  }
+
+  private async runMiddlewarePipeline(
+    task: Task,
+    middlewares: MiddlewareFn[],
+    handler?: HandlerFn,
+  ): Promise<void> {
+    let index = 0;
+
+    const executeNext = async (): Promise<void> => {
+      if (index < middlewares.length) {
+        const middleware = middlewares[index];
+        index++;
+        await middleware(task, executeNext);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    await executeNext();
+  }
+
+  // ──────────────────────────────────────────────
+  // Phase 12: Graceful Shutdown
+  // ──────────────────────────────────────────────
+
+  onShutdown(callback: ShutdownCallback): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeout: number = 30000): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShuttingDown = true;
+    this.shutdownPromise = this.performShutdown(timeout);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(timeout: number): Promise<ShutdownResult> {
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const callback of this.shutdownCallbacks) {
+      try {
+        await callback();
+      } catch {
+        // Swallow errors from callbacks
+      }
+    }
+
+    // Collect processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    let completed = 0;
+    let forceCancelled = 0;
+
+    if (processingTasks.length === 0) {
+      return {
+        completed,
+        forceCancelled,
+        duration: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete, up to timeout
+    const deadline = startTime + timeout;
+
+    await new Promise<void>((resolve) => {
+      const check = () => {
+        const stillProcessing = processingTasks.filter(t => t.status === 'processing');
+        if (stillProcessing.length === 0 || Date.now() >= deadline) {
+          resolve();
+          return;
+        }
+        setTimeout(check, 50);
+      };
+      check();
+    });
+
+    // Count results
+    for (const task of processingTasks) {
+      if (task.status === 'completed') {
+        completed++;
+      } else if (task.status === 'processing') {
+        // Force cancel
+        task.status = 'cancelled';
+        task.updatedAt = new Date();
+        const state = this.queueStates.get(task.queue);
+        if (state) {
+          state.activeCount = Math.max(0, state.activeCount - 1);
+        }
+        forceCancelled++;
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      duration: Date.now() - startTime,
+    };
+  }
+
+  // ──────────────────────────────────────────────
+  // Internal helpers
+  // ──────────────────────────────────────────────
+
+  private ensureQueueState(queueName: string): QueueState {
+    if (!this.queueStates.has(queueName)) {
+      this.queueStates.set(queueName, {
+        concurrencyLimit: 0,
+        activeCount: 0,
+        middlewares: [],
+      });
+    }
+    return this.queueStates.get(queueName)!;
+  }
+}
