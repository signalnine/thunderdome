+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_011cjPD3eCPr9Wij3gNnsu2g","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BuY1F4HRZ17t4SFZz3jF5K","name":"Write","input":{"file_path":"/workspace/tests/taskqueue.test.ts","content":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\ndescribe('TaskQueue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 1: Basic FIFO Queue\n  // ──────────────────────────────────────────────\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = queue.add({ message: 'hello' });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign a unique ID to each task', () => {\n      const t1 = queue.add('task1');\n      const t2 = queue.add('task2');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      queue.add('first');\n      queue.add('second');\n      queue.add('third');\n\n      const t1 = queue.next();\n      expect(t1?.payload).toBe('first');\n      const t2 = queue.next();\n      expect(t2?.payload).toBe('second');\n      const t3 = queue.next();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should transition retrieved task to processing', () => {\n      queue.add('work');\n      const task = queue.next();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should track pending task count', () => {\n      expect(queue.size()).toBe(0);\n      queue.add('a');\n      queue.add('b');\n      expect(queue.size()).toBe(2);\n      queue.next();\n      expect(queue.size()).toBe(1);\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 2: Named Queues\n  // ──────────────────────────────────────────────\n  describe('Phase 2: Named Queues', () => {\n    it('should add tasks to named queues', () => {\n      queue.add('email-task', { queue: 'email' });\n      queue.add('sms-task', { queue: 'sms' });\n\n      expect(queue.size('email')).toBe(1);\n      expect(queue.size('sms')).toBe(1);\n    });\n\n    it('should retrieve tasks from specific queue only', () => {\n      queue.add('email-task', { queue: 'email' });\n      queue.add('sms-task', { queue: 'sms' });\n\n      const task = queue.next('email');\n      expect(task?.payload).toBe('email-task');\n      expect(queue.next('email')).toBeNull();\n      expect(queue.size('sms')).toBe(1);\n    });\n\n    it('should use default queue when no name given', () => {\n      queue.add('default-task');\n      expect(queue.size()).toBe(1);\n      expect(queue.size('default')).toBe(1);\n    });\n\n    it('should list all queue names', () => {\n      queue.add('a', { queue: 'q1' });\n      queue.add('b', { queue: 'q2' });\n      const names = queue.listQueues();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n    });\n\n    it('should return null from non-existent queue', () => {\n      expect(queue.next('nonexistent')).toBeNull();\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 3: Priority\n  // ──────────────────────────────────────────────\n  describe('Phase 3: Priority', () => {\n    it('should process higher priority tasks first', () => {\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n      queue.add('medium', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('high');\n      expect(queue.next()?.payload).toBe('medium');\n      expect(queue.next()?.payload).toBe('low');\n    });\n\n    it('should default to priority 5', () => {\n      const task = queue.add('default');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      queue.add('first', { priority: 5 });\n      queue.add('second', { priority: 5 });\n      queue.add('third', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('first');\n      expect(queue.next()?.payload).toBe('second');\n      expect(queue.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => queue.add('x', { priority: 0 })).toThrow();\n      expect(() => queue.add('x', { priority: 11 })).toThrow();\n      expect(() => queue.add('x', { priority: 1.5 })).toThrow();\n    });\n\n    it('should expose priority on task object', () => {\n      const task = queue.add('x', { priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n\n    it('should handle priority per queue', () => {\n      queue.add('q1-low', { queue: 'q1', priority: 10 });\n      queue.add('q1-high', { queue: 'q1', priority: 1 });\n      queue.add('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(queue.next('q1')?.payload).toBe('q1-high');\n      expect(queue.next('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 4: Delayed Tasks\n  // ──────────────────────────────────────────────\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their available time', () => {\n      queue.add('delayed', { delay: 60000 });\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should return delayed tasks after their available time', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.add('ready', { availableAt: past });\n      const task = queue.next();\n      expect(task?.payload).toBe('ready');\n    });\n\n    it('should prefer non-delayed tasks', () => {\n      queue.add('delayed', { delay: 60000 });\n      queue.add('immediate');\n\n      const task = queue.next();\n      expect(task?.payload).toBe('immediate');\n    });\n\n    it('should expose availableAt on task', () => {\n      const task = queue.add('delayed', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should support specific future time', () => {\n      const future = new Date(Date.now() + 60000);\n      const task = queue.add('scheduled', { availableAt: future });\n      expect(task.availableAt).toEqual(future);\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should order delayed tasks by availability, then priority, then FIFO', () => {\n      const past1 = new Date(Date.now() - 2000);\n      const past2 = new Date(Date.now() - 1000);\n\n      queue.add('later', { availableAt: past2, priority: 1 });\n      queue.add('earlier', { availableAt: past1, priority: 1 });\n\n      expect(queue.next()?.payload).toBe('earlier');\n      expect(queue.next()?.payload).toBe('later');\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 5: Retry with Backoff\n  // ──────────────────────────────────────────────\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      queue.complete(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should retry failed tasks with backoff', () => {\n      const task = queue.add('work', { maxRetries: 3, backoffDelay: 100 });\n      const retrieved = queue.next()!;\n      expect(retrieved.attempts).toBe(1);\n\n      queue.fail(retrieved.id, 'oops');\n      const failedTask = queue.getTask(task.id)!;\n      expect(failedTask.status).toBe('pending');\n      expect(failedTask.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should track attempt count', () => {\n      const task = queue.add('work', { maxRetries: 3, backoffDelay: 0 });\n\n      // Attempt 1\n      let t = queue.next()!;\n      expect(t.attempts).toBe(1);\n      queue.fail(t.id);\n\n      // The task is now pending but delayed - set availableAt to past for testing\n      const taskObj = queue.getTask(task.id)!;\n      taskObj.availableAt = new Date(Date.now() - 1000);\n\n      // Attempt 2\n      t = queue.next()!;\n      expect(t.attempts).toBe(2);\n      queue.fail(t.id);\n\n      taskObj.availableAt = new Date(Date.now() - 1000);\n\n      // Attempt 3\n      t = queue.next()!;\n      expect(t.attempts).toBe(3);\n      queue.fail(t.id);\n\n      // Should now be failed (exhausted retries)\n      expect(queue.getTask(task.id)?.status).toBe('failed');\n    });\n\n    it('should use exponential backoff delay', () => {\n      const task = queue.add('work', { maxRetries: 3, backoffDelay: 1000 });\n\n      // Attempt 1\n      const t = queue.next()!;\n      const beforeFail = Date.now();\n      queue.fail(t.id, 'err');\n\n      const taskObj = queue.getTask(task.id)!;\n      // First retry: 1000 * 2^0 = 1000ms\n      expect(taskObj.availableAt.getTime() - beforeFail).toBeGreaterThanOrEqual(900);\n      expect(taskObj.availableAt.getTime() - beforeFail).toBeLessThan(2000);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = queue.add('work', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      const t = queue.next('myq')!;\n      queue.fail(t.id);\n\n      const taskObj = queue.getTask(task.id)!;\n      expect(taskObj.queue).toBe('myq');\n      expect(taskObj.priority).toBe(2);\n    });\n\n    it('should default to 3 retries', () => {\n      const task = queue.add('work');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should throw when completing non-processing task', () => {\n      const task = queue.add('work');\n      expect(() => queue.complete(task.id)).toThrow();\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 6: Dead Letter Queue\n  // ──────────────────────────────────────────────\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move task to DLQ after all retries exhausted', () => {\n      const task = queue.add('work', { maxRetries: 1, backoffDelay: 0 });\n\n      const t = queue.next()!;\n      queue.fail(t.id, 'error1');\n\n      const dlqTasks = queue.getDeadLetterTasks();\n      expect(dlqTasks).toHaveLength(1);\n      expect(dlqTasks[0].id).toBe(task.id);\n      expect(dlqTasks[0].error).toBe('error1');\n    });\n\n    it('should retain error info in DLQ', () => {\n      const task = queue.add('work', { maxRetries: 1 });\n      const t = queue.next()!;\n      queue.fail(t.id, 'test error');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq[0].error).toBe('test error');\n      expect(dlq[0].attempts).toBe(1);\n    });\n\n    it('should retry a dead-lettered task', () => {\n      queue.add('work', { maxRetries: 1, backoffDelay: 0 });\n      const t = queue.next()!;\n      queue.fail(t.id, 'err');\n\n      const retried = queue.retryDeadLetterTask(t.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempts).toBe(0);\n      expect(retried.error).toBeUndefined();\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should clear dead letter queue', () => {\n      queue.add('work1', { maxRetries: 1 });\n      queue.add('work2', { maxRetries: 1 });\n\n      const t1 = queue.next()!;\n      queue.fail(t1.id, 'err');\n      const t2 = queue.next()!;\n      queue.fail(t2.id, 'err');\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should have independent DLQ per named queue', () => {\n      queue.add('q1-work', { queue: 'q1', maxRetries: 1 });\n      queue.add('q2-work', { queue: 'q2', maxRetries: 1 });\n\n      const t1 = queue.next('q1')!;\n      queue.fail(t1.id, 'err');\n      const t2 = queue.next('q2')!;\n      queue.fail(t2.id, 'err');\n\n      expect(queue.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 7: Task Dependencies\n  // ──────────────────────────────────────────────\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const t1 = queue.add('parent');\n      const t2 = queue.add('child', { dependencies: [t1.id] });\n\n      expect(t2.status).toBe('blocked');\n      // Should not return blocked tasks\n      const next = queue.next();\n      expect(next?.id).toBe(t1.id);\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const t1 = queue.add('parent');\n      const t2 = queue.add('child', { dependencies: [t1.id] });\n\n      const parent = queue.next()!;\n      queue.complete(parent.id);\n\n      expect(queue.getTask(t2.id)?.status).toBe('pending');\n      const child = queue.next();\n      expect(child?.payload).toBe('child');\n    });\n\n    it('should reject dependencies on non-existent tasks', () => {\n      expect(() => queue.add('child', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const t1 = queue.add('parent', { maxRetries: 1 });\n      const t2 = queue.add('child', { dependencies: [t1.id] });\n\n      const parent = queue.next()!;\n      queue.fail(parent.id, 'failed');\n\n      expect(queue.getTask(t2.id)?.status).toBe('blocked');\n    });\n\n    it('should support multiple dependencies', () => {\n      const t1 = queue.add('dep1');\n      const t2 = queue.add('dep2');\n      const t3 = queue.add('child', { dependencies: [t1.id, t2.id] });\n\n      const d1 = queue.next()!;\n      queue.complete(d1.id);\n\n      // Still blocked because t2 not complete\n      expect(queue.getTask(t3.id)?.status).toBe('blocked');\n\n      const d2 = queue.next()!;\n      queue.complete(d2.id);\n\n      // Now unblocked\n      expect(queue.getTask(t3.id)?.status).toBe('pending');\n    });\n\n    it('should expose dependency status', () => {\n      const t1 = queue.add('dep1');\n      const t2 = queue.add('child', { dependencies: [t1.id] });\n\n      const deps = queue.getDependencyStatus(t2.id);\n      expect(deps).toHaveLength(1);\n      expect(deps[0].taskId).toBe(t1.id);\n      expect(deps[0].resolved).toBe(false);\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 8: Concurrency Control\n  // ──────────────────────────────────────────────\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      queue.setConcurrency('default', 2);\n      queue.add('t1');\n      queue.add('t2');\n      queue.add('t3');\n\n      const r1 = queue.next();\n      const r2 = queue.next();\n      const r3 = queue.next();\n\n      expect(r1).not.toBeNull();\n      expect(r2).not.toBeNull();\n      expect(r3).toBeNull(); // Blocked by concurrency\n    });\n\n    it('should free slot on complete', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1');\n      queue.add('t2');\n\n      const r1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.complete(r1.id);\n      expect(queue.next()).not.toBeNull();\n    });\n\n    it('should free slot on fail', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1', { maxRetries: 1 });\n      queue.add('t2');\n\n      const r1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.fail(r1.id, 'err');\n      // t2 should now be available\n      const r2 = queue.next();\n      expect(r2?.payload).toBe('t2');\n    });\n\n    it('should default to unlimited concurrency', () => {\n      const conc = queue.getConcurrency();\n      expect(conc.limit).toBe(0);\n    });\n\n    it('should report concurrency status', () => {\n      queue.setConcurrency('default', 3);\n      queue.add('t1');\n      queue.add('t2');\n\n      queue.next();\n      queue.next();\n\n      const conc = queue.getConcurrency();\n      expect(conc.limit).toBe(3);\n      expect(conc.active).toBe(2);\n    });\n\n    it('should respect priority within concurrency limits', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const task = queue.next()!;\n      expect(task.payload).toBe('high');\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 9: Progress and Cancellation\n  // ──────────────────────────────────────────────\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report and query progress', () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      queue.reportProgress(task.id, 50, 'halfway');\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      const updates: number[] = [];\n      queue.onProgress(task.id, (update) => {\n        updates.push(update.progress);\n      });\n\n      queue.reportProgress(task.id, 25);\n      queue.reportProgress(task.id, 75);\n\n      expect(updates).toEqual([25, 75]);\n    });\n\n    it('should support unsubscribing from progress', () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      const updates: number[] = [];\n      const unsubscribe = queue.onProgress(task.id, (update) => {\n        updates.push(update.progress);\n      });\n\n      queue.reportProgress(task.id, 25);\n      unsubscribe();\n      queue.reportProgress(task.id, 75);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should reject invalid progress values', () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = queue.add('work');\n      queue.cancel(task.id);\n\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.next()).toBeNull();\n      expect(queue.size()).toBe(0);\n    });\n\n    it('should cancel processing tasks', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      queue.cancel(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should free concurrency slot on cancel of processing task', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1');\n      queue.add('t2');\n\n      const t1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.cancel(t1.id);\n      expect(queue.next()).not.toBeNull();\n    });\n\n    it('should not retry cancelled tasks', () => {\n      queue.add('work', { maxRetries: 3 });\n      const task = queue.next()!;\n      queue.cancel(task.id);\n\n      // Should not end up in DLQ either\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should throw when cancelling completed tasks', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      queue.complete(task.id);\n      expect(() => queue.cancel(task.id)).toThrow();\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 10: Recurring Tasks\n  // ──────────────────────────────────────────────\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = queue.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(schedule.id).toBeDefined();\n      expect(schedule.active).toBe(true);\n    });\n\n    it('should list active schedules', () => {\n      queue.addSchedule('*/5 * * * *', 'default', 'cleanup');\n      queue.addSchedule('0 * * * *', 'default', 'hourly');\n\n      expect(queue.listSchedules()).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      const schedule = queue.addSchedule('*/5 * * * *', 'default', 'cleanup');\n      queue.removeSchedule(schedule.id);\n\n      expect(queue.listSchedules()).toHaveLength(0);\n    });\n\n    it('should create tasks on tick when due', () => {\n      queue.addSchedule('*/5 * * * *', 'default', 'every5min');\n\n      // Tick at minute 0 (divisible by 5)\n      const now = new Date();\n      now.setMinutes(0, 0, 0);\n      const created = queue.tick(now);\n\n      expect(created).toHaveLength(1);\n      expect(created[0].payload).toBe('every5min');\n    });\n\n    it('should not create tasks when not due', () => {\n      queue.addSchedule('*/5 * * * *', 'default', 'every5min');\n\n      const now = new Date();\n      now.setMinutes(3, 0, 0); // Not divisible by 5\n      const created = queue.tick(now);\n\n      expect(created).toHaveLength(0);\n    });\n\n    it('should not duplicate on repeated tick at same time', () => {\n      queue.addSchedule('*/5 * * * *', 'default', 'every5min');\n\n      const now = new Date();\n      now.setMinutes(10, 0, 0);\n      queue.tick(now);\n      const second = queue.tick(now);\n\n      expect(second).toHaveLength(0);\n    });\n\n    it('should support hourly schedule', () => {\n      queue.addSchedule('0 * * * *', 'default', 'hourly');\n\n      const now = new Date();\n      now.setMinutes(0, 0, 0);\n      const created = queue.tick(now);\n\n      expect(created).toHaveLength(1);\n    });\n\n    it('should support daily midnight schedule', () => {\n      queue.addSchedule('0 0 * * *', 'default', 'daily');\n\n      const midnight = new Date();\n      midnight.setHours(0, 0, 0, 0);\n      const created = queue.tick(midnight);\n\n      expect(created).toHaveLength(1);\n\n      const noon = new Date();\n      noon.setHours(12, 0, 0, 0);\n      const notCreated = queue.tick(noon);\n\n      expect(notCreated).toHaveLength(0);\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      const schedule = queue.addSchedule('*/5 * * * *', 'default', 'work');\n      queue.removeSchedule(schedule.id);\n\n      const now = new Date();\n      now.setMinutes(0, 0, 0);\n      const created = queue.tick(now);\n\n      expect(created).toHaveLength(0);\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 11: Middleware Pipeline\n  // ──────────────────────────────────────────────\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware in order', async () => {\n      const order: number[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push(1);\n        await next();\n      });\n      queue.use('default', async (_task, next) => {\n        order.push(2);\n        await next();\n      });\n      queue.setHandler('default', async () => {\n        order.push(3);\n      });\n\n      queue.add('work');\n      await queue.process();\n\n      expect(order).toEqual([1, 2, 3]);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      queue.use('default', async (task, next) => {\n        (task as unknown as Record<string, unknown>).metadata = { modified: true };\n        await next();\n      });\n\n      let receivedTask: unknown;\n      queue.setHandler('default', async (task) => {\n        receivedTask = task;\n      });\n\n      queue.add('work');\n      await queue.process();\n\n      expect((receivedTask as Record<string, unknown>).metadata).toEqual({ modified: true });\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      let handlerCalled = false;\n\n      queue.use('default', async () => {\n        // Deliberately not calling next\n      });\n      queue.setHandler('default', async () => {\n        handlerCalled = true;\n      });\n\n      queue.add('work');\n      await queue.process();\n\n      expect(handlerCalled).toBe(false);\n    });\n\n    it('should fail task if middleware throws', async () => {\n      queue.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = queue.add('work', { maxRetries: 1 });\n      await queue.process();\n\n      const t = queue.getTask(task.id)!;\n      expect(t.status).toBe('failed');\n      expect(t.error).toBe('middleware error');\n    });\n\n    it('should auto-complete task after handler finishes', async () => {\n      queue.setHandler('default', async () => {\n        // do nothing\n      });\n\n      const task = queue.add('work');\n      await queue.process();\n\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should return null when no tasks to process', async () => {\n      const result = await queue.process();\n      expect(result).toBeNull();\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const q1Order: string[] = [];\n      const q2Order: string[] = [];\n\n      queue.use('q1', async (_task, next) => {\n        q1Order.push('q1-middleware');\n        await next();\n      });\n      queue.use('q2', async (_task, next) => {\n        q2Order.push('q2-middleware');\n        await next();\n      });\n\n      queue.add('work1', { queue: 'q1' });\n      queue.add('work2', { queue: 'q2' });\n\n      await queue.process('q1');\n      await queue.process('q2');\n\n      expect(q1Order).toEqual(['q1-middleware']);\n      expect(q2Order).toEqual(['q2-middleware']);\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 12: Graceful Shutdown\n  // ──────────────────────────────────────────────\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await queue.shutdown();\n      expect(() => queue.add('late')).toThrow('shutting down');\n    });\n\n    it('should complete immediately when no tasks processing', async () => {\n      const result = await queue.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks', async () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      // Start shutdown\n      const shutdownPromise = queue.shutdown(5000);\n\n      // Complete the task\n      queue.complete(task.id);\n\n      const result = await shutdownPromise;\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force cancel after timeout', async () => {\n      queue.add('slow-work');\n      queue.next()!;\n\n      const result = await queue.shutdown(100);\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should return same result on multiple shutdown calls', async () => {\n      const r1 = queue.shutdown();\n      const r2 = queue.shutdown();\n\n      const result1 = await r1;\n      const result2 = await r2;\n\n      expect(result1).toBe(result2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let called = false;\n      queue.onShutdown(() => {\n        called = true;\n      });\n\n      await queue.shutdown();\n      expect(called).toBe(true);\n    });\n\n    it('should include duration in result', async () => {\n      const result = await queue.shutdown();\n      expect(typeof result.duration).toBe('number');\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Cross-phase interaction tests\n  // ──────────────────────────────────────────────\n  describe('Cross-phase interactions', () => {\n    it('should handle priority + delay correctly', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.add('delayed-high', { priority: 1, availableAt: past });\n      queue.add('immediate-low', { priority: 10 });\n\n      // Higher priority should still win\n      expect(queue.next()?.payload).toBe('delayed-high');\n    });\n\n    it('should handle dependencies + concurrency', () => {\n      queue.setConcurrency('default', 1);\n\n      const t1 = queue.add('parent');\n      queue.add('child', { dependencies: [t1.id] });\n\n      const parent = queue.next()!;\n      // Concurrency full, but also child is blocked\n      expect(queue.next()).toBeNull();\n\n      queue.complete(parent.id);\n      // Now child should be available\n      const child = queue.next();\n      expect(child?.payload).toBe('child');\n    });\n\n    it('should handle middleware + retry', async () => {\n      let attempts = 0;\n\n      queue.use('default', async (task, next) => {\n        attempts++;\n        await next();\n      });\n      queue.setHandler('default', async () => {\n        if (attempts < 2) throw new Error('not ready');\n      });\n\n      const task = queue.add('work', { maxRetries: 3, backoffDelay: 0 });\n      await queue.process();\n\n      // Task failed and was re-queued with delay\n      const t = queue.getTask(task.id)!;\n      expect(t.status).toBe('pending');\n\n      // Adjust availableAt for testing\n      t.availableAt = new Date(Date.now() - 1000);\n\n      await queue.process();\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":245,"cache_read_input_tokens":33144,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":245},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"2de83810-7a72-481a-a6b4-88c160ea80ca","uuid":"899b028c-6735-44dd-bdfb-11627d914001"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BuY1F4HRZ17t4SFZz3jF5K","type":"tool_result","content":"File created successfully at: /workspace/tests/taskqueue.test.ts"}]},"parent_tool_use_id":null,"session_id":"2de83810-7a72-481a-a6b4-88c160ea80ca","uuid":"cc84b0b6-27e4-4f40-834a-96b5fec90658","tool_use_result":{"type":"create","filePath":"/workspace/tests/taskqueue.test.ts","content":"import { describe, it, expect, beforeEach, vi } from 'vitest';\nimport { TaskQueue } from '../src/index.js';\n\ndescribe('TaskQueue', () => {\n  let queue: TaskQueue;\n\n  beforeEach(() => {\n    queue = new TaskQueue();\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 1: Basic FIFO Queue\n  // ──────────────────────────────────────────────\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = queue.add({ message: 'hello' });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign a unique ID to each task', () => {\n      const t1 = queue.add('task1');\n      const t2 = queue.add('task2');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      queue.add('first');\n      queue.add('second');\n      queue.add('third');\n\n      const t1 = queue.next();\n      expect(t1?.payload).toBe('first');\n      const t2 = queue.next();\n      expect(t2?.payload).toBe('second');\n      const t3 = queue.next();\n      expect(t3?.payload).toBe('third');\n    });\n\n    it('should transition retrieved task to processing', () => {\n      queue.add('work');\n      const task = queue.next();\n      expect(task?.status).toBe('processing');\n    });\n\n    it('should return null when no tasks available', () => {\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should track pending task count', () => {\n      expect(queue.size()).toBe(0);\n      queue.add('a');\n      queue.add('b');\n      expect(queue.size()).toBe(2);\n      queue.next();\n      expect(queue.size()).toBe(1);\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 2: Named Queues\n  // ──────────────────────────────────────────────\n  describe('Phase 2: Named Queues', () => {\n    it('should add tasks to named queues', () => {\n      queue.add('email-task', { queue: 'email' });\n      queue.add('sms-task', { queue: 'sms' });\n\n      expect(queue.size('email')).toBe(1);\n      expect(queue.size('sms')).toBe(1);\n    });\n\n    it('should retrieve tasks from specific queue only', () => {\n      queue.add('email-task', { queue: 'email' });\n      queue.add('sms-task', { queue: 'sms' });\n\n      const task = queue.next('email');\n      expect(task?.payload).toBe('email-task');\n      expect(queue.next('email')).toBeNull();\n      expect(queue.size('sms')).toBe(1);\n    });\n\n    it('should use default queue when no name given', () => {\n      queue.add('default-task');\n      expect(queue.size()).toBe(1);\n      expect(queue.size('default')).toBe(1);\n    });\n\n    it('should list all queue names', () => {\n      queue.add('a', { queue: 'q1' });\n      queue.add('b', { queue: 'q2' });\n      const names = queue.listQueues();\n      expect(names).toContain('q1');\n      expect(names).toContain('q2');\n    });\n\n    it('should return null from non-existent queue', () => {\n      expect(queue.next('nonexistent')).toBeNull();\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 3: Priority\n  // ──────────────────────────────────────────────\n  describe('Phase 3: Priority', () => {\n    it('should process higher priority tasks first', () => {\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n      queue.add('medium', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('high');\n      expect(queue.next()?.payload).toBe('medium');\n      expect(queue.next()?.payload).toBe('low');\n    });\n\n    it('should default to priority 5', () => {\n      const task = queue.add('default');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      queue.add('first', { priority: 5 });\n      queue.add('second', { priority: 5 });\n      queue.add('third', { priority: 5 });\n\n      expect(queue.next()?.payload).toBe('first');\n      expect(queue.next()?.payload).toBe('second');\n      expect(queue.next()?.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => queue.add('x', { priority: 0 })).toThrow();\n      expect(() => queue.add('x', { priority: 11 })).toThrow();\n      expect(() => queue.add('x', { priority: 1.5 })).toThrow();\n    });\n\n    it('should expose priority on task object', () => {\n      const task = queue.add('x', { priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n\n    it('should handle priority per queue', () => {\n      queue.add('q1-low', { queue: 'q1', priority: 10 });\n      queue.add('q1-high', { queue: 'q1', priority: 1 });\n      queue.add('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(queue.next('q1')?.payload).toBe('q1-high');\n      expect(queue.next('q2')?.payload).toBe('q2-low');\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 4: Delayed Tasks\n  // ──────────────────────────────────────────────\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their available time', () => {\n      queue.add('delayed', { delay: 60000 });\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should return delayed tasks after their available time', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.add('ready', { availableAt: past });\n      const task = queue.next();\n      expect(task?.payload).toBe('ready');\n    });\n\n    it('should prefer non-delayed tasks', () => {\n      queue.add('delayed', { delay: 60000 });\n      queue.add('immediate');\n\n      const task = queue.next();\n      expect(task?.payload).toBe('immediate');\n    });\n\n    it('should expose availableAt on task', () => {\n      const task = queue.add('delayed', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should support specific future time', () => {\n      const future = new Date(Date.now() + 60000);\n      const task = queue.add('scheduled', { availableAt: future });\n      expect(task.availableAt).toEqual(future);\n      expect(queue.next()).toBeNull();\n    });\n\n    it('should order delayed tasks by availability, then priority, then FIFO', () => {\n      const past1 = new Date(Date.now() - 2000);\n      const past2 = new Date(Date.now() - 1000);\n\n      queue.add('later', { availableAt: past2, priority: 1 });\n      queue.add('earlier', { availableAt: past1, priority: 1 });\n\n      expect(queue.next()?.payload).toBe('earlier');\n      expect(queue.next()?.payload).toBe('later');\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 5: Retry with Backoff\n  // ──────────────────────────────────────────────\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      queue.complete(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should retry failed tasks with backoff', () => {\n      const task = queue.add('work', { maxRetries: 3, backoffDelay: 100 });\n      const retrieved = queue.next()!;\n      expect(retrieved.attempts).toBe(1);\n\n      queue.fail(retrieved.id, 'oops');\n      const failedTask = queue.getTask(task.id)!;\n      expect(failedTask.status).toBe('pending');\n      expect(failedTask.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should track attempt count', () => {\n      const task = queue.add('work', { maxRetries: 3, backoffDelay: 0 });\n\n      // Attempt 1\n      let t = queue.next()!;\n      expect(t.attempts).toBe(1);\n      queue.fail(t.id);\n\n      // The task is now pending but delayed - set availableAt to past for testing\n      const taskObj = queue.getTask(task.id)!;\n      taskObj.availableAt = new Date(Date.now() - 1000);\n\n      // Attempt 2\n      t = queue.next()!;\n      expect(t.attempts).toBe(2);\n      queue.fail(t.id);\n\n      taskObj.availableAt = new Date(Date.now() - 1000);\n\n      // Attempt 3\n      t = queue.next()!;\n      expect(t.attempts).toBe(3);\n      queue.fail(t.id);\n\n      // Should now be failed (exhausted retries)\n      expect(queue.getTask(task.id)?.status).toBe('failed');\n    });\n\n    it('should use exponential backoff delay', () => {\n      const task = queue.add('work', { maxRetries: 3, backoffDelay: 1000 });\n\n      // Attempt 1\n      const t = queue.next()!;\n      const beforeFail = Date.now();\n      queue.fail(t.id, 'err');\n\n      const taskObj = queue.getTask(task.id)!;\n      // First retry: 1000 * 2^0 = 1000ms\n      expect(taskObj.availableAt.getTime() - beforeFail).toBeGreaterThanOrEqual(900);\n      expect(taskObj.availableAt.getTime() - beforeFail).toBeLessThan(2000);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = queue.add('work', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      const t = queue.next('myq')!;\n      queue.fail(t.id);\n\n      const taskObj = queue.getTask(task.id)!;\n      expect(taskObj.queue).toBe('myq');\n      expect(taskObj.priority).toBe(2);\n    });\n\n    it('should default to 3 retries', () => {\n      const task = queue.add('work');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should throw when completing non-processing task', () => {\n      const task = queue.add('work');\n      expect(() => queue.complete(task.id)).toThrow();\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 6: Dead Letter Queue\n  // ──────────────────────────────────────────────\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move task to DLQ after all retries exhausted', () => {\n      const task = queue.add('work', { maxRetries: 1, backoffDelay: 0 });\n\n      const t = queue.next()!;\n      queue.fail(t.id, 'error1');\n\n      const dlqTasks = queue.getDeadLetterTasks();\n      expect(dlqTasks).toHaveLength(1);\n      expect(dlqTasks[0].id).toBe(task.id);\n      expect(dlqTasks[0].error).toBe('error1');\n    });\n\n    it('should retain error info in DLQ', () => {\n      const task = queue.add('work', { maxRetries: 1 });\n      const t = queue.next()!;\n      queue.fail(t.id, 'test error');\n\n      const dlq = queue.getDeadLetterTasks();\n      expect(dlq[0].error).toBe('test error');\n      expect(dlq[0].attempts).toBe(1);\n    });\n\n    it('should retry a dead-lettered task', () => {\n      queue.add('work', { maxRetries: 1, backoffDelay: 0 });\n      const t = queue.next()!;\n      queue.fail(t.id, 'err');\n\n      const retried = queue.retryDeadLetterTask(t.id);\n      expect(retried.status).toBe('pending');\n      expect(retried.attempts).toBe(0);\n      expect(retried.error).toBeUndefined();\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should clear dead letter queue', () => {\n      queue.add('work1', { maxRetries: 1 });\n      queue.add('work2', { maxRetries: 1 });\n\n      const t1 = queue.next()!;\n      queue.fail(t1.id, 'err');\n      const t2 = queue.next()!;\n      queue.fail(t2.id, 'err');\n\n      expect(queue.getDeadLetterTasks()).toHaveLength(2);\n      queue.clearDeadLetterQueue();\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should have independent DLQ per named queue', () => {\n      queue.add('q1-work', { queue: 'q1', maxRetries: 1 });\n      queue.add('q2-work', { queue: 'q2', maxRetries: 1 });\n\n      const t1 = queue.next('q1')!;\n      queue.fail(t1.id, 'err');\n      const t2 = queue.next('q2')!;\n      queue.fail(t2.id, 'err');\n\n      expect(queue.getDeadLetterTasks('q1')).toHaveLength(1);\n      expect(queue.getDeadLetterTasks('q2')).toHaveLength(1);\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 7: Task Dependencies\n  // ──────────────────────────────────────────────\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const t1 = queue.add('parent');\n      const t2 = queue.add('child', { dependencies: [t1.id] });\n\n      expect(t2.status).toBe('blocked');\n      // Should not return blocked tasks\n      const next = queue.next();\n      expect(next?.id).toBe(t1.id);\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const t1 = queue.add('parent');\n      const t2 = queue.add('child', { dependencies: [t1.id] });\n\n      const parent = queue.next()!;\n      queue.complete(parent.id);\n\n      expect(queue.getTask(t2.id)?.status).toBe('pending');\n      const child = queue.next();\n      expect(child?.payload).toBe('child');\n    });\n\n    it('should reject dependencies on non-existent tasks', () => {\n      expect(() => queue.add('child', { dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should keep dependents blocked when dependency fails', () => {\n      const t1 = queue.add('parent', { maxRetries: 1 });\n      const t2 = queue.add('child', { dependencies: [t1.id] });\n\n      const parent = queue.next()!;\n      queue.fail(parent.id, 'failed');\n\n      expect(queue.getTask(t2.id)?.status).toBe('blocked');\n    });\n\n    it('should support multiple dependencies', () => {\n      const t1 = queue.add('dep1');\n      const t2 = queue.add('dep2');\n      const t3 = queue.add('child', { dependencies: [t1.id, t2.id] });\n\n      const d1 = queue.next()!;\n      queue.complete(d1.id);\n\n      // Still blocked because t2 not complete\n      expect(queue.getTask(t3.id)?.status).toBe('blocked');\n\n      const d2 = queue.next()!;\n      queue.complete(d2.id);\n\n      // Now unblocked\n      expect(queue.getTask(t3.id)?.status).toBe('pending');\n    });\n\n    it('should expose dependency status', () => {\n      const t1 = queue.add('dep1');\n      const t2 = queue.add('child', { dependencies: [t1.id] });\n\n      const deps = queue.getDependencyStatus(t2.id);\n      expect(deps).toHaveLength(1);\n      expect(deps[0].taskId).toBe(t1.id);\n      expect(deps[0].resolved).toBe(false);\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 8: Concurrency Control\n  // ──────────────────────────────────────────────\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      queue.setConcurrency('default', 2);\n      queue.add('t1');\n      queue.add('t2');\n      queue.add('t3');\n\n      const r1 = queue.next();\n      const r2 = queue.next();\n      const r3 = queue.next();\n\n      expect(r1).not.toBeNull();\n      expect(r2).not.toBeNull();\n      expect(r3).toBeNull(); // Blocked by concurrency\n    });\n\n    it('should free slot on complete', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1');\n      queue.add('t2');\n\n      const r1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.complete(r1.id);\n      expect(queue.next()).not.toBeNull();\n    });\n\n    it('should free slot on fail', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1', { maxRetries: 1 });\n      queue.add('t2');\n\n      const r1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.fail(r1.id, 'err');\n      // t2 should now be available\n      const r2 = queue.next();\n      expect(r2?.payload).toBe('t2');\n    });\n\n    it('should default to unlimited concurrency', () => {\n      const conc = queue.getConcurrency();\n      expect(conc.limit).toBe(0);\n    });\n\n    it('should report concurrency status', () => {\n      queue.setConcurrency('default', 3);\n      queue.add('t1');\n      queue.add('t2');\n\n      queue.next();\n      queue.next();\n\n      const conc = queue.getConcurrency();\n      expect(conc.limit).toBe(3);\n      expect(conc.active).toBe(2);\n    });\n\n    it('should respect priority within concurrency limits', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('low', { priority: 10 });\n      queue.add('high', { priority: 1 });\n\n      const task = queue.next()!;\n      expect(task.payload).toBe('high');\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 9: Progress and Cancellation\n  // ──────────────────────────────────────────────\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report and query progress', () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      queue.reportProgress(task.id, 50, 'halfway');\n      const progress = queue.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      const updates: number[] = [];\n      queue.onProgress(task.id, (update) => {\n        updates.push(update.progress);\n      });\n\n      queue.reportProgress(task.id, 25);\n      queue.reportProgress(task.id, 75);\n\n      expect(updates).toEqual([25, 75]);\n    });\n\n    it('should support unsubscribing from progress', () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      const updates: number[] = [];\n      const unsubscribe = queue.onProgress(task.id, (update) => {\n        updates.push(update.progress);\n      });\n\n      queue.reportProgress(task.id, 25);\n      unsubscribe();\n      queue.reportProgress(task.id, 75);\n\n      expect(updates).toEqual([25]);\n    });\n\n    it('should reject invalid progress values', () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      expect(() => queue.reportProgress(task.id, -1)).toThrow();\n      expect(() => queue.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('should cancel pending tasks', () => {\n      const task = queue.add('work');\n      queue.cancel(task.id);\n\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n      expect(queue.next()).toBeNull();\n      expect(queue.size()).toBe(0);\n    });\n\n    it('should cancel processing tasks', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      queue.cancel(task.id);\n      expect(queue.getTask(task.id)?.status).toBe('cancelled');\n    });\n\n    it('should free concurrency slot on cancel of processing task', () => {\n      queue.setConcurrency('default', 1);\n      queue.add('t1');\n      queue.add('t2');\n\n      const t1 = queue.next()!;\n      expect(queue.next()).toBeNull();\n\n      queue.cancel(t1.id);\n      expect(queue.next()).not.toBeNull();\n    });\n\n    it('should not retry cancelled tasks', () => {\n      queue.add('work', { maxRetries: 3 });\n      const task = queue.next()!;\n      queue.cancel(task.id);\n\n      // Should not end up in DLQ either\n      expect(queue.getDeadLetterTasks()).toHaveLength(0);\n    });\n\n    it('should throw when cancelling completed tasks', () => {\n      queue.add('work');\n      const task = queue.next()!;\n      queue.complete(task.id);\n      expect(() => queue.cancel(task.id)).toThrow();\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 10: Recurring Tasks\n  // ──────────────────────────────────────────────\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = queue.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(schedule.id).toBeDefined();\n      expect(schedule.active).toBe(true);\n    });\n\n    it('should list active schedules', () => {\n      queue.addSchedule('*/5 * * * *', 'default', 'cleanup');\n      queue.addSchedule('0 * * * *', 'default', 'hourly');\n\n      expect(queue.listSchedules()).toHaveLength(2);\n    });\n\n    it('should remove a schedule', () => {\n      const schedule = queue.addSchedule('*/5 * * * *', 'default', 'cleanup');\n      queue.removeSchedule(schedule.id);\n\n      expect(queue.listSchedules()).toHaveLength(0);\n    });\n\n    it('should create tasks on tick when due', () => {\n      queue.addSchedule('*/5 * * * *', 'default', 'every5min');\n\n      // Tick at minute 0 (divisible by 5)\n      const now = new Date();\n      now.setMinutes(0, 0, 0);\n      const created = queue.tick(now);\n\n      expect(created).toHaveLength(1);\n      expect(created[0].payload).toBe('every5min');\n    });\n\n    it('should not create tasks when not due', () => {\n      queue.addSchedule('*/5 * * * *', 'default', 'every5min');\n\n      const now = new Date();\n      now.setMinutes(3, 0, 0); // Not divisible by 5\n      const created = queue.tick(now);\n\n      expect(created).toHaveLength(0);\n    });\n\n    it('should not duplicate on repeated tick at same time', () => {\n      queue.addSchedule('*/5 * * * *', 'default', 'every5min');\n\n      const now = new Date();\n      now.setMinutes(10, 0, 0);\n      queue.tick(now);\n      const second = queue.tick(now);\n\n      expect(second).toHaveLength(0);\n    });\n\n    it('should support hourly schedule', () => {\n      queue.addSchedule('0 * * * *', 'default', 'hourly');\n\n      const now = new Date();\n      now.setMinutes(0, 0, 0);\n      const created = queue.tick(now);\n\n      expect(created).toHaveLength(1);\n    });\n\n    it('should support daily midnight schedule', () => {\n      queue.addSchedule('0 0 * * *', 'default', 'daily');\n\n      const midnight = new Date();\n      midnight.setHours(0, 0, 0, 0);\n      const created = queue.tick(midnight);\n\n      expect(created).toHaveLength(1);\n\n      const noon = new Date();\n      noon.setHours(12, 0, 0, 0);\n      const notCreated = queue.tick(noon);\n\n      expect(notCreated).toHaveLength(0);\n    });\n\n    it('should stop creating tasks after schedule removal', () => {\n      const schedule = queue.addSchedule('*/5 * * * *', 'default', 'work');\n      queue.removeSchedule(schedule.id);\n\n      const now = new Date();\n      now.setMinutes(0, 0, 0);\n      const created = queue.tick(now);\n\n      expect(created).toHaveLength(0);\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 11: Middleware Pipeline\n  // ──────────────────────────────────────────────\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware in order', async () => {\n      const order: number[] = [];\n\n      queue.use('default', async (_task, next) => {\n        order.push(1);\n        await next();\n      });\n      queue.use('default', async (_task, next) => {\n        order.push(2);\n        await next();\n      });\n      queue.setHandler('default', async () => {\n        order.push(3);\n      });\n\n      queue.add('work');\n      await queue.process();\n\n      expect(order).toEqual([1, 2, 3]);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      queue.use('default', async (task, next) => {\n        (task as unknown as Record<string, unknown>).metadata = { modified: true };\n        await next();\n      });\n\n      let receivedTask: unknown;\n      queue.setHandler('default', async (task) => {\n        receivedTask = task;\n      });\n\n      queue.add('work');\n      await queue.process();\n\n      expect((receivedTask as Record<string, unknown>).metadata).toEqual({ modified: true });\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      let handlerCalled = false;\n\n      queue.use('default', async () => {\n        // Deliberately not calling next\n      });\n      queue.setHandler('default', async () => {\n        handlerCalled = true;\n      });\n\n      queue.add('work');\n      await queue.process();\n\n      expect(handlerCalled).toBe(false);\n    });\n\n    it('should fail task if middleware throws', async () => {\n      queue.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = queue.add('work', { maxRetries: 1 });\n      await queue.process();\n\n      const t = queue.getTask(task.id)!;\n      expect(t.status).toBe('failed');\n      expect(t.error).toBe('middleware error');\n    });\n\n    it('should auto-complete task after handler finishes', async () => {\n      queue.setHandler('default', async () => {\n        // do nothing\n      });\n\n      const task = queue.add('work');\n      await queue.process();\n\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should return null when no tasks to process', async () => {\n      const result = await queue.process();\n      expect(result).toBeNull();\n    });\n\n    it('should have independent middleware per queue', async () => {\n      const q1Order: string[] = [];\n      const q2Order: string[] = [];\n\n      queue.use('q1', async (_task, next) => {\n        q1Order.push('q1-middleware');\n        await next();\n      });\n      queue.use('q2', async (_task, next) => {\n        q2Order.push('q2-middleware');\n        await next();\n      });\n\n      queue.add('work1', { queue: 'q1' });\n      queue.add('work2', { queue: 'q2' });\n\n      await queue.process('q1');\n      await queue.process('q2');\n\n      expect(q1Order).toEqual(['q1-middleware']);\n      expect(q2Order).toEqual(['q2-middleware']);\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Phase 12: Graceful Shutdown\n  // ──────────────────────────────────────────────\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await queue.shutdown();\n      expect(() => queue.add('late')).toThrow('shutting down');\n    });\n\n    it('should complete immediately when no tasks processing', async () => {\n      const result = await queue.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.duration).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks', async () => {\n      queue.add('work');\n      const task = queue.next()!;\n\n      // Start shutdown\n      const shutdownPromise = queue.shutdown(5000);\n\n      // Complete the task\n      queue.complete(task.id);\n\n      const result = await shutdownPromise;\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force cancel after timeout', async () => {\n      queue.add('slow-work');\n      queue.next()!;\n\n      const result = await queue.shutdown(100);\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should return same result on multiple shutdown calls', async () => {\n      const r1 = queue.shutdown();\n      const r2 = queue.shutdown();\n\n      const result1 = await r1;\n      const result2 = await r2;\n\n      expect(result1).toBe(result2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let called = false;\n      queue.onShutdown(() => {\n        called = true;\n      });\n\n      await queue.shutdown();\n      expect(called).toBe(true);\n    });\n\n    it('should include duration in result', async () => {\n      const result = await queue.shutdown();\n      expect(typeof result.duration).toBe('number');\n    });\n  });\n\n  // ──────────────────────────────────────────────\n  // Cross-phase interaction tests\n  // ──────────────────────────────────────────────\n  describe('Cross-phase interactions', () => {\n    it('should handle priority + delay correctly', () => {\n      const past = new Date(Date.now() - 1000);\n      queue.add('delayed-high', { priority: 1, availableAt: past });\n      queue.add('immediate-low', { priority: 10 });\n\n      // Higher priority should still win\n      expect(queue.next()?.payload).toBe('delayed-high');\n    });\n\n    it('should handle dependencies + concurrency', () => {\n      queue.setConcurrency('default', 1);\n\n      const t1 = queue.add('parent');\n      queue.add('child', { dependencies: [t1.id] });\n\n      const parent = queue.next()!;\n      // Concurrency full, but also child is blocked\n      expect(queue.next()).toBeNull();\n\n      queue.complete(parent.id);\n      // Now child should be available\n      const child = queue.next();\n      expect(child?.payload).toBe('child');\n    });\n\n    it('should handle middleware + retry', async () => {\n      let attempts = 0;\n\n      queue.use('default', async (task, next) => {\n        attempts++;\n        await next();\n      });\n      queue.setHandler('default', async () => {\n        if (attempts < 2) throw new Error('not ready');\n      });\n\n      const task = queue.add('work', { maxRetries: 3, backoffDelay: 0 });\n      await queue.process();\n\n      // Task failed and was re-queued with delay\n      const t = queue.getTask(task.id)!;\n      expect(t.status).toBe('pending');\n\n      // Adjust availableAt for testing\n      t.availableAt = new Date(Date.now() - 1000);\n\n      await queue.process();\n      expect(queue.getTask(task.id)?.status).toBe('completed');\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
