--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,65 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled' | 'blocked';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  priority: number;
+  queue: string;
+  createdAt: Date;
+  updatedAt: Date;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  error?: string;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+}
+
+export interface TaskOptions {
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+  queue?: string;
+}
+
+export interface ProgressUpdate {
+  taskId: string;
+  progress: number;
+  message?: string;
+}
+
+export type ProgressListener = (update: ProgressUpdate) => void;
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'availableAt' | 'dependencies'>;
+  lastRun?: Date;
+  active: boolean;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFn = (task: Task) => Promise<void> | void;
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  duration: number;
+}
+
+export type ShutdownCallback = () => void | Promise<void>;
+
+export interface QueueState {
+  concurrencyLimit: number;
+  activeCount: number;
+  middlewares: MiddlewareFn[];
+  handler?: HandlerFn;
+}
