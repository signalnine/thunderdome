t: Snapshot | null; // snapshot of parent at fork time\n}\n\ntype SnapshotEntry = { content: object; deleted: boolean };\ntype Snapshot = Map<string, SnapshotEntry>;\n\nfunction clone<T>(obj: T): T {\n  return JSON.parse(JSON.stringify(obj));\n}\n\nlet versionCounter = 0;\nfunction generateVersionId(): string {\n  return `v_${++versionCounter}_${Date.now()}`;\n}\n\nfunction snapshotBranch(branch: BranchData): Snapshot {\n  const snap: Snapshot = new Map();\n  for (const [id, entry] of branch.documents) {\n    snap.set(id, { content: clone(entry.content), deleted: entry.deleted });\n  }\n  return snap;\n}\n\nfunction cloneSnapshot(snap: Snapshot): Snapshot {\n  const result: Snapshot = new Map();\n  for (const [id, entry] of snap) {\n    result.set(id, { content: clone(entry.content), deleted: entry.deleted });\n  }\n  return result;\n}\n\nfunction getAllKeys(...maps: Map<string, unknown>[]): Set<string> {\n  const keys = new Set<string>();\n  for (const m of maps) {\n    for (const k of m.keys()) {\n      keys.add(k);\n    }\n  }\n  return keys;\n}\n\nfunction isPlainObject(val: unknown): val is Record<string, unknown> {\n  return val !== null && typeof val === \"object\" && !Array.isArray(val);\n}\n\nfunction deepEqual(a: unknown, b: unknown): boolean {\n  if (a === b) return true;\n  if (a === null || b === null) return a === b;\n  if (typeof a !== typeof b) return false;\n  if (typeof a !== \"object\") return a === b;\n  if (Array.isArray(a) !== Array.isArray(b)) return false;\n  if (Array.isArray(a) && Array.isArray(b)) {\n    if (a.length !== b.length) return false;\n    for (let i = 0; i < a.length; i++) {\n      if (!deepEqual(a[i], b[i])) return false;\n    }\n    return true;\n  }\n  const aObj = a as Record<string, unknown>;\n  const bObj = b as Record<string, unknown>;\n  const aKeys = Object.keys(aObj);\n  const bKeys = Object.keys(bObj);\n  if (aKeys.length !== bKeys.length) return false;\n  for (const key of aKeys) {\n    if (!Object.prototype.hasOwnProperty.call(bObj, key)) return false;\n    if (!deepEqual(aObj[key], bObj[key])) return false;\n  }\n  return true;\n}\n\nfunction threeWayMerge(\n  base: unknown,\n  ours: unknown,\n  theirs: unknown,\n  path: string,\n  conflicts: Conflict[],\n  documentId: string\n): unknown {\n  if (deepEqual(ours, theirs)) {\n    return clone(ours);\n  }\n  if (deepEqual(base, ours)) {\n    return clone(theirs);\n  }\n  if (deepEqual(base, theirs)) {\n    return clone(ours);\n  }\n\n  // Both sides changed from base to different values\n  if (isPlainObject(base) && isPlainObject(ours) && isPlainObject(theirs)) {\n    const result: Record<string, unknown> = {};\n    const allKeys = new Set([\n      ...Object.keys(base),\n      ...Object.keys(ours),\n      ...Object.keys(theirs),\n    ]);\n\n    for (const key of allKeys) {\n      const subPath = path ? `${path}.${key}` : key;\n      const baseVal = Object.prototype.hasOwnProperty.call(base, key)\n        ? base[key]\n        : undefined;\n      const oursVal = Object.prototype.hasOwnProperty.call(ours, key)\n        ? ours[key]\n        : undefined;\n      const theirsVal = Object.prototype.hasOwnProperty.call(theirs, key)\n        ? theirs[key]\n        : undefined;\n\n      result[key] = threeWayMerge(\n        baseVal,\n        oursVal,\n        theirsVal,\n        subPath,\n        conflicts,\n        documentId\n      );\n    }\n    return result;\n  }\n\n  // Leaf conflict\n  conflicts.push({\n    documentId,\n    path,\n    base: clone(base),\n    ours: clone(ours),\n    theirs: clone(theirs),\n  });\n  return clone(ours);\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch = \"main\";\n  // Tracks merge-updated fork points between branch pairs\n  // Key: \"branchA<>branchB\" (sorted), Value: snapshot\n  private mergedAncestors: Map<string, Snapshot> = new Map();\n\n  constructor() {\n    this.branches.set(\"main\", {\n      documents: new Map(),\n      parent: null,\n      forkSnapshot: null,\n    });\n  }\n\n  private getBranchData(name?: string): BranchData {\n    const branchName = name ?? this.currentBranch;\n    const branch = this.branches.get(branchName);\n    if (!branch) {\n      throw new Error(`Branch \"${branchName}\" does not exist`);\n    }\n    return branch;\n  }\n\n  private pairKey(a: string, b: string): string {\n    return a < b ? `${a}<>${b}` : `${b}<>${a}`;\n  }\n\n  /**\n   * Find the common ancestor snapshot for two branches.\n   * Strategy:\n   * 1. Check if there's a merge-updated ancestor (from a previous merge).\n   * 2. If one is the direct parent of the other, use the fork snapshot.\n   * 3. If both share a common ancestor in the branch tree, compute the ancestor.\n   */\n  private findCommonAncestor(branchA: string, branchB: string): Snapshot {\n    // Check merge-updated ancestors first\n    const mergeKey = this.pairKey(branchA, branchB);\n    const mergedAnc = this.mergedAncestors.get(mergeKey);\n    if (mergedAnc) {\n      return mergedAnc;\n    }\n\n    // Check direct parent relationship\n    const dataA = this.getBranchData(branchA);\n    const dataB = this.getBranchData(branchB);\n\n    if (dataB.parent === branchA && dataB.forkSnapshot) {\n      return dataB.forkSnapshot;\n    }\n    if (dataA.parent === branchB && dataA.forkSnapshot) {\n      return dataA.forkSnapshot;\n    }\n\n    // Find common ancestor through parent chains\n    const ancestorsA = this.getAncestorChain(branchA);\n    const ancestorsB = this.getAncestorChain(branchB);\n\n    // Find the lowest common ancestor\n    for (const ancA of ancestorsA) {\n      for (const ancB of ancestorsB) {\n        if (ancA === ancB) {\n          // Both branches descend from ancA. The common ancestor state\n          // is the state of ancA when the first descendant was forked.\n          // We need the fork snapshot of the branch closest to the LCA.\n          const snapA = this.getForkSnapshotTowards(branchA, ancA);\n          const snapB = this.getForkSnapshotTowards(branchB, ancA);\n          if (snapA && snapB) {\n            // Use the earlier fork point — the state that both branches\n            // share. Since both forked from the same ancestor, the\n            // fork snapshot of the branch that forked earlier is the\n            // true common base.\n            // Actually, both fork snapshots capture the state of their\n            // parent at fork time. If A forked from LCA at time T1 and\n            // B forked from LCA at time T2 (T1 < T2), then:\n            // - snapA = LCA at T1\n            // - snapB = LCA at T2\n            // The common ancestor should be snapA (the earlier state)\n            // because A doesn't know about changes between T1 and T2.\n            // Wait: actually, A has the state of LCA at T1, and B has\n            // the state of LCA at T2. But they could have diverged\n            // differently. The TRUE common base is the state that both\n            // branches \"started\" from in common. That's the state at T1\n            // (the earlier fork), because:\n            // - Branch A started from LCA_T1\n            // - Branch B started from LCA_T2, which includes changes\n            //   after T1 that A doesn't have\n            // So the common base should be the fork snapshot of whichever\n            // branch forked first from the LCA path.\n            // Actually for the simple case where both are direct children\n            // of the same parent: use the earlier snapshot.\n            return snapA;\n          }\n          if (snapA) return snapA;\n          if (snapB) return snapB;\n          // Fallback: empty snapshot\n          return new Map();\n        }\n      }\n    }\n\n    // No common ancestor found — use empty snapshot\n    return new Map();\n  }\n\n  private getAncestorChain(branchName: string): string[] {\n    const chain: string[] = [];\n    let current: string | null = branchName;\n    const visited = new Set<string>();\n    while (current !== null) {\n      if (visited.has(current)) break;\n      visited.add(current);\n      chain.push(current);\n      const data = this.branches.get(current);\n      current = data?.parent ?? null;\n    }\n    return chain;\n  }\n\n  private getForkSnapshotTowards(\n    branchName: string,\n    ancestorName: string\n  ): Snapshot | null {\n    // Walk from branchName towards ancestorName, return the fork snapshot\n    // of the first branch in the chain that was forked from ancestorName\n    let current = branchName;\n    const visited = new Set<string>();\n    while (current !== ancestorName) {\n      if (visited.has(current)) return null;\n      visited.add(current);\n      const data = this.branches.get(current);\n      if (!data || !data.parent) return null;\n      if (data.parent === ancestorName) {\n        return data.forkSnapshot;\n      }\n      current = data.parent;\n    }\n    return null;\n  }\n\n  // --- Document CRUD ---\n\n  create(id: string, content: object): void {\n    const branch = this.getBranchData();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n    const cloned = clone(content);\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: clone(cloned),\n    };\n    branch.documents.set(id, {\n      content: cloned,\n      versions: existing?.deleted ? [...existing.versions, version] : [version],\n      deleted: false,\n    });\n  }\n\n  get(id: string): object {\n    const branch = this.getBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    return clone(entry.content);\n  }\n\n  update(id: string, content: object): void {\n    const branch = this.getBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    const cloned = clone(content);\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: clone(cloned),\n    };\n    entry.content = cloned;\n    entry.versions.push(version);\n  }\n\n  delete(id: string): void {\n    const branch = this.getBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry || entry.deleted) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    entry.deleted = true;\n  }\n\n  // --- Version History ---\n\n  getHistory(id: string): Version[] {\n    const branch = this.getBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    return clone(entry.versions);\n  }\n\n  getVersion(id: string, versionId: string): object {\n    const branch = this.getBranchData();\n    const entry = branch.documents.get(id);\n    if (!entry) {\n      throw new Error(`Document \"${id}\" does not exist`);\n    }\n    const version = entry.versions.find((v) => v.id === versionId);\n    if (!version) {\n      throw new Error(`Version \"${versionId}\" does not exist`);\n    }\n    return clone(version.content);\n  }\n\n  // --- Branching ---\n\n  createBranch(name: string, fromBranch?: string): void {\n    if (this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" already exists`);\n    }\n    const sourceName = fromBranch ?? this.currentBranch;\n    const source = this.getBranchData(sourceName);\n\n    const newDocs: Map<string, DocumentEntry> = new Map();\n    for (const [id, entry] of source.documents) {\n      newDocs.set(id, {\n        content: clone(entry.content),\n        versions: clone(entry.versions),\n        deleted: entry.deleted,\n      });\n    }\n    this.branches.set(name, {\n      documents: newDocs,\n      parent: sourceName,\n      forkSnapshot: snapshotBranch(source),\n    });\n  }\n\n  switchBranch(name: string): void {\n    if (!this.branches.has(name)) {\n      throw new Error(`Branch \"${name}\" does not exist`);\n    }\n    this.currentBranch = name;\n  }\n\n  getBranch(): string {\n    return this.currentBranch;\n  }\n\n  listBranches(): string[] {\n    return Array.from(this.branches.keys());\n  }\n\n  // --- Merging ---\n\n  merge(sourceBranch: string): MergeResult {\n    const targetName = this.currentBranch;\n    if (sourceBranch === targetName) {\n      throw new Error(\"Cannot merge a branch into itself\");\n    }\n\n    const source = this.getBranchData(sourceBranch);\n    const target = this.getBranchData(targetName);\n    const baseSnapshot = this.findCommonAncestor(targetName, sourceBranch);\n\n    const allDocIds = getAllKeys(\n      baseSnapshot,\n      source.documents,\n      target.documents\n    );\n\n    const merged: Record<string, object> = {};\n    const conflicts: Conflict[] = [];\n    let hasChanges = false;\n\n    for (const docId of allDocIds) {\n      const baseEntry = baseSnapshot.get(docId);\n      const sourceEntry = source.documents.get(docId);\n      const targetEntry = target.documents.get(docId);\n\n      const baseContent =\n        baseEntry && !baseEntry.deleted ? baseEntry.content : undefined;\n      const sourceContent =\n        sourceEntry && !sourceEntry.deleted\n          ? sourceEntry.content\n          : undefined;\n      const targetContent =\n        targetEntry && !targetEntry.deleted\n          ? targetEntry.content\n          : undefined;\n\n      const baseExists = baseContent !== undefined;\n      const sourceExists = sourceContent !== undefined;\n      const targetExists = targetContent !== undefined;\n\n      // No changes on either side\n      if (\n        deepEqual(baseContent, sourceContent) &&\n        deepEqual(baseContent, targetContent)\n      ) {\n        if (targetExists) {\n          merged[docId] = clone(targetContent) as object;\n        }\n        continue;\n      }\n\n      hasChanges = true;\n\n      // Source deleted, base existed\n      if (baseExists && !sourceExists) {\n        if (!targetExists || deepEqual(baseContent, targetContent)) {\n          continue; // accept deletion\n        }\n        // Target modified, source deleted\n        conflicts.push({\n          documentId: docId,\n          path: \"\",\n          base: clone(baseContent),\n          ours: clone(targetContent),\n          theirs: undefined,\n        });\n        merged[docId] = clone(targetContent) as object;\n        continue;\n      }\n\n      // Target deleted, base existed\n      if (baseExists && !targetExists) {\n        if (!sourceExists || deepEqual(baseContent, sourceContent)) {\n          continue; // keep deletion\n        }\n        // Source modified, target deleted\n        conflicts.push({\n          documentId: docId,\n          path: \"\",\n          base: clone(baseContent),\n          ours: undefined,\n          theirs: clone(sourceContent),\n        });\n        continue;\n      }\n\n      // New on source only\n      if (!baseExists && sourceExists && !targetExists) {\n        merged[docId] = clone(sourceContent) as object;\n        continue;\n      }\n\n      // New on target only\n      if (!baseExists && !sourceExists && targetExists) {\n        merged[docId] = clone(targetContent) as object;\n        continue;\n      }\n\n      // Created on both sides\n      if (!baseExists && sourceExists && targetExists) {\n        const mergedContent = threeWayMerge(\n          {},\n          targetContent,\n          sourceContent,\n          \"\",\n          conflicts,\n          docId\n        );\n        merged[docId] = mergedContent as object;\n        continue;\n      }\n\n      // Both exist with base: three-way merge\n      const mergedContent = threeWayMerge(\n        baseContent ?? {},\n        targetContent ?? {},\n        sourceContent ?? {},\n        \"\",\n        conflicts,\n        docId\n      );\n      merged[docId] = mergedContent as object;\n    }\n\n    const applied = conflicts.length === 0 && hasChanges;\n\n    if (applied) {\n      for (const docId of allDocIds) {\n        if (docId in merged) {\n          const targetEntry = target.documents.get(docId);\n          const mergedContent = clone(merged[docId]);\n          if (targetEntry && !targetEntry.deleted) {\n            if (!deepEqual(targetEntry.content, mergedContent)) {\n              const version: Version = {\n                id: generateVersionId(),\n                timestamp: Date.now(),\n                content: clone(mergedContent),\n              };\n              targetEntry.content = mergedContent;\n              targetEntry.versions.push(version);\n            }\n          } else if (targetEntry && targetEntry.deleted) {\n            const version: Version = {\n              id: generateVersionId(),\n              timestamp: Date.now(),\n              content: clone(mergedContent),\n            };\n            targetEntry.content = mergedContent;\n            targetEntry.deleted = false;\n            targetEntry.versions.push(version);\n          } else {\n            const version: Version = {\n              id: generateVersionId(),\n              timestamp: Date.now(),\n              content: clone(mergedContent),\n            };\n            target.documents.set(docId, {\n              content: mergedContent,\n              versions: [version],\n              deleted: false,\n            });\n          }\n        } else {\n          const targetEntry = target.documents.get(docId);\n          if (targetEntry && !targetEntry.deleted) {\n            targetEntry.deleted = true;\n          }\n        }\n      }\n    }\n\n    // Update the ancestor for future merges between these branches\n    const pairKey = this.pairKey(targetName, sourceBranch);\n    if (conflicts.length === 0) {\n      // After a successful merge (or no-op), update the common ancestor\n      // to the current state of both branches (they should 