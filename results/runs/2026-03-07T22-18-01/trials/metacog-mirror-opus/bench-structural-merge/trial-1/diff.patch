.prototype.hasOwnProperty.call(theirs, key)\n        ? theirs[key]\n        : undefined;\n\n      result[key] = threeWayMerge(\n        baseVal,\n        oursVal,\n        theirsVal,\n        subPath,\n        conflicts,\n        documentId\n      );\n    }\n    return result;\n  }\n\n  // Leaf conflict: both sides changed a non-object field differently\n  conflicts.push({\n    documentId,\n    path,\n    base: clone(base),\n    ours: clone(ours),\n    theirs: clone(theirs),\n  });\n  // Resolve in favor of \"ours\" for the merged preview\n  return clone(ours);\n}\n\nexport class DocumentStore {\n  private branches: Map<string, BranchData> = new Map();\n  private currentBranch: string = \"main\";\n  // forkPoints[childBranch][parentBranch] = snapshot of parent at fork time\n  // We also track the reverse for merging: when merging source into target,\n  // we need the common ancestor.\n  // Key: \"target<-source\" or \"source<-target\", Value: snapshot\n  private forkPoints: Map<string, Snapshot> = new Map();\n\n  constructor() {\n    this.branches.set(\"main\", { documents: new Map() });\n  }\n\n  private getBranchData(name?: string): BranchData {\n    const branchName = name ?? this.currentBranch;\n    const branch = this.branches.get(branchName);\n    if (!branch) {\n      throw new Error(`Branch \"${branchName}\" does not exist`);\n    }\n    return branch;\n  }\n\n  private forkPointKey(a: string, b: string): string {\n    // Canonical key: sorted alphabetically\n    return a < b ? `${a}<>${b}` : `${b}<>${a}`;\n  }\n\n  // --- Document CRUD ---\n\n  create(id: string, content: object): void {\n    const branch = this.getBranchData();\n    const existing = branch.documents.get(id);\n    if (existing && !existing.deleted) {\n      throw new Error(`Document \"${id}\" already exists`);\n    }\n    const cloned = clone(content);\n    const version: Version = {\n      id: generateVersionId(),\n      timestamp: Date.now(),\n      content: clone(cloned),\n    };\n    br