event \"${e.id}\" is a prerequisite of itself`);\n        }\n        if (eventIds.has(prereq)) {\n          adjList.get(prereq)!.push(e.id);\n          inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);\n        }\n      }\n    }\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const sorted: string[] = [];\n  while (queue.length > 0) {\n    const node = queue.shift()!;\n    sorted.push(node);\n    for (const neighbor of adjList.get(node) ?? []) {\n      const newDeg = (inDegree.get(neighbor) ?? 1) - 1;\n      inDegree.set(neighbor, newDeg);\n      if (newDeg === 0) queue.push(neighbor);\n    }\n  }\n\n  if (sorted.length !== events.length) {\n    throw new Error('Cycle detected in prerequisite graph');\n  }\n\n  return sorted;\n}\n\n/**\n * Find the earliest start time for an event in a given room,\n * considering existing assignments and prerequisite constraints.\n */\nfunction findEarliestStart(\n  event: Event,\n  room: Room,\n  assignments: Assignment[],\n  eventMap: Map<string, Event>,\n  options: ScheduleOptions,\n  gap: number,\n): number | null {\n  const attendees = event.attendees ?? 1;\n  if (attendees > room.capacity) return null;\n\n  let earliest = options.startTime;\n\n  // Respect prerequisite ordering: must start after all prereqs finish + gap\n  if (event.prerequisites) {\n    for (const prereqId of event.prerequisites) {\n      const prereqAssignment = assignments.find(a => a.eventId === prereqId);\n      if (prereqAssignment) {\n        earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n      }\n      // If prereq exists in eventMap but isn't scheduled, we can't schedule this event\n      if (eventMap.has(prereqId) && !prereqAssignment) {\n        return null;\n      }\n    }\n  }\n\n  // Must fit within time window\n  if (earliest + event.duration > options.endTime) return null;\n\n  // Find room assignments sorted by start time\n  const roomAssignments = assignments\n    .filter(a => a.roomId === room.id)\n    .sort((a, b) => a.startTime - b.startTime);\n\n  if (roomAssignments.length === 0) {\n    return earliest;\n  }\n\n  // Try to fit before the first room assignment\n  if (earliest + event.duration + gap <= roomAssignments[0].startTime) {\n    return earliest;\n  }\n\n  // Try to fit between existing assignments\n  for (let i = 0; i < roomAssignments.length; i++) {\n    const slotStart = Math.max(earliest, roomAssignments[i].endTime + gap);\n    const nextStart = i + 1 < roomAssignments.length\n      ? roomAssignments[i + 1].startTime\n      : options.endTime + gap; // no next event, just need to fit before endTime\n\n    if (slotStart + event.duration <= Math.min(nextStart - gap, options.endTime) ||\n        (i + 1 >= roomAssignments.length && slotStart + event.duration <= options.endTime)) {\n      // Check gap with next assignment if it exists\n      if (i + 1 < roomAssignments.length) {\n        if (slotStart + event.duration + gap <= roomAssignments[i + 1].startTime) {\n          return slotStart;\n        }\n      } else {\n        return slotStart;\n      }\n    }\n  }\n\n  return null;\n}\n\n/**\n * Count available time slots remaining in a room after a hypothetical placement.\n * Higher = more future flexibility.\n */\nfunction countRemainingCapacity(\n  room: Room,\n  assignments: Assignment[],\n  options: ScheduleOptions,\n  gap: number,\n): number {\n  const roomAssignments = assignments\n    .filter(a => a.roomId === room.id)\n    .sort((a, b) => a.startTime - b.startTime);\n\n  let totalFree = 0;\n  let cursor = options.startTime;\n\n  for (const a of roomAssignments) {\n    totalFree += Math.max(0, a.startTime - cursor - gap);\n    cursor = a.endTime;\n  }\n  totalFree += Math.max(0, options.endTime - cursor);\n\n  return totalFree;\n}\n\n/**\n * Constraint-based event scheduler.\n * Uses topological sort, constraint-density ordering, and backtracking\n * to maximize the number of events scheduled.\n */\nexport function schedule(\n  events: Event[],\n  rooms: Room[],\n  options: ScheduleOptions,\n): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n  const eventMap = new Map<string, Event>();\n  for (const e of events) {\n    eventMap.set(e.id, e);\n  }\n\n  // Cycle detection via topological sort (throws on cycles)\n  const topoOrder = topologicalSort(events);\n  const topoIndex = new Map<string, number>();\n  topoOrder.forEach((id, idx) => topoIndex.set(id, idx));\n\n  // Compute constraint density for each event\n  const validRoomCount = new Map<string, number>();\n  for (const e of events) {\n    const attendees = e.attendees ?? 1;\n    const count = rooms.filter(r => r.capacity >= attendees).length;\n    validRoomCount.set(e.id, count);\n  }\n\n  // Sort events: topological order first, then by constraint density\n  // (fewer valid rooms = more constrained = schedule first)\n  const sortedEventIds = [...topoOrder].sort((a, b) => {\n    const topoA = topoIndex.get(a)!;\n    const topoB = topoIndex.get(b)!;\n    // Must respect topological order for prerequisites\n    if (topoA !== topoB) return topoA - topoB;\n    // More constrained first\n    const roomsA = validRoomCount.get(a)!;\n    const roomsB = validRoomCount.get(b)!;\n    if (roomsA !== roomsB) return roomsA - roomsB;\n    // Larger events first (harder to place)\n    const evA = eventMap.get(a)!;\n    const evB = eventMap.get(b)!;\n    return evB.duration - evA.duration;\n  });\n\n  // Try scheduling with backtracking to maximize placed events\n  const result = backtrackSchedule(\n    sortedEventIds,\n    eventMap,\n    rooms,\n    options,\n    gap,\n    validRoomCount,\n  );\n\n  return result;\n}\n\ninterface Placement {\n  eventId: string;\n  roomId: string;\n  startTime: number;\n  endTime: number;\n}\n\n/**\n * Backtracking scheduler that tries to maximize events placed.\n */\nfunction backtrackSchedule(\n  eventIds: string[],\n  eventMap: Map<string, Event>,\n  rooms: Room[],\n  options: ScheduleOptions,\n  gap: number,\n  validRoomCount: Map<string, number>,\n): ScheduleResult {\n  const bestResult = { assignments: [] as Assignment[], unscheduled: [] as string[] };\n\n  // For each event, compute possible room+time placements\n  function getPlacements(\n    eventId: string,\n    currentAssignments: Assignment[],\n  ): Placement[] {\n    const event = eventMap.get(eventId)!;\n    const placements: Placement[] = [];\n\n    // Sort rooms: preferred room first, then by remaining capacity (most flexible)\n    const sortedRooms = [...rooms].sort((a, b) => {\n      if (event.preferredRoom === a.id && event.preferredRoom !== b.id) return -1;\n      if (event.preferredRoom === b.id && event.preferredRoom !== a.id) return 1;\n      // prefer room with more remaining capacity (to leave constrained rooms for constrained events)\n      const capA = countRemainingCapacity(a, currentAssignments, options, gap);\n      const capB = countRemainingCapacity(b, currentAssignments, options, gap);\n      return capB - capA;\n    });\n\n    for (const room of sortedRooms) {\n      const startTime = findEarliestStart(event, room, currentAssignments, eventMap, options, gap);\n      if (startTime !== null) {\n        placements.push({\n          eventId,\n          roomId: room.id,\n          startTime,\n          endTime: startTime + event.duration,\n        });\n      }\n    }\n\n    return placements;\n  }\n\n  // Use iterative deepening / recursive backtracking with pruning\n  let bestCount = 0;\n\n  function solve(\n    index: number,\n    currentAssignments: Assignment[],\n    scheduledCount: number,\n    skippedIds: string[],\n  ): boolean {\n    if (index >= eventIds.length) {\n      if (scheduledCount > bestCount) {\n        bestCount = scheduledCount;\n        bestResult.assignments = [...currentAssignments];\n        bestResult.unscheduled = [...skippedIds];\n        return scheduledCount === eventIds.length; // perfect solution found\n      }\n      return false;\n    }\n\n    // Pruning: even if we schedule all remaining events, can't beat best?\n    const remaining = eventIds.length - index;\n    if (scheduledCount + remaining <= bestCount) {\n      return false;\n    }\n\n    const eventId = eventIds[index];\n    const event = eventMap.get(eventId)!;\n\n    // Check if prerequisites are met\n    const prereqsMet = !event.prerequisites || event.prerequisites.every(pId => {\n      if (!eventMap.has(pId)) return true; // external prereq, ignore\n      return currentAssignments.some(a => a.eventId === pId);\n    });\n\n    if (!prereqsMet) {\n      // Can't schedule this event, skip it\n      skippedIds.push(eventId);\n      const result = solve(index + 1, currentAssignments, scheduledCount, skippedIds);\n      if (!result) skippedIds.pop();\n      return result;\n    }\n\n    const placements = getPlacements(eventId, currentAssignments);\n\n    // Try each placement\n    for (const placement of placements) {\n      const assignment: Assignment = {\n        eventId: placement.eventId,\n        roomId: placement.roomId,\n        startTime: placement.startTime,\n        endTime: placement.endTime,\n      };\n      currentAssignments.push(assignment);\n      if (solve(index + 1, currentAssignments, scheduledCount + 1, skippedIds)) {\n        return true;\n      }\n      currentAssignments.pop();\n    }\n\n    // Try skipping this event\n    skippedIds.push(eventId);\n    const result = solve(index + 1, currentAssignments, scheduledCount, skippedIds);\n    if (!result) skippedIds.pop();\n    return result;\n  }\n\n  // First, do a greedy pass to establish a baseline\n  const greedyAssignments: Assignment[] = [];\n  const greedyUnscheduled: string[] = [];\n\n  for (const eventId of eventIds) {\n    const placements = getPlacements(eventId, greedyAssignments);\n    if (placements.length > 0) {\n      const p = placements[0];\n      greedyAssignm