+  timestamp: number;
+  content: object;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: unknown;
+  ours: unknown;
+  theirs: unknown;
+}
+
+// ── Utilities ────────────────────────────────────────────────────────────────
+
+function deepClone<T>(value: T): T {
+  if (value === null || typeof value !== "object") return value;
+  if (Array.isArray(value)) return value.map((v) => deepClone(v)) as T;
+  const result: Record<string, unknown> = {};
+  for (const key of Object.keys(value as Record<string, unknown>)) {
+    result[key] = deepClone((value as Record<string, unknown>)[key]);
+  }
+  return result as T;
+}
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (a === null || b === null) return false;
+  if (typeof a !== typeof b) return false;
+  if (typeof a !== "object") return false;
+  if (Array.isArray(a) !== Array.isArray(b)) return false;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    if (a.length !== b.length) return false;
+    return a.every((val, i) => deepEqual(val, b[i]));
+  }
+  const aObj = a as Record<string, unknown>;
+  const bObj = b as Record<string, unknown>;
+  const aKeys = Object.keys(aObj);
+  const bKeys = Object.keys(bObj);
+  if (aKeys.length !== bKeys.length) return false;
+  return aKeys.every((key) => key in bObj && deepEqual(aObj[key], bObj[key]));
+}
+
+let versionCounter = 0;
+
+function generateVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+// ── Internal structures ──────────────────────────────────────────────────────
+
+interface DocRecord {
+  content: object;
+  deleted: boolean;
+  versions: Version[];
+}
+
+interface BranchState {
+  docs: Map<string, DocRecord>;
+  /** Name of the branch this was forked from + snapshot of docs at fork time */
+  parentBranch: string | null;
+  forkPoint: Map<string, DocRecord> | null;
+}
+
+function cloneDocRecord(rec: DocRecord): DocRecord {
+  return {
+    content: deepClone(rec.content),
+    deleted: rec.deleted,
+    versions: rec.versions.map((v) => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+  };
+}
+
+function cloneDocs(docs: Map<string, DocRecord>): Map<string, DocRecord> {
+  const result = new Map<string, DocRecord>();
+  for (const [id, rec] of docs) {
+    result.set(id, cloneDocRecord(rec));
+  }
+  return result;
+}
+
+// ── Three-way merge logic ────────────────────────────────────────────────────
+
+/**
+ * Collect all leaf paths that differ between two objects.
+ * Returns a set of dot-separated paths.
+ */
+function diffPaths(
+  base: Record<string, unknown> | undefined,
+  obj: Record<string, unknown> | undefined,
+  prefix: string,
+): string[] {
+  const paths: string[] = [];
+  const baseObj = base ?? {};
+  const curObj = obj ?? {};
+  const allKeys = new Set([...Object.keys(baseObj), ...Object.keys(curObj)]);
+
+  for (const key of allKeys) {
+    const p = prefix ? `${prefix}.${key}` : key;
+    const bVal = baseObj[key];
+    const oVal = curObj[key];
+
+    if (deepEqual(bVal, oVal)) continue;
+
+    // If both are plain objects (not arrays, not null), recurse
+    if (
+      bVal !== null &&
+      oVal !== null &&
+      typeof bVal === "object" &&
+      typeof oVal === "object" &&
+      !Array.isArray(bVal) &&
+      !Array.isArray(oVal)
+    ) {
+      paths.push(
+        ...diffPaths(
+          bVal as Record<string, unknown>,
+          oVal as Record<string, unknown>,
+          p,
+        ),
+      );
+    } else {
+      paths.push(p);
+    }
+  }
+  return paths;
+}
+
+function getAtPath(obj: Record<string, unknown>, path: string): unknown {
+  const parts = path.split(".");
+  let cur: unknown = obj;
+  for (const part of parts) {
+    if (cur === null || cur === undefined || typeof cur !== "object") {
+      return undefined;
+    }
+    cur = (cur as Record<string, unknown>)[part];
+  }
+  return cur;
+}
+
+function setAtPath(
+  obj: Record<string, unknown>,
+  path: string,
+  value: unknown,
+): void {
+  const parts = path.split(".");
+  let cur: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (
+      !(parts[i] in cur) ||
+      cur[parts[i]] === null ||
+      typeof cur[parts[i]] !== "object" ||
+      Array.isArray(cur[parts[i]])
+    ) {
+      cur[parts[i]] = {};
+    }
+    cur = cur[parts[i]] as Record<string, unknown>;
+  }
+  cur[parts[parts.length - 1]] = value;
+}
+
+function deleteAtPath(obj: Record<string, unknown>, path: string): void {
+  const parts = path.split(".");
+  let cur: Record<string, unknown> = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (
+      !(parts[i] in cur) ||
+      cur[parts[i]] === null ||
+      typeof cur[parts[i]] !== "object"
+    ) {
+      return;
+    }
+    cur = cur[parts[i]] as Record<string, unknown>;
+  }
+  delete cur[parts[parts.length - 1]];
+}
+
+function threeWayMergeDoc(
+  base: Record<string, unknown> | undefined,
+  ours: Record<string, unknown> | undefined,
+  theirs: Record<string, unknown> | undefined,
+  docId: string,
+): { merged: Record<string, unknown>; conflicts: Conflict[] } {
+  const ourChanges = diffPaths(base, ours, "");
+  const theirChanges = diffPaths(base, theirs, "");
+
+  const conflicts: Conflict[] = [];
+  const allChangedPaths = new Set([...ourChanges, ...theirChanges]);
+
+  // Start from a clone of base (or empty if no base)
+  const merged = deepClone(base ?? {}) as Record<string, unknown>;
+
+  for (const path of allChangedPaths) {
+    const baseVal = base ? getAtPath(base, path) : undefined;
+    const ourVal = ours ? getAtPath(ours, path) : undefined;
+    const theirVal = theirs ? getAtPath(theirs, path) : undefined;
+
+    const ourChanged = !deepEqual(baseVal, ourVal);
+    const theirChanged = !deepEqual(baseVal, theirVal);
+
+    if (ourChanged && theirChanged) {
+      if (deepEqual(ourVal, theirVal)) {
+        // Both changed to same value — no conflict
+        if (ourVal === undefined) {
+          deleteAtPath(merged, path);
+        } else {
+          setAtPath(merged, path, deepClone(ourVal));
+        }
+      } else {
+        // Conflict — use "ours" for merged preview
+        conflicts.push({
+          documentId: docId,
+          path,
+          base: deepClone(baseVal),
+          ours: deepClone(ourVal),
+          theirs: deepClone(theirVal),
+        });
+        if (ourVal === undefined) {
+          deleteAtPath(merged, path);
+        } else {
+          setAtPath(merged, path, deepClone(ourVal));
+        }
+      }
+    } else if (ourChanged) {
+      if (ourVal === undefined) {
+        deleteAtPath(merged, path);
+      } else {
+        setAtPath(merged, path, deepClone(ourVal));
+      }
+    } else if (theirChanged) {
+      if (theirVal === undefined) {
+        deleteAtPath(merged, path);
+      } else {
+        setAtPath(merged, path, deepClone(theirVal));
+      }
+    }
+  }
+
+  return { merged, conflicts };
+}
+
+// ── DocumentStore ────────────────────────────────────────────────────────────
+
+export class DocumentStore {
+  private branches: Map<string, BranchState> = new Map();
+  private currentBranch: string = "main";
+
+  constructor() {
+    this.branches.set("main", {
+      docs: new Map(),
+      parentBranch: null,
+      forkPoint: null,
+    });
+  }
+
+  // ── helpers ──────────────────────────────────────────────────────────────
+
+  private branch(): BranchState {
+    return this.branches.get(this.currentBranch)!;
+  }
+
+  // ── CRUD ─────────────────────────────────────────────────────────────────
+
+  create(id: string, content: object): void {
+    const br = this.branch();
+    const existing = br.docs.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const cloned = deepClone(content);
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(cloned),
+    };
+    br.docs.set(id, {
+      content: cloned,
+      deleted: false,
+      versions: existing ? [...existing.versions, version] : [version],
+    });
+  }
+
+  get(id: string): object {
+    const br = this.branch();
+    const doc = br.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return deepClone(doc.content);
+  }
+
+  update(id: string, content: object): void {
+    const br = this.branch();
+    const doc = br.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const cloned = deepClone(content);
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(cloned),
+    };
+    doc.content = cloned;
+    doc.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const br = this.branch();
+    const doc = br.docs.get(id);
+    if (!doc || doc.deleted) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    doc.deleted = true;
+    doc.content = {};
+  }
+
+  // ── Version history ──────────────────────────────────────────────────────
+
+  getHistory(id: string): Version[] {
+    const br = this.branch();
+    const doc = br.docs.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    return doc.versions.map((v) => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const br = this.branch();
+    const doc = br.docs.get(id);
+    if (!doc) {
+      throw new Error(`Document "${id}" not found`);
+    }
+    const version = doc.versions.find((v) => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" not found for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  // ── Branching ────────────────────────────────────────────────────────────
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.branches.get(sourceName);
+    if (!source) {
+      throw new Error(`Branch "${sourceName}" not found`);
+    }
+    this.branches.set(name, {
+      docs: cloneDocs(source.docs),
+      parentBranch: sourceName,
+      forkPoint: cloneDocs(source.docs),
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" not found`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return [...this.branches.keys()];
+  }
+
+  // ── Merging ──────────────────────────────────────────────────────────────
+
+  merge(sourceBranch: string): MergeResult {
+    const source = this.branches.get(sourceBranch);
+    if (!source) {
+      throw new Error(`Branch "${sourceBranch}" not found`);
+    }
+
+    const target = this.branch();
+
+    // Determine common ancestor (base).
+    // The base is the fork point of the source branch if the source was
+    // branched from the current branch, or vice versa.
+    const base = this.findCommonAncestor(sourceBranch, this.currentBranch);
+
+    // Gather all document IDs across base, source, and target
+    const allDocIds = new Set<string>();
+    if (base) for (const id of base.keys()) allDocIds.add(id);
+    for (const id of source.docs.keys()) allDocIds.add(id);
+    for (const id of target.docs.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseRec = base?.get(docId);
+      const oursRec = target.docs.get(docId);
+      const theirsRec = source.docs.get(docId);
+
+      // Determine effective content (undefined if deleted or never existed)
+      const baseContent =
+        baseRec && !baseRec.deleted
+          ? (baseRec.content as Record<string, unknown>)
+          : undefined;
+      const oursContent =
+        oursRec && !oursRec.deleted
+          ? (oursRec.content as Record<string, unknown>)
+          : undefined;
+      const theirsContent =
+        theirsRec && !theirsRec.deleted
+          ? (theirsRec.content as Record<string, unknown>)
+          : undefined;
+
+      // If nothing changed from base on either side, skip
+      const oursChanged = !deepEqual(baseContent, oursContent);
+      const theirsChanged = !deepEqual(baseContent, theirsContent);
+
+      if (!oursChanged && !theirsChanged) {
+        // No changes — keep current state (fast-forward / no-op)
+        if (oursContent !== undefined) {
+          merged[docId] = deepClone(oursContent) as object;
+        }
+        continue;
+      }
+
+      // If only one side changed the document at a high level
+      if (!oursChanged && theirsChanged) {
+        // Take theirs entirely
+        if (theirsContent !== undefined) {
+          merged[docId] = deepClone(theirsContent) as object;
+        }
+        // If theirs deleted it, don't include in merged
+        continue;
+      }
+
+      if (oursChanged && !theirsChanged) {
+        // Keep ours
+        if (oursContent !== undefined) {
+          merged[docId] = deepClone(oursContent) as object;
+        }
+        continue;
+      }
+
+      // Both sides changed — need field-level merge
+      // Handle document-level deletion cases
+      if (oursContent === undefined && theirsContent === undefined) {
+        // Both deleted — no conflict, document stays deleted
+        continue;
+      }
+
+      if (oursContent === undefined || theirsContent === undefined) {
+        // One deleted, other modified — conflict at document level
+        // For the merged preview, use ours
+        if (oursContent !== undefined) {
+          merged[docId] = deepClone(oursContent) as object;
+        }
+        // We could report this as a top-level conflict; treat deletion vs modification as conflict
+        conflicts.push({
+          documentId: docId,
+          path: "",
+          base: baseContent !== undefined ? deepClone(baseContent) : undefined,
+          ours:
+            oursContent !== undefined ? deepClone(oursContent) : undefined,
+          theirs:
+            theirsContent !== undefined ? deepClone(theirsContent) : undefined,
+        });
+        continue;
+      }
+
+      // Both sides modified — three-way field merge
+      const result = threeWayMergeDoc(
+        baseContent,
+        oursContent,
+        theirsContent,
+        docId,
+      );
+      merged[docId] = result.merged as object;
+      conflicts.push(...result.conflicts);
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      // Apply merge to current branch
+      for (const docId of allDocIds) {
+        if (docId in merged) {
+          const existing = target.docs.get(docId);
+          const newContent = deepClone(merged[docId]) as object;
+          if (existing && !existing.deleted) {
+            // Check if content actually changed
+            if (!deepEqual(existing.content, newContent)) {
+              const version: Version = {
+                id: generateVersionId(),
+                timestamp: Date.now(),
+                content: deepClone(newContent),
+              };
+              existing.content = newContent;
+              existing.versions.push(version);
+            }
+          } else if (existing && existing.deleted) {
+            // Re-create
+            const version: Version = {
+              id: generateVersionId(),
+              timestamp: Date.now(),
+              content: deepClone(newContent),
+            };
+            existing.content = newContent;
+            existing.deleted = false;
+            existing.versions.push(version);
+          } else {
+            // New doc from source branch
+            const version: Version = {
+              id: generateVersionId(),
+              timestamp: Date.now(),
+              content: deepClone(newContent),
+            };
+            target.docs.set(docId, {
+              content: newContent,
+              deleted: false,
+              versions: [version],
+            });
+          }
+        } else {
+          // Document was deleted in the merge
+          const existing = target.docs.get(docId);
+          if (existing && !existing.deleted) {
+            existing.deleted = true;
+            existing.content = {};
+          }
+        }
+      }
+
+      // Update fork point of source branch to reflect current state
+      // so subsequent merges have the right base
+      source.forkPoint = cloneDocs(target.docs);
+      source.parentBranch = this.currentBranch;
+    }
+
+    return { merged, conflicts, applied };
+  }
+
+  private findCommonAncestor(
+    branchA: string,
+    branchB: string,
+  ): Map<string, DocRecord> | null {
+    const a = this.branches.get(branchA)!;
+    const b = this.branches.get(branchB)!;
+
+    // If A was forked from B, the common ancestor is A's fork point
+    if (a.parentBranch === branchB && a.forkPoint) {
+      return a.forkPoint;
+    }
+    // If B was forked from A, the common ancestor is B's fork point
+    if (b.parentBranch === branchA && b.forkPoint) {
+      return b.forkPoint;
+    }
+    // If both share a common parent, we need to find it
+    // For simplicity, walk up A's parents to find common ground
+    if (a.parentBranch && a.parentBranch === b.parentBranch) {
+      // Both forked from the same branch — use the earlier fork point
+      // In practice, use A's fork point since that's the source being merged
+      return a.forkPoint;
+    }
+
+    // Fallback: empty base (treat as if no common history)
+    return new Map();
+  }
+}
