nst bKeys = Object.keys(bObj);\n  if (aKeys.length !== bKeys.length) return false;\n  return aKeys.every((key) => key in bObj && deepEqual(aObj[key], bObj[key]));\n}\n\nlet versionCounter = 0;\n\nfunction generateVersionId(): string {\n  return `v_${++versionCounter}_${Date.now()}`;\n}\n\n// ── Internal structures ──────────────────────────────────────────────────────\n\ninterface DocRecord {\n  content: object;\n  deleted: boolean;\n  versions: Version[];\n}\n\ninterface BranchState {\n  docs: Map<string, DocRecord>;\n  /** Name of the branch this was forked from + snapshot of docs at fork time */\n  parentBranch: string | null;\n  forkPoint: Map<string, DocRecord> | null;\n}\n\nfunction cloneDocRecord(rec: DocRecord): DocRecord {\n  return {\n    content: deepClone(rec.content),\n    deleted: rec.deleted,\n    versions: rec.versions.map((v) => ({\n      id: v.id,\n      timestamp: v.timestamp,\n      content: deepClone(v.content),\n    })),\n  };\n}\n\nfunction cloneDocs(docs: Map<string, DocRecord>): Map<string, DocRecord> {\n  const result = new Map<string, DocRecord>();\n  for (const [id, rec] of docs) {\n    result.set(id, cloneDocRecord(rec));\n  }\n  return result;\n}\n\n// ── Three-way merge logic ────────────────────────────────────────────────────\n\n/**\n * Collect all leaf paths that differ between two objects.\n * Returns a set of dot-separated paths.\n */\nfunction diffPaths(\n  base: Record<string, unknown> | undefined,\n  obj: Record<string, unknown> | undefined,\n  prefix: string,\n): string[] {\n  const paths: string[] = [];\n  const baseObj = base ?? {};\n  const curObj = obj ?? {};\n  const allKeys = new Set([...Object.keys(baseObj), ...Object.keys(curObj)]);\n\n  for (const key of allKeys) {\n    const p = prefix ? `${prefix}.${key}` : key;\n    const bVal = baseObj[key];\n    const oVal = curObj[key];\n\n    if (deepEqual(bVal, oVal)) continue;\n\n    // If both are plain objects (not arrays, not null), recurse\n    if (\n      bVal !== null &&\n      oVal !== null &&\n      typeof bVal === \"object\" &&\n      typeof oVal === \"object\" &&\n      !Array.isArray(bVal) &&\n      !Array.isArray(oVal)\n    ) {\n      paths.push(\n        ...diffPaths(\n          bVal as Record<string, unknown>,\n          oVal as Record<string, unknown>,\n          p,\n        ),\n      );\n    } else {\n      paths.push(p);\n    }\n  }\n  return paths;\n}\n\nfunction getAtPath(obj: Record<string, unknown>, path: string): unknown {\n  const parts = path.split(\".\");\n  let cur: unknown = obj;\n  for (const part of parts) {\n    if (cur === null || cur === undefined || typeof cur !== \"object\") {\n      return undefined;\n    }\n    cur = (cur as Record<string, unknown>)[part];\n  }\n  return cur;\n}\n\nfunction setAtPath(\n  obj: Record<string, unknown>,\n  path: string,\n  value: unknown,\n): void {\n  const parts = path.split(\".\");\n  let cur: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (\n      !(parts[i] in cur) ||\n      cur[parts[i]] === null ||\n      typeof cur[parts[i]] !== \"object\" ||\n      Array.isArray(cur[parts[i]])\n    ) {\n      cur[parts[i]] = {};\n    }\n    cur = cur[parts[i]] as Record<string, unknown>;\n  }\n  cur[parts[parts.length - 1]] = value;\n}\n\nfunction deleteAtPath(obj: Record<string, unknown>, path: string): void {\n  const parts = path.split(\".\");\n  let cur: Record<string, unknown> = obj;\n  for (let i = 0; i < parts.length - 1; i++) {\n    if (\n      !(parts[i] in cur) ||\n      cur[parts[i]] === null ||\n      typeof cur[parts[i]] !== \"object\"\n    ) {\n      return;\n    }\n    cur = cur[parts[i]] as Record<string, unknown>;\n  }\n  delete cur[parts[parts.length - 1]];\n}\n\nconst DELETED_SENTINEL = Symbol(\"DELETED\");\n\nfunction threeWayMergeDoc(\n  base: Record<string, unknown> | undefined,\n  ours: Record<string, unknown> | undefined,\n  theirs: Record<string, unknown> | undefined,\n  docId: string,\n): { merged: Record<string, unknown>; conflicts: Conflict[] } {\n  const ourChanges = diffPaths(base, ours, \"\");\n  const theirChanges = diffPaths(base, theirs, \"\");\n\n  const conflicts: Conflict[] = [];\n  const allChangedPaths = new Set([...ourChanges, ...theirChanges]);\n\n  // Start from a clone of base (or empty if no base)\n  const merged = deepClone(base ?? {}) as Record<string, unknown>;\n\n  for (const path of allChangedPaths) {\n    const baseVal = base ? getAtPath(base, path) : undefined;\n    const ourVal = ours ? getAtPath(ours, path) : undefined;\n    const theirVal = theirs ? getAtPath(theirs, path) : undefined;\n\n    const ourChanged = !deepEqual(baseVal, ourVal);\n    const theirChanged = !deepEqual(baseVal, theirVal);\n\n    if (ourChanged && theirChanged) {\n      if (deepEqual(ourVal, theirVal)) {\n        // Both changed to same value — no conflict\n        if (ourVal === undefined) {\n          deleteAtPath(merged, path);\n        } else {\n          setAtPath(merged, path, deepClone(ourVal));\n        }\n      } else {\n        // Conflict — use \"ours\" for merged preview\n        conflicts.push({\n          documentId: docId,\n          path,\n          base: deepClone(baseVal),\n          ours: deepClone(ourVal),\n          theirs: deepClone(theirVal),\n        });\n        if (ourVal === undefined) {\n          deleteAtPath(merged, path);\n        } else {\n          setAtPath(merged, path, deepClone(ourVal));\n        }\n      }\n    } else if (ourChanged) {\n      if (ourVal === undefined) {\n        deleteAtPath(merged, path);\n      } else {\n        setAtPath(merged, path, deepClone(ourVal));\n      }\n    } else if (theirChanged) {\n      if (theirVal === undefined) {\n        deleteAtPath(merged, path);\n      } else {\n        setAtPath(merged, path, deepClone(theirVal));\n      }\n    }\n  }\n\n  return { merged, conflicts };\n}\n\n// ── DocumentStore ────────────────────────────────────────────────────────────\n\nexport class DocumentStore {\n  privat