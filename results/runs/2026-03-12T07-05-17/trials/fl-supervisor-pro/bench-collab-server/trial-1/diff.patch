+import request from 'supertest';
+import http from 'http';
+import { createApp, AppComponents } from './server.js'; // Assuming server.ts is in the same directory
+import Database from 'better-sqlite3';
+import WebSocket, { WebSocket as WebSocketType } from 'ws'; // Import WebSocketType for clarity
+import { beforeAll, afterAll, beforeEach, it, describe, expect } from 'vitest';
+import { resolve } from 'path'; // Needed if we want to use absolute paths for db
+
+// Use an in-memory database for tests
+const DB_PATH = ':memory:';
+
+let components: AppComponents;
+let server: http.Server;
+let wsPort: number;
+
+// Helper to start the server for tests
+const startTestServer = async (port: number = 0): Promise<number> => {
+    components = createApp(DB_PATH);
+    const serverInstance = components.server;
+
+    return new Promise<number>((resolve, reject) => {
+        serverInstance.listen(port, () => {
+            const addr = serverInstance.address();
+            if (addr && typeof addr === 'object' && addr.port) {
+                wsPort = addr.port;
+                console.log(`Test server listening on port ${wsPort}`);
+                resolve(wsPort);
+            } else {
+                reject(new Error("Could not determine server port after listen."));
+            }
+        });
+
+        serverInstance.on('error', (err: NodeJS.ErrnoException) => {
+            console.error('Test server error:', err);
+            reject(err);
+        });
+    });
+};
+
+// Helper to stop the server
+const stopTestServer = async () => {
+    if (components && components.stop) {
+        await components.stop();
+    }
+};
+
+// Helper to create a WebSocket client
+const createWebSocketClient = (docId: string): WebSocket => {
+    return new WebSocket(`ws://localhost:${wsPort}/ws/${docId}`);
+};
+
+// Helper to promise-wrap WebSocket events
+const wrapWebSocket = (ws: WebSocket): Promise<any> => {
+    return new Promise((resolve, reject) => {
+        ws.onopen = () => {}; // No-op, handled by specific tests
+        ws.onmessage = (event) => resolve({ type: 'message', data: JSON.parse(event.data as string) });
+        ws.onclose = (event) => resolve({ type: 'close', code: event.code, reason: event.reason });
+        ws.onerror = (event) => reject(event);
+    });
+};
+
+
+describe('Document Management REST API', () => {
+    beforeAll(async () => {
+        await startTestServer();
+    });
+
+    afterAll(async () => {
+        await stopTestServer();
+    });
+
+    beforeEach(async () => {
+        await stopTestServer(); // Ensure any previous server is stopped
+        components = createApp(DB_PATH); // Re-initialize app components
+        wsPort = await startTestServer(wsPort); // Start server and capture the port
+    });
+
+    it('should create a new document', async () => {
+        const res = await request(components.app)
+            .post('/documents')
+            .send({ title: 'My First Doc' });
+
+        expect(res.statusCode).toBe(201);
+        expect(res.body).toHaveProperty('id');
+        expect(res.body.title).toBe('My First Doc');
+        expect(res.body.content).toBe('');
+        expect(res.body.version).toBe(1);
+    });
+
+    it('should list all documents', async () => {
+        await request(components.app)
+            .post('/documents')
+            .send({ title: 'Doc A' });
+        await request(components.app)
+            .post('/documents')
+            .send({ title: 'Doc B' });
+
+        const res = await request(components.app).get('/documents');
+
+        expect(res.statusCode).toBe(200);
+        expect(res.body).toHaveLength(2);
+        expect(res.body[0].title).toBe('Doc B'); 
+        expect(res.body[1].title).toBe('Doc A');
+    });
+
+    it('should get a specific document by ID', async () => {
+        const createRes = await request(components.app)
+            .post('/documents')
+            .send({ title: 'Get Me Doc' });
+        const docId = createRes.body.id;
+
+        const res = await request(components.app).get(`/documents/${docId}`);
+
+        expect(res.statusCode).toBe(200);
+        expect(res.body.id).toBe(docId);
+        expect(res.body.title).toBe('Get Me Doc');
+        expect(res.body.content).toBe('');
+        expect(res.body.version).toBe(1);
+    });
+
+    it('should return 400 if document not found for GET', async () => {
+        const res = await request(components.app).get('/documents/non-existent-id');
+        expect(res.statusCode).toBe(400);
+        expect(res.body).toHaveProperty('error', 'Document not found');
+    });
+
+    it('should update a document', async () => {
+        const createRes = await request(components.app)
+            .post('/documents')
+            .send({ title: 'Updatable Doc' });
+        const docId = createRes.body.id;
+
+        const newContent = 'This is the updated content.';
+        const res = await request(components.app)
+            .put(`/documents/${docId}`)
+            .send({ content: newContent });
+
+        expect(res.statusCode).toBe(200);
+        expect(res.body.id).toBe(docId);
+        expect(res.body.content).toBe(newContent);
+        expect(res.body.version).toBe(2); 
+    });
+
+    it('should return 400 if document not found for PUT', async () => {
+        const res = await request(components.app)
+            .put('/documents/non-existent-id')
+            .send({ content: 'new content' });
+        expect(res.statusCode).toBe(400);
+        expect(res.body).toHaveProperty('error', 'Document not found');
+    });
+
+    it('should delete a document', async () => {
+        const createRes = await request(components.app)
+            .post('/documents')
+            .send({ title: 'Deletable Doc' });
+        const docId = createRes.body.id;
+
+        const res = await request(components.app).delete(`/documents/${docId}`);
+
+        expect(res.statusCode).toBe(204); 
+
+        const getRes = await request(components.app).get(`/documents/${docId}`);
+        expect(getRes.statusCode).toBe(400);
+    });
+
+    it('should return 400 if document not found for DELETE', async () => {
+        const res = await request(components.app).delete('/documents/non-existent-id');
+        expect(res.statusCode).toBe(400);
+        expect(res.body).toHaveProperty('error', 'Document not found');
+    });
+
+    it('should get document version history', async () => {
+        const createRes = await request(components.app)
+            .post('/documents')
+            .send({ title: 'History Doc' });
+        const docId = createRes.body.id;
+
+        await request(components.app)
+            .put(`/documents/${docId}`)
+            .send({ content: 'Version 2 content' });
+        await request(components.app)
+            .put(`/documents/${docId}`)
+            .send({ content: 'Version 3 content' });
+
+        const res = await request(components.app).get(`/documents/${docId}/history`);
+
+        expect(res.statusCode).toBe(200);
+        expect(res.body).toHaveLength(3); 
+
+        expect(res.body[0].version).toBe(1);
+        expect(res.body[0].content).toBe('');
+
+        expect(res.body[1].version).toBe(2);
+        expect(res.body[1].content).toBe('Version 2 content');
+
+        expect(res.body[2].version).toBe(3);
+        expect(res.body[2].content).toBe('Version 3 content');
+    });
+
+    it('should return 400 if document not found for history GET', async () => {
+        const res = await request(components.app).get('/documents/non-existent-id/history');
+        expect(res.statusCode).toBe(400);
+        expect(res.body).toHaveProperty('error', 'Document not found');
+    });
+});
+
+describe('WebSocket Collaboration', () => {
+    beforeAll(async () => {
+        await startTestServer();
+    });
+
+    afterAll(async () => {
+        await stopTestServer();
+    });
+
+    let testDocId: string;
+
+    beforeEach(async () => {
+        await stopTestServer();
+        components = createApp(DB_PATH);
+        const actualPort = await components.start(wsPort);
+        const serverInstance = components.server;
+        if (serverInstance && serverInstance.listening) {
+            const addr = serverInstance.address();
+            if (addr && typeof addr === 'object' && addr.port) {
+                wsPort = addr.port;
+            }
+        } else {
+            throw new Error("HTTP server not started or accessible in beforeEach.");
+        }
+
+        const createRes = await request(components.app)
+            .post('/documents')
+            .send({ title: 'WS Test Doc' });
+        testDocId = createRes.body.id;
+    });
+
+    it('should allow a client to connect to a valid document endpoint', async () => {
+        const ws = createWebSocketClient(testDocId);
+
+        await new Promise<void>((resolve, reject) => {
+            ws.onopen = () => {
+                expect(ws.readyState).toBe(WebSocketType.OPEN);
+                ws.close();
+                resolve();
+            };
+            ws.onerror = (error) => reject(error);
+        });
+    });
+
+    it('should reject connection for invalid WebSocket URL', async () => {
+        const ws = new WebSocket(`ws://localhost:${wsPort}/invalid/path`); // Incorrect path structure
+        
+        await new Promise<void>((resolve, reject) => {
+            ws.onopen = () => {
+                ws.close();
+                reject(new Error('Connection should have been rejected for invalid URL'));
+            };
+            ws.onclose = (event) => {
+                expect(event.code).toBe(1008); // Policy violation
+                resolve();
+            };
+            ws.onerror = (error) => reject(error);
+        });
+    });
+
+    it('should reject connection for non-existent document ID', async () => {
+        const nonExistentDocId = 'non-existent-doc';
+        const ws = createWebSocketClient(nonExistentDocId);
+
+        await new Promise<void>((resolve, reject) => {
+            ws.onopen = () => {
+                ws.close();
+                reject(new Error('Connection should have been rejected for non-existent document'));
+            };
+            ws.onclose = (event) => {
+                expect(event.code).toBe(1011); // Internal Error / Unexpected condition
+                resolve();
+            };
+            ws.onerror = (error) => reject(error);
+        });
+    });
+
+    it('should send initial document state (sync message) upon connection', async () => {
+        const ws = createWebSocketClient(testDocId);
+
+        await new Promise<void>((resolve, reject) => {
+            ws.onopen = () => {
+                ws.onmessage = (event) => {
+                    try {
+                        const message = JSON.parse(event.data as string);
+                        expect(message.type).toBe('sync');
+                        expect(message.data).toHaveProperty('documentId', testDocId);
+                        expect(message.data).toHaveProperty('version', 1); 
+                        expect(message.data).toHaveProperty('content', ''); 
+                        ws.close();
+                        resolve();
+                    } catch (error) {
+                        reject(error);
+                    }
+                };
+            };
+            ws.onerror = (error) => reject(error);
+        });
+    });
+
+    it('should apply and broadcast an insert operation', async () => {
+        const ws1 = createWebSocketClient(testDocId); // Client 1
+        const ws2 = createWebSocketClient(testDocId); // Client 2
+
+        // Wait for both clients to sync
+        await Promise.all([wrapWebSocket(ws1), wrapWebSocket(ws2)]);
+        
+        // Ensure both clients are ready and have initial state
+        // The sync messages are resolved by wrapWebSocket, so proceed with operations.
+
+        // Client 1 sends an insert operation
+        const insertOp1 = {
+            type: 'insert',
+            documentId: testDocId,
+            baseVersion: 1, // Based on initial sync (version 1)
+            position: 0,
+            text: 'Hello, ',
+        };
+        ws1.send(JSON.stringify({ type: 'operation', data: insertOp1 }));
+
+        // Client 2 should receive the broadcasted operation
+        const msg2 = await wrapWebSocket(ws2); // Wait for message on ws2
+        expect(msg2.data.type).toBe('broadcast_operation');
+        expect(msg2.data.data.text).toBe('Hello, ');
+        expect(msg2.data.data.position).toBe(0);
+        expect(msg2.data.data.newVersion).toBe(2); // Should be version 2 now
+        expect(msg2.data.data.newContent).toBe('Hello, ');
+        
+        // Client 1 should also receive an ack or confirmation of its operation (optional, depends on server logic)
+        // For now, we check if the broadcast reached ws2 correctly.
+
+        ws1.close();
+        ws2.close();
+    });
+
+    it('should apply and broadcast a delete operation', async () => {
