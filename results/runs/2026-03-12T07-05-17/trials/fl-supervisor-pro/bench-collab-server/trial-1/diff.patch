+
+// Define the database schema as a string
+const DB_SCHEMA = `
+-- Documents table
+CREATE TABLE IF NOT EXISTS documents (
+    id TEXT PRIMARY KEY,
+    title TEXT NOT NULL,
+    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
+    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
+);
+
+-- Document versions table
+CREATE TABLE IF NOT EXISTS document_versions (
+    id INTEGER PRIMARY KEY AUTOINCREMENT,
+    document_id TEXT NOT NULL,
+    version INTEGER NOT NULL,
+    content TEXT NOT NULL,
+    timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
+    FOREIGN KEY (document_id) REFERENCES documents(id) ON DELETE CASCADE,
+    UNIQUE (document_id, version)
+);
+`;
+
+interface Document {
+    id: string;
+    title: string;
+    created_at: string;
+    updated_at: string;
+}
+
+interface DocumentVersion {
+    id: number;
+    document_id: string;
+    version: number;
+    content: string;
+    timestamp: string;
+}
+
+// Define the structure for operational messages
+interface Operation {
+    type: 'insert' | 'delete';
+    documentId: string;
+    version: number; // The version of the document this operation is based on
+    position: number; // For insert/delete
+    text?: string;    // For insert
+    length?: number;  // For delete
+}
+
+// Interface for the returned application components
+export interface AppComponents {
+    app: express.Express;
+    server: HttpServer; // Add the http.Server instance
+    start: (port?: number) => Promise<number>;
+    stop: () => Promise<void>;
+}
+
+// Map to store active WebSocket connections per document ID
+// Key: documentId, Value: Set of WebSocket clients
+const documentConnections: Map<string, Set<WebSocket>> = new Map();
+
+export function createApp(dbPath: string = ':memory:'): AppComponents {
+    const app = express();
+    app.use(express.json()); // Middleware to parse JSON bodies
+
+    const server = http.createServer(app);
+    // WebSocket server for real-time collaboration
+    const wss = new WebSocketServer({ server });
+
+    // Initialize database and create tables if they don't exist
+    const db = new Database(dbPath);
+    db.exec(DB_SCHEMA);
+
+    // --- REST API for document management ---
+
+    // POST /documents: Create a new document
+    app.post('/documents', (req, res) => {
+        const { title } = req.body;
+        if (!title) {
+            return res.status(400).json({ error: 'Title is required' });
+        }
+
+        const id = uuidv4();
+        const now = new Date().toISOString();
+
+        try {
+            db.transaction(() => {
+                db.prepare('INSERT INTO documents (id, title, created_at, updated_at) VALUES (?, ?, ?, ?)').run(id, title, now, now);
+                // Create initial version (version 1, empty content)
+                db.prepare('INSERT INTO document_versions (document_id, version, content, timestamp) VALUES (?, ?, ?, ?)').run(id, 1, '', now);
+            })();
+            res.status(201).json({ id, title, content: '', version: 1, created_at: now, updated_at: now });
+        } catch (error: any) {
+            console.error('Error creating document:', error);
+            res.status(500).json({ error: 'Failed to create document' });
+        }
+    });
+
+    // GET /documents: List all documents
+    app.get('/documents', (req, res) => {
+        try {
+            const documents = db.prepare('SELECT id, title, created_at, updated_at FROM documents ORDER BY created_at DESC').all() as Document[];
+            res.json(documents);
+        } catch (error: any) {
+            console.error('Error listing documents:', error);
+            res.status(500).json({ error: 'Failed to list documents' });
+        }
+    });
+
+    // GET /documents/:id: Read a specific document (including latest content)
+    app.get('/documents/:id', (req, res) => {
+        const { id } = req.params;
+        try {
+            const doc = db.prepare('SELECT * FROM documents WHERE id = ?').get([id]) as Document;
+            if (!doc) {
+                return res.status(400).json({ error: 'Document not found' });
+            }
+
+            const latestVersion = db.prepare('SELECT * FROM document_versions WHERE document_id = ? ORDER BY version DESC LIMIT 1').get([id]) as DocumentVersion;
+
+            res.json({
+                ...doc,
+                content: latestVersion ? latestVersion.content : '',
+                version: latestVersion ? latestVersion.version : 1,
+            });
+        } catch (error: any) {
+            console.error(`Error reading document ${id}:`, error);
+            res.status(500).json({ error: 'Failed to read document' });
+        }
+    });
+
+    // PUT /documents/:id: Update a document
+    app.put('/documents/:id', (req, res) => {
+        const { id } = req.params;
+        const { content } = req.body;
+
+        if (content === undefined) {
+            return res.status(400).json({ error: 'Content is required for update' });
+        }
+
+        const now = new Date().toISOString();
+
+        try {
+            const docExists = db.prepare('SELECT id FROM documents WHERE id = ?').get([id]);
+            if (!docExists) {
+                return res.status(400).json({ error: 'Document not found' });
+            }
+
+            const currentVersionRow = db.prepare('SELECT version FROM document_versions WHERE document_id = ? ORDER BY version DESC LIMIT 1').get([id]) as { version: number };
+            const newVersion = currentVersionRow ? currentVersionRow.version + 1 : 1;
+
+            db.transaction(() => {
+                db.prepare('UPDATE documents SET updated_at = ? WHERE id = ?').run(now, id);
+                db.prepare('INSERT INTO document_versions (document_id, version, content, timestamp) VALUES (?, ?, ?, ?)').run(id, newVersion, content, now);
+            })();
+
+            const updatedDoc = db.prepare('SELECT * FROM documents WHERE id = ?').get([id]) as Document;
+            res.json({
+                ...updatedDoc,
+                content: content,
+                version: newVersion,
+            });
+
+        } catch (error: any) {
+            console.error(`Error updating document ${id}:`, error);
+            res.status(500).json({ error: 'Failed to update document' });
+        }
+    });
+
+    // DELETE /documents/:id: Delete a document
+    app.delete('/documents/:id', (req, res) => {
+        const { id } = req.params;
+
+        try {
+            const docExists = db.prepare('SELECT id FROM documents WHERE id = ?').get([id]);
+            if (!docExists) {
+                return res.status(400).json({ error: 'Document not found' });
+            }
+
+            const result = db.prepare('DELETE FROM documents WHERE id = ?').run([id]);
+            if (result.changes === 0) {
+                return res.status(400).json({ error: 'Document not found or could not be deleted' });
+            }
+            
+            res.sendStatus(204); // No Content
+        } catch (error: any) {
+            console.error(`Error deleting document ${id}:`, error);
+            res.status(500).json({ error: 'Failed to delete document' });
+        }
+    });
+
+    // --- WebSocket setup for real-time collaboration ---
+
+    wss.on('connection', (ws: WebSocket, req: any) => {
+        console.log(`WebSocket connection attempt with URL: ${req.url}`); // Added log
+        // Extract document ID from the connection URL (e.g., ws://localhost:3000/ws/documentId)
+        const urlParts = req.url.split('/');
+        let documentId: string | undefined;
+
+        // Ensure there's a segment after the expected path parts (e.g., '/ws/')
+        // Assuming path is like /ws/:documentId
+        if (urlParts.length > 2 && urlParts[urlParts.length - 1] !== undefined) {
+            documentId = urlParts[urlParts.length - 1];
+        }
+
+        // --- Robustly extract and validate documentId ---
+        if (!documentId || typeof documentId !== 'string' || documentId.trim() === '') {
+            console.error('WebSocket connection rejected: Invalid or missing Document ID in URL.');
+            ws.close(1008, 'Invalid Document ID format.'); // 1008 for Policy Violation
+            return;
+        }
+        // Trim whitespace in case of accidental spaces in URL
+        documentId = documentId.trim(); 
+
+        // Check if document exists
+        console.log(`Attempting to query for documentId: '${documentId}'`); // Debug log
+        const doc = db.prepare('SELECT id FROM documents WHERE id = ?').get([documentId]) as Document;
+        if (!doc) {
+            console.error(`WebSocket connection rejected: Document ${documentId} not found.`);
+            ws.close(1011, 'Document not found.'); // 1011 indicates an internal error or unexpected condition
+            return;
+        }
+        // --- End of validation ---
+
+        console.log(`Client connected to document: ${documentId}`);
+
+        // Add client to the set of connections for this document
+        if (!documentConnections.has(documentId)) {
+            documentConnections.set(documentId, new Set());
+        }
+        documentConnections.get(documentId)!.add(ws);
+
+        // --- Send current document state to the new client ---
+        try {
+            const latestVersion = db.prepare('SELECT * FROM document_versions WHERE document_id = ? ORDER BY version DESC LIMIT 1').get([documentId]) as DocumentVersion;
+            const initialState = {
+                type: 'sync',
+                documentId: documentId,
+                version: latestVersion ? latestVersion.version : 1,
+                content: latestVersion ? latestVersion.content : '',
+            };
+            ws.send(JSON.stringify(initialState));
+            console.log(`Sent initial state for ${documentId} to client.`);
+        } catch (error: any) {
+            console.error(`Error sending initial state for ${documentId}:`, error);
+            ws.close(1011, 'Failed to send initial document state.');
+        }
+
+        // --- Handle messages (operations) from clients ---
+        ws.on('message', (message: string) => {
+            try {
+                const operation: Operation = JSON.parse(message);
+
+                if (operation.documentId !== documentId) {
+                    console.error(`Received operation for wrong document: ${operation.documentId} vs ${documentId}`);
+                    ws.send(JSON.stringify({ type: 'error', message: 'Operation for wrong document.' }));
+                    return;
+                }
+
+                // Basic check: Ensure the operation is based on a version we know or can handle
+                // In a real OT/CRDT system, this would be more complex.
+                // Here, we'll simply apply it if it's the next sequential version.
+                const currentVersionRow = db.prepare('SELECT version FROM document_versions WHERE document_id = ? ORDER BY version DESC LIMIT 1').get([documentId]) as { version: number };
+                const currentVersion = currentVersionRow ? currentVersionRow.version : 0; // Use 0 if no versions exist yet (shouldn't happen after creation)
+
+                if (operation.version !== currentVersion + 1) {
+                    // This indicates a potential conflict or out-of-sync client.
+                    // For now, we'll reject it and ask the client to resync.
+                    console.warn(`Client ${documentId} sent operation for version ${operation.version}, but server is at ${currentVersion}. Requesting resync.`);
+                    ws.send(JSON.stringify({
+                        type: 'resync',
+                        documentId: documentId,
+                        message: `Client is out of sync. Expected version ${currentVersion + 1}, received ${operation.version}. Please resync.`
+                    }));
+                    return;
+                }
+
+                // Apply the operation to the document in the database
+                let newContent = '';
+                db.transaction(() => {
+                    // Get the document and its current content
+                    const docData = db.prepare('SELECT * FROM documents WHERE id = ?').get([documentId]) as Document;
+                    if (!docData) throw new Error('Document disappeared during transaction'); // Should not happen due to initial check
+
+                    const docVersionData = db.prepare('SELECT content FROM document_versions WHERE document_id = ? AND version = ?').get([documentId, operation.version]) as DocumentVersion;
+                    if (!docVersionData) throw new Error(`Document version ${operation.version} not found for ${documentId}`); // Should not happen with correct version check
+
+                    let currentContent = docVersionData.content;
+
+                    // Apply the operation
+                    if (operation.type === 'insert') {
+                        if (operation.text === undefined || operation.position === undefined) {
+                            throw new Error('Insert operation missing text or position');
+                        }
+                        newContent = currentContent.slice(0, operation.position) + operation.text + currentContent.slice(operation.position);
+                    } else if (operation.type === 'delete') {
+                        if (operation.position === undefined || operation.length === undefined) {
+                            throw new Error('Delete operation missing position or length');
+                        }
+                        newContent = currentContent.slice(0, operation.position) + currentContent.slice(operation.position + operation.length);
+                    } else {
+                        throw new Error(`Unknown operation type: ${operation.type}`);
+                    }
+
+                    // Update document's latest version and content
+                    const newVersionNumber = operation.version + 1;
+                    const now = new Date().toISOString();
+                    db.prepare('UPDATE documents SET updated_at = ? WHERE id = ?').run(now, documentId);
+                    db.prepare('INSERT INTO document_versions (document_id, version, content, timestamp) VALUES (?, ?, ?, ?)').run(documentId, newVersionNumber, newContent, now);
+                })();
+
+                // Broadcast the operation to all other clients connected to this document
+                const broadcastOperation = {
+                    ...operation,
+                    version: operation.version + 1, // The version *after* applying this operation
+                    newContent: newContent, // Send the resulting content for easier sync if needed
+                };
+
+                documentConnections.get(documentId)!.forEach(client => {
+                    if (client !== ws && client.readyState === WebSocket.OPEN) {
+                        client.send(JSON.stringify(broadcastOperation));
+                    }
+                });
+                console.log(`Operation ${operation.type} on ${documentId} (v${operation.version} -> v${operation.version + 1}) broadcasted.`);
+
+            } catch (error: any) {
+                console.error(`Error processing WebSocket message for ${documentId}:`, error);
+                // Send an error message back to the client
+                ws.send(JSON.stringify({ type: 'error', message: `Failed to process operation: ${error.message}` }));
+            }
+        });
+
+        // --- Handle client disconnection ---
+        ws.on('close', () => {
+            console.log(`Client disconnected from document: ${documentId}`);
+            // Remove client from the set of connections
+            if (documentConnections.has(documentId)) {
+                documentConnections.get(documentId)!.delete(ws);
+                // If no clients are connected to this document, clean up the map entry
+                if (documentConnections.get(documentId)!.size === 0) {
+                    documentConnections.delete(documentId);
+                }
+            }
+        });
+
+        ws.on('error', (error: Error) => { // Explicitly typed error
+            console.error(`WebSocket error for document ${documentId}:`, error);
+            // Clean up connection on error
+            if (documentConnections.has(documentId)) {
+                documentConnections.get(documentId)!.delete(ws);
+                if (documentConnections.get(documentId)!.size === 0) {
+                    documentConnections.delete(documentId);
+                }
+            }
+        });
+    });
+
+    // --- Server lifecycle methods ---
+
+    // Starts the HTTP server and returns the port number it's listening on.
+    const start = async (port: number = 0): Promise<number> => {
+        return new Promise((resolve, reject) => {
+            server.listen(port, () => {
+                const address = server.address();
+                if (address && typeof address === 'object' && address.port) {
+                    const actualPort = address.port;
+                    console.log(`Server listening on port ${actualPort}`);
+                    resolve(actualPort);
+                } else {
+                    reject(new Error('Failed to get server port after listen.'));
+                }
+            });
+            server.on('error', (err: NodeJS.ErrnoException) => {
+                console.error('HTTP server error:', err);
+                reject(err);
+            });
+        });
+    };
+
+    // Stops the HTTP server and closes the database connection.
+    const stop = async (): Promise<void> => {
+        return new Promise((resolve, reject) => {
+            server.close((err) => {
+                if (err) {
+                    console.error('Error closing HTTP server:', err);
+                    return reject(err);
+                }
+                console.log('HTTP server closed.');
+                try {
+                    db.close(); // Close the SQLite database connection (synchronous)
+                    console.log('Database closed.');
+                    resolve();
+                } catch (dbErr) {
+                    console.error('Error closing database:', dbErr);
+                    reject(dbErr);
+                }
+            });
+        });
+    };
+
+    return { app, server, start, stop }; // Return the server instance
+}
