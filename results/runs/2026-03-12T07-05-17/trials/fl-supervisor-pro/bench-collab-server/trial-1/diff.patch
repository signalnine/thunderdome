+        await request(components.app)
+            .put(`/documents/${testDocId}`)
+            .send({ content: 'Initial content for delete test.' });
+        
+        const ws1 = createWebSocketClient(testDocId);
+        const ws2 = createWebSocketClient(testDocId);
+
+        // Wait for both clients to sync (they should get version 2, with 'Initial content for delete test.')
+        const initialSync1 = await wrapWebSocket(ws1);
+        const initialSync2 = await wrapWebSocket(ws2);
+        expect(initialSync1.data.version).toBe(2);
+        expect(initialSync2.data.version).toBe(2);
+        expect(initialSync1.data.content).toBe('Initial content for delete test.');
+
+        // Client 1 sends a delete operation
+        const deleteOp1 = {
+            type: 'delete',
+            documentId: testDocId,
+            baseVersion: 2, // Based on the content we just set
