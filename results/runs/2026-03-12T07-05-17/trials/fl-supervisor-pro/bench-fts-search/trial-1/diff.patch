diff --git a/src/db.ts b/src/db.ts
index 810e0fd..d1441e9 100644
--- a/src/db.ts
+++ b/src/db.ts
@@ -18,9 +18,49 @@ export function createDatabase(path?: string): Database.Database {
     )
   `);
 
+  // --- FTS5 Setup ---
+  // Create the FTS5 virtual table.
+  // It will store `note_id` to link back to the original notes table, and the indexed content.
+  db.exec(`
+    CREATE VIRTUAL TABLE IF NOT EXISTS notes_fts USING fts5(
+      note_id UNINDEXED, -- Store the original row ID, but don't index it for search
+      title,             -- Index the title
+      body,              -- Index the body
+      -- Use 'ascii' tokenizer for basic word splitting and lowercasing.
+      -- For more advanced stemming, consider 'porter'.
+      -- For prefix search support, you can add 'prefix=<lengths>' to the tokenizer.
+      tokenize = 'ascii'
+    );
+  `);
+
+  // Trigger for INSERT: When a new note is added, insert its searchable content into FTS5.
+  db.exec(`
+    CREATE TRIGGER IF NOT EXISTS notes_ai AFTER INSERT ON notes BEGIN
+      INSERT INTO notes_fts (note_id, title, body) VALUES (new.id, new.title, new.body);
+    END;
+  `);
+
+  // Trigger for UPDATE: When a note's title or body is updated, update the FTS5 entry.
+  // We use `UPDATE OF title, body` to ensure this trigger only fires if these specific columns change.
+  // The common strategy is to delete the old FTS entry and insert a new one.
