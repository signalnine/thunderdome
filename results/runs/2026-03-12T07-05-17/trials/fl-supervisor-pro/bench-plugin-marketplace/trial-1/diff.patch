index 0000000..1ef1bb8
--- /dev/null
+++ b/src/runner/SandboxedRunner.ts
@@ -0,0 +1,83 @@
+import { SandboxResult, RunnerService } from '../types.js';
+import * as vm from 'vm';
+
+// Define a type for the module object in the sandbox
+interface SandboxModule {
+  exports: Record<string, unknown>;
+}
+
+export class SandboxedRunner implements RunnerService {
+  async execute(code: string, context?: Record<string, unknown>): Promise<SandboxResult> {
+    return this.executeWithTimeout(code, 5000, context); // Default timeout of 5 seconds
+  }
+
+  async executeWithTimeout(code: string, timeoutMs: number, context?: Record<string, unknown>): Promise<SandboxResult> {
+    const sandboxModule: SandboxModule = { exports: {} };
+    const sandboxContext: vm.Context = {
+      ...context,
+      module: sandboxModule,
+      exports: sandboxModule.exports, // 'exports' points to 'module.exports'
+      require, // Allow require in sandbox for basic modules, but this is a potential security risk
+      console,
+      Buffer,
+      process,
+      setTimeout,
+      clearTimeout,
+      setInterval,
+      clearInterval,
+    };
+
+    vm.createContext(sandboxContext);
+
+    const startTime = process.hrtime.bigint();
+    let result: unknown;
+    let caughtError: Error | undefined = undefined;
+    let success = true;
+
+    // Use a WeakMap to track memory usage if needed, but for now, rely on `heapUsed` snapshot
+    const memoryBefore = process.memoryUsage().heapUsed;
+
+    try {
+      const script = new vm.Script(code, {
+        filename: 'plugin.js',
+        // displayErrors: true, // Removed: Causes TypeScript error, potentially deprecated or not needed
+      });
+
+      result = await script.runInContext(sandboxContext, {
+        timeout: timeoutMs,
+        breakOnSigint: true, // Allow interrupting with SIGINT
+      });
+      // If the code defines exports, return them
+      if (sandboxModule.exports && Object.keys(sandboxModule.exports).length > 0) {
+        result = sandboxModule.exports;
+      }
+    } catch (e: unknown) { // Changed from 'any' to 'unknown'
+      if (e instanceof Error) { // Type guard to access error properties safely
+        caughtError = e;
+      } else {
+        caughtError = new Error(String(e)); // Convert non-Error objects to Error
+      }
+      success = false;
+
+      // WORKAROUND: vm.Script.runInContext seems to prefix error messages with "Error: "
+      // even if the original error's message did not have it.
+      // We strip it here to match the test's expectation of just the message.
+      if (caughtError && caughtError.message.startsWith('Error: ')) {
+        caughtError.message = caughtError.message.substring('Error: '.length);
+      }
+    }
+
+    const endTime = process.hrtime.bigint();
+    const duration = Number(endTime - startTime) / 1_000_000; // Convert nanoseconds to milliseconds
+    const memoryAfter = process.memoryUsage().heapUsed;
+    const memoryUsed = memoryAfter - memoryBefore; // Rough estimate of memory used by script
+
+    return {
+      success,
+      output: result,
+      duration,
+      memoryUsed,
+      error: caughtError ? caughtError.message : undefined,
+    };
+  }
+}
