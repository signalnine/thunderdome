index 0000000..027b047
--- /dev/null
+++ b/src/deps/DependencyGraph.ts
@@ -0,0 +1,241 @@
+import { DependencyNode, DepsService, RegistryService, PluginManifest } from '../types.js';
+import * as semver from 'semver';
+
+export class DependencyGraph implements DepsService {
+  constructor(private registry: RegistryService) {}
+
+  buildTree(pluginName: string, version: string): DependencyNode {
+    const rootPlugin = this.registry.getVersion(pluginName, version);
+    if (!rootPlugin) {
+      throw new Error(`Plugin ${pluginName}@${version} not found in registry.`);
+    }
+
+    const visited = new Set<string>(); // To detect cycles during tree building
+    const buildNode = (name: string, ver: string): DependencyNode => {
+      const plugin = this.registry.getVersion(name, ver);
+      if (!plugin) {
+        throw new Error(`Dependency ${name}@${ver} not found for ${pluginName}@${version}`);
+      }
+
+      const node: DependencyNode = { name: plugin.name, version: plugin.version, dependencies: [] };
+      const id = `${name}@${ver}`;
+
+      if (visited.has(id)) {
+        // Simple cycle detection during tree building. If we encounter an already visited node
+        // in the current path, it's a cycle. For tree building, we just return the node
+        // to stop infinite recursion, but for full cycle detection, a different approach is needed.
+        return node;
+      }
+      visited.add(id);
+
+      for (const depName in plugin.dependencies) {
+        const depRange = plugin.dependencies[depName];
+        const availableVersions = this.registry.listVersions(depName);
+        if (!availableVersions || availableVersions.length === 0) {
+          throw new Error(`No versions available for dependency ${depName} of ${name}@${ver}`);
+        }
+        const maxSatisfyingVersion = semver.maxSatisfying(availableVersions, depRange);
+        if (!maxSatisfyingVersion) {
+          throw new Error(`No version of ${depName} satisfies range ${depRange} for ${name}@${ver}`);
+        }
+        node.dependencies.push(buildNode(depName, maxSatisfyingVersion));
+      }
+      visited.delete(id); // Backtrack
+      return node;
+    };
+
+    return buildNode(pluginName, version);
+  }
+
+  detectCycles(pluginName: string, version: string): string[][] | null {
+    const rootPlugin = this.registry.getVersion(pluginName, version);
+    if (!rootPlugin) {
+      throw new Error(`Plugin ${pluginName}@${version} not found in registry.`);
+    }
+
+    const graph = new Map<string, string[]>(); // pluginId -> list of dependencyIds
+    // Use a queue for BFS-like discovery to build the complete graph from root
+    const queue: PluginManifest[] = [rootPlugin];
+    const discoveredPlugins = new Map<string, PluginManifest>(); // pluginId -> PluginManifest
+
+    while(queue.length > 0) {
+      const currentPlugin = queue.shift()!;
+      const currentPluginId = `${currentPlugin.name}@${currentPlugin.version}`;
+
+      if (discoveredPlugins.has(currentPluginId)) {
+        continue;
+      }
+      discoveredPlugins.set(currentPluginId, currentPlugin);
+      graph.set(currentPluginId, []);
+
+      for (const depName in currentPlugin.dependencies) {
+        const depRange = currentPlugin.dependencies[depName];
+        const availableVersions = this.registry.listVersions(depName);
+        if (!availableVersions || availableVersions.length === 0) {
+          throw new Error(`No versions available for dependency ${depName} of ${currentPluginId}`);
+        }
+        const maxSatisfyingVersion = semver.maxSatisfying(availableVersions, depRange);
+        if (!maxSatisfyingVersion) {
+          throw new Error(`No version of ${depName} satisfies range ${depRange} for ${currentPluginId}`);
+        }
+        const depId = `${depName}@${maxSatisfyingVersion}`;
+        graph.get(currentPluginId)!.push(depId);
+
+        const depPlugin = this.registry.getVersion(depName, maxSatisfyingVersion);
+        if (!depPlugin) {
+          throw new Error(`Dependency ${depName}@${maxSatisfyingVersion} not found for ${currentPluginId}`);
+        }
+        queue.push(depPlugin);
+      }
+    }
+
+    const visited = new Set<string>();
+    const recursionStack = new Set<string>();
+    const cycles: string[][] = [];
+
+    const dfs = (nodeId: string, path: string[]): void => {
+      visited.add(nodeId);
+      recursionStack.add(nodeId);
+      path.push(nodeId);
+
+      const neighbors = graph.get(nodeId) || [];
+      for (const neighborId of neighbors) {
+        if (!visited.has(neighborId)) {
+          dfs(neighborId, path);
+        } else if (recursionStack.has(neighborId)) {
+          // Cycle detected
+          const cycleStart = path.indexOf(neighborId);
+          cycles.push(path.slice(cycleStart));
+        }
+      }
+      recursionStack.delete(nodeId);
+      path.pop();
+    };
+
+    // Perform DFS for all discovered nodes in the graph to find all cycles
+    for (const nodeId of graph.keys()) {
+      if (!visited.has(nodeId)) {
+        dfs(nodeId, []);
+      }
+    }
+
+    return cycles.length > 0 ? cycles : null;
+  }
+
+  hasCircularDependency(pluginName: string, version: string): boolean {
+    return this.detectCycles(pluginName, version) !== null;
+  }
+
+  topologicalSort(pluginName: string, version: string): string[] {
+    const rootPlugin = this.registry.getVersion(pluginName, version);
+    if (!rootPlugin) {
+      throw new Error(`Plugin ${pluginName}@${version} not found in registry.`);
+    }
+
+    const graph = new Map<string, string[]>(); // depId -> [pluginId1, pluginId2] (meaning depId points to pluginIds)
+    const inDegree = new Map<string, number>(); // pluginId -> count of incoming edges
+    const discoveredPlugins = new Map<string, PluginManifest>(); // pluginId -> PluginManifest
+
+    // First pass: Discover all reachable plugins and store their manifests
+    const queue: PluginManifest[] = [rootPlugin];
+    while(queue.length > 0) {
+      const currentPlugin = queue.shift()!;
+      const currentPluginId = `${currentPlugin.name}@${currentPlugin.version}`;
+
+      if (discoveredPlugins.has(currentPluginId)) {
+        continue;
+      }
+      discoveredPlugins.set(currentPluginId, currentPlugin);
+      inDegree.set(currentPluginId, 0); // Initialize in-degree for all discovered plugins to 0
+      graph.set(currentPluginId, []); // Initialize adjacency list for all discovered nodes
+
+      // Add to queue for further discovery
+      for (const depName in currentPlugin.dependencies) {
+        const depRange = currentPlugin.dependencies[depName];
+        const availableVersions = this.registry.listVersions(depName);
+        if (!availableVersions || availableVersions.length === 0) {
+          throw new Error(`No versions available for dependency ${depName} of ${currentPluginId}`);
+        }
+        const maxSatisfyingVersion = semver.maxSatisfying(availableVersions, depRange);
+        if (!maxSatisfyingVersion) {
+          throw new Error(`No version of ${depName} satisfies range ${depRange} for ${currentPluginId}`);
+        }
+        const depPlugin = this.registry.getVersion(depName, maxSatisfyingVersion);
+        if (!depPlugin) {
+          throw new Error(`Dependency ${depName}@${maxSatisfyingVersion} not found for ${currentPluginId}`);
+        }
+        queue.push(depPlugin);
+      }
+    }
+
+    // Second pass: Build actual edges and calculate in-degrees based on discovered plugins
+    // For topological sort for installation, if A depends on B, the edge should be B -> A (B needs to be processed before A).
+    // So, 'depId' points to 'pluginId'.
+    // We iterate through all discovered plugins and their dependencies to establish edges and calculate in-degrees.
+    for (const pluginId of discoveredPlugins.keys()) {
+      const pluginManifest = discoveredPlugins.get(pluginId)!;
+      for (const depName in pluginManifest.dependencies) {
+        const depRange = pluginManifest.dependencies[depName];
+        const maxSatisfyingVersion = semver.maxSatisfying(this.registry.listVersions(depName), depRange)!; // Must exist from first pass
+        const depId = `${depName}@${maxSatisfyingVersion}`;
+
+        // Create edge: depId -> pluginId
+        // This means pluginId has an incoming edge from depId
+        if (graph.has(depId)) { // Ensure dependency node exists in our graph
+          graph.get(depId)!.push(pluginId); // depId points to pluginId
+          inDegree.set(pluginId, (inDegree.get(pluginId) || 0) + 1); // Increment in-degree of pluginId
+        } else {
+          // This case should ideally not happen if discoveredPlugins correctly identifies all reachable nodes
+          // console.warn(`Dependency node ${depId} not found in graph for edge from ${pluginId}`);
+        }
+      }
+    }
+    
+    // Kahn's algorithm
+    const q: string[] = [];
+    const sorted: string[] = [];
+
+    for (const [nodeId, degree] of inDegree.entries()) {
+      if (degree === 0) {
+        q.push(nodeId);
+      }
+    }
+
+    let count = 0; // To detect cycles
+
+    while (q.length > 0) {
+      const u = q.shift()!;
+      sorted.push(u);
+      count++;
+
+      const neighbors = graph.get(u) || [];
+      for (const v of neighbors) {
+        inDegree.set(v, inDegree.get(v)! - 1);
+        if (inDegree.get(v) === 0) {
+          q.push(v);
+        }
+      }
+    }
+
+    if (count !== discoveredPlugins.size) { // Check if all nodes were included in the sort
+      throw new Error(`Circular dependency detected for ${pluginName}@${version}`);
+    }
+
+    return sorted;
+  }
+
+  flattenDependencies(pluginName: string, version: string): string[] {
+    // This calls buildTree internally, which handles simple cycle detection to prevent infinite recursion.
+    const tree = this.buildTree(pluginName, version);
+    const flattened = new Set<string>();
+
+    const traverse = (node: DependencyNode) => {
+      flattened.add(`${node.name}@${node.version}`);
+      for (const dep of node.dependencies) {
+        traverse(dep);
+      }
+    };
+    traverse(tree);
+    return Array.from(flattened);
+  }
+}
