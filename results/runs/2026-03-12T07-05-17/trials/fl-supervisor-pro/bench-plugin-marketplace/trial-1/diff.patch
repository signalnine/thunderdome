+// Plugin Registry Module
+import { PluginManifest, RegistryService } from '../types.js';
+
+export class PluginRegistry implements RegistryService {
+  private plugins: Map<string, Map<string, PluginManifest>> = new Map();
+  private nextReviewId = 1; // Placeholder for review ID generation, though not used in Registry
+
+  register(manifest: PluginManifest): void {
+    const { name, version } = manifest;
+    if (!this.plugins.has(name)) {
+      this.plugins.set(name, new Map());
+    }
+    const versions = this.plugins.get(name)!;
+    if (versions.has(version)) {
+      // Optionally update existing version or throw an error
+      // For now, let's assume it's an update or overwrite
+      console.warn(`Overwriting plugin ${name}@${version}`);
+    }
+    versions.set(version, manifest);
+  }
+
+  get(name: string): PluginManifest | null {
+    const versions = this.plugins.get(name);
+    if (!versions || versions.size === 0) {
+      return null;
+    }
+    // Return the latest version by default? Or first found?
+    // For now, let's just return one if it exists. The interface doesn't specify which version.
+    // A more robust approach might be to return the manifest for a specific version or the latest.
+    // The current `getVersion` handles specific versions.
+    return versions.values().next().value || null;
+  }
+
+  getVersion(name: string, version: string): PluginManifest | null {
+    const versions = this.plugins.get(name);
+    return versions?.get(version) || null;
+  }
+
+  list(): PluginManifest[] {
+    const allPlugins: PluginManifest[] = [];
+    for (const versions of this.plugins.values()) {
+      for (const manifest of versions.values()) {
+        allPlugins.push(manifest);
+      }
+    }
+    return allPlugins;
+  }
+
+  search(query: string): PluginManifest[] {
+    // Simple search by name for now. Could be extended to search description, author, etc.
+    const results: PluginManifest[] = [];
+    const lowerQuery = query.toLowerCase();
+    for (const versions of this.plugins.values()) {
+      for (const manifest of versions.values()) {
+        if (manifest.name.toLowerCase().includes(lowerQuery) || manifest.description.toLowerCase().includes(lowerQuery)) {
+          results.push(manifest);
+        }
+      }
+    }
+    return results;
+  }
+
+  remove(name: string, version: string): boolean {
+    const versions = this.plugins.get(name);
+    if (!versions) {
+      return false;
+    }
+    return versions.delete(version);
+  }
+
+  listVersions(name: string): string[] {
+    const versions = this.plugins.get(name);
+    return versions ? Array.from(versions.keys()) : [];
+  }
+
+  update(name: string, version: string, updates: Partial<PluginManifest>): void {
+    const manifest = this.getVersion(name, version);
+    if (manifest) {
+      // Merge updates into the existing manifest
+      const updatedManifest = { ...manifest, ...updates };
+      this.plugins.get(name)!.set(version, updatedManifest);
+    } else {
+      throw new Error(`Plugin ${name}@${version} not found for update.`);
+    }
+  }
+}
