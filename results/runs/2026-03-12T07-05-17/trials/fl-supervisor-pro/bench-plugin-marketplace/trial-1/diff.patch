@@ -0,0 +1,82 @@
+import { Review, ReviewService } from '../types.js';
+
+export class ReviewSystem implements ReviewService {
+  private reviews: Map<number, Review> = new Map();
+  private pluginReviews: Map<string, number[]> = new Map(); // pluginName -> review IDs
+  private nextReviewId = 1;
+
+  addReview(review: Omit<Review, 'id' | 'createdAt' | 'flagged'>): Review {
+    const newReview: Review = {
+      ...review,
+      id: this.nextReviewId++,
+      createdAt: new Date().toISOString(),
+      flagged: false,
+    };
+    this.reviews.set(newReview.id, newReview);
+
+    if (!this.pluginReviews.has(newReview.pluginName)) {
+      this.pluginReviews.set(newReview.pluginName, []);
+    }
+    this.pluginReviews.get(newReview.pluginName)!.push(newReview.id);
+
+    return newReview;
+  }
+
+  getReviews(pluginName: string): Review[] {
+    const reviewIds = this.pluginReviews.get(pluginName);
+    if (!reviewIds) {
+      return [];
+    }
+    return reviewIds.map(id => this.reviews.get(id)!);
+  }
+
+  getAverageRating(pluginName: string): number {
+    const reviews = this.getReviews(pluginName).filter(review => !review.flagged);
+    if (reviews.length === 0) {
+      return 0;
+    }
+    const totalRating = reviews.reduce((sum, review) => sum + review.rating, 0);
+    return totalRating / reviews.length;
+  }
+
+  flagReview(reviewId: number): void {
+    const review = this.reviews.get(reviewId);
+    if (review) {
+      review.flagged = true;
+    }
+  }
+
+  getFlaggedReviews(): Review[] {
+    return Array.from(this.reviews.values()).filter(review => review.flagged);
+  }
+
+  removeReview(reviewId: number): boolean {
+    const review = this.reviews.get(reviewId);
+    if (!review) {
+      return false;
+    }
+
+    // Remove from pluginReviews map
+    const pluginName = review.pluginName;
+    const reviewIds = this.pluginReviews.get(pluginName);
+    if (reviewIds) {
+      const index = reviewIds.indexOf(reviewId);
+      if (index > -1) {
+        reviewIds.splice(index, 1);
+      }
+      if (reviewIds.length === 0) {
+        this.pluginReviews.delete(pluginName);
+      }
+    }
+
+    return this.reviews.delete(reviewId);
+  }
+
+  getReviewsByUser(userId: string): Review[] {
+    return Array.from(this.reviews.values()).filter(review => review.userId === userId);
+  }
+
+  getReviewCount(pluginName: string): number {
+    return this.pluginReviews.get(pluginName)?.length || 0;
+  }
+}
