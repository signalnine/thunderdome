+import { VersionConstraint, ResolvedVersion, ResolverService } from '../types.js';
+import * as semver from 'semver';
+
+export class VersionResolver implements ResolverService {
+  resolve(constraints: VersionConstraint[], available: Record<string, string[]>): ResolvedVersion[] {
+    const resolved: ResolvedVersion[] = [];
+    for (const constraint of constraints) {
+      const versions = available[constraint.name];
+      if (!versions) {
+        throw new Error(`No versions available for plugin: ${constraint.name}`);
+      }
+
+      const maxSatisfyingVersion = this.maxSatisfying(versions, constraint.range);
+
+      if (!maxSatisfyingVersion) {
+        throw new Error(`No version satisfies constraint ${constraint.name}@${constraint.range}`);
+      }
+
+      resolved.push({
+        name: constraint.name,
+        version: maxSatisfyingVersion,
+        satisfies: constraint.range,
+      });
+    }
+    return resolved;
+  }
+
+  satisfies(version: string, range: string): boolean {
+    return semver.satisfies(version, range);
+  }
+
+  maxSatisfying(versions: string[], range: string): string | null {
+    // Filter out invalid versions before finding max satisfying
+    const validVersions = versions.filter(v => semver.valid(v));
+    return semver.maxSatisfying(validVersions, range);
+  }
+
+  validRange(range: string): boolean {
+    if (range === '') {
+      return false; // Explicitly treat empty string as an invalid range
+    }
+    return semver.validRange(range) !== null;
+  }
+}
