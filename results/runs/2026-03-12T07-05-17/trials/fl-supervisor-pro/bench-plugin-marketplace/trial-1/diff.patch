+import { SandboxedRunner } from './SandboxedRunner';
+import { vi } from 'vitest';
+
+describe('SandboxedRunner', () => {
+  let runner: SandboxedRunner;
+
+  beforeEach(() => {
+    runner = new SandboxedRunner();
+    // No general mocks for vm.createContext or vm.Script in beforeEach.
+    // Tests will run against the real vm module for more accurate results.
+  });
+
+  afterEach(() => {
+    vi.restoreAllMocks(); // Restore mocks if any were applied within a specific test
+  });
+
+  it('should execute basic code successfully', async () => {
+    const code = '1 + 1;';
+    const result = await runner.execute(code);
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(2); // Actual output of 1 + 1
+    expect(result.error).toBeUndefined();
+    expect(result.duration).toBeGreaterThanOrEqual(0);
+    expect(result.memoryUsed).toBeDefined();
+  });
+
+  it('should handle context variables', async () => {
+    const code = 'result = contextVar * 2; result;'; // Last expression `result` is the completion value
+    const context = { contextVar: 5, result: 0 };
+    const result = await runner.execute(code, context);
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(10);
+  });
+
+  it('should detect and report errors', async () => {
+    const code = 'throw new Error("Plugin failed")';
+    const result = await runner.execute(code);
+    expect(result.success).toBe(false);
+    expect(result.output).toBeUndefined();
+    expect(result.error).toBe('Plugin failed');
+  });
+
+  it('should enforce execution timeout', async () => {
+    // This test needs a real long-running script and checks against a small timeout
+    const code = `
+      let i = 0;
+      while (true) { i++; } // Infinite loop
+    `;
+    const timeout = 200; // milliseconds
+
+    const result = await runner.executeWithTimeout(code, timeout);
+    expect(result.success).toBe(false);
+    expect(result.error).toContain('Script execution timed out');
+    expect(result.duration).toBeGreaterThanOrEqual(timeout); // Duration should be around the timeout
+  });
+
+  it('should return exported module content', async () => {
+    const code = 'module.exports = { func: () => "hello" };';
+    const result = await runner.execute(code);
+    expect(result.success).toBe(true);
+    type OutputWithFunc = { func: () => string; };
+    expect((result.output as OutputWithFunc).func()).toBe('hello');
+  });
+
+  it('should handle code that modifies the sandbox context', async () => {
+    const code = 'var x = 10; x;'; // The completion value of `x;` is `10`
+    const sandboxContext = {};
+    const result = await runner.execute(code, sandboxContext);
+    expect(result.success).toBe(true);
+    expect(result.output).toBe(10);
+    // Note: To truly assert context modification, we'd need to pass a mutable object
+    // to the sandbox and inspect it after execution. The `output` captures the script's
+    // completion value.
+  });
+});
