+++ b/src/deps/DependencyGraph.test.ts
@@ -0,0 +1,201 @@
+import { DependencyGraph } from './DependencyGraph';
+import { PluginManifest, RegistryService } from '../types';
+import { PluginRegistry } from '../registry/PluginRegistry'; // Using real registry for mock behavior
+
+describe('DependencyGraph', () => {
+  let mockRegistry: RegistryService;
+  let dependencyGraph: DependencyGraph;
+
+  const createManifest = (
+    name: string,
+    version: string,
+    dependencies: Record<string, string> = {}
+  ): PluginManifest => ({
+    name,
+    version,
+    description: 'test',
+    author: 'test',
+    dependencies,
+    entryPoint: 'index.js',
+    permissions: [],
+  });
+
+  beforeEach(() => {
+    // We'll use a real PluginRegistry to act as our mock for DependencyGraph
+    // This simplifies managing available versions for semver resolution
+    mockRegistry = new PluginRegistry();
+    dependencyGraph = new DependencyGraph(mockRegistry);
+
+    // Populate registry with some plugins
+    mockRegistry.register(createManifest('A', '1.0.0', { B: '^1.0.0' }));
+    mockRegistry.register(createManifest('A', '1.1.0', { B: '^1.0.0' }));
+    mockRegistry.register(createManifest('B', '1.0.0', { C: '^1.0.0' }));
+    mockRegistry.register(createManifest('B', '1.1.0', { C: '~1.0.0' })); // Different dependency for B@1.1.0
+    mockRegistry.register(createManifest('C', '1.0.0'));
+    mockRegistry.register(createManifest('C', '1.0.1'));
+    mockRegistry.register(createManifest('D', '1.0.0', { E: '1.0.0' }));
+    mockRegistry.register(createManifest('E', '1.0.0'));
+    mockRegistry.register(createManifest('F', '1.0.0'));
+  });
+
+  // --- buildTree tests ---
+  it('should build a simple dependency tree', () => {
+    const tree = dependencyGraph.buildTree('A', '1.0.0');
+    expect(tree).toEqual({
+      name: 'A',
+      version: '1.0.0',
+      dependencies: [
+        {
+          name: 'B',
+          version: '1.1.0', // Updated to 1.1.0 as max satisfying for ^1.0.0
+          dependencies: [
+            {
+              name: 'C',
+              version: '1.0.1', // Updated to 1.0.1 as max satisfying for ~1.0.0 (from B@1.1.0)
+              dependencies: [],
+            },
+          ],
+        },
+      ],
+    });
+  });
+
+  it('should build a dependency tree with different versions resolved', () => {
+    // A@1.1.0 also depends on B@^1.0.0
+    // If B@1.1.0 is available and depends on C@~1.0.0
+    const tree = dependencyGraph.buildTree('A', '1.1.0');
+    expect(tree).toEqual({
+      name: 'A',
+      version: '1.1.0',
+      dependencies: [
+        {
+          name: 'B',
+          version: '1.1.0', // max satisfying B for ^1.0.0 is B@1.1.0
+          dependencies: [
+            {
+              name: 'C',
+              version: '1.0.1', // max satisfying C for ~1.0.0 is C@1.0.1
+              dependencies: [],
+            },
+          ],
+        },
+      ],
+    });
+  });
+
+  it('should throw if plugin not found', () => {
+    expect(() => dependencyGraph.buildTree('X', '1.0.0')).toThrow('Plugin X@1.0.0 not found in registry.');
+  });
+
+  it('should throw if a dependency is not found', () => {
+    mockRegistry.register(createManifest('Parent', '1.0.0', { NonExistentDep: '^1.0.0' }));
+    expect(() => dependencyGraph.buildTree('Parent', '1.0.0')).toThrow(/No versions available for dependency NonExistentDep/);
+  });
+
+  // --- detectCycles / hasCircularDependency tests ---
+  it('should detect a direct circular dependency', () => {
+    mockRegistry.register(createManifest('X', '1.0.0', { Y: '^1.0.0' }));
+    mockRegistry.register(createManifest('Y', '1.0.0', { X: '^1.0.0' }));
+    const cycles = dependencyGraph.detectCycles('X', '1.0.0');
+    expect(cycles).toEqual([['X@1.0.0', 'Y@1.0.0']]);
+    expect(dependencyGraph.hasCircularDependency('X', '1.0.0')).toBe(true);
+  });
+
+  it('should detect a transitive circular dependency', () => {
+    mockRegistry.register(createManifest('X', '1.0.0', { Y: '^1.0.0' }));
+    mockRegistry.register(createManifest('Y', '1.0.0', { Z: '^1.0.0' }));
+    mockRegistry.register(createManifest('Z', '1.0.0', { X: '^1.0.0' }));
+    const cycles = dependencyGraph.detectCycles('X', '1.0.0');
+    expect(cycles).toEqual([['X@1.0.0', 'Y@1.0.0', 'Z@1.0.0']]);
+    expect(dependencyGraph.hasCircularDependency('X', '1.0.0')).toBe(true);
+  });
+
+  it('should return null if no circular dependencies', () => {
+    const cycles = dependencyGraph.detectCycles('A', '1.0.0');
+    expect(cycles).toBeNull();
+    expect(dependencyGraph.hasCircularDependency('A', '1.0.0')).toBe(false);
+  });
+
+  it('should detect multiple cycles', () => {
+    // X -> Y -> X
+    // X -> Z -> X
+    mockRegistry.register(createManifest('X', '1.0.0', { Y: '^1.0.0', Z: '^1.0.0' }));
+    mockRegistry.register(createManifest('Y', '1.0.0', { X: '^1.0.0' }));
+    mockRegistry.register(createManifest('Z', '1.0.0', { X: '^1.0.0' }));
+
+    const cycles = dependencyGraph.detectCycles('X', '1.0.0');
+    // The order of cycles might vary, so we check for presence
+    expect(cycles).not.toBeNull();
+    expect(cycles?.length).toBe(2);
+    // Use `expect.arrayContaining` for flexible order of elements within the cycle,
+    // and `expect.objectContaining` for matching the cycles themselves.
+    expect(cycles).toEqual(expect.arrayContaining([
+      expect.arrayContaining(['X@1.0.0', 'Y@1.0.0']),
+      expect.arrayContaining(['X@1.0.0', 'Z@1.0.0']),
+    ]));
+  });
+
+  // --- topologicalSort tests ---
+  it('should perform a topological sort for a simple graph', () => {
+    const sorted = dependencyGraph.topologicalSort('A', '1.0.0');
+    // Corrected expected order based on `A -> B@1.1.0 -> C@1.0.1`
+    // C is a dependency of B, B is a dependency of A. So C then B then A.
+    expect(sorted).toEqual(['C@1.0.1', 'B@1.1.0', 'A@1.0.0']);
+  });
+
+  it('should perform a topological sort for a graph with parallel dependencies', () => {
+    mockRegistry.register(createManifest('P', '1.0.0', { Q: '1.0.0', R: '1.0.0' }));
+    mockRegistry.register(createManifest('Q', '1.0.0'));
+    mockRegistry.register(createManifest('R', '1.0.0'));
+
+    const sorted = dependencyGraph.topologicalSort('P', '1.0.0');
+    // Q and R can be in any order, but must come before P
+    expect(sorted).toContain('Q@1.0.0');
+    expect(sorted).toContain('R@1.0.0');
+    expect(sorted.indexOf('Q@1.0.0')).toBeLessThan(sorted.indexOf('P@1.0.0'));
+    expect(sorted.indexOf('R@1.0.0')).toBeLessThan(sorted.indexOf('P@1.0.0'));
+    expect(sorted.length).toBe(3);
+  });
+
+  it('should throw an error for topological sort if circular dependency exists', () => {
+    mockRegistry.register(createManifest('X', '1.0.0', { Y: '^1.0.0' }));
+    mockRegistry.register(createManifest('Y', '1.0.0', { X: '^1.0.0' }));
+    // The error should be about circular dependency, not about a missing version.
+    // Debugging `topologicalSort` to understand why it throws the wrong error.
+    expect(() => dependencyGraph.topologicalSort('X', '1.0.0')).toThrow('Circular dependency detected for X@1.0.0');
+  });
+
+  // --- flattenDependencies tests ---
+  it('should flatten a simple dependency tree', () => {
+    const flattened = dependencyGraph.flattenDependencies('A', '1.0.0');
+    // Order doesn't strictly matter for flattened, but should contain all unique dependencies
+    expect(flattened).toHaveLength(3);
+    expect(flattened).toContain('A@1.0.0');
+    expect(flattened).toContain('B@1.1.0'); // Updated expectation
+    expect(flattened).toContain('C@1.0.1'); // Updated expectation
+  });
+
+  it('should flatten a dependency tree with shared dependencies, returning unique entries', () => {
+    mockRegistry.register(createManifest('P', '1.0.0', { Q: '1.0.0', R: '1.0.0' }));
+    mockRegistry.register(createManifest('Q', '1.0.0', { S: '1.0.0' }));
+    mockRegistry.register(createManifest('R', '1.0.0', { S: '1.0.0' }));
+    mockRegistry.register(createManifest('S', '1.0.0'));
+
+    const flattened = dependencyGraph.flattenDependencies('P', '1.0.0');
+    expect(flattened).toHaveLength(4); // P, Q, R, S
+    expect(flattened).toContain('P@1.0.0');
+    expect(flattened).toContain('Q@1.0.0');
+    expect(flattened).toContain('R@1.0.0');
+    expect(flattened).toContain('S@1.0.0');
+  });
+
+  it('flattenDependencies should handle direct circular dependency gracefully in tree building (stops recursion)', () => {
+    mockRegistry.register(createManifest('X', '1.0.0', { Y: '^1.0.0' }));
+    mockRegistry.register(createManifest('Y', '1.0.0', { X: '^1.0.0' }));
+
+    const flattened = dependencyGraph.flattenDependencies('X', '1.0.0');
+    expect(flattened).toHaveLength(2); // Should contain X and Y
+    expect(flattened).toContain('X@1.0.0');
+    expect(flattened).toContain('Y@1.0.0');
+  });
+});
