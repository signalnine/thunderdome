+import { VersionResolver } from './VersionResolver';
+import { VersionConstraint } from '../types';
+
+describe('VersionResolver', () => {
+  let resolver: VersionResolver;
+
+  beforeEach(() => {
+    resolver = new VersionResolver();
+  });
+
+  const availableVersions = {
+    'plugin-a': ['1.0.0', '1.0.1', '1.1.0', '2.0.0'],
+    'plugin-b': ['0.9.0', '1.0.0', '1.0.5'],
+    'plugin-c': ['3.0.0'],
+    'plugin-d': ['1.0.0-alpha', '1.0.0-beta', '1.0.0'], // Includes a stable version
+    'invalid-plugin': ['abc', '1.2.3', 'def'], // Contains invalid semver
+  };
+
+  it('should resolve a single constraint', () => {
+    const constraints: VersionConstraint[] = [{ name: 'plugin-a', range: '^1.0.0' }];
+    const resolved = resolver.resolve(constraints, availableVersions);
+    expect(resolved).toEqual([{ name: 'plugin-a', version: '1.1.0', satisfies: '^1.0.0' }]);
+  });
+
+  it('should resolve multiple constraints', () => {
+    const constraints: VersionConstraint[] = [
+      { name: 'plugin-a', range: '~1.0.0' },
+      { name: 'plugin-b', range: '>=1.0.0' },
+    ];
+    const resolved = resolver.resolve(constraints, availableVersions);
+    expect(resolved).toEqual([
+      { name: 'plugin-a', version: '1.0.1', satisfies: '~1.0.0' },
+      { name: 'plugin-b', version: '1.0.5', satisfies: '>=1.0.0' },
+    ]);
+  });
+
+  it('should throw error if no versions available for a plugin', () => {
+    const constraints: VersionConstraint[] = [{ name: 'non-existent-plugin', range: '^1.0.0' }];
+    expect(() => resolver.resolve(constraints, availableVersions)).toThrow(
+      'No versions available for plugin: non-existent-plugin'
+    );
+  });
+
+  it('should throw error if no version satisfies the constraint', () => {
+    const constraints: VersionConstraint[] = [{ name: 'plugin-c', range: '^4.0.0' }];
+    expect(() => resolver.resolve(constraints, availableVersions)).toThrow(
+      'No version satisfies constraint plugin-c@^4.0.0'
+    );
+  });
+
+  it('should handle pre-release versions correctly with specific ranges', () => {
+    // When a pre-release tag is included in a caret range (e.g., ^1.0.0-alpha),
+    // semver will find the highest matching version that is also a pre-release within the same major.minor.patch line,
+    // *unless* a stable version within that range is also available and higher.
+    // In semver's behavior, 1.0.0 is considered "higher" than 1.0.0-beta for the ^1.0.0-alpha range.
+    // So, we expect '1.0.0' as the max satisfying version here.
+    const constraints: VersionConstraint[] = [{ name: 'plugin-d', range: '^1.0.0-alpha' }];
+    const resolved = resolver.resolve(constraints, availableVersions);
+    expect(resolved).toEqual([{ name: 'plugin-d', version: '1.0.0', satisfies: '^1.0.0-alpha' }]);
+  });
+
+  it('should satisfy a version against a range', () => {
+    expect(resolver.satisfies('1.0.0', '^1.0.0')).toBe(true);
+    expect(resolver.satisfies('1.1.0', '^1.0.0')).toBe(true);
+    expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+    expect(resolver.satisfies('1.0.0-alpha', '1.0.0-alpha.1')).toBe(false);
+    expect(resolver.satisfies('1.0.0-alpha', '1.0.0-alpha')).toBe(true);
+  });
+
+  it('should find max satisfying version', () => {
+    expect(resolver.maxSatisfying(availableVersions['plugin-a'], '^1.0.0')).toBe('1.1.0');
+    expect(resolver.maxSatisfying(availableVersions['plugin-b'], '1.0.0')).toBe('1.0.0');
+    expect(resolver.maxSatisfying(availableVersions['plugin-b'], '~0.9.0')).toBe('0.9.0');
+    expect(resolver.maxSatisfying(availableVersions['plugin-a'], '3.0.0')).toBeNull();
+    // Update expectation based on semver behavior for ^1.0.0-alpha when 1.0.0 is present.
+    expect(resolver.maxSatisfying(availableVersions['plugin-d'], '^1.0.0-alpha')).toBe('1.0.0');
+  });
+
+  it('maxSatisfying should ignore invalid semver versions', () => {
+    expect(resolver.maxSatisfying(availableVersions['invalid-plugin'], '^1.0.0')).toBe('1.2.3');
+  });
+
+  it('should validate semver ranges', () => {
+    // Create a fresh resolver to ensure no state interference
+    const localResolver = new VersionResolver();
+    expect(localResolver.validRange('^1.0.0')).toBe(true);
+    expect(localResolver.validRange('1.x')).toBe(true);
+    expect(localResolver.validRange('>=1.0.0 <2.0.0')).toBe(true);
+    expect(localResolver.validRange('invalid-range')).toBe(false);
+    expect(localResolver.validRange('')).toBe(false);
+    // Removed console.log
+  });
+});
