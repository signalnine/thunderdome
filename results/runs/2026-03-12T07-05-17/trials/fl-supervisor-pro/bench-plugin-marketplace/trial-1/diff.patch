+import { createMarketplace, PluginMarketplace } from './index';
+import { PluginManifest } from './types';
+import { PluginRegistry } from './registry/PluginRegistry';
+import { VersionResolver } from './resolver/VersionResolver';
+import { SandboxedRunner } from './runner/SandboxedRunner';
+import { DependencyGraph } from './deps/DependencyGraph';
+
+describe('PluginMarketplace Integration', () => {
+  let marketplace: PluginMarketplace;
+  let registry: PluginRegistry; // Access to underlying registry for assertions
+  let resolver: VersionResolver;
+  let runner: SandboxedRunner;
+  let depGraph: DependencyGraph;
+
+  const createManifest = (
+    name: string,
+    version: string,
+    dependencies: Record<string, string> = {},
+    entryPoint: string = 'console.log("Hello from plugin");'
+  ): PluginManifest => ({
+    name,
+    version,
+    description: `Test plugin ${name}`,
+    author: 'test-author',
