+import {
+  PluginManifest,
+  RegistryService,
+  ResolverService,
+  RunnerService,
+  ReviewService,
+  DepsService,
+  ResolvedVersion,
+  SandboxResult,
+  VersionConstraint,
+} from './types.js';
+import { PluginRegistry } from './registry/PluginRegistry.js';
+import { VersionResolver } from './resolver/VersionResolver.js';
+import { SandboxedRunner } from './runner/SandboxedRunner.js';
+import { ReviewSystem } from './reviews/ReviewSystem.js';
+import { DependencyGraph } from './deps/DependencyGraph.js';
+
+// Define the Marketplace interface to expose high-level functions
+export interface PluginMarketplace {
+  installPlugin(manifest: PluginManifest, context?: Record<string, unknown>): Promise<{
+    resolvedDependencies: ResolvedVersion[];
+    executionResult: SandboxResult;
+  }>;
+  getRegistry(): RegistryService;
+  getReviewSystem(): ReviewService;
+  getDependencyGraph(): DepsService;
+  getRunner(): RunnerService;
+  getResolver(): ResolverService;
+  // Add other marketplace-level operations as needed
+}
+
+export function createMarketplace(): PluginMarketplace {
+  const registry = new PluginRegistry();
+  const resolver = new VersionResolver();
+  const runner = new SandboxedRunner();
+  const reviewSystem = new ReviewSystem();
+  const depGraph = new DependencyGraph(registry); // DependencyGraph needs access to the registry
+
+  return {
+    getRegistry: () => registry,
+    getReviewSystem: () => reviewSystem,
+    getDependencyGraph: () => depGraph,
+    getRunner: () => runner,
+    getResolver: () => resolver,
+
+    async installPlugin(manifest: PluginManifest, context?: Record<string, unknown>): Promise<{
+      resolvedDependencies: ResolvedVersion[];
+      executionResult: SandboxResult;
+    }> {
+      // 1. Validate that the plugin manifest has the required fields
+      if (!manifest.name || !manifest.version || !manifest.entryPoint) {
+        throw new Error('Plugin manifest must contain name, version, and entryPoint.');
+      }
+
+      // 2. Register the plugin in the catalog
+      // This is crucial because DependencyGraph and VersionResolver will query the registry
+      registry.register(manifest);
+
+      // Prepare dependency constraints for direct dependencies
+      const directDependencyConstraints: VersionConstraint[] = Object.entries(manifest.dependencies).map(
+        ([name, range]) => ({ name, range })
+      );
+
+      // Get available versions for all direct dependencies from the registry
+      const availableDirectDependencyVersions: Record<string, string[]> = {};
+      for (const depName in manifest.dependencies) {
+        availableDirectDependencyVersions[depName] = registry.listVersions(depName);
+        if (!availableDirectDependencyVersions[depName] || availableDirectDependencyVersions[depName].length === 0) {
+            throw new Error(`No versions available in registry for direct dependency: ${depName}`);
+        }
+      }
+
+      // 3. Resolve its direct dependency versions against what's available in the registry
+      const resolvedDependencies = resolver.resolve(directDependencyConstraints, availableDirectDependencyVersions);
+
+      // 4. Check for circular dependencies (reject if found)
+      // The depGraph will internally resolve all transitive dependencies using the registry.
+      // So, if any transitive dependency is not found in the registry, depGraph methods will throw.
+      // This is the desired behavior as all dependencies must be resolvable from the registry.
+      if (depGraph.hasCircularDependency(manifest.name, manifest.version)) {
+        throw new Error(`Circular dependency detected for plugin ${manifest.name}@${manifest.version}`);
+      }
+      
+      // Get the topological order of all dependencies for this plugin.
+      // This ensures that all dependencies can be loaded in the correct order.
+      const topologicalOrder = depGraph.topologicalSort(manifest.name, manifest.version);
+
+      // 5. Execute the plugin's entry point in the sandbox
+      const executionResult = await runner.execute(manifest.entryPoint, {
+        ...context,
+        // Make resolved direct dependencies available in sandbox context
+        resolvedDependencies: resolvedDependencies,
+        // Also provide the full topological order if it's relevant for plugin execution logic
+        topologicalOrder: topologicalOrder,
+      });
+
+      // 6. Return the resolved dependency versions and sandbox execution result
+      return {
+        resolvedDependencies,
+        executionResult,
+      };
+    },
+  };
+}
