+import request from 'supertest';
+import { createApp } from '../index';
+import { getDatabase, initializeDatabase } from '../db';
+import { v4 as uuidv4 } from 'uuid';
+
+describe('Auth API', () => {
+  let app: Express.Application;
+
+  beforeAll(() => {
+    process.env.NODE_ENV = 'test';
+    app = createApp();
+    // Ensure database is initialized for each test run,
+    // in-memory database will be created.
+    initializeDatabase();
+  });
+
+  afterEach(() => {
+    // Clear database after each test to ensure isolation
+    const db = getDatabase();
+    db.exec(`
+      DELETE FROM users;
+    `);
+  });
+
+  afterAll(() => {
+    // Close the database connection after all tests are done
+    const db = getDatabase();
+    db.close();
+  });
+
+  it('should register a new user successfully', async () => {
+    const email = `test-${uuidv4()}@example.com`;
+    const password = 'password123';
+
+    const res = await request(app)
+      .post('/auth/register')
+      .send({ email, password });
+
+    expect(res.statusCode).toEqual(201);
+    expect(res.body.message).toEqual('User registered successfully');
+    expect(res.body).toHaveProperty('userId');
+    expect(res.body).toHaveProperty('tenantId');
+
+    const db = getDatabase();
+    const user = db.prepare('SELECT * FROM users WHERE email = ?').get(email);
+    expect(user).toBeDefined();
+    expect(user.email).toEqual(email);
+    expect(user.role).toEqual('admin');
+  });
+
+  it('should not register a user with an existing email', async () => {
+    const email = `existing-${uuidv4()}@example.com`;
+    const password = 'password123';
+
+    // First registration
+    await request(app)
+      .post('/auth/register')
+      .send({ email, password })
+      .expect(201);
+
+    // Second registration with the same email
+    const res = await request(app)
+      .post('/auth/register')
+      .send({ email, password });
+
+    expect(res.statusCode).toEqual(409);
+    expect(res.text).toEqual('User with that email already exists');
+  });
+
+  it('should login a registered user successfully and return a token', async () => {
+    const email = `login-${uuidv4()}@example.com`;
+    const password = 'password123';
+
+    // Register user first
+    await request(app)
+      .post('/auth/register')
+      .send({ email, password })
+      .expect(201);
+
+    // Then login
+    const res = await request(app)
+      .post('/auth/login')
+      .send({ email, password });
+
+    expect(res.statusCode).toEqual(200);
+    expect(res.body).toHaveProperty('token');
+    expect(typeof res.body.token).toBe('string');
+  });
+
+  it('should not login with invalid credentials', async () => {
+    const email = `invalid-${uuidv4()}@example.com`;
+    const password = 'wrongpassword';
+
+    // Try to login without registering
+    const res = await request(app)
+      .post('/auth/login')
+      .send({ email, password });
+
+    expect(res.statusCode).toEqual(401);
+    expect(res.text).toEqual('Invalid credentials');
+  });
+
+  it('should require email and password for registration', async () => {
+    const res = await request(app)
+      .post('/auth/register')
+      .send({}); // Empty body
+
+    expect(res.statusCode).toEqual(400);
+    expect(res.text).toEqual('Email and password are required');
+  });
+
+  it('should require email and password for login', async () => {
+    const res = await request(app)
+      .post('/auth/login')
+      .send({}); // Empty body
+
+    expect(res.statusCode).toEqual(400);
+    expect(res.text).toEqual('Email and password are required');
+  });
+});
