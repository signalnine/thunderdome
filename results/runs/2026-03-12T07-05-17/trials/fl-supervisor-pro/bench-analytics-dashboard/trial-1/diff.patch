+import request from 'supertest';
+import { createApp } from '../index';
+import { getDatabase, initializeDatabase } from '../db';
+import { v4 as uuidv4 } from 'uuid';
+
+describe('Events Ingestion API', () => {
+  let app: Express.Application;
+  let authToken: string;
+  let tenantId: string;
+  let userId: string;
+
+  beforeAll(async () => {
+    process.env.NODE_ENV = 'test';
+    app = createApp();
+    initializeDatabase();
+
+    // Register a user and get a token for authentication
+    const email = `event-user-${uuidv4()}@example.com`;
+    const password = 'password123';
+    const registerRes = await request(app)
+      .post('/auth/register')
+      .send({ email, password });
+    userId = registerRes.body.userId;
+    tenantId = registerRes.body.tenantId;
+
+    const loginRes = await request(app)
+      .post('/auth/login')
+      .send({ email, password });
+    authToken = loginRes.body.token;
+  });
+
+  afterEach(() => {
+    // Clear events and users tables after each test to ensure isolation
+    const db = getDatabase();
+    db.exec(`
+      DELETE FROM events;
+      DELETE FROM users;
+    `);
+  });
+
+  afterAll(() => {
+    const db = getDatabase();
+    db.close();
+  });
+
+  describe('POST /events/ingest - Single Event', () => {
+    it('should successfully ingest a single event with valid token', async () => {
+      const event = {
+        name: 'page_view',
+        properties: { path: '/home', duration: 1000 },
+        timestamp: new Date().toISOString(),
+      };
+
+      const res = await request(app)
+        .post('/events/ingest')
+        .set('Authorization', `Bearer ${authToken}`)
+        .send({ events: [event] });
+
+      expect(res.statusCode).toEqual(202);
+      expect(res.body.message).toEqual('Successfully ingested 1 events.');
+
+      const db = getDatabase();
+      const storedEvent = db.prepare('SELECT * FROM events WHERE tenant_id = ? AND name = ?').get(tenantId, event.name);
+
+      expect(storedEvent).toBeDefined();
+      expect(storedEvent.tenant_id).toEqual(tenantId);
+      expect(storedEvent.name).toEqual(event.name);
+      expect(JSON.parse(storedEvent.properties)).toEqual(event.properties);
+      expect(storedEvent.timestamp).toEqual(event.timestamp);
+      expect(storedEvent.user_id).toEqual(userId);
+    });
+
+    it('should return 401 if no token is provided', async () => {
+      const event = { name: 'page_view' };
+      const res = await request(app)
+        .post('/events/ingest')
+        .send({ events: [event] });
+
+      expect(res.statusCode).toEqual(401);
+    });
+
+    it('should return 403 if an invalid token is provided', async () => {
+      const event = { name: 'page_view' };
+      const res = await request(app)
+        .post('/events/ingest')
+        .set('Authorization', `Bearer invalidtoken`)
+        .send({ events: [event] });
+
+      expect(res.statusCode).toEqual(403);
+    });
+
+    it('should return 400 if event name is missing', async () => {
+      const event = { properties: { path: '/home' } }; // Missing name
+      const res = await request(app)
+        .post('/events/ingest')
+        .set('Authorization', `Bearer ${authToken}`)
+        .send({ events: [event] });
+
+      expect(res.statusCode).toEqual(400);
+      expect(res.text).toEqual('Event name is required.');
+    });
+  });
+
+  describe('POST /events/ingest - Batch Events', () => {
+    it('should successfully ingest multiple events with valid token', async () => {
+      const events = [
+        { name: 'product_add_to_cart', properties: { productId: 'p1', quantity: 1 } },
+        { name: 'product_view', properties: { productId: 'p2' }, timestamp: new Date().toISOString() },
+        { name: 'checkout_started' },
+      ];
+
+      const res = await request(app)
+        .post('/events/ingest')
+        .set('Authorization', `Bearer ${authToken}`)
+        .send({ events });
+
+      expect(res.statusCode).toEqual(202);
+      expect(res.body.message).toEqual(`Successfully ingested ${events.length} events.`);
+
+      // Verify all events were ingested
+      const db = getDatabase();
+      const storedEvents = db.prepare('SELECT * FROM events WHERE tenant_id = ?').all(tenantId);
+      expect(storedEvents.length).toEqual(events.length);
+
+      // Helper to find an event by name in the stored events
+      const findStoredEvent = (name: string) => storedEvents.find(e => e.name === name);
+
+      const event1 = events[0];
+      const storedEvent1 = findStoredEvent(event1.name);
+      expect(storedEvent1).toBeDefined();
+      expect(JSON.parse(storedEvent1.properties)).toEqual(event1.properties);
+      expect(storedEvent1.user_id).toEqual(userId);
+
+      const event2 = events[1];
+      const storedEvent2 = findStoredEvent(event2.name);
+      expect(storedEvent2).toBeDefined();
+      expect(JSON.parse(storedEvent2.properties)).toEqual(event2.properties);
+      expect(storedEvent2.timestamp).toEqual(event2.timestamp);
+      expect(storedEvent2.user_id).toEqual(userId);
+
+      const event3 = events[2];
+      const storedEvent3 = findStoredEvent(event3.name);
+      expect(storedEvent3).toBeDefined();
+      expect(JSON.parse(storedEvent3.properties)).toEqual({}); // Properties should default to empty object
+      expect(storedEvent3.user_id).toEqual(userId);
+
+    });
+
+    it('should return 400 if events array is empty', async () => {
+      const res = await request(app)
+        .post('/events/ingest')
+        .set('Authorization', `Bearer ${authToken}`)
+        .send({ events: [] });
+
+      expect(res.statusCode).toEqual(400);
+      expect(res.text).toEqual('Events array is required.');
+    });
+
+    it('should return 400 if events is not an array', async () => {
+      const res = await request(app)
+        .post('/events/ingest')
+        .set('Authorization', `Bearer ${authToken}`)
+        .send({ events: {} }); // Not an array
+
+      expect(res.statusCode).toEqual(400);
+      expect(res.text).toEqual('Events array is required.');
+    });
+  });
+});
