+import { Router } from 'express';
+import { authenticateToken } from './auth';
+import { getDatabase } from './db';
+import { v4 as uuidv4 } from 'uuid';
+import { stringify } from 'csv-stringify';
+
+const dashboardsRouter = Router();
+
+// Create Dashboard
+dashboardsRouter.post('/', authenticateToken, (req, res) => {
+  const db = getDatabase();
+  const tenantId = req.tenantId;
+  const ownerId = req.userId;
+  const { name, config } = req.body;
+
+  if (!tenantId || !ownerId) {
+    return res.status(401).send('Authentication error: Tenant ID or User ID missing.');
+  }
+  if (!name) {
+    return res.status(400).send('Dashboard name is required.');
+  }
+
+  const dashboardId = uuidv4();
+  try {
+    db.prepare('INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)').run(
+      dashboardId,
+      tenantId,
+      name,
+      ownerId,
+      JSON.stringify(config || {})
+    );
+    res.status(201).json({ id: dashboardId, name, config: config || {} });
+  } catch (error) {
+    console.error('Error creating dashboard:', error);
+    res.status(500).send('Failed to create dashboard.');
+  }
+});
+
+// Get all Dashboards for a Tenant
+dashboardsRouter.get('/', authenticateToken, (req, res) => {
+  const db = getDatabase();
+  const tenantId = req.tenantId;
+
+  if (!tenantId) {
+    return res.status(401).send('Authentication error: Tenant ID missing.');
+  }
+
+  try {
+    const dashboards = db.prepare('SELECT id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ?').all(tenantId) as { id: string; name: string; owner_id: string; config: string; created_at: string; updated_at: string; }[];
+    res.status(200).json(dashboards.map(d => ({ ...d, config: JSON.parse(d.config) })));
+  } catch (error) {
+    console.error('Error fetching dashboards:', error);
+    res.status(500).send('Failed to fetch dashboards.');
+  }
+});
+
+// Get a single Dashboard by ID
+dashboardsRouter.get('/:id', authenticateToken, (req, res) => {
+  const db = getDatabase();
+  const tenantId = req.tenantId;
+  const { id } = req.params;
+
+  if (!tenantId) {
+    return res.status(401).send('Authentication error: Tenant ID missing.');
+  }
+
+  try {
+    const dashboard = db.prepare('SELECT id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE id = ? AND tenant_id = ?').get(id, tenantId) as { id: string; name: string; owner_id: string; config: string; created_at: string; updated_at: string; } | undefined;
+    if (!dashboard) {
+      return res.status(404).send('Dashboard not found or not accessible.');
+    }
+    res.status(200).json({ ...dashboard, config: JSON.parse(dashboard.config) });
+  } catch (error) {
+    console.error('Error fetching dashboard:', error);
+    res.status(500).send('Failed to fetch dashboard.');
+  }
+});
+
+// Update Dashboard
+dashboardsRouter.put('/:id', authenticateToken, (req, res) => {
+  const db = getDatabase();
+  const tenantId = req.tenantId;
+  const { id } = req.params;
+  const { name, config } = req.body;
+
+  if (!tenantId) {
+    return res.status(401).send('Authentication error: Tenant ID missing.');
+  }
+  if (!name && !config) {
+    return res.status(400).send('No update data provided. Requires name or config.');
+  }
+
+  const updateFields: string[] = [];
+  const updateParams: (string | number)[] = [];
+
+  if (name) {
+    updateFields.push('name = ?');
+    updateParams.push(name);
+  }
+  if (config) {
+    updateFields.push('config = ?');
+    updateParams.push(JSON.stringify(config));
+  }
+  updateFields.push('updated_at = datetime(\'now\')');
+
+  const query = `UPDATE dashboards SET ${updateFields.join(', ')} WHERE id = ? AND tenant_id = ?`;
+  updateParams.push(id, tenantId);
+
+  try {
+    const result = db.prepare(query).run(...updateParams);
+    if (result.changes === 0) {
+      return res.status(404).send('Dashboard not found or not accessible.');
+    }
+    res.status(200).send('Dashboard updated successfully.');
+  } catch (error) {
+    console.error('Error updating dashboard:', error);
+    res.status(500).send('Failed to update dashboard.');
+  }
+});
+
+// Delete Dashboard
+dashboardsRouter.delete('/:id', authenticateToken, (req, res) => {
+  const db = getDatabase();
+  const tenantId = req.tenantId;
+  const { id } = req.params;
+
+  if (!tenantId) {
+    return res.status(401).send('Authentication error: Tenant ID missing.');
+  }
+
+  try {
+    const result = db.prepare('DELETE FROM dashboards WHERE id = ? AND tenant_id = ?').run(id, tenantId);
+    if (result.changes === 0) {
+      return res.status(404).send('Dashboard not found or not accessible.');
+    }
+    res.status(204).send(); // No content for successful deletion
+  } catch (error) {
+    console.error('Error deleting dashboard:', error);
+    res.status(500).send('Failed to delete dashboard.');
+  }
+});
+
+dashboardsRouter.get('/export', authenticateToken, (req, res) => {
+  const db = getDatabase();
+  const tenantId = req.tenantId;
+
+  if (!tenantId) {
+    return res.status(401).send('Authentication error: Tenant ID missing.');
+  }
+
+  const { format = 'json' } = req.query;
+
+  try {
+    const dashboards = db.prepare('SELECT id, name, owner_id, config, created_at, updated_at FROM dashboards WHERE tenant_id = ?').all(tenantId) as { id: string; name: string; owner_id: string; config: string; created_at: string; updated_at: string; }[];
+
+    if (format === 'json') {
+      res.setHeader('Content-Type', 'application/json');
+      res.status(200).json(dashboards.map(d => ({ ...d, config: JSON.parse(d.config) })));
+    } else if (format === 'csv') {
+      res.setHeader('Content-Type', 'text/csv');
+      res.setHeader('Content-Disposition', 'attachment; filename="dashboards.csv"');
+
+      const processedDashboards = dashboards.map(d => ({
+        id: d.id,
+        name: d.name,
+        owner_id: d.owner_id,
+        config: JSON.stringify(JSON.parse(d.config)), // Re-stringify to keep it as a single string in CSV
+        created_at: d.created_at,
+        updated_at: d.updated_at,
+      }));
+
+      stringify(processedDashboards, { header: true }, (err, output) => {
+        if (err) {
+          console.error('CSV stringify error:', err);
+          return res.status(500).send('Failed to generate CSV.');
+        }
+        res.status(200).send(output);
+      });
+    } else {
+      res.status(400).send('Invalid format specified. Supported formats: json, csv.');
+    }
+  } catch (error) {
+    console.error('Dashboard export error:', error);
+    res.status(500).send('Failed to export dashboards.');
+  }
+});
+
+export default dashboardsRouter;
