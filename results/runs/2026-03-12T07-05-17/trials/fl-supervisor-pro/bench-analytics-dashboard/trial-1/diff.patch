+import { Router } from 'express';
+import { authenticateToken } from './auth';
+import { getDatabase } from './db';
+import { v4 as uuidv4 } from 'uuid';
+import { stringify } from 'csv-stringify';
+
+interface EventPayload {
+  name: string;
+  properties?: Record<string, unknown>; // Use unknown for arbitrary properties
+  timestamp?: string;
+  userId?: string;
+  sessionId?: string;
+}
+
+interface StoredEvent {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string; // Stored as JSON string
+  timestamp: string;
+  user_id?: string;
+  session_id?: string;
+}
+
+const eventsRouter = Router();
+
+eventsRouter.post('/ingest', authenticateToken, (req, res) => {
+  const { events } = req.body;
+  const tenantId = req.tenantId;
+
+  if (!tenantId) {
+    return res.status(401).send('Tenant ID not found in token.');
+  }
+
+  if (!events || !Array.isArray(events) || events.length === 0) {
+    return res.status(400).send('Events array is required.');
+  }
+
+  const db = getDatabase();
+  const insert = db.prepare(
+    'INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)'
+  );
+  const insertMany = db.transaction((eventsToInsert: EventPayload[]) => {
+    for (const event of eventsToInsert) {
+      const { name, properties, timestamp, userId, sessionId } = event;
+      if (!name) {
+        throw new Error('Event name is required.');
+      }
+      insert.run(
+        uuidv4(),
+        tenantId,
+        name,
+        JSON.stringify(properties || {}),
+        timestamp || new Date().toISOString(),
+        userId || req.userId,
+        sessionId
+      );
+    }
+  });
+
+  try {
+    insertMany(events);
+    res.status(202).send({ message: `Successfully ingested ${events.length} events.` });
+  } catch (error: unknown) {
+    console.error('Event ingestion error:', error);
+    if (error instanceof Error) {
+      return res.status(400).send(error.message);
+    }
+    res.status(500).send('Failed to ingest events due to an internal error.');
+  }
+});
+
+
+eventsRouter.get('/count', authenticateToken, (req, res) => {
+  const db = getDatabase();
+  const tenantId = req.tenantId;
+
+  if (!tenantId) {
+    return res.status(401).send('Tenant ID not found in token.');
+  }
+
+  const { name, properties, startDate, endDate } = req.query;
+
+  let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+  const params: (string | number)[] = [tenantId];
+
+  if (name) {
+    query += ' AND name = ?';
+    params.push(name as string);
+  }
+  if (properties) {
+    query += ' AND properties LIKE ?';
+    const parsedProperties = JSON.parse(properties as string);
+    const key = Object.keys(parsedProperties)[0];
+    const value = parsedProperties[key];
+    // This pattern will match "key":"value" anywhere in the JSON string
+    params.push(`%"${key}":"${value}"%`);
+  }
+  if (startDate) {
+    query += ' AND timestamp >= ?';
+    params.push(startDate as string);
+  }
+  if (endDate) {
+    query += ' AND timestamp <= ?';
+    params.push(endDate as string);
+  }
+
+  try {
+    const result = db.prepare(query).get(...params) as { count: number };
+    res.status(200).json({ count: result.count });
+  } catch (error) {
+    console.error('Event count error:', error);
+    res.status(500).send('Failed to count events.');
+  }
+});
+
+
+eventsRouter.get('/timeseries', authenticateToken, (req, res) => {
+  const db = getDatabase();
+  const tenantId = req.tenantId;
+
+  if (!tenantId) {
+    return res.status(401).send('Tenant ID not found in token.');
+  }
+
+  const { name, interval, startDate, endDate } = req.query;
+
+  if (!name || !interval) {
+    return res.status(400).send('Event name and interval are required for timeseries query.');
+  }
+
+  let format: string;
+  switch (interval) {
+    case 'hour':
+      format = '%Y-%m-%dT%H:00:00';
+      break;
+    case 'day':
+      format = '%Y-%m-%d';
+      break;
+    case 'month':
+      format = '%Y-%m';
+      break;
+    default:
+      return res.status(400).send('Invalid interval. Supported intervals: hour, day, month.');
+  }
+
+  let query = `
+    SELECT
+      strftime('${format}', timestamp) as time_bucket,
+      COUNT(*) as count
+    FROM events
+    WHERE tenant_id = ? AND name = ?
+  `;
+  const params: (string | number)[] = [tenantId, name as string];
+
+  if (startDate) {
+    query += ' AND timestamp >= ?';
+    params.push(startDate as string);
+  }
+  if (endDate) {
+    query += ' AND timestamp <= ?';
+    params.push(endDate as string);
+  }
+
+  query += ` GROUP BY time_bucket ORDER BY time_bucket ASC`;
+
+  try {
+    const results = db.prepare(query).all(...params);
+    res.status(200).json(results);
+  } catch (error) {
+    console.error('Timeseries query error:', error);
+    res.status(500).send('Failed to perform timeseries query.');
+  }
+});
+
+
+eventsRouter.get('/breakdowns', authenticateToken, (req, res) => {
+  const db = getDatabase();
+  const tenantId = req.tenantId;
+
+  if (!tenantId) {
+    return res.status(401).send('Tenant ID not found in token.');
+  }
+
+  const { name, propertyName, startDate, endDate } = req.query;
+
+  if (!name || !propertyName) {
+    return res.status(400).send('Event name and propertyName are required for breakdown query.');
+  }
+
+  // SQLite doesn't have native JSON functions before version 3.38.0 which is not guaranteed.
+  // We'll perform a basic text search for the property, and then parse in application.
+  // A more robust solution for complex JSON queries might involve a different DB or custom functions.
+
+  let query = `
+    SELECT
+      properties,
+      COUNT(*) as count
+    FROM events
+    WHERE tenant_id = ? AND name = ?
+  `;
+  const params: (string | number)[] = [tenantId, name as string];
+
+  if (startDate) {
+    query += ' AND timestamp >= ?';
+    params.push(startDate as string);
+  }
+  if (endDate) {
+    query += ' AND timestamp <= ?';
+    params.push(endDate as string);
+  }
+
+  query += ` GROUP BY properties`; // Grouping by the full properties JSON string is a workaround
+
+  try {
+    const rawResults = db.prepare(query).all(...params) as { properties: string; count: number }[];
+    const breakdowns: { [key: string]: number } = {};
+
+    rawResults.forEach(row => {
+      try {
+        const props = JSON.parse(row.properties);
+        const value = props[propertyName as string];
+        if (value !== undefined) {
+          const key = String(value);
+          breakdowns[key] = (breakdowns[key] || 0) + row.count;
+        }
+      } catch (e) {
+        // Handle malformed JSON or cases where property is not found
+        console.warn('Error parsing properties or property not found for breakdown:', e);
+      }
+    });
+
+    const formattedBreakdowns = Object.keys(breakdowns).map(key => ({
+      value: key,
+      count: breakdowns[key],
+    }));
+
+    res.status(200).json(formattedBreakdowns);
+  } catch (error) {
+    console.error('Breakdown query error:', error);
+    res.status(500).send('Failed to perform breakdown query.');
+  }
+});
+
+eventsRouter.get('/export', authenticateToken, (req, res) => {
+  const db = getDatabase();
+  const tenantId = req.tenantId;
+
+  if (!tenantId) {
+    return res.status(401).send('Tenant ID not found in token.');
+  }
+
+  const { format = 'json', name, properties, startDate, endDate } = req.query;
+
+  let query = 'SELECT id, name, properties, timestamp, user_id, session_id FROM events WHERE tenant_id = ?';
+  const params: (string | number)[] = [tenantId];
+
+  if (name) {
+    query += ' AND name = ?';
+    params.push(name as string);
+  }
+  if (properties) {
+    query += ' AND properties LIKE ?';
+    params.push(`%${properties}%`);
+  }
+  if (startDate) {
+    query += ' AND timestamp >= ?';
+    params.push(startDate as string);
+  }
+  if (endDate) {
+    query += ' AND timestamp <= ?';
+    params.push(endDate as string);
+  }
+
+  try {
+    const events = db.prepare(query).all(...params) as StoredEvent[];
+
+    if (format === 'json') {
+      res.setHeader('Content-Type', 'application/json');
+      res.status(200).json(events.map(event => ({ ...event, properties: JSON.parse(event.properties) })));
+    } else if (format === 'csv') {
+      res.setHeader('Content-Type', 'text/csv');
+      res.setHeader('Content-Disposition', 'attachment; filename="events.csv"');
+
+      // Convert properties JSON string to object for CSV output
+      const processedEvents = events.map(event => ({
+        ...event,
+        properties: JSON.parse(event.properties),
+      }));
+
+      stringify(processedEvents, { header: true }, (err, output) => {
+        if (err) {
+          console.error('CSV stringify error:', err);
+          return res.status(500).send('Failed to generate CSV.');
+        }
+        res.status(200).send(output);
+      });
+    } else {
+      res.status(400).send('Invalid format specified. Supported formats: json, csv.');
+    }
+  } catch (error) {
+    console.error('Event export error:', error);
+    res.status(500).send('Failed to export events.');
+  }
+});
+
+export default eventsRouter;
