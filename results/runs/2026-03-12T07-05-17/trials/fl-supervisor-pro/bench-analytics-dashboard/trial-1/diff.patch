+import Database, { Database as BetterSqlite3Database } from 'better-sqlite3';
+import path from 'path';
+import fs from 'fs';
+
+const dbPath = process.env.NODE_ENV === 'test' ? ':memory:' : path.resolve(__dirname, '../db.sqlite');
+let db: BetterSqlite3Database | null = null;
+
+export function initializeDatabase(): BetterSqlite3Database {
+  if (db) {
+    return db;
+  }
+
+  db = new Database(dbPath);
+  db.pragma('journal_mode = WAL');
+
+  const schemaPath = path.resolve(__dirname, '../schema.sql');
+  const schema = fs.readFileSync(schemaPath, 'utf8');
+  db.exec(schema);
+
+  console.log('Database initialized successfully.');
+  return db;
+}
+
+export function getDatabase(): BetterSqlite3Database {
+  if (!db) {
+    throw new Error('Database not initialized. Call initializeDatabase() first.');
+  }
+  return db;
+}
