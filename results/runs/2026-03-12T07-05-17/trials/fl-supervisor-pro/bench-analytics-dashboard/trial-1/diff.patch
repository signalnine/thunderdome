@@ -0,0 +1,54 @@
+import { Router, Request, Response, NextFunction } from 'express';
+import { authenticateToken } from './auth';
+import { getDatabase } from './db';
+
+const userRouter = Router();
+
+const authorizeRoles = (roles: string[]) => (req: Request, res: Response, next: NextFunction) => {
+  if (!req.role || !roles.includes(req.role)) {
+    return res.status(403).send('Forbidden: Insufficient permissions');
+  }
+  next();
+};
+
+userRouter.get('/profile', authenticateToken, (req, res) => {
+  const db = getDatabase();
+  const user = db.prepare('SELECT id, email, tenant_id, role, created_at FROM users WHERE id = ?').get(req.userId);
+
+  if (!user) {
+    return res.status(404).send('User not found');
+  }
+
+  res.status(200).json(user);
+});
+
+userRouter.post('/:id/role', authenticateToken, authorizeRoles(['admin']), (req, res) => {
+  const { id } = req.params;
+  const { role } = req.body;
+  const tenantId = req.tenantId;
+
+  if (!role || !['admin', 'viewer', 'editor'].includes(role)) {
+    return res.status(400).send('Invalid role provided. Role must be admin, viewer, or editor.');
+  }
+
+  const db = getDatabase();
+  try {
+    const userToUpdate = db.prepare('SELECT id, tenant_id FROM users WHERE id = ?').get(id) as { id: string; tenant_id: string } | undefined;
+
+    if (!userToUpdate) {
+      return res.status(404).send('User not found.');
+    }
+
+    if (userToUpdate.tenant_id !== tenantId) {
+      return res.status(403).send('Forbidden: Cannot change role of a user outside your tenant.');
+    }
+
+    db.prepare('UPDATE users SET role = ? WHERE id = ?').run(role, id);
+    res.status(200).send({ message: `User ${id} role updated to ${role}.` });
+  } catch (error) {
+    console.error('Error updating user role:', error);
+    res.status(500).send('Internal server error.');
+  }
+});
+
+export default userRouter;
