+++ b/src/plugins/taxonomy.ts
@@ -0,0 +1,46 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createTaxonomyPlugin(): Plugin {
+  return {
+    name: 'taxonomy',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      beforeBuild: (ctx: BuildContext) => {
+        const tagMap = new Map<string, ContentFile[]>();
+
+        ctx.files.forEach(file => {
+          const tags = file.tags || []; // Use file.tags
+          if (Array.isArray(tags)) {
+            tags.forEach(tag => {
+              const normalizedTag = String(tag).toLowerCase();
+              if (!tagMap.has(normalizedTag)) {
+                tagMap.set(normalizedTag, []);
+              }
+              tagMap.get(normalizedTag)!.push(file);
+            });
+          }
+        });
+        ctx.data.set('taxonomy-tags', tagMap);
+      },
+
+      afterBuild: (ctx: BuildContext) => {
+        const tagMap = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]>;
+
+        if (tagMap) {
+          tagMap.forEach((files, tag) => {
+            let tagPageContent = `<h1>Tag: ${tag}</h1>
+<ul>
+`;
+            files.forEach(file => {
+              tagPageContent += `  <li><a href="/${file.slug}.html">${file.title}</a></li>
+`;
+            });
+            tagPageContent += `</ul>`;
+            ctx.output.set(`tags/${tag}.html`, tagPageContent);
+          });
+        }
+      },
+    },
+  };
+}
