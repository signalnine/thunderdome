@@ -0,0 +1,46 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createSyntaxHighlightPlugin(): Plugin {
+  return {
+    name: 'syntax-highlight',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext) => {
+        // Regex to find <pre><code> blocks that have a language-* class
+        // Captures:
+        //   1: The entire <pre...tag
+        //   2: The entire <code...tag up to the closing >
+        //   3: The full class attribute string: class="..." (if present)
+        //   4: The full class attribute value: "language-js my-class" (if present)
+        //   5: The language itself (e.g., "js")
+        //   6: The content inside the <code> tag
+        //   7: The closing </code> and </pre> tags
+        const codeBlockRegex = /(<pre[^>]*>)\s*(<code\s+(class="([^"]*language-([a-zA-Z0-9]+)[^"]*)")?[^>]*>)(.*?)(<\/code>\s*<\/pre>)/gs;
+
+        file.content = file.content.replace(codeBlockRegex, (match, preTagOpen, codeTagOpenFull, classAttrOuterGroup, classAttrValue, lang, codeContent, closingTags) => {
+          if (!lang) {
+            return match; // If no language is found, return original match (e.g., <code> or <code class="not-lang">)
+          }
+
+          // Modify <pre> tag: add data-language attribute
+          const newPreTagOpen = preTagOpen.replace('>', ` data-language="${lang}">`);
+
+          // Modify <code> tag: add 'highlighted' class
+          let newCodeTagOpenFull = codeTagOpenFull;
+          if (classAttrOuterGroup) { // If class="value" is captured
+            // Class attribute exists, replace it with the modified one
+            newCodeTagOpenFull = codeTagOpenFull.replace(classAttrOuterGroup, `class="${classAttrValue} highlighted"`);
+          } else {
+            // No class attribute, add new 'class="language-XYZ highlighted"' before the closing >
+            newCodeTagOpenFull = codeTagOpenFull.replace('>', ` class="language-${lang} highlighted">`);
+          }
+
+          return `${newPreTagOpen}${newCodeTagOpenFull}${codeContent}${closingTags}`;
+        });
+
+        return file;
+      },
+    },
+  };
+}
