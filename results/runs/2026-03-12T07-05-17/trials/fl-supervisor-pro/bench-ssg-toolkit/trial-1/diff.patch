--- /dev/null
+++ b/src/plugins/rss-feed.ts
@@ -0,0 +1,52 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+export function createRssFeedPlugin(): Plugin {
+  return {
+    name: 'rss-feed',
+    version: '1.0.0',
+    dependencies: ['markdown-ext', 'taxonomy'], // Depends on markdown-ext for HTML content, and taxonomy for categories
+    hooks: {
+      afterBuild: (ctx: BuildContext) => {
+        const feedItems: string[] = [];
+        const filesToProcess = [...ctx.files]; // Create a mutable copy
+
+        filesToProcess.sort((a, b) => {
+          // Sort by date, newest first. Files without dates are treated as older.
+          const dateA = a.date ? new Date(a.date).getTime() : 0;
+          const dateB = b.date ? new Date(b.date).getTime() : 0;
+          return dateB - dateA;
+        });
+
+        filesToProcess.forEach(file => {
+          const pubDate = file.date ? `<pubDate>${new Date(file.date).toUTCString()}</pubDate>` : '';
+          const categories: string[] = file.tags || [];
+
+          let categoryXml = '';
+          categories.forEach(cat => {
+            categoryXml += `      <category>${cat}</category>\n`;
+          });
+
+          feedItems.push(`    <item>
+      <title>${file.title}</title>
+      <link>${ctx.config.baseUrl}/${file.slug}.html</link>
+      <guid>${ctx.config.baseUrl}/${file.slug}.html</guid>
+      ${pubDate}
+      <description><![CDATA[${file.content}]]></description>
+      ${categoryXml}    </item>`);
+        });
+
+        const rssFeed = `<?xml version="1.0" encoding="UTF-8"?>
+<rss version="2.0">
+  <channel>
+    <title>${ctx.config.title}</title>
+    <link>${ctx.config.baseUrl}</link>
+    <description>A feed of ${ctx.config.title}'s content</description>
+    ${feedItems.join('\n')}
+  </channel>
+</rss>`;
+
+        ctx.output.set('feed.xml', rssFeed);
+      },
+    },
+  };
+}
