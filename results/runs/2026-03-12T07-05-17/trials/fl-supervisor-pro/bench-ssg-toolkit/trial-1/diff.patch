--- /dev/null
+++ b/src/plugins/dev-server.ts
@@ -0,0 +1,49 @@
+import { Plugin, BuildContext } from '../core/types.js';
+
+interface DevServerConfig {
+  port: number;
+  routes: Array<{ path: string; handler: string }>;
+  assetPaths: string[];
+  searchIndexPath?: string;
+}
+
+export function createDevServerPlugin(): Plugin {
+  return {
+    name: 'dev-server',
+    version: '1.0.0',
+    dependencies: ['asset-pipeline', 'search-index'],
+    hooks: {
+      afterBuild: (ctx: BuildContext) => {
+        const config: DevServerConfig = {
+          port: 3000,
+          routes: [],
+          assetPaths: [],
+        };
+
+        // Add content routes
+        ctx.output.forEach((_content, path) => {
+          if (path.endsWith('.html')) {
+            config.routes.push({ path: `/${path}`, handler: 'static' });
+          }
+        });
+
+        // Add asset paths from asset-pipeline
+        const assetManifest = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        if (assetManifest && assetManifest.assets) {
+          config.assetPaths = assetManifest.assets;
+          assetManifest.assets.forEach(assetPath => {
+            config.routes.push({ path: `/${assetPath}`, handler: 'asset' });
+          });
+        }
+
+        // Add search index path
+        if (ctx.output.has('search-index.json')) {
+          config.searchIndexPath = '/search-index.json';
+          config.routes.push({ path: '/search-index.json', handler: 'static' });
+        }
+
+        ctx.data.set('dev-server-config', config);
+      },
+    },
+  };
+}
diff --git a/src/plugins/markdown-ext.ts b/src/plugins/markdown-ext.ts
new file mode 100644
index 0000000..4c5df04
--- /dev/null
+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,85 @@
+import MarkdownIt from 'markdown-it';
+import footnote from 'markdown-it-footnote';
+import container from 'markdown-it-container';
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+// Initialize markdown-it with plugins
+const md = new MarkdownIt()
+  .use(footnote);
+
+// Custom renderer for footnote_ref to match test expectations (<sup><a href="#fn-1">1</a></sup>)
+md.renderer.rules.footnote_ref = (tokens, idx, _options, _env, _self) => { // _options, _env, _self are unused
+  const id = tokens[idx].meta.id + 1; // Adjust to 1-based index
+  return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+};
+
+// Custom renderer for footnote_open to match test expectations (<li id="fn-1">)
+md.renderer.rules.footnote_open = (tokens, idx, _options, _env, _self) => { // _options, _env, _self are unused
+  const id = tokens[idx].meta.id + 1; // Adjust to 1-based index
+  return `<li id="fn-${id}">`;
+};
+
+// Custom renderer for footnote_close to match test expectations (</li>)
+md.renderer.rules.footnote_close = (_tokens, _idx, _options, _env, _self) => { // _tokens, _idx, _options, _env, _self are unused
+  return `</li>`;
+};
+
+// Custom renderer for footnote_block_open to match test expectations (<section class="footnotes">)
+md.renderer.rules.footnote_block_open = (_tokens, _idx, _options, _env, _self) => { // _tokens, _idx, _options, _env, _self are unused
+  return `<section class="footnotes">`;
+};
+
+// Custom renderer for footnote_block_close to match test expectations (</section>)
+md.renderer.rules.footnote_block_close = (_tokens, _idx, _options, _env, _self) => { // _tokens, _idx, _options, _env, _self are unused
+  return `</section>`;
+};
+
+// Custom renderer for footnote_anchor to remove the backref link (<a> element)
+md.renderer.rules.footnote_anchor = () => {
+    return ''; // The test does not expect the back reference link
+};
+
+
+// Helper to create admonition containers
+function createAdmonitionContainer(name: string) {
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  md.use(container, name, {
+    validate: function(params: string) {
+      return params.trim().match(new RegExp(`^${name}(\s|$)`));
+    },
+    // eslint-disable-next-line @typescript-eslint/no-explicit-any
+    render: function (tokens: any[], idx: number) {
+      if (tokens[idx].nesting === 1) {
+        return `<div class="admonition admonition-${name}">`;
+      } else {
+        return '</div>';
+      }
+    }
+  });
+}
+
+createAdmonitionContainer('note');
+createAdmonitionContainer('warning');
+createAdmonitionContainer('tip');
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, _ctx: BuildContext) => { // _ctx is unused
+        file.content = md.render(file.content);
+        // Post-process to remove <p> tags directly inside <li> in footnotes,
+        // while preserving newlines if they exist.
+        // The (?:\s*) non-capturing group will match any trailing whitespace (including newlines)
+        // before the </p> tag, preventing it from being captured by (.*?)
+        const footnoteRegex = /<li id="fn-(\d+)">(?:<p>)?(.*?)(?:<\/p>)?(\n?)<\/li>/gs; // Direct regex literal
+        file.content = file.content.replace(footnoteRegex, (match, p1, p2, _p3) => { // _p3 is unused
+          return `<li id="fn-${p1}">${p2.trim()}</li>`;
+        });
+        return file;
+      },
+    },
+  };
+}
