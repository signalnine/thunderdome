+import { Plugin, BuildContext, ContentFile } from '../core/types.js';
+
+export function createSitemapPlugin(): Plugin {
+  return {
+    name: 'sitemap',
+    version: '1.0.0',
+    dependencies: ['taxonomy', 'rss-feed'],
+    hooks: {
+      afterBuild: (ctx: BuildContext) => {
+        const urls: string[] = [];
+        const baseUrl = ctx.config.baseUrl;
+
+        // Add content pages
+        ctx.output.forEach((_content, path) => {
+          if (path.endsWith('.html') && !path.startsWith('tags/')) { // Exclude tag pages for now, they are handled separately if present
+            urls.push(`${baseUrl}/${path}`);
+          }
+        });
+
+        // Add taxonomy tag pages
+        const taxonomyTags = ctx.data.get('taxonomy-tags') as Map<string, ContentFile[]> | undefined;
+        if (taxonomyTags) {
+          taxonomyTags.forEach((_files, tag) => {
+            urls.push(`${baseUrl}/tags/${tag}.html`);
+          });
+        }
+
+        // Add RSS feed if it exists
+        if (ctx.output.has('feed.xml')) {
+          urls.push(`${baseUrl}/feed.xml`);
+        }
+
+        const sitemapXml = `<?xml version="1.0" encoding="UTF-8"?>
+<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
+${urls.map(url => `  <url>
+    <loc>${url}</loc>
+  </url>`).join('\n')}
+</urlset>`;
+
+        ctx.output.set('sitemap.xml', sitemapXml);
+      },
+    },
+  };
+}
