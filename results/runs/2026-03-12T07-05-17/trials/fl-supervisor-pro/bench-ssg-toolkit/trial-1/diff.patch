index 0000000..209e408
--- /dev/null
+++ b/src/plugins/asset-pipeline.ts
@@ -0,0 +1,41 @@
+import { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent: (file: ContentFile, ctx: BuildContext) => {
+        const assetManifest = (ctx.data.get('asset-manifest') || { assets: [] }) as { assets: string[] };
+
+        // Regex for img src attributes
+        // Captures the part before the URL, the URL itself, and the part after the URL.
+        // Ensures the URL is relative (doesn't start with /assets/, //, http://, or https://)
+        const imgSrcRegex = /(<img[^>]*src=["'])(?!(?:\/assets\/|\/\/|https?:\/\/))([^"']+)(["'][^>]*>)/gs;
+        file.content = file.content.replace(imgSrcRegex, (match, prefix, url, suffix) => {
+          const assetFilename = url.split('/').pop() || url;
+          const rewrittenUrl = `/assets/${assetFilename}`;
+          if (!assetManifest.assets.includes(assetFilename)) {
+            assetManifest.assets.push(assetFilename);
+          }
+          return `${prefix}${rewrittenUrl}${suffix}`;
+        });
+
+        // Regex for a href attributes
+        const aHrefRegex = /(<a[^>]*href=["'])(?!(?:\/assets\/|\/\/|https?:\/\/))([^"']+)(["'][^>]*>)/gs;
+        file.content = file.content.replace(aHrefRegex, (match, prefix, url, suffix) => {
+          const assetFilename = url.split('/').pop() || url;
+          const rewrittenUrl = `/assets/${assetFilename}`;
+          if (!assetManifest.assets.includes(assetFilename)) {
+            assetManifest.assets.push(assetFilename);
+          }
+          return `${prefix}${rewrittenUrl}${suffix}`;
+        });
+
+        ctx.data.set('asset-manifest', assetManifest);
+        return file;
+      },
+    },
+  };
+}
