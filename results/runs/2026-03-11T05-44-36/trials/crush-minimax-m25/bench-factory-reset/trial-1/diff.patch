@@ -0,0 +1,531 @@
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+function boolToNum(b: boolean): number {
+  return b ? 1 : 0;
+}
+
+// Toggle Puzzle: Solve over GF(2)
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const n = target.length;
+  const m = buttons.length;
+
+  // Build augmented matrix [A|b] where A[i][j] = 1 if button j toggles light i
+  const augMatrix: number[][] = [];
+  const b: number[] = target.map(boolToNum);
+
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row.push(b[i]);
+    augMatrix.push(row);
+  }
+
+  // Gaussian elimination over GF(2) - get RREF and solution info
+  const result = gaussianEliminationGF2(augMatrix, m);
+  if (result === null) {
+    return null;
+  }
+
+  const { particular, freeVars, pivotToRow, matrix } = result;
+
+  // If no free variables, we have a unique solution
+  if (freeVars.length === 0) {
+    const pressed: number[] = [];
+    for (let i = 0; i < m; i++) {
+      if (particular[i] === 1) {
+        pressed.push(i);
+      }
+    }
+    return pressed;
+  }
+
+  // Enumerate all solutions to find minimum weight, then lexicographically smallest
+  let bestWeight = Infinity;
+  let bestLex: number[] = [];
+
+  const numFree = freeVars.length;
+
+  // For each free variable assignment, compute full solution
+  if (numFree <= 22) {
+    // Direct enumeration (2^22 = ~4 million, manageable)
+    for (let mask = 0; mask < (1 << numFree); mask++) {
+      // Compute solution for this assignment
+      const solution = computeSolutionFromRREF(
+        particular, freeVars, pivotToRow, matrix, m, mask
+      );
+
+      // Calculate weight and get pressed buttons
+      const pressed: number[] = [];
+      for (let i = 0; i < m; i++) {
+        if (solution[i] === 1) {
+          pressed.push(i);
+        }
+      }
+
+      const weight = pressed.length;
+
+      if (weight < bestWeight || (weight === bestWeight && compareLex(pressed, bestLex) < 0)) {
+        bestWeight = weight;
+        bestLex = pressed;
+      }
+    }
+  } else {
+    // Too many free variables - use pruning-based search
+    // For each assignment, compute partial solution and prune if weight exceeds best
+    const maxIterations = 5000000; // Limit iterations
+    let iterations = 0;
+
+    for (let mask = 0; mask < (1 << numFree) && iterations < maxIterations; mask++) {
+      iterations++;
+
+      const solution = computeSolutionFromRREF(
+        particular, freeVars, pivotToRow, matrix, m, mask
+      );
+
+      const pressed: number[] = [];
+      for (let i = 0; i < m; i++) {
+        if (solution[i] === 1) {
+          pressed.push(i);
+        }
+      }
+
+      const weight = pressed.length;
+
+      if (weight >= bestWeight) continue;
+
+      if (weight < bestWeight || (weight === bestWeight && compareLex(pressed, bestLex) < 0)) {
+        bestWeight = weight;
+        bestLex = pressed;
+      }
+    }
+  }
+
+  return bestLex;
+}
+
+function computeSolutionFromRREF(
+  particular: number[],
+  freeVars: number[],
+  pivotToRow: Map<number, number>,
+  matrix: number[][],
+  m: number,
+  mask: number
+): number[] {
+  // Start with particular solution (all free vars = 0)
+  const solution = [...particular];
+
+  // For each free variable, if set to 1, add its effect
+  for (let fi = 0; fi < freeVars.length; fi++) {
+    if ((mask >> fi) & 1) {
+      const freeVar = freeVars[fi];
+      // Toggle the free variable
+      solution[freeVar] = (solution[freeVar] + 1) % 2;
+
+      // In RREF, this also toggles all pivot variables that have a 1 in this free var column
+      for (const [pivotCol, rowIdx] of pivotToRow) {
+        const coeff = matrix[rowIdx][freeVar];
+        if (coeff === 1) {
+          solution[pivotCol] = (solution[pivotCol] + 1) % 2;
+        }
+      }
+    }
+  }
+
+  return solution;
+}
+
+function compareLex(a: number[], b: number[]): number {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] !== b[i]) {
+      return a[i] - b[i];
+    }
+  }
+  return a.length - b.length;
+}
+
+// Gaussian elimination over GF(2)
+// Returns null if no solution, otherwise returns RREF matrix and solution info
+function gaussianEliminationGF2(
+  augMatrix: number[][],
+  numVars: number
+): {
+  particular: number[];
+  freeVars: number[];
+  pivotToRow: Map<number, number>;
+  matrix: number[][];
+} | null {
+  // Make a copy since we'll modify it
+  const m = augMatrix.length;
+  const n = numVars;
+  const matrix = augMatrix.map(row => [...row]);
+
+  let row = 0;
+  const pivotCols: number[] = [];
+  const pivotToRow = new Map<number, number>();
+
+  // Forward elimination to RREF
+  for (let col = 0; col < n && row < m; col++) {
+    // Find pivot in this column
+    let pivotRow = -1;
+    for (let i = row; i < m; i++) {
+      if (matrix[i][col] === 1) {
+        pivotRow = i;
+        break;
+      }
+    }
+
+    if (pivotRow === -1) {
+      continue; // No pivot in this column, it's a free variable
+    }
+
+    // Swap rows
+    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];
+
+    // Eliminate in all other rows (to get RREF)
+    for (let i = 0; i < m; i++) {
+      if (i !== row && matrix[i][col] === 1) {
+        for (let j = col; j <= n; j++) {
+          matrix[i][j] = (matrix[i][j] + matrix[row][j]) % 2;
+        }
+      }
+    }
+
+    pivotCols.push(col);
+    pivotToRow.set(col, row);
+    row++;
+  }
+
+  // Check for inconsistency
+  for (let i = row; i < m; i++) {
+    if (matrix[i][n] === 1) {
+      // 0 = 1, no solution
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let i = 0; i < n; i++) {
+    if (!pivotSet.has(i)) {
+      freeVars.push(i);
+    }
+  }
+
+  // Build particular solution (with all free vars = 0)
+  const particular = new Array(n).fill(0);
+
+  // In RREF form: x_pivot = rhs - sum(coeff_free * x_free)
+  // With free vars = 0: x_pivot = rhs
+  for (let i = 0; i < pivotCols.length; i++) {
+    const pivotCol = pivotCols[i];
+    const rhs = matrix[i][n];
+    particular[pivotCol] = rhs;
+  }
+
+  return {
+    particular,
+    freeVars,
+    pivotToRow,
+    matrix,
+  };
+}
+
+// Counter Puzzle: Solve over Z_p
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const n = lights.length;
+  const m = buttons.length;
+
+  // Build augmented matrix [A|b] where A[i][j] = 1 if button j increments counter i
+  const augMatrix: number[][] = [];
+  for (let i = 0; i < n; i++) {
+    const row = new Array(m).fill(0);
+    for (let j = 0; j < m; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1 % modulus;
+      }
+    }
+    row.push(lights[i] % modulus);
+    augMatrix.push(row);
+  }
+
+  // Gaussian elimination over Z_p
+  const result = gaussianEliminationZP(augMatrix, m, modulus);
+  if (result === null) {
+    return null;
+  }
+
+  const { particular, freeVars, pivotToRow, matrix } = result;
+
+  // If no free variables, we have a unique solution
+  if (freeVars.length === 0) {
+    return particular;
+  }
+
+  // Enumerate all solutions
+  let bestSolution: number[] | null = null;
+  let bestWeight = Infinity;
+  let bestLex: number[] = [];
+
+  const numFree = freeVars.length;
+  const p = modulus;
+
+  // For small solution space, enumerate all
+  const total = Math.pow(p, numFree);
+  if (total <= 5000000) {
+    for (let i = 0; i < total; i++) {
+      // Compute solution for this assignment
+      const solution = computeSolutionZP(
+        particular, freeVars, pivotToRow, matrix, m, p, i
+      );
+
+      // Calculate total presses
+      const totalPresses = solution.reduce((a, b) => a + b, 0);
+
+      if (totalPresses < bestWeight || (totalPresses === bestWeight && compareLexNum(solution, bestLex) < 0)) {
+        bestWeight = totalPresses;
+        bestSolution = solution;
+        bestLex = solution;
+        if (bestWeight === 0) break;
+      }
+    }
+  } else {
+    // Use greedy/random search for large solution spaces
+    return heuristicSolveCounter(particular, freeVars, pivotToRow, matrix, p, m);
+  }
+
+  return bestSolution || null;
+}
+
+function computeSolutionZP(
+  particular: number[],
+  freeVars: number[],
+  pivotToRow: Map<number, number>,
+  matrix: number[][],
+  m: number,
+  p: number,
+  value: number
+): number[] {
+  // Start with particular solution (all free vars = 0)
+  const solution = [...particular];
+  const numFree = freeVars.length;
+
+  // Decode value into free variable assignments
+  let temp = value;
+  for (let fi = 0; fi < numFree; fi++) {
+    const val = temp % p;
+    if (val !== 0) {
+      const freeVar = freeVars[fi];
+      // Add val to free variable
+      solution[freeVar] = (solution[freeVar] + val) % p;
+
+      // This also adds val * coeff to all pivot variables that depend on it
+      for (const [pivotCol, rowIdx] of pivotToRow) {
+        const coeff = matrix[rowIdx][freeVar];
+        if (coeff !== 0) {
+          solution[pivotCol] = (solution[pivotCol] + coeff * val) % p;
+        }
+      }
+    }
+    temp = Math.floor(temp / p);
+  }
+
+  return solution;
+}
+
+function heuristicSolveCounter(
+  particular: number[],
+  freeVars: number[],
+  pivotToRow: Map<number, number>,
+  matrix: number[][],
+  p: number,
+  _m: number
+): number[] | null {
+  // Use greedy/random approach to find a good solution
+  let bestSolution: number[] = [...particular];
+  let bestWeight = bestSolution.reduce((a, b) => a + b, 0);
+
+  const numFree = freeVars.length;
+  const trials = 50000;
+
+  for (let i = 0; i < trials; i++) {
+    const solution = [...particular];
+    for (let j = 0; j < numFree; j++) {
+      const val = Math.floor(Math.random() * p);
+      if (val !== 0) {
+        const freeVar = freeVars[j];
+        solution[freeVar] = (solution[freeVar] + val) % p;
+
+        for (const [pivotCol, rowIdx] of pivotToRow) {
+          const coeff = matrix[rowIdx][freeVar];
+          if (coeff !== 0) {
+            solution[pivotCol] = (solution[pivotCol] + coeff * val) % p;
+          }
+        }
+      }
+    }
+
+    const weight = solution.reduce((a, b) => a + b, 0);
+    if (weight < bestWeight || (weight === bestWeight && compareLexNum(solution, bestSolution) < 0)) {
+      bestWeight = weight;
+      bestSolution = solution;
+      if (weight === 0) break;
+    }
+  }
+
+  return bestSolution;
+}
+
+function compareLexNum(a: number[], b: number[]): number {
+  const len = Math.min(a.length, b.length);
+  for (let i = 0; i < len; i++) {
+    if (a[i] !== b[i]) {
+      return a[i] - b[i];
+    }
+  }
+  return a.length - b.length;
+}
+
+// Gaussian elimination over Z_p (prime modulus)
+function gaussianEliminationZP(
+  augMatrix: number[][],
+  numVars: number,
+  p: number
+): {
+  particular: number[];
+  freeVars: number[];
+  pivotToRow: Map<number, number>;
+  matrix: number[][];
+} | null {
+  // Make a copy
+  const m = augMatrix.length;
+  const n = numVars;
+  const matrix = augMatrix.map(row => [...row]);
+
+  // Modulo p
+  for (let i = 0; i < m; i++) {
+    for (let j = 0; j <= n; j++) {
+      matrix[i][j] = ((matrix[i][j] % p) + p) % p;
+    }
+  }
+
+  let row = 0;
+  const pivotCols: number[] = [];
+  const pivotToRow = new Map<number, number>();
+
+  // Forward elimination to RREF
+  for (let col = 0; col < n && row < m; col++) {
+    // Find pivot in this column (non-zero)
+    let pivotRow = -1;
+    for (let i = row; i < m; i++) {
+      if (matrix[i][col] !== 0) {
+        pivotRow = i;
+        break;
+      }
+    }
+
+    if (pivotRow === -1) {
+      continue;
+    }
+
+    // Swap rows
+    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];
+
+    // Make pivot 1 (multiply by inverse)
+    const inv = modInverse(matrix[row][col], p);
+    for (let j = col; j <= n; j++) {
+      matrix[row][j] = (matrix[row][j] * inv) % p;
+    }
+
+    // Eliminate in all other rows (to get RREF)
+    for (let i = 0; i < m; i++) {
+      if (i !== row && matrix[i][col] !== 0) {
+        const factor = matrix[i][col];
+        for (let j = col; j <= n; j++) {
+          matrix[i][j] = (matrix[i][j] - factor * matrix[row][j]) % p;
+          if (matrix[i][j] < 0) matrix[i][j] += p;
+        }
+      }
+    }
+
+    pivotCols.push(col);
+    pivotToRow.set(col, row);
+    row++;
+  }
+
+  // Check for inconsistency
+  for (let i = row; i < m; i++) {
+    if (matrix[i][n] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCols);
+  const freeVars: number[] = [];
+  for (let i = 0; i < n; i++) {
+    if (!pivotSet.has(i)) {
+      freeVars.push(i);
+    }
+  }
+
+  // Build particular solution (with all free vars = 0)
+  const particular = new Array(n).fill(0);
+
+  // In RREF: x_pivot = rhs - sum(coeff_free * x_free)
+  // With free vars = 0: x_pivot = rhs
+  for (let i = 0; i < pivotCols.length; i++) {
+    const pivotCol = pivotCols[i];
+    const rhs = matrix[i][n];
+    particular[pivotCol] = rhs;
+  }
+
+  return {
+    particular,
+    freeVars,
+    pivotToRow,
+    matrix,
+  };
+}
+
+// Compute modular inverse using extended Euclidean algorithm
+function modInverse(a: number, p: number): number {
+  // a and p are coprime since p is prime and a != 0
+  let t = 0;
+  let newT = 1;
+  let r = p;
+  let newR = a % p;
+
+  while (newR !== 0) {
+    const quotient = Math.floor(r / newR);
+    const tempT = t - quotient * newT;
+    const tempR = r - quotient * newR;
+    t = newT;
+    newT = tempT;
+    r = newR;
+    newR = tempR;
+  }
+
+  if (r > 1) {
+    return -1; // a is not invertible
+  }
+
+  if (t < 0) {
+    t = t + p;
+  }
+
+  return t % p;
+}
