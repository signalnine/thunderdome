+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+export function simulate(gates: Gate[], inputs: Record<string, number>): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+
+  const processed = new Set<number>();
+
+  while (processed.size < gates.length) {
+    for (let i = 0; i < gates.length; i++) {
+      if (processed.has(i)) continue;
+      const gate = gates[i];
+
+      const val1 = wires[gate.in1] !== undefined ? wires[gate.in1] : inputs[gate.in1];
+      const val2 = wires[gate.in2] !== undefined ? wires[gate.in2] : inputs[gate.in2];
+
+      if (val1 === undefined || val2 === undefined) continue;
+
+      let result: number;
+
+      switch (gate.op) {
+        case 'AND':
+          result = (val1 === 1 && val2 === 1) ? 1 : 0;
+          break;
+        case 'OR':
+          result = (val1 === 1 || val2 === 1) ? 1 : 0;
+          break;
+        case 'XOR':
+          result = (val1 !== val2) ? 1 : 0;
+          break;
+        default:
+          throw new Error(`Unknown gate operation: ${gate.op}`);
+      }
+
+      wires[gate.out] = result;
+      processed.add(i);
+    }
+  }
+
+  return wires;
+}
+
+export function findSwappedWires(gates: Gate[]): string[] {
+  const outputPositions = new Map<string, number>();
+
+  // Map known z/c output wire positions
+  for (const gate of gates) {
+    const zMatch = gate.out.match(/^z([0-9]+)_?[a-z]*$/);
+    const cMatch = gate.out.match(/^c([0-9]+)_?[a-z]*$/);
+
+    if (zMatch) {
+      const pos = parseInt(zMatch[1], 10);
+      outputPositions.set(gate.out, pos);
+    } else if (cMatch) {
+      const pos = parseInt(cMatch[1], 10);
+      outputPositions.set(gate.out, pos);
+    }
+  }
+
+  const groupsByPosition = new Map<number, Set<string>>();
+
+  // Group wires by their output position
+  for (const [wire, pos] of outputPositions) {
+    if (!groupsByPosition.has(pos)) {
+      groupsByPosition.set(pos, new Set());
+    }
+    groupsByPosition.get(pos)!.add(wire);
+  }
+
+  const swappedWires: Set<string> = new Set();
+
+  // For each position, if there are multiple wires, those might be swapped
+  for (const wires of groupsByPosition.values()) {
+    if (wires.size === 2) {
+      const [wire1, wire2] = Array.from(wires);
+      swappedWires.add(wire1);
+      swappedWires.add(wire2);
+    }
+  }
+
+  return Array.from(swappedWires).sort();
+}
