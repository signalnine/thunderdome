+import { describe, it, expect } from 'vitest';
+import {
+  simulate,
+  findSwappedWires,
+  type Gate,
+} from './index.js';
+
+describe('simulate', () => {
+  it('should simulate AND gates', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    const inputs = { a: 1, b: 0 };
+    const result = simulate(gates, inputs);
+    expect(result.c).toBe(0);
+  });
+
+  it('should simulate OR gates', () => {
+    const gates: Gate[] = [
+      { op: 'OR', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    const inputs = { a: 0, b: 1 };
+    const result = simulate(gates, inputs);
+    expect(result.c).toBe(1);
+  });
+
+  it('should simulate XOR gates', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' },
+    ];
+    const inputs = { a: 1, b: 0 };
+    const result = simulate(gates, inputs);
+    expect(result.c).toBe(1);
+  });
+
+  it('should handle gate dependencies', () => {
+    const gates: Gate[] = [
+      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },
+    ];
+    const inputs = { a: 1, b: 1, c: 1, d: 0 };
+    const result = simulate(gates, inputs);
+    expect(result.e).toBe(1);
+  });
+
+  it('should handle circular dependencies gracefully', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'a', in2: 'b', out: 'c' },
+      { op: 'XOR', in1: 'c', in2: 'd', out: 'e' },
+      { op: 'XOR', in1: 'e', in2: 'f', out: 'g' },
+      { op: 'XOR', in1: 'g', in2: 'h', out: 'c' },
+    ];
+    const inputs = {
+      a: 0,
+      b: 1,
+      c: 0,
+      d: 1,
+      e: 0,
+      f: 1,
+      g: 0,
+      h: 1,
+    };
+    const result = simulate(gates, inputs);
+    expect(result.c).toBeDefined();
+  });
+});
+
+describe('findSwappedWires', () => {
+  it('should identify swapped z wires', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'in1', in2: 'in2', out: 'z0' },
+      { op: 'XOR', in1: 'in1', in2: 'in2', out: 'z0_swap' },
+    ];
+    const result = findSwappedWires(gates);
+    expect(result).toContain('z0');
+    expect(result).toContain('z0_swap');
+  });
+
+  it('should handle z with multiple outputs', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'in1', in2: 'in2', out: 'z0' },
+      { op: 'XOR', in1: 'in1', in2: 'in2', out: 'z1' },
+      { op: 'XOR', in1: 'in1', in2: 'in2', out: 'z2' },
+    ];
+    const result = findSwappedWires(gates);
+    expect(result).toHaveLength(0);
+  });
+
+  it('should return empty array for valid circuit', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'in1', in2: 'in2', out: 'out' },
+    ];
+    const result = findSwappedWires(gates);
+    expect(result).toHaveLength(0);
+  });
+
+  it('should find multiple swapped pairs', () => {
+    const gates: Gate[] = [];
+
+    for (let i = 0; i < 10; i++) {
+      gates.push({ op: 'XOR', in1: 'in1', in2: 'in2', out: `z${i}` });
+      gates.push({ op: 'XOR', in1: 'in1', in2: 'in2', out: `z${i}_swap` });
+    }
+
+    const result = findSwappedWires(gates);
+    expect(result).toHaveLength(20);
+    for (let i = 0; i < 10; i++) {
+      expect(result).toContain(`z${i}`);
+      expect(result).toContain(`z${i}_swap`);
+    }
+  });
+
+  it('should handle mixed z and c wires', () => {
+    const gates: Gate[] = [
+      { op: 'XOR', in1: 'in1', in2: 'in2', out: 'z0' },
+      { op: 'XOR', in1: 'in1', in2: 'in2', out: 'z0_swap' },
+      { op: 'XOR', in1: 'in1', in2: 'in2', out: 'c1' },
+      { op: 'XOR', in1: 'in1', in2: 'in2', out: 'c1_swap' },
+    ];
+
+    const result = findSwappedWires(gates);
+    expect(result).toHaveLength(4);
+    expect(result).toContain('z0');
+    expect(result).toContain('z0_swap');
+    expect(result).toContain('c1');
+    expect(result).toContain('c1_swap');
+  });
+
+  it('should handle large circuits under 5 seconds', () => {
+    const numBits = 45;
+    const gates: Gate[] = [];
+
+    for (let bit = 0; bit < numBits; bit++) {
+      // Only create z wires, not c wires
+      gates.push({ op: 'XOR', in1: 'in1', in2: 'in2', out: `z${bit}` });
+    }
+
+    const startTime = Date.now();
+    const result = findSwappedWires(gates);
+    const duration = Date.now() - startTime;
+
+    expect(duration).toBeLessThan(5000);
+    expect(result).toHaveLength(0);
+  });
+});
