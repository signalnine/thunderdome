@@ -0,0 +1,27 @@
+import express from "express";
+import { initDb } from "./db.js";
+import { createAuthRouter, createUsersRouter } from "./routes/auth.js";
+import { createEventsRouter } from "./routes/events.js";
+import { createQueryRouter } from "./routes/query.js";
+import { createDashboardsRouter } from "./routes/dashboards.js";
+import { createExportRouter } from "./routes/export.js";
+
+export function createApp(dbPath?: string): express.Express {
+  const app = express();
+  const db = initDb(dbPath);
+
+  app.use(express.json());
+
+  app.get("/health", (_req, res) => {
+    res.json({ status: "ok" });
+  });
+
+  app.use("/api/auth", createAuthRouter(db));
+  app.use("/api/users", createUsersRouter(db));
+  app.use("/api/events", createEventsRouter(db));
+  app.use("/api/query", createQueryRouter(db));
+  app.use("/api/dashboards", createDashboardsRouter(db));
+  app.use("/api/export", createExportRouter(db));
+
+  return app;
+}
diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..a8203ef
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,22 @@
+import Database from "better-sqlite3";
+import { readFileSync } from "fs";
+import { join } from "path";
+
+export function initDb(dbPath?: string): Database.Database {
+  const db = dbPath ? new Database(dbPath) : new Database(":memory:");
+  db.pragma("journal_mode = WAL");
+  db.pragma("foreign_keys = ON");
+
+  const schemaPath = join(__dirname, "..", "schema.sql");
+  try {
+    const schema = readFileSync(schemaPath, "utf-8");
+    db.exec(schema);
+  } catch {
+    // If schema.sql not found relative to dist, try workspace root
+    const fallbackPath = join(process.cwd(), "schema.sql");
+    const schema = readFileSync(fallbackPath, "utf-8");
+    db.exec(schema);
+  }
+
+  return db;
+}
