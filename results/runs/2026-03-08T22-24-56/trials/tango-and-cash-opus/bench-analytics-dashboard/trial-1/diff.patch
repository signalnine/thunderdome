+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01BXG7JRqmUXWDkPhaZRaa1g","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BHs8puQyLVkFcGAFNUDnta","name":"Write","input":{"file_path":"/workspace/src/routes/export.ts","content":"import { Router, Response } from \"express\";\nimport Database from \"better-sqlite3\";\nimport { AuthRequest, authMiddleware } from \"../middleware/auth.js\";\n\ninterface EventRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  properties: string;\n  timestamp: string;\n  user_id: string | null;\n  session_id: string | null;\n}\n\ninterface DashboardRow {\n  id: string;\n  tenant_id: string;\n  name: string;\n  owner_id: string;\n  config: string;\n  created_at: string;\n  updated_at: string;\n}\n\nfunction eventsToCsv(events: EventRow[]): string {\n  const header = \"id,tenant_id,name,properties,timestamp,user_id,session_id\";\n  const rows = events.map(\n    (e) =>\n      `${e.id},${e.tenant_id},${e.name},\"${e.properties.replace(/\"/g, '\"\"')}\",${e.timestamp},${e.user_id || \"\"},${e.session_id || \"\"}`\n  );\n  return [header, ...rows].join(\"\\n\");\n}\n\nfunction dashboardToCsv(dashboard: DashboardRow): string {\n  const header = \"id,tenant_id,name,owner_id,config,created_at,updated_at\";\n  const row = `${dashboard.id},${dashboard.tenant_id},${dashboard.name},${dashboard.owner_id},\"${dashboard.config.replace(/\"/g, '\"\"')}\",${dashboard.created_at},${dashboard.updated_at}`;\n  return [header, row].join(\"\\n\");\n}\n\nexport function createExportRouter(db: Database.Database): Router {\n  const router = Router();\n\n  // Export events\n  router.get(\"/events\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    const tenantId = req.user!.tenantId;\n    const format = (req.query.format as string) || \"json\";\n    const eventName = req.query.eventName as string | undefined;\n\n    let sql = \"SELECT * FROM events WHERE tenant_id = ?\";\n    const params: unknown[] = [tenantId];\n\n    if (eventName) {\n      sql += \" AND name = ?\";\n      params.push(eventName);\n    }\n\n    sql += \" ORDER BY timestamp DESC\";\n\n    const events = db.prepare(sql).all(...params) as EventRow[];\n\n    if (format === \"csv\") {\n      res.setHeader(\"Content-Type\", \"text/csv\");\n      res.setHeader(\"Content-Disposition\", \"attachment; filename=events.csv\");\n      res.send(eventsToCsv(events));\n    } else {\n      res.json({ events });\n    }\n  });\n\n  // Export dashboard\n  router.get(\"/dashboards/:id\", authMiddleware, (req: AuthRequest, res: Response): void => {\n    const tenantId = req.user!.tenantId;\n    const format = (req.query.format as string) || \"json\";\n\n    const dashboard = db\n      .prepare(\"SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?\")\n      .get(req.params.id, tenantId) as DashboardRow | undefined;\n\n    if (!dashboard) {\n      res.status(404).json({ error: \"Dashboard not found\" });\n      return;\n    }\n\n    if (format === \"csv\") {\n      res.setHeader(\"Content-Type\", \"text/csv\");\n      res.setHeader(\"Content-Disposition\", `attachment; filename=dashboard-${dashboard.id}.csv`);\n      res.send(dashboardToCsv(dashboard));\n    } else {\n      res.json(dashboard);\n    }\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2236,"cache_read_input_tokens":29002,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2236},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d95683e4-30eb-48fb-943e-47ac735c729e","uuid":"a758b416-0d88-4f17-b002-85c6d8c0cae6"}
