@@ -0,0 +1,109 @@
+import { Router, Response } from "express";
+import Database from "better-sqlite3";
+import { AuthRequest, authMiddleware } from "../middleware/auth.js";
+
+export function createQueryRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // Count query
+  router.post("/count", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const { eventName, startDate, endDate } = req.body as {
+      eventName?: string;
+      startDate?: string;
+      endDate?: string;
+    };
+
+    const tenantId = req.user!.tenantId;
+    let sql = "SELECT COUNT(*) as count FROM events WHERE tenant_id = ?";
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    const result = db.prepare(sql).get(...params) as { count: number };
+    res.json({ count: result.count });
+  });
+
+  // Timeseries query
+  router.post("/timeseries", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const { eventName, startDate, endDate, interval } = req.body as {
+      eventName?: string;
+      startDate?: string;
+      endDate?: string;
+      interval?: string;
+    };
+
+    const tenantId = req.user!.tenantId;
+    const bucket = interval === "hour" ? "%Y-%m-%dT%H:00:00" : "%Y-%m-%d";
+
+    let sql = `SELECT strftime('${bucket}', timestamp) as period, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    sql += " GROUP BY period ORDER BY period";
+
+    const rows = db.prepare(sql).all(...params) as { period: string; count: number }[];
+    res.json({ data: rows });
+  });
+
+  // Breakdown query
+  router.post("/breakdown", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const { eventName, property, startDate, endDate } = req.body as {
+      eventName?: string;
+      property: string;
+      startDate?: string;
+      endDate?: string;
+    };
+
+    if (!property) {
+      res.status(400).json({ error: "property is required" });
+      return;
+    }
+
+    const tenantId = req.user!.tenantId;
+    let sql = `SELECT json_extract(properties, '$.' || ?) as property_value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+    const params: unknown[] = [property, tenantId];
+
+    if (eventName) {
+      sql += " AND name = ?";
+      params.push(eventName);
+    }
+    if (startDate) {
+      sql += " AND timestamp >= ?";
+      params.push(startDate);
+    }
+    if (endDate) {
+      sql += " AND timestamp <= ?";
+      params.push(endDate);
+    }
+
+    sql += " GROUP BY property_value ORDER BY count DESC";
+
+    const rows = db.prepare(sql).all(...params) as { property_value: string; count: number }[];
+    res.json({ data: rows });
+  });
+
+  return router;
+}
