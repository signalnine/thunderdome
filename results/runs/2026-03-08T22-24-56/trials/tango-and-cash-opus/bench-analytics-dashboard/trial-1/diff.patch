+import { Router, Response } from "express";
+import { v4 as uuidv4 } from "uuid";
+import Database from "better-sqlite3";
+import { AuthRequest, authMiddleware } from "../middleware/auth.js";
+
+export function createDashboardsRouter(db: Database.Database): Router {
+  const router = Router();
+
+  // List dashboards for tenant
+  router.get("/", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const dashboards = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenantId);
+    res.json({ dashboards });
+  });
+
+  // Create dashboard
+  router.post("/", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const { name, config } = req.body as { name?: string; config?: Record<string, unknown> };
+
+    if (!name) {
+      res.status(400).json({ error: "Dashboard name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const ownerId = req.user!.userId;
+    const configStr = JSON.stringify(config || {});
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, ownerId, configStr);
+
+    res.status(201).json({ id, name, tenantId, ownerId, config: config || {} });
+  });
+
+  // Get dashboard by ID
+  router.get("/:id", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenantId) as Record<string, unknown> | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    res.json(dashboard);
+  });
+
+  // Update dashboard
+  router.put("/:id", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { name, config } = req.body as { name?: string; config?: Record<string, unknown> };
+
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenantId) as Record<string, unknown> | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const updatedName = name || (existing.name as string);
+    const updatedConfig = config ? JSON.stringify(config) : (existing.config as string);
+
+    db.prepare(
+      "UPDATE dashboards SET name = ?, config = ?, updated_at = datetime('now') WHERE id = ? AND tenant_id = ?"
+    ).run(updatedName, updatedConfig, req.params.id, tenantId);
+
+    res.json({ id: req.params.id, name: updatedName, config: config || JSON.parse(existing.config as string) });
+  });
+
+  // Delete dashboard
+  router.delete("/:id", authMiddleware, (req: AuthRequest, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenantId) as Record<string, unknown> | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM dashboards WHERE id = ? AND tenant_id = ?").run(req.params.id, tenantId);
+    res.status(204).send();
+  });
+
+  return router;
+}
