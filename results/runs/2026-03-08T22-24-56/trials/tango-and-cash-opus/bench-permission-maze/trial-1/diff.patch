ync () => {\n      const { token } = await createUser('alice', 'pass');\n      const folder = await request(app).post('/folders').set('Authorization', `Bearer ${token}`).send({ name: 'Folder' });\n      const doc = await request(app)\n        .post(`/folders/${folder.body.id}/documents`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'Hello' });\n\n      const res = await request(app)\n        .put(`/documents/${doc.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Updated', content: 'World' });\n      expect(res.status).toBe(200);\n      expect(res.body.title).toBe('Updated');\n      expect(res.body.content).toBe('World');\n    });\n\n    it('should delete a document', async () => {\n      const { token } = await createUser('alice', 'pass');\n      const folder = await request(app).post('/folders').set('Authorization', `Bearer ${token}`).send({ name: 'Folder' });\n      const doc = await request(app)\n        .post(`/folders/${folder.body.id}/documents`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'Hello' });\n\n      const res = await request(app).delete(`/documents/${doc.body.id}`).set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(204);\n      const get = await request(app).get(`/documents/${doc.body.id}`).set('Authorization', `Bearer ${token}`);\n      expect(get.status).toBe(404);\n    });\n\n    it('should return 404 for non-existent document', async () => {\n      const { token } = await createUser('alice', 'pass');\n      const res = await request(app).get('/documents/nonexistent').set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(404);\n    });\n  });\n\n  // --- Sharing & Permissions ---\n  describe('Sharing & Permissions', () => {\n    it('should share a folder with another user as viewer', async () => {\n      const alice = await createUser('alice', 'pass');\n      const bob = await createUser('bob', 'pass');\n\n      const folder = await request(app).post('/folders').set('Authorization', `Bearer ${alice.token}`).send({ name: 'Shared' });\n\n      const res = await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n      expect(res.status).toBe(200);\n\n      // Bob can read\n      const get = await request(app).get(`/folders/${folder.body.id}`).set('Authorization', `Bearer ${bob.token}`);\n      expect(get.status).toBe(200);\n    });\n\n    it('viewer cannot edit a folder', async () => {\n      const alice = await createUser('alice', 'pass');\n      const bob = await createUser('bob', 'pass');\n\n      const folder = await request(app).post('/folders').set('Authorization', `Bearer ${alice.token}`).send({ name: 'Shared' });\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n\n      const res = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${bob.token}`)\n        .send({ name: 'Hacked' });\n      expect(res.status).toBe(403);\n    });\n\n    it('viewer cannot delete a folder', async () => {\n      const alice = await createUser('alice', 'pass');\n      const bob = await createUser('bob', 'pass');\n\n      const folder = await request(app).post('/folders').set('Authorization', `Bearer ${alice.token}`).send({ name: 'Shared' });\n      await request(app)\n        .post(`/folders/${folder.body.id}/share`)\n        .set('Authorization', `Bearer ${alice.token}`)\n        .send({ userId: bob.userId, role: 'viewer' });\n\n      const res = await request(app).delete(`/folders/${folder.body.id}`).set('Authorization', `Bearer ${bob.token}`);\n      expect(res.status).toBe(403);\n    });\n\n    it('editor can edit but not delete a document', async