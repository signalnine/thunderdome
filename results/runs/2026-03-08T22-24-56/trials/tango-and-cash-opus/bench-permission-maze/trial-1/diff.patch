+import express, { Request, Response, NextFunction } from 'express';
+import crypto from 'crypto';
+
+// --- Types ---
+
+interface User {
+  id: string;
+  username: string;
+  password: string;
+}
+
+interface Folder {
+  id: string;
+  name: string;
+  parentId: string | null;
+  ownerId: string;
+  createdAt: string;
+}
+
+interface Document {
+  id: string;
+  title: string;
+  content: string;
+  folderId: string;
+  ownerId: string;
+  createdAt: string;
+  updatedAt: string;
+}
+
+type Role = 'viewer' | 'editor' | 'owner';
+
+interface Permission {
+  resourceType: 'folder' | 'document';
+  resourceId: string;
+  userId: string;
+  role: Role;
+}
+
+interface ActivityEntry {
+  id: string;
+  action: string;
+  userId: string;
+  resourceType: string;
+  resourceId: string;
+  timestamp: string;
+}
+
+interface AuthRequest extends Request {
+  userId?: string;
+}
+
+// --- Storage ---
+
+const users = new Map<string, User>();
+const tokens = new Map<string, string>(); // token -> userId
+const folders = new Map<string, Folder>();
+const documents = new Map<string, Document>();
+const permissions: Permission[] = [];
+const activityLog: ActivityEntry[] = [];
+
+function genId(): string {
+  return crypto.randomUUID();
+}
+
+function genToken(): string {
+  return crypto.randomBytes(32).toString('hex');
+}
+
+// --- Permission helpers ---
+
+const roleRank: Record<Role, number> = { viewer: 1, editor: 2, owner: 3 };
+
+function getAncestorFolderIds(folderId: string): string[] {
+  const ancestors: string[] = [];
+  let currentId: string | null = folderId;
+  while (currentId) {
+    ancestors.push(currentId);
+    const folder = folders.get(currentId);
+    currentId = folder?.parentId ?? null;
+  }
+  return ancestors;
+}
+
+function getEffectiveRole(userId: string, resourceType: 'folder' | 'document', resourceId: string): Role | null {
+  let bestRole: Role | null = null;
+
+  // Direct permissions on the resource
+  for (const p of permissions) {
+    if (p.userId === userId && p.resourceType === resourceType && p.resourceId === resourceId) {
+      if (!bestRole || roleRank[p.role] > roleRank[bestRole]) {
+        bestRole = p.role;
+      }
+    }
+  }
+
+  // If it's a document, check folder hierarchy permissions
+  if (resourceType === 'document') {
+    const doc = documents.get(resourceId);
+    if (doc) {
+      const ancestorIds = getAncestorFolderIds(doc.folderId);
+      for (const fId of ancestorIds) {
+        for (const p of permissions) {
+          if (p.userId === userId && p.resourceType === 'folder' && p.resourceId === fId) {
+            if (!bestRole || roleRank[p.role] > roleRank[bestRole]) {
+              bestRole = p.role;
+            }
+          }
+        }
+      }
+    }
+  }
+
+  // If it's a folder, check parent folder hierarchy permissions
+  if (resourceType === 'folder') {
+    const ancestorIds = getAncestorFolderIds(resourceId);
+    // Skip the first one (itself, already checked via direct)
+    for (let i = 1; i < ancestorIds.length; i++) {
+      for (const p of permissions) {
+        if (p.userId === userId && p.resourceType === 'folder' && p.resourceId === ancestorIds[i]) {
+          if (!bestRole || roleRank[p.role] > roleRank[bestRole]) {
+            bestRole = p.role;
+          }
+        }
+      }
+    }
+  }
+
+  return bestRole;
+}
+
+function canRead(userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(userId, resourceType, resourceId);
+  return role !== null;
+}
+
+function canEdit(userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(userId, resourceType, resourceId);
+  return role === 'editor' || role === 'owner';
+}
+
+function canDelete(userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(userId, resourceType, resourceId);
+  return role === 'owner';
+}
+
+function canShare(userId: string, resourceType: 'folder' | 'document', resourceId: string): boolean {
+  const role = getEffectiveRole(userId, resourceType, resourceId);
+  return role === 'editor' || role === 'owner';
+}
+
+function addActivity(action: string, userId: string, resourceType: string, resourceId: string): void {
+  activityLog.push({
+    id: genId(),
+    action,
+    userId,
+    resourceType,
+    resourceId,
+    timestamp: new Date().toISOString(),
+  });
+}
+
+// --- App ---
+
+export function createApp(): express.Express {
+  // Reset storage for each app instance
+  users.clear();
+  tokens.clear();
+  folders.clear();
+  documents.clear();
+  permissions.length = 0;
+  activityLog.length = 0;
+
+  const app = express();
+  app.use(express.json());
+
+  // --- Auth middleware ---
+  function authenticate(req: AuthRequest, res: Response, next: NextFunction): void {
+    const authHeader = req.headers.authorization;
+    if (!authHeader || !authHeader.startsWith('Bearer ')) {
+      res.status(401).json({ error: 'Authentication required' });
+      return;
+    }
+    const token = authHeader.slice(7);
+    const userId = tokens.get(token);
+    if (!userId) {
+      res.status(401).json({ error: 'Invalid token' });
+      return;
+    }
+    req.userId = userId;
+    next();
+  }
+
+  // --- Auth routes ---
+  app.post('/auth/register', (req: Request, res: Response) => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+    // Check duplicate
+    for (const u of users.values()) {
+      if (u.username === username) {
+        res.status(400).json({ error: 'Username already taken' });
+        return;
+      }
+    }
+    const user: User = { id: genId(), username, password };
+    users.set(user.id, user);
+    res.status(201).json({ id: user.id, username: user.username });
+  });
+
+  app.post('/auth/login', (req: Request, res: Response) => {
+    const { username, password } = req.body;
+    if (!username || !password) {
+      res.status(400).json({ error: 'Username and password are required' });
+      return;
+    }
+    let found: User | undefined;
+    for (const u of users.values()) {
+      if (u.username === username && u.password === password) {
+        found = u;
+        break;
+      }
+    }
+    if (!found) {
+      res.status(401).json({ error: 'Invalid credentials' });
+      return;
+    }
+    const token = genToken();
+    tokens.set(token, found.id);
+    res.status(200).json({ token, userId: found.id });
+  });
+
+  // --- Folder routes ---
+  app.post('/folders', authenticate, (req: AuthRequest, res: Response) => {
+    const { name, parentId } = req.body;
+    if (!name) {
+      res.status(400).json({ error: 'Folder name is required' });
+      return;
+    }
+    if (parentId !== undefined && parentId !== null) {
+      if (!folders.has(parentId)) {
+        res.status(404).json({ error: 'Parent folder not found' });
+        return;
+      }
+      // Must have at least editor on parent to create subfolder
+      if (!canEdit(req.userId!, 'folder', parentId)) {
+        res.status(403).json({ error: 'Insufficient permissions on parent folder' });
+        return;
+      }
+    }
+    const folder: Folder = {
+      id: genId(),
+      name,
+      parentId: parentId || null,
+      ownerId: req.userId!,
+      createdAt: new Date().toISOString(),
+    };
+    folders.set(folder.id, folder);
+    // Grant owner permission
+    permissions.push({ resourceType: 'folder', resourceId: folder.id, userId: req.userId!, role: 'owner' });
+    res.status(201).json(folder);
+  });
+
+  app.get('/folders/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const folder = folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (!canRead(req.userId!, 'folder', folder.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    // Include children folders and documents
+    const children: Folder[] = [];
+    for (const f of folders.values()) {
+      if (f.parentId === folder.id) children.push(f);
+    }
+    const docs: Document[] = [];
+    for (const d of documents.values()) {
+      if (d.folderId === folder.id) docs.push(d);
+    }
+    res.json({ ...folder, children, documents: docs });
+  });
+
+  app.put('/folders/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const folder = folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (!canEdit(req.userId!, 'folder', folder.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    if (req.body.name !== undefined) folder.name = req.body.name;
+    if (req.body.parentId !== undefined) folder.parentId = req.body.parentId;
+    res.json(folder);
+  });
+
+  app.delete('/folders/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const folder = folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    if (!canDelete(req.userId!, 'folder', folder.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    // Delete folder and its contents recursively
+    function deleteFolderRecursive(folderId: string): void {
+      // Delete child folders
+      for (const f of folders.values()) {
+        if (f.parentId === folderId) deleteFolderRecursive(f.id);
+      }
+      // Delete documents in folder
+      for (const d of documents.values()) {
+        if (d.folderId === folderId) {
+          documents.delete(d.id);
+          // Remove permissions for document
+          for (let i = permissions.length - 1; i >= 0; i--) {
+            if (permissions[i].resourceType === 'document' && permissions[i].resourceId === d.id) {
+              permissions.splice(i, 1);
+            }
+          }
+        }
+      }
+      folders.delete(folderId);
+      // Remove permissions for folder
+      for (let i = permissions.length - 1; i >= 0; i--) {
+        if (permissions[i].resourceType === 'folder' && permissions[i].resourceId === folderId) {
+          permissions.splice(i, 1);
+        }
+      }
+    }
+    deleteFolderRecursive(folder.id);
+    res.status(204).send();
+  });
+
+  // --- Document routes ---
+  app.post('/folders/:folderId/documents', authenticate, (req: AuthRequest, res: Response) => {
+    const { title, content } = req.body;
+    const { folderId } = req.params;
+    if (!title || content === undefined) {
+      res.status(400).json({ error: 'Title and content are required' });
+      return;
+    }
+    if (!folders.has(folderId)) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    // Must have at least editor on folder to create doc
+    if (!canEdit(req.userId!, 'folder', folderId)) {
+      res.status(403).json({ error: 'Insufficient permissions on folder' });
+      return;
+    }
+    const now = new Date().toISOString();
+    const doc: Document = {
+      id: genId(),
+      title,
+      content,
+      folderId,
+      ownerId: req.userId!,
+      createdAt: now,
+      updatedAt: now,
+    };
+    documents.set(doc.id, doc);
+    permissions.push({ resourceType: 'document', resourceId: doc.id, userId: req.userId!, role: 'owner' });
+    addActivity('document_created', req.userId!, 'document', doc.id);
+    res.status(201).json(doc);
+  });
+
+  app.get('/documents/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const doc = documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!canRead(req.userId!, 'document', doc.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  app.put('/documents/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const doc = documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!canEdit(req.userId!, 'document', doc.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    if (req.body.title !== undefined) doc.title = req.body.title;
+    if (req.body.content !== undefined) doc.content = req.body.content;
+    doc.updatedAt = new Date().toISOString();
+    addActivity('document_updated', req.userId!, 'document', doc.id);
+    res.json(doc);
+  });
+
+  app.delete('/documents/:id', authenticate, (req: AuthRequest, res: Response) => {
+    const doc = documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    if (!canDelete(req.userId!, 'document', doc.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    documents.delete(doc.id);
+    // Remove permissions
+    for (let i = permissions.length - 1; i >= 0; i--) {
+      if (permissions[i].resourceType === 'document' && permissions[i].resourceId === doc.id) {
+        permissions.splice(i, 1);
+      }
+    }
+    addActivity('document_deleted', req.userId!, 'document', doc.id);
+    res.status(204).send();
+  });
+
+  // --- Sharing routes ---
+  app.post('/folders/:id/share', authenticate, (req: AuthRequest, res: Response) => {
+    const folder = folders.get(req.params.id);
+    if (!folder) {
+      res.status(404).json({ error: 'Folder not found' });
+      return;
+    }
+    const { userId, role } = req.body;
+    if (!userId || !role) {
+      res.status(400).json({ error: 'userId and role are required' });
+      return;
+    }
+    if (!['viewer', 'editor', 'owner'].includes(role)) {
+      res.status(400).json({ error: 'Invalid role' });
+      return;
+    }
+    if (!users.has(userId)) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+    if (!canShare(req.userId!, 'folder', folder.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    // Only owners can assign owner role
+    if (role === 'owner' && getEffectiveRole(req.userId!, 'folder', folder.id) !== 'owner') {
+      res.status(403).json({ error: 'Only owners can assign owner role' });
+      return;
+    }
+    // Update existing permission or add new one
+    const existing = permissions.find(
+      p => p.resourceType === 'folder' && p.resourceId === folder.id && p.userId === userId
+    );
+    if (existing) {
+      existing.role = role as Role;
+    } else {
+      permissions.push({ resourceType: 'folder', resourceId: folder.id, userId, role: role as Role });
+    }
+    addActivity('shared', req.userId!, 'folder', folder.id);
+    res.json({ message: 'Folder shared successfully', resourceType: 'folder', resourceId: folder.id, userId, role });
+  });
+
+  app.post('/documents/:id/share', authenticate, (req: AuthRequest, res: Response) => {
+    const doc = documents.get(req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const { userId, role } = req.body;
+    if (!userId || !role) {
+      res.status(400).json({ error: 'userId and role are required' });
+      return;
+    }
+    if (!['viewer', 'editor', 'owner'].includes(role)) {
+      res.status(400).json({ error: 'Invalid role' });
+      return;
+    }
+    if (!users.has(userId)) {
+      res.status(404).json({ error: 'User not found' });
+      return;
+    }
+    if (!canShare(req.userId!, 'document', doc.id)) {
+      res.status(403).json({ error: 'Access denied' });
+      return;
+    }
+    // Only owners can assign owner role
+    if (role === 'owner' && getEffectiveRole(req.userId!, 'document', doc.id) !== 'owner') {
+      res.status(403).json({ error: 'Only owners can assign owner role' });
+      return;
+    }
+    // Update existing or add new
+    const existing = permissions.find(
+      p => p.resourceType === 'document' && p.resourceId === doc.id && p.userId === userId
+    );
+    if (existing) {
+      existing.role = role as Role;
+    } else {
+      permissions.push({ resourceType: 'document', resourceId: doc.id, userId, role: role as Role });
+    }
+    addActivity('shared', req.userId!, 'document', doc.id);
+    res.json({ message: 'Document shared successfully', resourceType: 'document', resourceId: doc.id, userId, role });
+  });
+
+  // --- Activity log ---
+  app.get('/activity', authenticate, (_req: AuthRequest, res: Response) => {
+    res.json(activityLog);
+  });
+
+  return app;
+}
