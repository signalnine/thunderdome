or: 'Folder not found' });\n      return;\n    }\n    const { userId, role } = req.body;\n    if (!userId || !role) {\n      res.status(400).json({ error: 'userId and role are required' });\n      return;\n    }\n    if (!['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'Invalid role' });\n      return;\n    }\n    if (!users.has(userId)) {\n      res.status(404).json({ error: 'User not found' });\n      return;\n    }\n    if (!canShare(req.userId!, 'folder', folder.id)) {\n      res.status(403).json({ error: 'Access denied' });\n      return;\n    }\n    // Only owners can assign owner role\n    if (role === 'owner' && getEffectiveRole(req.userId!, 'folder', folder.id) !== 'owner') {\n      res.status(403).json({ error: 'Only owners can assign owner role' });\n      return;\n    }\n    // Update existing permission or add new one\n    const existing = permissions.find(\n      p => p.resourceType === 'folder' && p.resourceId === folder.id && p.userId === userId\n    );\n    if (existing) {\n      existing.role = role as Role;\n    } else {\n      permissions.push({ resourceType: 'folder', resourceId: folder.id, userId, role: role as Role });\n    }\n    addActivity('shared', req.userId!, 'folder', folder.id);\n    res.json({ message: 'Folder shared successfully', resourceType: 'folder', resourceId: folder.id, userId, role });\n  });\n\n  app.post('/documents/:id/share', authenticate, (req: AuthRequest, res: Response) => {\n    const doc = documents.get(req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const { userId, role } = req.body;\n    if (!userId || !role) {\n      res.status(400).json({ error: 'userId and role are required' });\n      return;\n    }\n    if (!['viewer', 'editor', 'owner'].includes(role)) {\n      res.status(400).json({ error: 'Invalid role' });\n      return;\n    }\n    if (!users.has(userId)) {\n      res.status(404).json({ error: 'U