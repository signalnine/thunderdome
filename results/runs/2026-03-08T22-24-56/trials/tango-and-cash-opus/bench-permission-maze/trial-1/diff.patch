n and receive a token', async () => {\n      await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });\n      const res = await request(app).post('/auth/login').send({ username: 'alice', password: 'pass123' });\n      expect(res.status).toBe(200);\n      expect(res.body).toHaveProperty('token');\n      expect(res.body).toHaveProperty('userId');\n    });\n\n    it('should reject login with wrong password', async () => {\n      await request(app).post('/auth/register').send({ username: 'alice', password: 'pass123' });\n      const res = await request(app).post('/auth/login').send({ username: 'alice', password: 'wrong' });\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject login with missing fields', async () => {\n      const res = await request(app).post('/auth/login').send({ username: 'alice' });\n      expect(res.status).toBe(400);\n    });\n\n    it('should reject requests without token', async () => {\n      const res = await request(app).get('/folders/some-id');\n      expect(res.status).toBe(401);\n    });\n\n    it('should reject requests with invalid token', async () => {\n      const res = await request(app).get('/folders/some-id').set('Authorization', 'Bearer invalidtoken');\n      expect(res.status).toBe(401);\n    });\n  });\n\n  // --- Folders ---\n  describe('Folders', () => {\n    it('should create a folder', async () => {\n      const { token } = await createUser('alice', 'pass');\n      const res = await request(app).post('/folders').set('Authorization', `Bearer ${token}`).send({ name: 'My Folder' });\n      expect(res.status).toBe(201);\n      expect(res.body.name).toBe('My Folder');\n      expect(res.body.parentId).toBeNull();\n    });\n\n    it('should reject folder creation without name', async () => {\n      const { token } = await createUser('alice', 'pass');\n      const res = await request(app).post('/folders').set('Authorization', `Bearer ${token}`).send({});\n      expect(res.status).toBe(400);\n    });\n\n    it('should create a nested folder', async () => {\n      const { token } = await createUser('alice', 'pass');\n      const parent = await request(app).post('/folders').set('Authorization', `Bearer ${token}`).send({ name: 'Parent' });\n      const child = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: parent.body.id });\n      expect(child.status).toBe(201);\n      expect(child.body.parentId).toBe(parent.body.id);\n    });\n\n    it('should get a folder with children and documents', async () => {\n      const { token } = await createUser('alice', 'pass');\n      const parent = await request(app).post('/folders').set('Authorization', `Bearer ${token}`).send({ name: 'Parent' });\n      await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: parent.body.id });\n      await request(app)\n        .post(`/folders/${parent.body.id}/documents`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'Hello' });\n\n      const res = await request(app).get(`/folders/${parent.body.id}`).set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(200);\n      expect(res.body.children).toHaveLength(1);\n      expect(res.body.documents).toHaveLength(1);\n    });\n\n    it('should update a folder', async () => {\n      const { token } = await createUser('alice', 'pass');\n      const folder = await request(app).post('/folders').set('Authorization', `Bearer ${token}`).send({ name: 'Old' });\n      const res = await request(app)\n        .put(`/folders/${folder.body.id}`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'New' });\n      expect(res.status).toBe(200);\n      expect(res.body.name).toBe('New');\n    });\n\n    it('should delete a folder', async () => {\n      const { token } = await createUser('alice', 'pass');\n      const folder = await request(app).post('/folders').set('Authorization', `Bearer ${token}`).send({ name: 'ToDelete' });\n      const res = await request(app).delete(`/folders/${folder.body.id}`).set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(204);\n      // Verify deleted\n      const get = await request(app).get(`/folders/${folder.body.id}`).set('Authorization', `Bearer ${token}`);\n      expect(get.status).toBe(404);\n    });\n\n    it('should return 404 for non-existent folder', async () => {\n      const { token } = await createUser('alice', 'pass');\n      const res = await request(app).get('/folders/nonexistent').set('Authorization', `Bearer ${token}`);\n      expect(res.status).toBe(404);\n    });\n\n    it('should recursively delete folder contents', async () => {\n      const { token } = await createUser('alice', 'pass');\n      const parent = await request(app).post('/folders').set('Authorization', `Bearer ${token}`).send({ name: 'Parent' });\n      const child = await request(app)\n        .post('/folders')\n        .set('Authorization', `Bearer ${token}`)\n        .send({ name: 'Child', parentId: parent.body.id });\n      const doc = await request(app)\n        .post(`/folders/${child.body.id}/documents`)\n        .set('Authorization', `Bearer ${token}`)\n        .send({ title: 'Doc', content: 'Hello' });\n\n      await request(app).delete(`/folders/${parent.body.id}`).set('Authorization', `Bearer ${token}`);\n\n      const childGet = await request(app).get(`/folders/${child.body.id}`).set('Authorization', `Bearer ${token}`);\n      expect(childGet.status).toBe(404);\n      const docGet = await request(app).get(`/documents/${doc.body.id}`).set('Authorization', `Bearer ${token}`);\n      expect(docGet.status).toBe(404);\n    });\n  });\n\n  // --- Documents ---\n  describe('Documents', () => {\n    it('should create a document in a folder', async () => {\n      const { token } = await createUser('alice', 'pass');\n      c