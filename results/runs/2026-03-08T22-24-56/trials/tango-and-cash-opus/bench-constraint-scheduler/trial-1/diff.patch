+import type { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+
+/**
+ * Detect cycles in the prerequisite graph using DFS.
+ * Throws an error if a cycle is found (including self-references).
+ */
+function detectCycles(events: Event[]): void {
+  const eventIds = new Set(events.map(e => e.id));
+  const WHITE = 0, GRAY = 1, BLACK = 2;
+  const color = new Map<string, number>();
+  for (const e of events) {
+    color.set(e.id, WHITE);
+  }
+
+  const adjList = new Map<string, string[]>();
+  for (const e of events) {
+    adjList.set(e.id, e.prerequisites?.filter(p => eventIds.has(p)) ?? []);
+  }
+
+  function dfs(node: string): void {
+    color.set(node, GRAY);
+    for (const dep of adjList.get(node) ?? []) {
+      if (color.get(dep) === GRAY) {
+        throw new Error(`Prerequisite cycle detected involving event "${dep}"`);
+      }
+      if (color.get(dep) === WHITE) {
+        dfs(dep);
+      }
+    }
+    color.set(node, BLACK);
+  }
+
+  for (const e of events) {
+    if (color.get(e.id) === WHITE) {
+      dfs(e.id);
+    }
+  }
+}
+
+/**
+ * Topological sort of events based on prerequisites.
+ * Returns event IDs in an order where prerequisites come before dependents.
+ */
+function topologicalSort(events: Event[]): string[] {
+  const eventIds = new Set(events.map(e => e.id));
+  const inDegree = new Map<string, number>();
+  const adjList = new Map<string, string[]>();
+
+  for (const e of events) {
+    inDegree.set(e.id, 0);
+    adjList.set(e.id, []);
+  }
+
+  for (const e of events) {
+    for (const pre of e.prerequisites ?? []) {
+      if (eventIds.has(pre)) {
+        adjList.get(pre)!.push(e.id);
+        inDegree.set(e.id, (inDegree.get(e.id) ?? 0) + 1);
+      }
+    }
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const sorted: string[] = [];
+  while (queue.length > 0) {
+    const node = queue.shift()!;
+    sorted.push(node);
+    for (const neighbor of adjList.get(node) ?? []) {
+      const newDeg = (inDegree.get(neighbor) ?? 1) - 1;
+      inDegree.set(neighbor, newDeg);
+      if (newDeg === 0) {
+        queue.push(neighbor);
+      }
+    }
+  }
+
+  return sorted;
+}
+
+/**
+ * Find the earliest start time for an event in a given room, respecting:
+ * - Room gap constraints
+ * - Prerequisite completion times
+ * - Time window
+ */
+function findEarliestStart(
+  event: Event,
+  room: Room,
+  assignments: Assignment[],
+  gap: number,
+  options: ScheduleOptions,
+  eventMap: Map<string, Event>,
+): number | null {
+  const attendees = event.attendees ?? 1;
+  if (attendees > room.capacity) return null;
+
+  // Calculate earliest start based on prerequisites
+  let earliest = options.startTime;
+  for (const preId of event.prerequisites ?? []) {
+    const preAssignment = assignments.find(a => a.eventId === preId);
+    if (preAssignment) {
+      earliest = Math.max(earliest, preAssignment.endTime + gap);
+    } else {
+      // Prerequisite exists as an event but wasn't scheduled — can't schedule this
+      if (eventMap.has(preId)) {
+        return null;
+      }
+      // Prerequisite doesn't exist as an event — ignore it
+    }
+  }
+
+  // Get existing assignments for this room, sorted by start time
+  const roomAssignments = assignments
+    .filter(a => a.roomId === room.id)
+    .sort((a, b) => a.startTime - b.startTime);
+
+  // Try to find a slot
+  let candidateStart = earliest;
+
+  for (const existing of roomAssignments) {
+    if (candidateStart + event.duration <= existing.startTime - gap + 0.0001) {
+      // There's a gap before this assignment, but we need gap after us too
+      if (candidateStart + event.duration + gap <= existing.startTime + 0.0001) {
+        break; // Found a valid slot before this assignment
+      }
+    }
+    // Need to start after this assignment + gap
+    if (candidateStart < existing.endTime + gap) {
+      candidateStart = existing.endTime + gap;
+    }
+  }
+
+  // Check if it fits within the time window
+  if (candidateStart + event.duration > options.endTime) {
+    return null;
+  }
+
+  return candidateStart;
+}
+
+/**
+ * Schedule events using backtracking to maximize the number of scheduled events.
+ */
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  const gap = options.gap ?? 15;
+
+  // Check for cycles first
+  detectCycles(events);
+
+  if (events.length === 0 || rooms.length === 0) {
+    return {
+      assignments: [],
+      unscheduled: events.map(e => e.id),
+    };
+  }
+
+  const eventMap = new Map<string, Event>();
+  for (const e of events) {
+    eventMap.set(e.id, e);
+  }
+
+  // Get topological order
+  const sortedIds = topologicalSort(events);
+
+  // Build dependency info: for each event, which events depend on it
+  const dependents = new Map<string, Set<string>>();
+  for (const e of events) {
+    dependents.set(e.id, new Set());
+  }
+  for (const e of events) {
+    for (const pre of e.prerequisites ?? []) {
+      if (dependents.has(pre)) {
+        dependents.get(pre)!.add(e.id);
+      }
+    }
+  }
+
+  // Greedy approach with smart ordering and preferred room handling
+  // Try preferred room first, then other rooms sorted by capacity (smallest fit first)
+  const assignments: Assignment[] = [];
+  const scheduled = new Set<string>();
+
+  // Process events in topological order
+  for (const eventId of sortedIds) {
+    const event = eventMap.get(eventId)!;
+    const attendees = event.attendees ?? 1;
+
+    // Sort rooms: preferred room first, then by capacity ascending (smallest room that fits)
+    const eligibleRooms = rooms
+      .filter(r => r.capacity >= attendees)
+      .sort((a, b) => {
+        if (event.preferredRoom) {
+          if (a.id === event.preferredRoom && b.id !== event.preferredRoom) return -1;
+          if (b.id === event.preferredRoom && a.id !== event.preferredRoom) return 1;
+        }
+        return a.capacity - b.capacity;
+      });
+
+    let bestStart: number | null = null;
+    let bestRoom: Room | null = null;
+
+    for (const room of eligibleRooms) {
+      const start = findEarliestStart(event, room, assignments, gap, options, eventMap);
+      if (start !== null) {
+        if (bestStart === null || start < bestStart) {
+          bestStart = start;
+          bestRoom = room;
+          // If this is the preferred room and it works, use it
+          if (room.id === event.preferredRoom) break;
+        }
+      }
+    }
+
+    if (bestStart !== null && bestRoom !== null) {
+      // If the preferred room can also accommodate at the same or very close time, use it
+      if (event.preferredRoom && bestRoom.id !== event.preferredRoom) {
+        const prefRoom = eligibleRooms.find(r => r.id === event.preferredRoom);
+        if (prefRoom) {
+          const prefStart = findEarliestStart(event, prefRoom, assignments, gap, options, eventMap);
+          if (prefStart !== null) {
+            bestStart = prefStart;
+            bestRoom = prefRoom;
+          }
+        }
+      }
+
+      assignments.push({
+        eventId: event.id,
+        roomId: bestRoom.id,
+        startTime: bestStart,
+        endTime: bestStart + event.duration,
+      });
+      scheduled.add(event.id);
+    }
+  }
+
+  // Now try to improve: see if any unscheduled events can be fit by rearranging
+  // Try a second pass with backtracking for unscheduled events
+  const unscheduledIds = sortedIds.filter(id => !scheduled.has(id));
+
+  if (unscheduledIds.length > 0 && unscheduledIds.length <= events.length) {
+    // Try removing some events and re-scheduling to fit more
+    // Use a more sophisticated approach: try scheduling unscheduled events
+    // by finding if removing a less-constrained event frees up space
+    const improved = tryImproveSchedule(
+      events, rooms, options, gap, eventMap, sortedIds, dependents
+    );
+    if (improved.assignments.length > assignments.length) {
+      return improved;
+    }
+  }
+
+  const unscheduled = events
+    .filter(e => !scheduled.has(e.id))
+    .map(e => e.id);
+
+  return { assignments, unscheduled };
+}
+
+/**
+ * Try to improve the schedule by using backtracking search.
+ * This tries different room/time combinations to maximize scheduled events.
+ */
+function tryImproveSchedule(
+  events: Event[],
+  rooms: Room[],
+  options: ScheduleOptions,
+  gap: number,
+  eventMap: Map<string, Event>,
+  sortedIds: string[],
+  _dependents: Map<string, Set<string>>,
+): ScheduleResult {
+  let bestAssignments: Assignment[] = [];
+  let bestCount = 0;
+
+  // For each event in topo order, try all possible (room, time) placements
+  // Use recursive backtracking with pruning
+
+  const assignments: Assignment[] = [];
+  const scheduled = new Set<string>();
+
+  function backtrack(index: number): void {
+    // Pruning: even if we schedule all remaining events, can we beat best?
+    const remaining = sortedIds.length - index;
+    if (scheduled.size + remaining <= bestCount) return;
+
+    if (index >= sortedIds.length) {
+      if (scheduled.size > bestCount) {
+        bestCount = scheduled.size;
+        bestAssignments = [...assignments];
+      }
+      return;
+    }
+
+    const eventId = sortedIds[index];
+    const event = eventMap.get(eventId)!;
+    const attendees = event.attendees ?? 1;
+
+    // Check if prerequisites are scheduled
+    let prereqsMet = true;
+    for (const preId of event.prerequisites ?? []) {
+      if (eventMap.has(preId) && !scheduled.has(preId)) {
+        prereqsMet = false;
+        break;
+      }
+    }
+
+    // Try placing in each eligible room
+    if (prereqsMet) {
+      const eligibleRooms = rooms.filter(r => r.capacity >= attendees);
+
+      // Sort: preferred room first
+      const sortedRooms = [...eligibleRooms].sort((a, b) => {
+        if (event.preferredRoom) {
+          if (a.id === event.preferredRoom) return -1;
+          if (b.id === event.preferredRoom) return 1;
+        }
+        return a.capacity - b.capacity;
+      });
+
+      for (const room of sortedRooms) {
+        const start = findEarliestStart(event, room, assignments, gap, options, eventMap);
+        if (start !== null) {
+          const assignment: Assignment = {
+            eventId: event.id,
+            roomId: room.id,
+            startTime: start,
+            endTime: start + event.duration,
+          };
+          assignments.push(assignment);
+          scheduled.add(event.id);
+
+          backtrack(index + 1);
+
+          // If we've scheduled everything, no need to try more
+          if (bestCount === sortedIds.length) return;
+
+          assignments.pop();
+          scheduled.delete(event.id);
+        }
+      }
+    }
+
+    // Also try skipping this event
+    backtrack(index + 1);
+  }
+
+  // Limit backtracking for large inputs
+  if (sortedIds.length <= 15) {
+    backtrack(0);
+  } else {
+    // For larger inputs, use the greedy result
+    return {
+      assignments: [],
+      unscheduled: events.map(e => e.id),
+    };
+  }
+
+  const scheduledSet = new Set(bestAssignments.map(a => a.eventId));
+  const unscheduled = events.filter(e => !scheduledSet.has(e.id)).map(e => e.id);
+
+  return { assignments: bestAssignments, unscheduled };
+}
