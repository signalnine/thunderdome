+import { Plugin } from '../core/types.js';
+
+export function createAssetPipelinePlugin(): Plugin {
+  return {
+    name: 'asset-pipeline',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file, ctx) {
+        let content = file.content;
+        const discovered: string[] = [];
+
+        // Rewrite relative src="./..." to src="/assets/..."
+        content = content.replace(
+          /src="\.\/([^"]+)"/g,
+          (_m, filename: string) => {
+            discovered.push(filename);
+            return `src="/assets/${filename}"`;
+          }
+        );
+
+        // Rewrite relative href="./..." to href="/assets/..."
+        content = content.replace(
+          /href="\.\/([^"]+)"/g,
+          (_m, filename: string) => {
+            discovered.push(filename);
+            return `href="/assets/${filename}"`;
+          }
+        );
+
+        // Update manifest
+        const existing = ctx.data.get('asset-manifest') as { assets: string[] } | undefined;
+        const assets = existing ? [...existing.assets, ...discovered] : [...discovered];
+        ctx.data.set('asset-manifest', { assets });
+
+        return { ...file, content };
+      },
+    },
+  };
+}
