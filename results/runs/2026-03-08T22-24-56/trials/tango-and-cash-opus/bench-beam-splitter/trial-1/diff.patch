@@ -0,0 +1,123 @@
+type Direction = 'down' | 'down-left' | 'down-right';
+
+interface Beam {
+  row: number;
+  col: number;
+  dir: Direction;
+}
+
+function advance(row: number, col: number, dir: Direction): [number, number] {
+  switch (dir) {
+    case 'down':       return [row + 1, col];
+    case 'down-left':  return [row + 1, col - 1];
+    case 'down-right': return [row + 1, col + 1];
+  }
+}
+
+function findSource(grid: string[][]): [number, number] {
+  for (let c = 0; c < grid[0].length; c++) {
+    if (grid[0][c] === 'S') return [0, c];
+  }
+  throw new Error('No source found');
+}
+
+export function countBeamCells(grid: string[][]): number {
+  const rows = grid.length;
+  const cols = grid[0]?.length ?? 0;
+  if (rows === 0 || cols === 0) return 0;
+
+  const [, sc] = findSource(grid);
+  const visited = new Set<string>();
+  const seen = new Set<string>();
+
+  const queue: Beam[] = [{ row: 0, col: sc, dir: 'down' }];
+
+  while (queue.length > 0) {
+    const { row, col, dir } = queue.pop()!;
+
+    const stateKey = `${row},${col},${dir}`;
+    if (seen.has(stateKey)) continue;
+    seen.add(stateKey);
+
+    visited.add(`${row},${col}`);
+
+    if (grid[row][col] === '^') {
+      for (const newDir of ['down-left', 'down-right'] as Direction[]) {
+        const [nr, nc] = advance(row, col, newDir);
+        if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
+          queue.push({ row: nr, col: nc, dir: newDir });
+        }
+      }
+    } else {
+      const [nr, nc] = advance(row, col, dir);
+      if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
+        queue.push({ row: nr, col: nc, dir });
+      }
+    }
+  }
+
+  return visited.size;
+}
+
+export function countBeamPaths(grid: string[][]): bigint {
+  const rows = grid.length;
+  const cols = grid[0]?.length ?? 0;
+  if (rows === 0 || cols === 0) return 0n;
+
+  const [, sc] = findSource(grid);
+
+  // Process row-by-row. current maps "(col),(dir)" -> path count for beams at row r.
+  let current = new Map<string, bigint>();
+  current.set(`${sc},down`, 1n);
+
+  let totalPaths = 0n;
+
+  for (let r = 0; r < rows; r++) {
+    const next = new Map<string, bigint>();
+
+    for (const [key, count] of current) {
+      const commaIdx = key.indexOf(',');
+      const col = parseInt(key.substring(0, commaIdx));
+      const dir = key.substring(commaIdx + 1) as Direction;
+
+      if (grid[r][col] === '^') {
+        const [, c1] = advance(r, col, 'down-left');
+        const [, c2] = advance(r, col, 'down-right');
+        const nr = r + 1;
+
+        if (nr < rows && c1 >= 0 && c1 < cols) {
+          addToMap(next, `${c1},down-left`, count);
+        } else {
+          totalPaths += count;
+        }
+
+        if (nr < rows && c2 >= 0 && c2 < cols) {
+          addToMap(next, `${c2},down-right`, count);
+        } else {
+          totalPaths += count;
+        }
+      } else {
+        const [, nc] = advance(r, col, dir);
+        const nr = r + 1;
+
+        if (nr < rows && nc >= 0 && nc < cols) {
+          addToMap(next, `${nc},${dir}`, count);
+        } else {
+          totalPaths += count;
+        }
+      }
+    }
+
+    current = next;
+  }
+
+  for (const [, count] of current) {
+    totalPaths += count;
+  }
+
+  return totalPaths;
+}
+
+function addToMap(map: Map<string, bigint>, key: string, value: bigint): void {
+  map.set(key, (map.get(key) ?? 0n) + value);
+}
