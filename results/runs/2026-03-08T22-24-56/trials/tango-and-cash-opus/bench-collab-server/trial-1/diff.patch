    res.status(204).end();\n  });\n\n  // Get version history\n  router.get('/api/documents/:id/versions', (req, res) => {\n    const doc = getDocument(db, req.params.id);\n    if (!doc) {\n      res.status(404).json({ error: 'Document not found' });\n      return;\n    }\n    const versions = getVersions(db, req.params.id);\n    res.json(versions);\n  });\n\n  return router;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":318,"cache_read_input_tokens":28041,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":318},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"43a72fe2-20de-46d2-afb1-c5e742c408f8","uuid":"e41712d1-18f9-4b62-a2aa-d66554ce08cb"}
