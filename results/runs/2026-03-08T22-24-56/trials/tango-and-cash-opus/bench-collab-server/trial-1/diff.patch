 b: Operation = [\n        { type: 'retain', count: 2 },\n        { type: 'insert', text: 'Y' },\n        { type: 'retain', count: 1 },\n      ];\n\n      const { aPrime, bPrime } = transform(a, b);\n\n      const doc = 'abc';\n      const afterA = apply(doc, a);   // \"aXbc\"\n      const afterB = apply(doc, b);   // \"abYc\"\n\n      const result1 = apply(afterA, bPrime);\n      const result2 = apply(afterB, aPrime);\n\n      expect(result1).toBe(result2);\n      expect(result1).toContain('X');\n      expect(result1).toContain('Y');\n    });\n\n    it('should transform two concurrent inserts at the same position', () => {\n      const a: Operation = [\n        { type: 'insert', text: 'A' },\n        { type: 'retain', count: 3 },\n      ];\n      const b: Operation = [\n        { type: 'insert', text: 'B' },\n        { type: 'retain', count: 3 },\n      ];\n\n      const { aPrime, bPrime } = transform(a, b);\n\n      const doc = 'abc';\n      const result1 = apply(apply(doc, a), bPrime);\n      const result2 = apply(apply(doc, b), aPrime);\n\n      expect(result1).toBe(result2);\n      expect(result1).toContain('A');\n      expect(result1).toContain('B');\n    });\n\n    it('should transform insert vs delete', () => {\n      // doc = \"abcde\" (len 5)\n      // a inserts \"X\" at pos 2\n      // b deletes 2 chars at pos 1 (deletes \"bc\")\n      const a: Operation = [\n        { type: 'retain', count: 2 },\n        { type: 'insert', text: 'X' },\n        { type: 'retain', count: 3 },\n      ];\n      const b: Operation = [\n        { type: 'retain', count: 1 },\n        { type: 'delete', count: 2 },\n        { type: 'retain', count: 2 },\n      ];\n\n      const { aPrime, bPrime } = transform(a, b);\n\n      const doc = 'abcde';\n      const result1 = apply(apply(doc, a), bPrime);\n      const result2 = apply(apply(doc, b), aPrime);\n\n      expect(result1).toBe(result2);\n      expect(result1).toContain('X');\n    });\n\n    it('should handle both deleting overlapping ranges', () => {\n      // doc = \"abcde\" (len 5)\n      // a deletes \"bcd\" (pos 1, count 3)\n      // b deletes \"cd\" (pos 2, count 2)\n      const a: Operation = [\n        { type: 'retain', count: 1 },\n        { type: 'delete', count: 3 },\n        { type: 'retain', count: 1 },\n      ];\n      const b: Operation = [\n        { type: 'retain', count: 2 },\n        { type: 'delete', count: 2 },\n        { type: 'retain', count: 1 },\n      ];\n\n      const { aPrime, bPrime } = transform(a, b);\n\n      const doc = 'abcde';\n      const result1 = apply(apply(doc, a), bPrime);\n      const result2 = apply(apply(doc, b), aPrime);\n\n      expect(result1).toBe(result2);\n      expect(result1).toBe('ae');\n    });\n  });\n\n  describe('compose', () => {\n    it('should compose two operations', () => {\n      const doc = 'hello';\n      const a: Operation = [\n        { type: 'retain', count: 5 },\n        { type: 'insert', text: ' world' },\n      ];\n      const b: Operation = [\n        { type: 'retain', count: 11 },\n        { type: 'insert', text: '!' },\n      ];\n\n      const composed = compose(a, b);\n      const result1 = apply(apply(doc, a), b);\n      const result2 = apply(doc, composed);\n\n      expect(result1).toBe(result2);\n      expect(result1).toBe('hello world!');\n    });\n  });\n\n  describe('inputLength / outputLength', () => {\n    it('should calculate correct lengths', () => {\n      const op: Operation = [\n        { type: 'retain', count: 3 },\n        { type: 'insert', text: 'XY' },\n        { type: 'delete', count: 2 },\n      ];\n      expect(inputLength(op)).toBe(5);\n      expect(outputLength(op)).toBe(5); // 3 + 2 = 5\n    });\n  });\n\n  describe('validateOperation', () => {\n    it('should accept valid operations', () => {\n      expect(validateOperation([{ type: 'retain', count: 5 }])).toBe(true);\n      expect(validateOperation([{ type: 'insert', text: 'hi' }])).toBe(true);\n      expect(validateOperation([{ type: 'delete'