@@ -0,0 +1,319 @@
+import { describe, it, expect } from 'vitest';
+import WebSocket from 'ws';
+import { createApp } from '../server.js';
+
+interface WsClient {
+  ws: WebSocket;
+  messages: Record<string, unknown>[];
+  waitForMessage: (type?: string) => Promise<Record<string, unknown>>;
+}
+
+function connectWs(port: number, docId: string): Promise<WsClient> {
+  return new Promise((resolve, reject) => {
+    const ws = new WebSocket(`ws://localhost:${port}/ws/${docId}`);
+    const messages: Record<string, unknown>[] = [];
+    const waiters: Array<{ type?: string; resolve: (msg: Record<string, unknown>) => void }> = [];
+
+    ws.on('message', (data) => {
+      const msg = JSON.parse(data.toString()) as Record<string, unknown>;
+      // Check if any waiter matches
+      const idx = waiters.findIndex((w) => !w.type || w.type === msg.type);
+      if (idx >= 0) {
+        const waiter = waiters.splice(idx, 1)[0];
+        waiter.resolve(msg);
+      } else {
+        messages.push(msg);
+      }
+    });
+
+    function waitForMessage(type?: string): Promise<Record<string, unknown>> {
+      // Check buffered messages first
+      const idx = messages.findIndex((m) => !type || m.type === type);
+      if (idx >= 0) {
+        return Promise.resolve(messages.splice(idx, 1)[0]);
+      }
+      return new Promise((res) => {
+        waiters.push({ type, resolve: res });
+      });
+    }
+
+    ws.on('open', () => resolve({ ws, messages, waitForMessage }));
+    ws.on('error', reject);
+  });
+}
+
+async function createDocViaRest(baseUrl: string, title: string, content = '') {
+  const res = await fetch(`${baseUrl}/api/documents`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ title, content }),
+  });
+  return res.json() as Promise<{ id: string; title: string; content: string }>;
+}
+
+describe('WebSocket collaboration', () => {
+  it('should send sync message on connection', async () => {
+    const instance = createApp();
+    const port = await instance.start(0);
+    const baseUrl = `http://localhost:${port}`;
+
+    try {
+      const doc = await createDocViaRest(baseUrl, 'WS Test', 'hello');
+      const client = await connectWs(port, doc.id);
+      const msg = await client.waitForMessage('sync');
+
+      expect(msg.type).toBe('sync');
+      expect(msg.content).toBe('hello');
+      expect(msg.version).toBe(1);
+
+      client.ws.close();
+    } finally {
+      await instance.stop();
+    }
+  });
+
+  it('should broadcast operations to other clients', async () => {
+    const instance = createApp();
+    const port = await instance.start(0);
+    const baseUrl = `http://localhost:${port}`;
+
+    try {
+      const doc = await createDocViaRest(baseUrl, 'Broadcast', 'abc');
+
+      const c1 = await connectWs(port, doc.id);
+      const c2 = await connectWs(port, doc.id);
+
+      // Consume sync messages
+      await c1.waitForMessage('sync');
+      await c2.waitForMessage('sync');
+
+      c1.ws.send(
+        JSON.stringify({
+          type: 'operation',
+          version: 1,
+          operation: [
+            { type: 'retain', count: 3 },
+            { type: 'insert', text: 'def' },
+          ],
+        })
+      );
+
+      const ack = await c1.waitForMessage('ack');
+      expect(ack.version).toBe(2);
+
+      const broadcast = await c2.waitForMessage('operation');
+      expect(broadcast.type).toBe('operation');
+      expect(broadcast.version).toBe(2);
+
+      c1.ws.close();
+      c2.ws.close();
+    } finally {
+      await instance.stop();
+    }
+  });
+
+  it('should handle concurrent edits and converge', async () => {
+    const instance = createApp();
+    const port = await instance.start(0);
+    const baseUrl = `http://localhost:${port}`;
+
+    try {
+      const doc = await createDocViaRest(baseUrl, 'Concurrent', 'abc');
+
+      const c1 = await connectWs(port, doc.id);
+      const c2 = await connectWs(port, doc.id);
+
+      await c1.waitForMessage('sync');
+      await c2.waitForMessage('sync');
+
+      // ws1 inserts X at start, ws2 inserts Y at end, both based on version 1
+      c1.ws.send(
+        JSON.stringify({
+          type: 'operation',
+          version: 1,
+          operation: [
+            { type: 'insert', text: 'X' },
+            { type: 'retain', count: 3 },
+          ],
+        })
+      );
+
+      await c1.waitForMessage('ack');
+
+      c2.ws.send(
+        JSON.stringify({
+          type: 'operation',
+          version: 1,
+          operation: [
+            { type: 'retain', count: 3 },
+            { type: 'insert', text: 'Y' },
+          ],
+        })
+      );
+
+      await c2.waitForMessage('ack');
+
+      const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);
+      const result = await getRes.json() as { content: string };
+
+      expect(result.content).toContain('X');
+      expect(result.content).toContain('Y');
+      expect(result.content).toContain('abc');
+      expect(result.content.length).toBe(5);
+
+      c1.ws.close();
+      c2.ws.close();
+    } finally {
+      await instance.stop();
+    }
+  });
+
+  it('should reject malformed operations', async () => {
+    const instance = createApp();
+    const port = await instance.start(0);
+    const baseUrl = `http://localhost:${port}`;
+
+    try {
+      const doc = await createDocViaRest(baseUrl, 'Malformed', 'abc');
+      const client = await connectWs(port, doc.id);
+      await client.waitForMessage('sync');
+
+      client.ws.send(
+        JSON.stringify({
+          type: 'operation',
+          version: 1,
+          operation: [{ type: 'banana' }],
+        })
+      );
+
+      const err = await client.waitForMessage('error');
+      expect(err.type).toBe('error');
+
+      client.ws.close();
+    } finally {
+      await instance.stop();
+    }
+  });
+
+  it('should send error for invalid path', async () => {
+    const instance = createApp();
+    const port = await instance.start(0);
+
+    try {
+      const ws = new WebSocket(`ws://localhost:${port}/invalid`);
+      const msg: Record<string, unknown> = await new Promise((resolve) => {
+        ws.on('message', (data) => {
+          resolve(JSON.parse(data.toString()));
+        });
+      });
+      expect(msg.type).toBe('error');
+    } finally {
+      await instance.stop();
+    }
+  });
+
+  it('should send error for non-existent document', async () => {
+    const instance = createApp();
+    const port = await instance.start(0);
+
+    try {
+      const client = await connectWs(port, 'nonexistent-id');
+      const msg = await client.waitForMessage('error');
+      expect(msg.type).toBe('error');
+      client.ws.close();
+    } finally {
+      await instance.stop();
+    }
+  });
+
+  it('should handle 10 concurrent clients without corruption', async () => {
+    const instance = createApp();
+    const port = await instance.start(0);
+    const baseUrl = `http://localhost:${port}`;
+
+    try {
+      const doc = await createDocViaRest(baseUrl, 'Stress Test', '');
+
+      const clients: WsClient[] = [];
+      for (let i = 0; i < 10; i++) {
+        const c = await connectWs(port, doc.id);
+        await c.waitForMessage('sync');
+        clients.push(c);
+      }
+
+      // Each client sends an insert sequentially, all based on version 1
+      for (let i = 0; i < 10; i++) {
+        clients[i].ws.send(
+          JSON.stringify({
+            type: 'operation',
+            version: 1,
+            operation: [{ type: 'insert', text: String.fromCharCode(65 + i) }],
+          })
+        );
+        await clients[i].waitForMessage('ack');
+      }
+
+      await new Promise((resolve) => setTimeout(resolve, 200));
+
+      const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);
+      const result = await getRes.json() as { content: string };
+
+      for (let i = 0; i < 10; i++) {
+        expect(result.content).toContain(String.fromCharCode(65 + i));
+      }
+      expect(result.content.length).toBe(10);
+
+      for (const c of clients) {
+        c.ws.close();
+      }
+    } finally {
+      await instance.stop();
+    }
+  });
+
+  it('should handle 10 clients sending simultaneously', async () => {
+    const instance = createApp();
+    const port = await instance.start(0);
+    const baseUrl = `http://localhost:${port}`;
+
+    try {
+      const doc = await createDocViaRest(baseUrl, 'Concurrent Stress', '');
+
+      const clients: WsClient[] = [];
+      for (let i = 0; i < 10; i++) {
+        const c = await connectWs(port, doc.id);
+        await c.waitForMessage('sync');
+        clients.push(c);
+      }
+
+      const ackPromises = clients.map((c) => c.waitForMessage('ack'));
+
+      for (let i = 0; i < 10; i++) {
+        clients[i].ws.send(
+          JSON.stringify({
+            type: 'operation',
+            version: 1,
+            operation: [{ type: 'insert', text: String.fromCharCode(65 + i) }],
+          })
+        );
+      }
+
+      await Promise.all(ackPromises);
+      await new Promise((resolve) => setTimeout(resolve, 200));
+
+      const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);
+      const result = await getRes.json() as { content: string };
+
+      for (let i = 0; i < 10; i++) {
+        expect(result.content).toContain(String.fromCharCode(65 + i));
+      }
+      expect(result.content.length).toBe(10);
+
+      for (const c of clients) {
+        c.ws.close();
+      }
+    } finally {
+      await instance.stop();
+    }
+  });
+});
