new file mode 100644
index 0000000..44e7197
--- /dev/null
+++ b/src/__tests__/ot.test.ts
@@ -0,0 +1,189 @@
+import { describe, it, expect } from 'vitest';
+import { apply, transform, compose, inputLength, outputLength, validateOperation, type Operation } from '../ot.js';
+
+describe('OT module', () => {
+  describe('apply', () => {
+    it('should apply a retain-only operation (identity)', () => {
+      expect(apply('hello', [{ type: 'retain', count: 5 }])).toBe('hello');
+    });
+
+    it('should apply an insert operation', () => {
+      const op: Operation = [
+        { type: 'retain', count: 5 },
+        { type: 'insert', text: ' world' },
+      ];
+      expect(apply('hello', op)).toBe('hello world');
+    });
+
+    it('should apply a delete operation', () => {
+      const op: Operation = [
+        { type: 'retain', count: 5 },
+        { type: 'delete', count: 6 },
+      ];
+      expect(apply('hello world', op)).toBe('hello');
+    });
+
+    it('should apply insert at the beginning', () => {
+      const op: Operation = [
+        { type: 'insert', text: 'Hey ' },
+        { type: 'retain', count: 5 },
+      ];
+      expect(apply('world', op)).toBe('Hey world');
+    });
+
+    it('should throw on length mismatch', () => {
+      expect(() => apply('hello', [{ type: 'retain', count: 10 }])).toThrow();
+    });
+  });
+
+  describe('transform', () => {
+    it('should transform two concurrent inserts at different positions', () => {
+      // doc = "abc" (len 3)
+      // a inserts "X" at position 1: retain 1, insert "X", retain 2
+      // b inserts "Y" at position 2: retain 2, insert "Y", retain 1
+      const a: Operation = [
+        { type: 'retain', count: 1 },
+        { type: 'insert', text: 'X' },
+        { type: 'retain', count: 2 },
+      ];
+      const b: Operation = [
+        { type: 'retain', count: 2 },
+        { type: 'insert', text: 'Y' },
+        { type: 'retain', count: 1 },
+      ];
+
+      const { aPrime, bPrime } = transform(a, b);
+
+      const doc = 'abc';
+      const afterA = apply(doc, a);   // "aXbc"
+      const afterB = apply(doc, b);   // "abYc"
+
+      const result1 = apply(afterA, bPrime);
+      const result2 = apply(afterB, aPrime);
+
+      expect(result1).toBe(result2);
+      expect(result1).toContain('X');
+      expect(result1).toContain('Y');
+    });
+
+    it('should transform two concurrent inserts at the same position', () => {
+      const a: Operation = [
+        { type: 'insert', text: 'A' },
+        { type: 'retain', count: 3 },
+      ];
+      const b: Operation = [
+        { type: 'insert', text: 'B' },
+        { type: 'retain', count: 3 },
+      ];
+
+      const { aPrime, bPrime } = transform(a, b);
+
+      const doc = 'abc';
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+
+      expect(result1).toBe(result2);
+      expect(result1).toContain('A');
+      expect(result1).toContain('B');
+    });
+
+    it('should transform insert vs delete', () => {
+      // doc = "abcde" (len 5)
+      // a inserts "X" at pos 2
+      // b deletes 2 chars at pos 1 (deletes "bc")
+      const a: Operation = [
+        { type: 'retain', count: 2 },
+        { type: 'insert', text: 'X' },
+        { type: 'retain', count: 3 },
+      ];
+      const b: Operation = [
+        { type: 'retain', count: 1 },
+        { type: 'delete', count: 2 },
+        { type: 'retain', count: 2 },
+      ];
+
+      const { aPrime, bPrime } = transform(a, b);
+
+      const doc = 'abcde';
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+
+      expect(result1).toBe(result2);
+      expect(result1).toContain('X');
+    });
+
+    it('should handle both deleting overlapping ranges', () => {
+      // doc = "abcde" (len 5)
+      // a deletes "bcd" (pos 1, count 3)
+      // b deletes "cd" (pos 2, count 2)
+      const a: Operation = [
+        { type: 'retain', count: 1 },
+        { type: 'delete', count: 3 },
+        { type: 'retain', count: 1 },
+      ];
+      const b: Operation = [
+        { type: 'retain', count: 2 },
+        { type: 'delete', count: 2 },
+        { type: 'retain', count: 1 },
+      ];
+
+      const { aPrime, bPrime } = transform(a, b);
+
+      const doc = 'abcde';
+      const result1 = apply(apply(doc, a), bPrime);
+      const result2 = apply(apply(doc, b), aPrime);
+
+      expect(result1).toBe(result2);
+      expect(result1).toBe('ae');
+    });
+  });
+
+  describe('compose', () => {
+    it('should compose two operations', () => {
+      const doc = 'hello';
+      const a: Operation = [
+        { type: 'retain', count: 5 },
+        { type: 'insert', text: ' world' },
+      ];
+      const b: Operation = [
+        { type: 'retain', count: 11 },
+        { type: 'insert', text: '!' },
+      ];
+
+      const composed = compose(a, b);
+      const result1 = apply(apply(doc, a), b);
+      const result2 = apply(doc, composed);
+
+      expect(result1).toBe(result2);
+      expect(result1).toBe('hello world!');
+    });
+  });
+
+  describe('inputLength / outputLength', () => {
+    it('should calculate correct lengths', () => {
+      const op: Operation = [
+        { type: 'retain', count: 3 },
+        { type: 'insert', text: 'XY' },
+        { type: 'delete', count: 2 },
+      ];
+      expect(inputLength(op)).toBe(5);
+      expect(outputLength(op)).toBe(5); // 3 + 2 = 5
+    });
+  });
+
+  describe('validateOperation', () => {
+    it('should accept valid operations', () => {
+      expect(validateOperation([{ type: 'retain', count: 5 }])).toBe(true);
+      expect(validateOperation([{ type: 'insert', text: 'hi' }])).toBe(true);
+      expect(validateOperation([{ type: 'delete', count: 3 }])).toBe(true);
+    });
+
+    it('should reject invalid operations', () => {
+      expect(validateOperation('not an array')).toBe(false);
+      expect(validateOperation([{ type: 'unknown' }])).toBe(false);
+      expect(validateOperation([{ type: 'retain', count: -1 }])).toBe(false);
+      expect(validateOperation([{ type: 'retain', count: 1.5 }])).toBe(false);
+      expect(validateOperation([{ type: 'insert', text: 123 }])).toBe(false);
+    });
+  });
+});
