@@ -0,0 +1,76 @@
+import { Router, json } from 'express';
+import type Database from 'better-sqlite3';
+import {
+  createDocument,
+  getDocument,
+  listDocuments,
+  updateDocument,
+  deleteDocument,
+  getVersions,
+} from './db.js';
+
+export function createRouter(db: Database.Database): Router {
+  const router = Router();
+  router.use(json());
+
+  // List documents
+  router.get('/api/documents', (_req, res) => {
+    const docs = listDocuments(db);
+    res.json(docs);
+  });
+
+  // Create document
+  router.post('/api/documents', (req, res) => {
+    const { title, content } = req.body as { title?: string; content?: string };
+    if (!title || typeof title !== 'string') {
+      res.status(400).json({ error: 'title is required and must be a string' });
+      return;
+    }
+    const doc = createDocument(db, title, content ?? '');
+    res.status(201).json(doc);
+  });
+
+  // Get document
+  router.get('/api/documents/:id', (req, res) => {
+    const doc = getDocument(db, req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Update document
+  router.put('/api/documents/:id', (req, res) => {
+    const { title, content } = req.body as { title?: string; content?: string };
+    const doc = updateDocument(db, req.params.id, { title, content });
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.json(doc);
+  });
+
+  // Delete document
+  router.delete('/api/documents/:id', (req, res) => {
+    const deleted = deleteDocument(db, req.params.id);
+    if (!deleted) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    res.status(204).end();
+  });
+
+  // Get version history
+  router.get('/api/documents/:id/versions', (req, res) => {
+    const doc = getDocument(db, req.params.id);
+    if (!doc) {
+      res.status(404).json({ error: 'Document not found' });
+      return;
+    }
+    const versions = getVersions(db, req.params.id);
+    res.json(versions);
+  });
+
+  return router;
+}
