rt', port);\n\n  const res = await fetch(`http://localhost:${port}/api/documents`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ title: 'Test', content: 'hello' }),\n  });\n  const doc = await res.json() as { id: string };\n  console.log('created doc', doc.id);\n\n  console.log('creating websocket');\n  const ws = new WebSocket(`ws://localhost:${port}/ws/${doc.id}`);\n  console.log('ws readyState:', ws.readyState);\n\n  ws.on('open', () => console.log('OPEN event'));\n  ws.on('error', (e) => console.log('ERROR event:', e.message));\n  ws.on('close', (code) => console.log('CLOSE event:', code));\n  ws.on('message', (d) => console.log('MESSAGE event:', d.toString()));\n\n  await new Promise<void>((resolve, reject) => {\n    const t = setTimeout(() => {\n      console.log('TIMEOUT - readyState:', ws.readyState);\n      reject(new Error('ws open timeout'));\n    }, 5000);\n    ws.on('open', () => { clearTimeout(t); resolve(); });\n  });\n\n  console.log('ws is open');\n\n  const msg = await new Promise<Record<string, unknown>>((resolve) => {\n    ws.once('message', (data) => resolve(JSON.parse(data.toString())));\n  });\n\n  console.log('got message:', msg);\n  expect(msg.type).toBe('sync');\n\n  ws.close();\n  await instance.stop();\n});\n"}}
