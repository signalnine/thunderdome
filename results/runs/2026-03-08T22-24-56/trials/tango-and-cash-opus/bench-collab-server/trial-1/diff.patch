@@ -0,0 +1,196 @@
+import { WebSocketServer, WebSocket } from 'ws';
+import type { Server as HTTPServer } from 'http';
+import type Database from 'better-sqlite3';
+import {
+  getDocument,
+  getLatestVersion,
+  addVersion,
+  updateDocumentContent,
+} from './db.js';
+import {
+  type Operation,
+  validateOperation,
+  apply,
+  transform,
+  inputLength,
+} from './ot.js';
+
+interface ClientInfo {
+  ws: WebSocket;
+  documentId: string;
+}
+
+interface DocumentState {
+  version: number;
+  content: string;
+  // Buffer of operations since version 0.  Index i holds the op that transformed version i → i+1.
+  ops: Operation[];
+}
+
+export function setupWebSocket(
+  server: HTTPServer,
+  db: Database.Database
+): { wss: WebSocketServer; closeAll: () => void } {
+  const wss = new WebSocketServer({ server });
+
+  // In-memory document states, keyed by document ID
+  const documents = new Map<string, DocumentState>();
+  // All connected clients
+  const clients = new Set<ClientInfo>();
+
+  function getDocState(docId: string): DocumentState | undefined {
+    if (documents.has(docId)) return documents.get(docId)!;
+
+    // Load from DB
+    const doc = getDocument(db, docId);
+    if (!doc) return undefined;
+
+    const version = getLatestVersion(db, docId);
+    const state: DocumentState = {
+      version,
+      content: doc.content,
+      ops: [],
+    };
+    documents.set(docId, state);
+    return state;
+  }
+
+  function broadcastToDocument(docId: string, message: object, exclude?: WebSocket) {
+    const msg = JSON.stringify(message);
+    for (const client of clients) {
+      if (client.documentId === docId && client.ws !== exclude && client.ws.readyState === WebSocket.OPEN) {
+        client.ws.send(msg);
+      }
+    }
+  }
+
+  wss.on('connection', (ws, req) => {
+    // Extract document ID from URL path: /ws/:documentId
+    const url = req.url ?? '';
+    const match = url.match(/\/ws\/([^/?]+)/);
+    if (!match) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Invalid WebSocket path. Use /ws/:documentId' }));
+      ws.close();
+      return;
+    }
+
+    const documentId = match[1];
+    const state = getDocState(documentId);
+    if (!state) {
+      ws.send(JSON.stringify({ type: 'error', message: 'Document not found' }));
+      ws.close();
+      return;
+    }
+
+    const clientInfo: ClientInfo = { ws, documentId };
+    clients.add(clientInfo);
+
+    // Send sync message with current state
+    ws.send(
+      JSON.stringify({
+        type: 'sync',
+        content: state.content,
+        version: state.version,
+      })
+    );
+
+    ws.on('message', (data) => {
+      try {
+        const msg = JSON.parse(data.toString());
+
+        if (msg.type !== 'operation') {
+          ws.send(JSON.stringify({ type: 'error', message: `Unknown message type: ${msg.type}` }));
+          return;
+        }
+
+        if (!validateOperation(msg.operation)) {
+          ws.send(JSON.stringify({ type: 'error', message: 'Invalid operation format' }));
+          return;
+        }
+
+        const clientVersion: number = typeof msg.version === 'number' ? msg.version : state.version;
+
+        if (clientVersion < 0 || clientVersion > state.version) {
+          ws.send(
+            JSON.stringify({
+              type: 'error',
+              message: `Invalid version ${clientVersion}. Current server version is ${state.version}`,
+            })
+          );
+          return;
+        }
+
+        let op: Operation = msg.operation;
+
+        // Transform against all operations that happened since the client's version
+        for (let i = clientVersion; i < state.version; i++) {
+          const serverOp = state.ops[i - (state.version - state.ops.length)];
+          if (!serverOp) {
+            ws.send(JSON.stringify({ type: 'error', message: 'Cannot transform: missing server operation history' }));
+            return;
+          }
+          const result = transform(serverOp, op);
+          op = result.bPrime;
+        }
+
+        // Validate that the transformed operation matches the current document length
+        if (inputLength(op) !== state.content.length) {
+          ws.send(
+            JSON.stringify({
+              type: 'error',
+              message: `Operation input length (${inputLength(op)}) does not match document length (${state.content.length})`,
+            })
+          );
+          return;
+        }
+
+        // Apply the transformed operation
+        const newContent = apply(state.content, op);
+        state.version++;
+        state.ops.push(op);
+        state.content = newContent;
+
+        // Persist
+        addVersion(db, documentId, state.version, newContent, JSON.stringify(op));
+        updateDocumentContent(db, documentId, newContent);
+
+        // Acknowledge to the sender
+        ws.send(
+          JSON.stringify({
+            type: 'ack',
+            version: state.version,
+          })
+        );
+
+        // Broadcast the transformed operation to other clients
+        broadcastToDocument(
+          documentId,
+          {
+            type: 'operation',
+            operation: op,
+            version: state.version,
+          },
+          ws
+        );
+      } catch (err) {
+        const message = err instanceof Error ? err.message : 'Unknown error';
+        ws.send(JSON.stringify({ type: 'error', message }));
+      }
+    });
+
+    ws.on('close', () => {
+      clients.delete(clientInfo);
+    });
+  });
+
+  function closeAll() {
+    for (const client of clients) {
+      client.ws.close();
+    }
+    clients.clear();
+    documents.clear();
+    wss.close();
+  }
+
+  return { wss, closeAll };
+}
