--- /dev/null
+++ b/src/ot.ts
@@ -0,0 +1,312 @@
+/**
+ * Operational Transform module.
+ *
+ * Operations are arrays of components. Each component is one of:
+ *   - { type: 'retain', count: number }
+ *   - { type: 'insert', text: string }
+ *   - { type: 'delete', count: number }
+ *
+ * An operation's *input length* must equal the document length it is applied to.
+ * After applying, the document length equals the *output length*.
+ */
+
+export interface RetainOp {
+  type: 'retain';
+  count: number;
+}
+
+export interface InsertOp {
+  type: 'insert';
+  text: string;
+}
+
+export interface DeleteOp {
+  type: 'delete';
+  count: number;
+}
+
+export type OpComponent = RetainOp | InsertOp | DeleteOp;
+
+export type Operation = OpComponent[];
+
+// ---------------------------------------------------------------------------
+// Helpers
+// ---------------------------------------------------------------------------
+
+export function inputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (c.type === 'retain') len += c.count;
+    else if (c.type === 'delete') len += c.count;
+    // insert doesn't consume input
+  }
+  return len;
+}
+
+export function outputLength(op: Operation): number {
+  let len = 0;
+  for (const c of op) {
+    if (c.type === 'retain') len += c.count;
+    else if (c.type === 'insert') len += c.text.length;
+    // delete doesn't produce output
+  }
+  return len;
+}
+
+// ---------------------------------------------------------------------------
+// Apply
+// ---------------------------------------------------------------------------
+
+export function apply(doc: string, op: Operation): string {
+  if (inputLength(op) !== doc.length) {
+    throw new Error(
+      `Operation input length (${inputLength(op)}) does not match document length (${doc.length})`
+    );
+  }
+  let cursor = 0;
+  let result = '';
+  for (const c of op) {
+    switch (c.type) {
+      case 'retain':
+        result += doc.slice(cursor, cursor + c.count);
+        cursor += c.count;
+        break;
+      case 'insert':
+        result += c.text;
+        break;
+      case 'delete':
+        cursor += c.count;
+        break;
+    }
+  }
+  return result;
+}
+
+// ---------------------------------------------------------------------------
+// Compose  (apply(doc, a) then apply(result, b)  ==  apply(doc, compose(a,b)))
+// ---------------------------------------------------------------------------
+
+export function compose(a: Operation, b: Operation): Operation {
+  if (outputLength(a) !== inputLength(b)) {
+    throw new Error('compose: mismatched lengths');
+  }
+
+  const result: OpComponent[] = [];
+  let ia = 0;
+  let ib = 0;
+
+  const push = (c: OpComponent) => {
+    if (c.type === 'retain' && c.count === 0) return;
+    if (c.type === 'delete' && c.count === 0) return;
+    if (c.type === 'insert' && c.text === '') return;
+    // merge with last
+    if (result.length > 0) {
+      const last = result[result.length - 1];
+      if (last.type === 'retain' && c.type === 'retain') {
+        result[result.length - 1] = { type: 'retain', count: last.count + c.count };
+        return;
+      }
+      if (last.type === 'insert' && c.type === 'insert') {
+        result[result.length - 1] = { type: 'insert', text: last.text + c.text };
+        return;
+      }
+      if (last.type === 'delete' && c.type === 'delete') {
+        result[result.length - 1] = { type: 'delete', count: last.count + c.count };
+        return;
+      }
+    }
+    result.push(c);
+  };
+
+  while (ia < a.length || ib < b.length) {
+    const ca = a[ia];
+    const cb = b[ib];
+
+    // If b has a pure insert, emit it (it doesn't consume from a's output)
+    if (cb && cb.type === 'insert') {
+      push({ type: 'insert', text: cb.text });
+      ib++;
+      continue;
+    }
+
+    // If a has a pure delete, emit it (it doesn't produce output for b to consume)
+    if (ca && ca.type === 'delete') {
+      push({ type: 'delete', count: ca.count });
+      ia++;
+      continue;
+    }
+
+    if (!ca || !cb) {
+      throw new Error('compose: ran out of components');
+    }
+
+    if (ca.type === 'retain' && cb.type === 'retain') {
+      const min = Math.min(ca.count, cb.count);
+      push({ type: 'retain', count: min });
+      a = [...a];
+      b = [...b];
+      if (ca.count > min) a[ia] = { type: 'retain', count: ca.count - min };
+      else ia++;
+      if (cb.count > min) b[ib] = { type: 'retain', count: cb.count - min };
+      else ib++;
+    } else if (ca.type === 'insert' && cb.type === 'retain') {
+      const min = Math.min(ca.text.length, cb.count);
+      push({ type: 'insert', text: ca.text.slice(0, min) });
+      a = [...a];
+      b = [...b];
+      if (ca.text.length > min) a[ia] = { type: 'insert', text: ca.text.slice(min) };
+      else ia++;
+      if (cb.count > min) b[ib] = { type: 'retain', count: cb.count - min };
+      else ib++;
+    } else if (ca.type === 'insert' && cb.type === 'delete') {
+      const min = Math.min(ca.text.length, cb.count);
+      // insert then delete cancel each other
+      a = [...a];
+      b = [...b];
+      if (ca.text.length > min) a[ia] = { type: 'insert', text: ca.text.slice(min) };
+      else ia++;
+      if (cb.count > min) b[ib] = { type: 'delete', count: cb.count - min };
+      else ib++;
+    } else if (ca.type === 'retain' && cb.type === 'delete') {
+      const min = Math.min(ca.count, cb.count);
+      push({ type: 'delete', count: min });
+      a = [...a];
+      b = [...b];
+      if (ca.count > min) a[ia] = { type: 'retain', count: ca.count - min };
+      else ia++;
+      if (cb.count > min) b[ib] = { type: 'delete', count: cb.count - min };
+      else ib++;
+    } else {
+      throw new Error(`compose: unexpected pair ${ca.type} / ${cb.type}`);
+    }
+  }
+
+  return result;
+}
+
+// ---------------------------------------------------------------------------
+// Transform  –  the core of OT
+//
+//   Given two concurrent operations a and b (both based on the same document),
+//   produce a' and b' such that apply(apply(doc,a),b') == apply(apply(doc,b),a')
+// ---------------------------------------------------------------------------
+
+export function transform(
+  a: Operation,
+  b: Operation
+): { aPrime: Operation; bPrime: Operation } {
+  if (inputLength(a) !== inputLength(b)) {
+    throw new Error('transform: operations must have same input length');
+  }
+
+  const aPrime: OpComponent[] = [];
+  const bPrime: OpComponent[] = [];
+
+  // We iterate through both operations simultaneously, consuming matching
+  // input lengths.  We work with mutable copies so we can "shrink" components.
+  const aCopy: OpComponent[] = a.map((c) => ({ ...c }));
+  const bCopy: OpComponent[] = b.map((c) => ({ ...c }));
+
+  let ia = 0;
+  let ib = 0;
+
+  const pushA = (c: OpComponent) => {
+    if (c.type === 'retain' && c.count === 0) return;
+    if (c.type === 'delete' && c.count === 0) return;
+    if (c.type === 'insert' && c.text === '') return;
+    aPrime.push(c);
+  };
+  const pushB = (c: OpComponent) => {
+    if (c.type === 'retain' && c.count === 0) return;
+    if (c.type === 'delete' && c.count === 0) return;
+    if (c.type === 'insert' && c.text === '') return;
+    bPrime.push(c);
+  };
+
+  while (ia < aCopy.length || ib < bCopy.length) {
+    const ca = aCopy[ia];
+    const cb = bCopy[ib];
+
+    // a inserts – this is a local-only addition, b' must retain over it
+    if (ca && ca.type === 'insert') {
+      pushA({ type: 'insert', text: ca.text });
+      pushB({ type: 'retain', count: ca.text.length });
+      ia++;
+      continue;
+    }
+
+    // b inserts
+    if (cb && cb.type === 'insert') {
+      pushB({ type: 'insert', text: cb.text });
+      pushA({ type: 'retain', count: cb.text.length });
+      ib++;
+      continue;
+    }
+
+    if (!ca || !cb) {
+      throw new Error('transform: ran out of components');
+    }
+
+    // Both retain
+    if (ca.type === 'retain' && cb.type === 'retain') {
+      const min = Math.min(ca.count, cb.count);
+      pushA({ type: 'retain', count: min });
+      pushB({ type: 'retain', count: min });
+      if (ca.count > min) aCopy[ia] = { type: 'retain', count: ca.count - min };
+      else ia++;
+      if (cb.count > min) bCopy[ib] = { type: 'retain', count: cb.count - min };
+      else ib++;
+    }
+    // a deletes, b retains
+    else if (ca.type === 'delete' && cb.type === 'retain') {
+      const min = Math.min(ca.count, cb.count);
+      pushA({ type: 'delete', count: min });
+      // b' doesn't need to do anything for deleted chars
+      if (ca.count > min) aCopy[ia] = { type: 'delete', count: ca.count - min };
+      else ia++;
+      if (cb.count > min) bCopy[ib] = { type: 'retain', count: cb.count - min };
+      else ib++;
+    }
+    // a retains, b deletes
+    else if (ca.type === 'retain' && cb.type === 'delete') {
+      const min = Math.min(ca.count, cb.count);
+      pushB({ type: 'delete', count: min });
+      if (ca.count > min) aCopy[ia] = { type: 'retain', count: ca.count - min };
+      else ia++;
+      if (cb.count > min) bCopy[ib] = { type: 'delete', count: cb.count - min };
+      else ib++;
+    }
+    // Both delete same region – they cancel each other
+    else if (ca.type === 'delete' && cb.type === 'delete') {
+      const min = Math.min(ca.count, cb.count);
+      if (ca.count > min) aCopy[ia] = { type: 'delete', count: ca.count - min };
+      else ia++;
+      if (cb.count > min) bCopy[ib] = { type: 'delete', count: cb.count - min };
+      else ib++;
+    }
+  }
+
+  return { aPrime, bPrime };
+}
+
+// ---------------------------------------------------------------------------
+// Validation helpers
+// ---------------------------------------------------------------------------
+
+export function validateOperation(op: unknown): op is Operation {
+  if (!Array.isArray(op)) return false;
+  for (const c of op) {
+    if (typeof c !== 'object' || c === null) return false;
+    const comp = c as Record<string, unknown>;
+    if (comp.type === 'retain') {
+      if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) return false;
+    } else if (comp.type === 'insert') {
+      if (typeof comp.text !== 'string') return false;
+    } else if (comp.type === 'delete') {
+      if (typeof comp.count !== 'number' || comp.count < 0 || !Number.isInteger(comp.count)) return false;
+    } else {
+      return false;
+    }
+  }
+  return true;
+}
