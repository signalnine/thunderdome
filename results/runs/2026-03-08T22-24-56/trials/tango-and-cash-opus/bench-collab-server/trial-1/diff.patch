ng, unknown>> {\n  return new Promise((resolve) => {\n    const handler = (data: WebSocket.RawData) => {\n      const msg = JSON.parse(data.toString());\n      if (msg.type === type) {\n        ws.off('message', handler);\n        resolve(msg);\n      }\n    };\n    ws.on('message', handler);\n  });\n}\n\nasync function createDocViaRest(baseUrl: string, title: string, content = ''): Promise<{ id: string; title: string; content: string }> {\n  const res = await fetch(`${baseUrl}/api/documents`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ title, content }),\n  });\n  return res.json() as Promise<{ id: string; title: string; content: string }>;\n}\n\ndescribe('REST API', () => {\n  let instance: AppInstance;\n  let port: number;\n  let baseUrl: string;\n\n  beforeAll(async () => {\n    instance = createApp();\n    port = await instance.start(0);\n    baseUrl = `http://localhost:${port}`;\n  });\n\n  afterAll(async () => {\n    await instance.stop();\n  });\n\n  it('should create a document', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Test Doc', content: 'hello' }),\n    });\n    expect(res.status).toBe(201);\n    const doc = await res.json() as Record<string, unknown>;\n    expect(doc.title).toBe('Test Doc');\n    expect(doc.content).toBe('hello');\n    expect(doc.id).toBeDefined();\n  });\n\n  it('should list documents', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`);\n    expect(res.status).toBe(200);\n    const docs = await res.json() as unknown[];\n    expect(Array.isArray(docs)).toBe(true);\n    expect(docs.length).toBeGreaterThan(0);\n  });\n\n  it('should get a specific document', async () => {\n    const created = await createDocViaRest(baseUrl, 'Get Me');\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(res.status).toBe(200);\n    const doc = await res.json() as Record<string, unknown>;\n    expect(doc.title).toBe('Get Me');\n  });\n\n  it('should update a document', async () => {\n    const created = await createDocViaRest(baseUrl, 'Original');\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'PUT',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ title: 'Updated', content: 'new content' }),\n    });\n    expect(res.status).toBe(200);\n    const doc = await res.json() as Record<string, unknown>;\n    expect(doc.title).toBe('Updated');\n    expect(doc.content).toBe('new content');\n  });\n\n  it('should delete a document', async () => {\n    const created = await createDocViaRest(baseUrl, 'Delete Me');\n    const delRes = await fetch(`${baseUrl}/api/documents/${created.id}`, {\n      method: 'DELETE',\n    });\n    expect(delRes.status).toBe(204);\n\n    const getRes = await fetch(`${baseUrl}/api/documents/${created.id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it('should return 404 for non-existent document', async () => {\n    const res = await fetch(`${baseUrl}/api/documents/nonexistent`);\n    expect(res.status).toBe(404);\n  });\n\n  it('should return 400 when creating without title', async () => {\n    const res = await fetch(`${baseUrl}/api/documents`, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  it('should get version history', async () => {\n    const created = await createDocViaRest(baseUrl, 'Versioned', 'v1');\n    const res = await fetch(`${baseUrl}/api/documents/${created.id}/versions`);\n    expect(res.status).toBe(200);\n    const versions = await res.json() as { version: number; content: string }[];\n    expect(Array.isArray(versions)).toBe(true);\n    expect(versions.length).toBe(1);\n    expect(versions[0].version).toBe(1);\n    expect(versions[0].content).toBe('v1');\n  });\n});\n\ndescribe('WebSocket collaboration', () => {\n  it('should send sync message on connection', async () => {\n    const instance = createApp();\n    const port = await instance.start(0);\n    const baseUrl = `http://localhost:${port}`;\n\n    try {\n      const doc = await createDocViaRest(baseUrl, 'WS Test', 'hello');\n      const ws = await connectWs(port, doc.id);\n      const msg = await nextMessage(ws);\n\n      expect(msg.type).toBe('sync');\n      expect(msg.content).toBe('hello');\n      expect(msg.version).toBe(1);\n\n      ws.close();\n    } finally {\n      await instance.stop();\n    }\n  });\n\n  it('should broadcast operations to other clients', async () => {\n    const instance = createApp();\n    const port = await instance.start(0);\n    const baseUrl = `http://localhost:${port}`;\n\n    try {\n      const doc = await createDocViaRest(baseUrl, 'Broadcast', 'abc');\n\n      const ws1 = await connectWs(port, doc.id);\n      const ws2 = await connectWs(port, doc.id);\n\n      await nextMessage(ws1);\n      await nextMessage(ws2);\n\n      const opPromise = waitForMessageType(ws2, 'operation');\n      ws1.send(\n        JSON.stringify({\n          type: 'operation',\n          version: 1,\n          operation: [\n            { type: 'retain', count: 3 },\n            { type: 'insert', text: 'def' },\n          ],\n        })\n      );\n\n      const ack = await waitForMessageType(ws1, 'ack');\n      expect(ack.version).toBe(2);\n\n      const broadcast = await opPromise;\n      expect(broadcast.type).toBe('operation');\n      expect(broadcast.version).toBe(2);\n\n      ws1.close();\n      ws2.close();\n    } finally {\n      await instance.stop();\n    }\n  });\n\n  it('should handle concurrent edits and converge', async () => {\n    const instance = createApp();\n    const port = await instance.start(0);\n    const baseUrl = `http://localhost:${port}`;\n\n    try {\n      const doc = await createDocViaRest(baseUrl, 'Concurrent', 'abc');\n\n      const ws1 = await connectWs(port, doc.id);\n      const ws2 = await connectWs(port, doc.id);\n\n      await nextMessage(ws1);\n      await nextMessage(ws2);\n\n      // Both clients send operations based on version 1\n      ws1.send(\n        JSON.stringify({\n          type: 'operation',\n          version: 1,\n          operation: [\n            { type: 'insert', text: 'X' },\n            { type: 'retain', count: 3 },\n          ],\n        })\n      );\n\n      await waitForMessageType(ws1, 'ack');\n\n      ws2.send(\n        JSON.stringify({\n          type: 'operation',\n          version: 1,\n          operation: [\n            { type: 'retain', count: 3 },\n            { type: 'insert', text: 'Y' },\n          ],\n        })\n      );\n\n      await waitForMessageType(ws2, 'ack');\n\n      const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n      const result = await getRes.json() as { content: string };\n\n      expect(result.content).toContain('X');\n      expect(result.content).toContain('Y');\n      expect(result.content).toContain('abc');\n      expect(result.content.length).toBe(5);\n\n      ws1.close();\n      ws2.close();\n    } finally {\n      await instance.stop();\n    }\n  });\n\n  it('should reject malformed operations', async () => {\n    const instance = createApp();\n    const port = await instance.start(0);\n    const baseUrl = `http://localhost:${port}`;\n\n    try {\n      const doc = await createDocViaRest(baseUrl, 'Malformed', 'abc');\n      const ws = await connectWs(port, doc.id);\n      await nextMessage(ws);\n\n      ws.send(\n        JSON.stringify({\n          type: 'operation',\n          version: 1,\n          operation: [{ type: 'banana' }],\n        })\n      );\n\n      const err = await nextMessage(ws);\n      expect(err.type).toBe('error');\n\n      ws.close();\n    } finally {\n      await instance.stop();\n    }\n  });\n\n  it('should send error for invalid path', async () => {\n    const instance = createApp();\n    const port = await instance.start(0);\n\n    try {\n      const ws = new WebSocket(`ws://localhost:${port}/invalid`);\n      const msg: Record<string, unknown> = await new Promise((resolve) => {\n        ws.on('message', (data) => {\n          resolve(JSON.parse(data.toString()));\n        });\n      });\n      expect(msg.type).toBe('error');\n    } finally {\n      await instance.stop();\n    }\n  });\n\n  it('should send error for non-existent document', async () => {\n    const instance = createApp();\n    const port = await instance.start(0);\n\n    try {\n      const ws = await connectWs(port, 'nonexistent-id');\n      const msg = await nextMessage(ws);\n      expect(msg.type).toBe('error');\n      ws.close();\n    } finally {\n      await instance.stop();\n    }\n  });\n});\n\ndescribe('Persistence', () => {\n  it('should persist documents across server restarts', async () => {\n    const tmpDb = '/tmp/test-persist-' + Date.now() + '.db';\n\n    const instance1 = createApp(tmpDb);\n    const port1 = await instance1.start(0);\n    const base1 = `http://localhost:${port1}`;\n\n    const doc = await createDocViaRest(base1, 'Persistent', 'survives restart');\n    await instance1.stop();\n\n    const instance2 = createApp(tmpDb);\n    const port2 = await instance2.start(0);\n    const base2 = `http://localhost:${port2}`;\n\n    const getRes = await fetch(`${base2}/api/documents/${doc.id}`);\n    expect(getRes.status).toBe(200);\n    const retrieved = await getRes.json() as { title: string; content: string };\n    expect(retrieved.title).toBe('Persistent');\n    expect(retrieved.content).toBe('survives restart');\n\n    await instance2.stop();\n  });\n});\n\ndescribe('10 concurrent clients', () => {\n  it('should handle 10 concurrent clients without corruption', async () => {\n    const instance = createApp();\n    const port = await instance.start(0);\n    const baseUrl = `http://localhost:${port}`;\n\n    try {\n      const doc = await createDocViaRest(baseUrl, 'Stress Test', '');\n\n      const clients: WebSocket[] = [];\n      for (let i = 0; i < 10; i++) {\n        const ws = await connectWs(port, doc.id);\n        await nextMessage(ws); // sync\n        clients.push(ws);\n      }\n\n      // Each client sends an insert sequentially, each based on version 1\n      // The server will transform them\n      for (let i = 0; i < 10; i++) {\n        const ws = clients[i];\n        ws.send(\n          JSON.stringify({\n            type: 'operation',\n            version: 1,\n            operation: [{ type: 'insert', text: String.fromCharCode(65 + i) }],\n          })\n        );\n        await waitForMessageType(ws, 'ack');\n      }\n\n      await new Promise((resolve) => setTimeout(resolve, 200));\n\n      const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n      const result = await getRes.json() as { content: string };\n\n      for (let i = 0; i < 10; i++) {\n        expect(result.content).toContain(String.fromCharCode(65 + i));\n      }\n      expect(result.content.length).toBe(10);\n\n      for (const ws of clients) {\n        ws.close();\n      }\n    } finally {\n      await instance.stop();\n    }\n  });\n\n  it('should handle 10 clients sending simultaneously based on same version', async () => {\n    const instance = createApp();\n    const port = await instance.start(0);\n    const baseUrl = `http://localhost:${port}`;\n\n    try {\n      const doc = await createDocViaRest(baseUrl, 'Concurrent Stress', '');\n\n      const clients: WebSocket[] = [];\n      for (let i = 0; i < 10; i++) {\n        const ws = await connectWs(port, doc.id);\n        await nextMessage(ws); // sync\n        clients.push(ws);\n      }\n\n      // All send at once based on version 1\n      const ackPromises = clients.map((ws) => waitForMessageType(ws, 'ack'));\n\n      for (let i = 0; i < 10; i++) {\n        clients[i].send(\n          JSON.stringify({\n            type: 'operation',\n            version: 1,\n            operation: [{ type: 'insert', text: String.fromCharCode(65 + i) }],\n          })\n        );\n      }\n\n      await Promise.all(ackPromises);\n      await new Promise((resolve) => setTimeout(resolve, 200));\n\n      const getRes = await fetch(`${baseUrl}/api/documents/${doc.id}`);\n      const result = await getRes.json() as { content: string };\n\n      for (let i = 0; i < 10; i++) {\n        expect(result.content).toContain(String.fromCharCode(65 + i));\n      }\n      expect(result.content.length).toBe(10);\n\n      for (const ws of clients) {\n        ws.close();\n      }\n    } finally {\n      await instance.stop();\n    }\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":4,"lines":["-import { describe, it, expect, beforeAll, afterAll, beforeEach, afterEach } from 'vitest';","+import { describe, it, expect, beforeAll, afterAll } from 'vitest';"," import { createApp, type AppInstance } from '../server.js';"," import WebSocket from 'ws';"," "]},{"oldStart":34,"oldLines":6,"newStart":34,"newLines":15,"lines":["   });"," }"," ","+async function createDocViaRest(baseUrl: string, title: string, content = ''): Promise<{ id: string; title: string; content: string }> {","+  const res = await fetch(`${baseUrl}/api/documents`, {","+    method: 'POST',","+    headers: { 'Content-Type': 'application/json' },","+    body: JSON.stringify({ title, content }),","+  });","+  return res.json() as Promise<{ id: string; title: string; content: string }>;","+}","+"," describe('REST API', () => {","   let instance: AppInstance;","   let port: number;"]},{"oldStart":56,"oldLines":7,"newStart":65,"newLines":7,"lines":["       body: JSON.stringify({ title: 'Test Doc', content: 'hello' }),","     });","     expect(res.status).toBe(201);","-    const doc = await res.json();","+    const doc = await res.json() as Record<string, unknown>;","     expect(doc.title).toBe('Test Doc');","     expect(doc.content).t