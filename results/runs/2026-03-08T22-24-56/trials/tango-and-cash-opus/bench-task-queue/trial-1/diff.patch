+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01R3yGAFTkHQT1KFkRfRVUhn","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015ktVpZzjvRB5D6HQLpU4ye","name":"Write","input":{"file_path":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './index.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ==================== Phase 1: Basic FIFO Queue ====================\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object with id, status, and createdAt', () => {\n      const task = tq.add({ payload: { message: 'hello' } });\n      expect(task.id).toBeDefined();\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n      expect(task.payload).toEqual({ message: 'hello' });\n    });\n\n    it('should return tasks in FIFO order', () => {\n      tq.add({ payload: 'first' });\n      tq.add({ payload: 'second' });\n      tq.add({ payload: 'third' });\n\n      expect(tq.next()?.payload).toBe('first');\n      expect(tq.next()?.payload).toBe('second');\n      expect(tq.next()?.payload).toBe('third');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should transition task to processing when retrieved', () => {\n      const task = tq.add({ payload: 'test' });\n      const retrieved = tq.next();\n      expect(retrieved?.id).toBe(task.id);\n      expect(retrieved?.status).toBe('processing');\n    });\n\n    it('should not return processing tasks', () => {\n      tq.add({ payload: 'test' });\n      tq.next(); // now processing\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should track queue size', () => {\n      expect(tq.size()).toBe(0);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      expect(tq.size()).toBe(2);\n      tq.next();\n      expect(tq.size()).toBe(1);\n    });\n\n    it('should retrieve a task by id', () => {\n      const task = tq.add({ payload: 'hello' });\n      expect(tq.getTask(task.id)?.payload).toBe('hello');\n    });\n  });\n\n  // ==================== Phase 2: Named Queues ====================\n  describe('Phase 2: Named Queues', () => {\n    it('should support named queues', () => {\n      tq.add({ payload: 'a', queue: 'queue-a' });\n      tq.add({ payload: 'b', queue: 'queue-b' });\n\n      expect(tq.next('queue-a')?.payload).toBe('a');\n      expect(tq.next('queue-b')?.payload).toBe('b');\n    });\n\n    it('should use default queue when no name specified', () => {\n      tq.add({ payload: 'default-task' });\n      expect(tq.next()?.payload).toBe('default-task');\n    });\n\n    it('should return null from non-existent queue', () => {\n      expect(tq.next('non-existent')).toBeNull();\n    });\n\n    it('should list all queue names', () => {\n      tq.add({ payload: 'a', queue: 'alpha' });\n      tq.add({ payload: 'b', queue: 'beta' });\n      const names = tq.listQueues();\n      expect(names).toContain('alpha');\n      expect(names).toContain('beta');\n    });\n\n    it('queues operate independently', () => {\n      tq.add({ payload: 'a', queue: 'q1' });\n      tq.add({ payload: 'b', queue: 'q2' });\n      expect(tq.size('q1')).toBe(1);\n      expect(tq.size('q2')).toBe(1);\n      tq.next('q1');\n      expect(tq.size('q1')).toBe(0);\n      expect(tq.size('q2')).toBe(1);\n    });\n  });\n\n  // ==================== Phase 3: Priority ====================\n  describe('Phase 3: Priority', () => {\n    it('should return higher priority tasks first', () => {\n      tq.add({ payload: 'low', priority: 10 });\n      tq.add({ payload: 'high', priority: 1 });\n      tq.add({ payload: 'medium', priority: 5 });\n\n      expect(tq.next()?.payload).toBe('high');\n      expect(tq.next()?.payload).toBe('medium');\n      expect(tq.next()?.payload).toBe('low');\n    });\n\n    it('should default to priority 5', () => {\n      const task = tq.add({ payload: 'test' });\n      expect(task.priority).toBe(5);\n    });\n\n    it('should reject invalid priorities', () => {\n      expect(() => tq.add({ payload: 'test', priority: 0 })).toThrow();\n      expect(() => tq.add({ payload: 'test', priority: 11 })).toThrow();\n      expect(() => tq.add({ payload: 'test', priority: 1.5 })).toThrow();\n    });\n\n    it('should use FIFO for same priority', () => {\n      tq.add({ payload: 'first', priority: 5 });\n      tq.add({ payload: 'second', priority: 5 });\n      expect(tq.next()?.payload).toBe('first');\n      expect(tq.next()?.payload).toBe('second');\n    });\n\n    it('should expose priority on task object', () => {\n      const task = tq.add({ payload: 'test', priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n  });\n\n  // ==================== Phase 4: Delayed Tasks ====================\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their availability time', () => {\n      tq.add({ payload: 'delayed', delay: 10000 });\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should return delayed tasks after their availability time', () => {\n      vi.useFakeTimers();\n      tq.add({ payload: 'delayed', delay: 1000 });\n      expect(tq.next()).toBeNull();\n      vi.advanceTimersByTime(1001);\n      expect(tq.next()?.payload).toBe('delayed');\n      vi.useRealTimers();\n    });\n\n    it('should accept availableAt date', () => {\n      const futureDate = new Date(Date.now() + 100000);\n      const task = tq.add({ payload: 'scheduled', availableAt: futureDate });\n      expect(task.availableAt).toEqual(futureDate);\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should prefer non-delayed tasks', () => {\n      vi.useFakeTimers();\n      tq.add({ payload: 'delayed', delay: 500 });\n      tq.add({ payload: 'immediate' });\n      expect(tq.next()?.payload).toBe('immediate');\n      vi.useRealTimers();\n    });\n\n    it('delayed tasks work with named queues', () => {\n      tq.add({ payload: 'delayed', delay: 10000, queue: 'myq' });\n      expect(tq.next('myq')).toBeNull();\n    });\n  });\n\n  // ==================== Phase 5: Retry with Backoff ====================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      tq.complete(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should retry a failed task with delay', () => {\n      vi.useFakeTimers();\n      const task = tq.add({ payload: 'test', maxRetries: 3, baseDelay: 1000 });\n      tq.next();\n      tq.fail(task.id, 'some error');\n\n      expect(task.status).toBe('pending');\n      expect(task.attempts).toBe(1);\n\n      // Not available yet due to backoff\n      expect(tq.next()).toBeNull();\n\n      // Advance past backoff: 1000 * 2^0 = 1000\n      vi.advanceTimersByTime(1001);\n      const retried = tq.next();\n      expect(retried?.id).toBe(task.id);\n      expect(retried?.attempts).toBe(2);\n      vi.useRealTimers();\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1 });\n      tq.next();\n      expect(task.attempts).toBe(1);\n    });\n\n    it('should mark as failed when retries exhausted', () => {\n      vi.useFakeTimers();\n      const task = tq.add({ payload: 'test', maxRetries: 2, baseDelay: 100 });\n\n      // Attempt 1\n      tq.next();\n      tq.fail(task.id, 'err');\n      vi.advanceTimersByTime(200);\n\n      // Attempt 2 (final)\n      tq.next();\n      tq.fail(task.id, 'err2');\n\n      expect(task.status).toBe('failed');\n      vi.useRealTimers();\n    });\n\n    it('should use exponential backoff', () => {\n      vi.useFakeTimers();\n      const task = tq.add({ payload: 'test', maxRetries: 3, baseDelay: 100 });\n\n      // Attempt 1\n      tq.next();\n      tq.fail(task.id, 'err');\n      // Backoff: 100 * 2^0 = 100ms\n      vi.advanceTimersByTime(99);\n      expect(tq.next()).toBeNull();\n      vi.advanceTimersByTime(2);\n      expect(tq.next()?.id).toBe(task.id);\n\n      // Attempt 2\n      tq.fail(task.id, 'err');\n      // Backoff: 100 * 2^1 = 200ms\n      vi.advanceTimersByTime(199);\n      expect(tq.next()).toBeNull();\n      vi.advanceTimersByTime(2);\n      expect(tq.next()?.id).toBe(task.id);\n\n      vi.useRealTimers();\n    });\n\n    it('retried tasks keep original queue and priority', () => {\n      vi.useFakeTimers();\n      const task = tq.add({ payload: 'test', queue: 'myq', priority: 2, maxRetries: 3, baseDelay: 100 });\n      tq.next('myq');\n      tq.fail(task.id, 'err');\n      vi.advanceTimersByTime(200);\n      const retried = tq.next('myq');\n      expect(retried?.queue).toBe('myq');\n      expect(retried?.priority).toBe(2);\n      vi.useRealTimers();\n    });\n\n    it('should error when completing non-processing task', () => {\n      const task = tq.add({ payload: 'test' });\n      expect(() => tq.complete(task.id)).toThrow();\n    });\n\n    it('should error for non-existent task', () => {\n      expect(() => tq.complete('nonexistent')).toThrow();\n    });\n  });\n\n  // ==================== Phase 6: Dead Letter Queue ====================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move exhausted tasks to DLQ', () => {\n      vi.useFakeTimers();\n      const task = tq.add({ payload: 'test', maxRetries: 1, baseDelay: 100 });\n      tq.next();\n      tq.fail(task.id, 'err');\n      expect(task.status).toBe('failed');\n      const dlq = tq.getDeadLetterQueue();\n      expect(dlq.length).toBe(1);\n      expect(dlq[0].id).toBe(task.id);\n      vi.useRealTimers();\n    });\n\n    it('should retain error information', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1, baseDelay: 100 });\n      tq.next();\n      tq.fail(task.id, 'final error');\n      const dlq = tq.getDeadLetterQueue();\n      expect(dlq[0].error).toBe('final error');\n      expect(dlq[0].failCount).toBe(1);\n    });\n\n    it('should redrive a task from DLQ', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1, baseDelay: 100 });\n      tq.next();\n      tq.fail(task.id, 'err');\n      expect(tq.getDeadLetterQueue().length).toBe(1);\n\n      const redriven = tq.redriveTask(task.id);\n      expect(redriven.status).toBe('pending');\n      expect(redriven.attempts).toBe(0);\n      expect(tq.getDeadLetterQueue().length).toBe(0);\n      expect(tq.size()).toBe(1);\n    });\n\n    it('should clear the DLQ', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1, baseDelay: 100 });\n      tq.next();\n      tq.fail(task.id, 'err');\n      expect(tq.getDeadLetterQueue().length).toBe(1);\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterQueue().length).toBe(0);\n    });\n\n    it('each named queue has its own DLQ', () => {\n      const t1 = tq.add({ payload: 'a', queue: 'q1', maxRetries: 1 });\n      const t2 = tq.add({ payload: 'b', queue: 'q2', maxRetries: 1 });\n      tq.next('q1');\n      tq.fail(t1.id, 'err');\n      tq.next('q2');\n      tq.fail(t2.id, 'err');\n\n      expect(tq.getDeadLetterQueue('q1').length).toBe(1);\n      expect(tq.getDeadLetterQueue('q2').length).toBe(1);\n      tq.clearDeadLetterQueue('q1');\n      expect(tq.getDeadLetterQueue('q1').length).toBe(0);\n      expect(tq.getDeadLetterQueue('q2').length).toBe(1);\n    });\n  });\n\n  // ==================== Phase 7: Task Dependencies ====================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.add({ payload: 'dependency' });\n      tq.add({ payload: 'dependent', dependencies: [dep.id] });\n\n      // The dependent should not be returned\n      const next = tq.next();\n      expect(next?.payload).toBe('dependency');\n      const next2 = tq.next();\n      expect(next2).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.add({ payload: 'dependency' });\n      const dependent = tq.add({ payload: 'dependent', dependencies: [dep.id] });\n\n      tq.next(); // get the dependency\n      tq.complete(dep.id);\n\n      const next = tq.next();\n      expect(next?.id).toBe(dependent.id);\n    });\n\n    it('should reject non-existent dependencies', () => {\n      expect(() => tq.add({ payload: 'test', dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should detect circular dependencies', () => {\n      const a = tq.add({ payload: 'a' });\n      const b = tq.add({ payload: 'b', dependencies: [a.id] });\n      expect(() => tq.add({ payload: 'c', dependencies: [b.id] })).not.toThrow();\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = tq.add({ payload: 'dep1' });\n      const dep2 = tq.add({ payload: 'dep2' });\n      const task = tq.add({ payload: 'task', dependencies: [dep1.id, dep2.id] });\n\n      tq.next(); // dep1\n      tq.complete(dep1.id);\n\n      const status = tq.getDependencyStatus(task.id);\n      expect(status.resolved).toContain(dep1.id);\n      expect(status.unresolved).toContain(dep2.id);\n    });\n\n    it('failed dependency does not fail dependents', () => {\n      const dep = tq.add({ payload: 'dep', maxRetries: 1 });\n      const dependent = tq.add({ payload: 'dependent', dependencies: [dep.id] });\n\n      tq.next();\n      tq.fail(dep.id, 'err');\n\n      // Dependent should stay blocked (not failed)\n      expect(dependent.status).toBe('pending');\n    });\n  });\n\n  // ==================== Phase 8: Concurrency Control ====================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      tq.setConcurrency('default', 1);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n\n      expect(tq.next()?.payload).toBe('a');\n      expect(tq.next()).toBeNull(); // limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      tq.setConcurrency('default', 1);\n      const task = tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n\n      tq.next();\n      tq.complete(task.id); // frees the slot\n      expect(tq.next()?.payload).toBe('b');\n    });\n\n    it('should free slot when task fails', () => {\n      vi.useFakeTimers();\n      tq.setConcurrency('default', 1);\n      const task = tq.add({ payload: 'a', maxRetries: 1, baseDelay: 100 });\n      tq.add({ payload: 'b' });\n\n      tq.next();\n      tq.fail(task.id, 'err'); // exhausts retries, frees slot\n      expect(tq.next()?.payload).toBe('b');\n      vi.useRealTimers();\n    });\n\n    it('should default to no limit', () => {\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      tq.add({ payload: 'c' });\n\n      expect(tq.next()).not.toBeNull();\n      expect(tq.next()).not.toBeNull();\n      expect(tq.next()).not.toBeNull();\n    });\n\n    it('should query concurrency limit and active count', () => {\n      tq.setConcurrency('default', 3);\n      expect(tq.getConcurrency('default')).toBe(3);\n      expect(tq.getActiveCount()).toBe(0);\n\n      tq.add({ payload: 'a' });\n      tq.next();\n      expect(tq.getActiveCount()).toBe(1);\n    });\n\n    it('respects priority with concurrency', () => {\n      tq.setConcurrency('default', 1);\n      tq.add({ payload: 'low', priority: 10 });\n      tq.add({ payload: 'high', priority: 1 });\n\n      expect(tq.next()?.payload).toBe('high');\n    });\n  });\n\n  // ==================== Phase 9: Progress & Cancellation ====================\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report and query progress', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      tq.reportProgress(task.id, 50, 'halfway');\n      expect(tq.getTask(task.id)?.progress).toBe(50);\n      expect(tq.getTask(task.id)?.progressMessage).toBe('halfway');\n    });\n\n    it('should subscribe and receive progress updates', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      tq.reportProgress(task.id, 25, 'quarter');\n      tq.reportProgress(task.id, 75, 'three-quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n      expect(updates[1]).toEqual({ progress: 75, message: 'three-quarters' });\n    });\n\n    it('should unsubscribe from progress updates', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      const updates: number[] = [];\n      const unsubscribe = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 25);\n      unsubscribe();\n      tq.reportProgress(task.id, 75);\n\n      expect(updates).toHaveLength(1);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n    });\n\n    it('cancelled tasks are never retried', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 3 });\n      tq.next();\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      // Shouldn't be able to fail it into a retry\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('cannot cancel a completed task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      tq.complete(task.id);\n      expect(() => tq.cancel(task.id)).toThrow();\n    });\n  });\n\n  // ==================== Phase 10: Recurring Tasks ====================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create and list schedules', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'check' });\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cron).toBe('*/5 * * * *');\n      expect(tq.listSchedules()).toHaveLength(1);\n    });\n\n    it('should remove a schedule', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'check' });\n      tq.removeSchedule(schedule.id);\n      expect(tq.listSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick when schedule is due', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'recurring' });\n\n      // Tick at minute 0 (divisible by 5)\n      const now = new Date(2024, 0, 1, 12, 0, 0);\n      const tasks = tq.tick(now);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'recurring' });\n    });\n\n    it('should not enqueue tasks when not due', () => {\n      tq.addSchedule('0 0 * * *', 'default', { type: 'daily' });\n\n      // Tick at 12:30 - should not trigger \"0 0 * * *\" (midnight)\n      const now = new Date(2024, 0, 1, 12, 30, 0);\n      const tasks = tq.tick(now);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not double-enqueue within same minute', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'recurring' });\n      const now = new Date(2024, 0, 1, 12, 0, 0);\n      tq.tick(now);\n      const tasks2 = tq.tick(now);\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should validate cron expressions', () => {\n      expect(() => tq.addSchedule('invalid', 'default', {})).toThrow();\n      expect(() => tq.addSchedule('* *', 'default', {})).toThrow();\n    });\n\n    it('removing schedule stops future occurrences', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'recurring' });\n      tq.removeSchedule(schedule.id);\n      const tasks = tq.tick(new Date(2024, 0, 1, 12, 0, 0));\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('every hour cron works', () => {\n      tq.addSchedule('0 * * * *', 'default', { type: 'hourly' });\n      const atHour = new Date(2024, 0, 1, 14, 0, 0);\n      const tasks = tq.tick(atHour);\n      expect(tasks).toHaveLength(1);\n\n      const notAtHour = new Date(2024, 0, 1, 14, 30, 0);\n      const tasks2 = tq.tick(notAtHour);\n      expect(tasks2).toHaveLength(0);\n    });\n  });\n\n  // ==================== Phase 11: Middleware ====================\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware in order', async () => {\n      const order: number[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push(1);\n        await next();\n      });\n      tq.use('default', async (_task, next) => {\n        order.push(2);\n        await next();\n      });\n      tq.setHandler('default', async () => {\n        order.push(3);\n      });\n\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      await tq.process(task.id);\n\n      expect(order).toEqual([1, 2, 3]);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      let handlerCalled = false;\n\n      tq.use('default', async () => {\n        // Don't call next\n      });\n      tq.setHandler('default', async () => {\n        handlerCalled = true;\n      });\n\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      await tq.process(task.id);\n\n      expect(handlerCalled).toBe(false);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      tq.use('default', async (task, next) => {\n        (task.payload as Record<string, unknown>).modified = true;\n        await next();\n      });\n\n      let receivedPayload: unknown;\n      tq.setHandler('default', async (task) => {\n        receivedPayload = task.payload;\n      });\n\n      const task = tq.add({ payload: { original: true } });\n      tq.next();\n      await tq.process(task.id);\n\n      expect((receivedPayload as Record<string, unknown>).modified).toBe(true);\n    });\n\n    it('should fail task if middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = tq.add({ payload: 'test', maxRetries: 1 });\n      tq.next();\n\n      await expect(tq.process(task.id)).rejects.toThrow('middleware error');\n      expect(task.status).toBe('failed');\n    });\n\n    it('each queue has independent middleware', async () => {\n      const q1Calls: string[] = [];\n      const q2Calls: string[] = [];\n\n      tq.use('q1', async (_task, next) => {\n        q1Calls.push('mw');\n        await next();\n      });\n      tq.use('q2', async (_task, next) => {\n        q2Calls.push('mw');\n        await next();\n      });\n\n      const t1 = tq.add({ payload: 'a', queue: 'q1' });\n      tq.next('q1');\n      await tq.process(t1.id);\n\n      expect(q1Calls).toHaveLength(1);\n      expect(q2Calls).toHaveLength(0);\n    });\n  });\n\n  // ==================== Phase 12: Graceful Shutdown ====================\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.add({ payload: 'test' })).toThrow();\n    });\n\n    it('should complete immediately with no processing tasks', async () => {\n      const result = await tq.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks to complete', async () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      // Complete it asynchronously\n      setTimeout(() => tq.complete(task.id), 50);\n\n      const result = await tq.shutdown(5000);\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force-cancel on timeout', async () => {\n      tq.add({ payload: 'test' });\n      tq.next(); // Start processing but never complete\n\n      const result = await tq.shutdown(100);\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should be idempotent', async () => {\n      const result1 = await tq.shutdown();\n      const result2 = await tq.shutdown();\n      expect(result1).toEqual(result2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let callbackRan = false;\n      tq.onShutdown(() => {\n        callbackRan = true;\n      });\n      await tq.shutdown();\n      expect(callbackRan).toBe(true);\n    });\n\n    it('should produce shutdown summary', async () => {\n      const result = await tq.shutdown();\n      expect(result).toHaveProperty('completed');\n      expect(result).toHaveProperty('forceCancelled');\n      expect(result).toHaveProperty('durationMs');\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":261,"cache_read_input_tokens":31693,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":261},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"71ad3c1f-e722-4d18-965f-74ec38d2a140","uuid":"49b0a3c3-5055-4acc-98fa-3f05b081ae13"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015ktVpZzjvRB5D6HQLpU4ye","type":"tool_result","content":"File created successfully at: /workspace/src/task-queue.test.ts"}]},"parent_tool_use_id":null,"session_id":"71ad3c1f-e722-4d18-965f-74ec38d2a140","uuid":"c205d6a2-ce83-4a84-8952-79dad7291f0b","tool_use_result":{"type":"create","filePath":"/workspace/src/task-queue.test.ts","content":"import { describe, it, expect, vi, beforeEach } from 'vitest';\nimport { TaskQueue } from './index.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ==================== Phase 1: Basic FIFO Queue ====================\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object with id, status, and createdAt', () => {\n      const task = tq.add({ payload: { message: 'hello' } });\n      expect(task.id).toBeDefined();\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n      expect(task.payload).toEqual({ message: 'hello' });\n    });\n\n    it('should return tasks in FIFO order', () => {\n      tq.add({ payload: 'first' });\n      tq.add({ payload: 'second' });\n      tq.add({ payload: 'third' });\n\n      expect(tq.next()?.payload).toBe('first');\n      expect(tq.next()?.payload).toBe('second');\n      expect(tq.next()?.payload).toBe('third');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should transition task to processing when retrieved', () => {\n      const task = tq.add({ payload: 'test' });\n      const retrieved = tq.next();\n      expect(retrieved?.id).toBe(task.id);\n      expect(retrieved?.status).toBe('processing');\n    });\n\n    it('should not return processing tasks', () => {\n      tq.add({ payload: 'test' });\n      tq.next(); // now processing\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should track queue size', () => {\n      expect(tq.size()).toBe(0);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      expect(tq.size()).toBe(2);\n      tq.next();\n      expect(tq.size()).toBe(1);\n    });\n\n    it('should retrieve a task by id', () => {\n      const task = tq.add({ payload: 'hello' });\n      expect(tq.getTask(task.id)?.payload).toBe('hello');\n    });\n  });\n\n  // ==================== Phase 2: Named Queues ====================\n  describe('Phase 2: Named Queues', () => {\n    it('should support named queues', () => {\n      tq.add({ payload: 'a', queue: 'queue-a' });\n      tq.add({ payload: 'b', queue: 'queue-b' });\n\n      expect(tq.next('queue-a')?.payload).toBe('a');\n      expect(tq.next('queue-b')?.payload).toBe('b');\n    });\n\n    it('should use default queue when no name specified', () => {\n      tq.add({ payload: 'default-task' });\n      expect(tq.next()?.payload).toBe('default-task');\n    });\n\n    it('should return null from non-existent queue', () => {\n      expect(tq.next('non-existent')).toBeNull();\n    });\n\n    it('should list all queue names', () => {\n      tq.add({ payload: 'a', queue: 'alpha' });\n      tq.add({ payload: 'b', queue: 'beta' });\n      const names = tq.listQueues();\n      expect(names).toContain('alpha');\n      expect(names).toContain('beta');\n    });\n\n    it('queues operate independently', () => {\n      tq.add({ payload: 'a', queue: 'q1' });\n      tq.add({ payload: 'b', queue: 'q2' });\n      expect(tq.size('q1')).toBe(1);\n      expect(tq.size('q2')).toBe(1);\n      tq.next('q1');\n      expect(tq.size('q1')).toBe(0);\n      expect(tq.size('q2')).toBe(1);\n    });\n  });\n\n  // ==================== Phase 3: Priority ====================\n  describe('Phase 3: Priority', () => {\n    it('should return higher priority tasks first', () => {\n      tq.add({ payload: 'low', priority: 10 });\n      tq.add({ payload: 'high', priority: 1 });\n      tq.add({ payload: 'medium', priority: 5 });\n\n      expect(tq.next()?.payload).toBe('high');\n      expect(tq.next()?.payload).toBe('medium');\n      expect(tq.next()?.payload).toBe('low');\n    });\n\n    it('should default to priority 5', () => {\n      const task = tq.add({ payload: 'test' });\n      expect(task.priority).toBe(5);\n    });\n\n    it('should reject invalid priorities', () => {\n      expect(() => tq.add({ payload: 'test', priority: 0 })).toThrow();\n      expect(() => tq.add({ payload: 'test', priority: 11 })).toThrow();\n      expect(() => tq.add({ payload: 'test', priority: 1.5 })).toThrow();\n    });\n\n    it('should use FIFO for same priority', () => {\n      tq.add({ payload: 'first', priority: 5 });\n      tq.add({ payload: 'second', priority: 5 });\n      expect(tq.next()?.payload).toBe('first');\n      expect(tq.next()?.payload).toBe('second');\n    });\n\n    it('should expose priority on task object', () => {\n      const task = tq.add({ payload: 'test', priority: 3 });\n      expect(task.priority).toBe(3);\n    });\n  });\n\n  // ==================== Phase 4: Delayed Tasks ====================\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their availability time', () => {\n      tq.add({ payload: 'delayed', delay: 10000 });\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should return delayed tasks after their availability time', () => {\n      vi.useFakeTimers();\n      tq.add({ payload: 'delayed', delay: 1000 });\n      expect(tq.next()).toBeNull();\n      vi.advanceTimersByTime(1001);\n      expect(tq.next()?.payload).toBe('delayed');\n      vi.useRealTimers();\n    });\n\n    it('should accept availableAt date', () => {\n      const futureDate = new Date(Date.now() + 100000);\n      const task = tq.add({ payload: 'scheduled', availableAt: futureDate });\n      expect(task.availableAt).toEqual(futureDate);\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should prefer non-delayed tasks', () => {\n      vi.useFakeTimers();\n      tq.add({ payload: 'delayed', delay: 500 });\n      tq.add({ payload: 'immediate' });\n      expect(tq.next()?.payload).toBe('immediate');\n      vi.useRealTimers();\n    });\n\n    it('delayed tasks work with named queues', () => {\n      tq.add({ payload: 'delayed', delay: 10000, queue: 'myq' });\n      expect(tq.next('myq')).toBeNull();\n    });\n  });\n\n  // ==================== Phase 5: Retry with Backoff ====================\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should complete a task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      tq.complete(task.id);\n      expect(tq.getTask(task.id)?.status).toBe('completed');\n    });\n\n    it('should retry a failed task with delay', () => {\n      vi.useFakeTimers();\n      const task = tq.add({ payload: 'test', maxRetries: 3, baseDelay: 1000 });\n      tq.next();\n      tq.fail(task.id, 'some error');\n\n      expect(task.status).toBe('pending');\n      expect(task.attempts).toBe(1);\n\n      // Not available yet due to backoff\n      expect(tq.next()).toBeNull();\n\n      // Advance past backoff: 1000 * 2^0 = 1000\n      vi.advanceTimersByTime(1001);\n      const retried = tq.next();\n      expect(retried?.id).toBe(task.id);\n      expect(retried?.attempts).toBe(2);\n      vi.useRealTimers();\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1 });\n      tq.next();\n      expect(task.attempts).toBe(1);\n    });\n\n    it('should mark as failed when retries exhausted', () => {\n      vi.useFakeTimers();\n      const task = tq.add({ payload: 'test', maxRetries: 2, baseDelay: 100 });\n\n      // Attempt 1\n      tq.next();\n      tq.fail(task.id, 'err');\n      vi.advanceTimersByTime(200);\n\n      // Attempt 2 (final)\n      tq.next();\n      tq.fail(task.id, 'err2');\n\n      expect(task.status).toBe('failed');\n      vi.useRealTimers();\n    });\n\n    it('should use exponential backoff', () => {\n      vi.useFakeTimers();\n      const task = tq.add({ payload: 'test', maxRetries: 3, baseDelay: 100 });\n\n      // Attempt 1\n      tq.next();\n      tq.fail(task.id, 'err');\n      // Backoff: 100 * 2^0 = 100ms\n      vi.advanceTimersByTime(99);\n      expect(tq.next()).toBeNull();\n      vi.advanceTimersByTime(2);\n      expect(tq.next()?.id).toBe(task.id);\n\n      // Attempt 2\n      tq.fail(task.id, 'err');\n      // Backoff: 100 * 2^1 = 200ms\n      vi.advanceTimersByTime(199);\n      expect(tq.next()).toBeNull();\n      vi.advanceTimersByTime(2);\n      expect(tq.next()?.id).toBe(task.id);\n\n      vi.useRealTimers();\n    });\n\n    it('retried tasks keep original queue and priority', () => {\n      vi.useFakeTimers();\n      const task = tq.add({ payload: 'test', queue: 'myq', priority: 2, maxRetries: 3, baseDelay: 100 });\n      tq.next('myq');\n      tq.fail(task.id, 'err');\n      vi.advanceTimersByTime(200);\n      const retried = tq.next('myq');\n      expect(retried?.queue).toBe('myq');\n      expect(retried?.priority).toBe(2);\n      vi.useRealTimers();\n    });\n\n    it('should error when completing non-processing task', () => {\n      const task = tq.add({ payload: 'test' });\n      expect(() => tq.complete(task.id)).toThrow();\n    });\n\n    it('should error for non-existent task', () => {\n      expect(() => tq.complete('nonexistent')).toThrow();\n    });\n  });\n\n  // ==================== Phase 6: Dead Letter Queue ====================\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move exhausted tasks to DLQ', () => {\n      vi.useFakeTimers();\n      const task = tq.add({ payload: 'test', maxRetries: 1, baseDelay: 100 });\n      tq.next();\n      tq.fail(task.id, 'err');\n      expect(task.status).toBe('failed');\n      const dlq = tq.getDeadLetterQueue();\n      expect(dlq.length).toBe(1);\n      expect(dlq[0].id).toBe(task.id);\n      vi.useRealTimers();\n    });\n\n    it('should retain error information', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1, baseDelay: 100 });\n      tq.next();\n      tq.fail(task.id, 'final error');\n      const dlq = tq.getDeadLetterQueue();\n      expect(dlq[0].error).toBe('final error');\n      expect(dlq[0].failCount).toBe(1);\n    });\n\n    it('should redrive a task from DLQ', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1, baseDelay: 100 });\n      tq.next();\n      tq.fail(task.id, 'err');\n      expect(tq.getDeadLetterQueue().length).toBe(1);\n\n      const redriven = tq.redriveTask(task.id);\n      expect(redriven.status).toBe('pending');\n      expect(redriven.attempts).toBe(0);\n      expect(tq.getDeadLetterQueue().length).toBe(0);\n      expect(tq.size()).toBe(1);\n    });\n\n    it('should clear the DLQ', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 1, baseDelay: 100 });\n      tq.next();\n      tq.fail(task.id, 'err');\n      expect(tq.getDeadLetterQueue().length).toBe(1);\n      tq.clearDeadLetterQueue();\n      expect(tq.getDeadLetterQueue().length).toBe(0);\n    });\n\n    it('each named queue has its own DLQ', () => {\n      const t1 = tq.add({ payload: 'a', queue: 'q1', maxRetries: 1 });\n      const t2 = tq.add({ payload: 'b', queue: 'q2', maxRetries: 1 });\n      tq.next('q1');\n      tq.fail(t1.id, 'err');\n      tq.next('q2');\n      tq.fail(t2.id, 'err');\n\n      expect(tq.getDeadLetterQueue('q1').length).toBe(1);\n      expect(tq.getDeadLetterQueue('q2').length).toBe(1);\n      tq.clearDeadLetterQueue('q1');\n      expect(tq.getDeadLetterQueue('q1').length).toBe(0);\n      expect(tq.getDeadLetterQueue('q2').length).toBe(1);\n    });\n  });\n\n  // ==================== Phase 7: Task Dependencies ====================\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block tasks with unresolved dependencies', () => {\n      const dep = tq.add({ payload: 'dependency' });\n      tq.add({ payload: 'dependent', dependencies: [dep.id] });\n\n      // The dependent should not be returned\n      const next = tq.next();\n      expect(next?.payload).toBe('dependency');\n      const next2 = tq.next();\n      expect(next2).toBeNull();\n    });\n\n    it('should unblock tasks when dependencies complete', () => {\n      const dep = tq.add({ payload: 'dependency' });\n      const dependent = tq.add({ payload: 'dependent', dependencies: [dep.id] });\n\n      tq.next(); // get the dependency\n      tq.complete(dep.id);\n\n      const next = tq.next();\n      expect(next?.id).toBe(dependent.id);\n    });\n\n    it('should reject non-existent dependencies', () => {\n      expect(() => tq.add({ payload: 'test', dependencies: ['nonexistent'] })).toThrow();\n    });\n\n    it('should detect circular dependencies', () => {\n      const a = tq.add({ payload: 'a' });\n      const b = tq.add({ payload: 'b', dependencies: [a.id] });\n      expect(() => tq.add({ payload: 'c', dependencies: [b.id] })).not.toThrow();\n    });\n\n    it('should inspect dependency status', () => {\n      const dep1 = tq.add({ payload: 'dep1' });\n      const dep2 = tq.add({ payload: 'dep2' });\n      const task = tq.add({ payload: 'task', dependencies: [dep1.id, dep2.id] });\n\n      tq.next(); // dep1\n      tq.complete(dep1.id);\n\n      const status = tq.getDependencyStatus(task.id);\n      expect(status.resolved).toContain(dep1.id);\n      expect(status.unresolved).toContain(dep2.id);\n    });\n\n    it('failed dependency does not fail dependents', () => {\n      const dep = tq.add({ payload: 'dep', maxRetries: 1 });\n      const dependent = tq.add({ payload: 'dependent', dependencies: [dep.id] });\n\n      tq.next();\n      tq.fail(dep.id, 'err');\n\n      // Dependent should stay blocked (not failed)\n      expect(dependent.status).toBe('pending');\n    });\n  });\n\n  // ==================== Phase 8: Concurrency Control ====================\n  describe('Phase 8: Concurrency Control', () => {\n    it('should limit concurrent processing', () => {\n      tq.setConcurrency('default', 1);\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n\n      expect(tq.next()?.payload).toBe('a');\n      expect(tq.next()).toBeNull(); // limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      tq.setConcurrency('default', 1);\n      const task = tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n\n      tq.next();\n      tq.complete(task.id); // frees the slot\n      expect(tq.next()?.payload).toBe('b');\n    });\n\n    it('should free slot when task fails', () => {\n      vi.useFakeTimers();\n      tq.setConcurrency('default', 1);\n      const task = tq.add({ payload: 'a', maxRetries: 1, baseDelay: 100 });\n      tq.add({ payload: 'b' });\n\n      tq.next();\n      tq.fail(task.id, 'err'); // exhausts retries, frees slot\n      expect(tq.next()?.payload).toBe('b');\n      vi.useRealTimers();\n    });\n\n    it('should default to no limit', () => {\n      tq.add({ payload: 'a' });\n      tq.add({ payload: 'b' });\n      tq.add({ payload: 'c' });\n\n      expect(tq.next()).not.toBeNull();\n      expect(tq.next()).not.toBeNull();\n      expect(tq.next()).not.toBeNull();\n    });\n\n    it('should query concurrency limit and active count', () => {\n      tq.setConcurrency('default', 3);\n      expect(tq.getConcurrency('default')).toBe(3);\n      expect(tq.getActiveCount()).toBe(0);\n\n      tq.add({ payload: 'a' });\n      tq.next();\n      expect(tq.getActiveCount()).toBe(1);\n    });\n\n    it('respects priority with concurrency', () => {\n      tq.setConcurrency('default', 1);\n      tq.add({ payload: 'low', priority: 10 });\n      tq.add({ payload: 'high', priority: 1 });\n\n      expect(tq.next()?.payload).toBe('high');\n    });\n  });\n\n  // ==================== Phase 9: Progress & Cancellation ====================\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report and query progress', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      tq.reportProgress(task.id, 50, 'halfway');\n      expect(tq.getTask(task.id)?.progress).toBe(50);\n      expect(tq.getTask(task.id)?.progressMessage).toBe('halfway');\n    });\n\n    it('should subscribe and receive progress updates', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      tq.reportProgress(task.id, 25, 'quarter');\n      tq.reportProgress(task.id, 75, 'three-quarters');\n\n      expect(updates).toHaveLength(2);\n      expect(updates[0]).toEqual({ progress: 25, message: 'quarter' });\n      expect(updates[1]).toEqual({ progress: 75, message: 'three-quarters' });\n    });\n\n    it('should unsubscribe from progress updates', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      const updates: number[] = [];\n      const unsubscribe = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 25);\n      unsubscribe();\n      tq.reportProgress(task.id, 75);\n\n      expect(updates).toHaveLength(1);\n    });\n\n    it('should cancel a pending task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      expect(tq.next()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n    });\n\n    it('cancelled tasks are never retried', () => {\n      const task = tq.add({ payload: 'test', maxRetries: 3 });\n      tq.next();\n      tq.cancel(task.id);\n      expect(task.status).toBe('cancelled');\n      // Shouldn't be able to fail it into a retry\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('cannot cancel a completed task', () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      tq.complete(task.id);\n      expect(() => tq.cancel(task.id)).toThrow();\n    });\n  });\n\n  // ==================== Phase 10: Recurring Tasks ====================\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create and list schedules', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'check' });\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cron).toBe('*/5 * * * *');\n      expect(tq.listSchedules()).toHaveLength(1);\n    });\n\n    it('should remove a schedule', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'check' });\n      tq.removeSchedule(schedule.id);\n      expect(tq.listSchedules()).toHaveLength(0);\n    });\n\n    it('should enqueue tasks on tick when schedule is due', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'recurring' });\n\n      // Tick at minute 0 (divisible by 5)\n      const now = new Date(2024, 0, 1, 12, 0, 0);\n      const tasks = tq.tick(now);\n      expect(tasks).toHaveLength(1);\n      expect(tasks[0].payload).toEqual({ type: 'recurring' });\n    });\n\n    it('should not enqueue tasks when not due', () => {\n      tq.addSchedule('0 0 * * *', 'default', { type: 'daily' });\n\n      // Tick at 12:30 - should not trigger \"0 0 * * *\" (midnight)\n      const now = new Date(2024, 0, 1, 12, 30, 0);\n      const tasks = tq.tick(now);\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('should not double-enqueue within same minute', () => {\n      tq.addSchedule('*/5 * * * *', 'default', { type: 'recurring' });\n      const now = new Date(2024, 0, 1, 12, 0, 0);\n      tq.tick(now);\n      const tasks2 = tq.tick(now);\n      expect(tasks2).toHaveLength(0);\n    });\n\n    it('should validate cron expressions', () => {\n      expect(() => tq.addSchedule('invalid', 'default', {})).toThrow();\n      expect(() => tq.addSchedule('* *', 'default', {})).toThrow();\n    });\n\n    it('removing schedule stops future occurrences', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'recurring' });\n      tq.removeSchedule(schedule.id);\n      const tasks = tq.tick(new Date(2024, 0, 1, 12, 0, 0));\n      expect(tasks).toHaveLength(0);\n    });\n\n    it('every hour cron works', () => {\n      tq.addSchedule('0 * * * *', 'default', { type: 'hourly' });\n      const atHour = new Date(2024, 0, 1, 14, 0, 0);\n      const tasks = tq.tick(atHour);\n      expect(tasks).toHaveLength(1);\n\n      const notAtHour = new Date(2024, 0, 1, 14, 30, 0);\n      const tasks2 = tq.tick(notAtHour);\n      expect(tasks2).toHaveLength(0);\n    });\n  });\n\n  // ==================== Phase 11: Middleware ====================\n  describe('Phase 11: Middleware Pipeline', () => {\n    it('should run middleware in order', async () => {\n      const order: number[] = [];\n\n      tq.use('default', async (_task, next) => {\n        order.push(1);\n        await next();\n      });\n      tq.use('default', async (_task, next) => {\n        order.push(2);\n        await next();\n      });\n      tq.setHandler('default', async () => {\n        order.push(3);\n      });\n\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      await tq.process(task.id);\n\n      expect(order).toEqual([1, 2, 3]);\n    });\n\n    it('should skip processing if middleware does not call next', async () => {\n      let handlerCalled = false;\n\n      tq.use('default', async () => {\n        // Don't call next\n      });\n      tq.setHandler('default', async () => {\n        handlerCalled = true;\n      });\n\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n      await tq.process(task.id);\n\n      expect(handlerCalled).toBe(false);\n    });\n\n    it('should allow middleware to modify task', async () => {\n      tq.use('default', async (task, next) => {\n        (task.payload as Record<string, unknown>).modified = true;\n        await next();\n      });\n\n      let receivedPayload: unknown;\n      tq.setHandler('default', async (task) => {\n        receivedPayload = task.payload;\n      });\n\n      const task = tq.add({ payload: { original: true } });\n      tq.next();\n      await tq.process(task.id);\n\n      expect((receivedPayload as Record<string, unknown>).modified).toBe(true);\n    });\n\n    it('should fail task if middleware throws', async () => {\n      tq.use('default', async () => {\n        throw new Error('middleware error');\n      });\n\n      const task = tq.add({ payload: 'test', maxRetries: 1 });\n      tq.next();\n\n      await expect(tq.process(task.id)).rejects.toThrow('middleware error');\n      expect(task.status).toBe('failed');\n    });\n\n    it('each queue has independent middleware', async () => {\n      const q1Calls: string[] = [];\n      const q2Calls: string[] = [];\n\n      tq.use('q1', async (_task, next) => {\n        q1Calls.push('mw');\n        await next();\n      });\n      tq.use('q2', async (_task, next) => {\n        q2Calls.push('mw');\n        await next();\n      });\n\n      const t1 = tq.add({ payload: 'a', queue: 'q1' });\n      tq.next('q1');\n      await tq.process(t1.id);\n\n      expect(q1Calls).toHaveLength(1);\n      expect(q2Calls).toHaveLength(0);\n    });\n  });\n\n  // ==================== Phase 12: Graceful Shutdown ====================\n  describe('Phase 12: Graceful Shutdown', () => {\n    it('should reject new tasks after shutdown', async () => {\n      await tq.shutdown();\n      expect(() => tq.add({ payload: 'test' })).toThrow();\n    });\n\n    it('should complete immediately with no processing tasks', async () => {\n      const result = await tq.shutdown();\n      expect(result.completed).toBe(0);\n      expect(result.forceCancelled).toBe(0);\n      expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    });\n\n    it('should wait for processing tasks to complete', async () => {\n      const task = tq.add({ payload: 'test' });\n      tq.next();\n\n      // Complete it asynchronously\n      setTimeout(() => tq.complete(task.id), 50);\n\n      const result = await tq.shutdown(5000);\n      expect(result.completed).toBe(1);\n      expect(result.forceCancelled).toBe(0);\n    });\n\n    it('should force-cancel on timeout', async () => {\n      tq.add({ payload: 'test' });\n      tq.next(); // Start processing but never complete\n\n      const result = await tq.shutdown(100);\n      expect(result.forceCancelled).toBe(1);\n    });\n\n    it('should be idempotent', async () => {\n      const result1 = await tq.shutdown();\n      const result2 = await tq.shutdown();\n      expect(result1).toEqual(result2);\n    });\n\n    it('should run shutdown callbacks', async () => {\n      let callbackRan = false;\n      tq.onShutdown(() => {\n        callbackRan = true;\n      });\n      await tq.shutdown();\n      expect(callbackRan).toBe(true);\n    });\n\n    it('should produce shutdown summary', async () => {\n      const result = await tq.shutdown();\n      expect(result).toHaveProperty('completed');\n      expect(result).toHaveProperty('forceCancelled');\n      expect(result).toHaveProperty('durationMs');\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
