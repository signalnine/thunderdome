diff --git a/src/index.ts b/src/index.ts
new file mode 100644
index 0000000..528118c
--- /dev/null
+++ b/src/index.ts
@@ -0,0 +1,613 @@
+import { randomUUID } from 'crypto';
+
+// ==================== Types ====================
+
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  queue: string;
+  attempts: number;
+  maxRetries: number;
+  baseDelay: number;
+  error?: string;
+  failCount: number;
+  dependencies: string[];
+  progress: number;
+  progressMessage?: string;
+}
+
+export interface AddTaskOptions<T = unknown> {
+  payload: T;
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  baseDelay?: number;
+  dependencies?: string[];
+}
+
+export interface Schedule {
+  id: string;
+  cron: string;
+  queue: string;
+  payload: unknown;
+  lastRun?: Date;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFn = (task: Task) => Promise<void>;
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
+
+// ==================== TaskQueue ====================
+
+const DEFAULT_QUEUE = 'default';
+
+export class TaskQueue {
+  private tasks: Map<string, Task> = new Map();
+  private queues: Map<string, Task[]> = new Map();
+  private dlqs: Map<string, Task[]> = new Map();
+  private concurrencyLimits: Map<string, number> = new Map();
+  private progressListeners: Map<string, Set<ProgressListener>> = new Map();
+  private schedules: Map<string, Schedule> = new Map();
+  private middlewares: Map<string, MiddlewareFn[]> = new Map();
+  private handlers: Map<string, HandlerFn> = new Map();
+  private isShutdown = false;
+  private shutdownPromise: Promise<ShutdownResult> | null = null;
+  private shutdownCallbacks: Array<() => void | Promise<void>> = [];
+
+  // ---- Phase 1: Basic FIFO ----
+
+  add<T = unknown>(options: AddTaskOptions<T>): Task<T> {
+    if (this.isShutdown) {
+      throw new Error('Queue is shut down; cannot add new tasks');
+    }
+
+    const queueName = options.queue ?? DEFAULT_QUEUE;
+    const priority = options.priority ?? 5;
+
+    if (priority < 1 || priority > 10 || !Number.isInteger(priority)) {
+      throw new Error(`Invalid priority: ${priority}. Must be an integer between 1 and 10.`);
+    }
+
+    // Validate dependencies
+    const deps = options.dependencies ?? [];
+    for (const depId of deps) {
+      if (!this.tasks.has(depId)) {
+        throw new Error(`Dependency task '${depId}' does not exist`);
+      }
+    }
+
+    // Check circular dependencies
+    if (deps.length > 0) {
+      // We'll do the check after creating the task ID
+    }
+
+    let availableAt: Date;
+    if (options.availableAt) {
+      availableAt = options.availableAt;
+    } else if (options.delay != null && options.delay > 0) {
+      availableAt = new Date(Date.now() + options.delay);
+    } else {
+      availableAt = new Date();
+    }
+
+    const task: Task<T> = {
+      id: randomUUID(),
+      payload: options.payload,
+      status: 'pending',
+      priority,
+      createdAt: new Date(),
+      availableAt,
+      queue: queueName,
+      attempts: 0,
+      maxRetries: options.maxRetries ?? 3,
+      baseDelay: options.baseDelay ?? 1000,
+      failCount: 0,
+      dependencies: [...deps],
+      progress: 0,
+    };
+
+    // Check circular deps with temporary task
+    if (deps.length > 0) {
+      this.tasks.set(task.id, task as Task);
+      if (this.hasCircularDependency(task.id)) {
+        this.tasks.delete(task.id);
+        throw new Error('Circular dependency detected');
+      }
+    } else {
+      this.tasks.set(task.id, task as Task);
+    }
+
+    if (!this.queues.has(queueName)) {
+      this.queues.set(queueName, []);
+    }
+    this.queues.get(queueName)!.push(task as Task);
+
+    return task;
+  }
+
+  private hasCircularDependency(taskId: string, visited: Set<string> = new Set(), path: Set<string> = new Set()): boolean {
+    if (path.has(taskId)) return true;
+    if (visited.has(taskId)) return false;
+
+    visited.add(taskId);
+    path.add(taskId);
+
+    const task = this.tasks.get(taskId);
+    if (task) {
+      for (const depId of task.dependencies) {
+        if (this.hasCircularDependency(depId, visited, path)) {
+          return true;
+        }
+      }
+    }
+
+    // Also check if any other task depends on this task (reverse direction)
+    for (const [id, t] of this.tasks) {
+      if (id !== taskId && t.dependencies.includes(taskId)) {
+        if (path.has(id)) continue;
+        // Check if depId has a path back to taskId through deps
+      }
+    }
+
+    path.delete(taskId);
+    return false;
+  }
+
+  next(queueName?: string): Task | null {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const queue = this.queues.get(name);
+    if (!queue) return null;
+
+    // Check concurrency limit
+    const limit = this.concurrencyLimits.get(name);
+    if (limit != null) {
+      const activeCount = this.getActiveCount(name);
+      if (activeCount >= limit) return null;
+    }
+
+    const now = Date.now();
+
+    // Find eligible tasks: pending, available, dependencies met
+    const eligible: Array<{ task: Task; index: number }> = [];
+    for (let i = 0; i < queue.length; i++) {
+      const task = queue[i];
+      if (task.status !== 'pending') continue;
+      if (task.availableAt.getTime() > now) continue;
+      if (!this.areDependenciesMet(task)) continue;
+      eligible.push({ task, index: i });
+    }
+
+    if (eligible.length === 0) return null;
+
+    // Sort by priority (ascending = higher priority first), then by availableAt, then FIFO (createdAt)
+    eligible.sort((a, b) => {
+      if (a.task.priority !== b.task.priority) return a.task.priority - b.task.priority;
+      if (a.task.availableAt.getTime() !== b.task.availableAt.getTime()) {
+        return a.task.availableAt.getTime() - b.task.availableAt.getTime();
+      }
+      return a.index - b.index;
+    });
+
+    const chosen = eligible[0];
+    chosen.task.status = 'processing';
+    chosen.task.attempts++;
+    return chosen.task;
+  }
+
+  private areDependenciesMet(task: Task): boolean {
+    for (const depId of task.dependencies) {
+      const dep = this.tasks.get(depId);
+      if (!dep || dep.status !== 'completed') return false;
+    }
+    return true;
+  }
+
+  size(queueName?: string): number {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const queue = this.queues.get(name);
+    if (!queue) return 0;
+    return queue.filter(t => t.status === 'pending').length;
+  }
+
+  getTask(id: string): Task | undefined {
+    return this.tasks.get(id);
+  }
+
+  // ---- Phase 2: Named Queues ----
+
+  listQueues(): string[] {
+    return Array.from(this.queues.keys());
+  }
+
+  // ---- Phase 5: Complete / Fail ----
+
+  complete(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task '${taskId}' not found`);
+    if (task.status !== 'processing') throw new Error(`Task '${taskId}' is not in processing state`);
+
+    task.status = 'completed';
+    task.progress = 100;
+  }
+
+  fail(taskId: string, error?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task '${taskId}' not found`);
+    if (task.status !== 'processing') throw new Error(`Task '${taskId}' is not in processing state`);
+
+    task.error = error;
+    task.failCount++;
+
+    if (task.attempts < task.maxRetries) {
+      // Retry with backoff
+      const delay = task.baseDelay * Math.pow(2, task.attempts - 1);
+      task.status = 'pending';
+      task.availableAt = new Date(Date.now() + delay);
+      task.progress = 0;
+    } else {
+      // All retries exhausted
+      task.status = 'failed';
+
+      // Move to DLQ
+      const dlqName = task.queue;
+      if (!this.dlqs.has(dlqName)) {
+        this.dlqs.set(dlqName, []);
+      }
+      this.dlqs.get(dlqName)!.push(task);
+
+      // Remove from queue
+      const queue = this.queues.get(task.queue);
+      if (queue) {
+        const idx = queue.indexOf(task);
+        if (idx !== -1) queue.splice(idx, 1);
+      }
+    }
+  }
+
+  // ---- Phase 6: Dead Letter Queue ----
+
+  getDeadLetterQueue(queueName?: string): Task[] {
+    const name = queueName ?? DEFAULT_QUEUE;
+    return [...(this.dlqs.get(name) ?? [])];
+  }
+
+  redriveTask(taskId: string): Task {
+    // Find which DLQ has the task
+    for (const [queueName, dlq] of this.dlqs) {
+      const idx = dlq.findIndex(t => t.id === taskId);
+      if (idx !== -1) {
+        const task = dlq[idx];
+        dlq.splice(idx, 1);
+
+        // Reset and re-add
+        task.status = 'pending';
+        task.attempts = 0;
+        task.failCount = 0;
+        task.error = undefined;
+        task.progress = 0;
+        task.availableAt = new Date();
+
+        if (!this.queues.has(queueName)) {
+          this.queues.set(queueName, []);
+        }
+        this.queues.get(queueName)!.push(task);
+        return task;
+      }
+    }
+    throw new Error(`Task '${taskId}' not found in any dead letter queue`);
+  }
+
+  clearDeadLetterQueue(queueName?: string): void {
+    const name = queueName ?? DEFAULT_QUEUE;
+    this.dlqs.set(name, []);
+  }
+
+  // ---- Phase 7: Task Dependencies ----
+
+  getDependencyStatus(taskId: string): { resolved: string[]; unresolved: string[] } {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task '${taskId}' not found`);
+
+    const resolved: string[] = [];
+    const unresolved: string[] = [];
+
+    for (const depId of task.dependencies) {
+      const dep = this.tasks.get(depId);
+      if (dep && dep.status === 'completed') {
+        resolved.push(depId);
+      } else {
+        unresolved.push(depId);
+      }
+    }
+
+    return { resolved, unresolved };
+  }
+
+  // ---- Phase 8: Concurrency Control ----
+
+  setConcurrency(queueName: string, limit: number): void {
+    if (limit < 1 || !Number.isInteger(limit)) {
+      throw new Error(`Invalid concurrency limit: ${limit}`);
+    }
+    this.concurrencyLimits.set(queueName, limit);
+  }
+
+  getConcurrency(queueName: string): number | undefined {
+    return this.concurrencyLimits.get(queueName);
+  }
+
+  getActiveCount(queueName?: string): number {
+    const name = queueName ?? DEFAULT_QUEUE;
+    const queue = this.queues.get(name);
+    if (!queue) return 0;
+    return queue.filter(t => t.status === 'processing').length;
+  }
+
+  // ---- Phase 9: Progress & Cancellation ----
+
+  reportProgress(taskId: string, progress: number, message?: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task '${taskId}' not found`);
+    if (task.status !== 'processing') throw new Error(`Task '${taskId}' is not in processing state`);
+    if (progress < 0 || progress > 100) throw new Error(`Invalid progress: ${progress}`);
+
+    task.progress = progress;
+    task.progressMessage = message;
+
+    const listeners = this.progressListeners.get(taskId);
+    if (listeners) {
+      for (const listener of listeners) {
+        listener(progress, message);
+      }
+    }
+  }
+
+  onProgress(taskId: string, listener: ProgressListener): () => void {
+    if (!this.progressListeners.has(taskId)) {
+      this.progressListeners.set(taskId, new Set());
+    }
+    this.progressListeners.get(taskId)!.add(listener);
+
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(listener);
+      }
+    };
+  }
+
+  cancel(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task '${taskId}' not found`);
+    if (task.status !== 'pending' && task.status !== 'processing') {
+      throw new Error(`Task '${taskId}' cannot be cancelled (status: ${task.status})`);
+    }
+
+    task.status = 'cancelled';
+  }
+
+  // ---- Phase 10: Recurring Tasks ----
+
+  addSchedule(cron: string, queueName: string, payload: unknown): Schedule {
+    this.validateCron(cron);
+    const schedule: Schedule = {
+      id: randomUUID(),
+      cron,
+      queue: queueName,
+      payload,
+    };
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    if (!this.schedules.has(scheduleId)) {
+      throw new Error(`Schedule '${scheduleId}' not found`);
+    }
+    this.schedules.delete(scheduleId);
+  }
+
+  listSchedules(): Schedule[] {
+    return Array.from(this.schedules.values());
+  }
+
+  tick(now?: Date): Task[] {
+    const currentTime = now ?? new Date();
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (this.shouldRun(schedule, currentTime)) {
+        const task = this.add({ payload: schedule.payload, queue: schedule.queue });
+        created.push(task);
+        schedule.lastRun = currentTime;
+      }
+    }
+
+    return created;
+  }
+
+  private validateCron(cron: string): void {
+    const parts = cron.split(' ');
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${cron}`);
+    }
+
+    // Support: */N * * * *, 0 * * * *, 0 0 * * *
+    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;
+
+    // Validate basic patterns
+    const validField = (f: string): boolean => {
+      if (f === '*') return true;
+      if (/^\d+$/.test(f)) return true;
+      if (/^\*\/\d+$/.test(f)) return true;
+      return false;
+    };
+
+    if (!validField(minute) || !validField(hour) || !validField(dayOfMonth) || !validField(month) || !validField(dayOfWeek)) {
+      throw new Error(`Invalid cron expression: ${cron}`);
+    }
+  }
+
+  private shouldRun(schedule: Schedule, now: Date): boolean {
+    const parts = schedule.cron.split(' ');
+    const [minuteExpr, hourExpr] = parts;
+
+    const currentMinute = now.getMinutes();
+    const currentHour = now.getHours();
+
+    // Check minute match
+    if (!this.cronFieldMatches(minuteExpr, currentMinute)) return false;
+    // Check hour match
+    if (!this.cronFieldMatches(hourExpr, currentHour)) return false;
+
+    // Check if already ran this minute
+    if (schedule.lastRun) {
+      const lastMinute = schedule.lastRun.getMinutes();
+      const lastHour = schedule.lastRun.getHours();
+      const lastDate = schedule.lastRun.toDateString();
+      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === now.toDateString()) {
+        return false;
+      }
+    }
+
+    return true;
+  }
+
+  private cronFieldMatches(expr: string, value: number): boolean {
+    if (expr === '*') return true;
+    if (/^\d+$/.test(expr)) return parseInt(expr, 10) === value;
+    const stepMatch = expr.match(/^\*\/(\d+)$/);
+    if (stepMatch) {
+      const step = parseInt(stepMatch[1], 10);
+      return value % step === 0;
+    }
+    return false;
+  }
+
+  // ---- Phase 11: Middleware ----
+
+  use(queueName: string, middleware: MiddlewareFn): void {
+    if (!this.middlewares.has(queueName)) {
+      this.middlewares.set(queueName, []);
+    }
+    this.middlewares.get(queueName)!.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: HandlerFn): void {
+    this.handlers.set(queueName, handler);
+  }
+
+  async process(taskId: string): Promise<void> {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task '${taskId}' not found`);
+    if (task.status !== 'processing') throw new Error(`Task '${taskId}' is not in processing state`);
+
+    const middlewareStack = this.middlewares.get(task.queue) ?? [];
+    const handler = this.handlers.get(task.queue);
+
+    let index = 0;
+    const executeNext = async (): Promise<void> => {
+      if (index < middlewareStack.length) {
+        const mw = middlewareStack[index++];
+        await mw(task, executeNext);
+      } else if (handler) {
+        await handler(task);
+      }
+    };
+
+    try {
+      await executeNext();
+    } catch (err) {
+      const errorMsg = err instanceof Error ? err.message : String(err);
+      this.fail(taskId, errorMsg);
+      throw err;
+    }
+  }
+
+  // ---- Phase 12: Graceful Shutdown ----
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {
+    if (this.shutdownPromise) return this.shutdownPromise;
+
+    this.isShutdown = true;
+    this.shutdownPromise = this.performShutdown(timeoutMs);
+    return this.shutdownPromise;
+  }
+
+  private async performShutdown(timeoutMs: number): Promise<ShutdownResult> {
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Find all currently processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    let completed = 0;
+    let forceCancelled = 0;
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        durationMs: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete, up to timeout
+    const deadline = startTime + timeoutMs;
+
+    await new Promise<void>((resolve) => {
+      const check = () => {
+        const stillProcessing = processingTasks.filter(t => t.status === 'processing');
+        if (stillProcessing.length === 0 || Date.now() >= deadline) {
+          resolve();
+          return;
+        }
+        setTimeout(check, 50);
+      };
+      check();
+    });
+
+    // Count completed and force-cancel the rest
+    for (const task of processingTasks) {
+      if (task.status === 'completed' || task.status === 'failed') {
+        completed++;
+      } else if (task.status === 'processing') {
+        task.status = 'cancelled';
+        forceCancelled++;
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      durationMs: Date.now() - startTime,
+    };
+  }
+}
