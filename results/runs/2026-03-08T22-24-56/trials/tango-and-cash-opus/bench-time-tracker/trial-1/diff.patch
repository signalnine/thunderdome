entries).toHaveLength(2);\n    expect(entries[0].task).toBe(\"task1\");\n    expect(entries[0].stop).not.toBeNull();\n    expect(entries[1].task).toBe(\"task2\");\n    expect(entries[1].stop).toBeNull();\n  });\n\n  it(\"persists data to JSON file\", () => {\n    const tracker = new TimeTracker(filePath);\n    tracker.start(\"persist-test\");\n    tracker.stop();\n\n    // Load from same file\n    const tracker2 = new TimeTracker(filePath);\n    const entries = tracker2.getEntries();\n    expect(entries).toHaveLength(1);\n    expect(entries[0].task).toBe(\"persist-test\");\n  });\n\n  it(\"creates parent directories automatically\", () => {\n    const deepPath = path.join(os.tmpdir(), \"tt-deep-\" + Date.now(), \"a\", \"b\", \"data.json\");\n    const tracker = new TimeTracker(deepPath);\n    tracker.start(\"deep\");\n    tracker.stop();\n\n    expect(fs.existsSync(deepPath)).toBe(true);\n    cleanup(deepPath);\n  });\n\n  it(\"filters entries by date range\", () => {\n    const tracker = new TimeTracker(filePath);\n\n    const now = new Date();\n    const past = new Date(now.getTime() - 86400000); // 1 day ago\n    const future = new Date(now.getTime() + 86400000); // 1 day from now\n\n    tracker.start(\"recent\");\n    tracker.stop();\n\n    const all = tracker.getEntries();\n    expect(all).toHaveLength(1);\n\n    const filtered = tracker.getEntries(past, future);\n    expect(filtered).toHaveLength(1);\n\n    const none = tracker.getEntries(future);\n    expect(none).toHaveLength(0);\n  });\n\n  it(\"summarizes time per task\", () => {\n    const tracker = new TimeTracker(filePath);\n\n    tracker.start(\"coding\");\n    tracker.stop();\n    tracker.start(\"coding\");\n    tracker.stop();\n    tracker.start(\"review\");\n    tracker.stop();\n\n    const summary = tracker.getSummary();\n    expect(summary[\"coding\"]).toBeGreaterThanOrEqual(0);\n    expect(summary[\"review\"]).toBeGreaterThanOrEqual(0);\n    expect(Object.keys(summary)).toHaveLength(2);\n  });\n\