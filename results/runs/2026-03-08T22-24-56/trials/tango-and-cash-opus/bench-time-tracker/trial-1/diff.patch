diff --git a/src/tracker.ts b/src/tracker.ts
new file mode 100644
index 0000000..22b5e8e
--- /dev/null
+++ b/src/tracker.ts
@@ -0,0 +1,118 @@
+import * as fs from "node:fs";
+import * as path from "node:path";
+
+export interface TimeEntry {
+  task: string;
+  start: string; // ISO 8601
+  stop: string | null; // ISO 8601 or null if running
+}
+
+export interface TimeSummary {
+  [task: string]: number; // milliseconds
+}
+
+export class TimeTracker {
+  private entries: TimeEntry[] = [];
+  private filePath: string;
+
+  constructor(filePath: string) {
+    this.filePath = filePath;
+    this.load();
+  }
+
+  private load(): void {
+    try {
+      const data = fs.readFileSync(this.filePath, "utf-8");
+      const parsed: unknown = JSON.parse(data);
+      if (Array.isArray(parsed)) {
+        this.entries = parsed as TimeEntry[];
+      }
+    } catch {
+      // File doesn't exist or is invalid — start fresh
+      this.entries = [];
+    }
+  }
+
+  private save(): void {
+    const dir = path.dirname(this.filePath);
+    fs.mkdirSync(dir, { recursive: true });
+    fs.writeFileSync(this.filePath, JSON.stringify(this.entries, null, 2), "utf-8");
+  }
+
+  private getRunningEntry(): TimeEntry | undefined {
+    return this.entries.find((e) => e.stop === null);
+  }
+
+  start(task: string): void {
+    if (!task || task.trim().length === 0) {
+      throw new Error("Task name must not be empty");
+    }
+
+    const running = this.getRunningEntry();
+    if (running) {
+      running.stop = new Date().toISOString();
+    }
+
+    this.entries.push({
+      task,
+      start: new Date().toISOString(),
+      stop: null,
+    });
+
+    this.save();
+  }
+
+  stop(): TimeEntry {
+    const running = this.getRunningEntry();
+    if (!running) {
+      throw new Error("No timer is currently running");
+    }
+
+    running.stop = new Date().toISOString();
+    this.save();
+    return { ...running };
+  }
+
+  getEntries(from?: Date, to?: Date): TimeEntry[] {
+    let result = [...this.entries];
+
+    if (from) {
+      const fromTime = from.getTime();
+      result = result.filter((e) => new Date(e.start).getTime() >= fromTime);
+    }
+
+    if (to) {
+      const toTime = to.getTime();
+      result = result.filter((e) => new Date(e.start).getTime() <= toTime);
+    }
+
+    return result;
+  }
+
+  getSummary(): TimeSummary {
+    const summary: TimeSummary = {};
+    const now = Date.now();
+
+    for (const entry of this.entries) {
+      const startTime = new Date(entry.start).getTime();
+      const endTime = entry.stop ? new Date(entry.stop).getTime() : now;
+      const duration = endTime - startTime;
+
+      if (summary[entry.task] === undefined) {
+        summary[entry.task] = 0;
+      }
+      summary[entry.task] += duration;
+    }
+
+    return summary;
+  }
+
+  isRunning(): boolean {
+    return this.getRunningEntry() !== undefined;
+  }
+
+  currentTask(): string | null {
+    const running = this.getRunningEntry();
+    return running ? running.task : null;
+  }
+}
