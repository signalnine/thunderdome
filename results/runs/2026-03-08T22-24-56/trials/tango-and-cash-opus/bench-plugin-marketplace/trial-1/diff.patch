   expect(flagged[0].flagged).toBe(true);\n  });\n\n  it('should remove a review', () => {\n    const r = reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    expect(reviews.removeReview(r.id)).toBe(true);\n    expect(reviews.removeReview(r.id)).toBe(false);\n    expect(reviews.getReviews('foo')).toHaveLength(0);\n  });\n\n  it('should get reviews by user', () => {\n    reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    reviews.addReview({ pluginName: 'b', pluginVersion: '1.0.0', userId: 'u1', rating: 4, comment: '' });\n    reviews.addReview({ pluginName: 'a', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n    expect(reviews.getReviewsByUser('u1')).toHaveLength(2);\n    expect(reviews.getReviewsByUser('u2')).toHaveLength(1);\n  });\n\n  it('should count reviews excluding flagged', () => {\n    reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u1', rating: 5, comment: '' });\n    const r2 = reviews.addReview({ pluginName: 'foo', pluginVersion: '1.0.0', userId: 'u2', rating: 3, comment: '' });\n    expect(reviews.getReviewCount('foo')).toBe(2);\n    reviews.flagReview(r2.id);\n    expect(reviews.getReviewCount('foo')).toBe(1);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4832,"cache_read_input_tokens":22832,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4832},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"91657cad-0549-44af-8ce9-0aa3f1127c9e","uuid":"2bc09ba4-c1fb-43ce-b2f2-52eb38be796d"}
