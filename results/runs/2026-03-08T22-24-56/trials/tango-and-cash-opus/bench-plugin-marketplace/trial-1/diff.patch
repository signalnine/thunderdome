index 0000000..9b21190
--- /dev/null
+++ b/src/deps/index.ts
@@ -0,0 +1,121 @@
+import type { DependencyNode, DepsService, RegistryService } from '../types.js';
+
+export class DependencyGraph implements DepsService {
+  buildTree(name: string, registry: RegistryService): DependencyNode {
+    const visited = new Set<string>();
+    return this.buildNode(name, registry, visited);
+  }
+
+  private buildNode(name: string, registry: RegistryService, visited: Set<string>): DependencyNode {
+    const manifest = registry.get(name);
+    if (!manifest) {
+      return { name, version: 'unknown', dependencies: [] };
+    }
+
+    if (visited.has(name)) {
+      return { name, version: manifest.version, dependencies: [] };
+    }
+
+    visited.add(name);
+    const deps: DependencyNode[] = [];
+    for (const depName of Object.keys(manifest.dependencies)) {
+      deps.push(this.buildNode(depName, registry, visited));
+    }
+    visited.delete(name);
+
+    return { name, version: manifest.version, dependencies: deps };
+  }
+
+  detectCycles(name: string, registry: RegistryService): string[][] | null {
+    const cycles: string[][] = [];
+    const visited = new Set<string>();
+    const path: string[] = [];
+
+    this.findCycles(name, registry, visited, path, new Set<string>(), cycles);
+
+    return cycles.length > 0 ? cycles : null;
+  }
+
+  private findCycles(
+    name: string,
+    registry: RegistryService,
+    visited: Set<string>,
+    path: string[],
+    inStack: Set<string>,
+    cycles: string[][],
+  ): void {
+    if (inStack.has(name)) {
+      const cycleStart = path.indexOf(name);
+      cycles.push([...path.slice(cycleStart), name]);
+      return;
+    }
+
+    if (visited.has(name)) return;
+
+    const manifest = registry.get(name);
+    if (!manifest) return;
+
+    visited.add(name);
+    inStack.add(name);
+    path.push(name);
+
+    for (const depName of Object.keys(manifest.dependencies)) {
+      const depVisitedBefore = visited.has(depName);
+      if (inStack.has(depName)) {
+        const cycleStart = path.indexOf(depName);
+        cycles.push([...path.slice(cycleStart), depName]);
+      } else if (!depVisitedBefore) {
+        this.findCycles(depName, registry, visited, path, inStack, cycles);
+      }
+    }
+
+    path.pop();
+    inStack.delete(name);
+  }
+
+  topologicalSort(name: string, registry: RegistryService): string[] {
+    const result: string[] = [];
+    const visited = new Set<string>();
+
+    this.topoVisit(name, registry, visited, result);
+
+    return result;
+  }
+
+  private topoVisit(name: string, registry: RegistryService, visited: Set<string>, result: string[]): void {
+    if (visited.has(name)) return;
+    visited.add(name);
+
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        this.topoVisit(depName, registry, visited, result);
+      }
+    }
+
+    result.push(name);
+  }
+
+  flattenDependencies(name: string, registry: RegistryService): string[] {
+    const deps = new Set<string>();
+    this.collectDeps(name, registry, deps);
+    deps.delete(name);
+    return [...deps];
+  }
+
+  private collectDeps(name: string, registry: RegistryService, deps: Set<string>): void {
+    if (deps.has(name)) return;
+    deps.add(name);
+
+    const manifest = registry.get(name);
+    if (manifest) {
+      for (const depName of Object.keys(manifest.dependencies)) {
+        this.collectDeps(depName, registry, deps);
+      }
+    }
+  }
+
+  hasCircularDependency(name: string, registry: RegistryService): boolean {
+    return this.detectCycles(name, registry) !== null;
+  }
+}
