+import { describe, it, expect } from 'vitest';
+import { VersionResolver } from './index.js';
+
+describe('VersionResolver', () => {
+  const resolver = new VersionResolver();
+
+  it('should resolve constraints to max satisfying versions', () => {
+    const result = resolver.resolve(
+      [{ name: 'foo', range: '^1.0.0' }],
+      { foo: ['1.0.0', '1.2.0', '1.5.0', '2.0.0'] },
+    );
+    expect(result).toEqual([{ name: 'foo', version: '1.5.0', satisfies: '^1.0.0' }]);
+  });
+
+  it('should resolve multiple constraints', () => {
+    const result = resolver.resolve(
+      [
+        { name: 'a', range: '>=1.0.0' },
+        { name: 'b', range: '~2.1.0' },
+      ],
+      { a: ['1.0.0', '2.0.0'], b: ['2.1.0', '2.1.5', '2.2.0'] },
+    );
+    expect(result).toHaveLength(2);
+    expect(result[0].version).toBe('2.0.0');
+    expect(result[1].version).toBe('2.1.5');
+  });
+
+  it('should throw when no versions available', () => {
+    expect(() => resolver.resolve([{ name: 'x', range: '^1.0.0' }], {})).toThrow();
+  });
+
+  it('should throw when no version satisfies', () => {
+    expect(() => resolver.resolve(
+      [{ name: 'x', range: '^3.0.0' }],
+      { x: ['1.0.0', '2.0.0'] },
+    )).toThrow();
+  });
+
+  it('should check satisfies', () => {
+    expect(resolver.satisfies('1.2.3', '^1.0.0')).toBe(true);
+    expect(resolver.satisfies('2.0.0', '^1.0.0')).toBe(false);
+  });
+
+  it('should find max satisfying', () => {
+    expect(resolver.maxSatisfying(['1.0.0', '1.5.0', '2.0.0'], '^1.0.0')).toBe('1.5.0');
+    expect(resolver.maxSatisfying(['3.0.0'], '^1.0.0')).toBeNull();
+  });
+
+  it('should validate ranges', () => {
+    expect(resolver.validRange('^1.0.0')).toBe(true);
+    expect(resolver.validRange('>=1.0.0 <2.0.0')).toBe(true);
+    expect(resolver.validRange('not-a-range')).toBe(false);
+  });
+});
