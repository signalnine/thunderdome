new file mode 100644
index 0000000..47bca0f
--- /dev/null
+++ b/src/runner/index.ts
@@ -0,0 +1,27 @@
+import vm from 'node:vm';
+import type { SandboxResult, RunnerService } from '../types.js';
+
+export class SandboxRunner implements RunnerService {
+  async execute(code: string, context?: Record<string, unknown>): Promise<SandboxResult> {
+    return this.executeWithTimeout(code, 5000, context);
+  }
+
+  async executeWithTimeout(code: string, timeoutMs: number, context?: Record<string, unknown>): Promise<SandboxResult> {
+    const sandbox: Record<string, unknown> = { ...context };
+    const vmContext = vm.createContext(sandbox);
+    const startMem = process.memoryUsage().heapUsed;
+    const start = performance.now();
+
+    try {
+      const output = vm.runInContext(code, vmContext, { timeout: timeoutMs });
+      const duration = performance.now() - start;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - startMem);
+      return { success: true, output, duration, memoryUsed };
+    } catch (err: unknown) {
+      const duration = performance.now() - start;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - startMem);
+      const error = err instanceof Error ? err.message : String(err);
+      return { success: false, output: null, duration, memoryUsed, error };
+    }
+  }
+}
