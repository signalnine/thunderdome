+import { describe, it, expect } from 'vitest';
+import { createMarketplace } from './index.js';
+import type { PluginManifest } from './types.js';
+
+const make = (overrides: Partial<PluginManifest> = {}): PluginManifest => ({
+  name: 'my-plugin',
+  version: '1.0.0',
+  description: 'test',
+  author: 'tester',
+  dependencies: {},
+  entryPoint: '"installed"',
+  permissions: [],
+  ...overrides,
+});
+
+describe('createMarketplace', () => {
+  it('should create a marketplace with all services', () => {
+    const mp = createMarketplace();
+    expect(mp.registry).toBeDefined();
+    expect(mp.resolver).toBeDefined();
+    expect(mp.runner).toBeDefined();
+    expect(mp.reviews).toBeDefined();
+    expect(mp.deps).toBeDefined();
+    expect(mp.installPlugin).toBeDefined();
+  });
+
+  it('should install a simple plugin', async () => {
+    const mp = createMarketplace();
+    const result = await mp.installPlugin(make());
+    expect(result.resolvedDependencies).toEqual([]);
+    expect(result.executionResult.success).toBe(true);
+    expect(result.executionResult.output).toBe('installed');
+  });
+
+  it('should reject plugin without required fields', async () => {
+    const mp = createMarketplace();
+    await expect(mp.installPlugin(make({ name: '' }))).rejects.toThrow();
+    await expect(mp.installPlugin(make({ version: '' }))).rejects.toThrow();
+    await expect(mp.installPlugin(make({ entryPoint: '' }))).rejects.toThrow();
+  });
+
+  it('should resolve dependencies during install', async () => {
+    const mp = createMarketplace();
+    mp.registry.register(make({ name: 'dep-a', version: '1.0.0' }));
+    mp.registry.register(make({ name: 'dep-a', version: '1.2.0' }));
+
+    const result = await mp.installPlugin(make({
+      name: 'consumer',
+      dependencies: { 'dep-a': '^1.0.0' },
+    }));
+    expect(result.resolvedDependencies).toHaveLength(1);
+    expect(result.resolvedDependencies[0].version).toBe('1.2.0');
+  });
+
+  it('should reject circular dependencies', async () => {
+    const mp = createMarketplace();
+    mp.registry.register(make({ name: 'a', dependencies: { b: '^1.0.0' } }));
+    mp.registry.register(make({ name: 'b', dependencies: { a: '^1.0.0' } }));
+
+    // Plugin c depends on a, which has a cycle with b
+    // But more directly, let's create a direct cycle
+    await expect(
+      mp.installPlugin(make({ name: 'a', version: '2.0.0', dependencies: { b: '^1.0.0' } }))
+    ).rejects.toThrow('Circular dependency');
+  });
+
+  it('should execute entryPoint and return result', async () => {
+    const mp = createMarketplace();
+    const result = await mp.installPlugin(make({ entryPoint: '2 + 2' }));
+    expect(result.executionResult.success).toBe(true);
+    expect(result.executionResult.output).toBe(4);
+  });
+});
