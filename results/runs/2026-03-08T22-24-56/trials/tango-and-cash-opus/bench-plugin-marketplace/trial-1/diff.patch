diff --git a/src/deps/deps.test.ts b/src/deps/deps.test.ts
new file mode 100644
index 0000000..539bef9
--- /dev/null
+++ b/src/deps/deps.test.ts
@@ -0,0 +1,101 @@
+import { describe, it, expect, beforeEach } from 'vitest';
+import { DependencyGraph } from './index.js';
+import { PluginRegistry } from '../registry/index.js';
+import type { PluginManifest } from '../types.js';
+
+const make = (name: string, deps: Record<string, string> = {}): PluginManifest => ({
+  name,
+  version: '1.0.0',
+  description: '',
+  author: '',
+  dependencies: deps,
+  entryPoint: '"ok"',
+  permissions: [],
+});
+
+describe('DependencyGraph', () => {
+  let graph: DependencyGraph;
+  let registry: PluginRegistry;
+
+  beforeEach(() => {
+    graph = new DependencyGraph();
+    registry = new PluginRegistry();
+  });
+
+  it('should build a simple dependency tree', () => {
+    registry.register(make('a', { b: '^1.0.0' }));
+    registry.register(make('b', { c: '^1.0.0' }));
+    registry.register(make('c'));
+
+    const tree = graph.buildTree('a', registry);
+    expect(tree.name).toBe('a');
+    expect(tree.dependencies).toHaveLength(1);
+    expect(tree.dependencies[0].name).toBe('b');
+    expect(tree.dependencies[0].dependencies[0].name).toBe('c');
+  });
+
+  it('should handle missing dependencies', () => {
+    registry.register(make('a', { missing: '^1.0.0' }));
+    const tree = graph.buildTree('a', registry);
+    expect(tree.dependencies[0].name).toBe('missing');
+    expect(tree.dependencies[0].version).toBe('unknown');
+  });
+
+  it('should detect circular dependencies', () => {
+    registry.register(make('a', { b: '^1.0.0' }));
+    registry.register(make('b', { a: '^1.0.0' }));
+
+    const cycles = graph.detectCycles('a', registry);
+    expect(cycles).not.toBeNull();
+    expect(cycles!.length).toBeGreaterThan(0);
+  });
+
+  it('should return null when no cycles', () => {
+    registry.register(make('a', { b: '^1.0.0' }));
+    registry.register(make('b'));
+    expect(graph.detectCycles('a', registry)).toBeNull();
+  });
+
+  it('should check hasCircularDependency', () => {
+    registry.register(make('a', { b: '^1.0.0' }));
+    registry.register(make('b', { a: '^1.0.0' }));
+    expect(graph.hasCircularDependency('a', registry)).toBe(true);
+
+    const reg2 = new PluginRegistry();
+    reg2.register(make('x', { y: '^1.0.0' }));
+    reg2.register(make('y'));
+    expect(graph.hasCircularDependency('x', reg2)).toBe(false);
+  });
+
+  it('should topologically sort dependencies', () => {
+    registry.register(make('a', { b: '^1.0.0', c: '^1.0.0' }));
+    registry.register(make('b', { c: '^1.0.0' }));
+    registry.register(make('c'));
+
+    const sorted = graph.topologicalSort('a', registry);
+    expect(sorted.indexOf('c')).toBeLessThan(sorted.indexOf('b'));
+    expect(sorted.indexOf('b')).toBeLessThan(sorted.indexOf('a'));
+    expect(sorted).toContain('a');
+    expect(sorted).toContain('b');
+    expect(sorted).toContain('c');
+  });
+
+  it('should flatten dependencies', () => {
+    registry.register(make('a', { b: '^1.0.0' }));
+    registry.register(make('b', { c: '^1.0.0' }));
+    registry.register(make('c'));
+
+    const flat = graph.flattenDependencies('a', registry);
+    expect(flat).toContain('b');
+    expect(flat).toContain('c');
+    expect(flat).not.toContain('a');
+  });
+
+  it('should handle plugin with no dependencies', () => {
+    registry.register(make('solo'));
+    const tree = graph.buildTree('solo', registry);
+    expect(tree.dependencies).toHaveLength(0);
+    expect(graph.flattenDependencies('solo', registry)).toEqual([]);
+    expect(graph.topologicalSort('solo', registry)).toEqual(['solo']);
+  });
+});
