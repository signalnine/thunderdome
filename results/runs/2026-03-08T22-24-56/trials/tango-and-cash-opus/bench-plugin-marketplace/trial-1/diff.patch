+
+const makeManifest = (overrides: Partial<PluginManifest> = {}): PluginManifest => ({
+  name: 'test-plugin',
+  version: '1.0.0',
+  description: 'A test plugin',
+  author: 'tester',
+  dependencies: {},
+  entryPoint: '"hello"',
+  permissions: [],
+  ...overrides,
+});
+
+describe('PluginRegistry', () => {
+  let registry: PluginRegistry;
+
+  beforeEach(() => {
+    registry = new PluginRegistry();
+  });
+
+  it('should register and retrieve a plugin', () => {
+    const m = makeManifest();
+    registry.register(m);
+    const result = registry.get('test-plugin');
+    expect(result).toEqual(m);
+  });
+
+  it('should return null for unknown plugin', () => {
+    expect(registry.get('nope')).toBeNull();
+  });
+
+  it('should get latest version', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    registry.register(makeManifest({ version: '1.5.0' }));
+    expect(registry.get('test-plugin')!.version).toBe('2.0.0');
+  });
+
+  it('should get a specific version', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    expect(registry.getVersion('test-plugin', '1.0.0')!.version).toBe('1.0.0');
+    expect(registry.getVersion('test-plugin', '3.0.0')).toBeNull();
+    expect(registry.getVersion('unknown', '1.0.0')).toBeNull();
+  });
+
+  it('should list latest version per plugin', () => {
+    registry.register(makeManifest({ name: 'a', version: '1.0.0' }));
+    registry.register(makeManifest({ name: 'a', version: '2.0.0' }));
+    registry.register(makeManifest({ name: 'b', version: '3.0.0' }));
+    const list = registry.list();
+    expect(list).toHaveLength(2);
+    expect(list.find(p => p.name === 'a')!.version).toBe('2.0.0');
+  });
+
+  it('should search by name and description', () => {
+    registry.register(makeManifest({ name: 'foo-bar', description: 'xyz' }));
+    registry.register(makeManifest({ name: 'baz', description: 'has foo in desc' }));
+    registry.register(makeManifest({ name: 'qux', description: 'nothing' }));
+    expect(registry.search('foo')).toHaveLength(2);
+    expect(registry.search('QUX')).toHaveLength(1);
+  });
+
+  it('should remove a specific version', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '2.0.0' }));
+    expect(registry.remove('test-plugin', '1.0.0')).toBe(true);
+    expect(registry.listVersions('test-plugin')).toEqual(['2.0.0']);
+    expect(registry.remove('test-plugin', '1.0.0')).toBe(false);
+    expect(registry.remove('nope', '1.0.0')).toBe(false);
+  });
+
+  it('should remove plugin entry when last version removed', () => {
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.remove('test-plugin', '1.0.0');
+    expect(registry.get('test-plugin')).toBeNull();
+  });
+
+  it('should list versions sorted', () => {
+    registry.register(makeManifest({ version: '2.0.0' }));
+    registry.register(makeManifest({ version: '1.0.0' }));
+    registry.register(makeManifest({ version: '1.5.0' }));
+    expect(registry.listVersions('test-plugin')).toEqual(['1.0.0', '1.5.0', '2.0.0']);
+    expect(registry.listVersions('nope')).toEqual([]);
+  });
+
+  it('should update a plugin manifest', () => {
+    registry.register(makeManifest());
+    registry.update('test-plugin', '1.0.0', { description: 'updated' });
+    expect(registry.getVersion('test-plugin', '1.0.0')!.description).toBe('updated');
+  });
+
+  it('should throw on update for unknown plugin', () => {
+    expect(() => registry.update('nope', '1.0.0', {})).toThrow();
+    registry.register(makeManifest());
+    expect(() => registry.update('test-plugin', '9.0.0', {})).toThrow();
+  });
+});
