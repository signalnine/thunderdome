+++ b/src/index.ts
@@ -0,0 +1,82 @@
+import type {
+  PluginManifest,
+  RegistryService,
+  ResolverService,
+  RunnerService,
+  ReviewService,
+  DepsService,
+  ResolvedVersion,
+  SandboxResult,
+  VersionConstraint,
+} from './types.js';
+import { PluginRegistry } from './registry/index.js';
+import { VersionResolver } from './resolver/index.js';
+import { SandboxRunner } from './runner/index.js';
+import { ReviewSystem } from './reviews/index.js';
+import { DependencyGraph } from './deps/index.js';
+
+export interface Marketplace {
+  registry: RegistryService;
+  resolver: ResolverService;
+  runner: RunnerService;
+  reviews: ReviewService;
+  deps: DepsService;
+  installPlugin(manifest: PluginManifest): Promise<{
+    resolvedDependencies: ResolvedVersion[];
+    executionResult: SandboxResult;
+  }>;
+}
+
+export function createMarketplace(): Marketplace {
+  const registry = new PluginRegistry();
+  const resolver = new VersionResolver();
+  const runner = new SandboxRunner();
+  const reviews = new ReviewSystem();
+  const deps = new DependencyGraph();
+
+  return {
+    registry,
+    resolver,
+    runner,
+    reviews,
+    deps,
+
+    async installPlugin(manifest: PluginManifest) {
+      // Validate required fields
+      if (!manifest.name || !manifest.version || !manifest.entryPoint) {
+        throw new Error('Plugin manifest must have name, version, and entryPoint');
+      }
+
+      // Register the plugin
+      registry.register(manifest);
+
+      // Resolve dependency versions
+      let resolvedDependencies: ResolvedVersion[] = [];
+      const depEntries = Object.entries(manifest.dependencies);
+      if (depEntries.length > 0) {
+        const constraints: VersionConstraint[] = depEntries.map(([name, range]) => ({ name, range }));
+        const available: Record<string, string[]> = {};
+        for (const [depName] of depEntries) {
+          available[depName] = registry.listVersions(depName);
+        }
+        resolvedDependencies = resolver.resolve(constraints, available);
+      }
+
+      // Check for circular dependencies
+      if (deps.hasCircularDependency(manifest.name, registry)) {
+        throw new Error(`Circular dependency detected for plugin ${manifest.name}`);
+      }
+
+      // Execute plugin entry point in sandbox
+      const executionResult = await runner.execute(manifest.entryPoint);
+
+      return { resolvedDependencies, executionResult };
+    },
+  };
+}
+
+export { PluginRegistry } from './registry/index.js';
+export { VersionResolver } from './resolver/index.js';
+export { SandboxRunner } from './runner/index.js';
+export { ReviewSystem } from './reviews/index.js';
+export { DependencyGraph } from './deps/index.js';
