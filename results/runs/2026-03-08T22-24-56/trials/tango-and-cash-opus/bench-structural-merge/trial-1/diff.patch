d: Record<string, object> = {};\n    const conflicts: Conflict[] = [];\n\n    for (const docId of allDocIds) {\n      const baseEntry = baseDocsMap.get(docId);\n      const sourceEntry = sourceBranchData.docs.get(docId);\n      const targetEntry = targetBranchData.docs.get(docId);\n\n      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;\n      const sourceContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : null;\n      const targetContent = targetEntry && !targetEntry.deleted ? targetEntry.content : null;\n\n      const baseJson = JSON.stringify(baseContent);\n      const sourceJson = JSON.stringify(sourceContent);\n      const targetJson = JSON.stringify(targetContent);\n\n      // If neither side changed this doc, skip\n      if (sourceJson === baseJson && targetJson === baseJson) {\n        continue;\n      }\n\n      // If only source changed\n      if (targetJson === baseJson && sourceJson !== baseJson) {\n        if (sourceContent !== null) {\n          merged[docId] = deepClone(sourceContent);\n        }\n        continue;\n      }\n\n      // If only target changed\n      if (sourceJson === baseJson && targetJson !== baseJson) {\n        if (targetContent !== null) {\n          merged[docId] = deepClone(targetContent);\n        }\n        continue;\n      }\n\n      // Both sides changed - need three-way merge at field level\n      const baseObj = baseContent ?? {};\n      const sourceObj = sourceContent ?? {};\n      const targetObj = targetContent ?? {};\n\n      // If both deleted, skip\n      if (sourceContent === null && targetContent === null) {\n        continue;\n      }\n\n      // If one deleted, one modified -> conflict at root level\n      if (sourceContent === null && targetContent !== null) {\n        // source deleted, target modified\n        // Check if target actually changed from base\n        if (targetJson !== baseJson) {\n          conflicts.push({\n            documentId: docId,\n      