+import { describe, it, expect, beforeEach } from 'vitest';
+import { DocumentStore } from '../index.js';
+
+describe('DocumentStore', () => {
+  let store: DocumentStore;
+
+  beforeEach(() => {
+    store = new DocumentStore();
+  });
+
+  describe('CRUD operations', () => {
+    it('should create and get a document', () => {
+      store.create('doc1', { name: 'Alice' });
+      expect(store.get('doc1')).toEqual({ name: 'Alice' });
+    });
+
+    it('should throw when creating duplicate id', () => {
+      store.create('doc1', { name: 'Alice' });
+      expect(() => store.create('doc1', { name: 'Bob' })).toThrow();
+    });
+
+    it('should throw when getting non-existent document', () => {
+      expect(() => store.get('nonexistent')).toThrow();
+    });
+
+    it('should update a document', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.update('doc1', { name: 'Bob' });
+      expect(store.get('doc1')).toEqual({ name: 'Bob' });
+    });
+
+    it('should throw when updating non-existent document', () => {
+      expect(() => store.update('nonexistent', { name: 'Alice' })).toThrow();
+    });
+
+    it('should delete a document', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.delete('doc1');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should throw when deleting non-existent document', () => {
+      expect(() => store.delete('nonexistent')).toThrow();
+    });
+
+    it('should throw when deleting already deleted document', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.delete('doc1');
+      expect(() => store.delete('doc1')).toThrow();
+    });
+
+    it('should deep clone on create', () => {
+      const obj = { name: 'Alice', nested: { x: 1 } };
+      store.create('doc1', obj);
+      obj.nested.x = 999;
+      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });
+    });
+
+    it('should deep clone on get', () => {
+      store.create('doc1', { name: 'Alice', nested: { x: 1 } });
+      const result = store.get('doc1') as any;
+      result.nested.x = 999;
+      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });
+    });
+
+    it('should deep clone on update', () => {
+      store.create('doc1', { name: 'Alice' });
+      const obj = { name: 'Bob', nested: { x: 1 } };
+      store.update('doc1', obj);
+      obj.nested.x = 999;
+      expect(store.get('doc1')).toEqual({ name: 'Bob', nested: { x: 1 } });
+    });
+  });
+
+  describe('Version history', () => {
+    it('should create versions on create and update', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.update('doc1', { name: 'Bob' });
+      store.update('doc1', { name: 'Charlie' });
+
+      const history = store.getHistory('doc1');
+      expect(history).toHaveLength(3);
+      expect(history[0].content).toEqual({ name: 'Alice' });
+      expect(history[1].content).toEqual({ name: 'Bob' });
+      expect(history[2].content).toEqual({ name: 'Charlie' });
+    });
+
+    it('should return versions in chronological order', () => {
+      store.create('doc1', { v: 1 });
+      store.update('doc1', { v: 2 });
+      store.update('doc1', { v: 3 });
+
+      const history = store.getHistory('doc1');
+      for (let i = 1; i < history.length; i++) {
+        expect(history[i].timestamp).toBeGreaterThanOrEqual(history[i - 1].timestamp);
+      }
+    });
+
+    it('should get a specific version', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.update('doc1', { name: 'Bob' });
+
+      const history = store.getHistory('doc1');
+      const v1Content = store.getVersion('doc1', history[0].id);
+      expect(v1Content).toEqual({ name: 'Alice' });
+    });
+
+    it('should throw for non-existent version', () => {
+      store.create('doc1', { name: 'Alice' });
+      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();
+    });
+
+    it('should throw getHistory for non-existent doc', () => {
+      expect(() => store.getHistory('nonexistent')).toThrow();
+    });
+
+    it('should deep clone version content', () => {
+      store.create('doc1', { nested: { x: 1 } });
+      const history = store.getHistory('doc1');
+      (history[0].content as any).nested.x = 999;
+      expect(store.getHistory('doc1')[0].content).toEqual({ nested: { x: 1 } });
+    });
+  });
+
+  describe('Branching', () => {
+    it('should default to main branch', () => {
+      expect(store.getBranch()).toBe('main');
+    });
+
+    it('should list branches', () => {
+      expect(store.listBranches()).toEqual(['main']);
+    });
+
+    it('should create and switch to a branch', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      expect(store.getBranch()).toBe('feature');
+      expect(store.listBranches()).toContain('feature');
+    });
+
+    it('should isolate changes between branches', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+
+      store.update('doc1', { name: 'Bob' });
+      expect(store.get('doc1')).toEqual({ name: 'Bob' });
+
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ name: 'Alice' });
+    });
+
+    it('should create branch from specified branch', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.update('doc1', { name: 'Bob' });
+
+      // Create branch from feature, not from main
+      store.switchBranch('main');
+      store.createBranch('feature2', 'feature');
+      store.switchBranch('feature2');
+      expect(store.get('doc1')).toEqual({ name: 'Bob' });
+    });
+
+    it('should throw when creating duplicate branch', () => {
+      store.createBranch('feature');
+      expect(() => store.createBranch('feature')).toThrow();
+    });
+
+    it('should throw when switching to non-existent branch', () => {
+      expect(() => store.switchBranch('nonexistent')).toThrow();
+    });
+
+    it('should isolate new documents between branches', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { name: 'Alice' });
+
+      store.switchBranch('main');
+      expect(() => store.get('doc1')).toThrow();
+    });
+
+    it('should isolate deletes between branches', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.delete('doc1');
+
+      expect(() => store.get('doc1')).toThrow();
+      store.switchBranch('main');
+      expect(store.get('doc1')).toEqual({ name: 'Alice' });
+    });
+  });
+
+  describe('Merging', () => {
+    it('should merge non-conflicting changes', () => {
+      store.create('doc1', { a: 1, b: 2, c: 3 });
+      store.createBranch('feature');
+
+      // Change on feature branch
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10, b: 2, c: 3 });
+
+      // Change different field on main
+      store.switchBranch('main');
+      store.update('doc1', { a: 1, b: 20, c: 3 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(result.merged['doc1']).toEqual({ a: 10, b: 20, c: 3 });
+      expect(store.get('doc1')).toEqual({ a: 10, b: 20, c: 3 });
+    });
+
+    it('should detect conflicts when both sides change same field differently', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100, b: 2 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 200, b: 2 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts).toHaveLength(1);
+      expect(result.conflicts[0]).toEqual({
+        documentId: 'doc1',
+        path: 'a',
+        base: 1,
+        ours: 200,
+        theirs: 100,
+      });
+      // current branch unchanged
+      expect(store.get('doc1')).toEqual({ a: 200, b: 2 });
+    });
+
+    it('should not conflict when both sides change same field to same value', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 42, b: 2 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 42, b: 2 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+    });
+
+    it('should merge new documents from source branch', () => {
+      store.createBranch('feature');
+      store.switchBranch('feature');
+      store.create('doc1', { name: 'Alice' });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ name: 'Alice' });
+      expect(store.get('doc1')).toEqual({ name: 'Alice' });
+    });
+
+    it('should handle merge with no changes (fast-forward)', () => {
+      store.create('doc1', { name: 'Alice' });
+      store.createBranch('feature');
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(Object.keys(result.merged)).toHaveLength(0);
+    });
+
+    it('should merge changes to different documents independently', () => {
+      store.create('doc1', { a: 1 });
+      store.create('doc2', { x: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 10 });
+
+      store.switchBranch('main');
+      store.update('doc2', { x: 10 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.conflicts).toHaveLength(0);
+      expect(store.get('doc1')).toEqual({ a: 10 });
+      expect(store.get('doc2')).toEqual({ x: 10 });
+    });
+
+    it('should handle nested field merges', () => {
+      store.create('doc1', { nested: { a: 1, b: 2 } });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { nested: { a: 10, b: 2 } });
+
+      store.switchBranch('main');
+      store.update('doc1', { nested: { a: 1, b: 20 } });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(result.merged['doc1']).toEqual({ nested: { a: 10, b: 20 } });
+    });
+
+    it('should report nested field conflicts with dot-separated paths', () => {
+      store.create('doc1', { nested: { a: 1 } });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { nested: { a: 100 } });
+
+      store.switchBranch('main');
+      store.update('doc1', { nested: { a: 200 } });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      expect(result.conflicts[0].path).toBe('nested.a');
+      expect(result.conflicts[0].base).toBe(1);
+      expect(result.conflicts[0].ours).toBe(200);
+      expect(result.conflicts[0].theirs).toBe(100);
+    });
+
+    it('should use "ours" for merged output when there are conflicts', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100, b: 200 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 300, b: 400 });
+
+      const result = store.merge('feature');
+      expect(result.applied).toBe(false);
+      // merged uses "ours" (target/main branch values)
+      expect(result.merged['doc1']).toEqual({ a: 300, b: 400 });
+    });
+
+    it('should not apply changes to branch when there are conflicts', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 100 });
+
+      store.switchBranch('main');
+      store.update('doc1', { a: 200 });
+
+      const before = store.get('doc1');
+      store.merge('feature');
+      expect(store.get('doc1')).toEqual(before);
+    });
+
+    it('should handle merging when source adds a new field', () => {
+      store.create('doc1', { a: 1 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1, b: 2 });
+
+      store.switchBranch('main');
+      const result = store.merge('feature');
+      expect(result.applied).toBe(true);
+      expect(store.get('doc1')).toEqual({ a: 1, b: 2 });
+    });
+
+    it('should handle merging when source removes a field', () => {
+      store.create('doc1', { a: 1, b: 2 });
+      store.createBranch('feature');
+
+      store.switchBranch('feature');
+      store.update('doc1', { a: 1 });
