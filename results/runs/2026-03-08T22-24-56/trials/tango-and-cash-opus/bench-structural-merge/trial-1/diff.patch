 });\n      store.delete('doc1');\n      expect(() => store.delete('doc1')).toThrow();\n    });\n\n    it('should deep clone on create', () => {\n      const obj = { name: 'Alice', nested: { x: 1 } };\n      store.create('doc1', obj);\n      obj.nested.x = 999;\n      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });\n    });\n\n    it('should deep clone on get', () => {\n      store.create('doc1', { name: 'Alice', nested: { x: 1 } });\n      const result = store.get('doc1') as any;\n      result.nested.x = 999;\n      expect(store.get('doc1')).toEqual({ name: 'Alice', nested: { x: 1 } });\n    });\n\n    it('should deep clone on update', () => {\n      store.create('doc1', { name: 'Alice' });\n      const obj = { name: 'Bob', nested: { x: 1 } };\n      store.update('doc1', obj);\n      obj.nested.x = 999;\n      expect(store.get('doc1')).toEqual({ name: 'Bob', nested: { x: 1 } });\n    });\n  });\n\n  describe('Version history', () => {\n    it('should create versions on create and update', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.update('doc1', { name: 'Bob' });\n      store.update('doc1', { name: 'Charlie' });\n\n      const history = store.getHistory('doc1');\n      expect(history).toHaveLength(3);\n      expect(history[0].content).toEqual({ name: 'Alice' });\n      expect(history[1].content).toEqual({ name: 'Bob' });\n      expect(history[2].content).toEqual({ name: 'Charlie' });\n    });\n\n    it('should return versions in chronological order', () => {\n      store.create('doc1', { v: 1 });\n      store.update('doc1', { v: 2 });\n      store.update('doc1', { v: 3 });\n\n      const history = store.getHistory('doc1');\n      for (let i = 1; i < history.length; i++) {\n        expect(history[i].timestamp).toBeGreaterThanOrEqual(history[i - 1].timestamp);\n      }\n    });\n\n    it('should get a specific version', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.update('doc1', { name: 'Bob' });\n\n      const history = store.getHistory('doc1');\n      const v1Content = store.getVersion('doc1', history[0].id);\n      expect(v1Content).toEqual({ name: 'Alice' });\n    });\n\n    it('should throw for non-existent version', () => {\n      store.create('doc1', { name: 'Alice' });\n      expect(() => store.getVersion('doc1', 'nonexistent')).toThrow();\n    });\n\n    it('should throw getHistory for non-existent doc', () => {\n      expect(() => store.getHistory('nonexistent')).toThrow();\n    });\n\n    it('should deep clone version content', () => {\n      store.create('doc1', { nested: { x: 1 } });\n      const history = store.getHistory('doc1');\n      (history[0].content as any).nested.x = 999;\n      expect(store.getHistory('doc1')[0].content).toEqual({ nested: { x: 1 } });\n    });\n  });\n\n  describe('Branching', () => {\n    it('should default to main branch', () => {\n      expect(store.getBranch()).toBe('main');\n    });\n\n    it('should list branches', () => {\n      expect(store.listBranches()).toEqual(['main']);\n    });\n\n    it('should create and switch to a branch', () => {\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      expect(store.getBranch()).toBe('feature');\n      expect(store.listBranches()).toContain('feature');\n    });\n\n    it('should isolate changes between branches', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n\n      store.update('doc1', { name: 'Bob' });\n      expect(store.get('doc1')).toEqual({ name: 'Bob' });\n\n      store.switchBranch('main');\n      expect(store.get('doc1')).toEqual({ name: 'Alice' });\n    });\n\n    it('should create branch from specified branch', () => {\n      store.create('doc1', { name: 'Alice' });\n      store.createBranch('feature');\n      store.switchBranch('feature');\n      store.update('doc1', { name: 'Bob' });\n\n      // Create branch from feature, not from main\n  