+++ b/src/index.ts
@@ -0,0 +1,430 @@
+export interface Version {
+  id: string;
+  timestamp: number;
+  content: object;
+}
+
+export interface Conflict {
+  documentId: string;
+  path: string;
+  base: any;
+  ours: any;
+  theirs: any;
+}
+
+export interface MergeResult {
+  merged: Record<string, object>;
+  conflicts: Conflict[];
+  applied: boolean;
+}
+
+interface DocEntry {
+  content: object;
+  deleted: boolean;
+  versions: Version[];
+}
+
+interface BranchData {
+  docs: Map<string, DocEntry>;
+  parent?: string;
+  snapshot?: Map<string, DocEntry>; // snapshot of parent at branch creation time
+}
+
+let versionCounter = 0;
+
+function generateVersionId(): string {
+  return `v_${++versionCounter}_${Date.now()}`;
+}
+
+function deepClone<T>(obj: T): T {
+  return JSON.parse(JSON.stringify(obj));
+}
+
+function cloneDocEntry(entry: DocEntry): DocEntry {
+  return {
+    content: deepClone(entry.content),
+    deleted: entry.deleted,
+    versions: entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    })),
+  };
+}
+
+function cloneDocsMap(docs: Map<string, DocEntry>): Map<string, DocEntry> {
+  const result = new Map<string, DocEntry>();
+  for (const [id, entry] of docs) {
+    result.set(id, cloneDocEntry(entry));
+  }
+  return result;
+}
+
+function diffPaths(
+  base: any,
+  obj: any,
+  prefix: string,
+  result: Map<string, { base: any; current: any }>
+): void {
+  const baseKeys = base !== null && base !== undefined && typeof base === 'object' ? Object.keys(base) : [];
+  const objKeys = obj !== null && obj !== undefined && typeof obj === 'object' ? Object.keys(obj) : [];
+  const allKeys = new Set([...baseKeys, ...objKeys]);
+
+  for (const key of allKeys) {
+    const path = prefix ? `${prefix}.${key}` : key;
+    const baseVal = base !== null && base !== undefined && typeof base === 'object' ? base[key] : undefined;
+    const objVal = obj !== null && obj !== undefined && typeof obj === 'object' ? obj[key] : undefined;
+
+    if (
+      baseVal !== null && baseVal !== undefined && typeof baseVal === 'object' && !Array.isArray(baseVal) &&
+      objVal !== null && objVal !== undefined && typeof objVal === 'object' && !Array.isArray(objVal)
+    ) {
+      diffPaths(baseVal, objVal, path, result);
+    } else {
+      if (JSON.stringify(baseVal) !== JSON.stringify(objVal)) {
+        result.set(path, { base: baseVal, current: objVal });
+      }
+    }
+  }
+}
+
+function setAtPath(obj: any, path: string, value: any): void {
+  const parts = path.split('.');
+  let current = obj;
+  for (let i = 0; i < parts.length - 1; i++) {
+    if (current[parts[i]] === undefined || current[parts[i]] === null || typeof current[parts[i]] !== 'object') {
+      current[parts[i]] = {};
+    }
+    current = current[parts[i]];
+  }
+  if (value === undefined) {
+    delete current[parts[parts.length - 1]];
+  } else {
+    current[parts[parts.length - 1]] = value;
+  }
+}
+
+export class DocumentStore {
+  private branches: Map<string, BranchData> = new Map();
+  private currentBranch: string = 'main';
+
+  constructor() {
+    this.branches.set('main', { docs: new Map() });
+  }
+
+  private getBranchData(name?: string): BranchData {
+    const branch = this.branches.get(name ?? this.currentBranch);
+    if (!branch) {
+      throw new Error(`Branch "${name ?? this.currentBranch}" does not exist`);
+    }
+    return branch;
+  }
+
+  create(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const existing = branch.docs.get(id);
+    if (existing && !existing.deleted) {
+      throw new Error(`Document "${id}" already exists`);
+    }
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    branch.docs.set(id, {
+      content: deepClone(content),
+      deleted: false,
+      versions: existing ? [...existing.versions, version] : [version],
+    });
+  }
+
+  get(id: string): object {
+    const branch = this.getBranchData();
+    const entry = branch.docs.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return deepClone(entry.content);
+  }
+
+  update(id: string, content: object): void {
+    const branch = this.getBranchData();
+    const entry = branch.docs.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version: Version = {
+      id: generateVersionId(),
+      timestamp: Date.now(),
+      content: deepClone(content),
+    };
+    entry.content = deepClone(content);
+    entry.versions.push(version);
+  }
+
+  delete(id: string): void {
+    const branch = this.getBranchData();
+    const entry = branch.docs.get(id);
+    if (!entry || entry.deleted) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    entry.deleted = true;
+  }
+
+  getHistory(id: string): Version[] {
+    const branch = this.getBranchData();
+    const entry = branch.docs.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    return entry.versions.map(v => ({
+      id: v.id,
+      timestamp: v.timestamp,
+      content: deepClone(v.content),
+    }));
+  }
+
+  getVersion(id: string, versionId: string): object {
+    const branch = this.getBranchData();
+    const entry = branch.docs.get(id);
+    if (!entry) {
+      throw new Error(`Document "${id}" does not exist`);
+    }
+    const version = entry.versions.find(v => v.id === versionId);
+    if (!version) {
+      throw new Error(`Version "${versionId}" does not exist for document "${id}"`);
+    }
+    return deepClone(version.content);
+  }
+
+  createBranch(name: string, fromBranch?: string): void {
+    if (this.branches.has(name)) {
+      throw new Error(`Branch "${name}" already exists`);
+    }
+    const sourceName = fromBranch ?? this.currentBranch;
+    const source = this.getBranchData(sourceName);
+    const clonedDocs = cloneDocsMap(source.docs);
+    this.branches.set(name, {
+      docs: clonedDocs,
+      parent: sourceName,
+      snapshot: cloneDocsMap(source.docs),
+    });
+  }
+
+  switchBranch(name: string): void {
+    if (!this.branches.has(name)) {
+      throw new Error(`Branch "${name}" does not exist`);
+    }
+    this.currentBranch = name;
+  }
+
+  getBranch(): string {
+    return this.currentBranch;
+  }
+
+  listBranches(): string[] {
+    return Array.from(this.branches.keys());
+  }
+
+  merge(sourceBranch: string): MergeResult {
+    const targetName = this.currentBranch;
+    if (sourceBranch === targetName) {
+      throw new Error('Cannot merge a branch into itself');
+    }
+
+    const sourceBranchData = this.getBranchData(sourceBranch);
+    const targetBranchData = this.getBranchData(targetName);
+
+    // Find common ancestor: the snapshot stored when the source branch was created
+    // If source was branched from target (or vice versa), use that snapshot
+    let baseDocsMap: Map<string, DocEntry>;
+
+    if (sourceBranchData.parent === targetName && sourceBranchData.snapshot) {
+      baseDocsMap = sourceBranchData.snapshot;
+    } else if (targetBranchData.parent === sourceBranch && targetBranchData.snapshot) {
+      baseDocsMap = targetBranchData.snapshot;
+    } else {
+      // Fallback: empty base (treat everything as new)
+      baseDocsMap = new Map();
+    }
+
+    const allDocIds = new Set<string>();
+    for (const id of sourceBranchData.docs.keys()) allDocIds.add(id);
+    for (const id of targetBranchData.docs.keys()) allDocIds.add(id);
+    for (const id of baseDocsMap.keys()) allDocIds.add(id);
+
+    const merged: Record<string, object> = {};
+    const conflicts: Conflict[] = [];
+
+    for (const docId of allDocIds) {
+      const baseEntry = baseDocsMap.get(docId);
+      const sourceEntry = sourceBranchData.docs.get(docId);
+      const targetEntry = targetBranchData.docs.get(docId);
+
+      const baseContent = baseEntry && !baseEntry.deleted ? baseEntry.content : null;
+      const sourceContent = sourceEntry && !sourceEntry.deleted ? sourceEntry.content : null;
+      const targetContent = targetEntry && !targetEntry.deleted ? targetEntry.content : null;
+
+      const baseJson = JSON.stringify(baseContent);
+      const sourceJson = JSON.stringify(sourceContent);
+      const targetJson = JSON.stringify(targetContent);
+
+      // If neither side changed this doc, skip
+      if (sourceJson === baseJson && targetJson === baseJson) {
+        continue;
+      }
+
+      // If only source changed
+      if (targetJson === baseJson && sourceJson !== baseJson) {
+        if (sourceContent !== null) {
+          merged[docId] = deepClone(sourceContent);
+        }
+        continue;
+      }
+
+      // If only target changed
+      if (sourceJson === baseJson && targetJson !== baseJson) {
+        if (targetContent !== null) {
+          merged[docId] = deepClone(targetContent);
+        }
+        continue;
+      }
+
+      // Both sides changed - need three-way merge at field level
+      const baseObj = baseContent ?? {};
+      const sourceObj = sourceContent ?? {};
+      const targetObj = targetContent ?? {};
+
+      // If both deleted, skip
+      if (sourceContent === null && targetContent === null) {
+        continue;
+      }
+
+      // If one deleted, one modified -> conflict at root level
+      if (sourceContent === null && targetContent !== null) {
+        // source deleted, target modified
+        // Check if target actually changed from base
+        if (targetJson !== baseJson) {
+          conflicts.push({
+            documentId: docId,
+            path: '',
+            base: baseContent !== null ? deepClone(baseContent) : undefined,
+            ours: deepClone(targetContent),
+            theirs: null,
+          });
+          merged[docId] = deepClone(targetContent); // ours wins
+        }
+        continue;
+      }
+
+      if (sourceContent !== null && targetContent === null) {
+        // source modified, target deleted
+        if (sourceJson !== baseJson) {
+          conflicts.push({
+            documentId: docId,
+            path: '',
+            base: baseContent !== null ? deepClone(baseContent) : undefined,
+            ours: null,
+            theirs: deepClone(sourceContent),
+          });
+          // ours is delete, but we still produce merged content
+          merged[docId] = deepClone(sourceContent);
+        }
+        continue;
+      }
+
+      // Both modified the same doc - field-level merge
+      const sourceDiffs = new Map<string, { base: any; current: any }>();
+      const targetDiffs = new Map<string, { base: any; current: any }>();
+      diffPaths(baseObj, sourceObj, '', sourceDiffs);
+      diffPaths(baseObj, targetObj, '', targetDiffs);
+
+      // Start with a deep clone of base, apply non-conflicting changes
+      const mergedDoc = deepClone(baseObj) as any;
+
+      // Apply source-only changes
+      for (const [path, diff] of sourceDiffs) {
+        if (!targetDiffs.has(path)) {
+          setAtPath(mergedDoc, path, deepClone(diff.current));
+        }
+      }
+
+      // Apply target-only changes
+      for (const [path, diff] of targetDiffs) {
+        if (!sourceDiffs.has(path)) {
+          setAtPath(mergedDoc, path, deepClone(diff.current));
+        }
+      }
+
+      // Handle fields changed by both
+      for (const [path, sourceDiff] of sourceDiffs) {
+        const targetDiff = targetDiffs.get(path);
+        if (targetDiff) {
+          if (JSON.stringify(sourceDiff.current) === JSON.stringify(targetDiff.current)) {
+            // Same change, no conflict
+            setAtPath(mergedDoc, path, deepClone(sourceDiff.current));
+          } else {
+            // Conflict! Use "ours" (target) for merged output
+            setAtPath(mergedDoc, path, deepClone(targetDiff.current));
+            conflicts.push({
+              documentId: docId,
+              path,
+              base: deepClone(sourceDiff.base),
+              ours: deepClone(targetDiff.current),
+              theirs: deepClone(sourceDiff.current),
+            });
+          }
+        }
+      }
+
+      merged[docId] = mergedDoc;
+    }
+
+    const applied = conflicts.length === 0;
+
+    if (applied) {
+      // Apply merged content to target branch
+      for (const [docId, content] of Object.entries(merged)) {
+        const existingEntry = targetBranchData.docs.get(docId);
+        if (existingEntry) {
+          const version: Version = {
+            id: generateVersionId(),
+            timestamp: Date.now(),
+            content: deepClone(content),
+          };
+          existingEntry.content = deepClone(content);
+          existingEntry.deleted = false;
+          existingEntry.versions.push(version);
+        } else {
+          const version: Version = {
+            id: generateVersionId(),
+            timestamp: Date.now(),
+            content: deepClone(content),
+          };
+          targetBranchData.docs.set(docId, {
+            content: deepClone(content),
+            deleted: false,
+            versions: [version],
+          });
+        }
+      }
+
+      // Handle documents deleted on source but not changed on target
+      for (const docId of allDocIds) {
+        const sourceEntry = sourceBranchData.docs.get(docId);
+        const targetEntry = targetBranchData.docs.get(docId);
+        const baseEntry = baseDocsMap.get(docId);
+        if (
+          sourceEntry?.deleted &&
+          baseEntry && !baseEntry.deleted &&
+          targetEntry && !targetEntry.deleted &&
+          JSON.stringify(targetEntry.content) === JSON.stringify(baseEntry.content)
+        ) {
+          targetEntry.deleted = true;
+        }
+      }
+    }
+
+    return { merged, conflicts, applied };
+  }
+}
