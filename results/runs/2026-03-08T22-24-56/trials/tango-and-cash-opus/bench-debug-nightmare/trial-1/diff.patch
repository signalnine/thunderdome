+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Nhyc5Yvd8ijysjuodeXhaF","type":"tool_result","content":"     1→export interface OrderEvent {\n     2→  orderId: string;\n     3→  timestamp: number;\n     4→}\n     5→\n     6→export interface OrderCreatedEvent extends OrderEvent {\n     7→  items: Array<{ productId: string; quantity: number; unitPrice: number }>;\n     8→  customerId: string;\n     9→}\n    10→\n    11→export interface OrderCancelledEvent extends OrderEvent {\n    12→  reason: string;\n    13→}\n    14→\n    15→export interface OrderRefundedEvent extends OrderEvent {\n    16→  amount: number;\n    17→}\n    18→\n    19→export interface PaymentChargedEvent extends OrderEvent {\n    20→  amount: number;\n    21→  paymentMethod: string;\n    22→}\n    23→\n    24→export interface StockReservedEvent extends OrderEvent {\n    25→  items: Array<{ productId: string; quantity: number }>;\n    26→}\n    27→\n    28→export const ORDER_EVENTS = {\n    29→  CREATED: 'order.created',\n    30→  CONFIRMED: 'order.confirmed',\n    31→  CANCELLED: 'order.cancelled',\n    32→  REFUNDED: 'order.refunded',\n    33→  PAYMENT_CHARGED: 'order.payment.charged',\n    34→  STOCK_RESERVED: 'order.stock.reserved',\n    35→  STOCK_RELEASED: 'order.stock.released',\n    36→  NOTIFICATION_SENT: 'order.notification.sent',\n    37→} as const;\n    38→"}]},"parent_tool_use_id":"toolu_01Fz8t97Fnc9vJNSewzg3xKg","session_id":"5e9ccb72-92b1-4105-bb6a-f0ce0b7c984f","uuid":"4d954faf-0416-4df0-b8f4-2c771f977be9"}
