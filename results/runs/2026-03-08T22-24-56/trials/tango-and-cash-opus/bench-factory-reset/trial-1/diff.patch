+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+/**
+ * Solve toggle puzzle over GF(2) using Gaussian elimination.
+ * Each button toggles specific lights. Find minimum set of buttons to press.
+ */
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return target.every((t) => !t) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(2): rows = lights, cols = buttons + 1 (augmented)
+  // matrix[light][button] = 1 if button toggles that light
+  // matrix[light][numButtons] = target[light] ? 1 : 0
+  const matrix: number[][] = [];
+  for (let i = 0; i < numLights; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = target[i] ? 1 : 0;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(2)
+  const pivotCol: number[] = []; // pivotCol[row] = column index of pivot
+  let row = 0;
+  for (let col = 0; col < numButtons && row < numLights; col++) {
+    // Find pivot row
+    let pivotRow = -1;
+    for (let r = row; r < numLights; r++) {
+      if (matrix[r][col] === 1) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    // Swap rows
+    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];
+    pivotCol.push(col);
+
+    // Eliminate
+    for (let r = 0; r < numLights; r++) {
+      if (r !== row && matrix[r][col] === 1) {
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[r][c] ^= matrix[row][c];
+        }
+      }
+    }
+    row++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check for inconsistency: any row with all zeros but augmented = 1
+  for (let r = rank; r < numLights; r++) {
+    if (matrix[r][numButtons] === 1) {
+      return null;
+    }
+  }
+
+  // Identify free variables (columns not in pivotCol)
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotSet.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  // Enumerate all 2^k combinations of free variables
+  const numFree = freeVars.length;
+  let bestSolution: number[] | null = null;
+  let bestCount = Infinity;
+
+  for (let mask = 0; mask < (1 << numFree); mask++) {
+    const solution = new Array(numButtons).fill(0);
+
+    // Set free variables
+    for (let i = 0; i < numFree; i++) {
+      solution[freeVars[i]] = (mask >> i) & 1;
+    }
+
+    // Back-substitute for pivot variables
+    for (let r = rank - 1; r >= 0; r--) {
+      const pc = pivotCol[r];
+      let val = matrix[r][numButtons];
+      for (let c = pc + 1; c < numButtons; c++) {
+        val ^= matrix[r][c] & solution[c];
+      }
+      solution[pc] = val;
+    }
+
+    const pressed: number[] = [];
+    for (let i = 0; i < numButtons; i++) {
+      if (solution[i] === 1) pressed.push(i);
+    }
+
+    const count = pressed.length;
+    if (count < bestCount || (count === bestCount && lexSmaller(pressed, bestSolution!))) {
+      bestCount = count;
+      bestSolution = pressed;
+    }
+  }
+
+  return bestSolution;
+}
+
+function lexSmaller(a: number[], b: number[]): boolean {
+  // Compare two sorted arrays lexicographically
+  // For sets of button indices: smaller set is preferred, then lex order
+  if (a.length !== b.length) return a.length < b.length;
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] < b[i];
+  }
+  return false;
+}
+
+/**
+ * Solve counter puzzle over GF(p) using Gaussian elimination.
+ */
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  if (numButtons === 0) {
+    return lights.every((v) => v === 0) ? [] : null;
+  }
+
+  // Build augmented matrix over GF(p): rows = counters, cols = buttons + 1
+  const matrix: number[][] = [];
+  for (let i = 0; i < numCounters; i++) {
+    const row = new Array(numButtons + 1).fill(0);
+    for (let j = 0; j < numButtons; j++) {
+      if (buttons[j].includes(i)) {
+        row[j] = 1;
+      }
+    }
+    row[numButtons] = ((lights[i] % modulus) + modulus) % modulus;
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(p)
+  const pivotCol: number[] = [];
+  let row = 0;
+  for (let col = 0; col < numButtons && row < numCounters; col++) {
+    // Find pivot row
+    let pivotRow = -1;
+    for (let r = row; r < numCounters; r++) {
+      if (matrix[r][col] !== 0) {
+        pivotRow = r;
+        break;
+      }
+    }
+    if (pivotRow === -1) continue;
+
+    // Swap rows
+    [matrix[row], matrix[pivotRow]] = [matrix[pivotRow], matrix[row]];
+    pivotCol.push(col);
+
+    // Scale pivot row so pivot element = 1
+    const inv = modInverse(matrix[row][col], modulus);
+    for (let c = 0; c <= numButtons; c++) {
+      matrix[row][c] = (matrix[row][c] * inv) % modulus;
+    }
+
+    // Eliminate
+    for (let r = 0; r < numCounters; r++) {
+      if (r !== row && matrix[r][col] !== 0) {
+        const factor = matrix[r][col];
+        for (let c = 0; c <= numButtons; c++) {
+          matrix[r][c] = (((matrix[r][c] - factor * matrix[row][c]) % modulus) + modulus) % modulus;
+        }
+      }
+    }
+    row++;
+  }
+
+  const rank = pivotCol.length;
+
+  // Check consistency
+  for (let r = rank; r < numCounters; r++) {
+    if (matrix[r][numButtons] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free variables
+  const pivotSet = new Set(pivotCol);
+  const freeVars: number[] = [];
+  for (let col = 0; col < numButtons; col++) {
+    if (!pivotSet.has(col)) {
+      freeVars.push(col);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // Enumerate all modulus^numFree combinations
+  let bestSolution: number[] | null = null;
+  let bestTotal = Infinity;
+
+  let totalCombinations = 1;
+  for (let i = 0; i < numFree; i++) {
+    totalCombinations *= modulus;
+  }
+
+  for (let combo = 0; combo < totalCombinations; combo++) {
+    const solution = new Array(numButtons).fill(0);
+
+    // Decode combo into free variable values
+    let tmp = combo;
+    for (let i = numFree - 1; i >= 0; i--) {
+      solution[freeVars[i]] = tmp % modulus;
+      tmp = Math.floor(tmp / modulus);
+    }
+
+    // Back-substitute for pivot variables
+    for (let r = rank - 1; r >= 0; r--) {
+      const pc = pivotCol[r];
+      let val = matrix[r][numButtons];
+      for (let c = pc + 1; c < numButtons; c++) {
+        val = (((val - matrix[r][c] * solution[c]) % modulus) + modulus) % modulus;
+      }
+      solution[pc] = val;
+    }
+
+    const total = solution.reduce((s: number, v: number) => s + v, 0);
+    if (
+      total < bestTotal ||
+      (total === bestTotal && lexSmallerArray(solution, bestSolution!))
+    ) {
+      bestTotal = total;
+      bestSolution = [...solution];
+    }
+  }
+
+  return bestSolution;
+}
+
+function lexSmallerArray(a: number[], b: number[]): boolean {
+  for (let i = 0; i < a.length; i++) {
+    if (a[i] !== b[i]) return a[i] < b[i];
+  }
+  return false;
+}
+
+function modInverse(a: number, m: number): number {
+  // Extended Euclidean algorithm
+  let [old_r, r] = [((a % m) + m) % m, m];
+  let [old_s, s] = [1, 0];
+  while (r !== 0) {
+    const q = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - q * r];
+    [old_s, s] = [s, old_s - q * s];
+  }
+  return ((old_s % m) + m) % m;
+}
