+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+// Helper: simulate toggle and verify
+function verifyToggle(machine: Machine, pressed: number[]): boolean {
+  const state = new Array(machine.target.length).fill(false);
+  for (const b of pressed) {
+    for (const light of machine.buttons[b]) {
+      state[light] = !state[light];
+    }
+  }
+  return state.every((v, i) => v === machine.target[i]);
+}
+
+// Helper: simulate counter and verify
+function verifyCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number,
+  presses: number[]
+): boolean {
+  const state = new Array(lights.length).fill(0);
+  for (let b = 0; b < buttons.length; b++) {
+    for (const counter of buttons[b]) {
+      state[counter] = (state[counter] + presses[b]) % modulus;
+    }
+  }
+  return state.every((v, i) => v === lights[i]);
+}
+
+describe('solveToggle', () => {
+  it('returns null for the spec example (no solution)', () => {
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('returns empty array when all lights already match (all off)', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0], [1], [2]],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('solves single button case', () => {
+    const machine: Machine = {
+      target: [true, false, true],
+      buttons: [[0, 2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+  });
+
+  it('solves two-button case', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 1]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('chooses minimum presses when multiple solutions exist', () => {
+    // Light 0 can be toggled by button 0 or buttons 1+2
+    // Target: light 0 = on
+    // Button 0: [0], Button 1: [0], Button 2: [0]
+    // Solutions: {0}, {1}, {2}, {0,1,2}
+    // Minimum is 1 press, lexicographically smallest is {0}
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0], [0]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('returns lexicographically smallest among tied solutions', () => {
+    // Two buttons both toggle light 0 only; target is on
+    // Solutions with 1 press: {0} or {1}; lex smallest is {0}
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+  });
+
+  it('handles no buttons with non-zero target', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('handles no buttons with zero target', () => {
+    const machine: Machine = {
+      target: [false, false],
+      buttons: [],
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('solves a 3-button identity-like system', () => {
+    const machine: Machine = {
+      target: [true, true, true],
+      buttons: [[0], [1], [2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 1, 2]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('handles overlapping buttons correctly', () => {
+    // Button 0: toggles [0,1], Button 1: toggles [1,2]
+    // Target: [true, false, true] => b0 XOR 0 = 1 (light 0), b0 XOR b1 = 0 (light 1), b1 = 1 (light 2)
+    // b1 = 1, b0 = 1. Check: light0 = 1, light1 = 1 XOR 1 = 0, light2 = 1. Correct!
+    const machine: Machine = {
+      target: [true, false, true],
+      buttons: [[0, 1], [1, 2]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0, 1]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('solves a larger case with 10 buttons', () => {
+    // Identity-like: button i toggles light i
+    const n = 10;
+    const target = new Array(n).fill(true);
+    const btns = Array.from({ length: n }, (_, i) => [i]);
+    const machine: Machine = { target, buttons: btns };
+    const result = solveToggle(machine);
+    expect(result).toEqual(Array.from({ length: n }, (_, i) => i));
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+
+  it('handles empty target', () => {
+    const machine: Machine = {
+      target: [],
+      buttons: [[]], // button that toggles nothing
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('returns null when system is inconsistent', () => {
+    // Two lights, one button that toggles both
+    // Target: [true, false] => b0 = 1 (light 0), b0 = 0 (light 1). Inconsistent.
+    const machine: Machine = {
+      target: [true, false],
+      buttons: [[0, 1]],
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('prefers fewer buttons over lex order', () => {
+    // Button 0: [0,1], Button 1: [0], Button 2: [1]
+    // Target: [true, true]
+    // Solutions: {0} (1 press), {1,2} (2 presses)
+    // Should pick {0}
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]],
+    };
+    const result = solveToggle(machine);
+    expect(result).toEqual([0]);
+    expect(verifyToggle(machine, result!)).toBe(true);
+  });
+});
+
+describe('solveCounter', () => {
+  it('returns empty array when all counters are already 0', () => {
+    const result = solveCounter([0, 0, 0], [[0], [1], [2]], 5);
+    expect(result).toEqual([0, 0, 0]);
+  });
+
+  it('solves simple single-button case', () => {
+    // Button 0 increments counter 0. Target: counter 0 = 3 (mod 5)
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+    expect(verifyCounter([3], [[0]], 5, result!)).toBe(true);
+  });
+
+  it('solves identity system', () => {
+    const result = solveCounter([1, 2, 3], [[0], [1], [2]], 5);
+    expect(result).toEqual([1, 2, 3]);
+    expect(verifyCounter([1, 2, 3], [[0], [1], [2]], 5, result!)).toBe(true);
+  });
+
+  it('returns null for impossible system', () => {
+    // Two counters, one button affecting both. Target: [1, 2] mod 5
+    // b0 = 1 (counter 0), b0 = 2 (counter 1). Inconsistent.
+    const result = solveCounter([1, 2], [[0, 1]], 5);
+    expect(result).toBeNull();
+  });
+
+  it('handles modular arithmetic correctly', () => {
+    // Button 0: [0], target: counter 0 = 0 mod 5
+    // Solution: press 0 times
+    const result = solveCounter([0], [[0]], 5);
+    expect(result).toEqual([0]);
+  });
+
+  it('uses modular inverse correctly', () => {
+    // Button 0 affects counter 0, but what if we have a coefficient > 1?
+    // Two buttons both affect counter 0: target = 3 mod 7
+    // b0 + b1 = 3 (mod 7). Free var b1. Min total: b0=3,b1=0 (total 3) or b0=0,b1=3 (total 3)
+    // Lex smallest with total 3: [0, 3]? No: [0,3] vs [1,2] vs [2,1] vs [3,0]
+    // Total 3: {0,3}, {1,2}, {2,1}, {3,0}. Lex smallest is [0,3].
+    const result = solveCounter([3], [[0], [0]], 7);
+    expect(result).toEqual([0, 3]);
+    expect(verifyCounter([3], [[0], [0]], 7, result!)).toBe(true);
+  });
+
+  it('handles no buttons with non-zero target', () => {
+    expect(solveCounter([1], [], 5)).toBeNull();
+  });
+
+  it('handles no buttons with zero target', () => {
+    expect(solveCounter([0, 0], [], 5)).toEqual([]);
+  });
+
+  it('chooses minimum total presses', () => {
+    // One counter, two buttons, both affect counter 0
+    // Target: 1 mod 5. b0+b1 = 1.
+    // Solutions: (0,1), (1,0), (2,4), (3,3), (4,2)
+    // Min total = 1: (0,1) and (1,0). Lex smallest: [0,1]
+    const result = solveCounter([1], [[0], [0]], 5);
+    expect(result).toEqual([0, 1]);
+    expect(verifyCounter([1], [[0], [0]], 5, result!)).toBe(true);
+  });
+
+  it('solves with prime modulus 97', () => {
+    const result = solveCounter([50], [[0]], 97);
+    expect(result).toEqual([50]);
+    expect(verifyCounter([50], [[0]], 97, result!)).toBe(true);
+  });
+
+  it('solves overlapping buttons', () => {
+    // Button 0: [0,1], Button 1: [1,2]
+    // Target: [1, 0, 1] mod 3
+    // Equations: b0 = 1, b0+b1 = 0, b1 = 1 (all mod 3)
+    // b0 = 1, b1 = 1. Check: b0+b1 = 2 mod 3 ≠ 0. Hmm.
+    // Actually: b0 = 1 (counter 0), b0+b1 ≡ 0 (counter 1), b1 ≡ 1 (counter 2)
+    // b0=1, b1=1. Counter 1: 1+1=2 ≠ 0 mod 3. No solution!
+    // Let me pick a solvable one:
+    // Target: [1, 2, 1] mod 3
+    // b0=1, b0+b1=2 => b1=1, b1=1. Check: all consistent!
+    const result = solveCounter([1, 2, 1], [[0, 1], [1, 2]], 3);
+    expect(result).toEqual([1, 1]);
+    expect(verifyCounter([1, 2, 1], [[0, 1], [1, 2]], 3, result!)).toBe(true);
+  });
+
+  it('handles larger system', () => {
+    const n = 10;
+    const lights = Array.from({ length: n }, (_, i) => (i + 1) % 7);
+    const btns = Array.from({ length: n }, (_, i) => [i]);
+    const result = solveCounter(lights, btns, 7);
+    expect(result).not.toBeNull();
+    expect(verifyCounter(lights, btns, 7, result!)).toBe(true);
+  });
+});
