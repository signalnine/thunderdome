unter, two buttons, both affect counter 0\n    // Target: 1 mod 5. b0+b1 = 1.\n    // Solutions: (0,1), (1,0), (2,4), (3,3), (4,2)\n    // Min total = 1: (0,1) and (1,0). Lex smallest: [0,1]\n    const result = solveCounter([1], [[0], [0]], 5);\n    expect(result).toEqual([0, 1]);\n    expect(verifyCounter([1], [[0], [0]], 5, result!)).toBe(true);\n  });\n\n  it('solves with prime modulus 97', () => {\n    const result = solveCounter([50], [[0]], 97);\n    expect(result).toEqual([50]);\n    expect(verifyCounter([50], [[0]], 97, result!)).toBe(true);\n  });\n\n  it('solves overlapping buttons', () => {\n    // Button 0: [0,1], Button 1: [1,2]\n    // Target: [1, 0, 1] mod 3\n    // Equations: b0 = 1, b0+b1 = 0, b1 = 1 (all mod 3)\n    // b0 = 1, b1 = 1. Check: b0+b1 = 2 mod 3 ≠ 0. Hmm.\n    // Actually: b0 = 1 (counter 0), b0+b1 ≡ 0 (counter 1), b1 ≡ 1 (counter 2)\n    // b0=1, b1=1. Counter 1: 1+1=2 ≠ 0 mod 3. No solution!\n    // Let me pick a solvable one:\n    // Target: [1, 2, 1] mod 3\n    // b0=1, b0+b1=2 => b1=1, b1=1. Check: all consistent!\n    const result = solveCounter([1, 2, 1], [[0, 1], [1, 2]], 3);\n    expect(result).toEqual([1, 1]);\n    expect(verifyCounter([1, 2, 1], [[0, 1], [1, 2]], 3, result!)).toBe(true);\n  });\n\n  it('handles larger system', () => {\n    const n = 10;\n    const lights = Array.from({ length: n }, (_, i) => (i + 1) % 7);\n    const btns = Array.from({ length: n }, (_, i) => [i]);\n    const result = solveCounter(lights, btns, 7);\n    expect(result).not.toBeNull();\n    expect(verifyCounter(lights, btns, 7, result!)).toBe(true);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":239,"cache_read_input_tokens":26158,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":239},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"