+      sheet.set('A1', 50);
+      sheet.set('B1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('B1')).toBe('big');
+
+      sheet.set('A1', 10);
+      expect(sheet.get('B1')).toBe('small');
+    });
+
+    it('should handle formula replacement', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      sheet.set('C1', '=A1+B1');
+      expect(sheet.get('C1')).toBe(30);
+
+      sheet.set('C1', '=A1*B1');
+      expect(sheet.get('C1')).toBe(200);
+    });
+  });
+
+  describe('circular reference detection', () => {
+    it('should detect direct circular reference', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=B1');
+      expect(() => sheet.set('B1', '=A1')).toThrow(/[Cc]ircular/);
+    });
+
+    it('should detect indirect circular reference', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', '=B1');
+      sheet.set('B1', '=C1');
+      expect(() => sheet.set('C1', '=A1')).toThrow(/[Cc]ircular/);
+    });
+
+    it('should detect self-reference', () => {
+      const sheet = new Spreadsheet();
+      expect(() => sheet.set('A1', '=A1')).toThrow(/[Cc]ircular/);
+    });
+  });
+
+  describe('column references', () => {
+    it('should handle multi-letter columns', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('AA1', 100);
+      expect(sheet.get('AA1')).toBe(100);
+    });
+
+    it('should handle formulas with multi-letter columns', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('AA1', 10);
+      sheet.set('AB1', 20);
+      sheet.set('AC1', '=AA1+AB1');
+      expect(sheet.get('AC1')).toBe(30);
+    });
+  });
+
+  describe('example from spec', () => {
+    it('should match the example usage', () => {
+      const sheet = new Spreadsheet();
+
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+      expect(sheet.getDisplay('A3')).toBe('30');
+
+      sheet.set('A1', 50);
+      expect(sheet.get('A3')).toBe(70);
+
+      sheet.set('B1', '=SUM(A1:A2)');
+      expect(sheet.get('B1')).toBe(70);
+
+      sheet.set('C1', '=IF(A1>30, "big", "small")');
+      expect(sheet.get('C1')).toBe('big');
+    });
+  });
+});
