+      expect(sheet.get('B1')).toBe(60);
+    });
+
+    it('should sum a row range', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 1);
+      sheet.set('B1', 2);
+      sheet.set('C1', 3);
+      sheet.set('D1', '=SUM(A1:C1)');
+      expect(sheet.get('D1')).toBe(6);
+    });
