+      sheet.set('B1', '=SUM(A1:A3)');
+      expect(sheet.get('B1')).toBe(30);
+    });
+  });
+
+  describe('functions - AVERAGE', () => {
+    it('should compute average', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', 30);
+      sheet.set('B1', '=AVERAGE(A1:A3)');
+      expect(sheet.get('B1')).toBe(20);
+    });
+  });
+
