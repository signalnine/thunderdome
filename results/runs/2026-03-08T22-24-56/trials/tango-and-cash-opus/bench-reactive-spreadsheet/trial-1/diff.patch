+type CellValue = string | number | boolean | null;
+
+interface CellData {
+  raw: string | number | boolean;
+  computed: CellValue;
+  formula: boolean;
+  deps: Set<string>;
+}
+
+// Token types for formula parser
+type Token =
+  | { type: 'number'; value: number }
+  | { type: 'string'; value: string }
+  | { type: 'boolean'; value: boolean }
+  | { type: 'cell'; value: string }
+  | { type: 'range'; start: string; end: string }
+  | { type: 'func'; name: string }
+  | { type: 'op'; value: string }
+  | { type: 'paren'; value: '(' | ')' }
+  | { type: 'comma' };
+
+function columnToNumber(col: string): number {
+  let n = 0;
+  for (let i = 0; i < col.length; i++) {
+    n = n * 26 + (col.charCodeAt(i) - 64);
+  }
+  return n;
+}
+
+function numberToColumn(n: number): string {
+  let result = '';
+  while (n > 0) {
+    n--;
+    result = String.fromCharCode(65 + (n % 26)) + result;
+    n = Math.floor(n / 26);
+  }
+  return result;
+}
+
+function parseRef(ref: string): { col: string; row: number } {
+  const match = ref.match(/^([A-Z]+)(\d+)$/);
+  if (!match) throw new Error(`Invalid cell reference: ${ref}`);
+  return { col: match[1], row: parseInt(match[2], 10) };
+}
+
+function normalizeRef(ref: string): string {
+  return ref.toUpperCase();
+}
+
+function expandRange(start: string, end: string): string[] {
+  const s = parseRef(start);
+  const e = parseRef(end);
+  const startCol = columnToNumber(s.col);
+  const endCol = columnToNumber(e.col);
+  const minCol = Math.min(startCol, endCol);
+  const maxCol = Math.max(startCol, endCol);
+  const minRow = Math.min(s.row, e.row);
+  const maxRow = Math.max(s.row, e.row);
+  const cells: string[] = [];
+  for (let c = minCol; c <= maxCol; c++) {
+    for (let r = minRow; r <= maxRow; r++) {
+      cells.push(numberToColumn(c) + r);
+    }
+  }
+  return cells;
+}
+
+function tokenize(formula: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+  while (i < formula.length) {
+    const ch = formula[i];
+    if (ch === ' ') { i++; continue; }
+    if (ch === '(') { tokens.push({ type: 'paren', value: '(' }); i++; continue; }
+    if (ch === ')') { tokens.push({ type: 'paren', value: ')' }); i++; continue; }
+    if (ch === ',') { tokens.push({ type: 'comma' }); i++; continue; }
+    if (ch === '"') {
+      let s = '';
+      i++;
+      while (i < formula.length && formula[i] !== '"') { s += formula[i]; i++; }
+      i++; // skip closing quote
+      tokens.push({ type: 'string', value: s });
+      continue;
+    }
+    // Comparison operators
+    if (ch === '<') {
+      if (formula[i + 1] === '>') { tokens.push({ type: 'op', value: '<>' }); i += 2; }
+      else if (formula[i + 1] === '=') { tokens.push({ type: 'op', value: '<=' }); i += 2; }
+      else { tokens.push({ type: 'op', value: '<' }); i++; }
+      continue;
+    }
+    if (ch === '>') {
+      if (formula[i + 1] === '=') { tokens.push({ type: 'op', value: '>=' }); i += 2; }
+      else { tokens.push({ type: 'op', value: '>' }); i++; }
+      continue;
+    }
+    if (ch === '=') { tokens.push({ type: 'op', value: '=' }); i++; continue; }
+    if (ch === '+' || ch === '-' || ch === '*' || ch === '/') {
+      tokens.push({ type: 'op', value: ch }); i++; continue;
+    }
+    // Number
+    if (ch >= '0' && ch <= '9' || (ch === '.' && i + 1 < formula.length && formula[i + 1] >= '0' && formula[i + 1] <= '9')) {
+      let num = '';
+      while (i < formula.length && ((formula[i] >= '0' && formula[i] <= '9') || formula[i] === '.')) {
+        num += formula[i]; i++;
+      }
+      tokens.push({ type: 'number', value: parseFloat(num) });
+      continue;
+    }
+    // Identifiers: cell refs, function names, booleans
+    if ((ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z')) {
+      let ident = '';
+      while (i < formula.length && ((formula[i] >= 'A' && formula[i] <= 'Z') || (formula[i] >= 'a' && formula[i] <= 'z') || (formula[i] >= '0' && formula[i] <= '9'))) {
+        ident += formula[i]; i++;
+      }
+      const upper = ident.toUpperCase();
+      if (upper === 'TRUE') { tokens.push({ type: 'boolean', value: true }); continue; }
+      if (upper === 'FALSE') { tokens.push({ type: 'boolean', value: false }); continue; }
+      // Check if function (next non-space char is '(')
+      let j = i;
+      while (j < formula.length && formula[j] === ' ') j++;
+      if (j < formula.length && formula[j] === '(') {
+        tokens.push({ type: 'func', name: upper });
+        continue;
+      }
+      // Check if range (next non-space char is ':')
+      if (j < formula.length && formula[j] === ':') {
+        const startRef = upper;
+        i = j + 1;
+        let endIdent = '';
+        while (i < formula.length && ((formula[i] >= 'A' && formula[i] <= 'Z') || (formula[i] >= 'a' && formula[i] <= 'z') || (formula[i] >= '0' && formula[i] <= '9'))) {
+          endIdent += formula[i]; i++;
+        }
+        tokens.push({ type: 'range', start: startRef, end: endIdent.toUpperCase() });
+        continue;
+      }
+      // Cell reference
+      tokens.push({ type: 'cell', value: upper });
+      continue;
+    }
+    throw new Error(`Unexpected character in formula: ${ch}`);
+  }
+  return tokens;
+}
+
+type ASTNode =
+  | { kind: 'number'; value: number }
+  | { kind: 'string'; value: string }
+  | { kind: 'boolean'; value: boolean }
+  | { kind: 'cell'; ref: string }
+  | { kind: 'range'; start: string; end: string }
+  | { kind: 'binary'; op: string; left: ASTNode; right: ASTNode }
+  | { kind: 'unary'; op: string; operand: ASTNode }
+  | { kind: 'call'; name: string; args: ASTNode[] };
+
+class Parser {
+  private tokens: Token[];
+  private pos: number;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+    this.pos = 0;
+  }
+
+  private peek(): Token | undefined {
+    return this.tokens[this.pos];
+  }
+
+  private advance(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  parse(): ASTNode {
+    const node = this.parseComparison();
+    return node;
+  }
+
+  private parseComparison(): ASTNode {
+    let left = this.parseAddSub();
+    while (this.peek() && this.peek()!.type === 'op' &&
+      ['>', '<', '>=', '<=', '=', '<>'].includes((this.peek() as { type: 'op'; value: string }).value)) {
+      const op = (this.advance() as { type: 'op'; value: string }).value;
+      const right = this.parseAddSub();
+      left = { kind: 'binary', op, left, right };
+    }
+    return left;
+  }
+
+  private parseAddSub(): ASTNode {
+    let left = this.parseMulDiv();
+    while (this.peek() && this.peek()!.type === 'op' &&
+      ['+', '-'].includes((this.peek() as { type: 'op'; value: string }).value)) {
+      const op = (this.advance() as { type: 'op'; value: string }).value;
+      const right = this.parseMulDiv();
+      left = { kind: 'binary', op, left, right };
+    }
+    return left;
+  }
+
+  private parseMulDiv(): ASTNode {
+    let left = this.parseUnary();
+    while (this.peek() && this.peek()!.type === 'op' &&
+      ['*', '/'].includes((this.peek() as { type: 'op'; value: string }).value)) {
+      const op = (this.advance() as { type: 'op'; value: string }).value;
+      const right = this.parseUnary();
+      left = { kind: 'binary', op, left, right };
+    }
+    return left;
+  }
+
+  private parseUnary(): ASTNode {
+    const t = this.peek();
+    if (t && t.type === 'op' && (t.value === '-' || t.value === '+')) {
+      const op = (this.advance() as { type: 'op'; value: string }).value;
+      const operand = this.parseUnary();
+      return { kind: 'unary', op, operand };
+    }
+    return this.parsePrimary();
+  }
+
+  private parsePrimary(): ASTNode {
+    const t = this.peek();
+    if (!t) throw new Error('Unexpected end of formula');
+
+    if (t.type === 'number') { this.advance(); return { kind: 'number', value: t.value }; }
+    if (t.type === 'string') { this.advance(); return { kind: 'string', value: t.value }; }
+    if (t.type === 'boolean') { this.advance(); return { kind: 'boolean', value: t.value }; }
+    if (t.type === 'range') { this.advance(); return { kind: 'range', start: t.start, end: t.end }; }
+    if (t.type === 'cell') { this.advance(); return { kind: 'cell', ref: t.value }; }
+
+    if (t.type === 'func') {
+      const name = t.name;
+      this.advance(); // func name
+      this.advance(); // (
+      const args: ASTNode[] = [];
+      while (this.peek() && !(this.peek()!.type === 'paren' && (this.peek() as { type: 'paren'; value: string }).value === ')')) {
+        if (args.length > 0) this.advance(); // comma
+        args.push(this.parse());
+      }
+      this.advance(); // )
+      return { kind: 'call', name, args };
+    }
+
+    if (t.type === 'paren' && t.value === '(') {
+      this.advance();
+      const node = this.parse();
+      this.advance(); // )
+      return node;
+    }
+
+    throw new Error(`Unexpected token: ${JSON.stringify(t)}`);
+  }
+}
+
+function collectDeps(node: ASTNode, deps: Set<string>): void {
+  switch (node.kind) {
+    case 'cell': deps.add(node.ref); break;
+    case 'range':
+      for (const c of expandRange(node.start, node.end)) deps.add(c);
+      break;
+    case 'binary': collectDeps(node.left, deps); collectDeps(node.right, deps); break;
+    case 'unary': collectDeps(node.operand, deps); break;
+    case 'call': for (const a of node.args) collectDeps(a, deps); break;
+  }
+}
+
+export class Spreadsheet {
+  private cells: Map<string, CellData> = new Map();
+  private dependents: Map<string, Set<string>> = new Map(); // cell -> cells that depend on it
+  private asts: Map<string, ASTNode> = new Map();
+
+  set(cell: string, value: string | number | boolean): void {
+    const ref = normalizeRef(cell);
+    const isFormula = typeof value === 'string' && value.startsWith('=');
+
+    // Remove old dependency links
+    const old = this.cells.get(ref);
+    if (old) {
+      for (const dep of old.deps) {
+        this.dependents.get(dep)?.delete(ref);
+      }
+    }
+
+    const deps = new Set<string>();
+    let ast: ASTNode | undefined;
+
+    if (isFormula) {
+      const tokens = tokenize((value as string).slice(1));
+      ast = new Parser(tokens).parse();
+      collectDeps(ast, deps);
+      this.asts.set(ref, ast);
+    } else {
+      this.asts.delete(ref);
+    }
+
+    // Register new dependencies
+    for (const dep of deps) {
+      if (!this.dependents.has(dep)) this.dependents.set(dep, new Set());
+      this.dependents.get(dep)!.add(ref);
+    }
+
+    const data: CellData = { raw: value, computed: null, formula: isFormula, deps };
+    this.cells.set(ref, data);
+
+    // Check for circular dependencies before computing
+    this.checkCircular(ref, new Set());
+
+    // Compute this cell
+    data.computed = isFormula ? this.evaluate(ast!) : this.coerceRawValue(value);
+
+    // Propagate to dependents
+    this.propagate(ref);
+  }
+
+  get(cell: string): CellValue {
+    const ref = normalizeRef(cell);
+    const data = this.cells.get(ref);
+    if (!data) return null;
+    return data.computed;
+  }
+
+  getDisplay(cell: string): string {
+    const v = this.get(cell);
+    if (v === null) return '';
+    return String(v);
+  }
+
+  getCells(): Map<string, any> {
+    const result = new Map<string, any>();
+    for (const [ref, data] of this.cells) {
+      result.set(ref, data.computed);
+    }
+    return result;
+  }
+
+  private coerceRawValue(value: string | number | boolean): CellValue {
+    return value;
+  }
+
+  private checkCircular(start: string, visited: Set<string>): void {
+    if (visited.has(start)) {
+      throw new Error(`Circular reference detected involving ${start}`);
+    }
+    visited.add(start);
+    const deps = this.cells.get(start)?.deps;
+    if (deps) {
+      for (const dep of deps) {
+        this.checkCircular(dep, new Set(visited));
+      }
+    }
+    // Also check if any dependent of start eventually depends back on start
+    this.checkCircularUp(start, start, new Set());
+  }
+
+  private checkCircularUp(origin: string, current: string, visited: Set<string>): void {
+    const deps = this.cells.get(current)?.deps;
+    if (!deps) return;
+    for (const dep of deps) {
+      if (dep === origin) {
+        throw new Error(`Circular reference detected involving ${origin}`);
+      }
+      if (visited.has(dep)) continue;
+      visited.add(dep);
+      this.checkCircularUp(origin, dep, visited);
+    }
+  }
+
+  private propagate(changed: string): void {
+    const toRecompute = this.topologicalSort(changed);
+    for (const ref of toRecompute) {
+      const data = this.cells.get(ref);
+      if (data && data.formula) {
+        const ast = this.asts.get(ref);
+        if (ast) data.computed = this.evaluate(ast);
+      }
+    }
+  }
+
+  private topologicalSort(start: string): string[] {
+    // BFS to collect all transitive dependents, then sort so that
+    // if X depends on Y, Y comes before X in the result.
+    const allDeps = new Set<string>();
+    const queue = [start];
+    while (queue.length > 0) {
+      const current = queue.shift()!;
+      const deps = this.dependents.get(current);
+      if (deps) {
+        for (const d of deps) {
+          if (!allDeps.has(d)) {
+            allDeps.add(d);
+            queue.push(d);
+          }
+        }
+      }
+    }
+    // Topological sort using DFS post-order
+    const result: string[] = [];
+    const visited = new Set<string>();
+    const visit = (ref: string) => {
+      if (visited.has(ref)) return;
+      visited.add(ref);
+      // Visit this cell's dependencies that are also in allDeps
+      const cellData = this.cells.get(ref);
+      if (cellData) {
+        for (const dep of cellData.deps) {
+          if (allDeps.has(dep)) visit(dep);
+        }
+      }
+      result.push(ref);
+    };
+    for (const ref of allDeps) visit(ref);
+    return result;
+  }
+
+  private evaluate(node: ASTNode): CellValue {
+    switch (node.kind) {
+      case 'number': return node.value;
+      case 'string': return node.value;
+      case 'boolean': return node.value;
+      case 'cell': {
+        const data = this.cells.get(node.ref);
+        if (!data) return 0; // empty cells treated as 0 in formulas
+        return data.computed;
+      }
+      case 'unary': {
+        const val = this.evaluate(node.operand);
+        if (node.op === '-') return -(val as number);
+        return val as number;
+      }
+      case 'binary': {
+        const left = this.evaluate(node.left);
+        const right = this.evaluate(node.right);
+        switch (node.op) {
+          case '+': return (left as number) + (right as number);
+          case '-': return (left as number) - (right as number);
+          case '*': return (left as number) * (right as number);
+          case '/': return (left as number) / (right as number);
+          case '>': return (left as number) > (right as number);
+          case '<': return (left as number) < (right as number);
+          case '>=': return (left as number) >= (right as number);
+          case '<=': return (left as number) <= (right as number);
+          case '=': return left === right;
+          case '<>': return left !== right;
+          default: throw new Error(`Unknown operator: ${node.op}`);
+        }
+      }
+      case 'range': {
+        // Ranges in expression context: return array of values
+        return expandRange(node.start, node.end).map(ref => {
+          const data = this.cells.get(ref);
+          return data ? data.computed : null;
+        }) as any;
+      }
+      case 'call': return this.evaluateFunction(node.name, node.args);
+      default: throw new Error(`Unknown node kind`);
+    }
+  }
+
+  private resolveValues(args: ASTNode[]): CellValue[] {
+    const values: CellValue[] = [];
+    for (const arg of args) {
+      if (arg.kind === 'range') {
+        const cells = expandRange(arg.start, arg.end);
+        for (const ref of cells) {
+          const data = this.cells.get(ref);
+          values.push(data ? data.computed : null);
+        }
+      } else {
+        values.push(this.evaluate(arg));
+      }
+    }
+    return values;
+  }
+
+  private evaluateFunction(name: string, args: ASTNode[]): CellValue {
+    switch (name) {
+      case 'SUM': {
+        const values = this.resolveValues(args);
+        return values.reduce<number>((sum, v) => sum + (typeof v === 'number' ? v : 0), 0);
+      }
+      case 'AVERAGE': {
+        const values = this.resolveValues(args);
+        const nums = values.filter((v): v is number => typeof v === 'number');
+        return nums.length === 0 ? 0 : nums.reduce((s, n) => s + n, 0) / nums.length;
+      }
+      case 'MIN': {
+        const values = this.resolveValues(args);
+        const nums = values.filter((v): v is number => typeof v === 'number');
+        return nums.length === 0 ? 0 : Math.min(...nums);
+      }
+      case 'MAX': {
+        const values = this.resolveValues(args);
+        const nums = values.filter((v): v is number => typeof v === 'number');
+        return nums.length === 0 ? 0 : Math.max(...nums);
+      }
+      case 'COUNT': {
+        const values = this.resolveValues(args);
+        return values.filter(v => typeof v === 'number').length;
+      }
+      case 'IF': {
+        if (args.length !== 3) throw new Error('IF requires 3 arguments');
+        const condition = this.evaluate(args[0]);
+        return condition ? this.evaluate(args[1]) : this.evaluate(args[2]);
+      }
+      default: throw new Error(`Unknown function: ${name}`);
+    }
+  }
+}
