+import { describe, it, expect } from 'vitest';
+import { Spreadsheet } from './index.js';
+
+describe('Spreadsheet', () => {
+  describe('basic values', () => {
+    it('should store and retrieve numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.get('A1')).toBe(42);
+    });
+
+    it('should store and retrieve strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.get('A1')).toBe('hello');
+    });
+
+    it('should store and retrieve booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.get('A1')).toBe(true);
+      sheet.set('A2', false);
+      expect(sheet.get('A2')).toBe(false);
+    });
+
+    it('should return null for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.get('A1')).toBe(null);
+    });
+
+    it('should handle case-insensitive cell refs', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('a1', 10);
+      expect(sheet.get('A1')).toBe(10);
+    });
+  });
+
+  describe('getDisplay', () => {
+    it('should return string representation of numbers', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 42);
+      expect(sheet.getDisplay('A1')).toBe('42');
+    });
+
+    it('should return string representation of strings', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 'hello');
+      expect(sheet.getDisplay('A1')).toBe('hello');
+    });
+
+    it('should return string representation of booleans', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', true);
+      expect(sheet.getDisplay('A1')).toBe('true');
+    });
+
+    it('should return empty string for empty cells', () => {
+      const sheet = new Spreadsheet();
+      expect(sheet.getDisplay('A1')).toBe('');
+    });
+
+    it('should return computed formula result as string', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.getDisplay('A3')).toBe('30');
+    });
+  });
+
+  describe('getCells', () => {
+    it('should return map of all non-empty cells', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('B1', 20);
+      const cells = sheet.getCells();
+      expect(cells.size).toBe(2);
+      expect(cells.get('A1')).toBe(10);
+      expect(cells.get('B1')).toBe(20);
+    });
+  });
+
+  describe('formulas - arithmetic', () => {
+    it('should evaluate addition', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 10);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1+A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate subtraction', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 50);
+      sheet.set('A2', 20);
+      sheet.set('A3', '=A1-A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate multiplication', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 5);
+      sheet.set('A2', 6);
+      sheet.set('A3', '=A1*A2');
+      expect(sheet.get('A3')).toBe(30);
+    });
+
+    it('should evaluate division', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 100);
+      sheet.set('A2', 4);
+      sheet.set('A3', '=A1/A2');
+      expect(sheet.get('A3')).toBe(25);
+    });
+
+    it('should respect operator precedence', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('B1', '=A1+A2*A3');
+      expect(sheet.get('B1')).toBe(14);
+    });
+
+    it('should handle parentheses', () => {
+      const sheet = new Spreadsheet();
+      sheet.set('A1', 2);
+      sheet.set('A2', 3);
+      sheet.set('A3', 4);
+      sheet.set('B1', '=(A1+A2)*A3');
+      expect(sheet.get('B1')).toBe(20);
+    });
+
+    it('should handle unary negation', () => {
