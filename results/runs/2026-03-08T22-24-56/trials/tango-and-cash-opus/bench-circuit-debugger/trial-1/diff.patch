+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a logic gate circuit given initial wire values.
+ * Returns the final value of every wire.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>,
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const remaining = [...gates];
+
+  let progress = true;
+  while (remaining.length > 0 && progress) {
+    progress = false;
+    for (let i = remaining.length - 1; i >= 0; i--) {
+      const g = remaining[i];
+      if (wires[g.in1] !== undefined && wires[g.in2] !== undefined) {
+        const a = wires[g.in1];
+        const b = wires[g.in2];
+        switch (g.op) {
+          case 'AND':
+            wires[g.out] = a & b;
+            break;
+          case 'OR':
+            wires[g.out] = a | b;
+            break;
+          case 'XOR':
+            wires[g.out] = a ^ b;
+            break;
+        }
+        remaining.splice(i, 1);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires involved in 4 output-wire swaps in a ripple-carry adder circuit.
+ *
+ * Strategy: Walk the expected adder structure bit by bit. At each stage,
+ * if the expected gate is missing, find what went wrong and record swaps.
+ * Also apply surface-level rules to catch obvious violations.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  const gateByOut = new Map<string, Gate>();
+  for (const g of gates) {
+    gateByOut.set(g.out, g);
+  }
+
+  // Index gates by (op, sorted inputs)
+  const gateIndex = new Map<string, Gate>();
+  for (const g of gates) {
+    const key = `${g.op}:${[g.in1, g.in2].sort().join(',')}`;
+    gateIndex.set(key, g);
+  }
+
+  let numBits = 0;
+  for (const g of gates) {
+    for (const w of [g.in1, g.in2]) {
+      const m = w.match(/^x(\d+)$/);
+      if (m) {
+        numBits = Math.max(numBits, parseInt(m[1], 10) + 1);
+      }
+    }
+  }
+
+  const swapped = new Set<string>();
+
+  function isXY(wire: string): boolean {
+    return /^[xy]\d+$/.test(wire);
+  }
+
+  function hasXYInputs(g: Gate): boolean {
+    return isXY(g.in1) && isXY(g.in2);
+  }
+
+  function findGate(op: Gate['op'], a: string, b: string): Gate | undefined {
+    const key = `${op}:${[a, b].sort().join(',')}`;
+    return gateIndex.get(key);
+  }
+
+  function findGateWithInput(op: Gate['op'], input: string): Gate | undefined {
+    return gates.find(
+      (g) => g.op === op && (g.in1 === input || g.in2 === input),
+    );
+  }
+
+  function otherInput(g: Gate, known: string): string {
+    return g.in1 === known ? g.in2 : g.in1;
+  }
+
+  const lastZ = `z${String(numBits).padStart(2, '0')}`;
+
+  // Surface rules
+  for (const g of gates) {
+    if (g.out.startsWith('z') && g.out !== lastZ && g.op !== 'XOR') {
+      swapped.add(g.out);
+    }
+    if (g.op === 'XOR' && hasXYInputs(g) && g.out.startsWith('z') && g.out !== 'z00') {
+      swapped.add(g.out);
+    }
+    if (g.op === 'XOR' && !hasXYInputs(g) && !g.out.startsWith('z')) {
+      swapped.add(g.out);
+    }
+  }
+
+  // Structural walk
+  let carry: string | undefined = undefined;
+
+  for (let bit = 0; bit < numBits; bit++) {
+    const xw = `x${String(bit).padStart(2, '0')}`;
+    const yw = `y${String(bit).padStart(2, '0')}`;
+    const zw = `z${String(bit).padStart(2, '0')}`;
+
+    if (bit === 0) {
+      const andGate = findGate('AND', xw, yw);
+      carry = andGate?.out;
+      continue;
+    }
+
+    const xorXY = findGate('XOR', xw, yw);
+    if (!xorXY || carry === undefined) continue;
+    let partial = xorXY.out;
+
+    // If partial was flagged as swapped, we need to figure out correct value
+    // Look for the XOR gate that should produce zw
+    let sumGate = findGate('XOR', partial, carry);
+
+    if (!sumGate) {
+      // partial or carry might be swapped — try to find sumGate differently
+      // Option A: find the gate that outputs zw and check its inputs
+      const zGate = gateByOut.get(zw);
+      if (zGate && zGate.op === 'XOR') {
+        if (zGate.in1 === carry || zGate.in2 === carry) {
+          const correctPartial = otherInput(zGate, carry);
+          if (correctPartial !== partial) {
+            swapped.add(partial);
+            swapped.add(correctPartial);
+            partial = correctPartial;
+          }
+          sumGate = zGate;
+        } else if (zGate.in1 === partial || zGate.in2 === partial) {
+          const correctCarry = otherInput(zGate, partial);
+          if (correctCarry !== carry) {
+            swapped.add(carry);
+            swapped.add(correctCarry);
+            carry = correctCarry;
+          }
+          sumGate = zGate;
+        }
+      }
+
+      // Option B: find any XOR gate that uses carry (but doesn't have xy inputs)
+      if (!sumGate) {
+        const xorWithCarry = findGateWithInput('XOR', carry);
+        if (xorWithCarry && !hasXYInputs(xorWithCarry)) {
+          const correctPartial = otherInput(xorWithCarry, carry);
+          if (correctPartial !== partial) {
+            swapped.add(partial);
+            swapped.add(correctPartial);
+            partial = correctPartial;
+          }
+          sumGate = xorWithCarry;
+        }
+      }
+
+      // Option C: find any XOR gate that uses partial (non-xy)
+      if (!sumGate) {
+        const xorWithPartial = findGateWithInput('XOR', partial);
+        if (xorWithPartial && !hasXYInputs(xorWithPartial) && xorWithPartial !== xorXY) {
+          const correctCarry = otherInput(xorWithPartial, partial);
+          if (correctCarry !== carry) {
+            swapped.add(carry);
+            swapped.add(correctCarry);
+            carry = correctCarry;
+          }
+          sumGate = xorWithPartial;
+        }
+      }
+    }
+
+    if (!sumGate) continue;
+
+    // Verify sumGate outputs zw
+    if (sumGate.out !== zw) {
+      // sumGate.out is swapped with zw (already caught by surface rules usually)
+      if (!swapped.has(sumGate.out)) {
+        swapped.add(sumGate.out);
+      }
+    }
+
+    // Now find the carry chain for this bit
+    const andXY = findGate('AND', xw, yw);
+    if (!andXY) continue;
+    const generate = andXY.out;
+
+    const andPC = findGate('AND', partial, carry);
+    let propagate = andPC?.out;
+
+    if (propagate !== undefined) {
+      const orGate = findGate('OR', generate, propagate);
+      if (orGate) {
+        carry = orGate.out;
+      } else {
+        // generate or propagate might be swapped
+        // Try to find OR gate with generate
+        const orWithGen = findGateWithInput('OR', generate);
+        if (orWithGen) {
+          const expectedProp = otherInput(orWithGen, generate);
+          if (expectedProp !== propagate) {
+            swapped.add(propagate);
+            swapped.add(expectedProp);
+            propagate = expectedProp;
+          }
+          carry = orWithGen.out;
+        } else {
+          // Try to find OR gate with propagate
+          const orWithProp = findGateWithInput('OR', propagate);
+          if (orWithProp) {
+            const expectedGen = otherInput(orWithProp, propagate);
+            if (expectedGen !== generate) {
+              swapped.add(generate);
+              swapped.add(expectedGen);
+            }
+            carry = orWithProp.out;
+          }
+        }
+      }
+    } else {
+      // Can't find AND(partial, carry)
+      // Try to find carry via generate
+      const orWithGen = findGateWithInput('OR', generate);
+      if (orWithGen) {
+        carry = orWithGen.out;
+      }
+    }
+  }
+
+  return [...swapped].sort();
+}
