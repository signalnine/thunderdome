0, b: 1, c: 0 })).toEqual({\n      a: 0, b: 1, c: 0, mid: 0, out: 0,\n    });\n  });\n\n  it('should handle gates listed in reverse dependency order', () => {\n    // out depends on mid, but out gate is listed first\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'mid', in2: 'c', out: 'out' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'mid' },\n    ];\n    expect(simulate(gates, { a: 1, b: 1, c: 0 })).toEqual({\n      a: 1, b: 1, c: 0, mid: 1, out: 1,\n    });\n  });\n\n  it('should simulate a small correct adder (2-bit)', () => {\n    // 2-bit adder: x(01..00) + y(01..00) = z(02..00)\n    const gates: Gate[] = [\n      // Bit 0 - half adder\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      // Bit 1 - full adder\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'z02' },\n    ];\n\n    // 1 + 1 = 2 (01 + 01 = 010)\n    const r1 = simulate(gates, { x00: 1, x01: 0, y00: 1, y01: 0 });\n    expect(r1['z00']).toBe(0);\n    expect(r1['z01']).toBe(1);\n    expect(r1['z02']).toBe(0);\n\n    // 3 + 3 = 6 (11 + 11 = 110)\n    const r2 = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 1 });\n    expect(r2['z00']).toBe(0);\n    expect(r2['z01']).toBe(1);\n    expect(r2['z02']).toBe(1);\n\n    // 3 + 1 = 4 (11 + 01 = 100)\n    const r3 = simulate(gates, { x00: 1, x01: 1, y00: 1, y01: 0 });\n    expect(r3['z00']).toBe(0);\n    expect(r3['z01']).toBe(0);\n    expect(r3['z02']).toBe(1);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  /**\n   * Build a correct N-bit ripple-carry adder.\n   * Returns an array of gates with deterministic wire names.\n   */\n  function buildCorrectAdder(numBits: number): Gate[] {\n    const gates: Gate[] = [];\n\n    for (let i = 0; i < numBits; i++) {\n      const x = `x${String(i).padStart(2, '0')}`;\n      const y = `y${String(i).padStart(2, '0')}`;\n      const z = `z${String(i).padStart(2, '0')}`;\n\n      if (i === 0) {\n        gates.push({ op: 'XOR', in1: x, in2: y, out: z });\n        gates.push({ op: 'AND', in1: x, in2: y, out: `carry_${i}` });\n      } else {\n        const partial = `partial_${i}`;\n        const gen = `gen_${i}`;\n        const prop = `prop_${i}`;\n        const carryIn = `carry_${i - 1}`;\n        const carryOut = i === numBits - 1\n          ? `z${String(numBits).padStart(2, '0')}`\n          : `carry_${i}`;\n\n        gates.push({ op: 'XOR', in1: x, in2: y, out: partial });\n        gates.push({ op: 'XOR', in1: partial, in2: carryIn, out: z });\n        gates.push({ op: 'AND', in1: x, in2: y, out: gen });\n        gates.push({ op: 'AND', in1: partial, in2: carryIn, out: prop });\n        gates.push({ op: 'OR', in1: gen, in2: prop, out: carryOut });\n      }\n    }\n\n    return gates;\n  }\n\n  /**\n   * Swap the outputs of two gates.\n   */\n  function swapOutputs(gates: Gate[], wire1: string, wire2: string): Gate[] {\n    return gates.map((g) => {\n      if (g.out === wire1) return { ...g, out: wire2 };\n      if (g.out === wire2) return { ...g, out: wire1 };\n      return { ...g };\n    });\n  }\n\n  it('should find swapped wires in a small adder (8-bit)', () => {\n    let gates = buildCorrectAdder(8);\n\n    // Swap 4 pairs\n    gates = swapOutputs(gates, 'z01', 'gen_1');\n    gates = swapOutputs(gates, 'z03', 'partial_3');\n    gates = swapOutputs(gates, 'carry_4', 'z05');\n    gates = swapOutputs(gates, 'prop_6', 'z07');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual([\n      'carry_4', 'gen_1', 'partial_3', 'prop_6',\n      'z01', 'z03', 'z05', 'z07',\n    ]);\n  });\n\n  it('should find swapped wires in a larger adder (20-bit)', () => {\n    let gates = buildCorrectAdder(20);\n\n    gates = swapOutputs(gates, 'z02', 'gen_2');\n    gates = swapOutputs(gates, 'z10', 'partial_10');\n    gates = swapOutputs(gates, 'carry_14', 'z15');\n    gates = swapOutputs(gates, 'prop_18', 'z19');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual([\n      'carry_14', 'gen_2', 'partial_10', 'prop_18',\n      'z02', 'z10', 'z15', 'z19',\n    ]);\n  });\n\n  it('should find swapped wires in a 45-bit adder within time limit', () => {\n    let gates = buildCorrectAdder(45);\n\n    gates = swapOutputs(gates, 'z05', 'gen_5');\n    gates = swapOutputs(gates, 'z12', 'partial_12');\n    gates = swapOutputs(gates, 'carry_20', 'z21');\n    gates = swapOutputs(gates, 'prop_40', 'z44');\n\n    const start = Date.now();\n    const result = findSwappedWires(gates);\n    const elapsed = Date.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual([\n      'carry_20', 'gen_5', 'partial_12', 'prop_40',\n      'z05', 'z12', 'z21', 'z44',\n    ]);\n  });\n\n  it('should handle swaps between non-z wires and z wires', () => {\n    let gates = buildCorrectAdder(10);\n\n    // Swap carry with z (carry output goes to z, z output goes to carry role)\n    gates = swapOutputs(gates, 'carry_2', 'z03');\n    // Swap partial with z\n    gates = swapOutputs(gates, 'partial_5', 'z05');\n    // Swap generate with z\n    gates = swapOutputs(gates, 'gen_7', 'z07');\n    // Swap propagate with z\n    gates = swapOutputs(gates, 'prop_8', 'z08');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual([\n      'carry_2', 'gen_7', 'partial_5', 'prop_8',\n      'z03', 'z05', 'z07', 'z08',\n    ]);\n  });\n});\n","structuredPatch":[{"oldStart":197,"oldLines":4,"newStart":197,"newLines":22,"lines":["       'z03', 'z05', 'z07', 'z08',","     ]);","   });","+","+  it('should handle swaps involving carry wires across bits', () => {","+    let gates = buildCorrectAdder(12);","+","+    // Swap carry with partial at a different bit","+    gates = swapOutputs(gates, 'carry_1', 'partial_3');","+    // Swap gen with carry at different bit","+    gates = swapOutputs(gates, 'gen_5', 'carry_6');","+    // z swaps","+    gates = swapOutputs(gates, 'z08', 'prop_8');","+    gates = swapOutputs(gates, 'z11', 'gen_11');","+","+    const result = findSwappedWires(gates);","+    expect(result).toEqual([","+      'carry_1', 'carry_6', 'gen_11', 'gen_5',","+      'partial_3', 'prop_8', 'z08', 'z11',","+    ]);","+  });"," });"]}],"userModified":false,"replaceAll":false}}
