mber of input bits by scanning for x## wires\n  let numBits = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) {\n        numBits = Math.max(numBits, parseInt(m[1], 10) + 1);\n      }\n    }\n  }\n\n  const swapped = new Set<string>();\n\n  // Helper: check if a wire name matches x## or y##\n  function isXY(wire: string): boolean {\n    return /^[xy]\\d+$/.test(wire);\n  }\n\n  // Helper: check if a gate has specific inputs (order-independent)\n  function gateHasInputs(g: Gate, a: string, b: string): boolean {\n    return (g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a);\n  }\n\n  // Find gate by op and inputs\n  function findGate(\n    op: Gate['op'],\n    a: string,\n    b: string,\n  ): Gate | undefined {\n    return gates.find((g) => g.op === op && gateHasInputs(g, a, b));\n  }\n\n  // Find gate by op where at least one input matches\n  function findGateWithInput(\n    op: Gate['op'],\n    input: string,\n  ): Gate | undefined {\n    return gates.find(\n      (g) => g.op === op && (g.in1 === input || g.in2 === input),\n    );\n  }\n\n  // Rule-based detection of adder pattern violations:\n  // 1. XOR gates must either have x/y inputs OR output to z (except z00 which does both)\n  // 2. AND gates must never output to z (except the final bit)\n  // 3. OR gates must never output to z (except the final bit)\n  // 4. XOR gates that don't have x/y inputs and don't output z are wrong\n  // 5. Non-XOR gates that output z are wrong (except last z)\n\n  const lastZ = `z${String(numBits).padStart(2, '0')}`;\n\n  for (const g of gates) {\n    // Rule: if a gate outputs to z## (not the last z), it must be XOR\n    if (\n      g.out.startsWith('z') &&\n      g.out !== lastZ &&\n      g.op !== 'XOR'\n    ) {\n      swapped.add(g.out);\n    }\n\n    // Rule: XOR gates that take x##/y## inputs should NOT output z## (except z00)\n    // because x XOR y produces partial sum, not final sum (for bits > 0)\n    if (g.op === 'XOR' && hasXYInputs(g) && g.out.startsWith('z') && g.out !== 'z00') {\n      swapped.add(g.out);\n    }\n\n    // Rule: XOR gates that do NOT take x##/y## inputs must output z##\n    // (these are the \"partial XOR carry\" gates)\n    if (g.op === 'XOR' && !hasXYInputs(g) && !g.out.startsWith('z')) {\n      swapped.add(g.out);\n    }\n\n    // Rule: AND gates must never output z (except possibly lastZ)\n    // Already covered by first rule\n\n    // Rule: OR gates must never output z (except lastZ)\n    // Already covered by first rule\n  }\n\n  function hasXYInputs(g: Gate): boolean {\n    return isXY(g.in1) && isXY(g.in2);\n  }\n\n  // Now we need to find the swap partners. We have some of the 8 wires.\n  // For each identified bad wire, find what it should be swapped with.\n\n  // If we found fewer than 8 wires with the rules above, we need deeper analysis.\n  // Walk the adder structure to find remaining issues.\n\n  if (swapped.size < 8) {\n    // For each non-z XOR output that was flagged (should output z), find which z it should map to\n    // For each z output on a non-XOR gate, find what that gate should output\n\n    // Deeper structural walk\n    let carry: string | undefined = undefined;\n\n    for (let bit = 0; bit < numBits; bit++) {\n      const xw = `x${String(bit).padStart(2, '0')}`;\n      const yw = `y${String(bit).padStart(2, '0')}`;\n      const zw = `z${String(bit).padStart(2, '0')}`;\n\n      if (bit === 0) {\n        // Half adder: x00 XOR y00 -> z00, x00 AND y00 -> carry\n        const xorGate = findGate('XOR', xw, yw);\n        const andGate = findGate('AND', xw, yw);\n        if (xorGate) {\n          carry = andGate?.out;\n        }\n        continue;\n      }\n\n      // Full adder for bit >= 1\n      // Step 1: xNN XOR yNN -> partial\n      const xorXY = findGate('XOR', xw, yw);\n      if (!xorXY) continue;\n      let partial = xorXY.out;\n\n      // Step 2: partial XOR carry -> zNN\n      if (carry === undefined) continue;\n\n      let sumGate = findGate('XOR', partial, carry);\n\n      if (!sumGate) {\n        // One of partial or carry might be swapped\n        // Try to find XOR gate that produces zw\n        const zGate = gateByOut.get(zw);\n        if (zGate && zGate.op === 'XOR') {\n          // One of zGate's inputs should be carry or partial, the other is the swap partner\n          if (zGate.in1 === carry || zGate.in2 === carry) {\n            // partial was swapped with something\n            const correctPartial =\n              zGate.in1 === carry ? zGate.in2 : zGate.in1;\n            swapped.add(partial);\n            swapped.add(correctPartial);\n            partial = correctPartial;\n            sumGate = zGate;\n          } else if (zGate.in1 === partial || zGate.in2 === partial) {\n            // carry was swapped\n            const correctCarry =\n              zGate.in1 === partial ? zGate.in2 : zGate.in1;\n            swapped.add(carry);\n            swapped.add(correctCarry);\n            carry = correctCarry;\n            sumGate = zGate;\n          }\n        }\n      }\n\n      if (!sumGate) continue;\n\n      // Step 3: xNN AND yNN -> generate\n      const andXY = findGate('AND', xw, yw);\n      if (!andXY) continue;\n      const generate = andXY.out;\n\n      // Step 4: partial AND carry -> propagate\n      const andPC = findGate('AND', partial, carry);\n      const propagate = andPC?.out;\n\n      // Step 5: generate OR propagate -> carry_out\n      if (propagate !== undefined) {\n        const orGate = findGate('OR', generate, propagate);\n        if (orGate) {\n          carry = orGate.out;\n        } else {\n          // Try finding OR gate with one of them\n          const orWithGen = findGateWithInput('OR', generate);\n          const orWithProp = findGateWithInput('OR', propagate);\n          if (orWithGen) {\n            carry = orWithGen.out;\n          } else if (orWithProp) {\n            carry = orWithProp.out;\n          }\n       