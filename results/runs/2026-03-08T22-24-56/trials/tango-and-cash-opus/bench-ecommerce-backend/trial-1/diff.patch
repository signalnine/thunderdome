diff --git a/src/analytics/index.ts b/src/analytics/index.ts
new file mode 100644
index 0000000..6588f9b
--- /dev/null
+++ b/src/analytics/index.ts
@@ -0,0 +1,83 @@
+import { EventBus } from '../bus.js';
+import { AnalyticsService, Events, PaymentProcessedEvent, PaymentStatus, OrderCreatedEvent, CartUpdatedEvent } from '../types.js';
+
+export function createAnalyticsService(bus: EventBus): AnalyticsService {
+  const eventCounts = new Map<string, number>();
+  let revenue = 0;
+  const cartsCreated = new Set<string>();
+  let orderCount = 0;
+  const productCounts = new Map<string, number>();
+  const orderTotals = new Map<string, number>();
+  const cartItems = new Map<string, Array<{ productId: string; quantity: number }>>();
+
+  const allEvents = [
+    Events.PRODUCT_CREATED,
+    Events.INVENTORY_UPDATED,
+    Events.LOW_STOCK_ALERT,
+    Events.CART_UPDATED,
+    Events.PRICE_CALCULATED,
+    Events.ORDER_CREATED,
+    Events.ORDER_STATUS_CHANGED,
+    Events.PAYMENT_PROCESSED,
+    Events.NOTIFICATION_SENT,
+    Events.ANALYTICS_EVENT,
+  ];
+
+  for (const eventName of allEvents) {
+    bus.on(eventName, () => {
+      eventCounts.set(eventName, (eventCounts.get(eventName) ?? 0) + 1);
+    });
+  }
+
+  bus.on(Events.CART_UPDATED, (payload: unknown) => {
+    const event = payload as CartUpdatedEvent;
+    cartsCreated.add(event.cartId);
+    cartItems.set(event.cartId, [...event.items]);
+  });
+
+  bus.on(Events.ORDER_CREATED, (payload: unknown) => {
+    const event = payload as OrderCreatedEvent;
+    orderCount++;
+    orderTotals.set(event.orderId, event.total);
+
+    const items = cartItems.get(event.cartId);
+    if (items) {
+      for (const item of items) {
+        productCounts.set(item.productId, (productCounts.get(item.productId) ?? 0) + item.quantity);
+      }
+    }
+  });
+
+  bus.on(Events.PAYMENT_PROCESSED, (payload: unknown) => {
+    const event = payload as PaymentProcessedEvent;
+    if (event.status === PaymentStatus.SUCCESS) {
+      const total = orderTotals.get(event.orderId);
+      if (total !== undefined) {
+        revenue += total;
+      }
+    }
+  });
+
+  return {
+    getEventCount(eventType: string): number {
+      return eventCounts.get(eventType) ?? 0;
+    },
+
+    getRevenue(): number {
+      return revenue;
+    },
+
+    getConversionRate(): number {
+      const totalCarts = cartsCreated.size;
+      if (totalCarts === 0) return 0;
+      return orderCount / totalCarts;
+    },
+
+    getTopProducts(limit: number) {
+      return Array.from(productCounts.entries())
+        .map(([productId, count]) => ({ productId, count }))
+        .sort((a, b) => b.count - a.count)
+        .slice(0, limit);
+    },
+  };
+}
diff --git a/src/cart/index.ts b/src/cart/index.ts
new file mode 100644
index 0000000..eaae68a
--- /dev/null
+++ b/src/cart/index.ts
@@ -0,0 +1,67 @@
+import { v4 as uuidv4 } from 'uuid';
+import { EventBus } from '../bus.js';
+import { CartService, Events, CartUpdatedEvent } from '../types.js';
+
+export function createCartService(bus: EventBus): CartService {
+  const carts = new Map<string, { id: string; userId: string; items: Map<string, number> }>();
+
+  function getItemsArray(cartId: string): Array<{ productId: string; quantity: number }> {
+    const cart = carts.get(cartId);
+    if (!cart) return [];
+    return Array.from(cart.items.entries()).map(([productId, quantity]) => ({ productId, quantity }));
+  }
+
+  function emitUpdate(cartId: string) {
+    const cart = carts.get(cartId);
+    if (!cart) return;
+    const event: CartUpdatedEvent = { cartId, userId: cart.userId, items: getItemsArray(cartId) };
+    void bus.emit(Events.CART_UPDATED, event);
+  }
+
+  return {
+    createCart(userId: string): string {
+      const id = uuidv4();
+      carts.set(id, { id, userId, items: new Map() });
+      return id;
+    },
+
+    addItem(cartId: string, productId: string, quantity: number) {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      const current = cart.items.get(productId) ?? 0;
+      cart.items.set(productId, current + quantity);
+      emitUpdate(cartId);
+    },
+
+    removeItem(cartId: string, productId: string) {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.delete(productId);
+      emitUpdate(cartId);
+    },
+
+    getCart(cartId: string) {
+      const cart = carts.get(cartId);
+      if (!cart) return null;
+      return { id: cart.id, userId: cart.userId, items: getItemsArray(cartId) };
+    },
+
+    clearCart(cartId: string) {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      cart.items.clear();
+      emitUpdate(cartId);
+    },
+
+    updateQuantity(cartId: string, productId: string, quantity: number) {
+      const cart = carts.get(cartId);
+      if (!cart) return;
+      if (quantity <= 0) {
+        cart.items.delete(productId);
+      } else {
+        cart.items.set(productId, quantity);
+      }
+      emitUpdate(cartId);
+    },
+  };
+}
diff --git a/src/catalog/index.ts b/src/catalog/index.ts
