ctId);\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":418,"cache_read_input_tokens":25476,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":418},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"7fe45f81-e81a-4e14-9d55-0dce94d84e9f","uuid":"16f4ed96-5555-4ce5-85a7-24ea556fbcd0"}
