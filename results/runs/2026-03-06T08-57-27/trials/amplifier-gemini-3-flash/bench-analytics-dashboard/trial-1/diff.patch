@@ -0,0 +1,101 @@
+import { Router, Response } from 'express';
+import db from './db.js';
+import { authenticate } from './auth.js';
+import { AuthRequest } from './types.js';
+
+const router = Router();
+
+// Count events
+router.get('/query/count', authenticate, (req: AuthRequest, res: Response) => {
+  const { name, start, end } = req.query;
+  const user = req.user!;
+
+  let query = 'SELECT COUNT(*) as count FROM events WHERE tenant_id = ?';
+  const params: (string | number | string[] | undefined)[] = [user.tenant_id];
+
+  if (name) {
+    query += ' AND name = ?';
+    params.push(name as string);
+  }
+  if (start) {
+    query += ' AND timestamp >= ?';
+    params.push(start as string);
+  }
+  if (end) {
+    query += ' AND timestamp <= ?';
+    params.push(end as string);
+  }
+
+  const result = db.prepare(query).get(...params) as { count: number };
+  res.json(result);
+});
+
+// Timeseries
+router.get('/query/timeseries', authenticate, (req: AuthRequest, res: Response) => {
+  const { name, start, end, interval } = req.query; // interval could be 'day', 'hour', etc. Default 'day'
+  const user = req.user!;
+
+  const timeFormat = interval === 'hour' ? '%Y-%m-%d %H:00:00' : '%Y-%m-%d';
+  
+  let query = `SELECT strftime('${timeFormat}', timestamp) as bucket, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+  const params: (string | number | string[] | undefined)[] = [user.tenant_id];
+
+  if (name) {
+    query += ' AND name = ?';
+    params.push(name as string);
+  }
+  if (start) {
+    query += ' AND timestamp >= ?';
+    params.push(start as string);
+  }
+  if (end) {
+    query += ' AND timestamp <= ?';
+    params.push(end as string);
+  }
+
+  query += ' GROUP BY bucket ORDER BY bucket ASC';
+
+  const results = db.prepare(query).all(...params);
+  res.json(results);
+});
+
+// Breakdowns
+router.get('/query/breakdown', authenticate, (req: AuthRequest, res: Response) => {
+  const { name, property, start, end } = req.query;
+  const user = req.user!;
+
+  if (!property) {
+    return res.status(400).json({ error: 'Property name is required for breakdown' });
+  }
+
+  // SQLite doesn't have native JSON path extraction as easily as PG, 
+  // but better-sqlite3 supports json_extract if the sqlite version is recent enough.
+  // We'll use json_extract(properties, '$.' || ?)
+  
+  let query = `SELECT json_extract(properties, '$.' || ?) as value, COUNT(*) as count FROM events WHERE tenant_id = ?`;
+  const params: (string | number | string[] | undefined)[] = [property as string, user.tenant_id];
+
+  if (name) {
+    query += ' AND name = ?';
+    params.push(name as string);
+  }
+  if (start) {
+    query += ' AND timestamp >= ?';
+    params.push(start as string);
+  }
+  if (end) {
+    query += ' AND timestamp <= ?';
+    params.push(end as string);
+  }
+
+  query += ' GROUP BY value ORDER BY count DESC';
+
+  try {
+    const results = db.prepare(query).all(...params);
+    res.json(results);
+  } catch (err) {
+    res.status(500).json({ error: 'Query failed. Ensure property exists and JSON is valid.' });
+  }
+});
+
+export default router;
