@@ -0,0 +1,115 @@
+import { Router, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import db from './db.js';
+import { authenticate, authorize } from './auth.js';
+import { Dashboard, Widget, AuthRequest } from './types.js';
+
+const router = Router();
+
+// Create dashboard
+router.post('/dashboards', authenticate, authorize(['admin', 'editor']), (req: AuthRequest, res: Response) => {
+  const { name, config } = req.body;
+  const user = req.user!;
+
+  if (!name) {
+    return res.status(400).json({ error: 'Dashboard name is required' });
+  }
+
+  const id = uuidv4();
+  const dashboardConfig = JSON.stringify(config || {});
+
+  try {
+    db.prepare('INSERT INTO dashboards (id, tenant_id, name, owner_id, config) VALUES (?, ?, ?, ?, ?)')
+      .run(id, user.tenant_id, name, user.id, dashboardConfig);
+    res.status(201).json({ id });
+  } catch (err) {
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// List dashboards
+router.get('/dashboards', authenticate, (req: AuthRequest, res: Response) => {
+  const user = req.user!;
+  const dashboards = db.prepare('SELECT * FROM dashboards WHERE tenant_id = ?').all(user.tenant_id) as Dashboard[];
+  res.json(dashboards.map((d) => ({ ...d, config: JSON.parse(d.config) })));
+});
+
+// Get dashboard
+router.get('/dashboards/:id', authenticate, (req: AuthRequest, res: Response) => {
+  const user = req.user!;
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, user.tenant_id) as Dashboard | undefined;
+
+  if (!dashboard) {
+    return res.status(404).json({ error: 'Dashboard not found' });
+  }
+
+  const widgets = db.prepare('SELECT * FROM widgets WHERE dashboard_id = ?').all(dashboard.id) as Widget[];
+  res.json({
+    ...dashboard,
+    config: JSON.parse(dashboard.config),
+    widgets: widgets.map((w) => ({ ...w, config: JSON.parse(w.config) }))
+  });
+});
+
+// Update dashboard
+router.put('/dashboards/:id', authenticate, authorize(['admin', 'editor']), (req: AuthRequest, res: Response) => {
+  const { name, config } = req.body;
+  const user = req.user!;
+
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, user.tenant_id);
+  if (!dashboard) {
+    return res.status(404).json({ error: 'Dashboard not found' });
+  }
+
+  const updates: string[] = [];
+  const params: (string | number)[] = [];
+
+  if (name) {
+    updates.push('name = ?');
+    params.push(name);
+  }
+  if (config) {
+    updates.push('config = ?');
+    params.push(JSON.stringify(config));
+  }
+  updates.push("updated_at = datetime('now')");
+
+  params.push(req.params.id, user.tenant_id);
+
+  db.prepare(`UPDATE dashboards SET ${updates.join(', ')} WHERE id = ? AND tenant_id = ?`).run(...params);
+  res.json({ message: 'Dashboard updated' });
+});
+
+// Delete dashboard
+router.delete('/dashboards/:id', authenticate, authorize(['admin', 'editor']), (req: AuthRequest, res: Response) => {
+  const user = req.user!;
+  const result = db.prepare('DELETE FROM dashboards WHERE id = ? AND tenant_id = ?').run(req.params.id, user.tenant_id);
+
+  if (result.changes === 0) {
+    return res.status(404).json({ error: 'Dashboard not found' });
+  }
+
+  res.json({ message: 'Dashboard deleted' });
+});
+
+// Add widget to dashboard
+router.post('/dashboards/:id/widgets', authenticate, authorize(['admin', 'editor']), (req: AuthRequest, res: Response) => {
+  const { type, config, position_x, position_y, width, height } = req.body;
+  const user = req.user!;
+
+  const dashboard = db.prepare('SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?').get(req.params.id, user.tenant_id);
+  if (!dashboard) {
+    return res.status(404).json({ error: 'Dashboard not found' });
+  }
+
+  const id = uuidv4();
+  try {
+    db.prepare('INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)')
+      .run(id, req.params.id, type, JSON.stringify(config || {}), position_x || 0, position_y || 0, width || 1, height || 1);
+    res.status(201).json({ id });
+  } catch (err) {
+    res.status(400).json({ error: 'Invalid widget data' });
+  }
+});
+
+export default router;
