+import { describe, it, expect, beforeAll } from 'vitest';
+import request from 'supertest';
+import { createApp } from '../src/app.js';
+import db from '../src/db.js';
+
+const app = createApp();
+
+describe('Analytics Dashboard API', () => {
+  let token: string;
+  const tenantId = 'tenant-1';
+
+  beforeAll(() => {
+    // Clean database
+    db.prepare('DELETE FROM users').run();
+    db.prepare('DELETE FROM events').run();
+    db.prepare('DELETE FROM dashboards').run();
+    db.prepare('DELETE FROM widgets').run();
+  });
+
+  it('should register a new user', async () => {
+    const res = await request(app)
+      .post('/api/register')
+      .send({
+        email: 'test@example.com',
+        password: 'password123',
+        tenant_id: tenantId,
+        role: 'admin'
+      });
+    
+    expect(res.status).toBe(201);
+    expect(res.body.token).toBeDefined();
+    token = res.body.token;
+  });
+
+  it('should login an existing user', async () => {
+    const res = await request(app)
+      .post('/api/login')
+      .send({
+        email: 'test@example.com',
+        password: 'password123'
+      });
+    
+    expect(res.status).toBe(200);
+    expect(res.body.token).toBeDefined();
+  });
+
+  it('should ingest an event', async () => {
+    const res = await request(app)
+      .post('/api/events')
+      .set('Authorization', `Bearer ${token}`)
+      .send({
+        name: 'page_view',
+        properties: { url: '/home', browser: 'chrome' }
+      });
+    
+    expect(res.status).toBe(201);
+    expect(res.body.id).toBeDefined();
+  });
+
+  it('should ingest a batch of events', async () => {
+    const res = await request(app)
+      .post('/api/events/batch')
+      .set('Authorization', `Bearer ${token}`)
+      .send([
+        { name: 'click', properties: { button: 'login' } },
+        { name: 'page_view', properties: { url: '/pricing' } }
+      ]);
+    
+    expect(res.status).toBe(201);
+  });
+
+  it('should query event count', async () => {
+    const res = await request(app)
+      .get('/api/query/count')
+      .set('Authorization', `Bearer ${token}`)
+      .query({ name: 'page_view' });
+    
+    expect(res.status).toBe(200);
+    expect(res.body.count).toBeGreaterThanOrEqual(2);
+  });
+
+  it('should query breakdown', async () => {
+    const res = await request(app)
+      .get('/api/query/breakdown')
+      .set('Authorization', `Bearer ${token}`)
+      .query({ property: 'url' });
+    
+    expect(res.status).toBe(200);
+    expect(Array.isArray(res.body)).toBe(true);
+  });
+
+  it('should create a dashboard', async () => {
