+import { Router, Response } from 'express';
+import { v4 as uuidv4 } from 'uuid';
+import db from './db.js';
+import { authenticate } from './auth.js';
+import { AuthRequest } from './types.js';
+
+const router = Router();
+
+// Ingest single event
+router.post('/events', authenticate, (req: AuthRequest, res: Response) => {
+  const { name, properties, timestamp, session_id } = req.body;
+  const user = req.user!;
+
+  if (!name) {
+    return res.status(400).json({ error: 'Event name is required' });
+  }
+
+  const id = uuidv4();
+  const eventTimestamp = timestamp || new Date().toISOString();
+  const eventProperties = JSON.stringify(properties || {});
+
+  try {
+    db.prepare('INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)')
+      .run(id, user.tenant_id, name, eventProperties, eventTimestamp, user.id, session_id || null);
+
+    res.status(201).json({ id });
+  } catch (err) {
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+// Ingest batch events
+router.post('/events/batch', authenticate, (req: AuthRequest, res: Response) => {
+  const events = req.body;
+  const user = req.user!;
+
+  if (!Array.isArray(events)) {
+    return res.status(400).json({ error: 'Batch must be an array of events' });
+  }
+
+  const insert = db.prepare('INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)');
+
+  const transaction = db.transaction((batch) => {
+    for (const event of batch) {
+      const id = uuidv4();
+      const eventTimestamp = event.timestamp || new Date().toISOString();
+      const eventProperties = JSON.stringify(event.properties || {});
+      insert.run(id, user.tenant_id, event.name, eventProperties, eventTimestamp, user.id, event.session_id || null);
+    }
+  });
+
+  try {
+    transaction(events);
+    res.status(201).json({ message: `Successfully ingested ${events.length} events` });
+  } catch (err) {
+    res.status(500).json({ error: 'Internal server error' });
+  }
+});
+
+export default router;
