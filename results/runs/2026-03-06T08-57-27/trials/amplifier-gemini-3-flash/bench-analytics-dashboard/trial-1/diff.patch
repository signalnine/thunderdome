+import { Request } from 'express';
+
+export type UserRole = 'admin' | 'editor' | 'viewer';
+
+export interface User {
+  id: string;
+  email: string;
+  password_hash: string;
+  tenant_id: string;
+  role: UserRole;
+  created_at: string;
+}
+
+export interface Event {
+  id: string;
+  tenant_id: string;
+  name: string;
+  properties: string; // JSON string
+  timestamp: string;
+  user_id?: string;
+  session_id?: string;
+}
+
+export interface Dashboard {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string; // JSON string
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Widget {
+  id: string;
+  dashboard_id: string;
+  type: 'counter' | 'timeseries' | 'breakdown' | 'funnel';
+  config: string; // JSON string
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+export interface AuthRequest extends Request {
+  user?: {
+    id: string;
+    email: string;
+    tenant_id: string;
+    role: UserRole;
+  };
+}
