 import { NotFoundError, ValidationError } from './errors.js';
 
 export function createRoutes(db: Database.Database): Router {
@@ -118,5 +118,101 @@ export function createRoutes(db: Database.Database): Router {
     }
   });
 
+  // GET /notes/search - Full-text search
+  router.get('/notes/search', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const query = req.query.q as string | undefined;
+
+      if (!query || query.trim() === '') {
+        throw new ValidationError('Query parameter q is required');
+      }
+
+      const page = parseInt(req.query.page as string) || 1;
+      const perPage = 20;
+      const offset = (page - 1) * perPage;
+
+      // Escape special FTS5 characters and handle the query
+      const escapedQuery = escapeFtsQuery(query);
+
+      // Get total count
+      const countStmt = db.prepare(`
+        SELECT COUNT(*) as total FROM notes_fts WHERE notes_fts MATCH ?
+      `);
+      const { total } = countStmt.get(escapedQuery) as { total: number };
+
+      // Get paginated results with BM25 ranking and snippet highlighting
+      const searchStmt = db.prepare(`
+        SELECT
+          n.id,
+          n.title,
+          snippet(notes_fts, 0, '<mark>', '</mark>', '...', 32) as snippet,
+          bm25(notes_fts) as rank
+        FROM notes_fts
+        JOIN notes n ON n.id = notes_fts.note_id
+        WHERE notes_fts MATCH ?
+        ORDER BY bm25(notes_fts)
+        LIMIT ? OFFSET ?
+      `);
+
+      const results = searchStmt.all(escapedQuery, perPage, offset) as SearchResult[];
+
+      res.json({
+        results,
+        total,
+        page,
+        perPage,
+      });
+    } catch (err) {
+      next(err);
+    }
+  });
+
+  // GET /notes/search/suggest - Autocomplete suggestions
+  router.get('/notes/search/suggest', (req: Request, res: Response, next: NextFunction) => {
+    try {
+      const prefix = req.query.q as string | undefined;
+
+      if (!prefix || prefix.trim() === '') {
+        throw new ValidationError('Query parameter q is required');
+      }
+
+      // Use FTS5 with prefix matching (append * to search for terms starting with prefix)
+      // We search in both title and body using OR
+      const ftsQuery = prefix + '*';
+
+      const suggestStmt = db.prepare(`
+        SELECT DISTINCT n.id, n.title
+        FROM notes_fts
+        JOIN notes n ON n.id = notes_fts.note_id
+        WHERE notes_fts MATCH ?
+        ORDER BY bm25(notes_fts)
+        LIMIT 5
+      `);
+
+      const results = suggestStmt.all(ftsQuery) as SuggestResult[];
+
+      res.json({ results });
+    } catch (err) {
+      next(err);
+    }
+  });
+
   return router;
 }
+
+// Helper function to escape FTS5 special characters and handle quoted phrases
+function escapeFtsQuery(query: string): string {
+  // Check for quoted phrase
+  const quotedMatch = query.match(/^"(.+)"$/);
+  if (quotedMatch) {
+    // Return quoted phrase for exact match
+    return `"${quotedMatch[1]}"`;
+  }
+
+  // Split by spaces and escape each term
+  const terms = query.trim().split(/\s+/);
+  return terms.map(term => {
+    // Escape double quotes and backslashes in individual terms
+    return term.replace(/["\\]/g, '\\$&');
+  }).join(' ');
+}
