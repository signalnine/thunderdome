@@ -0,0 +1,562 @@
+export interface Machine {
+  target: boolean[];
+  buttons: number[][];
+}
+
+export function solveToggle(machine: Machine): number[] | null {
+  const { target, buttons } = machine;
+  const numLights = target.length;
+  const numButtons = buttons.length;
+
+  if (numLights === 0) {
+    return [];
+  }
+
+  if (numButtons === 0) {
+    return target.every(t => !t) ? [] : null;
+  }
+
+  // Build the augmented matrix over GF(2)
+  // Each row is a light, each column is a button, plus RHS column for target
+  const matrix: number[][] = [];
+  for (let light = 0; light < numLights; light++) {
+    const row: number[] = [];
+    for (let btn = 0; btn < numButtons; btn++) {
+      row.push(buttons[btn].includes(light) ? 1 : 0);
+    }
+    row.push(target[light] ? 1 : 0);
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(2)
+  const numCols = numButtons;
+  const pivotCol: number[] = new Array(numLights).fill(-1);
+  let pivotRow = 0;
+
+  for (let col = 0; col < numCols && pivotRow < numLights; col++) {
+    // Find pivot
+    let found = -1;
+    for (let row = pivotRow; row < numLights; row++) {
+      if (matrix[row][col] === 1) {
+        found = row;
+        break;
+      }
+    }
+
+    if (found === -1) continue;
+
+    // Swap rows
+    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];
+    pivotCol[pivotRow] = col;
+
+    // Eliminate
+    for (let row = 0; row < numLights; row++) {
+      if (row !== pivotRow && matrix[row][col] === 1) {
+        for (let c = 0; c <= numCols; c++) {
+          matrix[row][c] ^= matrix[pivotRow][c];
+        }
+      }
+    }
+    pivotRow++;
+  }
+
+  const rank = pivotRow;
+
+  // Check for inconsistency
+  for (let row = rank; row < numLights; row++) {
+    if (matrix[row][numCols] === 1) {
+      return null;
+    }
+  }
+
+  // Identify free and basic variables
+  const isBasic = new Set<number>();
+  for (let r = 0; r < rank; r++) {
+    isBasic.add(pivotCol[r]);
+  }
+
+  const freeVars: number[] = [];
+  for (let btn = 0; btn < numButtons; btn++) {
+    if (!isBasic.has(btn)) {
+      freeVars.push(btn);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // If no free variables, compute the unique solution
+  if (numFree === 0) {
+    const solution: number[] = [];
+    for (let r = 0; r < rank; r++) {
+      if (matrix[r][numCols] === 1) {
+        solution.push(pivotCol[r]);
+      }
+    }
+    return solution.sort((a, b) => a - b);
+  }
+
+  // Meet-in-the-middle for optimal solution
+  const half = Math.floor(numFree / 2);
+  const leftFree = freeVars.slice(0, half);
+  const rightFree = freeVars.slice(half);
+
+  // Express basic variables in terms of free variables
+  // x[basic] = rhs + sum(free contribution)
+  const basicExpr: Map<number, { rhs: number; coeffs: Map<number, number> }> = new Map();
+
+  for (let r = 0; r < rank; r++) {
+    const basicVar = pivotCol[r];
+    const rhs = matrix[r][numCols];
+    const coeffs = new Map<number, number>();
+
+    for (let c = 0; c < numCols; c++) {
+      if (c !== basicVar && matrix[r][c] === 1 && !isBasic.has(c)) {
+        coeffs.set(c, 1);
+      }
+    }
+
+    basicExpr.set(basicVar, { rhs, coeffs });
+  }
+
+  // Store left entries indexed by the pattern of leftContrib to basic vars
+  const leftByPattern: Map<string, { leftPressed: Set<number>; leftCount: number }[]> = new Map();
+
+  for (let mask = 0; mask < (1 << leftFree.length); mask++) {
+    const leftContrib = new Map<number, number>();
+
+    // Compute left contribution to each basic variable
+    for (const [basicVar, expr] of basicExpr) {
+      let contrib = 0;
+      for (const [freeVar, coeff] of expr.coeffs) {
+        if (leftFree.includes(freeVar)) {
+          const idx = leftFree.indexOf(freeVar);
+          contrib ^= (coeff * ((mask >> idx) & 1));
+        }
+      }
+      leftContrib.set(basicVar, contrib);
+    }
+
+    // Create pattern signature
+    const pattern: number[] = [];
+    for (let r = 0; r < rank; r++) {
+      pattern.push(leftContrib.get(pivotCol[r]) ?? 0);
+    }
+    const sig = pattern.join(',');
+
+    // Count left presses
+    const leftPressed = new Set<number>();
+    for (let i = 0; i < leftFree.length; i++) {
+      if ((mask >> i) & 1) {
+        leftPressed.add(leftFree[i]);
+      }
+    }
+
+    if (!leftByPattern.has(sig)) {
+      leftByPattern.set(sig, []);
+    }
+    leftByPattern.get(sig)!.push({ leftPressed, leftCount: leftPressed.size });
+  }
+
+  // For each pattern, keep only Pareto-optimal entries (minimum count for superset of presses)
+  for (const [sig, entries] of leftByPattern) {
+    entries.sort((a, b) => a.leftCount - b.leftCount);
+    const filtered: typeof entries = [];
+    for (const entry of entries) {
+      let dominated = false;
+      for (const existing of filtered) {
+        if (existing.leftCount <= entry.leftCount) {
+          // Check if existing dominates entry (existing presses is subset of entry presses)
+          let isSubset = true;
+          for (const p of entry.leftPressed) {
+            if (!existing.leftPressed.has(p)) {
+              isSubset = false;
+              break;
+            }
+          }
+          if (isSubset) {
+            dominated = true;
+            break;
+          }
+        }
+      }
+      if (!dominated) {
+        filtered.push(entry);
+      }
+    }
+    leftByPattern.set(sig, filtered);
+  }
+
+  let bestSolution: number[] | null = null;
+  let bestCount = Infinity;
+
+  for (let mask = 0; mask < (1 << rightFree.length); mask++) {
+    const rightContrib = new Map<number, number>();
+
+    // Compute right contribution to each basic variable
+    for (const [basicVar, expr] of basicExpr) {
+      let contrib = 0;
+      for (const [freeVar, coeff] of expr.coeffs) {
+        if (rightFree.includes(freeVar)) {
+          const idx = rightFree.indexOf(freeVar);
+          contrib ^= (coeff * ((mask >> idx) & 1));
+        }
+      }
+      rightContrib.set(basicVar, contrib);
+    }
+
+    // For combined to be valid, we need: rhs XOR leftContrib XOR rightContrib for basic vars
+    // We want to find left entries that, combined with this right, give minimum total
+
+    // The final basic var value is: rhs XOR leftContrib XOR rightContrib
+    // We want basic vars to be either 0 or 1 (any is valid), we just want minimum total presses
+
+    // For each right assignment, compute the required leftContrib pattern
+    // Wait, any leftContrib is valid - we just need to find the combination that gives min presses
+
+    // Actually, the solution is valid regardless of the basic var values (they're determined by the equations)
+    // We just want minimum total presses: sum of (free vars that are 1) + sum of (basic vars that are 1)
+
+    // For this right assignment:
+    // - right presses = popcount of right free vars
+    // - basic var final values depend on left contribution
+
+    const rightPressed = new Set<number>();
+    for (let i = 0; i < rightFree.length; i++) {
+      if ((mask >> i) & 1) {
+        rightPressed.add(rightFree[i]);
+      }
+    }
+    const rightCount = rightPressed.size;
+
+    // For each left pattern, compute the resulting basic var values and total count
+    for (const [sig, entries] of leftByPattern) {
+      const leftContribList = sig.split(',').map(Number);
+
+      // Compute basic var values
+      let basicCount = 0;
+      for (let r = 0; r < rank; r++) {
+        const basicVar = pivotCol[r];
+        const rhs = matrix[r][numCols];
+        const leftC = leftContribList[r];
+        const rightC = rightContrib.get(basicVar) ?? 0;
+        const finalVal = rhs ^ leftC ^ rightC;
+        if (finalVal === 1) basicCount++;
+      }
+
+      for (const entry of entries) {
+        const totalCount = entry.leftCount + rightCount + basicCount;
+
+        if (totalCount < bestCount || (totalCount === bestCount && bestSolution !== null)) {
+          // Build the solution
+          const solution = new Set<number>();
+          for (const p of entry.leftPressed) solution.add(p);
+          for (const p of rightPressed) solution.add(p);
+          for (let r = 0; r < rank; r++) {
+            const basicVar = pivotCol[r];
+            const rhs = matrix[r][numCols];
+            const leftC = leftContribList[r];
+            const rightC = rightContrib.get(basicVar) ?? 0;
+            const finalVal = rhs ^ leftC ^ rightC;
+            if (finalVal === 1) solution.add(basicVar);
+          }
+
+          const sortedSolution = Array.from(solution).sort((a, b) => a - b);
+
+          if (totalCount < bestCount || (totalCount === bestCount && compareLex(sortedSolution, bestSolution) < 0)) {
+            bestCount = totalCount;
+            bestSolution = sortedSolution;
+          }
+        }
+      }
+    }
+  }
+
+  return bestSolution;
+}
+
+function compareLex(a: number[], b: number[] | null): number {
+  if (b === null) return -1;
+  for (let i = 0; i < Math.max(a.length, b.length); i++) {
+    if (i >= a.length) return -1;
+    if (i >= b.length) return 1;
+    if (a[i] < b[i]) return -1;
+    if (a[i] > b[i]) return 1;
+  }
+  return 0;
+}
+
+export function solveCounter(
+  lights: number[],
+  buttons: number[][],
+  modulus: number
+): number[] | null {
+  const numCounters = lights.length;
+  const numButtons = buttons.length;
+
+  if (numCounters === 0) {
+    return new Array(numButtons).fill(0);
+  }
+
+  if (numButtons === 0) {
+    return lights.every(l => l === 0) ? [] : null;
+  }
+
+  // Build the augmented matrix over GF(modulus)
+  const matrix: number[][] = [];
+  for (let counter = 0; counter < numCounters; counter++) {
+    const row: number[] = [];
+    for (let btn = 0; btn < numButtons; btn++) {
+      row.push(buttons[btn].filter(c => c === counter).length % modulus);
+    }
+    row.push(lights[counter] % modulus);
+    matrix.push(row);
+  }
+
+  // Gaussian elimination over GF(p)
+  const numCols = numButtons;
+  const pivotCol: number[] = new Array(numCounters).fill(-1);
+  let pivotRow = 0;
+
+  for (let col = 0; col < numCols && pivotRow < numCounters; col++) {
+    // Find pivot
+    let found = -1;
+    for (let row = pivotRow; row < numCounters; row++) {
+      if (matrix[row][col] !== 0) {
+        found = row;
+        break;
+      }
+    }
+
+    if (found === -1) continue;
+
+    // Swap rows
+    [matrix[pivotRow], matrix[found]] = [matrix[found], matrix[pivotRow]];
+    pivotCol[pivotRow] = col;
+
+    // Scale pivot row so pivot is 1
+    const pivotVal = matrix[pivotRow][col];
+    const inv = modInverse(pivotVal, modulus);
+    for (let c = 0; c <= numCols; c++) {
+      matrix[pivotRow][c] = (matrix[pivotRow][c] * inv) % modulus;
+    }
+
+    // Eliminate
+    for (let row = 0; row < numCounters; row++) {
+      if (row !== pivotRow && matrix[row][col] !== 0) {
+        const factor = matrix[row][col];
+        for (let c = 0; c <= numCols; c++) {
+          matrix[row][c] = (matrix[row][c] - factor * matrix[pivotRow][c] % modulus + modulus) % modulus;
+        }
+      }
+    }
+    pivotRow++;
+  }
+
+  const rank = pivotRow;
+
+  // Check for inconsistency
+  for (let row = rank; row < numCounters; row++) {
+    if (matrix[row][numCols] !== 0) {
+      return null;
+    }
+  }
+
+  // Identify free and basic variables
+  const isBasic = new Set<number>();
+  for (let r = 0; r < rank; r++) {
+    isBasic.add(pivotCol[r]);
+  }
+
+  const freeVars: number[] = [];
+  for (let btn = 0; btn < numButtons; btn++) {
+    if (!isBasic.has(btn)) {
+      freeVars.push(btn);
+    }
+  }
+
+  const numFree = freeVars.length;
+
+  // Base solution (all free vars = 0)
+  const baseSolution: number[] = new Array(numButtons).fill(0);
+  for (let r = 0; r < rank; r++) {
+    baseSolution[pivotCol[r]] = matrix[r][numCols];
+  }
+
+  // If no free variables, return the unique solution
+  if (numFree === 0) {
+    // Verify it's valid (all values in range)
+    for (let btn = 0; btn < numButtons; btn++) {
+      if (baseSolution[btn] < 0 || baseSolution[btn] >= modulus) {
+        return null;
+      }
+    }
+    return baseSolution;
+  }
+
+  // For each free variable, compute its contribution to basic variables
+  // After RREF: x[basic] + sum(coeff * x[free]) = RHS
+  // So: x[basic] = RHS - sum(coeff * x[free])
+  // We store the negated coefficient so we can add during combination
+  const freeCoeffs: Map<number, Map<number, number>> = new Map(); // freeVar -> (basicVar -> -coeff)
+
+  for (const freeVar of freeVars) {
+    const coeffs = new Map<number, number>();
+    for (let r = 0; r < rank; r++) {
+      if (matrix[r][freeVar] !== 0) {
+        coeffs.set(pivotCol[r], (modulus - matrix[r][freeVar]) % modulus);
+      }
+    }
+    freeCoeffs.set(freeVar, coeffs);
+  }
+
+  // Meet-in-the-middle for minimum total presses
+  const half = Math.floor(numFree / 2);
+  const leftFree = freeVars.slice(0, half);
+  const rightFree = freeVars.slice(half);
+
+  // Generate left half entries
+  interface LeftEntry {
+    leftVals: Map<number, number>;
+    basicContrib: number[];
+    leftSum: number;
+  }
+  const leftEntries: LeftEntry[] = [];
+
+  function enumerateLeft(idx: number, assignment: Map<number, number>, basicContrib: number[], sum: number) {
+    if (idx === leftFree.length) {
+      leftEntries.push({
+        leftVals: new Map(assignment),
+        basicContrib: [...basicContrib],
+        leftSum: sum
+      });
+      return;
+    }
+
+    for (let val = 0; val < modulus; val++) {
+      assignment.set(leftFree[idx], val);
+      const newContrib = [...basicContrib];
+      const coeffs = freeCoeffs.get(leftFree[idx])!;
+      for (const [basicVar, coeff] of coeffs) {
+        const r = pivotCol.indexOf(basicVar);
+        if (r !== -1) {
+          newContrib[r] = (newContrib[r] + val * coeff % modulus + modulus) % modulus;
+        }
+      }
+      enumerateLeft(idx + 1, assignment, newContrib, sum + val);
+    }
+  }
+
+  enumerateLeft(0, new Map(), new Array(rank).fill(0), 0);
+
+  // Group by basicContrib signature and keep Pareto-optimal
+  const leftBySig: Map<string, LeftEntry[]> = new Map();
+  for (const entry of leftEntries) {
+    const sig = entry.basicContrib.join(',');
+    if (!leftBySig.has(sig)) {
+      leftBySig.set(sig, []);
+    }
+    leftBySig.get(sig)!.push(entry);
+  }
+
+  // For each signature, sort by leftSum and filter
+  for (const [sig, entries] of leftBySig) {
+    entries.sort((a, b) => a.leftSum - b.leftSum);
+    // Keep only the minimum for each signature
+    leftBySig.set(sig, [entries[0]]);
+  }
+
+  let bestSolution: number[] | null = null;
+  let bestSum = Infinity;
+
+  function enumerateRight(idx: number, assignment: Map<number, number>, basicContrib: number[], sum: number) {
+    if (idx === rightFree.length) {
+      // Compute what left basicContrib we need to match
+      // final basic = baseRHS + leftContrib + rightContrib
+      // We want to find left entries that give minimum total
+
+      const rightContrib = basicContrib;
+      const rightSum = sum;
+
+      // For each left signature, compute final basic values and total
+      for (const [sig, entries] of leftBySig) {
+        const leftContrib = sig.split(',').map(Number);
+        const leftEntry = entries[0];
+        const leftSum = leftEntry.leftSum;
+
+        // Final basic values
+        let basicSum = 0;
+        for (let r = 0; r < rank; r++) {
+          const baseRHS = matrix[r][numCols];
+          const finalVal = (baseRHS + leftContrib[r] + rightContrib[r]) % modulus;
+          basicSum += finalVal;
+        }
+
+        const totalSum = leftSum + rightSum + basicSum;
+
+        if (totalSum < bestSum || (totalSum === bestSum && bestSolution !== null)) {
+          // Build solution
+          const solution = new Array(numButtons).fill(0);
+
+          // Free vars
+          for (const [v, val] of leftEntry.leftVals) solution[v] = val;
+          for (const [v, val] of assignment) solution[v] = val;
+
+          // Basic vars
+          for (let r = 0; r < rank; r++) {
+            const baseRHS = matrix[r][numCols];
+            const finalVal = (baseRHS + leftContrib[r] + rightContrib[r]) % modulus;
+            solution[pivotCol[r]] = finalVal;
+          }
+
+          if (totalSum < bestSum || (totalSum === bestSum && compareLexArr(solution, bestSolution) < 0)) {
+            bestSum = totalSum;
+            bestSolution = solution;
+          }
+        }
+      }
+      return;
+    }
+
+    for (let val = 0; val < modulus; val++) {
+      assignment.set(rightFree[idx], val);
+      const newContrib = [...basicContrib];
+      const coeffs = freeCoeffs.get(rightFree[idx])!;
+      for (const [basicVar, coeff] of coeffs) {
+        const r = pivotCol.indexOf(basicVar);
+        if (r !== -1) {
+          newContrib[r] = (newContrib[r] + val * coeff % modulus + modulus) % modulus;
+        }
+      }
+      enumerateRight(idx + 1, assignment, newContrib, sum + val);
+    }
+  }
+
+  enumerateRight(0, new Map(), new Array(rank).fill(0), 0);
+
+  return bestSolution;
+}
+
+function compareLexArr(a: number[], b: number[] | null): number {
+  if (b === null) return -1;
+  for (let i = 0; i < Math.max(a.length, b.length); i++) {
+    if (i >= a.length) return -1;
+    if (i >= b.length) return 1;
+    if (a[i] < b[i]) return -1;
+    if (a[i] > b[i]) return 1;
+  }
+  return 0;
+}
+
+function modInverse(a: number, p: number): number {
+  // Extended Euclidean algorithm
+  let [old_r, r] = [a, p];
+  let [old_s, s] = [1, 0];
+
+  while (r !== 0) {
+    const quotient = Math.floor(old_r / r);
+    [old_r, r] = [r, old_r - quotient * r];
+    [old_s, s] = [s, old_s - quotient * s];
+  }
+
+  return ((old_s % p) + p) % p;
+}
