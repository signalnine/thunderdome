+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter, Machine } from './index.js';
+
+describe('solveToggle', () => {
+  it('solves the example from the problem (returns null)', () => {
+    const machine: Machine = {
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]]
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('solves a simple solvable case', () => {
+    const machine: Machine = {
+      target: [true, false],
+      buttons: [[0], [1]]
+    };
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('solves when all lights should be off', () => {
+    const machine: Machine = {
+      target: [false, false, false],
+      buttons: [[0], [1], [2]]
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('solves a case requiring all buttons', () => {
+    const machine: Machine = {
+      target: [true, true],
+      buttons: [[0], [1]]
+    };
+    expect(solveToggle(machine)).toEqual([0, 1]);
+  });
+
+  it('returns null for impossible case', () => {
+    const machine: Machine = {
+      target: [true],
+      buttons: []
+    };
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('handles empty target', () => {
+    const machine: Machine = {
+      target: [],
+      buttons: [[0], [1]]
+    };
+    expect(solveToggle(machine)).toEqual([]);
+  });
+
+  it('solves a case with multiple solutions, returns minimum', () => {
+    // Two ways to turn on light 0: button 0 alone, or buttons 1+2 together
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0], [0]]
+    };
+    // Button 0 alone is optimal
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('solves a case with tied solutions, returns lexicographically smallest', () => {
+    // Buttons 0 and 1 both toggle light 0
+    const machine: Machine = {
+      target: [true],
+      buttons: [[0], [0]]
+    };
+    // Either button works, return [0] as it's lexicographically smaller
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+
+  it('handles larger instance', () => {
+    // 5 lights, 3 buttons
+    const machine: Machine = {
+      target: [true, true, false, false, true],
+      buttons: [[0, 1], [2, 3], [4, 0]]
+    };
+    // Button 0: lights [0,1] -> [on, on, off, off, off]
+    // Button 2: lights [4,0] -> [off, on, off, off, on]
+    // Wait, that doesn't work. Let me recalculate.
+    // We need [1,1,0,0,1]
+    // Button 0 affects {0,1}, Button 1 affects {2,3}, Button 2 affects {4,0}
+    // light 0: b0 XOR b2 = 1
+    // light 1: b0 = 1
+    // light 2: b1 = 0
+    // light 3: b1 = 0
+    // light 4: b2 = 1
+    // From light 1: b0 = 1
+    // From light 4: b2 = 1
+    // Check light 0: 1 XOR 1 = 0 ≠ 1. No solution!
+    expect(solveToggle(machine)).toBeNull();
+  });
+
+  it('solves a solvable larger instance', () => {
+    const machine: Machine = {
+      target: [true, true, false, false, false],
+      buttons: [[0, 1], [2, 3], [4, 0]]
+    };
+    // We need [1,1,0,0,0]
+    // light 0: b0 XOR b2 = 1
+    // light 1: b0 = 1
+    // light 2: b1 = 0
+    // light 3: b1 = 0
+    // light 4: b2 = 0
+    // From light 1: b0 = 1
+    // From light 4: b2 = 0
+    // Check light 0: 1 XOR 0 = 1 ✓
+    expect(solveToggle(machine)).toEqual([0]);
+  });
+});
