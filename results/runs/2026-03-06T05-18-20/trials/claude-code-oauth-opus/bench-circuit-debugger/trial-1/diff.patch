its = maxBit + 1;\n  const finalZ = `z${numBits.toString().padStart(2, '0')}`;\n\n  // Build lookup: wire -> gate that produces it\n  const producerOf = new Map<string, Gate>();\n  for (const g of gates) {\n    producerOf.set(g.out, g);\n  }\n\n  // Build lookup: wire -> set of consumer gate ops\n  const consumedByOps = new Map<string, Set<string>>();\n  for (const g of gates) {\n    for (const inp of [g.in1, g.in2]) {\n      let s = consumedByOps.get(inp);\n      if (!s) {\n        s = new Set();\n        consumedByOps.set(inp, s);\n      }\n      s.add(g.op);\n    }\n  }\n\n  const isXYInput = (w: string) => /^[xy]\\d+$/.test(w);\n  const isZOutput = (w: string) => /^z\\d+$/.test(w);\n  const hasXYInputs = (g: Gate) => isXYInput(g.in1) && isXYInput(g.in2);\n  const isHalfAdderBit = (g: Gate) =>\n    (g.in1 === 'x00' && g.in2 === 'y00') ||\n    (g.in1 === 'y00' && g.in2 === 'x00');\n\n  const badWires = new Set<string>();\n\n  for (const g of gates) {\n    const out = g.out;\n    const ops = consumedByOps.get(out) ?? new Set();\n\n    if (g.op === 'XOR') {\n      if (hasXYInputs(g)) {\n        if (isHalfAdderBit(g)) {\n          // x00 XOR y00 must output z00\n          if (out !== 'z00') {\n            badWires.add(out);\n          }\n        } else {\n          // Partial sum XOR must feed into XOR and AND\n          if (!ops.has('XOR') || !ops.has('AND')) {\n            badWires.add(out);\n          }\n        }\n      } else {\n        // Sum XOR must output a z-wire\n        if (!isZOutput(out)) {\n          badWires.add(out);\n        }\n\n        // Additional check: one input should come from a XOR gate (partial sum)\n        // and the other from an OR gate or initial carry (AND x00 y00).\n        // If both inputs come from XOR gates, one of the inputs is a swapped\n        // carry wire (should be from OR but was swapped with partial sum).\n        const prod1 = producerOf.get(g.in1);\n        const prod2 = producerOf.get(g.in2);\n\n        // Determine which input is the partial sum and which is carry\n        const isPartialSum = (p: Gate | undefined) =>\n          p !== undefined && p.op === 'XOR' && hasXYInputs(p);\n        const isCarry = (p: Gate | undefined) =>\n          p !== undefined && (p.op === 'OR' || (p.op === 'AND' && isHalfAdderBit(p)));\n\n        if (isPartialSum(prod1) && isPartialSum(prod2)) {\n          // Both inputs are partial sums — one should be a carry\n          // The wire that's in the carry position (should be from OR) is bad\n          // We can't tell which is which by position alone, so flag both inputs\n          // Actually, one of the inputs IS a partial sum that was swapped with a carry\n          // We need to check which input's wire name was swapped\n          badWires.add(g.in1);\n          badWires.add(g.in2);\n        } else if (!isPartialSum(prod1) && !isPartialSum(prod2) && !isCarry(prod1) && !isCarry(prod2)) {\n          // Neither input is from expected source types\n          badWires.add(g.in1);\n          badWires.add(g.in2);\n        }\n      }\n    } else if (g.op === 'AND') {\n      if (isHalfAdderBit(g)) {\n        // Initial carry must feed into XOR (if there are more bits)\n        if (numBits > 1 && !ops.has('XOR')) {\n          badWires.add(out);\n        }\n      } else {\n        // Generate/propagate AND must feed into OR gate\n        if (!ops.has('OR')) {\n          badWires.add(out);\n        }\n      }\n    } else if (g.op === 'OR') {\n      if (out === finalZ) {\n        // Final carry is z_final — correct\n      } else {\n        // Carry must feed into XOR and AND\n        if (!ops.has('XOR') || !ops.has('AND')) {\n          badWires.add(out);\n        }\n        // Carry should not be a z-wire\n        if (isZOutput(out)) {\n          badWires.add(out);\n        }\n      }\n    }\n  }\n\n  return [...badWires].sort();\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_token