 return inputs;\n    37→}\n    38→\n    39→function readZ(wires: Record<string, number>, bits: number): number {\n    40→  let result = 0;\n    41→  for (let i = 0; i <= bits; i++) {\n    42→    const key = `z${i.toString().padStart(2, '0')}`;\n    43→    if (wires[key]) {\n    44→      result |= 1 << i;\n    45→    }\n    46→  }\n    47→  return result;\n    48→}\n    49→\n    50→describe('simulate', () => {\n    51→  it('computes basic gate operations', () => {\n    52→    const gates: Gate[] = [\n    53→      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    54→      { op: 'OR', in1: 'a', in2: 'b', out: 'd' },\n    55→      { op: 'XOR', in1: 'a', in2: 'b', out: 'e' },\n    56→    ];\n    57→    const result = simulate(gates, { a: 1, b: 0 });\n    58→    expect(result.c).toBe(0);\n    59→    expect(result.d).toBe(1);\n    60→    expect(result.e).toBe(1);\n    61→  });\n    62→\n    63→  it('handles dependency chains', () => {\n    64→    const gates: Gate[] = [\n    65→      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    66→      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    67→    ];\n    68→    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    69→    expect(result.c).toBe(1);\n    70→    expect(result.e).toBe(1);\n    71→  });\n    72→\n    73→  it('handles all AND combinations', () => {\n    74→    expect(simulate([{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }], { a: 0, b: 0 }).c).toBe(0);\n    75→    expect(simulate([{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }], { a: 0, b: 1 }).c).toBe(0);\n    76→    expect(simulate([{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }], { a: 1, b: 0 }).c).toBe(0);\n    77→    expect(simulate([{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }], { a: 1, b: 1 }).c).toBe(1);\n    78→  });\n    79→\n    80→  it('handles all OR combinations', () => {\n    81→    expect(simulate([{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }], { a: 0, b: 0 }).c).toBe(0);\n    82→    expect(simulate([{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }], { a: 0, b