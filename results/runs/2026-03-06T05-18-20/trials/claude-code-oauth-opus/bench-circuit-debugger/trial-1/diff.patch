te | undefined;\n      let foundViaCarry: Gate | undefined;\n\n      for (const g of gates) {\n        if (g.op !== 'XOR') continue;\n        if (g === partialXor) continue;\n        if (g.in1 === tWire || g.in2 === tWire) {\n          foundViaTWire = g;\n        }\n        if (g.in1 === carry || g.in2 === carry) {\n          foundViaCarry = g;\n        }\n      }\n\n      if (foundViaTWire && !foundViaCarry) {\n        // carry is wrong; the other input of foundViaTWire should be carry\n        const otherInput =\n          foundViaTWire.in1 === tWire\n            ? foundViaTWire.in2\n            : foundViaTWire.in1;\n        swapOutputs(carry, otherInput);\n        // Recompute carry\n        const prevAndGate = findGate('AND', `x${pad(i - 1)}`, `y${pad(i - 1)}`);\n        if (i === 1) {\n          carry = prevAndGate!.out;\n        } else {\n          // Carry is the OR gate output from previous bit - we need to find it\n          // It's simpler to just use otherInput as the correct carry\n          carry = otherInput;\n        }\n        sumXor = findGate('XOR', tWire, carry);\n      } else if (foundViaCarry && !foundViaTWire) {\n        // tWire is wrong\n        const otherInput =\n          foundViaCarry.in1 === carry\n            ? foundViaCarry.in2\n            : foundViaCarry.in1;\n        swapOutputs(tWire, otherInput);\n        partialXor = findGate('XOR', xWire, yWire);\n        tWire = partialXor!.out;\n        sumXor = findGate('XOR', tWire, carry);\n      } else if (foundViaTWire && foundViaCarry) {\n        // Both found different gates — one of the wires is swapped\n        // The foundViaCarry gate has carry + something, where something should be tWire\n        // The foundViaTWire gate has tWire + something, where something should be carry\n        // This means carry and tWire's actual wires got swapped somehow\n        // Let's check which correction makes sense\n        const otherFromCarry =\n          foundViaCarry.in1 === carry\n          