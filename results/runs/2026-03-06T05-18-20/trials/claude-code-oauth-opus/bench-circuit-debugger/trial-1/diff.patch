he structural pattern of a ripple-carry adder and find\n * gates whose outputs violate the expected pattern.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Build lookup structures\n  const gateByOut = new Map<string, Gate>();\n  for (const g of gates) {\n    gateByOut.set(g.out, g);\n  }\n\n  // Helper: check if a wire is an x/y input\n  const isInput = (w: string) => /^[xy]\\d+$/.test(w);\n\n  // Helper: find a gate by its op and input wires (order-independent)\n  const findGate = (\n    op: string,\n    a: string,\n    b: string\n  ): Gate | undefined => {\n    for (const g of gates) {\n      if (\n        g.op === op &&\n        ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a))\n      ) {\n        return g;\n      }\n    }\n    return undefined;\n  };\n\n  // Determine the number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    const mx = g.in1.match(/^x(\\d+)$/);\n    const my = g.in2.match(/^x(\\d+)$/);\n    if (mx) maxBit = Math.max(maxBit, parseInt(mx[1]));\n    if (my) maxBit = Math.max(maxBit, parseInt(my[1]));\n  }\n  const numBits = maxBit + 1;\n\n  const swapped = new Set<string>();\n\n  // Helper to swap two gate outputs and update our lookup\n  const swapOutputs = (w1: string, w2: string) => {\n    swapped.add(w1);\n    swapped.add(w2);\n    const g1 = gateByOut.get(w1)!;\n    const g2 = gateByOut.get(w2)!;\n    g1.out = w2;\n    g2.out = w1;\n    gateByOut.set(w1, g2);\n    gateByOut.set(w2, g1);\n  };\n\n  // For a correct ripple-carry adder, the structure for each bit is:\n  //\n  // Bit 0 (half adder):\n  //   x00 XOR y00 -> z00\n  //   x00 AND y00 -> c00\n  //\n  // Bit i (i > 0, full adder):\n  //   xNN XOR yNN -> tNN    (partial sum)\n  //   tNN XOR cPrev -> zNN  (final sum)\n  //   xNN AND yNN -> aNN    (generate)\n  //   tNN AND cPrev -> bNN  (propagate)\n  //   aNN OR bNN -> cNN     (carry out)\n  //\n  // Final: c(N-1) -> z(N)  (last carry = MSB of output)\n  //\n  // We trace through bit by bit, identifying structural violations.\n\n  const pad = (n: number) => n.toString().padStart(2, '0');\n\n  // Process bit 0\n  // Find x00 XOR y00 -> should be z00\n  let xorGate = findGate('XOR', 'x00', 'y00');\n  let andGate = findGate('AND', 'x00', 'y00');\n\n  if (xorGate && xorGate.out !== 'z00') {\n    // The XOR gate output should be z00. Find what currently outputs z00.\n    if (andGate && andGate.out === 'z00') {\n      swapOutputs(xorGate.out, andGate.out);\n      // Refresh references\n      xorGate = findGate('XOR', 'x00', 'y00');\n      andGate = findGate('AND', 'x00', 'y00');\n    } else {\n      swapOutputs(xorGate.out, 'z00');\n      xorGate = findGate('XOR', 'x00', 'y00');\n      andGate = findGate('AND', 'x00', 'y00');\n    }\n  }\n\n  let carry = andGate!.out; // c00\n\n  // Process bits 1 through numBits-1\n  for (let i = 1; i < numBits; i++) {\n    const xWire = `x${pad(i)}`;\n    const yWire = `y${pad(i)}`;\n    const zWire = `z${pad(i)}`;\n\n    // Step 1: Find xNN XOR yNN -> tNN (partial sum)\n    let partialXor = findGate('XOR', xWire, yWire);\n    if (!partialXor) break;\n\n    let tWire = partialXor.out;\n\n    // If tWire is a z-wire, it's likely swapped with something\n    if (tWire.startsWith('z')) {\n      // The partial XOR should NOT output directly to z.\n      // We need to find the correct swap partner.\n      // The final sum gate should be: tNN XOR carry -> zNN\n      // Since tWire is incorrectly a z-wire, find what should be zNN's output.\n      // Look for the gate that uses carry as input with XOR\n      // That gate's other input tells us what tWire should be.\n\n      // For now, let's check: is there a gate (? XOR carry -> zNN)?\n      // The wire that should produce zNN might have been swapped with tWire.\n      // Try to find the gate that should produce zNN.\n      const gateForZ = gateByOut.get(zWire);\n      if (gateForZ) {\n        swapOutputs(tWire, zWire);\n        partialXor = findGate('XOR', xWire, yWire);\n        tWire = partialXor!.out;\n      }\n    }\n\n    // Step 2: Find tNN XOR carry -> zNN (final sum)\n    let sumXor = findGate('XOR', tWire, carry);\n\n    if (!sumXor) {\n      // carry or tWire might be wrong due to a swap.\n      // Try: find any XOR gate that uses carry as input\n      // or any XOR gate that uses tWire as input (other than the partialXor).\n      let foundViaTWire: Gate | undefined;\n      let foundViaCarry: Gate | undefined;\n\n      for (const g of gates) {\n        if (g.op !== 'XOR') continue;\n        if (g === partialXor) continue;\n        if (g.in1 === tWire || g.in2 === tWire) {\n          foundViaTWire = g;\n        }\n        if (g.in1 === carry || g.in2 === carry) {\n          foundViaCarry = g;\n        }\n      }\n\n      if (foundViaTWire && !foundViaCarry) {\n        // carry is wrong; the other input of foundViaTWire should be carry\n        const otherInput =\n          foundViaTWire.in1 === tWire\n            ? foundViaTWire.in2\n            : foundViaTWire.in1;\n        swapOutputs(carry, otherInput);\n        // Recompute carry\n        const prevAndGate = findGate('AND', `x${pad(i - 1)}`, `y${pad(i - 1)}`);\n        if (i === 1) {\n          carry = prevAndGate!.out;\n        } else {\n          // Carry is the OR gate output from previous bit - we need to find it\n          // It's simpler to just use otherInput as the correct carry\n          carry = otherInput;\n        }\n        sumXor = findGate('XOR', tWire, carry);\n      } else if (foundViaCarry && !foundViaTWire) {\n        // tWire is wrong\n        const otherInput =\n          foundViaCarry.in1 === carry\n            ? foundViaCarry.in2\n            : foundViaCarry.in1;\n        swapOutputs(tWire, otherInput);\n        partialXor = findGate('XOR', xWire, yWire);\n        tWire = partialXor!.out;\n        sumXor = findGate('XOR', tWire, carry);\n      } else if (foundViaTWire && foundViaCarry) {\n        // Both found different gates — one of the wires i