{i.toString().padStart(2, '0')}`] = (y >> i) & 1;\n  }\n  return inputs;\n}\n\nfunction readZ(wires: Record<string, number>, bits: number): number {\n  let result = 0;\n  for (let i = 0; i <= bits; i++) {\n    const key = `z${i.toString().padStart(2, '0')}`;\n    if (wires[key]) {\n      result |= 1 << i;\n    }\n  }\n  return result;\n}\n\ndescribe('simulate', () => {\n  it('computes basic gate operations', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'a', in2: 'b', out: 'd' },\n      { op: 'XOR', in1: 'a', in2: 'b', out: 'e' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result.c).toBe(0);\n    expect(result.d).toBe(1);\n    expect(result.e).toBe(1);\n  });\n\n  it('handles dependency chains', () => {\n    const gates: Gate[] = [\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n    ];\n    const result = simulate(gates, { a: 1, b: 1, d: 0 });\n    expect(result.c).toBe(1);\n    expect(result.e).toBe(1);\n  });\n\n  it('handles all AND combinations', () => {\n    expect(simulate([{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }], { a: 0, b: 0 }).c).toBe(0);\n    expect(simulate([{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }], { a: 0, b: 1 }).c).toBe(0);\n    expect(simulate([{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }], { a: 1, b: 0 }).c).toBe(0);\n    expect(simulate([{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }], { a: 1, b: 1 }).c).toBe(1);\n  });\n\n  it('handles all OR combinations', () => {\n    expect(simulate([{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }], { a: 0, b: 0 }).c).toBe(0);\n    expect(simulate([{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }], { a: 0, b: 1 }).c).toBe(1);\n    expect(simulate([{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }], { a: 1, b: 0 }).c).toBe(1);\n    expect(simulate([{ op: 'OR', in1: 'a', in2: 'b', out: 'c' }], { a: 1, b: 1 }).c).toBe(1);\n  });\n\n  it('handles all XOR combinations', () => {\n    expect(simulate([{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }], { a: 0, b: 0 }).c).toBe(0);\n    expect(simulate([{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }], { a: 0, b: 1 }).c).toBe(1);\n    expect(simulate([{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }], { a: 1, b: 0 }).c).toBe(1);\n    expect(simulate([{ op: 'XOR', in1: 'a', in2: 'b', out: 'c' }], { a: 1, b: 1 }).c).toBe(0);\n  });\n\n  it('simulates a 4-bit adder correctly', () => {\n    const gates = make4BitAdder();\n    // Test 7 + 8 = 15\n    const wires = simulate(gates, makeInputs(7, 8, 4));\n    expect(readZ(wires, 4)).toBe(15);\n  });\n\n  it('simulates 4-bit adder with carry', () => {\n    const gates = make4BitAdder();\n    // 15 + 1 = 16 (requires carry into bit 4)\n    const wires = simulate(gates, makeInputs(15, 1, 4));\n    expect(readZ(wires, 4)).toBe(16);\n  });\n\n  it('simulates multiple additions', () => {\n    const gates = make4BitAdder();\n    for (let x = 0; x < 16; x++) {\n      for (let y = 0; y < 16; y++) {\n        const wires = simulate(gates, makeInputs(x, y, 4));\n        expect(readZ(wires, 4)).toBe(x + y);\n      }\n    }\n  });\n});\n\n// Helper to build a large correct adder\nfunction makeAdder(numBits: number): Gate[] {\n  const gates: Gate[] = [];\n  const pad = (n: number) => n.toString().padStart(2, '0');\n\n  // Bit 0: half adder\n  gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n  gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' });\n\n  for (let i = 1; i < numBits; i++) {\n    const x = `x${pad(i)}`;\n    const y = `y${pad(i)}`;\n    const t = `t${pad(i)}`;\n    const z = `z${pad(i)}`;\n    const a = `a${pad(i)}`;\n    const b = `b${pad(i)}`;\n    const c = `c${pad(i)}`;\n    const cPrev = `c${pad(i - 1)}`;\n\n    gates.push({ op: 'XOR', in1: x, in2: y, out: t });\n    gates.push({ op: 'XOR', in1: t, in2: cPrev, out: z });\n    gates.push({ op: 'AND', in1: x, in2: y, out: a });\n    gates.push({ op: 'AND', in1: t, in2: cPrev, out: b });\n    gates.push({ op: 'OR', in1: a, in2: b, out: c });\n  }\n\n  // Final carry: the last carry OR gate directly outputs z(numBits)\n  // In the real circuit, the carry out of the last full adder IS the MSB\n  // So we rename the last carry wire to the final z wire\n  const lastCarryWire = `c${pad(numBits - 1)}`;\n  const finalZWire = `z${pad(numBits)}`;\n  // Find the last OR gate (carry out of last bit) and rename its output\n  const lastOrGate = gates.find(g => g.out === lastCarryWire);\n  if (lastOrGate) {\n    lastOrGate.out = finalZWire;\n    // Also update any references to this wire in other gates' inputs\n    // (there shouldn't be any since it's the last carry, but just in case)\n    for (const g of gates) {\n      if (g.in1 === lastCarryWire) g.in1 = finalZWire;\n      if (g.in2 === lastCarryWire) g.in2 = finalZWire;\n    }\n  }\n\n  return gates;\n}\n\nfunction swapOutputWires(gates: Gate[], w1: string, w2: string) {\n  const g1 = gates.find((g) => g.out === w1)!;\n  const g2 = gates.find((g) => g.out === w2)!;\n  g1.out = w2;\n  g2.out = w1;\n}\n\ndescribe('findSwappedWires', () => {\n  it('finds swapped wires in an 8-bit adder', () => {\n    const gates = makeAdder(8);\n    // Swap 4 pairs - all structurally detectable swaps\n    swapOutputWires(gates, 'z01', 'a01');  // sum output <-> generate AND\n    swapOutputWires(gates, 't03', 'c03');  // partial sum <-> carry out\n    swapOutputWires(gates, 'z05', 'b05');  // sum output <-> propagate AND\n    swapOutputWires(gates, 'a07', 'z08');  // generate AND (bit7) <-> sum output (bit8)\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a01', 'a07', 'b05', 'c03', 't03', 'z01', 'z05', 'z08'].sort()\n    );\n  });\n\n  it('finds swapped wires in a 16-bit adder', () => {\n    const gates = makeAdder(16);\n    swapOutputWires(gates, 'z02', 't02');  // sum output <-> partial sum\n    swapOutputWires(gates, 'c05', 'z06');  // carry out (bit5) <-> sum output (bit6)\n    swapOutputWires(gates, 'c10', 'z11');  // carry out (bit10) <-> sum output (bit11)\n    swapOutputWires(gates, 'z15', 'a15');  // sum output <-> generate AND\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['a15', 'c05', 'c10', 't02', 'z02', 'z06', 'z11', 'z15'].sort()\n    );\n  });\n\n  it('finds swapped wires in a 45-bit adder under 5 seconds', () => {\n    const gates = makeAdder(45);\n    swapOutputWires(gates, 'z01', 'c01');\n    swapOutputWires(gates, 't10', 'a10');\n    swapOutputWires(gates, 'b25', 'z25');\n    swapOutputWires(gates, 'z44', 'c44');\n\n    const start = performance.now();\n    const result = findSwappedWires(gates);\n    const elapsed = performance.now() - start;\n\n    expect(elapsed).toBeLessThan(5000);\n    expect(result).toEqual(\n      ['a10', 'b25', 'c01', 'c44', 't10', 'z01', 'z25', 'z44'].sort()\n    );\n  });\n\n  it('finds swaps involving z00 and the final carry', () => {\n    const gates = makeAdder(8);\n    swapOutputWires(gates, 'z00', 'c00');     // bit0 XOR output <-> bit0 AND output\n    swapOutputWires(gates, 't02', 'z02');     // partial sum <-> sum output\n    swapOutputWires(gates, 'z04', 'b04');     // sum <-> propagate AND\n    swapOutputWires(gates, 'c07', 'z08');     // last carry <-> final z\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['b04', 'c00', 'c07', 't02', 'z00', 'z02', 'z04', 'z08'].sort()\n    );\n  });\n\n  it('handles circuits with random wire names', () => {\n    // Build a 4-bit adder with random internal wire names\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'abc' },  // c00\n\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 'def' },  // t01\n      { op: 'XOR', in1: 'def', in2: 'abc', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'ghi' },  // a01\n      { op: 'AND', in1: 'def', in2: 'abc', out: 'jkl' },  // b01\n      { op: 'OR', in1: 'ghi', in2: 'jkl', out: 'mno' },   // c01\n\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 'pqr' },  // t02\n      { op: 'XOR', in1: 'pqr', in2: 'mno', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'stu' },  // a02\n      { op: 'AND', in1: 'pqr', in2: 'mno', out: 'vwx' },  // b02\n      { op: 'OR', in1: 'stu', in2: 'vwx', out: 'yza' },   // c02\n\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 'bbb' },  // t03\n      { op: 'XOR', in1: 'bbb', in2: 'yza', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'ccc' },  // a03\n      { op: 'AND', in1: 'bbb', in2: 'yza', out: 'ddd' },  // b03\n      { op: 'OR', in1: 'ccc', in2: 'ddd', out: 'eee' },   // c03\n\n      { op: 'OR', in1: 'eee', in2: 'eee', out: 'z04' },   // final carry\n    ];\n\n    // Swap z01 <-> ghi (sum output <-> generate)\n    // Swap z03 <-> pqr (sum output bit3 <-> partial sum bit2)\n    // Swap abc <-> z00 (carry0 <-> sum0)\n    // Swap eee <-> z04 (carry3 <-> final z)\n    swapOutputWires(gates, 'z01', 'ghi');\n    swapOutputWires(gates, 'z03', 'pqr');\n    swapOutputWires(gates, 'abc', 'z00');\n    swapOutputWires(gates, 'eee', 'z04');\n\n    const result = findSwappedWires(gates);\n    expect(result).toEqual(\n      ['abc', 'eee', 'ghi', 'pqr', 'z00', 'z01', 'z03', 'z04'].sort()\n    );\n  });\n});\n"}}
