 }\n        }","originalFile":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\n/**\n * Simulate a circuit of logic gates given initial wire values.\n * Returns the final value of every wire.\n */\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>\n): Record<string, number> {\n  const wires: Record<string, number> = { ...inputs };\n  const pending = [...gates];\n\n  let progress = true;\n  while (pending.length > 0 && progress) {\n    progress = false;\n    for (let i = pending.length - 1; i >= 0; i--) {\n      const gate = pending[i];\n      const v1 = wires[gate.in1];\n      const v2 = wires[gate.in2];\n      if (v1 !== undefined && v2 !== undefined) {\n        let result: number;\n        switch (gate.op) {\n          case 'AND':\n            result = v1 & v2;\n            break;\n          case 'OR':\n            result = v1 | v2;\n            break;\n          case 'XOR':\n            result = v1 ^ v2;\n            break;\n        }\n        wires[gate.out] = result;\n        pending.splice(i, 1);\n        progress = true;\n      }\n    }\n  }\n\n  return wires;\n}\n\n/**\n * Find the 8 wires (4 swapped pairs) in a broken binary adder circuit.\n *\n * Uses structural rule checking. Every gate in a correct ripple-carry adder\n * must satisfy specific invariants about its output and how that output\n * is consumed by downstream gates.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Determine number of input bits\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const inp of [g.in1, g.in2]) {\n      const m = inp.match(/^x(\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));\n    }\n  }\n  const numBits = maxBit + 1;\n  const finalZ = `z${numBits.toString().padStart(2, '0')}`;\n\n  // Build lookup: wire -> gate that produces it\n  const producerOf = new Map<string, Gate>();\n  for (const g of gates) {\n    producerOf.set(g.out, g);\n  }\n\n  // Build lookup: wire -> set of consumer gate ops\n  const consumedByOps = new Map<string, Set<string>>();\n  for (const g of gates) {\n    for (const inp of [g.in1, g.in2]) {\n      let s = consumedByOps.get(inp);\n      if (!s) {\n        s = new Set();\n        consumedByOps.set(inp, s);\n      }\n      s.add(g.op);\n    }\n  }\n\n  const isXYInput = (w: string) => /^[xy]\\d+$/.test(w);\n  const isZOutput = (w: string) => /^z\\d+$/.test(w);\n  const hasXYInputs = (g: Gate) => isXYInput(g.in1) && isXYInput(g.in2);\n  const isHalfAdderBit = (g: Gate) =>\n    (g.in1 === 'x00' && g.in2 === 'y00') ||\n    (g.in1 === 'y00' && g.in2 === 'x00');\n\n  const badWires = new Set<string>();\n\n  for (const g of gates) {\n    const out = g.out;\n    const ops = consumedByOps.get(out) ?? new Set();\n\n    if (g.op === 'XOR') {\n      if (hasXYInputs(g)) {\n        if (isHalfAdderBit(g)) {\n          // x00 XOR y00 must output z00\n          if (out !== 'z00') {\n            badWires.add(out);\n          }\n        } else {\n          // Partial sum XOR must feed into XOR and AND\n          if (!ops.has('XOR') || !ops.has('AND')) {\n            badWires.add(out);\n          }\n        }\n      } else {\n        // Sum XOR must output a z-wire\n        if (!isZOutput(out)) {\n          badWires.add(out);\n        }\n\n        // Additional check: one input should come from a XOR gate (partial sum)\n        // and the other from an OR gate or initial carry (AND x00 y00).\n        // If both inputs come from XOR gates, one of the inputs is a swapped\n        // carry wire (should be from OR but was swapped with partial sum).\n        const prod1 = producerOf.get(g.in1);\n        const prod2 = producerOf.get(g.in2);\n\n        // Determine which input is the partial sum and which is carry\n        const isPartialSum = (p: Gate | undefined) =>\n          p !== undefined && p.op === 'XOR' && hasXYInputs(p);\n        const isCarry = (p: Gate | undefined) =>\n          p !== undefined && (p.op === 'OR' || (p.op === 'AND' && isHalfAdderBit(p)));\n\n        // Determine which input is the partial sum for THIS bit\n        // The z output tells us the bit index; the partial sum for that bit\n        // comes from XOR(xNN, yNN) with matching NN.\n        const zMatch = out.match(/^z(\\d+)$/);\n        const bitIdx = zMatch ? zMatch[1] : null;\n        const xForBit = bitIdx ? `x${bitIdx}` : null;\n        const yForBit = bitIdx ? `y${bitIdx}` : null;\n\n        const isPartialSumForThisBit = (p: Gate | undefined) =>\n          p !== undefined && p.op === 'XOR' &&\n          ((p.in1 === xForBit && p.in2 === yForBit) ||\n           (p.in1 === yForBit && p.in2 === xForBit));\n\n        // Identify which input is the partial sum and which is the carry\n        const ps1 = isPartialSumForThisBit(prod1);\n        const ps2 = isPartialSumForThisBit(prod2);\n\n        if (ps1 && !isCarry(prod2)) {\n          // in2 should be carry but isn't\n          badWires.add(g.in2);\n        } else if (ps2 && !isCarry(prod1)) {\n          // in1 should be carry but isn't\n          badWires.add(g.in1);\n        } else if (!ps1 && !ps2) {\n          // Neither input is the correct partial sum — both might be wrong\n          if (!isCarry(prod1)) badWires.add(g.in1);\n          if (!isCarry(prod2)) badWires.add(g.in2);\n        }\n      }\n    } else if (g.op === 'AND') {\n      if (isHalfAdderBit(g)) {\n        // Initial carry must feed into XOR (if there are more bits)\n        if (numBits > 1 && !ops.has('XOR')) {\n          badWires.add(out);\n        }\n      } else {\n        // Generate/propagate AND must feed into OR gate\n        if (!ops.has('OR')) {\n          badWires.add(out);\n        }\n      }\n    } else if (g.op === 'OR') {\n      if (out === finalZ) {\n        // Final carry is z_final — correct\n      } else {\n        // Carry must feed into XOR and AND\n        if (!ops.has('XOR') || !ops.has('AND')) {\n          badWires.add(out);\n        }