@@ -0,0 +1,296 @@
+export interface Gate {
+  op: 'AND' | 'OR' | 'XOR';
+  in1: string;
+  in2: string;
+  out: string;
+}
+
+/**
+ * Simulate a circuit of logic gates given initial wire values.
+ * Returns the final value of every wire.
+ */
+export function simulate(
+  gates: Gate[],
+  inputs: Record<string, number>
+): Record<string, number> {
+  const wires: Record<string, number> = { ...inputs };
+  const pending = [...gates];
+
+  let progress = true;
+  while (pending.length > 0 && progress) {
+    progress = false;
+    for (let i = pending.length - 1; i >= 0; i--) {
+      const gate = pending[i];
+      const v1 = wires[gate.in1];
+      const v2 = wires[gate.in2];
+      if (v1 !== undefined && v2 !== undefined) {
+        let result: number;
+        switch (gate.op) {
+          case 'AND':
+            result = v1 & v2;
+            break;
+          case 'OR':
+            result = v1 | v2;
+            break;
+          case 'XOR':
+            result = v1 ^ v2;
+            break;
+        }
+        wires[gate.out] = result;
+        pending.splice(i, 1);
+        progress = true;
+      }
+    }
+  }
+
+  return wires;
+}
+
+/**
+ * Find the 8 wires (4 swapped pairs) in a broken binary adder circuit.
+ *
+ * Uses structural rule checking to identify gates whose outputs violate
+ * the invariants of a correct ripple-carry adder.
+ */
+export function findSwappedWires(gates: Gate[]): string[] {
+  // Determine number of input bits
+  let maxBit = 0;
+  for (const g of gates) {
+    for (const inp of [g.in1, g.in2]) {
+      const m = inp.match(/^x(\d+)$/);
+      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));
+    }
+  }
+  const numBits = maxBit + 1;
+  const finalZ = `z${numBits.toString().padStart(2, '0')}`;
+
+  // Build lookup: wire -> gate that produces it
+  const producerOf = new Map<string, Gate>();
+  for (const g of gates) {
+    producerOf.set(g.out, g);
+  }
+
+  // Build lookup: wire -> set of consumer ops
+  const consumedByOps = new Map<string, Set<string>>();
+  for (const g of gates) {
+    for (const inp of [g.in1, g.in2]) {
+      let s = consumedByOps.get(inp);
+      if (!s) {
+        s = new Set();
+        consumedByOps.set(inp, s);
+      }
+      s.add(g.op);
+    }
+  }
+
+  const isXYInput = (w: string) => /^[xy]\d+$/.test(w);
+  const isZOutput = (w: string) => /^z\d+$/.test(w);
+  const hasXYInputs = (g: Gate) => isXYInput(g.in1) && isXYInput(g.in2);
+  const isHalfAdderBit = (g: Gate) =>
+    (g.in1 === 'x00' && g.in2 === 'y00') ||
+    (g.in1 === 'y00' && g.in2 === 'x00');
+
+  const badWires = new Set<string>();
+
+  // === Phase 1: Check structural rules for each gate ===
+  for (const g of gates) {
+    const out = g.out;
+    const ops = consumedByOps.get(out) ?? new Set();
+
+    if (g.op === 'XOR') {
+      if (hasXYInputs(g)) {
+        if (isHalfAdderBit(g)) {
+          // x00 XOR y00 must output z00
+          if (out !== 'z00') {
+            badWires.add(out);
+          }
+        } else {
+          // Partial sum XOR must feed into XOR (sum gate) and AND (propagate gate)
+          if (!ops.has('XOR') || !ops.has('AND')) {
+            badWires.add(out);
+          }
+        }
+      } else {
+        // Sum XOR must output a z-wire
+        if (!isZOutput(out)) {
+          badWires.add(out);
+        }
+      }
+    } else if (g.op === 'AND') {
+      if (isHalfAdderBit(g)) {
+        // Initial carry must feed into XOR
+        if (numBits > 1 && !ops.has('XOR')) {
+          badWires.add(out);
+        }
+      } else {
+        // Generate/propagate AND must feed into OR gate
+        if (!ops.has('OR')) {
+          badWires.add(out);
+        }
+      }
+    } else if (g.op === 'OR') {
+      if (out === finalZ) {
+        // Final carry is z_final — correct
+      } else {
+        // Carry must feed into XOR and AND
+        if (!ops.has('XOR') || !ops.has('AND')) {
+          badWires.add(out);
+        }
+        // Carry should not be a z-wire
+        if (isZOutput(out)) {
+          badWires.add(out);
+        }
+      }
+    }
+  }
+
+  // === Phase 2: Check sum XOR input sources ===
+  // For each sum XOR (non-x/y-input XOR) whose output IS a z-wire:
+  // One input must be a partial sum XOR(xNN, yNN) for matching bit NN,
+  // the other must be a carry (OR output or initial AND).
+  for (const g of gates) {
+    if (g.op !== 'XOR') continue;
+    if (hasXYInputs(g)) continue;
+    if (!isZOutput(g.out)) continue;
+
+    const zMatch = g.out.match(/^z(\d+)$/)!;
+    const bitIdx = zMatch[1];
+    const xForBit = `x${bitIdx}`;
+    const yForBit = `y${bitIdx}`;
+
+    const prod1 = producerOf.get(g.in1);
+    const prod2 = producerOf.get(g.in2);
+
+    const isPartialSumForThisBit = (p: Gate | undefined) =>
+      p !== undefined && p.op === 'XOR' &&
+      ((p.in1 === xForBit && p.in2 === yForBit) ||
+       (p.in1 === yForBit && p.in2 === xForBit));
+
+    const isCarry = (p: Gate | undefined) =>
+      p !== undefined && (p.op === 'OR' || (p.op === 'AND' && isHalfAdderBit(p)));
+
+    const ps1 = isPartialSumForThisBit(prod1);
+    const ps2 = isPartialSumForThisBit(prod2);
+
+    if (ps1 && !isCarry(prod2)) {
+      badWires.add(g.in2);
+    } else if (ps2 && !isCarry(prod1)) {
+      badWires.add(g.in1);
+    } else if (!ps1 && !ps2) {
+      // Neither input is the correct partial sum for this bit.
+      // The partial sum XOR for this bit outputs some wire W.
+      // W was supposed to be an input here but isn't.
+      // Find the partial sum XOR for this bit and check its output.
+      let partialSumGate: Gate | undefined;
+      for (const gg of gates) {
+        if (gg.op === 'XOR' &&
+          ((gg.in1 === xForBit && gg.in2 === yForBit) ||
+           (gg.in1 === yForBit && gg.in2 === xForBit))) {
+          partialSumGate = gg;
+          break;
+        }
+      }
+
+      if (partialSumGate) {
+        // The partial sum output wire W is not an input to this sum XOR.
+        // One of the sum XOR's inputs took W's place.
+        // Determine which input is the "impostor":
+        // The correct carry-in is the one from the previous bit.
+        // The impostor is the one that's NOT the carry from the previous bit.
+        // We identify the carry from the previous bit as the OR/initial-AND
+        // whose dependents don't include this bit's x/y.
+        //
+        // Simpler approach: the partial sum gate's output (W) is bad (already
+        // caught by Phase 1 if it doesn't feed into XOR+AND). Its swap partner
+        // is whichever input of this sum XOR is NOT the correct carry.
+        //
+        // If both inputs are carries, one is from the current bit and one from
+        // the previous bit. Flag the one from the current bit.
+        if (isCarry(prod1) && isCarry(prod2)) {
+          // One of these carries is from the current bit (wrong position).
+          // Check which OR gate's AND inputs reference this bit's x/y wires.
+          const isFromCurrentBit = (p: Gate): boolean => {
+            // Check if p's inputs (AND gate outputs) reference this bit's x/y
+            for (const andWire of [p.in1, p.in2]) {
+              const andGate = producerOf.get(andWire);
+              if (andGate && andGate.op === 'AND') {
+                if ((andGate.in1 === xForBit || andGate.in2 === xForBit) ||
+                    (andGate.in1 === yForBit || andGate.in2 === yForBit)) {
+                  return true;
+                }
+              }
+            }
+            return false;
+          };
+
+          if (prod1!.op === 'OR' && isFromCurrentBit(prod1!)) {
+            badWires.add(g.in1);
+          } else if (prod2!.op === 'OR' && isFromCurrentBit(prod2!)) {
+            badWires.add(g.in2);
+          } else {
+            // Can't determine — flag both
+            badWires.add(g.in1);
+            badWires.add(g.in2);
+          }
+        } else {
+          if (!isCarry(prod1)) badWires.add(g.in1);
+          if (!isCarry(prod2)) badWires.add(g.in2);
+        }
+      }
+    }
+  }
+
+  // === Phase 3: Check the final carry ===
+  // The final z-wire must be produced by an OR gate, AND that OR gate
+  // must be from the last bit (its AND inputs must reference the
+  // highest-bit x/y wires).
+  if (badWires.size < 8) {
+    const finalGate = producerOf.get(finalZ);
+    if (finalGate) {
+      if (finalGate.op !== 'OR') {
+        badWires.add(finalZ);
+      } else {
+        // Check that this OR gate's AND inputs reference the last bit's x/y
+        const lastBit = numBits - 1;
+        const xLast = `x${lastBit.toString().padStart(2, '0')}`;
+        const yLast = `y${lastBit.toString().padStart(2, '0')}`;
+
+        const isFromLastBit = (): boolean => {
+          for (const andWire of [finalGate.in1, finalGate.in2]) {
+            const andGate = producerOf.get(andWire);
+            if (andGate && andGate.op === 'AND') {
+              if (andGate.in1 === xLast || andGate.in2 === xLast ||
+                  andGate.in1 === yLast || andGate.in2 === yLast) {
+                return true;
+              }
+            }
+          }
+          return false;
+        };
+
+        if (!isFromLastBit()) {
+          // The wrong OR gate produces finalZ — it's swapped.
+          // Find the correct OR gate (the one from the last bit).
+          badWires.add(finalZ);
+
+          // Find the OR gate that SHOULD produce finalZ
+          for (const gg of gates) {
+            if (gg.op !== 'OR' || gg === finalGate) continue;
+            for (const andWire of [gg.in1, gg.in2]) {
+              const andGate = producerOf.get(andWire);
+              if (andGate && andGate.op === 'AND') {
+                if (andGate.in1 === xLast || andGate.in2 === xLast ||
+                    andGate.in1 === yLast || andGate.in2 === yLast) {
+                  badWires.add(gg.out);
+                  break;
+                }
+              }
+            }
+          }
+        }
+      }
+    }
+  }
+
+  return [...badWires].sort();
+}
