milar wires\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Work on a copy to avoid mutating the input\n  const gatesCopy: Gate[] = gates.map(g => ({ ...g }));\n\n  // Determine number of input bits\n  let maxBit = 0;\n  for (const g of gatesCopy) {\n    for (const inp of [g.in1, g.in2]) {\n      const m = inp.match(/^x(\\d+)$/);\n      if (m) maxBit = Math.max(maxBit, parseInt(m[1]));\n    }\n  }\n  const numBits = maxBit + 1;\n  const pad = (n: number) => n.toString().padStart(2, '0');\n  const finalZ = `z${pad(numBits)}`;\n\n  // === Build indexes ===\n  const gateByOut = new Map<string, Gate>();\n  const gatesByOpAndInput = new Map<string, Gate[]>();\n\n  const addToIndex = (g: Gate) => {\n    gateByOut.set(g.out, g);\n    for (const inp of [g.in1, g.in2]) {\n      const key = `${g.op}:${inp}`;\n      const list = gatesByOpAndInput.get(key);\n      if (list) list.push(g);\n      else gatesByOpAndInput.set(key, [g]);\n    }\n  };\n\n  const removeFromIndex = (g: Gate) => {\n    gateByOut.delete(g.out);\n    for (const inp of [g.in1, g.in2]) {\n      const key = `${g.op}:${inp}`;\n      const list = gatesByOpAndInput.get(key);\n      if (list) {\n        const idx = list.indexOf(g);\n        if (idx >= 0) list.splice(idx, 1);\n      }\n    }\n  };\n\n  for (const g of gatesCopy) {\n    addToIndex(g);\n  }\n\n  const findGate = (op: string, a: string, b: string): Gate | undefined => {\n    const candidates = gatesByOpAndInput.get(`${op}:${a}`);\n    if (!candidates) return undefined;\n    for (const g of candidates) {\n      if ((g.in1 === a && g.in2 === b) || (g.in1 === b && g.in2 === a)) {\n        return g;\n      }\n    }\n    return undefined;\n  };\n\n  const findGateExcluding = (op: string, wire: string, exclude: Gate): Gate | undefined => {\n    const candidates = gatesByOpAndInput.get(`${op}:${wire}`);\n    if (!candidates) return undefined;\n    for (const g of candidates) {\n      if (g !== exclude) return g;\n    }\n    return undefined;\n  };\n\n  const swapped = new Set<string>();\n\n  const swapOutputs = (w1: string, w2: string) => {\n    swapped.add(w1);\n    swapped.add(w2);\n    const g1 = gateByOut.get(w1)!;\n    const g2 = gateByOut.get(w2)!;\n    removeFromIndex(g1);\n    removeFromIndex(g2);\n    g1.out = w2;\n    g2.out = w1;\n    addToIndex(g1);\n    addToIndex(g2);\n  };\n\n  // Helpers\n  const isXYInput = (w: string) => /^[xy]\\d+$/.test(w);\n  const isZOutput = (w: string) => /^z\\d+$/.test(w);\n\n  // === Carry-chain tracing ===\n  // At each bit, we know the structure. We find gates by their inputs\n  // and check outputs. We also verify cross-relationships.\n\n  // Bit 0\n  const xor0 = findGate('XOR', 'x00', 'y00')!;\n  if (xor0.out !== 'z00') {\n    swapOutputs(xor0.out, 'z00');\n  }\n\n  let carry = findGate('AND', 'x00', 'y00')!.out;\n\n  // Check: the initial carry should be consumed by a XOR and AND gate\n  // (bit 1's sum and propagate). If not, it might be swapped.\n  // We handle this in the main loop.\n\n  for (let i = 1; i < numBits; i++) {\n    const xW = `x${pad(i)}`;\n    const yW = `y${pad(i)}`;\n    const zW = `z${pad(i)}`;\n\n    // 1. Partial XOR: xNN XOR yNN -> tWire\n    const partialXor = findGate('XOR', xW, yW)!;\n    let tWire = partialXor.out;\n\n    // 2. Sum XOR: tWire XOR carry -> zNN\n    let sumXor = findGate('XOR', tWire, carry);\n\n    if (!sumXor) {\n      // Either tWire or carry is wrong.\n      // Find what XOR gates use tWire (other than partialXor) or carry.\n      const xorUsingT = findGateExcluding('XOR', tWire, partialXor);\n      const xorUsingC = findGateExcluding('XOR', carry, partialXor);\n\n      if (xorUsingT && !xorUsingC) {\n        // carry is wrong\n        const correctCarry = xorUsingT.in1 === tWire ? xorUsingT.in2 : xorUsingT.in1;\n        swapOutputs(carry, correctCarry);\n        carry = correctCarry;\n      } else if (xorUsingC && !xorUsingT) {\n        // tWire is wrong\n        const correctT = xorUsingC.in1 === carry ? xorUsingC.in2 : xorUsingC.in1;\n        swapOutputs(tWire, correctT);\n        tWire = findGate('XOR', xW, yW)!.out;\n      } else if (xorUsingT && xorUsingC && xorUsingT !== xorUsingC) {\n        // Both exist but in different gates. Determine which is the sum gate.\n        // The sum gate's OTHER input should come from a source consistent with its role.\n        // The partial sum's co-input in the sum gate should be a carry (OR output or initial AND).\n        const otherFromC = xorUsingC.in1 === carry ? xorUsingC.in2 : xorUsingC.in1;\n        const producerOfOtherFromC = gateByOut.get(otherFromC);\n        if (producerOfOtherFromC && producerOfOtherFromC.op === 'XOR' &&\n            isXYInput(producerOfOtherFromC.in1) && isXYInput(producerOfOtherFromC.in2)) {\n          // xorUsingC's other input is a partial sum → xorUsingC is the sum gate\n          // tWire needs to be swapped with otherFromC\n          swapOutputs(tWire, otherFromC);\n          tWire = findGate('XOR', xW, yW)!.out;\n        } else {\n          // xorUsingT is the sum gate → carry needs swapping\n          const correctCarry = xorUsingT.in1 === tWire ? xorUsingT.in2 : xorUsingT.in1;\n          swapOutputs(carry, correctCarry);\n          carry = correctCarry;\n        }\n      }\n\n      sumXor = findGate('XOR', tWire, carry);\n      if (!sumXor) break;\n    }\n\n    // 3. Check sum XOR outputs zNN\n    if (sumXor.out !== zW) {\n      swapOutputs(sumXor.out, zW);\n    }\n\n    // 4. Generate AND: xNN AND yNN -> aWire\n    const genAnd = findGate('AND', xW, yW)!;\n    const aWire = genAnd.out;\n\n    // 5. Propagate AND: tWire AND carry -> bWire\n    const propAnd = findGate('AND', tWire, carry)!;\n    const bWire = propAnd.out;\n\n    // 6. Carry OR: aWire OR bWire -> carry_out\n    let carryOr = findGate('OR', aWire, bWire);\n\n    if (!carryOr) {\n      // One of aWire/bWire might be swapped\n      const orUsingA = gatesByOpAndInput.get(`OR:${aWire}`);\n      const orUsingB = gatesByOpAndInput.get(`OR:${bWire}`);\n      const orA = orUsingA && orUsingA.length > 0 ? orUsingA[0] : undefined;\n      const orB = orUsingB && orUsingB.length > 0 ? orUsingB[0] : undefined;\n\n      if (orA && !orB) {\n        const correctB = orA.in1 === aWire ? orA.in2 : orA.in1;\n        swapOutputs(bWire, correctB);\n        carryOr = findGate('OR', aWire, findGate('AND', tWire, carry)!.out);\n      } else if (orB && !orA) {\n        const correctA = orB.in1 === bWire ? orB.in2 : orB.in1;\n        swapOutputs(aWire, correctA);\n        carryOr = findGate('OR', findGate('AND', xW, yW)!.out, bWire);\n      }\n    }\n\n    if (!carryOr) break;\n\n    carry = carryOr.out;\n\n    // For the last bit, carry should be finalZ\n    if (i === numBits - 1 && carry !== finalZ) {\n      swapOutputs(carry, finalZ);\n      carry = finalZ;\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":49,"oldLines":157,"newStart":49,"newLines":208,"lines":[" /**","  * Find the 8 wires (4 swapped pairs) in a broken binary adder circuit.","  *","- * Uses structural rule checking combined with carry-chain tracing.","- *","- * Phase 1: Check local structural rules that every gate must satisfy.","- * Phase 2: Trace the carry chain to catch swaps between structurally","- *          similar positions that local rules can't detect.","+ * Combines two approaches:","+ * 1. Rule-based: check structural invariants each gate must satisfy","+ * 2. Carry-chain tracing: walk the adder bit by bit to catch swaps","+ *    between structurally similar wires","  */"," export function findSwappedWires(gates: Gate[]): string[] {","+  // Work on a copy to avoid mutating the input","+  const gatesCopy: Gate[] = gates.map(g => ({ ...g }));","+","   // Determine number of input bits","   let maxBit = 0;","-  for (const g of gates) {","+  for (const g of gatesCopy) {","     for (const inp of [g.in1, g.in2]) {","       const m = inp.match(/^x(\\d+)$/);","       if (m) maxBit = Math.max(maxB