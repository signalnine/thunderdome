uts = (w1: string, w2: string) => {\n    swapped.add(w1);\n    swapped.add(w2);\n    const g1 = gateByOut.get(w1)!;\n    const g2 = gateByOut.get(w2)!;\n    removeFromIndex(g1);\n    removeFromIndex(g2);\n    g1.out = w2;\n    g2.out = w1;\n    addToIndex(g1);\n    addToIndex(g2);\n  };\n\n  // Find all consumers of a wire (gates that use it as input)\n  const findConsumers = (wire: string): Gate[] => {\n    const result: Gate[] = [];\n    for (const op of ['AND', 'OR', 'XOR']) {\n      const candidates = gatesByOpAndInput.get(`${op}:${wire}`);\n      if (candidates) result.push(...candidates);\n    }\n    return result;\n  };\n\n  // Helper: find a gate with given op using 'wire' as input, excluding a gate\n  const findGateWithOpAndInputExcluding = (\n    op: string,\n    wire: string,\n    exclude: Gate | undefined\n  ): Gate | undefined => {\n    const candidates = gatesByOpAndInput.get(`${op}:${wire}`);\n    if (!candidates) return undefined;\n    for (const g of candidates) {\n      if (g !== exclude) return g;\n    }\n    return undefined;\n  };\n\n  // === Bit 0: half adder ===\n  const xorGate0 = findGate('XOR', 'x00', 'y00')!;\n  if (xorGate0.out !== 'z00') {\n    swapOutputs(xorGate0.out, 'z00');\n  }\n\n  let carry = findGate('AND', 'x00', 'y00')!.out;\n\n  // === Bits 1..numBits-1: full adders ===\n  for (let i = 1; i < numBits; i++) {\n    const xW = `x${pad(i)}`;\n    const yW = `y${pad(i)}`;\n    const zW = `z${pad(i)}`;\n    const isLastBit = i === numBits - 1;\n\n    // 1. Find partial XOR: xNN XOR yNN -> tWire\n    const partialXor = findGate('XOR', xW, yW)!;\n    let tWire = partialXor.out;\n\n    // 2. Find sum XOR: tWire XOR carry -> zNN\n    let sumXor = findGate('XOR', tWire, carry);\n\n    if (!sumXor) {\n      // Either tWire or carry is wrong. Look for XOR gates that use either.\n      const xorUsingT = findGateWithOpAndInputExcluding('XOR', tWire, partialXor);\n      const xorUsingCarry = findGateWithOpAndInputExcluding('XOR', carry, partialXor);\n\n      if (xorUsingT && !xorUsingCarry) {\n        // carry wire is wrong; the other input of xorUsingT should be carry\n        const correctCarry = xorUsingT.in1 === tWire ? xorUsingT.in2 : xorUsingT.in1;\n        swapOutputs(carry, correctCarry);\n        carry = correctCarry;\n      } else if (xorUsingCarry && !xorUsingT) {\n        // tWire is wrong\n        const correctT = xorUsingCarry.in1 === carry ? xorUsingCarry.in2 : xorUsingCarry.in1;\n        swapOutputs(tWire, correctT);\n        tWire = findGate('XOR', xW, yW)!.out;\n      } else if (xorUsingT && xorUsingCarry && xorUsingT !== xorUsingCarry) {\n        // Both tWire and carry are used in different XOR gates.\n        // Figure out which one is the sum XOR.\n        // The sum XOR should output zNN or something that should be swapped to zNN.\n        // Check: does xorUsingCarry's other input come from XOR(x,y)?\n        const otherFromCarry = xorUsingCarry.in1 === carry ? xorUsingCarry.in2 : xorUsingCarry.in1;\n        const producerOfOther = gateByOut.get(otherFromCarry);\n        if (producerOfOther && producerOfOther.op === 'XOR') {\n          // xorUsingCarry looks like the sum gate — swap tWire\n          swapOutputs(tWire, otherFromCarry);\n          tWire = findGate('XOR', xW, yW)!.out;\n        } else {\n          // xorUsingT looks like the sum gate — swap carry\n          const correctCarry = xorUsingT.in1 === tWire ? xorUsingT.in2 : xorUsingT.in1;\n          swapOutputs(carry, correctCarry);\n          carry = correctCarry;\n        }\n      }\n\n      sumXor = findGate('XOR', tWire, carry);\n      if (!sumXor) break;\n    }\n\n    // 3. Check sum XOR output is zNN\n    if (sumXor.out !== zW) {\n      swapOutputs(sumXor.out, zW);\n    }\n\n    // 4. Find generate AND: xNN AND yNN -> aWire\n    const genAnd = findGate('AND', xW, yW)!;\n    const aWire = genAnd.out;\n\n    // 5. Find propagate AND: tWire AND carry -> bWire\n    const propAnd = findGate('AND', tWire, carry)!;\n    const bWire = propAnd.out;\n\n    // 6. Find carry OR: aWire OR bWire -> carry_out\n    let carryOr = findGate('OR', aWire, bWire);\n\n    if (!carryOr) {\n      // One of aWire or bWire might be swapped.\n      // Find OR gate using aWire or bWire.\n      const orUsingA = findGateWithOpAndInputExcluding('OR', aWire, undefined);\n      const orUsingB = findGateWithOpAndInputExcluding('OR', bWire, undefined);\n\n      if (orUsingA && !orUsingB) {\n        const correctB = orUsingA.in1 === aWire ? orUsingA.in2 : orUsingA.in1;\n        swapOutputs(bWire, correctB);\n        carryOr = findGate('OR', aWire, findGate('AND', tWire, carry)!.out);\n      } else if (orUsingB && !orUsingA) {\n        const correctA = orUsingB.in1 === bWire ? orUsingB.in2 : orUsingB.in1;\n        swapOutputs(aWire, correctA);\n        carryOr = findGate('OR', findGate('AND', xW, yW)!.out, bWire);\n      }\n    }\n\n    if (!carryOr) break;\n\n    carry = carryOr.out;\n\n    // For the last bit, carry should be z(numBits)\n    if (isLastBit) {\n      const finalZ = `z${pad(numBits)}`;\n      if (carry !== finalZ) {\n        swapOutputs(carry, finalZ);\n        carry = finalZ;\n      }\n    }\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":49,"oldLines":16,"newStart":49,"newLines":17,"lines":[" /**","  * Find the 8 wires (4 swapped pairs) in a broken binary adder circuit.","  *","- * Strategy: Walk the ripple-carry adder structure bit by bit.","- * At each bit, we know what gates should exist with what inputs.","- * We find gates by their inputs (which are structurally determined)","- * and check if their outputs are consistent. When we find an inconsistency,","- * we fix it by swapping and record it.","+ * Strategy: Walk the ripple-carry adder structure bit by bit, tracing","+ * the carry chain. At each bit, find gates by their inputs (which are","+ * determined by the structure) and verify their outputs match expectations.","+ * When a mismatch is found, identify and r