tring, w2: string) => {\n    swapped.add(w1);\n    swapped.add(w2);\n    const g1 = gateByOut.get(w1)!;\n    const g2 = gateByOut.get(w2)!;\n    // Update: swap their out fields\n    removeFromIndex(g1);\n    removeFromIndex(g2);\n    g1.out = w2;\n    g2.out = w1;\n    addToIndex(g1);\n    addToIndex(g2);\n  };\n\n  const pad = (n: number) => n.toString().padStart(2, '0');\n\n  // === Bit 0: half adder ===\n  // x00 XOR y00 -> z00\n  // x00 AND y00 -> carry\n  let xorGate0 = findGate('XOR', 'x00', 'y00');\n  const andGate0 = findGate('AND', 'x00', 'y00');\n\n  if (xorGate0 && xorGate0.out !== 'z00') {\n    swapOutputs(xorGate0.out, 'z00');\n    xorGate0 = findGate('XOR', 'x00', 'y00');\n  }\n\n  let carry = findGate('AND', 'x00', 'y00')!.out;\n\n  // === Bits 1..numBits-1: full adders ===\n  for (let i = 1; i < numBits; i++) {\n    const xW = `x${pad(i)}`;\n    const yW = `y${pad(i)}`;\n    const zW = `z${pad(i)}`;\n\n    // 1. Find partial XOR: xNN XOR yNN -> tWire\n    let partialXor = findGate('XOR', xW, yW);\n    if (!partialXor) break;\n    let tWire = partialXor.out;\n\n    // 2. Find sum XOR: tWire XOR carry -> zNN\n    let sumXor = findGate('XOR', tWire, carry);\n\n    if (!sumXor) {\n      // Either tWire or carry has been swapped somewhere.\n      // We can determine which by looking at what XOR gates exist.\n\n      // Find XOR gate that uses tWire (other than partialXor)\n      const xorUsingT = findGateWithOpAndInputExcluding('XOR', tWire, partialXor);\n      // Find XOR gate that uses carry (other than partialXor for x/y which is different)\n      const xorUsingCarry = findGateWithOpAndInputExcluding('XOR', carry, partialXor);\n\n      if (xorUsingT && !xorUsingCarry) {\n        // The XOR gate uses tWire but not carry => carry is the wrong wire\n        // The other input of xorUsingT is what carry should be\n        const correctCarry = xorUsingT.in1 === tWire ? xorUsingT.in2 : xorUsingT.in1;\n        swapOutputs(carry, correctCarry);\n        carry