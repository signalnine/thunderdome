nst bWire = propAnd.out;\n\n    // 6. Find carry OR: aWire OR bWire -> carry_out\n    let carryOr = findGate('OR', aWire, bWire);\n\n    if (!carryOr) {\n      // One of aWire or bWire might be swapped.\n      // Find OR gates that use aWire or bWire.\n      const orUsingA = findGateByOneInput('OR', aWire);\n      const orUsingB = findGateByOneInput('OR', bWire);\n\n      if (orUsingA && !orUsingB) {\n        // bWire is wrong; the other input of orUsingA should be bWire\n        const correctB = orUsingA.in1 === aWire ? orUsingA.in2 : orUsingA.in1;\n        swapOutputs(bWire, correctB);\n        carryOr = findGate('OR', aWire, findGate('AND', tWire, carry)!.out);\n      } else if (orUsingB && !orUsingA) {\n        // aWire is wrong\n        const correctA = orUsingB.in1 === bWire ? orUsingB.in2 : orUsingB.in1;\n        swapOutputs(aWire, correctA);\n        carryOr = findGate('OR', findGate('AND', xW, yW)!.out, bWire);\n      }\n    }\n\n    if (!carryOr) break;\n\n    carry = carryOr.out;\n  }\n\n  // Check final carry: carry should be z(numBits)\n  const finalZ = `z${pad(numBits)}`;\n  if (carry !== finalZ) {\n    // The final carry wire should feed into the final z output.\n    // But the circuit might use an OR gate to pass it through, or it might be direct.\n    // Check if there's a gate whose output is finalZ that uses carry as input.\n    const finalGate = gateByOut.get(finalZ);\n    if (finalGate) {\n      if (finalGate.in1 === carry || finalGate.in2 === carry) {\n        // The carry feeds into a gate that outputs finalZ — this is fine\n        // (the gate passes carry through, like OR(carry, carry))\n      } else {\n        // The final z gate doesn't use carry — something's swapped\n        swapOutputs(carry, finalZ);\n      }\n    } else {\n      swapOutputs(carry, finalZ);\n    }\n  }\n\n  return [...swapped].sort();\n\n  // Helper: find a gate with given op that uses 'wire' as input, excluding a specific gate\n  function findGateWithOpAndInputExclud