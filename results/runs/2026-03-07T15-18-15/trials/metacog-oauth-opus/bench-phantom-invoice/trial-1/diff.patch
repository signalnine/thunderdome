+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AfGD9rvJwn7xBMdJLFhSMZ","type":"tool_result","content":"     1‚Üíimport type Database from 'better-sqlite3';\n     2‚Üíimport type { Invoice, LineItem } from '../models/invoice.js';\n     3‚Üí\n     4‚Üí/**\n     5‚Üí * Retrieve invoices within a date range (inclusive on both ends).\n     6‚Üí */\n     7‚Üíexport function getInvoicesByDateRange(\n     8‚Üí  db: Database.Database,\n     9‚Üí  startDate: string,\n    10‚Üí  endDate: string,\n    11‚Üí): Invoice[] {\n    12‚Üí  const stmt = db.prepare(`\n    13‚Üí    SELECT * FROM invoices\n    14‚Üí    WHERE date >= ? AND date < ?\n    15‚Üí    ORDER BY date ASC\n    16‚Üí  `);\n    17‚Üí  return stmt.all(startDate, endDate) as Invoice[];\n    18‚Üí}\n    19‚Üí\n    20‚Üí/**\n    21‚Üí * Retrieve a single invoice by ID, including its line items.\n    22‚Üí */\n    23‚Üíexport function getInvoiceById(\n    24‚Üí  db: Database.Database,\n    25‚Üí  id: number,\n    26‚Üí): (Invoice & { line_items: LineItem[] }) | undefined {\n    27‚Üí  const invoiceStmt = db.prepare('SELECT * FROM invoices WHERE id = ?');\n    28‚Üí  const invoice = invoiceStmt.get(id) as Invoice | undefined;\n    29‚Üí\n    30‚Üí  if (!invoice) return undefined;\n    31‚Üí\n    32‚Üí  const itemsStmt = db.prepare('SELECT * FROM line_items WHERE invoice_id = ?');\n    33‚Üí  const line_items = itemsStmt.all(id) as LineItem[];\n    34‚Üí\n    35‚Üí  return { ...invoice, line_items };\n    36‚Üí}\n    37‚Üí\n    38‚Üí/**\n    39‚Üí * Create a new invoice with line items.\n    40‚Üí */\n    41‚Üíexport function createInvoice(\n    42‚Üí  db: Database.Database,\n    43‚Üí  data: Invoice & { line_items?: LineItem[] },\n    44‚Üí): number {\n    45‚Üí  const insertInvoice = db.prepare(`\n    46‚Üí    INSERT INTO invoices (customer_id, date, subtotal, discount_rate, tax_rate, total, status)\n    47‚Üí    VALUES (?, ?, ?, ?, ?, ?, ?)\n    48‚Üí  `);\n    49‚Üí\n    50‚Üí  const insertLineItem = db.prepare(`\n    51‚Üí    INSERT INTO line_items (invoice_id, description, quantity, unit_price)\n    52‚Üí    VALUES (?, ?, ?, ?)\n    53‚Üí  `);\n    54‚Üí\n    55‚Üí  const result = insertInvoice.run(\n    56‚Üí    data.customer_id,\n    57‚Üí    data.date,\n    58‚Üí    data.subtotal,\n    59‚Üí    data.discount_rate,\n    60‚Üí    data.tax_rate,\n    61‚Üí    data.total,\n    62‚Üí    data.status || 'draft',\n    63‚Üí  );\n    64‚Üí\n    65‚Üí  const invoiceId = result.lastInsertRowid as number;\n    66‚Üí\n    67‚Üí  if (data.line_items) {\n    68‚Üí    for (const item of data.line_items) {\n    69‚Üí      insertLineItem.run(invoiceId, item.description, item.quantity, item.unit_price);\n    70‚Üí    }\n    71‚Üí  }\n    72‚Üí\n    73‚Üí  return invoiceId;\n    74‚Üí}\n    75‚Üí\n    76‚Üí/**\n    77‚Üí * Retrieve all invoices for a specific customer.\n    78‚Üí */\n    79‚Üíexport function getInvoicesByCustomer(\n    80‚Üí  db: Database.Database,\n    81‚Üí  customerId: string,\n    82‚Üí): Invoice[] {\n    83‚Üí  const stmt = db.prepare(`\n    84‚Üí    SELECT * FROM invoices\n    85‚Üí    WHERE customer_id = ?\n    86‚Üí    ORDER BY date ASC\n    87‚Üí  `);\n    88‚Üí  return stmt.all(customerId) as Invoice[];\n    89‚Üí}\n    90‚Üí"}]},"parent_tool_use_id":"toolu_01KbRHk5cLN5HLuroTPVG8dw","session_id":"53811a29-0446-4208-afcd-d53aaea285ec","uuid":"d702f04d-7f49-4952-96d1-170f6d2ecc9c"}
