+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NT7W1nR99QthGZrMnUhE36","type":"tool_result","content":"     1‚Üíimport type Database from 'better-sqlite3';\n     2‚Üíimport type { Invoice, InvoiceSummary, CustomerReport } from '../models/invoice.js';\n     3‚Üí\n     4‚Üí/**\n     5‚Üí * Generate a monthly revenue report for a given year.\n     6‚Üí * Groups invoices by their UTC month and aggregates totals.\n     7‚Üí */\n     8‚Üíexport function getMonthlyReport(\n     9‚Üí  db: Database.Database,\n    10‚Üí  year: number,\n    11‚Üí): InvoiceSummary[] {\n    12‚Üí  const startDate = `${year}-01-01`;\n    13‚Üí  const endDate = `${year}-12-31`;\n    14‚Üí\n    15‚Üí  const stmt = db.prepare(`\n    16‚Üí    SELECT * FROM invoices\n    17‚Üí    WHERE date >= ? AND date <= ?\n    18‚Üí    ORDER BY date ASC\n    19‚Üí  `);\n    20‚Üí\n    21‚Üí  const invoices = stmt.all(startDate, endDate) as Invoice[];\n    22‚Üí\n    23‚Üí  // Group invoices by month\n    24‚Üí  const monthlyMap = new Map<number, { count: number; total: number }>();\n    25‚Üí\n    26‚Üí  for (const inv of invoices) {\n    27‚Üí    const d = new Date(inv.date + 'T00:00:00Z');\n    28‚Üí    const month = d.getMonth() + 1; // 1-indexed\n    29‚Üí\n    30‚Üí    const current = monthlyMap.get(month) || { count: 0, total: 0 };\n    31‚Üí    current.count += 1;\n    32‚Üí    current.total += inv.total;\n    33‚Üí    monthlyMap.set(month, current);\n    34‚Üí  }\n    35‚Üí\n    36‚Üí  // Convert to array of summaries\n    37‚Üí  const summaries: InvoiceSummary[] = [];\n    38‚Üí  for (const [month, data] of monthlyMap) {\n    39‚Üí    summaries.push({\n    40‚Üí      month,\n    41‚Üí      year,\n    42‚Üí      count: data.count,\n    43‚Üí      total_revenue: Math.round(data.total * 100) / 100,\n    44‚Üí    });\n    45‚Üí  }\n    46‚Üí\n    47‚Üí  return summaries.sort((a, b) => a.month - b.month);\n    48‚Üí}\n    49‚Üí\n    50‚Üí/**\n    51‚Üí * Generate a report for a specific customer.\n    52‚Üí */\n    53‚Üíexport function getCustomerReport(\n    54‚Üí  db: Database.Database,\n    55‚Üí  customerId: string,\n    56‚Üí): CustomerReport {\n    57‚Üí  const stmt = db.prepare(`\n    58‚Üí    SELECT * FROM invoices\n    59‚Üí    WHERE customer_id = ?\n    60‚Üí  `);\n    61‚Üí\n    62‚Üí  const invoices = stmt.all(customerId) as Invoice[];\n    63‚Üí\n    64‚Üí  const totalSpent = invoices.reduce((sum, inv) => sum + inv.total, 0);\n    65‚Üí\n    66‚Üí  return {\n    67‚Üí    customer_id: customerId,\n    68‚Üí    invoice_count: invoices.length,\n    69‚Üí    total_spent: Math.round(totalSpent * 100) / 100,\n    70‚Üí    average_invoice: invoices.length > 0\n    71‚Üí      ? Math.round((totalSpent / invoices.length) * 100) / 100\n    72‚Üí      : 0,\n    73‚Üí  };\n    74‚Üí}\n    75‚Üí\n    76‚Üí/**\n    77‚Üí * Get total revenue for a date period.\n    78‚Üí */\n    79‚Üíexport function getRevenueByPeriod(\n    80‚Üí  db: Database.Database,\n    81‚Üí  start: string,\n    82‚Üí  end: string,\n    83‚Üí): { total: number; count: number } {\n    84‚Üí  const stmt = db.prepare(`\n    85‚Üí    SELECT COALESCE(SUM(total), 0) as total, COUNT(*) as count\n    86‚Üí    FROM invoices\n    87‚Üí    WHERE date >= ? AND date <= ?\n    88‚Üí  `);\n    89‚Üí\n    90‚Üí  const result = stmt.get(start, end) as { total: number; count: number };\n    91‚Üí  return {\n    92‚Üí    total: Math.round(result.total * 100) / 100,\n    93‚Üí    count: result.count,\n    94‚Üí  };\n    95‚Üí}\n    96‚Üí"}]},"parent_tool_use_id":"toolu_01KbRHk5cLN5HLuroTPVG8dw","session_id":"53811a29-0446-4208-afcd-d53aaea285ec","uuid":"5a4c7d3f-e1ff-4d43-829d-af0f37cbbef2"}
