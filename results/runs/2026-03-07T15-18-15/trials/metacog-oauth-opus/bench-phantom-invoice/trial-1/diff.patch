cific customer.\n    52‚Üí */\n    53‚Üíexport function getCustomerReport(\n    54‚Üí  db: Database.Database,\n    55‚Üí  customerId: string,\n    56‚Üí): CustomerReport {\n    57‚Üí  const stmt = db.prepare(`\n    58‚Üí    SELECT * FROM invoices\n    59‚Üí    WHERE customer_id = ?\n    60‚Üí  `);\n    61‚Üí\n    62‚Üí  const invoices = stmt.all(customerId) as Invoice[];\n    63‚Üí\n    64‚Üí  const totalSpent = invoices.reduce((sum, inv) => sum + inv.total, 0);\n    65‚Üí\n    66‚Üí  return {\n    67‚Üí    customer_id: customerId,\n    68‚Üí    invoice_count: invoices.length,\n    69‚Üí    total_spent: Math.round(totalSpent * 100) / 100,\n    70‚Üí    average_invoice: invoices.length > 0\n    71‚Üí      ? Math.round((totalSpent / invoices.length) * 100) / 100\n    72‚Üí      : 0,\n    73‚Üí  };\n    74‚Üí}\n    75‚Üí\n    76‚Üí/**\n    77‚Üí * Get total revenue for a date period.\n    78‚Üí */\n    79‚Üíexport function getRevenueByPeriod(\n    80‚Üí  db: Database.Database,\n    81‚Üí  start: string,\n    82‚Üí  end: string,\n    83‚Üí): { total: number; count: number } {\n    84‚Üí  const stmt = db.prepare(`\n    85‚Üí    SELECT COALESCE(SUM(total), 0) as total, COUNT(*) as count\n    86‚Üí    FROM invoices\n    87‚Üí    WHERE date >= ? AND date <= ?\n    88‚Üí  `);\n    89‚Üí\n    90‚Üí  const result = stmt.get(start, end) as { total: number; count: number };\n    91‚Üí  return {\n    92‚Üí    total: Math.round(result.total * 100) / 100,\n    93‚Üí    count: result.count,\n    94‚Üí  };\n    95‚Üí}\n    96‚Üí"}]},"parent_tool_use_id":null,"session_id":"53811a29-0446-4208-afcd-d53aaea285ec","uuid":"bf86a086-28c2-48a0-8026-03b7372866b1","tool_use_result":{"type":"text","file":{"filePath":"/workspace/src/services/reporting.ts","content":"import type Database from 'better-sqlite3';\nimport type { Invoice, InvoiceSummary, CustomerReport } from '../models/invoice.js';\n\n/**\n * Generate a monthly revenue report for a given year.\n * Groups invoices by their UTC month and aggregates totals.\n */\nexport function getMonthlyReport(\n  db: Database.Database,\n  year: number,\n): InvoiceSummary[] {\n  const startDate = `${year}-01-01`;\n  const endDate = `${year}-12-31`;\n\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE date >= ? AND date <= ?\n    ORDER BY date ASC\n  `);\n\n  const invoices = stmt.all(startDate, endDate) as Invoice[];\n\n  // Group invoices by month\n  const monthlyMap = new Map<number, { count: number; total: number }>();\n\n  for (const inv of invoices) {\n    const d = new Date(inv.date + 'T00:00:00Z');\n    const month = d.getMonth() + 1; // 1-indexed\n\n    const current = monthlyMap.get(month) || { count: 0, total: 0 };\n    current.count += 1;\n    current.total += inv.total;\n    monthlyMap.set(month, current);\n  }\n\n  // Convert to array of summaries\n  const summaries: InvoiceSummary[] = [];\n  for (const [month, data] of monthlyMap) {\n    summaries.push({\n      month,\n      year,\n      count: data.count,\n      total_revenue: Math.round(data.total * 100) / 100,\n    });\n  }\n\n  return summaries.sort((a, b) => a.month - b.month);\n}\n\n/**\n * Generate a report for a specific customer.\n */\nexport function getCustomerReport(\n  db: Database.Database,\n  customerId: string,\n): CustomerReport {\n  const stmt = db.prepare(`\n    SELECT * FROM invoices\n    WHERE customer_id = ?\n  `);\n\n  const invoices = stmt.all(customerId) as Invoice[];\n\n  const totalSpent = invoices.reduce((sum, inv) => sum + inv.total, 0);\n\n  return {\n    customer_id: customerId,\n    invoice_count: invoices.length,\n    total_spent: Math.round(totalSpent * 100) / 100,\n    average_invoice: invoices.length > 0\n      ? Math.round((totalSpent / invoices.length) * 100) / 100\n      : 0,\n  };\n}\n\n/**\n * Get total revenue for a date period.\n */\nexport function getRevenueByPeriod(\n  db: Database.Database,\n  start: string,\n  end: string,\n): { total: number; count: number } {\n  const stmt = db.prep