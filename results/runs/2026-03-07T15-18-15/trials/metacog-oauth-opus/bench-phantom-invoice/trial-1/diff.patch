+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P7c5VAVnP359xXpGZDnAfo","type":"tool_result","content":"     1‚Üíexport interface LineItem {\n     2‚Üí  id?: number;\n     3‚Üí  invoice_id?: number;\n     4‚Üí  description: string;\n     5‚Üí  quantity: number;\n     6‚Üí  unit_price: number;\n     7‚Üí}\n     8‚Üí\n     9‚Üíexport interface Invoice {\n    10‚Üí  id?: number;\n    11‚Üí  customer_id: string;\n    12‚Üí  date: string; // ISO date string YYYY-MM-DD\n    13‚Üí  subtotal: number;\n    14‚Üí  discount_rate: number; // 0.0 to 1.0\n    15‚Üí  tax_rate: number; // 0.0 to 1.0\n    16‚Üí  total: number;\n    17‚Üí  status: 'draft' | 'sent' | 'paid' | 'cancelled';\n    18‚Üí  line_items?: LineItem[];\n    19‚Üí}\n    20‚Üí\n    21‚Üíexport interface InvoiceCreateInput {\n    22‚Üí  customer_id: string;\n    23‚Üí  date: string;\n    24‚Üí  discount_rate: number;\n    25‚Üí  tax_rate: number;\n    26‚Üí  status?: 'draft' | 'sent' | 'paid' | 'cancelled';\n    27‚Üí  line_items: LineItem[];\n    28‚Üí}\n    29‚Üí\n    30‚Üíexport interface InvoiceSummary {\n    31‚Üí  month: number;\n    32‚Üí  year: number;\n    33‚Üí  count: number;\n    34‚Üí  total_revenue: number;\n    35‚Üí}\n    36‚Üí\n    37‚Üíexport interface CustomerReport {\n    38‚Üí  customer_id: string;\n    39‚Üí  invoice_count: number;\n    40‚Üí  total_spent: number;\n    41‚Üí  average_invoice: number;\n    42‚Üí}\n    43‚Üí"}]},"parent_tool_use_id":"toolu_01KbRHk5cLN5HLuroTPVG8dw","session_id":"53811a29-0446-4208-afcd-d53aaea285ec","uuid":"5684ae6b-744b-4107-b444-6ff2dd6e5a4a"}
