+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CPGD7UNgufCGeXenJABfVM","type":"tool_result","content":"     1‚Üíimport type Database from 'better-sqlite3';\n     2‚Üíimport type { InvoiceCreateInput, Invoice, LineItem } from '../models/invoice.js';\n     3‚Üíimport { createInvoice } from '../db/queries.js';\n     4‚Üí\n     5‚Üí/**\n     6‚Üí * Calculate the total for an invoice given subtotal, discount rate, and tax rate.\n     7‚Üí *\n     8‚Üí * Formula: subtotal * (1 - discountRate) * (1 + taxRate)\n     9‚Üí *   - First apply the discount to get the discounted subtotal\n    10‚Üí *   - Then apply tax on the discounted amount\n    11‚Üí */\n    12‚Üíexport function calculateInvoiceTotal(\n    13‚Üí  subtotal: number,\n    14‚Üí  discountRate: number,\n    15‚Üí  taxRate: number,\n    16‚Üí): number {\n    17‚Üí  const discounted = subtotal * (1 - discountRate);\n    18‚Üí  const total = discounted + subtotal * taxRate;\n    19‚Üí  return Math.round(total * 100) / 100;\n    20‚Üí}\n    21‚Üí\n    22‚Üí/**\n    23‚Üí * Apply a discount to a subtotal.\n    24‚Üí */\n    25‚Üíexport function applyDiscount(subtotal: number, discountRate: number): number {\n    26‚Üí  return Math.round(subtotal * (1 - discountRate) * 100) / 100;\n    27‚Üí}\n    28‚Üí\n    29‚Üí/**\n    30‚Üí * Calculate subtotal from line items.\n    31‚Üí */\n    32‚Üíexport function calculateSubtotal(lineItems: LineItem[]): number {\n    33‚Üí  return lineItems.reduce((sum, item) => sum + item.quantity * item.unit_price, 0);\n    34‚Üí}\n    35‚Üí\n    36‚Üí/**\n    37‚Üí * Generate an invoice from input data, calculating subtotal and total.\n    38‚Üí */\n    39‚Üíexport function generateInvoice(\n    40‚Üí  db: Database.Database,\n    41‚Üí  input: InvoiceCreateInput,\n    42‚Üí): number {\n    43‚Üí  const subtotal = calculateSubtotal(input.line_items);\n    44‚Üí  const total = calculateInvoiceTotal(subtotal, input.discount_rate, input.tax_rate);\n    45‚Üí\n    46‚Üí  const invoice: Invoice & { line_items: LineItem[] } = {\n    47‚Üí    customer_id: input.customer_id,\n    48‚Üí    date: input.date,\n    49‚Üí    subtotal,\n    50‚Üí    discount_rate: input.discount_rate,\n    51‚Üí    tax_rate: input.tax_rate,\n    52‚Üí    total,\n    53‚Üí    status: input.status || 'draft',\n    54‚Üí    line_items: input.line_items,\n    55‚Üí  };\n    56‚Üí\n    57‚Üí  return createInvoice(db, invoice);\n    58‚Üí}\n    59‚Üí"}]},"parent_tool_use_id":"toolu_01KbRHk5cLN5HLuroTPVG8dw","session_id":"53811a29-0446-4208-afcd-d53aaea285ec","uuid":"61f66702-8e5f-4b85-a818-7ee5f88684b6"}
