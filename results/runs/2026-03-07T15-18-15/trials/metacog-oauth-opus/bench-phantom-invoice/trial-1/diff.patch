+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JJTidxMmKs9Gzvd9X9Ae86","type":"tool_result","content":"     1‚Üíimport Database from 'better-sqlite3';\n     2‚Üí\n     3‚Üíexport function createDatabase(filename: string = ':memory:'): Database.Database {\n     4‚Üí  const db = new Database(filename);\n     5‚Üí\n     6‚Üí  db.pragma('journal_mode = WAL');\n     7‚Üí\n     8‚Üí  db.exec(`\n     9‚Üí    CREATE TABLE IF NOT EXISTS invoices (\n    10‚Üí      id INTEGER PRIMARY KEY AUTOINCREMENT,\n    11‚Üí      customer_id TEXT NOT NULL,\n    12‚Üí      date TEXT NOT NULL,\n    13‚Üí      subtotal REAL NOT NULL,\n    14‚Üí      discount_rate REAL NOT NULL DEFAULT 0,\n    15‚Üí      tax_rate REAL NOT NULL DEFAULT 0,\n    16‚Üí      total REAL NOT NULL,\n    17‚Üí      status TEXT NOT NULL DEFAULT 'draft'\n    18‚Üí    );\n    19‚Üí\n    20‚Üí    CREATE TABLE IF NOT EXISTS line_items (\n    21‚Üí      id INTEGER PRIMARY KEY AUTOINCREMENT,\n    22‚Üí      invoice_id INTEGER NOT NULL,\n    23‚Üí      description TEXT NOT NULL,\n    24‚Üí      quantity INTEGER NOT NULL,\n    25‚Üí      unit_price REAL NOT NULL,\n    26‚Üí      FOREIGN KEY (invoice_id) REFERENCES invoices(id)\n    27‚Üí    );\n    28‚Üí  `);\n    29‚Üí\n    30‚Üí  return db;\n    31‚Üí}\n    32‚Üí"}]},"parent_tool_use_id":"toolu_01KbRHk5cLN5HLuroTPVG8dw","session_id":"53811a29-0446-4208-afcd-d53aaea285ec","uuid":"3d1e3764-3ffb-45ee-8d3c-708193dce809"}
