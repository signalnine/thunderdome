+import vm from 'node:vm';
+import type { SandboxResult, RunnerService } from '../types.js';
+
+const DEFAULT_TIMEOUT_MS = 5000;
+
+export function createRunner(): RunnerService {
+  async function runInSandbox(
+    code: string,
+    timeoutMs: number,
+    context: Record<string, unknown> = {}
+  ): Promise<SandboxResult> {
+    const startTime = performance.now();
+    const startMemory = process.memoryUsage().heapUsed;
+
+    try {
+      const sandbox: Record<string, unknown> = {
+        ...context,
+        console: {
+          log: (...args: unknown[]) => {
+            outputs.push(args.map(String).join(' '));
+          },
+          error: (...args: unknown[]) => {
+            outputs.push(args.map(String).join(' '));
+          },
+          warn: (...args: unknown[]) => {
+            outputs.push(args.map(String).join(' '));
+          },
+        },
+      };
+      const outputs: string[] = [];
+
+      vm.createContext(sandbox);
+      const script = new vm.Script(code);
+      const result = script.runInContext(sandbox, { timeout: timeoutMs });
+
+      const duration = performance.now() - startTime;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - startMemory);
+
+      return {
+        success: true,
+        output: result !== undefined ? result : (outputs.length > 0 ? outputs.join('\n') : undefined),
+        duration,
+        memoryUsed,
+      };
+    } catch (err) {
+      const duration = performance.now() - startTime;
+      const memoryUsed = Math.max(0, process.memoryUsage().heapUsed - startMemory);
+
+      return {
+        success: false,
+        output: null,
+        duration,
+        memoryUsed,
+        error: (err && typeof err === 'object' && 'message' in err)
+          ? String((err as { message: unknown }).message)
+          : String(err),
+      };
+    }
+  }
+
+  return {
+    async execute(
+      code: string,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return runInSandbox(code, DEFAULT_TIMEOUT_MS, context);
+    },
+
+    async executeWithTimeout(
+      code: string,
+      timeoutMs: number,
+      context?: Record<string, unknown>
+    ): Promise<SandboxResult> {
+      return runInSandbox(code, timeoutMs, context);
+    },
+  };
+}
