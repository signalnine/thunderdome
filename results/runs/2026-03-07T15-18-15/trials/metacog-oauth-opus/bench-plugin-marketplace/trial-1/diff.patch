list all plugins', () => {\n    registry.register(makeManifest({ name: 'plugin-a', version: '1.0.0' }));\n    registry.register(makeManifest({ name: 'plugin-b', version: '1.0.0' }));\n    const all = registry.list();\n    expect(all).toHaveLength(2);\n  });\n\n  it('should list multiple versions of the same plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    const all = registry.list();\n    expect(all).toHaveLength(2);\n  });\n\n  it('should search plugins by name', () => {\n    registry.register(makeManifest({ name: 'auth-plugin' }));\n    registry.register(makeManifest({ name: 'logger-plugin' }));\n    const results = registry.search('auth');\n    expect(results).toHaveLength(1);\n    expect(results[0].name).toBe('auth-plugin');\n  });\n\n  it('should search plugins by description', () => {\n    registry.register(makeManifest({ description: 'Handles authentication' }));\n    const results = registry.search('authentication');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should search plugins by author', () => {\n    registry.register(makeManifest({ author: 'JaneDoe' }));\n    const results = registry.search('janedoe');\n    expect(results).toHaveLength(1);\n  });\n\n  it('should remove a specific version', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n\n    const removed = registry.remove('test-plugin', '1.0.0');\n    expect(removed).toBe(true);\n    expect(registry.getVersion('test-plugin', '1.0.0')).toBeNull();\n    expect(registry.getVersion('test-plugin', '2.0.0')).not.toBeNull();\n  });\n\n  it('should return false when removing non-existent version', () => {\n    expect(registry.remove('nonexistent', '1.0.0')).toBe(false);\n  });\n\n  it('should list versions for a plugin', () => {\n    registry.register(makeManifest({ version: '1.0.0' }));\n    registry.register(makeManifest({ version: '1.1.0' }));\n    registry.register(makeManifest({ version: '2.0.0' }));\n    const versions = registry.listVersions('test-plugin');\n    expect(versions).toEqual(['1.0.0', '1.1.0', '2.0.0']);\n  });\n\n  it('should return empty array for unknown plugin versions', () => {\n    expect(registry.listVersions('nonexistent')).toEqual([]);\n  });\n\n  it('should update a plugin', () => {\n    registry.register(makeManifest());\n    registry.update('test-plugin', '1.0.0', { description: 'Updated description' });\n    const plugin = registry.getVersion('test-plugin', '1.0.0');\n    expect(plugin!.description).toBe('Updated description');\n  });\n\n  it('should throw when updating non-existent plugin', () => {\n    expect(() => registry.update('nonexistent', '1.0.0', {})).toThrow();\n  });\n\n  it('should return copies so mutation is safe', () => {\n    registry.register(makeManifest());\n    const result = registry.get('test-plugin');\n    result!.name = 'mutated';\n    const again = registry.get('test-plugin');\n    expect(again!.name).toBe('test-plugin');\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":133,"cache_read_input_tokens":29179,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":133},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a4f6ac5a-d6b1-4d32-8bda-42def2ec4088","uuid":"ba0bfd90-2939-429c-a6e4-ec7d7d0c4c8d"}
