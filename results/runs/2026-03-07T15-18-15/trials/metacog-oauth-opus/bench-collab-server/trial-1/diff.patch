rime.push({ type: \"insert\", text: opB.text });\n      aPrime.push({ type: \"retain\", count: opB.text.length });\n      if (opA) aRemain = opA; // put a back\n      continue;\n    }\n\n    if (opA === null || opB === null) {\n      throw new Error(\"Transform: operations have mismatched lengths\");\n    }\n\n    // Both retain\n    if (opA.type === \"retain\" && opB.type === \"retain\") {\n      const min = Math.min(opA.count, opB.count);\n      aPrime.push({ type: \"retain\", count: min });\n      bPrime.push({ type: \"retain\", count: min });\n      if (opA.count > min) aRemain = { type: \"retain\", count: opA.count - min };\n      if (opB.count > min) bRemain = { type: \"retain\", count: opB.count - min };\n    }\n    // a deletes, b deletes\n    else if (opA.type === \"delete\" && opB.type === \"delete\") {\n      const min = Math.min(opA.count, opB.count);\n      // Both deleted the same chars, so neither needs to do anything for those\n      if (opA.count > min) aRemain = { type: \"delete\", count: opA.count - min };\n      if (opB.count > min) bRemain = { type: \"delete\", count: opB.count - min };\n    }\n    // a deletes, b retains\n    else if (opA.type === \"delete\" && opB.type === \"retain\") {\n      const min = Math.min(opA.count, opB.count);\n      aPrime.push({ type: \"delete\", count: min });\n      // b doesn't need to retain what a deleted\n      if (opA.count > min) aRemain = { type: \"delete\", count: opA.count - min };\n      if (opB.count > min) bRemain = { type: \"retain\", count: opB.count - min };\n    }\n    // a retains, b deletes\n    else if (opA.type === \"retain\" && opB.type === \"delete\") {\n      const min = Math.min(opA.count, opB.count);\n      bPrime.push({ type: \"delete\", count: min });\n      // a doesn't need to retain what b deleted\n      if (opA.count > min) aRemain = { type: \"retain\", count: opA.count - min };\n      if (opB.count > min) bRemain = { type: \"delete\", count: opB.count - min };\n    }\n  }\n\n  return [compact(aPrime), compact(bPrime)];\n}\n\n/** Compact adjacent same-type operations. */\nfunction compact(ops: OpComponent[]): OpComponent[] {\n  const result: OpComponent[] = [];\n  for (const op of ops) {\n    if (result.length === 0) {\n      result.push(op);\n      continue;\n    }\n    const last = result[result.length - 1];\n    if (last.type === \"retain\" && op.type === \"retain\") {\n      result[result.length - 1] = { type: \"retain\", count: last.count + op.count };\n    } else if (last.type === \"delete\" && op.type === \"delete\") {\n      result[result.length - 1] = { type: \"delete\", count: last.count + op.count };\n    } else if (last.type === \"insert\" && op.type === \"insert\") {\n      result[result.length - 1] = { type: \"insert\", text: last.text + op.text };\n    } else {\n      result.push(op);\n    }\n  }\n  return result;\n}\n\n/** Compose two operations into one: compose(a, b) such that apply(doc, compose(a,b)) === apply(apply(doc, a), b). */\nexport function compose(a: OpComponent[], b: OpComponent[]): OpComponent[] {\n  const result: OpComponent[] = [];\n\n  let ai = 0;\n  let bi = 0;\n  let aRemain: OpComponent | null = null;\n  let bRemain: OpComponent | null = null;\n\n  function nextA(): OpComponent | null {\n    if (aRemain) {\n      const r = aRemain;\n      aRemain = null;\n      return r;\n    }\n    if (ai < a.length) return a[ai++];\n    return null;\n  }\n\n  function nextB(): OpComponent | null {\n    if (bRemain) {\n      const r = bRemain;\n      bRemain = null;\n      return r;\n    }\n    if (bi < b.length) return b[bi++];\n    return null;\n  }\n\n  while (true) {\n    const opA = nextA();\n    const opB = nextB();\n\n    if (opA === null && opB === null) break;\n\n    // a deletes: just delete from original, doesn't consume b\n    if (opA && opA.type === \"delete\") {\n      result.push(opA);\n      if (opB) bRemain = opB;\n      continue;\n    }\n\n    // b inserts: just insert, doesn't consume a\n    if (opB && opB.type === \"insert\") {\n      result.push(opB);\n      if (opA) aRemain = opA;\n      continue;\n    }\n\n    if (opA === null || opB === null) {\n      throw new Error(\"Compose: operations have mismatched lengths\");\n    }\n\n    // a retains, b retains\n    if (opA.type === \"retain\" && opB.type === \"retain\") {\n      const min = Math.min(opA.count, opB.count);\n      result.push({ type: \"retain\", count: min });\n      if (opA.count > min) aRemain = { type: \"retain\", count: opA.count - min };\n      if (opB.count > min) bRemain = { type: \"retain\", count: opB.count - min };\n    }\n    // a retains, b deletes\n    else if (opA.type === \"retain\" && opB.type === \"delete\") {\n      const min = Math.min(opA.count, opB.count);\n      result.push({ type: \"delete\", count: min });\n      if (opA.count > min) aRemain = { type: \"retain\", count: opA.count - min };\n      if (opB.count > min) bRemain = { type: \"delete\", count: opB.count - min };\n    }\n    // a inserts, b retains\n    else if (opA.type === \"insert\" && opB.type === \"retain\") {\n      const min = Math.min(opA.text.length, opB.count);\n      result.push({ type: \"insert\", text: opA.text.slice(0, min) });\n      if (opA.text.length > min) aRemain = { type: \"insert\", text: opA.text.slice(min) };\n      if (opB.count > min) bRemain = { type: \"retain\", count: opB.count - min };\n    }\n    // a inserts, b deletes (b deletes what a inserted)\n    else if (opA.type === \"insert\" && opB.type === \"delete\") {\n      const min = Math.min(opA.text.length, opB.count);\n      // These cancel out\n      if (opA.text.length > min) aRemain = { type: \"insert\", text: opA.text.slice(min) };\n      if (opB.count > min) bRemain = { type: \"delete\", count: opB.count - min };\n    }\n  }\n\n  return compact(result);\n}\n\n/**\n * Validate that an operation is well-formed and applicable to a document of the given length.\n */\nexport function validate(ops: OpComponent[], docLength: number): string | null {\n  for (const op of ops) {\n    if (op.type === \"retain\") {\n      if (typeof op.count !== \"number\" || op.count <= 0 || !Number.isInteger(op.count)) {\n        return \"retain count must be a positive integer\";\n      }\n    } else if (op.type === \"insert\") {\n      if (typeof op.text !== \"string\" || op.text.length === 0) {\n        return \"insert text must be a non-empty string\";\n      }\n    } else if (op.type === \"delete\") {\n      if (typeof op.count !== \"number\" || op.count <= 0 || !Number.isInteger(op.count)) {\n        return \"delete count must be a positive integer\";\n      }\n    } else {\n      return `unknown operation type: ${(op as OpComponent).type}`;\n    }\n  }\n\n  const inLen = inputLength(ops);\n  if (inLen !== docLength) {\n    return `operation input length (${inLen}) does not match document length (${docLength})`;\n  }\n\n  return null;\n}\n","structuredPatch":[],"originalFile":null}}
