diff --git a/src/db.ts b/src/db.ts
new file mode 100644
index 0000000..369af43
--- /dev/null
+++ b/src/db.ts
@@ -0,0 +1,157 @@
+import Database from "better-sqlite3";
+import { randomUUID } from "crypto";
+import { readFileSync } from "fs";
+import { resolve, dirname } from "path";
+import { fileURLToPath } from "url";
+
+const __dirname = dirname(fileURLToPath(import.meta.url));
+
+export interface Document {
+  id: string;
+  title: string;
+  content: string;
+  created_at: string;
+  updated_at: string;
+}
+
+export interface Version {
+  id: number;
+  document_id: string;
+  version: number;
+  content: string;
+  operation: string | null;
+  created_at: string;
+}
+
+export function createDatabase(dbPath?: string): DatabaseLayer {
+  return new DatabaseLayer(dbPath);
+}
+
+export class DatabaseLayer {
+  public db: Database.Database;
+
+  constructor(dbPath?: string) {
+    this.db = new Database(dbPath || ":memory:");
+    this.db.pragma("journal_mode = WAL");
+    this.db.pragma("foreign_keys = ON");
+    this.init();
+  }
+
+  private init(): void {
+    const schemaPath = resolve(__dirname, "..", "schema.sql");
+    let schema: string;
+    try {
+      schema = readFileSync(schemaPath, "utf-8");
+    } catch {
+      // Fallback inline schema if file not found
+      schema = `
+        CREATE TABLE IF NOT EXISTS documents (
+          id TEXT PRIMARY KEY,
+          title TEXT NOT NULL,
+          content TEXT NOT NULL DEFAULT '',
+          created_at TEXT NOT NULL DEFAULT (datetime('now')),
+          updated_at TEXT NOT NULL DEFAULT (datetime('now'))
+        );
+        CREATE TABLE IF NOT EXISTS versions (
+          id INTEGER PRIMARY KEY AUTOINCREMENT,
+          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+          version INTEGER NOT NULL,
+          content TEXT NOT NULL,
+          operation TEXT,
+          created_at TEXT NOT NULL DEFAULT (datetime('now')),
+          UNIQUE(document_id, version)
+        );
+        CREATE TABLE IF NOT EXISTS active_connections (
+          id TEXT PRIMARY KEY,
+          document_id TEXT NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
+          connected_at TEXT NOT NULL DEFAULT (datetime('now'))
+        );
+      `;
+    }
+    this.db.exec(schema);
+  }
+
+  createDocument(title: string, content: string = ""): Document {
+    const id = randomUUID();
+    const stmt = this.db.prepare(
+      "INSERT INTO documents (id, title, content) VALUES (?, ?, ?)"
+    );
+    stmt.run(id, title, content);
+
+    // Create initial version
+    this.db.prepare(
+      "INSERT INTO versions (document_id, version, content, operation) VALUES (?, 1, ?, ?)"
+    ).run(id, content, JSON.stringify({ type: "init", content }));
+
+    return this.getDocument(id)!;
+  }
+
+  getDocument(id: string): Document | undefined {
+    const stmt = this.db.prepare("SELECT * FROM documents WHERE id = ?");
+    return stmt.get(id) as Document | undefined;
+  }
+
+  listDocuments(): Document[] {
+    const stmt = this.db.prepare("SELECT * FROM documents ORDER BY updated_at DESC");
+    return stmt.all() as Document[];
+  }
+
+  updateDocument(id: string, updates: { title?: string; content?: string }): Document | undefined {
+    const doc = this.getDocument(id);
+    if (!doc) return undefined;
+
+    const title = updates.title ?? doc.title;
+    const content = updates.content ?? doc.content;
+
+    this.db.prepare(
+      "UPDATE documents SET title = ?, content = ?, updated_at = datetime('now') WHERE id = ?"
+    ).run(title, content, id);
+
+    return this.getDocument(id);
+  }
+
+  deleteDocument(id: string): boolean {
+    const result = this.db.prepare("DELETE FROM documents WHERE id = ?").run(id);
+    return result.changes > 0;
+  }
+
+  updateDocumentContent(id: string, content: string, operation?: object): void {
+    this.db.prepare(
+      "UPDATE documents SET content = ?, updated_at = datetime('now') WHERE id = ?"
+    ).run(content, id);
+
+    // Add version entry
+    const maxVersion = this.db.prepare(
+      "SELECT COALESCE(MAX(version), 0) as max_ver FROM versions WHERE document_id = ?"
+    ).get(id) as { max_ver: number };
+
+    this.db.prepare(
+      "INSERT INTO versions (document_id, version, content, operation) VALUES (?, ?, ?, ?)"
+    ).run(id, maxVersion.max_ver + 1, content, operation ? JSON.stringify(operation) : null);
+  }
+
+  getVersions(documentId: string): Version[] {
+    const stmt = this.db.prepare(
+      "SELECT * FROM versions WHERE document_id = ? ORDER BY version ASC"
+    );
+    return stmt.all(documentId) as Version[];
+  }
+
+  getVersion(documentId: string, version: number): Version | undefined {
+    const stmt = this.db.prepare(
+      "SELECT * FROM versions WHERE document_id = ? AND version = ?"
+    );
+    return stmt.get(documentId, version) as Version | undefined;
+  }
+
+  getCurrentVersion(documentId: string): number {
+    const result = this.db.prepare(
+      "SELECT COALESCE(MAX(version), 0) as max_ver FROM versions WHERE document_id = ?"
+    ).get(documentId) as { max_ver: number };
+    return result.max_ver;
+  }
+
+  close(): void {
+    this.db.close();
+  }
+}
diff --git a/src/ot.test.ts b/src/ot.test.ts
new file mode 100644
index 0000000..4ffa57b
--- /dev/null
+++ b/src/ot.test.ts
@@ -0,0 +1,240 @@
+import { describe, it, expect } from "vitest";
+import { apply, transform, validate, inputLength, outputLength, compose, OpComponent } from "./ot.js";
+
+describe("OT Engine", () => {
+  describe("apply", () => {
+    it("should apply a simple insert at the beginning", () => {
+      const result = apply("hello", [
+        { type: "insert", text: "say " },
+        { type: "retain", count: 5 },
+      ]);
+      expect(result).toBe("say hello");
+    });
+
+    it("should apply a simple insert at the end", () => {
+      const result = apply("hello", [
+        { type: "retain", count: 5 },
+        { type: "insert", text: " world" },
+      ]);
+      expect(result).toBe("hello world");
+    });
+
+    it("should apply a delete", () => {
+      const result = apply("hello world", [
+        { type: "retain", count: 5 },
+        { type: "delete", count: 6 },
+      ]);
+      expect(result).toBe("hello");
+    });
+
+    it("should apply insert in the middle", () => {
+      const result = apply("helo", [
+        { type: "retain", count: 2 },
+        { type: "insert", text: "l" },
+        { type: "retain", count: 2 },
+      ]);
+      expect(result).toBe("hello");
+    });
+
+    it("should handle empty document with insert", () => {
+      const result = apply("", [{ type: "insert", text: "hello" }]);
+      expect(result).toBe("hello");
+    });
+
+    it("should throw on mismatched lengths", () => {
+      expect(() =>
+        apply("hello", [{ type: "retain", count: 10 }])
+      ).toThrow();
+    });
+  });
+
+  describe("inputLength / outputLength", () => {
+    it("should calculate input length", () => {
+      const ops: OpComponent[] = [
+        { type: "retain", count: 3 },
+        { type: "insert", text: "abc" },
+        { type: "delete", count: 2 },
+      ];
+      expect(inputLength(ops)).toBe(5); // retain 3 + delete 2
+    });
+
+    it("should calculate output length", () => {
+      const ops: OpComponent[] = [
+        { type: "retain", count: 3 },
+        { type: "insert", text: "abc" },
+        { type: "delete", count: 2 },
+      ];
+      expect(outputLength(ops)).toBe(6); // retain 3 + insert 3
+    });
+  });
+
+  describe("transform", () => {
+    it("should transform two inserts at different positions", () => {
+      // doc: "abc" (len 3)
+      // a: insert "X" at pos 1: retain(1), insert("X"), retain(2)
+      // b: insert "Y" at pos 2: retain(2), insert("Y"), retain(1)
+      const a: OpComponent[] = [
+        { type: "retain", count: 1 },
+        { type: "insert", text: "X" },
+        { type: "retain", count: 2 },
+      ];
+      const b: OpComponent[] = [
+        { type: "retain", count: 2 },
+        { type: "insert", text: "Y" },
+        { type: "retain", count: 1 },
+      ];
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      // After a: "aXbc" (len 4)
+      // bPrime should insert Y at correct position in "aXbc"
+      const afterA = apply("abc", a);
+      expect(afterA).toBe("aXbc");
+      const afterAB = apply(afterA, bPrime);
+
+      // After b: "abYc" (len 4)
+      // aPrime should insert X at correct position in "abYc"
+      const afterB = apply("abc", b);
+      expect(afterB).toBe("abYc");
+      const afterBA = apply(afterB, aPrime);
+
+      // Both should converge
+      expect(afterAB).toBe(afterBA);
+      expect(afterAB).toBe("aXbYc");
+    });
+
+    it("should transform two inserts at the same position (a wins)", () => {
+      // doc: "abc" (len 3)
+      // Both insert at position 1
+      const a: OpComponent[] = [
+        { type: "retain", count: 1 },
+        { type: "insert", text: "X" },
+        { type: "retain", count: 2 },
+      ];
+      const b: OpComponent[] = [
+        { type: "retain", count: 1 },
+        { type: "insert", text: "Y" },
+        { type: "retain", count: 2 },
+      ];
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const afterA = apply("abc", a);
+      const afterAB = apply(afterA, bPrime);
+
+      const afterB = apply("abc", b);
+      const afterBA = apply(afterB, aPrime);
+
+      expect(afterAB).toBe(afterBA);
+      // a has priority, so X comes before Y
+      expect(afterAB).toBe("aXYbc");
+    });
+
+    it("should transform insert and delete", () => {
+      // doc: "abcde" (len 5)
+      // a: insert "X" at pos 2
+      // b: delete chars at pos 1-3 (delete "bc")
+      const a: OpComponent[] = [
+        { type: "retain", count: 2 },
+        { type: "insert", text: "X" },
+        { type: "retain", count: 3 },
+      ];
+      const b: OpComponent[] = [
+        { type: "retain", count: 1 },
+        { type: "delete", count: 2 },
+        { type: "retain", count: 2 },
+      ];
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const afterA = apply("abcde", a);
+      const afterAB = apply(afterA, bPrime);
+
+      const afterB = apply("abcde", b);
+      const afterBA = apply(afterB, aPrime);
+
+      expect(afterAB).toBe(afterBA);
+    });
+
+    it("should transform two deletes on overlapping ranges", () => {
+      // doc: "abcde" (len 5)
+      // a: delete "bc" (pos 1-2)
+      // b: delete "cd" (pos 2-3)
+      const a: OpComponent[] = [
+        { type: "retain", count: 1 },
+        { type: "delete", count: 2 },
+        { type: "retain", count: 2 },
+      ];
+      const b: OpComponent[] = [
+        { type: "retain", count: 2 },
+        { type: "delete", count: 2 },
+        { type: "retain", count: 1 },
+      ];
+
+      const [aPrime, bPrime] = transform(a, b);
+
+      const afterA = apply("abcde", a);
+      const afterAB = apply(afterA, bPrime);
+
+      const afterB = apply("abcde", b);
+      const afterBA = apply(afterB, aPrime);
+
+      expect(afterAB).toBe(afterBA);
+      expect(afterAB).toBe("ae");
+    });
+  });
+
+  describe("compose", () => {
+    it("should compose two sequential operations", () => {
+      // doc: "hello"
+      // op1: insert " world" at end
+      // op2: insert "!" at end of "hello world"
+      const op1: OpComponent[] = [
+        { type: "retain", count: 5 },
+        { type: "insert", text: " world" },
+      ];
+      const op2: OpComponent[] = [
+        { type: "retain", count: 11 },
+        { type: "insert", text: "!" },
+      ];
+
+      const composed = compose(op1, op2);
+      const result = apply("hello", composed);
+      expect(result).toBe("hello world!");
+
+      // Should match sequential application
+      const step1 = apply("hello", op1);
+      const step2 = apply(step1, op2);
+      expect(result).toBe(step2);
+    });
+  });
+
+  describe("validate", () => {
+    it("should return null for valid operations", () => {
+      const ops: OpComponent[] = [
+        { type: "retain", count: 3 },
+        { type: "insert", text: "hello" },
+        { type: "delete", count: 2 },
+      ];
+      expect(validate(ops, 5)).toBeNull();
+    });
+
+    it("should reject mismatched input length", () => {
+      const ops: OpComponent[] = [{ type: "retain", count: 10 }];
+      expect(validate(ops, 5)).toContain("does not match");
+    });
+
+    it("should reject invalid retain count", () => {
+      const ops: OpComponent[] = [{ type: "retain", count: -1 }];
+      expect(validate(ops, 5)).toContain("positive integer");
+    });
+
+    it("should reject empty insert text", () => {
+      const ops: OpComponent[] = [
+        { type: "insert", text: "" },
+        { type: "retain", count: 5 },
+      ];
+      expect(validate(ops, 5)).toContain("non-empty string");
+    });
+  });
+});
