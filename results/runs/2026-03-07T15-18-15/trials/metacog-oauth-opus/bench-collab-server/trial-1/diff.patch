s Record<string, unknown>).content as string;","+    expect(content).toBe(\"0123456789\");","+    expect(content.length).toBe(10);"," ","     // Verify version history","-    const versionsRes = await request(app.app)","-      .get(`/api/documents/${docId}/versions`)","-      .expect(200);","-    expect(versionsRes.body.length).toBe(11); // initial + 10 edits","+    const versionsRes = await api(\"GET\", `/api/documents/${docId}/versions`);","+    expect((versionsRes.body as unknown[]).length).toBe(11); // initial + 10 edits"," ","     for (const ws of clients) {","       ws.close();"]},{"oldStart":399,"oldLines":13,"newStart":370,"newLines":14,"lines":["     const port1 = await app1.start(0);"," ","     // Create a document","-    const createRes = await request(app1.app)","-      .post(\"/api/documents\")","-      .send({ title: \"Persistent Doc\", content: \"Survives restart\" })","-      .expect(201);","+    const createRes = await fetch(`http://localhost:${port1}/api/documents`, {","+      method: \"POST\",","+      headers: { \"Content-Type\": \"application/json\" },","+      body: JSON.stringify({ title: \"Persistent Doc\", content: \"Survives restart\" }),","+    });","+    const createBody = await createRes.json() as Record<string, unknown>;","+    const docId = createBody.id as string;"," ","-    const docId = createRes.body.id;","-","     // Modify via WebSocket","     const ws = await new Promise<WebSocket>((resolve, reject) => {","       const w = new WebSocket(`ws://localhost:${port1}/ws/documents/${docId}`);"]},{"oldStart":429,"oldLines":20,"newStart":401,"newLines":18,"lines":[" ","     // Restart with same database","     const app2 = createApp(tmpDbPath);","-    await app2.start(0);","+    const port2 = await app2.start(0);"," ","-    const res = await request(app2.app)","-      .get(`/api/documents/${docId}`)","-      .expect(200);","+    const getRes = await fetch(`http://localhost:${port2}/api/documents/${docId}`);","+    const getBody = await getRes.json() as Record<string, unknown>;"," ","-    expect(res.body.title).toBe(\"Persistent Doc\");","-    expect(res.body.content).toBe(\"Survives restart!\");","+    expect(getBody.title).toBe(\"Persistent Doc\");","+    expect(getBody.content).toBe(\"Survives restart!\");"," ","     // Check version history survived","-    const versionsRes = await request(app2.app)","-      .get(`/api/documents/${docId}/versions`)","-      .expect(200);","-    expect(versionsRes.body.length).toBe(2);","+    const versionsRes = await fetch(`http://localhost:${port2}/api/documents/${docId}/versions`);","+    const versionsBody = await versionsRes.json() as unknown[];","+    expect(versionsBody.length).toBe(2);"," ","     await app2.stop();","   });"]}],"originalFile":"import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\nimport request from \"supertest\";\nimport WebSocket from \"ws\";\nimport { createApp, AppInstance } from \"./server.js\";\nimport { OpComponent } from \"./ot.js\";\n\nlet app: AppInstance;\nlet port: number;\n\nbeforeEach(async () => {\n  app = createApp(); // in-memory DB\n  port = await app.start(0);\n});\n\nafterEach(async () => {\n  await app.stop();\n});\n\nfunction wsUrl(docId: string): string {\n  return `ws://localhost:${port}/ws/documents/${docId}`;\n}\n\nfunction connectWs(docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(wsUrl(docId));\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve) => {\n    ws.once(\"message\", (data) => {\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\nfunction sendOp(ws: WebSocket, ops: OpComponent[], version: number): void {\n  ws.send(JSON.stringify({ type: \"operation\", ops, version }));\n}\n\ndescribe(\"REST API\", () => {\n  it(\"should create a document\", async () => {\n    const res = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    expect(res.body.title).toBe(\"Test Doc\");\n    expect(res.body.content).toBe(\"Hello\");\n    expect(res.body.id).toBeDefined();\n  });\n\n  it(\"should reject document creation without title\", async () => {\n    await request(app.app)\n      .post(\"/api/documents\")\n      .send({ content: \"Hello\" })\n      .expect(400);\n  });\n\n  it(\"should list documents\", async () => {\n    await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Doc 1\" })\n      .expect(201);\n    await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Doc 2\" })\n      .expect(201);\n\n    const res = await request(app.app).get(\"/api/documents\").expect(200);\n    expect(res.body.length).toBe(2);\n  });\n\n  it(\"should get a document by id\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const res = await request(app.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(200);\n\n    expect(res.body.title).toBe(\"Test Doc\");\n    expect(res.body.content).toBe(\"Hello\");\n  });\n\n  it(\"should return 404 for non-existent document\", async () => {\n    await request(app.app)\n      .get(\"/api/documents/nonexistent\")\n      .expect(404);\n  });\n\n  it(\"should update a document\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const res = await request(app.app)\n      .put(`/api/documents/${createRes.body.id}`)\n      .send({ title: \"Updated Title\", content: \"Updated Content\" })\n      .expect(200);\n\n    expect(res.body.title).toBe(\"Updated Title\");\n    expect(res.body.content).toBe(\"Updated Content\");\n  });\n\n  it(\"should delete a document\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\" })\n      .expect(201);\n\n    await request(app.app)\n      .delete(`/api/documents/${createRes.body.id}`)\n      .expect(204);\n\n    await request(app.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(404);\n  });\n\n  it(\"should get version history\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const res = await request(app.app)\n      .get(`/api/documents/${createRes.body.id}/versions`)\n      .expect(200);\n\n    expect(res.body.length).toBe(1);\n    expect(res.body[0].version).toBe(1);\n    expect(res.body[0].content).toBe(\"Hello\");\n  });\n\n  it(\"should get a specific version\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const res = await request(app.app)\n      .get(`/api/documents/${createRes.body.id}/versions/1`)\n      .expect(200);\n\n    expect(res.body.version).toBe(1);\n    expect(res.body.content).toBe(\"Hello\");\n  });\n});\n\ndescribe(\"WebSocket Collaboration\", () => {\n  it(\"should send sync message on connect\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const ws = await connectWs(createRes.body.id);\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe(\"sync\");\n    expect(msg.content).toBe(\"Hello\");\n    expect(msg.version).toBe(1);\n    expect(msg.documentId).toBe(createRes.body.id);\n\n    ws.close();\n  });\n\n  it(\"should reject connection to non-existent document\", async () => {\n    const ws = new WebSocket(wsUrl(\"nonexistent\"));\n    return new Promise<void>((resolve) => {\n      ws.on(\"error\", () => {\n        resolve();\n      });\n      ws.on(\"close\", () => {\n        resolve();\n      });\n    });\n  });\n\n  it(\"should apply and ack an operation\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const ws = await connectWs(createRes.body.id);\n    const syncMsg = await waitForMessage(ws);\n    expect(syncMsg.type).toBe(\"sync\");\n\n    // Insert \" World\" at the end\n    sendOp(ws, [\n      { type: \"retain\", count: 5 },\n      { type: \"insert\", text: \" World\" },\n    ], 1);\n\n    const ackMsg = await waitForMessage(ws);\n    expect(ackMsg.type).toBe(\"ack\");\n    expect(ackMsg.version).toBe(2);\n\n    // Verify via REST\n    const res = await request(app.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"Hello World\");\n\n    ws.close();\n  });\n\n  it(\"should broadcast operations to other clients\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const ws1 = await connectWs(createRes.body.id);\n    const sync1 = await waitForMessage(ws1);\n    expect(sync1.type).toBe(\"sync\");\n\n    const ws2 = await connectWs(createRes.body.id);\n    const sync2 = await waitForMessage(ws2);\n    expect(sync2.type).toBe(\"sync\");\n\n    // ws1 sends an operation\n    const opMsg = waitForMessage(ws2);\n    sendOp(ws1, [\n      { type: \"retain\", count: 5 },\n      { type: \"insert\", text: \" World\" },\n    ], 1);\n\n    // ws1 gets ack\n    const ack = await waitForMessage(ws1);\n    expect(ack.type).toBe(\"ack\");\n\n    // ws2 gets the operation broadcast\n    const broadcast = await opMsg;\n    expect(broadcast.type).toBe(\"operation\");\n    expect(broadcast.version).toBe(2);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle concurrent edits with OT\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"abc\" })\n      .expect(201);\n\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(docId);\n    const sync1 = await waitForMessage(ws1);\n    expect(sync1.type).toBe(\"sync\");\n    expect(sync1.content).toBe(\"abc\");\n\n    const ws2 = await connectWs(docId);\n    const sync2 = await waitForMessage(ws2);\n    expect(sync2.type).toBe(\"sync\");\n    expect(sync2.content).toBe(\"abc\");\n\n    // Both based on version 1\n    // ws1: insert \"X\" at beginning -> \"Xabc\"\n    // ws2: insert \"Y\" at end -> \"abcY\"\n\n    // Send ws1's op first (will be applied directly)\n    sendOp(ws1, [\n      { type: \"insert\", text: \"X\" },\n      { type: \"retain\", count: 3 },\n    ], 1);\n\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe(\"ack\");\n    expect(ack1.version).toBe(2);\n\n    // ws2 receives ws1's broadcast\n    const broadcast1 = await waitForMessage(ws2);\n    expect(broadcast1.type).toBe(\"operation\");\n\n    // Now ws2 sends its op (still based on version 1, server will transform it)\n    sendOp(ws2, [\n      { type: \"retain\", count: 3 },\n      { type: \"insert\", text: \"Y\" },\n    ], 1);\n\n    const ack2 = await waitForMessage(ws2);\n    expect(ack2.type).toBe(\"ack\");\n    expect(ack2.version).toBe(3);\n\n    // ws1 receives ws2's transformed broadcast\n    const broadcast2 = await waitForMessage(ws1);\n    expect(broadcast2.type).toBe(\"operation\");\n\n    // Verify final document state via REST\n    const res = await request(app.app)\n      .get(`/api/documents/${docId}`)\n      .expect(200);\n\n    // Both X and Y should be preserved\n    expect(res.body.content).toContain(\"X\");\n    expect(res.body.content).toContain(\"Y\");\n    expect(res.body.content).toContain(\"abc\");\n    expect(res.body.content).toBe(\"XabcY\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle invalid operation gracefully\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const ws = await connectWs(createRes.body.id);\n    const syncMsg = await waitForMessage(ws);\n    expect(syncMsg.type).toBe(\"sync\");\n\n    // Send invalid JSON\n    ws.send(\"not json\");\n    const errMsg1 = await waitForMessage(ws);\n    expect(errMsg1.type).toBe(\"error\");\n\n    // Send invalid operation (wrong length)\n    sendOp(ws, [{ type: \"retain\", count: 100 }], 1);\n    const errMsg2 = await waitForMessage(ws);\n    expect(errMsg2.type).toBe(\"error\");\n\n    ws.close();\n  });\n\n  it(\"should handle 10 concurrent clients\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"\" })\n      .expect(201);\n\n    const docId = createRes.body.id;\n    const clientCount = 10;\n    const clients: WebSocket[] = [];\n\n    // Connect all clients\n    for (let i = 0; i < clientCount; i++) {\n      const ws = await connectWs(docId);\n      const sync = await waitForMessage(ws);\n      expect(sync.type).toBe(\"sync\");\n      clients.push(ws);\n    }\n\n    // Each client inserts a character, sequentially to avoid complexity\n    let currentVersion = 1;\n    for (let i = 0; i < clientCount; i++) {\n      const ws = clients[i];\n\n      // Each client inserts its index at the end of the current document\n      const currentDoc = (await request(app.app).get(`/api/documents/${docId}`)).body.content;\n      sendOp(ws, [\n        ...(currentDoc.length > 0 ? [{ type: \"retain\" as const, count: currentDoc.length }] : []),\n        { type: \"insert\" as const, text: String(i) },\n      ], currentVersion);\n\n  