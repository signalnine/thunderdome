 handle 10 concurrent clients\", async () => {\n    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"\" });\n    const docId = (createRes.body as Record<string, unknown>).id as string;\n    const clientCount = 10;\n    const clients: WsClient[] = [];\n\n    // Connect all clients\n    for (let i = 0; i < clientCount; i++) {\n      const client = connectWs(docId);\n      const sync = await client.nextMessage();\n      expect(sync.type).toBe(\"sync\");\n      clients.push(client);\n    }\n\n    // Each client inserts a character, sequentially to avoid complexity\n    let currentVersion = 1;\n    for (let i = 0; i < clientCount; i++) {\n      const client = clients[i];\n\n      // Each client inserts its index at the end of the current document\n      const docRes = await api(\"GET\", `/api/documents/${docId}`);\n      const currentDoc = (docRes.body as Record<string, unknown>).content as string;\n      client.sendOp([\n        ...(currentDoc.length > 0 ? [{ type: \"retain\" as const, count: currentDoc.length }] : []),\n        { type: \"insert\" as const, text: String(i) },\n      ], currentVersion);\n\n      const ack = await client.nextMessage();\n      expect(ack.type).toBe(\"ack\");\n      currentVersion = ack.version as number;\n\n      // Drain broadcast messages from other clients\n      for (let j = 0; j < clientCount; j++) {\n        if (j !== i) {\n          await clients[j].nextMessage();\n        }\n      }\n    }\n\n    // Verify final state\n    const res = await api(\"GET\", `/api/documents/${docId}`);\n    const content = (res.body as Record<string, unknown>).content as string;\n    expect(content).toBe(\"0123456789\");\n    expect(content.length).toBe(10);\n\n    // Verify version history\n    const versionsRes = await api(\"GET\", `/api/documents/${docId}/versions`);\n    expect((versionsRes.body as unknown[]).length).toBe(11); // initial + 10 edits\n\n    for (const client of clients) {\n      client.close(