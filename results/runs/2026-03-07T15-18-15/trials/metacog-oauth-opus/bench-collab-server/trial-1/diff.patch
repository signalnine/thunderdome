oid complexity\n   327→    let currentVersion = 1;\n   328→    for (let i = 0; i < clientCount; i++) {\n   329→      const ws = clients[i];\n   330→\n   331→      // Each client inserts its index at the end of the current document\n   332→      const docRes = await api(\"GET\", `/api/documents/${docId}`);\n   333→      const currentDoc = (docRes.body as Record<string, unknown>).content as string;\n   334→      sendOp(ws, [\n   335→        ...(currentDoc.length > 0 ? [{ type: \"retain\" as const, count: currentDoc.length }] : []),\n   336→        { type: \"insert\" as const, text: String(i) },\n   337→      ], currentVersion);\n   338→\n   339→      const ack = await waitForMessage(ws);\n   340→      expect(ack.type).toBe(\"ack\");\n   341→      currentVersion = ack.version as number;\n   342→\n   343→      // Drain broadcast messages from other clients\n   344→      for (let j = 0; j < clientCount; j++) {\n   345→        if (j !== i) {\n   346→          await waitForMessage(clients[j]);\n   347→        }\n   348→      }\n   349→    }\n   350→\n   351→    // Verify final state\n   352→    const res = await api(\"GET\", `/api/documents/${docId}`);\n   353→    const content = (res.body as Record<string, unknown>).content as string;\n   354→    expect(content).toBe(\"0123456789\");\n   355→    expect(content.length).toBe(10);\n   356→\n   357→    // Verify version history\n   358→    const versionsRes = await api(\"GET\", `/api/documents/${docId}/versions`);\n   359→    expect((versionsRes.body as unknown[]).length).toBe(11); // initial + 10 edits\n   360→\n   361→    for (const ws of clients) {\n   362→      ws.close();\n   363→    }\n   364→  });\n   365→\n   366→  it(\"should persist data across server restarts\", async () => {\n   367→    // Use a file-based database for persistence test\n   368→    const tmpDbPath = `/tmp/test-collab-${Date.now()}.db`;\n   369→    const app1 = createApp(tmpDbPath);\n   370→    const port1 = await app1.start(0);\n   371→\n   372→   