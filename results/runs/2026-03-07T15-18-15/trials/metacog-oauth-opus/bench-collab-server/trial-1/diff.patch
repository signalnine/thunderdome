st ack1 = await client1.nextMessage();\n   285→    expect(ack1.type).toBe(\"ack\");\n   286→    expect(ack1.version).toBe(2);\n   287→\n   288→    // client2 receives client1's broadcast\n   289→    const broadcast1 = await client2.nextMessage();\n   290→    expect(broadcast1.type).toBe(\"operation\");\n   291→\n   292→    // Now client2 sends its op (still based on version 1, server will transform it)\n   293→    client2.sendOp([\n   294→      { type: \"retain\", count: 3 },\n   295→      { type: \"insert\", text: \"Y\" },\n   296→    ], 1);\n   297→\n   298→    const ack2 = await client2.nextMessage();\n   299→    expect(ack2.type).toBe(\"ack\");\n   300→    expect(ack2.version).toBe(3);\n   301→\n   302→    // client1 receives client2's transformed broadcast\n   303→    const broadcast2 = await client1.nextMessage();\n   304→    expect(broadcast2.type).toBe(\"operation\");\n   305→\n   306→    // Verify final document state via REST\n   307→    const res = await api(\"GET\", `/api/documents/${docId}`);\n   308→\n   309→    // Both X and Y should be preserved\n   310→    const content = (res.body as Record<string, unknown>).content as string;\n   311→    expect(content).toContain(\"X\");\n   312→    expect(content).toContain(\"Y\");\n   313→    expect(content).toContain(\"abc\");\n   314→    expect(content).toBe(\"XabcY\");\n   315→\n   316→    client1.close();\n   317→    client2.close();\n   318→  });\n   319→\n   320→  it(\"should handle invalid operation gracefully\", async () => {\n   321→    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"Hello\" });\n   322→    const id = (createRes.body as Record<string, unknown>).id as string;\n   323→\n   324→    const client = connectWs(id);\n   325→    const syncMsg = await client.nextMessage();\n   326→    expect(syncMsg.type).toBe(\"sync\");\n   327→\n   328→    // Send invalid JSON\n   329→    client.ws.send(\"not json\");\n   330→    const errMsg1 = await client.nextMessage();\n   331→    expect(errMsg1.type).toBe(\"error\");\n   332→\n   333→    // Send invalid operation (wrong length)\n   334→    client.sendOp([{ type: \"retain\", count: 100 }], 1);\n   335→    const errMsg2 = await client.nextMessage();\n   336→    expect(errMsg2.type).toBe(\"error\");\n   337→\n   338→    client.close();\n   339→  });\n   340→\n   341→  it(\"should handle 10 concurrent clients\", async () => {\n   342→    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"\" });\n   343→    const docId = (createRes.body as Record<string, unknown>).id as string;\n   344→    const clientCount = 10;\n   345→    const clients: WsClient[] = [];\n   346→\n   347→    // Connect all clients\n   348→    for (let i = 0; i < clientCount; i++) {\n   349→      const client = connectWs(docId);\n   350→      const sync = await client.nextMessage();\n   351→      expect(sync.type).toBe(\"sync\");\n   352→      clients.push(client);\n   353→    }\n   354→\n   355→    // Each client inserts a character, sequentially to avoid complexity\n   356→    let currentVersion = 1;\n   357→    for (let i = 0; i < clientCount; i++) {\n   358→      const client = clients[i];\n   359→\n   360→      // Each client inserts its index at the end of the current document\n   361→      const docRes = await api(\"GET\", `/api/documents/${docId}`);\n   362→      const currentDoc = (docRes.body as Record<string, unknown>).content as string;\n   363→      client.sendOp([\n   364→        ...(currentDoc.length > 0 ? [{ type: \"retain\" as const, count: currentDoc.length }] : []),\n   365→        { type: \"insert\" as const, text: String(i) },\n   366→      ], currentVersion);\n   367→\n   368→      const ack = await client.nextMessage();\n   369→      expect(ack.type).toBe(\"ack\");\n   370→      currentVersion = ack.version as number;\n   371→\n   372→      // Drain broadcast messages from other clients\n   373→      for (let j = 0; j < clientCount; j++) {\n   374→        if (j !== i) {\n   375→          await clients[j].nextMessage();\n   376→        }\n   377→      }\n   378→    }\n   379→\n   380→    // Verify final state\n   381→    const res = await api(\"GET\", `/api/documents/${docId}`);\n   382→    const content = (res.body as Record<string, unknown>).content as string;\n   383→    expect(content).toBe(\"0123456789\");\n   384→    expect(content.length).toBe(10);\n   385→\n   386→    // Verify version history\n   387→    const versionsRes = await api(\"GET\", `/api/documents/${docId}/versions`);\n   388→    expect((versionsRes.body as unknown[]).length).toBe(11); // initial + 10 edits\n   389→\n   390→    for (const client of clients) {\n   391→      client.close();\n   392→    }\n   393→  });\n   394→\n   395→  it(\"should persist data across server restarts\", async () => {\n   396→    // Use a file-based database for persistence test\n   397→    const tmpDbPath = `/tmp/test-collab-${Date.now()}.db`;\n   398→    const app1 = createApp(tmpDbPath);\n   399→    const port1 = await app1.start(0);\n   400→\n   401→    // Create a document\n   402→    const createRes = await fetch(`http://localhost:${port1}/api/documents`, {\n   403→      method: \"POST\",\n   404→      headers: { \"Content-Type\": \"application/json\" },\n   405→      body: JSON.stringify({ title: \"Persistent Doc\", content: \"Survives restart\" }),\n   406→    });\n   407→    const createBody = await createRes.json() as Record<string, unknown>;\n   408→    const docId = createBody.id as string;\n   409→\n   410→    // Modify via WebSocket\n   411→    const client = new WsClient(`ws://localhost:${port1}/ws/documents/${docId}`);\n   412→\n   413→    const syncMsg = await client.nextMessage();\n   414→    expect(syncMsg.type).toBe(\"sync\");\n   415→\n   416→    client.sendOp([\n   417→      { type: \"retain\", count: 16 },\n   418→      { type: \"insert\", text: \"!\" },\n   419→    ], 1);\n   420→\n   421→    const ack = await client.nextMessage();\n   422→    expect(ack.type).toBe(\"ack\");\n   423→\n   424→    client.close();\n   425→    await app1.stop();\n   426→\n   427→    // Restart with same database\n   428→    const app2 = createApp(tmpDbPath);\n   429→    const port2 = await app2.start(0);\n   430→\n   431→    const getRes = await fetch(`http://localhost:${port2}/api/documents/${docId}`);\n   432→    const getBody = await getRes.json() as Record<string, unknown>;\n   433→\n   434→    expect(getBody.title).toBe(\"Persistent Doc\");\n   435→    expect(getBody.content).toBe(\"Survives restart!\");\n   436→\n   437→    // Check version history survived\n   438→    const versionsRes = await fetch(`http://localhost:${port2}/api/documents/${docId}/versions`);\n   439→    const versionsBody = await versionsRes.json() as unknown[];\n   440→    expect(versionsBody.length).toBe(2);\n   441→\n   442→    await app2.stop();\n   443→  });\n   444→});\n   445→"}]},"parent_tool_use_id":null,"session_id":"889fa0f9-7abc-4e52-9e88-0ef573ab4c1d","uuid":"0f0e1e6c-a286-4d46-9dd9-3cc699603e43","tool_use_result":{"type":"update","filePath":"/workspace/src/server.test.ts","content":"import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\nimport WebSocket from \"ws\";\nimport { createApp, AppInstance } from \"./server.js\";\nimport { OpComponent } from \"./ot.js\";\n\nlet app: AppInstance;\nlet port: number;\nlet baseUrl: string;\n\nbeforeEach(async () => {\n  app = createApp(); // in-memory DB\n  port = await app.start(0);\n  baseUrl = `http://localhost:${port}`;\n});\n\nafterEach(async () => {\n  await app.stop();\n});\n\nasync function api(method: string, path: string, body?: unknown): Promise<{ status: number; body: Record<string, unknown> | Record<string, unknown>[] }> {\n  const options: RequestInit = {\n    method,\n    headers: { \"Content-Type\": \"application/json\" },\n  };\n  if (body !== undefined) {\n    options.body = JSON.stringify(body);\n  }\n  const res = await fetch(`${baseUrl}${path}`, options);\n  let responseBody;\n  const text = await res.text();\n  try {\n    responseBody = text ? JSON.parse(text) : {};\n  } catch {\n    responseBody = {};\n  }\n  return { status: res.status, body: responseBody };\n}\n\n/** Wrapper that buffers incoming messages so none are missed. */\nclass WsClient {\n  ws: WebSocket;\n  private messageQueue: Record<string, unknown>[] = [];\n  private waiters: ((msg: Record<string, unknown>) => void)[] = [];\n  private openPromise: Promise<void>;\n\n  constructor(url: string) {\n    this.ws = new WebSocket(url);\n    this.openPromise = new Promise((resolve, reject) => {\n      this.ws.on(\"open\", resolve);\n      this.ws.on(\"error\", reject);\n    });\n    this.ws.on(\"message\", (data) => {\n      const msg = JSON.parse(data.toString());\n      if (this.waiters.length > 0) {\n        const waiter = this.waiters.shift()!;\n        waiter(msg);\n      } else {\n        this.messageQueue.push(msg);\n      }\n    });\n  }\n\n  async waitOpen(): Promise<void> {\n    await this.openPromise;\n  }\n\n  nextMessage(): Promise<Record<string, unknown>> {\n    if (this.messageQueue.length > 0) {\n      return Promise.resolve(this.messageQueue.shift()!);\n    }\n    return new Promise((resolve) => {\n      this.waiters.push(resolve);\n    });\n  }\n\n  send(msg: unknown): void {\n    this.ws.send(JSON.stringify(msg));\n  }\n\n  sendOp(ops: OpComponent[], version: number): void {\n    this.send({ type: \"operation\", ops, version });\n  }\n\n  close(): void {\n    this.ws.close();\n  }\n}\n\nfunction connectWs(docId: string): WsClient {\n  return new WsClient(`ws://localhost:${port}/ws/documents/${docId}`);\n}\n\ndescribe(\"REST API\", () => {\n  it(\"should create a document\", async () => {\n    const res = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"Hello\" });\n\n    expect(res.status).toBe(201);\n    expect(res.body).toHaveProperty(\"title\", \"Test Doc\");\n    expect(res.body).toHaveProperty(\"content\", \"Hello\");\n    expect(res.body).toHaveProperty(\"id\");\n  });\n\n  it(\"should reject document creation without title\", async () => {\n    const res = await api(\"POST\", \"/api/documents\", { content: \"Hello\" });\n    expect(res.status).toBe(400);\n  });\n\n  it(\"should list documents\", async () => {\n    await api(\"POST\", \"/api/documents\", { title: \"Doc 1\" });\n    await api(\"POST\", \"/api/documents\", { title: \"Doc 2\" });\n\n    const res = await api(\"GET\", \"/api/documents\");\n    expect(res.status).toBe(200);\n    expect(Array.isArray(res.body)).toBe(true);\n    expect((res.body as unknown[]).length).toBe(2);\n  });\n\n  it(\"should get a document by id\", async () => {\n    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"Hello\" });\n    const id = (createRes.body as Record<string, unknown>).id;\n\n    const res = await api(\"GET\", `/api/documents/${id}`);\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveProperty(\"title\", \"Test Doc\");\n    expect(res.body).toHaveProperty(\"content\", \"Hello\");\n  });\n\n  it(\"should return 404 for non-existent document\", async () => {\n    const res = await api(\"GET\", \"/api/documents/nonexistent\");\n    expect(res.status).toBe(404);\n  });\n\n  it(\"should update a document\", async () => {\n    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"Hello\" });\n    const id = (createRes.body as Record<string, unknown>).id;\n\n    const res = await api(\"PUT\", `/api/documents/${id}`, { title: \"Updated Title\", content: \"Updated Content\" });\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveProperty(\"title\", \"Updated Title\");\n    expect(res.body).toHaveProperty(\"content\", \"Updated Content\");\n  });\n\n  it(\"should delete a document\", async () => {\n    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\" });\n    const id = (createRes.body as Record<string, unknown>).id;\n\n    const deleteRes = await api(\"DELETE\", `/api/documents/${id}`);\n    expect(deleteRes.status).toBe(204);\n\n    const getRes = await api(\"GET\", `/api/documents/${id}`);\n    expect(getRes.status).toBe(404);\n  });\n\n  it(\"should get version history\", async () => {\n    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"Hello\" });\n    const id = (createRes.body as Record<string, unknown>).id;\n\n    const res = await api(\"GET\", `/api/documents/${id}/versions`);\n    expect(res.status).toBe(200);\n    const versions = res.body as Record<string, unknown>[];\n    expect(versions.length).toBe(1);\n    expect(versions[0].version).toBe(1);\n    expect(versions[0].content).toBe(\"Hello\");\n  });\n\n  it(\"should get a specific version\", async () => {\n    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"Hello\" });\n    const id = (createRes.body as Record<string, unknown>).id;\n\n    const res = await api(\"GET\", `/api/documents/${id}/versions/1`);\n    expect(res.status).toBe(200);\n    expect(res.body).toHaveProperty(\"version\", 1);\n    expect(res.body).toHaveProperty(\"content\", \"Hello\");\n  });\n});\n\ndescribe(\"WebSocket Collaboration\", () => {\n  it(\"should send sync message on connect\", async () => {\n    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"Hello\" });\n    const id = (createRes.body as Record<string, unknown>).id as string;\n\n    const client = connectWs(id);\n    const msg = await client.nextMessage();\n\n    expect(msg.type).toBe(\"sync\");\n    expect(msg.content).toBe(\"Hello\");\n    expect(msg.version).toBe(1);\n    expect(msg.documentId).toBe(id);\n\n    client.close();\n  });\n\n  it(\"should reject connection to non-existent document\", async () => {\n    const ws = new WebSocket(`ws://localhost:${port}/ws/documents/nonexistent`);\n    return new Promise<void>((resolve) => {\n      ws.on(\"error\", () => {\n        resolve();\n      });\n      ws.on(\"close\", () => {\n        resolve();\n      });\n    });\n  });\n\n  it(\"should apply and ack an operation\", async () => {\n    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"Hello\" });\n    const id = (createRes.body as Record<string, unknown>).id as string;\n\n    const client = connectWs(id);\n    const syncMsg = await client.nextMessage();\n    expect(syncMsg.type).toBe(\"sync\");\n\n    client.sendOp([\n      { type: \"retain\", count: 5 },\n      { type: \"insert\", text: \" World\" },\n    ], 1);\n\n    const ackMsg = await client.nextMessage();\n    expect(ackMsg.type).toBe(\"ack\");\n    expect(ackMsg.version).toBe(2);\n\n    // Verify via REST\n    const res = await api(\"GET\", `/api/documents/${id}`);\n    expect(res.body).toHaveProperty(\"content\", \"Hello World\");\n\n    client.close();\n  });\n\n  it(\"should broadcast operations to other clients\", async () => {\n    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"Hello\" });\n    const id = (createRes.body as Record<string, unknown>).id as string;\n\n    const client1 = connectWs(id);\n    const sync1 = await client1.nextMessage();\n    expect(sync1.type).toBe(\"sync\");\n\n    const client2 = connectWs(id);\n    const sync2 = await client2.nextMessage();\n    expect(sync2.type).toBe(\"sync\");\n\n    // client1 sends an operation\n    client1.sendOp([\n      { type: \"retain\", count: 5 },\n      { type: \"insert\", text: \" World\" },\n    ], 1);\n\n    // client1 gets ack\n    const ack = await client1.nextMessage();\n    expect(ack.type).toBe(\"ack\");\n\n    // client2 gets the operation broadcast\n    const broadcast = await client2.nextMessage();\n    expect(broadcast.type).toBe(\"operation\");\n    expect(broadcast.version).toBe(2);\n\n    client1.close();\n    client2.close();\n  });\n\n  it(\"should handle concurrent edits with OT\", async () => {\n    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"abc\" });\n    const docId = (createRes.body as Record<string, unknown>).id as string;\n\n    const client1 = connectWs(docId);\n    const sync1 = await client1.nextMessage();\n    expect(sync1.type).toBe(\"sync\");\n    expect(sync1.content).toBe(\"abc\");\n\n    const client2 = connectWs(docId);\n    const sync2 = await client2.nextMessage();\n    expect(sync2.type).toBe(\"sync\");\n    expect(sync2.content).toBe(\"abc\");\n\n    // Both based on version 1\n    // client1: insert \"X\" at beginning -> \"Xabc\"\n    // client2: insert \"Y\" at end -> \"abcY\"\n\n    // Send client1's op first (will be applied directly)\n    client1.sendOp([\n      { type: \"insert\", text: \"X\" },\n      { type: \"retain\", count: 3 },\n    ], 1);\n\n    const ack1 = await client1.nextMessage();\n    expect(ack1.type).toBe(\"ack\");\n    expect(ack1.version).toBe(2);\n\n    // client2 receives client1's broadcast\n    const broadcast1 = await client2.nextMessage();\n    expect(broadcast1.type).toBe(\"operation\");\n\n    // Now client2 sends its op (still based on version 1, server will transform it)\n    client2.sendOp([\n      { type: \"retain\", count: 3 },\n      { type: \"insert\", text: \"Y\" },\n    ], 1);\n\n    const ack2 = await client2.nextMessage();\n    expect(ack2.type).toBe(\"ack\");\n    expect(ack2.version).toBe(3);\n\n    // client1 receives client2's transformed broadcast\n    const broadcast2 = await client1.nextMessage();\n    expect(broadcast2.type).toBe(\"operation\");\n\n    // Verify final document state via REST\n    const res = await api(\"GET\", `/api/documents/${docId}`);\n\n    // Both X and Y should be preserved\n    const content = (res.body as Record<string, unknown>).content as string;\n    expect(content).toContain(\"X\");\n    expect(content).toContain(\"Y\");\n    expect(content).toContain(\"abc\");\n    expect(content).toBe(\"XabcY\");\n\n    client1.close();\n    client2.close();\n  });\n\n  it(\"should handle invalid operation gracefully\", async () => {\n    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"Hello\" });\n    const id = (createRes.body as Record<string, unknown>).id as string;\n\n    const client = connectWs(id);\n    const syncMsg = await client.nextMessage();\n    expect(syncMsg.type).toBe(\"sync\");\n\n    // Send invalid JSON\n    client.ws.send(\"not json\");\n    const errMsg1 = await client.nextMessage();\n    expect(errMsg1.type).toBe(\"error\");\n\n    // Send invalid operation (wrong length)\n    client.sendOp([{ type: \"retain\", count: 100 }], 1);\n    const errMsg2 = await client.nextMessage();\n    expect(errMsg2.type).toBe(\"error\");\n\n    client.close();\n  });\n\n  it(\"should handle 10 concurrent clients\", async () => {\n    const createRes = await api(\"POST\", \"/api/documents\", { title: \"Test Doc\", content: \"\" });\n    const docId = (createRes.body as Record<string, unknown>).id as string;\n    const clientCount = 10;\n    const clients: WsClient[] = [];\n\n    // Connect all clients\n    for (let i = 0; i < clientCount; i++) {\n      const client = connectWs(docId);\n      const sync = await client.nextMessage();\n      expect(sync.type).toBe(\"sync\");\n      clients.push(client);\n    }\n\n    // Each client inserts a character, sequentially to avoid complexity\n    let currentVersion = 1;\n    for (let i = 0; i < clientCount; i++) {\n      const client = clients[i];\n\n      // Each client inserts its index at the end of the current document\n      const docRes = await api(\"GET\", `/api/documents/${docId}`);\n      const currentDoc = (docRes.body as Record<string, unknown>).content as string;\n      client.sendOp([\n        ...(currentDoc.length > 0 ? [{ type: \"retain\" as const, count: currentDoc.length }] : []),\n        { type: \"insert\" as const, text: String(i) },\n      ], currentVersion);\n\n      const ack = await client.nextMessage();\n      expect(ack.type).toBe(\"ack\");\n      currentVersion = ack.version as number;\n\n      // Drain broadcast messages from other clients\n      for (let j = 0; j < clientCount; j++) {\n        if (j !== i) {\n          await clients[j].nextMessage();\n        }\n      }\n    }\n\n    // Verify final state\n    const res = await api(\"GET\", `/api/documents/${docId}`);\n    const content = (res.body as Record<string, unknown>).content as string;\n    expect(content).toBe(\"0123456789\");\n    expect(content.length).toBe(10);\n\n    // Verify version history\n    const versionsRes = await api(\"GET\", `/api/documents/${docId}/versions`);\n    expect((versionsRes.body as unknown[]).length).toBe(11); // initial + 10 edits\n\n    for (const client of clients) {\n      client.close();\n    }\n  });\n\n  it(\"should persist data across server restarts\", async () => {\n    // Use a file-based database for persistence test\n    const tmpDbPath = `/tmp/test-collab-${Date.now()}.db`;\n    const app1 = createApp(tmpDbPath);\n    const port1 = await app1.start(0);\n\n    // Create a document\n    const createRes = await fetch(`http://localhost:${port1}/api/documents`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ title: \"Persistent Doc\", content: \"Survives restart\" }),\n    });\n    const createBody = await createRes.json() as Record<string, unknown>;\n    const docId = createBody.id as string;\n\n    // Modify via WebSocket\n    const client = new WsClient(`ws://localhost:${port1}/ws/documents/${docId}`);\n\n    const syncMsg = await client.nextMessage();\n    expect(syncMsg.type).toBe(\"sync\");\n\n    client.sendOp([\n      { type: \"retain\", count: 16 },\n      { type: \"insert\", text: \"!\" },\n    ], 1);\n\n    const ack = await client.nextMessage();\n    expect(ack.type).toBe(\"ack\");\n\n    client.close();\n    await app1.stop();\n\n    // Restart with same database\n    const app2 = createApp(tmpDbPath);\n    const port2 = await app2.start(0);\n\n    const getRes = await fetch(`http://localhost:${port2}/api/documents/${docId}`);\n    const getBody = await getRes.json() as Record<string, unknown>;\n\n    expect(getBody.title).toBe(\"Persistent Doc\");\n    expect(getBody.content).toBe(\"Survives restart!\");\n\n    // Check version history survived\n    const versionsRes = await fetch(`http://localhost:${port2}/api/documents/${docId}/versions`);\n    const versionsBody = await versionsRes.json() as unknown[];\n    expect(versionsBody.length).toBe(2);\n\n    await app2.stop();\n  });\n});\n","structuredPatch":[{"oldStart":36,"oldLines":28,"newStart":36,"newLines":58,"lines":["   return { status: res.status, body: responseBody };"," }"," ","-function wsUrl(docId: string): string {","-  return `ws://localhost:${port}/ws/documents/${docId}`;","-}","+/** Wrapper that buffers incoming messages so none are missed. */","+class WsClient {","+  ws: WebSocket;","+  private messageQueue: Record<string, unknown>[] = [];","+  private waiters: ((msg: Record<string, unknown>) => void)[] = [];","+  private openPromise: Promise<void>;"," ","-function connectWs(docId: string): Promise<WebSocket> {","-  return new Promise((resolve, reject) => {","-    const ws = new WebSocket(wsUrl(docId));","-    ws.on(\"open\", () => resolve(ws));","-    ws.on(\"error\", reject);","-  });","-}","+  constructor(url: string) {","+    this.ws = new WebSocket(url);","+    this.openPromise = new Promise((resolve, reject) => {","+      this.ws.on(\"open\", resolve);","+      this.ws.on(\"error\", reject);","+    });","+    this.ws.on(\"message\", (data) => {","+      const msg = JSON.parse(data.toString());","+      if (this.waiters.length > 0) {","+        const waiter = this.waiters.shift()!;","+        waiter(msg);","+      } else {","+        this.messageQueue.push(msg);","+      }","+    });","+  }"," ","-function wa