;\n    });\n  });\n\n  describe(\"inputLength / outputLength\", () => {\n    it(\"should calculate input length\", () => {\n      const ops: OpComponent[] = [\n        { type: \"retain\", count: 3 },\n        { type: \"insert\", text: \"abc\" },\n        { type: \"delete\", count: 2 },\n      ];\n      expect(inputLength(ops)).toBe(5); // retain 3 + delete 2\n    });\n\n    it(\"should calculate output length\", () => {\n      const ops: OpComponent[] = [\n        { type: \"retain\", count: 3 },\n        { type: \"insert\", text: \"abc\" },\n        { type: \"delete\", count: 2 },\n      ];\n      expect(outputLength(ops)).toBe(6); // retain 3 + insert 3\n    });\n  });\n\n  describe(\"transform\", () => {\n    it(\"should transform two inserts at different positions\", () => {\n      // doc: \"abc\" (len 3)\n      // a: insert \"X\" at pos 1: retain(1), insert(\"X\"), retain(2)\n      // b: insert \"Y\" at pos 2: retain(2), insert(\"Y\"), retain(1)\n      const a: OpComponent[] = [\n        { type: \"retain\", count: 1 },\n        { type: \"insert\", text: \"X\" },\n        { type: \"retain\", count: 2 },\n      ];\n      const b: OpComponent[] = [\n        { type: \"retain\", count: 2 },\n        { type: \"insert\", text: \"Y\" },\n        { type: \"retain\", count: 1 },\n      ];\n\n      const [aPrime, bPrime] = transform(a, b);\n\n      // After a: \"aXbc\" (len 4)\n      // bPrime should insert Y at correct position in \"aXbc\"\n      const afterA = apply(\"abc\", a);\n      expect(afterA).toBe(\"aXbc\");\n      const afterAB = apply(afterA, bPrime);\n\n      // After b: \"abYc\" (len 4)\n      // aPrime should insert X at correct position in \"abYc\"\n      const afterB = apply(\"abc\", b);\n      expect(afterB).toBe(\"abYc\");\n      const afterBA = apply(afterB, aPrime);\n\n      // Both should converge\n      expect(afterAB).toBe(afterBA);\n      expect(afterAB).toBe(\"aXbYc\");\n    });\n\n    it(\"should transform two inserts at the same position (a wins)\", () => {\n      // doc: \"abc\" (len 3)\n      // Both insert at position 1\n      const a: OpComponent[] = [\n        { type: \"retain\", count: 1 },\n        { type: \"insert\", text: \"X\" },\n        { type: \"retain\", count: 2 },\n      ];\n      const b: OpComponent[] = [\n        { type: \"retain\", count: 1 },\n        { type: \"insert\", text: \"Y\" },\n        { type: \"retain\", count: 2 },\n      ];\n\n      const [aPrime, bPrime] = transform(a, b);\n\n      const afterA = apply(\"abc\", a);\n      const afterAB = apply(afterA, bPrime);\n\n      const afterB = apply(\"abc\", b);\n      const afterBA = apply(afterB, aPrime);\n\n      expect(afterAB).toBe(afterBA);\n      // a has priority, so X comes before Y\n      expect(afterAB).toBe(\"aXYbc\");\n    });\n\n    it(\"should transform insert and delete\", () => {\n      // doc: \"abcde\" (len 5)\n      // a: insert \"X\" at pos 2\n      // b: delete chars at pos 1-3 (delete \"bc\")\n      const a: OpComponent[] = [\n        { type: \"retain\", count: 2 },\n        { type: \"insert\", text: \"X\" },\n        { type: \"retain\", count: 3 },\n      ];\n      const b: OpComponent[] = [\n        { type: \"retain\", count: 1 },\n        { type: \"delete\", count: 2 },\n        { type: \"retain\", count: 2 },\n      ];\n\n      const [aPrime, bPrime] = transform(a, b);\n\n      const afterA = apply(\"abcde\", a);\n      const afterAB = apply(afterA, bPrime);\n\n      const afterB = apply(\"abcde\", b);\n      const afterBA = apply(afterB, aPrime);\n\n      expect(afterAB).toBe(afterBA);\n    });\n\n    it(\"should transform two deletes on overlapping ranges\", () => {\n      // doc: \"abcde\" (len 5)\n      // a: delete \"bc\" (pos 1-2)\n      // b: delete \"cd\" (pos 2-3)\n      const a: OpComponent[] = [\n        { type: \"retain\", count: 1 },\n        { type: \"delete\", count: 2 },\n        { type: \"retain\", count: 2 },\n      ];\n      const b: OpComponent[] = [\n        { type: \"retain\", count: 2 },\n        { type: \"delete\", count: 2 },\n        { type: \"retain\", count: 1 },\n      ];\n\n      const [aPrime, bPrime] = transform(a, b);\n\n      const afterA = apply(\"abcde\", a);\n      const afterAB = apply(afterA, bPrime);\n\n      const afterB = apply(\"abcde\", b);\n      const afterBA = apply(afterB, aPrime);\n\n      expect(afterAB).toBe(afterBA);\n      expect(afterAB).toBe(\"ae\");\n    });\n  });\n\n  describe(\"compose\", () => {\n    it(\"should compose two sequential operations\", () => {\n      // doc: \"hello\"\n      // op1: insert \" world\" at end\n      // op2: insert \"!\" at end of \"hello world\"\n      const op1: OpComponent[] = [\n        { type: \"retain\", count: 5 },\n        { type: \"insert\", text: \" world\" },\n      ];\n      const op2: OpComponent[] = [\n        { type: \"retain\", count: 11 },\n        { type: \"insert\", text: \"!\" },\n      ];\n\n      const composed = compose(op1, op2);\n      const result = apply(\"hello\", composed);\n      expect(result).toBe(\"hello world!\");\n\n      // Should match sequential application\n      const step1 = apply(\"hello\", op1);\n      const step2 = apply(step1, op2);\n      expect(result).toBe(step2);\n    });\n  });\n\n  describe(\"validate\", () => {\n    it(\"should return null for valid operations\", () => {\n      const ops: OpComponent[] = [\n        { type: \"retain\", count: 3 },\n        { type: \"insert\", text: \"hello\" },\n        { type: \"delete\", count: 2 },\n      ];\n      expect(validate(ops, 5)).toBeNull();\n    });\n\n    it(\"should reject mismatched input length\", () => {\n      const ops: OpComponent[] = [{ type: \"retain\", count: 10 }];\n      expect(validate(ops, 5)).toContain(\"does not match\");\n    });\n\n    it(\"should reject invalid retain count\", () => {\n      const ops: OpComponent[] = [{ type: \"retain\", count: -1 }];\n      expect(validate(ops, 5)).toContain(\"positive integer\");\n    });\n\n    it(\"should reject empty insert text\", () => {\n      const ops: OpComponent[] = [\n        { type: \"insert\", text: \"\" },\n        { type: \"retain\", count: 5 },\n      ];\n      expect(validate(ops, 5)).toContain(\"non-empty string\");\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null}}
+{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01QymCVGmb38R2GcLfJkxtkM","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RutyL1Q8wDekxa3tQ2Y2Wg","name":"Write","input":{"file_path":"/workspace/src/server.test.ts","content":"import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\nimport request from \"supertest\";\nimport WebSocket from \"ws\";\nimport { createApp, AppInstance } from \"./server.js\";\nimport { OpComponent } from \"./ot.js\";\n\nlet app: AppInstance;\nlet port: number;\n\nbeforeEach(async () => {\n  app = createApp(); // in-memory DB\n  port = await app.start(0);\n});\n\nafterEach(async () => {\n  await app.stop();\n});\n\nfunction wsUrl(docId: string): string {\n  return `ws://localhost:${port}/ws/documents/${docId}`;\n}\n\nfunction connectWs(docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(wsUrl(docId));\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve) => {\n    ws.once(\"message\", (data) => {\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\nfunction sendOp(ws: WebSocket, ops: OpComponent[], version: number): void {\n  ws.send(JSON.stringify({ type: \"operation\", ops, version }));\n}\n\ndescribe(\"REST API\", () => {\n  it(\"should create a document\", async () => {\n    const res = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    expect(res.body.title).toBe(\"Test Doc\");\n    expect(res.body.content).toBe(\"Hello\");\n    expect(res.body.id).toBeDefined();\n  });\n\n  it(\"should reject document creation without title\", async () => {\n    await request(app.app)\n      .post(\"/api/documents\")\n      .send({ content: \"Hello\" })\n      .expect(400);\n  });\n\n  it(\"should list documents\", async () => {\n    await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Doc 1\" })\n      .expect(201);\n    await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Doc 2\" })\n      .expect(201);\n\n    const res = await request(app.app).get(\"/api/documents\").expect(200);\n    expect(res.body.length).toBe(2);\n  });\n\n  it(\"should get a document by id\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const res = await request(app.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(200);\n\n    expect(res.body.title).toBe(\"Test Doc\");\n    expect(res.body.content).toBe(\"Hello\");\n  });\n\n  it(\"should return 404 for non-existent document\", async () => {\n    await request(app.app)\n      .get(\"/api/documents/nonexistent\")\n      .expect(404);\n  });\n\n  it(\"should update a document\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const res = await request(app.app)\n      .put(`/api/documents/${createRes.body.id}`)\n      .send({ title: \"Updated Title\", content: \"Updated Content\" })\n      .expect(200);\n\n    expect(res.body.title).toBe(\"Updated Title\");\n    expect(res.body.content).toBe(\"Updated Content\");\n  });\n\n  it(\"should delete a document\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\" })\n      .expect(201);\n\n    await request(app.app)\n      .delete(`/api/documents/${createRes.body.id}`)\n      .expect(204);\n\n    await request(app.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(404);\n  });\n\n  it(\"should get version history\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const res = await request(app.app)\n      .get(`/api/documents/${createRes.body.id}/versions`)\n      .expect(200);\n\n    expect(res.body.length).toBe(1);\n    expect(res.body[0].version).toBe(1);\n    expect(res.body[0].content).toBe(\"Hello\");\n  });\n\n  it(\"should get a specific version\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const res = await request(app.app)\n      .get(`/api/documents/${createRes.body.id}/versions/1`)\n      .expect(200);\n\n    expect(res.body.version).toBe(1);\n    expect(res.body.content).toBe(\"Hello\");\n  });\n});\n\ndescribe(\"WebSocket Collaboration\", () => {\n  it(\"should send sync message on connect\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const ws = await connectWs(createRes.body.id);\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe(\"sync\");\n    expect(msg.content).toBe(\"Hello\");\n    expect(msg.version).toBe(1);\n    expect(msg.documentId).toBe(createRes.body.id);\n\n    ws.close();\n  });\n\n  it(\"should reject connection to non-existent document\", async () => {\n    const ws = new WebSocket(wsUrl(\"nonexistent\"));\n    return new Promise<void>((resolve) => {\n      ws.on(\"error\", () => {\n        resolve();\n      });\n      ws.on(\"close\", () => {\n        resolve();\n      });\n    });\n  });\n\n  it(\"should apply and ack an operation\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const ws = await connectWs(createRes.body.id);\n    const syncMsg = await waitForMessage(ws);\n    expect(syncMsg.type).toBe(\"sync\");\n\n    // Insert \" World\" at the end\n    sendOp(ws, [\n      { type: \"retain\", count: 5 },\n      { type: \"insert\", text: \" World\" },\n    ], 1);\n\n    const ackMsg = await waitForMessage(ws);\n    expect(ackMsg.type).toBe(\"ack\");\n    expect(ackMsg.version).toBe(2);\n\n    // Verify via REST\n    const res = await request(app.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"Hello World\");\n\n    ws.close();\n  });\n\n  it(\"should broadcast operations to other clients\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const ws1 = await connectWs(createRes.body.id);\n    const sync1 = await waitForMessage(ws1);\n    expect(sync1.type).toBe(\"sync\");\n\n    const ws2 = await connectWs(createRes.body.id);\n    const sync2 = await waitForMessage(ws2);\n    expect(sync2.type).toBe(\"sync\");\n\n    // ws1 sends an operation\n    const opMsg = waitForMessage(ws2);\n    sendOp(ws1, [\n      { type: \"retain\", count: 5 },\n      { type: \"insert\", text: \" World\" },\n    ], 1);\n\n    // ws1 gets ack\n    const ack = await waitForMessage(ws1);\n    expect(ack.type).toBe(\"ack\");\n\n    // ws2 gets the operation broadcast\n    const broadcast = await opMsg;\n    expect(broadcast.type).toBe(\"operation\");\n    expect(broadcast.version).toBe(2);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle concurrent edits with OT\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"abc\" })\n      .expect(201);\n\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(docId);\n    const sync1 = await waitForMessage(ws1);\n    expect(sync1.type).toBe(\"sync\");\n    expect(sync1.content).toBe(\"abc\");\n\n    const ws2 = await connectWs(docId);\n    const sync2 = await waitForMessage(ws2);\n    expect(sync2.type).toBe(\"sync\");\n    expect(sync2.content).toBe(\"abc\");\n\n    // Both based on version 1\n    // ws1: insert \"X\" at beginning -> \"Xabc\"\n    // ws2: insert \"Y\" at end -> \"abcY\"\n\n    // Send ws1's op first (will be applied directly)\n    sendOp(ws1, [\n      { type: \"insert\", text: \"X\" },\n      { type: \"retain\", count: 3 },\n    ], 1);\n\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe(\"ack\");\n    expect(ack1.version).toBe(2);\n\n    // ws2 receives ws1's broadcast\n    const broadcast1 = await waitForMessage(ws2);\n    expect(broadcast1.type).toBe(\"operation\");\n\n    // Now ws2 sends its op (still based on version 1, server will transform it)\n    sendOp(ws2, [\n      { type: \"retain\", count: 3 },\n      { type: \"insert\", text: \"Y\" },\n    ], 1);\n\n    const ack2 = await waitForMessage(ws2);\n    expect(ack2.type).toBe(\"ack\");\n    expect(ack2.version).toBe(3);\n\n    // ws1 receives ws2's transformed broadcast\n    const broadcast2 = await waitForMessage(ws1);\n    expect(broadcast2.type).toBe(\"operation\");\n\n    // Verify final document state via REST\n    const res = await request(app.app)\n      .get(`/api/documents/${docId}`)\n      .expect(200);\n\n    // Both X and Y should be preserved\n    expect(res.body.content).toContain(\"X\");\n    expect(res.body.content).toContain(\"Y\");\n    expect(res.body.content).toContain(\"abc\");\n    expect(res.body.content).toBe(\"XabcY\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle invalid operation gracefully\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const ws = await connectWs(createRes.body.id);\n    const syncMsg = await waitForMessage(ws);\n    expect(syncMsg.type).toBe(\"sync\");\n\n    // Send invalid JSON\n    ws.send(\"not json\");\n    const errMsg1 = await waitForMessage(ws);\n    expect(errMsg1.type).toBe(\"error\");\n\n    // Send invalid operation (wrong length)\n    sendOp(ws, [{ type: \"retain\", count: 100 }], 1);\n    const errMsg2 = await waitForMessage(ws);\n    expect(errMsg2.type).toBe(\"error\");\n\n    ws.close();\n  });\n\n  it(\"should handle 10 concurrent clients\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"\" })\n      .expect(201);\n\n    const docId = createRes.body.id;\n    const clientCount = 10;\n    const clients: WebSocket[] = [];\n\n    // Connect all clients\n    for (let i = 0; i < clientCount; i++) {\n      const ws = await connectWs(docId);\n      const sync = await waitForMessage(ws);\n      expect(sync.type).toBe(\"sync\");\n      clients.push(ws);\n    }\n\n    // Each client inserts a character, sequentially to avoid complexity\n    let currentVersion = 1;\n    for (let i = 0; i < clientCount; i++) {\n      const ws = clients[i];\n\n      // Each client inserts its index at the end of the current document\n      const currentDoc = (await request(app.app).get(`/api/documents/${docId}`)).body.content;\n      sendOp(ws, [\n        ...(currentDoc.length > 0 ? [{ type: \"retain\" as const, count: currentDoc.length }] : []),\n        { type: \"insert\" as const, text: String(i) },\n      ], currentVersion);\n\n      const ack = await waitForMessage(ws);\n      expect(ack.type).toBe(\"ack\");\n      currentVersion = ack.version as number;\n\n      // Drain broadcast messages from other clients\n      for (let j = 0; j < clientCount; j++) {\n        if (j !== i) {\n          await waitForMessage(clients[j]);\n        }\n      }\n    }\n\n    // Verify final state\n    const res = await request(app.app).get(`/api/documents/${docId}`).expect(200);\n    expect(res.body.content).toBe(\"0123456789\");\n    expect(res.body.content.length).toBe(10);\n\n    // Verify version history\n    const versionsRes = await request(app.app)\n      .get(`/api/documents/${docId}/versions`)\n      .expect(200);\n    expect(versionsRes.body.length).toBe(11); // initial + 10 edits\n\n    for (const ws of clients) {\n      ws.close();\n    }\n  });\n\n  it(\"should persist data across server restarts\", async () => {\n    // Use a file-based database for persistence test\n    const tmpDbPath = `/tmp/test-collab-${Date.now()}.db`;\n    const app1 = createApp(tmpDbPath);\n    const port1 = await app1.start(0);\n\n    // Create a document\n    const createRes = await request(app1.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Persistent Doc\", content: \"Survives restart\" })\n      .expect(201);\n\n    const docId = createRes.body.id;\n\n    // Modify via WebSocket\n    const ws = await new Promise<WebSocket>((resolve, reject) => {\n      const w = new WebSocket(`ws://localhost:${port1}/ws/documents/${docId}`);\n      w.on(\"open\", () => resolve(w));\n      w.on(\"error\", reject);\n    });\n\n    const syncMsg = await waitForMessage(ws);\n    expect(syncMsg.type).toBe(\"sync\");\n\n    sendOp(ws, [\n      { type: \"retain\", count: 16 },\n      { type: \"insert\", text: \"!\" },\n    ], 1);\n\n    const ack = await waitForMessage(ws);\n    expect(ack.type).toBe(\"ack\");\n\n    ws.close();\n    await app1.stop();\n\n    // Restart with same database\n    const app2 = createApp(tmpDbPath);\n    await app2.start(0);\n\n    const res = await request(app2.app)\n      .get(`/api/documents/${docId}`)\n      .expect(200);\n\n    expect(res.body.title).toBe(\"Persistent Doc\");\n    expect(res.body.content).toBe(\"Survives restart!\");\n\n    // Check version history survived\n    const versionsRes = await request(app2.app)\n      .get(`/api/documents/${docId}/versions`)\n      .expect(200);\n    expect(versionsRes.body.length).toBe(2);\n\n    await app2.stop();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2540,"cache_read_input_tokens":33742,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2540},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"889fa0f9-7abc-4e52-9e88-0ef573ab4c1d","uuid":"d7c1d29d-c789-47b8-9a58-b2e3a4724f72"}
+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RutyL1Q8wDekxa3tQ2Y2Wg","type":"tool_result","content":"File created successfully at: /workspace/src/server.test.ts"}]},"parent_tool_use_id":null,"session_id":"889fa0f9-7abc-4e52-9e88-0ef573ab4c1d","uuid":"6d16fe4e-904d-4eb0-8686-df12fa3ab35e","tool_use_result":{"type":"create","filePath":"/workspace/src/server.test.ts","content":"import { describe, it, expect, beforeEach, afterEach } from \"vitest\";\nimport request from \"supertest\";\nimport WebSocket from \"ws\";\nimport { createApp, AppInstance } from \"./server.js\";\nimport { OpComponent } from \"./ot.js\";\n\nlet app: AppInstance;\nlet port: number;\n\nbeforeEach(async () => {\n  app = createApp(); // in-memory DB\n  port = await app.start(0);\n});\n\nafterEach(async () => {\n  await app.stop();\n});\n\nfunction wsUrl(docId: string): string {\n  return `ws://localhost:${port}/ws/documents/${docId}`;\n}\n\nfunction connectWs(docId: string): Promise<WebSocket> {\n  return new Promise((resolve, reject) => {\n    const ws = new WebSocket(wsUrl(docId));\n    ws.on(\"open\", () => resolve(ws));\n    ws.on(\"error\", reject);\n  });\n}\n\nfunction waitForMessage(ws: WebSocket): Promise<Record<string, unknown>> {\n  return new Promise((resolve) => {\n    ws.once(\"message\", (data) => {\n      resolve(JSON.parse(data.toString()));\n    });\n  });\n}\n\nfunction sendOp(ws: WebSocket, ops: OpComponent[], version: number): void {\n  ws.send(JSON.stringify({ type: \"operation\", ops, version }));\n}\n\ndescribe(\"REST API\", () => {\n  it(\"should create a document\", async () => {\n    const res = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    expect(res.body.title).toBe(\"Test Doc\");\n    expect(res.body.content).toBe(\"Hello\");\n    expect(res.body.id).toBeDefined();\n  });\n\n  it(\"should reject document creation without title\", async () => {\n    await request(app.app)\n      .post(\"/api/documents\")\n      .send({ content: \"Hello\" })\n      .expect(400);\n  });\n\n  it(\"should list documents\", async () => {\n    await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Doc 1\" })\n      .expect(201);\n    await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Doc 2\" })\n      .expect(201);\n\n    const res = await request(app.app).get(\"/api/documents\").expect(200);\n    expect(res.body.length).toBe(2);\n  });\n\n  it(\"should get a document by id\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const res = await request(app.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(200);\n\n    expect(res.body.title).toBe(\"Test Doc\");\n    expect(res.body.content).toBe(\"Hello\");\n  });\n\n  it(\"should return 404 for non-existent document\", async () => {\n    await request(app.app)\n      .get(\"/api/documents/nonexistent\")\n      .expect(404);\n  });\n\n  it(\"should update a document\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const res = await request(app.app)\n      .put(`/api/documents/${createRes.body.id}`)\n      .send({ title: \"Updated Title\", content: \"Updated Content\" })\n      .expect(200);\n\n    expect(res.body.title).toBe(\"Updated Title\");\n    expect(res.body.content).toBe(\"Updated Content\");\n  });\n\n  it(\"should delete a document\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\" })\n      .expect(201);\n\n    await request(app.app)\n      .delete(`/api/documents/${createRes.body.id}`)\n      .expect(204);\n\n    await request(app.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(404);\n  });\n\n  it(\"should get version history\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const res = await request(app.app)\n      .get(`/api/documents/${createRes.body.id}/versions`)\n      .expect(200);\n\n    expect(res.body.length).toBe(1);\n    expect(res.body[0].version).toBe(1);\n    expect(res.body[0].content).toBe(\"Hello\");\n  });\n\n  it(\"should get a specific version\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const res = await request(app.app)\n      .get(`/api/documents/${createRes.body.id}/versions/1`)\n      .expect(200);\n\n    expect(res.body.version).toBe(1);\n    expect(res.body.content).toBe(\"Hello\");\n  });\n});\n\ndescribe(\"WebSocket Collaboration\", () => {\n  it(\"should send sync message on connect\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const ws = await connectWs(createRes.body.id);\n    const msg = await waitForMessage(ws);\n\n    expect(msg.type).toBe(\"sync\");\n    expect(msg.content).toBe(\"Hello\");\n    expect(msg.version).toBe(1);\n    expect(msg.documentId).toBe(createRes.body.id);\n\n    ws.close();\n  });\n\n  it(\"should reject connection to non-existent document\", async () => {\n    const ws = new WebSocket(wsUrl(\"nonexistent\"));\n    return new Promise<void>((resolve) => {\n      ws.on(\"error\", () => {\n        resolve();\n      });\n      ws.on(\"close\", () => {\n        resolve();\n      });\n    });\n  });\n\n  it(\"should apply and ack an operation\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const ws = await connectWs(createRes.body.id);\n    const syncMsg = await waitForMessage(ws);\n    expect(syncMsg.type).toBe(\"sync\");\n\n    // Insert \" World\" at the end\n    sendOp(ws, [\n      { type: \"retain\", count: 5 },\n      { type: \"insert\", text: \" World\" },\n    ], 1);\n\n    const ackMsg = await waitForMessage(ws);\n    expect(ackMsg.type).toBe(\"ack\");\n    expect(ackMsg.version).toBe(2);\n\n    // Verify via REST\n    const res = await request(app.app)\n      .get(`/api/documents/${createRes.body.id}`)\n      .expect(200);\n    expect(res.body.content).toBe(\"Hello World\");\n\n    ws.close();\n  });\n\n  it(\"should broadcast operations to other clients\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const ws1 = await connectWs(createRes.body.id);\n    const sync1 = await waitForMessage(ws1);\n    expect(sync1.type).toBe(\"sync\");\n\n    const ws2 = await connectWs(createRes.body.id);\n    const sync2 = await waitForMessage(ws2);\n    expect(sync2.type).toBe(\"sync\");\n\n    // ws1 sends an operation\n    const opMsg = waitForMessage(ws2);\n    sendOp(ws1, [\n      { type: \"retain\", count: 5 },\n      { type: \"insert\", text: \" World\" },\n    ], 1);\n\n    // ws1 gets ack\n    const ack = await waitForMessage(ws1);\n    expect(ack.type).toBe(\"ack\");\n\n    // ws2 gets the operation broadcast\n    const broadcast = await opMsg;\n    expect(broadcast.type).toBe(\"operation\");\n    expect(broadcast.version).toBe(2);\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle concurrent edits with OT\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"abc\" })\n      .expect(201);\n\n    const docId = createRes.body.id;\n\n    const ws1 = await connectWs(docId);\n    const sync1 = await waitForMessage(ws1);\n    expect(sync1.type).toBe(\"sync\");\n    expect(sync1.content).toBe(\"abc\");\n\n    const ws2 = await connectWs(docId);\n    const sync2 = await waitForMessage(ws2);\n    expect(sync2.type).toBe(\"sync\");\n    expect(sync2.content).toBe(\"abc\");\n\n    // Both based on version 1\n    // ws1: insert \"X\" at beginning -> \"Xabc\"\n    // ws2: insert \"Y\" at end -> \"abcY\"\n\n    // Send ws1's op first (will be applied directly)\n    sendOp(ws1, [\n      { type: \"insert\", text: \"X\" },\n      { type: \"retain\", count: 3 },\n    ], 1);\n\n    const ack1 = await waitForMessage(ws1);\n    expect(ack1.type).toBe(\"ack\");\n    expect(ack1.version).toBe(2);\n\n    // ws2 receives ws1's broadcast\n    const broadcast1 = await waitForMessage(ws2);\n    expect(broadcast1.type).toBe(\"operation\");\n\n    // Now ws2 sends its op (still based on version 1, server will transform it)\n    sendOp(ws2, [\n      { type: \"retain\", count: 3 },\n      { type: \"insert\", text: \"Y\" },\n    ], 1);\n\n    const ack2 = await waitForMessage(ws2);\n    expect(ack2.type).toBe(\"ack\");\n    expect(ack2.version).toBe(3);\n\n    // ws1 receives ws2's transformed broadcast\n    const broadcast2 = await waitForMessage(ws1);\n    expect(broadcast2.type).toBe(\"operation\");\n\n    // Verify final document state via REST\n    const res = await request(app.app)\n      .get(`/api/documents/${docId}`)\n      .expect(200);\n\n    // Both X and Y should be preserved\n    expect(res.body.content).toContain(\"X\");\n    expect(res.body.content).toContain(\"Y\");\n    expect(res.body.content).toContain(\"abc\");\n    expect(res.body.content).toBe(\"XabcY\");\n\n    ws1.close();\n    ws2.close();\n  });\n\n  it(\"should handle invalid operation gracefully\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"Hello\" })\n      .expect(201);\n\n    const ws = await connectWs(createRes.body.id);\n    const syncMsg = await waitForMessage(ws);\n    expect(syncMsg.type).toBe(\"sync\");\n\n    // Send invalid JSON\n    ws.send(\"not json\");\n    const errMsg1 = await waitForMessage(ws);\n    expect(errMsg1.type).toBe(\"error\");\n\n    // Send invalid operation (wrong length)\n    sendOp(ws, [{ type: \"retain\", count: 100 }], 1);\n    const errMsg2 = await waitForMessage(ws);\n    expect(errMsg2.type).toBe(\"error\");\n\n    ws.close();\n  });\n\n  it(\"should handle 10 concurrent clients\", async () => {\n    const createRes = await request(app.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Test Doc\", content: \"\" })\n      .expect(201);\n\n    const docId = createRes.body.id;\n    const clientCount = 10;\n    const clients: WebSocket[] = [];\n\n    // Connect all clients\n    for (let i = 0; i < clientCount; i++) {\n      const ws = await connectWs(docId);\n      const sync = await waitForMessage(ws);\n      expect(sync.type).toBe(\"sync\");\n      clients.push(ws);\n    }\n\n    // Each client inserts a character, sequentially to avoid complexity\n    let currentVersion = 1;\n    for (let i = 0; i < clientCount; i++) {\n      const ws = clients[i];\n\n      // Each client inserts its index at the end of the current document\n      const currentDoc = (await request(app.app).get(`/api/documents/${docId}`)).body.content;\n      sendOp(ws, [\n        ...(currentDoc.length > 0 ? [{ type: \"retain\" as const, count: currentDoc.length }] : []),\n        { type: \"insert\" as const, text: String(i) },\n      ], currentVersion);\n\n      const ack = await waitForMessage(ws);\n      expect(ack.type).toBe(\"ack\");\n      currentVersion = ack.version as number;\n\n      // Drain broadcast messages from other clients\n      for (let j = 0; j < clientCount; j++) {\n        if (j !== i) {\n          await waitForMessage(clients[j]);\n        }\n      }\n    }\n\n    // Verify final state\n    const res = await request(app.app).get(`/api/documents/${docId}`).expect(200);\n    expect(res.body.content).toBe(\"0123456789\");\n    expect(res.body.content.length).toBe(10);\n\n    // Verify version history\n    const versionsRes = await request(app.app)\n      .get(`/api/documents/${docId}/versions`)\n      .expect(200);\n    expect(versionsRes.body.length).toBe(11); // initial + 10 edits\n\n    for (const ws of clients) {\n      ws.close();\n    }\n  });\n\n  it(\"should persist data across server restarts\", async () => {\n    // Use a file-based database for persistence test\n    const tmpDbPath = `/tmp/test-collab-${Date.now()}.db`;\n    const app1 = createApp(tmpDbPath);\n    const port1 = await app1.start(0);\n\n    // Create a document\n    const createRes = await request(app1.app)\n      .post(\"/api/documents\")\n      .send({ title: \"Persistent Doc\", content: \"Survives restart\" })\n      .expect(201);\n\n    const docId = createRes.body.id;\n\n    // Modify via WebSocket\n    const ws = await new Promise<WebSocket>((resolve, reject) => {\n      const w = new WebSocket(`ws://localhost:${port1}/ws/documents/${docId}`);\n      w.on(\"open\", () => resolve(w));\n      w.on(\"error\", reject);\n    });\n\n    const syncMsg = await waitForMessage(ws);\n    expect(syncMsg.type).toBe(\"sync\");\n\n    sendOp(ws, [\n      { type: \"retain\", count: 16 },\n      { type: \"insert\", text: \"!\" },\n    ], 1);\n\n    const ack = await waitForMessage(ws);\n    expect(ack.type).toBe(\"ack\");\n\n    ws.close();\n    await app1.stop();\n\n    // Restart with same database\n    const app2 = createApp(tmpDbPath);\n    await app2.start(0);\n\n    const res = await request(app2.app)\n      .get(`/api/documents/${docId}`)\n      .expect(200);\n\n    expect(res.body.title).toBe(\"Persistent Doc\");\n    expect(res.body.content).toBe(\"Survives restart!\");\n\n    // Check version history survived\n    const versionsRes = await request(app2.app)\n      .get(`/api/documents/${docId}/versions`)\n      .expect(200);\n    expect(versionsRes.body.length).toBe(2);\n\n    await app2.stop();\n  });\n});\n","structuredPatch":[],"originalFile":null}}
