+import express from "express";
+import { createServer, Server as HttpServer } from "http";
+import { createDatabase, DatabaseLayer } from "./db.js";
+import { createRouter } from "./routes.js";
+import { CollaborationManager } from "./ws.js";
+
+export interface AppInstance {
+  app: express.Express;
+  start(port?: number): Promise<number>;
+  stop(): Promise<void>;
+}
+
+export function createApp(dbPath?: string): AppInstance {
+  const app = express();
+  app.use(express.json());
+
+  const db: DatabaseLayer = createDatabase(dbPath);
+  const router = createRouter(db);
+  app.use("/api", router);
+
+  let httpServer: HttpServer | null = null;
+  let collaborationManager: CollaborationManager | null = null;
+
+  return {
+    app,
+
+    async start(port?: number): Promise<number> {
+      httpServer = createServer(app);
+      collaborationManager = new CollaborationManager(httpServer, db);
+
+      return new Promise((resolve, reject) => {
+        httpServer!.on("error", reject);
+        httpServer!.listen(port || 0, () => {
+          const addr = httpServer!.address();
+          if (typeof addr === "object" && addr !== null) {
+            resolve(addr.port);
+          } else {
+            resolve(0);
+          }
+        });
+      });
+    },
+
+    async stop(): Promise<void> {
+      if (collaborationManager) {
+        collaborationManager.closeAll();
+        collaborationManager = null;
+      }
+      if (httpServer) {
+        await new Promise<void>((resolve, reject) => {
+          httpServer!.close((err) => {
+            if (err) reject(err);
+            else resolve();
+          });
+        });
+        httpServer = null;
+      }
+      db.close();
+    },
+  };
+}
