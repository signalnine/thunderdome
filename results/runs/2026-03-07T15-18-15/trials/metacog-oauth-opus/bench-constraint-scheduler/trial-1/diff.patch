@@ -0,0 +1,482 @@
+import type { Event, Room, ScheduleOptions, Assignment, ScheduleResult } from './types.js';
+
+/**
+ * Detect cycles in the prerequisite graph using DFS.
+ * Throws an error if a cycle is found (including self-references).
+ */
+function validateNoCycles(events: Event[]): void {
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  for (const event of events) {
+    if (event.prerequisites?.includes(event.id)) {
+      throw new Error(`Cycle detected: event "${event.id}" has a self-referencing prerequisite`);
+    }
+  }
+
+  const WHITE = 0;
+  const GRAY = 1;
+  const BLACK = 2;
+
+  const color = new Map<string, number>();
+  for (const event of events) {
+    color.set(event.id, WHITE);
+  }
+
+  function dfs(id: string): void {
+    color.set(id, GRAY);
+
+    const event = eventMap.get(id);
+    if (event?.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        if (!color.has(prereqId)) continue;
+
+        const prereqColor = color.get(prereqId);
+        if (prereqColor === GRAY) {
+          throw new Error(`Cycle detected in prerequisites involving event "${prereqId}"`);
+        }
+        if (prereqColor === WHITE) {
+          dfs(prereqId);
+        }
+      }
+    }
+
+    color.set(id, BLACK);
+  }
+
+  for (const event of events) {
+    if (color.get(event.id) === WHITE) {
+      dfs(event.id);
+    }
+  }
+}
+
+/**
+ * Tracks occupied time slots per room.
+ */
+class RoomTimeline {
+  private slots: Array<{ start: number; end: number }> = [];
+
+  addSlot(start: number, end: number): void {
+    // Insert in sorted position
+    let i = 0;
+    while (i < this.slots.length && this.slots[i].start < start) i++;
+    this.slots.splice(i, 0, { start, end });
+  }
+
+  removeSlot(start: number, end: number): void {
+    const idx = this.slots.findIndex(s => s.start === start && s.end === end);
+    if (idx !== -1) {
+      this.slots.splice(idx, 1);
+    }
+  }
+
+  findEarliestSlot(duration: number, minStart: number, windowEnd: number, gap: number): number | null {
+    let candidate = minStart;
+
+    for (const slot of this.slots) {
+      if (candidate + duration <= slot.start - gap) {
+        break;
+      }
+      if (candidate < slot.end + gap) {
+        candidate = slot.end + gap;
+      }
+    }
+
+    if (candidate + duration <= windowEnd) {
+      return candidate;
+    }
+    return null;
+  }
+}
+
+/**
+ * Compute a topological ordering using Kahn's algorithm, with events in each
+ * layer sorted by the given comparator.
+ */
+function topoSortWithPriority(
+  events: Event[],
+  eventMap: Map<string, Event>,
+  dependents: Map<string, Set<string>>,
+  comparator: (a: string, b: string) => number
+): string[] {
+  const inDegree = new Map<string, number>();
+  for (const event of events) {
+    let deg = 0;
+    if (event.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        if (eventMap.has(prereqId)) deg++;
+      }
+    }
+    inDegree.set(event.id, deg);
+  }
+
+  const queue: string[] = [];
+  for (const [id, deg] of inDegree) {
+    if (deg === 0) queue.push(id);
+  }
+
+  const order: string[] = [];
+
+  while (queue.length > 0) {
+    queue.sort(comparator);
+    const layer = [...queue];
+    queue.length = 0;
+
+    for (const eventId of layer) {
+      order.push(eventId);
+
+      const deps = dependents.get(eventId);
+      if (deps) {
+        for (const depId of deps) {
+          const newDeg = (inDegree.get(depId) ?? 0) - 1;
+          inDegree.set(depId, newDeg);
+          if (newDeg === 0) {
+            queue.push(depId);
+          }
+        }
+      }
+    }
+  }
+
+  return order;
+}
+
+export function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {
+  if (events.length === 0) {
+    return { assignments: [], unscheduled: [] };
+  }
+
+  const gap = options.gap ?? 15;
+  const { startTime, endTime } = options;
+
+  // Validate no cycles (throws on cycles)
+  validateNoCycles(events);
+
+  const eventMap = new Map<string, Event>();
+  for (const event of events) {
+    eventMap.set(event.id, event);
+  }
+
+  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);
+
+  // Build dependency graph
+  const dependents = new Map<string, Set<string>>();
+  for (const event of events) {
+    if (event.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        if (!dependents.has(prereqId)) {
+          dependents.set(prereqId, new Set());
+        }
+        dependents.get(prereqId)!.add(event.id);
+      }
+    }
+  }
+
+  // Compute transitive dependent count for each event
+  const depCountCache = new Map<string, number>();
+  function getTransitiveDependentCount(eventId: string): number {
+    if (depCountCache.has(eventId)) return depCountCache.get(eventId)!;
+
+    const deps = dependents.get(eventId);
+    if (!deps || deps.size === 0) {
+      depCountCache.set(eventId, 0);
+      return 0;
+    }
+
+    let count = deps.size;
+    for (const depId of deps) {
+      count += getTransitiveDependentCount(depId);
+    }
+
+    depCountCache.set(eventId, count);
+    return count;
+  }
+
+  function getEarliestStart(
+    event: Event,
+    assignments: Map<string, Assignment>
+  ): number {
+    let earliest = startTime;
+    if (event.prerequisites) {
+      for (const prereqId of event.prerequisites) {
+        if (!eventMap.has(prereqId)) continue;
+        const prereqAssignment = assignments.get(prereqId);
+        if (prereqAssignment) {
+          earliest = Math.max(earliest, prereqAssignment.endTime + gap);
+        } else {
+          return -1;
+        }
+      }
+    }
+    return earliest;
+  }
+
+  function tryPlace(
+    event: Event,
+    assignments: Map<string, Assignment>,
+    timelines: Map<string, RoomTimeline>
+  ): Assignment | null {
+    const attendees = event.attendees ?? 1;
+    const earliestStart = getEarliestStart(event, assignments);
+    if (earliestStart === -1) return null;
+
+    const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);
+    if (eligibleRooms.length === 0) return null;
+
+    // Preferred room first, then smallest capacity that fits
+    const orderedRooms = [...eligibleRooms];
+    if (event.preferredRoom) {
+      const prefIdx = orderedRooms.findIndex(r => r.id === event.preferredRoom);
+      if (prefIdx > 0) {
+        const [prefRoom] = orderedRooms.splice(prefIdx, 1);
+        orderedRooms.unshift(prefRoom);
+      }
+    }
+
+    let best: Assignment | null = null;
+
+    for (const room of orderedRooms) {
+      const timeline = timelines.get(room.id)!;
+      const slotStart = timeline.findEarliestSlot(event.duration, earliestStart, endTime, gap);
+
+      if (slotStart !== null) {
+        const candidate: Assignment = {
+          eventId: event.id,
+          roomId: room.id,
+          startTime: slotStart,
+          endTime: slotStart + event.duration,
+        };
+
+        if (room.id === event.preferredRoom) {
+          return candidate;
+        }
+
+        if (!best || slotStart < best.startTime) {
+          best = candidate;
+        }
+      }
+    }
+
+    return best;
+  }
+
+  /**
+   * Run the greedy scheduler with a given event ordering.
+   * Returns the set of assignments and unscheduled events.
+   */
+  function runGreedy(ordering: string[]): {
+    assignments: Map<string, Assignment>;
+    timelines: Map<string, RoomTimeline>;
+    unscheduled: string[];
+  } {
+    const timelines = new Map<string, RoomTimeline>();
+    for (const room of rooms) {
+      timelines.set(room.id, new RoomTimeline());
+    }
+    const assignments = new Map<string, Assignment>();
+    const unscheduled: string[] = [];
+
+    for (const eventId of ordering) {
+      const event = eventMap.get(eventId)!;
+      const assignment = tryPlace(event, assignments, timelines);
+
+      if (assignment) {
+        assignments.set(eventId, assignment);
+        timelines.get(assignment.roomId)!.addSlot(assignment.startTime, assignment.endTime);
+      } else {
+        unscheduled.push(eventId);
+      }
+    }
+
+    return { assignments, timelines, unscheduled };
+  }
+
+  // Try multiple heuristic orderings and pick the one that schedules the most events
+  const strategies: Array<(a: string, b: string) => number> = [
+    // Strategy 1: Most constrained first (fewer eligible rooms, longer duration)
+    (a, b) => {
+      const evA = eventMap.get(a)!;
+      const evB = eventMap.get(b)!;
+      const depDiff = getTransitiveDependentCount(b) - getTransitiveDependentCount(a);
+      if (depDiff !== 0) return depDiff;
+      const attA = evA.attendees ?? 1;
+      const attB = evB.attendees ?? 1;
+      const eligA = sortedRooms.filter(r => r.capacity >= attA).length;
+      const eligB = sortedRooms.filter(r => r.capacity >= attB).length;
+      if (eligA !== eligB) return eligA - eligB;
+      return evB.duration - evA.duration;
+    },
+    // Strategy 2: Shortest first (fit more events)
+    (a, b) => {
+      const evA = eventMap.get(a)!;
+      const evB = eventMap.get(b)!;
+      const depDiff = getTransitiveDependentCount(b) - getTransitiveDependentCount(a);
+      if (depDiff !== 0) return depDiff;
+      return evA.duration - evB.duration;
+    },
+    // Strategy 3: Most attendees first (most constrained by room capacity)
+    (a, b) => {
+      const evA = eventMap.get(a)!;
+      const evB = eventMap.get(b)!;
+      const depDiff = getTransitiveDependentCount(b) - getTransitiveDependentCount(a);
+      if (depDiff !== 0) return depDiff;
+      const attA = evA.attendees ?? 1;
+      const attB = evB.attendees ?? 1;
+      return attB - attA;
+    },
+    // Strategy 4: Fewest attendees first (use small rooms first, save big rooms)
+    (a, b) => {
+      const evA = eventMap.get(a)!;
+      const evB = eventMap.get(b)!;
+      const depDiff = getTransitiveDependentCount(b) - getTransitiveDependentCount(a);
+      if (depDiff !== 0) return depDiff;
+      const attA = evA.attendees ?? 1;
+      const attB = evB.attendees ?? 1;
+      return attA - attB;
+    },
+  ];
+
+  let bestResult: {
+    assignments: Map<string, Assignment>;
+    timelines: Map<string, RoomTimeline>;
+    unscheduled: string[];
+  } | null = null;
+
+  for (const comparator of strategies) {
+    const ordering = topoSortWithPriority(events, eventMap, dependents, comparator);
+    const result = runGreedy(ordering);
+
+    if (!bestResult || result.unscheduled.length < bestResult.unscheduled.length) {
+      bestResult = result;
+      if (result.unscheduled.length === 0) break;
+    }
+  }
+
+  // Post-optimization: try to fit unscheduled events by swapping
+  if (bestResult!.unscheduled.length > 0) {
+    const { assignments, timelines, unscheduled } = bestResult!;
+
+    let improved = true;
+    while (improved) {
+      improved = false;
+
+      for (let i = unscheduled.length - 1; i >= 0; i--) {
+        const eventId = unscheduled[i];
+        const event = eventMap.get(eventId)!;
+
+        // Try direct placement
+        const direct = tryPlace(event, assignments, timelines);
+        if (direct) {
+          assignments.set(eventId, direct);
+          timelines.get(direct.roomId)!.addSlot(direct.startTime, direct.endTime);
+          unscheduled.splice(i, 1);
+          improved = true;
+          continue;
+        }
+
+        // Try displacing a scheduled event to make room
+        const attendees = event.attendees ?? 1;
+        const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);
+        let swapped = false;
+
+        for (const room of eligibleRooms) {
+          const timeline = timelines.get(room.id)!;
+          const earliestStart = getEarliestStart(event, assignments);
+          if (earliestStart === -1) break;
+
+          const roomAssignments = Array.from(assignments.values())
+            .filter(a => a.roomId === room.id);
+
+          for (const blocking of roomAssignments) {
+            const blockingEvent = eventMap.get(blocking.eventId)!;
+            const blockingAttendees = blockingEvent.attendees ?? 1;
+
+            const altRooms = sortedRooms.filter(
+              r => r.id !== room.id && r.capacity >= blockingAttendees
+            );
+
+            for (const altRoom of altRooms) {
+              const altTimeline = timelines.get(altRoom.id)!;
+              const blockingEarliestStart = getEarliestStart(blockingEvent, assignments);
+              if (blockingEarliestStart === -1) continue;
+
+              const altStart = altTimeline.findEarliestSlot(
+                blockingEvent.duration,
+                blockingEarliestStart,
+                endTime,
+                gap
+              );
+
+              if (altStart !== null) {
+                // Try removing blocking from this room
+                timeline.removeSlot(blocking.startTime, blocking.endTime);
+                const newPlacement = timeline.findEarliestSlot(event.duration, earliestStart, endTime, gap);
+
+                if (newPlacement !== null) {
+                  // Check that moving the blocking event doesn't break its dependents
+                  const newBlockingEnd = altStart + blockingEvent.duration;
+                  let dependentsOk = true;
+
+                  // Temporarily update assignments to check dependents
+                  const oldAssignment = assignments.get(blocking.eventId)!;
+                  assignments.set(blocking.eventId, {
+                    eventId: blocking.eventId,
+                    roomId: altRoom.id,
+                    startTime: altStart,
+                    endTime: newBlockingEnd,
+                  });
+
+                  // Check all events that depend on the blocking event
+                  const blockingDeps = dependents.get(blocking.eventId);
+                  if (blockingDeps) {
+                    for (const depId of blockingDeps) {
+                      if (depId === eventId) continue;
+                      const depAssignment = assignments.get(depId);
+                      if (depAssignment && depAssignment.startTime < newBlockingEnd + gap) {
+                        dependentsOk = false;
+                        break;
+                      }
+                    }
+                  }
+
+                  if (dependentsOk) {
+                    altTimeline.addSlot(altStart, newBlockingEnd);
+                    timeline.addSlot(newPlacement, newPlacement + event.duration);
+
+                    assignments.set(eventId, {
+                      eventId: event.id,
+                      roomId: room.id,
+                      startTime: newPlacement,
+                      endTime: newPlacement + event.duration,
+                    });
+
+                    unscheduled.splice(i, 1);
+                    improved = true;
+                    swapped = true;
+                    break;
+                  } else {
+                    // Restore
+                    assignments.set(blocking.eventId, oldAssignment);
+                    timeline.addSlot(blocking.startTime, blocking.endTime);
+                  }
+                } else {
+                  timeline.addSlot(blocking.startTime, blocking.endTime);
+                }
+              }
+            }
+            if (swapped) break;
+          }
+          if (swapped) break;
+        }
+      }
+    }
+  }
+
+  return {
+    assignments: Array.from(bestResult!.assignments.values()),
+    unscheduled: bestResult!.unscheduled,
+  };
+}
