gree) {\n      if (deg === 0) queue.push(id);\n    }\n\n    while (queue.length > 0) {\n      // Sort current layer by priority\n      const layer = prioritySort(queue);\n      queue.length = 0;\n\n      for (const eventId of layer) {\n        processing.push(eventId);\n        scheduled.add(eventId);\n\n        // Update in-degrees\n        const deps = dependents.get(eventId);\n        if (deps) {\n          for (const depId of deps) {\n            const newDeg = (inDegree.get(depId) ?? 0) - 1;\n            inDegree.set(depId, newDeg);\n            if (newDeg === 0) {\n              queue.push(depId);\n            }\n          }\n        }\n      }\n    }\n\n    // Schedule events in the computed order\n    for (const eventId of processing) {\n      const event = eventMap.get(eventId)!;\n      const assignment = tryScheduleEvent(event, assignments, timelines);\n\n      if (assignment) {\n        assignments.set(eventId, assignment);\n        timelines.get(assignment.roomId)!.addSlot(assignment.startTime, assignment.endTime);\n      }\n    }\n\n    return { assignments, timelines };\n  }\n\n  function getEarliestStartForEvent(\n    event: Event,\n    assignments: Map<string, Assignment>\n  ): number {\n    let earliest = startTime;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (!eventMap.has(prereqId)) continue;\n        const prereqAssignment = assignments.get(prereqId);\n        if (prereqAssignment) {\n          earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n        } else {\n          return -1;\n        }\n      }\n    }\n    return earliest;\n  }\n\n  function tryScheduleEvent(\n    event: Event,\n    assignments: Map<string, Assignment>,\n    timelines: Map<string, RoomTimeline>\n  ): Assignment | null {\n    const attendees = event.attendees ?? 1;\n    const earliestStart = getEarliestStartForEvent(event, assignments);\n    if (earliestStart === -1) return null;\n\n    // Filter rooms by capacity\n    const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);\n    if (eligibleRooms.length === 0) return null;\n\n    // Order rooms: preferred room first, then by capacity (best fit)\n    const orderedRooms = [...eligibleRooms];\n    if (event.preferredRoom) {\n      const prefIdx = orderedRooms.findIndex(r => r.id === event.preferredRoom);\n      if (prefIdx > 0) {\n        const [prefRoom] = orderedRooms.splice(prefIdx, 1);\n        orderedRooms.unshift(prefRoom);\n      }\n    }\n\n    let bestAssignment: Assignment | null = null;\n\n    for (const room of orderedRooms) {\n      const timeline = timelines.get(room.id)!;\n      const slotStart = timeline.findEarliestSlot(event.duration, earliestStart, endTime, gap);\n\n      if (slotStart !== null) {\n        const candidate: Assignment = {\n          eventId: event.id,\n          roomId: room.id,\n          startTime: slotStart,\n          endTime: slotStart + event.duration,\n        };\n\n        // If this is the preferred room and it works, use it immediately\n        if (room.id === event.preferredRoom) {\n          return candidate;\n        }\n\n        if (!bestAssignment || slotStart < bestAssignment.startTime) {\n          bestAssignment = candidate;\n        }\n      }\n    }\n\n    return bestAssignment;\n  }\n\n  // Run the main scheduling\n  const result = solveSchedule();\n  const { assignments } = result;\n\n  // Collect unscheduled events\n  const unscheduled: string[] = [];\n  for (const event of events) {\n    if (!assignments.has(event.id)) {\n      unscheduled.push(event.id);\n    }\n  }\n\n  // Optimization: try swapping room assignments to make space for unscheduled events\n  if (unscheduled.length > 0) {\n    const { timelines } = result;\n    let improved = true;\n\n    while (improved) {\n      improved = false;\n\n      for (let i = unscheduled.length - 1; i >= 0; i--) {\n        const eventId = unscheduled[i];\n        const event = eventMap.get(eventId)!;\n\n        // Try direct placement first (slots may have freed up)\n        const directPlacement = tryScheduleEvent(event, assignments, timelines);\n        if (directPlacement) {\n          assignments.set(eventId, directPlacement);\n          timelines.get(directPlacement.roomId)!.addSlot(directPlacement.startTime, directPlacement.endTime);\n          unscheduled.splice(i, 1);\n          improved = true;\n          continue;\n        }\n\n        // Try displacing a scheduled event to a different room to make space\n        const attendees = event.attendees ?? 1;\n        const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);\n\n        for (const room of eligibleRooms) {\n          const timeline = timelines.get(room.id)!;\n          const earliestStart = getEarliestStartForEvent(event, assignments);\n          if (earliestStart === -1) break;\n\n          // Find which scheduled events in this room overlap with where we need to place\n          const currentAssignmentsInRoom = Array.from(assignments.values())\n            .filter(a => a.roomId === room.id);\n\n          // Try moving each blocking event to another room\n          for (const blocking of currentAssignmentsInRoom) {\n            const blockingEvent = eventMap.get(blocking.eventId)!;\n            const blockingAttendees = blockingEvent.attendees ?? 1;\n\n            // Find alternative rooms for the blocking event\n            const altRooms = sortedRooms.filter(\n              r => r.id !== room.id && r.capacity >= blockingAttendees\n            );\n\n            for (const altRoom of altRooms) {\n              const altTimeline = timelines.get(altRoom.id)!;\n              const altStart = altTimeline.findEarliestSlot(\n                blockingEvent.duration,\n                getEarliestStartForEvent(blockingEvent, assignments),\n                endTime,\n                gap\n              );\n\n              if (altStart !== null) {\n                // Try the swap: move blocking to altRoom, place event in room\n                timeline.removeSlot(blocking.startTime, blocking.endTime);\n                const newPlacement = timeline.findEarliestSlot(event.duration, earliestStart, endTime, gap);\n\n                if (newPlacement !== null) {\n                  // Swap works!\n                  altTimeline.addSlot(altStart, altStart + blockingEvent.duration);\n                  timeline.addSlot(newPlacement, newPlacement + event.duration);\n\n                  assignments.set(blocking.eventId, {\n                    eventId: blocking.eventId,\n                    roomId: altRoom.id,\n                    startTime: altStart,\n                    endTime: altStart + blockingEvent.duration,\n                  });\n\n                  assignments.set(eventId, {\n                    eventId: event.id,\n                    roomId: room.id,\n                    startTime: newPlacement,\n                    endTime: newPlacement + event.duration,\n                  });\n\n                  unscheduled.splice(i, 1);\n                  improved = true;\n                  break;\n                } else {\n                  // Swap didn't work, restore\n                  timeline.addSlot(blocking.startTime, blocking.endTime);\n                }\n              }\n            }\n\n            if (improved) break;\n          }\n\n          if (improved) break;\n        }\n      }\n    }\n  }\n\n  return {\n    assignments: Array.from(assignments.values()),\n    unscheduled,\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":338,"cache_read_input_tokens":30353,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":338},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3008fcde-1f55-4d48-8199-9fe1598806c4","uuid":"1121b7b7-a984-4632-b6e8-5f1cfe983127"}
