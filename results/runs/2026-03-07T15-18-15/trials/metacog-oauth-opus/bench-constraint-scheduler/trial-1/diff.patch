t.id}\" has a self-referencing prerequisite`);\n    }\n  }\n\n  const WHITE = 0;\n  const GRAY = 1;\n  const BLACK = 2;\n\n  const color = new Map<string, number>();\n  for (const event of events) {\n    color.set(event.id, WHITE);\n  }\n\n  function dfs(id: string): void {\n    color.set(id, GRAY);\n\n    const event = eventMap.get(id);\n    if (event?.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (!color.has(prereqId)) continue;\n\n        const prereqColor = color.get(prereqId);\n        if (prereqColor === GRAY) {\n          throw new Error(`Cycle detected in prerequisites involving event \"${prereqId}\"`);\n        }\n        if (prereqColor === WHITE) {\n          dfs(prereqId);\n        }\n      }\n    }\n\n    color.set(id, BLACK);\n  }\n\n  for (const event of events) {\n    if (color.get(event.id) === WHITE) {\n      dfs(event.id);\n    }\n  }\n}\n\n/**\n * Tracks occupied time slots per room.\n */\nclass RoomTimeline {\n  private slots: Array<{ start: number; end: number }> = [];\n\n  addSlot(start: number, end: number): void {\n    // Insert in sorted position\n    let i = 0;\n    while (i < this.slots.length && this.slots[i].start < start) i++;\n    this.slots.splice(i, 0, { start, end });\n  }\n\n  removeSlot(start: number, end: number): void {\n    const idx = this.slots.findIndex(s => s.start === start && s.end === end);\n    if (idx !== -1) {\n      this.slots.splice(idx, 1);\n    }\n  }\n\n  findEarliestSlot(duration: number, minStart: number, windowEnd: number, gap: number): number | null {\n    let candidate = minStart;\n\n    for (const slot of this.slots) {\n      if (candidate + duration <= slot.start - gap) {\n        break;\n      }\n      if (candidate < slot.end + gap) {\n        candidate = slot.end + gap;\n      }\n    }\n\n    if (candidate + duration <= windowEnd) {\n      return candidate;\n    }\n    return null;\n  }\n}\n\n/**\n * Compute a topological ordering using Kahn's algorithm, with events in each\n * layer sorted by the given comparator.\n */\nfunction topoSortWithPriority(\n  events: Event[],\n  eventMap: Map<string, Event>,\n  dependents: Map<string, Set<string>>,\n  comparator: (a: string, b: string) => number\n): string[] {\n  const inDegree = new Map<string, number>();\n  for (const event of events) {\n    let deg = 0;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (eventMap.has(prereqId)) deg++;\n      }\n    }\n    inDegree.set(event.id, deg);\n  }\n\n  const queue: string[] = [];\n  for (const [id, deg] of inDegree) {\n    if (deg === 0) queue.push(id);\n  }\n\n  const order: string[] = [];\n\n  while (queue.length > 0) {\n    queue.sort(comparator);\n    const layer = [...queue];\n    queue.length = 0;\n\n    for (const eventId of layer) {\n      order.push(eventId);\n\n      const deps = dependents.get(eventId);\n      if (deps) {\n        for (const depId of deps) {\n          const newDeg = (inDegree.get(depId) ?? 0) - 1;\n          inDegree.set(depId, newDeg);\n          if (newDeg === 0) {\n            queue.push(depId);\n          }\n        }\n      }\n    }\n  }\n\n  return order;\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  // Validate no cycles (throws on cycles)\n  validateNoCycles(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Build dependency graph\n  const dependents = new Map<string, Set<string>>();\n  for (const event of events) {\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (!dependents.has(prereqId)) {\n          dependents.set(pre