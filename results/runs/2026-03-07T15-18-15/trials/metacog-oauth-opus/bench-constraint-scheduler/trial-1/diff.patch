\n  // Process events in topological order\n  for (const eventId of topoOrder) {\n    const event = eventMap.get(eventId)!;\n    const assignment = tryScheduleEvent(event);\n\n    if (assignment) {\n      assignments.set(eventId, assignment);\n      timelines.get(assignment.roomId)!.addSlot(assignment.startTime, assignment.endTime);\n    } else {\n      unscheduled.push(eventId);\n    }\n  }\n\n  // Optimization pass: try to reschedule unscheduled events\n  // by trying different placements. This is a simple retry since\n  // earlier events may have left gaps.\n  let improved = true;\n  while (improved && unscheduled.length > 0) {\n    improved = false;\n    for (let i = unscheduled.length - 1; i >= 0; i--) {\n      const eventId = unscheduled[i];\n      const event = eventMap.get(eventId)!;\n      const assignment = tryScheduleEvent(event);\n      if (assignment) {\n        assignments.set(eventId, assignment);\n        timelines.get(assignment.roomId)!.addSlot(assignment.startTime, assignment.endTime);\n        unscheduled.splice(i, 1);\n        improved = true;\n      }\n    }\n  }\n\n  return {\n    assignments: Array.from(assignments.values()),\n    unscheduled,\n  };\n}\n","structuredPatch":[],"originalFile":null}}
