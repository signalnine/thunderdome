ng event \"${prereqId}\"`);\n        }\n        if (prereqColor === WHITE) {\n          dfs(prereqId);\n        }\n      }\n    }\n\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const event of events) {\n    if (color.get(event.id) === WHITE) {\n      dfs(event.id);\n    }\n  }\n\n  return order;\n}\n\n/**\n * Tracks occupied time slots per room and supports efficient queries.\n */\nclass RoomTimeline {\n  private slots: Array<{ start: number; end: number }> = [];\n\n  addSlot(start: number, end: number): void {\n    this.slots.push({ start, end });\n    this.slots.sort((a, b) => a.start - b.start);\n  }\n\n  removeSlot(start: number, end: number): void {\n    const idx = this.slots.findIndex(s => s.start === start && s.end === end);\n    if (idx !== -1) {\n      this.slots.splice(idx, 1);\n    }\n  }\n\n  /**\n   * Find the earliest start time >= minStart where a slot of `duration` minutes\n   * can fit, respecting gaps and the overall time window.\n   */\n  findEarliestSlot(duration: number, minStart: number, windowEnd: number, gap: number): number | null {\n    let candidate = minStart;\n\n    for (const slot of this.slots) {\n      // If candidate + duration fits before this slot (with gap before it)\n      if (candidate + duration <= slot.start - gap) {\n        break;\n      }\n\n      // Move candidate past this slot plus gap\n      if (candidate < slot.end + gap) {\n        candidate = slot.end + gap;\n      }\n    }\n\n    if (candidate + duration <= windowEnd) {\n      return candidate;\n    }\n\n    return null;\n  }\n\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  // Topological sort — validates no cycles exist (throws on cycles)\n  topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  // Sort rooms by capacity ascending for best-fit matching\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Build dependency graph info for scheduling priority\n  const dependents = new Map<string, Set<string>>(); // event -> events that depend on it\n  const depthCache = new Map<string, number>();\n\n  for (const event of events) {\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (!dependents.has(prereqId)) {\n          dependents.set(prereqId, new Set());\n        }\n        dependents.get(prereqId)!.add(event.id);\n      }\n    }\n  }\n\n  // Compute chain depth (how many events depend on this one transitively)\n  function getChainDepth(eventId: string): number {\n    if (depthCache.has(eventId)) return depthCache.get(eventId)!;\n\n    const deps = dependents.get(eventId);\n    if (!deps || deps.size === 0) {\n      depthCache.set(eventId, 0);\n      return 0;\n    }\n\n    let maxDepth = 0;\n    for (const depId of deps) {\n      maxDepth = Math.max(maxDepth, 1 + getChainDepth(depId));\n    }\n\n    depthCache.set(eventId, maxDepth);\n    return maxDepth;\n  }\n\n  // Strategy: process events in topological order, but within each \"layer\"\n  // (events whose prerequisites are all met), prioritize by:\n  //   1. Chain depth (events with more dependents first)\n  //   2. Fewer eligible rooms (more constrained first)\n  //   3. Longer duration (harder to fit)\n  function prioritySort(eventIds: string[]): string[] {\n    return [...eventIds].sort((a, b) => {\n      const evA = eventMap.get(a)!;\n      const evB = eventMap.get(b)!;\n\n      // Events with longer dependency chains go first\n      const depthDiff = getChainDepth(b) - getChainDepth(a);\n      if (depthDiff !== 0) return depthDiff;\n\n      // More constrained events (fewer eligible rooms) go first\n      const attendeesA = evA.attendees ?? 1;\n      const attendeesB = evB.attendees ?? 1;\n      const eligibleA = sortedRooms.filter(r => r.capacity >= attendeesA).length;\n      const eligibleB = sortedRooms.filter(r => r.capacity >= attendeesB).length;\n      if (eligibleA !== eligibleB) return eligibleA - eligibleB;\n\n      // Longer events go first (harder to place)\n      return evB.duration - evA.duration;\n    });\n  }\n\n  // Main scheduling with backtracking support\n  function solveSchedule(): { assignments: Map<string, Assignment>; timelines: Map<string, RoomTimeline> } {\n    const timelines = new Map<string, RoomTimeline>();\n    for (const room of rooms) {\n      timelines.set(room.id, new RoomTimeline());\n    }\n    const assignments = new Map<string, Assignment>();\n\n    const processing: string[] = [];\n\n    // Build layers from topological order\n    const inDegree = new Map<string, number>();\n    for (const event of events) {\n      let deg = 0;\n      if (event.prerequisites) {\n        for (const prereqId of event.prerequisites) {\n          if (eventMap.has(prereqId)) deg++;\n        }\n      }\n      inDegree.set(event.id, deg);\n    }\n\n    // Kahn's algorithm with priority ordering per layer\n    const queue: string[] = [];\n    for (const [id, deg] of inDegree) {\n      if (deg === 0) queue.push(id);\n    }\n\n    while (queue.length > 0) {\n      // Sort current layer by priority\n      const layer = prioritySort(queue);\n      queue.length = 0;\n\n      for (const eventId of layer) {\n        processing.push(eventId);\n        scheduled.add(eventId);\n\n        // Update in-degrees\n        const deps = dependents.get(eventId);\n        if (deps) {\n          for (const depId of deps) {\n            const newDeg = (inDegree.get(depId) ?? 0) - 1;\n            inDegree.set(depId, newDeg);\n            if (newDeg === 0) {\n              queue.push(depId);\n            }\n          }\n        }\n      }\n    }\n\n    // Schedule events in the computed order\n    for (const eventId of processing) {\n      const event = eventMap.get(eventId)!;\n      const assignment = tryScheduleEvent(event, assignments, timelines);\n\n      if (assignment) {\n        assignments.set(eventId, assignment);\n        timelines.get(assignment.roomId)!.addSlot(assignment.startTime, assignment.endTime);\n      }\n    }\n\n    return { assignments, timelines };\n  }\n\n  function getEarliestStartForEvent(\n    event: Event,\n    assignments: Map<string, Assignment>\n  ): number {\n    let earliest = startTime;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (!eventMap.has(prereqId)) continue;\n        const prereqAssignment = assignments.get(prereqId);\n        if (prereqAssignment) {\n          earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n        } else {\n          return -1;\n        }\n      }\n    }\n    return earliest;\n  }\n\n  function tryScheduleEvent(\n    event: Event,\n    assignments: Map<string, Assignment>,\n    timelines: Map<string, RoomTimeline>\n  ): Assignment | null {\n    const attendees = event.attendees ?? 1;\n    const earliestStart = getEarliestStartForEvent(event, assignments);\n    if (earliestStart === -1) return null;\n\n    // Filter rooms by capacity\n    const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);\n    if (eligibleRooms.length === 0) return null;\n\n    // Order rooms: preferred room first, then by capacity (best fit)\n    const orderedRooms = [...eligibleRooms];\n    if (event.preferredRoom) {\n      const prefIdx = orderedRooms.findIndex(r => r.id === event.preferredRoom);\n      if (prefIdx > 0) {\n        const [prefRoom] = orderedRooms.splice(prefIdx, 1);\n        orderedRooms.unshift(prefRoom);\n      }\n    }\n\n    let bestAssignment: Assignment | null = null;\n\n    for (const room of orderedRooms) {\n      const timeline = timelines.get(room.id)!;\n      const slotStart = timeline.findEarliestSlot(event.duration, earliestStart, endTime, gap);\n\n      if (slotStart !== null) {\n        const candidate: Assignment = {\n          eventId: event.id,\n          roomId: room.id,\n          startTime: slotStart,\n          endTime: slotStart + event.duration,\n        };\n\n        // If this is the preferred room and it works, use it immediately\n        if (room.id === event.preferredRoom) {\n          return candidate;\n        }\n\n        if (!bestAssignment || slotStart < bestAssignment.startTime) {\n          bestAssignment = candidate;\n        }\n      }\n    }\n\n    return bestAssignment;\n  }\n\n  // Run the main scheduling\n  const result = solveSchedule();\n  const { assignments } = result;\n\n  // Collect unscheduled events\n  const unscheduled: string[] = [];\n  for (const event of events) {\n    if (!assignments.has(event.id)) {\n      unscheduled.push(event.id);\n    }\n  }\n\n  // Optimization: try swapping room assignments to make space for unscheduled events\n  if (unscheduled.length > 0) {\n    const { timelines } = result;\n    let improved = true;\n\n    while (improved) {\n      improved = false;\n\n      for (let i = unscheduled.length - 1; i >= 0; i--) {\n        const eventId = unscheduled[i];\n        const event = eventMap.get(eventId)!;\n\n        // Try direct placement first (slots may have freed up)\n        const directPlacement = tryScheduleEvent(event, assignments, timelines);\n        if (directPlacement) {\n          assignments.set(eventId, directPlacement);\n          timelines.get(directPlacement.roomId)!.addSlot(directPlacement.startTime, directPlacement.endTime);\n          unscheduled.splice(i, 1);\n          improved = true;\n          continue;\n        }\n\n        // Try displacing a scheduled event to a different room to make space\n        const attendees = event.attendees ?? 1;\n        const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);\n\n        for (const room of eligibleRooms) {\n          const timeline = timelines.get(room.id)!;\n          const earliestStart = getEarliestStartForEvent(event, assignments);\n          if (earliestStart === -1) break;\n\n          // Find which scheduled events in this room overlap with where we need to place\n          const currentAssignmentsInRoom = Array.from(assignments.values())\n            .filter(a => a.roomId === room.id);\n\n          // Try moving each blocking event to another room\n          for (const blocking of currentAssignmentsInRoom) {\n            const blockingEvent = eventMap.get(blocking.eventId)!;\n            const blockingAttendees = blockingEvent.attendees ?? 1;\n\n            // Find alternative rooms for the blocking event\n            const altRooms = sortedRooms.filter(\n              r => r.id !== room.id && r.capacity >= blockingAttendees\n            );\n\n            for (const altRoom of altRooms) {\n              const altTimeline = timelines.get(altRoom.id)!;\n              const altStart = altTimeline.findEarliestSlot(\n                blockingEvent.duration,\n                getEarliestStartForEvent(blockingEvent, assignments),\n                endTime,\n                gap\n              );\n\n              if (altStart !== null) {\n                // Try the swap: move blocking to altRoom, place event in room\n                timeline.removeSlot(blocking.startTime, blocking.endTime);\n                const newPlacement = timeline.findEarliestSlot(event.duration, earliestStart, endTime, gap);\n\n                if (newPlacement !== null) {\n                  // Swap works!\n                  altTimeline.addSlot(altStart, altStart + blockingEvent.duration);\n                  timeline.addSlot(newPlacement, newPlacement + event.duration);\n\n                  assignments.set(blocking.eventId, {\n                    eventId: blocking.eventId,\n                    roomId: altRoom.id,\n                    startTime: altStart,\n                    endTime: altStart + blockingEvent.duration,\n                  });\n\n                  assignments.set(eventId, {\n                    eventId: event.id,\n                    roomId: room.id,\n                    startTime: newPlacement,\n                    endTime: newPlacement + event.duration,\n                  });\n\n                  unscheduled.splice(i, 1);\n                  improved = true;\n                  break;\n                } else {\n                  // Swap didn't work, restore\n                  timeline.addSlot(blocking.startTime, blocking.endTime);\n                }\n              }\n            }\n\n            if (improved) break;\n          }\n\n          if (improved) break;\n        }\n      }\n    }\n  }\n\n  return {\n    assignments: Array.from(assignments.values()),\n    unscheduled,\n  };\n}\n","structuredPatch":[{"oldStart":221,"oldLines":7,"newStart":221,"newLines":6,"lines":[" ","       for (const eventId of layer) {","         processing.push(eventId);","-        scheduled.add(eventId);"," ","         // Update in-degrees","         const deps = dependents.get(eventId);"]}],"userModified":false,"replaceAll":false}}
