d — skip\n      }\n    }\n\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const event of events) {\n    if (color.get(event.id) === WHITE) {\n      dfs(event.id);\n    }\n  }\n\n  return order;\n}\n\n/**\n * Tracks occupied time slots per room.\n */\nclass RoomTimeline {\n  private slots: Array<{ start: number; end: number }> = [];\n\n  addSlot(start: number, end: number): void {\n    this.slots.push({ start, end });\n    this.slots.sort((a, b) => a.start - b.start);\n  }\n\n  removeLastAdded(start: number, end: number): void {\n    const idx = this.slots.findIndex(s => s.start === start && s.end === end);\n    if (idx !== -1) {\n      this.slots.splice(idx, 1);\n    }\n  }\n\n  /**\n   * Find the earliest start time >= minStart where a slot of `duration` minutes\n   * can fit, respecting gaps and the overall time window.\n   */\n  findEarliestSlot(duration: number, minStart: number, windowEnd: number, gap: number): number | null {\n    let candidate = minStart;\n\n    for (const slot of this.slots) {\n      const slotStartWithGap = slot.start - gap;\n      const slotEndWithGap = slot.end + gap;\n\n      // If candidate + duration fits before this slot (with gap)\n      if (candidate + duration <= slotStartWithGap) {\n        break; // We can use `candidate`\n      }\n\n      // Otherwise, move candidate past this slot (with gap)\n      if (candidate < slotEndWithGap) {\n        candidate = slotEndWithGap;\n      }\n    }\n\n    // Check if the candidate fits within the window\n    if (candidate + duration <= windowEnd) {\n      return candidate;\n    }\n\n    return null;\n  }\n\n  /**\n   * Get all possible start times for a given duration, respecting gaps.\n   */\n  getAllPossibleStarts(duration: number, minStart: number, windowEnd: number, gap: number): number[] {\n    const starts: number[] = [];\n    let candidate = minStart;\n\n    // Collect gap intervals\n    const blocked: Array<{ start: number; end: number }> = [];\n    for (const slot of this.slots) {\n      blocked.push({ start: slot.start - gap, end: slot.end + gap });\n    }\n\n    // Merge overlapping blocked intervals\n    blocked.sort((a, b) => a.start - b.start);\n    const merged: Array<{ start: number; end: number }> = [];\n    for (const b of blocked) {\n      if (merged.length > 0 && b.start <= merged[merged.length - 1].end) {\n        merged[merged.length - 1].end = Math.max(merged[merged.length - 1].end, b.end);\n      } else {\n        merged.push({ ...b });\n      }\n    }\n\n    // Find all free windows\n    let freeStart = candidate;\n    for (const b of merged) {\n      if (freeStart < b.start) {\n        // Free window: [freeStart, b.start)\n        if (freeStart + duration <= Math.min(b.start, windowEnd)) {\n          starts.push(freeStart);\n        }\n      }\n      freeStart = Math.max(freeStart, b.end);\n    }\n    // After all blocked intervals\n    if (freeStart + duration <= windowEnd) {\n      starts.push(freeStart);\n    }\n\n    return starts;\n  }\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  // Topological sort (throws on cycles)\n  const topoOrder = topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  // Sort rooms by capacity ascending for best-fit matching\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // State tracking\n  const timelines = new Map<string, RoomTimeline>();\n  for (const room of rooms) {\n    timelines.set(room.id, new RoomTimeline());\n  }\n\n  const assignments = new Map<string, Assignment>();\n  const unscheduled: string[] = [];\n\n  // For each event in topological order, compute earliest possible start\n  // based on prerequisites\n  function getEarliestStartForEvent(event: Event): number {\n    let earliest = startTime;\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        const prereqAssignment = assignments.get(prereqId);\n        if (prereqAssignment) {\n          earliest = Math.max(earliest, prereqAssignment.endTime + gap);\n        } else {\n          // Prerequisite not scheduled — this event can't be scheduled\n          return -1;\n        }\n      }\n    }\n    return earliest;\n  }\n\n  // Try to schedule an event, returning the best assignment or null\n  function tryScheduleEvent(event: Event): Assignment | null {\n    const attendees = event.attendees ?? 1;\n    const earliestStart = getEarliestStartForEvent(event);\n    if (earliestStart === -1) return null;\n\n    // Filter rooms by capacity\n    const eligibleRooms = sortedRooms.filter(r => r.capacity >= attendees);\n    if (eligibleRooms.length === 0) return null;\n\n    // Order rooms: preferred room first, then by capacity (best fit)\n    const orderedRooms = [...eligibleRooms];\n    if (event.preferredRoom) {\n      const prefIdx = orderedRooms.findIndex(r => r.id === event.preferredRoom);\n      if (prefIdx > 0) {\n        const [prefRoom] = orderedRooms.splice(prefIdx, 1);\n        orderedRooms.unshift(prefRoom);\n      }\n    }\n\n    let bestAssignment: Assignment | null = null;\n\n    for (const room of orderedRooms) {\n      const timeline = timelines.get(room.id)!;\n      const slotStart = timeline.findEarliestSlot(event.duration, earliestStart, endTime, gap);\n\n      if (slotStart !== null) {\n        const candidate: Assignment = {\n          eventId: event.id,\n          roomId: room.id,\n          startTime: slotStart,\n          endTime: slotStart + event.duration,\n        };\n\n        if (!bestAssignment || slotStart < bestAssignment.startTime) {\n          bestAssignment = candidate;\n        }\n\n        // If this is the preferred room and it works, use it\n        if (ro