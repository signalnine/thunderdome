sites involving event \"${prereqId}\"`);\n        }\n        if (prereqColor === WHITE) {\n          dfs(prereqId);\n        }\n      }\n    }\n\n    color.set(id, BLACK);\n    order.push(id);\n  }\n\n  for (const event of events) {\n    if (color.get(event.id) === WHITE) {\n      dfs(event.id);\n    }\n  }\n\n  return order;\n}\n\n/**\n * Tracks occupied time slots per room and supports efficient queries.\n */\nclass RoomTimeline {\n  private slots: Array<{ start: number; end: number }> = [];\n\n  addSlot(start: number, end: number): void {\n    this.slots.push({ start, end });\n    this.slots.sort((a, b) => a.start - b.start);\n  }\n\n  removeSlot(start: number, end: number): void {\n    const idx = this.slots.findIndex(s => s.start === start && s.end === end);\n    if (idx !== -1) {\n      this.slots.splice(idx, 1);\n    }\n  }\n\n  /**\n   * Find the earliest start time >= minStart where a slot of `duration` minutes\n   * can fit, respecting gaps and the overall time window.\n   */\n  findEarliestSlot(duration: number, minStart: number, windowEnd: number, gap: number): number | null {\n    let candidate = minStart;\n\n    for (const slot of this.slots) {\n      // If candidate + duration fits before this slot (with gap before it)\n      if (candidate + duration <= slot.start - gap) {\n        break;\n      }\n\n      // Move candidate past this slot plus gap\n      if (candidate < slot.end + gap) {\n        candidate = slot.end + gap;\n      }\n    }\n\n    if (candidate + duration <= windowEnd) {\n      return candidate;\n    }\n\n    return null;\n  }\n\n}\n\nexport function schedule(events: Event[], rooms: Room[], options: ScheduleOptions): ScheduleResult {\n  if (events.length === 0) {\n    return { assignments: [], unscheduled: [] };\n  }\n\n  const gap = options.gap ?? 15;\n  const { startTime, endTime } = options;\n\n  // Topological sort — validates no cycles exist (throws on cycles)\n  topologicalSort(events);\n\n  const eventMap = new Map<string, Event>();\n  for (const event of events) {\n    eventMap.set(event.id, event);\n  }\n\n  // Sort rooms by capacity ascending for best-fit matching\n  const sortedRooms = [...rooms].sort((a, b) => a.capacity - b.capacity);\n\n  // Build dependency graph info for scheduling priority\n  const dependents = new Map<string, Set<string>>(); // event -> events that depend on it\n  const depthCache = new Map<string, number>();\n\n  for (const event of events) {\n    if (event.prerequisites) {\n      for (const prereqId of event.prerequisites) {\n        if (!dependents.has(prereqId)) {\n          dependents.set(prereqId, new Set());\n        }\n        dependents.get(prereqId)!.add(event.id);\n      }\n    }\n  }\n\n  // Compute chain depth (how many events depend on this one transitively)\n  function getChainDepth(eventId: string): number {\n    if (depthCache.has(eventId)) return depthCache.get(eventId)!;\n\n    const deps = dependents.get(eventId);\n    if (!deps || deps.size === 0) {\n      depthCache.set(eventId, 0);\n      return 0;\n    }\n\n    let maxDepth = 0;\n    for (const depId of deps) {\n      maxDepth = Math.max(maxDepth, 1 + getChainDepth(depId));\n    }\n\n    depthCache.set(eventId, maxDepth);\n    return maxDepth;\n  }\n\n  // Strategy: process events in topological order, but within each \"layer\"\n  // (events whose prerequisites are all met), prioritize by:\n  //   1. Chain depth (events with more dependents first)\n  //   2. Fewer eligible rooms (more constrained first)\n  //   3. Longer duration (harder to fit)\n  function prioritySort(eventIds: string[]): string[] {\n    return [...eventIds].sort((a, b) => {\n      const evA = eventMap.get(a)!;\n      const evB = eventMap.get(b)!;\n\n      // Events with longer dependency chains go first\n      const depthDiff = getChainDepth(b) - getChainDepth(a);\n      if (depthDiff !== 0) return depthDiff;\n\n      // More constrained events (fewer eligible rooms) go first\n      const attendeesA = evA.attendees ?? 1;\n      const attendeesB = evB.attendees ?? 1;\n      const eligibleA = sortedRooms.filter(r => r.capacity >= attendeesA).length;\n      const eligibleB = sortedRooms.filter(r => r.capacity >= attendeesB).length;\n      if (eligibleA !== eligibleB) return eligibleA - eligibleB;\n\n      // Longer events go first (harder to place)\n      return evB.duration - evA.duration;\n    });\n  }\n\n  // Main scheduling with backtracking support\n  function solveSchedule(): { assignments: Map<string, Assignment>; timelines: Map<string, RoomTimeline> } {\n    const timelines = new Map<string, RoomTimeline>();\n    for (const room of rooms) {\n      timelines.set(room.id, new RoomTimeline());\n    }\n    const assignments = new Map<string, Assignment>();\n\n    // Reorder topological order with priority within layers\n    const scheduled = new Set<string>();\n    const processing: string[] = [];\n\n    // Build layers from topological order\n    const inDegree = new Map<string, number>();\n    for (const event of events) {\n      let deg = 0;\n      if (event.prerequisites) {\n        for (const prereqId of event.prerequisites) {\n          if (eventMap.has(prereqId)) deg++;\n        }\n      }\n      inDegree.set(event.id, deg);\n    }\n\n    // Kahn's algorithm with priority ordering per layer\n    const queue: string[] = [];\n    for (const [id, deg] of inDegree) {\n      if (deg === 0) queue.push(id);\n    }\n\n    while (queue.length > 0) {\n      // Sort current layer by priority\n      const layer = prioritySort(queue);\n      queue.length = 0;\n\n      for (const eventId of layer) {\n        processing.push(eventId);\n        scheduled.add(eventId);\n\n        // Update in-degrees\n        const deps = dependents.get(eventId);\n        if (deps) {\n          for (const depId of deps) {\n            const newDeg = (inDegree.get(depId) ?? 0) - 1;\n            inDegree.set(depId, newDeg);\n            if (newDeg === 0) {\n              queue.push(depId);\n            }\n 