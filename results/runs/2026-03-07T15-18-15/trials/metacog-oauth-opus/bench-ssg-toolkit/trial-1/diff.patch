index 0000000..a22d639
--- /dev/null
+++ b/src/plugins/markdown-ext.ts
@@ -0,0 +1,65 @@
+import { marked } from 'marked';
+import type { Plugin, ContentFile, BuildContext } from '../core/types.js';
+
+function processFootnotes(content: string): string {
+  const footnoteDefRegex = /^\[\^(\d+)\]:\s*(.+)$/gm;
+  const definitions = new Map<string, string>();
+  let match: RegExpExecArray | null;
+
+  while ((match = footnoteDefRegex.exec(content)) !== null) {
+    definitions.set(match[1], match[2]);
+  }
+
+  // Remove footnote definitions from content
+  let processed = content.replace(/^\[\^(\d+)\]:\s*(.+)$/gm, '');
+
+  // Replace inline footnote references with sup/a tags
+  processed = processed.replace(/\[\^(\d+)\]/g, (_m, id: string) => {
+    return `<sup><a href="#fn-${id}">${id}</a></sup>`;
+  });
+
+  // Append footnote section if there are definitions
+  if (definitions.size > 0) {
+    let section = '<section class="footnotes"><ol>';
+    for (const [id, text] of definitions) {
+      section += `<li id="fn-${id}">${text}</li>`;
+    }
+    section += '</ol></section>';
+    processed += '\n' + section;
+  }
+
+  return processed;
+}
+
+function processAdmonitions(content: string): string {
+  return content.replace(
+    /^:::(\w+)\n([\s\S]*?)^:::/gm,
+    (_m, type: string, body: string) => {
+      return `<div class="admonition admonition-${type}">\n${body.trim()}\n</div>`;
+    }
+  );
+}
+
+export function createMarkdownExtPlugin(): Plugin {
+  return {
+    name: 'markdown-ext',
+    version: '1.0.0',
+    dependencies: [],
+    hooks: {
+      transformContent(file: ContentFile, _ctx: BuildContext): ContentFile {
+        let content = file.content;
+
+        // Process admonitions before markdown
+        content = processAdmonitions(content);
+
+        // Process footnotes before markdown
+        content = processFootnotes(content);
+
+        // Convert markdown to HTML
+        content = marked.parse(content, { async: false }) as string;
+
+        return { ...file, content };
+      },
+    },
+  };
+}
