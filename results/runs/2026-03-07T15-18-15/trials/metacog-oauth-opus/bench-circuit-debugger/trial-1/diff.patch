we find a swap, we conceptually fix it and continue.\n   110→\n   111→  // Working copy of gates that we can fix as we find swaps\n   112→  const fixedOutput: Map<string, string> = new Map(); // original out -> fixed out\n   113→\n   114→  function getEffectiveOut(g: Gate): string {\n   115→    return fixedOutput.get(g.out) ?? g.out;\n   116→  }\n   117→\n   118→  function swap(w1: string, w2: string): void {\n   119→    swapped.add(w1);\n   120→    swapped.add(w2);\n   121→\n   122→    // Find the gates that output w1 and w2 and swap them\n   123→    const g1 = gates.find(g => g.out === w1)!;\n   124→    const g2 = gates.find(g => g.out === w2)!;\n   125→    g1.out = w2;\n   126→    g2.out = w1;\n   127→\n   128→    // Rebuild lookup\n   129→    gateByOutput.set(w1, g2);\n   130→    gateByOutput.set(w2, g1);\n   131→  }\n   132→\n   133→  // Validate the structure bit by bit\n   134→  // For each bit, we expect certain structural patterns.\n   135→  //\n   136→  // The approach:\n   137→  // 1. For each bit, check that the expected gates exist with correct outputs\n   138→  // 2. When a violation is found, determine which wire is wrong and find its swap partner\n   139→\n   140→  // For bit 0: x00 XOR y00 -> z00, x00 AND y00 -> carry0\n   141→  const bit0Xor = findGate('XOR', 'x00', 'y00');\n   142→  const bit0And = findGate('AND', 'x00', 'y00');\n   143→\n   144→  if (!bit0Xor || !bit0And) {\n   145→    return []; // shouldn't happen in valid input\n   146→  }\n   147→\n   148→  let carry: string;\n   149→\n   150→  // Check bit 0 XOR outputs to z00\n   151→  if (bit0Xor.out !== 'z00') {\n   152→    // z00 is swapped with whatever bit0Xor outputs\n   153→    swap(bit0Xor.out, 'z00');\n   154→  }\n   155→  carry = bit0And.out;\n   156→\n   157→  // Check if carry from bit 0 is wrongly set to a z-wire (would indicate swap)\n   158→  // We'll catch this in the loop below.\n   159→\n   160→  for (let i = 1; i <= maxBit; i++) {\n   161→    const xi = `x${i.toString().p