-4e8e9948c055","tool_use_result":{"type":"update","filePath":"/workspace/src/index.ts","content":"export interface Gate {\n  op: 'AND' | 'OR' | 'XOR';\n  in1: string;\n  in2: string;\n  out: string;\n}\n\n/**\n * Simulate a logic gate circuit given gates and initial wire values.\n * Gates are processed in dependency order (topological sort).\n */\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>\n): Record<string, number> {\n  const wireValues: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n  let changed = true;\n\n  while (remaining.length > 0 && changed) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      const v1 = wireValues[gate.in1];\n      const v2 = wireValues[gate.in2];\n      if (v1 !== undefined && v2 !== undefined) {\n        wireValues[gate.out] = applyOp(gate.op, v1, v2);\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wireValues;\n}\n\nfunction applyOp(op: 'AND' | 'OR' | 'XOR', a: number, b: number): number {\n  switch (op) {\n    case 'AND':\n      return a & b;\n    case 'OR':\n      return a | b;\n    case 'XOR':\n      return a ^ b;\n  }\n}\n\nfunction isXYInput(wire: string): boolean {\n  return /^[xy]\\d+$/.test(wire);\n}\n\nfunction isZOutput(wire: string): boolean {\n  return /^z\\d+$/.test(wire);\n}\n\n/**\n * Find the 8 wires involved in 4 swapped pairs in a broken ripple-carry adder.\n *\n * Uses carry-chain walking to trace the adder structure bit by bit,\n * detecting and fixing structural violations as they're encountered.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Deep copy so we don't mutate input\n  const gs: Gate[] = gates.map((g) => ({ ...g }));\n  const swapped: Set<string> = new Set();\n\n  // Find the number of input bits\n  let maxBit = 0;\n  for (const g of gs) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n\n  const lastZWire = `z${(maxBit + 1).toString().padStart(2, '0')}`;\n\n  function findGate(op: string, w1: string, w2: string): Gate | undefined {\n    return gs.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))\n    );\n  }\n\n  function findGatesWithInput(op: string, w: string): Gate[] {\n    return gs.filter(\n      (g) => g.op === op && (g.in1 === w || g.in2 === w)\n    );\n  }\n\n  function otherInput(g: Gate, w: string): string {\n    return g.in1 === w ? g.in2 : g.in1;\n  }\n\n  function hasXYInputs(g: Gate): boolean {\n    return isXYInput(g.in1) && isXYInput(g.in2);\n  }\n\n  function gateByOutput(wire: string): Gate | undefined {\n    return gs.find((g) => g.out === wire);\n  }\n\n  function doSwap(w1: string, w2: string): void {\n    swapped.add(w1);\n    swapped.add(w2);\n    const g1 = gs.find((g) => g.out === w1)!;\n    const g2 = gs.find((g) => g.out === w2)!;\n    g1.out = w2;\n    g2.out = w1;\n  }\n\n  // Carry-chain walk: trace the adder structure bit by bit\n\n  // Bit 0\n  const bit0Xor = findGate('XOR', 'x00', 'y00')!;\n  const bit0And = findGate('AND', 'x00', 'y00')!;\n\n  if (bit0Xor.out !== 'z00') {\n    doSwap(bit0Xor.out, 'z00');\n  }\n\n  let carry = bit0And.out;\n\n  // Check if bit0 carry is a z-wire (swapped)\n  if (isZOutput(carry) && carry !== lastZWire) {\n    // The carry from bit 0 shouldn't be a z-wire.\n    // Find what should produce this z-wire (a non-xy XOR gate)\n    const zGate = gateByOutput(carry);\n    if (zGate && zGate.op === 'AND') {\n      // Find the XOR gate that should produce this z wire\n      // It should be an XOR gate with non-xy inputs\n      for (const g of gs) {\n        if (g.op === 'XOR' && !hasXYInputs(g) && !isZOutput(g.out)) {\n          // Check if this could be the partner: look for one that\n          // is supposed to produce the z-wire that carry currently holds\n          doSwap(carry, g.out);\n          carry = bit0And.out; // re-read after swap\n          break;\n        }\n      }\n    }\n  }\n\n  for (let i = 1; i <= maxBit && swapped.size < 8; i++) {\n    const xi = `x${i.toString().padStart(2, '0')}`;\n    const yi = `y${i.toString().padStart(2, '0')}`;\n    const zi = `z${i.toString().padStart(2, '0')}`;\n\n    // Step 1: xNN XOR yNN -> partialSum\n    const xorGate = findGate('XOR', xi, yi)!;\n    let partialSum = xorGate.out;\n\n    // Step 2: partialSum XOR carry -> zNN\n    let sumGate = findGate('XOR', partialSum, carry);\n\n    if (!sumGate) {\n      // Either partialSum or carry is wrong.\n\n      // Look for an XOR gate (not xorGate) that uses carry as input\n      const carryXors = findGatesWithInput('XOR', carry).filter(\n        (g) => g !== xorGate\n      );\n\n      if (carryXors.length === 1) {\n        // Found: the other input should be partialSum\n        const expectedPartialSum = otherInput(carryXors[0], carry);\n        doSwap(partialSum, expectedPartialSum);\n        partialSum = xorGate.out;\n        sumGate = carryXors[0];\n      } else {\n        // Look for an XOR gate that uses partialSum as input\n        const psXors = findGatesWithInput('XOR', partialSum).filter(\n          (g) => g !== xorGate\n        );\n        if (psXors.length === 1) {\n          const expectedCarry = otherInput(psXors[0], partialSum);\n          doSwap(carry, expectedCarry);\n          carry = expectedCarry;\n          sumGate = psXors[0];\n        } else {\n          // Neither input found in a sum XOR. This can happen if\n          // partialSum got swapped with a wire that's not used by any XOR.\n          // Check: is partialSum a z-wire? That would be wrong for a partial sum.\n          if (isZOutput(partialSum)) {\n            // Find the non-xy XOR gate that should produce this z wire\n            for (const g of gs) {\n              if (g.op === 'XOR' && !hasXYInputs(g) && g.out !== partialSum && !isZOutput(g.out)) {\n                // Possible swap partner\n                doSwap(partialSum, g.out);\n                partialSum = xorGate.out;\n                sumGate = findGate('XOR', partialSum, carry) ?? undefined;\n                break;\n              }\n            }\n          }\n        }\n      }\n    }\n\n    if (!sumGate) continue;\n\n    // Check that sumGate outputs to zNN\n    if (sumGate.out !== zi) {\n      doSwap(sumGate.out, zi);\n    }\n\n    // Step 3: xNN AND yNN -> generate\n    const genGate = findGate('AND', xi, yi)!;\n\n    // Step 4: partialSum AND carry -> propagate\n    const propGate = findGate('AND', partialSum, carry);\n\n    if (!propGate) {\n      // Try to find carry via genGate's OR connection\n      const orGates = findGatesWithInput('OR', genGate.out);\n      if (orGates.length === 1) {\n        carry = orGates[0].out;\n      }\n      continue;\n    }\n\n    // Step 5: generate OR propagate -> carryOut\n    const orGate = findGate('OR', genGate.out, propGate.out);\n\n    if (!orGate) {\n      // One of genGate.out or propGate.out is swapped\n      const orWithGen = findGatesWithInput('OR', genGate.out);\n      const orWithProp = findGatesWithInput('OR', propGate.out);\n\n      if (orWithGen.length >= 1 && orWithProp.length === 0) {\n        const expectedProp = otherInput(orWithGen[0], genGate.out);\n        doSwap(propGate.out, expectedProp);\n        carry = orWithGen[0].out;\n      } else if (orWithProp.length >= 1 && orWithGen.length === 0) {\n        const expectedGen = otherInput(orWithProp[0], propGate.out);\n        doSwap(genGate.out, expectedGen);\n        carry = orWithProp[0].out;\n      } else {\n        continue;\n      }\n    } else {\n      carry = orGate.out;\n    }\n  }\n\n  // Check final carry\n  if (carry !== lastZWire && swapped.size < 8) {\n    doSwap(carry, lastZWire);\n  }\n\n  return [...swapped].sort();\n}\n","structuredPatch":[{"oldStart":56,"oldLines":9,"newStart":56,