});\n    expect(result.c).toBe(1);\n    expect(result.e).toBe(1);\n  });\n\n  it('should handle gates listed out of dependency order', () => {\n    const gates: Gate[] = [\n      { op: 'OR', in1: 'c', in2: 'd', out: 'e' },\n      { op: 'AND', in1: 'a', in2: 'b', out: 'c' },\n    ];\n    const result = simulate(gates, { a: 1, b: 0, d: 1 });\n    expect(result.c).toBe(0);\n    expect(result.e).toBe(1);\n  });\n\n  it('should simulate a correct 4-bit adder: 3+5=8', () => {\n    const gates: Gate[] = [\n      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },\n      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },\n      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },\n      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },\n      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },\n      { op: 'AND', in1: 't01', in2: 'c00', out: 'b01' },\n      { op: 'OR', in1: 'a01', in2: 'b01', out: 'c01' },\n      { op: 'XOR', in1: 'x02', in2: 'y02', out: 't02' },\n      { op: 'XOR', in1: 't02', in2: 'c01', out: 'z02' },\n      { op: 'AND', in1: 'x02', in2: 'y02', out: 'a02' },\n      { op: 'AND', in1: 't02', in2: 'c01', out: 'b02' },\n      { op: 'OR', in1: 'a02', in2: 'b02', out: 'c02' },\n      { op: 'XOR', in1: 'x03', in2: 'y03', out: 't03' },\n      { op: 'XOR', in1: 't03', in2: 'c02', out: 'z03' },\n      { op: 'AND', in1: 'x03', in2: 'y03', out: 'a03' },\n      { op: 'AND', in1: 't03', in2: 'c02', out: 'b03' },\n      { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },\n    ];\n    const inputs: Record<string, number> = {\n      x00: 1, x01: 1, x02: 0, x03: 0,\n      y00: 1, y01: 0, y02: 1, y03: 0,\n    };\n    const result = simulate(gates, inputs);\n    expect(result.z00).toBe(0);\n    expect(result.z01).toBe(0);\n    expect(result.z02).toBe(0);\n    expect(result.z03).toBe(1);\n    expect(result.z04).toBe(0);\n  });\n\n  it('should preserve all input wire values', () => {\n    const gates: Gate[] = [{ op: 'AND', in1: 'a', in2: 'b', out: 'c' }];\n    const result = simulate(gates, { a: 1, b: 0 });\n    expect(result.a).toBe(1);\n    expect(result.b).toBe(0);\n    expect(result.c).toBe(0);\n  });\n});\n\ndescribe('findSwappedWires', () => {\n  // Build an N-bit adder with controlled wire names\n  function makeAdder(bits: number): {\n    gates: Gate[];\n    wireNames: Record<string, string>;\n  } {\n    const gates: Gate[] = [];\n    const wireNames: Record<string, string> = {};\n\n    // Bit 0\n    gates.push({ op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' });\n    const c0 = `carry_0`;\n    wireNames['c0'] = c0;\n    gates.push({ op: 'AND', in1: 'x00', in2: 'y00', out: c0 });\n\n    let carry = c0;\n    for (let i = 1; i < bits; i++) {\n      const pad = i.toString().padStart(2, '0');\n      const xi = `x${pad}`;\n      const yi = `y${pad}`;\n      const zi = `z${pad}`;\n\n      const t = `partial_${pad}`;\n      const a = `gen_${pad}`;\n      const b = `prop_${pad}`;\n      const c = `carry_${pad}`;\n\n      wireNames[`t${pad}`] = t;\n      wireNames[`a${pad}`] = a;\n      wireNames[`b${pad}`] = b;\n      wireNames[`c${pad}`] = c;\n\n      gates.push({ op: 'XOR', in1: xi, in2: yi, out: t });\n      gates.push({ op: 'XOR', in1: t, in2: carry, out: zi });\n      gates.push({ op: 'AND', in1: xi, in2: yi, out: a });\n      gates.push({ op: 'AND', in1: t, in2: carry, out: b });\n      gates.push({ op: 'OR', in1: a, in2: b, out: c });\n      carry = c;\n    }\n\n    // Last carry = last z wire\n    const lastGate = gates[gates.length - 1];\n    const lastZ = `z${bits.toString().padStart(2, '0')}`;\n    lastGate.out = lastZ;\n    wireNames[`c${(bits - 1).toString().padStart(2, '0')}`] = lastZ;\n\n    return { gates, wireNames };\n  }\n\n  function swapOutputs(gates: Gate[], w1: string, w2: string): void {\n    const g1 = gates.find((g) => g.out === w1)!;\n    const g2 = gates.find((g) => g.out === w2)!;\n    g1.out = w2;\n    g2.out = w1;\n  }\n\n  it('should detect swapped z-wire with non-XOR gate output', () => {\n    // Swap z01 with a01 (z wire from AND gate = obvious rule violation)\n    const { gates, wireNames } = makeAdder(4);\n    const a01 = wireNames['a01'];\n\n    // 4 swaps required, use detectable ones\n    swapOutputs(gates, 'z01', a01);\n    swapOutputs(gates, 'z02', wireNames['a02']);\n    swapOutputs(gates, 'z03', wireNames['a03']);\n    swapOutputs(gates, 'z04', wireNames['c02']);\n\n    const result = findSwappedWires(gates);\n    expect(result.length).toBe(8);\n    const expected = [\n      'z01', a01,\n      'z02', wireNames['a02'],\n      'z03', wireNames['a03'],\n      'z04', wireNames['c02'],\n    ].sort();\n    expect(result).toEqual(expected);\n  });\n\n  it('should detect carry-chain swaps via chain walking', () => {\n    const { gates, wireNames } = makeAdder(8);\n\n    // Swap carry with z-wire (detectable: OR output is z-wire)\n    swapOutputs(gates, wireNames['c01'], 'z02');\n    // Swap partial sum with generate carry (detectable: XOR output not used by XOR)\n    swapOutputs(gates, wireNames['t03'], wireNames['a03']);\n    // Swap z-wire with propagate carry (detectable: z from AND)\n    swapOutputs(gates, 'z05', wireNames['b05']);\n    // Swap last carry (z08 really) with something\n    swapOutputs(gates, 'z08', wireNames['c06']);\n\n    const result = findSwappedWires(gates);\n    expect(result.length).toBe(8);\n    const expected = [\n      wireNames['c01'], 'z02',\n      wireNames['t03'], wireNames['a03'],\n      'z05', wireNames['b05'],\n      'z08', wireNames['c06'],\n    ].sort();\n    expect(result).toEqual(expected);\n  });\n\n  it('should return sorted array of exactly 8 wires', () => {\n    const { gates, wireNames } = makeAdder(6);\n\n    swapOutputs(gates, 'z01', wireNames['b01']);\n    swapOutputs(gates, wireNames['t02'], wireNames['a02']);\n    swapOutputs(gates, 'z04', wireNames['c03']);\n    swapOutputs(gates, 'z06', wireNames['c04']);\n\n    const result = findSwappedWires(gates);\n    expect(result.length).toBe(8);\n    // Check sorted\n    for (let i = 1; i < result.length; i++) {\n      expect(result[i] >= result[i - 1]).toBe(true);\n    }\n  });\n\n  it('should handle a large 45-bit adder', () => {\n    const { gates, wireNames } = makeAdder(45);\n\n    swapOutputs(gates, 'z10', wireNames['a10']);\n    swapOutputs(gates, 'z20', wireNames['b20']);\n    swapOutputs(gates, 'z30', wireNames['c29']);\n    swapOutputs(gates, 'z45', wireNames['c43']);\n\n    const result = findSwappedWires(gates);\n    expect(result.length).toBe(8);\n    const expected = [\n      'z10', wireNames['a10'],\n      'z20', wireNames['b20'],\n      'z30', wireNames['c29'],\n      'z45', wireNames['c43'],\n    ].sort();\n    expect(result).toEqual(expected);\n  });\n});\n","structuredPatch":[{"oldStart":53,"oldLines":7,"newStart":53,"newLines":6,"lines":["   });"," ","   it('should simulate a correct 4-bit adder: 3+5=8', () => {","-    // 3 = 0011, 5 = 0101, result = 1000 = 8","     const gates: Gate[] = [","       { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },","       { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },"]},{"oldStart":74,"oldLines":8,"newStart":73,"newLines":8,"lines":["       { op: 'OR', in1: 'a03', in2: 'b03', out: 'z04' },","     ];","     const inputs: Record<string, number> = {","-      x00: 1, x01: 1, x02: 0, x03: 0, // 3","-      y00: 1, y01: 0, y02: 1, y03: 0, // 5","+      x00: 1, x01: 1, x02: 0, x03: 0,","+      y00: 1, y01: 0, y02: 1, y03: 0,","     };","     const result = simulate(gates, inputs);","     expect(result.z00).toBe(0);"]},{"oldStart":95,"oldLines":26,"newStart":94,"newLines":52,"lines":[" });"," "," describe('findSwappedWires', () => {","-  function make4BitAdder(): Gate[] {","-    return [","-      { op: 'XOR', in1: 'x00', in2: 'y00', out: 'z00' },","-      { op: 'AND', in1: 'x00', in2: 'y00', out: 'c00' },","-      { op: 'XOR', in1: 'x01', in2: 'y01', out: 't01' },","-      { op: 'XOR', in1: 't01', in2: 'c00', out: 'z01' },","-      { op: 'AND', in1: 'x01', in2: 'y01', out: 'a01' },","-  