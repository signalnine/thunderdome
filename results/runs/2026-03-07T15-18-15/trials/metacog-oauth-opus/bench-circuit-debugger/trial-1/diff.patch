arge 45-bit adder', () => {\n    const { gates, wireNames } = makeAdder(45);\n\n    swapOutputs(gates, 'z10', wireNames['a10']);\n    swapOutputs(gates, 'z20', wireNames['b20']);\n    swapOutputs(gates, 'z30', wireNames['c29']);\n    swapOutputs(gates, 'z45', wireNames['c43']);\n\n    const result = findSwappedWires(gates);\n    expect(result.length).toBe(8);\n    const expected = [\n      'z10', wireNames['a10'],\n      'z20', wireNames['b20'],\n      'z30', wireNames['c29'],\n      'z45', wireNames['c43'],\n    ].sort();\n    expect(result).toEqual(expected);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":13053,"cache_read_input_tokens":41567,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":13053},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"2842fe93-5727-4ed9-80db-c1b2cf80bde6","uuid":"baa249eb-28e1-4885-ae97-66692f7dbe7e"}
