n dependency order (topological sort).\n */\nexport function simulate(\n  gates: Gate[],\n  inputs: Record<string, number>\n): Record<string, number> {\n  const wireValues: Record<string, number> = { ...inputs };\n  const remaining = [...gates];\n  let changed = true;\n\n  while (remaining.length > 0 && changed) {\n    changed = false;\n    for (let i = remaining.length - 1; i >= 0; i--) {\n      const gate = remaining[i];\n      const v1 = wireValues[gate.in1];\n      const v2 = wireValues[gate.in2];\n      if (v1 !== undefined && v2 !== undefined) {\n        wireValues[gate.out] = applyOp(gate.op, v1, v2);\n        remaining.splice(i, 1);\n        changed = true;\n      }\n    }\n  }\n\n  return wireValues;\n}\n\nfunction applyOp(op: 'AND' | 'OR' | 'XOR', a: number, b: number): number {\n  switch (op) {\n    case 'AND':\n      return a & b;\n    case 'OR':\n      return a | b;\n    case 'XOR':\n      return a ^ b;\n  }\n}\n\nfunction isXYInput(wire: string): boolean {\n  return /^[xy]\\d+$/.test(wire);\n}\n\nfunction isZOutput(wire: string): boolean {\n  return /^z\\d+$/.test(wire);\n}\n\n/**\n * Find the 8 wires involved in 4 swapped pairs in a broken ripple-carry adder.\n *\n * Uses a hybrid approach:\n * 1. Rule-based: apply structural rules to identify obvious violations\n * 2. Carry-chain walking: trace the adder structure bit by bit, fixing swaps as found\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  // Deep copy so we don't mutate input\n  const gs: Gate[] = gates.map((g) => ({ ...g }));\n  const swapped: Set<string> = new Set();\n\n  // Find the number of input bits\n  let maxBit = 0;\n  for (const g of gs) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n\n  const lastZWire = `z${(maxBit + 1).toString().padStart(2, '0')}`;\n\n  function findGate(op: string, w1: string, w2: string): Gate | undefined {\n    return gs.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))\n    );\n  }\n\n  function findGatesWithInput(op: string, w: string): Gate[] {\n    return gs.filter(\n      (g) => g.op === op && (g.in1 === w || g.in2 === w)\n    );\n  }\n\n  function findGatesThatUse(w: string): Gate[] {\n    return gs.filter((g) => g.in1 === w || g.in2 === w);\n  }\n\n  function otherInput(g: Gate, w: string): string {\n    return g.in1 === w ? g.in2 : g.in1;\n  }\n\n  function doSwap(w1: string, w2: string): void {\n    swapped.add(w1);\n    swapped.add(w2);\n    const g1 = gs.find((g) => g.out === w1)!;\n    const g2 = gs.find((g) => g.out === w2)!;\n    g1.out = w2;\n    g2.out = w1;\n  }\n\n  function hasXYInputs(g: Gate): boolean {\n    return isXYInput(g.in1) && isXYInput(g.in2);\n  }\n\n  // Apply structural rules iteratively until no more swaps are found\n  let foundSwap = true;\n  while (foundSwap && swapped.size < 8) {\n    foundSwap = false;\n\n    for (const g of gs) {\n      // Rule 1: XOR gates that DON'T take x/y inputs must output to z wire\n      // (these are the \"sum\" XOR gates: partialSum XOR carry -> zNN)\n      if (g.op === 'XOR' && !hasXYInputs(g)) {\n        if (!isZOutput(g.out)) {\n          // This gate should output a z wire but doesn't.\n          // Find what's producing the z wire that should be here.\n          // We need to find which z wire this gate should produce.\n          // Use carry-chain walk to determine this.\n          // For now, flag this wire as suspicious.\n          // Actually, we can just check: there must be a z wire somewhere\n          // that is produced by a non-XOR gate (its swap partner).\n          // Find z wires produced by non-XOR gates (except the last one which is OR output)\n          for (const gz of gs) {\n            if (\n              isZOutput(gz.out) &&\n              gz.out !== lastZWire &&\n              gz.op !== 'XOR'\n            ) {\n              doSwap(g.out, gz.out);\n              foundSwap = true;\n              break;\n            }\n          }\n          if (foundSwap) break;\n        }\n      }\n\n      // Rule 2: z wires (except last) must come from XOR gates\n      if (isZOutput(g.out) && g.out !== lastZWire && g.op !== 'XOR') {\n        // This z wire should come from an XOR gate but doesn't.\n        // Find a non-z XOR output that should be this z wire.\n        for (const gx of gs) {\n          if (\n            gx.op === 'XOR' &&\n            !hasXYInputs(gx) &&\n            !isZOutput(gx.out)\n          ) {\n            doSwap(g.out, gx.out);\n            foundSwap = true;\n            break;\n          }\n        }\n        if (foundSwap) break;\n      }\n\n      // Rule 3: XOR gates with x/y inputs (partial sum) should feed into\n      // another XOR gate and an AND gate (except bit 0 which feeds into z00 directly)\n      if (g.op === 'XOR' && hasXYInputs(g) && g.out !== 'z00') {\n        const usedByXor = findGatesWithInput('XOR', g.out);\n        const usedByAnd = findGatesWithInput('AND', g.out);\n        if (usedByXor.length === 0 && usedByAnd.length === 0) {\n          // This partial sum isn't used correctly - it's been swapped.\n          // It should be used by an XOR and AND gate.\n          // The correct partialSum wire should be one of the inputs\n          // of a sum XOR gate that has a carry as the other input.\n          // This is a more complex case - handle in carry chain walk.\n        }\n      }\n\n      // Rule 4: AND gate outputs should be used by an OR gate\n      // (except bit 0's AND which can directly be the carry)\n      if (g.op === 'AND' && !hasXYInputs(g)) {\n        // Non-x/y AND gates (propagate carry) should feed into OR\n        const usedByOr = findGatesWithInput('OR', g.out);\n        if (usedByOr.length === 0) {\n          // This output is wrong - should be used by an OR gate\n          // Find what it's actually used by, and find the OR gate\