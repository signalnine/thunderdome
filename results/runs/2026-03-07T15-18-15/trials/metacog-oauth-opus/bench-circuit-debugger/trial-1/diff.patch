t: b });\n      gates.push({ op: 'OR', in1: a, in2: b, out: c });\n      carry = c;\n    }\n    // Final carry\n    const lastGate = gates[gates.length - 1];\n    lastGate.out = 'z08';\n\n    // Swap 4 pairs\n    swapOutputs(gates, 'z01', randomNames[1]); // z01 <-> def (t01)\n    swapOutputs(gates, 'z03', randomNames[9]); // z03 <-> bbc (t03... actually let's check)\n    swapOutputs(gates, randomNames[4], randomNames[5]); // ghi <-> jkl (a/b at bit1? no...)\n    swapOutputs(gates, 'z08', randomNames[24]); // z08 <-> qqr\n\n    const result = findSwappedWires(gates);\n    expect(result.length).toBe(8);\n    expect(result).toEqual(\n      [\n        'z01', randomNames[1],\n        'z03', randomNames[9],\n        randomNames[4], randomNames[5],\n        'z08', randomNames[24],\n      ].sort()\n    );\n  });\n});\n"}}
