s z(N+1).\n *\n * We detect structural violations and identify swaps.\n */\nexport function findSwappedWires(gates: Gate[]): string[] {\n  const swapped: Set<string> = new Set();\n\n  // Build lookup structures\n  const gateByOutput: Map<string, Gate> = new Map();\n  for (const g of gates) {\n    gateByOutput.set(g.out, g);\n  }\n\n  // Find the number of input bits by finding the highest x## wire\n  let maxBit = 0;\n  for (const g of gates) {\n    for (const w of [g.in1, g.in2]) {\n      const m = w.match(/^x(\\d+)$/);\n      if (m) {\n        maxBit = Math.max(maxBit, parseInt(m[1], 10));\n      }\n    }\n  }\n\n  // Helper: find gate by op and input wires (unordered)\n  function findGate(op: string, w1: string, w2: string): Gate | undefined {\n    return gates.find(\n      (g) =>\n        g.op === op &&\n        ((g.in1 === w1 && g.in2 === w2) || (g.in1 === w2 && g.in2 === w1))\n    );\n  }\n\n  // Helper: find gate that uses a given wire as input with a given op\n  function findGateWithInput(op: string, w: string): Gate | undefined {\n    return gates.find(\n      (g) => g.op === op && (g.in1 === w || g.in2 === w)\n    );\n  }\n\n  // Helper: get the other input of a gate\n  function otherInput(g: Gate, w: string): string {\n    return g.in1 === w ? g.in2 : g.in1;\n  }\n\n  // We'll validate the structure bit by bit and detect violations.\n  // When we find a swap, we conceptually fix it and continue.\n\n  // Working copy of gates that we can fix as we find swaps\n  const fixedOutput: Map<string, string> = new Map(); // original out -> fixed out\n\n  function getEffectiveOut(g: Gate): string {\n    return fixedOutput.get(g.out) ?? g.out;\n  }\n\n  function swap(w1: string, w2: string): void {\n    swapped.add(w1);\n    swapped.add(w2);\n\n    // Find the gates that output w1 and w2 and swap them\n    const g1 = gates.find(g => g.out === w1)!;\n    const g2 = gates.find(g => g.out === w2)!;\n    g1.out = w2;\n    g2.out = w1;\n\n    // Rebuild lookup\n    gateByOutput.set(w1, g2);\n    gateByOutput.set(w2, g1);\n  }\n\n  // Validate the structure bit by bit\n  // For each bit, we expect certain structural patterns.\n  //\n  // The approach:\n  // 1. For each bit, check that the expected gates exist with correct outputs\n  // 2. When a violation is found, determine which wire is wrong and find its swap partner\n\n  // For bit 0: x00 XOR y00 -> z00, x00 AND y00 -> carry0\n  const bit0Xor = findGate('XOR', 'x00', 'y00');\n  const bit0And = findGate('AND', 'x00', 'y00');\n\n  if (!bit0Xor || !bit0And) {\n    return []; // shouldn't happen in valid input\n  }\n\n  let carry: string;\n\n  // Check bit 0 XOR outputs to z00\n  if (bit0Xor.out !== 'z00') {\n    // z00 is swapped with whatever bit0Xor outputs\n    swap(bit0Xor.out, 'z00');\n  }\n  carry = bit0And.out;\n\n  // Check if carry from bit 0 is wrongly set to a z-wire (would indicate swap)\n  // We'll catch this in the loop below.\n\n  for (let i = 1; i <= maxBit; i++) {\n    const xi = `x${i.toString().padStart(2, '0')}`;\n    const yi = `y${i.toString().padStart(2, '0')}`;\n    const zi = `z${i.toString().padStart(2, '0')}`;\n\n    // Step 1: Find xNN XOR yNN -> tNN (partial sum)\n    const xorGate = findGate('XOR', xi, yi);\n    if (!xorGate) continue;\n\n    let partialSum = xorGate.out;\n\n    // Step 2: Find partialSum XOR carry -> zNN (final sum)\n    let sumGate = findGate('XOR', partialSum, carry);\n\n    if (!sumGate) {\n      // Either partialSum or carry is wrong.\n      // Check if there's an XOR gate using carry - if so, partialSum might be swapped\n      const carryXor = findGateWithInput('XOR', carry);\n      if (carryXor && carryXor !== xorGate) {\n        // The other input should be partialSum but isn't\n        const expectedPartialSum = otherInput(carryXor, carry);\n        // partialSum (xorGate.out) is swapped with expectedPartialSum\n        swap(partialSum, expectedPartialSum);\n        partialSum = xorGate.out; // after swap, xorGate.out is now expectedPartialSum\n        sumGate = carryXor;\n      } else {\n        // Check if there's an XOR gate using partialSum\n        const psXor = findGateWithInput('XOR', partialSum);\n        if (psXor && psXor !== xorGate) {\n          const expectedCarry = otherInput(psXor, partialSum);\n          // carry is swapped with expectedCarry\n          swap(carry, expectedCarry);\n          carry = expectedCarry; // but after swap, the gate that had carry now has expectedCarry\n          // Actually after swap, we need to re-check\n          sumGate = psXor;\n        }\n      }\n    }\n\n    if (!sumGate) continue;\n\n    // Check that sumGate outputs to zNN\n    if (sumGate.out !== zi) {\n      swap(sumGate.out, zi);\n    }\n\n    // Step 3: Find xNN AND yNN -> aNN (generate carry)\n    const andGate = findGate('AND', xi, yi);\n    if (!andGate) continue;\n\n    // Step 4: Find partialSum AND carry -> bNN (propagate carry)\n    const propGate = findGate('AND', partialSum, carry);\n    // If propGate is missing, it could be because partialSum or carry got swapped above\n    // and we need to re-lookup\n\n    if (!propGate) continue;\n\n    // Step 5: Find aNN OR bNN -> cNN (carry out)\n    const orGate = findGate('OR', andGate.out, propGate.out);\n\n    if (!orGate) {\n      // One of andGate.out or propGate.out might be swapped\n      // Try to find an OR gate using one of them\n      const orWithAnd = findGateWithInput('OR', andGate.out);\n      const orWithProp = findGateWithInput('OR', propGate.out);\n\n      if (orWithAnd && !orWithProp) {\n        const expectedProp = otherInput(orWithAnd, andGate.out);\n        swap(propGate.out, expectedProp);\n        carry = orWithAnd.out;\n      } else if (orWithProp && !orWithAnd) {\n        const expectedAnd = otherInput(orWithProp, propGate.out);\n        swap(andGate.out, expectedAnd);\n        carry = orWithProp.out;\n      } else {\n        continue;\n      }\n    } else {\n      carry = orGate.out;\n    }\n\n    // For th