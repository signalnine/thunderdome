task ─────────────────────────────────────\n\n  failTask(taskId: string, error?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot fail task in status: ${task.status}`);\n    }\n\n    task.error = error;\n    task.failureCount += 1;\n\n    // Check retries\n    if (task.attempts < task.maxRetries) {\n      // Re-queue with backoff delay\n      const delay = task.backoffDelay * Math.pow(2, task.attempts - 1);\n      task.availableAt = new Date(Date.now() + delay);\n      task.status = 'pending';\n      task.progress = 0;\n      task.progressMessage = undefined;\n    } else {\n      // Exhausted retries\n      task.status = 'failed';\n\n      // Phase 6: move to DLQ\n      const queue = this.queues.get(task.queue);\n      if (queue) queue.delete(taskId);\n\n      this.ensureDLQ(task.queue);\n      this.deadLetterQueues.get(task.queue)!.set(taskId, {\n        task,\n        error: error ?? 'Unknown error',\n        failureCount: task.failureCount,\n        deadLetteredAt: new Date(),\n      });\n    }\n  }\n\n  // ── Phase 6: Dead letter queue operations ──────────────────\n\n  getDeadLetterTasks(queueName: string = DEFAULT_QUEUE): DeadLetteredTask[] {\n    const dlq = this.deadLetterQueues.get(queueName);\n    if (!dlq) return [];\n    return [...dlq.values()];\n  }\n\n  redriveTask(taskId: string): Task {\n    // Find which DLQ has this task\n    for (const [queueName, dlq] of this.deadLetterQueues) {\n      const entry = dlq.get(taskId);\n      if (entry) {\n        dlq.delete(taskId);\n        const task = entry.task;\n        task.status = 'pending';\n        task.attempts = 0;\n        task.failureCount = 0;\n        task.error = undefined;\n        task.progress = 0;\n        task.progressMessage = undefined;\n        task.availableAt = new Date();\n\n        this.ensureQueue(queueName);\n        this.queues.get(queueName)