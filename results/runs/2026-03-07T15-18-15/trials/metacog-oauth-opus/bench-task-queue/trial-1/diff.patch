+
+    // Return unsubscribe function
+    return () => {
+      const listeners = this.progressListeners.get(taskId);
+      if (listeners) {
+        listeners.delete(listener);
+        if (listeners.size === 0) {
+          this.progressListeners.delete(taskId);
+        }
+      }
+    };
+  }
+
+  // ── Phase 9: Cancellation ─────────────────────────────────
+
+  cancelTask(taskId: string): void {
+    const task = this.tasks.get(taskId);
+    if (!task) throw new Error(`Task not found: ${taskId}`);
+
+    if (task.status !== 'pending' && task.status !== 'processing' && task.status !== 'blocked') {
+      throw new Error(`Cannot cancel task in status: ${task.status}`);
+    }
+
+    task.status = 'cancelled';
+
+    // Remove from queue
+    const queue = this.queues.get(task.queue);
+    if (queue) queue.delete(taskId);
+  }
+
+  // ── Phase 10: Recurring tasks (cron) ──────────────────────
+
+  addSchedule(
+    cronExpression: string,
+    queueName: string,
+    payload: unknown,
+    taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'availableAt' | 'dependencies'>
+  ): Schedule {
+    this.validateCron(cronExpression);
+
+    const schedule: Schedule = {
+      id: randomUUID(),
+      cronExpression,
+      queue: queueName,
+      payload,
+      taskOptions,
+    };
+
+    this.schedules.set(schedule.id, schedule);
+    return schedule;
+  }
+
+  removeSchedule(scheduleId: string): void {
+    if (!this.schedules.has(scheduleId)) {
+      throw new Error(`Schedule not found: ${scheduleId}`);
+    }
+    this.schedules.delete(scheduleId);
+  }
+
+  listSchedules(): Schedule[] {
+    return [...this.schedules.values()];
+  }
+
+  tick(now: Date = new Date()): Task[] {
+    const created: Task[] = [];
+
+    for (const schedule of this.schedules.values()) {
+      if (this.shouldRunSchedule(schedule, now)) {
+        const task = this.addTask(schedule.payload, {
+          queue: schedule.queue,
+          ...schedule.taskOptions,
+        });
+        created.push(task);
+        schedule.lastRun = now;
+      }
+    }
+
+    return created;
+  }
+
+  private validateCron(expression: string): void {
+    const parts = expression.trim().split(/\s+/);
+    if (parts.length !== 5) {
+      throw new Error(`Invalid cron expression: ${expression}. Must have 5 fields.`);
+    }
+
+    const [minute, hour, dayOfMonth, month, dayOfWeek] = parts;
+
+    // Validate basic patterns
+    const isValidField = (field: string, allowStar: boolean = true): boolean => {
+      if (allowStar && field === '*') return true;
+      if (/^\d+$/.test(field)) return true;
+      if (/^\*\/\d+$/.test(field)) return true;
+      return false;
+    };
+
+    if (!isValidField(minute) || !isValidField(hour) || !isValidField(dayOfMonth) ||
+        !isValidField(month) || !isValidField(dayOfWeek)) {
+      throw new Error(`Invalid cron expression: ${expression}`);
+    }
+  }
+
+  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {
+    const parts = schedule.cronExpression.trim().split(/\s+/);
+    const [minuteField, hourField] = parts;
+
+    const currentMinute = now.getMinutes();
+    const currentHour = now.getHours();
+
+    // Check minute field
+    if (!this.matchesCronField(minuteField, currentMinute)) return false;
+    // Check hour field
+    if (!this.matchesCronField(hourField, currentHour)) return false;
+
+    // Check if already ran at this time
+    if (schedule.lastRun) {
+      const lastMinute = schedule.lastRun.getMinutes();
+      const lastHour = schedule.lastRun.getHours();
+      const lastDate = schedule.lastRun.toDateString();
+      const nowDate = now.toDateString();
+
+      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {
+        return false;
+      }
+    }
+
+    return true;
+  }
+
+  private matchesCronField(field: string, value: number): boolean {
+    if (field === '*') return true;
+    if (/^\d+$/.test(field)) return parseInt(field, 10) === value;
+    const stepMatch = field.match(/^\*\/(\d+)$/);
+    if (stepMatch) {
+      const step = parseInt(stepMatch[1], 10);
+      return value % step === 0;
+    }
+    return false;
+  }
+
+  // ── Phase 11: Middleware ───────────────────────────────────
+
+  use(queueName: string, middleware: MiddlewareFn): void {
+    if (!this.middlewareStacks.has(queueName)) {
+      this.middlewareStacks.set(queueName, []);
+    }
+    this.middlewareStacks.get(queueName)!.push(middleware);
+  }
+
+  setHandler(queueName: string, handler: HandlerFn): void {
+    this.handlers.set(queueName, handler);
+  }
+
+  async processTask(queueName: string = DEFAULT_QUEUE): Promise<Task | null> {
+    const task = this.getNextTask(queueName);
+    if (!task) return null;
+
+    const middlewares = this.middlewareStacks.get(queueName) ?? [];
+    const handler = this.handlers.get(queueName);
+
+    try {
+      let index = 0;
+
+      const executeNext = async (): Promise<void> => {
+        if (index < middlewares.length) {
+          const mw = middlewares[index++];
+          await mw(task, executeNext);
+        } else if (handler) {
+          await handler(task);
+        }
+      };
+
+      // If no middleware and no handler, just return the task
+      if (middlewares.length === 0 && !handler) {
+        return task;
+      }
+
+      await executeNext();
+    } catch (err) {
+      const errorMsg = err instanceof Error ? err.message : String(err);
+      this.failTask(task.id, errorMsg);
+    }
+
+    return task;
+  }
+
+  // ── Phase 12: Graceful shutdown ───────────────────────────
+
+  onShutdown(callback: () => void | Promise<void>): void {
+    this.shutdownCallbacks.push(callback);
+  }
+
+  async shutdown(timeoutMs: number = 30000): Promise<ShutdownResult> {
+    if (this.shutdownPromise) {
+      return this.shutdownPromise;
+    }
+
+    this.isShutdown = true;
+    this.shutdownPromise = this.executeShutdown(timeoutMs);
+    return this.shutdownPromise;
+  }
+
+  private async executeShutdown(timeoutMs: number): Promise<ShutdownResult> {
+    const startTime = Date.now();
+
+    // Run shutdown callbacks
+    for (const cb of this.shutdownCallbacks) {
+      await cb();
+    }
+
+    // Collect currently processing tasks
+    const processingTasks: Task[] = [];
+    for (const task of this.tasks.values()) {
+      if (task.status === 'processing') {
+        processingTasks.push(task);
+      }
+    }
+
+    if (processingTasks.length === 0) {
+      return {
+        completed: 0,
+        forceCancelled: 0,
+        durationMs: Date.now() - startTime,
+      };
+    }
+
+    // Wait for processing tasks to complete
+    let completed = 0;
+    let forceCancelled = 0;
+
+    const waitForCompletion = (): Promise<void> => {
+      return new Promise<void>((resolve) => {
+        const checkInterval = setInterval(() => {
+          let allDone = true;
+          for (const task of processingTasks) {
+            if (task.status === 'processing') {
+              allDone = false;
+              break;
+            }
+          }
+          if (allDone) {
+            clearInterval(checkInterval);
+            resolve();
+          }
+        }, 10);
+
+        // Force timeout
+        setTimeout(() => {
+          clearInterval(checkInterval);
+          resolve();
+        }, timeoutMs);
+      });
+    };
+
+    await waitForCompletion();
+
+    // Count results
+    for (const task of processingTasks) {
+      if (task.status === 'processing') {
+        task.status = 'cancelled';
+        const queue = this.queues.get(task.queue);
+        if (queue) queue.delete(task.id);
+        forceCancelled++;
+      } else {
+        completed++;
+      }
+    }
+
+    return {
+      completed,
+      forceCancelled,
+      durationMs: Date.now() - startTime,
+    };
+  }
+
+  // ── Utility methods ────────────────────────────────────────
+
+  getTask(taskId: string): Task | undefined {
+    return this.tasks.get(taskId);
+  }
+
+  private ensureQueue(name: string): void {
+    if (!this.queues.has(name)) {
+      this.queues.set(name, new Set());
+    }
+  }
+
+  private ensureDLQ(name: string): void {
+    if (!this.deadLetterQueues.has(name)) {
+      this.deadLetterQueues.set(name, new Map());
+    }
+  }
+
+  private compareTasks(a: Task, b: Task): number {
+    // Lower priority number = higher priority
+    if (a.priority !== b.priority) return a.priority - b.priority;
+    // Earlier availability time first
+    if (a.availableAt.getTime() !== b.availableAt.getTime()) {
+      return a.availableAt.getTime() - b.availableAt.getTime();
+    }
+    // FIFO: earlier creation time first
+    return a.createdAt.getTime() - b.createdAt.getTime();
+  }
+}
diff --git a/src/types.ts b/src/types.ts
new file mode 100644
index 0000000..a65a384
--- /dev/null
+++ b/src/types.ts
@@ -0,0 +1,56 @@
+export type TaskStatus = 'pending' | 'processing' | 'completed' | 'failed' | 'cancelled' | 'blocked';
+
+export interface Task<T = unknown> {
+  id: string;
+  payload: T;
+  status: TaskStatus;
+  queue: string;
+  priority: number;
+  createdAt: Date;
+  availableAt: Date;
+  attempts: number;
+  maxRetries: number;
+  backoffDelay: number;
+  dependencies: string[];
+  resolvedDependencies: Set<string>;
+  progress: number;
+  progressMessage?: string;
+  error?: string;
+  failureCount: number;
+}
+
+export interface TaskOptions {
+  queue?: string;
+  priority?: number;
+  delay?: number;
+  availableAt?: Date;
+  maxRetries?: number;
+  backoffDelay?: number;
+  dependencies?: string[];
+}
+
+export interface DeadLetteredTask<T = unknown> {
+  task: Task<T>;
+  error: string;
+  failureCount: number;
+  deadLetteredAt: Date;
+}
+
+export interface Schedule {
+  id: string;
+  cronExpression: string;
+  queue: string;
+  payload: unknown;
+  taskOptions?: Omit<TaskOptions, 'queue' | 'delay' | 'availableAt' | 'dependencies'>;
+  lastRun?: Date;
+}
+
+export type MiddlewareFn = (task: Task, next: () => Promise<void>) => Promise<void>;
+export type HandlerFn = (task: Task) => Promise<void>;
+export type ProgressListener = (progress: number, message?: string) => void;
+
+export interface ShutdownResult {
+  completed: number;
+  forceCancelled: number;
+  durationMs: number;
+}
