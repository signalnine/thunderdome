ecuteShutdown(timeoutMs: number): Promise<ShutdownResult> {\n    const startTime = Date.now();\n\n    // Run shutdown callbacks\n    for (const cb of this.shutdownCallbacks) {\n      await cb();\n    }\n\n    // Collect currently processing tasks\n    const processingTasks: Task[] = [];\n    for (const task of this.tasks.values()) {\n      if (task.status === 'processing') {\n        processingTasks.push(task);\n      }\n    }\n\n    if (processingTasks.length === 0) {\n      return {\n        completed: 0,\n        forceCancelled: 0,\n        durationMs: Date.now() - startTime,\n      };\n    }\n\n    // Wait for processing tasks to complete\n    let completed = 0;\n    let forceCancelled = 0;\n\n    const waitForCompletion = (): Promise<void> => {\n      return new Promise<void>((resolve) => {\n        const checkInterval = setInterval(() => {\n          let allDone = true;\n          for (const task of processingTasks) {\n            if (task.status === 'processing') {\n              allDone = false;\n              break;\n            }\n          }\n          if (allDone) {\n            clearInterval(checkInterval);\n            resolve();\n          }\n        }, 10);\n\n        // Force timeout\n        setTimeout(() => {\n          clearInterval(checkInterval);\n          resolve();\n        }, timeoutMs);\n      });\n    };\n\n    await waitForCompletion();\n\n    // Count results\n    for (const task of processingTasks) {\n      if (task.status === 'processing') {\n        task.status = 'cancelled';\n        const queue = this.queues.get(task.queue);\n        if (queue) queue.delete(task.id);\n        forceCancelled++;\n      } else {\n        completed++;\n      }\n    }\n\n    return {\n      completed,\n      forceCancelled,\n      durationMs: Date.now() - startTime,\n    };\n  }\n\n  // ── Utility methods ────────────────────────────────────────\n\n  getTask(taskId: string): Task | undefined {\n    return this.tasks.get(taskId);\n  }\n\n  private ensure