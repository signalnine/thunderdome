n    // Validate basic patterns\n    const isValidField = (field: string, allowStar: boolean = true): boolean => {\n      if (allowStar && field === '*') return true;\n      if (/^\\d+$/.test(field)) return true;\n      if (/^\\*\\/\\d+$/.test(field)) return true;\n      return false;\n    };\n\n    if (!isValidField(minute) || !isValidField(hour) || !isValidField(dayOfMonth) ||\n        !isValidField(month) || !isValidField(dayOfWeek)) {\n      throw new Error(`Invalid cron expression: ${expression}`);\n    }\n  }\n\n  private shouldRunSchedule(schedule: Schedule, now: Date): boolean {\n    const parts = schedule.cronExpression.trim().split(/\\s+/);\n    const [minuteField, hourField] = parts;\n\n    const currentMinute = now.getMinutes();\n    const currentHour = now.getHours();\n\n    // Check minute field\n    if (!this.matchesCronField(minuteField, currentMinute)) return false;\n    // Check hour field\n    if (!this.matchesCronField(hourField, currentHour)) return false;\n\n    // Check if already ran at this time\n    if (schedule.lastRun) {\n      const lastMinute = schedule.lastRun.getMinutes();\n      const lastHour = schedule.lastRun.getHours();\n      const lastDate = schedule.lastRun.toDateString();\n      const nowDate = now.toDateString();\n\n      if (lastMinute === currentMinute && lastHour === currentHour && lastDate === nowDate) {\n        return false;\n      }\n    }\n\n    return true;\n  }\n\n  private matchesCronField(field: string, value: number): boolean {\n    if (field === '*') return true;\n    if (/^\\d+$/.test(field)) return parseInt(field, 10) === value;\n    const stepMatch = field.match(/^\\*\\/(\\d+)$/);\n    if (stepMatch) {\n      const step = parseInt(stepMatch[1], 10);\n      return value % step === 0;\n    }\n    return false;\n  }\n\n  // ── Phase 11: Middleware ───────────────────────────────────\n\n  use(queueName: string, middleware: MiddlewareFn): void {\n    if (!this.middlewareStacks.has(queueName)) {\n      this.middle