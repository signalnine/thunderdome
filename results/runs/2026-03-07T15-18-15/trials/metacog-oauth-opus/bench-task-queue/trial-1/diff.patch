kId);\n      }\n      dlq.clear();\n    }\n  }\n\n  // ── Phase 7: Dependency helpers ────────────────────────────\n\n  getTaskDependencyStatus(taskId: string): { dependencies: string[]; resolved: string[]; unresolved: string[] } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n\n    const resolved = [...task.resolvedDependencies];\n    const unresolved = task.dependencies.filter(d => !task.resolvedDependencies.has(d));\n    return { dependencies: [...task.dependencies], resolved, unresolved };\n  }\n\n  private detectCircularDependencies(newTask: Task): void {\n    const visited = new Set<string>();\n    const stack = [...newTask.dependencies];\n\n    while (stack.length > 0) {\n      const depId = stack.pop()!;\n      if (depId === newTask.id) {\n        throw new Error('Circular dependency detected');\n      }\n      if (visited.has(depId)) continue;\n      visited.add(depId);\n\n      const depTask = this.tasks.get(depId);\n      if (depTask) {\n        for (const d of depTask.dependencies) {\n          stack.push(d);\n        }\n      }\n    }\n  }\n\n  private unblockDependents(completedTaskId: string): void {\n    for (const [, task] of this.tasks) {\n      if (task.status !== 'blocked') continue;\n      if (!task.dependencies.includes(completedTaskId)) continue;\n\n      task.resolvedDependencies.add(completedTaskId);\n      if (task.resolvedDependencies.size === task.dependencies.length) {\n        task.status = 'pending';\n      }\n    }\n  }\n\n  // ── Phase 8: Concurrency control ──────────────────────────\n\n  setConcurrency(queueName: string, limit: number): void {\n    this.concurrencyLimits.set(queueName, limit);\n  }\n\n  getConcurrency(queueName: string): number | undefined {\n    return this.concurrencyLimits.get(queueName);\n  }\n\n  getActiveCount(queueName: string = DEFAULT_QUEUE): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n\n    let count = 0;\n    for (const taskId of queue) {\n      const task = this.tasks.get(taskId);\n      if (task && task.status === 'processing') count++;\n    }\n\n    // Also count processing tasks not in queue set (they may have been removed)\n    // Actually, processing tasks stay in the queue set until completed/failed\n    return count;\n  }\n\n  // ── Phase 9: Progress tracking ─────────────────────────────\n\n  reportProgress(taskId: string, progress: number, message?: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot report progress for task in status: ${task.status}`);\n    }\n\n    if (progress < 0 || progress > 100) {\n      throw new Error(`Invalid progress: ${progress}. Must be between 0 and 100.`);\n    }\n\n    task.progress = progress;\n    task.progressMessage = message;\n\n    const listeners = this.progressListeners.get(taskId);\n    if (listeners) {\n      for (const listener of listeners) {\n        listener(progress, message);\n      }\n    }\n  }\n\n  getProgress(taskId: string): { progress: number; message?: string } {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    return { progress: task.progress, message: task.progressMessage };\n  }\n\n  onProgress(taskId: string, listener: ProgressListener): () => void {\n    if (!this.progressListeners.has(taskId)) {\n      this.progressListeners.set(taskId, new Set());\n    }\n    this.progressListeners.get(taskId)!.add(listener);\n\n    // Return unsubscribe function\n    return () => {\n      const listeners = this.progressListeners.get(taskId);\n      if (listeners) {\n        listeners.delete(listener);\n        if (listeners.size === 0) {\n          this.progressListeners.delete(taskId);\n        }\n      }\n    };\n  }\n\n  // ── Phase 9: Cancellation ─────────────────────────────────\n\n  cancelTask(taskId: string)