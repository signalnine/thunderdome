+{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DK2GPPwmLS9e5ZYXhgqVMa","type":"tool_result","content":"The file /workspace/src/queue.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"09529994-9437-4374-896a-f6237220442e","uuid":"79fd695d-ab2b-44b5-8f1d-e4b9d969bd12","tool_use_result":{"filePath":"/workspace/src/queue.test.ts","oldString":"    it('should allow middleware to modify task', async () => {\n      tq.use('default', async (task, next) => {\n        (task as any).metadata = { enriched: true };\n        await next();\n      });\n\n      let receivedTask: any = null;\n      tq.setHandler('default', async (task) => {\n        receivedTask = task;\n      });\n\n      tq.addTask('test');\n      await tq.processTask();\n\n      expect(receivedTask.metadata).toEqual({ enriched: true });","newString":"    it('should allow middleware to modify task', async () => {\n      tq.use('default', async (task, next) => {\n        (task as Record<string, unknown>).metadata = { enriched: true };\n        await next();\n      });\n\n      let receivedTask: Record<string, unknown> | null = null;\n      tq.setHandler('default', async (task) => {\n        receivedTask = task as unknown as Record<string, unknown>;\n      });\n\n      tq.addTask('test');\n      await tq.processTask();\n\n      expect(receivedTask!.metadata).toEqual({ enriched: true });","originalFile":"import { describe, it, expect, beforeEach } from 'vitest';\nimport { TaskQueue } from './queue.js';\n\ndescribe('TaskQueue', () => {\n  let tq: TaskQueue;\n\n  beforeEach(() => {\n    tq = new TaskQueue();\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 1: Basic FIFO Queue\n  // ═══════════════════════════════════════════════════════════\n  describe('Phase 1: Basic FIFO Queue', () => {\n    it('should add a task and return a task object', () => {\n      const task = tq.addTask({ message: 'hello' });\n      expect(task).toBeDefined();\n      expect(task.id).toBeDefined();\n      expect(task.payload).toEqual({ message: 'hello' });\n      expect(task.status).toBe('pending');\n      expect(task.createdAt).toBeInstanceOf(Date);\n    });\n\n    it('should assign unique IDs to tasks', () => {\n      const t1 = tq.addTask('a');\n      const t2 = tq.addTask('b');\n      expect(t1.id).not.toBe(t2.id);\n    });\n\n    it('should retrieve tasks in FIFO order', () => {\n      tq.addTask('first');\n      tq.addTask('second');\n      tq.addTask('third');\n\n      const next = tq.getNextTask();\n      expect(next!.payload).toBe('first');\n      expect(next!.status).toBe('processing');\n    });\n\n    it('should return null when no tasks are available', () => {\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should transition task to processing on retrieval', () => {\n      const added = tq.addTask('test');\n      const retrieved = tq.getNextTask();\n      expect(retrieved!.id).toBe(added.id);\n      expect(retrieved!.status).toBe('processing');\n    });\n\n    it('should not return a processing task again', () => {\n      tq.addTask('only one');\n      tq.getNextTask();\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should report correct pending count', () => {\n      expect(tq.pendingCount()).toBe(0);\n      tq.addTask('a');\n      tq.addTask('b');\n      expect(tq.pendingCount()).toBe(2);\n      tq.getNextTask();\n      expect(tq.pendingCount()).toBe(1);\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 2: Named Queues\n  // ═══════════════════════════════════════════════════════════\n  describe('Phase 2: Named Queues', () => {\n    it('should use default queue when no name is specified', () => {\n      tq.addTask('x');\n      expect(tq.listQueues()).toContain('default');\n    });\n\n    it('should support multiple independent queues', () => {\n      tq.addTask('email-job', { queue: 'emails' });\n      tq.addTask('image-job', { queue: 'images' });\n\n      expect(tq.pendingCount('emails')).toBe(1);\n      expect(tq.pendingCount('images')).toBe(1);\n    });\n\n    it('should retrieve from the correct queue', () => {\n      tq.addTask('email', { queue: 'emails' });\n      tq.addTask('image', { queue: 'images' });\n\n      const next = tq.getNextTask('emails');\n      expect(next!.payload).toBe('email');\n\n      expect(tq.getNextTask('emails')).toBeNull();\n      expect(tq.getNextTask('images')).not.toBeNull();\n    });\n\n    it('should return null for non-existent queue', () => {\n      expect(tq.getNextTask('nonexistent')).toBeNull();\n    });\n\n    it('should list all queue names', () => {\n      tq.addTask('a', { queue: 'q1' });\n      tq.addTask('b', { queue: 'q2' });\n      tq.addTask('c'); // default\n\n      const queues = tq.listQueues();\n      expect(queues).toContain('q1');\n      expect(queues).toContain('q2');\n      expect(queues).toContain('default');\n    });\n\n    it('should be backward compatible (no queue = default)', () => {\n      tq.addTask('task1');\n      const next = tq.getNextTask();\n      expect(next!.payload).toBe('task1');\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 3: Priority\n  // ═══════════════════════════════════════════════════════════\n  describe('Phase 3: Priority', () => {\n    it('should default priority to 5', () => {\n      const task = tq.addTask('test');\n      expect(task.priority).toBe(5);\n    });\n\n    it('should return higher priority tasks first', () => {\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n      tq.addTask('medium', { priority: 5 });\n\n      expect(tq.getNextTask()!.payload).toBe('high');\n      expect(tq.getNextTask()!.payload).toBe('medium');\n      expect(tq.getNextTask()!.payload).toBe('low');\n    });\n\n    it('should maintain FIFO within same priority', () => {\n      tq.addTask('first', { priority: 5 });\n      tq.addTask('second', { priority: 5 });\n      tq.addTask('third', { priority: 5 });\n\n      expect(tq.getNextTask()!.payload).toBe('first');\n      expect(tq.getNextTask()!.payload).toBe('second');\n      expect(tq.getNextTask()!.payload).toBe('third');\n    });\n\n    it('should reject invalid priority values', () => {\n      expect(() => tq.addTask('x', { priority: 0 })).toThrow();\n      expect(() => tq.addTask('x', { priority: 11 })).toThrow();\n      expect(() => tq.addTask('x', { priority: -1 })).toThrow();\n      expect(() => tq.addTask('x', { priority: 1.5 })).toThrow();\n    });\n\n    it('should have independent priority per queue', () => {\n      tq.addTask('q1-low', { queue: 'q1', priority: 10 });\n      tq.addTask('q1-high', { queue: 'q1', priority: 1 });\n      tq.addTask('q2-low', { queue: 'q2', priority: 10 });\n\n      expect(tq.getNextTask('q1')!.payload).toBe('q1-high');\n      expect(tq.getNextTask('q2')!.payload).toBe('q2-low');\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 4: Delayed Tasks\n  // ═══════════════════════════════════════════════════════════\n  describe('Phase 4: Delayed Tasks', () => {\n    it('should not return delayed tasks before their availability time', () => {\n      tq.addTask('delayed', { delay: 60000 });\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should return delayed tasks after their availability time', () => {\n      const pastTime = new Date(Date.now() - 1000);\n      tq.addTask('ready', { availableAt: pastTime });\n\n      const next = tq.getNextTask();\n      expect(next).not.toBeNull();\n      expect(next!.payload).toBe('ready');\n    });\n\n    it('should prefer non-delayed tasks over unavailable delayed tasks', () => {\n      tq.addTask('delayed', { delay: 60000 });\n      tq.addTask('immediate');\n\n      expect(tq.getNextTask()!.payload).toBe('immediate');\n    });\n\n    it('should order available delayed tasks by availability then priority then FIFO', () => {\n      const past1 = new Date(Date.now() - 3000);\n      const past2 = new Date(Date.now() - 1000);\n\n      tq.addTask('later', { availableAt: past2, priority: 5 });\n      tq.addTask('earlier', { availableAt: past1, priority: 5 });\n\n      expect(tq.getNextTask()!.payload).toBe('earlier');\n      expect(tq.getNextTask()!.payload).toBe('later');\n    });\n\n    it('should expose availability time on task', () => {\n      const task = tq.addTask('test', { delay: 5000 });\n      expect(task.availableAt.getTime()).toBeGreaterThan(Date.now() - 100);\n    });\n\n    it('should work with named queues', () => {\n      tq.addTask('delayed', { queue: 'q1', delay: 60000 });\n      tq.addTask('immediate', { queue: 'q1' });\n\n      expect(tq.getNextTask('q1')!.payload).toBe('immediate');\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 5: Retry with Backoff\n  // ═══════════════════════════════════════════════════════════\n  describe('Phase 5: Retry with Backoff', () => {\n    it('should mark a task as completed', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n      tq.completeTask(task.id);\n      expect(tq.getTask(task.id)!.status).toBe('completed');\n    });\n\n    it('should mark a task as failed and re-queue with backoff', () => {\n      const task = tq.addTask('test', { maxRetries: 3, backoffDelay: 1000 });\n      tq.getNextTask();\n      tq.failTask(task.id, 'oops');\n\n      const t = tq.getTask(task.id)!;\n      expect(t.status).toBe('pending');\n      expect(t.attempts).toBe(1);\n      expect(t.availableAt.getTime()).toBeGreaterThan(Date.now());\n    });\n\n    it('should use exponential backoff', () => {\n      const task = tq.addTask('test', { maxRetries: 3, backoffDelay: 1000 });\n\n      // Attempt 1\n      tq.getNextTask();\n      const before1 = Date.now();\n      tq.failTask(task.id, 'fail1');\n      const delay1 = tq.getTask(task.id)!.availableAt.getTime() - before1;\n      expect(delay1).toBeGreaterThanOrEqual(900); // ~1000ms with small tolerance\n      expect(delay1).toBeLessThan(1500);\n    });\n\n    it('should fail permanently when retries exhausted', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id, 'final fail');\n\n      expect(tq.getTask(task.id)!.status).toBe('failed');\n    });\n\n    it('should track attempt count', () => {\n      const task = tq.addTask('test', { maxRetries: 3, backoffDelay: 0 });\n\n      // Attempt 1\n      tq.getNextTask();\n      expect(tq.getTask(task.id)!.attempts).toBe(1);\n    });\n\n    it('should keep original queue and priority on retry', () => {\n      const task = tq.addTask('test', { queue: 'myq', priority: 2, maxRetries: 3, backoffDelay: 0 });\n      tq.getNextTask('myq');\n      tq.failTask(task.id, 'fail');\n\n      const t = tq.getTask(task.id)!;\n      expect(t.queue).toBe('myq');\n      expect(t.priority).toBe(2);\n    });\n\n    it('should default maxRetries to 3', () => {\n      const task = tq.addTask('test');\n      expect(task.maxRetries).toBe(3);\n    });\n\n    it('should default backoffDelay to 1000', () => {\n      const task = tq.addTask('test');\n      expect(task.backoffDelay).toBe(1000);\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 6: Dead Letter Queue\n  // ═══════════════════════════════════════════════════════════\n  describe('Phase 6: Dead Letter Queue', () => {\n    it('should move task to DLQ when retries are exhausted', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id, 'permanent fail');\n\n      const dlqTasks = tq.getDeadLetterTasks('default');\n      expect(dlqTasks.length).toBe(1);\n      expect(dlqTasks[0].task.id).toBe(task.id);\n      expect(dlqTasks[0].error).toBe('permanent fail');\n      expect(dlqTasks[0].failureCount).toBe(1);\n    });\n\n    it('should retain error info on DLQ tasks', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id, 'my error');\n\n      const dlqTasks = tq.getDeadLetterTasks('default');\n      expect(dlqTasks[0].error).toBe('my error');\n    });\n\n    it('should redrive a task from DLQ back to its queue', () => {\n      const task = tq.addTask('test', { maxRetries: 1, backoffDelay: 0 });\n      tq.getNextTask();\n      tq.failTask(task.id, 'fail');\n\n      const redriven = tq.redriveTask(task.id);\n      expect(redriven.status).toBe('pending');\n      expect(redriven.attempts).toBe(0);\n      expect(redriven.failureCount).toBe(0);\n\n      expect(tq.getDeadLetterTasks('default').length).toBe(0);\n      expect(tq.getNextTask()!.id).toBe(task.id);\n    });\n\n    it('should clear dead letter queue', () => {\n      const t1 = tq.addTask('a', { maxRetries: 1, backoffDelay: 0 });\n      const t2 = tq.addTask('b', { maxRetries: 1, backoffDelay: 0 });\n\n      tq.getNextTask();\n      tq.failTask(t1.id, 'fail');\n      tq.getNextTask();\n      tq.failTask(t2.id, 'fail');\n\n      expect(tq.getDeadLetterTasks('default').length).toBe(2);\n      tq.clearDeadLetterQueue('default');\n      expect(tq.getDeadLetterTasks('default').length).toBe(0);\n    });\n\n    it('should have independent DLQ per named queue', () => {\n      const t1 = tq.addTask('a', { queue: 'q1', maxRetries: 1, backoffDelay: 0 });\n      const t2 = tq.addTask('b', { queue: 'q2', maxRetries: 1, backoffDelay: 0 });\n\n      tq.getNextTask('q1');\n      tq.failTask(t1.id, 'fail');\n      tq.getNextTask('q2');\n      tq.failTask(t2.id, 'fail');\n\n      expect(tq.getDeadLetterTasks('q1').length).toBe(1);\n      expect(tq.getDeadLetterTasks('q2').length).toBe(1);\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 7: Task Dependencies\n  // ═══════════════════════════════════════════════════════════\n  describe('Phase 7: Task Dependencies', () => {\n    it('should block a task with unresolved dependencies', () => {\n      const dep = tq.addTask('dep');\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      expect(dependent.status).toBe('blocked');\n      // Should only return the non-blocked task\n      const next = tq.getNextTask();\n      expect(next!.id).toBe(dep.id);\n      expect(tq.getNextTask()).toBeNull(); // dependent is blocked\n    });\n\n    it('should unblock task when dependency completes', () => {\n      const dep = tq.addTask('dep');\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      tq.getNextTask();\n      tq.completeTask(dep.id);\n\n      expect(tq.getTask(dependent.id)!.status).toBe('pending');\n      const next = tq.getNextTask();\n      expect(next!.id).toBe(dependent.id);\n    });\n\n    it('should detect circular dependencies', () => {\n      const t1 = tq.addTask('t1');\n      tq.getNextTask(); // make t1 processing so it exists\n      tq.addTask('t2', { dependencies: [t1.id] });\n\n      // Non-circular: a -> b is fine\n      expect(() => {\n        const a = tq.addTask('a');\n        tq.addTask('b', { dependencies: [a.id] });\n      }).not.toThrow();\n    });\n\n    it('should reject dependency on non-existent task', () => {\n      expect(() => {\n        tq.addTask('test', { dependencies: ['nonexistent-id'] });\n      }).toThrow('Dependency task not found');\n    });\n\n    it('should not auto-fail dependents when dependency fails', () => {\n      const dep = tq.addTask('dep', { maxRetries: 1, backoffDelay: 0 });\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n\n      tq.getNextTask();\n      tq.failTask(dep.id, 'fail');\n\n      // Dependent should still be blocked, not failed\n      expect(tq.getTask(dependent.id)!.status).toBe('blocked');\n    });\n\n    it('should provide dependency status info', () => {\n      const dep1 = tq.addTask('dep1');\n      const dep2 = tq.addTask('dep2');\n      const dependent = tq.addTask('dependent', { dependencies: [dep1.id, dep2.id] });\n\n      const status = tq.getTaskDependencyStatus(dependent.id);\n      expect(status.dependencies).toEqual([dep1.id, dep2.id]);\n      expect(status.unresolved.length).toBe(2);\n\n      // Complete dep1\n      tq.getNextTask();\n      tq.completeTask(dep1.id);\n\n      const status2 = tq.getTaskDependencyStatus(dependent.id);\n      expect(status2.resolved).toContain(dep1.id);\n      expect(status2.unresolved).toContain(dep2.id);\n    });\n\n    it('should handle task with already-completed dependency', () => {\n      const dep = tq.addTask('dep');\n      tq.getNextTask();\n      tq.completeTask(dep.id);\n\n      const dependent = tq.addTask('dependent', { dependencies: [dep.id] });\n      expect(dependent.status).toBe('pending'); // already unblocked\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 8: Concurrency Control\n  // ═══════════════════════════════════════════════════════════\n  describe('Phase 8: Concurrency Control', () => {\n    it('should enforce concurrency limit', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('a');\n      tq.addTask('b');\n\n      expect(tq.getNextTask()).not.toBeNull();\n      expect(tq.getNextTask()).toBeNull(); // limit reached\n    });\n\n    it('should free slot when task completes', () => {\n      tq.setConcurrency('default', 1);\n      const t1 = tq.addTask('a');\n      tq.addTask('b');\n\n      tq.getNextTask();\n      tq.completeTask(t1.id);\n\n      expect(tq.getNextTask()).not.toBeNull();\n    });\n\n    it('should free slot when task fails', () => {\n      tq.setConcurrency('default', 1);\n      const t1 = tq.addTask('a', { maxRetries: 1, backoffDelay: 0 });\n      tq.addTask('b');\n\n      tq.getNextTask();\n      tq.failTask(t1.id, 'fail');\n\n      // t1 goes to DLQ, slot freed\n      expect(tq.getNextTask()).not.toBeNull();\n    });\n\n    it('should default to no concurrency limit', () => {\n      expect(tq.getConcurrency('default')).toBeUndefined();\n\n      tq.addTask('a');\n      tq.addTask('b');\n      tq.addTask('c');\n\n      expect(tq.getNextTask()).not.toBeNull();\n      expect(tq.getNextTask()).not.toBeNull();\n      expect(tq.getNextTask()).not.toBeNull();\n    });\n\n    it('should report active count', () => {\n      tq.addTask('a');\n      tq.addTask('b');\n\n      expect(tq.getActiveCount()).toBe(0);\n      tq.getNextTask();\n      expect(tq.getActiveCount()).toBe(1);\n      tq.getNextTask();\n      expect(tq.getActiveCount()).toBe(2);\n    });\n\n    it('should respect priority with concurrency', () => {\n      tq.setConcurrency('default', 1);\n      tq.addTask('low', { priority: 10 });\n      tq.addTask('high', { priority: 1 });\n\n      expect(tq.getNextTask()!.payload).toBe('high');\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 9: Progress Tracking and Cancellation\n  // ═══════════════════════════════════════════════════════════\n  describe('Phase 9: Progress and Cancellation', () => {\n    it('should report and query progress', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n\n      tq.reportProgress(task.id, 50, 'halfway');\n      const progress = tq.getProgress(task.id);\n      expect(progress.progress).toBe(50);\n      expect(progress.message).toBe('halfway');\n    });\n\n    it('should notify progress listeners', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n\n      const updates: Array<{ progress: number; message?: string }> = [];\n      tq.onProgress(task.id, (p, m) => updates.push({ progress: p, message: m }));\n\n      tq.reportProgress(task.id, 25, 'quarter');\n      tq.reportProgress(task.id, 75, 'three quarters');\n\n      expect(updates.length).toBe(2);\n      expect(updates[0].progress).toBe(25);\n      expect(updates[1].progress).toBe(75);\n    });\n\n    it('should allow unsubscribing from progress', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n\n      const updates: number[] = [];\n      const unsub = tq.onProgress(task.id, (p) => updates.push(p));\n\n      tq.reportProgress(task.id, 25);\n      unsub();\n      tq.reportProgress(task.id, 50);\n\n      expect(updates.length).toBe(1);\n    });\n\n    it('should reject invalid progress values', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n\n      expect(() => tq.reportProgress(task.id, -1)).toThrow();\n      expect(() => tq.reportProgress(task.id, 101)).toThrow();\n    });\n\n    it('should cancel a pending task', () => {\n      const task = tq.addTask('test');\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)!.status).toBe('cancelled');\n      expect(tq.getNextTask()).toBeNull();\n    });\n\n    it('should cancel a processing task', () => {\n      const task = tq.addTask('test');\n      tq.getNextTask();\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)!.status).toBe('cancelled');\n    });\n\n    it('should not retry cancelled tasks', () => {\n      const task = tq.addTask('test', { maxRetries: 3 });\n      tq.getNextTask();\n      tq.cancelTask(task.id);\n\n      expect(tq.getTask(task.id)!.status).toBe('cancelled');\n      // Cannot fail a cancelled task\n      expect(() => tq.failTask(task.id, 'fail')).toThrow();\n    });\n  });\n\n  // ═══════════════════════════════════════════════════════════\n  // Phase 10: Recurring Tasks\n  // ═══════════════════════════════════════════════════════════\n  describe('Phase 10: Recurring Tasks', () => {\n    it('should create a schedule', () => {\n      const schedule = tq.addSchedule('*/5 * * * *', 'default', { type: 'cleanup' });\n      expect(schedule.id).toBeDefined();\n      expect(schedule.cronExpression).toBe('*/5 * * * *');\n    });\n\n    it('should list active schedules', () => {\n      