w Date();\n    let availableAt = now;\n    if (options.availableAt) {\n      availableAt = options.availableAt;\n    } else if (options.delay != null && options.delay > 0) {\n      availableAt = new Date(now.getTime() + options.delay);\n    }\n\n    // Phase 7: validate dependencies\n    const dependencies = options.dependencies ?? [];\n    for (const depId of dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (!depTask) {\n        throw new Error(`Dependency task not found: ${depId}`);\n      }\n    }\n\n    const task: Task<T> = {\n      id: randomUUID(),\n      payload,\n      status: 'pending',\n      queue: queueName,\n      priority,\n      createdAt: now,\n      availableAt,\n      attempts: 0,\n      maxRetries: options.maxRetries ?? 3,\n      backoffDelay: options.backoffDelay ?? 1000,\n      dependencies: [...dependencies],\n      resolvedDependencies: new Set<string>(),\n      progress: 0,\n      failureCount: 0,\n    };\n\n    // Check which dependencies are already completed\n    for (const depId of task.dependencies) {\n      const depTask = this.tasks.get(depId);\n      if (depTask && depTask.status === 'completed') {\n        task.resolvedDependencies.add(depId);\n      }\n    }\n\n    // If has unresolved deps, mark as blocked\n    if (task.dependencies.length > 0 && task.resolvedDependencies.size < task.dependencies.length) {\n      // Detect circular dependencies before adding\n      this.detectCircularDependencies(task);\n      task.status = 'blocked';\n    } else if (task.dependencies.length > 0) {\n      // All deps already resolved\n      this.detectCircularDependencies(task);\n    }\n\n    this.tasks.set(task.id, task as Task);\n    this.ensureQueue(queueName);\n    this.queues.get(queueName)!.add(task.id);\n\n    return task;\n  }\n\n  // ── Phase 1: Get next task ─────────────────────────────────\n\n  getNextTask(queueName: string = DEFAULT_QUEUE): Task | null {\n    const queue = this.queues.get(queueName);\n    if (!queue) return null;\n\n    // Phase 8: concurrency check\n    const limit = this.concurrencyLimits.get(queueName);\n    if (limit !== undefined) {\n      const activeCount = this.getActiveCount(queueName);\n      if (activeCount >= limit) return null;\n    }\n\n    const now = new Date();\n    let bestTask: Task | null = null;\n\n    for (const taskId of queue) {\n      const task = this.tasks.get(taskId);\n      if (!task || task.status !== 'pending') continue;\n      if (task.availableAt > now) continue;\n\n      if (!bestTask || this.compareTasks(task, bestTask) < 0) {\n        bestTask = task;\n      }\n    }\n\n    if (bestTask) {\n      bestTask.status = 'processing';\n      bestTask.attempts += 1;\n    }\n\n    return bestTask;\n  }\n\n  // ── Phase 1: Pending count ─────────────────────────────────\n\n  pendingCount(queueName: string = DEFAULT_QUEUE): number {\n    const queue = this.queues.get(queueName);\n    if (!queue) return 0;\n\n    let count = 0;\n    for (const taskId of queue) {\n      const task = this.tasks.get(taskId);\n      if (task && task.status === 'pending') count++;\n    }\n    return count;\n  }\n\n  // ── Phase 2: List queues ───────────────────────────────────\n\n  listQueues(): string[] {\n    return [...this.queues.keys()];\n  }\n\n  // ── Phase 5: Complete task ─────────────────────────────────\n\n  completeTask(taskId: string): void {\n    const task = this.tasks.get(taskId);\n    if (!task) throw new Error(`Task not found: ${taskId}`);\n    if (task.status !== 'processing') {\n      throw new Error(`Cannot complete task in status: ${task.status}`);\n    }\n\n    task.status = 'completed';\n    task.progress = 100;\n\n    // Remove from queue set\n    const queue = this.queues.get(task.queue);\n    if (queue) queue.delete(taskId);\n\n    // Phase 7: unblock dependents\n    this.unblockDependents(taskId);\n  }\n\n  // ── Phase 5: Fail task ─────────────────────────────────────\n\n  failTask(taskId: string, error?: string): void {\n  