pi/events\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"page_view\" });\n    const res = await request(app)\n      .get(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(1);\n  });\n\n  it(\"returns 401 without auth\", async () => {\n    const res = await request(app)\n      .post(\"/api/events\")\n      .send({ name: \"page_view\" });\n    expect(res.status).toBe(401);\n  });\n});\n\ndescribe(\"Query Engine\", () => {\n  let token: string;\n\n  beforeEach(async () => {\n    const reg = await request(app).post(\"/api/users/register\").send({\n      email: \"test@example.com\",\n      password: \"password123\",\n      tenantId: \"tenant1\",\n    });\n    token = reg.body.token;\n\n    // Insert test events\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-15T10:00:00Z\" },\n          { name: \"page_view\", properties: { url: \"/about\" }, timestamp: \"2024-01-15T11:00:00Z\" },\n          { name: \"page_view\", properties: { url: \"/home\" }, timestamp: \"2024-01-16T10:00:00Z\" },\n          { name: \"click\", properties: { element: \"button\" }, timestamp: \"2024-01-15T12:00:00Z\" },\n        ],\n      });\n  });\n\n  it(\"counts events\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\" });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(3);\n  });\n\n  it(\"counts with filter\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\", filters: { url: \"/home\" } });\n    expect(res.status).toBe(200);\n    expect(res.body.count).toBe(2);\n  });\n\n  it(\"timeseries query\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/timeseries\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\", interval: \"day\" });\n    expect(res.status).toBe(200);\n    expect(res.body.data.length).toBe(2);\n  });\n\n  it(\"breakdown query\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/breakdown\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ eventName: \"page_view\", property: \"url\" });\n    expect(res.status).toBe(200);\n    expect(res.body.data.length).toBe(2);\n    expect(res.body.data[0].count).toBe(2); // /home has 2\n  });\n});\n\ndescribe(\"Tenant Isolation\", () => {\n  let token1: string;\n  let token2: string;\n\n  beforeEach(async () => {\n    const reg1 = await request(app).post(\"/api/users/register\").send({\n      email: \"user1@example.com\",\n      password: \"password123\",\n      tenantId: \"tenant1\",\n    });\n    token1 = reg1.body.token;\n\n    const reg2 = await request(app).post(\"/api/users/register\").send({\n      email: \"user2@example.com\",\n      password: \"password123\",\n      tenantId: \"tenant2\",\n    });\n    token2 = reg2.body.token;\n\n    // Insert events for tenant 1\n    await request(app)\n      .post(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token1}`)\n      .send({ name: \"page_view\", properties: { url: \"/home\" } });\n  });\n\n  it(\"tenant2 cannot see tenant1 events\", async () => {\n    const res = await request(app)\n      .get(\"/api/events\")\n      .set(\"Authorization\", `Bearer ${token2}`);\n    expect(res.body.events.length).toBe(0);\n  });\n\n  it(\"tenant2 count is zero for tenant1 events\", async () => {\n    const res = await request(app)\n      .post(\"/api/queries/count\")\n      .set(\"Authorization\", `Bearer ${token2}`)\n      .send({ eventName: \"page_view\" });\n    expect(res.body.count).toBe(0);\n  });\n});\n\ndescribe(\"Dashboards\", () => {\n  let token: string;\n\n  beforeEach(async () => {\n    const reg = await request(app).post(\"/api/users/register\").send({\n      email: \"test@example.com\",\n      password: \"password123\",\n      tenantId: \"tenant1\",\n    });\n    token = reg.body.token;\n  });\n\n  it(\"creates a dashboard\", async () => {\n    const res = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"My Dashboard\", config: { theme: \"dark\" } });\n    expect(res.status).toBe(201);\n    expect(res.body.name).toBe(\"My Dashboard\");\n  });\n\n  it(\"lists dashboards\", async () => {\n    await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    const res = await request(app)\n      .get(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.dashboards.length).toBe(1);\n  });\n\n  it(\"gets a single dashboard\", async () => {\n    const created = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    const res = await request(app)\n      .get(`/api/dashboards/${created.body.id}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe(\"Dashboard 1\");\n    expect(res.body.widgets).toBeDefined();\n  });\n\n  it(\"updates a dashboard\", async () => {\n    const created = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    const res = await request(app)\n      .put(`/api/dashboards/${created.body.id}`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Updated Dashboard\" });\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe(\"Updated Dashboard\");\n  });\n\n  it(\"deletes a dashboard\", async () => {\n    const created = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    const res = await request(app)\n      .delete(`/api/dashboards/${created.body.id}`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(204);\n  });\n\n  it(\"adds a widget\", async () => {\n    const created = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    const res = await request(app)\n      .post(`/api/dashboards/${created.body.id}/widgets`)\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        type: \"counter\",\n        config: { eventName: \"page_view\" },\n        positionX: 0,\n        positionY: 0,\n        width: 2,\n        height: 1,\n      });\n    expect(res.status).toBe(201);\n    expect(res.body.type).toBe(\"counter\");\n  });\n});\n\ndescribe(\"Export\", () => {\n  let token: string;\n\n  beforeEach(async () => {\n    const reg = await request(app).post(\"/api/users/register\").send({\n      email: \"test@example.com\",\n      password: \"password123\",\n      tenantId: \"tenant1\",\n    });\n    token = reg.body.token;\n\n    await request(app)\n      .post(\"/api/events/batch\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({\n        events: [\n          { name: \"page_view\", properties: { url: \"/home\" } },\n          { name: \"click\", properties: { element: \"button\" } },\n        ],\n      });\n  });\n\n  it(\"exports events as JSON\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events/json\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.events.length).toBe(2);\n  });\n\n  it(\"exports events as CSV\", async () => {\n    const res = await request(app)\n      .get(\"/api/export/events/csv\")\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n    expect(res.text).toContain(\"id,tenant_id,name,properties,timestamp,user_id,session_id\");\n  });\n\n  it(\"exports dashboard as JSON\", async () => {\n    const created = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    const res = await request(app)\n      .get(`/api/export/dashboards/${created.body.id}/json`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.body.name).toBe(\"Dashboard 1\");\n  });\n\n  it(\"exports dashboard as CSV\", async () => {\n    const created = await request(app)\n      .post(\"/api/dashboards\")\n      .set(\"Authorization\", `Bearer ${token}`)\n      .send({ name: \"Dashboard 1\" });\n    const res = await request(app)\n      .get(`/api/export/dashboards/${created.body.id}/csv`)\n      .set(\"Authorization\", `Bearer ${token}`);\n    expect(res.status).toBe(200);\n    expect(res.headers[\"content-type\"]).toContain(\"text/csv\");\n  });\n\n  it(\"returns 401 without auth\", async () => {\n    const res = await request(app).get(\"/api/export/events/json\");\n    expect(res.status).toBe(401);\n  });\n});\n","structuredPatch":[],"originalFile":null}}
