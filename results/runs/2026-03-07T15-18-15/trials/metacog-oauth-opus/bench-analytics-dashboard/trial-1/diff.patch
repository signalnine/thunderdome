ms.push(startDate);\n    }\n    if (endDate) {\n      query += \" AND timestamp <= ?\";\n      params.push(endDate);\n    }\n\n    if (filters && typeof filters === \"object\") {\n      for (const [key, value] of Object.entries(filters)) {\n        query += \" AND json_extract(properties, ?) = ?\";\n        params.push(`$.${key}`);\n        params.push(String(value));\n      }\n    }\n\n    query += \" GROUP BY value ORDER BY count DESC\";\n\n    if (limit) {\n      query += \" LIMIT ?\";\n      params.push(String(limit));\n    }\n\n    const rows = db.prepare(query).all(...params) as Array<{ value: string | null; count: number }>;\n\n    res.json({ eventName, property, data: rows });\n  });\n\n  return router;\n}\n","structuredPatch":[],"originalFile":null}}
