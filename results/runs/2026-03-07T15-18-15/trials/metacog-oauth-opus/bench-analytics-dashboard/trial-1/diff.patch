@@ -0,0 +1,247 @@
+import { Router, Request, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { authenticate } from "../auth.js";
+
+interface DashboardRow {
+  id: string;
+  tenant_id: string;
+  name: string;
+  owner_id: string;
+  config: string;
+  created_at: string;
+  updated_at: string;
+}
+
+interface WidgetRow {
+  id: string;
+  dashboard_id: string;
+  type: string;
+  config: string;
+  position_x: number;
+  position_y: number;
+  width: number;
+  height: number;
+}
+
+export function createDashboardRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Create dashboard
+  router.post("/", authenticate, (req: Request, res: Response): void => {
+    const { name, config } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const ownerId = req.user!.userId;
+    const dashConfig = config ? JSON.stringify(config) : "{}";
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "INSERT INTO dashboards (id, tenant_id, name, owner_id, config, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, ownerId, dashConfig, now, now);
+
+    res.status(201).json({
+      id,
+      tenantId,
+      name,
+      ownerId,
+      config: config ?? {},
+      createdAt: now,
+      updatedAt: now,
+    });
+  });
+
+  // List dashboards for tenant
+  router.get("/", authenticate, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+
+    const rows = db
+      .prepare("SELECT * FROM dashboards WHERE tenant_id = ? ORDER BY created_at DESC")
+      .all(tenantId) as DashboardRow[];
+
+    const dashboards = rows.map((row) => ({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      ownerId: row.owner_id,
+      config: JSON.parse(row.config),
+      createdAt: row.created_at,
+      updatedAt: row.updated_at,
+    }));
+
+    res.json({ dashboards });
+  });
+
+  // Get single dashboard
+  router.get("/:id", authenticate, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+
+    const row = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!row) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widgets = db
+      .prepare("SELECT * FROM widgets WHERE dashboard_id = ?")
+      .all(row.id) as WidgetRow[];
+
+    res.json({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      ownerId: row.owner_id,
+      config: JSON.parse(row.config),
+      createdAt: row.created_at,
+      updatedAt: row.updated_at,
+      widgets: widgets.map((w) => ({
+        id: w.id,
+        dashboardId: w.dashboard_id,
+        type: w.type,
+        config: JSON.parse(w.config),
+        positionX: w.position_x,
+        positionY: w.position_y,
+        width: w.width,
+        height: w.height,
+      })),
+    });
+  });
+
+  // Update dashboard
+  router.put("/:id", authenticate, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { name, config } = req.body;
+
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const updatedName = name ?? existing.name;
+    const updatedConfig = config ? JSON.stringify(config) : existing.config;
+    const now = new Date().toISOString();
+
+    db.prepare(
+      "UPDATE dashboards SET name = ?, config = ?, updated_at = ? WHERE id = ?"
+    ).run(updatedName, updatedConfig, now, req.params.id);
+
+    res.json({
+      id: existing.id,
+      tenantId: existing.tenant_id,
+      name: updatedName,
+      ownerId: existing.owner_id,
+      config: JSON.parse(updatedConfig),
+      createdAt: existing.created_at,
+      updatedAt: now,
+    });
+  });
+
+  // Delete dashboard
+  router.delete("/:id", authenticate, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+
+    const existing = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!existing) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM widgets WHERE dashboard_id = ?").run(req.params.id);
+    db.prepare("DELETE FROM dashboards WHERE id = ?").run(req.params.id);
+
+    res.status(204).send();
+  });
+
+  // Add widget to dashboard
+  router.post("/:id/widgets", authenticate, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.id, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const { type, config, positionX, positionY, width, height } = req.body;
+
+    if (!type || !["counter", "timeseries", "breakdown", "funnel"].includes(type)) {
+      res.status(400).json({ error: "type must be counter, timeseries, breakdown, or funnel" });
+      return;
+    }
+
+    const id = uuidv4();
+    const widgetConfig = config ? JSON.stringify(config) : "{}";
+
+    db.prepare(
+      "INSERT INTO widgets (id, dashboard_id, type, config, position_x, position_y, width, height) VALUES (?, ?, ?, ?, ?, ?, ?, ?)"
+    ).run(
+      id,
+      req.params.id,
+      type,
+      widgetConfig,
+      positionX ?? 0,
+      positionY ?? 0,
+      width ?? 1,
+      height ?? 1
+    );
+
+    res.status(201).json({
+      id,
+      dashboardId: req.params.id,
+      type,
+      config: config ?? {},
+      positionX: positionX ?? 0,
+      positionY: positionY ?? 0,
+      width: width ?? 1,
+      height: height ?? 1,
+    });
+  });
+
+  // Delete widget
+  router.delete("/:dashboardId/widgets/:widgetId", authenticate, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+
+    const dashboard = db
+      .prepare("SELECT * FROM dashboards WHERE id = ? AND tenant_id = ?")
+      .get(req.params.dashboardId, tenantId) as DashboardRow | undefined;
+
+    if (!dashboard) {
+      res.status(404).json({ error: "Dashboard not found" });
+      return;
+    }
+
+    const widget = db
+      .prepare("SELECT * FROM widgets WHERE id = ? AND dashboard_id = ?")
+      .get(req.params.widgetId, req.params.dashboardId) as WidgetRow | undefined;
+
+    if (!widget) {
+      res.status(404).json({ error: "Widget not found" });
+      return;
+    }
+
+    db.prepare("DELETE FROM widgets WHERE id = ?").run(req.params.widgetId);
+
+    res.status(204).send();
+  });
+
+  return router;
+}
diff --git a/src/routes/events.ts b/src/routes/events.ts
new file mode 100644
index 0000000..3c73166
--- /dev/null
+++ b/src/routes/events.ts
@@ -0,0 +1,136 @@
+import { Router, Request, Response } from "express";
+import Database from "better-sqlite3";
+import { v4 as uuidv4 } from "uuid";
+import { authenticate } from "../auth.js";
+
+export function createEventRoutes(db: Database.Database): Router {
+  const router = Router();
+
+  // Ingest single event
+  router.post("/", authenticate, (req: Request, res: Response): void => {
+    const { name, properties, timestamp, sessionId } = req.body;
+
+    if (!name) {
+      res.status(400).json({ error: "name is required" });
+      return;
+    }
+
+    const id = uuidv4();
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+    const eventTimestamp = timestamp ?? new Date().toISOString();
+    const eventProperties = properties ? JSON.stringify(properties) : "{}";
+
+    db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    ).run(id, tenantId, name, eventProperties, eventTimestamp, userId, sessionId ?? null);
+
+    res.status(201).json({
+      id,
+      tenantId,
+      name,
+      properties: properties ?? {},
+      timestamp: eventTimestamp,
+      userId,
+      sessionId: sessionId ?? null,
+    });
+  });
+
+  // Ingest batch of events
+  router.post("/batch", authenticate, (req: Request, res: Response): void => {
+    const { events } = req.body;
+
+    if (!Array.isArray(events) || events.length === 0) {
+      res.status(400).json({ error: "events array is required and must not be empty" });
+      return;
+    }
+
+    const tenantId = req.user!.tenantId;
+    const userId = req.user!.userId;
+
+    const insertStmt = db.prepare(
+      "INSERT INTO events (id, tenant_id, name, properties, timestamp, user_id, session_id) VALUES (?, ?, ?, ?, ?, ?, ?)"
+    );
+
+    const results: Array<{ id: string; name: string }> = [];
+
+    const insertMany = db.transaction(() => {
+      for (const event of events) {
+        if (!event.name) continue;
+        const id = uuidv4();
+        const eventTimestamp = event.timestamp ?? new Date().toISOString();
+        const eventProperties = event.properties
+          ? JSON.stringify(event.properties)
+          : "{}";
+
+        insertStmt.run(
+          id,
+          tenantId,
+          event.name,
+          eventProperties,
+          eventTimestamp,
+          userId,
+          event.sessionId ?? null
+        );
+        results.push({ id, name: event.name });
+      }
+    });
+
+    insertMany();
+
+    res.status(201).json({ inserted: results.length, events: results });
+  });
+
+  // List events (with optional filters)
+  router.get("/", authenticate, (req: Request, res: Response): void => {
+    const tenantId = req.user!.tenantId;
+    const { name, startDate, endDate, limit, offset } = req.query;
+
+    let query = "SELECT * FROM events WHERE tenant_id = ?";
+    const params: (string | number)[] = [tenantId];
+
+    if (name) {
+      query += " AND name = ?";
+      params.push(name as string);
+    }
+    if (startDate) {
+      query += " AND timestamp >= ?";
+      params.push(startDate as string);
+    }
+    if (endDate) {
+      query += " AND timestamp <= ?";
+      params.push(endDate as string);
+    }
+
+    query += " ORDER BY timestamp DESC";
+
+    const lim = parseInt(limit as string) || 100;
+    const off = parseInt(offset as string) || 0;
+    query += " LIMIT ? OFFSET ?";
+    params.push(lim, off);
+
+    const rows = db.prepare(query).all(...params) as Array<{
+      id: string;
+      tenant_id: string;
+      name: string;
+      properties: string;
+      timestamp: string;
+      user_id: string;
+      session_id: string | null;
+    }>;
+
+    const events = rows.map((row) => ({
+      id: row.id,
+      tenantId: row.tenant_id,
+      name: row.name,
+      properties: JSON.parse(row.properties),
+      timestamp: row.timestamp,
+      userId: row.user_id,
+      sessionId: row.session_id,
+    }));
+
+    res.json({ events, limit: lim, offset: off });
+  });
+
+  return router;
+}
diff --git a/src/routes/export.ts b/src/routes/export.ts
