+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import { TimeTracker } from "../src/index.js";
+import { unlinkSync, existsSync } from "node:fs";
+import { join } from "node:path";
+import { tmpdir } from "node:os";
+
+function tmpFile(): string {
+  return join(tmpdir(), `time-tracker-test-${Date.now()}-${Math.random().toString(36).slice(2)}.json`);
+}
+
+describe("TimeTracker", () => {
+  let filePath: string;
+  let tracker: TimeTracker;
+
+  beforeEach(() => {
+    filePath = tmpFile();
+    tracker = new TimeTracker(filePath);
+  });
+
+  afterEach(() => {
+    try {
+      if (existsSync(filePath)) unlinkSync(filePath);
+    } catch {
+      // ignore
+    }
+  });
+
+  describe("start/stop", () => {
+    it("should start a timer", () => {
+      const entry = tracker.start("coding");
+      expect(entry.task).toBe("coding");
+      expect(entry.start).toBeTruthy();
+      expect(entry.stop).toBeNull();
+    });
+
+    it("should stop a running timer", () => {
+      tracker.start("coding");
+      const stopped = tracker.stop();
+      expect(stopped.task).toBe("coding");
+      expect(stopped.stop).toBeTruthy();
+    });
+
+    it("should auto-stop previous timer when starting a new one", () => {
+      tracker.start("coding");
+      tracker.start("review");
+
+      const entries = tracker.getEntries();
+      expect(entries).toHaveLength(2);
+      expect(entries[0].task).toBe("coding");
+      expect(entries[0].stop).toBeTruthy();
+      expect(entries[1].task).toBe("review");
+      expect(entries[1].stop).toBeNull();
+    });
+
+    it("should throw when starting with empty name", () => {
+      expect(() => tracker.start("")).toThrow();
+      expect(() => tracker.start("   ")).toThrow();
+    });
+
+    it("should throw when stopping with no running timer", () => {
+      expect(() => tracker.stop()).toThrow();
+    });
+
+    it("should throw when stopping after already stopped", () => {
+      tracker.start("coding");
+      tracker.stop();
+      expect(() => tracker.stop()).toThrow();
+    });
+  });
+
+  describe("persistence", () => {
+    it("should persist entries to disk", () => {
+      tracker.start("coding");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      const entries = tracker2.getEntries();
+      expect(entries).toHaveLength(1);
+      expect(entries[0].task).toBe("coding");
+    });
+
+    it("should create parent directories if they don't exist", () => {
+      const deepPath = join(tmpdir(), `deep-${Date.now()}`, "nested", "dir", "data.json");
+      const t = new TimeTracker(deepPath);
+      t.start("test");
+      t.stop();
+      expect(existsSync(deepPath)).toBe(true);
+      // Clean up
+      try { unlinkSync(deepPath); } catch { /* ignore */ }
+    });
+  });
+
+  describe("querying", () => {
+    it("should return all entries", () => {
+      tracker.start("a");
+      tracker.start("b");
+      tracker.stop();
+      expect(tracker.getEntries()).toHaveLength(2);
+    });
+
+    it("should filter by date range", () => {
+      tracker.start("old-task");
+      tracker.stop();
+
+      const now = new Date();
+      const future = new Date(now.getTime() + 100000);
+
+      tracker.start("new-task");
+      tracker.stop();
+
+      const entries = tracker.getEntries(now, future);
+      // new-task was started at or after `now`
+      expect(entries.length).toBeGreaterThanOrEqual(1);
+      expect(entries.every((e) => e.task === "new-task")).toBe(true);
+    });
+  });
+
+  describe("summary", () => {
+    it("should sum time per task", () => {
+      tracker.start("coding");
+      tracker.stop();
+      tracker.start("coding");
+      tracker.stop();
+
+      const summary = tracker.getSummary();
+      expect(summary["coding"]).toBeGreaterThanOrEqual(0);
+      expect(typeof summary["coding"]).toBe("number");
+    });
+
+    it("should use current time for running tasks", () => {
+      tracker.start("running-task");
+      const summary = tracker.getSummary();
+      expect(summary["running-task"]).toBeGreaterThanOrEqual(0);
+    });
+  });
+
+  describe("unicode support", () => {
+    it("should handle unicode task names", () => {
+      tracker.start("日本語タスク");
+      tracker.stop();
+      const entries = tracker.getEntries();
+      expect(entries[0].task).toBe("日本語タスク");
+    });
+
+    it("should handle emoji task names", () => {
+      tracker.start("🚀 Deploy");
+      tracker.stop();
+      const summary = tracker.getSummary();
+      expect(summary["🚀 Deploy"]).toBeGreaterThanOrEqual(0);
+    });
+
+    it("should persist unicode names", () => {
+      tracker.start("café ☕");
+      tracker.stop();
+
+      const tracker2 = new TimeTracker(filePath);
+      expect(tracker2.getEntries()[0].task).toBe("café ☕");
+    });
   });
 });
