+    // Button 0 affects counter 0
+    // Button 1 affects counter 0
+    // All solutions where b0 + b1 ≡ 2 (mod 5):
+    //   (0,2) sum=2, (1,1) sum=2, (2,0) sum=2, (3,4) sum=7, (4,3) sum=7
+    // Minimum sum: 2. Lex smallest with sum 2: [0,2]
+    const result = solveCounter([2], [[0], [0]], 5);
+    expect(result).toEqual([0, 2]);
+  });
+
