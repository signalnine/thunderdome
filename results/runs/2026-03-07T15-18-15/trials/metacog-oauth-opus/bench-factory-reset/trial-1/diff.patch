+    // Button 0: affects [0, 1]
+    // Button 1: affects [1, 2]
+    // Button 2: affects [0]
+    // Target: [1, 1, 0]
+    // Equations:
+    //   b0 + b2 = 1 (mod 2)
+    //   b0 + b1 = 1 (mod 2)
+    //   b1 = 0 (mod 2)
+    // From eq3: b1 = 0
+    // From eq2: b0 = 1
+    // From eq1: b2 = 0
+    // Result: [1, 0, 0]
+    expect(result).toEqual([1, 0, 0]);
+  });
+
+  it('should find lex smallest on sum tie', () => {
