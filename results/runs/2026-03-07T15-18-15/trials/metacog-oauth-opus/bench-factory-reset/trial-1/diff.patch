 it('should handle single button', () => {\n    // Counter 0 target: 3, modulus 5\n    // Button 0 affects counter 0\n    // Press 3 times → counter 0 = 3\n    const result = solveCounter([3], [[0]], 5);\n    expect(result).toEqual([3]);\n  });\n\n  it('should handle multiple independent counters', () => {\n    // Counter 0 target: 2, counter 1 target: 3, modulus 5\n    // Button 0 affects counter 0\n    // Button 1 affects counter 1\n    const result = solveCounter([2, 3], [[0], [1]], 5);\n    expect(result).toEqual([2, 3]);\n  });\n\n  it('should return null when no solution exists', () => {\n    // Counter 0 target: 1, modulus 3\n    // No buttons → can't reach target\n    const result = solveCounter([1], [], 3);\n    expect(result).toBeNull();\n  });\n\n  it('should handle overlapping buttons', () => {\n    // Counter 0 target: 1, counter 1 target: 1, modulus 2\n    // Button 0 affects [0, 1] → pressing once sets both to 1\n    const result = solveCounter([1, 1], [[0, 1]], 2);\n    expect(result).toEqual([1]);\n  });\n\n  it('should return null for inconsistent system', () => {\n    // Counter 0 target: 1, counter 1 target: 0, modulus 2\n    // Button 0 affects [0, 1] → always sets both equally\n    const result = solveCounter([1, 0], [[0, 1]], 2);\n    expect(result).toBeNull();\n  });\n\n  it('should find minimum total presses', () => {\n    // Counter 0 target: 0, modulus 5\n    // Button 0 affects counter 0\n    // Solutions: 0 presses (target is 0) → result [0]\n    const result = solveCounter([0], [[0]], 5);\n    expect(result).toEqual([0]);\n  });\n\n  it('should use modular arithmetic', () => {\n    // Counter 0 target: 1, modulus 3\n    // Button 0 affects counter 0\n    // Button 1 affects counter 0\n    // Solutions:\n    //   b0=0, b1=1 → sum=1 → [0,1]\n    //   b0=1, b1=0 → sum=1 → [1,0]\n    //   b0=2, b1=2 → sum=4 → [2,2]\n    // Minimum sum: 1. Lex smallest: [0,1]\n    const result = solveCounter([1], [[0], [0]], 3);\n    expect(result).toEqual([