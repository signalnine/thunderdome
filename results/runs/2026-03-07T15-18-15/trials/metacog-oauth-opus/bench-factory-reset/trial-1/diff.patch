ntFree: number): bigint {\n   110→    let sig = 0n;\n   111→    for (let r = 0; r < rank; r++) {\n   112→      const relevantBits = (pivotFreeEffect[r] >> BigInt(startFree)) & ((1n << BigInt(countFree)) - 1n);\n   113→      const masked = relevantBits & BigInt(freeMask);\n   114→      let parity = 0n;\n   115→      let tmp = masked;\n   116→      while (tmp) { parity ^= 1n; tmp &= tmp - 1n; }\n   117→      if (parity) sig |= 1n << BigInt(r);\n   118→    }\n   119→    return sig;\n   120→  }\n   121→\n   122→  function bigPopcount(x: bigint): number {\n   123→    let count = 0;\n   124→    while (x) { x &= x - 1n; count++; }\n   125→    return count;\n   126→  }\n   127→\n   128→  function bitcount(x: number): number {\n   129→    let count = 0;\n   130→    while (x) { x &= x - 1; count++; }\n   131→    return count;\n   132→  }\n   133→\n   134→  if (numFree <= 25) {\n   135→    let bestResult: number[] | null = null;\n   136→    let bestCount = Infinity;\n   137→\n   138→    for (let mask = 0; mask < (1 << numFree); mask++) {\n   139→      const freeCount = bitcount(mask);\n   140→      const sig = getSignature(mask, 0, numFree);\n   141→      const pivotPresses = bigPopcount(basePivotRHS ^ sig);\n   142→      const total = freeCount + pivotPresses;\n   143→\n   144→      if (total < bestCount) {\n   145→        bestCount = total;\n   146→        bestResult = buildToggleResult(mask, numFree, freeVars, rows, pivotCol, rank, numButtons);\n   147→      } else if (total === bestCount) {\n   148→        const candidate = buildToggleResult(mask, numFree, freeVars, rows, pivotCol, rank, numButtons);\n   149→        if (lexSmaller(candidate, bestResult!)) {\n   150→          bestResult = candidate;\n   151→        }\n   152→      }\n   153→    }\n   154→\n   155→    return bestResult!;\n   156→  }\n   157→\n   158→  // MITM for numFree > 25 (rank < 15, so ≤ 32768 distinct signatures)\n   159→  const half1Size = Math.floor(numFree / 2);\n   160→  const half2Size = numFree -