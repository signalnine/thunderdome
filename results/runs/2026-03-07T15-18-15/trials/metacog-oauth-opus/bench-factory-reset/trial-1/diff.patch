 a.length; i++) {\n   259→    if (a[i] !== b[i]) return a[i] < b[i];\n   260→  }\n   261→  return false;\n   262→}\n   263→\n   264→// ─── Counter Solver ──────────────────────────────────────────────────────────\n   265→\n   266→export function solveCounter(\n   267→  lights: number[],\n   268→  buttons: number[][],\n   269→  modulus: number\n   270→): number[] | null {\n   271→  const numCounters = lights.length;\n   272→  const numButtons = buttons.length;\n   273→\n   274→  // Build augmented matrix [A | target]\n   275→  const matrix: number[][] = [];\n   276→  for (let i = 0; i < numCounters; i++) {\n   277→    const row = new Array(numButtons + 1).fill(0);\n   278→    for (let j = 0; j < numButtons; j++) {\n   279→      if (buttons[j].includes(i)) row[j] = 1;\n   280→    }\n   281→    row[numButtons] = lights[i];\n   282→    matrix.push(row);\n   283→  }\n   284→\n   285→  // Gaussian elimination over GF(p) → reduced row echelon form\n   286→  const pivotCol: number[] = new Array(numCounters).fill(-1);\n   287→  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);\n   288→  let rank = 0;\n   289→\n   290→  for (let col = 0; col < numButtons; col++) {\n   291→    let found = -1;\n   292→    for (let row = rank; row < numCounters; row++) {\n   293→      if (matrix[row][col] !== 0) { found = row; break; }\n   294→    }\n   295→    if (found === -1) continue;\n   296→\n   297→    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n   298→    pivotCol[rank] = col;\n   299→    pivotRowForCol[col] = rank;\n   300→\n   301→    const inv = modInverse(matrix[rank][col], modulus);\n   302→    for (let c = 0; c < numButtons + 1; c++) {\n   303→      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;\n   304→    }\n   305→\n   306→    for (let row = 0; row < numCounters; row++) {\n   307→      if (row !== rank && matrix[row][col] !== 0) {\n   308→        const factor = matrix[row][col];\n   309→        for (let c = 0; c < numButtons + 1; c++) {\n   310→          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;\n   311→        }\n   312→      }\n   313→    }\n   314→    rank++;\n   315→  }\n   316→\n   317→  // Check consistency\n   318→  for (let row = rank; row < numCounters; row++) {\n   319→    if (matrix[row][numButtons] !== 0) return null;\n   320→  }\n   321→\n   322→  // Identify free variables\n   323→  const freeVars: number[] = [];\n   324→  for (let col = 0; col < numButtons; col++) {\n   325→    if (pivotRowForCol[col] === -1) freeVars.push(col);\n   326→  }\n   327→\n   328→  const numFree = freeVars.length;\n   329→\n   330→  if (numFree === 0) {\n   331→    const result = new Array(numButtons).fill(0);\n   332→    for (let r = 0; r < rank; r++) {\n   333→      result[pivotCol[r]] = matrix[r][numButtons];\n   334→    }\n   335→    return result;\n   336→  }\n   337→\n   338→  // Extract free variable effects and RHS\n   339→  const freeEffect: number[][] = [];\n   340→  for (let r = 0; r < rank; r++) {\n   341→    const effects: number[] = [];\n   342→    for (let f = 0; f < numFree; f++) effects.push(matrix[r][freeVars[f]]);\n   343→    freeEffect.push(effects);\n   344→  }\n   345→\n   346→  const rhsVals: number[] = [];\n   347→  for (let r = 0; r < rank; r++) rhsVals.push(matrix[r][numButtons]);\n   348→\n   349→  // Strategy: use brute force for small search space, DP for small rank\n   350→  const bruteForceSize = Math.pow(modulus, numFree);\n   351→  const dpStateSize = Math.pow(modulus, rank);\n   352→  const dpWork = numFree * dpStateSize * modulus;\n   353→\n   354→  if (bruteForceSize <= 5_000_000) {\n   355→    return counterBruteForce(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n   356→  } else if (dpWork <= 100_000_000 && dpStateSize <= 5_000_000) {\n   357→    return counterDP(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n   358→  } else {\n   359→    // Fall back to MITM via DP on each half\n   360→    return counterMITM(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n   361→  }\n   362→}\n   363→\n   364→function counterBruteForce(\n   365→  numButtons: number, numFree: number, freeVars: number[],\n   366→  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n   367→  rank: number, modulus: number\n   368→): number[] {\n   369→  let bestResult: number[] | null = null;\n   370→  let bestSum = Infinity;\n   371→  const freeVals = new Array(numFree).fill(0);\n   372→\n   373→  // eslint-disable-next-line no-constant-condition\n   374→  while (true) {\n   375→    let totalSum = 0;\n   376→    const result = new Array(numButtons).fill(0);\n   377→\n   378→    for (let f = 0; f < numFree; f++) {\n   379→      result[freeVars[f]] = freeVals[f];\n   380→      totalSum += freeVals[f];\n   381→    }\n   382→\n   383→    if (totalSum <= bestSum) {\n   384→      for (let r = 0; r < rank; r++) {\n   385→        let val = rhsVals[r];\n   386→        for (let f = 0; f < numFree; f++) {\n   387→          val = ((val - freeEffect[r][f] * freeVals[f]) % modulus + modulus * modulus) % modulus;\n   388→        }\n   389→        result[pivotCol[r]] = val;\n   390→        totalSum += val;\n   391→      }\n   392→\n   393→      if (totalSum < bestSum || (totalSum === bestSum && lexSmallerArr(result, bestResult!))) {\n   394→        bestSum = totalSum;\n   395→        bestResult = [...result];\n   396→      }\n   397→    }\n   398→\n   399→    let carry = true;\n   400→    for (let f = numFree - 1; f >= 0 && carry; f--) {\n   401→      freeVals[f]++;\n   402→      if (freeVals[f] >= modulus) freeVals[f] = 0;\n   403→      else carry = false;\n   404→    }\n   405→    if (carry) break;\n   406→  }\n   407→\n   408→  return bestResult!;\n   409→}\n   410→\n   411→/**\n   412→ * DP approach using backward DP + forward reconstruction.\n   413→ * State = contribution vector encoded as integer (p^rank states).\n   414→ */\n   415→function counterDP(\n   416→  numButtons: number, numFree: number, freeVars: number[],\n   417→  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n   418→  rank: number, modulus: number\n   419→): number[] {\n   420→  const totalStates = Math.round(Math.pow(modulus, rank));\n   421→\n   422→  // Backward DP: backDP[f][s] = min cost (sum of free vars f..numFree-1 + pivot cost)\n   423→  // starting from contribution state s.\n   424→  // Base case (f = numFree): backDP[numFree][s] = pivot cost for state s.\n   425→\n   426→  // Compute base case: pivot cost for each final state\n   427→  const baseCost = new Float64Array(totalStates);\n   428→  for (let s = 0; s < totalStates; s++) {\n   429→    let pivotSum = 0;\n   430→    let tmp = s;\n   431→    for (let r = rank - 1; r >= 0; r--) {\n   432→      const c = tmp % modulus;\n   433→      pivotSum += (rhsVals[r] - c + modulus * modulus) % modulus;\n   434→      tmp = Math.floor(tmp / modulus);\n   435→    }\n   436→    baseCost[s] = pivotSum;\n   437→  }\n   438→\n   439→  // Build all backward layers (we need them for reconstruction)\n   440→  const backLayers: Float64Array[] = new Array(numFree + 1);\n   441→  backLayers[numFree] = baseCost;\n   442→\n   443→  for (let f = numFree - 1; f >= 0; f--) {\n   444→    const prev = new Float64Array(totalStates).fill(Infinity);\n   445→\n   446→    for (let s = 0; s < totalStates; s++) {\n   447→      const contrib = decodeState(s, rank, modulus);\n   448→\n   449→      for (let v = 0; v < modulus; v++) {\n   450→        const ns = encodeTransition(contrib, freeEffect, f, v, rank, modulus);\n   451→        const cost = v + backLayers[f + 1][ns];\n   452→        if (cost < prev[s]) prev[s] = cost;\n   453→      }\n   454→    }\n   455→\n   456→    backLayers[f] = prev;\n   457→  }\n   458→\n   459→  // Forward reconstruction: greedily pick smallest v at each step\n   460→  const freeVals = new Array(numFree);\n   461→  let currentState = 0;\n   462→\n   463→  for (let f = 0; f < numFree; f++) {\n   464→    const contrib = decodeState(currentState, rank, modulus);\n   465→    const targetCost = backLayers[f][currentState];\n   466→\n   467→    for (let v = 0; v < modulus; v++) {\n   468→      const ns = encodeTransition(contrib, freeEffect, f, v, rank, modulus);\n   469→      if (v + backLayers[f + 1][ns] === targetCost) {\n   470→        freeVals[f] = v;\n   471→        currentState = ns;\n   472→        break;\n   473→      }\n   474→    }\n   475→  }\n   476→\n   477→  // Build result\n   478→  const result = new Array(numButtons).fill(0);\n   479→  for (let f = 0; f < numFree; f++) {\n   480→    result[freeVars[f]] = freeVals[f];\n   481→  }\n   482→\n   483→  let tmp = currentState;\n   484→  for (let r = rank - 1; r >= 0; r--) {\n   485→    const c = tmp % modulus;\n   486→    result[pivotCol[r]] = (rhsVals[r] - c + modulus * modulus) % modulus;\n   487→    tmp = Math.floor(tmp / modulus);\n   488→  }\n   489→\n   490→  return result;\n   491→}\n   492→\n   493→/**\n   494→ * MITM approach: split free variables into two halves, run backward DP on each,\n   495→ * then combine by iterating over all state pairs.\n   496→ */\n   497→function counterMITM(\n   498→  numButtons: number, numFree: number, freeVars: number[],\n   499→  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n   500→  rank: number, modulus: number\n   501→): number[] {\n   502→  const totalStates = Math.round(Math.pow(modulus, rank));\n   503→  const half1Size = Math.floor(numFree / 2);\n   504→  const half2Size = numFree - half1Size;\n   505→\n   506→  // Build backward DP for half1 (free vars 0..half1Size-1)\n   507→  // backH1[f][s] = min cost of vars f..half1Size-1, starting from state s\n   508→  // Base: backH1[half1Size][s] = 0 for all s (no more vars in this half, no pivot cost yet)\n   509→  const h1Layers: Float64Array[] = new Array(half1Size + 1);\n   510→  h1Layers[half1Size] = new Float64Array(totalStates).fill(0);\n   511→\n   512→  for (let f = half1Size - 1; f >= 0; f--) {\n   513→    const prev = new Float64Array(totalStates).fill(Infinity);\n   514→    for (let s = 0; s < totalStates; s++) {\n   515→      const contrib = decodeState(s, rank, modulus);\n   516→      for (let v = 0; v < modulus; v++) {\n   517→        const ns = encodeTransition(contrib, freeEffect, f, v, rank, modulus);\n   518→        const cost = v + h1Layers[f + 1][ns];\n   519→        if (cost < prev[s]) prev[s] = cost;\n   520→      }\n   521→    }\n   522→    h1Layers[f] = prev;\n   523→  }\n   524→\n   525→  // Build backward DP for half2 (free vars half1Size..numFree-1)\n   526→  // Base: backH2[half2Size][s] = pivotCost(s), since after all free vars, pivot cost applies\n   527→  const baseCost = new Float64Array(totalStates);\n   528→  for (let s = 0; s < totalStates; s++) {\n   529→    let pivotSum = 0;\n   530→    let tmp = s;\n   531→    for (let r = rank - 1; r >= 0; r--) {\n   532→      const c = tmp % modulus;\n   533→      pivotSum += (rhsVals[r] - c + modulus * modulus) % modulus;\n   534→      tmp = Math.floor(tmp / modulus);\n   535→    }\n   536→    baseCost[s] = pivotSum;\n   537→  }\n   538→\n   539→  const h2Layers: Float64Array[] = new Array(half2Size + 1);\n   540→  h2Layers[half2Size] = baseCost;\n   541→\n   542→  for (let f = half2Size - 1; f >= 0; f--) {\n   543→    const prev = new Float64Array(totalStates).fill(Infinity);\n   544→    for (let s = 0; s < totalStates; s++) {\n   545→      const contrib = decodeState(s, rank, modulus);\n   546→      for (let v = 0; v < modulus; v++) {\n   547→        const ns = encodeTransition(contrib, freeEffect, half1Size + f, v, rank, modulus);\n   548→        const cost = v + h2Layers[f + 1][ns];\n   549→        if (cost < prev[s]) prev[s] = cost;\n   550→      }\n   551→    }\n   552→    h2Layers[f] = prev;\n   553→  }\n   554→\n   555→  // Combine: total cost for a given \"intermediate state\" s (state after half1, before half2)\n   556→  // = h1_cost_to_reach_s + h2_cost_from_s\n   557→  // But h1's \"cost to reach s from state 0\" is h1Layers[0][0] minus... no.\n   558→  // Actually:\n   559→  // h1Layers[0][0] = min cost of half1 vars (sum of vars 0..half1Size-1)\n   560→  //   when starting from state 0. But this already picks the best final state.\n   561→  // We need: for each intermediate state s, min cost of half1 vars to reach s from state 0.\n   562→  //\n   563→  // The backward DP gives min cost REMAINING, not min cost TO REACH.\n   564→  // We need a forward DP for half1 to get min cost to reach each state.\n   565→\n   566→  // Forward DP for half1: fwdH1[s] = min sum of vars 0..half1Size-1 that reaches state s from state 0\n   567→  let h1Fwd = new Float64Array(totalStates).fill(Infinity);\n   568→  h1Fwd[0] = 0;\n   569→\n   570→  for (let f = 0; f < half1Size; f++) {\n   571→    const next = new Float64Array(totalStates).fill(Infinity);\n   572→    for (let s = 0; s < totalStates; s++) {\n   573→      if (h1Fwd[s] === Infinity) continue;\n   574→      const contrib = decodeState(s, rank, modulus);\n   575→      for (let v = 0; v < modulus; v++) {\n   576→        const ns = encodeTransition(contrib, freeEffect, f, v, rank, modulus);\n   577→        const cost = h1Fwd[s] + v;\n   578→        if (cost < next[ns]) next[ns] = cost;\n   579→      }\n   580→    }\n   581→    h1Fwd = next;\n   582→  }\n   583→\n   584→  // Now find optimal intermediate state\n   585→  let bestCost = Infinity;\n   586→  let bestMidState = 0;\n   587→\n   588→  for (let s = 0; s < totalStates; s++) {\n   589→    if (h1Fwd[s] === Infinity) continue;\n   590→    const total = h1Fwd[s] + h2Layers[0][s];\n   591→    if (total < bestCost) {\n   592→      bestCost = total;\n   593→      bestMidState = s;\n   594→    }\n   595→  }\n   596→\n   597→  // Reconstruct half1: use h1Layers backward DP for lex-smallest reaching bestMidState\n   598→  // Build backward layers specifically for reaching bestMidState\n   599→  const h1ReconLayers: Float64Array[] = new Array(half1Size + 1);\n   600→  h1ReconLayers[half1Size] = new Float64Array(totalStates).fill(Infinity);\n   601→  h1ReconLayers[half1Size][bestMidState] = 0;\n   602→\n   603→  for (let f = half1Size - 1; f >= 0; f--) {\n   604→    const prev = new Float64Array(totalStates).fill(Infinity);\n   605→    for (let s = 0; s < totalStates; s++) {\n   606→      const contrib = decodeState(s, rank, modulus);\n   607→      for (let v = 0; v < modulus; v++) {\n   608→        const ns = encodeTransition(contrib, freeEffect, f, v, rank, modulus);\n   609→        const cost = v + h1ReconLayers[f + 1][ns];\n   610→        if (cost < prev[s]) prev[s] = cost;\n   611→      }\n   612→    }\n   613→    h1ReconLayers[f] = prev;\n   614→  }\n   615→\n   616→  const h1Vals = new Array(half1Size);\n   617→  let state = 0;\n   618→  for (let f = 0; f < half1Size; f++) {\n   619→    const contrib = decodeState(state, rank, modulus);\n   620→    const target = h1ReconLayers[f][state];\n   621→    for (let v = 0; v < modulus; v++) {\n   622→      const ns = encodeTransition(contrib, freeEffect, f, v, rank, modulus);\n   623→      if (v + h1ReconLayers[f + 1][ns] === target) {\n   624→        h1Vals[f] = v;\n   625→        state = ns;\n   626→        break;\n   627→      }\n   628→    }\n   629→  }\n   630→\n   631→  // Reconstruct half2: use h2Layers for lex-smallest from bestMidState\n   632→  const h2Vals = new Array(half2Size);\n   633→  state = bestMidState;\n   634→  for (let f = 0; f < half2Size; f++) {\n   635→    const contrib = decodeState(state, rank, modulus);\n   636→    const target = h2Layers[f][state];\n   637→    for (let v = 0; v < modulus; v++) {\n   638→      const ns = encodeTransition(contrib, freeEffect, half1Size + f, v, rank, modulus);\n   639→      if (v + h2Layers[f + 1][ns] === target) {\n   640→        h2Vals[f] = v;\n   641→        state = ns;\n   642→        break;\n   643→      }\n   644→    }\n   645→  }\n   646→\n   647→  // But we also need to check all intermediate states that achieve bestCost\n   648→  // to find the lex-smallest overall result.\n   649→  // The current approach picks one midState, but a different midState with the same cost\n   650→  // might yield a lex-smaller result.\n   651→\n   652→  // Collect all tied mid states\n   653→  const tiedMidStates: number[] = [];\n   654→  for (let s = 0; s < totalStates; s++) {\n   655→    if (h1Fwd[s] === Infinity) continue;\n   656→    if (h1Fwd[s] + h2Layers[0][s] === bestCost) {\n   657→      tiedMidStates.push(s);\n   658→    }\n   659→  }\n   660→\n   661→  let bestResult: number[] | null = null;\n   662→\n   663→  for (const midState of tiedMidStates) {\n   664→    // Reconstruct for this midState\n   665→    // Half1 reconstruction\n   666→    const reconLayers: Float64Array[] = new Array(half1Size + 1);\n   667→    reconLayers[half1Size] = new Float64Array(totalStates).fill(Infinity);\n   668→    reconLayers[half1Size][midState] = 0;\n   669→\n   670→    for (let f = half1Size - 1; f >= 0; f--) {\n   671→      const prev = new Float64Array(totalStates).fill(Infinity);\n   672→      for (let s = 0; s < totalStates; s++) {\n   673→        const contrib = decodeState(s, rank, modulus);\n   674→        for (let v = 0; v < modulus; v++) {\n   675→          const ns = encodeTransition(contrib, freeEffect, f, v, rank, modulus);\n   676→          const cost = v + reconLayers[f + 1][ns];\n   677→          if (cost < prev[s]) prev[s] = cost;\n   678→        }\n   679→      }\n   680→      reconLayers[f] = prev;\n   681→    }\n   682→\n   683→    const vals1 = new Array(half1Size);\n   684→    let st = 0;\n   685→    for (let f = 0; f < half1Size; f++) {\n   686→      const contrib = decodeState(st, rank, modulus);\n   687→      const tgt = reconLayers[f][st];\n   688→      for (let v = 0; v < modulus; v++) {\n   689→        const ns = encodeTransition(contrib, freeEffect, f, v, rank, modulus);\n   690→        if (v + reconLayers[f + 1][ns] === tgt) {\n   691→          vals1[f] = v;\n   692→          st = ns;\n   693→          break;\n   694→        }\n   695→      }\n   696→    }\n   697→\n   698→    const vals2 = new Array(half2Size);\n   699→    st = midState;\n   700→    for (let f = 0; f < half2Size; f++) {\n   701→      const contrib = decodeState(st, rank, modulus);\n   702→      const tgt = h2Layers[f][st];\n   703→      for (let v = 0; v < modulus; v++) {\n   704→        const ns = encodeTransition(contrib, freeEffect, half1Size + f, v, rank, modulus);\n   705→        if (v + h2Layers[f + 1][ns] === tgt) {\n   706→          vals2[f] = v;\n   707→          st = ns;\n   708→          break;\n   709→        }\n   710→      }\n   711→    }\n   712→\n   713→    const result = new Array(numButtons).fill(0);\n   714→    for (let f = 0; f < half1Size; f++) result[freeVars[f]] = vals1[f];\n   715→    for (let f = 0; f < half2Size; f++) result[freeVars[half1Size + f]] = vals2[f];\n   716→\n   717→    let tmpSt = st;\n   718→    for (let r = rank - 1; r >= 0; r--) {\n   719→      const c = tmpSt % modulus;\n   720→      result[pivotCol[r]] = (rhsVals[r] - c + modulus * modulus) % modulus;\n   721→      tmpSt = Math.floor(tmpSt / modulus);\n   722→    }\n   723→\n   724→    if (!bestResult || lexSmallerArr(result, bestResult)) {\n   725→      bestResult = result;\n   726→    }\n   727→  }\n   728→\n   729→  return bestResult!;\n   730→}\n   731→\n   732→function decodeState(s: number, rank: number, modulus: number): number[] {\n   733→  const contrib = new Array(rank);\n   734→  let tmp = s;\n   735→  for (let r = rank - 1; r >= 0; r--) {\n   736→    contrib[r] = tmp % modulus;\n   737→    tmp = Math.floor(tmp / modulus);\n   738→  }\n   739→  return contrib;\n   740→}\n   741→\n   742→function encodeTransition(\n   743→  contrib: number[], freeEffect: number[][], f: number, v: number,\n   744→  rank: number, modulus: number\n   745→): number {\n   746→  let key = 0;\n   747→  for (let r = 0; r < rank; r++) {\n   748→    key = key * modulus + (contrib[r] + freeEffect[r][f] * v) % modulus;\n   749→  }\n   750→  return key;\n   751→}\n   752→\n   753→function lexSmallerArr(a: number[], b: number[]): boolean {\n   754→  for (let i = 0; i < a.length; i++) {\n   755→    if (a[i] !== b[i]) return a[i] < b[i];\n   756→  }\n   757→  return false;\n   758→}\n   759→\n   760→function modInverse(a: number, m: number): number {\n   761→  let [old_r, r] = [a % m, m];\n   762→  let [old_s, s] = [1, 0];\n   763→  while (r !== 0) {\n   764→    const quotient = Math.floor(old_r / r);\n   765→    [old_r, r] = [r, old_r - quotient * r];\n   766→    [old_s, s] = [s, old_s - quotient * s];\n   767→  }\n   768→  return ((old_s % m) + m) % m;\n   769→}\n   770→"}]},"parent_tool_use_id":null,"session_id":"b6d44172-140e-44bc-82be-d7c119bf96ba","uuid":"0bf51bee-a0dd-4496-8423-0f55550efa1d","tool_use_result":{"type":"update","filePath":"/workspace/src/index.ts","content":"/**\n * Factory Reset - Toggle and Counter puzzle solvers\n *\n * Both problems reduce to solving systems of linear equations over finite fields.\n * Toggle: GF(2), Counter: GF(p) where p is prime.\n */\n\ninterface Machine {\n  target: boolean[];\n  buttons: number[][];\n}\n\n// ─── Toggle Solver ───────────────────────────────────────────────────────────\n\nexport function solveToggle(machine: Machine): number[] | null {\n  const { target, buttons } = machine;\n  const numLights = target.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | target] over GF(2) using bigint bitmasks\n  const rows: bigint[] = new Array(numLights);\n  for (let i = 0; i < numLights; i++) {\n    let row = 0n;\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) {\n        row |= 1n << BigInt(j);\n      }\n    }\n    if (target[i]) {\n      row |= 1n << BigInt(numButtons);\n    }\n    rows[i] = row;\n  }\n\n  // Gaussian elimination over GF(2) → reduced row echelon form\n  const pivotCol: number[] = new Array(numLights).fill(-1);\n  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    let found = -1;\n    for (let row = rank; row < numLights; row++) {\n      if ((rows[row] >> BigInt(col)) & 1n) {\n        found = row;\n        break;\n      }\n    }\n    if (found === -1) continue;\n\n    [rows[rank], rows[found]] = [rows[found], rows[rank]];\n    pivotCol[rank] = col;\n    pivotRowForCol[col] = rank;\n\n    for (let row = 0; row < numLights; row++) {\n      if (row !== rank && (rows[row] >> BigInt(col)) & 1n) {\n        rows[row] ^= rows[rank];\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency\n  for (let row = rank; row < numLights; row++) {\n    if ((rows[row] >> BigInt(numButtons)) & 1n) {\n      return null;\n    }\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRowForCol[col] === -1) {\n      freeVars.push(col);\n    }\n  }\n\n  if (freeVars.length === 0) {\n    const result: number[] = [];\n    for (let r = 0; r < rank; r++) {\n      if ((rows[r] >> BigInt(numButtons)) & 1n) {\n        result.push(pivotCol[r]);\n      }\n    }\n    result.sort((a, b) => a - b);\n    return result;\n  }\n\n  const numFree = freeVars.length;\n\n  // Precompute: for each pivot row, which free vars affect it\n  const pivotFreeEffect: bigint[] = new Array(rank);\n  for (let r = 0; r < rank; r++) {\n    let effect = 0n;\n    for (let f = 0; f < numFree; f++) {\n      if ((rows[r] >> BigInt(freeVars[f])) & 1n) {\n        effect |= 1n << BigInt(f);\n      }\n    }\n    pivotFreeEffect[r] = effect;\n  }\n\n  let basePivotRHS = 0n;\n  for (let r = 0; r < rank; r++) {\n    if ((rows[r] >> BigInt(numButtons)) & 1n) {\n      basePivotRHS |= 1n << BigInt(r);\n    }\n  }\n\n  function getSignature(freeMask: number | bigint, startFree: number, countFree: number): bigint {\n    let sig = 0n;\n    for (let r = 0; r < rank; r++) {\n      const relevantBits = (pivotFreeEffect[r] >> BigInt(startFree)) & ((1n << BigInt(countFree)) - 1n);\n      const masked = relevantBits & BigInt(freeMask);\n      let parity = 0n;\n      let tmp = masked;\n      while (tmp) { parity ^= 1n; tmp &= tmp - 1n; }\n      if (parity) sig |= 1n << BigInt(r);\n    }\n    return sig;\n  }\n\n  function bigPopcount(x: bigint): number {\n    let count = 0;\n    while (x) { x &= x - 1n; count++; }\n    return count;\n  }\n\n  function bitcount(x: number): number {\n    let count = 0;\n    while (x) { x &= x - 1; count++; }\n    return count;\n  }\n\n  if (numFree <= 25) {\n    let bestResult: number[] | null = null;\n    let bestCount = Infinity;\n\n    for (let mask = 0; mask < (1 << numFree); mask++) {\n      const freeCount = bitcount(mask);\n      const sig = getSignature(mask, 0, numFree);\n      const pivotPresses = bigPopcount(basePivotRHS ^ sig);\n      const total = freeCount + pivotPresses;\n\n      if (total < bestCount) {\n        bestCount = total;\n        bestResult = buildToggleResult(mask, numFree, freeVars, rows, pivotCol, rank, numButtons);\n      } else if (total === bestCount) {\n        const candidate = buildToggleResult(mask, numFree, freeVars, rows, pivotCol, rank, numButtons);\n        if (lexSmaller(candidate, bestResult!)) {\n          bestResult = candidate;\n        }\n      }\n    }\n\n    return bestResult!;\n  }\n\n  // MITM for numFree > 25 (rank < 15, so ≤ 32768 distinct signatures)\n  const half1Size = Math.floor(numFree / 2);\n  const half2Size = numFree - half1Size;\n\n  interface HalfEntry { freeCount: number; freeMask: number; }\n  const half1Table = new Map<bigint, HalfEntry[]>();\n\n  for (let mask = 0; mask < (1 << half1Size); mask++) {\n    const sig = getSignature(mask, 0, half1Size);\n    const fc = bitcount(mask);\n    const entries = half1Table.get(sig);\n    if (entries) {\n      entries.push({ freeCount: fc, freeMask: mask });\n    } else {\n      half1Table.set(sig, [{ freeCount: fc, freeMask: mask }]);\n    }\n  }\n\n  for (const [, entries] of half1Table) {\n    entries.sort((a, b) => a.freeCount - b.freeCount || a.freeMask - b.freeMask);\n    const deduped: HalfEntry[] = [];\n    let lastFc = -1;\n    for (const e of entries) {\n      if (e.freeCount !== lastFc) {\n        deduped.push(e);\n        lastFc = e.freeCount;\n      }\n    }\n    // Replace inline since we can't modify the map entry by reference\n    entries.length = 0;\n    entries.push(...deduped);\n  }\n\n  let bestTotal = Infinity;\n  let bestResult: number[] | null = null;\n\n  for (let mask2 = 0; mask2 < (1 << half2Size); mask2++) {\n    const sig2 = getSignature(mask2, half1Size, half2Size);\n    const fc2 = bitcount(mask2);\n    if (fc2 > bestTotal) continue;\n\n    const needed = basePivotRHS ^ sig2;\n\n    for (const [sig1, entries] of half1Table) {\n      const pivotPresses = bigPopcount(needed ^ sig1);\n      const bestEntry = entries[0];\n      const total = bestEntry.freeCount + fc2 + pivotPresses;\n\n      if (total > bestTotal) continue;\n\n      if (total < bestTotal) {\n        bestTotal = total;\n        bestResult = buildToggleResultMITM(bestEntry.freeMask, mask2, half1Size, half2Size,\n          freeVars, rows, pivotCol, rank, numButtons);\n      } else {\n        for (const entry of entries) {\n          const t = entry.freeCount + fc2 + pivotPresses;\n          if (t > bestTotal) break;\n          const candidate = buildToggleResultMITM(entry.freeMask, mask2, half1Size, half2Size,\n            freeVars, rows, pivotCol, rank, numButtons);\n          if (lexSmaller(candidate, bestResult!)) {\n            bestResult = candidate;\n          }\n        }\n      }\n    }\n  }\n\n  return bestResult!;\n}\n\nfunction buildToggleResult(\n  freeMask: number, numFree: number, freeVars: number[],\n  rows: bigint[], pivotCol: number[], rank: number, numButtons: number\n): number[] {\n  const pressed: number[] = [];\n  for (let f = 0; f < numFree; f++) {\n    if (freeMask & (1 << f)) pressed.push(freeVars[f]);\n  }\n  for (let r = 0; r < rank; r++) {\n    let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n    for (let f = 0; f < numFree; f++) {\n      if ((freeMask & (1 << f)) && (rows[r] >> BigInt(freeVars[f])) & 1n) val ^= 1;\n    }\n    if (val) pressed.push(pivotCol[r]);\n  }\n  pressed.sort((a, b) => a - b);\n  return pressed;\n}\n\nfunction buildToggleResultMITM(\n  mask1: number, mask2: number, half1Size: number, half2Size: number,\n  freeVars: number[], rows: bigint[], pivotCol: number[], rank: number, numButtons: number\n): number[] {\n  return buildToggleResult(mask1 | (mask2 << half1Size), half1Size + half2Size,\n    freeVars, rows, pivotCol, rank, numButtons);\n}\n\nfunction lexSmaller(a: number[], b: number[]): boolean {\n  if (a.length !== b.length) return a.length < b.length;\n  for (let i = 0; i < a.length; i++) {\n    if (a[i] !== b[i]) return a[i] < b[i];\n  }\n  return false;\n}\n\n// ─── Counter Solver ──────────────────────────────────────────────────────────\n\nexport function solveCounter(\n  lights: number[],\n  buttons: number[][],\n  modulus: number\n): number[] | null {\n  const numCounters = lights.length;\n  const numButtons = buttons.length;\n\n  // Build augmented matrix [A | target]\n  const matrix: number[][] = [];\n  for (let i = 0; i < numCounters; i++) {\n    const row = new Array(numButtons + 1).fill(0);\n    for (let j = 0; j < numButtons; j++) {\n      if (buttons[j].includes(i)) row[j] = 1;\n    }\n    row[numButtons] = lights[i];\n    matrix.push(row);\n  }\n\n  // Gaussian elimination over GF(p) → reduced row echelon form\n  const pivotCol: number[] = new Array(numCounters).fill(-1);\n  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);\n  let rank = 0;\n\n  for (let col = 0; col < numButtons; col++) {\n    let found = -1;\n    for (let row = rank; row < numCounters; row++) {\n      if (matrix[row][col] !== 0) { found = row; break; }\n    }\n    if (found === -1) continue;\n\n    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n    pivotCol[rank] = col;\n    pivotRowForCol[col] = rank;\n\n    const inv = modInverse(matrix[rank][col], modulus);\n    for (let c = 0; c < numButtons + 1; c++) {\n      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;\n    }\n\n    for (let row = 0; row < numCounters; row++) {\n      if (row !== rank && matrix[row][col] !== 0) {\n        const factor = matrix[row][col];\n        for (let c = 0; c < numButtons + 1; c++) {\n          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;\n        }\n      }\n    }\n    rank++;\n  }\n\n  // Check consistency\n  for (let row = rank; row < numCounters; row++) {\n    if (matrix[row][numButtons] !== 0) return null;\n  }\n\n  // Identify free variables\n  const freeVars: number[] = [];\n  for (let col = 0; col < numButtons; col++) {\n    if (pivotRowForCol[col] === -1) freeVars.push(col);\n  }\n\n  const numFree = freeVars.length;\n\n  if (numFree === 0) {\n    const result = new Array(numButtons).fill(0);\n    for (let r = 0; r < rank; r++) {\n      result[pivotCol[r]] = matrix[r][numButtons];\n    }\n    return result;\n  }\n\n  // Extract free variable effects and RHS\n  const freeEffect: number[][] = [];\n  for (let r = 0; r < rank; r++) {\n    const effects: number[] = [];\n    for (let f = 0; f < numFree; f++) effects.push(matrix[r][freeVars[f]]);\n    freeEffect.push(effects);\n  }\n\n  const rhsVals: number[] = [];\n  for (let r = 0; r < rank; r++) rhsVals.push(matrix[r][numButtons]);\n\n  // Strategy: use brute force for small search space, DP for small rank\n  const bruteForceSize = Math.pow(modulus, numFree);\n  const dpStateSize = Math.pow(modulus, rank);\n  const dpWork = numFree * dpStateSize * modulus;\n\n  if (bruteForceSize <= 5_000_000) {\n    return counterBruteForce(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n  } else if (dpWork <= 100_000_000 && dpStateSize <= 5_000_000) {\n    return counterDP(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n  } else {\n    // Fall back to MITM via DP on each half\n    return counterMITM(numButtons, numFree, freeVars, freeEffect, rhsVals, pivotCol, rank, modulus);\n  }\n}\n\nfunction counterBruteForce(\n  numButtons: number, numFree: number, freeVars: number[],\n  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n  rank: number, modulus: number\n): number[] {\n  let bestResult: number[] | null = null;\n  let bestSum = Infinity;\n  const freeVals = new Array(numFree).fill(0);\n\n  // eslint-disable-next-line no-constant-condition\n  while (true) {\n    let totalSum = 0;\n    const result = new Array(numButtons).fill(0);\n\n    for (let f = 0; f < numFree; f++) {\n      result[freeVars[f]] = freeVals[f];\n      totalSum += freeVals[f];\n    }\n\n    if (totalSum <= bestSum) {\n      for (let r = 0; r < rank; r++) {\n        let val = rhsVals[r];\n        for (let f = 0; f < numFree; f++) {\n          val = ((val - freeEffect[r][f] * freeVals[f]) % modulus + modulus * modulus) % modulus;\n        }\n        result[pivotCol[r]] = val;\n        totalSum += val;\n      }\n\n      if (totalSum < bestSum || (totalSum === bestSum && lexSmallerArr(result, bestResult!))) {\n        bestSum = totalSum;\n        bestResult = [...result];\n      }\n    }\n\n    let carry = true;\n    for (let f = numFree - 1; f >= 0 && carry; f--) {\n      freeVals[f]++;\n      if (freeVals[f] >= modulus) freeVals[f] = 0;\n      else carry = false;\n    }\n    if (carry) break;\n  }\n\n  return bestResult!;\n}\n\n/**\n * DP approach using backward DP + forward reconstruction.\n * State = contribution vector encoded as integer (p^rank states).\n */\nfunction counterDP(\n  numButtons: number, numFree: number, freeVars: number[],\n  freeEffect: number[][], rhsVals: number[], pivotCol: number[],\n  rank: number, modulus: number\n): number[] {\n  const totalStates = Math.round(Math.pow(modulus, rank));\n\n  // Backward DP: backDP[f][s] = min cost (sum of free vars f..numFree-1 + pivot cost)\n  // starting from contribution state s.\n  // Base case (f = numFree): backDP[numFree][s] = pivot cost for state s.\n\n  // Compute base case: pivot cost for each final state\n  const baseCost = new Float64Array(totalStates);\n  for (let s = 0; s < totalStates; s++) {\n    let pivotSum = 0;\n    let tmp = s;\n    for (let r = rank - 1; r >= 0; r--) {\n      const c = tmp % modulus;\n      pivotSum += (rhsVals[r] - c + modulus * modulus) % modulus;\n      tmp = Math.floor(tmp / modulus);\n    }\n    baseCost[s] = pivotSum;\n  }\n\n  // Build all backward layers (we need them for reconstruction)\n  const backLayers: Float64Array[] = new Array(numFree + 1);\n  backLayers[numFree] = baseCost;\n\n  for (let f = numFree - 1; f >= 0; f--) {\n    const prev = new Float64Array(totalStates).fill(Infinity);\n\n    for (let s = 0; s < totalStates; s++) {\n      const contrib = decodeState(s, rank, modulus);\n\n      for (let v = 0; v < modulus; v++) {\n        const ns = encodeTransition(contrib, freeEffect, f, v, rank, modulus);\n        const cost = v + backLayers[f + 1][ns];\n        if (cost < prev[s]) prev[s] = cost;\n      }\n    }\n\n    backLayers[f] = prev;\n  }\n\n  // Forward reconstruction: greedily pick smallest v at each step\n  const freeVals = new Array(numFree);\n  let currentState = 0;\n\n  for (let f = 0; f < numFree; f++) {\n    const contrib = decodeState(currentState, rank, modulus);\n    const targetCost = backLayers[f][currentState];\n\n    for (let v = 0; v < modulus; v++) {\n      const ns = encodeTransition(contrib, freeEffect, f, v, rank, modulus);\n      if (v + backLayers[f + 1][ns] === targetCost) {\n        freeVals[f] = v;\n        currentState = ns;\n        break;\n      }\n    }\n  }\n\n  // Build result\n  const result = new Array(numButtons).fill(0);\n  fo