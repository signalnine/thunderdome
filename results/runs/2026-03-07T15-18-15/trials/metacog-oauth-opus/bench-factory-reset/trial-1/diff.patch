+import { describe, it, expect } from 'vitest';
+import { solveToggle, solveCounter } from './index.js';
+
+describe('solveToggle', () => {
+  it('should return null when no solution exists', () => {
+    // From the example in TASK.md
+    const result = solveToggle({
+      target: [true, true, false, true],
+      buttons: [[0, 1], [1, 2, 3], [0, 3]],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should return empty array when target is all false', () => {
+    const result = solveToggle({
+      target: [false, false, false],
+      buttons: [[0, 1], [1, 2]],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should handle single button solution', () => {
+    const result = solveToggle({
+      target: [true, true, false],
+      buttons: [[0, 1], [1, 2], [0, 2]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should find minimum presses', () => {
+    // Target: [true, false]
+    // Button 0: toggles [0]
+    // Button 1: toggles [1]
+    // Button 2: toggles [0, 1]
+    // Solution with 1 press: button 0 (gives [true, false]) ✓
+    const result = solveToggle({
+      target: [true, false],
+      buttons: [[0], [1], [0, 1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should find lexicographically smallest solution on tie', () => {
+    // Target: [true, true]
+    // Button 0: toggles [0, 1]
+    // Button 1: toggles [0]
+    // Button 2: toggles [1]
+    // 1-press solution: button 0 → [true, true] ✓
+    // 2-press solution: buttons 1,2 → [true, true]
+    // Minimum is 1 press: [0]
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1], [0], [1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should handle two button solution', () => {
+    // Target: [true, false, true]
+    // Button 0: toggles [0]
+    // Button 1: toggles [1]
+    // Button 2: toggles [2]
+    // Button 3: toggles [0, 2]
+    // Best 1-press: button 3 → [true, false, true] ✓
+    const result = solveToggle({
+      target: [true, false, true],
+      buttons: [[0], [1], [2], [0, 2]],
+    });
+    expect(result).toEqual([3]);
+  });
+
+  it('should handle case with no buttons', () => {
+    const result = solveToggle({
+      target: [true],
+      buttons: [],
+    });
+    expect(result).toBeNull();
+  });
+
+  it('should handle case with no buttons and all false target', () => {
+    const result = solveToggle({
+      target: [false, false],
+      buttons: [],
+    });
+    expect(result).toEqual([]);
+  });
+
+  it('should handle larger case', () => {
+    // 5 lights, identity-like buttons
+    const result = solveToggle({
+      target: [true, true, true, true, true],
+      buttons: [[0], [1], [2], [3], [4]],
+    });
+    expect(result).toEqual([0, 1, 2, 3, 4]);
+  });
+
+  it('should handle case where buttons overlap', () => {
+    // Target: [true, true]
+    // Button 0: toggles [0, 1] → both on
+    // Pressing button 0 gives [true, true] → matches!
+    const result = solveToggle({
+      target: [true, true],
+      buttons: [[0, 1]],
+    });
+    expect(result).toEqual([0]);
+  });
+
+  it('should prefer fewer presses with free variables', () => {
+    // Target: [true, false]
+    // Button 0: toggles [0]
+    // Button 1: toggles [0]
+    // Pressing both cancels out. Pressing one gives [true, false].
+    // Solutions: press 0, or press 1. Minimum is 1 press. Lex smallest: [0]
+    const result = solveToggle({
+      target: [true, false],
+      buttons: [[0], [0]],
+    });
+    expect(result).toEqual([0]);
+  });
+});
+
+describe('solveCounter', () => {
+  it('should return all zeros when target is all zeros', () => {
+    const result = solveCounter([0, 0, 0], [[0, 1], [1, 2]], 5);
+    expect(result).toEqual([0, 0]);
+  });
+
+  it('should handle single button', () => {
+    // Counter 0 target: 3, modulus 5
+    // Button 0 affects counter 0
+    // Press 3 times → counter 0 = 3
+    const result = solveCounter([3], [[0]], 5);
+    expect(result).toEqual([3]);
+  });
+
+  it('should handle multiple independent counters', () => {
+    // Counter 0 target: 2, counter 1 target: 3, modulus 5
+    // Button 0 affects counter 0
+    // Button 1 affects counter 1
+    const result = solveCounter([2, 3], [[0], [1]], 5);
+    expect(result).toEqual([2, 3]);
+  });
+
+  it('should return null when no solution exists', () => {
+    // Counter 0 target: 1, modulus 3
+    // No buttons → can't reach target
+    const result = solveCounter([1], [], 3);
+    expect(result).toBeNull();
+  });
+
+  it('should handle overlapping buttons', () => {
+    // Counter 0 target: 1, counter 1 target: 1, modulus 2
+    // Button 0 affects [0, 1] → pressing once sets both to 1
+    const result = solveCounter([1, 1], [[0, 1]], 2);
+    expect(result).toEqual([1]);
+  });
+
+  it('should return null for inconsistent system', () => {
+    // Counter 0 target: 1, counter 1 target: 0, modulus 2
+    // Button 0 affects [0, 1] → always sets both equally
+    const result = solveCounter([1, 0], [[0, 1]], 2);
+    expect(result).toBeNull();
+  });
+
+  it('should find minimum total presses', () => {
+    // Counter 0 target: 0, modulus 5
+    // Button 0 affects counter 0
+    // Solutions: 0 presses (target is 0) → result [0]
+    const result = solveCounter([0], [[0]], 5);
+    expect(result).toEqual([0]);
+  });
+
+  it('should use modular arithmetic', () => {
