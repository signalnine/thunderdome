+    // Button 1 affects counter 0
+    // Solutions:
+    //   b0=0, b1=1 → sum=1 → [0,1]
+    //   b0=1, b1=0 → sum=1 → [1,0]
+    //   b0=2, b1=2 → sum=4 → [2,2]
+    // Minimum sum: 1. Lex smallest: [0,1]
+    const result = solveCounter([1], [[0], [0]], 3);
+    expect(result).toEqual([0, 1]);
+  });
+
+  it('should handle modulus 2 (binary case)', () => {
