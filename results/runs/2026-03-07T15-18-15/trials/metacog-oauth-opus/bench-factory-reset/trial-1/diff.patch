   let val = Number((rows[r] >> BigInt(numButtons)) & 1n);\n   413→    for (let fv = 0; fv < freeVars.length; fv++) {\n   414→      if (freeValues[freeVars[fv]] && (rows[r] >> BigInt(freeVars[fv])) & 1n) {\n   415→        val ^= 1;\n   416→      }\n   417→    }\n   418→    if (val) {\n   419→      pressed.push(col);\n   420→    }\n   421→  }\n   422→\n   423→  pressed.sort((a, b) => a - b);\n   424→  return pressed;\n   425→}\n   426→\n   427→function lexSmaller(a: number[], b: number[]): boolean {\n   428→  // Compare two sorted arrays lexicographically as sets\n   429→  // Shorter length wins first (fewer presses)\n   430→  if (a.length !== b.length) return a.length < b.length;\n   431→  for (let i = 0; i < a.length; i++) {\n   432→    if (a[i] !== b[i]) return a[i] < b[i];\n   433→  }\n   434→  return false;\n   435→}\n   436→\n   437→/**\n   438→ * Solve the counter puzzle using Gaussian elimination over GF(p).\n   439→ *\n   440→ * We build a matrix A where A[i][j] = 1 if button j affects counter i, else 0.\n   441→ * We solve A * x = target (mod p), where x[j] ∈ {0, ..., p-1}.\n   442→ * Among all solutions, return the one with minimum sum of presses,\n   443→ * breaking ties by lex smallest result array.\n   444→ */\n   445→export function solveCounter(\n   446→  lights: number[],\n   447→  buttons: number[][],\n   448→  modulus: number\n   449→): number[] | null {\n   450→  const numCounters = lights.length;\n   451→  const numButtons = buttons.length;\n   452→\n   453→  // Build augmented matrix [A | lights] over GF(modulus)\n   454→  // matrix[i][j] = coefficient of button j in counter i's equation\n   455→  // matrix[i][numButtons] = target value for counter i\n   456→  const matrix: number[][] = [];\n   457→  for (let i = 0; i < numCounters; i++) {\n   458→    const row = new Array(numButtons + 1).fill(0);\n   459→    for (let j = 0; j < numButtons; j++) {\n   460→      if (buttons[j].includes(i)) {\n   461→        row[j] = 1;\n   462→      }\n   463→    }\n   464→    row[numButtons] = lights[i];\n   465→    matrix.push(row);\n   466→  }\n   467→\n   468→  // Gaussian elimination over GF(modulus)\n   469→  const pivotCol: number[] = new Array(numCounters).fill(-1);\n   470→  const pivotRowForCol: number[] = new Array(numButtons).fill(-1);\n   471→  let rank = 0;\n   472→\n   473→  for (let col = 0; col < numButtons; col++) {\n   474→    // Find a row with non-zero in this column\n   475→    let found = -1;\n   476→    for (let row = rank; row < numCounters; row++) {\n   477→      if (matrix[row][col] !== 0) {\n   478→        found = row;\n   479→        break;\n   480→      }\n   481→    }\n   482→    if (found === -1) continue;\n   483→\n   484→    // Swap rows\n   485→    [matrix[rank], matrix[found]] = [matrix[found], matrix[rank]];\n   486→    pivotCol[rank] = col;\n   487→    pivotRowForCol[col] = rank;\n   488→\n   489→    // Scale pivot row so pivot element = 1\n   490→    const inv = modInverse(matrix[rank][col], modulus);\n   491→    for (let c = 0; c < numButtons + 1; c++) {\n   492→      matrix[rank][c] = (matrix[rank][c] * inv) % modulus;\n   493→    }\n   494→\n   495→    // Eliminate this column from all other rows\n   496→    for (let row = 0; row < numCounters; row++) {\n   497→      if (row !== rank && matrix[row][col] !== 0) {\n   498→        const factor = matrix[row][col];\n   499→        for (let c = 0; c < numButtons + 1; c++) {\n   500→          matrix[row][c] = ((matrix[row][c] - factor * matrix[rank][c]) % modulus + modulus) % modulus;\n   501→        }\n   502→      }\n   503→    }\n   504→    rank++;\n   505→  }\n   506→\n   507→  // Check consistency\n   508→  for (let row = rank; row < numCounters; row++) {\n   509→    if (matrix[row][numButtons] !== 0) {\n   510→      return null;\n   511→    }\n   512→  }\n   513→\n   514→  // Identify free variables\n   515→  const freeVars: number[] = [];\n   516→  for (let col = 0; col < numButtons; col++) {\n   517→    if (pivotRowForCol[col] === -1) {\n   518→      freeVars.push(col);\n   519→    }\n   520→  }\n   521→\n   522→  const numFree = freeVars.length;\n   523→\n   524→  if (numFree === 0) {\n   525→    // Unique solution\n   526→    const result = new Array(numButtons).fill(0);\n   527→    for (let r = 0; r < rank; r++) {\n   528→      result[pivotCol[r]] = matrix[r][numButtons];\n   529→    }\n   530→    return result;\n   531→  }\n   532→\n   533→  // With free variables, we need to find the assignment that minimizes total presses.\n   534→  // Each free variable can take values 0..modulus-1.\n   535→  // Total combinations = modulus^numFree. With modulus up to 97 and numFree potentially large,\n   536→  // brute force is infeasible for large numFree.\n   537→  //\n   538→  // For small numFree (e.g., <= 5 with modulus 97: 97^5 ~ 8.5 billion -- too much),\n   539→  // we need a smarter approach.\n   540→  //\n   541→  // Strategy: meet-in-the-middle when numFree > threshold.\n   542→  // For numFree <= threshold, brute force.\n   543→  //\n   544→  // With modulus p and k free variables:\n   545→  // - Brute force: p^k iterations\n   546→  // - MITM: p^(k/2) * factor for each half, then combine\n   547→  //\n   548→  // But the \"combine\" step for GF(p) is more complex than GF(2).\n   549→  // For each assignment of free vars, the pivot vars are determined:\n   550→  //   pivotVal[r] = rhs[r] - sum(matrix[r][freeVar] * freeVal) mod p\n   551→  // The total presses = sum(freeVals) + sum(pivotVals) where all values are in [0, p-1].\n   552→  //\n   553→  // For MITM: split free vars into two halves.\n   554→  // For half1, compute a \"contribution vector\" to each pivot row.\n   555→  // For half2, same. Combined pivot values = rhs - contrib1 - contrib2 (mod p).\n   556→  // Total presses = sum(free1) + sum(free2) + sum(pivotVals).\n   557→  //\n   558→  // This is hard to optimize with MITM because pivotVals depend on both halves non-linearly\n   559→  // (each pivot val is in [0, p-1] and contributes its value to the sum).\n   560→  //\n   561→  // Alternative for small free var counts: direct enumeration\n   562→  // For modulus 2-3 and numFree up to ~25: feasible\n   563→  // For modulus up to 97 and numFree up to ~3: feasible (97^3 ~ 900K)\n   564→  // For larger: need smarter approach.\n   565→  //\n   566→  // Given the constraint of 40 buttons and 40 counters, rank is at most 40,\n   567→  // so numFree = numButtons - rank. Typically rank will be close to min(numButtons, numCounters).\n   568→  // With both at 40, numFree could be 0. In adversarial cases, numFree could be up to 40.\n   569→  //\n   570→  // For the general case with large numFree and large modulus, we need the MITM approach\n   571→  // with a hash map on the pivot contribution signature.\n   572→\n   573→  // Compute how each free variable affects each pivot row\n   574→  // freeEffect[r][f] = matrix[r][freeVars[f]] (the coefficient)\n   575→  const freeEffect: number[][] = [];\n   576→  for (let r = 0; r < rank; r++) {\n   577→    const effects: number[] = [];\n   578→    for (let f = 0; f < numFree; f++) {\n   579→      effects.push(matrix[r][freeVars[f]]);\n   580→    }\n   581→    freeEffect.push(effects);\n   582→  }\n   583→\n   584→  const rhs: number[] = [];\n   585→  for (let r = 0; r < rank; r++) {\n   586→    rhs.push(matrix[r][numButtons]);\n   587→  }\n   588→\n   589→  // Estimate total combinations\n   590→  const totalCombinations = Math.pow(modulus, numFree);\n   591→\n   592→  if (totalCombinations <= 5_000_000) {\n   593→    // Direct enumeration\n   594→    return solveCounterBruteForce(numButtons, numFree, freeVars, freeEffect, rhs, pivotCol, rank, modulus);\n   595→  } else {\n   596→    // Meet in the middle\n   597→    return solveCounterMITM(numButtons, numFree, freeVars, freeEffect, rhs, pivotCol, rank, modulus);\n   598→  }\n   599→}\n   600→\n   601→function solveCounterBruteForce(\n   602→  numButtons: number, numFree: number, freeVars: number[],\n   603→  freeEffect: number[][], rhs: number[], pivotCol: number[],\n   604→  rank: number, modulus: number\n   605→): number[] {\n   606→  let bestResult: number[] | null = null;\n   607→  let bestSum = Infinity;\n   608→\n   609→  // Enumerate all possible free variable assignments using a counter\n   610→  const freeVals = new Array(numFree).fill(0);\n   611→\n   612→  const enumerate = (): void => {\n   613→    while (true) {\n   614→      // Compute pivot values and total sum\n   615→      let totalSum = 0;\n   616→      const result = new Array(numButtons).fill(0);\n   617→      let valid = true;\n   618→\n   619→      // Set free variables\n   620→      for (let f = 0; f < numFree; f++) {\n   621→        result[freeVars[f]] = freeVals[f];\n   622→        totalSum += freeVals[f];\n   623→      }\n   624→\n   625→      // Early termination: if freeVals sum alone exceeds best, skip\n   626→      // Use <= because we still need to check lex ordering when sums are equal\n   627→      if (totalSum <= bestSum) {\n   628→        // Compute pivot values\n   629→        for (let r = 0; r < rank; r++) {\n   630→          let val = rhs[r];\n   631→          for (let f = 0; f < numFree; f++) {\n   632→            val = (val - freeEffect[r][f] * freeVals[f] % modulus + modulus * 2) % modulus;\n   633→          }\n   634→          result[pivotCol[r]] = val;\n   635→          totalSum += val;\n   636→        }\n   637→\n   638→        if (totalSum < bestSum || (totalSum === bestSum && lexSmallerArr(result, bestResult!))) {\n   639→          bestSum = totalSum;\n   640→          bestResult = [...result];\n   641→        }\n   642→      }\n   643→\n   644→      // Increment counter\n   645→      let carry = true;\n   646→      for (let f = numFree - 1; f >= 0 && carry; f--) {\n   647→        freeVals[f]++;\n   648→        if (freeVals[f] >= modulus) {\n   649→          freeVals[f] = 0;\n   650→        } else {\n   651→          carry = false;\n   652→        }\n   653→      }\n   654→      if (carry) break;\n   655→    }\n   656→  };\n   657→\n   658→  enumerate();\n   659→  return bestResult!;\n   660→}\n   661→\n   662→function solveCounterMITM(\n   663→  numButtons: number, numFree: number, freeVars: number[],\n   664→  freeEffect: number[][], rhs: number[], pivotCol: number[],\n   665→  rank: number, modulus: number\n   666→): number[] {\n   667→  // Split free variables into two halves\n   668→  const half1 = Math.floor(numFree / 2);\n   669→  const half2 = numFree - half1;\n   670→\n   671→  // For each half, compute:\n   672→  // - The contribution to each pivot row (a vector of length rank, each mod p)\n   673→  // - The sum of free variable values\n   674→\n   675→  // For half1, build a map from contribution vector to (best sum, best assignment)\n   676→  // contribution vector: for each pivot row r, sum of freeEffect[r][f] * val[f] for f in half1\n   677→\n   678→  // Use a string key for the contribution vector\n   679→  function contribKey(contrib: number[]): string {\n   680→    return contrib.join(',');\n   681→  }\n   682→\n   683→  // Build half1 table\n   684→  const half1Table = new Map<string, { sum: number; vals: number[] }>();\n   685→  const half1Vals = new Array(half1).fill(0);\n   686→\n   687→  const buildHalf1 = (): void => {\n   688→    while (true) {\n   689→      const contrib = new Array(rank).fill(0);\n   690→      let freeSum = 0;\n   691→\n   692→      for (let f = 0; f < half1; f++) {\n   693→        freeSum += half1Vals[f];\n   694→        for (let r = 0; r < rank; r++) {\n   695→          contrib[r] = (contrib[r] + freeEffect[r][f] * half1Vals[f]) % modulus;\n   696→        }\n   697→      }\n   698→\n   699→      const key = contribKey(contrib);\n   700→      const existing = half1Table.get(key);\n   701→      if (!existing || freeSum < existing.sum ||\n   702→          (freeSum === existing.sum && lexSmallerRaw(half1Vals, existing.vals, half1))) {\n   703→        half1Table.set(key, { sum: freeSum, vals: [...half1Vals] });\n   704→      }\n   705→\n   706→      // Increment\n   707→      let carry = true;\n   708→      for (let f = half1 - 1; f >= 0 && carry; f--) {\n   709→        half1Vals[f]++;\n   710→        if (half1Vals[f] >= modulus) {\n   711→          half1Vals[f] = 0;\n   712→        } else {\n   713→          carry = false;\n   714→        }\n   715→      }\n   716→      if (carry) break;\n   717→    }\n   718→  };\n   719→  buildHalf1();\n   720→\n   721→  // Iterate over half2 assignments\n   722→  let bestResult: number[] | null = null;\n   723→  let bestSum = Infinity;\n   724→  const half2Vals = new Array(half2).fill(0);\n   725→\n   726→  const searchHalf2 = (): void => {\n   727→    while (true) {\n   728→      const contrib2 = new Array(rank).fill(0);\n   729→      let freeSum2 = 0;\n   730→\n   731→      for (let f = 0; f < half2; f++) {\n   732→        freeSum2 += half2Vals[f];\n   733→        for (let r = 0; r < rank; r++) {\n   734→          contrib2[r] = (contrib2[r] + freeEffect[r][half1 + f] * half2Vals[f]) % modulus;\n   735→        }\n   736→      }\n   737→\n   738→      // For each pivot row r, the pivot value would be:\n   739→      // (rhs[r] - contrib1[r] - contrib2[r]) mod p\n   740→      // We need contrib1 such that the total sum is minimized.\n   741→      // Total = freeSum1 + freeSum2 + sum of pivot values\n   742→      // pivot value for row r = (rhs[r] - contrib1[r] - contrib2[r]) mod p\n   743→      // sum of pivot values = sum_r (rhs[r] - contrib1[r] - contrib2[r]) mod p\n   744→\n   745→      // The needed contrib1 vector: for each r, we need (rhs[r] - contrib2[r]) mod p\n   746→      // Then pivot[r] = (needed[r] - contrib1[r]) mod p\n   747→      // Total pivot sum = sum_r ((needed[r] - contrib1[r]) mod p)\n   748→\n   749→      // We can't just pick the contrib1 that makes all pivots 0 (that would minimize pivot sum to 0)\n   750→      // because not all contrib1 vectors may be achievable. We need to iterate over\n   751→      // all contrib1 vectors in our table.\n   752→\n   753→      // Actually, the minimum pivot sum for a given contrib1 is achieved when each\n   754→      // (needed[r] - contrib1[r]) mod p is as small as possible. Since these are determined\n   755→      // by the combo, we just evaluate.\n   756→\n   757→      // However, iterating over ALL half1 table entries for each half2 is too expensive\n   758→      // if both halves are large. The table could have up to modulus^half1 entries.\n   759→      // With half1 = 20 and modulus = 2, that's 1M entries -- feasible.\n   760→      // With modulus = 97 and half1 = 3, that's ~900K -- feasible.\n   761→      // With modulus = 97 and half1 = 20, that's 97^20 -- way too many.\n   762→\n   763→      // For very large cases, we'd need a smarter approach. But given practical constraints\n   764→      // (40 buttons, 40 counters), rank is typically close to 40, leaving few free vars.\n   765→\n   766→      // For now, check if we can find the exact match (all pivot values = 0)\n   767→      const needed = new Array(rank);\n   768→      for (let r = 0; r < rank; r++) {\n   769→        needed[r] = (rhs[r] - contrib2[r] + modulus * 100) % modulus;\n   770→      }\n   771→\n   772→      // Look up exact match first (this gives pivot sum = 0)\n   773→      const exactKey = contribKey(needed);\n   774→      const exact = half1Table.get(exactKey);\n   775→      if (exact) {\n   776→        const totalSum = exact.sum + freeSum2; // pivot sum is 0\n   777→        if (totalSum < bestSum) {\n   778→          bestSum = totalSum;\n   779→          bestResult = buildCounterResult(exact.vals, half2Vals, half1, half2,\n   780→            freeVars, freeEffect, rhs, pivotCol, rank, numButtons, modulus);\n   781→        } else if (totalSum === bestSum) {\n   782→          const candidate = buildCounterResult(exact.vals, half2Vals, half1, half2,\n   783→            freeVars, freeEffect, rhs, pivotCol, rank, numButtons, modulus);\n   784→  